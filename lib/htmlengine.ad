# lib/htmlengine.ad — the PURE HTML parse + block/inline layout engine that
# backs the native web browser.
#
# This module is deliberately I/O-FREE and UI-FREE: it has NO `extern def`
# syscalls, NO hamUI, NO http9. It consumes a source buffer (src_ptr/src_len,
# set by whichever front-end fetched the page) and produces a flat display
# list of styled SEGMENTS plus per-row heading-rule flags. Both front-ends
# share it byte-for-byte:
#
#   * user/hambrowse.ad     — the NATIVE browser: Plan 9-shape http9 fetch +
#                             hamUI scene render (the shipped bare-metal path).
#   * user/hambrowse_host.ad — a HOST test harness built for the x86_64-linux
#                             Adder target: reads a local HTML fixture and
#                             dumps the layout, so the engine can be iterated
#                             on the dev host in milliseconds with NO QEMU.
#
# Keeping the engine pure is the seam that makes hambrowse dual-target while
# the native path stays Plan 9-shape (the host harness is a TEST shim only —
# it never adds sockets to the native code path).
#
# MEMORY DISCIPLINE (memory/feedback_compiler_quirks.md U9): every sizable
# buffer is a top-level BSS Array, NEVER a stack local — the native user
# stack is a single 4 KiB page. No malloc.
#
# JAVASCRIPT: <script> execution + a minimal DOM are wired in at the bottom of
# this file (see the "JAVASCRIPT + minimal DOM" section). The engine imports
# the pure tree-walking interpreter from lib/jsengine.ad and binds a `document`
# host object through jsengine's host-object seam (NO jsengine edits). Scripts
# run at layout time; the DOM they mutate (textContent / style.color /
# style.display / document.title) is applied by re-laying-out a rewritten copy
# of the source. Pages with no <script> never touch jsengine at all.
#
# FORMS: <input>/<textarea>/<button>/<select> render as monospace-grid boxes
# ([text__], [x], (*), [ label ], [ opt v]) and expose a form DOM — value /
# checked / type / name, form.elements, document.forms — through the SAME
# host-object seam. Field changes and submissions are driven programmatically
# (pointer/keyboard-free) via he_dom_set_value / he_dom_set_checked /
# he_dom_submit, which fire oninput/onchange/onsubmit and re-lay-out; a submit
# that is not preventDefault'd GET-serializes the form into he_nav_* for the
# front-end to navigate to. A value/checked change bakes into the rewritten
# source (the input's value=/checked attr, a textarea's content, a select's
# selected option) so the control re-renders its new state.

from lib.jsengine import js_init, js_eval, js_error, js_out_ptr, js_out_len, \
    js_new_object_v, js_new_string, js_new_native_fn, js_set_prop, js_get_prop, \
    js_global_set, js_set_host_dispatch, js_arg_count, js_arg, js_host_base, \
    js_str_ptr, js_undefined, js_null, js_this, js_is_callable, js_call_fn, \
    js_bool, js_to_bool, js_number, js_to_number, js_new_array_v, js_array_push

# ====================================================================
# Tiny helper.
# ====================================================================
def _lower(c: uint8) -> uint8:
    if c >= 65 and c <= 90:
        return c + 32
    return c


# ====================================================================
# WINDOW geometry (mutable — a resize re-lays-out from the stored source).
# These live in the engine because layout wraps to bw and _vis_rows depends
# on bh; the front-ends read/write them directly (shared globals).
# ====================================================================
TITLE_H:   int32 = 18
ADDR_H:    int32 = 20           # editable address/URL bar (below the title)
ADDR_Y:    int32 = 18           # == TITLE_H
GO_W:      int32 = 30           # "Go" button width in the address bar
CONTENT_X: int32 = 8
CONTENT_Y: int32 = 38           # == TITLE_H + ADDR_H (page content starts here)
STATUS_H:  int32 = 16
LINE_H:    int32 = 16
CELL_W:    int32 = 8
bw: int32 = 880                 # window content width  (px; native default)
bh: int32 = 600                 # window content height (px)


# READABLE-MEASURE default (UA stylesheet): a plain page should not let body
# text span an arbitrarily wide window edge-to-edge — long lines are tiring to
# read. We cap the content column at MEASURE_MAX px and CENTRE it, leaving a
# symmetric page gutter on wide windows (exactly like a browser's default body
# max-width). MEASURE_MAX == 584 px == 73 character cells, chosen so that at the
# 600 px unit-test / legacy window the gutter is ZERO and geometry is byte-for-
# byte identical (avail = 600 - 2*8 = 584 == MEASURE_MAX): the cap only engages
# once the window is wider than 600 px, so all existing 600 px assertions hold.
MEASURE_MAX: int32 = 584


# Symmetric page gutter (px) added to CONTENT_X on wide windows so the content
# column is centred at its readable measure. 0 at bw <= 600.
def _page_gutter() -> int32:
    avail: int32 = bw - 2 * CONTENT_X
    if avail <= MEASURE_MAX:
        return 0
    return (avail - MEASURE_MAX) / 2


# Left edge of the body content column (CONTENT_X + centring gutter).
def _left_margin() -> int32:
    return CONTENT_X + _page_gutter()


def _content_right() -> int32:
    return bw - CONTENT_X - _page_gutter()


def _vis_rows() -> uint64:
    r: int32 = (bh - CONTENT_Y - STATUS_H) / LINE_H
    if r < 1:
        r = 1
    return cast[uint64](r)


# ====================================================================
# SOURCE — src_ptr/src_len point at the HTML the front-end wants parsed.
# ====================================================================
src_ptr:  Ptr[uint8] = 0
src_len:  uint64 = 0


# ====================================================================
# LAYOUT MODEL — the parsed page becomes a flat list of styled SEGMENTS.
# A segment is a run of same-styled text on one visual ROW at a pixel X.
# ====================================================================
MAX_SEGS:     uint64 = 6000
SEG_TEXT_CAP: uint64 = 131072
MAX_ROWS:     uint64 = 12000

seg_text_buf: Array[131072, uint8]
seg_text_len: uint64 = 0
seg_x:    Array[6000, int32]
seg_line: Array[6000, int32]
seg_off:  Array[6000, int32]
seg_len:  Array[6000, int32]
seg_color: Array[6000, uint8]    # palette index (role colour)
seg_rgb:  Array[6000, int32]     # explicit 0xRRGGBB, or -1 to use the palette
seg_bg:   Array[6000, int32]     # background 0xRRGGBB behind the text, or -1
seg_bold:  Array[6000, uint8]
seg_uline: Array[6000, uint8]
seg_link:  Array[6000, int32]    # link id or -1
# seg_face — pixel-render font FACE hint for the graphical (htmlpaint) backend.
# The legacy monospace-grid dump ignores it; the pixel engine maps it onto the
# available BDF faces/scales:
#   0 = body proportional sans
#   1 = monospace  (<pre>/<code>)
#   2..7 = heading h1..h6  (integer-scaled + bold sans)
seg_face:  Array[6000, uint8]
# seg_gridx — 1 = this segment is GRID-POSITIONED: the pixel renderer must
# honour its absolute seg_x column (tables, <pre>, box art) instead of the
# proportional inline reflow used for prose. 0 = flow proportionally.
seg_gridx: Array[6000, uint8]
# seg_pxsize — CSS font-size in PIXELS for this segment, or 0 = "use the face
# default". Consumed by the scalable (TrueType) pixel renderer so that
# font-size:14px/18px prose renders at its true continuous size. The legacy
# monospace-grid dump ignores it.
seg_pxsize: Array[6000, int32]
n_segs:   uint64 = 0

row_rule: Array[12000, uint8]    # 0 none, 1 heading rule on this row
total_rows: uint64 = 0
top_line:   uint64 = 0

# LINKS — href targets + the spans that point to them.
MAX_LINKS:    uint64 = 1024
LINK_HREF_CAP: uint64 = 32768
link_off: Array[1024, int32]
link_len: Array[1024, int32]
link_href_buf: Array[32768, uint8]
link_href_len: uint64 = 0
n_links: uint64 = 0

# parse-time "pen" + style state
cur_row:  uint64 = 0
pen_x:    int32 = 8
indent_x: int32 = 8
row_dirty: int32 = 0
need_space: int32 = 0
seg_open:  int32 = 0
seg_curlen: uint64 = 0
g_color: int32 = 0
g_bold:  int32 = 0
g_uline: int32 = 0
g_link:  int32 = -1
g_bold_n: int32 = 0          # nested <b>/<strong> depth
g_mono_n: int32 = 0          # nested inline <code> depth (mono face hint)
g_heading: int32 = 0        # 0 none, else 1..6
list_depth: int32 = 0
bq_depth: int32 = 0         # <blockquote> nesting depth (left indent)
BQ_INDENT: int32 = 24       # px of left indent per blockquote level
pre_mode: int32 = 0

# LIST layout — <ul>/<ol>/<li> with markers, ordered numbering + nesting.
# One entry per open list level (list_depth): list_type is 0 for <ul>
# (bullet marker) or 1 for <ol> (running number), list_count is the <ol>
# item counter (the NEXT item's number). LIST_STEP is the per-level left
# indent (in px); it is exactly wide enough to be the marker gutter so item
# markers hang in the parent level's left margin and wrapped continuation
# lines align under the item TEXT (a proper hanging indent).
MAX_LIST_DEPTH: int32 = 16
LIST_STEP:  int32 = 32       # px of left indent per list level (= 4 cells)
list_type:  Array[16, int32]
list_count: Array[16, int32]

# BLOCK left-indent from CSS margin-left/padding-left (inline style OR a
# stylesheet/class rule). A stack of px deltas parallel to open <p>/<div>
# blocks; blk_indent_sum is the live total folded into indent_x by
# _recompute_indent(). This makes margin/padding actually shift a block's
# content column (not just decorate it).
blk_indent_stack: Array[64, int32]
blk_indent_sp:  int32 = 0
blk_indent_sum: int32 = 0

# BLOCK right edge (px) — the live wrap boundary a block flows against, folded
# in by _flow_right(). margin-right/padding-right shrink it from the parent's
# edge and `width` pins it to indent_x+width; a border steals one more cell.
# Parallel stack to the left indent so nested blocks restore the parent edge.
blk_right_stack: Array[64, int32]
blk_right_sp:   int32 = 0
blk_right_cur:  int32 = 0        # current right edge; reset to _content_right()

# BOX unit mapping (char-grid model): 1em == EM_PX px == 2 character cells wide
# (CELL_W=8) and one text line tall (LINE_H=16); `%` is taken of the body
# content width (bw - 2*CONTENT_X). Vertical margin/padding px are quantised to
# blank text lines at LINE_H granularity.
EM_PX: int32 = 16

# UA default background for <pre>/<code> so code stands out from body text
# (a light neutral panel behind the monospace run).
CODE_BG: int32 = 0xeef0f3

# Per-open-block state carried from _block_box_open() to _block_box_close():
# the bottom vertical gap (blank lines), whether a border is drawn, and the
# border box geometry (left/right pixel columns + the first content row) so the
# closing side/bottom glyphs land in the right place.
box_botg_stack: Array[64, int32]
box_bord_stack: Array[64, int32]
box_lx_stack:   Array[64, int32]
box_rx_stack:   Array[64, int32]
box_srow_stack: Array[64, int32]
box_sp: int32 = 0

# TABLE layout — two-pass column model. Pass 1 (_measure_table) walks the
# table source and records the widest cell (in characters) per column; pass 2
# (_compute_cols) turns those into pixel column x-positions. During the normal
# linear parse each <tr> is one visual row and each <td>/<th> places its text
# at its column's x, clamped to the column's right edge (cell_right) so a wide
# cell wraps inside its column instead of bleeding across the table.
MAX_COLS:    int32 = 32
CELL_PAD:    int32 = 2       # inter-column gap, in character cells
col_x:    Array[33, int32]   # pixel x of each column (index n_cols = right edge)
col_chars: Array[32, int32]  # widest cell per column, in characters
n_cols:      int32 = 0
table_active: int32 = 0
cell_active:  int32 = 0      # inside a <td>/<th> (drives cell_right + styling)
cell_is_th:   int32 = 0      # current cell is a <th> (bold)
cell_right:   int32 = 0      # right edge (px) of the current cell's column
cur_col:      int32 = 0
skip_active: int32 = 0
skip_name: Array[16, uint8]
skip_nlen: uint64 = 0

# CSS colour state — a stack of explicit colours pushed by colour-bearing
# elements (span/font/p/div/h1-h3). g_rgb is the effective colour (topmost
# non-sentinel entry), or -1 when no explicit colour applies.
COLOR_STACK_CAP: int32 = 64
color_stack: Array[64, int32]
color_sp: int32 = 0
g_rgb: int32 = -1

# CSS background-colour state — a parallel stack to the text-colour stack.
# Pushed by bgcolor / background-color-bearing elements (body-less: p/div/
# span/font/h*/blockquote/table/tr/td/th). g_bg is the effective (topmost
# non-sentinel) background, or -1 when none applies.
bg_stack: Array[64, int32]
bg_sp: int32 = 0
g_bg: int32 = -1

# inline word accumulator
WORD_CAP: uint64 = 2048
word_buf: Array[2048, uint8]
word_len: uint64 = 0
# Decoded-entity output: up to 4 UTF-8 bytes for one code point.
g_ent_buf: Array[4, uint8]
g_ent_len: int32 = 0


def _palette(idx: uint8) -> Ptr[uint8]:
    if idx == 1:
        return cast[Ptr[uint8]]("#1a4fd0")          # link blue
    if idx == 2:
        return cast[Ptr[uint8]]("#14306e")          # heading dark blue
    if idx == 3:
        return cast[Ptr[uint8]]("#0a6b5a")          # pre/code teal
    return cast[Ptr[uint8]]("#101010")              # body text


# Palette index -> packed 0xRRGGBB (mirrors _palette; used to resolve a
# segment to a concrete colour for rendering / dumping).
def _palette_rgb(idx: uint8) -> int32:
    if idx == 1:
        return 0x1a4fd0
    if idx == 2:
        return 0x14306e
    if idx == 3:
        return 0x0a6b5a
    return 0x101010


# ---- CSS colour stack ----------------------------------------------
def _color_effective() -> int32:
    i: int32 = color_sp - 1
    while i >= 0:
        if color_stack[i] >= 0:
            return color_stack[i]
        i = i - 1
    return -1


def _color_push(rgb: int32):
    if color_sp < COLOR_STACK_CAP:
        color_stack[color_sp] = rgb
        color_sp = color_sp + 1
    g_rgb = _color_effective()


def _color_pop():
    if color_sp > 0:
        color_sp = color_sp - 1
    g_rgb = _color_effective()


# ---- CSS background-colour stack (mirrors the text-colour stack) -----
def _bg_effective() -> int32:
    i: int32 = bg_sp - 1
    while i >= 0:
        if bg_stack[i] >= 0:
            return bg_stack[i]
        i = i - 1
    return -1


def _bg_push(rgb: int32):
    if bg_sp < COLOR_STACK_CAP:
        bg_stack[bg_sp] = rgb
        bg_sp = bg_sp + 1
    g_bg = _bg_effective()


def _bg_pop():
    if bg_sp > 0:
        bg_sp = bg_sp - 1
    g_bg = _bg_effective()


def _base_color() -> int32:
    if g_heading != 0:
        return 2
    if pre_mode != 0:
        return 3
    return 0


def _recompute_style():
    if g_link >= 0:
        g_color = 1
        g_uline = 1
    else:
        g_color = _base_color()
        g_uline = 0
    if g_bold_n > 0 or g_heading != 0 or g_css_bold != 0:
        g_bold = 1
    else:
        g_bold = 0


# ---- segment building -----------------------------------------------
# Pixel-render FACE hint for the segment currently being opened. Heading wins
# (headings are never <pre>/<code>); then monospace; else body sans.
def _cur_face() -> uint8:
    if g_heading != 0:
        h: int32 = g_heading
        if h > 6:
            h = 6
        return cast[uint8](1 + h)                     # 2..7 = h1..h6
    if pre_mode != 0 or g_mono_n > 0:
        return 1                                       # monospace
    return 0                                           # body sans


def _seg_ensure():
    if seg_open != 0:
        return
    if n_segs >= MAX_SEGS:
        return
    seg_open = 1
    seg_x[n_segs]    = pen_x
    seg_line[n_segs] = cast[int32](cur_row)
    seg_off[n_segs]  = cast[int32](seg_text_len)
    seg_color[n_segs] = cast[uint8](g_color)
    # An explicit CSS colour overrides the role palette, EXCEPT on links,
    # which keep their blue role colour.
    if g_link < 0:
        seg_rgb[n_segs] = g_rgb
    else:
        seg_rgb[n_segs] = -1
    seg_bg[n_segs]    = g_bg
    seg_bold[n_segs]  = cast[uint8](g_bold)
    seg_uline[n_segs] = cast[uint8](g_uline)
    seg_link[n_segs]  = g_link
    seg_face[n_segs]  = _cur_face()
    seg_pxsize[n_segs] = g_font_px
    # Table cells + <pre> are laid out on absolute grid columns; the pixel
    # renderer honours seg_x for them so columns/alignment survive.
    if table_active != 0 or pre_mode != 0:
        seg_gridx[n_segs] = 1
    else:
        seg_gridx[n_segs] = 0
    seg_curlen = 0
    # Record the row's text-alignment (a post-layout pass shifts seg_x).
    # Table/pre rows keep their computed geometry (no re-alignment).
    if g_align != 0 and table_active == 0 and pre_mode == 0 and \
       cur_row < MAX_ROWS:
        row_align[cur_row] = cast[uint8](g_align)


def _seg_putc(c: uint8):
    _seg_ensure()
    if seg_open == 0:
        return
    if seg_text_len < SEG_TEXT_CAP - 1:
        seg_text_buf[seg_text_len] = c
        seg_text_len = seg_text_len + 1
        seg_curlen = seg_curlen + 1
    row_dirty = 1


# Emit a non-negative decimal integer into the current segment (marker use).
def _seg_putc_dec(v: int32):
    if v < 0:
        v = 0
    if v >= 10:
        _seg_putc_dec(v / 10)
    _seg_putc(cast[uint8](48 + (v - (v / 10) * 10)))


def _close_seg():
    if seg_open == 0:
        return
    if seg_curlen > 0 and n_segs < MAX_SEGS:
        seg_len[n_segs] = cast[int32](seg_curlen)
        n_segs = n_segs + 1
    seg_open = 0
    seg_curlen = 0


# A style change closes the current segment so the next text opens a fresh
# one carrying the new attributes.
def _style_break():
    _close_seg()
    _recompute_style()


# ---- line breaks ----------------------------------------------------
def _bump_row():
    cur_row = cur_row + 1
    if cur_row >= MAX_ROWS:
        cur_row = MAX_ROWS - 1


def _soft_newline():
    # Move to a fresh line ONLY if the current one has content.
    _close_seg()
    if row_dirty != 0:
        _bump_row()
    pen_x = indent_x
    row_dirty = 0
    need_space = 0


def _newline():
    # Unconditional line break (<br>, pre newline).
    _close_seg()
    _bump_row()
    pen_x = indent_x
    row_dirty = 0
    need_space = 0


def _para_break():
    # End the current line + leave a single blank gap.
    _soft_newline()
    _bump_row()
    pen_x = indent_x
    need_space = 0


# Left indent = list nesting + blockquote nesting. Both front-ends flow to
# indent_x, so this is the single left-margin knob for block structure.
def _recompute_indent():
    indent_x = _left_margin() + list_depth * LIST_STEP + bq_depth * BQ_INDENT + \
               blk_indent_sum


# Push/pop a block's CSS left indent (margin-left+padding-left). Always paired
# per <p>/<div> open/close (a 0-px block still pushes, to stay balanced), and
# both refresh indent_x + the pen so content flows at the new left column.
def _blk_indent_push(px: int32):
    if blk_indent_sp < 64:
        blk_indent_stack[blk_indent_sp] = px
        blk_indent_sp = blk_indent_sp + 1
        blk_indent_sum = blk_indent_sum + px
    _recompute_indent()
    pen_x = indent_x


def _blk_indent_pop():
    if blk_indent_sp > 0:
        blk_indent_sp = blk_indent_sp - 1
        blk_indent_sum = blk_indent_sum - blk_indent_stack[blk_indent_sp]
    _recompute_indent()
    pen_x = indent_x


# ---- CSS border box (char-grid glyphs) ------------------------------
# Emit `ncells` copies of glyph `ch` as one standalone segment at (row, x).
# Used for the horizontal top/bottom border rules; writes the seg arrays
# directly (bypassing the pen) so it can target an arbitrary row.
def _emit_box_run(row: int32, x: int32, ch: uint8, ncells: int32):
    if ncells <= 0 or n_segs >= MAX_SEGS:
        return
    seg_x[n_segs]     = x
    seg_line[n_segs]  = row
    seg_off[n_segs]   = cast[int32](seg_text_len)
    seg_color[n_segs] = 0
    seg_rgb[n_segs]   = -1
    seg_bg[n_segs]    = -1
    seg_bold[n_segs]  = 0
    seg_uline[n_segs] = 0
    seg_link[n_segs]  = -1
    seg_face[n_segs]  = 1                              # box art = monospace
    seg_gridx[n_segs] = 1
    k: int32 = 0
    while k < ncells and seg_text_len < SEG_TEXT_CAP - 1:
        c: uint8 = ch
        if k == 0 or k == ncells - 1:
            c = 43                                    # '+' corners/ends
        seg_text_buf[seg_text_len] = c
        seg_text_len = seg_text_len + 1
        k = k + 1
    seg_len[n_segs] = k
    n_segs = n_segs + 1


# Emit a single vertical bar '|' glyph at (row, x).
def _emit_box_bar(row: int32, x: int32):
    if n_segs >= MAX_SEGS or seg_text_len >= SEG_TEXT_CAP - 1:
        return
    seg_x[n_segs]     = x
    seg_line[n_segs]  = row
    seg_off[n_segs]   = cast[int32](seg_text_len)
    seg_color[n_segs] = 0
    seg_rgb[n_segs]   = -1
    seg_bg[n_segs]    = -1
    seg_bold[n_segs]  = 0
    seg_uline[n_segs] = 0
    seg_link[n_segs]  = -1
    seg_face[n_segs]  = 1                              # box art = monospace
    seg_gridx[n_segs] = 1
    seg_text_buf[seg_text_len] = 124                  # '|'
    seg_text_len = seg_text_len + 1
    seg_len[n_segs] = 1
    n_segs = n_segs + 1


# Advance `n` blank visual rows (top/bottom vertical margin+padding gap).
def _blank_rows(n: int32):
    k: int32 = 0
    while k < n:
        _bump_row()
        k = k + 1


# Open a block box for a <p>/<div>. `left`/`rins` are the left/right insets
# (margin+padding, px); `wd` the content width (px, -1 none); `topg`/`botg` the
# top/bottom gaps (px); `bord` 1 to draw a border. Pushes the left-indent and
# right-edge stacks + records close-side state on box_*_stack.
def _block_box_open(left: int32, rins: int32, wd: int32, topg: int32, \
                    botg: int32, bord: int32):
    # top gap: quantise px -> blank lines.
    if topg > 0:
        _blank_rows((topg + LINE_H / 2) / LINE_H)
    # left inset (+ a cell for the border) shifts the content column.
    li: int32 = left
    if bord != 0:
        li = li + CELL_W
    _blk_indent_push(li)
    # right edge: shrink from the parent by the right inset (+ border cell), or
    # pin to indent_x + width when a width is set. Clamp to a sane range.
    parent_right: int32 = blk_right_cur
    if parent_right <= 0:
        parent_right = _content_right()
    new_right: int32 = parent_right - rins
    if bord != 0:
        new_right = new_right - CELL_W
    if wd >= 0:
        wr: int32 = indent_x + wd
        if wr < new_right:
            new_right = wr
    if new_right < indent_x + CELL_W:
        new_right = indent_x + CELL_W
    if new_right > _content_right():
        new_right = _content_right()
    if blk_right_sp < 64:
        blk_right_stack[blk_right_sp] = parent_right
        blk_right_sp = blk_right_sp + 1
    blk_right_cur = new_right
    # border: draw the top rule now, on a fresh row, then start content below.
    lx: int32 = indent_x - CELL_W                     # left bar column
    rx: int32 = new_right                             # right bar column
    if bord != 0:
        _soft_newline()
        row_dirty = 0
        span: int32 = (rx - lx) / CELL_W + 1
        _emit_box_run(cast[int32](cur_row), lx, 45, span)   # '-' top
        _bump_row()
        pen_x = indent_x
        row_dirty = 0
    # push close-side state.
    if box_sp < 64:
        box_botg_stack[box_sp] = botg
        box_bord_stack[box_sp] = bord
        box_lx_stack[box_sp]   = lx
        box_rx_stack[box_sp]   = rx
        box_srow_stack[box_sp] = cast[int32](cur_row)
        box_sp = box_sp + 1


# Close the block box opened by _block_box_open (pops both stacks; draws the
# bottom border rule + left/right bars over the content rows when bordered;
# emits the bottom gap as blank lines).
def _block_box_close():
    botg: int32 = 0
    bord: int32 = 0
    lx: int32 = 0
    rx: int32 = 0
    srow: int32 = 0
    if box_sp > 0:
        box_sp = box_sp - 1
        botg = box_botg_stack[box_sp]
        bord = box_bord_stack[box_sp]
        lx   = box_lx_stack[box_sp]
        rx   = box_rx_stack[box_sp]
        srow = box_srow_stack[box_sp]
    if bord != 0:
        _soft_newline()
        brow: int32 = cast[int32](cur_row)
        # side bars over every content row [srow, brow).
        r: int32 = srow
        while r < brow:
            _emit_box_bar(r, lx)
            _emit_box_bar(r, rx)
            r = r + 1
        span: int32 = (rx - lx) / CELL_W + 1
        _emit_box_run(brow, lx, 45, span)             # '-' bottom
        _bump_row()
        row_dirty = 0
    # restore the parent right edge + pop the left indent.
    if blk_right_sp > 0:
        blk_right_sp = blk_right_sp - 1
        blk_right_cur = blk_right_stack[blk_right_sp]
    _blk_indent_pop()
    if botg > 0:
        _blank_rows((botg + LINE_H / 2) / LINE_H)
    pen_x = indent_x


# The right edge the current flow wraps against: a table cell clamps to its
# column, everything else to the content area.
def _flow_right() -> int32:
    r: int32 = _content_right()
    # A block width / right margin / padding shrinks the wrap boundary.
    if blk_right_cur > 0 and blk_right_cur < r:
        r = blk_right_cur
    if cell_active != 0:
        cr: int32 = cell_right
        if cr > r:
            cr = r
        if cr < indent_x + CELL_W:
            cr = indent_x + CELL_W
        return cr
    return r


# ---- word placement (block+inline flow with word wrap) --------------
def _emit_word(wptr: Ptr[uint8], wlen: uint64):
    if wlen == 0:
        return
    cw: int32 = CELL_W
    right: int32 = _flow_right()
    wpx: int32 = cast[int32](wlen) * cw
    avail: int32 = right - indent_x
    # Decide a word-wrap (only when the word fits on a fresh line).
    if pen_x > indent_x:
        extra: int32 = wpx
        if need_space != 0:
            extra = extra + cw
        if pen_x + extra > right and wpx <= avail:
            _close_seg()
            _bump_row()
            pen_x = indent_x
            need_space = 0
            row_dirty = 0
    # Inter-word space.
    if need_space != 0 and pen_x > indent_x:
        _seg_putc(32)
        pen_x = pen_x + cw
        need_space = 0
    # A word longer than a whole line: hard char-break it.
    if wpx > avail:
        k: uint64 = 0
        while k < wlen:
            if pen_x + cw > right and pen_x > indent_x:
                _close_seg()
                _bump_row()
                pen_x = indent_x
                row_dirty = 0
            _seg_putc(wptr[k])
            pen_x = pen_x + cw
            k = k + 1
        need_space = 0
        return
    # Normal: whole word into the current segment.
    k2: uint64 = 0
    while k2 < wlen:
        _seg_putc(wptr[k2])
        pen_x = pen_x + cw
        k2 = k2 + 1
    need_space = 0


def _word_push(c: uint8):
    if word_len < WORD_CAP - 1:
        word_buf[word_len] = c
        word_len = word_len + 1


def _word_flush():
    if word_len > 0:
        _emit_word(&word_buf[0], word_len)
        word_len = 0


# ====================================================================
# ENTITY DECODE — &name; / &#NN; / &#xHH;.  Returns bytes consumed from
# src starting at `&` (0 if not a recognised entity), and sets g_ent_char.
# ====================================================================
def _ent_named_is(start: uint64, lit: Ptr[uint8]) -> int32:
    # `lit` already includes the trailing ';' — a full match consumes it.
    i: uint64 = 0
    while lit[i] != 0:
        if start + i >= src_len:
            return 0
        if src_ptr[start + i] != lit[i]:
            return 0
        i = i + 1
    return cast[int32](i)


# Encode one Unicode code point into g_ent_buf as UTF-8; sets g_ent_len.
# (The renderer already emits UTF-8 text, so decoded entities go out as UTF-8.)
def _ent_emit_cp(cp: uint32):
    if cp == 0:
        cp = 63                                       # NUL -> '?'
    if cp < 0x80:
        g_ent_buf[0] = cast[uint8](cp)
        g_ent_len = 1
    elif cp < 0x800:
        g_ent_buf[0] = cast[uint8](0xC0 | (cp >> 6))
        g_ent_buf[1] = cast[uint8](0x80 | (cp & 0x3F))
        g_ent_len = 2
    elif cp < 0x10000:
        g_ent_buf[0] = cast[uint8](0xE0 | (cp >> 12))
        g_ent_buf[1] = cast[uint8](0x80 | ((cp >> 6) & 0x3F))
        g_ent_buf[2] = cast[uint8](0x80 | (cp & 0x3F))
        g_ent_len = 3
    else:
        g_ent_buf[0] = cast[uint8](0xF0 | (cp >> 18))
        g_ent_buf[1] = cast[uint8](0x80 | ((cp >> 12) & 0x3F))
        g_ent_buf[2] = cast[uint8](0x80 | ((cp >> 6) & 0x3F))
        g_ent_buf[3] = cast[uint8](0x80 | (cp & 0x3F))
        g_ent_len = 4


# If src at `body` matches the named-entity literal `lit` (trailing ';'
# included), emit code point `cp` and return the bytes consumed AFTER the '&'
# (i.e. len(lit)); otherwise return 0.
def _ent_try(body: uint64, lit: Ptr[uint8], cp: uint32) -> uint64:
    n: int32 = _ent_named_is(body, lit)
    if n > 0:
        _ent_emit_cp(cp)
        return cast[uint64](n)
    return 0


def _entity(at: uint64) -> uint64:
    # `at` points at '&'. On success fills g_ent_buf/g_ent_len with the decoded
    # UTF-8 bytes and returns the number of source bytes consumed (including the
    # '&' and any trailing ';'). Returns 0 for a bare/unknown '&' — the caller
    # then passes the '&' through unchanged.
    body: uint64 = at + 1
    if body >= src_len:
        return 0
    if src_ptr[body] == 35:                          # '#': numeric
        p: uint64 = body + 1
        base: uint32 = 10
        if p < src_len and (src_ptr[p] == 120 or src_ptr[p] == 88):   # x/X
            base = 16
            p = p + 1
        val: uint32 = 0
        digits: int32 = 0
        while p < src_len and digits < 8:
            c: uint8 = src_ptr[p]
            d: int32 = -1
            if c >= 48 and c <= 57:
                d = cast[int32](c - 48)
            elif base == 16 and c >= 97 and c <= 102:
                d = cast[int32](c - 97) + 10
            elif base == 16 and c >= 65 and c <= 70:
                d = cast[int32](c - 65) + 10
            else:
                break
            val = val * base + cast[uint32](d)
            digits = digits + 1
            p = p + 1
        if digits == 0:
            return 0
        if p < src_len and src_ptr[p] == 59:
            p = p + 1
        _ent_emit_cp(val)
        return p - at
    # Named entities. Each literal carries its trailing ';', so a match consumes
    # it; unknown names fall through and the '&' is emitted literally.
    r: uint64 = 0
    r = _ent_try(body, cast[Ptr[uint8]]("amp;"), 38)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("lt;"), 60)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("gt;"), 62)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("quot;"), 34)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("apos;"), 39)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("nbsp;"), 32)   # -> normal space
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("copy;"), 0xA9)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("reg;"), 0xAE)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("trade;"), 0x2122)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("mdash;"), 0x2014)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ndash;"), 0x2013)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("hellip;"), 0x2026)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("lsquo;"), 0x2018)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("rsquo;"), 0x2019)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ldquo;"), 0x201C)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("rdquo;"), 0x201D)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("middot;"), 0xB7)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("deg;"), 0xB0)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("times;"), 0xD7)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("divide;"), 0xF7)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("bull;"), 0x2022)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("dagger;"), 0x2020)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("laquo;"), 0xAB)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("raquo;"), 0xBB)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("euro;"), 0x20AC)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("pound;"), 0xA3)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("cent;"), 0xA2)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("yen;"), 0xA5)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("sect;"), 0xA7)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("para;"), 0xB6)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("plusmn;"), 0xB1)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("micro;"), 0xB5)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("frac12;"), 0xBD)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("frac14;"), 0xBC)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("frac34;"), 0xBE)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("sup2;"), 0xB2)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("sup3;"), 0xB3)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("szlig;"), 0xDF)
    if r == 0:
        return 0
    return 1 + r                                      # +1 for the leading '&'


# ====================================================================
# COLOUR PARSING — extract a text colour from a tag body src[ts..te).
# Handles  style="…color:VALUE…"  and  color="VALUE" / color=VALUE
# (the <font> attribute). VALUE is #rgb, #rrggbb, or a named colour.
# Returns packed 0xRRGGBB, or -1 if none / unparseable.
# ====================================================================
def _hexval(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return cast[int32](c - 48)
    lc: uint8 = _lower(c)
    if lc >= 97 and lc <= 102:
        return cast[int32](lc - 97) + 10
    return -1


# Compare src[at..] against a lowercase literal; returns 1 on full match.
def _srcword_is(at: uint64, lit: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while lit[i] != 0:
        if at + i >= src_len:
            return 0
        if _lower(src_ptr[at + i]) != lit[i]:
            return 0
        i = i + 1
    return 1


# Named colours (the CSS/HTML basics). Returns 0xRRGGBB or -1.
def _named_color(at: uint64) -> int32:
    if _srcword_is(at, cast[Ptr[uint8]]("black")) != 0:
        return 0x000000
    if _srcword_is(at, cast[Ptr[uint8]]("white")) != 0:
        return 0xffffff
    if _srcword_is(at, cast[Ptr[uint8]]("red")) != 0:
        return 0xff0000
    if _srcword_is(at, cast[Ptr[uint8]]("green")) != 0:
        return 0x008000
    if _srcword_is(at, cast[Ptr[uint8]]("lime")) != 0:
        return 0x00ff00
    if _srcword_is(at, cast[Ptr[uint8]]("blue")) != 0:
        return 0x0000ff
    if _srcword_is(at, cast[Ptr[uint8]]("navy")) != 0:
        return 0x000080
    if _srcword_is(at, cast[Ptr[uint8]]("teal")) != 0:
        return 0x008080
    if _srcword_is(at, cast[Ptr[uint8]]("aqua")) != 0:
        return 0x00ffff
    if _srcword_is(at, cast[Ptr[uint8]]("olive")) != 0:
        return 0x808000
    if _srcword_is(at, cast[Ptr[uint8]]("yellow")) != 0:
        return 0xffff00
    if _srcword_is(at, cast[Ptr[uint8]]("orange")) != 0:
        return 0xffa500
    if _srcword_is(at, cast[Ptr[uint8]]("purple")) != 0:
        return 0x800080
    if _srcword_is(at, cast[Ptr[uint8]]("fuchsia")) != 0:
        return 0xff00ff
    if _srcword_is(at, cast[Ptr[uint8]]("maroon")) != 0:
        return 0x800000
    if _srcword_is(at, cast[Ptr[uint8]]("silver")) != 0:
        return 0xc0c0c0
    if _srcword_is(at, cast[Ptr[uint8]]("gray")) != 0:
        return 0x808080
    if _srcword_is(at, cast[Ptr[uint8]]("grey")) != 0:
        return 0x808080
    # Extended CSS named colours common on hand-written pages.
    if _srcword_is(at, cast[Ptr[uint8]]("magenta")) != 0:
        return 0xff00ff
    if _srcword_is(at, cast[Ptr[uint8]]("cyan")) != 0:
        return 0x00ffff
    if _srcword_is(at, cast[Ptr[uint8]]("pink")) != 0:
        return 0xffc0cb
    if _srcword_is(at, cast[Ptr[uint8]]("brown")) != 0:
        return 0xa52a2a
    if _srcword_is(at, cast[Ptr[uint8]]("gold")) != 0:
        return 0xffd700
    if _srcword_is(at, cast[Ptr[uint8]]("indigo")) != 0:
        return 0x4b0082
    if _srcword_is(at, cast[Ptr[uint8]]("violet")) != 0:
        return 0xee82ee
    if _srcword_is(at, cast[Ptr[uint8]]("crimson")) != 0:
        return 0xdc143c
    if _srcword_is(at, cast[Ptr[uint8]]("coral")) != 0:
        return 0xff7f50
    if _srcword_is(at, cast[Ptr[uint8]]("salmon")) != 0:
        return 0xfa8072
    if _srcword_is(at, cast[Ptr[uint8]]("tomato")) != 0:
        return 0xff6347
    if _srcword_is(at, cast[Ptr[uint8]]("khaki")) != 0:
        return 0xf0e68c
    if _srcword_is(at, cast[Ptr[uint8]]("tan")) != 0:
        return 0xd2b48c
    if _srcword_is(at, cast[Ptr[uint8]]("turquoise")) != 0:
        return 0x40e0d0
    if _srcword_is(at, cast[Ptr[uint8]]("skyblue")) != 0:
        return 0x87ceeb
    if _srcword_is(at, cast[Ptr[uint8]]("darkblue")) != 0:
        return 0x00008b
    if _srcword_is(at, cast[Ptr[uint8]]("darkgreen")) != 0:
        return 0x006400
    if _srcword_is(at, cast[Ptr[uint8]]("darkred")) != 0:
        return 0x8b0000
    if _srcword_is(at, cast[Ptr[uint8]]("lightblue")) != 0:
        return 0xadd8e6
    if _srcword_is(at, cast[Ptr[uint8]]("lightgreen")) != 0:
        return 0x90ee90
    if _srcword_is(at, cast[Ptr[uint8]]("lightgray")) != 0:
        return 0xd3d3d3
    if _srcword_is(at, cast[Ptr[uint8]]("lightgrey")) != 0:
        return 0xd3d3d3
    if _srcword_is(at, cast[Ptr[uint8]]("darkgray")) != 0:
        return 0xa9a9a9
    if _srcword_is(at, cast[Ptr[uint8]]("darkgrey")) != 0:
        return 0xa9a9a9
    if _srcword_is(at, cast[Ptr[uint8]]("beige")) != 0:
        return 0xf5f5dc
    if _srcword_is(at, cast[Ptr[uint8]]("ivory")) != 0:
        return 0xfffff0
    if _srcword_is(at, cast[Ptr[uint8]]("lavender")) != 0:
        return 0xe6e6fa
    return -1


# Parse an `rgb(r,g,b)` / `rgb(r, g, b)` functional colour at src[at].
# Returns packed 0xRRGGBB, or -1 if not an rgb() form.
def _rgb_func(at: uint64) -> int32:
    if _srcword_is(at, cast[Ptr[uint8]]("rgb")) == 0:
        return -1
    j: uint64 = at + 3
    while j < src_len and (src_ptr[j] == 32 or src_ptr[j] == 9):
        j = j + 1
    if j >= src_len or src_ptr[j] != 40:             # '('
        return -1
    j = j + 1
    comp: int32 = 0
    parts: Array[3, int32]
    while comp < 3:
        while j < src_len and (src_ptr[j] == 32 or src_ptr[j] == 9):
            j = j + 1
        v: int32 = 0
        nd: int32 = 0
        while j < src_len and src_ptr[j] >= 48 and src_ptr[j] <= 57:
            v = v * 10 + cast[int32](src_ptr[j] - 48)
            nd = nd + 1
            j = j + 1
        if nd == 0:
            return -1
        # A percentage component scales 0..100 -> 0..255.
        if j < src_len and src_ptr[j] == 37:         # '%'
            v = v * 255 / 100
            j = j + 1
        if v > 255:
            v = 255
        parts[comp] = v
        comp = comp + 1
        while j < src_len and (src_ptr[j] == 32 or src_ptr[j] == 9):
            j = j + 1
        if comp < 3:
            if j < src_len and src_ptr[j] == 44:     # ','
                j = j + 1
    return (parts[0] * 65536) + (parts[1] * 256) + parts[2]


# Parse a colour VALUE starting at src[at]. Returns 0xRRGGBB or -1.
def _color_value(at: uint64) -> int32:
    if at >= src_len:
        return -1
    if src_ptr[at] == 114 or src_ptr[at] == 82:      # 'r'/'R' -> maybe rgb(
        rv: int32 = _rgb_func(at)
        if rv >= 0:
            return rv
    if src_ptr[at] == 35:                            # '#rgb' or '#rrggbb'
        # count hex digits
        p: uint64 = at + 1
        nd: int32 = 0
        while p < src_len and _hexval(src_ptr[p]) >= 0:
            nd = nd + 1
            p = p + 1
        if nd >= 6:
            r: int32 = _hexval(src_ptr[at + 1]) * 16 + _hexval(src_ptr[at + 2])
            g: int32 = _hexval(src_ptr[at + 3]) * 16 + _hexval(src_ptr[at + 4])
            b: int32 = _hexval(src_ptr[at + 5]) * 16 + _hexval(src_ptr[at + 6])
            return (r * 65536) + (g * 256) + b
        if nd >= 3:
            r3: int32 = _hexval(src_ptr[at + 1])
            g3: int32 = _hexval(src_ptr[at + 2])
            b3: int32 = _hexval(src_ptr[at + 3])
            return ((r3 * 16 + r3) * 65536) + ((g3 * 16 + g3) * 256) + \
                   (b3 * 16 + b3)
        return -1
    return _named_color(at)


# Find a text-colour value in the tag body [ts,te). Looks for a `color`
# keyword at a word boundary (so `bgcolor` is NOT matched) followed by ':'
# (style syntax) or '=' (attribute syntax), then parses the value.
def _tag_color(ts: uint64, te: uint64) -> int32:
    i: uint64 = ts
    while i + 5 <= te:
        # word boundary: previous char must not be a letter (rejects bgcolor)
        prev_alpha: int32 = 0
        if i > ts:
            pc: uint8 = _lower(src_ptr[i - 1])
            if (pc >= 97 and pc <= 122) or pc == 45:   # letter or '-'
                prev_alpha = 1
        if prev_alpha == 0 and _srcword_is(i, cast[Ptr[uint8]]("color")) != 0:
            j: uint64 = i + 5
            while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
                j = j + 1
            if j < te and (src_ptr[j] == 58 or src_ptr[j] == 61):   # ':' '='
                j = j + 1
                while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9 or \
                                  src_ptr[j] == 34 or src_ptr[j] == 39):
                    j = j + 1
                cv: int32 = _color_value(j)
                if cv >= 0:
                    return cv
        i = i + 1
    return -1


# Skip whitespace + a ':'/'=' separator + opening quote, then parse a colour
# value starting at src[j]. Returns 0xRRGGBB or -1.
def _prop_value_at(j: uint64, te: uint64) -> int32:
    while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
        j = j + 1
    if j < te and (src_ptr[j] == 58 or src_ptr[j] == 61):        # ':' '='
        j = j + 1
    else:
        return -1
    while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9 or \
                      src_ptr[j] == 34 or src_ptr[j] == 39):
        j = j + 1
    return _color_value(j)


# Find a BACKGROUND colour in the tag body [ts,te): the `bgcolor` attribute
# or a `background-color:` style declaration. A word boundary before the
# keyword keeps `color`/other props from matching. Returns 0xRRGGBB or -1.
def _tag_bgcolor(ts: uint64, te: uint64) -> int32:
    i: uint64 = ts
    while i < te:
        prev_alpha: int32 = 0
        if i > ts:
            pc: uint8 = _lower(src_ptr[i - 1])
            if (pc >= 97 and pc <= 122) or pc == 45:             # letter / '-'
                prev_alpha = 1
        if prev_alpha == 0:
            if _srcword_is(i, cast[Ptr[uint8]]("background-color")) != 0:
                v: int32 = _prop_value_at(i + 16, te)
                if v >= 0:
                    return v
            if _srcword_is(i, cast[Ptr[uint8]]("bgcolor")) != 0:
                v2: int32 = _prop_value_at(i + 7, te)
                if v2 >= 0:
                    return v2
        i = i + 1
    return -1


# ====================================================================
# CSS CASCADE — <style> blocks + inline style="" for the properties that
# map onto this monospace-grid engine: color, background-color, font-weight
# (bold), text-align (center/right, baked into seg_x post-layout), and
# display:none (content skipped). A stylesheet is parsed once per page into a
# flat rule table; selectors support element / .class / #id and a single
# descendant combinator (`A B`), ordered by simple specificity
# (id=100, class=10, element=1; inline style wins over all).
# ====================================================================
MAX_RULES:   int32  = 256
CSS_STR_CAP: uint64 = 8192
css_sbuf: Array[8192, uint8]
css_slen: uint64 = 0

# target (rightmost) compound of each rule
r_tag_off: Array[256, int32]
r_tag_len: Array[256, int32]
r_cls_off: Array[256, int32]
r_cls_len: Array[256, int32]
r_id_off:  Array[256, int32]
r_id_len:  Array[256, int32]
# ancestor compound (present only for a descendant selector)
r_has_anc:  Array[256, int32]
r_atag_off: Array[256, int32]
r_atag_len: Array[256, int32]
r_acls_off: Array[256, int32]
r_acls_len: Array[256, int32]
r_aid_off:  Array[256, int32]
r_aid_len:  Array[256, int32]
# resolved declarations
r_color:  Array[256, int32]
r_bg:     Array[256, int32]
r_weight: Array[256, int32]     # 0 none, 1 bold, 2 normal
r_align:  Array[256, int32]     # 0 none, 1 left, 2 center, 3 right
r_disp:   Array[256, int32]     # 1 = display:none
# box model (px; -1 = the rule does not set this axis). ml/mr fold margin+
# padding on that side into one left/right inset; mt/mb are the top/bottom
# gaps; wd is the content width; bd is 0 (border:none) / 1 (border on) / -1.
r_ml:     Array[256, int32]
r_mr:     Array[256, int32]
r_mt:     Array[256, int32]
r_mb:     Array[256, int32]
r_wd:     Array[256, int32]
r_bd:     Array[256, int32]
r_fontpx: Array[256, int32]     # CSS font-size in px (-1 = rule sets no size)
r_spec:   Array[256, int32]
n_rules:  int32 = 0

# element stack (open elements) for descendant matching
MAX_EL:     int32  = 64
EL_STR_CAP: uint64 = 4096
el_sbuf: Array[4096, uint8]
el_slen: uint64 = 0
el_tag_off: Array[64, int32]
el_tag_len: Array[64, int32]
el_cls_off: Array[64, int32]
el_cls_len: Array[64, int32]
el_id_off:  Array[64, int32]
el_id_len:  Array[64, int32]
el_sp: int32 = 0

# cascade match results (filled by _cascade_match_current)
m_col:    int32 = -1
m_bg:     int32 = -1
m_weight: int32 = 0
m_align:  int32 = 0
m_disp:   int32 = 0
# box-model cascade winners (-1 = no matching rule set this axis)
m_ml:     int32 = -1
m_mr:     int32 = -1
m_mt:     int32 = -1
m_mb:     int32 = -1
m_wd:     int32 = -1
m_bd:     int32 = -1
m_fontpx: int32 = -1

# font-weight (bold) scope — parallels the colour stack.
weight_stack: Array[64, int32]
weight_sp:  int32 = 0
g_css_bold: int32 = 0

# font-size (px) scope — parallels the weight stack. A level pushes 0 when it
# sets no size, so the effective size INHERITS the nearest ancestor that did
# (CSS font-size inheritance). g_font_px 0 = "use the face default".
fontpx_stack: Array[64, int32]
fontpx_sp: int32 = 0
g_font_px: int32 = 0

# text-align scope + per-row alignment record (post-pass shifts seg_x).
align_stack: Array[64, int32]
align_sp: int32 = 0
g_align:  int32 = 0
row_align: Array[12000, uint8]

# selector/declaration parse scratch (globals — the compiler has no tuples).
c_tag_off: int32 = -1
c_tag_len: int32 = 0
c_cls_off: int32 = -1
c_cls_len: int32 = 0
c_id_off:  int32 = -1
c_id_len:  int32 = 0
c_spec:    int32 = 0
g_store_off: int32 = 0
g_store_len: int32 = 0
d_color:  int32 = -1
d_bg:     int32 = -1
d_weight: int32 = 0
d_align:  int32 = 0
d_disp:   int32 = 0
# box-model declaration scratch (per rule / per inline style="", -1 = unset).
# ml/mr fold the left/right margin+padding; mt/mb the top/bottom gaps (px);
# wd the content width (px); bd is 0 (none) / 1 (on) for a border.
d_ml:     int32 = -1
d_mr:     int32 = -1
d_mt:     int32 = -1
d_mb:     int32 = -1
d_wd:     int32 = -1
d_bd:     int32 = -1
d_fontpx: int32 = -1        # CSS font-size in px (-1 = declaration sets none)
# multi-length shorthand scratch (margin/padding: t r b l).
box_lens: Array[4, int32]
n_box_lens: int32 = 0


# Parse a CSS length from src[vs..ve) honouring px / em / % units into pixels.
# em == EM_PX px; % is of the body content width (bw - 2*CONTENT_X). Returns
# the pixel value (>=0), or -1 when there is no numeric prefix (auto/none/...).
def _style_len(vs: uint64, ve: uint64) -> int32:
    i: uint64 = vs
    while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    seen: int32 = 0
    v: int32 = 0
    while i < ve:
        d: uint8 = src_ptr[i]
        if d >= 48 and d <= 57:
            v = v * 10 + cast[int32](d - 48)
            seen = 1
            i = i + 1
        else:
            break
    if seen == 0:
        return -1
    if i < ve and src_ptr[i] == 37:                  # '%'
        base: int32 = _content_right() - _left_margin()
        if base < 0:
            base = 0
        return v * base / 100
    if i + 1 < ve and _lower(src_ptr[i]) == 101 and _lower(src_ptr[i + 1]) == 109:
        return v * EM_PX                             # "em"
    return v                                          # px or unitless


def _is_alpha(c: uint8) -> int32:
    lc: uint8 = _lower(c)
    if lc >= 97 and lc <= 122:
        return 1
    return 0


def _is_name_ch(c: uint8) -> int32:
    lc: uint8 = _lower(c)
    if (lc >= 97 and lc <= 122) or (c >= 48 and c <= 57) or c == 45 or c == 95:
        return 1
    return 0


# Copy src[a..b) lowercased into css_sbuf; sets g_store_off/g_store_len.
def _css_store(a: uint64, b: uint64):
    g_store_off = cast[int32](css_slen)
    i: uint64 = a
    while i < b and css_slen < CSS_STR_CAP - 1:
        css_sbuf[css_slen] = _lower(src_ptr[i])
        css_slen = css_slen + 1
        i = i + 1
    g_store_len = cast[int32](css_slen) - g_store_off


# Compare src[a..b) (whitespace-trimmed, lowercased) against literal `lit`.
def _prop_is(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    while a < b and (src_ptr[a] == 32 or src_ptr[a] == 9):
        a = a + 1
    while b > a and (src_ptr[b - 1] == 32 or src_ptr[b - 1] == 9):
        b = b - 1
    i: uint64 = 0
    while lit[i] != 0:
        if a + i >= b:
            return 0
        if _lower(src_ptr[a + i]) != lit[i]:
            return 0
        i = i + 1
    if a + i != b:
        return 0
    return 1


# Does the value src[a..b) begin (after whitespace) with literal `lit`?
def _val_starts(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    while a < b and (src_ptr[a] == 32 or src_ptr[a] == 9):
        a = a + 1
    return _srcword_is(a, lit)


# Does property name src[a..b) (trimmed) start with literal `lit`? Used to tell
# `margin` (shorthand) / `margin-left` (side) apart without over-matching.
def _prop_prefix(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    while a < b and (src_ptr[a] == 32 or src_ptr[a] == 9):
        a = a + 1
    while b > a and (src_ptr[b - 1] == 32 or src_ptr[b - 1] == 9):
        b = b - 1
    i: uint64 = 0
    while lit[i] != 0:
        if a + i >= b:
            return 0
        if _lower(src_ptr[a + i]) != lit[i]:
            return 0
        i = i + 1
    return 1


# Accumulate one side inset (margin/padding on that side sum into one column).
def _box_add_l(px: int32):
    if px < 0:
        return
    if d_ml < 0:
        d_ml = 0
    d_ml = d_ml + px


def _box_add_r(px: int32):
    if px < 0:
        return
    if d_mr < 0:
        d_mr = 0
    d_mr = d_mr + px


def _box_add_t(px: int32):
    if px < 0:
        return
    if d_mt < 0:
        d_mt = 0
    d_mt = d_mt + px


def _box_add_b(px: int32):
    if px < 0:
        return
    if d_mb < 0:
        d_mb = 0
    d_mb = d_mb + px


# Parse the space-separated length list of a margin/padding shorthand into
# box_lens[0..n_box_lens); non-length tokens (should not occur here) are skipped.
def _parse_box_lens(vs: uint64, ve: uint64):
    n_box_lens = 0
    i: uint64 = vs
    while i < ve and n_box_lens < 4:
        while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
            i = i + 1
        if i >= ve:
            break
        ts: uint64 = i
        while i < ve and src_ptr[i] != 32 and src_ptr[i] != 9:
            i = i + 1
        px: int32 = _style_len(ts, i)
        if px >= 0:
            box_lens[n_box_lens] = px
            n_box_lens = n_box_lens + 1


# Apply a `margin:`/`padding:` shorthand (1..4 lengths, CSS TRBL rules) into the
# left/right/top/bottom insets.
def _box_shorthand(vs: uint64, ve: uint64):
    _parse_box_lens(vs, ve)
    if n_box_lens == 0:
        return
    t: int32 = box_lens[0]
    r: int32 = box_lens[0]
    bo: int32 = box_lens[0]
    l: int32 = box_lens[0]
    if n_box_lens >= 2:
        r = box_lens[1]
        l = box_lens[1]
    if n_box_lens >= 3:
        bo = box_lens[2]
    if n_box_lens >= 4:
        l = box_lens[3]
    _box_add_t(t)
    _box_add_r(r)
    _box_add_b(bo)
    _box_add_l(l)


# Route ONE box-model declaration (property src[ps..pe) : value src[vs..ve))
# into the d_* box scratch. Shared by the stylesheet (_apply_decl) and inline
# style="" paths so classes and inline styles cascade identically. Returns 1 if
# the property was a box property (handled), else 0.
def _box_decl(ps: uint64, pe: uint64, vs: uint64, ve: uint64) -> int32:
    # Border: any border / border-style / border-width / border-<side> turns the
    # box on unless the value is none/hidden/0.
    if _prop_prefix(ps, pe, cast[Ptr[uint8]]("border")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("none")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("hidden")) != 0:
            d_bd = 0
        else:
            d_bd = 1
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("width")) != 0:
        w: int32 = _style_len(vs, ve)
        if w >= 0:
            d_wd = w
        return 1
    # side-specific first (longer names) so the shorthand check does not eat them
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-left")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-left")) != 0:
        _box_add_l(_style_len(vs, ve))
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-right")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-right")) != 0:
        _box_add_r(_style_len(vs, ve))
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-top")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-top")) != 0:
        _box_add_t(_style_len(vs, ve))
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-bottom")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-bottom")) != 0:
        _box_add_b(_style_len(vs, ve))
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding")) != 0:
        _box_shorthand(vs, ve)
        return 1
    return 0


# First non-space offset in [a,b) — where a colour value begins.
def _val_start(a: uint64, b: uint64) -> uint64:
    while a < b and (src_ptr[a] == 32 or src_ptr[a] == 9):
        a = a + 1
    return a


# ---- byte-buffer compares -------------------------------------------
def _buf_eq(a: Ptr[uint8], alen: int32, b: Ptr[uint8], blen: int32) -> int32:
    if alen != blen:
        return 0
    i: int32 = 0
    while i < alen:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# Does the element's class list (el_sbuf[coff..coff+clen)) contain the token
# css_sbuf[koff..koff+klen) (space-separated)?
def _cls_contains(coff: int32, clen: int32, koff: int32, klen: int32) -> int32:
    i: int32 = 0
    while i < clen:
        while i < clen and el_sbuf[coff + i] == 32:
            i = i + 1
        s: int32 = i
        while i < clen and el_sbuf[coff + i] != 32:
            i = i + 1
        tlen: int32 = i - s
        if tlen == klen and _buf_eq(&el_sbuf[coff + s], tlen, \
                                    &css_sbuf[koff], klen) != 0:
            return 1
    return 0


# ---- selector parsing -----------------------------------------------
def _read_name(i: uint64, b: uint64) -> uint64:
    while i < b and _is_name_ch(src_ptr[i]) != 0:
        i = i + 1
    return i


# Parse one compound selector at src[a..b) into c_* globals; c_spec gets its
# specificity contribution.
def _parse_compound(a: uint64, b: uint64):
    c_tag_off = -1
    c_tag_len = 0
    c_cls_off = -1
    c_cls_len = 0
    c_id_off = -1
    c_id_len = 0
    c_spec = 0
    i: uint64 = a
    if i < b and src_ptr[i] == 42:                   # '*' universal
        i = i + 1
    elif i < b and _is_alpha(src_ptr[i]) != 0:
        j: uint64 = _read_name(i, b)
        _css_store(i, j)
        c_tag_off = g_store_off
        c_tag_len = g_store_len
        c_spec = c_spec + 1
        i = j
    while i < b:
        if src_ptr[i] == 46:                         # '.class'
            j2: uint64 = _read_name(i + 1, b)
            _css_store(i + 1, j2)
            c_cls_off = g_store_off
            c_cls_len = g_store_len
            c_spec = c_spec + 10
            i = j2
        elif src_ptr[i] == 35:                       # '#id'
            j3: uint64 = _read_name(i + 1, b)
            _css_store(i + 1, j3)
            c_id_off = g_store_off
            c_id_len = g_store_len
            c_spec = c_spec + 100
            i = j3
        else:
            i = i + 1


# Parse a full selector src[a..b) into rule `ri`. Keeps the rightmost compound
# as the target and the nearest preceding compound as the ancestor.
def _parse_selector(a: uint64, b: uint64, ri: int32):
    # trim
    while a < b and (src_ptr[a] == 32 or src_ptr[a] == 9 or src_ptr[a] == 10 \
                     or src_ptr[a] == 13 or src_ptr[a] == 62):
        a = a + 1
    while b > a and (src_ptr[b - 1] == 32 or src_ptr[b - 1] == 9 or \
                     src_ptr[b - 1] == 10 or src_ptr[b - 1] == 13):
        b = b - 1
    r_has_anc[ri] = 0
    spec: int32 = 0
    # walk compounds left->right; remember previous compound as ancestor.
    i: uint64 = a
    prev_present: int32 = 0
    while i < b:
        while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9 or \
                         src_ptr[i] == 62 or src_ptr[i] == 10 or \
                         src_ptr[i] == 13):
            i = i + 1
        if i >= b:
            break
        cs: uint64 = i
        while i < b and src_ptr[i] != 32 and src_ptr[i] != 9 and \
              src_ptr[i] != 62 and src_ptr[i] != 10 and src_ptr[i] != 13:
            i = i + 1
        # a compound occupies [cs,i); shift current target -> ancestor.
        if prev_present != 0:
            r_has_anc[ri] = 1
            r_atag_off[ri] = r_tag_off[ri]
            r_atag_len[ri] = r_tag_len[ri]
            r_acls_off[ri] = r_cls_off[ri]
            r_acls_len[ri] = r_cls_len[ri]
            r_aid_off[ri]  = r_id_off[ri]
            r_aid_len[ri]  = r_id_len[ri]
        _parse_compound(cs, i)
        r_tag_off[ri] = c_tag_off
        r_tag_len[ri] = c_tag_len
        r_cls_off[ri] = c_cls_off
        r_cls_len[ri] = c_cls_len
        r_id_off[ri]  = c_id_off
        r_id_len[ri]  = c_id_len
        spec = spec + c_spec
        prev_present = 1
    r_spec[ri] = spec


# ---- declaration parsing --------------------------------------------
def _apply_decl(ps: uint64, pe: uint64, vs: uint64, ve: uint64):
    if _box_decl(ps, pe, vs, ve) != 0:
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("color")) != 0:
        d_color = _color_value(_val_start(vs, ve))
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("background-color")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("background")) != 0:
        cv: int32 = _color_value(_val_start(vs, ve))
        if cv >= 0:
            d_bg = cv
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("font-weight")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("bold")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("700")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("800")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("900")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("600")) != 0:
            d_weight = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("normal")) != 0:
            d_weight = 2
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("text-align")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("center")) != 0:
            d_align = 2
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("right")) != 0:
            d_align = 3
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("left")) != 0:
            d_align = 1
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("display")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("none")) != 0:
            d_disp = 1
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("font-size")) != 0:
        fp: int32 = _style_len(vs, ve)
        if fp > 0:
            d_fontpx = fp
        return


# Parse a declaration block src[a..b) into d_* globals.
def _parse_decls(a: uint64, b: uint64):
    d_color = -1
    d_bg = -1
    d_weight = 0
    d_align = 0
    d_disp = 0
    d_ml = -1
    d_mr = -1
    d_mt = -1
    d_mb = -1
    d_wd = -1
    d_bd = -1
    d_fontpx = -1
    i: uint64 = a
    while i < b:
        ps: uint64 = i
        while i < b and src_ptr[i] != 58 and src_ptr[i] != 59:   # ':' ';'
            i = i + 1
        if i < b and src_ptr[i] == 58:
            pe: uint64 = i
            i = i + 1
            vs: uint64 = i
            while i < b and src_ptr[i] != 59:
                i = i + 1
            _apply_decl(ps, pe, vs, i)
        if i < b and src_ptr[i] == 59:
            i = i + 1


# ---- stylesheet collection ------------------------------------------
# Parse selector-list { decls } starting at src[a]; returns offset just past
# the closing '}'. Emits one rule per comma-separated selector.
def _parse_ruleset(a: uint64, rgn_end: uint64) -> uint64:
    # selector list up to '{'
    sel_s: uint64 = a
    i: uint64 = a
    while i < rgn_end and src_ptr[i] != 123 and src_ptr[i] != 60:   # '{' '<'
        i = i + 1
    if i >= rgn_end or src_ptr[i] != 123:
        return i
    sel_e: uint64 = i
    i = i + 1
    dec_s: uint64 = i
    while i < rgn_end and src_ptr[i] != 125:                        # '}'
        i = i + 1
    dec_e: uint64 = i
    if i < rgn_end:
        i = i + 1
    _parse_decls(dec_s, dec_e)
    # Nothing we honour -> skip emitting rules entirely.
    if d_color < 0 and d_bg < 0 and d_weight == 0 and d_align == 0 and \
       d_disp == 0 and d_ml < 0 and d_mr < 0 and d_mt < 0 and d_mb < 0 and \
       d_wd < 0 and d_bd < 0 and d_fontpx < 0:
        return i
    # one rule per comma-separated selector
    ss: uint64 = sel_s
    k: uint64 = sel_s
    while k <= sel_e:
        if k == sel_e or src_ptr[k] == 44:           # ',' or end
            if n_rules < MAX_RULES and k > ss:
                ri: int32 = n_rules
                _parse_selector(ss, k, ri)
                r_color[ri]  = d_color
                r_bg[ri]     = d_bg
                r_weight[ri] = d_weight
                r_align[ri]  = d_align
                r_disp[ri]   = d_disp
                r_ml[ri]     = d_ml
                r_mr[ri]     = d_mr
                r_mt[ri]     = d_mt
                r_mb[ri]     = d_mb
                r_wd[ri]     = d_wd
                r_bd[ri]     = d_bd
                r_fontpx[ri] = d_fontpx
                n_rules = n_rules + 1
            ss = k + 1
        k = k + 1
    return i


# Scan the whole page for <style> blocks and parse their rules.
def _collect_css():
    n_rules = 0
    css_slen = 0
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60:                         # '<'
            k: uint64 = i + 1
            if _tagname_is(k, cast[Ptr[uint8]]("style")) != 0:
                # advance to end of the opening tag
                while i < src_len and src_ptr[i] != 62:
                    i = i + 1
                if i < src_len:
                    i = i + 1
                body: uint64 = i
                # region ends at </style>
                e: uint64 = body
                while e < src_len:
                    if src_ptr[e] == 60 and e + 1 < src_len and \
                       src_ptr[e + 1] == 47 and \
                       _tagname_is(e + 2, cast[Ptr[uint8]]("style")) != 0:
                        break
                    e = e + 1
                # parse rulesets within [body,e)
                p: uint64 = body
                while p < e:
                    # skip /* comments */ and whitespace
                    if p + 1 < e and src_ptr[p] == 47 and src_ptr[p + 1] == 42:
                        p = p + 2
                        while p + 1 < e and not (src_ptr[p] == 42 and \
                                                 src_ptr[p + 1] == 47):
                            p = p + 1
                        p = p + 2
                        continue
                    if src_ptr[p] == 32 or src_ptr[p] == 9 or \
                       src_ptr[p] == 10 or src_ptr[p] == 13:
                        p = p + 1
                        continue
                    np: uint64 = _parse_ruleset(p, e)
                    if np <= p:
                        p = p + 1
                    else:
                        p = np
                i = e
                continue
        i = i + 1


# ---- element stack + cascade matching -------------------------------
def _el_copy(a: uint64, b: uint64) -> int32:
    n: int32 = 0
    i: uint64 = a
    while i < b and el_slen < EL_STR_CAP - 1:
        el_sbuf[el_slen] = _lower(src_ptr[i])
        el_slen = el_slen + 1
        n = n + 1
        i = i + 1
    return n


def _el_push(np: uint64, nlen: uint64, ne: uint64, te: uint64):
    if el_sp >= MAX_EL:
        return
    s: int32 = cast[int32](el_slen)
    el_tag_off[el_sp] = s
    el_tag_len[el_sp] = _el_copy(np, np + nlen)
    el_cls_off[el_sp] = cast[int32](el_slen)
    el_cls_len[el_sp] = 0
    if _find_attr(ne, te, cast[Ptr[uint8]]("class")) != 0:
        el_cls_len[el_sp] = _el_copy(g_attr_start, g_attr_end)
    el_id_off[el_sp] = cast[int32](el_slen)
    el_id_len[el_sp] = 0
    if _find_attr(ne, te, cast[Ptr[uint8]]("id")) != 0:
        el_id_len[el_sp] = _el_copy(g_attr_start, g_attr_end)
    el_sp = el_sp + 1


def _el_pop(np: uint64, nlen: uint64):
    # forgiving: pop the nearest matching open element (tolerates unclosed
    # inner tags), else leave the stack unchanged.
    k: int32 = el_sp - 1
    while k >= 0:
        if _buf_eq(&el_sbuf[el_tag_off[k]], el_tag_len[k], \
                   &src_ptr[np], cast[int32](nlen)) != 0:
            el_slen = cast[uint64](el_tag_off[k])
            el_sp = k
            return
        k = k - 1


# Does compound (target of rule ri) match the element at stack index e?
def _tgt_matches(ri: int32, e: int32) -> int32:
    if r_tag_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_tag_off[e]], el_tag_len[e], \
                   &css_sbuf[r_tag_off[ri]], r_tag_len[ri]) == 0:
            return 0
    if r_cls_len[ri] > 0:
        if _cls_contains(el_cls_off[e], el_cls_len[e], \
                         r_cls_off[ri], r_cls_len[ri]) == 0:
            return 0
    if r_id_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_id_off[e]], el_id_len[e], \
                   &css_sbuf[r_id_off[ri]], r_id_len[ri]) == 0:
            return 0
    return 1


def _anc_matches(ri: int32, e: int32) -> int32:
    if r_atag_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_tag_off[e]], el_tag_len[e], \
                   &css_sbuf[r_atag_off[ri]], r_atag_len[ri]) == 0:
            return 0
    if r_acls_len[ri] > 0:
        if _cls_contains(el_cls_off[e], el_cls_len[e], \
                         r_acls_off[ri], r_acls_len[ri]) == 0:
            return 0
    if r_aid_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_id_off[e]], el_id_len[e], \
                   &css_sbuf[r_aid_off[ri]], r_aid_len[ri]) == 0:
            return 0
    return 1


def _rule_matches(ri: int32, top: int32) -> int32:
    if _tgt_matches(ri, top) == 0:
        return 0
    if r_has_anc[ri] == 0:
        return 1
    a: int32 = top - 1
    while a >= 0:
        if _anc_matches(ri, a) != 0:
            return 1
        a = a - 1
    return 0


# Resolve the cascade for the current (topmost) open element into m_*.
def _cascade_match_current():
    m_col = -1
    m_bg = -1
    m_weight = 0
    m_align = 0
    m_disp = 0
    m_ml = -1
    m_mr = -1
    m_mt = -1
    m_mb = -1
    m_wd = -1
    m_bd = -1
    m_fontpx = -1
    if el_sp == 0:
        return
    top: int32 = el_sp - 1
    bc: int32 = -1
    bb: int32 = -1
    bw: int32 = -1
    ba: int32 = -1
    bd: int32 = -1
    # best-spec trackers for the six box axes
    sml: int32 = -1
    smr: int32 = -1
    smt: int32 = -1
    smb: int32 = -1
    swd: int32 = -1
    sbd: int32 = -1
    sfp: int32 = -1
    ri: int32 = 0
    while ri < n_rules:
        if _rule_matches(ri, top) != 0:
            sp: int32 = r_spec[ri]
            if r_color[ri] >= 0 and sp >= bc:
                bc = sp
                m_col = r_color[ri]
            if r_bg[ri] >= 0 and sp >= bb:
                bb = sp
                m_bg = r_bg[ri]
            if r_weight[ri] != 0 and sp >= bw:
                bw = sp
                m_weight = r_weight[ri]
            if r_align[ri] != 0 and sp >= ba:
                ba = sp
                m_align = r_align[ri]
            if r_disp[ri] != 0 and sp >= bd:
                bd = sp
                m_disp = r_disp[ri]
            if r_ml[ri] >= 0 and sp >= sml:
                sml = sp
                m_ml = r_ml[ri]
            if r_mr[ri] >= 0 and sp >= smr:
                smr = sp
                m_mr = r_mr[ri]
            if r_mt[ri] >= 0 and sp >= smt:
                smt = sp
                m_mt = r_mt[ri]
            if r_mb[ri] >= 0 and sp >= smb:
                smb = sp
                m_mb = r_mb[ri]
            if r_wd[ri] >= 0 and sp >= swd:
                swd = sp
                m_wd = r_wd[ri]
            if r_bd[ri] >= 0 and sp >= sbd:
                sbd = sp
                m_bd = r_bd[ri]
            if r_fontpx[ri] >= 0 and sp >= sfp:
                sfp = sp
                m_fontpx = r_fontpx[ri]
        ri = ri + 1


# ---- font-weight (bold) scope ---------------------------------------
def _css_weight_effective() -> int32:
    i: int32 = weight_sp - 1
    while i >= 0:
        if weight_stack[i] != 0:
            return weight_stack[i]
        i = i - 1
    return 0


def _weight_push(w: int32):
    if weight_sp < 64:
        weight_stack[weight_sp] = w
        weight_sp = weight_sp + 1
    if _css_weight_effective() == 1:
        g_css_bold = 1
    else:
        g_css_bold = 0


def _weight_pop():
    if weight_sp > 0:
        weight_sp = weight_sp - 1
    if _css_weight_effective() == 1:
        g_css_bold = 1
    else:
        g_css_bold = 0


# ---- font-size (px) scope — inherits the nearest ancestor that set one ----
def _fontpx_effective() -> int32:
    i: int32 = fontpx_sp - 1
    while i >= 0:
        if fontpx_stack[i] > 0:
            return fontpx_stack[i]
        i = i - 1
    return 0


def _fontpx_push(px: int32):
    if fontpx_sp < 64:
        fontpx_stack[fontpx_sp] = px
        fontpx_sp = fontpx_sp + 1
    g_font_px = _fontpx_effective()


def _fontpx_pop():
    if fontpx_sp > 0:
        fontpx_sp = fontpx_sp - 1
    g_font_px = _fontpx_effective()


# ---- text-align scope -----------------------------------------------
def _align_effective() -> int32:
    i: int32 = align_sp - 1
    while i >= 0:
        if align_stack[i] != 0:
            return align_stack[i]
        i = i - 1
    return 0


def _align_push(a: int32):
    if align_sp < 64:
        align_stack[align_sp] = a
        align_sp = align_sp + 1
    g_align = _align_effective()


def _align_pop():
    if align_sp > 0:
        align_sp = align_sp - 1
    g_align = _align_effective()


# Open/close a full style scope for a stylable element. The cascade is matched
# from el_stack (already pushed) and merged with the inline style="" overrides.
def _open_style(ne: uint64, te: uint64):
    _cascade_match_current()
    col: int32 = m_col
    ic: int32 = _tag_color(ne, te)
    if ic >= 0:
        col = ic
    bgv: int32 = m_bg
    ib: int32 = _tag_bgcolor(ne, te)
    if ib >= 0:
        bgv = ib
    wt: int32 = m_weight
    al: int32 = m_align
    fpx: int32 = m_fontpx
    # inline style="" font-weight / text-align / font-size override the cascade.
    _parse_inline_wa(ne, te)
    if d_weight != 0:
        wt = d_weight
    if d_align != 0:
        al = d_align
    if d_fontpx >= 0:
        fpx = d_fontpx
    push_px: int32 = 0
    if fpx >= 0:
        push_px = fpx
    _color_push(col)
    _bg_push(bgv)
    _weight_push(wt)
    _align_push(al)
    _fontpx_push(push_px)


def _close_style():
    _color_pop()
    _bg_pop()
    _weight_pop()
    _align_pop()
    _fontpx_pop()


# Scan an inline style="" attribute for font-weight/text-align/display + the
# full box model (margin/padding/width/border); sets d_weight/d_align/d_disp
# and the d_* box scratch (d_color/d_bg come from _tag_color/_tag_bgcolor).
# Inline declarations here override any stylesheet/class rule (highest priority).
def _parse_inline_wa(ne: uint64, te: uint64):
    d_weight = 0
    d_align = 0
    d_disp = 0
    d_ml = -1
    d_mr = -1
    d_mt = -1
    d_mb = -1
    d_wd = -1
    d_bd = -1
    d_fontpx = -1
    if _find_attr(ne, te, cast[Ptr[uint8]]("style")) == 0:
        return
    a: uint64 = g_attr_start
    b: uint64 = g_attr_end
    i: uint64 = a
    while i < b:
        ps: uint64 = i
        while i < b and src_ptr[i] != 58 and src_ptr[i] != 59:
            i = i + 1
        if i < b and src_ptr[i] == 58:
            pe: uint64 = i
            i = i + 1
            vs: uint64 = i
            while i < b and src_ptr[i] != 59:
                i = i + 1
            # box model (margin/padding/width/border) — shared with the sheet.
            if _box_decl(ps, pe, vs, i) != 0:
                pass
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("font-weight")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("bold")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("700")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("800")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("900")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("600")) != 0:
                    d_weight = 1
                elif _val_starts(vs, i, cast[Ptr[uint8]]("normal")) != 0:
                    d_weight = 2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("text-align")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("center")) != 0:
                    d_align = 2
                elif _val_starts(vs, i, cast[Ptr[uint8]]("right")) != 0:
                    d_align = 3
                elif _val_starts(vs, i, cast[Ptr[uint8]]("left")) != 0:
                    d_align = 1
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("display")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("none")) != 0:
                    d_disp = 1
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("font-size")) != 0:
                fp: int32 = _style_len(vs, i)
                if fp > 0:
                    d_fontpx = fp
        if i < b and src_ptr[i] == 59:
            i = i + 1


# Resolve whether the element being opened is display:none (cascade or inline).
def _is_display_none(ne: uint64, te: uint64) -> int32:
    _parse_inline_wa(ne, te)
    if d_disp != 0:
        return 1
    if m_disp != 0:                                  # from the last cascade match
        return 1
    return 0


# ====================================================================
# TABLE two-pass column layout.
# ====================================================================
def _alnum_at(p: uint64) -> int32:
    if p >= src_len:
        return 0
    c: uint8 = _lower(src_ptr[p])
    if (c >= 97 and c <= 122) or (c >= 48 and c <= 57):
        return 1
    return 0


# Locate an attribute VALUE `name="..."` (or name='...' / name=bare) in the
# tag body [ts,te). On success sets g_attr_start/g_attr_end to the value span
# and returns 1; returns 0 if the attribute is absent.
g_attr_start: uint64 = 0
g_attr_end:   uint64 = 0


def _find_attr(ts: uint64, te: uint64, name: Ptr[uint8]) -> int32:
    nl: uint64 = 0
    while name[nl] != 0:
        nl = nl + 1
    i: uint64 = ts
    while i + nl <= te:
        prev_alpha: int32 = 0
        if i > ts:
            pc: uint8 = _lower(src_ptr[i - 1])
            if (pc >= 97 and pc <= 122) or (pc >= 48 and pc <= 57) or pc == 45:
                prev_alpha = 1
        if prev_alpha == 0 and _srcword_is(i, name) != 0 and \
           _alnum_at(i + nl) == 0:
            j: uint64 = i + nl
            while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
                j = j + 1
            if j < te and src_ptr[j] == 61:              # '='
                j = j + 1
                while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
                    j = j + 1
                quote: uint8 = 0
                if j < te and (src_ptr[j] == 34 or src_ptr[j] == 39):
                    quote = src_ptr[j]
                    j = j + 1
                g_attr_start = j
                while j < te:
                    c: uint8 = src_ptr[j]
                    if quote != 0:
                        if c == quote:
                            break
                    else:
                        if c == 32 or c == 9:
                            break
                    j = j + 1
                g_attr_end = j
                return 1
        i = i + 1
    return 0


# Read an integer-valued attribute (e.g. colspan="2") from tag body [ts,te).
# Returns the parsed value, or `dflt` when absent / non-numeric / < 1.
def _attr_int(ts: uint64, te: uint64, name: Ptr[uint8], dflt: int32) -> int32:
    if _find_attr(ts, te, name) == 0:
        return dflt
    v: int32 = 0
    p: uint64 = g_attr_start
    seen: int32 = 0
    while p < g_attr_end:
        d: uint8 = src_ptr[p]
        if d >= 48 and d <= 57:
            v = v * 10 + cast[int32](d - 48)
            seen = 1
        p = p + 1
    if seen == 0 or v < 1:
        return dflt
    return v


# A tag name at src[at] matches `lit` AND ends at a tag boundary (so "tr"
# does not match "track"). Returns 1 on a bounded match.
def _tagname_is(at: uint64, lit: Ptr[uint8]) -> int32:
    if _srcword_is(at, lit) == 0:
        return 0
    n: uint64 = 0
    while lit[n] != 0:
        n = n + 1
    if _alnum_at(at + n) != 0:
        return 0
    return 1


# Index of the '<' of the </table> that closes the table whose body begins at
# `body0` (nesting-aware). Returns src_len if unterminated.
def _table_region_end(body0: uint64) -> uint64:
    depth: int32 = 1
    i: uint64 = body0
    while i < src_len:
        if src_ptr[i] == 60:                         # '<'
            k: uint64 = i + 1
            close: int32 = 0
            if k < src_len and src_ptr[k] == 47:     # '/'
                close = 1
                k = k + 1
            if _tagname_is(k, cast[Ptr[uint8]]("table")) != 0:
                if close != 0:
                    depth = depth - 1
                    if depth == 0:
                        return i
                else:
                    depth = depth + 1
            while i < src_len and src_ptr[i] != 62:  # to '>'
                i = i + 1
            if i < src_len:
                i = i + 1
            continue
        i = i + 1
    return src_len


# Pass 1: record the widest cell (in characters, whitespace-collapsed) per
# column across [rgn_start, rgn_end). Sets col_chars[] and n_cols.
def _measure_table(rgn_start: uint64, rgn_end: uint64):
    c: int32 = 0
    while c < MAX_COLS:
        col_chars[c] = 0
        c = c + 1
    n_cols = 0
    col: int32 = -1
    nextcol: int32 = 0          # column index the next cell starts at
    cspan: int32 = 1            # colspan of the currently-counting cell
    counting: int32 = 0
    cell_n: int32 = 0
    pend_space: int32 = 0
    i: uint64 = rgn_start
    while i < rgn_end:
        ch: uint8 = src_ptr[i]
        if ch == 60:                                 # '<'
            k: uint64 = i + 1
            close: int32 = 0
            if k < rgn_end and src_ptr[k] == 47:
                close = 1
                k = k + 1
            is_cell: int32 = 0
            if _tagname_is(k, cast[Ptr[uint8]]("td")) != 0 or \
               _tagname_is(k, cast[Ptr[uint8]]("th")) != 0:
                is_cell = 1
            is_tr: int32 = _tagname_is(k, cast[Ptr[uint8]]("tr"))
            # end of this tag's body ('>')
            tend: uint64 = k
            while tend < rgn_end and src_ptr[tend] != 62:
                tend = tend + 1
            if is_cell != 0 or is_tr != 0:
                # finalize the cell that was open — a spanning cell (cspan>1)
                # does not size any single column, so only single-span cells
                # contribute to col_chars[].
                if col >= 0 and col < MAX_COLS and cspan == 1 and \
                   cell_n > col_chars[col]:
                    col_chars[col] = cell_n
                counting = 0
                cell_n = 0
                pend_space = 0
                cspan = 1
                if is_tr != 0 and close == 0:
                    nextcol = 0                       # new row restarts columns
                    col = -1
                elif is_cell != 0 and close == 0:
                    col = nextcol
                    cspan = _attr_int(k, tend, cast[Ptr[uint8]]("colspan"), 1)
                    nextcol = col + cspan
                    counting = 1
                    if nextcol > n_cols:
                        n_cols = nextcol
            i = tend
            if i < rgn_end:
                i = i + 1
            continue
        if counting != 0:
            if ch == 32 or ch == 9 or ch == 10 or ch == 13:
                pend_space = 1
            else:
                if pend_space != 0 and cell_n > 0:
                    cell_n = cell_n + 1
                pend_space = 0
                cell_n = cell_n + 1
        i = i + 1
    if col >= 0 and col < MAX_COLS and cspan == 1 and cell_n > col_chars[col]:
        col_chars[col] = cell_n


# Pass 2: turn per-column character widths into pixel column x-positions.
def _compute_cols():
    right: int32 = _content_right()
    x: int32 = indent_x
    c: int32 = 0
    while c < n_cols and c < MAX_COLS:
        col_x[c] = x
        w: int32 = col_chars[c]
        if w < 1:
            w = 1
        if w > 60:                                   # cap a runaway column
            w = 60
        x = x + (w + CELL_PAD) * CELL_W
        c = c + 1
    if n_cols > MAX_COLS:
        n_cols = MAX_COLS
    col_x[n_cols] = x                                # right sentinel


# Close the open table cell: flush its word, drop its bold + colour scope.
def _cell_close():
    if cell_active == 0:
        return
    _word_flush()
    if cell_is_th != 0 and g_bold_n > 0:
        g_bold_n = g_bold_n - 1
    _close_style()
    cell_active = 0
    cell_is_th = 0
    _style_break()


# ====================================================================
# TAG HANDLING.  tag content is src[ts .. te) (between '<' and '>').
# ====================================================================
def _name_eq(np: uint64, nlen: uint64, lit: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while lit[i] != 0:
        if i >= nlen:
            return 0
        if _lower(src_ptr[np + i]) != lit[i]:
            return 0
        i = i + 1
    if i != nlen:
        return 0
    return 1


# Extract the href="..."/href='...' value from a tag body into link_href_buf;
# returns the new link id, or -1 if no href / table full.
def _capture_href(ts: uint64, te: uint64) -> int32:
    if n_links >= MAX_LINKS:
        return -1
    # find "href" (case-insensitive) within [ts,te)
    i: uint64 = ts
    found: int32 = 0
    while i + 4 <= te:
        if _lower(src_ptr[i]) == 104 and _lower(src_ptr[i + 1]) == 114 \
           and _lower(src_ptr[i + 2]) == 101 and _lower(src_ptr[i + 3]) == 102:
            found = 1
            i = i + 4
            break
        i = i + 1
    if found == 0:
        return -1
    while i < te and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    if i >= te or src_ptr[i] != 61:                  # '='
        return -1
    i = i + 1
    while i < te and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    quote: uint8 = 0
    if i < te and (src_ptr[i] == 34 or src_ptr[i] == 39):
        quote = src_ptr[i]
        i = i + 1
    start: uint64 = link_href_len
    cnt: int32 = 0
    while i < te:
        c: uint8 = src_ptr[i]
        if quote != 0:
            if c == quote:
                break
        else:
            if c == 32 or c == 9 or c == 62:
                break
        if c == 38:                                  # '&' — decode entity
            consumed: uint64 = _entity(i)
            if consumed > 0:
                k: int32 = 0
                while k < g_ent_len:
                    if link_href_len < LINK_HREF_CAP - 1:
                        link_href_buf[link_href_len] = g_ent_buf[k]
                        link_href_len = link_href_len + 1
                        cnt = cnt + 1
                    k = k + 1
                i = i + consumed
                continue
        if link_href_len < LINK_HREF_CAP - 1:
            link_href_buf[link_href_len] = c
            link_href_len = link_href_len + 1
            cnt = cnt + 1
        i = i + 1
    if cnt == 0:
        return -1
    lid: int32 = cast[int32](n_links)
    link_off[n_links] = cast[int32](start)
    link_len[n_links] = cnt
    n_links = n_links + 1
    return lid


def _enter_skip(np: uint64, nlen: uint64):
    skip_active = 1
    skip_nlen = nlen
    i: uint64 = 0
    while i < nlen and i < 16:
        skip_name[i] = _lower(src_ptr[np + i])
        i = i + 1
    # NUL-terminate: the skip-end check (_name_eq) scans skip_name until a
    # zero, so a shorter skip name following a longer one must not inherit the
    # previous name's trailing bytes (else the skip would never end).
    if i < 16:
        skip_name[i] = 0


# ====================================================================
# FORM CONTROLS — monospace-grid rendering of <input>/<textarea>/<button>/
# <select>. The controls are drawn from the (possibly JS-rewritten) source
# attributes so a value/checked change re-renders through the normal rewrite
# path. See the DOM section for the value/checked get-set + event wiring.
# ====================================================================
fbuf: Array[512, uint8]                  # scratch for one attribute value


# Is the whitespace/boundary-delimited word `name` present in tag body [ts,te)?
# (Handles bare boolean attributes like `checked` / `selected` that carry no
# `=value`, which _find_attr — which requires an '=' — would miss.)
def _has_word(ts: uint64, te: uint64, name: Ptr[uint8]) -> int32:
    nl: uint64 = 0
    while name[nl] != 0:
        nl = nl + 1
    i: uint64 = ts
    while i + nl <= te:
        prev_alpha: int32 = 0
        if i > ts:
            pc: uint8 = _lower(src_ptr[i - 1])
            if (pc >= 97 and pc <= 122) or (pc >= 48 and pc <= 57) or pc == 45:
                prev_alpha = 1
        if prev_alpha == 0 and _srcword_is(i, name) != 0 and \
           _alnum_at(i + nl) == 0:
            return 1
        i = i + 1
    return 0


# Copy attribute `name`'s value from tag body [ne,te) into fbuf (NUL-term).
# Returns its length, or -1 if the attribute is absent.
def _attr_to_fbuf(ne: uint64, te: uint64, name: Ptr[uint8]) -> int32:
    if _find_attr(ne, te, name) == 0:
        return -1
    n: int32 = 0
    p: uint64 = g_attr_start
    while p < g_attr_end and n < 511:
        if src_ptr[p] == 38:                         # '&' — decode entity
            consumed: uint64 = _entity(p)
            if consumed > 0:
                k: int32 = 0
                while k < g_ent_len and n < 511:
                    fbuf[n] = g_ent_buf[k]
                    n = n + 1
                    k = k + 1
                p = p + consumed
                continue
        fbuf[n] = src_ptr[p]
        n = n + 1
        p = p + 1
    fbuf[n] = 0
    return n


# Push a NUL-terminated C string into the inline word accumulator.
def _wpush_cstr(s: Ptr[uint8]):
    i: int32 = 0
    while s[i] != 0:
        _word_push(s[i])
        i = i + 1


# Push a src span [a,b) into the word accumulator.
def _wpush_range(a: uint64, b: uint64):
    i: uint64 = a
    while i < b:
        _word_push(src_ptr[i])
        i = i + 1


# input type is `lit` (case-insensitive); missing type defaults to "text".
def _input_type_is(ne: uint64, te: uint64, lit: Ptr[uint8]) -> int32:
    n: int32 = _attr_to_fbuf(ne, te, cast[Ptr[uint8]]("type"))
    if n < 0:
        return _bytes_eq(cast[Ptr[uint8]]("text"), 4, lit, _cstr_len(lit))
    # lower-case the buffered type
    k: int32 = 0
    while k < n:
        fbuf[k] = _lower(fbuf[k])
        k = k + 1
    return _bytes_eq(&fbuf[0], n, lit, _cstr_len(lit))


# Emit a textual control token as one wrapping word: <pre-flushed> [box].
def _emit_input(ne: uint64, te: uint64):
    if _input_type_is(ne, te, cast[Ptr[uint8]]("hidden")) != 0:
        return                                        # hidden: renders nothing
    _word_flush()
    if _input_type_is(ne, te, cast[Ptr[uint8]]("checkbox")) != 0:
        _word_push(91)                                # '['
        if _has_word(ne, te, cast[Ptr[uint8]]("checked")) != 0:
            _word_push(120)                           # 'x'
        else:
            _word_push(32)
        _word_push(93)                                # ']'
        _word_flush()
        return
    if _input_type_is(ne, te, cast[Ptr[uint8]]("radio")) != 0:
        _word_push(40)                                # '('
        if _has_word(ne, te, cast[Ptr[uint8]]("checked")) != 0:
            _word_push(42)                            # '*'
        else:
            _word_push(32)
        _word_push(41)                                # ')'
        _word_flush()
        return
    is_btn: int32 = 0
    if _input_type_is(ne, te, cast[Ptr[uint8]]("submit")) != 0 or \
       _input_type_is(ne, te, cast[Ptr[uint8]]("button")) != 0 or \
       _input_type_is(ne, te, cast[Ptr[uint8]]("reset")) != 0:
        is_btn = 1
    if is_btn != 0:
        # push-button: [ label ]
        _word_push(91)
        _word_push(32)
        vn: int32 = _attr_to_fbuf(ne, te, cast[Ptr[uint8]]("value"))
        if vn > 0:
            _wpush_cstr(&fbuf[0])
        else:
            _wpush_cstr(cast[Ptr[uint8]]("Button"))
        _word_push(32)
        _word_push(93)
        _word_flush()
        return
    # text-like field: [value padded to >=8 with '_']
    _word_push(91)                                    # '['
    vlen: int32 = _attr_to_fbuf(ne, te, cast[Ptr[uint8]]("value"))
    ilen: int32 = 0
    if vlen > 0:
        _wpush_cstr(&fbuf[0])
        ilen = vlen
    else:
        pn: int32 = _attr_to_fbuf(ne, te, cast[Ptr[uint8]]("placeholder"))
        if pn > 0:
            _wpush_cstr(&fbuf[0])
            ilen = pn
    while ilen < 8:
        _word_push(95)                                # '_'
        ilen = ilen + 1
    _word_push(93)                                    # ']'
    _word_flush()


# Find the selected <option>'s visible text inside a <select> whose body
# starts at `body0`; copies it to fbuf (NUL-term) and returns its length.
# Picks the option carrying `selected`, else the first option.
def _select_text(body0: uint64) -> int32:
    i: uint64 = body0
    first_s: int32 = -1
    first_e: int32 = -1
    while i < src_len:
        if src_ptr[i] == 60:                          # '<'
            if i + 1 < src_len and src_ptr[i + 1] == 47 and \
               _tagname_is(i + 2, cast[Ptr[uint8]]("select")) != 0:
                break
            if _tagname_is(i + 1, cast[Ptr[uint8]]("option")) != 0:
                je: uint64 = i + 1
                while je < src_len and src_ptr[je] != 62:
                    je = je + 1
                ne: uint64 = i + 1
                while ne < je and _alnum_at(ne) != 0:
                    ne = ne + 1
                cs: uint64 = je + 1
                ce: uint64 = cs
                while ce < src_len and src_ptr[ce] != 60:
                    ce = ce + 1
                if first_s < 0:
                    first_s = cast[int32](cs)
                    first_e = cast[int32](ce)
                if _has_word(ne, je, cast[Ptr[uint8]]("selected")) != 0:
                    n: int32 = 0
                    p: uint64 = cs
                    while p < ce and n < 511:
                        fbuf[n] = src_ptr[p]
                        n = n + 1
                        p = p + 1
                    fbuf[n] = 0
                    return n
        i = i + 1
    if first_s >= 0:
        n2: int32 = 0
        p2: uint64 = cast[uint64](first_s)
        while p2 < cast[uint64](first_e) and n2 < 511:
            fbuf[n2] = src_ptr[p2]
            n2 = n2 + 1
            p2 = p2 + 1
        fbuf[n2] = 0
        return n2
    fbuf[0] = 0
    return 0


# Index (0-based) of a <select>'s selected option, scanning from body0.
# The option carrying `selected`, else 0 (the first).
def _select_index(body0: uint64) -> int32:
    i: uint64 = body0
    idx: int32 = -1
    sel: int32 = -1
    while i < src_len:
        if src_ptr[i] == 60:                          # '<'
            if i + 1 < src_len and src_ptr[i + 1] == 47 and \
               _tagname_is(i + 2, cast[Ptr[uint8]]("select")) != 0:
                break
            if _tagname_is(i + 1, cast[Ptr[uint8]]("option")) != 0:
                idx = idx + 1
                je: uint64 = i + 1
                while je < src_len and src_ptr[je] != 62:
                    je = je + 1
                if _has_word(i + 1, je, cast[Ptr[uint8]]("selected")) != 0 and \
                   sel < 0:
                    sel = idx
        i = i + 1
    if sel >= 0:
        return sel
    return 0


def _handle_tag(ts: uint64, te: uint64):
    if ts >= te:
        return
    # comment / doctype / processing — ignore.
    if src_ptr[ts] == 33 or src_ptr[ts] == 63:       # '!' or '?'
        return
    is_close: int32 = 0
    np: uint64 = ts
    if src_ptr[np] == 47:                            # '/'
        is_close = 1
        np = np + 1
    # tag name end (letters/digits)
    ne: uint64 = np
    while ne < te:
        c: uint8 = src_ptr[ne]
        if (c >= 97 and c <= 122) or (c >= 65 and c <= 90) or \
           (c >= 48 and c <= 57):
            ne = ne + 1
        else:
            break
    nlen: uint64 = ne - np
    if nlen == 0:
        return

    # script/style/head/title: drop their content from the render flow.
    # NOTE: <style> is still consumed for the render (its rules were already
    # harvested by _collect_css() before layout). <script> execution now happens
    # BEFORE layout in _run_scripts() (see the "JAVASCRIPT + minimal DOM"
    # section): every script body is js_eval'd against a shared context + a
    # `document` DOM binding, and any DOM the scripts mutate is baked into a
    # rewritten source that this layout pass then consumes. Here we simply drop
    # the <script> text from the RENDER flow so page text is not polluted by
    # code (its behaviour already ran).
    if is_close == 0:
        if _name_eq(np, nlen, cast[Ptr[uint8]]("script")) != 0 or \
           _name_eq(np, nlen, cast[Ptr[uint8]]("style")) != 0 or \
           _name_eq(np, nlen, cast[Ptr[uint8]]("head")) != 0 or \
           _name_eq(np, nlen, cast[Ptr[uint8]]("title")) != 0:
            _word_flush()
            _enter_skip(np, nlen)
            return

    # ---- element stack (for descendant selectors) + display:none ----
    # Void elements never open a scope; everything else is tracked so the CSS
    # cascade can match .class / #id / descendant selectors against ancestors.
    is_void: int32 = 0
    if _name_eq(np, nlen, cast[Ptr[uint8]]("br")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("hr")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("img")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("input")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("meta")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("link")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("area")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("col")) != 0:
        is_void = 1
    if is_close == 0:
        if is_void == 0:
            _el_push(np, nlen, ne, te)
            _cascade_match_current()
            if _is_display_none(ne, te) != 0:
                _el_pop(np, nlen)
                _word_flush()
                _enter_skip(np, nlen)
                return
    else:
        if is_void == 0:
            _el_pop(np, nlen)

    if _name_eq(np, nlen, cast[Ptr[uint8]]("br")) != 0:
        _word_flush()
        _newline()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("hr")) != 0:
        # A horizontal rule owns its own otherwise-empty visual row.
        _word_flush()
        _soft_newline()
        if cur_row < MAX_ROWS:
            row_rule[cur_row] = 2                     # 2 = <hr> full-width rule
        _bump_row()
        pen_x = indent_x
        row_dirty = 0
        need_space = 0
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("blockquote")) != 0:
        _word_flush()
        if is_close == 0:
            _soft_newline()
            bq_depth = bq_depth + 1
            _recompute_indent()
            # UA default: quoted text renders in a muted grey (author style can
            # still override — _open_style pushes on top of this default).
            _color_push(0x5a5a5a)
            _open_style(ne, te)
        else:
            if bq_depth > 0:
                bq_depth = bq_depth - 1
            _recompute_indent()
            _close_style()
            _color_pop()
            _para_break()
        pen_x = indent_x
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("span")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("font")) != 0:
        # Inline colour-bearing element: no layout effect, only colour(s).
        _word_flush()
        if is_close == 0:
            _open_style(ne, te)
        else:
            _close_style()
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("p")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("div")) != 0:
        _word_flush()
        if is_close == 0:
            _soft_newline()
            _open_style(ne, te)              # runs cascade (m_*) + inline (d_*)
            # merge the box model: inline wins over the stylesheet per axis.
            fleft: int32 = 0
            if m_ml >= 0:
                fleft = m_ml
            if d_ml >= 0:
                fleft = d_ml
            frins: int32 = 0
            if m_mr >= 0:
                frins = m_mr
            if d_mr >= 0:
                frins = d_mr
            fwd: int32 = -1
            if m_wd >= 0:
                fwd = m_wd
            if d_wd >= 0:
                fwd = d_wd
            ftop: int32 = 0
            if m_mt >= 0:
                ftop = m_mt
            if d_mt >= 0:
                ftop = d_mt
            fbot: int32 = 0
            if m_mb >= 0:
                fbot = m_mb
            if d_mb >= 0:
                fbot = d_mb
            fbord: int32 = 0
            if m_bd >= 0:
                fbord = m_bd
            if d_bd >= 0:
                fbord = d_bd
            _block_box_open(fleft, frins, fwd, ftop, fbot, fbord)
        else:
            _block_box_close()
            _close_style()
            _para_break()
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("h1")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("h2")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("h3")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("h4")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("h5")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("h6")) != 0:
        _word_flush()
        lvl: int32 = cast[int32](src_ptr[np + 1] - 48)
        if is_close == 0:
            _soft_newline()
            # UA-stylesheet section spacing: a top-level heading gets extra air
            # above it so sections breathe (like a browser's larger heading
            # margins). Suppressed at the very top of the document (no leading
            # blank), and only for h1/h2/h3 so deep sub-headings stay tight.
            if cur_row > 0 and lvl <= 3:
                _bump_row()
            g_heading = lvl
            _open_style(ne, te)
            _style_break()
        else:
            # rule under the heading's last content row, then a gap
            hr: uint64 = cur_row
            if row_dirty != 0 and lvl <= 2 and hr < MAX_ROWS:
                row_rule[hr] = 1
            g_heading = 0
            _close_style()
            _style_break()
            _para_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("b")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("strong")) != 0:
        _word_flush()
        if is_close == 0:
            g_bold_n = g_bold_n + 1
        else:
            if g_bold_n > 0:
                g_bold_n = g_bold_n - 1
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("i")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("em")) != 0:
        # parsed but rendered plain (no italic glyph set) — strip the tag.
        _word_flush()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("img")) != 0:
        # No pixel decode yet (a later rung): render an inline alt-text
        # placeholder "[alt]" (or "[img]" when no alt), which participates in
        # the normal word flow so it wraps like text.
        if is_close != 0:
            return
        _word_flush()
        _word_push(91)                               # '['
        if _find_attr(ne, te, cast[Ptr[uint8]]("alt")) != 0 and \
           g_attr_end > g_attr_start:
            p: uint64 = g_attr_start
            while p < g_attr_end:
                c: uint8 = src_ptr[p]
                if c == 32 or c == 9 or c == 10 or c == 13:
                    _word_flush()                    # word gap inside the alt
                    need_space = 1
                else:
                    _word_push(c)
                p = p + 1
        else:
            _word_push(105)                          # 'i'
            _word_push(109)                          # 'm'
            _word_push(103)                          # 'g'
        _word_push(93)                               # ']'
        _word_flush()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("a")) != 0:
        _word_flush()
        if is_close == 0:
            lid: int32 = _capture_href(ne, te)
            g_link = lid
            _open_style(ne, te)
        else:
            g_link = -1
            _close_style()
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("ul")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("ol")) != 0:
        is_ol: int32 = _name_eq(np, nlen, cast[Ptr[uint8]]("ol"))
        _word_flush()
        if is_close == 0:
            _soft_newline()
            if list_depth < MAX_LIST_DEPTH:
                list_type[list_depth] = is_ol
                # <ol start="N"> seeds the counter (default 1).
                start_n: int32 = 1
                if is_ol != 0 and \
                   _find_attr(ne, te, cast[Ptr[uint8]]("start")) != 0 and \
                   g_attr_end > g_attr_start:
                    v: int32 = 0
                    p: uint64 = g_attr_start
                    while p < g_attr_end:
                        d: uint8 = src_ptr[p]
                        if d >= 48 and d <= 57:
                            v = v * 10 + cast[int32](d - 48)
                        p = p + 1
                    if v > 0:
                        start_n = v
                list_count[list_depth] = start_n
            list_depth = list_depth + 1
        else:
            if list_depth > 0:
                list_depth = list_depth - 1
            _para_break()
        _recompute_indent()
        pen_x = indent_x
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("li")) != 0:
        _word_flush()
        if is_close == 0:
            _soft_newline()
            _recompute_indent()
            # Marker hangs in this level's gutter [indent_x - LIST_STEP,
            # indent_x); the item text then flows at indent_x so wrapped
            # continuation lines align under the text (hanging indent).
            lvl: int32 = list_depth - 1
            gutter_x: int32 = indent_x - LIST_STEP
            if gutter_x < _left_margin():
                gutter_x = _left_margin()
            pen_x = gutter_x
            if lvl >= 0 and lvl < MAX_LIST_DEPTH and list_type[lvl] != 0:
                # Ordered list: render the running number then '.'.
                num: int32 = list_count[lvl]
                list_count[lvl] = num + 1
                _seg_putc_dec(num)
                _seg_putc(46)                        # '.'
            else:
                # Unordered list: a bullet marker.
                _seg_putc(45)                        # '-'
            _close_seg()                             # marker is its own segment
            pen_x = indent_x                         # item text hangs here
            row_dirty = 1
            need_space = 0
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("pre")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("code")) != 0:
        is_pre: int32 = _name_eq(np, nlen, cast[Ptr[uint8]]("pre"))
        _word_flush()
        if is_pre != 0:
            if is_close == 0:
                _soft_newline()
                pre_mode = 1
                _bg_push(CODE_BG)              # light code-block background
            else:
                _bg_pop()
                pre_mode = 0
                _para_break()
        else:
            # inline <code>: teal monospace tint on a light code background so
            # inline code stands out from body text (UA default).
            if is_close == 0:
                _color_push(0x0a6b5a)
                _bg_push(CODE_BG)
                g_mono_n = g_mono_n + 1
            else:
                _bg_pop()
                _color_pop()
                if g_mono_n > 0:
                    g_mono_n = g_mono_n - 1
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("table")) != 0:
        _word_flush()
        if is_close == 0:
            _cell_close()
            _soft_newline()
            rgn_start: uint64 = te + 1
            rgn_end: uint64 = _table_region_end(rgn_start)
            _measure_table(rgn_start, rgn_end)
            _compute_cols()
            table_active = 1
            cur_col = 0
            cell_active = 0
            _open_style(ne, te)
        else:
            _cell_close()
            table_active = 0
            _close_style()
            _recompute_indent()
            pen_x = indent_x
            _para_break()
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("tr")) != 0:
        _word_flush()
        if table_active != 0:
            _cell_close()
            if is_close == 0:
                _soft_newline()
                cur_col = 0
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("td")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("th")) != 0:
        is_th: int32 = _name_eq(np, nlen, cast[Ptr[uint8]]("th"))
        _word_flush()
        if table_active == 0:
            return
        _cell_close()                         # close the previous cell first
        if is_close != 0:
            return
        cc: int32 = cur_col
        if cc >= n_cols:
            cc = n_cols - 1
        if cc < 0:
            cc = 0
        # colspan: the cell spans [cc, cc+span); its right edge is the LEFT
        # edge of the first column past the span, so its text flows across
        # the whole spanned width.
        span: int32 = _attr_int(ne, te, cast[Ptr[uint8]]("colspan"), 1)
        endc: int32 = cc + span
        if endc > n_cols:
            endc = n_cols
        indent_x = col_x[cc]
        pen_x = col_x[cc]
        cell_right = col_x[endc] - CELL_PAD * CELL_W
        cell_active = 1
        cell_is_th = is_th
        need_space = 0
        row_dirty = 1                         # the cell's row is now occupied
        _open_style(ne, te)
        if is_th != 0:
            g_bold_n = g_bold_n + 1
        cur_col = endc
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("input")) != 0:
        if is_close != 0:
            return
        _emit_input(ne, te)
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("textarea")) != 0:
        _word_flush()
        if is_close == 0:
            # Draw the textarea's current content as a single-line box, then
            # skip the literal content so it is not also rendered as flow text.
            _word_push(91)                            # '['
            cs: uint64 = te + 1
            ce: uint64 = cs
            while ce < src_len:
                if src_ptr[ce] == 60 and ce + 1 < src_len and \
                   src_ptr[ce + 1] == 47 and \
                   _tagname_is(ce + 2, cast[Ptr[uint8]]("textarea")) != 0:
                    break
                ce = ce + 1
            ilen: int32 = 0
            p: uint64 = cs
            while p < ce:
                c2: uint8 = src_ptr[p]
                if c2 == 10 or c2 == 13 or c2 == 9:
                    c2 = 32
                _word_push(c2)
                ilen = ilen + 1
                p = p + 1
            while ilen < 8:
                _word_push(95)                        # '_'
                ilen = ilen + 1
            _word_push(93)                            # ']'
            _word_flush()
            # The close </textarea> is consumed by skip mode (never reaches
            # _handle_tag), so pop the scope we pushed at the top to keep the
            # element stack balanced.
            _el_pop(np, nlen)
            _enter_skip(np, nlen)
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("button")) != 0:
        _word_flush()
        if is_close == 0:
            _word_push(91)                            # '['
            _word_push(32)
            _word_flush()
            need_space = 0
        else:
            _word_push(32)
            _word_push(93)                            # ']'
            _word_flush()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("select")) != 0:
        _word_flush()
        if is_close == 0:
            _word_push(91)                            # '['
            _word_push(32)
            sn: int32 = _select_text(te + 1)
            if sn > 0:
                _wpush_cstr(&fbuf[0])
            _word_push(32)
            _word_push(118)                           # 'v'
            _word_push(93)                            # ']'
            _word_flush()
            _el_pop(np, nlen)                          # balance the pushed scope
            _enter_skip(np, nlen)
        return
    # <option>/<label>/<form>/<fieldset>/<legend>: no direct box — options are
    # consumed by <select>; label/form/fieldset are transparent containers whose
    # inner text flows normally (handled by the unknown-tag fallthrough).
    # Unknown tag: ignore it, keep surrounding text.
    return


# ====================================================================
# LAYOUT — parse src_ptr/src_len into segments.
# ====================================================================
def _reset_layout():
    n_segs = 0
    seg_text_len = 0
    n_links = 0
    link_href_len = 0
    cur_row = 0
    pen_x = _left_margin()
    indent_x = _left_margin()
    row_dirty = 0
    need_space = 0
    seg_open = 0
    seg_curlen = 0
    g_color = 0
    g_bold = 0
    g_uline = 0
    g_link = -1
    g_bold_n = 0
    g_mono_n = 0
    g_heading = 0
    list_depth = 0
    bq_depth = 0
    blk_indent_sp = 0
    blk_indent_sum = 0
    blk_right_sp = 0
    blk_right_cur = _content_right()
    box_sp = 0
    table_active = 0
    cell_active = 0
    cell_is_th = 0
    cur_col = 0
    n_cols = 0
    pre_mode = 0
    skip_active = 0
    skip_nlen = 0
    word_len = 0
    top_line = 0
    color_sp = 0
    g_rgb = -1
    bg_sp = 0
    g_bg = -1
    el_sp = 0
    el_slen = 0
    weight_sp = 0
    g_css_bold = 0
    fontpx_sp = 0
    g_font_px = 0
    align_sp = 0
    g_align = 0
    r: uint64 = 0
    while r < MAX_ROWS:
        row_rule[r] = 0
        row_align[r] = 0
        r = r + 1


# Post-layout pass: shift each row's segments for text-align center/right.
def _apply_alignment():
    right: int32 = _content_right()
    r: uint64 = 0
    while r < total_rows:
        a: uint8 = row_align[r]
        if a == 2 or a == 3:
            minx: int32 = 0x7fffffff
            maxr: int32 = -1
            si: uint64 = 0
            while si < n_segs:
                if cast[uint64](seg_line[si]) == r:
                    x0: int32 = seg_x[si]
                    x1: int32 = x0 + seg_len[si] * CELL_W
                    if x0 < minx:
                        minx = x0
                    if x1 > maxr:
                        maxr = x1
                si = si + 1
            if maxr >= 0:
                shift: int32 = 0
                if a == 2:                            # center in [left,right]
                    width: int32 = maxr - minx
                    lm: int32 = _left_margin()
                    newmin: int32 = lm + (right - lm - width) / 2
                    shift = newmin - minx
                else:                                 # right-align
                    shift = right - maxr
                if shift > 0:
                    si2: uint64 = 0
                    while si2 < n_segs:
                        if cast[uint64](seg_line[si2]) == r:
                            seg_x[si2] = seg_x[si2] + shift
                        si2 = si2 + 1
        r = r + 1


def _layout():
    _collect_css()
    _reset_layout()
    i: uint64 = 0
    while i < src_len:
        c: uint8 = src_ptr[i]
        if skip_active != 0:
            if c == 60:                              # '<'
                if i + 1 < src_len and src_ptr[i + 1] == 47:     # '</'
                    if _name_eq(i + 2, skip_nlen, &skip_name[0]) != 0:
                        skip_active = 0
                # advance past '>'
                while i < src_len and src_ptr[i] != 62:
                    i = i + 1
                if i < src_len:
                    i = i + 1
                continue
            i = i + 1
            continue
        if c == 60:                                  # '<'
            ts: uint64 = i + 1
            j: uint64 = ts
            while j < src_len and src_ptr[j] != 62:
                j = j + 1
            _word_flush()
            _handle_tag(ts, j)
            if j < src_len:
                i = j + 1
            else:
                i = j
            continue
        if c == 38:                                  # '&'
            consumed: uint64 = _entity(i)
            if consumed > 0:
                k: int32 = 0
                while k < g_ent_len:
                    _word_push(g_ent_buf[k])
                    k = k + 1
                i = i + consumed
                continue
            _word_push(38)
            i = i + 1
            continue
        if pre_mode == 0:
            if c == 32 or c == 9 or c == 10 or c == 13:
                _word_flush()
                need_space = 1
                i = i + 1
                continue
            _word_push(c)
            i = i + 1
            continue
        # preformatted: preserve whitespace, honor newlines.
        if c == 10:
            _word_flush()
            _newline()
            i = i + 1
            continue
        if c == 13:
            i = i + 1
            continue
        if c == 9:
            _word_push(32)
            _word_push(32)
            i = i + 1
            continue
        _word_push(c)
        i = i + 1
    _word_flush()
    _close_seg()
    total_rows = cur_row + 1
    _apply_alignment()


# ====================================================================
# JAVASCRIPT + minimal DOM.
#
# At layout time we run every <script> body through lib/jsengine.ad (js_eval),
# sharing ONE JS context across a page's scripts so later scripts see earlier
# globals. A minimal DOM is exposed to those scripts through jsengine's
# host-object seam (js_set_host_dispatch + the value constructors) — NO edits
# to the engine. `document.getElementById(id)` returns a plain JS object whose
# `textContent`, `style.color`, and `style.display` are ordinary data
# properties; the script mutates them with normal assignment. After all scripts
# finish we READ those properties back and, for every element the script
# actually changed, record an override. If any override exists we rebuild a
# copy of the source HTML with the overrides baked in (replaced text, an inline
# colour wrapper, or a hidden element dropped) and lay THAT out — so the visual
# result reflects the JS. Pages with no <script> skip all of this and lay out
# the original source byte-for-byte (zero behavioural change, zero jsengine
# touch — which also sidesteps the native float-division #DE, task #51).
# ====================================================================
DOM_MAX:     int32  = 64
DOM_ID_CAP:  int32  = 4096
DOM_TXT_CAP: int32  = 65536
DOM_OV_CAP:  int32  = 65536

dom_idbuf:   Array[4096, uint8]      # concatenated element ids (case-sensitive)
dom_idbuf_len: int32 = 0
dom_id_off:  Array[64, int32]
dom_id_len:  Array[64, int32]
dom_obj:     Array[64, int32]        # JS object value-handle per element
dom_anchor:  Array[64, int32]        # source offset of the element's '<' (-1 = none)
dom_cstart:  Array[64, int32]        # inner-content span in the source
dom_cend:    Array[64, int32]
dom_ns:      Array[64, int32]        # tag-name span in the source
dom_nl:      Array[64, int32]
dom_orig_off: Array[64, int32]       # original textContent (in dom_txtbuf)
dom_orig_len: Array[64, int32]
dom_html_off: Array[64, int32]       # original innerHTML (raw markup, in dom_txtbuf)
dom_html_len: Array[64, int32]
dom_origcls_off: Array[64, int32]    # original class attribute value
dom_origcls_len: Array[64, int32]
dom_txtbuf:  Array[65536, uint8]
dom_txt_len: int32 = 0
dom_n:       int32 = 0

# event handlers (parallel to 0..dom_n)
dom_onclick_fn:  Array[64, int32]    # stored JS function value, or -1
dom_onclick_src: Array[64, int32]    # inline onclick="..." source off, or -1
dom_onclick_srclen: Array[64, int32]
dom_oninput_fn:  Array[64, int32]    # oninput handler fn value, or -1
dom_oninput_src: Array[64, int32]
dom_oninput_srclen: Array[64, int32]
dom_onchange_fn: Array[64, int32]    # onchange handler fn value, or -1
dom_onchange_src: Array[64, int32]
dom_onchange_srclen: Array[64, int32]
dom_onsubmit_fn: Array[64, int32]    # onsubmit handler fn value, or -1 (forms)
dom_onsubmit_src: Array[64, int32]
dom_onsubmit_srclen: Array[64, int32]

# form-control metadata (parallel to 0..dom_n). dom_kind: 0 generic, 1 input,
# 2 textarea, 3 select, 4 button, 5 form.
dom_kind:      Array[64, int32]
dom_origval_off: Array[64, int32]    # original value (input/textarea/select)
dom_origval_len: Array[64, int32]
dom_origchecked: Array[64, int32]    # original checked state (0/1), else -1

# resolved form overrides (parallel to 0..dom_n). off/len/flag == -1 = unset.
dom_ov_val_off:  Array[64, int32]    # replacement value string
dom_ov_val_len:  Array[64, int32]
dom_ov_checked:  Array[64, int32]    # 1 checked, 0 unchecked, -1 unchanged

# form submission serialization result ("?a=1&b=2"), + last-navigated URL.
dom_nav_buf:  Array[2048, uint8]
dom_nav_len:  int32 = 0
dom_nav_present: int32 = 0
g_prevent_default: int32 = 0         # set by event.preventDefault() in a handler
g_nmtmp: Array[128, uint8]           # scratch for a field name during serialize

# appended created children: flat (parent-idx, created-node-id) records.
APPEND_MAX:  int32 = 128
ap_parent:   Array[128, int32]
ap_child:    Array[128, int32]
ap_n:        int32 = 0

# createElement nodes (not in source): a tag + a JS object we read back.
CRE_MAX:     int32 = 64
cre_obj:     Array[64, int32]
cre_tag_off: Array[64, int32]        # tag name in dom_idbuf
cre_tag_len: Array[64, int32]
cre_n:       int32 = 0

# resolved overrides (parallel to 0..dom_n). off/len == -1 means "not set".
dom_ov_inner_off: Array[64, int32]   # replacement inner (text OR html)
dom_ov_inner_len: Array[64, int32]
dom_ov_inner_html: Array[64, int32]  # 1 = emit raw (innerHTML), 0 = escape (textContent)
dom_ov_col_off:  Array[64, int32]    # colour (raw CSS value)
dom_ov_col_len:  Array[64, int32]
dom_ov_bg_off:   Array[64, int32]    # background-color
dom_ov_bg_len:   Array[64, int32]
dom_ov_wt_off:   Array[64, int32]    # font-weight
dom_ov_wt_len:   Array[64, int32]
dom_ov_al_off:   Array[64, int32]    # text-align
dom_ov_al_len:   Array[64, int32]
dom_ov_cls_off:  Array[64, int32]    # className
dom_ov_cls_len:  Array[64, int32]
dom_ov_hide:     Array[64, int32]    # 1 = display:none (drop the element)
dom_ovbuf:   Array[65536, uint8]
dom_ov_len:  int32 = 0
dom_n_overrides: int32 = 0           # count of elements with ANY override

dom_title_buf: Array[256, uint8]
dom_title_len: int32 = 0
dom_title_present: int32 = 0

js_con_buf:  Array[8192, uint8]      # captured console.log output
js_con_len:  int32 = 0
js_had_error: int32 = 0
js_ctx_live: int32 = 0               # a persistent JS context exists this render
he_click_links: int32 = 0           # native: wrap handler elements in #__evt_N links

# rewritten source (only built when overrides exist)
RW_CAP:  uint64 = 262144
rw_buf:  Array[262144, uint8]
rw_len:  uint64 = 0

js_hbase: int32 = 0
js_doc:   int32 = 0
dom_idtmp: Array[256, uint8]

# native method ids (offsets from js_host_base()).
NID_GETBYID:  int32 = 0
NID_CREATE:   int32 = 1
NID_ADDEVT:   int32 = 2
NID_APPEND:   int32 = 3
NID_GETATTR:  int32 = 4
NID_SETATTR:  int32 = 5
NID_QUERY:    int32 = 6
NID_PREVENT:  int32 = 7               # event.preventDefault()

# close-tag scan results
g_close_lt:  uint64 = 0
g_close_end: uint64 = 0
# element-scan results: anchor '<', content span, tag-name span
g_el_lt: uint64 = 0
g_el_cs: uint64 = 0
g_el_ce: uint64 = 0
g_el_ns: uint64 = 0
g_el_nl: uint64 = 0


def _dom_reset():
    dom_n = 0
    dom_idbuf_len = 0
    dom_txt_len = 0
    dom_ov_len = 0
    dom_n_overrides = 0
    dom_title_len = 0
    dom_title_present = 0
    js_con_len = 0
    js_had_error = 0
    js_ctx_live = 0
    ap_n = 0
    cre_n = 0
    rw_len = 0
    dom_nav_len = 0
    dom_nav_present = 0
    g_prevent_default = 0


def _cstr_len(p: Ptr[uint8]) -> int32:
    n: int32 = 0
    while p[n] != 0:
        n = n + 1
    return n


def _bytes_eq(a: Ptr[uint8], an: int32, b: Ptr[uint8], bn: int32) -> int32:
    if an != bn:
        return 0
    i: int32 = 0
    while i < an:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# compare a src span [a,b) to a byte string idp[0..idn), case-insensitive.
def _idbytes_eq(a: uint64, b: uint64, idp: Ptr[uint8], idn: int32) -> int32:
    if cast[int32](b - a) != idn:
        return 0
    i: int32 = 0
    while i < idn:
        if _lower(src_ptr[a + cast[uint64](i)]) != _lower(idp[i]):
            return 0
        i = i + 1
    return 1


# does the tag name at src[at] equal the src name span [ns, ns+nl), bounded?
def _srcname_eq(at: uint64, ns: uint64, nl: uint64) -> int32:
    k: uint64 = 0
    while k < nl:
        if at + k >= src_len:
            return 0
        if _lower(src_ptr[at + k]) != _lower(src_ptr[ns + k]):
            return 0
        k = k + 1
    if _alnum_at(at + nl) != 0:
        return 0
    return 1


# Find the matching close tag </name> for an element opened with tag name
# span [ns, ns+nl), scanning from `from`. Sets g_close_lt (the '<' of the
# close tag) and g_close_end (index just past its '>'). Returns 1 if a close
# tag was found; on miss both are set to `from` (empty content, no close).
def _find_close(ns: uint64, nl: uint64, frm: uint64) -> int32:
    depth: int32 = 0
    i: uint64 = frm
    while i < src_len:
        if src_ptr[i] == 60:                              # '<'
            if i + 1 < src_len and src_ptr[i + 1] == 47:  # '</'
                if _srcname_eq(i + 2, ns, nl) != 0:
                    if depth == 0:
                        g_close_lt = i
                        j: uint64 = i
                        while j < src_len and src_ptr[j] != 62:
                            j = j + 1
                        if j < src_len:
                            j = j + 1
                        g_close_end = j
                        return 1
                    depth = depth - 1
            elif src_ptr[i + 1] != 33 and src_ptr[i + 1] != 63:
                if _srcname_eq(i + 1, ns, nl) != 0:
                    depth = depth + 1
        i = i + 1
    g_close_lt = frm
    g_close_end = frm
    return 0


# Extract the text content of src span [cs,ce) (tags stripped) into out[oo..].
# Returns the number of bytes written.
def _extract_text(cs: uint64, ce: uint64, oo: int32) -> int32:
    n: int32 = 0
    i: uint64 = cs
    while i < ce:
        c: uint8 = src_ptr[i]
        if c == 60:                                       # '<' — skip a tag
            while i < ce and src_ptr[i] != 62:
                i = i + 1
            if i < ce:
                i = i + 1
            continue
        if oo + n < DOM_TXT_CAP:
            dom_txtbuf[oo + n] = c
            n = n + 1
        i = i + 1
    return n


# Copy the RAW markup of src span [cs,ce) into out[oo..] (innerHTML).
def _extract_html(cs: uint64, ce: uint64, oo: int32) -> int32:
    n: int32 = 0
    i: uint64 = cs
    while i < ce:
        if oo + n < DOM_TXT_CAP:
            dom_txtbuf[oo + n] = src_ptr[i]
            n = n + 1
        i = i + 1
    return n


# Scan a start tag at src[i]=='<'. Sets g_el_lt/cs/ce/ns/nl for the element
# and returns 1; caller has already checked src[i]=='<' + not close/comment.
def _scan_start_tag(i: uint64) -> int32:
    ts: uint64 = i + 1
    je: uint64 = ts
    while je < src_len and src_ptr[je] != 62:
        je = je + 1
    ne: uint64 = ts
    while ne < je and _alnum_at(ne) != 0:
        ne = ne + 1
    _find_close(ts, ne - ts, je + 1)
    g_el_lt = i
    g_el_ns = ts
    g_el_nl = ne - ts
    g_el_cs = je + 1
    g_el_ce = g_close_lt
    return 1


# Locate the FIRST element whose id attribute equals idp[0..idn). Sets the
# g_el_* element globals and returns 1 on a hit.
def _dom_find_by_id(idp: Ptr[uint8], idn: int32) -> int32:
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           src_ptr[i + 1] != 47 and src_ptr[i + 1] != 33 and \
           src_ptr[i + 1] != 63:
            ts: uint64 = i + 1
            je: uint64 = ts
            while je < src_len and src_ptr[je] != 62:
                je = je + 1
            if _find_attr(ts, je, cast[Ptr[uint8]]("id")) != 0:
                if _idbytes_eq(g_attr_start, g_attr_end, idp, idn) != 0:
                    return _scan_start_tag(i)
            i = je
        i = i + 1
    return 0


# Does class-attr span [a,b) contain the whitespace-delimited token tok[0..tn)?
def _cls_has_token(a: uint64, b: uint64, tok: Ptr[uint8], tn: int32) -> int32:
    i: uint64 = a
    while i < b:
        while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9):
            i = i + 1
        s: uint64 = i
        while i < b and src_ptr[i] != 32 and src_ptr[i] != 9:
            i = i + 1
        if _idbytes_eq(s, i, tok, tn) != 0:
            return 1
    return 0


# Locate the first element matching a simple selector: '#id', '.class', or a
# bare 'tag'. Sets the g_el_* globals; returns 1 on a hit.
def _dom_find_selector(sel: Ptr[uint8], seln: int32) -> int32:
    if seln == 0:
        return 0
    kind: uint8 = sel[0]
    if kind == 35:                                        # '#id'
        return _dom_find_by_id(&sel[1], seln - 1)
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           src_ptr[i + 1] != 47 and src_ptr[i + 1] != 33 and \
           src_ptr[i + 1] != 63:
            ts: uint64 = i + 1
            je: uint64 = ts
            while je < src_len and src_ptr[je] != 62:
                je = je + 1
            ne: uint64 = ts
            while ne < je and _alnum_at(ne) != 0:
                ne = ne + 1
            hit: int32 = 0
            if kind == 46:                                # '.class'
                if _find_attr(ts, je, cast[Ptr[uint8]]("class")) != 0:
                    if _cls_has_token(g_attr_start, g_attr_end, \
                                      &sel[1], seln - 1) != 0:
                        hit = 1
            else:                                         # bare tag
                if _idbytes_eq(ts, ne, sel, seln) != 0:
                    hit = 1
            if hit != 0:
                return _scan_start_tag(i)
            i = je
        i = i + 1
    return 0


def _dom_lookup_anchor(off: int32) -> int32:
    e: int32 = 0
    while e < dom_n:
        if dom_anchor[e] == off:
            return e
        e = e + 1
    return -1


def _dom_lookup_id(idp: Ptr[uint8], idn: int32) -> int32:
    e: int32 = 0
    while e < dom_n:
        if _bytes_eq(&dom_idbuf[dom_id_off[e]], dom_id_len[e], idp, idn) != 0:
            return e
        e = e + 1
    return -1


def _find_el_by_obj(objv: int32) -> int32:
    e: int32 = 0
    while e < dom_n:
        if dom_obj[e] == objv:
            return e
        e = e + 1
    return -1


def _find_cre_by_obj(objv: int32) -> int32:
    e: int32 = 0
    while e < cre_n:
        if cre_obj[e] == objv:
            return e
        e = e + 1
    return -1


# Build a fresh JS style object with the mutable props we honour, all "".
def _new_style_obj() -> int32:
    st: int32 = js_new_object_v()
    js_set_prop(st, cast[Ptr[uint8]]("color"), 5, js_new_string(&dom_txtbuf[0], 0))
    js_set_prop(st, cast[Ptr[uint8]]("backgroundColor"), 15, \
                js_new_string(&dom_txtbuf[0], 0))
    js_set_prop(st, cast[Ptr[uint8]]("fontWeight"), 10, \
                js_new_string(&dom_txtbuf[0], 0))
    js_set_prop(st, cast[Ptr[uint8]]("textAlign"), 9, \
                js_new_string(&dom_txtbuf[0], 0))
    js_set_prop(st, cast[Ptr[uint8]]("display"), 7, \
                js_new_string(&dom_txtbuf[0], 0))
    return st


# Attach the element-level native methods to a DOM element object.
def _attach_el_methods(o: int32):
    js_set_prop(o, cast[Ptr[uint8]]("addEventListener"), 16, \
                js_new_native_fn(js_hbase + NID_ADDEVT))
    js_set_prop(o, cast[Ptr[uint8]]("appendChild"), 11, \
                js_new_native_fn(js_hbase + NID_APPEND))
    js_set_prop(o, cast[Ptr[uint8]]("getAttribute"), 12, \
                js_new_native_fn(js_hbase + NID_GETATTR))
    js_set_prop(o, cast[Ptr[uint8]]("setAttribute"), 12, \
                js_new_native_fn(js_hbase + NID_SETATTR))


# Capture an inline event-handler attribute (onclick=/oninput=/...) source into
# dom_txtbuf. Sets g_ih_off (dom_txtbuf offset, -1 if absent) and g_ih_len.
g_ih_off: int32 = 0
g_ih_len: int32 = 0


def _idbuf_push_cstr(s: Ptr[uint8]):
    i: int32 = 0
    while s[i] != 0 and dom_idbuf_len < DOM_ID_CAP:
        dom_idbuf[dom_idbuf_len] = s[i]
        dom_idbuf_len = dom_idbuf_len + 1
        i = i + 1


def _capture_inline(te: uint64, name: Ptr[uint8]):
    g_ih_off = -1
    g_ih_len = 0
    if _find_attr(g_el_ns, te, name) != 0:
        os: int32 = dom_txt_len
        p: uint64 = g_attr_start
        osl: int32 = 0
        while p < g_attr_end and dom_txt_len < DOM_TXT_CAP:
            dom_txtbuf[dom_txt_len] = src_ptr[p]
            dom_txt_len = dom_txt_len + 1
            osl = osl + 1
            p = p + 1
        g_ih_off = os
        g_ih_len = osl


# Classify the current g_el_* element by tag name into a dom_kind code.
def _kind_of(ns: uint64, nl: int32) -> int32:
    if _idbytes_eq(ns, ns + cast[uint64](nl), cast[Ptr[uint8]]("input"), 5) != 0:
        return 1
    if _idbytes_eq(ns, ns + cast[uint64](nl), cast[Ptr[uint8]]("textarea"), 8) != 0:
        return 2
    if _idbytes_eq(ns, ns + cast[uint64](nl), cast[Ptr[uint8]]("select"), 6) != 0:
        return 3
    if _idbytes_eq(ns, ns + cast[uint64](nl), cast[Ptr[uint8]]("button"), 6) != 0:
        return 4
    if _idbytes_eq(ns, ns + cast[uint64](nl), cast[Ptr[uint8]]("form"), 4) != 0:
        return 5
    return 0


# Register (or return the existing record for) the element described by the
# current g_el_* globals. Returns its JS object value-handle.
def _dom_register_el() -> int32:
    anchor: int32 = cast[int32](g_el_lt)
    ex: int32 = _dom_lookup_anchor(anchor)
    if ex >= 0:
        return dom_obj[ex]
    if dom_n >= DOM_MAX:
        return js_undefined()
    idx: int32 = dom_n
    dom_anchor[idx] = anchor
    dom_cstart[idx] = cast[int32](g_el_cs)
    dom_cend[idx] = cast[int32](g_el_ce)
    dom_ns[idx] = cast[int32](g_el_ns)
    dom_nl[idx] = cast[int32](g_el_nl)
    te: uint64 = g_el_cs - 1                              # the '>' of the start tag
    # original text + html
    ot: int32 = dom_txt_len
    otl: int32 = _extract_text(g_el_cs, g_el_ce, ot)
    dom_txt_len = ot + otl
    dom_orig_off[idx] = ot
    dom_orig_len[idx] = otl
    oh: int32 = dom_txt_len
    ohl: int32 = _extract_html(g_el_cs, g_el_ce, oh)
    dom_txt_len = oh + ohl
    dom_html_off[idx] = oh
    dom_html_len[idx] = ohl
    # id attribute
    ido: int32 = dom_idbuf_len
    idl: int32 = 0
    if _find_attr(g_el_ns, te, cast[Ptr[uint8]]("id")) != 0:
        p: uint64 = g_attr_start
        while p < g_attr_end and dom_idbuf_len < DOM_ID_CAP:
            dom_idbuf[dom_idbuf_len] = src_ptr[p]
            dom_idbuf_len = dom_idbuf_len + 1
            idl = idl + 1
            p = p + 1
    dom_id_off[idx] = ido
    dom_id_len[idx] = idl
    # class attribute (original)
    oc: int32 = dom_txt_len
    ocl: int32 = 0
    if _find_attr(g_el_ns, te, cast[Ptr[uint8]]("class")) != 0:
        p2: uint64 = g_attr_start
        while p2 < g_attr_end and dom_txt_len < DOM_TXT_CAP:
            dom_txtbuf[dom_txt_len] = src_ptr[p2]
            dom_txt_len = dom_txt_len + 1
            ocl = ocl + 1
            p2 = p2 + 1
    dom_origcls_off[idx] = oc
    dom_origcls_len[idx] = ocl
    # inline event-handler attributes (source stored; run on the event)
    dom_onclick_fn[idx] = -1
    _capture_inline(te, cast[Ptr[uint8]]("onclick"))
    dom_onclick_src[idx] = g_ih_off
    dom_onclick_srclen[idx] = g_ih_len
    dom_oninput_fn[idx] = -1
    _capture_inline(te, cast[Ptr[uint8]]("oninput"))
    dom_oninput_src[idx] = g_ih_off
    dom_oninput_srclen[idx] = g_ih_len
    dom_onchange_fn[idx] = -1
    _capture_inline(te, cast[Ptr[uint8]]("onchange"))
    dom_onchange_src[idx] = g_ih_off
    dom_onchange_srclen[idx] = g_ih_len
    dom_onsubmit_fn[idx] = -1
    _capture_inline(te, cast[Ptr[uint8]]("onsubmit"))
    dom_onsubmit_src[idx] = g_ih_off
    dom_onsubmit_srclen[idx] = g_ih_len
    # form-control metadata: kind, original value, original checked state.
    kind: int32 = _kind_of(g_el_ns, cast[int32](g_el_nl))
    dom_kind[idx] = kind
    dom_origchecked[idx] = -1
    ovo: int32 = dom_txt_len
    ovl: int32 = 0
    if kind == 2:                                        # textarea: value = text
        k: int32 = 0
        while k < otl and dom_txt_len < DOM_TXT_CAP:
            dom_txtbuf[dom_txt_len] = dom_txtbuf[ot + k]
            dom_txt_len = dom_txt_len + 1
            ovl = ovl + 1
            k = k + 1
    elif kind == 3:                                      # select: selected option
        sl: int32 = _select_text(g_el_cs)
        sk: int32 = 0
        while sk < sl and dom_txt_len < DOM_TXT_CAP:
            dom_txtbuf[dom_txt_len] = fbuf[sk]
            dom_txt_len = dom_txt_len + 1
            ovl = ovl + 1
            sk = sk + 1
    elif kind == 1:                                      # input: value attribute
        if _find_attr(g_el_ns, te, cast[Ptr[uint8]]("value")) != 0:
            pv: uint64 = g_attr_start
            while pv < g_attr_end and dom_txt_len < DOM_TXT_CAP:
                dom_txtbuf[dom_txt_len] = src_ptr[pv]
                dom_txt_len = dom_txt_len + 1
                ovl = ovl + 1
                pv = pv + 1
        if _input_type_is(g_el_ns, te, cast[Ptr[uint8]]("checkbox")) != 0 or \
           _input_type_is(g_el_ns, te, cast[Ptr[uint8]]("radio")) != 0:
            if _has_word(g_el_ns, te, cast[Ptr[uint8]]("checked")) != 0:
                dom_origchecked[idx] = 1
            else:
                dom_origchecked[idx] = 0
    dom_origval_off[idx] = ovo
    dom_origval_len[idx] = ovl
    # the JS object
    o: int32 = js_new_object_v()
    js_set_prop(o, cast[Ptr[uint8]]("textContent"), 11, \
                js_new_string(&dom_txtbuf[ot], cast[uint64](otl)))
    js_set_prop(o, cast[Ptr[uint8]]("innerHTML"), 9, \
                js_new_string(&dom_txtbuf[oh], cast[uint64](ohl)))
    js_set_prop(o, cast[Ptr[uint8]]("id"), 2, \
                js_new_string(&dom_idbuf[ido], cast[uint64](idl)))
    js_set_prop(o, cast[Ptr[uint8]]("className"), 9, \
                js_new_string(&dom_txtbuf[oc], cast[uint64](ocl)))
    js_set_prop(o, cast[Ptr[uint8]]("tagName"), 7, \
                js_new_string(&src_ptr[g_el_ns], g_el_nl))
    js_set_prop(o, cast[Ptr[uint8]]("style"), 5, _new_style_obj())
    # form-control DOM properties: value / checked / type / name (+ selectedIndex).
    if kind == 1 or kind == 2 or kind == 3 or kind == 4:
        js_set_prop(o, cast[Ptr[uint8]]("value"), 5, \
                    js_new_string(&dom_txtbuf[ovo], cast[uint64](ovl)))
        # name attribute
        nmo: int32 = dom_idbuf_len
        nml: int32 = 0
        if _find_attr(g_el_ns, te, cast[Ptr[uint8]]("name")) != 0:
            pn2: uint64 = g_attr_start
            while pn2 < g_attr_end and dom_idbuf_len < DOM_ID_CAP:
                dom_idbuf[dom_idbuf_len] = src_ptr[pn2]
                dom_idbuf_len = dom_idbuf_len + 1
                nml = nml + 1
                pn2 = pn2 + 1
        js_set_prop(o, cast[Ptr[uint8]]("name"), 4, \
                    js_new_string(&dom_idbuf[nmo], cast[uint64](nml)))
        # type (input: attr or "text"; else the tag name)
        tyo: int32 = dom_idbuf_len
        tyl: int32 = 0
        if kind == 1:
            if _find_attr(g_el_ns, te, cast[Ptr[uint8]]("type")) != 0:
                pt: uint64 = g_attr_start
                while pt < g_attr_end and dom_idbuf_len < DOM_ID_CAP:
                    dom_idbuf[dom_idbuf_len] = _lower(src_ptr[pt])
                    dom_idbuf_len = dom_idbuf_len + 1
                    tyl = tyl + 1
                    pt = pt + 1
            else:
                _idbuf_push_cstr(cast[Ptr[uint8]]("text"))
                tyl = 4
        js_set_prop(o, cast[Ptr[uint8]]("type"), 4, \
                    js_new_string(&dom_idbuf[tyo], cast[uint64](tyl)))
        if dom_origchecked[idx] >= 0:
            js_set_prop(o, cast[Ptr[uint8]]("checked"), 7, \
                        js_bool(dom_origchecked[idx]))
        if kind == 3:
            js_set_prop(o, cast[Ptr[uint8]]("selectedIndex"), 13, \
                        js_number(cast[float64](_select_index(g_el_cs))))
    _attach_el_methods(o)
    dom_obj[idx] = o
    dom_n = idx + 1
    return o


# Copy a JS-argument string into `buf`, capped at cap-1, NUL-terminated.
# Returns its length.
def _arg_bytes(argi: int32, buf: Ptr[uint8], cap: int32) -> int32:
    p: Ptr[uint8] = js_str_ptr(js_arg(argi))
    n: int32 = _cstr_len(p)
    if n > cap - 1:
        n = cap - 1
    i: int32 = 0
    while i < n:
        buf[i] = p[i]
        i = i + 1
    buf[n] = 0
    return n


# The host-object dispatcher jsengine calls for native ids >= js_host_base().
def _js_host_dispatch(id: int32) -> int32:
    rel: int32 = id - js_hbase
    if rel == NID_GETBYID:
        if js_arg_count() < 1:
            return js_null()
        n: int32 = _arg_bytes(0, &dom_idtmp[0], 256)
        if _dom_find_by_id(&dom_idtmp[0], n) == 0:
            return js_null()
        return _dom_register_el()
    if rel == NID_QUERY:
        if js_arg_count() < 1:
            return js_null()
        n2: int32 = _arg_bytes(0, &dom_idtmp[0], 256)
        if _dom_find_selector(&dom_idtmp[0], n2) == 0:
            return js_null()
        return _dom_register_el()
    if rel == NID_CREATE:
        if js_arg_count() < 1 or cre_n >= CRE_MAX:
            return js_null()
        tn: int32 = _arg_bytes(0, &dom_idtmp[0], 256)
        cid: int32 = cre_n
        cre_tag_off[cid] = dom_idbuf_len
        k: int32 = 0
        while k < tn and dom_idbuf_len < DOM_ID_CAP:
            dom_idbuf[dom_idbuf_len] = _lower(dom_idtmp[k])
            dom_idbuf_len = dom_idbuf_len + 1
            k = k + 1
        cre_tag_len[cid] = tn
        co: int32 = js_new_object_v()
        js_set_prop(co, cast[Ptr[uint8]]("textContent"), 11, \
                    js_new_string(&dom_txtbuf[0], 0))
        js_set_prop(co, cast[Ptr[uint8]]("style"), 5, _new_style_obj())
        cre_obj[cid] = co
        cre_n = cid + 1
        return co
    if rel == NID_ADDEVT:
        # element.addEventListener('click'|'input'|'change'|'submit', fn).
        if js_arg_count() >= 2:
            evn: int32 = _arg_bytes(0, &dom_idtmp[0], 256)
            el: int32 = _find_el_by_obj(js_this())
            if el >= 0 and js_is_callable(js_arg(1)) != 0:
                if _bytes_eq(&dom_idtmp[0], evn, cast[Ptr[uint8]]("click"), 5) != 0:
                    dom_onclick_fn[el] = js_arg(1)
                elif _bytes_eq(&dom_idtmp[0], evn, cast[Ptr[uint8]]("input"), 5) != 0:
                    dom_oninput_fn[el] = js_arg(1)
                elif _bytes_eq(&dom_idtmp[0], evn, cast[Ptr[uint8]]("change"), 6) != 0:
                    dom_onchange_fn[el] = js_arg(1)
                elif _bytes_eq(&dom_idtmp[0], evn, cast[Ptr[uint8]]("submit"), 6) != 0:
                    dom_onsubmit_fn[el] = js_arg(1)
        return js_undefined()
    if rel == NID_PREVENT:
        # event.preventDefault()
        g_prevent_default = 1
        return js_undefined()
    if rel == NID_APPEND:
        # parent.appendChild(childNode)
        if js_arg_count() >= 1 and ap_n < APPEND_MAX:
            par: int32 = _find_el_by_obj(js_this())
            ch: int32 = _find_cre_by_obj(js_arg(0))
            if par >= 0 and ch >= 0:
                ap_parent[ap_n] = par
                ap_child[ap_n] = ch
                ap_n = ap_n + 1
        return js_arg(0)
    if rel == NID_GETATTR:
        if js_arg_count() >= 1:
            nm: Array[64, uint8]
            an: int32 = _arg_bytes(0, &nm[0], 64)
            el2: int32 = _find_el_by_obj(js_this())
            if el2 >= 0:
                te2: uint64 = cast[uint64](dom_cstart[el2]) - 1
                if _find_attr(cast[uint64](dom_ns[el2]), te2, &nm[0]) != 0:
                    vlen: int32 = cast[int32](g_attr_end - g_attr_start)
                    return js_new_string(&src_ptr[g_attr_start], cast[uint64](vlen))
        return js_null()
    if rel == NID_SETATTR:
        if js_arg_count() >= 2:
            nm2: Array[64, uint8]
            an2: int32 = _arg_bytes(0, &nm2[0], 64)
            el3: int32 = _find_el_by_obj(js_this())
            if el3 >= 0:
                if _bytes_eq(&nm2[0], an2, cast[Ptr[uint8]]("class"), 5) != 0:
                    js_set_prop(dom_obj[el3], cast[Ptr[uint8]]("className"), 9, \
                                js_arg(1))
                else:
                    js_set_prop(dom_obj[el3], &nm2[0], cast[uint64](an2), js_arg(1))
        return js_undefined()
    return js_undefined()


# copy the page <title> text into dom_title_buf; returns its length.
def _scan_title() -> int32:
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           _tagname_is(i + 1, cast[Ptr[uint8]]("title")) != 0:
            j: uint64 = i + 1
            while j < src_len and src_ptr[j] != 62:
                j = j + 1
            if j < src_len:
                j = j + 1
            n: int32 = 0
            while j < src_len and n < 255:
                if src_ptr[j] == 60:                      # '<' -> </title>
                    break
                dom_title_buf[n] = src_ptr[j]
                n = n + 1
                j = j + 1
            return n
        i = i + 1
    return 0


def _js_build_document():
    doc: int32 = js_new_object_v()
    js_doc = doc
    js_set_prop(doc, cast[Ptr[uint8]]("getElementById"), 14, \
                js_new_native_fn(js_hbase + NID_GETBYID))
    js_set_prop(doc, cast[Ptr[uint8]]("createElement"), 13, \
                js_new_native_fn(js_hbase + NID_CREATE))
    js_set_prop(doc, cast[Ptr[uint8]]("querySelector"), 13, \
                js_new_native_fn(js_hbase + NID_QUERY))
    js_set_prop(doc, cast[Ptr[uint8]]("addEventListener"), 16, \
                js_new_native_fn(js_hbase + NID_ADDEVT))
    tl: int32 = _scan_title()
    dom_title_len = tl
    dom_title_present = 1
    js_set_prop(doc, cast[Ptr[uint8]]("title"), 5, \
                js_new_string(&dom_title_buf[0], cast[uint64](tl)))
    _build_forms(doc)
    js_global_set(cast[Ptr[uint8]]("document"), 8, doc)


# Eagerly register every <form> and its fields, exposing document.forms and
# each form's .elements array so a script can iterate them. Registering here
# means getElementById later returns the SAME element objects.
def _build_forms(doc: int32):
    forms: int32 = js_new_array_v()
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           _tagname_is(i + 1, cast[Ptr[uint8]]("form")) != 0:
            _scan_start_tag(i)
            fclose: uint64 = g_close_end
            fi: int32 = _dom_lookup_anchor(cast[int32](g_el_lt))
            if fi < 0:
                _dom_register_el()
                fi = _dom_lookup_anchor(cast[int32](g_el_lt))
            if fi >= 0:
                fobj: int32 = dom_obj[fi]
                elems: int32 = js_new_array_v()
                cs: uint64 = cast[uint64](dom_cstart[fi])
                ce: uint64 = cast[uint64](dom_cend[fi])
                j: uint64 = cs
                while j < ce:
                    if src_ptr[j] == 60 and j + 1 < ce and \
                       (_tagname_is(j + 1, cast[Ptr[uint8]]("input")) != 0 or \
                        _tagname_is(j + 1, cast[Ptr[uint8]]("select")) != 0 or \
                        _tagname_is(j + 1, cast[Ptr[uint8]]("textarea")) != 0):
                        _scan_start_tag(j)
                        jclose: uint64 = g_close_end
                        ei: int32 = _dom_lookup_anchor(cast[int32](g_el_lt))
                        if ei < 0:
                            _dom_register_el()
                            ei = _dom_lookup_anchor(cast[int32](g_el_lt))
                        if ei >= 0:
                            js_array_push(elems, dom_obj[ei])
                        j = jclose
                        continue
                    j = j + 1
                js_set_prop(fobj, cast[Ptr[uint8]]("elements"), 8, elems)
                js_array_push(forms, fobj)
            i = fclose
            continue
        i = i + 1
    js_set_prop(doc, cast[Ptr[uint8]]("forms"), 5, forms)


# Is `p[0..n)` the literal "undefined"? (a read of a never-set JS property).
def _is_undef_str(p: Ptr[uint8], n: int32) -> int32:
    return _bytes_eq(p, n, cast[Ptr[uint8]]("undefined"), 9)


# Read one JS string property `name` of object `o`; if non-empty and not
# "undefined", copy it into dom_ovbuf and set *off/*len via the returned pair
# encoded as: returns the length, and sets g_rb_off to the offset. -1 = unset.
g_rb_off: int32 = 0


def _readback_str(o: int32, name: Ptr[uint8], nlen: uint64) -> int32:
    v: int32 = js_get_prop(o, name, nlen)
    p: Ptr[uint8] = js_str_ptr(v)
    n: int32 = _cstr_len(p)
    if n == 0 or _is_undef_str(p, n) != 0:
        return -1
    g_rb_off = dom_ov_len
    k: int32 = 0
    while k < n and dom_ov_len < DOM_OV_CAP:
        dom_ovbuf[dom_ov_len] = p[k]
        dom_ov_len = dom_ov_len + 1
        k = k + 1
    return k


# Read the JS-mutated DOM back into the override tables. Idempotent: resets the
# override accumulators first, so it can run after the initial scripts AND
# again after an event handler mutates the DOM.
def _dom_readback():
    dom_ov_len = 0
    dom_n_overrides = 0
    idx: int32 = 0
    while idx < dom_n:
        o: int32 = dom_obj[idx]
        dom_ov_inner_off[idx] = -1
        dom_ov_inner_len[idx] = -1
        dom_ov_inner_html[idx] = 0
        dom_ov_col_off[idx] = -1
        dom_ov_col_len[idx] = -1
        dom_ov_bg_off[idx] = -1
        dom_ov_bg_len[idx] = -1
        dom_ov_wt_off[idx] = -1
        dom_ov_wt_len[idx] = -1
        dom_ov_al_off[idx] = -1
        dom_ov_al_len[idx] = -1
        dom_ov_cls_off[idx] = -1
        dom_ov_cls_len[idx] = -1
        dom_ov_hide[idx] = 0
        dom_ov_val_off[idx] = -1
        dom_ov_val_len[idx] = -1
        dom_ov_checked[idx] = -1
        changed: int32 = 0
        # innerHTML (raw) takes priority over textContent (escaped) as inner.
        hv: int32 = js_get_prop(o, cast[Ptr[uint8]]("innerHTML"), 9)
        hp: Ptr[uint8] = js_str_ptr(hv)
        hn: int32 = _cstr_len(hp)
        if _bytes_eq(hp, hn, &dom_txtbuf[dom_html_off[idx]], \
                     dom_html_len[idx]) == 0 and _is_undef_str(hp, hn) == 0:
            off: int32 = dom_ov_len
            k: int32 = 0
            while k < hn and dom_ov_len < DOM_OV_CAP:
                dom_ovbuf[dom_ov_len] = hp[k]
                dom_ov_len = dom_ov_len + 1
                k = k + 1
            dom_ov_inner_off[idx] = off
            dom_ov_inner_len[idx] = k
            dom_ov_inner_html[idx] = 1
            changed = 1
        else:
            tc: int32 = js_get_prop(o, cast[Ptr[uint8]]("textContent"), 11)
            tp: Ptr[uint8] = js_str_ptr(tc)
            tn: int32 = _cstr_len(tp)
            if _bytes_eq(tp, tn, &dom_txtbuf[dom_orig_off[idx]], \
                         dom_orig_len[idx]) == 0 and _is_undef_str(tp, tn) == 0:
                off2: int32 = dom_ov_len
                k2: int32 = 0
                while k2 < tn and dom_ov_len < DOM_OV_CAP:
                    dom_ovbuf[dom_ov_len] = tp[k2]
                    dom_ov_len = dom_ov_len + 1
                    k2 = k2 + 1
                dom_ov_inner_off[idx] = off2
                dom_ov_inner_len[idx] = k2
                dom_ov_inner_html[idx] = 0
                changed = 1
        # style props
        stv: int32 = js_get_prop(o, cast[Ptr[uint8]]("style"), 5)
        r: int32 = _readback_str(stv, cast[Ptr[uint8]]("color"), 5)
        if r >= 0:
            dom_ov_col_off[idx] = g_rb_off
            dom_ov_col_len[idx] = r
            changed = 1
        r = _readback_str(stv, cast[Ptr[uint8]]("backgroundColor"), 15)
        if r >= 0:
            dom_ov_bg_off[idx] = g_rb_off
            dom_ov_bg_len[idx] = r
            changed = 1
        r = _readback_str(stv, cast[Ptr[uint8]]("fontWeight"), 10)
        if r >= 0:
            dom_ov_wt_off[idx] = g_rb_off
            dom_ov_wt_len[idx] = r
            changed = 1
        r = _readback_str(stv, cast[Ptr[uint8]]("textAlign"), 9)
        if r >= 0:
            dom_ov_al_off[idx] = g_rb_off
            dom_ov_al_len[idx] = r
            changed = 1
        # display:none
        dv: int32 = js_get_prop(stv, cast[Ptr[uint8]]("display"), 7)
        dp: Ptr[uint8] = js_str_ptr(dv)
        dn: int32 = _cstr_len(dp)
        if _bytes_eq(dp, dn, cast[Ptr[uint8]]("none"), 4) != 0:
            dom_ov_hide[idx] = 1
            changed = 1
        # className
        clv: int32 = js_get_prop(o, cast[Ptr[uint8]]("className"), 9)
        clp: Ptr[uint8] = js_str_ptr(clv)
        cln: int32 = _cstr_len(clp)
        if _bytes_eq(clp, cln, &dom_txtbuf[dom_origcls_off[idx]], \
                     dom_origcls_len[idx]) == 0 and _is_undef_str(clp, cln) == 0:
            cco: int32 = dom_ov_len
            kc: int32 = 0
            while kc < cln and dom_ov_len < DOM_OV_CAP:
                dom_ovbuf[dom_ov_len] = clp[kc]
                dom_ov_len = dom_ov_len + 1
                kc = kc + 1
            dom_ov_cls_off[idx] = cco
            dom_ov_cls_len[idx] = kc
            changed = 1
        # form value / checked read-back (input / textarea / select).
        if dom_kind[idx] == 1 or dom_kind[idx] == 2 or dom_kind[idx] == 3:
            vv: int32 = js_get_prop(o, cast[Ptr[uint8]]("value"), 5)
            vp: Ptr[uint8] = js_str_ptr(vv)
            vn: int32 = _cstr_len(vp)
            if _bytes_eq(vp, vn, &dom_txtbuf[dom_origval_off[idx]], \
                         dom_origval_len[idx]) == 0 and _is_undef_str(vp, vn) == 0:
                voff: int32 = dom_ov_len
                kv: int32 = 0
                while kv < vn and dom_ov_len < DOM_OV_CAP:
                    dom_ovbuf[dom_ov_len] = vp[kv]
                    dom_ov_len = dom_ov_len + 1
                    kv = kv + 1
                dom_ov_val_off[idx] = voff
                dom_ov_val_len[idx] = kv
                changed = 1
        if dom_origchecked[idx] >= 0:
            ckv: int32 = js_get_prop(o, cast[Ptr[uint8]]("checked"), 7)
            ckb: int32 = 0
            if js_to_bool(ckv) != 0:
                ckb = 1
            if ckb != dom_origchecked[idx]:
                dom_ov_checked[idx] = ckb
                changed = 1
        # assigned handler-function properties (el.onX = fn).
        ocv: int32 = js_get_prop(o, cast[Ptr[uint8]]("onclick"), 7)
        if js_is_callable(ocv) != 0:
            dom_onclick_fn[idx] = ocv
        oiv: int32 = js_get_prop(o, cast[Ptr[uint8]]("oninput"), 7)
        if js_is_callable(oiv) != 0:
            dom_oninput_fn[idx] = oiv
        ocgv: int32 = js_get_prop(o, cast[Ptr[uint8]]("onchange"), 8)
        if js_is_callable(ocgv) != 0:
            dom_onchange_fn[idx] = ocgv
        osv: int32 = js_get_prop(o, cast[Ptr[uint8]]("onsubmit"), 8)
        if js_is_callable(osv) != 0:
            dom_onsubmit_fn[idx] = osv
        # appended children force a rewrite of this element too.
        a: int32 = 0
        while a < ap_n:
            if ap_parent[a] == idx:
                changed = 1
            a = a + 1
        if changed != 0:
            dom_n_overrides = dom_n_overrides + 1
        idx = idx + 1
    # document.title
    tv: int32 = js_get_prop(js_doc, cast[Ptr[uint8]]("title"), 5)
    pp: Ptr[uint8] = js_str_ptr(tv)
    pn: int32 = _cstr_len(pp)
    if pn > 255:
        pn = 255
    j: int32 = 0
    while j < pn:
        dom_title_buf[j] = pp[j]
        j = j + 1
    dom_title_len = pn
    dom_title_present = 1


def _js_capture_console():
    p: Ptr[uint8] = js_out_ptr()
    n: int32 = cast[int32](js_out_len())
    i: int32 = 0
    while i < n and i < 8191:
        js_con_buf[i] = p[i]
        i = i + 1
    js_con_buf[i] = 0
    js_con_len = i


# Run every <script> body. Returns 1 if at least one script ran (so the DOM
# overrides are meaningful), 0 if the page had no scripts at all.
def _run_scripts() -> int32:
    # fast pre-scan: does the page contain a <script ...> at all?
    has: int32 = 0
    p: uint64 = 0
    while p < src_len:
        if src_ptr[p] == 60 and p + 1 < src_len and \
           _tagname_is(p + 1, cast[Ptr[uint8]]("script")) != 0:
            has = 1
            break
        p = p + 1
    if has == 0:
        return 0
    js_init()
    js_hbase = js_host_base()
    js_set_host_dispatch(cast[Fn[int32, int32]](cast[uint64](_js_host_dispatch)))
    _js_build_document()
    js_ctx_live = 1
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           _tagname_is(i + 1, cast[Ptr[uint8]]("script")) != 0:
            # body starts after this start tag's '>'
            j: uint64 = i + 1
            while j < src_len and src_ptr[j] != 62:
                j = j + 1
            if j < src_len:
                j = j + 1
            bs: uint64 = j
            # body ends at </script>
            be: uint64 = bs
            while be < src_len:
                if src_ptr[be] == 60 and be + 1 < src_len and \
                   src_ptr[be + 1] == 47 and \
                   _tagname_is(be + 2, cast[Ptr[uint8]]("script")) != 0:
                    break
                be = be + 1
            if be > bs:
                js_eval(&src_ptr[bs], be - bs)
                if js_error() != 0:
                    js_had_error = 1
            # continue past </script>
            i = be
            while i < src_len and src_ptr[i] != 62:
                i = i + 1
            if i < src_len:
                i = i + 1
            continue
        i = i + 1
    _js_capture_console()
    _dom_readback()
    return 1


# ---- source rewrite (only when overrides exist) --------------------
def _rw_ch(c: uint8):
    if rw_len < RW_CAP:
        rw_buf[rw_len] = c
        rw_len = rw_len + 1


def _rw_range(a: uint64, b: uint64):
    i: uint64 = a
    while i < b:
        _rw_ch(src_ptr[i])
        i = i + 1


def _rw_cstr(s: Ptr[uint8]):
    i: int32 = 0
    while s[i] != 0:
        _rw_ch(s[i])
        i = i + 1


def _rw_ovbuf(off: int32, ln: int32):
    i: int32 = 0
    while i < ln:
        _rw_ch(dom_ovbuf[off + i])
        i = i + 1


# emit override bytes, escaping '<' and '&' so injected textContent renders as
# literal text (never re-parsed as markup).
def _rw_text_escaped(off: int32, ln: int32):
    i: int32 = 0
    while i < ln:
        c: uint8 = dom_ovbuf[off + i]
        if c == 60:
            _rw_cstr(cast[Ptr[uint8]]("&lt;"))
        elif c == 38:
            _rw_cstr(cast[Ptr[uint8]]("&amp;"))
        else:
            _rw_ch(c)
        i = i + 1


def _el_has_override(idx: int32) -> int32:
    if dom_ov_hide[idx] != 0 or dom_ov_inner_len[idx] >= 0 or \
       dom_ov_col_len[idx] >= 0 or dom_ov_bg_len[idx] >= 0 or \
       dom_ov_wt_len[idx] >= 0 or dom_ov_al_len[idx] >= 0 or \
       dom_ov_cls_len[idx] >= 0 or dom_ov_val_len[idx] >= 0 or \
       dom_ov_checked[idx] >= 0:
        return 1
    # a click handler alone makes the element a rewrite target when the native
    # front-end wants clickable event-links.
    if he_click_links != 0 and _el_has_handler(idx) != 0:
        return 1
    a: int32 = 0
    while a < ap_n:
        if ap_parent[a] == idx:
            return 1
        a = a + 1
    return 0


def _rw_dec(v: int32):
    if v == 0:
        _rw_ch(48)
        return
    d: Array[12, uint8]
    n: int32 = 0
    x: int32 = v
    while x > 0:
        d[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _rw_ch(d[n])


# Emit an appended, script-created child node's markup. The colour/background
# are carried on an inner <span> (so they render even for elements like <li>
# whose own tag doesn't parse an inline style): <tag><span style="..">text</span></tag>
def _emit_created(cid: int32):
    _rw_ch(60)                                            # '<'
    t: int32 = 0
    while t < cre_tag_len[cid]:
        _rw_ch(dom_idbuf[cre_tag_off[cid] + t])
        t = t + 1
    _rw_ch(62)                                            # '>'
    co: int32 = cre_obj[cid]
    stv: int32 = js_get_prop(co, cast[Ptr[uint8]]("style"), 5)
    dom_ov_len_save: int32 = dom_ov_len
    cl: int32 = _readback_str(stv, cast[Ptr[uint8]]("color"), 5)
    col_off: int32 = g_rb_off
    bg: int32 = _readback_str(stv, cast[Ptr[uint8]]("backgroundColor"), 15)
    bg_off: int32 = g_rb_off
    has_style: int32 = 0
    if cl >= 0 or bg >= 0:
        has_style = 1
        _rw_cstr(cast[Ptr[uint8]]("<span style=\""))
        if cl >= 0:
            _rw_cstr(cast[Ptr[uint8]]("color:"))
            _rw_ovbuf(col_off, cl)
            _rw_ch(59)
        if bg >= 0:
            _rw_cstr(cast[Ptr[uint8]]("background-color:"))
            _rw_ovbuf(bg_off, bg)
            _rw_ch(59)
        _rw_cstr(cast[Ptr[uint8]]("\">"))
    tv: int32 = js_get_prop(co, cast[Ptr[uint8]]("textContent"), 11)
    tp: Ptr[uint8] = js_str_ptr(tv)
    tn: int32 = _cstr_len(tp)
    if _is_undef_str(tp, tn) == 0:
        ti: int32 = 0
        while ti < tn:
            c: uint8 = tp[ti]
            if c == 60:
                _rw_cstr(cast[Ptr[uint8]]("&lt;"))
            elif c == 38:
                _rw_cstr(cast[Ptr[uint8]]("&amp;"))
            else:
                _rw_ch(c)
            ti = ti + 1
    if has_style != 0:
        _rw_cstr(cast[Ptr[uint8]]("</span>"))
    _rw_cstr(cast[Ptr[uint8]]("</"))
    t2: int32 = 0
    while t2 < cre_tag_len[cid]:
        _rw_ch(dom_idbuf[cre_tag_off[cid] + t2])
        t2 = t2 + 1
    _rw_ch(62)
    dom_ov_len = dom_ov_len_save                          # scratch reclaim


# Emit the merged inline style="" for an element's style overrides (or nothing).
def _emit_merged_style(idx: int32):
    if dom_ov_col_len[idx] < 0 and dom_ov_bg_len[idx] < 0 and \
       dom_ov_wt_len[idx] < 0 and dom_ov_al_len[idx] < 0:
        return
    _rw_cstr(cast[Ptr[uint8]](" style=\""))
    if dom_ov_col_len[idx] >= 0:
        _rw_cstr(cast[Ptr[uint8]]("color:"))
        _rw_ovbuf(dom_ov_col_off[idx], dom_ov_col_len[idx])
        _rw_ch(59)
    if dom_ov_bg_len[idx] >= 0:
        _rw_cstr(cast[Ptr[uint8]]("background-color:"))
        _rw_ovbuf(dom_ov_bg_off[idx], dom_ov_bg_len[idx])
        _rw_ch(59)
    if dom_ov_wt_len[idx] >= 0:
        _rw_cstr(cast[Ptr[uint8]]("font-weight:"))
        _rw_ovbuf(dom_ov_wt_off[idx], dom_ov_wt_len[idx])
        _rw_ch(59)
    if dom_ov_al_len[idx] >= 0:
        _rw_cstr(cast[Ptr[uint8]]("text-align:"))
        _rw_ovbuf(dom_ov_al_off[idx], dom_ov_al_len[idx])
        _rw_ch(59)
    _rw_ch(34)


# Copy tag-body attributes [a,b) into rw_buf, dropping any attribute named
# `s1` or `s2` (case-insensitive; both valued `name="v"` and bare `name` forms).
def _rw_copy_attrs_except(a: uint64, b: uint64, s1: Ptr[uint8], s2: Ptr[uint8]):
    l1: int32 = _cstr_len(s1)
    l2: int32 = _cstr_len(s2)
    i: uint64 = a
    while i < b:
        c: uint8 = src_ptr[i]
        if c == 32 or c == 9 or c == 10 or c == 13:
            _rw_ch(c)
            i = i + 1
            continue
        ns: uint64 = i
        while i < b and _is_name_ch(src_ptr[i]) != 0:
            i = i + 1
        ne2: uint64 = i
        # look ahead past spaces for '=' to find a valued attribute
        k: uint64 = i
        while k < b and (src_ptr[k] == 32 or src_ptr[k] == 9):
            k = k + 1
        attr_end: uint64 = ne2
        if k < b and src_ptr[k] == 61:                    # '='
            k = k + 1
            while k < b and (src_ptr[k] == 32 or src_ptr[k] == 9):
                k = k + 1
            if k < b and (src_ptr[k] == 34 or src_ptr[k] == 39):
                q: uint8 = src_ptr[k]
                k = k + 1
                while k < b and src_ptr[k] != q:
                    k = k + 1
                if k < b:
                    k = k + 1
            else:
                while k < b and src_ptr[k] != 32 and src_ptr[k] != 9:
                    k = k + 1
            attr_end = k
        skip: int32 = 0
        if _idbytes_eq(ns, ne2, s1, l1) != 0 or _idbytes_eq(ns, ne2, s2, l2) != 0:
            skip = 1
        if skip == 0:
            _rw_range(ns, attr_end)
        i = attr_end


# Does dom_ovbuf[off..off+len) equal src span [a,b) (byte-exact)?
def _ovbuf_eq_src(off: int32, ln: int32, a: uint64, b: uint64) -> int32:
    if cast[int32](b - a) != ln:
        return 0
    i: int32 = 0
    while i < ln:
        if dom_ovbuf[off + i] != src_ptr[a + cast[uint64](i)]:
            return 0
        i = i + 1
    return 1


# Re-emit a <select>'s option list [cs,ce), moving `selected` onto the option
# whose visible text equals the override value dom_ovbuf[voff..voff+vlen).
def _rw_select_options(cs: uint64, ce: uint64, voff: int32, vlen: int32):
    i: uint64 = cs
    while i < ce:
        if src_ptr[i] == 60 and _tagname_is(i + 1, cast[Ptr[uint8]]("option")) != 0:
            je: uint64 = i + 1
            while je < ce and src_ptr[je] != 62:
                je = je + 1
            ne: uint64 = i + 1
            while ne < je and _alnum_at(ne) != 0:
                ne = ne + 1
            ots: uint64 = je + 1
            ote: uint64 = ots
            while ote < ce and src_ptr[ote] != 60:
                ote = ote + 1
            _rw_ch(60)
            _rw_range(i + 1, ne)                          # 'option'
            _rw_copy_attrs_except(ne, je, cast[Ptr[uint8]]("selected"), \
                                  cast[Ptr[uint8]]("selected"))
            if _ovbuf_eq_src(voff, vlen, ots, ote) != 0:
                _rw_cstr(cast[Ptr[uint8]](" selected"))
            _rw_ch(62)
            i = je + 1
            continue
        _rw_ch(src_ptr[i])
        i = i + 1


# Build rw_buf: a copy of the source with each overridden element's mutations
# baked in. Overridden elements are matched by their source anchor offset, so
# id-less querySelector matches work too. Elements without overrides copy
# through byte-for-byte, so the rest of the page's layout is unchanged.
def _build_rewrite():
    rw_len = 0
    i: uint64 = 0
    while i < src_len:
        c: uint8 = src_ptr[i]
        if c == 60 and i + 1 < src_len and src_ptr[i + 1] != 47 and \
           src_ptr[i + 1] != 33 and src_ptr[i + 1] != 63:
            idx: int32 = _dom_lookup_anchor(cast[int32](i))
            if idx >= 0 and _el_has_override(idx) != 0:
                ts: uint64 = i + 1
                je: uint64 = ts
                while je < src_len and src_ptr[je] != 62:
                    je = je + 1
                ne: uint64 = ts
                while ne < je and _alnum_at(ne) != 0:
                    ne = ne + 1
                clt: uint64 = cast[uint64](dom_cend[idx])
                # locate the close tag end
                _find_close(ts, ne - ts, je + 1)
                cend: uint64 = g_close_end
                if dom_ov_hide[idx] != 0:
                    i = cend
                    continue
                # rebuild the start tag: <name [class] [style] original-attrs>
                _rw_ch(60)
                _rw_range(ts, ne)
                if dom_ov_cls_len[idx] >= 0:
                    _rw_cstr(cast[Ptr[uint8]](" class=\""))
                    _rw_ovbuf(dom_ov_cls_off[idx], dom_ov_cls_len[idx])
                    _rw_ch(34)
                _emit_merged_style(idx)
                if dom_kind[idx] == 1 and \
                   (dom_ov_val_len[idx] >= 0 or dom_ov_checked[idx] >= 0):
                    # input: re-emit attrs without value/checked, then the new
                    # value/checked so the control renders its updated state.
                    _rw_copy_attrs_except(ne, je, cast[Ptr[uint8]]("value"), \
                                          cast[Ptr[uint8]]("checked"))
                    if dom_ov_val_len[idx] >= 0:
                        _rw_cstr(cast[Ptr[uint8]](" value=\""))
                        _rw_ovbuf(dom_ov_val_off[idx], dom_ov_val_len[idx])
                        _rw_ch(34)
                    if dom_ov_checked[idx] == 1:
                        _rw_cstr(cast[Ptr[uint8]](" checked"))
                else:
                    _rw_range(ne, je)                     # original attributes
                _rw_ch(62)
                # native-only: wrap a click-handler element's content in a
                # synthetic "#__evt_IDX" link so the existing pointer link
                # hit-test can route the click to he_dom_click_index.
                wrap_evt: int32 = 0
                if he_click_links != 0 and _el_has_handler(idx) != 0:
                    wrap_evt = 1
                    _rw_cstr(cast[Ptr[uint8]]("<a href=\"#__evt_"))
                    _rw_dec(idx)
                    _rw_cstr(cast[Ptr[uint8]]("\">"))
                # inner content
                if dom_kind[idx] == 2 and dom_ov_val_len[idx] >= 0:
                    # textarea value change = new (escaped) inner text.
                    _rw_text_escaped(dom_ov_val_off[idx], dom_ov_val_len[idx])
                elif dom_kind[idx] == 3 and dom_ov_val_len[idx] >= 0:
                    # select value change = re-mark the selected <option>.
                    _rw_select_options(je + 1, clt, dom_ov_val_off[idx], \
                                       dom_ov_val_len[idx])
                elif dom_ov_inner_len[idx] >= 0:
                    if dom_ov_inner_html[idx] != 0:
                        _rw_ovbuf(dom_ov_inner_off[idx], dom_ov_inner_len[idx])
                    else:
                        _rw_text_escaped(dom_ov_inner_off[idx], \
                                         dom_ov_inner_len[idx])
                else:
                    _rw_range(je + 1, clt)
                # appended created children, in insertion order
                a: int32 = 0
                while a < ap_n:
                    if ap_parent[a] == idx:
                        _emit_created(ap_child[a])
                    a = a + 1
                if wrap_evt != 0:
                    _rw_cstr(cast[Ptr[uint8]]("</a>"))
                _rw_range(clt, cend)                      # original close tag
                i = cend
                continue
        _rw_ch(c)
        i = i + 1


# ---- front-end accessors (console / title / error) ------------------
def he_js_console_ptr() -> Ptr[uint8]:
    js_con_buf[js_con_len] = 0
    return &js_con_buf[0]


def he_js_console_len() -> uint64:
    return cast[uint64](js_con_len)


def he_js_error() -> int32:
    return js_had_error


def he_dom_title_ptr() -> Ptr[uint8]:
    return &dom_title_buf[0]


def he_dom_title_len() -> uint64:
    return cast[uint64](dom_title_len)


def he_dom_title_present() -> int32:
    return dom_title_present


# Lay out either the original source or, when the DOM carries overrides, a
# rewritten copy with them baked in. Shared by he_layout and post-event
# re-layout (he_dom_click).
def _relayout():
    if dom_n_overrides > 0:
        _build_rewrite()
        save_ptr: Ptr[uint8] = src_ptr
        save_len: uint64 = src_len
        src_ptr = &rw_buf[0]
        src_len = rw_len
        _layout()
        src_ptr = save_ptr
        src_len = save_len
    else:
        _layout()


# he_layout — public entry point (non-underscore so front-ends can call it
# without an underscore import). Runs the page's <script>s (if any) through
# the JS engine + minimal DOM, then lays out src_ptr/src_len into segments —
# re-laying-out a rewritten source when a script mutated the DOM. The JS
# context persists after this returns (until the next he_layout / js_init) so
# event handlers registered here stay live for he_dom_click().
def he_layout():
    _dom_reset()
    _run_scripts()
    _relayout()


# Dispatch a click to the DOM record at `idx`: invoke its stored handler (an
# el.onclick / addEventListener('click', fn) function value, or an inline
# onclick="" source string) in the LIVE JS context, then read the DOM back and
# re-lay-out so the handler's mutations render. Returns 1 if a handler ran.
g_argv1: Array[1, int32]


# Fire element `idx`'s handler for event `kind` (0 click, 1 input, 2 change,
# 3 submit) in the live JS context, passing `evtobj` as the sole argument
# (-1 = call with no args). A stored function value wins over an inline
# on<evt>="" source string. Returns 1 if a handler ran.
def _fire_handler(idx: int32, kind: int32, evtobj: int32) -> int32:
    fn: int32 = -1
    src: int32 = -1
    srclen: int32 = 0
    if kind == 0:
        fn = dom_onclick_fn[idx]
        src = dom_onclick_src[idx]
        srclen = dom_onclick_srclen[idx]
    elif kind == 1:
        fn = dom_oninput_fn[idx]
        src = dom_oninput_src[idx]
        srclen = dom_oninput_srclen[idx]
    elif kind == 2:
        fn = dom_onchange_fn[idx]
        src = dom_onchange_src[idx]
        srclen = dom_onchange_srclen[idx]
    elif kind == 3:
        fn = dom_onsubmit_fn[idx]
        src = dom_onsubmit_src[idx]
        srclen = dom_onsubmit_srclen[idx]
    # An inline on<evt>="" handler (and legacy code) references a global `event`;
    # bind it so both the function-value and source-string paths can see it.
    if evtobj >= 0:
        js_global_set(cast[Ptr[uint8]]("event"), 5, evtobj)
    if fn >= 0 and js_is_callable(fn) != 0:
        if evtobj >= 0:
            g_argv1[0] = evtobj
            js_call_fn(fn, dom_obj[idx], &g_argv1[0], 1)
        else:
            js_call_fn(fn, dom_obj[idx], cast[Ptr[int32]](0), 0)
        return 1
    if src >= 0:
        js_eval(&dom_txtbuf[src], cast[uint64](srclen))
        if js_error() != 0:
            js_had_error = 1
        return 1
    return 0


def he_dom_click_index(idx: int32) -> int32:
    if js_ctx_live == 0 or idx < 0 or idx >= dom_n:
        return 0
    if _fire_handler(idx, 0, -1) == 0:
        return 0
    _dom_readback()
    _js_capture_console()
    _relayout()
    return 1


# Look up a registered DOM element by id, registering it on demand (the JS
# context must be live). Returns its dom index, or -1.
def _lookup_or_register(idp: Ptr[uint8], idn: int32) -> int32:
    e: int32 = _dom_lookup_id(idp, idn)
    if e >= 0:
        return e
    if _dom_find_by_id(idp, idn) == 0:
        return -1
    _dom_register_el()
    return _dom_lookup_anchor(cast[int32](g_el_lt))


# Build a minimal event object exposing preventDefault().
def _new_event_obj() -> int32:
    ev: int32 = js_new_object_v()
    js_set_prop(ev, cast[Ptr[uint8]]("preventDefault"), 14, \
                js_new_native_fn(js_hbase + NID_PREVENT))
    js_set_prop(ev, cast[Ptr[uint8]]("defaultPrevented"), 16, js_bool(0))
    return ev


# Programmatically set a form field's value (input/textarea/select) by element
# id, then fire its oninput + onchange handlers and re-lay-out so the change
# renders. The pointer-free equivalent of a user typing into a field. Returns 1
# on success (JS context live + element found).
def he_dom_set_value(idp: Ptr[uint8], idn: int32, valp: Ptr[uint8], \
                     valn: int32) -> int32:
    if js_ctx_live == 0:
        return 0
    idx: int32 = _lookup_or_register(idp, idn)
    if idx < 0:
        return 0
    js_set_prop(dom_obj[idx], cast[Ptr[uint8]]("value"), 5, \
                js_new_string(valp, cast[uint64](valn)))
    _fire_handler(idx, 1, -1)                             # oninput
    _fire_handler(idx, 2, -1)                             # onchange
    _dom_readback()
    _js_capture_console()
    _relayout()
    return 1


# Set a checkbox/radio's checked state by id, fire oninput + onchange, re-lay.
def he_dom_set_checked(idp: Ptr[uint8], idn: int32, checked: int32) -> int32:
    if js_ctx_live == 0:
        return 0
    idx: int32 = _lookup_or_register(idp, idn)
    if idx < 0:
        return 0
    js_set_prop(dom_obj[idx], cast[Ptr[uint8]]("checked"), 7, js_bool(checked))
    _fire_handler(idx, 1, -1)
    _fire_handler(idx, 2, -1)
    _dom_readback()
    _js_capture_console()
    _relayout()
    return 1


# ---- form submission + GET serialization ---------------------------
def _nav_putc(c: uint8):
    if dom_nav_len < 2047:
        dom_nav_buf[dom_nav_len] = c
        dom_nav_len = dom_nav_len + 1


# Append `p[0..n)` URL-form-encoded: space -> '+', unreserved kept, else '_'.
def _nav_encoded(p: Ptr[uint8], n: int32):
    i: int32 = 0
    while i < n:
        c: uint8 = p[i]
        if c == 32:
            _nav_putc(43)                                # '+'
        elif (c >= 97 and c <= 122) or (c >= 65 and c <= 90) or \
             (c >= 48 and c <= 57) or c == 45 or c == 46 or c == 95:
            _nav_putc(c)
        else:
            _nav_putc(95)                                # '_'
        i = i + 1


# Serialize the form at dom index `fi` into dom_nav_buf as "?a=1&b=2", reading
# each named field's current value/checked from its (registered) JS object.
def _serialize_form(fi: int32):
    dom_nav_len = 0
    _nav_putc(63)                                        # '?'
    first: int32 = 1
    cs: uint64 = cast[uint64](dom_cstart[fi])
    ce: uint64 = cast[uint64](dom_cend[fi])
    i: uint64 = cs
    while i < ce:
        if src_ptr[i] == 60 and i + 1 < ce and \
           (_tagname_is(i + 1, cast[Ptr[uint8]]("input")) != 0 or \
            _tagname_is(i + 1, cast[Ptr[uint8]]("select")) != 0 or \
            _tagname_is(i + 1, cast[Ptr[uint8]]("textarea")) != 0):
            _scan_start_tag(i)
            skip_to: uint64 = g_close_end
            ei: int32 = _dom_lookup_anchor(cast[int32](g_el_lt))
            if ei < 0:
                _dom_register_el()
                ei = _dom_lookup_anchor(cast[int32](g_el_lt))
            if ei >= 0:
                _serialize_field(ei, &first)
            i = skip_to
            continue
        i = i + 1
    dom_nav_present = 1


# Emit one field's name=value pair into the nav buffer (if it carries a name and
# is a successful control). *first tracks whether a '&' separator is needed.
def _serialize_field(ei: int32, first: Ptr[int32]):
    obj: int32 = dom_obj[ei]
    nmv: int32 = js_get_prop(obj, cast[Ptr[uint8]]("name"), 4)
    np: Ptr[uint8] = js_str_ptr(nmv)
    nn: int32 = _cstr_len(np)
    if nn == 0 or _is_undef_str(np, nn) != 0:
        return
    # copy the name out of the shared scratch before reading other props.
    kk: int32 = 0
    while kk < nn and kk < 127:
        g_nmtmp[kk] = np[kk]
        kk = kk + 1
    nn2: int32 = kk
    # a checkbox/radio contributes only when checked.
    if dom_origchecked[ei] >= 0:
        ckv: int32 = js_get_prop(obj, cast[Ptr[uint8]]("checked"), 7)
        if js_to_bool(ckv) == 0:
            return
    # submit/reset/button inputs are not serialized.
    tyv: int32 = js_get_prop(obj, cast[Ptr[uint8]]("type"), 4)
    typ: Ptr[uint8] = js_str_ptr(tyv)
    tyn: int32 = _cstr_len(typ)
    if _bytes_eq(typ, tyn, cast[Ptr[uint8]]("submit"), 6) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("reset"), 5) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("button"), 6) != 0:
        return
    if first[0] == 0:
        _nav_putc(38)                                    # '&'
    first[0] = 0
    _nav_encoded(&g_nmtmp[0], nn2)
    _nav_putc(61)                                        # '='
    vv: int32 = js_get_prop(obj, cast[Ptr[uint8]]("value"), 5)
    vp: Ptr[uint8] = js_str_ptr(vv)
    vn: int32 = _cstr_len(vp)
    if _is_undef_str(vp, vn) != 0:
        vn = 0
    _nav_encoded(vp, vn)


# Submit the form with id idp[0..idn): fire its onsubmit handler (passing an
# event with preventDefault); if not prevented, GET-serialize its fields into
# the nav buffer for the front-end to "navigate" to. Returns 1 on dispatch.
def he_dom_submit(idp: Ptr[uint8], idn: int32) -> int32:
    if js_ctx_live == 0:
        return 0
    idx: int32 = _lookup_or_register(idp, idn)
    if idx < 0:
        return 0
    g_prevent_default = 0
    ev: int32 = _new_event_obj()
    _fire_handler(idx, 3, ev)
    _dom_readback()
    _js_capture_console()
    if g_prevent_default == 0:
        _serialize_form(idx)
    _relayout()
    return 1


def he_nav_ptr() -> Ptr[uint8]:
    dom_nav_buf[dom_nav_len] = 0
    return &dom_nav_buf[0]


def he_nav_len() -> uint64:
    return cast[uint64](dom_nav_len)


def he_nav_present() -> int32:
    return dom_nav_present


# Dispatch a click to the element with id idp[0..idn). Returns 1 if a handler
# ran, 0 otherwise. This is the programmatic, pointer-free dispatch used by the
# host gate AND (via he_dom_click_index) the native pointer path.
def he_dom_click(idp: Ptr[uint8], idn: int32) -> int32:
    return he_dom_click_index(_dom_lookup_id(idp, idn))


# Does the DOM element at `idx` carry a click handler?
def _el_has_handler(idx: int32) -> int32:
    if dom_onclick_fn[idx] >= 0 or dom_onclick_src[idx] >= 0:
        return 1
    return 0


# If link `lid`'s href is the synthetic "#__evt_N" the native rewrite injects
# around a click-handler element, return the DOM record index N; else -1. The
# native front-end calls this on a hit-tested link to route a pointer click to
# he_dom_click_index instead of navigating.
def he_link_evt_index(lid: int32) -> int32:
    if lid < 0 or cast[uint64](lid) >= n_links:
        return -1
    o: uint64 = cast[uint64](link_off[lid])
    l: int32 = link_len[lid]
    pfx: Ptr[uint8] = cast[Ptr[uint8]]("#__evt_")
    k: int32 = 0
    while k < 7:
        if k >= l or link_href_buf[o + cast[uint64](k)] != pfx[k]:
            return -1
        k = k + 1
    v: int32 = 0
    while k < l:
        c: uint8 = link_href_buf[o + cast[uint64](k)]
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[int32](c) - 48
        k = k + 1
    return v


# Native front-ends set this to 1 so the rewrite wraps click-handler elements
# in a synthetic "#__evt_N" link, reusing the existing pointer link hit-test
# for event dispatch. Host/default stays 0 so its render is byte-for-byte the
# same as with no handlers (keeps the host gate output stable).
def he_set_click_links(v: int32):
    he_click_links = v


# Format a packed 0xRRGGBB into a "#rrggbb\0" string in `out` (>= 8 bytes).
def he_rgb_hex(rgb: int32, out: Ptr[uint8]):
    out[0] = 35                                       # '#'
    hexd: Ptr[uint8] = cast[Ptr[uint8]]("0123456789abcdef")
    k: int32 = 0
    while k < 6:
        shift: int32 = (5 - k) * 4
        nib: int32 = (rgb / (1 << shift)) & 15
        out[1 + k] = hexd[nib]
        k = k + 1
    out[7] = 0


# Resolve segment `si` to a "#rrggbb\0" colour string in the caller's buffer
# (>= 8 bytes). Explicit CSS colour wins; otherwise the role palette.
def he_seg_color_hex(si: uint64, out: Ptr[uint8]):
    rgb: int32 = seg_rgb[si]
    if rgb < 0:
        rgb = _palette_rgb(seg_color[si])
    he_rgb_hex(rgb, out)


# ---- accessors for the graphical (htmlpaint) pixel backend -----------
# The pixel renderer (lib/htmlpaint.ad, driven by user/hambrowse*_gfx) reads
# the laid-out segment table through these instead of reaching into globals,
# so the same engine feeds both the legacy monospace-grid dump and the new
# proportional-font pixel paint.
def he_n_segs() -> uint64:
    return n_segs


def he_total_rows() -> uint64:
    return total_rows


def he_page_width() -> int32:
    return bw


def he_seg_line(si: uint64) -> int32:
    return seg_line[si]


def he_seg_x(si: uint64) -> int32:
    return seg_x[si]


def he_seg_off(si: uint64) -> int32:
    return seg_off[si]


def he_seg_len(si: uint64) -> int32:
    return seg_len[si]


def he_seg_text_ptr() -> Ptr[uint8]:
    return &seg_text_buf[0]


def he_seg_face(si: uint64) -> uint8:
    return seg_face[si]


def he_seg_gridx(si: uint64) -> int32:
    return cast[int32](seg_gridx[si])


# CSS font-size (px) for this segment, or 0 = use the face default.
def he_seg_pxsize(si: uint64) -> int32:
    return seg_pxsize[si]


def he_seg_bold(si: uint64) -> int32:
    return cast[int32](seg_bold[si])


def he_seg_uline(si: uint64) -> int32:
    return cast[int32](seg_uline[si])


def he_seg_link(si: uint64) -> int32:
    return seg_link[si]


def he_seg_bg(si: uint64) -> int32:
    return seg_bg[si]


# Effective 0xRRGGBB for segment si (explicit CSS colour, else role palette).
def he_seg_rgb(si: uint64) -> int32:
    rgb: int32 = seg_rgb[si]
    if rgb < 0:
        rgb = _palette_rgb(seg_color[si])
    return rgb


def he_row_rule(r: uint64) -> uint8:
    return row_rule[r]


# ====================================================================
# SCROLL helpers.
# ====================================================================
def _max_top() -> uint64:
    vr: uint64 = _vis_rows()
    if total_rows > vr:
        return total_rows - vr
    return 0


def _scroll_to(t: int64):
    mt: int64 = cast[int64](_max_top())
    if t < 0:
        t = 0
    if t > mt:
        t = mt
    top_line = cast[uint64](t)


def _scroll_by(delta: int64):
    _scroll_to(cast[int64](top_line) + delta)

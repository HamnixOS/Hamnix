# lib/htmlengine.ad — the PURE HTML parse + block/inline layout engine that
# backs the native web browser.
#
# This module is deliberately I/O-FREE and UI-FREE: it has NO `extern def`
# syscalls, NO hamUI, NO http9. It consumes a source buffer (src_ptr/src_len,
# set by whichever front-end fetched the page) and produces a flat display
# list of styled SEGMENTS plus per-row heading-rule flags. Both front-ends
# share it byte-for-byte:
#
#   * user/hambrowse.ad     — the NATIVE browser: Plan 9-shape http9 fetch +
#                             hamUI scene render (the shipped bare-metal path).
#   * user/hambrowse_host.ad — a HOST test harness built for the x86_64-linux
#                             Adder target: reads a local HTML fixture and
#                             dumps the layout, so the engine can be iterated
#                             on the dev host in milliseconds with NO QEMU.
#
# Keeping the engine pure is the seam that makes hambrowse dual-target while
# the native path stays Plan 9-shape (the host harness is a TEST shim only —
# it never adds sockets to the native code path).
#
# MEMORY DISCIPLINE (memory/feedback_compiler_quirks.md U9): every sizable
# buffer is a top-level BSS Array, NEVER a stack local — the native user
# stack is a single 4 KiB page. No malloc.
#
# JAVASCRIPT: <script> execution + a minimal DOM are wired in at the bottom of
# this file (see the "JAVASCRIPT + minimal DOM" section). The engine imports
# the pure tree-walking interpreter from lib/jsengine.ad and binds a `document`
# host object through jsengine's host-object seam (NO jsengine edits). Scripts
# run at layout time; the DOM they mutate (textContent / style.color /
# style.display / document.title) is applied by re-laying-out a rewritten copy
# of the source. Pages with no <script> never touch jsengine at all.
#
# FORMS: <input>/<textarea>/<button>/<select> render as monospace-grid boxes
# ([text__], [x], (*), [ label ], [ opt v]) and expose a form DOM — value /
# checked / type / name, form.elements, document.forms — through the SAME
# host-object seam. Field changes and submissions are driven programmatically
# (pointer/keyboard-free) via he_dom_set_value / he_dom_set_checked /
# he_dom_submit, which fire oninput/onchange/onsubmit and re-lay-out; a submit
# that is not preventDefault'd GET-serializes the form into he_nav_* for the
# front-end to navigate to. A value/checked change bakes into the rewritten
# source (the input's value=/checked attr, a textarea's content, a select's
# selected option) so the control re-renders its new state.

from lib.jsengine import js_init, js_eval, js_error, js_out_ptr, js_out_len, \
    js_new_object_v, js_new_string, js_new_native_fn, js_set_prop, js_get_prop, \
    js_global_set, js_global_get, js_set_host_dispatch, js_arg_count, js_arg, \
    js_host_base, js_set_member_hook, js_mset_this, js_mset_key, js_mset_val, \
    js_str_ptr, js_undefined, js_null, js_this, js_is_callable, js_call_fn, \
    js_bool, js_to_bool, js_number, js_to_number, js_new_array_v, js_array_push, \
    js_array_len, js_array_get
from lib.htmlimg import htmlimg_find, htmlimg_w, htmlimg_h, htmlimg_add_blank, \
    htmlimg_add
from lib.svg import svg_decode, svg_width, svg_height, svg_rgba_ptr
from lib.htmlcanvas import htmlcanvas_reset, htmlcanvas_new, htmlcanvas_slot, \
    htmlcanvas_fill_rect, htmlcanvas_clear_rect, htmlcanvas_stroke_rect, \
    htmlcanvas_begin, htmlcanvas_moveto, htmlcanvas_lineto, \
    htmlcanvas_closepath, htmlcanvas_arc, htmlcanvas_stroke, htmlcanvas_fill, \
    htmlcanvas_fill_text, htmlcanvas_measure_text

# ====================================================================
# Tiny helper.
# ====================================================================
def _hx_lower(c: uint8) -> uint8:
    if c >= 65 and c <= 90:
        return c + 32
    return c


# CSS whitespace: space, tab, newline, carriage-return. Rules/declarations may
# be formatted across lines (#250), so property-name/value trimming must skip
# newlines too — not just space/tab.
def _css_ws(c: uint8) -> int32:
    if c == 32 or c == 9 or c == 10 or c == 13:
        return 1
    return 0


# ====================================================================
# WINDOW geometry (mutable — a resize re-lays-out from the stored source).
# These live in the engine because layout wraps to bw and _vis_rows depends
# on bh; the front-ends read/write them directly (shared globals).
# ====================================================================
TITLE_H:   int32 = 18
ADDR_H:    int32 = 20           # editable address/URL bar (below the title)
ADDR_Y:    int32 = 18           # == TITLE_H
GO_W:      int32 = 30           # "Go" button width in the address bar
NAV_BTN_W: int32 = 22           # Back / Forward button width (left of the URL box)
NAV_BAR_W: int32 = 48           # 2*NAV_BTN_W + 4 left pad: URL box starts here
CONTENT_X: int32 = 8
CONTENT_Y: int32 = 38           # == TITLE_H + ADDR_H (page content starts here)
STATUS_H:  int32 = 16
LINE_H:    int32 = 16
CELL_W:    int32 = 8
bw: int32 = 880                 # window content width  (px; native default)
bh: int32 = 600                 # window content height (px)


# READABLE-MEASURE default (UA stylesheet): a plain page should not let body
# text span an arbitrarily wide window edge-to-edge — long lines are tiring to
# read. We cap the content column at MEASURE_MAX px and CENTRE it, leaving a
# symmetric page gutter on wide windows (exactly like a browser's default body
# max-width). MEASURE_MAX == 584 px == 73 character cells, chosen so that at the
# 600 px unit-test / legacy window the gutter is ZERO and geometry is byte-for-
# byte identical (avail = 600 - 2*8 = 584 == MEASURE_MAX): the cap only engages
# once the window is wider than 600 px, so all existing 600 px assertions hold.
MEASURE_MAX: int32 = 584


# Symmetric page gutter (px) added to CONTENT_X on wide windows so the content
# column is centred at its readable measure. 0 at bw <= 600.
def _page_gutter() -> int32:
    avail: int32 = bw - 2 * CONTENT_X
    if avail <= MEASURE_MAX:
        return 0
    return (avail - MEASURE_MAX) / 2


# Left edge of the body content column (CONTENT_X + centring gutter).
def _left_margin() -> int32:
    return CONTENT_X + _page_gutter()


def _content_right() -> int32:
    return bw - CONTENT_X - _page_gutter()


def _vis_rows() -> uint64:
    r: int32 = (bh - CONTENT_Y - STATUS_H) / LINE_H
    if r < 1:
        r = 1
    return cast[uint64](r)


# ====================================================================
# SOURCE — src_ptr/src_len point at the HTML the front-end wants parsed.
# ====================================================================
src_ptr:  Ptr[uint8] = 0
src_len:  uint64 = 0


# ====================================================================
# LAYOUT MODEL — the parsed page becomes a flat list of styled SEGMENTS.
# A segment is a run of same-styled text on one visual ROW at a pixel X.
# ====================================================================
MAX_SEGS:     uint64 = 6000
SEG_TEXT_CAP: uint64 = 131072
MAX_ROWS:     uint64 = 12000

seg_text_buf: Array[131072, uint8]
seg_text_len: uint64 = 0
seg_x:    Array[6000, int32]
seg_line: Array[6000, int32]
seg_off:  Array[6000, int32]
seg_len:  Array[6000, int32]
seg_color: Array[6000, uint8]    # palette index (role colour)
seg_rgb:  Array[6000, int32]     # explicit 0xRRGGBB, or -1 to use the palette
seg_bg:   Array[6000, int32]     # background 0xRRGGBB behind the text, or -1
seg_bold:  Array[6000, uint8]
seg_uline: Array[6000, uint8]
seg_link:  Array[6000, int32]    # link id or -1
# seg_face — pixel-render font FACE hint for the graphical (htmlpaint) backend.
# The legacy monospace-grid dump ignores it; the pixel engine maps it onto the
# available BDF faces/scales:
#   0 = body proportional sans
#   1 = monospace  (<pre>/<code>)
#   2..7 = heading h1..h6  (integer-scaled + bold sans)
seg_face:  Array[6000, uint8]
# seg_gridx — 1 = this segment is GRID-POSITIONED: the pixel renderer must
# honour its absolute seg_x column (tables, <pre>, box art) instead of the
# proportional inline reflow used for prose. 0 = flow proportionally.
seg_gridx: Array[6000, uint8]
# seg_pxsize — CSS font-size in PIXELS for this segment, or 0 = "use the face
# default". Consumed by the scalable (TrueType) pixel renderer so that
# font-size:14px/18px prose renders at its true continuous size. The legacy
# monospace-grid dump ignores it.
seg_pxsize: Array[6000, int32]
# seg_lineh — CSS line-height for this segment resolved to PIXELS (the line-box
# pitch), or 0 = "use the face default rhythm". Consumed by the pixel renderer
# (lib/htmlpage) to loosen inter-line spacing on a block that sets line-height;
# 0 keeps the default vertical rhythm so unstyled pages are byte-for-byte
# unchanged. The legacy monospace-grid dump ignores it.
seg_lineh: Array[6000, int32]
# seg_img — decoded-image slot (lib/htmlimg) for an <img> segment, or -1 for a
# normal text segment. When >= 0 the pixel renderer BLITS the image into the box
# (seg_imgw x seg_imgh px at seg_x/row-top) instead of drawing text; a value of
# -2 means the src was present but undecodable → draw a broken-image placeholder.
seg_img:   Array[6000, int32]
seg_imgw:  Array[6000, int32]     # image box width  (px)
seg_imgh:  Array[6000, int32]     # image box height (px)
# seg_boxart — 1 for the ASCII box-art border glyphs ('+'/'-'/'|') emitted by
# _emit_box_run/_emit_box_bar, 0 for real content. The monospace-grid text dump
# still paints these glyphs (its gates assert on them), but the PIXEL renderer
# SKIPS them and draws a true 1px border rectangle from the border-box registry
# below instead — so a CSS border looks like a drawn line, not typed characters.
seg_boxart: Array[6000, uint8]
# seg_marker — 1 for the UNORDERED-list ('<ul>') item bullet segment. The
# monospace-grid dump paints the '-' placeholder char it carries, but the PIXEL
# renderer draws a real round bullet DISC in the gutter instead (like a browser's
# default list-style-type:disc), so a list reads as a list and not a run of
# hyphens glued to the text. 0 = normal content.
seg_marker: Array[6000, uint8]
# seg_indjump — 1 for the FIRST text segment of a list item. The pixel renderer
# flows same-row prose contiguously from the pen, which would otherwise collapse
# the marker's hanging indent (packing the item text right after the bullet). A
# set flag tells the renderer to JUMP the pen forward to this segment's seg_x
# (indent_x), preserving the gutter between the marker and the item text.
seg_indjump: Array[6000, uint8]
# seg_yoff — signed VERTICAL pixel offset applied to this segment's baseline by
# the pixel renderer: negative RAISES the run (<sup>), positive LOWERS it
# (<sub>). 0 = on the row baseline (the default for all normal text, so
# unstyled pages are byte-for-byte unchanged).
seg_yoff: Array[6000, int32]
# seg_strike — 1 = draw a horizontal LINE-THROUGH the run (<s>/<del>/<strike>),
# 0 = none. The pixel renderer strokes a 1px rule across the seg's x-height.
seg_strike: Array[6000, uint8]
n_segs:   uint64 = 0
# Pending: mark the next opened segment as a list-item's first text seg so the
# pixel renderer honours its left indent. Set by the <li> handler after the
# marker is emitted; consumed (and cleared) by _seg_ensure.
_pending_indjump: int32 = 0

# ---- pixel border-box registry --------------------------------------
# Each bordered block/float box records its geometry here on close so the PIXEL
# renderer (lib/htmlpage) can stroke a real 1px rectangle with htmlpaint_fill_
# rect instead of leaning on the box-art glyphs. top_row carries the top rule,
# bot_row the bottom rule; lx/rx are the left/right bar pixel columns (char
# grid); rgb is the border colour (0xRRGGBB). Reset each layout with n_segs.
BBOX_MAX:  int32 = 256
bbox_lx:   Array[256, int32]
bbox_rx:   Array[256, int32]
bbox_top:  Array[256, int32]
bbox_bot:  Array[256, int32]
bbox_rgb:  Array[256, int32]
n_bboxes:  int32 = 0

# ---- element background-fill registry -------------------------------
# A block-level box with a `background-color` (or `background`) records its FULL
# box rectangle here on close, so the renderer paints the whole element box —
# header bars, footers, section/card panels, coloured nav strips — not just the
# strip behind each text run (seg_bg). This is the single biggest "looks like a
# real site" gap: virtually every modern page paints a coloured header/footer/
# card. lx/rx are the box's left/right pixel columns; top_row/bot_row bound the
# rows the fill covers [top_row, bot_row); rgb is 0xRRGGBB. Painted BEFORE the
# text segments so glyphs land on top. Reset each layout with n_segs.
BFILL_MAX:  int32 = 256
bfill_lx:   Array[256, int32]
bfill_rx:   Array[256, int32]
bfill_top:  Array[256, int32]
bfill_bot:  Array[256, int32]
bfill_rgb:  Array[256, int32]
bfill_z:    Array[256, int32]   # stacking order (z-index); 0 = default flow
n_bfills:   int32 = 0

# ---- <img> src registry (for the host driver to enumerate + decode) ----
# Every <img src="..."> seen during layout records its src string here so the
# file-reading host can slurp+decode each PNG and register it in lib/htmlimg
# BEFORE a second layout pass resolves natural sizes. Deduplicated by string.
EIMG_MAX:       uint64 = 64
EIMG_NAME_CAP:  uint64 = 8192
eimg_noff: Array[64, uint64]
eimg_nlen: Array[64, uint64]
n_eimg:    uint64 = 0
eimg_name_buf: Array[8192, uint8]
eimg_name_used: uint64 = 0

# broken-image placeholder box (px) when src is absent/undecodable.
IMG_BROKEN_W: int32 = 40
IMG_BROKEN_H: int32 = 32

row_rule: Array[12000, uint8]    # 0 none, 1 heading rule on this row
total_rows: uint64 = 0
top_line:   uint64 = 0

# LINKS — href targets + the spans that point to them.
MAX_LINKS:    uint64 = 1024
LINK_HREF_CAP: uint64 = 32768
link_off: Array[1024, int32]
link_len: Array[1024, int32]
link_href_buf: Array[32768, uint8]
link_href_len: uint64 = 0
n_links: uint64 = 0

# parse-time "pen" + style state
cur_row:  uint64 = 0
pen_x:    int32 = 8
indent_x: int32 = 8
row_dirty: int32 = 0
need_space: int32 = 0
seg_open:  int32 = 0
seg_curlen: uint64 = 0
g_color: int32 = 0
# Page-level background (gap #3): a <body>/<html> `background(-color)` fills the
# WHOLE viewport, not just element boxes. -1 = default white. The pixel renderer
# clears the canvas to this colour instead of white.
g_page_bg: int32 = -1
# Effective display of the element currently being dispatched (0 unset / 1 none
# / 2 flex / 3 block / 4 inline-block / 5 inline), and whether it should be laid
# out as a block box (the generic display:block / flex-item blockification path).
g_eff_disp: int32 = 0
g_treat_as_block: int32 = 0
# flex-direction of the container currently being opened (0 row / 1 column),
# read by _flex_container_open to stack (column) vs. columnise (row).
g_flex_dir: int32 = 0
# justify-content of the container currently being opened (0 unset/default,
# 1 flex-start, 2 center, 3 flex-end, 4 space-between, 5 space-around). Read by
# _flex_container_open: when SET it switches from the equal-column approximation
# to a natural-content-width row with real free-space distribution.
g_flex_just: int32 = 0
# column-gap (px) of the flex container currently being opened, or -1 to use the
# FLEX_GAP default. Read by _flex_container_open as the inter-column gutter.
g_flex_gap: int32 = -1
# row-gap (px) of the flex container currently being opened, or -1 to use no
# inter-line gap. Read by _flex_container_open: a wrapping flex row inserts this
# many px (rounded to whole LINE_H rows) of vertical space between wrapped lines.
g_flex_rowgap: int32 = -1
# flex-wrap of the container currently being opened (0 nowrap / 1 wrap). Read by
# _flex_container_open: when set, overflowing items WRAP onto additional flex
# lines instead of being crammed into one equal-column row.
g_flex_wrap: int32 = 0
# align-items (cross-axis) of the container currently being opened: 0 unset /
# 1 flex-start (== the default, top-aligned) / 2 center / 3 flex-end / 4 stretch.
# Read by _flex_container_open; a value >= 2 arms a deferred cross-axis fixup that
# shifts each already-emitted flex item's segments/fills within its line's height.
g_flex_align: int32 = 0
# ---- CSS grid (display:grid) ------------------------------------------------
# 1 when the container currently being opened is a `display:grid` box. Read by
# _flex_container_open, which lays the container's direct children out in the
# grid TRACK model (a fixed count of columns whose widths come from grid-
# template-columns; items auto-place left-to-right and wrap to the next row every
# ntrack items) instead of a flex row. Grid REUSES the flex frame machinery — it
# is a constrained flex-wrap with fixed per-track widths. Zero-cost when 0.
g_flex_grid: int32 = 0
# Nesting depth of OPEN flex items (a direct block child of a flex container that
# was columnised). Bumped when a flex-item box opens, dropped when it closes, so
# _emit_word can tell it is laying text inside a flex track. A flex item's CSS
# automatic minimum size is min-content: its column must never be shrunk below
# the widest unbreakable word it contains, so a word wider than the (monospace-
# estimated) track must NOT be hard char-broken — it stays intact and overflows
# the track (min-content floor) instead of splitting mid-word ("Nimbus" -> "Nim"
# "bus"). Zero-cost off the flex path: stays 0, so the guard short-circuits.
g_flex_item_depth: int32 = 0
# Nesting depth of open NATURAL-path flex items (justify-content nav/chip rows
# whose tracks are sized to each child's CONTENT, i.e. max-content). Such a track
# is content-sized, so its text is not meant to wrap at all — the child was
# allotted its whole run. The track width is a CELL_W monospace ESTIMATE, so a
# proportional two-word link ("Log in") whose real width exceeds the estimate
# would otherwise wrap between its words. Treat a natural-path item like
# white-space:nowrap so the link/label stays on one line (overflowing into the
# row's free space rather than wrapping). Only the natural path sets this; the
# equal-column fallback (content-heavy flex: article beside sidebar) keeps normal
# word wrap. Zero-cost off the flex path: stays 0.
g_flex_nowrap_depth: int32 = 0
# grid-template-columns of the container being opened, parsed to a compact per-
# track encoding: g_grid_n tracks, each g_grid_enc[c] >= 0 => a FIXED track of
# that many px; < 0 => an `fr` track of weight (-value). Resolved to pixel widths
# at container open (fr shares the free space). Filled at dispatch from the
# cascade winner (m_gtc[]) then the inline style (d_gtc[]). 0 tracks => no grid.
GRID_MAXTRACK: int32 = 8       # max grid columns (tracks) we resolve
GRID_MAXITEM:  int32 = 64      # max auto-placed grid items per container
g_grid_n:   int32 = 0
g_grid_enc: Array[8, int32]
# grid-template-rows of the container being opened, parsed to the SAME compact
# encoding as g_grid_enc but interpreted for ROWS: g_grid_renc[r] >= 0 => a FIXED
# row of that many px (fr rows are ignored — a grid row with no fixed height stays
# content-sized). Gives explicit, non-content row heights (the dashboard case).
g_grid_rn:   int32 = 0
g_grid_renc: Array[8, int32]
# Per-ITEM grid line placement, carried from the child's cascade/inline style to
# the grid item-open path: g_grid_cspan is how many TRACKS the item occupies
# (`grid-column: span N`, or `A / B` => B-A); g_grid_cstart is an explicit 1-based
# start line (`grid-column: A` / `A / B`), 0 = auto-flow into the next free track.
g_grid_cspan:  int32 = 1
g_grid_cstart: int32 = 0
# Stack of el-stack depths at which a GENERIC block box was opened (display:
# block/inline-block/flex, or a flex-item span). A close tag carries no style=""
# attribute, so its display cannot be recomputed from it; instead the matching
# close is recognised by comparing the current el-stack depth against this
# stack's top. This keeps open/close routing symmetric for inline-style blocks.
GBLK_MAX:   int32 = 64
gblk_sp:    int32 = 0
gblk_stack: Array[64, int32]
g_bold:  int32 = 0
g_uline: int32 = 0
g_link:  int32 = -1
# An explicit author colour specified ON the current anchor (a matched `a{}` /
# `.nav a{}` rule or an inline style=""), or -1 when the anchor sets no colour of
# its own. A link keeps its default blue role colour UNLESS this is >= 0, so a
# styled `<a style=color:…>` / `.nav a{color:…}` wins while an inherited ancestor
# colour (e.g. body{color:#333}) still leaves plain links blue.
g_link_rgb: int32 = -1
g_bold_n: int32 = 0          # nested <b>/<strong> depth
g_mono_n: int32 = 0          # nested inline <code>/<kbd>/<samp>/<var> depth
g_heading: int32 = 0        # 0 none, else 1..6
g_strike_n: int32 = 0        # nested <s>/<del>/<strike> depth (line-through)
# <sub>/<sup> vertical shift: g_yoff is the live signed baseline offset (px)
# folded into every opened segment. sub_depth lowers text, sup_depth raises it;
# g_yoff = sub_depth*SUB_DROP - sup_depth*SUP_RISE so nesting composes.
g_yoff: int32 = 0
sub_depth: int32 = 0
sup_depth: int32 = 0
SUB_DROP: int32 = 4          # px a <sub> baseline drops
SUP_RISE: int32 = 6          # px a <sup> baseline rises
list_depth: int32 = 0
bq_depth: int32 = 0         # <blockquote> nesting depth (left indent)
BQ_INDENT: int32 = 24       # px of left indent per blockquote level
dd_depth: int32 = 0         # <dd> nesting depth (left indent under a <dl>)
DD_INDENT: int32 = 40       # px of left indent per <dd> level (browser default)
MARK_BG: int32 = 0xfff275   # <mark> highlight background (yellow)
pre_mode: int32 = 0

# LIST layout — <ul>/<ol>/<li> with markers, ordered numbering + nesting.
# One entry per open list level (list_depth): list_type is 0 for <ul>
# (bullet marker) or 1 for <ol> (running number), list_count is the <ol>
# item counter (the NEXT item's number). LIST_STEP is the per-level left
# indent (in px); it is exactly wide enough to be the marker gutter so item
# markers hang in the parent level's left margin and wrapped continuation
# lines align under the item TEXT (a proper hanging indent).
MAX_LIST_DEPTH: int32 = 16
LIST_STEP:  int32 = 32       # px of left indent per list level (= 4 cells)
list_type:  Array[16, int32]
list_count: Array[16, int32]
# 1 for a list level whose <ul>/<ol> armed a horizontal flex row (display:flex)
# over its <li> columns, so the matching </ul>/</ol> pops the flex frame.
list_flex:  Array[16, int32]
# 1 for a list level whose flex <ul>/<ol> opened its OWN container box (so its
# background/border paints as a bar over the whole flex row); the close pops it.
list_box:   Array[16, int32]
# 1 for a list level that SUPPRESSED its LIST_STEP indent (a flex list resets its
# left padding, so the navbar sits flush); the close restores list_indent_drop.
list_supp:  Array[16, int32]
# 1 for a list level whose <ul>/<ol> set list-style[-type]:none — its <li>
# children draw no bullet/number marker (the ubiquitous navbar/menu reset).
list_nomarker: Array[16, int32]
# 1 for a list level whose CURRENT <li> opened an _open_style() scope (its own
# class/inline cascade — colour, text-decoration, font-weight, …). Real HTML
# routinely omits </li> (`<li>a<li>b<li>c`), so the scope is balanced by an
# IMPLICIT </li> synthesised at the next <li> / </ul> / </ol> at this level (or
# by an explicit </li>). This keeps the colour/deco style stack balanced even
# when </li> is absent — see _li_close_lvl and the <li> handler.
li_styled: Array[16, int32]
# px of LIST_STEP indent currently suppressed by open flex lists (subtracted in
# _recompute_indent). Accumulator so nested flex lists compose correctly.
list_indent_drop: int32 = 0

# BLOCK left-indent from CSS margin-left/padding-left (inline style OR a
# stylesheet/class rule). A stack of px deltas parallel to open <p>/<div>
# blocks; blk_indent_sum is the live total folded into indent_x by
# _recompute_indent(). This makes margin/padding actually shift a block's
# content column (not just decorate it).
blk_indent_stack: Array[64, int32]
blk_indent_sp:  int32 = 0
blk_indent_sum: int32 = 0

# BLOCK right edge (px) — the live wrap boundary a block flows against, folded
# in by _flow_right(). margin-right/padding-right shrink it from the parent's
# edge and `width` pins it to indent_x+width; a border steals one more cell.
# Parallel stack to the left indent so nested blocks restore the parent edge.
blk_right_stack: Array[64, int32]
blk_right_sp:   int32 = 0
blk_right_cur:  int32 = 0        # current right edge; reset to _content_right()

# BOX unit mapping (char-grid model): 1em == EM_PX px == 2 character cells wide
# (CELL_W=8) and one text line tall (LINE_H=16); `%` is taken of the body
# content width (bw - 2*CONTENT_X). Vertical margin/padding px are quantised to
# blank text lines at LINE_H granularity.
EM_PX: int32 = 16

# UA default background for <pre>/<code> so code stands out from body text
# (a light neutral panel behind the monospace run).
CODE_BG: int32 = 0xeef0f3

# Per-open-block state carried from _block_box_open() to _block_box_close():
# the bottom vertical gap (blank lines), whether a border is drawn, and the
# border box geometry (left/right pixel columns + the first content row) so the
# closing side/bottom glyphs land in the right place.
box_botg_stack: Array[64, int32]
box_bord_stack: Array[64, int32]
box_lx_stack:   Array[64, int32]
box_rx_stack:   Array[64, int32]
box_srow_stack: Array[64, int32]
box_bg_stack:   Array[64, int32]      # element background-color (0xRRGGBB) or -1
box_sp: int32 = 0

# ---- CSS float --------------------------------------------------------------
# A `float: left|right` block is laid out as a NARROW box pinned to the left or
# right edge; the following in-flow content then RE-FLOWS beside it (the pixel
# renderer sorts segs by row-then-x, so the float on one side and the body text
# on the other share the same rows). The single-pass source walker makes this
# work without a second layout pass: the float's own content is emitted first
# (in source order), then on the float's close we REWIND cur_row to the float's
# top and set an exclusion so subsequent lines wrap in the remaining width until
# they clear the float's bottom. Only ONE float is active at a time — a second
# float that opens while one is active falls back to a normal in-flow block.
#
# Zero-cost for float-free pages: float_active stays 0, float_left_pad stays 0,
# so _recompute_indent()/_flow_right() are byte-identical to before.
FLOAT_GAP:      int32 = 8        # px gutter between a float and the body text
FLOAT_DEF_W:    int32 = 240      # default float width (px) when none is given
float_active:   int32 = 0        # a float exclusion is in effect
float_side:     int32 = 0        # 1 = left, 2 = right
float_bottom:   int32 = 0        # first row at/after which the exclusion ends
float_left_pad: int32 = 0        # left float: px added to indent_x while active
float_redge:    int32 = 0        # right float: right wrap boundary while active
# Per-open-block: which side THIS block floats (0 = in-flow), its top row (to
# rewind to on close), and its exclusion geometry (redge for right / pad for
# left). Parallel to the box_*_stack.
box_float_stack:  Array[64, int32]
box_ftop_stack:   Array[64, int32]
box_fgeom_stack:  Array[64, int32]

# ---- CSS flexbox (display:flex, row direction) ------------------------------
# A `display:flex` block lays its DIRECT-CHILD block boxes out HORIZONTALLY:
# each child becomes a column whose width is an equal share of the container's
# content width (minus inter-column gaps). This is the single most common
# real-page layout that the old block-stacking model got wrong — a Wikipedia
# article body beside its infobox, a card row, a two-column landing hero.
#
# Implementation reuses the same single-pass "rewind" trick the floats use: the
# container records its top row; each child column is opened as a normal block
# box pinned to its column x (left inset = column offset, width = column width),
# its content flows down, and on the child's close cur_row is REWOUND to the
# container top so the next sibling column starts level with it. The container's
# close advances cur_row past the TALLEST column. A pre-scan counts the direct
# block children so the column width is known before the first child is placed.
#
# Zero-cost for flex-free pages: flex_sp stays 0, so every guard short-circuits
# and the block path is byte-identical to before.
FLEX_MAX:      int32 = 8          # max flex frames / columns we handle
FLEX_GAP:      int32 = 8          # px gutter between flex columns
flex_sp:       int32 = 0
flex_top_row:  Array[8, int32]    # container top row (children rewind here)
flex_max_bot:  Array[8, int32]    # deepest child bottom row seen so far
flex_left:     Array[8, int32]    # container content-left px
flex_colw:     Array[8, int32]    # per-column width px
flex_gap:      Array[8, int32]    # per-column advance = colw + FLEX_GAP
flex_ncol:     Array[8, int32]    # number of child columns
flex_next:     Array[8, int32]    # index of the next child column to place
flex_eldepth:  Array[8, int32]    # el-stack depth of the container element
# justify-content NATURAL-width mode: when a container has an explicit
# justify-content and its children's natural content widths fit the row, each
# child is placed at its own pre-computed x with its own natural width (real
# free-space distribution) instead of the equal-column approximation.
flex_natural:  Array[8, int32]    # 1 => use flex_child_x/_w, not equal columns
flex_child_x:  Array[64, int32]   # [frame*FLEX_MAX+col] x offset from flex_left
flex_child_w:  Array[64, int32]   # [frame*FLEX_MAX+col] natural content width px
flex_meas_w:   Array[8, int32]    # scratch: per-child measured natural widths
# flex-wrap MULTI-LINE mode: an overflowing flex row wraps its items onto extra
# lines (modern card grids / responsive navbars). Placement is ONLINE — each item
# is measured at its own open (its resolved CSS `width`, else its pre-measured
# natural content width) and, if it no longer fits on the current line, starts a
# NEW line below the tallest item of the previous one. This reuses the same
# single-pass rewind trick as single-line flex, so line heights need no 2nd pass.
flex_wrap_on:  Array[8, int32]    # 1 => this frame wraps onto multiple lines
flex_avail:    Array[8, int32]    # content width the items wrap within (px)
flex_rawgap:   Array[8, int32]    # inter-item gap px (author gap / FLEX_GAP)
flex_rowgap:   Array[8, int32]    # inter-LINE gap in ROWS (row-gap px / LINE_H)
flex_cur_x:    Array[8, int32]    # running x cursor within the line (from flex_left)
flex_line_top: Array[8, int32]    # top row of the current line
flex_line_bot: Array[8, int32]    # running bottom (first free row) of cur line
# align-items (cross-axis) CROSS-AXIS FIXUP. The engine emits each flex item's
# glyphs/fills top-aligned at the line top during its single online pass; but the
# line's cross-axis extent (its tallest item) is only known once every item on the
# line has been placed. Rather than a full second layout pass, we record — per
# item, ONLY when flex_align >= 2 (so flex-start stays byte-identical, zero writes)
# — the [seg,bfill,bbox) index ranges it emitted plus its line-top and bottom rows,
# then at the container's close SHIFT those already-emitted coordinates down by the
# per-item cross-axis offset (center/flex-end) or STRETCH its box fill/border to the
# full line height. A deferred coordinate fixup, O(items + flex segs), not a re-pass.
flex_align:    Array[8, int32]    # 0/1 flex-start / 2 center / 3 flex-end / 4 stretch
flex_it_seg0:  Array[64, int32]   # [frame*FLEX_MAX+col] n_segs at item open
flex_it_seg1:  Array[64, int32]   # [frame*FLEX_MAX+col] n_segs at item close
flex_it_bf0:   Array[64, int32]   # [frame*FLEX_MAX+col] n_bfills at item open
flex_it_bf1:   Array[64, int32]   # [frame*FLEX_MAX+col] n_bfills at item close
flex_it_bx0:   Array[64, int32]   # [frame*FLEX_MAX+col] n_bboxes at item open
flex_it_bx1:   Array[64, int32]   # [frame*FLEX_MAX+col] n_bboxes at item close
flex_it_ltop:  Array[64, int32]   # [frame*FLEX_MAX+col] line-top row the item sat at
flex_it_bot:   Array[64, int32]   # [frame*FLEX_MAX+col] item's exclusive bottom row
# CSS GRID reuse of the flex frame: a `display:grid` container places its items
# into fixed TRACK columns (widths resolved from grid-template-columns into the
# shared flex_child_x/_w arrays; fr distributes free space) and auto-wraps to the
# next row every flex_ntrack items. The current row uses flex_line_top/_bot (the
# same seam flex-wrap uses). Zero-cost: flex_grid stays 0 for non-grid frames.
flex_grid:     Array[8, int32]    # 1 => this frame is a grid (track auto-placement)
flex_ntrack:   Array[8, int32]    # number of grid columns (tracks) <= GRID_MAXTRACK
# Grid explicit-placement + explicit-row-height state (all zero for non-grid /
# auto frames). flex_gcur is the next FREE track column (0-based) the auto-flow
# cursor will place into — reused in place of a modulo of the item index so that
# multi-track spans (grid-column) advance the cursor by their width. The grid-
# template-rows fixed heights are stored per row into flex_growh (px; 0 =
# content-sized) with flex_growidx tracking which grid row is currently open.
flex_gcur:     Array[8, int32]    # next free track column for auto-placement
flex_gridrn:   Array[8, int32]    # grid-template-rows count (0 => all content-sized)
flex_growidx:  Array[8, int32]    # current grid row index (0-based)
flex_growh:    Array[64, int32]   # [frame*FLEX_MAX+row] fixed row height px (0=content)
# Per-open-block markers (parallel to box_*_stack): 1 if THIS block box is a
# flex item (a column) / a flex container (owns a frame).
box_flexitem_stack: Array[64, int32]
box_flexcont_stack: Array[64, int32]
# Per-open-block CSS-position bookkeeping (parallel to box_*_stack): the box's
# position mode (0/1/2), the segment index at its open, the row to rewind to on
# close (absolute = out of flow), and whether this box pushed a posctx frame.
box_pos_stack:    Array[64, int32]
box_posrun_stack: Array[64, int32]   # index into the positioned-run table (-1)
box_pretrow_stack: Array[64, int32]  # row to rewind to on close (absolute)
box_pushedctx_stack: Array[64, int32]

# ---- CSS inline-block (inline-level box in the line grid) --------------------
# `display:inline-block` chips/badges/buttons/nav-pills flow INLINE on a text
# line (advancing pen_x) and WRAP to the next line when they overflow — unlike a
# block, they do NOT each claim their own full-width row. Each open chip is a
# fixed-width box (its collapsed inner-text width + 2*INLB_PADX) that paints a
# narrow background FILL over its box and insets its text by the left padding;
# its close snaps pen_x to the box's right edge + INLB_GAP so the next chip
# flows after it. Zero-cost for chip-free pages: inlb_sp stays 0.
INLB_MAX:   int32 = 64
INLB_PADX:  int32 = 6         # px inner horizontal padding each side of a chip
INLB_GAP:   int32 = 6         # px gutter after a chip before the next inline box
inlb_sp:    int32 = 0
inlb_startx:  Array[64, int32]   # left px of the chip box (before padding)
inlb_boxw:    Array[64, int32]   # total chip box width px (text + 2*INLB_PADX)
inlb_row:     Array[64, int32]   # the row the chip sits on
inlb_eldepth: Array[64, int32]   # el-stack depth of the chip element (close match)
inlb_yoff:    Array[64, int32]   # baseline shift (px) applied to centre a TALL chip
# Set in the tag-dispatch preamble when the element being opened/closed is an
# inline-block box handled by the inline-flow path (routes it AROUND the generic
# block-box blockification).
g_inlb: int32 = 0
# When an inline-block chip grows TALLER than one text line (vertical padding or
# min-height), this holds the first free row BELOW the tallest such chip on the
# current line (0 = no tall chip). The next line break (_bump_row) snaps cur_row
# down to it so following content clears the box, then clears it. Zero-cost for
# one-row chips: it stays 0 and every guard short-circuits.
g_inlb_floor: int32 = 0

# TABLE layout — two-pass column model. Pass 1 (_measure_table) walks the
# table source and records the widest cell (in characters) per column; pass 2
# (_compute_cols) turns those into pixel column x-positions. During the normal
# linear parse each <tr> is one visual row and each <td>/<th> places its text
# at its column's x, clamped to the column's right edge (cell_right) so a wide
# cell wraps inside its column instead of bleeding across the table.
MAX_COLS:    int32 = 32
CELL_PAD:    int32 = 2       # inter-column gap, in character cells
# CELL_PADX: per-side content inset (px) between a cell's border and its text,
# so header/body text never touches or overlaps the column/table border the way
# an inset-less pen (text drawn straight from col_x, i.e. the border) does. The
# UA default is ~1px border-spacing + a couple px cell padding; 6px reads right
# at CELL_W=8. Applied to BOTH edges (left inset on open, right clamp on close).
CELL_PADX:   int32 = 6
col_x:    Array[33, int32]   # pixel x of each column (index n_cols = right edge)
col_chars: Array[32, int32]  # widest cell per column, in characters
n_cols:      int32 = 0
table_active: int32 = 0
cell_active:  int32 = 0      # inside a <td>/<th> (drives cell_right + styling)
cell_is_th:   int32 = 0      # current cell is a <th> (bold)
cell_right:   int32 = 0      # right edge (px) of the current cell's column
cur_col:      int32 = 0
# A <table style="float:right|left"> (the Wikipedia infobox) is laid out inside
# the SAME float exclusion block containers use: the table's grid is measured to
# its natural width, a float box of that width is pinned to the edge, and the
# body text re-flows beside it. 1 while the current table floated (its close
# must go through _float_box_close instead of the in-flow para break).
table_floated: int32 = 0

# NESTED-TABLE context stack. A <table> inside a <td> is laid out as its own
# table box within the parent cell: on open the parent's column model + cell
# scope is pushed here (so _measure_table/_compute_cols may overwrite the shared
# col_x/col_chars/n_cols globals) and restored on the inner </table>, letting
# tables nest to arbitrary depth. Each entry also records THIS table's border
# geometry (left x, top row) so its border strokes as a real rectangle via the
# same bbox registry, independent of the outer table's border.
TBL_MAX:  int32 = 8
tbl_sp:   int32 = 0
tbl_ncols_st:     Array[8, int32]
tbl_curcol_st:    Array[8, int32]
tbl_cellact_st:   Array[8, int32]
tbl_cellright_st: Array[8, int32]
tbl_cellisth_st:  Array[8, int32]
tbl_indentx_st:   Array[8, int32]
tbl_floated_st:   Array[8, int32]
tbl_colx_st:      Array[264, int32]   # 8 * 33 saved col_x snapshots
tbl_srow_st:      Array[8, int32]     # this table's top-rule row
tbl_lx_st:        Array[8, int32]     # this table's left x (border left edge)
tbl_border_st:    Array[8, int32]     # 1 if this table strokes an in-flow border
tbl_rgb_st:       Array[8, int32]     # this table's border colour (0xRRGGBB)

skip_active: int32 = 0
skip_name: Array[16, uint8]
skip_nlen: uint64 = 0

# CSS colour state — a stack of explicit colours pushed by colour-bearing
# elements (span/font/p/div/h1-h3). g_rgb is the effective colour (topmost
# non-sentinel entry), or -1 when no explicit colour applies.
COLOR_STACK_CAP: int32 = 64
color_stack: Array[64, int32]
color_sp: int32 = 0
g_rgb: int32 = -1

# CSS background-colour state — a parallel stack to the text-colour stack.
# Pushed by bgcolor / background-color-bearing elements (body-less: p/div/
# span/font/h*/blockquote/table/tr/td/th). g_bg is the effective (topmost
# non-sentinel) background, or -1 when none applies.
bg_stack: Array[64, int32]
bg_sp: int32 = 0
g_bg: int32 = -1

# inline word accumulator
WORD_CAP: uint64 = 2048
word_buf: Array[2048, uint8]
word_len: uint64 = 0
# Decoded-entity output: up to 4 UTF-8 bytes for one code point.
g_ent_buf: Array[4, uint8]
g_ent_len: int32 = 0


def _palette(idx: uint8) -> Ptr[uint8]:
    if idx == 1:
        return cast[Ptr[uint8]]("#1a4fd0")          # link blue
    if idx == 2:
        return cast[Ptr[uint8]]("#14306e")          # heading dark blue
    if idx == 3:
        return cast[Ptr[uint8]]("#0a6b5a")          # pre/code teal
    return cast[Ptr[uint8]]("#101010")              # body text


# Palette index -> packed 0xRRGGBB (mirrors _palette; used to resolve a
# segment to a concrete colour for rendering / dumping).
def _palette_rgb(idx: uint8) -> int32:
    if idx == 1:
        return 0x1a4fd0
    if idx == 2:
        return 0x14306e
    if idx == 3:
        return 0x0a6b5a
    return 0x101010


# ---- CSS colour stack ----------------------------------------------
def _color_effective() -> int32:
    i: int32 = color_sp - 1
    while i >= 0:
        if color_stack[i] >= 0:
            return color_stack[i]
        i = i - 1
    return -1


def _color_push(rgb: int32):
    if color_sp < COLOR_STACK_CAP:
        color_stack[color_sp] = rgb
        color_sp = color_sp + 1
    g_rgb = _color_effective()


def _color_pop():
    if color_sp > 0:
        color_sp = color_sp - 1
    g_rgb = _color_effective()


# ---- CSS background-colour stack (mirrors the text-colour stack) -----
def _bg_effective() -> int32:
    i: int32 = bg_sp - 1
    while i >= 0:
        if bg_stack[i] >= 0:
            return bg_stack[i]
        i = i - 1
    return -1


def _bg_push(rgb: int32):
    if bg_sp < COLOR_STACK_CAP:
        bg_stack[bg_sp] = rgb
        bg_sp = bg_sp + 1
    g_bg = _bg_effective()


def _bg_pop():
    if bg_sp > 0:
        bg_sp = bg_sp - 1
    g_bg = _bg_effective()


def _base_color() -> int32:
    if g_heading != 0:
        return 2
    if pre_mode != 0:
        return 3
    return 0


def _recompute_style():
    if g_link >= 0:
        g_color = 1
        # Links default to underlined, but text-decoration:none (g_css_uline==2)
        # on the link (or an ancestor) strips it — the common nav/button pattern.
        if g_css_uline == 2:
            g_uline = 0
        else:
            g_uline = 1
    else:
        g_color = _base_color()
        # Non-link text underlines only when CSS text-decoration:underline set it.
        if g_css_uline == 1:
            g_uline = 1
        else:
            g_uline = 0
    if g_bold_n > 0 or g_heading != 0 or g_css_bold != 0:
        g_bold = 1
    else:
        g_bold = 0
    # text-decoration:line-through (deco 3) — separate from underline (1)/none (2).
    if g_css_uline == 3:
        g_css_strike = 1
    else:
        g_css_strike = 0


# ---- segment building -----------------------------------------------
# Pixel-render FACE hint for the segment currently being opened. Heading wins
# (headings are never <pre>/<code>); then monospace; else body sans.
def _cur_face() -> uint8:
    if g_heading != 0:
        h: int32 = g_heading
        if h > 6:
            h = 6
        return cast[uint8](1 + h)                     # 2..7 = h1..h6
    if pre_mode != 0 or g_mono_n > 0:
        return 1                                       # monospace
    return 0                                           # body sans


def _seg_ensure():
    if seg_open != 0:
        return
    if n_segs >= MAX_SEGS:
        return
    seg_open = 1
    seg_x[n_segs]    = pen_x
    seg_line[n_segs] = cast[int32](cur_row)
    seg_off[n_segs]  = cast[int32](seg_text_len)
    seg_color[n_segs] = cast[uint8](g_color)
    # An explicit CSS colour overrides the role palette, EXCEPT on links,
    # which keep their blue role colour.
    if g_link < 0:
        seg_rgb[n_segs] = g_rgb
    else:
        # Links keep their blue role colour, EXCEPT when the anchor specifies its
        # own colour (author `a{color:…}` / inline) — then that colour wins.
        seg_rgb[n_segs] = g_link_rgb
    seg_bg[n_segs]    = g_bg
    seg_bold[n_segs]  = cast[uint8](g_bold)
    seg_uline[n_segs] = cast[uint8](g_uline)
    seg_link[n_segs]  = g_link
    seg_face[n_segs]  = _cur_face()
    seg_pxsize[n_segs] = g_font_px
    seg_lineh[n_segs] = g_lineh
    seg_img[n_segs]   = -1
    seg_boxart[n_segs] = 0
    seg_marker[n_segs] = 0
    seg_yoff[n_segs]  = g_yoff
    if g_strike_n > 0 or g_css_strike != 0:
        seg_strike[n_segs] = 1
    else:
        seg_strike[n_segs] = 0
    # A list-item's first text seg claims the pending hanging-indent jump.
    if _pending_indjump != 0:
        seg_indjump[n_segs] = 1
        _pending_indjump = 0
    else:
        seg_indjump[n_segs] = 0
    # Table cells + <pre> are laid out on absolute grid columns; the pixel
    # renderer honours seg_x for them so columns/alignment survive.
    if table_active != 0 or pre_mode != 0:
        seg_gridx[n_segs] = 1
    else:
        seg_gridx[n_segs] = 0
    seg_curlen = 0
    # Record the row's text-alignment (a post-layout pass shifts seg_x).
    # Table/pre rows keep their computed geometry (no re-alignment).
    if g_align != 0 and table_active == 0 and pre_mode == 0 and \
       cur_row < MAX_ROWS:
        row_align[cur_row] = cast[uint8](g_align)


def _seg_putc(c: uint8):
    _seg_ensure()
    if seg_open == 0:
        return
    if seg_text_len < SEG_TEXT_CAP - 1:
        seg_text_buf[seg_text_len] = c
        seg_text_len = seg_text_len + 1
        seg_curlen = seg_curlen + 1
    row_dirty = 1


# Emit a non-negative decimal integer into the current segment (marker use).
def _seg_putc_dec(v: int32):
    if v < 0:
        v = 0
    if v >= 10:
        _seg_putc_dec(v / 10)
    _seg_putc(cast[uint8](48 + (v - (v / 10) * 10)))


def _close_seg():
    if seg_open == 0:
        return
    if seg_curlen > 0 and n_segs < MAX_SEGS:
        seg_len[n_segs] = cast[int32](seg_curlen)
        n_segs = n_segs + 1
    seg_open = 0
    seg_curlen = 0


# A style change closes the current segment so the next text opens a fresh
# one carrying the new attributes.
def _style_break():
    _close_seg()
    _recompute_style()


# ---- line breaks ----------------------------------------------------
def _bump_row():
    cur_row = cur_row + 1
    if cur_row >= MAX_ROWS:
        cur_row = MAX_ROWS - 1
    # Clear a tall inline-block chip: the first line break after it drops past the
    # box's reserved rows so following content does not overlap it. 0 => no-op.
    if g_inlb_floor != 0:
        if cur_row < cast[uint64](g_inlb_floor):
            cur_row = cast[uint64](g_inlb_floor)
        g_inlb_floor = 0


def _soft_newline():
    # Move to a fresh line ONLY if the current one has content.
    _close_seg()
    if row_dirty != 0:
        _bump_row()
    _maybe_clear_float()
    pen_x = indent_x
    row_dirty = 0
    need_space = 0


def _newline():
    # Unconditional line break (<br>, pre newline).
    _close_seg()
    _bump_row()
    _maybe_clear_float()
    pen_x = indent_x
    row_dirty = 0
    need_space = 0


def _para_break():
    # End the current line + leave a single blank gap.
    _soft_newline()
    _bump_row()
    _maybe_clear_float()
    pen_x = indent_x
    need_space = 0


# Left indent = list nesting + blockquote nesting. Both front-ends flow to
# indent_x, so this is the single left-margin knob for block structure.
def _recompute_indent():
    indent_x = _left_margin() + list_depth * LIST_STEP - list_indent_drop + \
               bq_depth * BQ_INDENT + \
               dd_depth * DD_INDENT + blk_indent_sum + float_left_pad


# Drop an active float exclusion once flow has passed the float's bottom row.
# Called at every line start; a no-op (single compare) when no float is active.
def _maybe_clear_float():
    if float_active != 0 and cast[int32](cur_row) >= float_bottom:
        float_active = 0
        float_side = 0
        float_redge = 0
        if float_left_pad != 0:
            float_left_pad = 0
            _recompute_indent()


# Push/pop a block's CSS left indent (margin-left+padding-left). Always paired
# per <p>/<div> open/close (a 0-px block still pushes, to stay balanced), and
# both refresh indent_x + the pen so content flows at the new left column.
def _blk_indent_push(px: int32):
    if blk_indent_sp < 64:
        blk_indent_stack[blk_indent_sp] = px
        blk_indent_sp = blk_indent_sp + 1
        blk_indent_sum = blk_indent_sum + px
    _recompute_indent()
    pen_x = indent_x


def _blk_indent_pop():
    if blk_indent_sp > 0:
        blk_indent_sp = blk_indent_sp - 1
        blk_indent_sum = blk_indent_sum - blk_indent_stack[blk_indent_sp]
    _recompute_indent()
    pen_x = indent_x


# ---- CSS border box (char-grid glyphs) ------------------------------
# Emit `ncells` copies of glyph `ch` as one standalone segment at (row, x).
# Used for the horizontal top/bottom border rules; writes the seg arrays
# directly (bypassing the pen) so it can target an arbitrary row.
def _emit_box_run(row: int32, x: int32, ch: uint8, ncells: int32):
    if ncells <= 0 or n_segs >= MAX_SEGS:
        return
    seg_x[n_segs]     = x
    seg_line[n_segs]  = row
    seg_off[n_segs]   = cast[int32](seg_text_len)
    seg_color[n_segs] = 0
    seg_rgb[n_segs]   = -1
    seg_bg[n_segs]    = -1
    seg_bold[n_segs]  = 0
    seg_uline[n_segs] = 0
    seg_link[n_segs]  = -1
    seg_face[n_segs]  = 1                              # box art = monospace
    seg_gridx[n_segs] = 1
    seg_img[n_segs]   = -1
    seg_boxart[n_segs] = 1
    seg_yoff[n_segs]  = 0
    seg_strike[n_segs] = 0
    k: int32 = 0
    while k < ncells and seg_text_len < SEG_TEXT_CAP - 1:
        c: uint8 = ch
        if k == 0 or k == ncells - 1:
            c = 43                                    # '+' corners/ends
        seg_text_buf[seg_text_len] = c
        seg_text_len = seg_text_len + 1
        k = k + 1
    seg_len[n_segs] = k
    n_segs = n_segs + 1


# Emit a single vertical bar '|' glyph at (row, x).
def _emit_box_bar(row: int32, x: int32):
    if n_segs >= MAX_SEGS or seg_text_len >= SEG_TEXT_CAP - 1:
        return
    seg_x[n_segs]     = x
    seg_line[n_segs]  = row
    seg_off[n_segs]   = cast[int32](seg_text_len)
    seg_color[n_segs] = 0
    seg_rgb[n_segs]   = -1
    seg_bg[n_segs]    = -1
    seg_bold[n_segs]  = 0
    seg_uline[n_segs] = 0
    seg_link[n_segs]  = -1
    seg_face[n_segs]  = 1                              # box art = monospace
    seg_gridx[n_segs] = 1
    seg_img[n_segs]   = -1
    seg_boxart[n_segs] = 1
    seg_yoff[n_segs]  = 0
    seg_strike[n_segs] = 0
    seg_text_buf[seg_text_len] = 124                  # '|'
    seg_text_len = seg_text_len + 1
    seg_len[n_segs] = 1
    n_segs = n_segs + 1


# ---- <img> pixel box ------------------------------------------------
# Record an <img>'s src string (src_ptr[soff..soff+slen)) in the registry the
# host driver reads to decode PNGs. Deduplicated; a no-op if src is empty/full.
def _eimg_record(soff: uint64, slen: uint64):
    if slen == 0:
        return
    i: uint64 = 0
    while i < n_eimg:
        if eimg_nlen[i] == slen:
            same: int32 = 1
            k: uint64 = 0
            while k < slen:
                if eimg_name_buf[eimg_noff[i] + k] != src_ptr[soff + k]:
                    same = 0
                    break
                k = k + 1
            if same != 0:
                return
        i = i + 1
    if n_eimg >= EIMG_MAX or eimg_name_used + slen > EIMG_NAME_CAP:
        return
    eimg_noff[n_eimg] = eimg_name_used
    eimg_nlen[n_eimg] = slen
    k2: uint64 = 0
    while k2 < slen:
        eimg_name_buf[eimg_name_used + k2] = src_ptr[soff + k2]
        k2 = k2 + 1
    eimg_name_used = eimg_name_used + slen
    n_eimg = n_eimg + 1


# alt-text placeholder for the current <img> (bracketed, e.g. "[Hamnix logo]").
img_alt_buf: Array[256, uint8]
img_alt_len: uint64 = 0


# Emit a standalone image segment: a block box of `bw2`x`bh2` px at the current
# left indent, carrying the decoded-image slot (or -2 = broken placeholder). The
# segment ALSO holds the bracketed alt text (img_alt_buf) so the legacy
# monospace-grid dump and the native text path have a meaningful glyph fallback;
# the PIXEL renderer ignores that text and blits the image box instead. The
# image owns its own visual row so following content flows below it.
def _emit_img_seg(slot: int32, bw2: int32, bh2: int32):
    _close_seg()
    _soft_newline()
    if n_segs >= MAX_SEGS:
        return
    seg_x[n_segs]     = indent_x
    seg_line[n_segs]  = cast[int32](cur_row)
    seg_off[n_segs]   = cast[int32](seg_text_len)
    seg_color[n_segs] = 0
    seg_rgb[n_segs]   = -1
    seg_bg[n_segs]    = -1
    seg_bold[n_segs]  = 0
    seg_uline[n_segs] = 0
    seg_link[n_segs]  = g_link
    seg_face[n_segs]  = 0
    seg_pxsize[n_segs] = 0
    seg_lineh[n_segs] = g_lineh
    seg_gridx[n_segs] = 1                              # absolute x, no reflow
    seg_img[n_segs]   = slot
    seg_boxart[n_segs] = 0
    seg_yoff[n_segs]  = 0
    seg_strike[n_segs] = 0
    seg_imgw[n_segs]  = bw2
    seg_imgh[n_segs]  = bh2
    # copy the bracketed alt text into the segment's glyph run.
    k: uint64 = 0
    while k < img_alt_len and seg_text_len < SEG_TEXT_CAP - 1:
        seg_text_buf[seg_text_len] = img_alt_buf[k]
        seg_text_len = seg_text_len + 1
        k = k + 1
    seg_len[n_segs]   = cast[int32](k)
    n_segs = n_segs + 1
    row_dirty = 1
    _soft_newline()                                   # content below the image


# Handle an <img> open tag: resolve src + width/height, compute the box size
# (natural size from a decoded image if available, else attribute size, else a
# broken-image placeholder), record the src for the host, and emit the box.
def _handle_img(ne: uint64, te: uint64):
    _word_flush()
    soff: uint64 = 0
    slen: uint64 = 0
    if _hx_find_attr(ne, te, cast[Ptr[uint8]]("src")) != 0 and g_attr_end > g_attr_start:
        soff = g_attr_start
        slen = g_attr_end - g_attr_start
    _eimg_record(soff, slen)
    # Build the bracketed alt placeholder ("[alt]" or "[img]") NOW, before the
    # width/height _attr_int calls clobber g_attr_start/end.
    img_alt_len = 0
    img_alt_buf[img_alt_len] = 91                      # '['
    img_alt_len = img_alt_len + 1
    if _hx_find_attr(ne, te, cast[Ptr[uint8]]("alt")) != 0 and g_attr_end > g_attr_start:
        p: uint64 = g_attr_start
        while p < g_attr_end and img_alt_len < 254:
            c: uint8 = src_ptr[p]
            if c == 9 or c == 10 or c == 13:
                c = 32
            img_alt_buf[img_alt_len] = c
            img_alt_len = img_alt_len + 1
            p = p + 1
    else:
        img_alt_buf[img_alt_len] = 105                 # 'i'
        img_alt_buf[img_alt_len + 1] = 109             # 'm'
        img_alt_buf[img_alt_len + 2] = 103             # 'g'
        img_alt_len = img_alt_len + 3
    img_alt_buf[img_alt_len] = 93                      # ']'
    img_alt_len = img_alt_len + 1
    slot: int32 = -1
    natw: int32 = 0
    nath: int32 = 0
    if slen > 0:
        slot = htmlimg_find(&src_ptr[soff], slen)
        if slot >= 0:
            natw = htmlimg_w(slot)
            nath = htmlimg_h(slot)
    aw: int32 = _attr_int(ne, te, cast[Ptr[uint8]]("width"), -1)
    ah: int32 = _attr_int(ne, te, cast[Ptr[uint8]]("height"), -1)
    bw2: int32 = 0
    bh2: int32 = 0
    if aw > 0 and ah > 0:
        bw2 = aw
        bh2 = ah
    elif aw > 0:
        bw2 = aw
        if natw > 0:
            bh2 = nath * aw / natw
        else:
            bh2 = aw
    elif ah > 0:
        bh2 = ah
        if nath > 0:
            bw2 = natw * ah / nath
        else:
            bw2 = ah
    else:
        if natw > 0:
            bw2 = natw
            bh2 = nath
    if bw2 <= 0 or bh2 <= 0:
        # no decoded image AND no usable attributes -> broken placeholder box.
        slot = -2
        bw2 = IMG_BROKEN_W
        bh2 = IMG_BROKEN_H
    elif slot < 0:
        slot = -2                                     # sized but undecodable
    # clamp the box so a pathological width can't blow up the canvas.
    if bw2 > bw:
        # scale height with width to preserve aspect when clamping.
        if bw2 > 0:
            bh2 = bh2 * bw / bw2
        bw2 = bw
    if bh2 < 1:
        bh2 = 1
    _emit_img_seg(slot, bw2, bh2)


# ---- inline <svg> ---------------------------------------------------
# A synthetic src-name buffer keying each inline <svg>'s rasterised RGBA in the
# lib/htmlimg store. The name is "svg@<byte-offset>" so a given <svg> in the
# source resolves to the SAME slot across the engine's two layout passes (no
# duplicate copies), yet two distinct <svg> elements never collide.
isvg_name: Array[24, uint8]


def _isvg_name(off: uint64) -> uint64:
    isvg_name[0] = 115                                 # 's'
    isvg_name[1] = 118                                 # 'v'
    isvg_name[2] = 103                                 # 'g'
    isvg_name[3] = 64                                  # '@'
    # decimal offset (max 20 digits fits uint64), written LSB-first then reversed
    n: uint64 = 4
    v: uint64 = off
    d0: uint64 = n
    if v == 0:
        isvg_name[n] = 48                              # '0'
        n = n + 1
    while v > 0 and n < 23:
        isvg_name[n] = cast[uint8](48 + cast[uint8](v % 10))
        v = v / 10
        n = n + 1
    # reverse the digits in place
    a: uint64 = d0
    b: uint64 = n - 1
    while a < b:
        t: uint8 = isvg_name[a]
        isvg_name[a] = isvg_name[b]
        isvg_name[b] = t
        a = a + 1
        b = b - 1
    return n


# Handle an inline <svg ...> element: rasterise the whole <svg>...</svg> subtree
# through the SHARED lib/svg rasterizer (the same one that decodes <img
# src=*.svg>), copy its RGBA into the lib/htmlimg store, and emit a replaced
# image box so the pixel renderer blits it exactly like an <img>. `ts` is the
# byte just after '<'; `te` is the '>' of the opening tag. Returns 1 if the
# element was consumed (caller must then _enter_skip past its children), 0 if it
# was self-closing / empty (nothing to skip).
def _handle_inline_svg(ts: uint64, te: uint64) -> int32:
    _word_flush()
    # self-closing "<svg .../>" carries no shapes — draw nothing, skip nothing.
    self_close: int32 = 0
    if te > ts and src_ptr[te - 1] == 47:              # '/'
        self_close = 1
    # Feed the rasterizer from the '<' of <svg> to end-of-source; svg_decode
    # finds the <svg> root at offset 0 and stops at the first </svg>.
    start: uint64 = ts - 1
    rc: int32 = svg_decode(&src_ptr[start], src_len - start)
    if rc != 0:
        # unsized / unparseable inline <svg> -> broken-image placeholder box.
        img_alt_len = 0
        img_alt_buf[0] = 91                            # '['
        img_alt_buf[1] = 115                           # 's'
        img_alt_buf[2] = 118                           # 'v'
        img_alt_buf[3] = 103                           # 'g'
        img_alt_buf[4] = 93                            # ']'
        img_alt_len = 5
        _emit_img_seg(-2, IMG_BROKEN_W, IMG_BROKEN_H)
        if self_close != 0:
            return 0
        return 1
    w: int32 = svg_width()
    h: int32 = svg_height()
    nl: uint64 = _isvg_name(start)
    slot: int32 = htmlimg_add(&isvg_name[0], nl, w, h, svg_rgba_ptr())
    bw2: int32 = w
    bh2: int32 = h
    if slot < 0:
        slot = -2                                      # store full -> placeholder
    # clamp to the content width, preserving aspect.
    if bw2 > bw:
        if bw2 > 0:
            bh2 = bh2 * bw / bw2
        bw2 = bw
    if bh2 < 1:
        bh2 = 1
    img_alt_len = 0
    img_alt_buf[0] = 91                                # '['
    img_alt_buf[1] = 115                               # 's'
    img_alt_buf[2] = 118                               # 'v'
    img_alt_buf[3] = 103                               # 'g'
    img_alt_buf[4] = 93                                # ']'
    img_alt_len = 5
    _emit_img_seg(slot, bw2, bh2)
    if self_close != 0:
        return 0
    return 1


# Advance `n` blank visual rows (top/bottom vertical margin+padding gap).
def _blank_rows(n: int32):
    k: int32 = 0
    while k < n:
        _bump_row()
        k = k + 1


# Open a block box for a <p>/<div>. `left`/`rins` are the left/right insets
# (margin+padding, px); `wd` the content width (px, -1 none); `topg`/`botg` the
# top/bottom gaps (px); `bord` 1 to draw a border. Pushes the left-indent and
# right-edge stacks + records close-side state on box_*_stack.
def _block_box_open(left: int32, rins: int32, wd: int32, topg: int32, \
                    botg: int32, bord: int32, bgc: int32):
    # top gap: quantise px -> blank lines.
    if topg > 0:
        _blank_rows((topg + LINE_H / 2) / LINE_H)
    # left inset (+ a cell for the border) shifts the content column.
    li: int32 = left
    if bord != 0:
        li = li + CELL_W
    _blk_indent_push(li)
    # right edge: shrink from the parent by the right inset (+ border cell), or
    # pin to indent_x + width when a width is set. Clamp to a sane range.
    parent_right: int32 = blk_right_cur
    if parent_right <= 0:
        parent_right = _content_right()
    new_right: int32 = parent_right - rins
    if bord != 0:
        new_right = new_right - CELL_W
    if wd >= 0:
        wr: int32 = indent_x + wd
        if wr < new_right:
            new_right = wr
    if new_right < indent_x + CELL_W:
        new_right = indent_x + CELL_W
    if new_right > _content_right():
        new_right = _content_right()
    if blk_right_sp < 64:
        blk_right_stack[blk_right_sp] = parent_right
        blk_right_sp = blk_right_sp + 1
    blk_right_cur = new_right
    # border: draw the top rule now, on a fresh row, then start content below.
    lx: int32 = indent_x - CELL_W                     # left bar column
    rx: int32 = new_right                             # right bar column
    if bord != 0:
        _soft_newline()
        row_dirty = 0
        span: int32 = (rx - lx) / CELL_W + 1
        _emit_box_run(cast[int32](cur_row), lx, 45, span)   # '-' top
        _bump_row()
        pen_x = indent_x
        row_dirty = 0
    # push close-side state.
    if box_sp < 64:
        box_botg_stack[box_sp] = botg
        box_bord_stack[box_sp] = bord
        box_lx_stack[box_sp]   = lx
        box_rx_stack[box_sp]   = rx
        box_srow_stack[box_sp] = cast[int32](cur_row)
        box_bg_stack[box_sp]   = bgc
        box_float_stack[box_sp] = 0                     # in-flow unless floated
        box_ftop_stack[box_sp]  = 0
        box_fgeom_stack[box_sp] = 0
        box_flexitem_stack[box_sp] = 0                  # set by the caller
        box_flexcont_stack[box_sp] = 0
        box_pos_stack[box_sp] = 0                        # set by the caller
        box_posrun_stack[box_sp] = -1
        box_pretrow_stack[box_sp] = 0
        box_pushedctx_stack[box_sp] = 0
        box_sp = box_sp + 1


# Close the block box opened by _block_box_open (pops both stacks; draws the
# bottom border rule + left/right bars over the content rows when bordered;
# emits the bottom gap as blank lines).
def _block_box_close():
    botg: int32 = 0
    bord: int32 = 0
    lx: int32 = 0
    rx: int32 = 0
    srow: int32 = 0
    bgc: int32 = -1
    if box_sp > 0:
        box_sp = box_sp - 1
        botg = box_botg_stack[box_sp]
        bord = box_bord_stack[box_sp]
        lx   = box_lx_stack[box_sp]
        rx   = box_rx_stack[box_sp]
        srow = box_srow_stack[box_sp]
        bgc  = box_bg_stack[box_sp]
    # element background: paint the WHOLE box rectangle (not just behind text).
    # Flush the pen so the box's last content row is counted, then register a
    # fill spanning [srow, bottom) at the box's left/right columns.
    if bgc >= 0 and n_bfills < BFILL_MAX:
        _word_flush()
        bfbot: int32 = cast[int32](cur_row)
        if row_dirty != 0:
            bfbot = bfbot + 1
        if bfbot > srow:
            bfill_lx[n_bfills]  = lx
            bfill_rx[n_bfills]  = rx + CELL_W
            bfill_top[n_bfills] = srow
            bfill_bot[n_bfills] = bfbot
            bfill_rgb[n_bfills] = bgc
            bfill_z[n_bfills]   = 0
            n_bfills = n_bfills + 1
    if bord != 0:
        _soft_newline()
        brow: int32 = cast[int32](cur_row)
        # side bars over every content row [srow, brow).
        r: int32 = srow
        while r < brow:
            _emit_box_bar(r, lx)
            _emit_box_bar(r, rx)
            r = r + 1
        span: int32 = (rx - lx) / CELL_W + 1
        _emit_box_run(brow, lx, 45, span)             # '-' bottom
        # Register the box for the pixel renderer to stroke a real 1px border
        # (the glyphs above are consumed only by the monospace-grid text dump).
        # top rule sits on srow-1 (open bumped a row past it); bottom on brow.
        if n_bboxes < BBOX_MAX:
            bbox_lx[n_bboxes]  = lx
            bbox_rx[n_bboxes]  = rx
            bbox_top[n_bboxes] = srow - 1
            bbox_bot[n_bboxes] = brow
            bbox_rgb[n_bboxes] = 0
            n_bboxes = n_bboxes + 1
        _bump_row()
        row_dirty = 0
    # restore the parent right edge + pop the left indent.
    if blk_right_sp > 0:
        blk_right_sp = blk_right_sp - 1
        blk_right_cur = blk_right_stack[blk_right_sp]
    _blk_indent_pop()
    if botg > 0:
        _blank_rows((botg + LINE_H / 2) / LINE_H)
    pen_x = indent_x


# Open a FLOATED block (side 1=left, 2=right). Lays the float out as a narrow
# box pinned to that edge (reusing the bordered-box machinery), recording the
# bookkeeping the close needs to set the wrap exclusion. Returns 1 if it opened
# as a real float (caller must not also open an in-flow box), 0 to fall back to
# a normal in-flow block (no room / a float already active).
def _float_box_open(side: int32, wd: int32, topg: int32, botg: int32, \
                    bord: int32, bgc: int32) -> int32:
    if float_active != 0:
        return 0                                        # one float at a time
    _word_flush()
    _soft_newline()
    fstart: int32 = cast[int32](cur_row)
    fw: int32 = wd
    if fw <= 0:
        fw = FLOAT_DEF_W
    left0: int32 = indent_x
    right0: int32 = _flow_right()
    avail: int32 = right0 - left0
    # cap the float so a readable body column (>= 4 cells) survives beside it.
    if fw > avail - 4 * CELL_W:
        fw = avail - 4 * CELL_W
    if fw < 6 * CELL_W:
        return 0                                        # too little room
    li: int32 = 0
    if side == 2:                                       # right: pin to right edge
        li = right0 - fw - left0
        if li < 0:
            li = 0
    _block_box_open(li, 0, fw, topg, botg, bord, bgc)
    idx: int32 = box_sp - 1
    if idx >= 0:
        box_float_stack[idx] = side
        box_ftop_stack[idx]  = fstart
        if side == 2:
            box_fgeom_stack[idx] = left0 + li - FLOAT_GAP    # right wrap edge
        else:
            box_fgeom_stack[idx] = fw + FLOAT_GAP            # left indent pad
    return 1


# Close a block that may be a float. Draws the box (via _block_box_close), then
# — if it floated — rewinds cur_row to the float's top and arms the exclusion so
# the following in-flow content re-flows beside it. Returns the float side
# (0 = it was a normal in-flow block, so the caller still emits its para gap).
def _float_box_close() -> int32:
    idx: int32 = box_sp - 1
    side: int32 = 0
    fstart: int32 = 0
    geom: int32 = 0
    if idx >= 0:
        side = box_float_stack[idx]
        fstart = box_ftop_stack[idx]
        geom = box_fgeom_stack[idx]
    _block_box_close()
    if side == 0:
        return 0
    fbot: int32 = cast[int32](cur_row)
    if fbot <= fstart:
        fbot = fstart + 1
    float_bottom = fbot
    float_active = 1
    float_side = side
    if side == 2:
        float_redge = geom
    else:
        float_left_pad = geom
        _recompute_indent()
    cur_row = cast[uint64](fstart)                       # rewind: flow beside
    pen_x = indent_x
    row_dirty = 0
    need_space = 0
    return side


# Drop any active float and drop flow below it (called at document end so the
# scroll height covers a trailing float taller than the beside-content).
def _float_flush():
    if float_active != 0:
        if cast[int32](cur_row) < float_bottom:
            cur_row = cast[uint64](float_bottom)
        float_active = 0
        float_side = 0
        float_redge = 0
        if float_left_pad != 0:
            float_left_pad = 0
            _recompute_indent()
        pen_x = indent_x
        row_dirty = 0


# ---- CSS flexbox ------------------------------------------------------------
# Is src[a..b) the name of a block-level element that opens a box (and so can be
# a flex column)? Mirrors the block set in _handle_tag's <p>/<div> branch.
def _is_flexblk(a: uint64, b: uint64) -> int32:
    n: uint64 = b - a
    if _hx_name_eq(a, n, cast[Ptr[uint8]]("div")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("p")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("section")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("aside")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("article")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("header")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("footer")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("main")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("nav")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("figure")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("figcaption")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("span")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("a")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("li")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("ul")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("ol")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("label")) != 0:
        return 1
    return 0


# Tags that own a dedicated layout/styling handler whose semantics must survive
# a stray `display:block`/`inline-block`/`flex` (or a flex-item context): links,
# headings, lists, tables, form controls, void tags, page structure. Everything
# NOT here is free to be blockified into a generic block box (the display:block
# and flex-item-blockification paths). Keeps `label{display:block}` +
# span-flex-navbars working without breaking tables/lists/links.
def _blk_dedicated(a: uint64, n: uint64) -> int32:
    if _hx_name_eq(a, n, cast[Ptr[uint8]]("a")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("ul")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("ol")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("li")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("dl")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("dt")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("dd")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("table")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("tr")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("td")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("th")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("thead")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("tbody")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("tfoot")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("caption")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("img")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("input")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("br")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("hr")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("pre")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("code")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("blockquote")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("textarea")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("select")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("option")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("button")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("mark")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("small")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("sub")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("sup")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("h1")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("h2")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("h3")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("h4")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("h5")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("h6")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("body")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("html")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("script")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("style")) != 0:
        return 1
    return 0


# Should the element currently being dispatched be laid out as a generic block
# box? True when (a) it is a direct child of an active flex container (flex-item
# blockification -> a column) or (b) its effective display is flex/block/
# inline-block -- provided it is not a dedicated-handler tag (see _blk_dedicated).
def _generic_block_wanted(a: uint64, n: uint64) -> int32:
    fitem: int32 = 0
    if _flex_item_col(el_sp) >= 0:
        fitem = 1
    if _blk_dedicated(a, n) != 0:
        # A DIRECT <a>/<li> child of an active flex row still columnises (the
        # canonical `<nav style=flex><a>…` / `<ul style=flex><li>…` navbar): the
        # generic-block path opens its column box, and the link/marker hook there
        # re-adds the href / bullet so link + list semantics survive. Every other
        # dedicated-handler tag stays dedicated (tables, headings, forms, …).
        if fitem != 0 and (_hx_name_eq(a, n, cast[Ptr[uint8]]("a")) != 0 or \
                           _hx_name_eq(a, n, cast[Ptr[uint8]]("li")) != 0):
            return 1
        return 0
    if fitem != 0:
        return 1
    if g_eff_disp == 2 or g_eff_disp == 3 or g_eff_disp == 4 or g_eff_disp == 6:
        return 1
    return 0


# Pre-scan the source from `after` (just past a flex container's '>') to its
# matching close tag, counting the number of DIRECT-CHILD block boxes (the flex
# items). Depth tracks nesting of the same block set; a direct child is one
# opened at relative depth 0. Returns the child count.
def _flex_count_children(after: uint64) -> int32:
    depth: int32 = 0
    n: int32 = 0
    i: uint64 = after
    while i < src_len:
        if src_ptr[i] != 60:                         # not '<'
            i = i + 1
            continue
        j: uint64 = i + 1
        closing: int32 = 0
        if j < src_len and src_ptr[j] == 47:         # '/'
            closing = 1
            j = j + 1
        ns: uint64 = j
        while j < src_len and _alnum_at(j) != 0:
            j = j + 1
        blk: int32 = _is_flexblk(ns, j)
        # advance to this tag's '>'
        k: uint64 = j
        while k < src_len and src_ptr[k] != 62:
            k = k + 1
        selfclose: int32 = 0
        if k > 0 and src_ptr[k - 1] == 47:
            selfclose = 1
        if closing == 0:
            if blk != 0:
                if depth == 0:
                    n = n + 1
                if selfclose == 0:
                    depth = depth + 1
        else:
            if blk != 0:
                if depth == 0:
                    return n                          # container's own close
                depth = depth - 1
        if k < src_len:
            i = k + 1
        else:
            i = k
    return n


# Measure the NATURAL content width (px) of each direct-child flex item, filling
# flex_meas_w[0..nc). A child's natural width is its collapsed visible-text run
# length in the CELL_W grid (the same grid the renderer places text on), so a
# nav link "Home" measures 4*CELL_W. Nested tag structure is skipped; interior
# whitespace collapses to one space; leading/trailing space is dropped. Returns
# the summed natural width of all children (0 if nothing measurable).
def _flex_measure_children(after: uint64, nc: int32) -> int32:
    depth: int32 = 0
    ci: int32 = -1                    # current direct-child index (-1 none open)
    chars: int32 = 0                  # visible chars in the current child
    pend_sp: int32 = 0                # a collapsed space is pending before next word
    total: int32 = 0
    i: uint64 = after
    while i < src_len:
        c: uint8 = src_ptr[i]
        if c == 60:                                  # '<'
            j: uint64 = i + 1
            closing: int32 = 0
            if j < src_len and src_ptr[j] == 47:     # '/'
                closing = 1
                j = j + 1
            ns: uint64 = j
            while j < src_len and _alnum_at(j) != 0:
                j = j + 1
            blk: int32 = _is_flexblk(ns, j)
            k: uint64 = j
            while k < src_len and src_ptr[k] != 62:  # '>'
                k = k + 1
            selfclose: int32 = 0
            if k > 0 and src_ptr[k - 1] == 47:
                selfclose = 1
            if closing == 0:
                if blk != 0:
                    if depth == 0:
                        ci = ci + 1                  # a new direct child opens
                        chars = 0
                        pend_sp = 0
                    if selfclose == 0:
                        depth = depth + 1
            else:
                if blk != 0:
                    if depth == 0:
                        return total                 # container's own close
                    depth = depth - 1
                    if depth == 0 and ci >= 0 and ci < nc:
                        w: int32 = chars * CELL_W
                        flex_meas_w[ci] = w
                        total = total + w
            if k < src_len:
                i = k + 1
            else:
                i = k
            continue
        if depth >= 1 and ci >= 0:
            if c == 32 or c == 9 or c == 10 or c == 13:
                if chars > 0:
                    pend_sp = 1
            else:
                if pend_sp != 0:
                    chars = chars + 1
                    pend_sp = 0
                chars = chars + 1
        i = i + 1
    return total


# Distribute the free space of a natural-width flex row per justify-content,
# writing each child's x offset (from flex_left) into flex_child_x[frame*..+col]
# and its width into flex_child_w. `just` is g_flex_just (1..5). Widths are read
# from flex_meas_w[0..nc). Free = avail - sum(widths).
def _flex_layout_natural(frame: int32, nc: int32, avail: int32, just: int32, \
                         gp: int32):
    base: int32 = frame * FLEX_MAX
    sumw: int32 = 0
    c: int32 = 0
    while c < nc:
        sumw = sumw + flex_meas_w[c]
        c = c + 1
    free: int32 = avail - sumw
    if free < 0:
        free = 0
    lead: int32 = 0                # x of the first item
    step_extra: int32 = gp         # inter-item gap beyond each item's width
    if just == 1:                                    # flex-start
        lead = 0
    elif just == 2:                                  # center
        lead = (free - (nc - 1) * gp) / 2
        if lead < 0:
            lead = 0
    elif just == 3:                                  # flex-end
        lead = free - (nc - 1) * gp
        if lead < 0:
            lead = 0
    elif just == 4:                                  # space-between
        lead = 0
        if nc > 1:
            step_extra = free / (nc - 1)
        else:
            lead = free / 2
    elif just == 5:                                  # space-around
        gap: int32 = free / nc
        lead = gap / 2
        step_extra = gap
    x: int32 = lead
    c = 0
    while c < nc:
        flex_child_x[base + c] = x
        flex_child_w[base + c] = flex_meas_w[c]
        x = x + flex_meas_w[c] + step_extra
        c = c + 1


# Resolve a grid frame's TRACK x-positions + widths into the shared flex_child_x/
# flex_child_w[frame*FLEX_MAX + c] from the parsed grid-template-columns encoding
# (g_grid_n tracks, g_grid_enc[c] >= 0 => fixed px; < 0 => fr weight negated).
# `avail` is the container content width, `gp` the column-gap. The fr tracks share
# the free space left after the fixed tracks and the (nt-1) gaps, split by weight.
# Returns the resolved track count (0 if nothing to resolve).
def _grid_resolve_tracks(frame: int32, avail: int32, gp: int32) -> int32:
    nt: int32 = g_grid_n
    if nt > GRID_MAXTRACK:
        nt = GRID_MAXTRACK
    if nt < 1:
        return 0
    sumfix: int32 = 0
    sumfr:  int32 = 0
    c: int32 = 0
    while c < nt:
        e: int32 = g_grid_enc[c]
        if e >= 0:
            sumfix = sumfix + e
        else:
            sumfr = sumfr - e                        # -e = fr weight
        c = c + 1
    free: int32 = avail - sumfix - (nt - 1) * gp
    if free < 0:
        free = 0
    base: int32 = frame * FLEX_MAX
    x: int32 = 0
    c = 0
    while c < nt:
        e2: int32 = g_grid_enc[c]
        w: int32 = 0
        if e2 >= 0:
            w = e2                                    # fixed px track
        else:
            if sumfr > 0:
                w = free * (-e2) / sumfr              # fr share of free space
        if w < CELL_W:
            w = CELL_W
        flex_child_x[base + c] = x
        flex_child_w[base + c] = w
        x = x + w + gp
        c = c + 1
    return nt


# Fixed height (in whole character ROWS) of grid row `ridx` for frame `frame`,
# from the parsed grid-template-rows px stored in flex_growh (0 = content-sized:
# no explicit height, or a row past the template / an fr row). px -> rows rounds
# to nearest LINE_H, mirroring the row-gap conversion.
def _grid_row_h_rows(frame: int32, ridx: int32) -> int32:
    if ridx >= flex_gridrn[frame]:
        return 0
    px: int32 = flex_growh[frame * FLEX_MAX + ridx]
    if px <= 0:
        return 0
    return (px + LINE_H / 2) / LINE_H


# Open a flex container: the box is already open (indent_x/blk_right_cur set to
# the container's content column). Compute the equal column width from the
# child count and push a frame. `eldepth` is the el-stack depth of the container
# element (its direct children sit at eldepth+1). Returns 1 if a real flex row
# was armed, 0 to fall back to normal block stacking (too few/many columns or
# too little width per column). A `display:grid` container (g_flex_grid) reuses
# this same frame in the fixed-track auto-placement model.
def _flex_container_open(content_after: uint64, eldepth: int32) -> int32:
    if flex_sp >= FLEX_MAX:
        return 0
    # flex-direction: column stacks children vertically -- that IS the default
    # block flow, so DON'T arm a horizontal column row; fall back to block
    # stacking (each child a normal full-width block). Only row flex columnises.
    # (grid ignores flex-direction — a grid always lays out in tracks.)
    if g_flex_grid == 0 and g_flex_dir == 1:
        return 0
    nc: int32 = _flex_count_children(content_after)
    if nc < 2:
        return 0
    # A flex row is capped at FLEX_MAX columns; a grid auto-places many items into
    # a fixed track count, so it allows up to GRID_MAXITEM children per container.
    if g_flex_grid == 0 and nc > FLEX_MAX:
        return 0
    if g_flex_grid != 0 and nc > GRID_MAXITEM:
        return 0
    left0: int32 = indent_x
    right0: int32 = blk_right_cur
    if right0 <= 0:
        right0 = _content_right()
    avail: int32 = right0 - left0
    # Inter-column gutter: an author `gap`/`column-gap` overrides the default.
    gp: int32 = FLEX_GAP
    if g_flex_gap >= 0:
        gp = g_flex_gap
    # NATURAL-width path: an EXPLICIT justify-content whose children's natural
    # content widths fit the row gets real free-space distribution (nav bars,
    # button/chip rows). Falls through to the equal-column approximation when the
    # items overflow (content-heavy flex: article beside infobox) or no explicit
    # justify was given (preserves the legacy spread).
    use_nat: int32 = 0
    use_wrap: int32 = 0
    use_grid: int32 = 0
    nt: int32 = 0
    # GRID path: `display:grid` resolves grid-template-columns into fixed track
    # widths (fr distributing free space) up front; items auto-place into those
    # tracks and wrap to the next row every `nt` items. A grid with no parseable
    # template falls back to normal block stacking.
    if g_flex_grid != 0:
        nt = _grid_resolve_tracks(flex_sp, avail, gp)
        if nt < 1:
            return 0
        use_grid = 1
    elif g_flex_wrap != 0:
        # WRAP path: `flex-wrap:wrap` places items ONLINE and wraps overflow onto
        # new lines. Pre-measure natural content widths so width-less items (nav
        # pills) size to content; items with an explicit CSS width use it.
        _flex_measure_children(content_after, nc)
        use_wrap = 1
    elif g_flex_just != 0:
        tot: int32 = _flex_measure_children(content_after, nc)
        if tot > 0 and tot + (nc - 1) * gp <= avail:
            _flex_layout_natural(flex_sp, nc, avail, g_flex_just, gp)
            use_nat = 1
    colw: int32 = (avail - (nc - 1) * gp) / nc
    if use_nat == 0 and use_wrap == 0 and use_grid == 0 and \
       colw < 6 * CELL_W:                            # columns too narrow
        return 0
    flex_top_row[flex_sp] = cast[int32](cur_row)
    flex_max_bot[flex_sp] = cast[int32](cur_row)
    flex_left[flex_sp]    = left0
    flex_colw[flex_sp]    = colw
    flex_gap[flex_sp]     = colw + gp
    flex_ncol[flex_sp]    = nc
    flex_next[flex_sp]    = 0
    flex_eldepth[flex_sp] = eldepth
    flex_natural[flex_sp] = use_nat
    flex_wrap_on[flex_sp] = use_wrap
    flex_grid[flex_sp]    = use_grid
    flex_ntrack[flex_sp]  = nt
    flex_avail[flex_sp]   = avail
    flex_rawgap[flex_sp]  = gp
    # row-gap: whole LINE_H rows between wrapped flex lines (rounded to nearest).
    rgr: int32 = 0
    if g_flex_rowgap > 0:
        rgr = (g_flex_rowgap + LINE_H / 2) / LINE_H
    flex_rowgap[flex_sp] = rgr
    flex_cur_x[flex_sp]   = 0
    flex_line_top[flex_sp] = cast[int32](cur_row)
    flex_line_bot[flex_sp] = cast[int32](cur_row)
    # Grid auto-flow cursor + explicit-row-height state (all no-ops for non-grid).
    flex_gcur[flex_sp]    = 0
    flex_growidx[flex_sp] = 0
    flex_gridrn[flex_sp]  = 0
    if use_grid != 0:
        nr: int32 = g_grid_rn
        if nr > GRID_MAXTRACK:
            nr = GRID_MAXTRACK
        flex_gridrn[flex_sp] = nr
        rr: int32 = 0
        while rr < nr:
            hpx: int32 = g_grid_renc[rr]
            if hpx < 0:
                hpx = 0                              # fr rows stay content-sized
            flex_growh[flex_sp * FLEX_MAX + rr] = hpx
            rr = rr + 1
        # A fixed row-0 height makes the first row occupy its track height even if
        # its content is shorter (the row is a floor; taller content still grows).
        h0: int32 = _grid_row_h_rows(flex_sp, 0)
        if h0 > 0:
            flex_line_bot[flex_sp] = flex_line_top[flex_sp] + h0
            if flex_line_bot[flex_sp] > flex_max_bot[flex_sp]:
                flex_max_bot[flex_sp] = flex_line_bot[flex_sp]
    # align-items: only 2 (center) / 3 (flex-end) / 4 (stretch) arm the deferred
    # cross-axis fixup; 0/1 (unset / flex-start) keep the byte-identical top-align.
    # NEVER armed for a grid (its item count can exceed FLEX_MAX, which the fixup's
    # per-column bookkeeping arrays do not size for) — grid rows stay top-aligned.
    fa: int32 = g_flex_align
    if fa < 2 or use_grid != 0:
        fa = 0
    flex_align[flex_sp] = fa
    flex_sp = flex_sp + 1
    return 1


# Would a block opening at el-stack depth `eldepth` be a direct child (flex
# item) of the current flex container? Returns the 0-based column index, or -1.
def _flex_item_col(eldepth: int32) -> int32:
    if flex_sp <= 0:
        return -1
    top: int32 = flex_sp - 1
    if eldepth != flex_eldepth[top] + 1:
        return -1
    if flex_next[top] >= flex_ncol[top]:
        return -1                                    # more children than counted
    return flex_next[top]


# Called on a flex item's close: record the column's bottom row into the frame's
# running max, then REWIND cur_row to the container top so the next sibling
# column starts level. pen/row state reset for the next column.
def _flex_item_close():
    top: int32 = flex_sp - 1
    if top < 0:
        return
    # Exclusive bottom (first free row): if the column left content on its
    # current row, that row is occupied, so the column's bottom is the row
    # BELOW it. Without the +1 a single-row column reports a zero-height span,
    # which collapses the container's background fill to nothing.
    bot: int32 = cast[int32](cur_row)
    if row_dirty != 0:
        bot = bot + 1
    if bot > flex_max_bot[top]:
        flex_max_bot[top] = bot
    # Cross-axis fixup: close this item's recorded seg/fill/border ranges (the box
    # background + border were already emitted by the preceding _block_box_close),
    # and stamp its bottom row. Only armed for align-items >= center. Commit any
    # still-open trailing text segment FIRST — a segment reserves seg_line at open
    # but only bumps n_segs at _close_seg, so an uncommitted tail would fall past
    # the recorded [seg0,seg1) range and escape the cross-axis shift.
    if flex_align[top] >= 2 and flex_next[top] < FLEX_MAX:
        _word_flush()
        _close_seg()
        fidx1: int32 = top * FLEX_MAX + flex_next[top]
        flex_it_seg1[fidx1] = cast[int32](n_segs)
        flex_it_bf1[fidx1]  = n_bfills
        flex_it_bx1[fidx1]  = n_bboxes
        flex_it_bot[fidx1]  = bot
    flex_next[top] = flex_next[top] + 1
    # WRAP/GRID: this item belongs to the current line/row — grow the line's
    # bottom and rewind to the LINE top (so the next item on the same line starts
    # level; a grid row advance is triggered at the next item's open).
    if flex_wrap_on[top] != 0 or flex_grid[top] != 0:
        if bot > flex_line_bot[top]:
            flex_line_bot[top] = bot
        cur_row = cast[uint64](flex_line_top[top])
    else:
        cur_row = cast[uint64](flex_top_row[top])
    pen_x = indent_x
    row_dirty = 0
    need_space = 0


# Shift one flex item's already-emitted segments/fills/borders DOWN by `dy` rows
# (center / flex-end cross-axis alignment). Rows clamp into [0, MAX_ROWS) and grow
# total_rows, mirroring _apply_positioned's relocation.
def _flex_shift_item(fidx: int32, dy: int32):
    if dy <= 0:
        return
    j: int32 = flex_it_seg0[fidx]
    s1: int32 = flex_it_seg1[fidx]
    while j < s1:
        nr: int32 = seg_line[j] + dy
        if cast[uint64](nr) >= MAX_ROWS:
            nr = cast[int32](MAX_ROWS) - 1
        seg_line[j] = nr
        if cast[uint64](nr) + 1 > total_rows:
            total_rows = cast[uint64](nr) + 1
        j = j + 1
    bf: int32 = flex_it_bf0[fidx]
    bf1: int32 = flex_it_bf1[fidx]
    while bf < bf1:
        bfill_top[bf] = bfill_top[bf] + dy
        bfill_bot[bf] = bfill_bot[bf] + dy
        bf = bf + 1
    bx: int32 = flex_it_bx0[fidx]
    bx1: int32 = flex_it_bx1[fidx]
    while bx < bx1:
        bbox_top[bx] = bbox_top[bx] + dy
        bbox_bot[bx] = bbox_bot[bx] + dy
        bx = bx + 1


# STRETCH one flex item: content stays top-aligned, but the item's OWN box
# background fill + border (the fill spanning exactly [ltop, item_bot) over the
# whole column) grows to the line's cross-axis extent `line_bot`.
def _flex_stretch_item(fidx: int32, line_bot: int32):
    ltop: int32 = flex_it_ltop[fidx]
    ibot: int32 = flex_it_bot[fidx]
    if line_bot <= ibot:
        return
    bf: int32 = flex_it_bf0[fidx]
    bf1: int32 = flex_it_bf1[fidx]
    while bf < bf1:
        if bfill_top[bf] == ltop and bfill_bot[bf] == ibot:
            bfill_bot[bf] = line_bot
        bf = bf + 1
    bx: int32 = flex_it_bx0[fidx]
    bx1: int32 = flex_it_bx1[fidx]
    while bx < bx1:
        if bbox_top[bx] == ltop - 1 and bbox_bot[bx] == ibot:
            bbox_bot[bx] = line_bot
        bx = bx + 1


# Deferred cross-axis (align-items) fixup, run at container close once every
# item's line-top/bottom is known. For each item, the line's cross extent is the
# tallest item sharing its line-top (so single-line AND wrapped lines both work);
# center/flex-end offset the item down within that extent, stretch grows its box.
def _flex_align_fixup(top: int32):
    mode: int32 = flex_align[top]
    if mode < 2:
        return
    nc: int32 = flex_next[top]
    if nc > flex_ncol[top]:
        nc = flex_ncol[top]
    c: int32 = 0
    while c < nc:
        fidx: int32 = top * FLEX_MAX + c
        ltop: int32 = flex_it_ltop[fidx]
        line_bot: int32 = flex_it_bot[fidx]
        k: int32 = 0
        while k < nc:
            kidx: int32 = top * FLEX_MAX + k
            if flex_it_ltop[kidx] == ltop and flex_it_bot[kidx] > line_bot:
                line_bot = flex_it_bot[kidx]
            k = k + 1
        line_h: int32 = line_bot - ltop
        item_h: int32 = flex_it_bot[fidx] - ltop
        if mode == 4:
            _flex_stretch_item(fidx, line_bot)
        elif mode == 2:
            _flex_shift_item(fidx, (line_h - item_h) / 2)
        elif mode == 3:
            _flex_shift_item(fidx, line_h - item_h)
        c = c + 1


# Called on a flex container's close (BEFORE its box closes): drop cur_row to the
# tallest column so the container spans the full flex-row height, then pop the
# frame.
def _flex_container_close():
    top: int32 = flex_sp - 1
    if top < 0:
        return
    _flex_align_fixup(top)
    if flex_max_bot[top] > cast[int32](cur_row):
        cur_row = cast[uint64](flex_max_bot[top])
    flex_sp = flex_sp - 1
    pen_x = indent_x
    row_dirty = 0


# ---- CSS inline-block (inline-level box flow) -------------------------------
# Void (self-closing) tags never open a nesting scope; used by the inline-block
# text measurer so its depth counter is not thrown off by <br>/<img>/<input>.
def _is_void_name(a: uint64, n: uint64) -> int32:
    if _hx_name_eq(a, n, cast[Ptr[uint8]]("br")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("hr")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("img")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("input")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("meta")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("link")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("area")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("col")) != 0:
        return 1
    return 0


# Which tags get inline-block INLINE-FLOW treatment (a chip/badge/button/pill)
# rather than the generic block-box blockification. Restricted to inline-level
# and neutral containers; dedicated block machinery (tables/lists/headings/
# forms/pre) keeps its own layout even under `display:inline-block`.
def _inlb_tag(a: uint64, n: uint64) -> int32:
    if _hx_name_eq(a, n, cast[Ptr[uint8]]("span")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("font")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("a")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("small")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("b")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("strong")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("em")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("i")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("label")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("div")) != 0:
        return 1
    return 0


# Collapsed visible-text width (px, CELL_W grid) of an inline-block element whose
# content starts at `after` (just past its opening '>'), stopping at the element's
# matching close tag. Interior whitespace collapses to one space; leading/trailing
# space is dropped. Nested tag structure is skipped (only its text counts).
def _inlb_text_w(after: uint64) -> int32:
    depth: int32 = 0
    chars: int32 = 0
    pend: int32 = 0
    i: uint64 = after
    while i < src_len:
        c: uint8 = src_ptr[i]
        if c == 60:                                  # '<'
            j: uint64 = i + 1
            closing: int32 = 0
            if j < src_len and src_ptr[j] == 47:     # '/'
                closing = 1
                j = j + 1
            ns: uint64 = j
            while j < src_len and _alnum_at(j) != 0:
                j = j + 1
            k: uint64 = j
            while k < src_len and src_ptr[k] != 62:  # '>'
                k = k + 1
            selfclose: int32 = 0
            if k > 0 and src_ptr[k - 1] == 47:
                selfclose = 1
            if closing != 0:
                if depth == 0:
                    return chars * CELL_W             # this element's own close
                depth = depth - 1
            else:
                if selfclose == 0 and _is_void_name(ns, j) == 0:
                    depth = depth + 1
            if k < src_len:
                i = k + 1
            else:
                i = k
            continue
        if c == 32 or c == 9 or c == 10 or c == 13:
            if chars > 0:
                pend = 1
        else:
            if pend != 0:
                chars = chars + 1
                pend = 0
            chars = chars + 1
        i = i + 1
    return chars * CELL_W


# Open an inline-block chip: place any pending text, wrap the whole box to a
# fresh line if it would overflow, push the element's style, paint the box's
# background FILL, then inset the pen by the left padding so its text flows
# inside the box. The chip's own text streams normally into the following segs.
def _inlb_open(ne: uint64, te: uint64, np: uint64, nlen: uint64):
    _word_flush()
    _close_seg()
    tw: int32 = _inlb_text_w(te + 1)
    boxw: int32 = tw + 2 * INLB_PADX
    right: int32 = _flow_right()
    # Wrap the whole chip to the next line if it does not fit after current flow.
    if pen_x > indent_x and pen_x + boxw > right:
        _bump_row()
        _maybe_clear_float()
        pen_x = indent_x
        row_dirty = 0
        need_space = 0
    _open_style(ne, te)                              # pushes colour + background
    _recompute_style()
    startx: int32 = pen_x
    row0: int32 = cast[int32](cur_row)
    # Vertical box growth: honour top+bottom padding (the badge/button/pill idiom)
    # so a chip is a real BOX, not one text-line tall. The resolved cascade/inline
    # top+bottom insets (m_mt/m_mb, d_mt/d_mb overriding) grow the box; the single
    # text line is centred within it and the box reserves the extra whole rows so
    # following content clears it. One-row chips (no vertical padding) are byte-
    # identical to before: boxrows stays 1 and every guard below short-circuits.
    padt: int32 = 0
    if m_mt > 0:
        padt = m_mt
    if d_mt > 0:
        padt = d_mt
    padb: int32 = 0
    if m_mb > 0:
        padb = m_mb
    if d_mb > 0:
        padb = d_mb
    boxrows: int32 = 1
    chip_yoff: int32 = 0
    if padt + padb > 0:
        boxh: int32 = LINE_H + padt + padb
        boxrows = (boxh + LINE_H - 1) / LINE_H
        if boxrows > 8:
            boxrows = 8
        chip_yoff = (boxrows - 1) * LINE_H / 2       # centre the text line
    if inlb_sp < INLB_MAX:
        inlb_startx[inlb_sp]  = startx
        inlb_boxw[inlb_sp]    = boxw
        inlb_row[inlb_sp]     = row0
        inlb_eldepth[inlb_sp] = el_sp
        inlb_yoff[inlb_sp]    = chip_yoff
        inlb_sp = inlb_sp + 1
    # A tall chip reserves the rows below it: the next line break snaps past them.
    if boxrows > 1 and row0 + boxrows > g_inlb_floor:
        g_inlb_floor = row0 + boxrows
    # Paint the chip box (a narrow FILL over exactly its box, boxrows tall).
    if g_bg >= 0 and n_bfills < BFILL_MAX and row0 < MAX_ROWS:
        bfill_lx[n_bfills]  = startx
        bfill_rx[n_bfills]  = startx + boxw
        bfill_top[n_bfills] = row0
        bfill_bot[n_bfills] = row0 + boxrows
        bfill_rgb[n_bfills] = g_bg
        bfill_z[n_bfills]   = 0
        n_bfills = n_bfills + 1
    # Drop the text baseline to the vertical centre of a tall box.
    g_yoff = g_yoff + chip_yoff
    # A chip that is an <a> keeps its href + own link colour (clickable pill).
    if _hx_name_eq(np, nlen, cast[Ptr[uint8]]("a")) != 0:
        g_link = _capture_href(ne, te)
        g_link_rgb = _own_color(ne, te)
        _recompute_style()
    pen_x = startx + INLB_PADX
    need_space = 0
    row_dirty = 1


# Close an inline-block chip: snap the pen to the box's right edge + gutter so
# the next inline content flows after it, then pop the element's style.
def _inlb_close(np: uint64, nlen: uint64):
    _word_flush()
    _close_seg()
    if inlb_sp > 0:
        inlb_sp = inlb_sp - 1
        pen_x = inlb_startx[inlb_sp] + inlb_boxw[inlb_sp] + INLB_GAP
        g_yoff = g_yoff - inlb_yoff[inlb_sp]         # undo the tall-chip centring
    if _hx_name_eq(np, nlen, cast[Ptr[uint8]]("a")) != 0:
        g_link = -1
        g_link_rgb = -1
    _close_style()
    _recompute_style()
    need_space = 0
    row_dirty = 1


# The right edge the current flow wraps against: a table cell clamps to its
# column, everything else to the content area.
def _flow_right() -> int32:
    r: int32 = _content_right()
    # A block width / right margin / padding shrinks the wrap boundary.
    if blk_right_cur > 0 and blk_right_cur < r:
        r = blk_right_cur
    # A right-floated box excludes its column: body text wraps to its left for
    # every row above the float's bottom.
    if float_active != 0 and float_side == 2 and \
       cast[int32](cur_row) < float_bottom and float_redge < r:
        if float_redge > indent_x + CELL_W:
            r = float_redge
    if cell_active != 0:
        cr: int32 = cell_right
        if cr > r:
            cr = r
        if cr < indent_x + CELL_W:
            cr = indent_x + CELL_W
        return cr
    return r


# ---- PIXEL-MEASURE line-break hook ----------------------------------
# The engine stays PURE (no font/htmlpaint import): the pixel front-end
# registers a callback that returns the real TrueType advance width (px) of the
# pending run, so the line-breaker can wrap prose to the true viewport measure
# instead of the 8px monospace CHARACTER GRID. When NO hook is registered the
# breaker falls back to CELL_W cells, so the legacy monospace-grid dump
# (user/hambrowse_host.ad) stays byte-for-byte identical. The hook reads the
# pending run through the he_meas_* accessors below (same globals-passing seam
# jsengine uses for host dispatch — Adder has no multi-arg Fn convention here).
#
# GRID segments (tables + <pre>) always use CELL_W so their absolute columns
# survive regardless of the hook — real reflow is prose-only.
he_meas_set:  int32 = 0
he_meas_addr: uint64 = 0
he_meas_face: uint8 = 0
he_meas_bold: int32 = 0
he_meas_px:   int32 = 0
he_meas_txt:  Ptr[uint8] = 0
he_meas_len:  int32 = 0
_he_sp_buf:   Array[1, uint8]        # one-space scratch for space-advance query


def he_set_measure_hook(fn: Fn[int32, int32]):
    he_meas_addr = cast[uint64](fn)
    he_meas_set = 1


def he_clear_measure_hook():
    he_meas_set = 0


# Accessors the registered hook reads to learn the pending run + its style.
def he_meas_face_get() -> uint8:
    return he_meas_face


def he_meas_bold_get() -> int32:
    return he_meas_bold


def he_meas_px_get() -> int32:
    return he_meas_px


def he_meas_txt_get() -> Ptr[uint8]:
    return he_meas_txt


def he_meas_len_get() -> int32:
    return he_meas_len


# Pixel width of a run in the CURRENT inline style. Falls back to CELL_W cells
# when no hook is set OR the run is grid-positioned (table/<pre>), so those keep
# their absolute char-grid columns.
def _run_px(ptr: Ptr[uint8], ln: uint64) -> int32:
    if he_meas_set == 0 or table_active != 0 or pre_mode != 0 or ln == 0:
        return cast[int32](ln) * CELL_W
    he_meas_face = _cur_face()
    he_meas_bold = g_bold
    he_meas_px   = g_font_px
    he_meas_txt  = ptr
    he_meas_len  = cast[int32](ln)
    hf: Fn[int32, int32] = cast[Fn[int32, int32]](he_meas_addr)
    w: int32 = hf(0)
    if w < 1:
        w = 1
    return w


# Pixel advance of a single inter-word space in the current style.
def _space_px() -> int32:
    if he_meas_set == 0 or table_active != 0 or pre_mode != 0:
        return CELL_W
    _he_sp_buf[0] = 32
    return _run_px(&_he_sp_buf[0], 1)


# ---- word placement (block+inline flow with word wrap) --------------
def _emit_word(wptr: Ptr[uint8], wlen: uint64):
    if wlen == 0:
        return
    right: int32 = _flow_right()
    avail: int32 = right - indent_x
    wpx: int32 = _run_px(wptr, wlen)
    spx: int32 = _space_px()
    # CSS white-space:nowrap / white-space:pre (g_ws 1 / 2) suppress ALL soft
    # wrapping — the line runs past the measure and overflows. (The <pre>/<code>
    # ELEMENT keeps its own grid path; this only fires for the CSS property.)
    ws_nowrap: int32 = 0
    if g_ws == 1 or g_ws == 2:
        ws_nowrap = 1
    # A natural-path flex item's track is content-sized (max-content); its text is
    # not meant to wrap, so treat it as nowrap — a proportional link wider than the
    # monospace track estimate stays on one line instead of splitting between its
    # words ("Log in" -> "Log"/"in").
    if g_flex_nowrap_depth > 0:
        ws_nowrap = 1
    # Decide a word-wrap (only when the word fits on a fresh line).
    if pen_x > indent_x and ws_nowrap == 0:
        extra: int32 = wpx
        if need_space != 0:
            extra = extra + spx
        if pen_x + extra > right and wpx <= avail:
            _close_seg()
            _bump_row()
            _maybe_clear_float()
            right = _flow_right()
            avail = right - indent_x
            pen_x = indent_x
            need_space = 0
            row_dirty = 0
    # Inter-word space.
    if need_space != 0 and pen_x > indent_x:
        _seg_putc(32)
        pen_x = pen_x + spx
        need_space = 0
    # A word longer than a whole line: hard char-break it (measured per glyph).
    # Suppressed under nowrap/pre — the run must overflow the measure intact.
    # ALSO suppressed inside a flex item: a flex item's automatic minimum size is
    # min-content, so its track must not shrink below the widest word — an
    # over-wide word stays intact (overflows the track) rather than splitting
    # mid-run. The track width was estimated on the CELL_W monospace grid at
    # container-open; under the proportional measure hook the real word can exceed
    # it, which pre-fix char-broke brand/nav text ("Nimbus" -> "Nim"/"bus").
    if wpx > avail and ws_nowrap == 0 and g_flex_item_depth == 0:
        k: uint64 = 0
        while k < wlen:
            cpx: int32 = _run_px(&wptr[k], 1)
            if pen_x + cpx > right and pen_x > indent_x:
                _close_seg()
                _bump_row()
                _maybe_clear_float()
                right = _flow_right()
                pen_x = indent_x
                row_dirty = 0
            _seg_putc(wptr[k])
            pen_x = pen_x + cpx
            k = k + 1
        need_space = 0
        return
    # Normal: whole word into the current segment.
    k2: uint64 = 0
    while k2 < wlen:
        _seg_putc(wptr[k2])
        k2 = k2 + 1
    pen_x = pen_x + wpx
    need_space = 0


def _word_push(c: uint8):
    if word_len < WORD_CAP - 1:
        word_buf[word_len] = c
        word_len = word_len + 1


def _word_flush():
    if word_len > 0:
        _emit_word(&word_buf[0], word_len)
        word_len = 0


from lib.web.html.entities import *
from lib.web.html.entities import _entity
from lib.web.css.values import *
from lib.web.css.values import _color_value, _hx_hexval, _srcword_is, _tag_bgcolor, _tag_color
# ====================================================================
# CSS CASCADE — <style> blocks + inline style="" for the properties that
# map onto this monospace-grid engine: color, background-color, font-weight
# (bold), text-align (center/right, baked into seg_x post-layout), and
# display:none (content skipped). A stylesheet is parsed once per page into a
# flat rule table; selectors support element / .class / #id and a single
# descendant combinator (`A B`), ordered by simple specificity
# (id=100, class=10, element=1; inline style wins over all).
# ====================================================================
MAX_RULES:   int32  = 256
CSS_STR_CAP: uint64 = 8192
css_sbuf: Array[8192, uint8]
css_slen: uint64 = 0

# target (rightmost) compound of each rule
r_tag_off: Array[256, int32]
r_tag_len: Array[256, int32]
r_cls_off: Array[256, int32]
r_cls_len: Array[256, int32]
r_id_off:  Array[256, int32]
r_id_len:  Array[256, int32]
# ancestor compound (present only for a descendant selector)
r_has_anc:  Array[256, int32]
r_atag_off: Array[256, int32]
r_atag_len: Array[256, int32]
r_acls_off: Array[256, int32]
r_acls_len: Array[256, int32]
r_aid_off:  Array[256, int32]
r_aid_len:  Array[256, int32]
# resolved declarations
r_color:  Array[256, int32]
r_bg:     Array[256, int32]
r_weight: Array[256, int32]     # 0 none, 1 bold, 2 normal
r_align:  Array[256, int32]     # 0 none, 1 left, 2 center, 3 right
r_deco:   Array[256, int32]     # text-decoration: 0 none-set, 1 underline, 2 none, 3 line-through
r_nomark: Array[256, int32]     # list-style[-type]:none -> 1 (suppress <li> markers)
r_disp:   Array[256, int32]     # display: 1=none 2=flex 3=block 4=inline-block 5=inline
r_flexdir: Array[256, int32]    # flex-direction: 0 unset / 1 column / 2 row
r_justify: Array[256, int32]    # justify-content: 0 unset / 1..5 (see _justify_value)
r_aitems: Array[256, int32]     # align-items: 0 unset / 1 flex-start / 2 center / 3 flex-end / 4 stretch
r_flexgap: Array[256, int32]    # flex column gap px: -1 unset (default FLEX_GAP)
r_rowgap: Array[256, int32]     # flex row gap px: -1 unset (0 => no inter-line gap)
r_flexwrap: Array[256, int32]   # flex-wrap: 0 unset/nowrap / 1 wrap
# grid-template-columns: r_gtcn[ri] tracks (0 = unset), each encoded track in
# r_gtc[ri*GRID_MAXTRACK + c] (>= 0 fixed px / < 0 fr weight negated).
r_gtcn: Array[256, int32]
r_gtc:  Array[2048, int32]      # 256 rules * GRID_MAXTRACK tracks
# grid-template-rows (fixed px row heights); same shape as grid-template-columns.
r_gtrn: Array[256, int32]
r_gtr:  Array[2048, int32]      # 256 rules * GRID_MAXTRACK rows
# per-ITEM grid-column line placement: r_gcspan[ri] tracks spanned (0 = unset =>
# a single track), r_gcstart[ri] explicit 1-based start line (0 = auto-flow).
r_gcspan:  Array[256, int32]
r_gcstart: Array[256, int32]
# box model (px; -1 = the rule does not set this axis). ml/mr fold margin+
# padding on that side into one left/right inset; mt/mb are the top/bottom
# gaps; wd is the content width; bd is 0 (border:none) / 1 (border on) / -1.
r_ml:     Array[256, int32]
r_mr:     Array[256, int32]
r_mt:     Array[256, int32]
r_mb:     Array[256, int32]
r_wd:     Array[256, int32]
r_bd:     Array[256, int32]
r_center: Array[256, int32]     # 1 = margin-left+right:auto (centre the box)
r_fontpx: Array[256, int32]     # CSS font-size in px (-1 = rule sets no size)
# CSS line-height. 0 = rule sets none; >0 = absolute PX (from px/em); <0 =
# unitless/percentage multiplier in milli, negated (e.g. 1.5 -> -1500, 150% ->
# -1500) resolved against the element's font-size when the style scope opens.
r_lineh:  Array[256, int32]
# CSS white-space, encoded mode+1 (0 = rule sets none): 1 normal, 2 nowrap,
# 3 pre, 4 pre-wrap.
r_ws:     Array[256, int32]
r_float:  Array[256, int32]     # CSS float: 0 none / 1 left / 2 right
# CSS position: 0 none, 1 relative (in-flow, shift rendered box), 2 absolute
# (out-of-flow, placed against the nearest positioned ancestor). top/left/right/
# bottom offsets in px, -1 = that edge is auto.
r_pos:    Array[256, int32]
r_top:    Array[256, int32]
r_left:   Array[256, int32]
r_right:  Array[256, int32]
r_bottom: Array[256, int32]
r_zidx:   Array[256, int32]     # z-index (ZIDX_UNSET = auto/unset)
r_spec:   Array[256, int32]
n_rules:  int32 = 0

# element stack (open elements) for descendant matching
MAX_EL:     int32  = 64
EL_STR_CAP: uint64 = 4096
el_sbuf: Array[4096, uint8]
el_slen: uint64 = 0
el_tag_off: Array[64, int32]
el_tag_len: Array[64, int32]
el_cls_off: Array[64, int32]
el_cls_len: Array[64, int32]
el_id_off:  Array[64, int32]
el_id_len:  Array[64, int32]
el_sp: int32 = 0

# cascade match results (filled by _cascade_match_current)
m_col:    int32 = -1
m_bg:     int32 = -1
m_weight: int32 = 0
m_align:  int32 = 0
m_deco:   int32 = 0
m_nomark: int32 = 0        # list-style:none cascade winner (1 = suppress markers)
m_disp:   int32 = 0
m_flexdir: int32 = 0       # flex-direction cascade winner: 0 unset / 1 col / 2 row
m_justify: int32 = 0       # justify-content cascade winner: 0 unset / 1..5
m_aitems: int32 = 0        # align-items cascade winner: 0 unset / 1..4
m_flexgap: int32 = -1      # flex column-gap cascade winner px: -1 unset
m_rowgap: int32 = -1       # flex row-gap cascade winner px: -1 unset
m_flexwrap: int32 = 0      # flex-wrap cascade winner: 0 nowrap / 1 wrap
m_gtcn: int32 = 0          # grid-template-columns cascade winner: track count
m_gtc:  Array[8, int32]    # winning template's encoded tracks
m_gtrn: int32 = 0          # grid-template-rows cascade winner: row count
m_gtr:  Array[8, int32]    # winning row template's encoded rows
m_gcspan:  int32 = 0       # grid-column cascade winner: span (0 = unset => 1)
m_gcstart: int32 = 0       # grid-column cascade winner: explicit start (0 = auto)
# box-model cascade winners (-1 = no matching rule set this axis)
m_ml:     int32 = -1
m_mr:     int32 = -1
m_mt:     int32 = -1
m_mb:     int32 = -1
m_wd:     int32 = -1
m_bd:     int32 = -1
m_center: int32 = 0        # 1 = auto side margins (centre the box in its parent)
m_fontpx: int32 = -1
m_lineh:  int32 = 0        # CSS line-height cascade winner (see r_lineh encoding)
m_ws:     int32 = 0        # CSS white-space cascade winner (mode+1; 0 = unset)
m_float:  int32 = 0
# CSS position cascade winners (m_pos 0/1/2; offsets px, -1 = auto).
m_pos:    int32 = 0
m_top:    int32 = -1
m_left:   int32 = -1
m_right:  int32 = -1
m_bottom: int32 = -1
m_zidx:   int32 = -2000000000       # z-index cascade winner (ZIDX_UNSET = unset)

# ---- CSS position (relative/absolute) ------------------------------------
# Positioned elements are laid out in normal flow, then a post-layout pass
# (_apply_positioned) shifts their whole segment run. `relative` keeps the
# element's in-flow space and offsets the rendered box by top/left (or pulls it
# back by right/bottom). `absolute` is out of flow: after laying its box out we
# REWIND cur_row (like a float) so following content reclaims the space, and the
# box is placed against the nearest positioned ancestor's origin (or the page
# top-left). A per-element context stack records each positioned ancestor's
# top-left/right so an absolute child resolves top/left/right against it. Pages
# that use no `position` add zero runs, so layout is byte-identical.
POS_MAX:  int32 = 64
pos_seg0: Array[64, int32]       # first segment of the positioned run
pos_seg1: Array[64, int32]       # one past the last segment
pos_mode: Array[64, int32]       # 1 relative, 2 absolute
pos_ox:   Array[64, int32]       # containing-block left x (absolute)
pos_ort:  Array[64, int32]       # containing-block right x (absolute)
pos_orow: Array[64, int32]       # containing-block top row (absolute)
pos_l:    Array[64, int32]       # left/top/right/bottom offsets (px, -1 auto)
pos_t:    Array[64, int32]
pos_r:    Array[64, int32]
pos_b:    Array[64, int32]
pos_z:    Array[64, int32]       # z-index (stacking order; 0 = auto/default)
pos_bf0:  Array[64, int32]       # first bfill (block background) of the run
pos_bf1:  Array[64, int32]       # one past the last bfill of the run
pos_n:    int32 = 0

# nearest-positioned-ancestor origin stack (containing block for `absolute`).
posctx_x:   Array[64, int32]
posctx_rt:  Array[64, int32]
posctx_row: Array[64, int32]
posctx_sp:  int32 = 0

# font-weight (bold) scope — parallels the colour stack.
weight_stack: Array[64, int32]
weight_sp:  int32 = 0
g_css_bold: int32 = 0

# text-decoration scope — parallels the weight stack. A level pushes 0 when it
# sets no decoration, so the effective decoration INHERITS the nearest ancestor
# that did (CSS text-decoration is NOT inherited per spec, but propagating the
# underline down matches how it renders in practice for the common cases:
# <u>/underlined blocks). 1 = underline, 2 = none (an explicit reset, e.g. to
# strip a link's default underline). g_css_uline folds into g_uline.
deco_stack: Array[64, int32]
deco_sp:  int32 = 0
g_css_uline: int32 = 0
# CSS `text-decoration: line-through` (deco value 3) folds into seg_strike the
# same way <s>/<del>/<strike> (g_strike_n) does. Recomputed with g_css_uline.
g_css_strike: int32 = 0

# font-size (px) scope — parallels the weight stack. A level pushes 0 when it
# sets no size, so the effective size INHERITS the nearest ancestor that did
# (CSS font-size inheritance). g_font_px 0 = "use the face default".
fontpx_stack: Array[64, int32]
fontpx_sp: int32 = 0
g_font_px: int32 = 0

# line-height (px) scope — parallels the font-size stack. A level pushes 0 when
# it sets no line-height, so the effective pitch INHERITS the nearest ancestor
# that did (CSS line-height inherits). g_lineh 0 = "use the default rhythm".
# Values are already resolved to PIXELS at the point the scope is opened.
lineh_stack: Array[64, int32]
lineh_sp: int32 = 0
g_lineh: int32 = 0

# white-space scope — parallels the line-height stack. CSS `white-space`
# INHERITS, so a level pushes 0 when it sets none and the effective mode
# inherits the nearest ancestor that did. Stack/decl/rule/winner entries are
# ENCODED as mode+1 (0 = unset): 1 normal, 2 nowrap, 3 pre, 4 pre-wrap. The
# resolved effective mode g_ws is 0..3 (0 normal = the default flow):
#   0 normal   -> collapse whitespace runs to one space, soft-wrap at measure
#   1 nowrap   -> collapse, but never soft-wrap (line overflows the measure)
#   2 pre      -> preserve spaces + newlines, never soft-wrap
#   3 pre-wrap -> preserve spaces + newlines, but DO soft-wrap at the measure
# g_ws only takes effect through the CSS property; the <pre>/<code> ELEMENT
# keeps its own monospace-grid pre_mode path untouched, so unstyled pages are
# byte-identical (every level pushes 0 -> g_ws stays 0 -> normal flow).
ws_stack: Array[64, int32]
ws_sp: int32 = 0
g_ws: int32 = 0

# text-align scope + per-row alignment record (post-pass shifts seg_x).
align_stack: Array[64, int32]
align_sp: int32 = 0
g_align:  int32 = 0
row_align: Array[12000, uint8]

# selector/declaration parse scratch (globals — the compiler has no tuples).
c_tag_off: int32 = -1
c_tag_len: int32 = 0
c_cls_off: int32 = -1
c_cls_len: int32 = 0
c_id_off:  int32 = -1
c_id_len:  int32 = 0
c_spec:    int32 = 0
g_store_off: int32 = 0
g_store_len: int32 = 0
d_color:  int32 = -1
d_bg:     int32 = -1
d_weight: int32 = 0
d_align:  int32 = 0
d_deco:   int32 = 0
d_nomark: int32 = 0         # list-style[-type]: 1 = none (suppress <li> markers)
d_disp:   int32 = 0
d_flexdir: int32 = 0        # flex-direction: 0 unset / 1 column / 2 row
d_justify: int32 = 0        # justify-content: 0 unset / 1..5
d_aitems: int32 = 0         # align-items: 0 unset / 1..4
d_flexgap: int32 = -1       # flex column-gap px: -1 unset
d_rowgap: int32 = -1        # flex row-gap px: -1 unset
d_flexwrap: int32 = 0       # flex-wrap: 0 nowrap / 1 wrap
d_gtcn: int32 = 0           # grid-template-columns: track count (0 = unset)
d_gtc:  Array[8, int32]     # parsed encoded tracks for this rule / inline style
d_gtrn: int32 = 0           # grid-template-rows: row count (0 = unset)
d_gtr:  Array[8, int32]     # parsed encoded rows for this rule / inline style
d_gcspan:  int32 = 0        # grid-column span (0 = unset => single track)
d_gcstart: int32 = 0        # grid-column explicit 1-based start line (0 = auto)
# box-model declaration scratch (per rule / per inline style="", -1 = unset).
# ml/mr fold the left/right margin+padding; mt/mb the top/bottom gaps (px);
# wd the content width (px); bd is 0 (none) / 1 (on) for a border.
d_ml:     int32 = -1
d_mr:     int32 = -1
d_mt:     int32 = -1
d_mb:     int32 = -1
d_wd:     int32 = -1
d_bd:     int32 = -1
d_center: int32 = 0         # 1 = auto side margins (centre the box)
d_fontpx: int32 = -1        # CSS font-size in px (-1 = declaration sets none)
d_lineh:  int32 = 0         # CSS line-height (0 none; >0 px; <0 -milli mult.)
d_ws:     int32 = 0         # CSS white-space (mode+1; 0 = declaration sets none)
d_float:  int32 = 0         # CSS float: 0 none / 1 left / 2 right
d_pos:    int32 = 0         # CSS position: 0 none / 1 relative / 2 absolute
d_top:    int32 = -1        # top/left/right/bottom offsets (px, -1 = auto)
d_left:   int32 = -1
d_right:  int32 = -1
d_bottom: int32 = -1
# CSS z-index (stacking order for positioned boxes). ZIDX_UNSET = auto/unset;
# any real integer (incl. negative) is an explicit stacking level.
ZIDX_UNSET: int32 = -2000000000
d_zidx:   int32 = -2000000000
# multi-length shorthand scratch (margin/padding: t r b l).
box_lens: Array[4, int32]
n_box_lens: int32 = 0


# ---- CSS length units + calc() --------------------------------------
# A cursor-based length scanner shared by _style_len and the calc() evaluator.
# _len_i walks src_ptr within [_len_i, _len_end); each _len_number() consumes one
# numeric term (optional sign, digits, optional .fraction, optional unit) and
# returns its resolved PIXEL value, advancing _len_i past the token+unit.
_len_i:   uint64 = 0
_len_end: uint64 = 0
_len_bad: int32  = 0        # set by _len_number when no numeric token was found


# Does src[i..] begin with the (already-lowercase) literal `lit`, within [i,e)?
def _unit_at(i: uint64, e: uint64, lit: Ptr[uint8]) -> int32:
    k: int32 = 0
    while lit[k] != 0:
        if i + cast[uint64](k) >= e:
            return 0
        if _hx_lower(src_ptr[i + cast[uint64](k)]) != lit[k]:
            return 0
        k = k + 1
    return 1


# Resolve a milli-length (value * 1000) with the CSS unit at src[_len_i..] to
# PIXELS, advancing _len_i past the unit. Longest units are tested first so
# `rem`/`vmin`/`vmax` are not shadowed by their shorter prefixes.
def _len_apply_unit(milli: int32) -> int32:
    i: uint64 = _len_i
    e: uint64 = _len_end
    if i < e and src_ptr[i] == 37:                   # '%' of the content column
        base: int32 = _content_right() - _left_margin()
        if base < 0:
            base = 0
        _len_i = i + 1
        return milli * base / 100000
    if _unit_at(i, e, cast[Ptr[uint8]]("vmin")) != 0:
        _len_i = i + 4
        mn: int32 = bw
        if bh < mn:
            mn = bh
        return milli * mn / 100000
    if _unit_at(i, e, cast[Ptr[uint8]]("vmax")) != 0:
        _len_i = i + 4
        mx: int32 = bw
        if bh > mx:
            mx = bh
        return milli * mx / 100000
    if _unit_at(i, e, cast[Ptr[uint8]]("rem")) != 0:
        _len_i = i + 3
        return milli * EM_PX / 1000
    if _unit_at(i, e, cast[Ptr[uint8]]("em")) != 0:
        _len_i = i + 2
        return milli * EM_PX / 1000
    if _unit_at(i, e, cast[Ptr[uint8]]("px")) != 0:
        _len_i = i + 2
        return milli / 1000
    if _unit_at(i, e, cast[Ptr[uint8]]("vw")) != 0:
        _len_i = i + 2
        return milli * bw / 100000
    if _unit_at(i, e, cast[Ptr[uint8]]("vh")) != 0:
        _len_i = i + 2
        return milli * bh / 100000
    if _unit_at(i, e, cast[Ptr[uint8]]("ch")) != 0:  # ~ one monospace cell
        _len_i = i + 2
        return milli * (EM_PX / 2) / 1000
    if _unit_at(i, e, cast[Ptr[uint8]]("pt")) != 0:  # 1pt == 4/3 px
        _len_i = i + 2
        return milli * 4 / 3 / 1000
    return milli / 1000                               # px / unitless


# Consume ONE numeric term at src[_len_i..] (optional sign, digits, optional
# .fraction to milli precision, optional unit) and return its pixel value,
# advancing _len_i. Sets _len_bad=1 (and returns 0) if no digits were present.
def _len_number() -> int32:
    i: uint64 = _len_i
    e: uint64 = _len_end
    while i < e and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    neg: int32 = 0
    if i < e and src_ptr[i] == 43:                   # '+'
        i = i + 1
    elif i < e and src_ptr[i] == 45:                 # '-'
        neg = 1
        i = i + 1
    seen: int32 = 0
    whole: int32 = 0
    while i < e and src_ptr[i] >= 48 and src_ptr[i] <= 57:
        whole = whole * 10 + cast[int32](src_ptr[i] - 48)
        seen = 1
        i = i + 1
    frac: int32 = 0
    scale: int32 = 100
    if i < e and src_ptr[i] == 46:                   # '.'
        i = i + 1
        while i < e and scale > 0 and src_ptr[i] >= 48 and src_ptr[i] <= 57:
            frac = frac + cast[int32](src_ptr[i] - 48) * scale
            scale = scale / 10
            seen = 1
            i = i + 1
    if seen == 0:
        _len_i = i
        _len_bad = 1
        return 0
    milli: int32 = whole * 1000 + frac
    _len_i = i
    px: int32 = _len_apply_unit(milli)
    if neg != 0:
        return 0 - px
    return px


# calc() recursive-descent over [_len_i, _len_end): expr := term (('+'|'-') term)*
# term := factor (('*'|'/') factor)*; factor := '(' expr ')' | number. Lengths
# resolve to px; bare numbers stay unitless so `calc(100%/3)` and `calc(2*8px)`
# both work. No unit typechecking (mixing is treated numerically).
def _calc_factor() -> int32:
    while _len_i < _len_end and (src_ptr[_len_i] == 32 or src_ptr[_len_i] == 9):
        _len_i = _len_i + 1
    if _len_i < _len_end and src_ptr[_len_i] == 40:  # '('
        _len_i = _len_i + 1
        v: int32 = _calc_expr()
        while _len_i < _len_end and src_ptr[_len_i] != 41:
            _len_i = _len_i + 1
        if _len_i < _len_end:
            _len_i = _len_i + 1                       # past ')'
        return v
    return _len_number()


def _calc_term() -> int32:
    v: int32 = _calc_factor()
    while _len_i < _len_end:
        while _len_i < _len_end and (src_ptr[_len_i] == 32 or \
                                     src_ptr[_len_i] == 9):
            _len_i = _len_i + 1
        if _len_i < _len_end and src_ptr[_len_i] == 42:      # '*'
            _len_i = _len_i + 1
            v = v * _calc_factor()
        elif _len_i < _len_end and src_ptr[_len_i] == 47:    # '/'
            _len_i = _len_i + 1
            d: int32 = _calc_factor()
            if d != 0:
                v = v / d
        else:
            break
    return v


def _calc_expr() -> int32:
    v: int32 = _calc_term()
    while _len_i < _len_end:
        while _len_i < _len_end and (src_ptr[_len_i] == 32 or \
                                     src_ptr[_len_i] == 9):
            _len_i = _len_i + 1
        if _len_i < _len_end and src_ptr[_len_i] == 43:      # '+'
            _len_i = _len_i + 1
            v = v + _calc_term()
        elif _len_i < _len_end and src_ptr[_len_i] == 45:    # '-'
            _len_i = _len_i + 1
            v = v - _calc_term()
        else:
            break
    return v


# Parse a CSS length from src[vs..ve) into PIXELS. Honours px / em / rem / % / vw
# / vh / vmin / vmax / ch / pt units, decimal values, a leading sign, and
# `calc(...)`. % is of the body content column (bw - 2*CONTENT_X); em/rem ==
# EM_PX px. Returns the pixel value, or -1 when there is no numeric prefix
# (auto/none/inherit/...).
def _style_len(vs: uint64, ve: uint64) -> int32:
    i: uint64 = vs
    while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    if _unit_at(i, ve, cast[Ptr[uint8]]("calc(")) != 0:
        j: uint64 = i + 5
        _len_i = j
        _len_end = ve
        return _calc_expr()
    _len_i = i
    _len_end = ve
    _len_bad = 0
    v: int32 = _len_number()
    if _len_bad != 0:
        return -1
    return v


# Parse a CSS z-index: an optional-sign integer (may be negative). Returns the
# value, or ZIDX_UNSET when the value is `auto`/empty/non-numeric.
def _zindex_value(vs: uint64, ve: uint64) -> int32:
    i: uint64 = vs
    while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    neg: int32 = 0
    if i < ve and src_ptr[i] == 45:                      # '-'
        neg = 1
        i = i + 1
    seen: int32 = 0
    v: int32 = 0
    while i < ve:
        d: uint8 = src_ptr[i]
        if d >= 48 and d <= 57:
            v = v * 10 + cast[int32](d - 48)
            seen = 1
            i = i + 1
        else:
            break
    if seen == 0:
        return ZIDX_UNSET
    if neg != 0:
        return 0 - v
    return v


# Parse a CSS line-height value from src[vs..ve) into the r_lineh/d_lineh
# encoding: 0 = none/normal/unparseable; >0 = absolute PIXELS (px/em); <0 =
# unitless number or percentage as a milli-multiplier, negated, resolved against
# the element font-size later (1.5 -> -1500; 1.4em -> +22px; 150% -> -1500;
# 24px -> +24). Handles up to 3 fractional digits so "1.5"/"2.0" round-trip.
def _lineh_value(vs: uint64, ve: uint64) -> int32:
    i: uint64 = vs
    while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    seen: int32 = 0
    whole: int32 = 0
    while i < ve:
        d: uint8 = src_ptr[i]
        if d >= 48 and d <= 57:
            whole = whole * 10 + cast[int32](d - 48)
            seen = 1
            i = i + 1
        else:
            break
    frac: int32 = 0          # milli fraction (0..999)
    scale: int32 = 100
    if i < ve and src_ptr[i] == 46:                  # '.'
        i = i + 1
        while i < ve and scale > 0:
            d2: uint8 = src_ptr[i]
            if d2 >= 48 and d2 <= 57:
                frac = frac + cast[int32](d2 - 48) * scale
                scale = scale / 10
                seen = 1
                i = i + 1
            else:
                break
    if seen == 0:
        return 0                                      # "normal" / unparseable
    milli: int32 = whole * 1000 + frac
    if i < ve and src_ptr[i] == 37:                  # '%' of font-size
        return -(milli / 100)
    if i + 1 < ve and _hx_lower(src_ptr[i]) == 112 and _hx_lower(src_ptr[i + 1]) == 120:
        return milli / 1000                           # 'px' -> px
    if i + 1 < ve and _hx_lower(src_ptr[i]) == 101 and _hx_lower(src_ptr[i + 1]) == 109:
        return milli * EM_PX / 1000                   # 'em' -> px
    return -milli                                     # unitless multiplier


# Resolve the r_lineh/d_lineh encoding to absolute PIXELS given the element's
# effective font-size (0 = use EM_PX default). 0 in -> 0 out (unset).
def _lineh_resolve(enc: int32, font_px: int32) -> int32:
    if enc == 0:
        return 0
    if enc > 0:
        return enc                                    # already px
    base: int32 = font_px
    if base <= 0:
        base = EM_PX
    return (-enc) * base / 1000                       # unitless/% multiplier


# Parse a CSS `white-space` keyword from src[vs..ve) into the mode+1 encoding
# (0 = unrecognised / sets none): 1 normal, 2 nowrap, 3 pre, 4 pre-wrap. Longer
# keywords are tested before their prefixes so "pre-wrap" is not eaten by "pre".
# `pre-line` (collapse spaces, keep newlines) has no dedicated flow mode here;
# we treat it as `normal` so it does NOT wrongly preserve the spaces.
def _ws_value(vs: uint64, ve: uint64) -> int32:
    s: uint64 = _val_start(vs, ve)
    if _val_starts(s, ve, cast[Ptr[uint8]]("pre-wrap")) != 0:
        return 4
    if _val_starts(s, ve, cast[Ptr[uint8]]("pre-line")) != 0:
        return 1
    if _val_starts(s, ve, cast[Ptr[uint8]]("pre")) != 0:
        return 3
    if _val_starts(s, ve, cast[Ptr[uint8]]("nowrap")) != 0:
        return 2
    if _val_starts(s, ve, cast[Ptr[uint8]]("normal")) != 0:
        return 1
    return 0


def _is_alpha(c: uint8) -> int32:
    lc: uint8 = _hx_lower(c)
    if lc >= 97 and lc <= 122:
        return 1
    return 0


def _is_name_ch(c: uint8) -> int32:
    lc: uint8 = _hx_lower(c)
    if (lc >= 97 and lc <= 122) or (c >= 48 and c <= 57) or c == 45 or c == 95:
        return 1
    return 0


# Copy src[a..b) lowercased into css_sbuf; sets g_store_off/g_store_len.
def _css_store(a: uint64, b: uint64):
    g_store_off = cast[int32](css_slen)
    i: uint64 = a
    while i < b and css_slen < CSS_STR_CAP - 1:
        css_sbuf[css_slen] = _hx_lower(src_ptr[i])
        css_slen = css_slen + 1
        i = i + 1
    g_store_len = cast[int32](css_slen) - g_store_off


# Compare src[a..b) (whitespace-trimmed, lowercased) against literal `lit`.
def _prop_is(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    while a < b and _css_ws(src_ptr[a]) != 0:
        a = a + 1
    while b > a and _css_ws(src_ptr[b - 1]) != 0:
        b = b - 1
    i: uint64 = 0
    while lit[i] != 0:
        if a + i >= b:
            return 0
        if _hx_lower(src_ptr[a + i]) != lit[i]:
            return 0
        i = i + 1
    if a + i != b:
        return 0
    return 1


# Does the value src[a..b) begin (after whitespace) with literal `lit`?
def _val_starts(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    while a < b and _css_ws(src_ptr[a]) != 0:
        a = a + 1
    return _srcword_is(a, lit)


# Does the value src[a..b) contain the token `auto` (e.g. `margin: 0 auto`, or a
# bare `margin-left: auto`)? Drives centred-block detection.
def _val_has_auto(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i + 4 <= b:
        if _hx_lower(src_ptr[i]) == 97 and _hx_lower(src_ptr[i + 1]) == 117 and \
           _hx_lower(src_ptr[i + 2]) == 116 and _hx_lower(src_ptr[i + 3]) == 111:
            return 1
        i = i + 1
    return 0


# Does the value src[a..b) contain `lit` as a whole space-delimited word? Used
# for shorthand values like `list-style: none inside` where the keyword we care
# about is not necessarily first.
def _val_has_word(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    i: uint64 = a
    while i < b:
        while i < b and _css_ws(src_ptr[i]) != 0:
            i = i + 1
        s: uint64 = i
        while i < b and _css_ws(src_ptr[i]) == 0:
            i = i + 1
        if i > s and _srcword_is(s, lit) != 0:
            return 1
    return 0


# Does property name src[a..b) (trimmed) start with literal `lit`? Used to tell
# `margin` (shorthand) / `margin-left` (side) apart without over-matching.
def _prop_prefix(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    while a < b and _css_ws(src_ptr[a]) != 0:
        a = a + 1
    while b > a and _css_ws(src_ptr[b - 1]) != 0:
        b = b - 1
    i: uint64 = 0
    while lit[i] != 0:
        if a + i >= b:
            return 0
        if _hx_lower(src_ptr[a + i]) != lit[i]:
            return 0
        i = i + 1
    return 1


# Accumulate one side inset (margin/padding on that side sum into one column).
def _box_add_l(px: int32):
    if px < 0:
        return
    if d_ml < 0:
        d_ml = 0
    d_ml = d_ml + px


def _box_add_r(px: int32):
    if px < 0:
        return
    if d_mr < 0:
        d_mr = 0
    d_mr = d_mr + px


def _box_add_t(px: int32):
    if px < 0:
        return
    if d_mt < 0:
        d_mt = 0
    d_mt = d_mt + px


def _box_add_b(px: int32):
    if px < 0:
        return
    if d_mb < 0:
        d_mb = 0
    d_mb = d_mb + px


# Parse the space-separated length list of a margin/padding shorthand into
# box_lens[0..n_box_lens); non-length tokens (should not occur here) are skipped.
def _parse_box_lens(vs: uint64, ve: uint64):
    n_box_lens = 0
    i: uint64 = vs
    while i < ve and n_box_lens < 4:
        while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
            i = i + 1
        if i >= ve:
            break
        ts: uint64 = i
        while i < ve and src_ptr[i] != 32 and src_ptr[i] != 9:
            i = i + 1
        px: int32 = _style_len(ts, i)
        if px >= 0:
            box_lens[n_box_lens] = px
            n_box_lens = n_box_lens + 1


# Apply a `margin:`/`padding:` shorthand (1..4 lengths, CSS TRBL rules) into the
# left/right/top/bottom insets.
def _box_shorthand(vs: uint64, ve: uint64):
    _parse_box_lens(vs, ve)
    if n_box_lens == 0:
        return
    t: int32 = box_lens[0]
    r: int32 = box_lens[0]
    bo: int32 = box_lens[0]
    l: int32 = box_lens[0]
    if n_box_lens >= 2:
        r = box_lens[1]
        l = box_lens[1]
    if n_box_lens >= 3:
        bo = box_lens[2]
    if n_box_lens >= 4:
        l = box_lens[3]
    _box_add_t(t)
    _box_add_r(r)
    _box_add_b(bo)
    _box_add_l(l)


# Route ONE box-model declaration (property src[ps..pe) : value src[vs..ve))
# into the d_* box scratch. Shared by the stylesheet (_apply_decl) and inline
# style="" paths so classes and inline styles cascade identically. Returns 1 if
# the property was a box property (handled), else 0.
def _box_decl(ps: uint64, pe: uint64, vs: uint64, ve: uint64) -> int32:
    # border-radius / border-image / border-collapse / border-spacing are NOT
    # box borders — they must never switch the 1px frame on (border-radius in
    # particular is ubiquitous on backgrounded cards/buttons that have no
    # border). Swallow them here so the generic `border` prefix below does not
    # spuriously draw a hard rectangle around every rounded card.
    if _prop_prefix(ps, pe, cast[Ptr[uint8]]("border-radius")) != 0 or \
       _prop_prefix(ps, pe, cast[Ptr[uint8]]("border-image")) != 0 or \
       _prop_prefix(ps, pe, cast[Ptr[uint8]]("border-collapse")) != 0 or \
       _prop_prefix(ps, pe, cast[Ptr[uint8]]("border-spacing")) != 0:
        return 1
    # Border: any border / border-style / border-width / border-<side> turns the
    # box on unless the value is none/hidden/0.
    if _prop_prefix(ps, pe, cast[Ptr[uint8]]("border")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("none")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("hidden")) != 0:
            d_bd = 0
        else:
            d_bd = 1
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("width")) != 0:
        w: int32 = _style_len(vs, ve)
        if w >= 0:
            d_wd = w
        return 1
    # max-width caps the content column; for our layout it pins the wrap width
    # like `width` (the common centred-container idiom `max-width:Npx;margin:0
    # auto`). A later explicit `width` still overrides via d_wd.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("max-width")) != 0:
        mw: int32 = _style_len(vs, ve)
        if mw >= 0:
            d_wd = mw
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("float")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("left")) != 0:
            d_float = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("right")) != 0:
            d_float = 2
        else:
            d_float = 0                                  # none / inline-start...
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("position")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("relative")) != 0:
            d_pos = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("absolute")) != 0 or \
             _val_starts(vs, ve, cast[Ptr[uint8]]("fixed")) != 0:
            d_pos = 2
        else:
            d_pos = 0                                    # static / sticky
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("top")) != 0:
        d_top = _style_len(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("left")) != 0:
        d_left = _style_len(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("right")) != 0:
        d_right = _style_len(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("bottom")) != 0:
        d_bottom = _style_len(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("z-index")) != 0:
        d_zidx = _zindex_value(vs, ve)
        return 1
    # side-specific first (longer names) so the shorthand check does not eat them
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-left")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-left")) != 0:
        if _val_has_auto(vs, ve) != 0:
            d_center = 1
        _box_add_l(_style_len(vs, ve))
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-right")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-right")) != 0:
        if _val_has_auto(vs, ve) != 0:
            d_center = 1
        _box_add_r(_style_len(vs, ve))
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-top")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-top")) != 0:
        _box_add_t(_style_len(vs, ve))
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-bottom")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-bottom")) != 0:
        _box_add_b(_style_len(vs, ve))
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding")) != 0:
        # `margin: <v> auto` (or `margin: auto`) centres the box in its parent.
        if _prop_is(ps, pe, cast[Ptr[uint8]]("margin")) != 0 and \
           _val_has_auto(vs, ve) != 0:
            d_center = 1
        _box_shorthand(vs, ve)
        return 1
    return 0


# First non-space offset in [a,b) — where a colour value begins.
def _val_start(a: uint64, b: uint64) -> uint64:
    while a < b and _css_ws(src_ptr[a]) != 0:
        a = a + 1
    return a


# ---- byte-buffer compares -------------------------------------------
def _buf_eq(a: Ptr[uint8], alen: int32, b: Ptr[uint8], blen: int32) -> int32:
    if alen != blen:
        return 0
    i: int32 = 0
    while i < alen:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# Does the element's class list (el_sbuf[coff..coff+clen)) contain the token
# css_sbuf[koff..koff+klen) (space-separated)?
def _cls_contains(coff: int32, clen: int32, koff: int32, klen: int32) -> int32:
    i: int32 = 0
    while i < clen:
        while i < clen and el_sbuf[coff + i] == 32:
            i = i + 1
        s: int32 = i
        while i < clen and el_sbuf[coff + i] != 32:
            i = i + 1
        tlen: int32 = i - s
        if tlen == klen and _buf_eq(&el_sbuf[coff + s], tlen, \
                                    &css_sbuf[koff], klen) != 0:
            return 1
    return 0


# ---- selector parsing -----------------------------------------------
def _read_name(i: uint64, b: uint64) -> uint64:
    while i < b and _is_name_ch(src_ptr[i]) != 0:
        i = i + 1
    return i


# Parse one compound selector at src[a..b) into c_* globals; c_spec gets its
# specificity contribution.
def _parse_compound(a: uint64, b: uint64):
    c_tag_off = -1
    c_tag_len = 0
    c_cls_off = -1
    c_cls_len = 0
    c_id_off = -1
    c_id_len = 0
    c_spec = 0
    i: uint64 = a
    if i < b and src_ptr[i] == 42:                   # '*' universal
        i = i + 1
    elif i < b and _is_alpha(src_ptr[i]) != 0:
        j: uint64 = _read_name(i, b)
        _css_store(i, j)
        c_tag_off = g_store_off
        c_tag_len = g_store_len
        c_spec = c_spec + 1
        i = j
    while i < b:
        if src_ptr[i] == 46:                         # '.class'
            j2: uint64 = _read_name(i + 1, b)
            # A compound may chain several classes (`.a.b`): store them all as
            # one space-joined token string so matching can require EVERY class
            # (and specificity grows +10 per class). The first class seeds
            # c_cls_off; each subsequent one appends " <name>" and extends len.
            if c_cls_off < 0:
                _css_store(i + 1, j2)
                c_cls_off = g_store_off
                c_cls_len = g_store_len
            else:
                if css_slen < CSS_STR_CAP - 1:
                    css_sbuf[css_slen] = 32          # separator space
                    css_slen = css_slen + 1
                _css_store(i + 1, j2)
                c_cls_len = g_store_off + g_store_len - c_cls_off
            c_spec = c_spec + 10
            i = j2
        elif src_ptr[i] == 35:                       # '#id'
            j3: uint64 = _read_name(i + 1, b)
            _css_store(i + 1, j3)
            c_id_off = g_store_off
            c_id_len = g_store_len
            c_spec = c_spec + 100
            i = j3
        else:
            i = i + 1


# Parse a full selector src[a..b) into rule `ri`. Keeps the rightmost compound
# as the target and the nearest preceding compound as the ancestor.
def _parse_selector(a: uint64, b: uint64, ri: int32):
    # trim
    while a < b and (src_ptr[a] == 32 or src_ptr[a] == 9 or src_ptr[a] == 10 \
                     or src_ptr[a] == 13 or src_ptr[a] == 62):
        a = a + 1
    while b > a and (src_ptr[b - 1] == 32 or src_ptr[b - 1] == 9 or \
                     src_ptr[b - 1] == 10 or src_ptr[b - 1] == 13):
        b = b - 1
    r_has_anc[ri] = 0
    spec: int32 = 0
    # walk compounds left->right; remember previous compound as ancestor.
    i: uint64 = a
    prev_present: int32 = 0
    while i < b:
        while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9 or \
                         src_ptr[i] == 62 or src_ptr[i] == 10 or \
                         src_ptr[i] == 13):
            i = i + 1
        if i >= b:
            break
        cs: uint64 = i
        while i < b and src_ptr[i] != 32 and src_ptr[i] != 9 and \
              src_ptr[i] != 62 and src_ptr[i] != 10 and src_ptr[i] != 13:
            i = i + 1
        # a compound occupies [cs,i); shift current target -> ancestor.
        if prev_present != 0:
            r_has_anc[ri] = 1
            r_atag_off[ri] = r_tag_off[ri]
            r_atag_len[ri] = r_tag_len[ri]
            r_acls_off[ri] = r_cls_off[ri]
            r_acls_len[ri] = r_cls_len[ri]
            r_aid_off[ri]  = r_id_off[ri]
            r_aid_len[ri]  = r_id_len[ri]
        _parse_compound(cs, i)
        r_tag_off[ri] = c_tag_off
        r_tag_len[ri] = c_tag_len
        r_cls_off[ri] = c_cls_off
        r_cls_len[ri] = c_cls_len
        r_id_off[ri]  = c_id_off
        r_id_len[ri]  = c_id_len
        spec = spec + c_spec
        prev_present = 1
    r_spec[ri] = spec


# ---- declaration parsing --------------------------------------------
# Map a `display:` value span to the engine's display code (shared by the
# stylesheet and inline-style parsers). inline-block/inline-flex are tested
# before the bare "inline" prefix; flex covers inline-flex too.
def _disp_value(vs: uint64, ve: uint64) -> int32:
    if _val_starts(vs, ve, cast[Ptr[uint8]]("none")) != 0:
        return 1
    if _val_starts(vs, ve, cast[Ptr[uint8]]("inline-block")) != 0:
        return 4
    if _val_starts(vs, ve, cast[Ptr[uint8]]("inline-flex")) != 0:
        return 2
    if _val_starts(vs, ve, cast[Ptr[uint8]]("inline-grid")) != 0:
        return 6
    if _val_starts(vs, ve, cast[Ptr[uint8]]("inline")) != 0:
        return 5
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex")) != 0:
        return 2
    if _val_starts(vs, ve, cast[Ptr[uint8]]("grid")) != 0:
        return 6
    if _val_starts(vs, ve, cast[Ptr[uint8]]("block")) != 0:
        return 3
    return 0


# justify-content value -> 1 flex-start, 2 center, 3 flex-end, 4 space-between,
# 5 space-around (space-evenly maps to around). 0 for unrecognised/unset.
def _justify_value(vs: uint64, ve: uint64) -> int32:
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex-start")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("start")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("left")) != 0:
        return 1
    if _val_starts(vs, ve, cast[Ptr[uint8]]("center")) != 0:
        return 2
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex-end")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("end")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("right")) != 0:
        return 3
    if _val_starts(vs, ve, cast[Ptr[uint8]]("space-between")) != 0:
        return 4
    if _val_starts(vs, ve, cast[Ptr[uint8]]("space-around")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("space-evenly")) != 0:
        return 5
    return 0


# align-items (cross axis) value -> 1 flex-start (== top-aligned default),
# 2 center, 3 flex-end, 4 stretch. `baseline` approximates to flex-start. 0 for
# unrecognised/unset (which keeps the engine's existing top-aligned behaviour).
def _align_items_value(vs: uint64, ve: uint64) -> int32:
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex-start")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("start")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("baseline")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("self-start")) != 0:
        return 1
    if _val_starts(vs, ve, cast[Ptr[uint8]]("center")) != 0:
        return 2
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex-end")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("end")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("self-end")) != 0:
        return 3
    if _val_starts(vs, ve, cast[Ptr[uint8]]("stretch")) != 0:
        return 4
    return 0


# Encode ONE grid-template-columns track token src[a..b) into the compact form:
#   <n>fr  -> negative fr weight (-n; a bare `fr` == -1)
#   <len>  -> a fixed px length (px/em/% via _style_len)
#   auto / min-content / max-content / other keyword -> a flexible 1fr track
# (a lean approximation — this round has no intrinsic sizing). fr is detected
# BEFORE _style_len so "1fr" is not mistaken for 1px.
def _grid_one_track(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    seen: int32 = 0
    v: int32 = 0
    j: uint64 = i
    while j < b and src_ptr[j] >= 48 and src_ptr[j] <= 57:
        v = v * 10 + cast[int32](src_ptr[j] - 48)
        seen = 1
        j = j + 1
    # trailing "fr" -> fractional track
    if j + 1 < b and _hx_lower(src_ptr[j]) == 102 and _hx_lower(src_ptr[j + 1]) == 114:
        w: int32 = v
        if seen == 0 or w <= 0:
            w = 1
        return -w
    if seen == 0:
        return -1                                    # auto / *-content -> 1fr
    px: int32 = _style_len(a, b)
    if px < 0:
        px = 0
    return px


# Scratch the shared track parser writes into; a caller copies it into the column
# (d_gtc) or row (d_gtr) destination so `grid-template-columns` and
# `grid-template-rows` in the same ruleset don't clobber each other.
gts_enc: Array[8, int32]


# Does token src[a..b) (leading ws skipped) contain the keyword `span`?
def _grid_tok_isspan(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i + 4 <= b:
        if _hx_lower(src_ptr[i]) == 115 and _hx_lower(src_ptr[i + 1]) == 112 and \
           _hx_lower(src_ptr[i + 2]) == 97 and _hx_lower(src_ptr[i + 3]) == 110:
            return 1
        i = i + 1
    return 0


# The first run of decimal digits in src[a..b) as an int (0 if none).
def _grid_tok_num(a: uint64, b: uint64) -> int32:
    v: int32 = 0
    seen: int32 = 0
    i: uint64 = a
    while i < b:
        c: uint8 = src_ptr[i]
        if c >= 48 and c <= 57:
            v = v * 10 + cast[int32](c - 48)
            seen = 1
        elif seen != 0:
            i = b                                        # stop at first non-digit run end
        i = i + 1
    return v


# Parse a per-ITEM `grid-column` value src[vs..ve) into d_gcstart (1-based start
# line; 0 = auto) and d_gcspan (track count; default 1). Handles `span N`,
# `A / B` (span = B-A), `A / span N`, and a bare `A` (start only). Row placement
# (`grid-row`) is NOT handled — the fixed-row model has no cross-row spanning.
def _grid_column_parse(vs: uint64, ve: uint64):
    d_gcstart = 0
    d_gcspan = 1
    slash: uint64 = ve
    i: uint64 = vs
    while i < ve:
        if src_ptr[i] == 47:                             # '/'
            slash = i
            break
        i = i + 1
    lsp: int32 = _grid_tok_isspan(vs, slash)
    lnum: int32 = _grid_tok_num(vs, slash)
    if slash < ve:
        rsp: int32 = _grid_tok_isspan(slash + 1, ve)
        rnum: int32 = _grid_tok_num(slash + 1, ve)
        if lsp == 0 and lnum > 0:
            d_gcstart = lnum
        if rsp != 0 and rnum > 0:
            d_gcspan = rnum
        elif lsp != 0 and lnum > 0:
            d_gcspan = lnum
        elif lnum > 0 and rnum > lnum:
            d_gcspan = rnum - lnum
    else:
        if lsp != 0 and lnum > 0:
            d_gcspan = lnum
        elif lnum > 0:
            d_gcstart = lnum


# Parse a `grid-template-columns`/`grid-template-rows` value src[vs..ve) into the
# compact per-track encoding, written into the shared gts_enc[0..) scratch (the
# caller copies it out). Understands `repeat(N, <track>)`, explicit space-
# separated track lists ("200px 1fr 1fr"), and bare single tracks. Caps at
# GRID_MAXTRACK tracks (extra dropped — >8 tracks is a deferred feature).
# Returns the track count (0 = nothing parseable). NOT handled this round (all
# fall back to block stacking / a flexible track): grid-template-areas, minmax(),
# auto-fit/auto-fill, subgrid.
def _grid_parse_template(vs: uint64, ve: uint64) -> int32:
    n: int32 = 0
    i: uint64 = vs
    while i < ve and n < GRID_MAXTRACK:
        c: uint8 = src_ptr[i]
        if c == 32 or c == 9 or c == 10 or c == 13 or c == 44:   # ws or ','
            i = i + 1
            continue
        if _val_starts(i, ve, cast[Ptr[uint8]]("repeat")) != 0:
            j: uint64 = i
            while j < ve and src_ptr[j] != 40:       # '('
                j = j + 1
            j = j + 1
            cnt: int32 = 0
            while j < ve and src_ptr[j] >= 48 and src_ptr[j] <= 57:
                cnt = cnt * 10 + cast[int32](src_ptr[j] - 48)
                j = j + 1
            while j < ve and src_ptr[j] != 44:       # ',' before the track
                j = j + 1
            j = j + 1
            ts: uint64 = j
            te2: uint64 = j
            while te2 < ve and src_ptr[te2] != 41:   # ')'
                te2 = te2 + 1
            enc: int32 = _grid_one_track(ts, te2)
            k: int32 = 0
            while k < cnt and n < GRID_MAXTRACK:
                gts_enc[n] = enc
                n = n + 1
                k = k + 1
            i = te2
            if i < ve:
                i = i + 1                            # past ')'
            continue
        te3: uint64 = i
        while te3 < ve and src_ptr[te3] != 32 and src_ptr[te3] != 9 and \
              src_ptr[te3] != 10 and src_ptr[te3] != 13 and src_ptr[te3] != 44:
            te3 = te3 + 1
        gts_enc[n] = _grid_one_track(i, te3)
        n = n + 1
        i = te3
    return n


# ---- CSS custom properties (var()) ----------------------------------
# `--name: value` declarations are harvested (name + raw value bytes copied out
# of whatever buffer is being parsed) into a flat token table BEFORE the rules
# are cascaded, so `prop: var(--name[, fallback])` resolves regardless of source
# order. Resolution (in _apply_decl) re-points the parser at the copied value and
# re-dispatches, so a token can carry any value type (colour, length, keyword)
# and even nest another var().
CVAR_MAX: int32 = 96
cvar_name_off: Array[96, int32]
cvar_name_len: Array[96, int32]
cvar_val_off:  Array[96, int32]
cvar_val_len:  Array[96, int32]
cvar_namebuf:  Array[4096, uint8]
cvar_namelen:  int32 = 0
cvar_valbuf:   Array[16384, uint8]
cvar_vallen:   int32 = 0
n_cvar: int32 = 0
# scratch for splicing "<property>:<tokenvalue>" during var() re-dispatch.
CVAR_SCRATCH: int32 = 1024
cvar_scratch: Array[1024, uint8]


def _cvar_reset():
    n_cvar = 0
    cvar_namelen = 0
    cvar_vallen = 0


# Store a `--name` (src[ns..ne), leading dashes included) -> value (src[vs..ve))
# token, trimming surrounding whitespace and copying both out of src_ptr.
def _cvar_store(ns: uint64, ne: uint64, vs: uint64, ve: uint64):
    if n_cvar >= CVAR_MAX:
        return
    while vs < ve and (src_ptr[vs] == 32 or src_ptr[vs] == 9):
        vs = vs + 1
    while ve > vs and (src_ptr[ve - 1] == 32 or src_ptr[ve - 1] == 9 or \
                       src_ptr[ve - 1] == 10 or src_ptr[ve - 1] == 13):
        ve = ve - 1
    while ns < ne and (src_ptr[ns] == 32 or src_ptr[ns] == 9):
        ns = ns + 1
    while ne > ns and (src_ptr[ne - 1] == 32 or src_ptr[ne - 1] == 9):
        ne = ne - 1
    nl: int32 = cast[int32](ne - ns)
    vl: int32 = cast[int32](ve - vs)
    if nl <= 0 or vl < 0:
        return
    if cvar_namelen + nl > 4096 or cvar_vallen + vl > 16384:
        return
    cvar_name_off[n_cvar] = cvar_namelen
    cvar_name_len[n_cvar] = nl
    ci: int32 = 0
    while ci < nl:
        cvar_namebuf[cvar_namelen + ci] = src_ptr[ns + cast[uint64](ci)]
        ci = ci + 1
    cvar_namelen = cvar_namelen + nl
    cvar_val_off[n_cvar] = cvar_vallen
    cvar_val_len[n_cvar] = vl
    vi: int32 = 0
    while vi < vl:
        cvar_valbuf[cvar_vallen + vi] = src_ptr[vs + cast[uint64](vi)]
        vi = vi + 1
    cvar_vallen = cvar_vallen + vl
    n_cvar = n_cvar + 1


# Find the token whose name matches src[ns..ne); later definitions win, so scan
# from the most recent. Returns the token index or -1.
def _cvar_find(ns: uint64, ne: uint64) -> int32:
    nl: int32 = cast[int32](ne - ns)
    idx: int32 = n_cvar - 1
    while idx >= 0:
        if cvar_name_len[idx] == nl:
            ok: int32 = 1
            k: int32 = 0
            while k < nl:
                if cvar_namebuf[cvar_name_off[idx] + k] != \
                   src_ptr[ns + cast[uint64](k)]:
                    ok = 0
                    break
                k = k + 1
            if ok != 0:
                return idx
        idx = idx - 1
    return -1


# Harvest every `--name: value` declaration in the CSS region src[a..b) into the
# token table. A `--` only counts at a declaration start (previous non-space is
# '{' or ';' or the region start), so `var(--x)` usages are not mistaken for
# definitions.
def _scan_cvars(a: uint64, b: uint64):
    i: uint64 = a
    while i + 1 < b:
        if src_ptr[i] == 45 and src_ptr[i + 1] == 45:        # '--'
            atstart: int32 = 0
            p: uint64 = i
            found: int32 = 0
            while p > a and found == 0:
                p = p - 1
                c2: uint8 = src_ptr[p]
                if c2 != 32 and c2 != 9 and c2 != 10 and c2 != 13:
                    found = 1
                    if c2 == 123 or c2 == 59:                # '{' ';'
                        atstart = 1
            if found == 0:
                atstart = 1                                  # region start
            if atstart != 0:
                ns: uint64 = i
                j: uint64 = i
                while j < b and src_ptr[j] != 58 and src_ptr[j] != 59 and \
                      src_ptr[j] != 125:                     # ':' ';' '}'
                    j = j + 1
                if j < b and src_ptr[j] == 58:
                    ne: uint64 = j
                    vsx: uint64 = j + 1
                    vex: uint64 = vsx
                    while vex < b and src_ptr[vex] != 59 and src_ptr[vex] != 125:
                        vex = vex + 1
                    _cvar_store(ns, ne, vsx, vex)
                    i = vex
                    continue
        i = i + 1


def _apply_decl(ps: uint64, pe: uint64, vs: uint64, ve: uint64):
    # var(--name[, fallback]): resolve the custom property, then re-dispatch this
    # declaration against the token's value (or, if unset, the fallback).
    vstart: uint64 = _val_start(vs, ve)
    if _unit_at(vstart, ve, cast[Ptr[uint8]]("var(")) != 0:
        q: uint64 = vstart + 4
        while q < ve and (src_ptr[q] == 32 or src_ptr[q] == 9):
            q = q + 1
        ns: uint64 = q
        while q < ve and src_ptr[q] != 44 and src_ptr[q] != 41:
            q = q + 1
        ne: uint64 = q
        while ne > ns and (src_ptr[ne - 1] == 32 or src_ptr[ne - 1] == 9):
            ne = ne - 1
        idx: int32 = _cvar_find(ns, ne)
        if idx >= 0:
            # Re-dispatch against the token's value. The property span (ps..pe)
            # lives in the current buffer while the value lives in cvar_valbuf,
            # so splice "<property>:<value>" into one scratch buffer and parse
            # that — otherwise the swapped src_ptr would misread the property.
            plen: int32 = cast[int32](pe - ps)
            v2s: uint64 = cast[uint64](cvar_val_off[idx])
            vlen: int32 = cvar_val_len[idx]
            if plen > 0 and plen + vlen + 1 <= CVAR_SCRATCH:
                w: int32 = 0
                while w < plen:
                    cvar_scratch[w] = src_ptr[ps + cast[uint64](w)]
                    w = w + 1
                cvar_scratch[plen] = 58                       # ':'
                w2: int32 = 0
                while w2 < vlen:
                    cvar_scratch[plen + 1 + w2] = cvar_valbuf[cast[int32](v2s) + w2]
                    w2 = w2 + 1
                sp: Ptr[uint8] = src_ptr
                sl: uint64 = src_len
                src_ptr = &cvar_scratch[0]
                src_len = cast[uint64](plen + 1 + vlen)
                _apply_decl(0, cast[uint64](plen), cast[uint64](plen + 1), \
                            cast[uint64](plen + 1 + vlen))
                src_ptr = sp
                src_len = sl
            return
        if q < ve and src_ptr[q] == 44:                      # ', fallback'
            fbs: uint64 = q + 1
            while fbs < ve and (src_ptr[fbs] == 32 or src_ptr[fbs] == 9):
                fbs = fbs + 1
            fbe: uint64 = ve
            while fbe > fbs and src_ptr[fbe - 1] != 41:      # trim to ')'
                fbe = fbe - 1
            if fbe > fbs:
                fbe = fbe - 1                                # drop the ')'
            if fbe > fbs:
                _apply_decl(ps, pe, fbs, fbe)
        return
    if _box_decl(ps, pe, vs, ve) != 0:
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("color")) != 0:
        d_color = _color_value(_val_start(vs, ve))
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("background-color")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("background")) != 0:
        cv: int32 = _color_value(_val_start(vs, ve))
        if cv >= 0:
            d_bg = cv
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("font-weight")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("bold")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("700")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("800")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("900")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("600")) != 0:
            d_weight = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("normal")) != 0:
            d_weight = 2
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("text-align")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("center")) != 0:
            d_align = 2
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("right")) != 0:
            d_align = 3
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("left")) != 0:
            d_align = 1
        return
    # text-decoration / text-decoration-line: the value is a space list that may
    # carry a style/colour (e.g. "underline dotted red"); we honour the LINE
    # keyword. "underline" -> draw a rule; "none" -> suppress (strip link u-line).
    if _prop_is(ps, pe, cast[Ptr[uint8]]("text-decoration")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("text-decoration-line")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("underline")) != 0:
            d_deco = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("line-through")) != 0:
            d_deco = 3
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("none")) != 0:
            d_deco = 2
        return
    # list-style / list-style-type: only `none` is honoured (suppress the <li>
    # bullet/number). Any list-style shorthand carrying `none` counts — the
    # shorthand rarely names a different type alongside none on real menus.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("list-style")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("list-style-type")) != 0:
        if _val_has_word(vs, ve, cast[Ptr[uint8]]("none")) != 0:
            d_nomark = 1
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("display")) != 0:
        d_disp = _disp_value(vs, ve)
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("flex-direction")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("column")) != 0:
            d_flexdir = 1
        else:
            d_flexdir = 2
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("justify-content")) != 0:
        jv: int32 = _justify_value(vs, ve)
        if jv != 0:
            d_justify = jv
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("align-items")) != 0:
        av: int32 = _align_items_value(vs, ve)
        if av != 0:
            d_aitems = av
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("flex-wrap")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("wrap")) != 0:
            d_flexwrap = 1
        else:
            d_flexwrap = 0                            # nowrap / wrap-reverse->off
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("grid-template-columns")) != 0:
        d_gtcn = _grid_parse_template(vs, ve)
        gc: int32 = 0
        while gc < d_gtcn and gc < GRID_MAXTRACK:
            d_gtc[gc] = gts_enc[gc]
            gc = gc + 1
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("grid-template-rows")) != 0:
        d_gtrn = _grid_parse_template(vs, ve)
        gr: int32 = 0
        while gr < d_gtrn and gr < GRID_MAXTRACK:
            d_gtr[gr] = gts_enc[gr]
            gr = gr + 1
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("grid-column")) != 0:
        _grid_column_parse(vs, ve)
        return
    # flex gaps. `gap: <row> [<col>]` shorthand sets both (one value => both);
    # `row-gap` / `column-gap` set one axis.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("gap")) != 0:
        _parse_box_lens(vs, ve)
        if n_box_lens >= 1:
            d_rowgap = box_lens[0]
            if n_box_lens >= 2:
                d_flexgap = box_lens[1]
            else:
                d_flexgap = box_lens[0]
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("column-gap")) != 0:
        gp: int32 = _style_len(vs, ve)
        if gp >= 0:
            d_flexgap = gp
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("row-gap")) != 0:
        rgp: int32 = _style_len(vs, ve)
        if rgp >= 0:
            d_rowgap = rgp
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("font-size")) != 0:
        fp: int32 = _style_len(vs, ve)
        if fp > 0:
            d_fontpx = fp
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("line-height")) != 0:
        lh: int32 = _lineh_value(_val_start(vs, ve), ve)
        if lh != 0:
            d_lineh = lh
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("white-space")) != 0:
        ws: int32 = _ws_value(vs, ve)
        if ws != 0:
            d_ws = ws
        return


# Parse a declaration block src[a..b) into d_* globals.
def _parse_decls(a: uint64, b: uint64):
    d_color = -1
    d_bg = -1
    d_weight = 0
    d_align = 0
    d_deco = 0
    d_nomark = 0
    d_disp = 0
    d_flexdir = 0
    d_justify = 0
    d_aitems = 0
    d_flexgap = -1
    d_rowgap = -1
    d_flexwrap = 0
    d_gtcn = 0
    d_gtrn = 0
    d_gcspan = 0
    d_gcstart = 0
    d_ml = -1
    d_mr = -1
    d_mt = -1
    d_mb = -1
    d_wd = -1
    d_bd = -1
    d_center = 0
    d_fontpx = -1
    d_lineh = 0
    d_ws = 0
    d_float = 0
    d_pos = 0
    d_top = -1
    d_left = -1
    d_right = -1
    d_bottom = -1
    d_zidx = ZIDX_UNSET
    i: uint64 = a
    while i < b:
        ps: uint64 = i
        while i < b and src_ptr[i] != 58 and src_ptr[i] != 59:   # ':' ';'
            i = i + 1
        if i < b and src_ptr[i] == 58:
            pe: uint64 = i
            i = i + 1
            vs: uint64 = i
            while i < b and src_ptr[i] != 59:
                i = i + 1
            _apply_decl(ps, pe, vs, i)
        if i < b and src_ptr[i] == 59:
            i = i + 1


# ---- stylesheet collection ------------------------------------------
# Parse selector-list { decls } starting at src[a]; returns offset just past
# the closing '}'. Emits one rule per comma-separated selector.
def _parse_ruleset(a: uint64, rgn_end: uint64) -> uint64:
    # selector list up to '{'
    sel_s: uint64 = a
    i: uint64 = a
    while i < rgn_end and src_ptr[i] != 123 and src_ptr[i] != 60:   # '{' '<'
        i = i + 1
    if i >= rgn_end or src_ptr[i] != 123:
        return i
    sel_e: uint64 = i
    i = i + 1
    dec_s: uint64 = i
    while i < rgn_end and src_ptr[i] != 125:                        # '}'
        i = i + 1
    dec_e: uint64 = i
    if i < rgn_end:
        i = i + 1
    _parse_decls(dec_s, dec_e)
    # Nothing we honour -> skip emitting rules entirely.
    if d_color < 0 and d_bg < 0 and d_weight == 0 and d_align == 0 and \
       d_deco == 0 and d_nomark == 0 and \
       d_disp == 0 and d_flexdir == 0 and d_justify == 0 and d_aitems == 0 and \
       d_flexgap < 0 and d_rowgap < 0 and d_flexwrap == 0 and d_gtcn == 0 and \
       d_gtrn == 0 and d_gcspan == 0 and d_gcstart == 0 and \
       d_ml < 0 and d_mr < 0 and d_mt < 0 and d_mb < 0 and \
       d_wd < 0 and d_bd < 0 and d_center == 0 and d_fontpx < 0 and \
       d_lineh == 0 and \
       d_ws == 0 and \
       d_float == 0 and \
       d_pos == 0 and d_top < 0 and d_left < 0 and d_right < 0 and d_bottom < 0 and \
       d_zidx == ZIDX_UNSET:
        return i
    # one rule per comma-separated selector
    ss: uint64 = sel_s
    k: uint64 = sel_s
    while k <= sel_e:
        if k == sel_e or src_ptr[k] == 44:           # ',' or end
            if n_rules < MAX_RULES and k > ss:
                ri: int32 = n_rules
                _parse_selector(ss, k, ri)
                r_color[ri]  = d_color
                r_bg[ri]     = d_bg
                r_weight[ri] = d_weight
                r_align[ri]  = d_align
                r_deco[ri]   = d_deco
                r_nomark[ri] = d_nomark
                r_disp[ri]   = d_disp
                r_flexdir[ri] = d_flexdir
                r_justify[ri] = d_justify
                r_aitems[ri] = d_aitems
                r_flexgap[ri] = d_flexgap
                r_rowgap[ri] = d_rowgap
                r_flexwrap[ri] = d_flexwrap
                r_gtcn[ri] = d_gtcn
                gtc: int32 = 0
                while gtc < d_gtcn and gtc < GRID_MAXTRACK:
                    r_gtc[ri * GRID_MAXTRACK + gtc] = d_gtc[gtc]
                    gtc = gtc + 1
                r_gtrn[ri] = d_gtrn
                gtr: int32 = 0
                while gtr < d_gtrn and gtr < GRID_MAXTRACK:
                    r_gtr[ri * GRID_MAXTRACK + gtr] = d_gtr[gtr]
                    gtr = gtr + 1
                r_gcspan[ri]  = d_gcspan
                r_gcstart[ri] = d_gcstart
                r_ml[ri]     = d_ml
                r_mr[ri]     = d_mr
                r_mt[ri]     = d_mt
                r_mb[ri]     = d_mb
                r_wd[ri]     = d_wd
                r_bd[ri]     = d_bd
                r_center[ri] = d_center
                r_fontpx[ri] = d_fontpx
                r_lineh[ri]  = d_lineh
                r_ws[ri]     = d_ws
                r_float[ri]  = d_float
                r_pos[ri]    = d_pos
                r_top[ri]    = d_top
                r_left[ri]   = d_left
                r_right[ri]  = d_right
                r_bottom[ri] = d_bottom
                r_zidx[ri]   = d_zidx
                n_rules = n_rules + 1
            ss = k + 1
        k = k + 1
    return i


# ---- external stylesheets (<link rel=stylesheet href=...>) ----------
# The engine is PURE (no fetch): a front-end resolves each linked sheet's href
# against the page URL, fetches it over its existing http9/file path, and hands
# the raw CSS bytes to he_css_append(); _collect_css() then parses them through
# the SAME cascade as inline <style>. he_css_reset() clears the buffer per page.
# The link-scan (he_css_scan_links) hands the front-end the hrefs to fetch.
HE_CSS_CAP:   uint64 = 262144
he_css_buf:   Array[262144, uint8]
he_css_len:   uint64 = 0
MAX_CSS_LINKS: int32 = 16
css_link_off: Array[16, uint64]      # href value offset into the loaded src
css_link_len: Array[16, int32]
n_css_links:  int32 = 0


def he_css_reset():
    he_css_len = 0


# Append raw CSS bytes (a fetched external sheet) to the cascade buffer. Silently
# truncates past the cap so a pathological megasheet can't run the engine away.
def he_css_append(p: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n and he_css_len < HE_CSS_CAP:
        he_css_buf[he_css_len] = p[i]
        he_css_len = he_css_len + 1
        i = i + 1
    # a declaration separator so back-to-back sheets never fuse a rule
    if he_css_len < HE_CSS_CAP:
        he_css_buf[he_css_len] = 10
        he_css_len = he_css_len + 1


# Parse a sheet region src[a,b) as a sequence of rulesets (skipping /* */ + ws).
# Shared by the <style> scan and the external he_css_buf parse.
def _parse_sheet(a: uint64, b: uint64):
    p: uint64 = a
    while p < b:
        if p + 1 < b and src_ptr[p] == 47 and src_ptr[p + 1] == 42:
            p = p + 2
            while p + 1 < b and not (src_ptr[p] == 42 and src_ptr[p + 1] == 47):
                p = p + 1
            p = p + 2
            continue
        if src_ptr[p] == 32 or src_ptr[p] == 9 or \
           src_ptr[p] == 10 or src_ptr[p] == 13:
            p = p + 1
            continue
        np: uint64 = _parse_ruleset(p, b)
        if np <= p:
            p = p + 1
        else:
            p = np


# Does the rel="..." value region src[a,b) contain the token "stylesheet"?
def _rel_is_stylesheet(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i < b:
        if _hx_lower(src_ptr[i]) == 115:                # 's'
            lit: Ptr[uint8] = cast[Ptr[uint8]]("stylesheet")
            j: int32 = 0
            ok: int32 = 1
            while lit[j] != 0:
                if i + cast[uint64](j) >= b or \
                   _hx_lower(src_ptr[i + cast[uint64](j)]) != lit[j]:
                    ok = 0
                    break
                j = j + 1
            if ok != 0:
                return 1
        i = i + 1
    return 0


# Scan the loaded HTML for <link rel=stylesheet href=...> and record each href
# (offset+len into src) so the front-end can fetch them. Front-end-agnostic +
# pure; the front-end resolves the URL and calls he_css_append() with the bytes.
def he_css_scan_links():
    n_css_links = 0
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60:                         # '<'
            k: uint64 = i + 1
            if _tagname_is(k, cast[Ptr[uint8]]("link")) != 0:
                te: uint64 = k
                while te < src_len and src_ptr[te] != 62:
                    te = te + 1
                is_ss: int32 = 0
                if _hx_find_attr(k, te, cast[Ptr[uint8]]("rel")) != 0:
                    is_ss = _rel_is_stylesheet(g_attr_start, g_attr_end)
                if is_ss != 0 and n_css_links < MAX_CSS_LINKS and \
                   _hx_find_attr(k, te, cast[Ptr[uint8]]("href")) != 0 and \
                   g_attr_end > g_attr_start:
                    css_link_off[n_css_links] = g_attr_start
                    css_link_len[n_css_links] = \
                        cast[int32](g_attr_end - g_attr_start)
                    n_css_links = n_css_links + 1
                i = te
                continue
        i = i + 1


def he_css_link_count() -> int32:
    return n_css_links


def he_css_link_off(i: int32) -> uint64:
    return css_link_off[i]


def he_css_link_len(i: int32) -> int32:
    return css_link_len[i]


# Pre-sweep: harvest every custom property (--name: value) from all <style>
# blocks and fetched external sheets BEFORE the rules are cascaded, so var()
# resolves independent of where the token is defined relative to its use.
def _collect_cvars():
    _cvar_reset()
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and _tagname_is(i + 1, cast[Ptr[uint8]]("style")) != 0:
            while i < src_len and src_ptr[i] != 62:
                i = i + 1
            if i < src_len:
                i = i + 1
            body: uint64 = i
            e: uint64 = body
            while e < src_len:
                if src_ptr[e] == 60 and e + 1 < src_len and \
                   src_ptr[e + 1] == 47 and \
                   _tagname_is(e + 2, cast[Ptr[uint8]]("style")) != 0:
                    break
                e = e + 1
            _scan_cvars(body, e)
            i = e
            continue
        i = i + 1
    if he_css_len > 0:
        sp: Ptr[uint8] = src_ptr
        sl: uint64 = src_len
        src_ptr = &he_css_buf[0]
        src_len = he_css_len
        _scan_cvars(0, he_css_len)
        src_ptr = sp
        src_len = sl


# Scan the whole page for <style> blocks and parse their rules.
def _collect_css():
    n_rules = 0
    css_slen = 0
    _collect_cvars()
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60:                         # '<'
            k: uint64 = i + 1
            if _tagname_is(k, cast[Ptr[uint8]]("style")) != 0:
                # advance to end of the opening tag
                while i < src_len and src_ptr[i] != 62:
                    i = i + 1
                if i < src_len:
                    i = i + 1
                body: uint64 = i
                # region ends at </style>
                e: uint64 = body
                while e < src_len:
                    if src_ptr[e] == 60 and e + 1 < src_len and \
                       src_ptr[e + 1] == 47 and \
                       _tagname_is(e + 2, cast[Ptr[uint8]]("style")) != 0:
                        break
                    e = e + 1
                # parse rulesets within [body,e)
                _parse_sheet(body, e)
                i = e
                continue
        i = i + 1
    # External <link rel=stylesheet> sheets the front-end fetched (he_css_append)
    # cascade through the SAME ruleset path: temporarily point the parser at the
    # CSS buffer so _parse_ruleset/_parse_selector read from it, then restore.
    if he_css_len > 0:
        save_p: Ptr[uint8] = src_ptr
        save_l: uint64 = src_len
        src_ptr = &he_css_buf[0]
        src_len = he_css_len
        _parse_sheet(0, he_css_len)
        src_ptr = save_p
        src_len = save_l


# ---- element stack + cascade matching -------------------------------
def _el_copy(a: uint64, b: uint64) -> int32:
    n: int32 = 0
    i: uint64 = a
    while i < b and el_slen < EL_STR_CAP - 1:
        el_sbuf[el_slen] = _hx_lower(src_ptr[i])
        el_slen = el_slen + 1
        n = n + 1
        i = i + 1
    return n


def _el_push(np: uint64, nlen: uint64, ne: uint64, te: uint64):
    if el_sp >= MAX_EL:
        return
    s: int32 = cast[int32](el_slen)
    el_tag_off[el_sp] = s
    el_tag_len[el_sp] = _el_copy(np, np + nlen)
    el_cls_off[el_sp] = cast[int32](el_slen)
    el_cls_len[el_sp] = 0
    if _hx_find_attr(ne, te, cast[Ptr[uint8]]("class")) != 0:
        el_cls_len[el_sp] = _el_copy(g_attr_start, g_attr_end)
    el_id_off[el_sp] = cast[int32](el_slen)
    el_id_len[el_sp] = 0
    if _hx_find_attr(ne, te, cast[Ptr[uint8]]("id")) != 0:
        el_id_len[el_sp] = _el_copy(g_attr_start, g_attr_end)
    el_sp = el_sp + 1


def _el_pop(np: uint64, nlen: uint64):
    # forgiving: pop the nearest matching open element (tolerates unclosed
    # inner tags), else leave the stack unchanged.
    k: int32 = el_sp - 1
    while k >= 0:
        if _buf_eq(&el_sbuf[el_tag_off[k]], el_tag_len[k], \
                   &src_ptr[np], cast[int32](nlen)) != 0:
            el_slen = cast[uint64](el_tag_off[k])
            el_sp = k
            return
        k = k - 1


# Does compound (target of rule ri) match the element at stack index e?
# Every class token in the selector's (space-joined) class string
# css_sbuf[koff..koff+klen) must be present in the element's class list — a
# compound `.a.b` matches only an element carrying BOTH `a` and `b`.
def _all_cls_match(coff: int32, clen: int32, koff: int32, klen: int32) -> int32:
    i: int32 = 0
    while i < klen:
        while i < klen and css_sbuf[koff + i] == 32:
            i = i + 1
        s: int32 = i
        while i < klen and css_sbuf[koff + i] != 32:
            i = i + 1
        tlen: int32 = i - s
        if tlen > 0:
            if _cls_contains(coff, clen, koff + s, tlen) == 0:
                return 0
    return 1


def _tgt_matches(ri: int32, e: int32) -> int32:
    if r_tag_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_tag_off[e]], el_tag_len[e], \
                   &css_sbuf[r_tag_off[ri]], r_tag_len[ri]) == 0:
            return 0
    if r_cls_len[ri] > 0:
        if _all_cls_match(el_cls_off[e], el_cls_len[e], \
                          r_cls_off[ri], r_cls_len[ri]) == 0:
            return 0
    if r_id_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_id_off[e]], el_id_len[e], \
                   &css_sbuf[r_id_off[ri]], r_id_len[ri]) == 0:
            return 0
    return 1


def _anc_matches(ri: int32, e: int32) -> int32:
    if r_atag_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_tag_off[e]], el_tag_len[e], \
                   &css_sbuf[r_atag_off[ri]], r_atag_len[ri]) == 0:
            return 0
    if r_acls_len[ri] > 0:
        if _all_cls_match(el_cls_off[e], el_cls_len[e], \
                          r_acls_off[ri], r_acls_len[ri]) == 0:
            return 0
    if r_aid_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_id_off[e]], el_id_len[e], \
                   &css_sbuf[r_aid_off[ri]], r_aid_len[ri]) == 0:
            return 0
    return 1


def _rule_matches(ri: int32, top: int32) -> int32:
    if _tgt_matches(ri, top) == 0:
        return 0
    if r_has_anc[ri] == 0:
        return 1
    a: int32 = top - 1
    while a >= 0:
        if _anc_matches(ri, a) != 0:
            return 1
        a = a - 1
    return 0


# Resolve the cascade for the current (topmost) open element into m_*.
def _cascade_match_current():
    m_col = -1
    m_bg = -1
    m_weight = 0
    m_align = 0
    m_deco = 0
    m_nomark = 0
    m_disp = 0
    m_flexdir = 0
    m_justify = 0
    m_aitems = 0
    m_flexgap = -1
    m_rowgap = -1
    m_flexwrap = 0
    m_gtcn = 0
    m_gtrn = 0
    m_gcspan = 0
    m_gcstart = 0
    m_ml = -1
    m_mr = -1
    m_mt = -1
    m_mb = -1
    m_wd = -1
    m_bd = -1
    m_center = 0
    m_fontpx = -1
    m_lineh = 0
    m_ws = 0
    m_float = 0
    m_pos = 0
    m_top = -1
    m_left = -1
    m_right = -1
    m_bottom = -1
    m_zidx = ZIDX_UNSET
    if el_sp == 0:
        return
    top: int32 = el_sp - 1
    bc: int32 = -1
    bb: int32 = -1
    bw: int32 = -1
    ba: int32 = -1
    bde: int32 = -1
    bd: int32 = -1
    bfd: int32 = -1
    bjc: int32 = -1
    bai: int32 = -1
    bjg: int32 = -1
    brg: int32 = -1
    bfw: int32 = -1
    bgt: int32 = -1
    bgr: int32 = -1
    bgp: int32 = -1
    # best-spec trackers for the six box axes
    sml: int32 = -1
    smr: int32 = -1
    smt: int32 = -1
    smb: int32 = -1
    swd: int32 = -1
    sbd: int32 = -1
    sfp: int32 = -1
    slh: int32 = -1
    sws: int32 = -1
    sfl: int32 = -1
    spo: int32 = -1
    stp: int32 = -1
    slf: int32 = -1
    srt: int32 = -1
    sbt: int32 = -1
    szi: int32 = -1
    ri: int32 = 0
    while ri < n_rules:
        if _rule_matches(ri, top) != 0:
            sp: int32 = r_spec[ri]
            if r_color[ri] >= 0 and sp >= bc:
                bc = sp
                m_col = r_color[ri]
            if r_bg[ri] >= 0 and sp >= bb:
                bb = sp
                m_bg = r_bg[ri]
            if r_weight[ri] != 0 and sp >= bw:
                bw = sp
                m_weight = r_weight[ri]
            if r_align[ri] != 0 and sp >= ba:
                ba = sp
                m_align = r_align[ri]
            if r_deco[ri] != 0 and sp >= bde:
                bde = sp
                m_deco = r_deco[ri]
            if r_nomark[ri] != 0:
                m_nomark = 1                              # only `none` is honoured
            if r_disp[ri] != 0 and sp >= bd:
                bd = sp
                m_disp = r_disp[ri]
            if r_flexdir[ri] != 0 and sp >= bfd:
                bfd = sp
                m_flexdir = r_flexdir[ri]
            if r_justify[ri] != 0 and sp >= bjc:
                bjc = sp
                m_justify = r_justify[ri]
            if r_aitems[ri] != 0 and sp >= bai:
                bai = sp
                m_aitems = r_aitems[ri]
            if r_flexgap[ri] >= 0 and sp >= bjg:
                bjg = sp
                m_flexgap = r_flexgap[ri]
            if r_rowgap[ri] >= 0 and sp >= brg:
                brg = sp
                m_rowgap = r_rowgap[ri]
            if r_flexwrap[ri] != 0 and sp >= bfw:
                bfw = sp
                m_flexwrap = r_flexwrap[ri]
            if r_gtcn[ri] != 0 and sp >= bgt:
                bgt = sp
                m_gtcn = r_gtcn[ri]
                gm: int32 = 0
                while gm < r_gtcn[ri] and gm < GRID_MAXTRACK:
                    m_gtc[gm] = r_gtc[ri * GRID_MAXTRACK + gm]
                    gm = gm + 1
            if r_gtrn[ri] != 0 and sp >= bgr:
                bgr = sp
                m_gtrn = r_gtrn[ri]
                gmr: int32 = 0
                while gmr < r_gtrn[ri] and gmr < GRID_MAXTRACK:
                    m_gtr[gmr] = r_gtr[ri * GRID_MAXTRACK + gmr]
                    gmr = gmr + 1
            if (r_gcspan[ri] != 0 or r_gcstart[ri] != 0) and sp >= bgp:
                bgp = sp
                m_gcspan  = r_gcspan[ri]
                m_gcstart = r_gcstart[ri]
            if r_ml[ri] >= 0 and sp >= sml:
                sml = sp
                m_ml = r_ml[ri]
            if r_mr[ri] >= 0 and sp >= smr:
                smr = sp
                m_mr = r_mr[ri]
            if r_mt[ri] >= 0 and sp >= smt:
                smt = sp
                m_mt = r_mt[ri]
            if r_mb[ri] >= 0 and sp >= smb:
                smb = sp
                m_mb = r_mb[ri]
            if r_wd[ri] >= 0 and sp >= swd:
                swd = sp
                m_wd = r_wd[ri]
            if r_bd[ri] >= 0 and sp >= sbd:
                sbd = sp
                m_bd = r_bd[ri]
            if r_center[ri] != 0:
                m_center = 1
            if r_fontpx[ri] >= 0 and sp >= sfp:
                sfp = sp
                m_fontpx = r_fontpx[ri]
            if r_lineh[ri] != 0 and sp >= slh:
                slh = sp
                m_lineh = r_lineh[ri]
            if r_ws[ri] != 0 and sp >= sws:
                sws = sp
                m_ws = r_ws[ri]
            if r_float[ri] != 0 and sp >= sfl:
                sfl = sp
                m_float = r_float[ri]
            if r_pos[ri] != 0 and sp >= spo:
                spo = sp
                m_pos = r_pos[ri]
            if r_top[ri] >= 0 and sp >= stp:
                stp = sp
                m_top = r_top[ri]
            if r_left[ri] >= 0 and sp >= slf:
                slf = sp
                m_left = r_left[ri]
            if r_right[ri] >= 0 and sp >= srt:
                srt = sp
                m_right = r_right[ri]
            if r_bottom[ri] >= 0 and sp >= sbt:
                sbt = sp
                m_bottom = r_bottom[ri]
            if r_zidx[ri] != ZIDX_UNSET and sp >= szi:
                szi = sp
                m_zidx = r_zidx[ri]
        ri = ri + 1


# ---- font-weight (bold) scope ---------------------------------------
def _css_weight_effective() -> int32:
    i: int32 = weight_sp - 1
    while i >= 0:
        if weight_stack[i] != 0:
            return weight_stack[i]
        i = i - 1
    return 0


def _weight_push(w: int32):
    if weight_sp < 64:
        weight_stack[weight_sp] = w
        weight_sp = weight_sp + 1
    if _css_weight_effective() == 1:
        g_css_bold = 1
    else:
        g_css_bold = 0


def _weight_pop():
    if weight_sp > 0:
        weight_sp = weight_sp - 1
    if _css_weight_effective() == 1:
        g_css_bold = 1
    else:
        g_css_bold = 0


# ---- font-size (px) scope — inherits the nearest ancestor that set one ----
def _fontpx_effective() -> int32:
    i: int32 = fontpx_sp - 1
    while i >= 0:
        if fontpx_stack[i] > 0:
            return fontpx_stack[i]
        i = i - 1
    return 0


def _fontpx_push(px: int32):
    if fontpx_sp < 64:
        fontpx_stack[fontpx_sp] = px
        fontpx_sp = fontpx_sp + 1
    g_font_px = _fontpx_effective()


def _fontpx_pop():
    if fontpx_sp > 0:
        fontpx_sp = fontpx_sp - 1
    g_font_px = _fontpx_effective()


# ---- line-height (px) scope — inherits the nearest ancestor that set one ----
def _lineh_effective() -> int32:
    i: int32 = lineh_sp - 1
    while i >= 0:
        if lineh_stack[i] > 0:
            return lineh_stack[i]
        i = i - 1
    return 0


def _lineh_push(px: int32):
    if lineh_sp < 64:
        lineh_stack[lineh_sp] = px
        lineh_sp = lineh_sp + 1
    g_lineh = _lineh_effective()


def _lineh_pop():
    if lineh_sp > 0:
        lineh_sp = lineh_sp - 1
    g_lineh = _lineh_effective()


# ---- white-space scope — inherits the nearest ancestor that set one --------
# Entries are mode+1 (0 = level sets none). Effective g_ws is the nearest
# non-zero entry minus 1 (0..3), or 0 (normal) when nothing on the stack set it.
def _ws_effective() -> int32:
    i: int32 = ws_sp - 1
    while i >= 0:
        if ws_stack[i] != 0:
            return ws_stack[i] - 1
        i = i - 1
    return 0


def _ws_push(enc: int32):
    if ws_sp < 64:
        ws_stack[ws_sp] = enc
        ws_sp = ws_sp + 1
    g_ws = _ws_effective()


def _ws_pop():
    if ws_sp > 0:
        ws_sp = ws_sp - 1
    g_ws = _ws_effective()


# ---- text-align scope -----------------------------------------------
def _align_effective() -> int32:
    i: int32 = align_sp - 1
    while i >= 0:
        if align_stack[i] != 0:
            return align_stack[i]
        i = i - 1
    return 0


def _align_push(a: int32):
    if align_sp < 64:
        align_stack[align_sp] = a
        align_sp = align_sp + 1
    g_align = _align_effective()


def _align_pop():
    if align_sp > 0:
        align_sp = align_sp - 1
    g_align = _align_effective()


# ---- text-decoration (underline) scope ------------------------------
# Inherits the nearest ancestor that set a decoration, so an underlined block
# carries the rule down to its inline text. 1 = underline, 2 = none.
def _deco_effective() -> int32:
    i: int32 = deco_sp - 1
    while i >= 0:
        if deco_stack[i] != 0:
            return deco_stack[i]
        i = i - 1
    return 0


def _deco_push(d: int32):
    if deco_sp < 64:
        deco_stack[deco_sp] = d
        deco_sp = deco_sp + 1
    g_css_uline = _deco_effective()
    _recompute_style()


def _deco_pop():
    if deco_sp > 0:
        deco_sp = deco_sp - 1
    g_css_uline = _deco_effective()
    _recompute_style()


# The colour an element specifies for ITSELF: its matched-cascade colour (m_col,
# valid right after the element's _cascade_match_current) overridden by an inline
# style="color:…". Returns -1 when the element sets no colour of its own (an
# inherited ancestor colour is NOT its own). Used to let a styled anchor override
# the default link blue without an inherited body colour leaking onto plain links.
def _own_color(ne: uint64, te: uint64) -> int32:
    c: int32 = m_col
    ic: int32 = _tag_color(ne, te)
    if ic >= 0:
        c = ic
    return c


# Open/close a full style scope for a stylable element. The cascade is matched
# from el_stack (already pushed) and merged with the inline style="" overrides.
def _open_style(ne: uint64, te: uint64):
    _cascade_match_current()
    col: int32 = m_col
    ic: int32 = _tag_color(ne, te)
    if ic >= 0:
        col = ic
    bgv: int32 = m_bg
    ib: int32 = _tag_bgcolor(ne, te)
    if ib >= 0:
        bgv = ib
    wt: int32 = m_weight
    al: int32 = m_align
    dec: int32 = m_deco
    fpx: int32 = m_fontpx
    # inline style="" font-weight / text-align / text-decoration / font-size
    # override the cascade.
    _parse_inline_wa(ne, te)
    if d_weight != 0:
        wt = d_weight
    if d_align != 0:
        al = d_align
    if d_deco != 0:
        dec = d_deco
    if d_fontpx >= 0:
        fpx = d_fontpx
    push_px: int32 = 0
    if fpx >= 0:
        push_px = fpx
    # line-height: inline overrides the cascade; resolve unitless/% against this
    # element's effective font-size (its own if set, else the inherited one).
    lh_enc: int32 = m_lineh
    if d_lineh != 0:
        lh_enc = d_lineh
    lh_base: int32 = push_px
    if lh_base <= 0:
        lh_base = g_font_px
    lh_px: int32 = _lineh_resolve(lh_enc, lh_base)
    # white-space: inline declaration wins over the cascade (both mode+1 encoded).
    ws_enc: int32 = m_ws
    if d_ws != 0:
        ws_enc = d_ws
    # The presentational HTML `nowrap` attribute (e.g. <td nowrap>) maps to
    # white-space:nowrap, unless an inline `white-space` style overrides it.
    # Real pages (google.com's footer cells) rely on this to keep a short label
    # like "Advanced search" on one line inside a narrow table column instead of
    # collapsing to one glyph per row.
    if d_ws == 0 and _hx_find_attr(ne, te, cast[Ptr[uint8]]("nowrap")) != 0:
        ws_enc = 2
    _color_push(col)
    _bg_push(bgv)
    _weight_push(wt)
    _align_push(al)
    _deco_push(dec)
    _fontpx_push(push_px)
    _lineh_push(lh_px)
    _ws_push(ws_enc)


def _close_style():
    _color_pop()
    _bg_pop()
    _weight_pop()
    _align_pop()
    _deco_pop()
    _fontpx_pop()
    _lineh_pop()
    _ws_pop()


# Synthesise the implicit `</li>` for the list item currently open at level `lvl`
# — pop its _open_style() scope exactly once and clear the flag. Called at the
# next <li>/</ul>/</ol> boundary at this level (and on an explicit </li>) so the
# style stack stays balanced whether or not the author wrote </li>. Idempotent:
# a no-op when no styled item is open, so a double close (explicit </li> then
# </ul>) can't over-pop the stack.
def _li_close_lvl(lvl: int32):
    if lvl >= 0 and lvl < MAX_LIST_DEPTH and li_styled[lvl] != 0:
        _close_style()
        li_styled[lvl] = 0


# Scan an inline style="" attribute for font-weight/text-align/display + the
# full box model (margin/padding/width/border); sets d_weight/d_align/d_disp
# and the d_* box scratch (d_color/d_bg come from _tag_color/_tag_bgcolor).
# Inline declarations here override any stylesheet/class rule (highest priority).
def _parse_inline_wa(ne: uint64, te: uint64):
    d_weight = 0
    d_align = 0
    d_deco = 0
    d_nomark = 0
    d_disp = 0
    d_flexdir = 0
    d_justify = 0
    d_aitems = 0
    d_flexgap = -1
    d_rowgap = -1
    d_flexwrap = 0
    d_gtcn = 0
    d_gtrn = 0
    d_gcspan = 0
    d_gcstart = 0
    d_ml = -1
    d_mr = -1
    d_mt = -1
    d_mb = -1
    d_wd = -1
    d_bd = -1
    d_center = 0
    d_fontpx = -1
    d_lineh = 0
    d_ws = 0
    d_float = 0
    d_pos = 0
    d_top = -1
    d_left = -1
    d_right = -1
    d_bottom = -1
    d_zidx = ZIDX_UNSET
    if _hx_find_attr(ne, te, cast[Ptr[uint8]]("style")) == 0:
        return
    a: uint64 = g_attr_start
    b: uint64 = g_attr_end
    i: uint64 = a
    while i < b:
        ps: uint64 = i
        while i < b and src_ptr[i] != 58 and src_ptr[i] != 59:
            i = i + 1
        if i < b and src_ptr[i] == 58:
            pe: uint64 = i
            i = i + 1
            vs: uint64 = i
            while i < b and src_ptr[i] != 59:
                i = i + 1
            # box model (margin/padding/width/border) — shared with the sheet.
            if _box_decl(ps, pe, vs, i) != 0:
                pass
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("font-weight")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("bold")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("700")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("800")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("900")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("600")) != 0:
                    d_weight = 1
                elif _val_starts(vs, i, cast[Ptr[uint8]]("normal")) != 0:
                    d_weight = 2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("text-align")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("center")) != 0:
                    d_align = 2
                elif _val_starts(vs, i, cast[Ptr[uint8]]("right")) != 0:
                    d_align = 3
                elif _val_starts(vs, i, cast[Ptr[uint8]]("left")) != 0:
                    d_align = 1
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("text-decoration")) != 0 or \
                 _prop_is(ps, pe, cast[Ptr[uint8]]("text-decoration-line")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("underline")) != 0:
                    d_deco = 1
                elif _val_starts(vs, i, cast[Ptr[uint8]]("none")) != 0:
                    d_deco = 2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("display")) != 0:
                d_disp = _disp_value(vs, i)
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("flex-direction")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("column")) != 0:
                    d_flexdir = 1
                else:
                    d_flexdir = 2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("justify-content")) != 0:
                jv2: int32 = _justify_value(vs, i)
                if jv2 != 0:
                    d_justify = jv2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("align-items")) != 0:
                av2: int32 = _align_items_value(vs, i)
                if av2 != 0:
                    d_aitems = av2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("flex-wrap")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("wrap")) != 0:
                    d_flexwrap = 1
                else:
                    d_flexwrap = 0
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("grid-template-columns")) != 0:
                d_gtcn = _grid_parse_template(vs, i)
                gci: int32 = 0
                while gci < d_gtcn and gci < GRID_MAXTRACK:
                    d_gtc[gci] = gts_enc[gci]
                    gci = gci + 1
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("grid-template-rows")) != 0:
                d_gtrn = _grid_parse_template(vs, i)
                gri: int32 = 0
                while gri < d_gtrn and gri < GRID_MAXTRACK:
                    d_gtr[gri] = gts_enc[gri]
                    gri = gri + 1
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("grid-column")) != 0:
                _grid_column_parse(vs, i)
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("gap")) != 0:
                _parse_box_lens(vs, i)
                if n_box_lens >= 1:
                    d_rowgap = box_lens[0]
                    if n_box_lens >= 2:
                        d_flexgap = box_lens[1]
                    else:
                        d_flexgap = box_lens[0]
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("column-gap")) != 0:
                gp2: int32 = _style_len(vs, i)
                if gp2 >= 0:
                    d_flexgap = gp2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("row-gap")) != 0:
                rgp2: int32 = _style_len(vs, i)
                if rgp2 >= 0:
                    d_rowgap = rgp2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("font-size")) != 0:
                fp: int32 = _style_len(vs, i)
                if fp > 0:
                    d_fontpx = fp
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("line-height")) != 0:
                lh: int32 = _lineh_value(_val_start(vs, i), i)
                if lh != 0:
                    d_lineh = lh
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("white-space")) != 0:
                wsv: int32 = _ws_value(vs, i)
                if wsv != 0:
                    d_ws = wsv
        if i < b and src_ptr[i] == 59:
            i = i + 1


# Resolve whether the element being opened is display:none (cascade or inline).
def _is_display_none(ne: uint64, te: uint64) -> int32:
    _parse_inline_wa(ne, te)
    if d_disp == 1:                                  # inline display:none
        return 1
    if d_disp >= 2:                                  # any explicit inline display (shown)
        return 0
    if m_disp == 1:                                  # cascade display:none
        return 1
    return 0


# ====================================================================
# TABLE two-pass column layout.
# ====================================================================
def _alnum_at(p: uint64) -> int32:
    if p >= src_len:
        return 0
    c: uint8 = _hx_lower(src_ptr[p])
    if (c >= 97 and c <= 122) or (c >= 48 and c <= 57):
        return 1
    return 0


# Locate an attribute VALUE `name="..."` (or name='...' / name=bare) in the
# tag body [ts,te). On success sets g_attr_start/g_attr_end to the value span
# and returns 1; returns 0 if the attribute is absent.
g_attr_start: uint64 = 0
g_attr_end:   uint64 = 0


def _hx_find_attr(ts: uint64, te: uint64, name: Ptr[uint8]) -> int32:
    nl: uint64 = 0
    while name[nl] != 0:
        nl = nl + 1
    i: uint64 = ts
    while i + nl <= te:
        prev_alpha: int32 = 0
        if i > ts:
            pc: uint8 = _hx_lower(src_ptr[i - 1])
            if (pc >= 97 and pc <= 122) or (pc >= 48 and pc <= 57) or pc == 45:
                prev_alpha = 1
        if prev_alpha == 0 and _srcword_is(i, name) != 0 and \
           _alnum_at(i + nl) == 0:
            j: uint64 = i + nl
            while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
                j = j + 1
            if j < te and src_ptr[j] == 61:              # '='
                j = j + 1
                while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
                    j = j + 1
                quote: uint8 = 0
                if j < te and (src_ptr[j] == 34 or src_ptr[j] == 39):
                    quote = src_ptr[j]
                    j = j + 1
                g_attr_start = j
                while j < te:
                    c: uint8 = src_ptr[j]
                    if quote != 0:
                        if c == quote:
                            break
                    else:
                        if c == 32 or c == 9:
                            break
                    j = j + 1
                g_attr_end = j
                return 1
        i = i + 1
    return 0


# Read an integer-valued attribute (e.g. colspan="2") from tag body [ts,te).
# Returns the parsed value, or `dflt` when absent / non-numeric / < 1.
def _attr_int(ts: uint64, te: uint64, name: Ptr[uint8], dflt: int32) -> int32:
    if _hx_find_attr(ts, te, name) == 0:
        return dflt
    v: int32 = 0
    p: uint64 = g_attr_start
    seen: int32 = 0
    while p < g_attr_end:
        d: uint8 = src_ptr[p]
        if d >= 48 and d <= 57:
            v = v * 10 + cast[int32](d - 48)
            seen = 1
        p = p + 1
    if seen == 0 or v < 1:
        return dflt
    return v


# A tag name at src[at] matches `lit` AND ends at a tag boundary (so "tr"
# does not match "track"). Returns 1 on a bounded match.
def _tagname_is(at: uint64, lit: Ptr[uint8]) -> int32:
    if _srcword_is(at, lit) == 0:
        return 0
    n: uint64 = 0
    while lit[n] != 0:
        n = n + 1
    if _alnum_at(at + n) != 0:
        return 0
    return 1


# Index of the '<' of the </table> that closes the table whose body begins at
# `body0` (nesting-aware). Returns src_len if unterminated.
def _table_region_end(body0: uint64) -> uint64:
    depth: int32 = 1
    i: uint64 = body0
    while i < src_len:
        if src_ptr[i] == 60:                         # '<'
            k: uint64 = i + 1
            close: int32 = 0
            if k < src_len and src_ptr[k] == 47:     # '/'
                close = 1
                k = k + 1
            if _tagname_is(k, cast[Ptr[uint8]]("table")) != 0:
                if close != 0:
                    depth = depth - 1
                    if depth == 0:
                        return i
                else:
                    depth = depth + 1
            while i < src_len and src_ptr[i] != 62:  # to '>'
                i = i + 1
            if i < src_len:
                i = i + 1
            continue
        i = i + 1
    return src_len


# Natural width (in character cells) of a table region, NESTING-AWARE and
# recursive: a cell that contains a sub-table contributes that sub-table's own
# natural width, so an outer cell's column grows wide enough to CONTAIN a nested
# table. Returns the widest row's summed cell widths — a safe containment upper
# bound; the per-column pass refines actual placement.
def _table_char_width(rgn_start: uint64, rgn_end: uint64) -> int32:
    maxrow: int32 = 0
    rowsum: int32 = 0
    cell_n: int32 = 0
    counting: int32 = 0
    pend_space: int32 = 0
    i: uint64 = rgn_start
    while i < rgn_end:
        ch: uint8 = src_ptr[i]
        if ch == 60:                                 # '<'
            k: uint64 = i + 1
            close: int32 = 0
            if k < rgn_end and src_ptr[k] == 47:
                close = 1
                k = k + 1
            tend: uint64 = k
            while tend < rgn_end and src_ptr[tend] != 62:
                tend = tend + 1
            if close == 0 and _tagname_is(k, cast[Ptr[uint8]]("table")) != 0:
                sub0: uint64 = tend
                if sub0 < rgn_end:
                    sub0 = sub0 + 1
                sube: uint64 = _table_region_end(sub0)
                w2: int32 = _table_char_width(sub0, sube)
                if w2 > cell_n:
                    cell_n = w2
                i = sube                             # resume at '<' of </table>
                continue
            is_cell: int32 = 0
            if _tagname_is(k, cast[Ptr[uint8]]("td")) != 0 or \
               _tagname_is(k, cast[Ptr[uint8]]("th")) != 0:
                is_cell = 1
            is_tr: int32 = _tagname_is(k, cast[Ptr[uint8]]("tr"))
            if is_cell != 0 or is_tr != 0:
                rowsum = rowsum + cell_n + CELL_PAD
                cell_n = 0
                counting = 0
                pend_space = 0
                if is_tr != 0 and close == 0:
                    if rowsum > maxrow:
                        maxrow = rowsum
                    rowsum = 0
                elif is_cell != 0 and close == 0:
                    counting = 1
            i = tend
            if i < rgn_end:
                i = i + 1
            continue
        if counting != 0:
            if ch == 32 or ch == 9 or ch == 10 or ch == 13:
                pend_space = 1
            else:
                if pend_space != 0 and cell_n > 0:
                    cell_n = cell_n + 1
                pend_space = 0
                cell_n = cell_n + 1
        i = i + 1
    rowsum = rowsum + cell_n + CELL_PAD
    if rowsum > maxrow:
        maxrow = rowsum
    return maxrow


# Pass 1: record the widest cell (in characters, whitespace-collapsed) per
# column across [rgn_start, rgn_end). Sets col_chars[] and n_cols. A nested
# <table> is skipped (its cells belong to the inner table) but its natural width
# sizes the enclosing cell so the outer column contains it.
def _measure_table(rgn_start: uint64, rgn_end: uint64):
    c: int32 = 0
    while c < MAX_COLS:
        col_chars[c] = 0
        c = c + 1
    n_cols = 0
    col: int32 = -1
    nextcol: int32 = 0          # column index the next cell starts at
    cspan: int32 = 1            # colspan of the currently-counting cell
    counting: int32 = 0
    cell_n: int32 = 0
    cell_th: int32 = 0          # the cell being counted is a <th> (bold glyphs)
    pend_space: int32 = 0
    i: uint64 = rgn_start
    while i < rgn_end:
        ch: uint8 = src_ptr[i]
        if ch == 60:                                 # '<'
            k: uint64 = i + 1
            close: int32 = 0
            if k < rgn_end and src_ptr[k] == 47:
                close = 1
                k = k + 1
            is_cell: int32 = 0
            is_th_tag: int32 = _tagname_is(k, cast[Ptr[uint8]]("th"))
            if _tagname_is(k, cast[Ptr[uint8]]("td")) != 0 or is_th_tag != 0:
                is_cell = 1
            is_tr: int32 = _tagname_is(k, cast[Ptr[uint8]]("tr"))
            # end of this tag's body ('>')
            tend: uint64 = k
            while tend < rgn_end and src_ptr[tend] != 62:
                tend = tend + 1
            if close == 0 and _tagname_is(k, cast[Ptr[uint8]]("table")) != 0:
                # nested table: skip its region, but grow the enclosing cell so
                # the outer column is wide enough to contain the inner grid.
                sub0: uint64 = tend
                if sub0 < rgn_end:
                    sub0 = sub0 + 1
                sube: uint64 = _table_region_end(sub0)
                if counting != 0:
                    w2: int32 = _table_char_width(sub0, sube)
                    if w2 > cell_n:
                        cell_n = w2
                i = sube                             # resume at '<' of </table>
                continue
            if is_cell != 0 or is_tr != 0:
                # finalize the cell that was open — a spanning cell (cspan>1)
                # does not size any single column, so only single-span cells
                # contribute to col_chars[]. A <th> renders BOLD, whose glyphs
                # are ~1/8 wider than the monospace CELL_W the column model
                # assumes, so reserve ~1/3 extra chars for it (covers the bold
                # advance plus the per-side CELL_PADX inset) — otherwise a bold
                # header like "Subsystem" overruns its column into the next one.
                eff: int32 = cell_n
                if cell_th != 0 and eff > 0:
                    eff = eff + (eff + 2) / 3
                if col >= 0 and col < MAX_COLS and cspan == 1 and \
                   eff > col_chars[col]:
                    col_chars[col] = eff
                counting = 0
                cell_n = 0
                cell_th = 0
                pend_space = 0
                cspan = 1
                if is_tr != 0 and close == 0:
                    nextcol = 0                       # new row restarts columns
                    col = -1
                elif is_cell != 0 and close == 0:
                    col = nextcol
                    cell_th = is_th_tag
                    cspan = _attr_int(k, tend, cast[Ptr[uint8]]("colspan"), 1)
                    nextcol = col + cspan
                    counting = 1
                    if nextcol > n_cols:
                        n_cols = nextcol
            i = tend
            if i < rgn_end:
                i = i + 1
            continue
        if counting != 0:
            if ch == 32 or ch == 9 or ch == 10 or ch == 13:
                pend_space = 1
            else:
                if pend_space != 0 and cell_n > 0:
                    cell_n = cell_n + 1
                pend_space = 0
                cell_n = cell_n + 1
        i = i + 1
    tail_eff: int32 = cell_n
    if cell_th != 0 and tail_eff > 0:
        tail_eff = tail_eff + (tail_eff + 2) / 3
    if col >= 0 and col < MAX_COLS and cspan == 1 and tail_eff > col_chars[col]:
        col_chars[col] = tail_eff


# Natural (unclamped) pixel width of the measured table — the sum of every
# column's char width (same growth rule _compute_cols uses). Drives the float
# box width for a floated <table> so the infobox is exactly as wide as its grid.
def _table_natural_width() -> int32:
    total: int32 = 0
    c: int32 = 0
    while c < n_cols and c < MAX_COLS:
        w: int32 = col_chars[c]
        if w < 1:
            w = 1
        if w > 60:
            w = 60
        total = total + (w + CELL_PAD) * CELL_W
        c = c + 1
    return total


# Pass 2: turn per-column character widths into pixel column x-positions.
def _compute_cols():
    # Inside a float/box, clamp columns to the box's right edge so a floated
    # infobox's grid stays within its pinned box; a top-level table (no block
    # active, blk_right_cur==0) keeps its historical full-width growth.
    right: int32 = _flow_right()
    bounded: int32 = 0
    if blk_right_cur > 0:
        bounded = 1
    # A nested table clamps to its parent cell's right edge (_flow_right returns
    # cell_right while cell_active) so the inner grid stays inside the outer cell.
    if cell_active != 0:
        bounded = 1
    x: int32 = indent_x
    c: int32 = 0
    while c < n_cols and c < MAX_COLS:
        col_x[c] = x
        w: int32 = col_chars[c]
        if w < 1:
            w = 1
        if w > 60:                                   # cap a runaway column
            w = 60
        cw: int32 = (w + CELL_PAD) * CELL_W
        if bounded != 0 and c > 0 and x + cw > right:
            cw = right - x
            if cw < 2 * CELL_W:
                cw = 2 * CELL_W
        x = x + cw
        c = c + 1
    if n_cols > MAX_COLS:
        n_cols = MAX_COLS
    col_x[n_cols] = x                                # right sentinel


# Close the open table cell: flush its word, drop its bold + colour scope.
def _cell_close():
    if cell_active == 0:
        return
    _word_flush()
    if cell_is_th != 0 and g_bold_n > 0:
        g_bold_n = g_bold_n - 1
    _close_style()
    cell_active = 0
    cell_is_th = 0
    _style_break()


# Push the parent table's column model + cell scope onto the nesting stack so a
# nested <table> can overwrite the shared col_x/n_cols/cur_col globals; the entry
# also carries slots for THIS table's border geometry (filled by the caller).
def _table_push():
    if tbl_sp >= TBL_MAX:
        return
    d: int32 = tbl_sp
    tbl_ncols_st[d]     = n_cols
    tbl_curcol_st[d]    = cur_col
    tbl_cellact_st[d]   = cell_active
    tbl_cellright_st[d] = cell_right
    tbl_cellisth_st[d]  = cell_is_th
    tbl_indentx_st[d]   = indent_x
    tbl_floated_st[d]   = table_floated
    c: int32 = 0
    while c <= MAX_COLS:
        tbl_colx_st[d * 33 + c] = col_x[c]
        c = c + 1
    tbl_srow_st[d]   = 0
    tbl_lx_st[d]     = 0
    tbl_border_st[d] = 0
    tbl_rgb_st[d]    = 0
    tbl_sp = tbl_sp + 1


# Restore the parent table's column model + cell scope saved by _table_push.
def _table_pop():
    if tbl_sp <= 0:
        return
    tbl_sp = tbl_sp - 1
    d: int32 = tbl_sp
    n_cols        = tbl_ncols_st[d]
    cur_col       = tbl_curcol_st[d]
    cell_active   = tbl_cellact_st[d]
    cell_right    = tbl_cellright_st[d]
    cell_is_th    = tbl_cellisth_st[d]
    indent_x      = tbl_indentx_st[d]
    table_floated = tbl_floated_st[d]
    c: int32 = 0
    while c <= MAX_COLS:
        col_x[c] = tbl_colx_st[d * 33 + c]
        c = c + 1



# lib/htmlengine.ad — the PURE HTML parse + block/inline layout engine that
# backs the native web browser.
#
# This module is deliberately I/O-FREE and UI-FREE: it has NO `extern def`
# syscalls, NO hamUI, NO http9. It consumes a source buffer (src_ptr/src_len,
# set by whichever front-end fetched the page) and produces a flat display
# list of styled SEGMENTS plus per-row heading-rule flags. Both front-ends
# share it byte-for-byte:
#
#   * user/hambrowse.ad     — the NATIVE browser: Plan 9-shape http9 fetch +
#                             hamUI scene render (the shipped bare-metal path).
#   * user/hambrowse_host.ad — a HOST test harness built for the x86_64-linux
#                             Adder target: reads a local HTML fixture and
#                             dumps the layout, so the engine can be iterated
#                             on the dev host in milliseconds with NO QEMU.
#
# Keeping the engine pure is the seam that makes hambrowse dual-target while
# the native path stays Plan 9-shape (the host harness is a TEST shim only —
# it never adds sockets to the native code path).
#
# MEMORY DISCIPLINE (memory/feedback_compiler_quirks.md U9): every sizable
# buffer is a top-level BSS Array, NEVER a stack local — the native user
# stack is a single 4 KiB page. No malloc.
#
# JAVASCRIPT: <script> execution + a minimal DOM are wired in at the bottom of
# this file (see the "JAVASCRIPT + minimal DOM" section). The engine imports
# the pure tree-walking interpreter from lib/jsengine.ad and binds a `document`
# host object through jsengine's host-object seam (NO jsengine edits). Scripts
# run at layout time; the DOM they mutate (textContent / style.color /
# style.display / document.title) is applied by re-laying-out a rewritten copy
# of the source. Pages with no <script> never touch jsengine at all.
#
# FORMS: <input>/<textarea>/<button>/<select> render as monospace-grid boxes
# ([text__], [x], (*), [ label ], [ opt v]) and expose a form DOM — value /
# checked / type / name, form.elements, document.forms — through the SAME
# host-object seam. Field changes and submissions are driven programmatically
# (pointer/keyboard-free) via he_dom_set_value / he_dom_set_checked /
# he_dom_submit, which fire oninput/onchange/onsubmit and re-lay-out; a submit
# that is not preventDefault'd GET-serializes the form into he_nav_* for the
# front-end to navigate to. A value/checked change bakes into the rewritten
# source (the input's value=/checked attr, a textarea's content, a select's
# selected option) so the control re-renders its new state.

from lib.jsengine import js_init, js_eval, js_error, js_out_ptr, js_out_len, \
    js_new_object_v, js_new_string, js_new_native_fn, js_set_prop, js_get_prop, \
    js_global_set, js_global_get, js_set_host_dispatch, js_arg_count, js_arg, \
    js_host_base, js_set_member_hook, js_mset_this, js_mset_key, js_mset_val, \
    js_str_ptr, js_undefined, js_null, js_this, js_is_callable, js_call_fn, \
    js_bool, js_to_bool, js_number, js_to_number, js_new_array_v, js_array_push, \
    js_array_len, js_array_get
from lib.htmlimg import htmlimg_find, htmlimg_w, htmlimg_h, htmlimg_add_blank, \
    htmlimg_add
from lib.svg import svg_decode, svg_width, svg_height, svg_rgba_ptr
from lib.htmlcanvas import htmlcanvas_reset, htmlcanvas_new, htmlcanvas_slot, \
    htmlcanvas_fill_rect, htmlcanvas_clear_rect, htmlcanvas_stroke_rect, \
    htmlcanvas_begin, htmlcanvas_moveto, htmlcanvas_lineto, \
    htmlcanvas_closepath, htmlcanvas_arc, htmlcanvas_stroke, htmlcanvas_fill, \
    htmlcanvas_fill_text, htmlcanvas_measure_text

# ====================================================================
# Tiny helper.
# ====================================================================
def _lower(c: uint8) -> uint8:
    if c >= 65 and c <= 90:
        return c + 32
    return c


# CSS whitespace: space, tab, newline, carriage-return. Rules/declarations may
# be formatted across lines (#250), so property-name/value trimming must skip
# newlines too — not just space/tab.
def _css_ws(c: uint8) -> int32:
    if c == 32 or c == 9 or c == 10 or c == 13:
        return 1
    return 0


# ====================================================================
# WINDOW geometry (mutable — a resize re-lays-out from the stored source).
# These live in the engine because layout wraps to bw and _vis_rows depends
# on bh; the front-ends read/write them directly (shared globals).
# ====================================================================
TITLE_H:   int32 = 18
ADDR_H:    int32 = 20           # editable address/URL bar (below the title)
ADDR_Y:    int32 = 18           # == TITLE_H
GO_W:      int32 = 30           # "Go" button width in the address bar
NAV_BTN_W: int32 = 22           # Back / Forward button width (left of the URL box)
NAV_BAR_W: int32 = 48           # 2*NAV_BTN_W + 4 left pad: URL box starts here
CONTENT_X: int32 = 8
CONTENT_Y: int32 = 38           # == TITLE_H + ADDR_H (page content starts here)
STATUS_H:  int32 = 16
LINE_H:    int32 = 16
CELL_W:    int32 = 8
bw: int32 = 880                 # window content width  (px; native default)
bh: int32 = 600                 # window content height (px)


# READABLE-MEASURE default (UA stylesheet): a plain page should not let body
# text span an arbitrarily wide window edge-to-edge — long lines are tiring to
# read. We cap the content column at MEASURE_MAX px and CENTRE it, leaving a
# symmetric page gutter on wide windows (exactly like a browser's default body
# max-width). MEASURE_MAX == 584 px == 73 character cells, chosen so that at the
# 600 px unit-test / legacy window the gutter is ZERO and geometry is byte-for-
# byte identical (avail = 600 - 2*8 = 584 == MEASURE_MAX): the cap only engages
# once the window is wider than 600 px, so all existing 600 px assertions hold.
MEASURE_MAX: int32 = 584


# Symmetric page gutter (px) added to CONTENT_X on wide windows so the content
# column is centred at its readable measure. 0 at bw <= 600.
def _page_gutter() -> int32:
    avail: int32 = bw - 2 * CONTENT_X
    if avail <= MEASURE_MAX:
        return 0
    return (avail - MEASURE_MAX) / 2


# Left edge of the body content column (CONTENT_X + centring gutter).
def _left_margin() -> int32:
    return CONTENT_X + _page_gutter()


def _content_right() -> int32:
    return bw - CONTENT_X - _page_gutter()


def _vis_rows() -> uint64:
    r: int32 = (bh - CONTENT_Y - STATUS_H) / LINE_H
    if r < 1:
        r = 1
    return cast[uint64](r)


# ====================================================================
# SOURCE — src_ptr/src_len point at the HTML the front-end wants parsed.
# ====================================================================
src_ptr:  Ptr[uint8] = 0
src_len:  uint64 = 0


# ====================================================================
# LAYOUT MODEL — the parsed page becomes a flat list of styled SEGMENTS.
# A segment is a run of same-styled text on one visual ROW at a pixel X.
# ====================================================================
MAX_SEGS:     uint64 = 6000
SEG_TEXT_CAP: uint64 = 131072
MAX_ROWS:     uint64 = 12000

seg_text_buf: Array[131072, uint8]
seg_text_len: uint64 = 0
seg_x:    Array[6000, int32]
seg_line: Array[6000, int32]
seg_off:  Array[6000, int32]
seg_len:  Array[6000, int32]
seg_color: Array[6000, uint8]    # palette index (role colour)
seg_rgb:  Array[6000, int32]     # explicit 0xRRGGBB, or -1 to use the palette
seg_bg:   Array[6000, int32]     # background 0xRRGGBB behind the text, or -1
seg_bold:  Array[6000, uint8]
seg_uline: Array[6000, uint8]
seg_link:  Array[6000, int32]    # link id or -1
# seg_face — pixel-render font FACE hint for the graphical (htmlpaint) backend.
# The legacy monospace-grid dump ignores it; the pixel engine maps it onto the
# available BDF faces/scales:
#   0 = body proportional sans
#   1 = monospace  (<pre>/<code>)
#   2..7 = heading h1..h6  (integer-scaled + bold sans)
seg_face:  Array[6000, uint8]
# seg_gridx — 1 = this segment is GRID-POSITIONED: the pixel renderer must
# honour its absolute seg_x column (tables, <pre>, box art) instead of the
# proportional inline reflow used for prose. 0 = flow proportionally.
seg_gridx: Array[6000, uint8]
# seg_pxsize — CSS font-size in PIXELS for this segment, or 0 = "use the face
# default". Consumed by the scalable (TrueType) pixel renderer so that
# font-size:14px/18px prose renders at its true continuous size. The legacy
# monospace-grid dump ignores it.
seg_pxsize: Array[6000, int32]
# seg_lineh — CSS line-height for this segment resolved to PIXELS (the line-box
# pitch), or 0 = "use the face default rhythm". Consumed by the pixel renderer
# (lib/htmlpage) to loosen inter-line spacing on a block that sets line-height;
# 0 keeps the default vertical rhythm so unstyled pages are byte-for-byte
# unchanged. The legacy monospace-grid dump ignores it.
seg_lineh: Array[6000, int32]
# seg_img — decoded-image slot (lib/htmlimg) for an <img> segment, or -1 for a
# normal text segment. When >= 0 the pixel renderer BLITS the image into the box
# (seg_imgw x seg_imgh px at seg_x/row-top) instead of drawing text; a value of
# -2 means the src was present but undecodable → draw a broken-image placeholder.
seg_img:   Array[6000, int32]
seg_imgw:  Array[6000, int32]     # image box width  (px)
seg_imgh:  Array[6000, int32]     # image box height (px)
# seg_boxart — 1 for the ASCII box-art border glyphs ('+'/'-'/'|') emitted by
# _emit_box_run/_emit_box_bar, 0 for real content. The monospace-grid text dump
# still paints these glyphs (its gates assert on them), but the PIXEL renderer
# SKIPS them and draws a true 1px border rectangle from the border-box registry
# below instead — so a CSS border looks like a drawn line, not typed characters.
seg_boxart: Array[6000, uint8]
# seg_marker — 1 for the UNORDERED-list ('<ul>') item bullet segment. The
# monospace-grid dump paints the '-' placeholder char it carries, but the PIXEL
# renderer draws a real round bullet DISC in the gutter instead (like a browser's
# default list-style-type:disc), so a list reads as a list and not a run of
# hyphens glued to the text. 0 = normal content.
seg_marker: Array[6000, uint8]
# seg_indjump — 1 for the FIRST text segment of a list item. The pixel renderer
# flows same-row prose contiguously from the pen, which would otherwise collapse
# the marker's hanging indent (packing the item text right after the bullet). A
# set flag tells the renderer to JUMP the pen forward to this segment's seg_x
# (indent_x), preserving the gutter between the marker and the item text.
seg_indjump: Array[6000, uint8]
# seg_yoff — signed VERTICAL pixel offset applied to this segment's baseline by
# the pixel renderer: negative RAISES the run (<sup>), positive LOWERS it
# (<sub>). 0 = on the row baseline (the default for all normal text, so
# unstyled pages are byte-for-byte unchanged).
seg_yoff: Array[6000, int32]
# seg_strike — 1 = draw a horizontal LINE-THROUGH the run (<s>/<del>/<strike>),
# 0 = none. The pixel renderer strokes a 1px rule across the seg's x-height.
seg_strike: Array[6000, uint8]
n_segs:   uint64 = 0
# Pending: mark the next opened segment as a list-item's first text seg so the
# pixel renderer honours its left indent. Set by the <li> handler after the
# marker is emitted; consumed (and cleared) by _seg_ensure.
_pending_indjump: int32 = 0

# ---- pixel border-box registry --------------------------------------
# Each bordered block/float box records its geometry here on close so the PIXEL
# renderer (lib/htmlpage) can stroke a real 1px rectangle with htmlpaint_fill_
# rect instead of leaning on the box-art glyphs. top_row carries the top rule,
# bot_row the bottom rule; lx/rx are the left/right bar pixel columns (char
# grid); rgb is the border colour (0xRRGGBB). Reset each layout with n_segs.
BBOX_MAX:  int32 = 256
bbox_lx:   Array[256, int32]
bbox_rx:   Array[256, int32]
bbox_top:  Array[256, int32]
bbox_bot:  Array[256, int32]
bbox_rgb:  Array[256, int32]
n_bboxes:  int32 = 0

# ---- element background-fill registry -------------------------------
# A block-level box with a `background-color` (or `background`) records its FULL
# box rectangle here on close, so the renderer paints the whole element box —
# header bars, footers, section/card panels, coloured nav strips — not just the
# strip behind each text run (seg_bg). This is the single biggest "looks like a
# real site" gap: virtually every modern page paints a coloured header/footer/
# card. lx/rx are the box's left/right pixel columns; top_row/bot_row bound the
# rows the fill covers [top_row, bot_row); rgb is 0xRRGGBB. Painted BEFORE the
# text segments so glyphs land on top. Reset each layout with n_segs.
BFILL_MAX:  int32 = 256
bfill_lx:   Array[256, int32]
bfill_rx:   Array[256, int32]
bfill_top:  Array[256, int32]
bfill_bot:  Array[256, int32]
bfill_rgb:  Array[256, int32]
bfill_z:    Array[256, int32]   # stacking order (z-index); 0 = default flow
n_bfills:   int32 = 0

# ---- <img> src registry (for the host driver to enumerate + decode) ----
# Every <img src="..."> seen during layout records its src string here so the
# file-reading host can slurp+decode each PNG and register it in lib/htmlimg
# BEFORE a second layout pass resolves natural sizes. Deduplicated by string.
EIMG_MAX:       uint64 = 64
EIMG_NAME_CAP:  uint64 = 8192
eimg_noff: Array[64, uint64]
eimg_nlen: Array[64, uint64]
n_eimg:    uint64 = 0
eimg_name_buf: Array[8192, uint8]
eimg_name_used: uint64 = 0

# broken-image placeholder box (px) when src is absent/undecodable.
IMG_BROKEN_W: int32 = 40
IMG_BROKEN_H: int32 = 32

row_rule: Array[12000, uint8]    # 0 none, 1 heading rule on this row
total_rows: uint64 = 0
top_line:   uint64 = 0

# LINKS — href targets + the spans that point to them.
MAX_LINKS:    uint64 = 1024
LINK_HREF_CAP: uint64 = 32768
link_off: Array[1024, int32]
link_len: Array[1024, int32]
link_href_buf: Array[32768, uint8]
link_href_len: uint64 = 0
n_links: uint64 = 0

# parse-time "pen" + style state
cur_row:  uint64 = 0
pen_x:    int32 = 8
indent_x: int32 = 8
row_dirty: int32 = 0
need_space: int32 = 0
seg_open:  int32 = 0
seg_curlen: uint64 = 0
g_color: int32 = 0
# Page-level background (gap #3): a <body>/<html> `background(-color)` fills the
# WHOLE viewport, not just element boxes. -1 = default white. The pixel renderer
# clears the canvas to this colour instead of white.
g_page_bg: int32 = -1
# Effective display of the element currently being dispatched (0 unset / 1 none
# / 2 flex / 3 block / 4 inline-block / 5 inline), and whether it should be laid
# out as a block box (the generic display:block / flex-item blockification path).
g_eff_disp: int32 = 0
g_treat_as_block: int32 = 0
# flex-direction of the container currently being opened (0 row / 1 column),
# read by _flex_container_open to stack (column) vs. columnise (row).
g_flex_dir: int32 = 0
# justify-content of the container currently being opened (0 unset/default,
# 1 flex-start, 2 center, 3 flex-end, 4 space-between, 5 space-around). Read by
# _flex_container_open: when SET it switches from the equal-column approximation
# to a natural-content-width row with real free-space distribution.
g_flex_just: int32 = 0
# column-gap (px) of the flex container currently being opened, or -1 to use the
# FLEX_GAP default. Read by _flex_container_open as the inter-column gutter.
g_flex_gap: int32 = -1
# row-gap (px) of the flex container currently being opened, or -1 to use no
# inter-line gap. Read by _flex_container_open: a wrapping flex row inserts this
# many px (rounded to whole LINE_H rows) of vertical space between wrapped lines.
g_flex_rowgap: int32 = -1
# flex-wrap of the container currently being opened (0 nowrap / 1 wrap). Read by
# _flex_container_open: when set, overflowing items WRAP onto additional flex
# lines instead of being crammed into one equal-column row.
g_flex_wrap: int32 = 0
# align-items (cross-axis) of the container currently being opened: 0 unset /
# 1 flex-start (== the default, top-aligned) / 2 center / 3 flex-end / 4 stretch.
# Read by _flex_container_open; a value >= 2 arms a deferred cross-axis fixup that
# shifts each already-emitted flex item's segments/fills within its line's height.
g_flex_align: int32 = 0
# ---- CSS grid (display:grid) ------------------------------------------------
# 1 when the container currently being opened is a `display:grid` box. Read by
# _flex_container_open, which lays the container's direct children out in the
# grid TRACK model (a fixed count of columns whose widths come from grid-
# template-columns; items auto-place left-to-right and wrap to the next row every
# ntrack items) instead of a flex row. Grid REUSES the flex frame machinery — it
# is a constrained flex-wrap with fixed per-track widths. Zero-cost when 0.
g_flex_grid: int32 = 0
# grid-template-columns of the container being opened, parsed to a compact per-
# track encoding: g_grid_n tracks, each g_grid_enc[c] >= 0 => a FIXED track of
# that many px; < 0 => an `fr` track of weight (-value). Resolved to pixel widths
# at container open (fr shares the free space). Filled at dispatch from the
# cascade winner (m_gtc[]) then the inline style (d_gtc[]). 0 tracks => no grid.
GRID_MAXTRACK: int32 = 8       # max grid columns (tracks) we resolve
GRID_MAXITEM:  int32 = 64      # max auto-placed grid items per container
g_grid_n:   int32 = 0
g_grid_enc: Array[8, int32]
# grid-template-rows of the container being opened, parsed to the SAME compact
# encoding as g_grid_enc but interpreted for ROWS: g_grid_renc[r] >= 0 => a FIXED
# row of that many px (fr rows are ignored — a grid row with no fixed height stays
# content-sized). Gives explicit, non-content row heights (the dashboard case).
g_grid_rn:   int32 = 0
g_grid_renc: Array[8, int32]
# Per-ITEM grid line placement, carried from the child's cascade/inline style to
# the grid item-open path: g_grid_cspan is how many TRACKS the item occupies
# (`grid-column: span N`, or `A / B` => B-A); g_grid_cstart is an explicit 1-based
# start line (`grid-column: A` / `A / B`), 0 = auto-flow into the next free track.
g_grid_cspan:  int32 = 1
g_grid_cstart: int32 = 0
# Stack of el-stack depths at which a GENERIC block box was opened (display:
# block/inline-block/flex, or a flex-item span). A close tag carries no style=""
# attribute, so its display cannot be recomputed from it; instead the matching
# close is recognised by comparing the current el-stack depth against this
# stack's top. This keeps open/close routing symmetric for inline-style blocks.
GBLK_MAX:   int32 = 64
gblk_sp:    int32 = 0
gblk_stack: Array[64, int32]
g_bold:  int32 = 0
g_uline: int32 = 0
g_link:  int32 = -1
# An explicit author colour specified ON the current anchor (a matched `a{}` /
# `.nav a{}` rule or an inline style=""), or -1 when the anchor sets no colour of
# its own. A link keeps its default blue role colour UNLESS this is >= 0, so a
# styled `<a style=color:…>` / `.nav a{color:…}` wins while an inherited ancestor
# colour (e.g. body{color:#333}) still leaves plain links blue.
g_link_rgb: int32 = -1
g_bold_n: int32 = 0          # nested <b>/<strong> depth
g_mono_n: int32 = 0          # nested inline <code>/<kbd>/<samp>/<var> depth
g_heading: int32 = 0        # 0 none, else 1..6
g_strike_n: int32 = 0        # nested <s>/<del>/<strike> depth (line-through)
# <sub>/<sup> vertical shift: g_yoff is the live signed baseline offset (px)
# folded into every opened segment. sub_depth lowers text, sup_depth raises it;
# g_yoff = sub_depth*SUB_DROP - sup_depth*SUP_RISE so nesting composes.
g_yoff: int32 = 0
sub_depth: int32 = 0
sup_depth: int32 = 0
SUB_DROP: int32 = 4          # px a <sub> baseline drops
SUP_RISE: int32 = 6          # px a <sup> baseline rises
list_depth: int32 = 0
bq_depth: int32 = 0         # <blockquote> nesting depth (left indent)
BQ_INDENT: int32 = 24       # px of left indent per blockquote level
dd_depth: int32 = 0         # <dd> nesting depth (left indent under a <dl>)
DD_INDENT: int32 = 40       # px of left indent per <dd> level (browser default)
MARK_BG: int32 = 0xfff275   # <mark> highlight background (yellow)
pre_mode: int32 = 0

# LIST layout — <ul>/<ol>/<li> with markers, ordered numbering + nesting.
# One entry per open list level (list_depth): list_type is 0 for <ul>
# (bullet marker) or 1 for <ol> (running number), list_count is the <ol>
# item counter (the NEXT item's number). LIST_STEP is the per-level left
# indent (in px); it is exactly wide enough to be the marker gutter so item
# markers hang in the parent level's left margin and wrapped continuation
# lines align under the item TEXT (a proper hanging indent).
MAX_LIST_DEPTH: int32 = 16
LIST_STEP:  int32 = 32       # px of left indent per list level (= 4 cells)
list_type:  Array[16, int32]
list_count: Array[16, int32]
# 1 for a list level whose <ul>/<ol> armed a horizontal flex row (display:flex)
# over its <li> columns, so the matching </ul>/</ol> pops the flex frame.
list_flex:  Array[16, int32]
# 1 for a list level whose flex <ul>/<ol> opened its OWN container box (so its
# background/border paints as a bar over the whole flex row); the close pops it.
list_box:   Array[16, int32]
# 1 for a list level that SUPPRESSED its LIST_STEP indent (a flex list resets its
# left padding, so the navbar sits flush); the close restores list_indent_drop.
list_supp:  Array[16, int32]
# px of LIST_STEP indent currently suppressed by open flex lists (subtracted in
# _recompute_indent). Accumulator so nested flex lists compose correctly.
list_indent_drop: int32 = 0

# BLOCK left-indent from CSS margin-left/padding-left (inline style OR a
# stylesheet/class rule). A stack of px deltas parallel to open <p>/<div>
# blocks; blk_indent_sum is the live total folded into indent_x by
# _recompute_indent(). This makes margin/padding actually shift a block's
# content column (not just decorate it).
blk_indent_stack: Array[64, int32]
blk_indent_sp:  int32 = 0
blk_indent_sum: int32 = 0

# BLOCK right edge (px) — the live wrap boundary a block flows against, folded
# in by _flow_right(). margin-right/padding-right shrink it from the parent's
# edge and `width` pins it to indent_x+width; a border steals one more cell.
# Parallel stack to the left indent so nested blocks restore the parent edge.
blk_right_stack: Array[64, int32]
blk_right_sp:   int32 = 0
blk_right_cur:  int32 = 0        # current right edge; reset to _content_right()

# BOX unit mapping (char-grid model): 1em == EM_PX px == 2 character cells wide
# (CELL_W=8) and one text line tall (LINE_H=16); `%` is taken of the body
# content width (bw - 2*CONTENT_X). Vertical margin/padding px are quantised to
# blank text lines at LINE_H granularity.
EM_PX: int32 = 16

# UA default background for <pre>/<code> so code stands out from body text
# (a light neutral panel behind the monospace run).
CODE_BG: int32 = 0xeef0f3

# Per-open-block state carried from _block_box_open() to _block_box_close():
# the bottom vertical gap (blank lines), whether a border is drawn, and the
# border box geometry (left/right pixel columns + the first content row) so the
# closing side/bottom glyphs land in the right place.
box_botg_stack: Array[64, int32]
box_bord_stack: Array[64, int32]
box_lx_stack:   Array[64, int32]
box_rx_stack:   Array[64, int32]
box_srow_stack: Array[64, int32]
box_bg_stack:   Array[64, int32]      # element background-color (0xRRGGBB) or -1
box_sp: int32 = 0

# ---- CSS float --------------------------------------------------------------
# A `float: left|right` block is laid out as a NARROW box pinned to the left or
# right edge; the following in-flow content then RE-FLOWS beside it (the pixel
# renderer sorts segs by row-then-x, so the float on one side and the body text
# on the other share the same rows). The single-pass source walker makes this
# work without a second layout pass: the float's own content is emitted first
# (in source order), then on the float's close we REWIND cur_row to the float's
# top and set an exclusion so subsequent lines wrap in the remaining width until
# they clear the float's bottom. Only ONE float is active at a time — a second
# float that opens while one is active falls back to a normal in-flow block.
#
# Zero-cost for float-free pages: float_active stays 0, float_left_pad stays 0,
# so _recompute_indent()/_flow_right() are byte-identical to before.
FLOAT_GAP:      int32 = 8        # px gutter between a float and the body text
FLOAT_DEF_W:    int32 = 240      # default float width (px) when none is given
float_active:   int32 = 0        # a float exclusion is in effect
float_side:     int32 = 0        # 1 = left, 2 = right
float_bottom:   int32 = 0        # first row at/after which the exclusion ends
float_left_pad: int32 = 0        # left float: px added to indent_x while active
float_redge:    int32 = 0        # right float: right wrap boundary while active
# Per-open-block: which side THIS block floats (0 = in-flow), its top row (to
# rewind to on close), and its exclusion geometry (redge for right / pad for
# left). Parallel to the box_*_stack.
box_float_stack:  Array[64, int32]
box_ftop_stack:   Array[64, int32]
box_fgeom_stack:  Array[64, int32]

# ---- CSS flexbox (display:flex, row direction) ------------------------------
# A `display:flex` block lays its DIRECT-CHILD block boxes out HORIZONTALLY:
# each child becomes a column whose width is an equal share of the container's
# content width (minus inter-column gaps). This is the single most common
# real-page layout that the old block-stacking model got wrong — a Wikipedia
# article body beside its infobox, a card row, a two-column landing hero.
#
# Implementation reuses the same single-pass "rewind" trick the floats use: the
# container records its top row; each child column is opened as a normal block
# box pinned to its column x (left inset = column offset, width = column width),
# its content flows down, and on the child's close cur_row is REWOUND to the
# container top so the next sibling column starts level with it. The container's
# close advances cur_row past the TALLEST column. A pre-scan counts the direct
# block children so the column width is known before the first child is placed.
#
# Zero-cost for flex-free pages: flex_sp stays 0, so every guard short-circuits
# and the block path is byte-identical to before.
FLEX_MAX:      int32 = 8          # max flex frames / columns we handle
FLEX_GAP:      int32 = 8          # px gutter between flex columns
flex_sp:       int32 = 0
flex_top_row:  Array[8, int32]    # container top row (children rewind here)
flex_max_bot:  Array[8, int32]    # deepest child bottom row seen so far
flex_left:     Array[8, int32]    # container content-left px
flex_colw:     Array[8, int32]    # per-column width px
flex_gap:      Array[8, int32]    # per-column advance = colw + FLEX_GAP
flex_ncol:     Array[8, int32]    # number of child columns
flex_next:     Array[8, int32]    # index of the next child column to place
flex_eldepth:  Array[8, int32]    # el-stack depth of the container element
# justify-content NATURAL-width mode: when a container has an explicit
# justify-content and its children's natural content widths fit the row, each
# child is placed at its own pre-computed x with its own natural width (real
# free-space distribution) instead of the equal-column approximation.
flex_natural:  Array[8, int32]    # 1 => use flex_child_x/_w, not equal columns
flex_child_x:  Array[64, int32]   # [frame*FLEX_MAX+col] x offset from flex_left
flex_child_w:  Array[64, int32]   # [frame*FLEX_MAX+col] natural content width px
flex_meas_w:   Array[8, int32]    # scratch: per-child measured natural widths
# flex-wrap MULTI-LINE mode: an overflowing flex row wraps its items onto extra
# lines (modern card grids / responsive navbars). Placement is ONLINE — each item
# is measured at its own open (its resolved CSS `width`, else its pre-measured
# natural content width) and, if it no longer fits on the current line, starts a
# NEW line below the tallest item of the previous one. This reuses the same
# single-pass rewind trick as single-line flex, so line heights need no 2nd pass.
flex_wrap_on:  Array[8, int32]    # 1 => this frame wraps onto multiple lines
flex_avail:    Array[8, int32]    # content width the items wrap within (px)
flex_rawgap:   Array[8, int32]    # inter-item gap px (author gap / FLEX_GAP)
flex_rowgap:   Array[8, int32]    # inter-LINE gap in ROWS (row-gap px / LINE_H)
flex_cur_x:    Array[8, int32]    # running x cursor within the line (from flex_left)
flex_line_top: Array[8, int32]    # top row of the current line
flex_line_bot: Array[8, int32]    # running bottom (first free row) of cur line
# align-items (cross-axis) CROSS-AXIS FIXUP. The engine emits each flex item's
# glyphs/fills top-aligned at the line top during its single online pass; but the
# line's cross-axis extent (its tallest item) is only known once every item on the
# line has been placed. Rather than a full second layout pass, we record — per
# item, ONLY when flex_align >= 2 (so flex-start stays byte-identical, zero writes)
# — the [seg,bfill,bbox) index ranges it emitted plus its line-top and bottom rows,
# then at the container's close SHIFT those already-emitted coordinates down by the
# per-item cross-axis offset (center/flex-end) or STRETCH its box fill/border to the
# full line height. A deferred coordinate fixup, O(items + flex segs), not a re-pass.
flex_align:    Array[8, int32]    # 0/1 flex-start / 2 center / 3 flex-end / 4 stretch
flex_it_seg0:  Array[64, int32]   # [frame*FLEX_MAX+col] n_segs at item open
flex_it_seg1:  Array[64, int32]   # [frame*FLEX_MAX+col] n_segs at item close
flex_it_bf0:   Array[64, int32]   # [frame*FLEX_MAX+col] n_bfills at item open
flex_it_bf1:   Array[64, int32]   # [frame*FLEX_MAX+col] n_bfills at item close
flex_it_bx0:   Array[64, int32]   # [frame*FLEX_MAX+col] n_bboxes at item open
flex_it_bx1:   Array[64, int32]   # [frame*FLEX_MAX+col] n_bboxes at item close
flex_it_ltop:  Array[64, int32]   # [frame*FLEX_MAX+col] line-top row the item sat at
flex_it_bot:   Array[64, int32]   # [frame*FLEX_MAX+col] item's exclusive bottom row
# CSS GRID reuse of the flex frame: a `display:grid` container places its items
# into fixed TRACK columns (widths resolved from grid-template-columns into the
# shared flex_child_x/_w arrays; fr distributes free space) and auto-wraps to the
# next row every flex_ntrack items. The current row uses flex_line_top/_bot (the
# same seam flex-wrap uses). Zero-cost: flex_grid stays 0 for non-grid frames.
flex_grid:     Array[8, int32]    # 1 => this frame is a grid (track auto-placement)
flex_ntrack:   Array[8, int32]    # number of grid columns (tracks) <= GRID_MAXTRACK
# Grid explicit-placement + explicit-row-height state (all zero for non-grid /
# auto frames). flex_gcur is the next FREE track column (0-based) the auto-flow
# cursor will place into — reused in place of a modulo of the item index so that
# multi-track spans (grid-column) advance the cursor by their width. The grid-
# template-rows fixed heights are stored per row into flex_growh (px; 0 =
# content-sized) with flex_growidx tracking which grid row is currently open.
flex_gcur:     Array[8, int32]    # next free track column for auto-placement
flex_gridrn:   Array[8, int32]    # grid-template-rows count (0 => all content-sized)
flex_growidx:  Array[8, int32]    # current grid row index (0-based)
flex_growh:    Array[64, int32]   # [frame*FLEX_MAX+row] fixed row height px (0=content)
# Per-open-block markers (parallel to box_*_stack): 1 if THIS block box is a
# flex item (a column) / a flex container (owns a frame).
box_flexitem_stack: Array[64, int32]
box_flexcont_stack: Array[64, int32]
# Per-open-block CSS-position bookkeeping (parallel to box_*_stack): the box's
# position mode (0/1/2), the segment index at its open, the row to rewind to on
# close (absolute = out of flow), and whether this box pushed a posctx frame.
box_pos_stack:    Array[64, int32]
box_posrun_stack: Array[64, int32]   # index into the positioned-run table (-1)
box_pretrow_stack: Array[64, int32]  # row to rewind to on close (absolute)
box_pushedctx_stack: Array[64, int32]

# ---- CSS inline-block (inline-level box in the line grid) --------------------
# `display:inline-block` chips/badges/buttons/nav-pills flow INLINE on a text
# line (advancing pen_x) and WRAP to the next line when they overflow — unlike a
# block, they do NOT each claim their own full-width row. Each open chip is a
# fixed-width box (its collapsed inner-text width + 2*INLB_PADX) that paints a
# narrow background FILL over its box and insets its text by the left padding;
# its close snaps pen_x to the box's right edge + INLB_GAP so the next chip
# flows after it. Zero-cost for chip-free pages: inlb_sp stays 0.
INLB_MAX:   int32 = 64
INLB_PADX:  int32 = 6         # px inner horizontal padding each side of a chip
INLB_GAP:   int32 = 6         # px gutter after a chip before the next inline box
inlb_sp:    int32 = 0
inlb_startx:  Array[64, int32]   # left px of the chip box (before padding)
inlb_boxw:    Array[64, int32]   # total chip box width px (text + 2*INLB_PADX)
inlb_row:     Array[64, int32]   # the row the chip sits on
inlb_eldepth: Array[64, int32]   # el-stack depth of the chip element (close match)
inlb_yoff:    Array[64, int32]   # baseline shift (px) applied to centre a TALL chip
# Set in the tag-dispatch preamble when the element being opened/closed is an
# inline-block box handled by the inline-flow path (routes it AROUND the generic
# block-box blockification).
g_inlb: int32 = 0
# When an inline-block chip grows TALLER than one text line (vertical padding or
# min-height), this holds the first free row BELOW the tallest such chip on the
# current line (0 = no tall chip). The next line break (_bump_row) snaps cur_row
# down to it so following content clears the box, then clears it. Zero-cost for
# one-row chips: it stays 0 and every guard short-circuits.
g_inlb_floor: int32 = 0

# TABLE layout — two-pass column model. Pass 1 (_measure_table) walks the
# table source and records the widest cell (in characters) per column; pass 2
# (_compute_cols) turns those into pixel column x-positions. During the normal
# linear parse each <tr> is one visual row and each <td>/<th> places its text
# at its column's x, clamped to the column's right edge (cell_right) so a wide
# cell wraps inside its column instead of bleeding across the table.
MAX_COLS:    int32 = 32
CELL_PAD:    int32 = 2       # inter-column gap, in character cells
# CELL_PADX: per-side content inset (px) between a cell's border and its text,
# so header/body text never touches or overlaps the column/table border the way
# an inset-less pen (text drawn straight from col_x, i.e. the border) does. The
# UA default is ~1px border-spacing + a couple px cell padding; 6px reads right
# at CELL_W=8. Applied to BOTH edges (left inset on open, right clamp on close).
CELL_PADX:   int32 = 6
col_x:    Array[33, int32]   # pixel x of each column (index n_cols = right edge)
col_chars: Array[32, int32]  # widest cell per column, in characters
n_cols:      int32 = 0
table_active: int32 = 0
cell_active:  int32 = 0      # inside a <td>/<th> (drives cell_right + styling)
cell_is_th:   int32 = 0      # current cell is a <th> (bold)
cell_right:   int32 = 0      # right edge (px) of the current cell's column
cur_col:      int32 = 0
# A <table style="float:right|left"> (the Wikipedia infobox) is laid out inside
# the SAME float exclusion block containers use: the table's grid is measured to
# its natural width, a float box of that width is pinned to the edge, and the
# body text re-flows beside it. 1 while the current table floated (its close
# must go through _float_box_close instead of the in-flow para break).
table_floated: int32 = 0

# NESTED-TABLE context stack. A <table> inside a <td> is laid out as its own
# table box within the parent cell: on open the parent's column model + cell
# scope is pushed here (so _measure_table/_compute_cols may overwrite the shared
# col_x/col_chars/n_cols globals) and restored on the inner </table>, letting
# tables nest to arbitrary depth. Each entry also records THIS table's border
# geometry (left x, top row) so its border strokes as a real rectangle via the
# same bbox registry, independent of the outer table's border.
TBL_MAX:  int32 = 8
tbl_sp:   int32 = 0
tbl_ncols_st:     Array[8, int32]
tbl_curcol_st:    Array[8, int32]
tbl_cellact_st:   Array[8, int32]
tbl_cellright_st: Array[8, int32]
tbl_cellisth_st:  Array[8, int32]
tbl_indentx_st:   Array[8, int32]
tbl_floated_st:   Array[8, int32]
tbl_colx_st:      Array[264, int32]   # 8 * 33 saved col_x snapshots
tbl_srow_st:      Array[8, int32]     # this table's top-rule row
tbl_lx_st:        Array[8, int32]     # this table's left x (border left edge)
tbl_border_st:    Array[8, int32]     # 1 if this table strokes an in-flow border
tbl_rgb_st:       Array[8, int32]     # this table's border colour (0xRRGGBB)

skip_active: int32 = 0
skip_name: Array[16, uint8]
skip_nlen: uint64 = 0

# CSS colour state — a stack of explicit colours pushed by colour-bearing
# elements (span/font/p/div/h1-h3). g_rgb is the effective colour (topmost
# non-sentinel entry), or -1 when no explicit colour applies.
COLOR_STACK_CAP: int32 = 64
color_stack: Array[64, int32]
color_sp: int32 = 0
g_rgb: int32 = -1

# CSS background-colour state — a parallel stack to the text-colour stack.
# Pushed by bgcolor / background-color-bearing elements (body-less: p/div/
# span/font/h*/blockquote/table/tr/td/th). g_bg is the effective (topmost
# non-sentinel) background, or -1 when none applies.
bg_stack: Array[64, int32]
bg_sp: int32 = 0
g_bg: int32 = -1

# inline word accumulator
WORD_CAP: uint64 = 2048
word_buf: Array[2048, uint8]
word_len: uint64 = 0
# Decoded-entity output: up to 4 UTF-8 bytes for one code point.
g_ent_buf: Array[4, uint8]
g_ent_len: int32 = 0


def _palette(idx: uint8) -> Ptr[uint8]:
    if idx == 1:
        return cast[Ptr[uint8]]("#1a4fd0")          # link blue
    if idx == 2:
        return cast[Ptr[uint8]]("#14306e")          # heading dark blue
    if idx == 3:
        return cast[Ptr[uint8]]("#0a6b5a")          # pre/code teal
    return cast[Ptr[uint8]]("#101010")              # body text


# Palette index -> packed 0xRRGGBB (mirrors _palette; used to resolve a
# segment to a concrete colour for rendering / dumping).
def _palette_rgb(idx: uint8) -> int32:
    if idx == 1:
        return 0x1a4fd0
    if idx == 2:
        return 0x14306e
    if idx == 3:
        return 0x0a6b5a
    return 0x101010


# ---- CSS colour stack ----------------------------------------------
def _color_effective() -> int32:
    i: int32 = color_sp - 1
    while i >= 0:
        if color_stack[i] >= 0:
            return color_stack[i]
        i = i - 1
    return -1


def _color_push(rgb: int32):
    if color_sp < COLOR_STACK_CAP:
        color_stack[color_sp] = rgb
        color_sp = color_sp + 1
    g_rgb = _color_effective()


def _color_pop():
    if color_sp > 0:
        color_sp = color_sp - 1
    g_rgb = _color_effective()


# ---- CSS background-colour stack (mirrors the text-colour stack) -----
def _bg_effective() -> int32:
    i: int32 = bg_sp - 1
    while i >= 0:
        if bg_stack[i] >= 0:
            return bg_stack[i]
        i = i - 1
    return -1


def _bg_push(rgb: int32):
    if bg_sp < COLOR_STACK_CAP:
        bg_stack[bg_sp] = rgb
        bg_sp = bg_sp + 1
    g_bg = _bg_effective()


def _bg_pop():
    if bg_sp > 0:
        bg_sp = bg_sp - 1
    g_bg = _bg_effective()


def _base_color() -> int32:
    if g_heading != 0:
        return 2
    if pre_mode != 0:
        return 3
    return 0


def _recompute_style():
    if g_link >= 0:
        g_color = 1
        # Links default to underlined, but text-decoration:none (g_css_uline==2)
        # on the link (or an ancestor) strips it — the common nav/button pattern.
        if g_css_uline == 2:
            g_uline = 0
        else:
            g_uline = 1
    else:
        g_color = _base_color()
        # Non-link text underlines only when CSS text-decoration:underline set it.
        if g_css_uline == 1:
            g_uline = 1
        else:
            g_uline = 0
    if g_bold_n > 0 or g_heading != 0 or g_css_bold != 0:
        g_bold = 1
    else:
        g_bold = 0


# ---- segment building -----------------------------------------------
# Pixel-render FACE hint for the segment currently being opened. Heading wins
# (headings are never <pre>/<code>); then monospace; else body sans.
def _cur_face() -> uint8:
    if g_heading != 0:
        h: int32 = g_heading
        if h > 6:
            h = 6
        return cast[uint8](1 + h)                     # 2..7 = h1..h6
    if pre_mode != 0 or g_mono_n > 0:
        return 1                                       # monospace
    return 0                                           # body sans


def _seg_ensure():
    if seg_open != 0:
        return
    if n_segs >= MAX_SEGS:
        return
    seg_open = 1
    seg_x[n_segs]    = pen_x
    seg_line[n_segs] = cast[int32](cur_row)
    seg_off[n_segs]  = cast[int32](seg_text_len)
    seg_color[n_segs] = cast[uint8](g_color)
    # An explicit CSS colour overrides the role palette, EXCEPT on links,
    # which keep their blue role colour.
    if g_link < 0:
        seg_rgb[n_segs] = g_rgb
    else:
        # Links keep their blue role colour, EXCEPT when the anchor specifies its
        # own colour (author `a{color:…}` / inline) — then that colour wins.
        seg_rgb[n_segs] = g_link_rgb
    seg_bg[n_segs]    = g_bg
    seg_bold[n_segs]  = cast[uint8](g_bold)
    seg_uline[n_segs] = cast[uint8](g_uline)
    seg_link[n_segs]  = g_link
    seg_face[n_segs]  = _cur_face()
    seg_pxsize[n_segs] = g_font_px
    seg_lineh[n_segs] = g_lineh
    seg_img[n_segs]   = -1
    seg_boxart[n_segs] = 0
    seg_marker[n_segs] = 0
    seg_yoff[n_segs]  = g_yoff
    if g_strike_n > 0:
        seg_strike[n_segs] = 1
    else:
        seg_strike[n_segs] = 0
    # A list-item's first text seg claims the pending hanging-indent jump.
    if _pending_indjump != 0:
        seg_indjump[n_segs] = 1
        _pending_indjump = 0
    else:
        seg_indjump[n_segs] = 0
    # Table cells + <pre> are laid out on absolute grid columns; the pixel
    # renderer honours seg_x for them so columns/alignment survive.
    if table_active != 0 or pre_mode != 0:
        seg_gridx[n_segs] = 1
    else:
        seg_gridx[n_segs] = 0
    seg_curlen = 0
    # Record the row's text-alignment (a post-layout pass shifts seg_x).
    # Table/pre rows keep their computed geometry (no re-alignment).
    if g_align != 0 and table_active == 0 and pre_mode == 0 and \
       cur_row < MAX_ROWS:
        row_align[cur_row] = cast[uint8](g_align)


def _seg_putc(c: uint8):
    _seg_ensure()
    if seg_open == 0:
        return
    if seg_text_len < SEG_TEXT_CAP - 1:
        seg_text_buf[seg_text_len] = c
        seg_text_len = seg_text_len + 1
        seg_curlen = seg_curlen + 1
    row_dirty = 1


# Emit a non-negative decimal integer into the current segment (marker use).
def _seg_putc_dec(v: int32):
    if v < 0:
        v = 0
    if v >= 10:
        _seg_putc_dec(v / 10)
    _seg_putc(cast[uint8](48 + (v - (v / 10) * 10)))


def _close_seg():
    if seg_open == 0:
        return
    if seg_curlen > 0 and n_segs < MAX_SEGS:
        seg_len[n_segs] = cast[int32](seg_curlen)
        n_segs = n_segs + 1
    seg_open = 0
    seg_curlen = 0


# A style change closes the current segment so the next text opens a fresh
# one carrying the new attributes.
def _style_break():
    _close_seg()
    _recompute_style()


# ---- line breaks ----------------------------------------------------
def _bump_row():
    cur_row = cur_row + 1
    if cur_row >= MAX_ROWS:
        cur_row = MAX_ROWS - 1
    # Clear a tall inline-block chip: the first line break after it drops past the
    # box's reserved rows so following content does not overlap it. 0 => no-op.
    if g_inlb_floor != 0:
        if cur_row < cast[uint64](g_inlb_floor):
            cur_row = cast[uint64](g_inlb_floor)
        g_inlb_floor = 0


def _soft_newline():
    # Move to a fresh line ONLY if the current one has content.
    _close_seg()
    if row_dirty != 0:
        _bump_row()
    _maybe_clear_float()
    pen_x = indent_x
    row_dirty = 0
    need_space = 0


def _newline():
    # Unconditional line break (<br>, pre newline).
    _close_seg()
    _bump_row()
    _maybe_clear_float()
    pen_x = indent_x
    row_dirty = 0
    need_space = 0


def _para_break():
    # End the current line + leave a single blank gap.
    _soft_newline()
    _bump_row()
    _maybe_clear_float()
    pen_x = indent_x
    need_space = 0


# Left indent = list nesting + blockquote nesting. Both front-ends flow to
# indent_x, so this is the single left-margin knob for block structure.
def _recompute_indent():
    indent_x = _left_margin() + list_depth * LIST_STEP - list_indent_drop + \
               bq_depth * BQ_INDENT + \
               dd_depth * DD_INDENT + blk_indent_sum + float_left_pad


# Drop an active float exclusion once flow has passed the float's bottom row.
# Called at every line start; a no-op (single compare) when no float is active.
def _maybe_clear_float():
    if float_active != 0 and cast[int32](cur_row) >= float_bottom:
        float_active = 0
        float_side = 0
        float_redge = 0
        if float_left_pad != 0:
            float_left_pad = 0
            _recompute_indent()


# Push/pop a block's CSS left indent (margin-left+padding-left). Always paired
# per <p>/<div> open/close (a 0-px block still pushes, to stay balanced), and
# both refresh indent_x + the pen so content flows at the new left column.
def _blk_indent_push(px: int32):
    if blk_indent_sp < 64:
        blk_indent_stack[blk_indent_sp] = px
        blk_indent_sp = blk_indent_sp + 1
        blk_indent_sum = blk_indent_sum + px
    _recompute_indent()
    pen_x = indent_x


def _blk_indent_pop():
    if blk_indent_sp > 0:
        blk_indent_sp = blk_indent_sp - 1
        blk_indent_sum = blk_indent_sum - blk_indent_stack[blk_indent_sp]
    _recompute_indent()
    pen_x = indent_x


# ---- CSS border box (char-grid glyphs) ------------------------------
# Emit `ncells` copies of glyph `ch` as one standalone segment at (row, x).
# Used for the horizontal top/bottom border rules; writes the seg arrays
# directly (bypassing the pen) so it can target an arbitrary row.
def _emit_box_run(row: int32, x: int32, ch: uint8, ncells: int32):
    if ncells <= 0 or n_segs >= MAX_SEGS:
        return
    seg_x[n_segs]     = x
    seg_line[n_segs]  = row
    seg_off[n_segs]   = cast[int32](seg_text_len)
    seg_color[n_segs] = 0
    seg_rgb[n_segs]   = -1
    seg_bg[n_segs]    = -1
    seg_bold[n_segs]  = 0
    seg_uline[n_segs] = 0
    seg_link[n_segs]  = -1
    seg_face[n_segs]  = 1                              # box art = monospace
    seg_gridx[n_segs] = 1
    seg_img[n_segs]   = -1
    seg_boxart[n_segs] = 1
    seg_yoff[n_segs]  = 0
    seg_strike[n_segs] = 0
    k: int32 = 0
    while k < ncells and seg_text_len < SEG_TEXT_CAP - 1:
        c: uint8 = ch
        if k == 0 or k == ncells - 1:
            c = 43                                    # '+' corners/ends
        seg_text_buf[seg_text_len] = c
        seg_text_len = seg_text_len + 1
        k = k + 1
    seg_len[n_segs] = k
    n_segs = n_segs + 1


# Emit a single vertical bar '|' glyph at (row, x).
def _emit_box_bar(row: int32, x: int32):
    if n_segs >= MAX_SEGS or seg_text_len >= SEG_TEXT_CAP - 1:
        return
    seg_x[n_segs]     = x
    seg_line[n_segs]  = row
    seg_off[n_segs]   = cast[int32](seg_text_len)
    seg_color[n_segs] = 0
    seg_rgb[n_segs]   = -1
    seg_bg[n_segs]    = -1
    seg_bold[n_segs]  = 0
    seg_uline[n_segs] = 0
    seg_link[n_segs]  = -1
    seg_face[n_segs]  = 1                              # box art = monospace
    seg_gridx[n_segs] = 1
    seg_img[n_segs]   = -1
    seg_boxart[n_segs] = 1
    seg_yoff[n_segs]  = 0
    seg_strike[n_segs] = 0
    seg_text_buf[seg_text_len] = 124                  # '|'
    seg_text_len = seg_text_len + 1
    seg_len[n_segs] = 1
    n_segs = n_segs + 1


# ---- <img> pixel box ------------------------------------------------
# Record an <img>'s src string (src_ptr[soff..soff+slen)) in the registry the
# host driver reads to decode PNGs. Deduplicated; a no-op if src is empty/full.
def _eimg_record(soff: uint64, slen: uint64):
    if slen == 0:
        return
    i: uint64 = 0
    while i < n_eimg:
        if eimg_nlen[i] == slen:
            same: int32 = 1
            k: uint64 = 0
            while k < slen:
                if eimg_name_buf[eimg_noff[i] + k] != src_ptr[soff + k]:
                    same = 0
                    break
                k = k + 1
            if same != 0:
                return
        i = i + 1
    if n_eimg >= EIMG_MAX or eimg_name_used + slen > EIMG_NAME_CAP:
        return
    eimg_noff[n_eimg] = eimg_name_used
    eimg_nlen[n_eimg] = slen
    k2: uint64 = 0
    while k2 < slen:
        eimg_name_buf[eimg_name_used + k2] = src_ptr[soff + k2]
        k2 = k2 + 1
    eimg_name_used = eimg_name_used + slen
    n_eimg = n_eimg + 1


# alt-text placeholder for the current <img> (bracketed, e.g. "[Hamnix logo]").
img_alt_buf: Array[256, uint8]
img_alt_len: uint64 = 0


# Emit a standalone image segment: a block box of `bw2`x`bh2` px at the current
# left indent, carrying the decoded-image slot (or -2 = broken placeholder). The
# segment ALSO holds the bracketed alt text (img_alt_buf) so the legacy
# monospace-grid dump and the native text path have a meaningful glyph fallback;
# the PIXEL renderer ignores that text and blits the image box instead. The
# image owns its own visual row so following content flows below it.
def _emit_img_seg(slot: int32, bw2: int32, bh2: int32):
    _close_seg()
    _soft_newline()
    if n_segs >= MAX_SEGS:
        return
    seg_x[n_segs]     = indent_x
    seg_line[n_segs]  = cast[int32](cur_row)
    seg_off[n_segs]   = cast[int32](seg_text_len)
    seg_color[n_segs] = 0
    seg_rgb[n_segs]   = -1
    seg_bg[n_segs]    = -1
    seg_bold[n_segs]  = 0
    seg_uline[n_segs] = 0
    seg_link[n_segs]  = g_link
    seg_face[n_segs]  = 0
    seg_pxsize[n_segs] = 0
    seg_lineh[n_segs] = g_lineh
    seg_gridx[n_segs] = 1                              # absolute x, no reflow
    seg_img[n_segs]   = slot
    seg_boxart[n_segs] = 0
    seg_yoff[n_segs]  = 0
    seg_strike[n_segs] = 0
    seg_imgw[n_segs]  = bw2
    seg_imgh[n_segs]  = bh2
    # copy the bracketed alt text into the segment's glyph run.
    k: uint64 = 0
    while k < img_alt_len and seg_text_len < SEG_TEXT_CAP - 1:
        seg_text_buf[seg_text_len] = img_alt_buf[k]
        seg_text_len = seg_text_len + 1
        k = k + 1
    seg_len[n_segs]   = cast[int32](k)
    n_segs = n_segs + 1
    row_dirty = 1
    _soft_newline()                                   # content below the image


# Handle an <img> open tag: resolve src + width/height, compute the box size
# (natural size from a decoded image if available, else attribute size, else a
# broken-image placeholder), record the src for the host, and emit the box.
def _handle_img(ne: uint64, te: uint64):
    _word_flush()
    soff: uint64 = 0
    slen: uint64 = 0
    if _find_attr(ne, te, cast[Ptr[uint8]]("src")) != 0 and g_attr_end > g_attr_start:
        soff = g_attr_start
        slen = g_attr_end - g_attr_start
    _eimg_record(soff, slen)
    # Build the bracketed alt placeholder ("[alt]" or "[img]") NOW, before the
    # width/height _attr_int calls clobber g_attr_start/end.
    img_alt_len = 0
    img_alt_buf[img_alt_len] = 91                      # '['
    img_alt_len = img_alt_len + 1
    if _find_attr(ne, te, cast[Ptr[uint8]]("alt")) != 0 and g_attr_end > g_attr_start:
        p: uint64 = g_attr_start
        while p < g_attr_end and img_alt_len < 254:
            c: uint8 = src_ptr[p]
            if c == 9 or c == 10 or c == 13:
                c = 32
            img_alt_buf[img_alt_len] = c
            img_alt_len = img_alt_len + 1
            p = p + 1
    else:
        img_alt_buf[img_alt_len] = 105                 # 'i'
        img_alt_buf[img_alt_len + 1] = 109             # 'm'
        img_alt_buf[img_alt_len + 2] = 103             # 'g'
        img_alt_len = img_alt_len + 3
    img_alt_buf[img_alt_len] = 93                      # ']'
    img_alt_len = img_alt_len + 1
    slot: int32 = -1
    natw: int32 = 0
    nath: int32 = 0
    if slen > 0:
        slot = htmlimg_find(&src_ptr[soff], slen)
        if slot >= 0:
            natw = htmlimg_w(slot)
            nath = htmlimg_h(slot)
    aw: int32 = _attr_int(ne, te, cast[Ptr[uint8]]("width"), -1)
    ah: int32 = _attr_int(ne, te, cast[Ptr[uint8]]("height"), -1)
    bw2: int32 = 0
    bh2: int32 = 0
    if aw > 0 and ah > 0:
        bw2 = aw
        bh2 = ah
    elif aw > 0:
        bw2 = aw
        if natw > 0:
            bh2 = nath * aw / natw
        else:
            bh2 = aw
    elif ah > 0:
        bh2 = ah
        if nath > 0:
            bw2 = natw * ah / nath
        else:
            bw2 = ah
    else:
        if natw > 0:
            bw2 = natw
            bh2 = nath
    if bw2 <= 0 or bh2 <= 0:
        # no decoded image AND no usable attributes -> broken placeholder box.
        slot = -2
        bw2 = IMG_BROKEN_W
        bh2 = IMG_BROKEN_H
    elif slot < 0:
        slot = -2                                     # sized but undecodable
    # clamp the box so a pathological width can't blow up the canvas.
    if bw2 > bw:
        # scale height with width to preserve aspect when clamping.
        if bw2 > 0:
            bh2 = bh2 * bw / bw2
        bw2 = bw
    if bh2 < 1:
        bh2 = 1
    _emit_img_seg(slot, bw2, bh2)


# ---- inline <svg> ---------------------------------------------------
# A synthetic src-name buffer keying each inline <svg>'s rasterised RGBA in the
# lib/htmlimg store. The name is "svg@<byte-offset>" so a given <svg> in the
# source resolves to the SAME slot across the engine's two layout passes (no
# duplicate copies), yet two distinct <svg> elements never collide.
isvg_name: Array[24, uint8]


def _isvg_name(off: uint64) -> uint64:
    isvg_name[0] = 115                                 # 's'
    isvg_name[1] = 118                                 # 'v'
    isvg_name[2] = 103                                 # 'g'
    isvg_name[3] = 64                                  # '@'
    # decimal offset (max 20 digits fits uint64), written LSB-first then reversed
    n: uint64 = 4
    v: uint64 = off
    d0: uint64 = n
    if v == 0:
        isvg_name[n] = 48                              # '0'
        n = n + 1
    while v > 0 and n < 23:
        isvg_name[n] = cast[uint8](48 + cast[uint8](v % 10))
        v = v / 10
        n = n + 1
    # reverse the digits in place
    a: uint64 = d0
    b: uint64 = n - 1
    while a < b:
        t: uint8 = isvg_name[a]
        isvg_name[a] = isvg_name[b]
        isvg_name[b] = t
        a = a + 1
        b = b - 1
    return n


# Handle an inline <svg ...> element: rasterise the whole <svg>...</svg> subtree
# through the SHARED lib/svg rasterizer (the same one that decodes <img
# src=*.svg>), copy its RGBA into the lib/htmlimg store, and emit a replaced
# image box so the pixel renderer blits it exactly like an <img>. `ts` is the
# byte just after '<'; `te` is the '>' of the opening tag. Returns 1 if the
# element was consumed (caller must then _enter_skip past its children), 0 if it
# was self-closing / empty (nothing to skip).
def _handle_inline_svg(ts: uint64, te: uint64) -> int32:
    _word_flush()
    # self-closing "<svg .../>" carries no shapes — draw nothing, skip nothing.
    self_close: int32 = 0
    if te > ts and src_ptr[te - 1] == 47:              # '/'
        self_close = 1
    # Feed the rasterizer from the '<' of <svg> to end-of-source; svg_decode
    # finds the <svg> root at offset 0 and stops at the first </svg>.
    start: uint64 = ts - 1
    rc: int32 = svg_decode(&src_ptr[start], src_len - start)
    if rc != 0:
        # unsized / unparseable inline <svg> -> broken-image placeholder box.
        img_alt_len = 0
        img_alt_buf[0] = 91                            # '['
        img_alt_buf[1] = 115                           # 's'
        img_alt_buf[2] = 118                           # 'v'
        img_alt_buf[3] = 103                           # 'g'
        img_alt_buf[4] = 93                            # ']'
        img_alt_len = 5
        _emit_img_seg(-2, IMG_BROKEN_W, IMG_BROKEN_H)
        if self_close != 0:
            return 0
        return 1
    w: int32 = svg_width()
    h: int32 = svg_height()
    nl: uint64 = _isvg_name(start)
    slot: int32 = htmlimg_add(&isvg_name[0], nl, w, h, svg_rgba_ptr())
    bw2: int32 = w
    bh2: int32 = h
    if slot < 0:
        slot = -2                                      # store full -> placeholder
    # clamp to the content width, preserving aspect.
    if bw2 > bw:
        if bw2 > 0:
            bh2 = bh2 * bw / bw2
        bw2 = bw
    if bh2 < 1:
        bh2 = 1
    img_alt_len = 0
    img_alt_buf[0] = 91                                # '['
    img_alt_buf[1] = 115                               # 's'
    img_alt_buf[2] = 118                               # 'v'
    img_alt_buf[3] = 103                               # 'g'
    img_alt_buf[4] = 93                                # ']'
    img_alt_len = 5
    _emit_img_seg(slot, bw2, bh2)
    if self_close != 0:
        return 0
    return 1


# Advance `n` blank visual rows (top/bottom vertical margin+padding gap).
def _blank_rows(n: int32):
    k: int32 = 0
    while k < n:
        _bump_row()
        k = k + 1


# Open a block box for a <p>/<div>. `left`/`rins` are the left/right insets
# (margin+padding, px); `wd` the content width (px, -1 none); `topg`/`botg` the
# top/bottom gaps (px); `bord` 1 to draw a border. Pushes the left-indent and
# right-edge stacks + records close-side state on box_*_stack.
def _block_box_open(left: int32, rins: int32, wd: int32, topg: int32, \
                    botg: int32, bord: int32, bgc: int32):
    # top gap: quantise px -> blank lines.
    if topg > 0:
        _blank_rows((topg + LINE_H / 2) / LINE_H)
    # left inset (+ a cell for the border) shifts the content column.
    li: int32 = left
    if bord != 0:
        li = li + CELL_W
    _blk_indent_push(li)
    # right edge: shrink from the parent by the right inset (+ border cell), or
    # pin to indent_x + width when a width is set. Clamp to a sane range.
    parent_right: int32 = blk_right_cur
    if parent_right <= 0:
        parent_right = _content_right()
    new_right: int32 = parent_right - rins
    if bord != 0:
        new_right = new_right - CELL_W
    if wd >= 0:
        wr: int32 = indent_x + wd
        if wr < new_right:
            new_right = wr
    if new_right < indent_x + CELL_W:
        new_right = indent_x + CELL_W
    if new_right > _content_right():
        new_right = _content_right()
    if blk_right_sp < 64:
        blk_right_stack[blk_right_sp] = parent_right
        blk_right_sp = blk_right_sp + 1
    blk_right_cur = new_right
    # border: draw the top rule now, on a fresh row, then start content below.
    lx: int32 = indent_x - CELL_W                     # left bar column
    rx: int32 = new_right                             # right bar column
    if bord != 0:
        _soft_newline()
        row_dirty = 0
        span: int32 = (rx - lx) / CELL_W + 1
        _emit_box_run(cast[int32](cur_row), lx, 45, span)   # '-' top
        _bump_row()
        pen_x = indent_x
        row_dirty = 0
    # push close-side state.
    if box_sp < 64:
        box_botg_stack[box_sp] = botg
        box_bord_stack[box_sp] = bord
        box_lx_stack[box_sp]   = lx
        box_rx_stack[box_sp]   = rx
        box_srow_stack[box_sp] = cast[int32](cur_row)
        box_bg_stack[box_sp]   = bgc
        box_float_stack[box_sp] = 0                     # in-flow unless floated
        box_ftop_stack[box_sp]  = 0
        box_fgeom_stack[box_sp] = 0
        box_flexitem_stack[box_sp] = 0                  # set by the caller
        box_flexcont_stack[box_sp] = 0
        box_pos_stack[box_sp] = 0                        # set by the caller
        box_posrun_stack[box_sp] = -1
        box_pretrow_stack[box_sp] = 0
        box_pushedctx_stack[box_sp] = 0
        box_sp = box_sp + 1


# Close the block box opened by _block_box_open (pops both stacks; draws the
# bottom border rule + left/right bars over the content rows when bordered;
# emits the bottom gap as blank lines).
def _block_box_close():
    botg: int32 = 0
    bord: int32 = 0
    lx: int32 = 0
    rx: int32 = 0
    srow: int32 = 0
    bgc: int32 = -1
    if box_sp > 0:
        box_sp = box_sp - 1
        botg = box_botg_stack[box_sp]
        bord = box_bord_stack[box_sp]
        lx   = box_lx_stack[box_sp]
        rx   = box_rx_stack[box_sp]
        srow = box_srow_stack[box_sp]
        bgc  = box_bg_stack[box_sp]
    # element background: paint the WHOLE box rectangle (not just behind text).
    # Flush the pen so the box's last content row is counted, then register a
    # fill spanning [srow, bottom) at the box's left/right columns.
    if bgc >= 0 and n_bfills < BFILL_MAX:
        _word_flush()
        bfbot: int32 = cast[int32](cur_row)
        if row_dirty != 0:
            bfbot = bfbot + 1
        if bfbot > srow:
            bfill_lx[n_bfills]  = lx
            bfill_rx[n_bfills]  = rx + CELL_W
            bfill_top[n_bfills] = srow
            bfill_bot[n_bfills] = bfbot
            bfill_rgb[n_bfills] = bgc
            bfill_z[n_bfills]   = 0
            n_bfills = n_bfills + 1
    if bord != 0:
        _soft_newline()
        brow: int32 = cast[int32](cur_row)
        # side bars over every content row [srow, brow).
        r: int32 = srow
        while r < brow:
            _emit_box_bar(r, lx)
            _emit_box_bar(r, rx)
            r = r + 1
        span: int32 = (rx - lx) / CELL_W + 1
        _emit_box_run(brow, lx, 45, span)             # '-' bottom
        # Register the box for the pixel renderer to stroke a real 1px border
        # (the glyphs above are consumed only by the monospace-grid text dump).
        # top rule sits on srow-1 (open bumped a row past it); bottom on brow.
        if n_bboxes < BBOX_MAX:
            bbox_lx[n_bboxes]  = lx
            bbox_rx[n_bboxes]  = rx
            bbox_top[n_bboxes] = srow - 1
            bbox_bot[n_bboxes] = brow
            bbox_rgb[n_bboxes] = 0
            n_bboxes = n_bboxes + 1
        _bump_row()
        row_dirty = 0
    # restore the parent right edge + pop the left indent.
    if blk_right_sp > 0:
        blk_right_sp = blk_right_sp - 1
        blk_right_cur = blk_right_stack[blk_right_sp]
    _blk_indent_pop()
    if botg > 0:
        _blank_rows((botg + LINE_H / 2) / LINE_H)
    pen_x = indent_x


# Open a FLOATED block (side 1=left, 2=right). Lays the float out as a narrow
# box pinned to that edge (reusing the bordered-box machinery), recording the
# bookkeeping the close needs to set the wrap exclusion. Returns 1 if it opened
# as a real float (caller must not also open an in-flow box), 0 to fall back to
# a normal in-flow block (no room / a float already active).
def _float_box_open(side: int32, wd: int32, topg: int32, botg: int32, \
                    bord: int32, bgc: int32) -> int32:
    if float_active != 0:
        return 0                                        # one float at a time
    _word_flush()
    _soft_newline()
    fstart: int32 = cast[int32](cur_row)
    fw: int32 = wd
    if fw <= 0:
        fw = FLOAT_DEF_W
    left0: int32 = indent_x
    right0: int32 = _flow_right()
    avail: int32 = right0 - left0
    # cap the float so a readable body column (>= 4 cells) survives beside it.
    if fw > avail - 4 * CELL_W:
        fw = avail - 4 * CELL_W
    if fw < 6 * CELL_W:
        return 0                                        # too little room
    li: int32 = 0
    if side == 2:                                       # right: pin to right edge
        li = right0 - fw - left0
        if li < 0:
            li = 0
    _block_box_open(li, 0, fw, topg, botg, bord, bgc)
    idx: int32 = box_sp - 1
    if idx >= 0:
        box_float_stack[idx] = side
        box_ftop_stack[idx]  = fstart
        if side == 2:
            box_fgeom_stack[idx] = left0 + li - FLOAT_GAP    # right wrap edge
        else:
            box_fgeom_stack[idx] = fw + FLOAT_GAP            # left indent pad
    return 1


# Close a block that may be a float. Draws the box (via _block_box_close), then
# — if it floated — rewinds cur_row to the float's top and arms the exclusion so
# the following in-flow content re-flows beside it. Returns the float side
# (0 = it was a normal in-flow block, so the caller still emits its para gap).
def _float_box_close() -> int32:
    idx: int32 = box_sp - 1
    side: int32 = 0
    fstart: int32 = 0
    geom: int32 = 0
    if idx >= 0:
        side = box_float_stack[idx]
        fstart = box_ftop_stack[idx]
        geom = box_fgeom_stack[idx]
    _block_box_close()
    if side == 0:
        return 0
    fbot: int32 = cast[int32](cur_row)
    if fbot <= fstart:
        fbot = fstart + 1
    float_bottom = fbot
    float_active = 1
    float_side = side
    if side == 2:
        float_redge = geom
    else:
        float_left_pad = geom
        _recompute_indent()
    cur_row = cast[uint64](fstart)                       # rewind: flow beside
    pen_x = indent_x
    row_dirty = 0
    need_space = 0
    return side


# Drop any active float and drop flow below it (called at document end so the
# scroll height covers a trailing float taller than the beside-content).
def _float_flush():
    if float_active != 0:
        if cast[int32](cur_row) < float_bottom:
            cur_row = cast[uint64](float_bottom)
        float_active = 0
        float_side = 0
        float_redge = 0
        if float_left_pad != 0:
            float_left_pad = 0
            _recompute_indent()
        pen_x = indent_x
        row_dirty = 0


# ---- CSS flexbox ------------------------------------------------------------
# Is src[a..b) the name of a block-level element that opens a box (and so can be
# a flex column)? Mirrors the block set in _handle_tag's <p>/<div> branch.
def _is_flexblk(a: uint64, b: uint64) -> int32:
    n: uint64 = b - a
    if _name_eq(a, n, cast[Ptr[uint8]]("div")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("p")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("section")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("aside")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("article")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("header")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("footer")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("main")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("nav")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("figure")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("figcaption")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("span")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("a")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("li")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("ul")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("ol")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("label")) != 0:
        return 1
    return 0


# Tags that own a dedicated layout/styling handler whose semantics must survive
# a stray `display:block`/`inline-block`/`flex` (or a flex-item context): links,
# headings, lists, tables, form controls, void tags, page structure. Everything
# NOT here is free to be blockified into a generic block box (the display:block
# and flex-item-blockification paths). Keeps `label{display:block}` +
# span-flex-navbars working without breaking tables/lists/links.
def _blk_dedicated(a: uint64, n: uint64) -> int32:
    if _name_eq(a, n, cast[Ptr[uint8]]("a")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("ul")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("ol")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("li")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("dl")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("dt")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("dd")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("table")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("tr")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("td")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("th")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("thead")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("tbody")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("tfoot")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("caption")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("img")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("input")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("br")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("hr")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("pre")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("code")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("blockquote")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("textarea")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("select")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("option")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("button")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("mark")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("small")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("sub")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("sup")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("h1")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("h2")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("h3")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("h4")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("h5")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("h6")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("body")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("html")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("script")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("style")) != 0:
        return 1
    return 0


# Should the element currently being dispatched be laid out as a generic block
# box? True when (a) it is a direct child of an active flex container (flex-item
# blockification -> a column) or (b) its effective display is flex/block/
# inline-block -- provided it is not a dedicated-handler tag (see _blk_dedicated).
def _generic_block_wanted(a: uint64, n: uint64) -> int32:
    fitem: int32 = 0
    if _flex_item_col(el_sp) >= 0:
        fitem = 1
    if _blk_dedicated(a, n) != 0:
        # A DIRECT <a>/<li> child of an active flex row still columnises (the
        # canonical `<nav style=flex><a>…` / `<ul style=flex><li>…` navbar): the
        # generic-block path opens its column box, and the link/marker hook there
        # re-adds the href / bullet so link + list semantics survive. Every other
        # dedicated-handler tag stays dedicated (tables, headings, forms, …).
        if fitem != 0 and (_name_eq(a, n, cast[Ptr[uint8]]("a")) != 0 or \
                           _name_eq(a, n, cast[Ptr[uint8]]("li")) != 0):
            return 1
        return 0
    if fitem != 0:
        return 1
    if g_eff_disp == 2 or g_eff_disp == 3 or g_eff_disp == 4 or g_eff_disp == 6:
        return 1
    return 0


# Pre-scan the source from `after` (just past a flex container's '>') to its
# matching close tag, counting the number of DIRECT-CHILD block boxes (the flex
# items). Depth tracks nesting of the same block set; a direct child is one
# opened at relative depth 0. Returns the child count.
def _flex_count_children(after: uint64) -> int32:
    depth: int32 = 0
    n: int32 = 0
    i: uint64 = after
    while i < src_len:
        if src_ptr[i] != 60:                         # not '<'
            i = i + 1
            continue
        j: uint64 = i + 1
        closing: int32 = 0
        if j < src_len and src_ptr[j] == 47:         # '/'
            closing = 1
            j = j + 1
        ns: uint64 = j
        while j < src_len and _alnum_at(j) != 0:
            j = j + 1
        blk: int32 = _is_flexblk(ns, j)
        # advance to this tag's '>'
        k: uint64 = j
        while k < src_len and src_ptr[k] != 62:
            k = k + 1
        selfclose: int32 = 0
        if k > 0 and src_ptr[k - 1] == 47:
            selfclose = 1
        if closing == 0:
            if blk != 0:
                if depth == 0:
                    n = n + 1
                if selfclose == 0:
                    depth = depth + 1
        else:
            if blk != 0:
                if depth == 0:
                    return n                          # container's own close
                depth = depth - 1
        if k < src_len:
            i = k + 1
        else:
            i = k
    return n


# Measure the NATURAL content width (px) of each direct-child flex item, filling
# flex_meas_w[0..nc). A child's natural width is its collapsed visible-text run
# length in the CELL_W grid (the same grid the renderer places text on), so a
# nav link "Home" measures 4*CELL_W. Nested tag structure is skipped; interior
# whitespace collapses to one space; leading/trailing space is dropped. Returns
# the summed natural width of all children (0 if nothing measurable).
def _flex_measure_children(after: uint64, nc: int32) -> int32:
    depth: int32 = 0
    ci: int32 = -1                    # current direct-child index (-1 none open)
    chars: int32 = 0                  # visible chars in the current child
    pend_sp: int32 = 0                # a collapsed space is pending before next word
    total: int32 = 0
    i: uint64 = after
    while i < src_len:
        c: uint8 = src_ptr[i]
        if c == 60:                                  # '<'
            j: uint64 = i + 1
            closing: int32 = 0
            if j < src_len and src_ptr[j] == 47:     # '/'
                closing = 1
                j = j + 1
            ns: uint64 = j
            while j < src_len and _alnum_at(j) != 0:
                j = j + 1
            blk: int32 = _is_flexblk(ns, j)
            k: uint64 = j
            while k < src_len and src_ptr[k] != 62:  # '>'
                k = k + 1
            selfclose: int32 = 0
            if k > 0 and src_ptr[k - 1] == 47:
                selfclose = 1
            if closing == 0:
                if blk != 0:
                    if depth == 0:
                        ci = ci + 1                  # a new direct child opens
                        chars = 0
                        pend_sp = 0
                    if selfclose == 0:
                        depth = depth + 1
            else:
                if blk != 0:
                    if depth == 0:
                        return total                 # container's own close
                    depth = depth - 1
                    if depth == 0 and ci >= 0 and ci < nc:
                        w: int32 = chars * CELL_W
                        flex_meas_w[ci] = w
                        total = total + w
            if k < src_len:
                i = k + 1
            else:
                i = k
            continue
        if depth >= 1 and ci >= 0:
            if c == 32 or c == 9 or c == 10 or c == 13:
                if chars > 0:
                    pend_sp = 1
            else:
                if pend_sp != 0:
                    chars = chars + 1
                    pend_sp = 0
                chars = chars + 1
        i = i + 1
    return total


# Distribute the free space of a natural-width flex row per justify-content,
# writing each child's x offset (from flex_left) into flex_child_x[frame*..+col]
# and its width into flex_child_w. `just` is g_flex_just (1..5). Widths are read
# from flex_meas_w[0..nc). Free = avail - sum(widths).
def _flex_layout_natural(frame: int32, nc: int32, avail: int32, just: int32, \
                         gp: int32):
    base: int32 = frame * FLEX_MAX
    sumw: int32 = 0
    c: int32 = 0
    while c < nc:
        sumw = sumw + flex_meas_w[c]
        c = c + 1
    free: int32 = avail - sumw
    if free < 0:
        free = 0
    lead: int32 = 0                # x of the first item
    step_extra: int32 = gp         # inter-item gap beyond each item's width
    if just == 1:                                    # flex-start
        lead = 0
    elif just == 2:                                  # center
        lead = (free - (nc - 1) * gp) / 2
        if lead < 0:
            lead = 0
    elif just == 3:                                  # flex-end
        lead = free - (nc - 1) * gp
        if lead < 0:
            lead = 0
    elif just == 4:                                  # space-between
        lead = 0
        if nc > 1:
            step_extra = free / (nc - 1)
        else:
            lead = free / 2
    elif just == 5:                                  # space-around
        gap: int32 = free / nc
        lead = gap / 2
        step_extra = gap
    x: int32 = lead
    c = 0
    while c < nc:
        flex_child_x[base + c] = x
        flex_child_w[base + c] = flex_meas_w[c]
        x = x + flex_meas_w[c] + step_extra
        c = c + 1


# Resolve a grid frame's TRACK x-positions + widths into the shared flex_child_x/
# flex_child_w[frame*FLEX_MAX + c] from the parsed grid-template-columns encoding
# (g_grid_n tracks, g_grid_enc[c] >= 0 => fixed px; < 0 => fr weight negated).
# `avail` is the container content width, `gp` the column-gap. The fr tracks share
# the free space left after the fixed tracks and the (nt-1) gaps, split by weight.
# Returns the resolved track count (0 if nothing to resolve).
def _grid_resolve_tracks(frame: int32, avail: int32, gp: int32) -> int32:
    nt: int32 = g_grid_n
    if nt > GRID_MAXTRACK:
        nt = GRID_MAXTRACK
    if nt < 1:
        return 0
    sumfix: int32 = 0
    sumfr:  int32 = 0
    c: int32 = 0
    while c < nt:
        e: int32 = g_grid_enc[c]
        if e >= 0:
            sumfix = sumfix + e
        else:
            sumfr = sumfr - e                        # -e = fr weight
        c = c + 1
    free: int32 = avail - sumfix - (nt - 1) * gp
    if free < 0:
        free = 0
    base: int32 = frame * FLEX_MAX
    x: int32 = 0
    c = 0
    while c < nt:
        e2: int32 = g_grid_enc[c]
        w: int32 = 0
        if e2 >= 0:
            w = e2                                    # fixed px track
        else:
            if sumfr > 0:
                w = free * (-e2) / sumfr              # fr share of free space
        if w < CELL_W:
            w = CELL_W
        flex_child_x[base + c] = x
        flex_child_w[base + c] = w
        x = x + w + gp
        c = c + 1
    return nt


# Fixed height (in whole character ROWS) of grid row `ridx` for frame `frame`,
# from the parsed grid-template-rows px stored in flex_growh (0 = content-sized:
# no explicit height, or a row past the template / an fr row). px -> rows rounds
# to nearest LINE_H, mirroring the row-gap conversion.
def _grid_row_h_rows(frame: int32, ridx: int32) -> int32:
    if ridx >= flex_gridrn[frame]:
        return 0
    px: int32 = flex_growh[frame * FLEX_MAX + ridx]
    if px <= 0:
        return 0
    return (px + LINE_H / 2) / LINE_H


# Open a flex container: the box is already open (indent_x/blk_right_cur set to
# the container's content column). Compute the equal column width from the
# child count and push a frame. `eldepth` is the el-stack depth of the container
# element (its direct children sit at eldepth+1). Returns 1 if a real flex row
# was armed, 0 to fall back to normal block stacking (too few/many columns or
# too little width per column). A `display:grid` container (g_flex_grid) reuses
# this same frame in the fixed-track auto-placement model.
def _flex_container_open(content_after: uint64, eldepth: int32) -> int32:
    if flex_sp >= FLEX_MAX:
        return 0
    # flex-direction: column stacks children vertically -- that IS the default
    # block flow, so DON'T arm a horizontal column row; fall back to block
    # stacking (each child a normal full-width block). Only row flex columnises.
    # (grid ignores flex-direction — a grid always lays out in tracks.)
    if g_flex_grid == 0 and g_flex_dir == 1:
        return 0
    nc: int32 = _flex_count_children(content_after)
    if nc < 2:
        return 0
    # A flex row is capped at FLEX_MAX columns; a grid auto-places many items into
    # a fixed track count, so it allows up to GRID_MAXITEM children per container.
    if g_flex_grid == 0 and nc > FLEX_MAX:
        return 0
    if g_flex_grid != 0 and nc > GRID_MAXITEM:
        return 0
    left0: int32 = indent_x
    right0: int32 = blk_right_cur
    if right0 <= 0:
        right0 = _content_right()
    avail: int32 = right0 - left0
    # Inter-column gutter: an author `gap`/`column-gap` overrides the default.
    gp: int32 = FLEX_GAP
    if g_flex_gap >= 0:
        gp = g_flex_gap
    # NATURAL-width path: an EXPLICIT justify-content whose children's natural
    # content widths fit the row gets real free-space distribution (nav bars,
    # button/chip rows). Falls through to the equal-column approximation when the
    # items overflow (content-heavy flex: article beside infobox) or no explicit
    # justify was given (preserves the legacy spread).
    use_nat: int32 = 0
    use_wrap: int32 = 0
    use_grid: int32 = 0
    nt: int32 = 0
    # GRID path: `display:grid` resolves grid-template-columns into fixed track
    # widths (fr distributing free space) up front; items auto-place into those
    # tracks and wrap to the next row every `nt` items. A grid with no parseable
    # template falls back to normal block stacking.
    if g_flex_grid != 0:
        nt = _grid_resolve_tracks(flex_sp, avail, gp)
        if nt < 1:
            return 0
        use_grid = 1
    elif g_flex_wrap != 0:
        # WRAP path: `flex-wrap:wrap` places items ONLINE and wraps overflow onto
        # new lines. Pre-measure natural content widths so width-less items (nav
        # pills) size to content; items with an explicit CSS width use it.
        _flex_measure_children(content_after, nc)
        use_wrap = 1
    elif g_flex_just != 0:
        tot: int32 = _flex_measure_children(content_after, nc)
        if tot > 0 and tot + (nc - 1) * gp <= avail:
            _flex_layout_natural(flex_sp, nc, avail, g_flex_just, gp)
            use_nat = 1
    colw: int32 = (avail - (nc - 1) * gp) / nc
    if use_nat == 0 and use_wrap == 0 and use_grid == 0 and \
       colw < 6 * CELL_W:                            # columns too narrow
        return 0
    flex_top_row[flex_sp] = cast[int32](cur_row)
    flex_max_bot[flex_sp] = cast[int32](cur_row)
    flex_left[flex_sp]    = left0
    flex_colw[flex_sp]    = colw
    flex_gap[flex_sp]     = colw + gp
    flex_ncol[flex_sp]    = nc
    flex_next[flex_sp]    = 0
    flex_eldepth[flex_sp] = eldepth
    flex_natural[flex_sp] = use_nat
    flex_wrap_on[flex_sp] = use_wrap
    flex_grid[flex_sp]    = use_grid
    flex_ntrack[flex_sp]  = nt
    flex_avail[flex_sp]   = avail
    flex_rawgap[flex_sp]  = gp
    # row-gap: whole LINE_H rows between wrapped flex lines (rounded to nearest).
    rgr: int32 = 0
    if g_flex_rowgap > 0:
        rgr = (g_flex_rowgap + LINE_H / 2) / LINE_H
    flex_rowgap[flex_sp] = rgr
    flex_cur_x[flex_sp]   = 0
    flex_line_top[flex_sp] = cast[int32](cur_row)
    flex_line_bot[flex_sp] = cast[int32](cur_row)
    # Grid auto-flow cursor + explicit-row-height state (all no-ops for non-grid).
    flex_gcur[flex_sp]    = 0
    flex_growidx[flex_sp] = 0
    flex_gridrn[flex_sp]  = 0
    if use_grid != 0:
        nr: int32 = g_grid_rn
        if nr > GRID_MAXTRACK:
            nr = GRID_MAXTRACK
        flex_gridrn[flex_sp] = nr
        rr: int32 = 0
        while rr < nr:
            hpx: int32 = g_grid_renc[rr]
            if hpx < 0:
                hpx = 0                              # fr rows stay content-sized
            flex_growh[flex_sp * FLEX_MAX + rr] = hpx
            rr = rr + 1
        # A fixed row-0 height makes the first row occupy its track height even if
        # its content is shorter (the row is a floor; taller content still grows).
        h0: int32 = _grid_row_h_rows(flex_sp, 0)
        if h0 > 0:
            flex_line_bot[flex_sp] = flex_line_top[flex_sp] + h0
            if flex_line_bot[flex_sp] > flex_max_bot[flex_sp]:
                flex_max_bot[flex_sp] = flex_line_bot[flex_sp]
    # align-items: only 2 (center) / 3 (flex-end) / 4 (stretch) arm the deferred
    # cross-axis fixup; 0/1 (unset / flex-start) keep the byte-identical top-align.
    # NEVER armed for a grid (its item count can exceed FLEX_MAX, which the fixup's
    # per-column bookkeeping arrays do not size for) — grid rows stay top-aligned.
    fa: int32 = g_flex_align
    if fa < 2 or use_grid != 0:
        fa = 0
    flex_align[flex_sp] = fa
    flex_sp = flex_sp + 1
    return 1


# Would a block opening at el-stack depth `eldepth` be a direct child (flex
# item) of the current flex container? Returns the 0-based column index, or -1.
def _flex_item_col(eldepth: int32) -> int32:
    if flex_sp <= 0:
        return -1
    top: int32 = flex_sp - 1
    if eldepth != flex_eldepth[top] + 1:
        return -1
    if flex_next[top] >= flex_ncol[top]:
        return -1                                    # more children than counted
    return flex_next[top]


# Called on a flex item's close: record the column's bottom row into the frame's
# running max, then REWIND cur_row to the container top so the next sibling
# column starts level. pen/row state reset for the next column.
def _flex_item_close():
    top: int32 = flex_sp - 1
    if top < 0:
        return
    # Exclusive bottom (first free row): if the column left content on its
    # current row, that row is occupied, so the column's bottom is the row
    # BELOW it. Without the +1 a single-row column reports a zero-height span,
    # which collapses the container's background fill to nothing.
    bot: int32 = cast[int32](cur_row)
    if row_dirty != 0:
        bot = bot + 1
    if bot > flex_max_bot[top]:
        flex_max_bot[top] = bot
    # Cross-axis fixup: close this item's recorded seg/fill/border ranges (the box
    # background + border were already emitted by the preceding _block_box_close),
    # and stamp its bottom row. Only armed for align-items >= center. Commit any
    # still-open trailing text segment FIRST — a segment reserves seg_line at open
    # but only bumps n_segs at _close_seg, so an uncommitted tail would fall past
    # the recorded [seg0,seg1) range and escape the cross-axis shift.
    if flex_align[top] >= 2 and flex_next[top] < FLEX_MAX:
        _word_flush()
        _close_seg()
        fidx1: int32 = top * FLEX_MAX + flex_next[top]
        flex_it_seg1[fidx1] = cast[int32](n_segs)
        flex_it_bf1[fidx1]  = n_bfills
        flex_it_bx1[fidx1]  = n_bboxes
        flex_it_bot[fidx1]  = bot
    flex_next[top] = flex_next[top] + 1
    # WRAP/GRID: this item belongs to the current line/row — grow the line's
    # bottom and rewind to the LINE top (so the next item on the same line starts
    # level; a grid row advance is triggered at the next item's open).
    if flex_wrap_on[top] != 0 or flex_grid[top] != 0:
        if bot > flex_line_bot[top]:
            flex_line_bot[top] = bot
        cur_row = cast[uint64](flex_line_top[top])
    else:
        cur_row = cast[uint64](flex_top_row[top])
    pen_x = indent_x
    row_dirty = 0
    need_space = 0


# Shift one flex item's already-emitted segments/fills/borders DOWN by `dy` rows
# (center / flex-end cross-axis alignment). Rows clamp into [0, MAX_ROWS) and grow
# total_rows, mirroring _apply_positioned's relocation.
def _flex_shift_item(fidx: int32, dy: int32):
    if dy <= 0:
        return
    j: int32 = flex_it_seg0[fidx]
    s1: int32 = flex_it_seg1[fidx]
    while j < s1:
        nr: int32 = seg_line[j] + dy
        if cast[uint64](nr) >= MAX_ROWS:
            nr = cast[int32](MAX_ROWS) - 1
        seg_line[j] = nr
        if cast[uint64](nr) + 1 > total_rows:
            total_rows = cast[uint64](nr) + 1
        j = j + 1
    bf: int32 = flex_it_bf0[fidx]
    bf1: int32 = flex_it_bf1[fidx]
    while bf < bf1:
        bfill_top[bf] = bfill_top[bf] + dy
        bfill_bot[bf] = bfill_bot[bf] + dy
        bf = bf + 1
    bx: int32 = flex_it_bx0[fidx]
    bx1: int32 = flex_it_bx1[fidx]
    while bx < bx1:
        bbox_top[bx] = bbox_top[bx] + dy
        bbox_bot[bx] = bbox_bot[bx] + dy
        bx = bx + 1


# STRETCH one flex item: content stays top-aligned, but the item's OWN box
# background fill + border (the fill spanning exactly [ltop, item_bot) over the
# whole column) grows to the line's cross-axis extent `line_bot`.
def _flex_stretch_item(fidx: int32, line_bot: int32):
    ltop: int32 = flex_it_ltop[fidx]
    ibot: int32 = flex_it_bot[fidx]
    if line_bot <= ibot:
        return
    bf: int32 = flex_it_bf0[fidx]
    bf1: int32 = flex_it_bf1[fidx]
    while bf < bf1:
        if bfill_top[bf] == ltop and bfill_bot[bf] == ibot:
            bfill_bot[bf] = line_bot
        bf = bf + 1
    bx: int32 = flex_it_bx0[fidx]
    bx1: int32 = flex_it_bx1[fidx]
    while bx < bx1:
        if bbox_top[bx] == ltop - 1 and bbox_bot[bx] == ibot:
            bbox_bot[bx] = line_bot
        bx = bx + 1


# Deferred cross-axis (align-items) fixup, run at container close once every
# item's line-top/bottom is known. For each item, the line's cross extent is the
# tallest item sharing its line-top (so single-line AND wrapped lines both work);
# center/flex-end offset the item down within that extent, stretch grows its box.
def _flex_align_fixup(top: int32):
    mode: int32 = flex_align[top]
    if mode < 2:
        return
    nc: int32 = flex_next[top]
    if nc > flex_ncol[top]:
        nc = flex_ncol[top]
    c: int32 = 0
    while c < nc:
        fidx: int32 = top * FLEX_MAX + c
        ltop: int32 = flex_it_ltop[fidx]
        line_bot: int32 = flex_it_bot[fidx]
        k: int32 = 0
        while k < nc:
            kidx: int32 = top * FLEX_MAX + k
            if flex_it_ltop[kidx] == ltop and flex_it_bot[kidx] > line_bot:
                line_bot = flex_it_bot[kidx]
            k = k + 1
        line_h: int32 = line_bot - ltop
        item_h: int32 = flex_it_bot[fidx] - ltop
        if mode == 4:
            _flex_stretch_item(fidx, line_bot)
        elif mode == 2:
            _flex_shift_item(fidx, (line_h - item_h) / 2)
        elif mode == 3:
            _flex_shift_item(fidx, line_h - item_h)
        c = c + 1


# Called on a flex container's close (BEFORE its box closes): drop cur_row to the
# tallest column so the container spans the full flex-row height, then pop the
# frame.
def _flex_container_close():
    top: int32 = flex_sp - 1
    if top < 0:
        return
    _flex_align_fixup(top)
    if flex_max_bot[top] > cast[int32](cur_row):
        cur_row = cast[uint64](flex_max_bot[top])
    flex_sp = flex_sp - 1
    pen_x = indent_x
    row_dirty = 0


# ---- CSS inline-block (inline-level box flow) -------------------------------
# Void (self-closing) tags never open a nesting scope; used by the inline-block
# text measurer so its depth counter is not thrown off by <br>/<img>/<input>.
def _is_void_name(a: uint64, n: uint64) -> int32:
    if _name_eq(a, n, cast[Ptr[uint8]]("br")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("hr")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("img")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("input")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("meta")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("link")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("area")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("col")) != 0:
        return 1
    return 0


# Which tags get inline-block INLINE-FLOW treatment (a chip/badge/button/pill)
# rather than the generic block-box blockification. Restricted to inline-level
# and neutral containers; dedicated block machinery (tables/lists/headings/
# forms/pre) keeps its own layout even under `display:inline-block`.
def _inlb_tag(a: uint64, n: uint64) -> int32:
    if _name_eq(a, n, cast[Ptr[uint8]]("span")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("font")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("a")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("small")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("b")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("strong")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("em")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("i")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("label")) != 0 or \
       _name_eq(a, n, cast[Ptr[uint8]]("div")) != 0:
        return 1
    return 0


# Collapsed visible-text width (px, CELL_W grid) of an inline-block element whose
# content starts at `after` (just past its opening '>'), stopping at the element's
# matching close tag. Interior whitespace collapses to one space; leading/trailing
# space is dropped. Nested tag structure is skipped (only its text counts).
def _inlb_text_w(after: uint64) -> int32:
    depth: int32 = 0
    chars: int32 = 0
    pend: int32 = 0
    i: uint64 = after
    while i < src_len:
        c: uint8 = src_ptr[i]
        if c == 60:                                  # '<'
            j: uint64 = i + 1
            closing: int32 = 0
            if j < src_len and src_ptr[j] == 47:     # '/'
                closing = 1
                j = j + 1
            ns: uint64 = j
            while j < src_len and _alnum_at(j) != 0:
                j = j + 1
            k: uint64 = j
            while k < src_len and src_ptr[k] != 62:  # '>'
                k = k + 1
            selfclose: int32 = 0
            if k > 0 and src_ptr[k - 1] == 47:
                selfclose = 1
            if closing != 0:
                if depth == 0:
                    return chars * CELL_W             # this element's own close
                depth = depth - 1
            else:
                if selfclose == 0 and _is_void_name(ns, j) == 0:
                    depth = depth + 1
            if k < src_len:
                i = k + 1
            else:
                i = k
            continue
        if c == 32 or c == 9 or c == 10 or c == 13:
            if chars > 0:
                pend = 1
        else:
            if pend != 0:
                chars = chars + 1
                pend = 0
            chars = chars + 1
        i = i + 1
    return chars * CELL_W


# Open an inline-block chip: place any pending text, wrap the whole box to a
# fresh line if it would overflow, push the element's style, paint the box's
# background FILL, then inset the pen by the left padding so its text flows
# inside the box. The chip's own text streams normally into the following segs.
def _inlb_open(ne: uint64, te: uint64, np: uint64, nlen: uint64):
    _word_flush()
    _close_seg()
    tw: int32 = _inlb_text_w(te + 1)
    boxw: int32 = tw + 2 * INLB_PADX
    right: int32 = _flow_right()
    # Wrap the whole chip to the next line if it does not fit after current flow.
    if pen_x > indent_x and pen_x + boxw > right:
        _bump_row()
        _maybe_clear_float()
        pen_x = indent_x
        row_dirty = 0
        need_space = 0
    _open_style(ne, te)                              # pushes colour + background
    _recompute_style()
    startx: int32 = pen_x
    row0: int32 = cast[int32](cur_row)
    # Vertical box growth: honour top+bottom padding (the badge/button/pill idiom)
    # so a chip is a real BOX, not one text-line tall. The resolved cascade/inline
    # top+bottom insets (m_mt/m_mb, d_mt/d_mb overriding) grow the box; the single
    # text line is centred within it and the box reserves the extra whole rows so
    # following content clears it. One-row chips (no vertical padding) are byte-
    # identical to before: boxrows stays 1 and every guard below short-circuits.
    padt: int32 = 0
    if m_mt > 0:
        padt = m_mt
    if d_mt > 0:
        padt = d_mt
    padb: int32 = 0
    if m_mb > 0:
        padb = m_mb
    if d_mb > 0:
        padb = d_mb
    boxrows: int32 = 1
    chip_yoff: int32 = 0
    if padt + padb > 0:
        boxh: int32 = LINE_H + padt + padb
        boxrows = (boxh + LINE_H - 1) / LINE_H
        if boxrows > 8:
            boxrows = 8
        chip_yoff = (boxrows - 1) * LINE_H / 2       # centre the text line
    if inlb_sp < INLB_MAX:
        inlb_startx[inlb_sp]  = startx
        inlb_boxw[inlb_sp]    = boxw
        inlb_row[inlb_sp]     = row0
        inlb_eldepth[inlb_sp] = el_sp
        inlb_yoff[inlb_sp]    = chip_yoff
        inlb_sp = inlb_sp + 1
    # A tall chip reserves the rows below it: the next line break snaps past them.
    if boxrows > 1 and row0 + boxrows > g_inlb_floor:
        g_inlb_floor = row0 + boxrows
    # Paint the chip box (a narrow FILL over exactly its box, boxrows tall).
    if g_bg >= 0 and n_bfills < BFILL_MAX and row0 < MAX_ROWS:
        bfill_lx[n_bfills]  = startx
        bfill_rx[n_bfills]  = startx + boxw
        bfill_top[n_bfills] = row0
        bfill_bot[n_bfills] = row0 + boxrows
        bfill_rgb[n_bfills] = g_bg
        bfill_z[n_bfills]   = 0
        n_bfills = n_bfills + 1
    # Drop the text baseline to the vertical centre of a tall box.
    g_yoff = g_yoff + chip_yoff
    # A chip that is an <a> keeps its href + own link colour (clickable pill).
    if _name_eq(np, nlen, cast[Ptr[uint8]]("a")) != 0:
        g_link = _capture_href(ne, te)
        g_link_rgb = _own_color(ne, te)
        _recompute_style()
    pen_x = startx + INLB_PADX
    need_space = 0
    row_dirty = 1


# Close an inline-block chip: snap the pen to the box's right edge + gutter so
# the next inline content flows after it, then pop the element's style.
def _inlb_close(np: uint64, nlen: uint64):
    _word_flush()
    _close_seg()
    if inlb_sp > 0:
        inlb_sp = inlb_sp - 1
        pen_x = inlb_startx[inlb_sp] + inlb_boxw[inlb_sp] + INLB_GAP
        g_yoff = g_yoff - inlb_yoff[inlb_sp]         # undo the tall-chip centring
    if _name_eq(np, nlen, cast[Ptr[uint8]]("a")) != 0:
        g_link = -1
        g_link_rgb = -1
    _close_style()
    _recompute_style()
    need_space = 0
    row_dirty = 1


# The right edge the current flow wraps against: a table cell clamps to its
# column, everything else to the content area.
def _flow_right() -> int32:
    r: int32 = _content_right()
    # A block width / right margin / padding shrinks the wrap boundary.
    if blk_right_cur > 0 and blk_right_cur < r:
        r = blk_right_cur
    # A right-floated box excludes its column: body text wraps to its left for
    # every row above the float's bottom.
    if float_active != 0 and float_side == 2 and \
       cast[int32](cur_row) < float_bottom and float_redge < r:
        if float_redge > indent_x + CELL_W:
            r = float_redge
    if cell_active != 0:
        cr: int32 = cell_right
        if cr > r:
            cr = r
        if cr < indent_x + CELL_W:
            cr = indent_x + CELL_W
        return cr
    return r


# ---- PIXEL-MEASURE line-break hook ----------------------------------
# The engine stays PURE (no font/htmlpaint import): the pixel front-end
# registers a callback that returns the real TrueType advance width (px) of the
# pending run, so the line-breaker can wrap prose to the true viewport measure
# instead of the 8px monospace CHARACTER GRID. When NO hook is registered the
# breaker falls back to CELL_W cells, so the legacy monospace-grid dump
# (user/hambrowse_host.ad) stays byte-for-byte identical. The hook reads the
# pending run through the he_meas_* accessors below (same globals-passing seam
# jsengine uses for host dispatch — Adder has no multi-arg Fn convention here).
#
# GRID segments (tables + <pre>) always use CELL_W so their absolute columns
# survive regardless of the hook — real reflow is prose-only.
he_meas_set:  int32 = 0
he_meas_addr: uint64 = 0
he_meas_face: uint8 = 0
he_meas_bold: int32 = 0
he_meas_px:   int32 = 0
he_meas_txt:  Ptr[uint8] = 0
he_meas_len:  int32 = 0
_he_sp_buf:   Array[1, uint8]        # one-space scratch for space-advance query


def he_set_measure_hook(fn: Fn[int32, int32]):
    he_meas_addr = cast[uint64](fn)
    he_meas_set = 1


def he_clear_measure_hook():
    he_meas_set = 0


# Accessors the registered hook reads to learn the pending run + its style.
def he_meas_face_get() -> uint8:
    return he_meas_face


def he_meas_bold_get() -> int32:
    return he_meas_bold


def he_meas_px_get() -> int32:
    return he_meas_px


def he_meas_txt_get() -> Ptr[uint8]:
    return he_meas_txt


def he_meas_len_get() -> int32:
    return he_meas_len


# Pixel width of a run in the CURRENT inline style. Falls back to CELL_W cells
# when no hook is set OR the run is grid-positioned (table/<pre>), so those keep
# their absolute char-grid columns.
def _run_px(ptr: Ptr[uint8], ln: uint64) -> int32:
    if he_meas_set == 0 or table_active != 0 or pre_mode != 0 or ln == 0:
        return cast[int32](ln) * CELL_W
    he_meas_face = _cur_face()
    he_meas_bold = g_bold
    he_meas_px   = g_font_px
    he_meas_txt  = ptr
    he_meas_len  = cast[int32](ln)
    hf: Fn[int32, int32] = cast[Fn[int32, int32]](he_meas_addr)
    w: int32 = hf(0)
    if w < 1:
        w = 1
    return w


# Pixel advance of a single inter-word space in the current style.
def _space_px() -> int32:
    if he_meas_set == 0 or table_active != 0 or pre_mode != 0:
        return CELL_W
    _he_sp_buf[0] = 32
    return _run_px(&_he_sp_buf[0], 1)


# ---- word placement (block+inline flow with word wrap) --------------
def _emit_word(wptr: Ptr[uint8], wlen: uint64):
    if wlen == 0:
        return
    right: int32 = _flow_right()
    avail: int32 = right - indent_x
    wpx: int32 = _run_px(wptr, wlen)
    spx: int32 = _space_px()
    # CSS white-space:nowrap / white-space:pre (g_ws 1 / 2) suppress ALL soft
    # wrapping — the line runs past the measure and overflows. (The <pre>/<code>
    # ELEMENT keeps its own grid path; this only fires for the CSS property.)
    ws_nowrap: int32 = 0
    if g_ws == 1 or g_ws == 2:
        ws_nowrap = 1
    # Decide a word-wrap (only when the word fits on a fresh line).
    if pen_x > indent_x and ws_nowrap == 0:
        extra: int32 = wpx
        if need_space != 0:
            extra = extra + spx
        if pen_x + extra > right and wpx <= avail:
            _close_seg()
            _bump_row()
            _maybe_clear_float()
            right = _flow_right()
            avail = right - indent_x
            pen_x = indent_x
            need_space = 0
            row_dirty = 0
    # Inter-word space.
    if need_space != 0 and pen_x > indent_x:
        _seg_putc(32)
        pen_x = pen_x + spx
        need_space = 0
    # A word longer than a whole line: hard char-break it (measured per glyph).
    # Suppressed under nowrap/pre — the run must overflow the measure intact.
    if wpx > avail and ws_nowrap == 0:
        k: uint64 = 0
        while k < wlen:
            cpx: int32 = _run_px(&wptr[k], 1)
            if pen_x + cpx > right and pen_x > indent_x:
                _close_seg()
                _bump_row()
                _maybe_clear_float()
                right = _flow_right()
                pen_x = indent_x
                row_dirty = 0
            _seg_putc(wptr[k])
            pen_x = pen_x + cpx
            k = k + 1
        need_space = 0
        return
    # Normal: whole word into the current segment.
    k2: uint64 = 0
    while k2 < wlen:
        _seg_putc(wptr[k2])
        k2 = k2 + 1
    pen_x = pen_x + wpx
    need_space = 0


def _word_push(c: uint8):
    if word_len < WORD_CAP - 1:
        word_buf[word_len] = c
        word_len = word_len + 1


def _word_flush():
    if word_len > 0:
        _emit_word(&word_buf[0], word_len)
        word_len = 0


# ====================================================================
# ENTITY DECODE — &name; / &#NN; / &#xHH;.  Returns bytes consumed from
# src starting at `&` (0 if not a recognised entity), and sets g_ent_char.
# ====================================================================
def _ent_named_is(start: uint64, lit: Ptr[uint8]) -> int32:
    # `lit` already includes the trailing ';' — a full match consumes it.
    i: uint64 = 0
    while lit[i] != 0:
        if start + i >= src_len:
            return 0
        if src_ptr[start + i] != lit[i]:
            return 0
        i = i + 1
    return cast[int32](i)


# Encode one Unicode code point into g_ent_buf as UTF-8; sets g_ent_len.
# (The renderer already emits UTF-8 text, so decoded entities go out as UTF-8.)
def _ent_emit_cp(cp: uint32):
    if cp == 0:
        cp = 63                                       # NUL -> '?'
    if cp < 0x80:
        g_ent_buf[0] = cast[uint8](cp)
        g_ent_len = 1
    elif cp < 0x800:
        g_ent_buf[0] = cast[uint8](0xC0 | (cp >> 6))
        g_ent_buf[1] = cast[uint8](0x80 | (cp & 0x3F))
        g_ent_len = 2
    elif cp < 0x10000:
        g_ent_buf[0] = cast[uint8](0xE0 | (cp >> 12))
        g_ent_buf[1] = cast[uint8](0x80 | ((cp >> 6) & 0x3F))
        g_ent_buf[2] = cast[uint8](0x80 | (cp & 0x3F))
        g_ent_len = 3
    else:
        g_ent_buf[0] = cast[uint8](0xF0 | (cp >> 18))
        g_ent_buf[1] = cast[uint8](0x80 | ((cp >> 12) & 0x3F))
        g_ent_buf[2] = cast[uint8](0x80 | ((cp >> 6) & 0x3F))
        g_ent_buf[3] = cast[uint8](0x80 | (cp & 0x3F))
        g_ent_len = 4


# If src at `body` matches the named-entity literal `lit` (trailing ';'
# included), emit code point `cp` and return the bytes consumed AFTER the '&'
# (i.e. len(lit)); otherwise return 0.
def _ent_try(body: uint64, lit: Ptr[uint8], cp: uint32) -> uint64:
    n: int32 = _ent_named_is(body, lit)
    if n > 0:
        _ent_emit_cp(cp)
        return cast[uint64](n)
    return 0


def _entity(at: uint64) -> uint64:
    # `at` points at '&'. On success fills g_ent_buf/g_ent_len with the decoded
    # UTF-8 bytes and returns the number of source bytes consumed (including the
    # '&' and any trailing ';'). Returns 0 for a bare/unknown '&' — the caller
    # then passes the '&' through unchanged.
    body: uint64 = at + 1
    if body >= src_len:
        return 0
    if src_ptr[body] == 35:                          # '#': numeric
        p: uint64 = body + 1
        base: uint32 = 10
        if p < src_len and (src_ptr[p] == 120 or src_ptr[p] == 88):   # x/X
            base = 16
            p = p + 1
        val: uint32 = 0
        digits: int32 = 0
        while p < src_len and digits < 8:
            c: uint8 = src_ptr[p]
            d: int32 = -1
            if c >= 48 and c <= 57:
                d = cast[int32](c - 48)
            elif base == 16 and c >= 97 and c <= 102:
                d = cast[int32](c - 97) + 10
            elif base == 16 and c >= 65 and c <= 70:
                d = cast[int32](c - 65) + 10
            else:
                break
            val = val * base + cast[uint32](d)
            digits = digits + 1
            p = p + 1
        if digits == 0:
            return 0
        if p < src_len and src_ptr[p] == 59:
            p = p + 1
        _ent_emit_cp(val)
        return p - at
    # Named entities. Each literal carries its trailing ';', so a match consumes
    # it; unknown names fall through and the '&' is emitted literally.
    r: uint64 = 0
    r = _ent_try(body, cast[Ptr[uint8]]("amp;"), 38)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("lt;"), 60)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("gt;"), 62)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("quot;"), 34)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("apos;"), 39)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("nbsp;"), 32)   # -> normal space
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("copy;"), 0xA9)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("reg;"), 0xAE)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("trade;"), 0x2122)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("mdash;"), 0x2014)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ndash;"), 0x2013)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("hellip;"), 0x2026)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("lsquo;"), 0x2018)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("rsquo;"), 0x2019)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ldquo;"), 0x201C)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("rdquo;"), 0x201D)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("middot;"), 0xB7)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("deg;"), 0xB0)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("times;"), 0xD7)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("divide;"), 0xF7)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("bull;"), 0x2022)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("dagger;"), 0x2020)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("laquo;"), 0xAB)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("raquo;"), 0xBB)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("euro;"), 0x20AC)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("pound;"), 0xA3)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("cent;"), 0xA2)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("yen;"), 0xA5)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("sect;"), 0xA7)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("para;"), 0xB6)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("plusmn;"), 0xB1)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("micro;"), 0xB5)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("frac12;"), 0xBD)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("frac14;"), 0xBC)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("frac34;"), 0xBE)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("sup2;"), 0xB2)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("sup3;"), 0xB3)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("szlig;"), 0xDF)
    if r == 0:
        return 0
    return 1 + r                                      # +1 for the leading '&'


# ====================================================================
# COLOUR PARSING — extract a text colour from a tag body src[ts..te).
# Handles  style="…color:VALUE…"  and  color="VALUE" / color=VALUE
# (the <font> attribute). VALUE is #rgb, #rrggbb, or a named colour.
# Returns packed 0xRRGGBB, or -1 if none / unparseable.
# ====================================================================
def _hexval(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return cast[int32](c - 48)
    lc: uint8 = _lower(c)
    if lc >= 97 and lc <= 102:
        return cast[int32](lc - 97) + 10
    return -1


# Compare src[at..] against a lowercase literal; returns 1 on full match.
def _srcword_is(at: uint64, lit: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while lit[i] != 0:
        if at + i >= src_len:
            return 0
        if _lower(src_ptr[at + i]) != lit[i]:
            return 0
        i = i + 1
    return 1


# Named colours (the CSS/HTML basics). Returns 0xRRGGBB or -1.
def _named_color(at: uint64) -> int32:
    if _srcword_is(at, cast[Ptr[uint8]]("black")) != 0:
        return 0x000000
    if _srcword_is(at, cast[Ptr[uint8]]("white")) != 0:
        return 0xffffff
    if _srcword_is(at, cast[Ptr[uint8]]("red")) != 0:
        return 0xff0000
    if _srcword_is(at, cast[Ptr[uint8]]("green")) != 0:
        return 0x008000
    if _srcword_is(at, cast[Ptr[uint8]]("lime")) != 0:
        return 0x00ff00
    if _srcword_is(at, cast[Ptr[uint8]]("blue")) != 0:
        return 0x0000ff
    if _srcword_is(at, cast[Ptr[uint8]]("navy")) != 0:
        return 0x000080
    if _srcword_is(at, cast[Ptr[uint8]]("teal")) != 0:
        return 0x008080
    if _srcword_is(at, cast[Ptr[uint8]]("aqua")) != 0:
        return 0x00ffff
    if _srcword_is(at, cast[Ptr[uint8]]("olive")) != 0:
        return 0x808000
    if _srcword_is(at, cast[Ptr[uint8]]("yellow")) != 0:
        return 0xffff00
    if _srcword_is(at, cast[Ptr[uint8]]("orange")) != 0:
        return 0xffa500
    if _srcword_is(at, cast[Ptr[uint8]]("purple")) != 0:
        return 0x800080
    if _srcword_is(at, cast[Ptr[uint8]]("fuchsia")) != 0:
        return 0xff00ff
    if _srcword_is(at, cast[Ptr[uint8]]("maroon")) != 0:
        return 0x800000
    if _srcword_is(at, cast[Ptr[uint8]]("silver")) != 0:
        return 0xc0c0c0
    if _srcword_is(at, cast[Ptr[uint8]]("gray")) != 0:
        return 0x808080
    if _srcword_is(at, cast[Ptr[uint8]]("grey")) != 0:
        return 0x808080
    # Extended CSS named colours common on hand-written pages.
    if _srcword_is(at, cast[Ptr[uint8]]("magenta")) != 0:
        return 0xff00ff
    if _srcword_is(at, cast[Ptr[uint8]]("cyan")) != 0:
        return 0x00ffff
    if _srcword_is(at, cast[Ptr[uint8]]("pink")) != 0:
        return 0xffc0cb
    if _srcword_is(at, cast[Ptr[uint8]]("brown")) != 0:
        return 0xa52a2a
    if _srcword_is(at, cast[Ptr[uint8]]("gold")) != 0:
        return 0xffd700
    if _srcword_is(at, cast[Ptr[uint8]]("indigo")) != 0:
        return 0x4b0082
    if _srcword_is(at, cast[Ptr[uint8]]("violet")) != 0:
        return 0xee82ee
    if _srcword_is(at, cast[Ptr[uint8]]("crimson")) != 0:
        return 0xdc143c
    if _srcword_is(at, cast[Ptr[uint8]]("coral")) != 0:
        return 0xff7f50
    if _srcword_is(at, cast[Ptr[uint8]]("salmon")) != 0:
        return 0xfa8072
    if _srcword_is(at, cast[Ptr[uint8]]("tomato")) != 0:
        return 0xff6347
    if _srcword_is(at, cast[Ptr[uint8]]("khaki")) != 0:
        return 0xf0e68c
    if _srcword_is(at, cast[Ptr[uint8]]("tan")) != 0:
        return 0xd2b48c
    if _srcword_is(at, cast[Ptr[uint8]]("turquoise")) != 0:
        return 0x40e0d0
    if _srcword_is(at, cast[Ptr[uint8]]("skyblue")) != 0:
        return 0x87ceeb
    if _srcword_is(at, cast[Ptr[uint8]]("darkblue")) != 0:
        return 0x00008b
    if _srcword_is(at, cast[Ptr[uint8]]("darkgreen")) != 0:
        return 0x006400
    if _srcword_is(at, cast[Ptr[uint8]]("darkred")) != 0:
        return 0x8b0000
    if _srcword_is(at, cast[Ptr[uint8]]("lightblue")) != 0:
        return 0xadd8e6
    if _srcword_is(at, cast[Ptr[uint8]]("lightgreen")) != 0:
        return 0x90ee90
    if _srcword_is(at, cast[Ptr[uint8]]("lightgray")) != 0:
        return 0xd3d3d3
    if _srcword_is(at, cast[Ptr[uint8]]("lightgrey")) != 0:
        return 0xd3d3d3
    if _srcword_is(at, cast[Ptr[uint8]]("darkgray")) != 0:
        return 0xa9a9a9
    if _srcword_is(at, cast[Ptr[uint8]]("darkgrey")) != 0:
        return 0xa9a9a9
    if _srcword_is(at, cast[Ptr[uint8]]("beige")) != 0:
        return 0xf5f5dc
    if _srcword_is(at, cast[Ptr[uint8]]("ivory")) != 0:
        return 0xfffff0
    if _srcword_is(at, cast[Ptr[uint8]]("lavender")) != 0:
        return 0xe6e6fa
    return -1


# Parse an `rgb(r,g,b)` / `rgb(r, g, b)` functional colour at src[at].
# Returns packed 0xRRGGBB, or -1 if not an rgb() form.
def _rgb_func(at: uint64) -> int32:
    if _srcword_is(at, cast[Ptr[uint8]]("rgb")) == 0:
        return -1
    j: uint64 = at + 3
    while j < src_len and (src_ptr[j] == 32 or src_ptr[j] == 9):
        j = j + 1
    if j >= src_len or src_ptr[j] != 40:             # '('
        return -1
    j = j + 1
    comp: int32 = 0
    parts: Array[3, int32]
    while comp < 3:
        while j < src_len and (src_ptr[j] == 32 or src_ptr[j] == 9):
            j = j + 1
        v: int32 = 0
        nd: int32 = 0
        while j < src_len and src_ptr[j] >= 48 and src_ptr[j] <= 57:
            v = v * 10 + cast[int32](src_ptr[j] - 48)
            nd = nd + 1
            j = j + 1
        if nd == 0:
            return -1
        # A percentage component scales 0..100 -> 0..255.
        if j < src_len and src_ptr[j] == 37:         # '%'
            v = v * 255 / 100
            j = j + 1
        if v > 255:
            v = 255
        parts[comp] = v
        comp = comp + 1
        while j < src_len and (src_ptr[j] == 32 or src_ptr[j] == 9):
            j = j + 1
        if comp < 3:
            if j < src_len and src_ptr[j] == 44:     # ','
                j = j + 1
    return (parts[0] * 65536) + (parts[1] * 256) + parts[2]


# Parse a colour VALUE starting at src[at]. Returns 0xRRGGBB or -1.
def _color_value(at: uint64) -> int32:
    if at >= src_len:
        return -1
    if src_ptr[at] == 114 or src_ptr[at] == 82:      # 'r'/'R' -> maybe rgb(
        rv: int32 = _rgb_func(at)
        if rv >= 0:
            return rv
    if src_ptr[at] == 35:                            # '#rgb' or '#rrggbb'
        # count hex digits
        p: uint64 = at + 1
        nd: int32 = 0
        while p < src_len and _hexval(src_ptr[p]) >= 0:
            nd = nd + 1
            p = p + 1
        if nd >= 6:
            r: int32 = _hexval(src_ptr[at + 1]) * 16 + _hexval(src_ptr[at + 2])
            g: int32 = _hexval(src_ptr[at + 3]) * 16 + _hexval(src_ptr[at + 4])
            b: int32 = _hexval(src_ptr[at + 5]) * 16 + _hexval(src_ptr[at + 6])
            return (r * 65536) + (g * 256) + b
        if nd >= 3:
            r3: int32 = _hexval(src_ptr[at + 1])
            g3: int32 = _hexval(src_ptr[at + 2])
            b3: int32 = _hexval(src_ptr[at + 3])
            return ((r3 * 16 + r3) * 65536) + ((g3 * 16 + g3) * 256) + \
                   (b3 * 16 + b3)
        return -1
    return _named_color(at)


# Find a text-colour value in the tag body [ts,te). Looks for a `color`
# keyword at a word boundary (so `bgcolor` is NOT matched) followed by ':'
# (style syntax) or '=' (attribute syntax), then parses the value.
def _tag_color(ts: uint64, te: uint64) -> int32:
    i: uint64 = ts
    while i + 5 <= te:
        # word boundary: previous char must not be a letter (rejects bgcolor)
        prev_alpha: int32 = 0
        if i > ts:
            pc: uint8 = _lower(src_ptr[i - 1])
            if (pc >= 97 and pc <= 122) or pc == 45:   # letter or '-'
                prev_alpha = 1
        if prev_alpha == 0 and _srcword_is(i, cast[Ptr[uint8]]("color")) != 0:
            j: uint64 = i + 5
            while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
                j = j + 1
            if j < te and (src_ptr[j] == 58 or src_ptr[j] == 61):   # ':' '='
                j = j + 1
                while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9 or \
                                  src_ptr[j] == 34 or src_ptr[j] == 39):
                    j = j + 1
                cv: int32 = _color_value(j)
                if cv >= 0:
                    return cv
        i = i + 1
    return -1


# Skip whitespace + a ':'/'=' separator + opening quote, then parse a colour
# value starting at src[j]. Returns 0xRRGGBB or -1.
def _prop_value_at(j: uint64, te: uint64) -> int32:
    while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
        j = j + 1
    if j < te and (src_ptr[j] == 58 or src_ptr[j] == 61):        # ':' '='
        j = j + 1
    else:
        return -1
    while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9 or \
                      src_ptr[j] == 34 or src_ptr[j] == 39):
        j = j + 1
    return _color_value(j)


# Find a BACKGROUND colour in the tag body [ts,te): the `bgcolor` attribute
# or a `background-color:` style declaration. A word boundary before the
# keyword keeps `color`/other props from matching. Returns 0xRRGGBB or -1.
def _tag_bgcolor(ts: uint64, te: uint64) -> int32:
    i: uint64 = ts
    while i < te:
        prev_alpha: int32 = 0
        if i > ts:
            pc: uint8 = _lower(src_ptr[i - 1])
            if (pc >= 97 and pc <= 122) or pc == 45:             # letter / '-'
                prev_alpha = 1
        if prev_alpha == 0:
            if _srcword_is(i, cast[Ptr[uint8]]("background-color")) != 0:
                v: int32 = _prop_value_at(i + 16, te)
                if v >= 0:
                    return v
            # `background:` shorthand (first token a colour) -- checked AFTER
            # background-color so the longer property wins its own value.
            if _srcword_is(i, cast[Ptr[uint8]]("background")) != 0:
                vb: int32 = _prop_value_at(i + 10, te)
                if vb >= 0:
                    return vb
            if _srcword_is(i, cast[Ptr[uint8]]("bgcolor")) != 0:
                v2: int32 = _prop_value_at(i + 7, te)
                if v2 >= 0:
                    return v2
        i = i + 1
    return -1


# ====================================================================
# CSS CASCADE — <style> blocks + inline style="" for the properties that
# map onto this monospace-grid engine: color, background-color, font-weight
# (bold), text-align (center/right, baked into seg_x post-layout), and
# display:none (content skipped). A stylesheet is parsed once per page into a
# flat rule table; selectors support element / .class / #id and a single
# descendant combinator (`A B`), ordered by simple specificity
# (id=100, class=10, element=1; inline style wins over all).
# ====================================================================
MAX_RULES:   int32  = 256
CSS_STR_CAP: uint64 = 8192
css_sbuf: Array[8192, uint8]
css_slen: uint64 = 0

# target (rightmost) compound of each rule
r_tag_off: Array[256, int32]
r_tag_len: Array[256, int32]
r_cls_off: Array[256, int32]
r_cls_len: Array[256, int32]
r_id_off:  Array[256, int32]
r_id_len:  Array[256, int32]
# ancestor compound (present only for a descendant selector)
r_has_anc:  Array[256, int32]
r_atag_off: Array[256, int32]
r_atag_len: Array[256, int32]
r_acls_off: Array[256, int32]
r_acls_len: Array[256, int32]
r_aid_off:  Array[256, int32]
r_aid_len:  Array[256, int32]
# resolved declarations
r_color:  Array[256, int32]
r_bg:     Array[256, int32]
r_weight: Array[256, int32]     # 0 none, 1 bold, 2 normal
r_align:  Array[256, int32]     # 0 none, 1 left, 2 center, 3 right
r_deco:   Array[256, int32]     # text-decoration: 0 none-set, 1 underline, 2 none
r_disp:   Array[256, int32]     # display: 1=none 2=flex 3=block 4=inline-block 5=inline
r_flexdir: Array[256, int32]    # flex-direction: 0 unset / 1 column / 2 row
r_justify: Array[256, int32]    # justify-content: 0 unset / 1..5 (see _justify_value)
r_aitems: Array[256, int32]     # align-items: 0 unset / 1 flex-start / 2 center / 3 flex-end / 4 stretch
r_flexgap: Array[256, int32]    # flex column gap px: -1 unset (default FLEX_GAP)
r_rowgap: Array[256, int32]     # flex row gap px: -1 unset (0 => no inter-line gap)
r_flexwrap: Array[256, int32]   # flex-wrap: 0 unset/nowrap / 1 wrap
# grid-template-columns: r_gtcn[ri] tracks (0 = unset), each encoded track in
# r_gtc[ri*GRID_MAXTRACK + c] (>= 0 fixed px / < 0 fr weight negated).
r_gtcn: Array[256, int32]
r_gtc:  Array[2048, int32]      # 256 rules * GRID_MAXTRACK tracks
# grid-template-rows (fixed px row heights); same shape as grid-template-columns.
r_gtrn: Array[256, int32]
r_gtr:  Array[2048, int32]      # 256 rules * GRID_MAXTRACK rows
# per-ITEM grid-column line placement: r_gcspan[ri] tracks spanned (0 = unset =>
# a single track), r_gcstart[ri] explicit 1-based start line (0 = auto-flow).
r_gcspan:  Array[256, int32]
r_gcstart: Array[256, int32]
# box model (px; -1 = the rule does not set this axis). ml/mr fold margin+
# padding on that side into one left/right inset; mt/mb are the top/bottom
# gaps; wd is the content width; bd is 0 (border:none) / 1 (border on) / -1.
r_ml:     Array[256, int32]
r_mr:     Array[256, int32]
r_mt:     Array[256, int32]
r_mb:     Array[256, int32]
r_wd:     Array[256, int32]
r_bd:     Array[256, int32]
r_center: Array[256, int32]     # 1 = margin-left+right:auto (centre the box)
r_fontpx: Array[256, int32]     # CSS font-size in px (-1 = rule sets no size)
# CSS line-height. 0 = rule sets none; >0 = absolute PX (from px/em); <0 =
# unitless/percentage multiplier in milli, negated (e.g. 1.5 -> -1500, 150% ->
# -1500) resolved against the element's font-size when the style scope opens.
r_lineh:  Array[256, int32]
# CSS white-space, encoded mode+1 (0 = rule sets none): 1 normal, 2 nowrap,
# 3 pre, 4 pre-wrap.
r_ws:     Array[256, int32]
r_float:  Array[256, int32]     # CSS float: 0 none / 1 left / 2 right
# CSS position: 0 none, 1 relative (in-flow, shift rendered box), 2 absolute
# (out-of-flow, placed against the nearest positioned ancestor). top/left/right/
# bottom offsets in px, -1 = that edge is auto.
r_pos:    Array[256, int32]
r_top:    Array[256, int32]
r_left:   Array[256, int32]
r_right:  Array[256, int32]
r_bottom: Array[256, int32]
r_zidx:   Array[256, int32]     # z-index (ZIDX_UNSET = auto/unset)
r_spec:   Array[256, int32]
n_rules:  int32 = 0

# element stack (open elements) for descendant matching
MAX_EL:     int32  = 64
EL_STR_CAP: uint64 = 4096
el_sbuf: Array[4096, uint8]
el_slen: uint64 = 0
el_tag_off: Array[64, int32]
el_tag_len: Array[64, int32]
el_cls_off: Array[64, int32]
el_cls_len: Array[64, int32]
el_id_off:  Array[64, int32]
el_id_len:  Array[64, int32]
el_sp: int32 = 0

# cascade match results (filled by _cascade_match_current)
m_col:    int32 = -1
m_bg:     int32 = -1
m_weight: int32 = 0
m_align:  int32 = 0
m_deco:   int32 = 0
m_disp:   int32 = 0
m_flexdir: int32 = 0       # flex-direction cascade winner: 0 unset / 1 col / 2 row
m_justify: int32 = 0       # justify-content cascade winner: 0 unset / 1..5
m_aitems: int32 = 0        # align-items cascade winner: 0 unset / 1..4
m_flexgap: int32 = -1      # flex column-gap cascade winner px: -1 unset
m_rowgap: int32 = -1       # flex row-gap cascade winner px: -1 unset
m_flexwrap: int32 = 0      # flex-wrap cascade winner: 0 nowrap / 1 wrap
m_gtcn: int32 = 0          # grid-template-columns cascade winner: track count
m_gtc:  Array[8, int32]    # winning template's encoded tracks
m_gtrn: int32 = 0          # grid-template-rows cascade winner: row count
m_gtr:  Array[8, int32]    # winning row template's encoded rows
m_gcspan:  int32 = 0       # grid-column cascade winner: span (0 = unset => 1)
m_gcstart: int32 = 0       # grid-column cascade winner: explicit start (0 = auto)
# box-model cascade winners (-1 = no matching rule set this axis)
m_ml:     int32 = -1
m_mr:     int32 = -1
m_mt:     int32 = -1
m_mb:     int32 = -1
m_wd:     int32 = -1
m_bd:     int32 = -1
m_center: int32 = 0        # 1 = auto side margins (centre the box in its parent)
m_fontpx: int32 = -1
m_lineh:  int32 = 0        # CSS line-height cascade winner (see r_lineh encoding)
m_ws:     int32 = 0        # CSS white-space cascade winner (mode+1; 0 = unset)
m_float:  int32 = 0
# CSS position cascade winners (m_pos 0/1/2; offsets px, -1 = auto).
m_pos:    int32 = 0
m_top:    int32 = -1
m_left:   int32 = -1
m_right:  int32 = -1
m_bottom: int32 = -1
m_zidx:   int32 = -2000000000       # z-index cascade winner (ZIDX_UNSET = unset)

# ---- CSS position (relative/absolute) ------------------------------------
# Positioned elements are laid out in normal flow, then a post-layout pass
# (_apply_positioned) shifts their whole segment run. `relative` keeps the
# element's in-flow space and offsets the rendered box by top/left (or pulls it
# back by right/bottom). `absolute` is out of flow: after laying its box out we
# REWIND cur_row (like a float) so following content reclaims the space, and the
# box is placed against the nearest positioned ancestor's origin (or the page
# top-left). A per-element context stack records each positioned ancestor's
# top-left/right so an absolute child resolves top/left/right against it. Pages
# that use no `position` add zero runs, so layout is byte-identical.
POS_MAX:  int32 = 64
pos_seg0: Array[64, int32]       # first segment of the positioned run
pos_seg1: Array[64, int32]       # one past the last segment
pos_mode: Array[64, int32]       # 1 relative, 2 absolute
pos_ox:   Array[64, int32]       # containing-block left x (absolute)
pos_ort:  Array[64, int32]       # containing-block right x (absolute)
pos_orow: Array[64, int32]       # containing-block top row (absolute)
pos_l:    Array[64, int32]       # left/top/right/bottom offsets (px, -1 auto)
pos_t:    Array[64, int32]
pos_r:    Array[64, int32]
pos_b:    Array[64, int32]
pos_z:    Array[64, int32]       # z-index (stacking order; 0 = auto/default)
pos_bf0:  Array[64, int32]       # first bfill (block background) of the run
pos_bf1:  Array[64, int32]       # one past the last bfill of the run
pos_n:    int32 = 0

# nearest-positioned-ancestor origin stack (containing block for `absolute`).
posctx_x:   Array[64, int32]
posctx_rt:  Array[64, int32]
posctx_row: Array[64, int32]
posctx_sp:  int32 = 0

# font-weight (bold) scope — parallels the colour stack.
weight_stack: Array[64, int32]
weight_sp:  int32 = 0
g_css_bold: int32 = 0

# text-decoration scope — parallels the weight stack. A level pushes 0 when it
# sets no decoration, so the effective decoration INHERITS the nearest ancestor
# that did (CSS text-decoration is NOT inherited per spec, but propagating the
# underline down matches how it renders in practice for the common cases:
# <u>/underlined blocks). 1 = underline, 2 = none (an explicit reset, e.g. to
# strip a link's default underline). g_css_uline folds into g_uline.
deco_stack: Array[64, int32]
deco_sp:  int32 = 0
g_css_uline: int32 = 0

# font-size (px) scope — parallels the weight stack. A level pushes 0 when it
# sets no size, so the effective size INHERITS the nearest ancestor that did
# (CSS font-size inheritance). g_font_px 0 = "use the face default".
fontpx_stack: Array[64, int32]
fontpx_sp: int32 = 0
g_font_px: int32 = 0

# line-height (px) scope — parallels the font-size stack. A level pushes 0 when
# it sets no line-height, so the effective pitch INHERITS the nearest ancestor
# that did (CSS line-height inherits). g_lineh 0 = "use the default rhythm".
# Values are already resolved to PIXELS at the point the scope is opened.
lineh_stack: Array[64, int32]
lineh_sp: int32 = 0
g_lineh: int32 = 0

# white-space scope — parallels the line-height stack. CSS `white-space`
# INHERITS, so a level pushes 0 when it sets none and the effective mode
# inherits the nearest ancestor that did. Stack/decl/rule/winner entries are
# ENCODED as mode+1 (0 = unset): 1 normal, 2 nowrap, 3 pre, 4 pre-wrap. The
# resolved effective mode g_ws is 0..3 (0 normal = the default flow):
#   0 normal   -> collapse whitespace runs to one space, soft-wrap at measure
#   1 nowrap   -> collapse, but never soft-wrap (line overflows the measure)
#   2 pre      -> preserve spaces + newlines, never soft-wrap
#   3 pre-wrap -> preserve spaces + newlines, but DO soft-wrap at the measure
# g_ws only takes effect through the CSS property; the <pre>/<code> ELEMENT
# keeps its own monospace-grid pre_mode path untouched, so unstyled pages are
# byte-identical (every level pushes 0 -> g_ws stays 0 -> normal flow).
ws_stack: Array[64, int32]
ws_sp: int32 = 0
g_ws: int32 = 0

# text-align scope + per-row alignment record (post-pass shifts seg_x).
align_stack: Array[64, int32]
align_sp: int32 = 0
g_align:  int32 = 0
row_align: Array[12000, uint8]

# selector/declaration parse scratch (globals — the compiler has no tuples).
c_tag_off: int32 = -1
c_tag_len: int32 = 0
c_cls_off: int32 = -1
c_cls_len: int32 = 0
c_id_off:  int32 = -1
c_id_len:  int32 = 0
c_spec:    int32 = 0
g_store_off: int32 = 0
g_store_len: int32 = 0
d_color:  int32 = -1
d_bg:     int32 = -1
d_weight: int32 = 0
d_align:  int32 = 0
d_deco:   int32 = 0
d_disp:   int32 = 0
d_flexdir: int32 = 0        # flex-direction: 0 unset / 1 column / 2 row
d_justify: int32 = 0        # justify-content: 0 unset / 1..5
d_aitems: int32 = 0         # align-items: 0 unset / 1..4
d_flexgap: int32 = -1       # flex column-gap px: -1 unset
d_rowgap: int32 = -1        # flex row-gap px: -1 unset
d_flexwrap: int32 = 0       # flex-wrap: 0 nowrap / 1 wrap
d_gtcn: int32 = 0           # grid-template-columns: track count (0 = unset)
d_gtc:  Array[8, int32]     # parsed encoded tracks for this rule / inline style
d_gtrn: int32 = 0           # grid-template-rows: row count (0 = unset)
d_gtr:  Array[8, int32]     # parsed encoded rows for this rule / inline style
d_gcspan:  int32 = 0        # grid-column span (0 = unset => single track)
d_gcstart: int32 = 0        # grid-column explicit 1-based start line (0 = auto)
# box-model declaration scratch (per rule / per inline style="", -1 = unset).
# ml/mr fold the left/right margin+padding; mt/mb the top/bottom gaps (px);
# wd the content width (px); bd is 0 (none) / 1 (on) for a border.
d_ml:     int32 = -1
d_mr:     int32 = -1
d_mt:     int32 = -1
d_mb:     int32 = -1
d_wd:     int32 = -1
d_bd:     int32 = -1
d_center: int32 = 0         # 1 = auto side margins (centre the box)
d_fontpx: int32 = -1        # CSS font-size in px (-1 = declaration sets none)
d_lineh:  int32 = 0         # CSS line-height (0 none; >0 px; <0 -milli mult.)
d_ws:     int32 = 0         # CSS white-space (mode+1; 0 = declaration sets none)
d_float:  int32 = 0         # CSS float: 0 none / 1 left / 2 right
d_pos:    int32 = 0         # CSS position: 0 none / 1 relative / 2 absolute
d_top:    int32 = -1        # top/left/right/bottom offsets (px, -1 = auto)
d_left:   int32 = -1
d_right:  int32 = -1
d_bottom: int32 = -1
# CSS z-index (stacking order for positioned boxes). ZIDX_UNSET = auto/unset;
# any real integer (incl. negative) is an explicit stacking level.
ZIDX_UNSET: int32 = -2000000000
d_zidx:   int32 = -2000000000
# multi-length shorthand scratch (margin/padding: t r b l).
box_lens: Array[4, int32]
n_box_lens: int32 = 0


# Parse a CSS length from src[vs..ve) honouring px / em / % units into pixels.
# em == EM_PX px; % is of the body content width (bw - 2*CONTENT_X). Returns
# the pixel value (>=0), or -1 when there is no numeric prefix (auto/none/...).
def _style_len(vs: uint64, ve: uint64) -> int32:
    i: uint64 = vs
    while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    seen: int32 = 0
    v: int32 = 0
    while i < ve:
        d: uint8 = src_ptr[i]
        if d >= 48 and d <= 57:
            v = v * 10 + cast[int32](d - 48)
            seen = 1
            i = i + 1
        else:
            break
    if seen == 0:
        return -1
    if i < ve and src_ptr[i] == 37:                  # '%'
        base: int32 = _content_right() - _left_margin()
        if base < 0:
            base = 0
        return v * base / 100
    if i + 1 < ve and _lower(src_ptr[i]) == 101 and _lower(src_ptr[i + 1]) == 109:
        return v * EM_PX                             # "em"
    return v                                          # px or unitless


# Parse a CSS z-index: an optional-sign integer (may be negative). Returns the
# value, or ZIDX_UNSET when the value is `auto`/empty/non-numeric.
def _zindex_value(vs: uint64, ve: uint64) -> int32:
    i: uint64 = vs
    while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    neg: int32 = 0
    if i < ve and src_ptr[i] == 45:                      # '-'
        neg = 1
        i = i + 1
    seen: int32 = 0
    v: int32 = 0
    while i < ve:
        d: uint8 = src_ptr[i]
        if d >= 48 and d <= 57:
            v = v * 10 + cast[int32](d - 48)
            seen = 1
            i = i + 1
        else:
            break
    if seen == 0:
        return ZIDX_UNSET
    if neg != 0:
        return 0 - v
    return v


# Parse a CSS line-height value from src[vs..ve) into the r_lineh/d_lineh
# encoding: 0 = none/normal/unparseable; >0 = absolute PIXELS (px/em); <0 =
# unitless number or percentage as a milli-multiplier, negated, resolved against
# the element font-size later (1.5 -> -1500; 1.4em -> +22px; 150% -> -1500;
# 24px -> +24). Handles up to 3 fractional digits so "1.5"/"2.0" round-trip.
def _lineh_value(vs: uint64, ve: uint64) -> int32:
    i: uint64 = vs
    while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    seen: int32 = 0
    whole: int32 = 0
    while i < ve:
        d: uint8 = src_ptr[i]
        if d >= 48 and d <= 57:
            whole = whole * 10 + cast[int32](d - 48)
            seen = 1
            i = i + 1
        else:
            break
    frac: int32 = 0          # milli fraction (0..999)
    scale: int32 = 100
    if i < ve and src_ptr[i] == 46:                  # '.'
        i = i + 1
        while i < ve and scale > 0:
            d2: uint8 = src_ptr[i]
            if d2 >= 48 and d2 <= 57:
                frac = frac + cast[int32](d2 - 48) * scale
                scale = scale / 10
                seen = 1
                i = i + 1
            else:
                break
    if seen == 0:
        return 0                                      # "normal" / unparseable
    milli: int32 = whole * 1000 + frac
    if i < ve and src_ptr[i] == 37:                  # '%' of font-size
        return -(milli / 100)
    if i + 1 < ve and _lower(src_ptr[i]) == 112 and _lower(src_ptr[i + 1]) == 120:
        return milli / 1000                           # 'px' -> px
    if i + 1 < ve and _lower(src_ptr[i]) == 101 and _lower(src_ptr[i + 1]) == 109:
        return milli * EM_PX / 1000                   # 'em' -> px
    return -milli                                     # unitless multiplier


# Resolve the r_lineh/d_lineh encoding to absolute PIXELS given the element's
# effective font-size (0 = use EM_PX default). 0 in -> 0 out (unset).
def _lineh_resolve(enc: int32, font_px: int32) -> int32:
    if enc == 0:
        return 0
    if enc > 0:
        return enc                                    # already px
    base: int32 = font_px
    if base <= 0:
        base = EM_PX
    return (-enc) * base / 1000                       # unitless/% multiplier


# Parse a CSS `white-space` keyword from src[vs..ve) into the mode+1 encoding
# (0 = unrecognised / sets none): 1 normal, 2 nowrap, 3 pre, 4 pre-wrap. Longer
# keywords are tested before their prefixes so "pre-wrap" is not eaten by "pre".
# `pre-line` (collapse spaces, keep newlines) has no dedicated flow mode here;
# we treat it as `normal` so it does NOT wrongly preserve the spaces.
def _ws_value(vs: uint64, ve: uint64) -> int32:
    s: uint64 = _val_start(vs, ve)
    if _val_starts(s, ve, cast[Ptr[uint8]]("pre-wrap")) != 0:
        return 4
    if _val_starts(s, ve, cast[Ptr[uint8]]("pre-line")) != 0:
        return 1
    if _val_starts(s, ve, cast[Ptr[uint8]]("pre")) != 0:
        return 3
    if _val_starts(s, ve, cast[Ptr[uint8]]("nowrap")) != 0:
        return 2
    if _val_starts(s, ve, cast[Ptr[uint8]]("normal")) != 0:
        return 1
    return 0


def _is_alpha(c: uint8) -> int32:
    lc: uint8 = _lower(c)
    if lc >= 97 and lc <= 122:
        return 1
    return 0


def _is_name_ch(c: uint8) -> int32:
    lc: uint8 = _lower(c)
    if (lc >= 97 and lc <= 122) or (c >= 48 and c <= 57) or c == 45 or c == 95:
        return 1
    return 0


# Copy src[a..b) lowercased into css_sbuf; sets g_store_off/g_store_len.
def _css_store(a: uint64, b: uint64):
    g_store_off = cast[int32](css_slen)
    i: uint64 = a
    while i < b and css_slen < CSS_STR_CAP - 1:
        css_sbuf[css_slen] = _lower(src_ptr[i])
        css_slen = css_slen + 1
        i = i + 1
    g_store_len = cast[int32](css_slen) - g_store_off


# Compare src[a..b) (whitespace-trimmed, lowercased) against literal `lit`.
def _prop_is(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    while a < b and _css_ws(src_ptr[a]) != 0:
        a = a + 1
    while b > a and _css_ws(src_ptr[b - 1]) != 0:
        b = b - 1
    i: uint64 = 0
    while lit[i] != 0:
        if a + i >= b:
            return 0
        if _lower(src_ptr[a + i]) != lit[i]:
            return 0
        i = i + 1
    if a + i != b:
        return 0
    return 1


# Does the value src[a..b) begin (after whitespace) with literal `lit`?
def _val_starts(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    while a < b and _css_ws(src_ptr[a]) != 0:
        a = a + 1
    return _srcword_is(a, lit)


# Does the value src[a..b) contain the token `auto` (e.g. `margin: 0 auto`, or a
# bare `margin-left: auto`)? Drives centred-block detection.
def _val_has_auto(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i + 4 <= b:
        if _lower(src_ptr[i]) == 97 and _lower(src_ptr[i + 1]) == 117 and \
           _lower(src_ptr[i + 2]) == 116 and _lower(src_ptr[i + 3]) == 111:
            return 1
        i = i + 1
    return 0


# Does property name src[a..b) (trimmed) start with literal `lit`? Used to tell
# `margin` (shorthand) / `margin-left` (side) apart without over-matching.
def _prop_prefix(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    while a < b and _css_ws(src_ptr[a]) != 0:
        a = a + 1
    while b > a and _css_ws(src_ptr[b - 1]) != 0:
        b = b - 1
    i: uint64 = 0
    while lit[i] != 0:
        if a + i >= b:
            return 0
        if _lower(src_ptr[a + i]) != lit[i]:
            return 0
        i = i + 1
    return 1


# Accumulate one side inset (margin/padding on that side sum into one column).
def _box_add_l(px: int32):
    if px < 0:
        return
    if d_ml < 0:
        d_ml = 0
    d_ml = d_ml + px


def _box_add_r(px: int32):
    if px < 0:
        return
    if d_mr < 0:
        d_mr = 0
    d_mr = d_mr + px


def _box_add_t(px: int32):
    if px < 0:
        return
    if d_mt < 0:
        d_mt = 0
    d_mt = d_mt + px


def _box_add_b(px: int32):
    if px < 0:
        return
    if d_mb < 0:
        d_mb = 0
    d_mb = d_mb + px


# Parse the space-separated length list of a margin/padding shorthand into
# box_lens[0..n_box_lens); non-length tokens (should not occur here) are skipped.
def _parse_box_lens(vs: uint64, ve: uint64):
    n_box_lens = 0
    i: uint64 = vs
    while i < ve and n_box_lens < 4:
        while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
            i = i + 1
        if i >= ve:
            break
        ts: uint64 = i
        while i < ve and src_ptr[i] != 32 and src_ptr[i] != 9:
            i = i + 1
        px: int32 = _style_len(ts, i)
        if px >= 0:
            box_lens[n_box_lens] = px
            n_box_lens = n_box_lens + 1


# Apply a `margin:`/`padding:` shorthand (1..4 lengths, CSS TRBL rules) into the
# left/right/top/bottom insets.
def _box_shorthand(vs: uint64, ve: uint64):
    _parse_box_lens(vs, ve)
    if n_box_lens == 0:
        return
    t: int32 = box_lens[0]
    r: int32 = box_lens[0]
    bo: int32 = box_lens[0]
    l: int32 = box_lens[0]
    if n_box_lens >= 2:
        r = box_lens[1]
        l = box_lens[1]
    if n_box_lens >= 3:
        bo = box_lens[2]
    if n_box_lens >= 4:
        l = box_lens[3]
    _box_add_t(t)
    _box_add_r(r)
    _box_add_b(bo)
    _box_add_l(l)


# Route ONE box-model declaration (property src[ps..pe) : value src[vs..ve))
# into the d_* box scratch. Shared by the stylesheet (_apply_decl) and inline
# style="" paths so classes and inline styles cascade identically. Returns 1 if
# the property was a box property (handled), else 0.
def _box_decl(ps: uint64, pe: uint64, vs: uint64, ve: uint64) -> int32:
    # Border: any border / border-style / border-width / border-<side> turns the
    # box on unless the value is none/hidden/0.
    if _prop_prefix(ps, pe, cast[Ptr[uint8]]("border")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("none")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("hidden")) != 0:
            d_bd = 0
        else:
            d_bd = 1
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("width")) != 0:
        w: int32 = _style_len(vs, ve)
        if w >= 0:
            d_wd = w
        return 1
    # max-width caps the content column; for our layout it pins the wrap width
    # like `width` (the common centred-container idiom `max-width:Npx;margin:0
    # auto`). A later explicit `width` still overrides via d_wd.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("max-width")) != 0:
        mw: int32 = _style_len(vs, ve)
        if mw >= 0:
            d_wd = mw
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("float")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("left")) != 0:
            d_float = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("right")) != 0:
            d_float = 2
        else:
            d_float = 0                                  # none / inline-start...
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("position")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("relative")) != 0:
            d_pos = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("absolute")) != 0 or \
             _val_starts(vs, ve, cast[Ptr[uint8]]("fixed")) != 0:
            d_pos = 2
        else:
            d_pos = 0                                    # static / sticky
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("top")) != 0:
        d_top = _style_len(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("left")) != 0:
        d_left = _style_len(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("right")) != 0:
        d_right = _style_len(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("bottom")) != 0:
        d_bottom = _style_len(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("z-index")) != 0:
        d_zidx = _zindex_value(vs, ve)
        return 1
    # side-specific first (longer names) so the shorthand check does not eat them
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-left")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-left")) != 0:
        if _val_has_auto(vs, ve) != 0:
            d_center = 1
        _box_add_l(_style_len(vs, ve))
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-right")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-right")) != 0:
        if _val_has_auto(vs, ve) != 0:
            d_center = 1
        _box_add_r(_style_len(vs, ve))
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-top")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-top")) != 0:
        _box_add_t(_style_len(vs, ve))
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-bottom")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-bottom")) != 0:
        _box_add_b(_style_len(vs, ve))
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding")) != 0:
        # `margin: <v> auto` (or `margin: auto`) centres the box in its parent.
        if _prop_is(ps, pe, cast[Ptr[uint8]]("margin")) != 0 and \
           _val_has_auto(vs, ve) != 0:
            d_center = 1
        _box_shorthand(vs, ve)
        return 1
    return 0


# First non-space offset in [a,b) — where a colour value begins.
def _val_start(a: uint64, b: uint64) -> uint64:
    while a < b and _css_ws(src_ptr[a]) != 0:
        a = a + 1
    return a


# ---- byte-buffer compares -------------------------------------------
def _buf_eq(a: Ptr[uint8], alen: int32, b: Ptr[uint8], blen: int32) -> int32:
    if alen != blen:
        return 0
    i: int32 = 0
    while i < alen:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# Does the element's class list (el_sbuf[coff..coff+clen)) contain the token
# css_sbuf[koff..koff+klen) (space-separated)?
def _cls_contains(coff: int32, clen: int32, koff: int32, klen: int32) -> int32:
    i: int32 = 0
    while i < clen:
        while i < clen and el_sbuf[coff + i] == 32:
            i = i + 1
        s: int32 = i
        while i < clen and el_sbuf[coff + i] != 32:
            i = i + 1
        tlen: int32 = i - s
        if tlen == klen and _buf_eq(&el_sbuf[coff + s], tlen, \
                                    &css_sbuf[koff], klen) != 0:
            return 1
    return 0


# ---- selector parsing -----------------------------------------------
def _read_name(i: uint64, b: uint64) -> uint64:
    while i < b and _is_name_ch(src_ptr[i]) != 0:
        i = i + 1
    return i


# Parse one compound selector at src[a..b) into c_* globals; c_spec gets its
# specificity contribution.
def _parse_compound(a: uint64, b: uint64):
    c_tag_off = -1
    c_tag_len = 0
    c_cls_off = -1
    c_cls_len = 0
    c_id_off = -1
    c_id_len = 0
    c_spec = 0
    i: uint64 = a
    if i < b and src_ptr[i] == 42:                   # '*' universal
        i = i + 1
    elif i < b and _is_alpha(src_ptr[i]) != 0:
        j: uint64 = _read_name(i, b)
        _css_store(i, j)
        c_tag_off = g_store_off
        c_tag_len = g_store_len
        c_spec = c_spec + 1
        i = j
    while i < b:
        if src_ptr[i] == 46:                         # '.class'
            j2: uint64 = _read_name(i + 1, b)
            # A compound may chain several classes (`.a.b`): store them all as
            # one space-joined token string so matching can require EVERY class
            # (and specificity grows +10 per class). The first class seeds
            # c_cls_off; each subsequent one appends " <name>" and extends len.
            if c_cls_off < 0:
                _css_store(i + 1, j2)
                c_cls_off = g_store_off
                c_cls_len = g_store_len
            else:
                if css_slen < CSS_STR_CAP - 1:
                    css_sbuf[css_slen] = 32          # separator space
                    css_slen = css_slen + 1
                _css_store(i + 1, j2)
                c_cls_len = g_store_off + g_store_len - c_cls_off
            c_spec = c_spec + 10
            i = j2
        elif src_ptr[i] == 35:                       # '#id'
            j3: uint64 = _read_name(i + 1, b)
            _css_store(i + 1, j3)
            c_id_off = g_store_off
            c_id_len = g_store_len
            c_spec = c_spec + 100
            i = j3
        else:
            i = i + 1


# Parse a full selector src[a..b) into rule `ri`. Keeps the rightmost compound
# as the target and the nearest preceding compound as the ancestor.
def _parse_selector(a: uint64, b: uint64, ri: int32):
    # trim
    while a < b and (src_ptr[a] == 32 or src_ptr[a] == 9 or src_ptr[a] == 10 \
                     or src_ptr[a] == 13 or src_ptr[a] == 62):
        a = a + 1
    while b > a and (src_ptr[b - 1] == 32 or src_ptr[b - 1] == 9 or \
                     src_ptr[b - 1] == 10 or src_ptr[b - 1] == 13):
        b = b - 1
    r_has_anc[ri] = 0
    spec: int32 = 0
    # walk compounds left->right; remember previous compound as ancestor.
    i: uint64 = a
    prev_present: int32 = 0
    while i < b:
        while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9 or \
                         src_ptr[i] == 62 or src_ptr[i] == 10 or \
                         src_ptr[i] == 13):
            i = i + 1
        if i >= b:
            break
        cs: uint64 = i
        while i < b and src_ptr[i] != 32 and src_ptr[i] != 9 and \
              src_ptr[i] != 62 and src_ptr[i] != 10 and src_ptr[i] != 13:
            i = i + 1
        # a compound occupies [cs,i); shift current target -> ancestor.
        if prev_present != 0:
            r_has_anc[ri] = 1
            r_atag_off[ri] = r_tag_off[ri]
            r_atag_len[ri] = r_tag_len[ri]
            r_acls_off[ri] = r_cls_off[ri]
            r_acls_len[ri] = r_cls_len[ri]
            r_aid_off[ri]  = r_id_off[ri]
            r_aid_len[ri]  = r_id_len[ri]
        _parse_compound(cs, i)
        r_tag_off[ri] = c_tag_off
        r_tag_len[ri] = c_tag_len
        r_cls_off[ri] = c_cls_off
        r_cls_len[ri] = c_cls_len
        r_id_off[ri]  = c_id_off
        r_id_len[ri]  = c_id_len
        spec = spec + c_spec
        prev_present = 1
    r_spec[ri] = spec


# ---- declaration parsing --------------------------------------------
# Map a `display:` value span to the engine's display code (shared by the
# stylesheet and inline-style parsers). inline-block/inline-flex are tested
# before the bare "inline" prefix; flex covers inline-flex too.
def _disp_value(vs: uint64, ve: uint64) -> int32:
    if _val_starts(vs, ve, cast[Ptr[uint8]]("none")) != 0:
        return 1
    if _val_starts(vs, ve, cast[Ptr[uint8]]("inline-block")) != 0:
        return 4
    if _val_starts(vs, ve, cast[Ptr[uint8]]("inline-flex")) != 0:
        return 2
    if _val_starts(vs, ve, cast[Ptr[uint8]]("inline-grid")) != 0:
        return 6
    if _val_starts(vs, ve, cast[Ptr[uint8]]("inline")) != 0:
        return 5
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex")) != 0:
        return 2
    if _val_starts(vs, ve, cast[Ptr[uint8]]("grid")) != 0:
        return 6
    if _val_starts(vs, ve, cast[Ptr[uint8]]("block")) != 0:
        return 3
    return 0


# justify-content value -> 1 flex-start, 2 center, 3 flex-end, 4 space-between,
# 5 space-around (space-evenly maps to around). 0 for unrecognised/unset.
def _justify_value(vs: uint64, ve: uint64) -> int32:
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex-start")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("start")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("left")) != 0:
        return 1
    if _val_starts(vs, ve, cast[Ptr[uint8]]("center")) != 0:
        return 2
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex-end")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("end")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("right")) != 0:
        return 3
    if _val_starts(vs, ve, cast[Ptr[uint8]]("space-between")) != 0:
        return 4
    if _val_starts(vs, ve, cast[Ptr[uint8]]("space-around")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("space-evenly")) != 0:
        return 5
    return 0


# align-items (cross axis) value -> 1 flex-start (== top-aligned default),
# 2 center, 3 flex-end, 4 stretch. `baseline` approximates to flex-start. 0 for
# unrecognised/unset (which keeps the engine's existing top-aligned behaviour).
def _align_items_value(vs: uint64, ve: uint64) -> int32:
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex-start")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("start")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("baseline")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("self-start")) != 0:
        return 1
    if _val_starts(vs, ve, cast[Ptr[uint8]]("center")) != 0:
        return 2
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex-end")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("end")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("self-end")) != 0:
        return 3
    if _val_starts(vs, ve, cast[Ptr[uint8]]("stretch")) != 0:
        return 4
    return 0


# Encode ONE grid-template-columns track token src[a..b) into the compact form:
#   <n>fr  -> negative fr weight (-n; a bare `fr` == -1)
#   <len>  -> a fixed px length (px/em/% via _style_len)
#   auto / min-content / max-content / other keyword -> a flexible 1fr track
# (a lean approximation — this round has no intrinsic sizing). fr is detected
# BEFORE _style_len so "1fr" is not mistaken for 1px.
def _grid_one_track(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    seen: int32 = 0
    v: int32 = 0
    j: uint64 = i
    while j < b and src_ptr[j] >= 48 and src_ptr[j] <= 57:
        v = v * 10 + cast[int32](src_ptr[j] - 48)
        seen = 1
        j = j + 1
    # trailing "fr" -> fractional track
    if j + 1 < b and _lower(src_ptr[j]) == 102 and _lower(src_ptr[j + 1]) == 114:
        w: int32 = v
        if seen == 0 or w <= 0:
            w = 1
        return -w
    if seen == 0:
        return -1                                    # auto / *-content -> 1fr
    px: int32 = _style_len(a, b)
    if px < 0:
        px = 0
    return px


# Scratch the shared track parser writes into; a caller copies it into the column
# (d_gtc) or row (d_gtr) destination so `grid-template-columns` and
# `grid-template-rows` in the same ruleset don't clobber each other.
gts_enc: Array[8, int32]


# Does token src[a..b) (leading ws skipped) contain the keyword `span`?
def _grid_tok_isspan(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i + 4 <= b:
        if _lower(src_ptr[i]) == 115 and _lower(src_ptr[i + 1]) == 112 and \
           _lower(src_ptr[i + 2]) == 97 and _lower(src_ptr[i + 3]) == 110:
            return 1
        i = i + 1
    return 0


# The first run of decimal digits in src[a..b) as an int (0 if none).
def _grid_tok_num(a: uint64, b: uint64) -> int32:
    v: int32 = 0
    seen: int32 = 0
    i: uint64 = a
    while i < b:
        c: uint8 = src_ptr[i]
        if c >= 48 and c <= 57:
            v = v * 10 + cast[int32](c - 48)
            seen = 1
        elif seen != 0:
            i = b                                        # stop at first non-digit run end
        i = i + 1
    return v


# Parse a per-ITEM `grid-column` value src[vs..ve) into d_gcstart (1-based start
# line; 0 = auto) and d_gcspan (track count; default 1). Handles `span N`,
# `A / B` (span = B-A), `A / span N`, and a bare `A` (start only). Row placement
# (`grid-row`) is NOT handled — the fixed-row model has no cross-row spanning.
def _grid_column_parse(vs: uint64, ve: uint64):
    d_gcstart = 0
    d_gcspan = 1
    slash: uint64 = ve
    i: uint64 = vs
    while i < ve:
        if src_ptr[i] == 47:                             # '/'
            slash = i
            break
        i = i + 1
    lsp: int32 = _grid_tok_isspan(vs, slash)
    lnum: int32 = _grid_tok_num(vs, slash)
    if slash < ve:
        rsp: int32 = _grid_tok_isspan(slash + 1, ve)
        rnum: int32 = _grid_tok_num(slash + 1, ve)
        if lsp == 0 and lnum > 0:
            d_gcstart = lnum
        if rsp != 0 and rnum > 0:
            d_gcspan = rnum
        elif lsp != 0 and lnum > 0:
            d_gcspan = lnum
        elif lnum > 0 and rnum > lnum:
            d_gcspan = rnum - lnum
    else:
        if lsp != 0 and lnum > 0:
            d_gcspan = lnum
        elif lnum > 0:
            d_gcstart = lnum


# Parse a `grid-template-columns`/`grid-template-rows` value src[vs..ve) into the
# compact per-track encoding, written into the shared gts_enc[0..) scratch (the
# caller copies it out). Understands `repeat(N, <track>)`, explicit space-
# separated track lists ("200px 1fr 1fr"), and bare single tracks. Caps at
# GRID_MAXTRACK tracks (extra dropped — >8 tracks is a deferred feature).
# Returns the track count (0 = nothing parseable). NOT handled this round (all
# fall back to block stacking / a flexible track): grid-template-areas, minmax(),
# auto-fit/auto-fill, subgrid.
def _grid_parse_template(vs: uint64, ve: uint64) -> int32:
    n: int32 = 0
    i: uint64 = vs
    while i < ve and n < GRID_MAXTRACK:
        c: uint8 = src_ptr[i]
        if c == 32 or c == 9 or c == 10 or c == 13 or c == 44:   # ws or ','
            i = i + 1
            continue
        if _val_starts(i, ve, cast[Ptr[uint8]]("repeat")) != 0:
            j: uint64 = i
            while j < ve and src_ptr[j] != 40:       # '('
                j = j + 1
            j = j + 1
            cnt: int32 = 0
            while j < ve and src_ptr[j] >= 48 and src_ptr[j] <= 57:
                cnt = cnt * 10 + cast[int32](src_ptr[j] - 48)
                j = j + 1
            while j < ve and src_ptr[j] != 44:       # ',' before the track
                j = j + 1
            j = j + 1
            ts: uint64 = j
            te2: uint64 = j
            while te2 < ve and src_ptr[te2] != 41:   # ')'
                te2 = te2 + 1
            enc: int32 = _grid_one_track(ts, te2)
            k: int32 = 0
            while k < cnt and n < GRID_MAXTRACK:
                gts_enc[n] = enc
                n = n + 1
                k = k + 1
            i = te2
            if i < ve:
                i = i + 1                            # past ')'
            continue
        te3: uint64 = i
        while te3 < ve and src_ptr[te3] != 32 and src_ptr[te3] != 9 and \
              src_ptr[te3] != 10 and src_ptr[te3] != 13 and src_ptr[te3] != 44:
            te3 = te3 + 1
        gts_enc[n] = _grid_one_track(i, te3)
        n = n + 1
        i = te3
    return n


def _apply_decl(ps: uint64, pe: uint64, vs: uint64, ve: uint64):
    if _box_decl(ps, pe, vs, ve) != 0:
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("color")) != 0:
        d_color = _color_value(_val_start(vs, ve))
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("background-color")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("background")) != 0:
        cv: int32 = _color_value(_val_start(vs, ve))
        if cv >= 0:
            d_bg = cv
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("font-weight")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("bold")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("700")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("800")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("900")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("600")) != 0:
            d_weight = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("normal")) != 0:
            d_weight = 2
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("text-align")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("center")) != 0:
            d_align = 2
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("right")) != 0:
            d_align = 3
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("left")) != 0:
            d_align = 1
        return
    # text-decoration / text-decoration-line: the value is a space list that may
    # carry a style/colour (e.g. "underline dotted red"); we honour the LINE
    # keyword. "underline" -> draw a rule; "none" -> suppress (strip link u-line).
    if _prop_is(ps, pe, cast[Ptr[uint8]]("text-decoration")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("text-decoration-line")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("underline")) != 0:
            d_deco = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("none")) != 0:
            d_deco = 2
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("display")) != 0:
        d_disp = _disp_value(vs, ve)
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("flex-direction")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("column")) != 0:
            d_flexdir = 1
        else:
            d_flexdir = 2
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("justify-content")) != 0:
        jv: int32 = _justify_value(vs, ve)
        if jv != 0:
            d_justify = jv
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("align-items")) != 0:
        av: int32 = _align_items_value(vs, ve)
        if av != 0:
            d_aitems = av
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("flex-wrap")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("wrap")) != 0:
            d_flexwrap = 1
        else:
            d_flexwrap = 0                            # nowrap / wrap-reverse->off
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("grid-template-columns")) != 0:
        d_gtcn = _grid_parse_template(vs, ve)
        gc: int32 = 0
        while gc < d_gtcn and gc < GRID_MAXTRACK:
            d_gtc[gc] = gts_enc[gc]
            gc = gc + 1
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("grid-template-rows")) != 0:
        d_gtrn = _grid_parse_template(vs, ve)
        gr: int32 = 0
        while gr < d_gtrn and gr < GRID_MAXTRACK:
            d_gtr[gr] = gts_enc[gr]
            gr = gr + 1
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("grid-column")) != 0:
        _grid_column_parse(vs, ve)
        return
    # flex gaps. `gap: <row> [<col>]` shorthand sets both (one value => both);
    # `row-gap` / `column-gap` set one axis.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("gap")) != 0:
        _parse_box_lens(vs, ve)
        if n_box_lens >= 1:
            d_rowgap = box_lens[0]
            if n_box_lens >= 2:
                d_flexgap = box_lens[1]
            else:
                d_flexgap = box_lens[0]
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("column-gap")) != 0:
        gp: int32 = _style_len(vs, ve)
        if gp >= 0:
            d_flexgap = gp
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("row-gap")) != 0:
        rgp: int32 = _style_len(vs, ve)
        if rgp >= 0:
            d_rowgap = rgp
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("font-size")) != 0:
        fp: int32 = _style_len(vs, ve)
        if fp > 0:
            d_fontpx = fp
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("line-height")) != 0:
        lh: int32 = _lineh_value(_val_start(vs, ve), ve)
        if lh != 0:
            d_lineh = lh
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("white-space")) != 0:
        ws: int32 = _ws_value(vs, ve)
        if ws != 0:
            d_ws = ws
        return


# Parse a declaration block src[a..b) into d_* globals.
def _parse_decls(a: uint64, b: uint64):
    d_color = -1
    d_bg = -1
    d_weight = 0
    d_align = 0
    d_deco = 0
    d_disp = 0
    d_flexdir = 0
    d_justify = 0
    d_aitems = 0
    d_flexgap = -1
    d_rowgap = -1
    d_flexwrap = 0
    d_gtcn = 0
    d_gtrn = 0
    d_gcspan = 0
    d_gcstart = 0
    d_ml = -1
    d_mr = -1
    d_mt = -1
    d_mb = -1
    d_wd = -1
    d_bd = -1
    d_center = 0
    d_fontpx = -1
    d_lineh = 0
    d_ws = 0
    d_float = 0
    d_pos = 0
    d_top = -1
    d_left = -1
    d_right = -1
    d_bottom = -1
    d_zidx = ZIDX_UNSET
    i: uint64 = a
    while i < b:
        ps: uint64 = i
        while i < b and src_ptr[i] != 58 and src_ptr[i] != 59:   # ':' ';'
            i = i + 1
        if i < b and src_ptr[i] == 58:
            pe: uint64 = i
            i = i + 1
            vs: uint64 = i
            while i < b and src_ptr[i] != 59:
                i = i + 1
            _apply_decl(ps, pe, vs, i)
        if i < b and src_ptr[i] == 59:
            i = i + 1


# ---- stylesheet collection ------------------------------------------
# Parse selector-list { decls } starting at src[a]; returns offset just past
# the closing '}'. Emits one rule per comma-separated selector.
def _parse_ruleset(a: uint64, rgn_end: uint64) -> uint64:
    # selector list up to '{'
    sel_s: uint64 = a
    i: uint64 = a
    while i < rgn_end and src_ptr[i] != 123 and src_ptr[i] != 60:   # '{' '<'
        i = i + 1
    if i >= rgn_end or src_ptr[i] != 123:
        return i
    sel_e: uint64 = i
    i = i + 1
    dec_s: uint64 = i
    while i < rgn_end and src_ptr[i] != 125:                        # '}'
        i = i + 1
    dec_e: uint64 = i
    if i < rgn_end:
        i = i + 1
    _parse_decls(dec_s, dec_e)
    # Nothing we honour -> skip emitting rules entirely.
    if d_color < 0 and d_bg < 0 and d_weight == 0 and d_align == 0 and \
       d_deco == 0 and \
       d_disp == 0 and d_flexdir == 0 and d_justify == 0 and d_aitems == 0 and \
       d_flexgap < 0 and d_rowgap < 0 and d_flexwrap == 0 and d_gtcn == 0 and \
       d_gtrn == 0 and d_gcspan == 0 and d_gcstart == 0 and \
       d_ml < 0 and d_mr < 0 and d_mt < 0 and d_mb < 0 and \
       d_wd < 0 and d_bd < 0 and d_center == 0 and d_fontpx < 0 and \
       d_lineh == 0 and \
       d_ws == 0 and \
       d_float == 0 and \
       d_pos == 0 and d_top < 0 and d_left < 0 and d_right < 0 and d_bottom < 0 and \
       d_zidx == ZIDX_UNSET:
        return i
    # one rule per comma-separated selector
    ss: uint64 = sel_s
    k: uint64 = sel_s
    while k <= sel_e:
        if k == sel_e or src_ptr[k] == 44:           # ',' or end
            if n_rules < MAX_RULES and k > ss:
                ri: int32 = n_rules
                _parse_selector(ss, k, ri)
                r_color[ri]  = d_color
                r_bg[ri]     = d_bg
                r_weight[ri] = d_weight
                r_align[ri]  = d_align
                r_deco[ri]   = d_deco
                r_disp[ri]   = d_disp
                r_flexdir[ri] = d_flexdir
                r_justify[ri] = d_justify
                r_aitems[ri] = d_aitems
                r_flexgap[ri] = d_flexgap
                r_rowgap[ri] = d_rowgap
                r_flexwrap[ri] = d_flexwrap
                r_gtcn[ri] = d_gtcn
                gtc: int32 = 0
                while gtc < d_gtcn and gtc < GRID_MAXTRACK:
                    r_gtc[ri * GRID_MAXTRACK + gtc] = d_gtc[gtc]
                    gtc = gtc + 1
                r_gtrn[ri] = d_gtrn
                gtr: int32 = 0
                while gtr < d_gtrn and gtr < GRID_MAXTRACK:
                    r_gtr[ri * GRID_MAXTRACK + gtr] = d_gtr[gtr]
                    gtr = gtr + 1
                r_gcspan[ri]  = d_gcspan
                r_gcstart[ri] = d_gcstart
                r_ml[ri]     = d_ml
                r_mr[ri]     = d_mr
                r_mt[ri]     = d_mt
                r_mb[ri]     = d_mb
                r_wd[ri]     = d_wd
                r_bd[ri]     = d_bd
                r_center[ri] = d_center
                r_fontpx[ri] = d_fontpx
                r_lineh[ri]  = d_lineh
                r_ws[ri]     = d_ws
                r_float[ri]  = d_float
                r_pos[ri]    = d_pos
                r_top[ri]    = d_top
                r_left[ri]   = d_left
                r_right[ri]  = d_right
                r_bottom[ri] = d_bottom
                r_zidx[ri]   = d_zidx
                n_rules = n_rules + 1
            ss = k + 1
        k = k + 1
    return i


# ---- external stylesheets (<link rel=stylesheet href=...>) ----------
# The engine is PURE (no fetch): a front-end resolves each linked sheet's href
# against the page URL, fetches it over its existing http9/file path, and hands
# the raw CSS bytes to he_css_append(); _collect_css() then parses them through
# the SAME cascade as inline <style>. he_css_reset() clears the buffer per page.
# The link-scan (he_css_scan_links) hands the front-end the hrefs to fetch.
HE_CSS_CAP:   uint64 = 262144
he_css_buf:   Array[262144, uint8]
he_css_len:   uint64 = 0
MAX_CSS_LINKS: int32 = 16
css_link_off: Array[16, uint64]      # href value offset into the loaded src
css_link_len: Array[16, int32]
n_css_links:  int32 = 0


def he_css_reset():
    he_css_len = 0


# Append raw CSS bytes (a fetched external sheet) to the cascade buffer. Silently
# truncates past the cap so a pathological megasheet can't run the engine away.
def he_css_append(p: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n and he_css_len < HE_CSS_CAP:
        he_css_buf[he_css_len] = p[i]
        he_css_len = he_css_len + 1
        i = i + 1
    # a declaration separator so back-to-back sheets never fuse a rule
    if he_css_len < HE_CSS_CAP:
        he_css_buf[he_css_len] = 10
        he_css_len = he_css_len + 1


# Parse a sheet region src[a,b) as a sequence of rulesets (skipping /* */ + ws).
# Shared by the <style> scan and the external he_css_buf parse.
def _parse_sheet(a: uint64, b: uint64):
    p: uint64 = a
    while p < b:
        if p + 1 < b and src_ptr[p] == 47 and src_ptr[p + 1] == 42:
            p = p + 2
            while p + 1 < b and not (src_ptr[p] == 42 and src_ptr[p + 1] == 47):
                p = p + 1
            p = p + 2
            continue
        if src_ptr[p] == 32 or src_ptr[p] == 9 or \
           src_ptr[p] == 10 or src_ptr[p] == 13:
            p = p + 1
            continue
        np: uint64 = _parse_ruleset(p, b)
        if np <= p:
            p = p + 1
        else:
            p = np


# Does the rel="..." value region src[a,b) contain the token "stylesheet"?
def _rel_is_stylesheet(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i < b:
        if _lower(src_ptr[i]) == 115:                # 's'
            lit: Ptr[uint8] = cast[Ptr[uint8]]("stylesheet")
            j: int32 = 0
            ok: int32 = 1
            while lit[j] != 0:
                if i + cast[uint64](j) >= b or \
                   _lower(src_ptr[i + cast[uint64](j)]) != lit[j]:
                    ok = 0
                    break
                j = j + 1
            if ok != 0:
                return 1
        i = i + 1
    return 0


# Scan the loaded HTML for <link rel=stylesheet href=...> and record each href
# (offset+len into src) so the front-end can fetch them. Front-end-agnostic +
# pure; the front-end resolves the URL and calls he_css_append() with the bytes.
def he_css_scan_links():
    n_css_links = 0
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60:                         # '<'
            k: uint64 = i + 1
            if _tagname_is(k, cast[Ptr[uint8]]("link")) != 0:
                te: uint64 = k
                while te < src_len and src_ptr[te] != 62:
                    te = te + 1
                is_ss: int32 = 0
                if _find_attr(k, te, cast[Ptr[uint8]]("rel")) != 0:
                    is_ss = _rel_is_stylesheet(g_attr_start, g_attr_end)
                if is_ss != 0 and n_css_links < MAX_CSS_LINKS and \
                   _find_attr(k, te, cast[Ptr[uint8]]("href")) != 0 and \
                   g_attr_end > g_attr_start:
                    css_link_off[n_css_links] = g_attr_start
                    css_link_len[n_css_links] = \
                        cast[int32](g_attr_end - g_attr_start)
                    n_css_links = n_css_links + 1
                i = te
                continue
        i = i + 1


def he_css_link_count() -> int32:
    return n_css_links


def he_css_link_off(i: int32) -> uint64:
    return css_link_off[i]


def he_css_link_len(i: int32) -> int32:
    return css_link_len[i]


# Scan the whole page for <style> blocks and parse their rules.
def _collect_css():
    n_rules = 0
    css_slen = 0
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60:                         # '<'
            k: uint64 = i + 1
            if _tagname_is(k, cast[Ptr[uint8]]("style")) != 0:
                # advance to end of the opening tag
                while i < src_len and src_ptr[i] != 62:
                    i = i + 1
                if i < src_len:
                    i = i + 1
                body: uint64 = i
                # region ends at </style>
                e: uint64 = body
                while e < src_len:
                    if src_ptr[e] == 60 and e + 1 < src_len and \
                       src_ptr[e + 1] == 47 and \
                       _tagname_is(e + 2, cast[Ptr[uint8]]("style")) != 0:
                        break
                    e = e + 1
                # parse rulesets within [body,e)
                _parse_sheet(body, e)
                i = e
                continue
        i = i + 1
    # External <link rel=stylesheet> sheets the front-end fetched (he_css_append)
    # cascade through the SAME ruleset path: temporarily point the parser at the
    # CSS buffer so _parse_ruleset/_parse_selector read from it, then restore.
    if he_css_len > 0:
        save_p: Ptr[uint8] = src_ptr
        save_l: uint64 = src_len
        src_ptr = &he_css_buf[0]
        src_len = he_css_len
        _parse_sheet(0, he_css_len)
        src_ptr = save_p
        src_len = save_l


# ---- element stack + cascade matching -------------------------------
def _el_copy(a: uint64, b: uint64) -> int32:
    n: int32 = 0
    i: uint64 = a
    while i < b and el_slen < EL_STR_CAP - 1:
        el_sbuf[el_slen] = _lower(src_ptr[i])
        el_slen = el_slen + 1
        n = n + 1
        i = i + 1
    return n


def _el_push(np: uint64, nlen: uint64, ne: uint64, te: uint64):
    if el_sp >= MAX_EL:
        return
    s: int32 = cast[int32](el_slen)
    el_tag_off[el_sp] = s
    el_tag_len[el_sp] = _el_copy(np, np + nlen)
    el_cls_off[el_sp] = cast[int32](el_slen)
    el_cls_len[el_sp] = 0
    if _find_attr(ne, te, cast[Ptr[uint8]]("class")) != 0:
        el_cls_len[el_sp] = _el_copy(g_attr_start, g_attr_end)
    el_id_off[el_sp] = cast[int32](el_slen)
    el_id_len[el_sp] = 0
    if _find_attr(ne, te, cast[Ptr[uint8]]("id")) != 0:
        el_id_len[el_sp] = _el_copy(g_attr_start, g_attr_end)
    el_sp = el_sp + 1


def _el_pop(np: uint64, nlen: uint64):
    # forgiving: pop the nearest matching open element (tolerates unclosed
    # inner tags), else leave the stack unchanged.
    k: int32 = el_sp - 1
    while k >= 0:
        if _buf_eq(&el_sbuf[el_tag_off[k]], el_tag_len[k], \
                   &src_ptr[np], cast[int32](nlen)) != 0:
            el_slen = cast[uint64](el_tag_off[k])
            el_sp = k
            return
        k = k - 1


# Does compound (target of rule ri) match the element at stack index e?
# Every class token in the selector's (space-joined) class string
# css_sbuf[koff..koff+klen) must be present in the element's class list — a
# compound `.a.b` matches only an element carrying BOTH `a` and `b`.
def _all_cls_match(coff: int32, clen: int32, koff: int32, klen: int32) -> int32:
    i: int32 = 0
    while i < klen:
        while i < klen and css_sbuf[koff + i] == 32:
            i = i + 1
        s: int32 = i
        while i < klen and css_sbuf[koff + i] != 32:
            i = i + 1
        tlen: int32 = i - s
        if tlen > 0:
            if _cls_contains(coff, clen, koff + s, tlen) == 0:
                return 0
    return 1


def _tgt_matches(ri: int32, e: int32) -> int32:
    if r_tag_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_tag_off[e]], el_tag_len[e], \
                   &css_sbuf[r_tag_off[ri]], r_tag_len[ri]) == 0:
            return 0
    if r_cls_len[ri] > 0:
        if _all_cls_match(el_cls_off[e], el_cls_len[e], \
                          r_cls_off[ri], r_cls_len[ri]) == 0:
            return 0
    if r_id_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_id_off[e]], el_id_len[e], \
                   &css_sbuf[r_id_off[ri]], r_id_len[ri]) == 0:
            return 0
    return 1


def _anc_matches(ri: int32, e: int32) -> int32:
    if r_atag_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_tag_off[e]], el_tag_len[e], \
                   &css_sbuf[r_atag_off[ri]], r_atag_len[ri]) == 0:
            return 0
    if r_acls_len[ri] > 0:
        if _all_cls_match(el_cls_off[e], el_cls_len[e], \
                          r_acls_off[ri], r_acls_len[ri]) == 0:
            return 0
    if r_aid_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_id_off[e]], el_id_len[e], \
                   &css_sbuf[r_aid_off[ri]], r_aid_len[ri]) == 0:
            return 0
    return 1


def _rule_matches(ri: int32, top: int32) -> int32:
    if _tgt_matches(ri, top) == 0:
        return 0
    if r_has_anc[ri] == 0:
        return 1
    a: int32 = top - 1
    while a >= 0:
        if _anc_matches(ri, a) != 0:
            return 1
        a = a - 1
    return 0


# Resolve the cascade for the current (topmost) open element into m_*.
def _cascade_match_current():
    m_col = -1
    m_bg = -1
    m_weight = 0
    m_align = 0
    m_deco = 0
    m_disp = 0
    m_flexdir = 0
    m_justify = 0
    m_aitems = 0
    m_flexgap = -1
    m_rowgap = -1
    m_flexwrap = 0
    m_gtcn = 0
    m_gtrn = 0
    m_gcspan = 0
    m_gcstart = 0
    m_ml = -1
    m_mr = -1
    m_mt = -1
    m_mb = -1
    m_wd = -1
    m_bd = -1
    m_center = 0
    m_fontpx = -1
    m_lineh = 0
    m_ws = 0
    m_float = 0
    m_pos = 0
    m_top = -1
    m_left = -1
    m_right = -1
    m_bottom = -1
    m_zidx = ZIDX_UNSET
    if el_sp == 0:
        return
    top: int32 = el_sp - 1
    bc: int32 = -1
    bb: int32 = -1
    bw: int32 = -1
    ba: int32 = -1
    bde: int32 = -1
    bd: int32 = -1
    bfd: int32 = -1
    bjc: int32 = -1
    bai: int32 = -1
    bjg: int32 = -1
    brg: int32 = -1
    bfw: int32 = -1
    bgt: int32 = -1
    bgr: int32 = -1
    bgp: int32 = -1
    # best-spec trackers for the six box axes
    sml: int32 = -1
    smr: int32 = -1
    smt: int32 = -1
    smb: int32 = -1
    swd: int32 = -1
    sbd: int32 = -1
    sfp: int32 = -1
    slh: int32 = -1
    sws: int32 = -1
    sfl: int32 = -1
    spo: int32 = -1
    stp: int32 = -1
    slf: int32 = -1
    srt: int32 = -1
    sbt: int32 = -1
    szi: int32 = -1
    ri: int32 = 0
    while ri < n_rules:
        if _rule_matches(ri, top) != 0:
            sp: int32 = r_spec[ri]
            if r_color[ri] >= 0 and sp >= bc:
                bc = sp
                m_col = r_color[ri]
            if r_bg[ri] >= 0 and sp >= bb:
                bb = sp
                m_bg = r_bg[ri]
            if r_weight[ri] != 0 and sp >= bw:
                bw = sp
                m_weight = r_weight[ri]
            if r_align[ri] != 0 and sp >= ba:
                ba = sp
                m_align = r_align[ri]
            if r_deco[ri] != 0 and sp >= bde:
                bde = sp
                m_deco = r_deco[ri]
            if r_disp[ri] != 0 and sp >= bd:
                bd = sp
                m_disp = r_disp[ri]
            if r_flexdir[ri] != 0 and sp >= bfd:
                bfd = sp
                m_flexdir = r_flexdir[ri]
            if r_justify[ri] != 0 and sp >= bjc:
                bjc = sp
                m_justify = r_justify[ri]
            if r_aitems[ri] != 0 and sp >= bai:
                bai = sp
                m_aitems = r_aitems[ri]
            if r_flexgap[ri] >= 0 and sp >= bjg:
                bjg = sp
                m_flexgap = r_flexgap[ri]
            if r_rowgap[ri] >= 0 and sp >= brg:
                brg = sp
                m_rowgap = r_rowgap[ri]
            if r_flexwrap[ri] != 0 and sp >= bfw:
                bfw = sp
                m_flexwrap = r_flexwrap[ri]
            if r_gtcn[ri] != 0 and sp >= bgt:
                bgt = sp
                m_gtcn = r_gtcn[ri]
                gm: int32 = 0
                while gm < r_gtcn[ri] and gm < GRID_MAXTRACK:
                    m_gtc[gm] = r_gtc[ri * GRID_MAXTRACK + gm]
                    gm = gm + 1
            if r_gtrn[ri] != 0 and sp >= bgr:
                bgr = sp
                m_gtrn = r_gtrn[ri]
                gmr: int32 = 0
                while gmr < r_gtrn[ri] and gmr < GRID_MAXTRACK:
                    m_gtr[gmr] = r_gtr[ri * GRID_MAXTRACK + gmr]
                    gmr = gmr + 1
            if (r_gcspan[ri] != 0 or r_gcstart[ri] != 0) and sp >= bgp:
                bgp = sp
                m_gcspan  = r_gcspan[ri]
                m_gcstart = r_gcstart[ri]
            if r_ml[ri] >= 0 and sp >= sml:
                sml = sp
                m_ml = r_ml[ri]
            if r_mr[ri] >= 0 and sp >= smr:
                smr = sp
                m_mr = r_mr[ri]
            if r_mt[ri] >= 0 and sp >= smt:
                smt = sp
                m_mt = r_mt[ri]
            if r_mb[ri] >= 0 and sp >= smb:
                smb = sp
                m_mb = r_mb[ri]
            if r_wd[ri] >= 0 and sp >= swd:
                swd = sp
                m_wd = r_wd[ri]
            if r_bd[ri] >= 0 and sp >= sbd:
                sbd = sp
                m_bd = r_bd[ri]
            if r_center[ri] != 0:
                m_center = 1
            if r_fontpx[ri] >= 0 and sp >= sfp:
                sfp = sp
                m_fontpx = r_fontpx[ri]
            if r_lineh[ri] != 0 and sp >= slh:
                slh = sp
                m_lineh = r_lineh[ri]
            if r_ws[ri] != 0 and sp >= sws:
                sws = sp
                m_ws = r_ws[ri]
            if r_float[ri] != 0 and sp >= sfl:
                sfl = sp
                m_float = r_float[ri]
            if r_pos[ri] != 0 and sp >= spo:
                spo = sp
                m_pos = r_pos[ri]
            if r_top[ri] >= 0 and sp >= stp:
                stp = sp
                m_top = r_top[ri]
            if r_left[ri] >= 0 and sp >= slf:
                slf = sp
                m_left = r_left[ri]
            if r_right[ri] >= 0 and sp >= srt:
                srt = sp
                m_right = r_right[ri]
            if r_bottom[ri] >= 0 and sp >= sbt:
                sbt = sp
                m_bottom = r_bottom[ri]
            if r_zidx[ri] != ZIDX_UNSET and sp >= szi:
                szi = sp
                m_zidx = r_zidx[ri]
        ri = ri + 1


# ---- font-weight (bold) scope ---------------------------------------
def _css_weight_effective() -> int32:
    i: int32 = weight_sp - 1
    while i >= 0:
        if weight_stack[i] != 0:
            return weight_stack[i]
        i = i - 1
    return 0


def _weight_push(w: int32):
    if weight_sp < 64:
        weight_stack[weight_sp] = w
        weight_sp = weight_sp + 1
    if _css_weight_effective() == 1:
        g_css_bold = 1
    else:
        g_css_bold = 0


def _weight_pop():
    if weight_sp > 0:
        weight_sp = weight_sp - 1
    if _css_weight_effective() == 1:
        g_css_bold = 1
    else:
        g_css_bold = 0


# ---- font-size (px) scope — inherits the nearest ancestor that set one ----
def _fontpx_effective() -> int32:
    i: int32 = fontpx_sp - 1
    while i >= 0:
        if fontpx_stack[i] > 0:
            return fontpx_stack[i]
        i = i - 1
    return 0


def _fontpx_push(px: int32):
    if fontpx_sp < 64:
        fontpx_stack[fontpx_sp] = px
        fontpx_sp = fontpx_sp + 1
    g_font_px = _fontpx_effective()


def _fontpx_pop():
    if fontpx_sp > 0:
        fontpx_sp = fontpx_sp - 1
    g_font_px = _fontpx_effective()


# ---- line-height (px) scope — inherits the nearest ancestor that set one ----
def _lineh_effective() -> int32:
    i: int32 = lineh_sp - 1
    while i >= 0:
        if lineh_stack[i] > 0:
            return lineh_stack[i]
        i = i - 1
    return 0


def _lineh_push(px: int32):
    if lineh_sp < 64:
        lineh_stack[lineh_sp] = px
        lineh_sp = lineh_sp + 1
    g_lineh = _lineh_effective()


def _lineh_pop():
    if lineh_sp > 0:
        lineh_sp = lineh_sp - 1
    g_lineh = _lineh_effective()


# ---- white-space scope — inherits the nearest ancestor that set one --------
# Entries are mode+1 (0 = level sets none). Effective g_ws is the nearest
# non-zero entry minus 1 (0..3), or 0 (normal) when nothing on the stack set it.
def _ws_effective() -> int32:
    i: int32 = ws_sp - 1
    while i >= 0:
        if ws_stack[i] != 0:
            return ws_stack[i] - 1
        i = i - 1
    return 0


def _ws_push(enc: int32):
    if ws_sp < 64:
        ws_stack[ws_sp] = enc
        ws_sp = ws_sp + 1
    g_ws = _ws_effective()


def _ws_pop():
    if ws_sp > 0:
        ws_sp = ws_sp - 1
    g_ws = _ws_effective()


# ---- text-align scope -----------------------------------------------
def _align_effective() -> int32:
    i: int32 = align_sp - 1
    while i >= 0:
        if align_stack[i] != 0:
            return align_stack[i]
        i = i - 1
    return 0


def _align_push(a: int32):
    if align_sp < 64:
        align_stack[align_sp] = a
        align_sp = align_sp + 1
    g_align = _align_effective()


def _align_pop():
    if align_sp > 0:
        align_sp = align_sp - 1
    g_align = _align_effective()


# ---- text-decoration (underline) scope ------------------------------
# Inherits the nearest ancestor that set a decoration, so an underlined block
# carries the rule down to its inline text. 1 = underline, 2 = none.
def _deco_effective() -> int32:
    i: int32 = deco_sp - 1
    while i >= 0:
        if deco_stack[i] != 0:
            return deco_stack[i]
        i = i - 1
    return 0


def _deco_push(d: int32):
    if deco_sp < 64:
        deco_stack[deco_sp] = d
        deco_sp = deco_sp + 1
    g_css_uline = _deco_effective()
    _recompute_style()


def _deco_pop():
    if deco_sp > 0:
        deco_sp = deco_sp - 1
    g_css_uline = _deco_effective()
    _recompute_style()


# The colour an element specifies for ITSELF: its matched-cascade colour (m_col,
# valid right after the element's _cascade_match_current) overridden by an inline
# style="color:…". Returns -1 when the element sets no colour of its own (an
# inherited ancestor colour is NOT its own). Used to let a styled anchor override
# the default link blue without an inherited body colour leaking onto plain links.
def _own_color(ne: uint64, te: uint64) -> int32:
    c: int32 = m_col
    ic: int32 = _tag_color(ne, te)
    if ic >= 0:
        c = ic
    return c


# Open/close a full style scope for a stylable element. The cascade is matched
# from el_stack (already pushed) and merged with the inline style="" overrides.
def _open_style(ne: uint64, te: uint64):
    _cascade_match_current()
    col: int32 = m_col
    ic: int32 = _tag_color(ne, te)
    if ic >= 0:
        col = ic
    bgv: int32 = m_bg
    ib: int32 = _tag_bgcolor(ne, te)
    if ib >= 0:
        bgv = ib
    wt: int32 = m_weight
    al: int32 = m_align
    dec: int32 = m_deco
    fpx: int32 = m_fontpx
    # inline style="" font-weight / text-align / text-decoration / font-size
    # override the cascade.
    _parse_inline_wa(ne, te)
    if d_weight != 0:
        wt = d_weight
    if d_align != 0:
        al = d_align
    if d_deco != 0:
        dec = d_deco
    if d_fontpx >= 0:
        fpx = d_fontpx
    push_px: int32 = 0
    if fpx >= 0:
        push_px = fpx
    # line-height: inline overrides the cascade; resolve unitless/% against this
    # element's effective font-size (its own if set, else the inherited one).
    lh_enc: int32 = m_lineh
    if d_lineh != 0:
        lh_enc = d_lineh
    lh_base: int32 = push_px
    if lh_base <= 0:
        lh_base = g_font_px
    lh_px: int32 = _lineh_resolve(lh_enc, lh_base)
    # white-space: inline declaration wins over the cascade (both mode+1 encoded).
    ws_enc: int32 = m_ws
    if d_ws != 0:
        ws_enc = d_ws
    # The presentational HTML `nowrap` attribute (e.g. <td nowrap>) maps to
    # white-space:nowrap, unless an inline `white-space` style overrides it.
    # Real pages (google.com's footer cells) rely on this to keep a short label
    # like "Advanced search" on one line inside a narrow table column instead of
    # collapsing to one glyph per row.
    if d_ws == 0 and _find_attr(ne, te, cast[Ptr[uint8]]("nowrap")) != 0:
        ws_enc = 2
    _color_push(col)
    _bg_push(bgv)
    _weight_push(wt)
    _align_push(al)
    _deco_push(dec)
    _fontpx_push(push_px)
    _lineh_push(lh_px)
    _ws_push(ws_enc)


def _close_style():
    _color_pop()
    _bg_pop()
    _weight_pop()
    _align_pop()
    _deco_pop()
    _fontpx_pop()
    _lineh_pop()
    _ws_pop()


# Scan an inline style="" attribute for font-weight/text-align/display + the
# full box model (margin/padding/width/border); sets d_weight/d_align/d_disp
# and the d_* box scratch (d_color/d_bg come from _tag_color/_tag_bgcolor).
# Inline declarations here override any stylesheet/class rule (highest priority).
def _parse_inline_wa(ne: uint64, te: uint64):
    d_weight = 0
    d_align = 0
    d_deco = 0
    d_disp = 0
    d_flexdir = 0
    d_justify = 0
    d_aitems = 0
    d_flexgap = -1
    d_rowgap = -1
    d_flexwrap = 0
    d_gtcn = 0
    d_gtrn = 0
    d_gcspan = 0
    d_gcstart = 0
    d_ml = -1
    d_mr = -1
    d_mt = -1
    d_mb = -1
    d_wd = -1
    d_bd = -1
    d_center = 0
    d_fontpx = -1
    d_lineh = 0
    d_ws = 0
    d_float = 0
    d_pos = 0
    d_top = -1
    d_left = -1
    d_right = -1
    d_bottom = -1
    d_zidx = ZIDX_UNSET
    if _find_attr(ne, te, cast[Ptr[uint8]]("style")) == 0:
        return
    a: uint64 = g_attr_start
    b: uint64 = g_attr_end
    i: uint64 = a
    while i < b:
        ps: uint64 = i
        while i < b and src_ptr[i] != 58 and src_ptr[i] != 59:
            i = i + 1
        if i < b and src_ptr[i] == 58:
            pe: uint64 = i
            i = i + 1
            vs: uint64 = i
            while i < b and src_ptr[i] != 59:
                i = i + 1
            # box model (margin/padding/width/border) — shared with the sheet.
            if _box_decl(ps, pe, vs, i) != 0:
                pass
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("font-weight")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("bold")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("700")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("800")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("900")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("600")) != 0:
                    d_weight = 1
                elif _val_starts(vs, i, cast[Ptr[uint8]]("normal")) != 0:
                    d_weight = 2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("text-align")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("center")) != 0:
                    d_align = 2
                elif _val_starts(vs, i, cast[Ptr[uint8]]("right")) != 0:
                    d_align = 3
                elif _val_starts(vs, i, cast[Ptr[uint8]]("left")) != 0:
                    d_align = 1
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("text-decoration")) != 0 or \
                 _prop_is(ps, pe, cast[Ptr[uint8]]("text-decoration-line")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("underline")) != 0:
                    d_deco = 1
                elif _val_starts(vs, i, cast[Ptr[uint8]]("none")) != 0:
                    d_deco = 2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("display")) != 0:
                d_disp = _disp_value(vs, i)
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("flex-direction")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("column")) != 0:
                    d_flexdir = 1
                else:
                    d_flexdir = 2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("justify-content")) != 0:
                jv2: int32 = _justify_value(vs, i)
                if jv2 != 0:
                    d_justify = jv2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("align-items")) != 0:
                av2: int32 = _align_items_value(vs, i)
                if av2 != 0:
                    d_aitems = av2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("flex-wrap")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("wrap")) != 0:
                    d_flexwrap = 1
                else:
                    d_flexwrap = 0
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("grid-template-columns")) != 0:
                d_gtcn = _grid_parse_template(vs, i)
                gci: int32 = 0
                while gci < d_gtcn and gci < GRID_MAXTRACK:
                    d_gtc[gci] = gts_enc[gci]
                    gci = gci + 1
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("grid-template-rows")) != 0:
                d_gtrn = _grid_parse_template(vs, i)
                gri: int32 = 0
                while gri < d_gtrn and gri < GRID_MAXTRACK:
                    d_gtr[gri] = gts_enc[gri]
                    gri = gri + 1
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("grid-column")) != 0:
                _grid_column_parse(vs, i)
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("gap")) != 0:
                _parse_box_lens(vs, i)
                if n_box_lens >= 1:
                    d_rowgap = box_lens[0]
                    if n_box_lens >= 2:
                        d_flexgap = box_lens[1]
                    else:
                        d_flexgap = box_lens[0]
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("column-gap")) != 0:
                gp2: int32 = _style_len(vs, i)
                if gp2 >= 0:
                    d_flexgap = gp2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("row-gap")) != 0:
                rgp2: int32 = _style_len(vs, i)
                if rgp2 >= 0:
                    d_rowgap = rgp2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("font-size")) != 0:
                fp: int32 = _style_len(vs, i)
                if fp > 0:
                    d_fontpx = fp
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("line-height")) != 0:
                lh: int32 = _lineh_value(_val_start(vs, i), i)
                if lh != 0:
                    d_lineh = lh
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("white-space")) != 0:
                wsv: int32 = _ws_value(vs, i)
                if wsv != 0:
                    d_ws = wsv
        if i < b and src_ptr[i] == 59:
            i = i + 1


# Resolve whether the element being opened is display:none (cascade or inline).
def _is_display_none(ne: uint64, te: uint64) -> int32:
    _parse_inline_wa(ne, te)
    if d_disp == 1:                                  # inline display:none
        return 1
    if d_disp >= 2:                                  # any explicit inline display (shown)
        return 0
    if m_disp == 1:                                  # cascade display:none
        return 1
    return 0


# ====================================================================
# TABLE two-pass column layout.
# ====================================================================
def _alnum_at(p: uint64) -> int32:
    if p >= src_len:
        return 0
    c: uint8 = _lower(src_ptr[p])
    if (c >= 97 and c <= 122) or (c >= 48 and c <= 57):
        return 1
    return 0


# Locate an attribute VALUE `name="..."` (or name='...' / name=bare) in the
# tag body [ts,te). On success sets g_attr_start/g_attr_end to the value span
# and returns 1; returns 0 if the attribute is absent.
g_attr_start: uint64 = 0
g_attr_end:   uint64 = 0


def _find_attr(ts: uint64, te: uint64, name: Ptr[uint8]) -> int32:
    nl: uint64 = 0
    while name[nl] != 0:
        nl = nl + 1
    i: uint64 = ts
    while i + nl <= te:
        prev_alpha: int32 = 0
        if i > ts:
            pc: uint8 = _lower(src_ptr[i - 1])
            if (pc >= 97 and pc <= 122) or (pc >= 48 and pc <= 57) or pc == 45:
                prev_alpha = 1
        if prev_alpha == 0 and _srcword_is(i, name) != 0 and \
           _alnum_at(i + nl) == 0:
            j: uint64 = i + nl
            while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
                j = j + 1
            if j < te and src_ptr[j] == 61:              # '='
                j = j + 1
                while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
                    j = j + 1
                quote: uint8 = 0
                if j < te and (src_ptr[j] == 34 or src_ptr[j] == 39):
                    quote = src_ptr[j]
                    j = j + 1
                g_attr_start = j
                while j < te:
                    c: uint8 = src_ptr[j]
                    if quote != 0:
                        if c == quote:
                            break
                    else:
                        if c == 32 or c == 9:
                            break
                    j = j + 1
                g_attr_end = j
                return 1
        i = i + 1
    return 0


# Read an integer-valued attribute (e.g. colspan="2") from tag body [ts,te).
# Returns the parsed value, or `dflt` when absent / non-numeric / < 1.
def _attr_int(ts: uint64, te: uint64, name: Ptr[uint8], dflt: int32) -> int32:
    if _find_attr(ts, te, name) == 0:
        return dflt
    v: int32 = 0
    p: uint64 = g_attr_start
    seen: int32 = 0
    while p < g_attr_end:
        d: uint8 = src_ptr[p]
        if d >= 48 and d <= 57:
            v = v * 10 + cast[int32](d - 48)
            seen = 1
        p = p + 1
    if seen == 0 or v < 1:
        return dflt
    return v


# A tag name at src[at] matches `lit` AND ends at a tag boundary (so "tr"
# does not match "track"). Returns 1 on a bounded match.
def _tagname_is(at: uint64, lit: Ptr[uint8]) -> int32:
    if _srcword_is(at, lit) == 0:
        return 0
    n: uint64 = 0
    while lit[n] != 0:
        n = n + 1
    if _alnum_at(at + n) != 0:
        return 0
    return 1


# Index of the '<' of the </table> that closes the table whose body begins at
# `body0` (nesting-aware). Returns src_len if unterminated.
def _table_region_end(body0: uint64) -> uint64:
    depth: int32 = 1
    i: uint64 = body0
    while i < src_len:
        if src_ptr[i] == 60:                         # '<'
            k: uint64 = i + 1
            close: int32 = 0
            if k < src_len and src_ptr[k] == 47:     # '/'
                close = 1
                k = k + 1
            if _tagname_is(k, cast[Ptr[uint8]]("table")) != 0:
                if close != 0:
                    depth = depth - 1
                    if depth == 0:
                        return i
                else:
                    depth = depth + 1
            while i < src_len and src_ptr[i] != 62:  # to '>'
                i = i + 1
            if i < src_len:
                i = i + 1
            continue
        i = i + 1
    return src_len


# Natural width (in character cells) of a table region, NESTING-AWARE and
# recursive: a cell that contains a sub-table contributes that sub-table's own
# natural width, so an outer cell's column grows wide enough to CONTAIN a nested
# table. Returns the widest row's summed cell widths — a safe containment upper
# bound; the per-column pass refines actual placement.
def _table_char_width(rgn_start: uint64, rgn_end: uint64) -> int32:
    maxrow: int32 = 0
    rowsum: int32 = 0
    cell_n: int32 = 0
    counting: int32 = 0
    pend_space: int32 = 0
    i: uint64 = rgn_start
    while i < rgn_end:
        ch: uint8 = src_ptr[i]
        if ch == 60:                                 # '<'
            k: uint64 = i + 1
            close: int32 = 0
            if k < rgn_end and src_ptr[k] == 47:
                close = 1
                k = k + 1
            tend: uint64 = k
            while tend < rgn_end and src_ptr[tend] != 62:
                tend = tend + 1
            if close == 0 and _tagname_is(k, cast[Ptr[uint8]]("table")) != 0:
                sub0: uint64 = tend
                if sub0 < rgn_end:
                    sub0 = sub0 + 1
                sube: uint64 = _table_region_end(sub0)
                w2: int32 = _table_char_width(sub0, sube)
                if w2 > cell_n:
                    cell_n = w2
                i = sube                             # resume at '<' of </table>
                continue
            is_cell: int32 = 0
            if _tagname_is(k, cast[Ptr[uint8]]("td")) != 0 or \
               _tagname_is(k, cast[Ptr[uint8]]("th")) != 0:
                is_cell = 1
            is_tr: int32 = _tagname_is(k, cast[Ptr[uint8]]("tr"))
            if is_cell != 0 or is_tr != 0:
                rowsum = rowsum + cell_n + CELL_PAD
                cell_n = 0
                counting = 0
                pend_space = 0
                if is_tr != 0 and close == 0:
                    if rowsum > maxrow:
                        maxrow = rowsum
                    rowsum = 0
                elif is_cell != 0 and close == 0:
                    counting = 1
            i = tend
            if i < rgn_end:
                i = i + 1
            continue
        if counting != 0:
            if ch == 32 or ch == 9 or ch == 10 or ch == 13:
                pend_space = 1
            else:
                if pend_space != 0 and cell_n > 0:
                    cell_n = cell_n + 1
                pend_space = 0
                cell_n = cell_n + 1
        i = i + 1
    rowsum = rowsum + cell_n + CELL_PAD
    if rowsum > maxrow:
        maxrow = rowsum
    return maxrow


# Pass 1: record the widest cell (in characters, whitespace-collapsed) per
# column across [rgn_start, rgn_end). Sets col_chars[] and n_cols. A nested
# <table> is skipped (its cells belong to the inner table) but its natural width
# sizes the enclosing cell so the outer column contains it.
def _measure_table(rgn_start: uint64, rgn_end: uint64):
    c: int32 = 0
    while c < MAX_COLS:
        col_chars[c] = 0
        c = c + 1
    n_cols = 0
    col: int32 = -1
    nextcol: int32 = 0          # column index the next cell starts at
    cspan: int32 = 1            # colspan of the currently-counting cell
    counting: int32 = 0
    cell_n: int32 = 0
    cell_th: int32 = 0          # the cell being counted is a <th> (bold glyphs)
    pend_space: int32 = 0
    i: uint64 = rgn_start
    while i < rgn_end:
        ch: uint8 = src_ptr[i]
        if ch == 60:                                 # '<'
            k: uint64 = i + 1
            close: int32 = 0
            if k < rgn_end and src_ptr[k] == 47:
                close = 1
                k = k + 1
            is_cell: int32 = 0
            is_th_tag: int32 = _tagname_is(k, cast[Ptr[uint8]]("th"))
            if _tagname_is(k, cast[Ptr[uint8]]("td")) != 0 or is_th_tag != 0:
                is_cell = 1
            is_tr: int32 = _tagname_is(k, cast[Ptr[uint8]]("tr"))
            # end of this tag's body ('>')
            tend: uint64 = k
            while tend < rgn_end and src_ptr[tend] != 62:
                tend = tend + 1
            if close == 0 and _tagname_is(k, cast[Ptr[uint8]]("table")) != 0:
                # nested table: skip its region, but grow the enclosing cell so
                # the outer column is wide enough to contain the inner grid.
                sub0: uint64 = tend
                if sub0 < rgn_end:
                    sub0 = sub0 + 1
                sube: uint64 = _table_region_end(sub0)
                if counting != 0:
                    w2: int32 = _table_char_width(sub0, sube)
                    if w2 > cell_n:
                        cell_n = w2
                i = sube                             # resume at '<' of </table>
                continue
            if is_cell != 0 or is_tr != 0:
                # finalize the cell that was open — a spanning cell (cspan>1)
                # does not size any single column, so only single-span cells
                # contribute to col_chars[]. A <th> renders BOLD, whose glyphs
                # are ~1/8 wider than the monospace CELL_W the column model
                # assumes, so reserve ~1/3 extra chars for it (covers the bold
                # advance plus the per-side CELL_PADX inset) — otherwise a bold
                # header like "Subsystem" overruns its column into the next one.
                eff: int32 = cell_n
                if cell_th != 0 and eff > 0:
                    eff = eff + (eff + 2) / 3
                if col >= 0 and col < MAX_COLS and cspan == 1 and \
                   eff > col_chars[col]:
                    col_chars[col] = eff
                counting = 0
                cell_n = 0
                cell_th = 0
                pend_space = 0
                cspan = 1
                if is_tr != 0 and close == 0:
                    nextcol = 0                       # new row restarts columns
                    col = -1
                elif is_cell != 0 and close == 0:
                    col = nextcol
                    cell_th = is_th_tag
                    cspan = _attr_int(k, tend, cast[Ptr[uint8]]("colspan"), 1)
                    nextcol = col + cspan
                    counting = 1
                    if nextcol > n_cols:
                        n_cols = nextcol
            i = tend
            if i < rgn_end:
                i = i + 1
            continue
        if counting != 0:
            if ch == 32 or ch == 9 or ch == 10 or ch == 13:
                pend_space = 1
            else:
                if pend_space != 0 and cell_n > 0:
                    cell_n = cell_n + 1
                pend_space = 0
                cell_n = cell_n + 1
        i = i + 1
    tail_eff: int32 = cell_n
    if cell_th != 0 and tail_eff > 0:
        tail_eff = tail_eff + (tail_eff + 2) / 3
    if col >= 0 and col < MAX_COLS and cspan == 1 and tail_eff > col_chars[col]:
        col_chars[col] = tail_eff


# Natural (unclamped) pixel width of the measured table — the sum of every
# column's char width (same growth rule _compute_cols uses). Drives the float
# box width for a floated <table> so the infobox is exactly as wide as its grid.
def _table_natural_width() -> int32:
    total: int32 = 0
    c: int32 = 0
    while c < n_cols and c < MAX_COLS:
        w: int32 = col_chars[c]
        if w < 1:
            w = 1
        if w > 60:
            w = 60
        total = total + (w + CELL_PAD) * CELL_W
        c = c + 1
    return total


# Pass 2: turn per-column character widths into pixel column x-positions.
def _compute_cols():
    # Inside a float/box, clamp columns to the box's right edge so a floated
    # infobox's grid stays within its pinned box; a top-level table (no block
    # active, blk_right_cur==0) keeps its historical full-width growth.
    right: int32 = _flow_right()
    bounded: int32 = 0
    if blk_right_cur > 0:
        bounded = 1
    # A nested table clamps to its parent cell's right edge (_flow_right returns
    # cell_right while cell_active) so the inner grid stays inside the outer cell.
    if cell_active != 0:
        bounded = 1
    x: int32 = indent_x
    c: int32 = 0
    while c < n_cols and c < MAX_COLS:
        col_x[c] = x
        w: int32 = col_chars[c]
        if w < 1:
            w = 1
        if w > 60:                                   # cap a runaway column
            w = 60
        cw: int32 = (w + CELL_PAD) * CELL_W
        if bounded != 0 and c > 0 and x + cw > right:
            cw = right - x
            if cw < 2 * CELL_W:
                cw = 2 * CELL_W
        x = x + cw
        c = c + 1
    if n_cols > MAX_COLS:
        n_cols = MAX_COLS
    col_x[n_cols] = x                                # right sentinel


# Close the open table cell: flush its word, drop its bold + colour scope.
def _cell_close():
    if cell_active == 0:
        return
    _word_flush()
    if cell_is_th != 0 and g_bold_n > 0:
        g_bold_n = g_bold_n - 1
    _close_style()
    cell_active = 0
    cell_is_th = 0
    _style_break()


# Push the parent table's column model + cell scope onto the nesting stack so a
# nested <table> can overwrite the shared col_x/n_cols/cur_col globals; the entry
# also carries slots for THIS table's border geometry (filled by the caller).
def _table_push():
    if tbl_sp >= TBL_MAX:
        return
    d: int32 = tbl_sp
    tbl_ncols_st[d]     = n_cols
    tbl_curcol_st[d]    = cur_col
    tbl_cellact_st[d]   = cell_active
    tbl_cellright_st[d] = cell_right
    tbl_cellisth_st[d]  = cell_is_th
    tbl_indentx_st[d]   = indent_x
    tbl_floated_st[d]   = table_floated
    c: int32 = 0
    while c <= MAX_COLS:
        tbl_colx_st[d * 33 + c] = col_x[c]
        c = c + 1
    tbl_srow_st[d]   = 0
    tbl_lx_st[d]     = 0
    tbl_border_st[d] = 0
    tbl_rgb_st[d]    = 0
    tbl_sp = tbl_sp + 1


# Restore the parent table's column model + cell scope saved by _table_push.
def _table_pop():
    if tbl_sp <= 0:
        return
    tbl_sp = tbl_sp - 1
    d: int32 = tbl_sp
    n_cols        = tbl_ncols_st[d]
    cur_col       = tbl_curcol_st[d]
    cell_active   = tbl_cellact_st[d]
    cell_right    = tbl_cellright_st[d]
    cell_is_th    = tbl_cellisth_st[d]
    indent_x      = tbl_indentx_st[d]
    table_floated = tbl_floated_st[d]
    c: int32 = 0
    while c <= MAX_COLS:
        col_x[c] = tbl_colx_st[d * 33 + c]
        c = c + 1


# ====================================================================
# TAG HANDLING.  tag content is src[ts .. te) (between '<' and '>').
# ====================================================================
def _name_eq(np: uint64, nlen: uint64, lit: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while lit[i] != 0:
        if i >= nlen:
            return 0
        if _lower(src_ptr[np + i]) != lit[i]:
            return 0
        i = i + 1
    if i != nlen:
        return 0
    return 1


# Extract the href="..."/href='...' value from a tag body into link_href_buf;
# returns the new link id, or -1 if no href / table full.
def _capture_href(ts: uint64, te: uint64) -> int32:
    if n_links >= MAX_LINKS:
        return -1
    # find "href" (case-insensitive) within [ts,te)
    i: uint64 = ts
    found: int32 = 0
    while i + 4 <= te:
        if _lower(src_ptr[i]) == 104 and _lower(src_ptr[i + 1]) == 114 \
           and _lower(src_ptr[i + 2]) == 101 and _lower(src_ptr[i + 3]) == 102:
            found = 1
            i = i + 4
            break
        i = i + 1
    if found == 0:
        return -1
    while i < te and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    if i >= te or src_ptr[i] != 61:                  # '='
        return -1
    i = i + 1
    while i < te and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    quote: uint8 = 0
    if i < te and (src_ptr[i] == 34 or src_ptr[i] == 39):
        quote = src_ptr[i]
        i = i + 1
    start: uint64 = link_href_len
    cnt: int32 = 0
    while i < te:
        c: uint8 = src_ptr[i]
        if quote != 0:
            if c == quote:
                break
        else:
            if c == 32 or c == 9 or c == 62:
                break
        if c == 38:                                  # '&' — decode entity
            consumed: uint64 = _entity(i)
            if consumed > 0:
                k: int32 = 0
                while k < g_ent_len:
                    if link_href_len < LINK_HREF_CAP - 1:
                        link_href_buf[link_href_len] = g_ent_buf[k]
                        link_href_len = link_href_len + 1
                        cnt = cnt + 1
                    k = k + 1
                i = i + consumed
                continue
        if link_href_len < LINK_HREF_CAP - 1:
            link_href_buf[link_href_len] = c
            link_href_len = link_href_len + 1
            cnt = cnt + 1
        i = i + 1
    if cnt == 0:
        return -1
    lid: int32 = cast[int32](n_links)
    link_off[n_links] = cast[int32](start)
    link_len[n_links] = cnt
    n_links = n_links + 1
    return lid


def _enter_skip(np: uint64, nlen: uint64):
    skip_active = 1
    skip_nlen = nlen
    i: uint64 = 0
    while i < nlen and i < 16:
        skip_name[i] = _lower(src_ptr[np + i])
        i = i + 1
    # NUL-terminate: the skip-end check (_name_eq) scans skip_name until a
    # zero, so a shorter skip name following a longer one must not inherit the
    # previous name's trailing bytes (else the skip would never end).
    if i < 16:
        skip_name[i] = 0


# ====================================================================
# FORM CONTROLS — monospace-grid rendering of <input>/<textarea>/<button>/
# <select>. The controls are drawn from the (possibly JS-rewritten) source
# attributes so a value/checked change re-renders through the normal rewrite
# path. See the DOM section for the value/checked get-set + event wiring.
# ====================================================================
fbuf: Array[512, uint8]                  # scratch for one attribute value


# Is the whitespace/boundary-delimited word `name` present in tag body [ts,te)?
# (Handles bare boolean attributes like `checked` / `selected` that carry no
# `=value`, which _find_attr — which requires an '=' — would miss.)
def _has_word(ts: uint64, te: uint64, name: Ptr[uint8]) -> int32:
    nl: uint64 = 0
    while name[nl] != 0:
        nl = nl + 1
    i: uint64 = ts
    while i + nl <= te:
        prev_alpha: int32 = 0
        if i > ts:
            pc: uint8 = _lower(src_ptr[i - 1])
            if (pc >= 97 and pc <= 122) or (pc >= 48 and pc <= 57) or pc == 45:
                prev_alpha = 1
        if prev_alpha == 0 and _srcword_is(i, name) != 0 and \
           _alnum_at(i + nl) == 0:
            return 1
        i = i + 1
    return 0


# Copy attribute `name`'s value from tag body [ne,te) into fbuf (NUL-term).
# Returns its length, or -1 if the attribute is absent.
def _attr_to_fbuf(ne: uint64, te: uint64, name: Ptr[uint8]) -> int32:
    if _find_attr(ne, te, name) == 0:
        return -1
    n: int32 = 0
    p: uint64 = g_attr_start
    while p < g_attr_end and n < 511:
        if src_ptr[p] == 38:                         # '&' — decode entity
            consumed: uint64 = _entity(p)
            if consumed > 0:
                k: int32 = 0
                while k < g_ent_len and n < 511:
                    fbuf[n] = g_ent_buf[k]
                    n = n + 1
                    k = k + 1
                p = p + consumed
                continue
        fbuf[n] = src_ptr[p]
        n = n + 1
        p = p + 1
    fbuf[n] = 0
    return n


# Push a NUL-terminated C string into the inline word accumulator.
def _wpush_cstr(s: Ptr[uint8]):
    i: int32 = 0
    while s[i] != 0:
        _word_push(s[i])
        i = i + 1


# Push a src span [a,b) into the word accumulator.
def _wpush_range(a: uint64, b: uint64):
    i: uint64 = a
    while i < b:
        _word_push(src_ptr[i])
        i = i + 1


# input type is `lit` (case-insensitive); missing type defaults to "text".
def _input_type_is(ne: uint64, te: uint64, lit: Ptr[uint8]) -> int32:
    n: int32 = _attr_to_fbuf(ne, te, cast[Ptr[uint8]]("type"))
    if n < 0:
        return _bytes_eq(cast[Ptr[uint8]]("text"), 4, lit, _cstr_len(lit))
    # lower-case the buffered type
    k: int32 = 0
    while k < n:
        fbuf[k] = _lower(fbuf[k])
        k = k + 1
    return _bytes_eq(&fbuf[0], n, lit, _cstr_len(lit))


# Emit a textual control token as one wrapping word: <pre-flushed> [box].
def _emit_input(ne: uint64, te: uint64):
    if _input_type_is(ne, te, cast[Ptr[uint8]]("hidden")) != 0:
        return                                        # hidden: renders nothing
    _word_flush()
    if _input_type_is(ne, te, cast[Ptr[uint8]]("checkbox")) != 0:
        _word_push(91)                                # '['
        if _has_word(ne, te, cast[Ptr[uint8]]("checked")) != 0:
            _word_push(120)                           # 'x'
        else:
            _word_push(32)
        _word_push(93)                                # ']'
        _word_flush()
        return
    if _input_type_is(ne, te, cast[Ptr[uint8]]("radio")) != 0:
        _word_push(40)                                # '('
        if _has_word(ne, te, cast[Ptr[uint8]]("checked")) != 0:
            _word_push(42)                            # '*'
        else:
            _word_push(32)
        _word_push(41)                                # ')'
        _word_flush()
        return
    is_btn: int32 = 0
    if _input_type_is(ne, te, cast[Ptr[uint8]]("submit")) != 0 or \
       _input_type_is(ne, te, cast[Ptr[uint8]]("button")) != 0 or \
       _input_type_is(ne, te, cast[Ptr[uint8]]("reset")) != 0:
        is_btn = 1
    if is_btn != 0:
        # push-button: [ label ]
        _word_push(91)
        _word_push(32)
        vn: int32 = _attr_to_fbuf(ne, te, cast[Ptr[uint8]]("value"))
        if vn > 0:
            _wpush_cstr(&fbuf[0])
        else:
            _wpush_cstr(cast[Ptr[uint8]]("Button"))
        _word_push(32)
        _word_push(93)
        _word_flush()
        return
    # text-like field: [value padded to >=8 with '_']
    _word_push(91)                                    # '['
    vlen: int32 = _attr_to_fbuf(ne, te, cast[Ptr[uint8]]("value"))
    ilen: int32 = 0
    if vlen > 0:
        _wpush_cstr(&fbuf[0])
        ilen = vlen
    else:
        pn: int32 = _attr_to_fbuf(ne, te, cast[Ptr[uint8]]("placeholder"))
        if pn > 0:
            _wpush_cstr(&fbuf[0])
            ilen = pn
    while ilen < 8:
        _word_push(95)                                # '_'
        ilen = ilen + 1
    _word_push(93)                                    # ']'
    _word_flush()


# Find the selected <option>'s visible text inside a <select> whose body
# starts at `body0`; copies it to fbuf (NUL-term) and returns its length.
# Picks the option carrying `selected`, else the first option.
def _select_text(body0: uint64) -> int32:
    i: uint64 = body0
    first_s: int32 = -1
    first_e: int32 = -1
    while i < src_len:
        if src_ptr[i] == 60:                          # '<'
            if i + 1 < src_len and src_ptr[i + 1] == 47 and \
               _tagname_is(i + 2, cast[Ptr[uint8]]("select")) != 0:
                break
            if _tagname_is(i + 1, cast[Ptr[uint8]]("option")) != 0:
                je: uint64 = i + 1
                while je < src_len and src_ptr[je] != 62:
                    je = je + 1
                ne: uint64 = i + 1
                while ne < je and _alnum_at(ne) != 0:
                    ne = ne + 1
                cs: uint64 = je + 1
                ce: uint64 = cs
                while ce < src_len and src_ptr[ce] != 60:
                    ce = ce + 1
                if first_s < 0:
                    first_s = cast[int32](cs)
                    first_e = cast[int32](ce)
                if _has_word(ne, je, cast[Ptr[uint8]]("selected")) != 0:
                    n: int32 = 0
                    p: uint64 = cs
                    while p < ce and n < 511:
                        fbuf[n] = src_ptr[p]
                        n = n + 1
                        p = p + 1
                    fbuf[n] = 0
                    return n
        i = i + 1
    if first_s >= 0:
        n2: int32 = 0
        p2: uint64 = cast[uint64](first_s)
        while p2 < cast[uint64](first_e) and n2 < 511:
            fbuf[n2] = src_ptr[p2]
            n2 = n2 + 1
            p2 = p2 + 1
        fbuf[n2] = 0
        return n2
    fbuf[0] = 0
    return 0


# Index (0-based) of a <select>'s selected option, scanning from body0.
# The option carrying `selected`, else 0 (the first).
def _select_index(body0: uint64) -> int32:
    i: uint64 = body0
    idx: int32 = -1
    sel: int32 = -1
    while i < src_len:
        if src_ptr[i] == 60:                          # '<'
            if i + 1 < src_len and src_ptr[i + 1] == 47 and \
               _tagname_is(i + 2, cast[Ptr[uint8]]("select")) != 0:
                break
            if _tagname_is(i + 1, cast[Ptr[uint8]]("option")) != 0:
                idx = idx + 1
                je: uint64 = i + 1
                while je < src_len and src_ptr[je] != 62:
                    je = je + 1
                if _has_word(i + 1, je, cast[Ptr[uint8]]("selected")) != 0 and \
                   sel < 0:
                    sel = idx
        i = i + 1
    if sel >= 0:
        return sel
    return 0


# Visible text of the option at 0-based index `want` inside a <select> whose
# body starts at body0 -> fbuf (NUL-term); returns its length, or -1 if the
# index is out of range. Mirror of _select_text but keyed on position, so a JS
# `select.selectedIndex = N` write can resolve to the option it now selects.
def _select_optext_at(body0: uint64, want: int32) -> int32:
    i: uint64 = body0
    idx: int32 = -1
    while i < src_len:
        if src_ptr[i] == 60:                          # '<'
            if i + 1 < src_len and src_ptr[i + 1] == 47 and \
               _tagname_is(i + 2, cast[Ptr[uint8]]("select")) != 0:
                break
            if _tagname_is(i + 1, cast[Ptr[uint8]]("option")) != 0:
                idx = idx + 1
                je: uint64 = i + 1
                while je < src_len and src_ptr[je] != 62:
                    je = je + 1
                cs: uint64 = je + 1
                ce: uint64 = cs
                while ce < src_len and src_ptr[ce] != 60:
                    ce = ce + 1
                if idx == want:
                    n: int32 = 0
                    p: uint64 = cs
                    while p < ce and n < 511:
                        fbuf[n] = src_ptr[p]
                        n = n + 1
                        p = p + 1
                    fbuf[n] = 0
                    return n
        i = i + 1
    return -1


def _handle_tag(ts: uint64, te: uint64):
    if ts >= te:
        return
    # comment / doctype / processing — ignore.
    if src_ptr[ts] == 33 or src_ptr[ts] == 63:       # '!' or '?'
        return
    is_close: int32 = 0
    np: uint64 = ts
    if src_ptr[np] == 47:                            # '/'
        is_close = 1
        np = np + 1
    # tag name end (letters/digits)
    ne: uint64 = np
    while ne < te:
        c: uint8 = src_ptr[ne]
        if (c >= 97 and c <= 122) or (c >= 65 and c <= 90) or \
           (c >= 48 and c <= 57):
            ne = ne + 1
        else:
            break
    nlen: uint64 = ne - np
    if nlen == 0:
        return

    # script/style/head/title: drop their content from the render flow.
    # NOTE: <style> is still consumed for the render (its rules were already
    # harvested by _collect_css() before layout). <script> execution now happens
    # BEFORE layout in _run_scripts() (see the "JAVASCRIPT + minimal DOM"
    # section): every script body is js_eval'd against a shared context + a
    # `document` DOM binding, and any DOM the scripts mutate is baked into a
    # rewritten source that this layout pass then consumes. Here we simply drop
    # the <script> text from the RENDER flow so page text is not polluted by
    # code (its behaviour already ran).
    if is_close == 0:
        if _name_eq(np, nlen, cast[Ptr[uint8]]("script")) != 0 or \
           _name_eq(np, nlen, cast[Ptr[uint8]]("style")) != 0 or \
           _name_eq(np, nlen, cast[Ptr[uint8]]("head")) != 0 or \
           _name_eq(np, nlen, cast[Ptr[uint8]]("title")) != 0:
            _word_flush()
            _enter_skip(np, nlen)
            return
        # <noscript>: fallback content shown ONLY when scripting is disabled.
        # hambrowse is a scripting-capable browser (lib/jsengine.ad is always
        # wired and <script>/inline handlers run in _run_scripts), so per the
        # HTML standard its children must NOT render — exactly like a real
        # browser with JS enabled. This is what suppresses the ubiquitous
        # "Please enable JavaScript" block real sites (Google) ship inside
        # <noscript>; before this, that text leaked into the render flow and
        # also skewed the layout with a stray paragraph/stylesheet.
        if _name_eq(np, nlen, cast[Ptr[uint8]]("noscript")) != 0:
            _word_flush()
            _enter_skip(np, nlen)
            return
        # <canvas>: reserve its pixel box (blitting the script-drawn buffer) and
        # SKIP any fallback content. Handled here, before the element stack is
        # touched, so it opens no unbalanced scope (like script/style above).
        if _name_eq(np, nlen, cast[Ptr[uint8]]("canvas")) != 0:
            _handle_canvas(ts, np, nlen, ne, te)
            return
        # inline <svg>: rasterise the whole <svg>...</svg> subtree through the
        # shared lib/svg rasterizer and emit a replaced image box, then SKIP the
        # shape children so they don't leak into the text flow. Handled here,
        # before the element stack, so it opens no unbalanced scope.
        if _name_eq(np, nlen, cast[Ptr[uint8]]("svg")) != 0:
            if _handle_inline_svg(ts, te) != 0:
                _enter_skip(np, nlen)
            return

    # ---- element stack (for descendant selectors) + display:none ----
    # Void elements never open a scope; everything else is tracked so the CSS
    # cascade can match .class / #id / descendant selectors against ancestors.
    is_void: int32 = 0
    if _name_eq(np, nlen, cast[Ptr[uint8]]("br")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("hr")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("img")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("input")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("meta")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("link")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("area")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("col")) != 0:
        is_void = 1
    g_eff_disp = 0
    g_flex_dir = 0
    g_flex_just = 0
    g_flex_align = 0
    g_flex_gap = -1
    g_flex_rowgap = -1
    g_flex_wrap = 0
    g_flex_grid = 0
    g_grid_n = 0
    g_grid_rn = 0
    g_grid_cspan = 1
    g_grid_cstart = 0
    g_treat_as_block = 0
    g_inlb = 0
    if is_close == 0:
        if is_void == 0:
            _el_push(np, nlen, ne, te)
            _cascade_match_current()
            if _is_display_none(ne, te) != 0:      # also runs _parse_inline_wa
                _el_pop(np, nlen)
                _word_flush()
                _enter_skip(np, nlen)
                return
            g_eff_disp = m_disp
            if d_disp != 0:
                g_eff_disp = d_disp
            g_flex_dir = m_flexdir
            if d_flexdir != 0:
                g_flex_dir = d_flexdir
            g_flex_just = m_justify
            if d_justify != 0:
                g_flex_just = d_justify
            g_flex_align = m_aitems
            if d_aitems != 0:
                g_flex_align = d_aitems
            g_flex_gap = m_flexgap
            if d_flexgap >= 0:
                g_flex_gap = d_flexgap
            g_flex_rowgap = m_rowgap
            if d_rowgap >= 0:
                g_flex_rowgap = d_rowgap
            g_flex_wrap = m_flexwrap
            if d_flexwrap != 0:
                g_flex_wrap = d_flexwrap
            # display:grid arms the grid track model; resolve grid-template-columns
            # (and grid-template-rows) from the cascade winner (m_gtc[]/m_gtr[])
            # then override with the inline style (d_gtc[]/d_gtr[]) into the carried
            # g_grid_enc/g_grid_n (columns) and g_grid_renc/g_grid_rn (rows).
            if g_eff_disp == 6:
                g_flex_grid = 1
                gi: int32 = 0
                if m_gtcn > 0:
                    while gi < m_gtcn and gi < GRID_MAXTRACK:
                        g_grid_enc[gi] = m_gtc[gi]
                        gi = gi + 1
                    g_grid_n = m_gtcn
                if d_gtcn > 0:
                    gi = 0
                    while gi < d_gtcn and gi < GRID_MAXTRACK:
                        g_grid_enc[gi] = d_gtc[gi]
                        gi = gi + 1
                    g_grid_n = d_gtcn
                gj: int32 = 0
                if m_gtrn > 0:
                    while gj < m_gtrn and gj < GRID_MAXTRACK:
                        g_grid_renc[gj] = m_gtr[gj]
                        gj = gj + 1
                    g_grid_rn = m_gtrn
                if d_gtrn > 0:
                    gj = 0
                    while gj < d_gtrn and gj < GRID_MAXTRACK:
                        g_grid_renc[gj] = d_gtr[gj]
                        gj = gj + 1
                    g_grid_rn = d_gtrn
            # grid-column line placement is a per-ITEM property (carried on the
            # child, not the container): resolve span/start from the cascade winner
            # then the inline style into g_grid_cspan/g_grid_cstart, read by the
            # grid item-open path. Default span 1 / auto start when unset.
            if m_gcspan != 0:
                g_grid_cspan = m_gcspan
            if m_gcstart != 0:
                g_grid_cstart = m_gcstart
            if d_gcspan != 0:
                g_grid_cspan = d_gcspan
            if d_gcstart != 0:
                g_grid_cstart = d_gcstart
            g_treat_as_block = _generic_block_wanted(np, nlen)
            # display:inline-block on an inline-level tag flows as an inline box
            # (chip/badge/pill) INSTEAD of blockifying into its own full-width row.
            if g_eff_disp == 4 and _inlb_tag(np, nlen) != 0:
                g_inlb = 1
                g_treat_as_block = 0
            if g_treat_as_block != 0 and gblk_sp < GBLK_MAX:
                gblk_stack[gblk_sp] = el_sp
                gblk_sp = gblk_sp + 1
    else:
        if is_void == 0:
            # A close tag has no style="" to re-read; recognise the matching
            # generic-block / inline-block close by el-stack depth (pushed at
            # open) so it takes the SAME close path as its open.
            if inlb_sp > 0 and inlb_eldepth[inlb_sp - 1] == el_sp:
                g_inlb = 1
            elif gblk_sp > 0 and gblk_stack[gblk_sp - 1] == el_sp:
                g_treat_as_block = 1
                gblk_sp = gblk_sp - 1
            _el_pop(np, nlen)

    # <body>/<html>: a page-level background (gap #3) fills the WHOLE viewport,
    # not just element boxes, so the pixel renderer clears the canvas to it. The
    # body's text COLOUR is also pushed so it inherits to descendants (a dark
    # theme needs both bg AND colour). No box/paragraph break is emitted.
    if _name_eq(np, nlen, cast[Ptr[uint8]]("body")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("html")) != 0:
        _word_flush()
        if is_close == 0:
            bcol: int32 = m_col
            ibc: int32 = _tag_color(ne, te)
            if ibc >= 0:
                bcol = ibc
            bbg: int32 = m_bg
            ibb: int32 = _tag_bgcolor(ne, te)
            if ibb >= 0:
                bbg = ibb
            if bbg >= 0:
                g_page_bg = bbg
            _color_push(bcol)
        else:
            _color_pop()
        _style_break()
        return

    if _name_eq(np, nlen, cast[Ptr[uint8]]("br")) != 0:
        _word_flush()
        _newline()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("hr")) != 0:
        # A horizontal rule owns its own otherwise-empty visual row.
        _word_flush()
        _soft_newline()
        if cur_row < MAX_ROWS:
            row_rule[cur_row] = 2                     # 2 = <hr> full-width rule
        _bump_row()
        pen_x = indent_x
        row_dirty = 0
        need_space = 0
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("blockquote")) != 0:
        _word_flush()
        if is_close == 0:
            _soft_newline()
            bq_depth = bq_depth + 1
            _recompute_indent()
            # UA default: quoted text renders in a muted grey (author style can
            # still override — _open_style pushes on top of this default).
            _color_push(0x5a5a5a)
            _open_style(ne, te)
        else:
            if bq_depth > 0:
                bq_depth = bq_depth - 1
            _recompute_indent()
            _close_style()
            _color_pop()
            _para_break()
        pen_x = indent_x
        _style_break()
        return
    if g_inlb != 0:
        # display:inline-block chip/badge/pill: an inline-level box in the line
        # grid (flows + wraps), not a full-width block row.
        if is_close == 0:
            _inlb_open(ne, te, np, nlen)
        else:
            _inlb_close(np, nlen)
        return
    if (_name_eq(np, nlen, cast[Ptr[uint8]]("span")) != 0 or \
        _name_eq(np, nlen, cast[Ptr[uint8]]("font")) != 0) and \
       g_treat_as_block == 0:
        # Inline colour-bearing element: no layout effect, only colour(s). A
        # `display:block`/flex span (or a span that is a flex item) instead
        # falls through to the block-box branch below (g_treat_as_block set).
        _word_flush()
        if is_close == 0:
            _open_style(ne, te)
        else:
            _close_style()
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("p")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("div")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("figure")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("figcaption")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("address")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("aside")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("section")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("article")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("header")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("footer")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("main")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("nav")) != 0 or \
       g_treat_as_block != 0:
        _word_flush()
        if is_close == 0:
            _soft_newline()
            _open_style(ne, te)              # runs cascade (m_*) + inline (d_*)
            # merge the box model: inline wins over the stylesheet per axis.
            fleft: int32 = 0
            if m_ml >= 0:
                fleft = m_ml
            if d_ml >= 0:
                fleft = d_ml
            frins: int32 = 0
            if m_mr >= 0:
                frins = m_mr
            if d_mr >= 0:
                frins = d_mr
            fwd: int32 = -1
            if m_wd >= 0:
                fwd = m_wd
            if d_wd >= 0:
                fwd = d_wd
            ftop: int32 = 0
            if m_mt >= 0:
                ftop = m_mt
            if d_mt >= 0:
                ftop = d_mt
            fbot: int32 = 0
            if m_mb >= 0:
                fbot = m_mb
            if d_mb >= 0:
                fbot = d_mb
            fbord: int32 = 0
            if m_bd >= 0:
                fbord = m_bd
            if d_bd >= 0:
                fbord = d_bd
            # effective element background (inline wins over the sheet): fed to
            # the box open so its close paints the WHOLE box rectangle. The inline
            # value comes from _tag_bgcolor (NOT d_bg — that scratch holds the
            # last-parsed stylesheet rule's bg and would leak onto every box).
            fbg: int32 = m_bg
            ibg: int32 = _tag_bgcolor(ne, te)
            if ibg >= 0:
                fbg = ibg
            # CSS centred block: `width/max-width` + auto side margins. Compute
            # the left offset that centres the box in its parent's content width
            # and fold it into fleft (the canonical `main { max-width:Npx;
            # margin:0 auto }` article column — the most common modern layout).
            fcenter: int32 = m_center
            if d_center != 0:
                fcenter = 1
            if fcenter != 0 and fwd >= 0:
                pr_c: int32 = blk_right_cur
                if pr_c <= 0:
                    pr_c = _content_right()
                extra_c: int32 = (pr_c - indent_x) - fwd
                if extra_c > 0:
                    fleft = extra_c / 2
                    frins = extra_c / 2
            ffloat: int32 = 0
            if m_float != 0:
                ffloat = m_float
            if d_float != 0:
                ffloat = d_float
            fdisp: int32 = m_disp
            if d_disp != 0:
                fdisp = d_disp
            # CSS position: mode + the four edge offsets (inline over sheet).
            fpos: int32 = m_pos
            if d_pos != 0:
                fpos = d_pos
            ptopv: int32 = m_top
            if d_top >= 0:
                ptopv = d_top
            pleftv: int32 = m_left
            if d_left >= 0:
                pleftv = d_left
            prightv: int32 = m_right
            if d_right >= 0:
                prightv = d_right
            pbotv: int32 = m_bottom
            if d_bottom >= 0:
                pbotv = d_bottom
            # z-index (inline over sheet); ZIDX_UNSET/auto stacks at 0.
            pzv: int32 = m_zidx
            if d_zidx != ZIDX_UNSET:
                pzv = d_zidx
            if pzv == ZIDX_UNSET:
                pzv = 0
            # Containing block for an `absolute` child = nearest positioned
            # ancestor's top-left/right, or the page content box.
            cbx: int32 = CONTENT_X
            cbr: int32 = _content_right()
            cbrow: int32 = 0
            if posctx_sp > 0:
                cbx   = posctx_x[posctx_sp - 1]
                cbr   = posctx_rt[posctx_sp - 1]
                cbrow = posctx_row[posctx_sp - 1]
            ps_before: int32 = cast[int32](n_segs)
            if fpos == 2:
                # ABSOLUTE: out of flow. Lay the box out on a fresh line, register
                # its run, then (on close) rewind cur_row so siblings reclaim the
                # space and _apply_positioned relocates the segments.
                abs_ret: int32 = cast[int32](cur_row)
                _soft_newline()
                row_dirty = 0
                runa: int32 = _register_pos(ps_before, 2, cbx, cbr, cbrow, \
                                            pleftv, ptopv, prightv, pbotv, pzv)
                _block_box_open(fleft, frins, fwd, 0, 0, fbord, fbg)
                aidx: int32 = box_sp - 1
                if aidx >= 0:
                    box_pos_stack[aidx]     = 2
                    box_posrun_stack[aidx]  = runa
                    box_pretrow_stack[aidx] = abs_ret
                    box_pushedctx_stack[aidx] = 1
                _posctx_push(indent_x, blk_right_cur, cast[int32](cur_row))
                if fdisp == 2 or fdisp == 6:
                    if _flex_container_open(te + 1, el_sp) != 0:
                        idxa: int32 = box_sp - 1
                        if idxa >= 0:
                            box_flexcont_stack[idxa] = 1
            else:
                # A direct-child block of an active flex container becomes a
                # COLUMN: pinned to its column x, equal share of the row width,
                # tops aligned (cur_row rewound to the container top). This takes
                # priority over a float on the same element.
                fcol: int32 = _flex_item_col(el_sp)
                is_item: int32 = 0
                if fcol >= 0:
                    top: int32 = flex_sp - 1
                    coloff: int32 = fcol * flex_gap[top]
                    ccw: int32 = flex_colw[top]
                    if flex_grid[top] != 0:
                        # GRID placement: place this item at the auto-flow cursor
                        # (flex_gcur = next free track) OR at its explicit
                        # grid-column start line; it OCCUPIES `span` tracks (its box
                        # width covers them + the internal column-gaps). When the
                        # auto-flow span won't fit the remaining tracks the item
                        # wraps to a new grid ROW (advancing flex_growidx, applying
                        # any grid-template-rows fixed height for that row).
                        nt2: int32 = flex_ntrack[top]
                        gbase: int32 = top * FLEX_MAX
                        sp0: int32 = g_grid_cspan
                        if sp0 < 1:
                            sp0 = 1
                        if sp0 > nt2:
                            sp0 = nt2
                        cur: int32 = flex_gcur[top]
                        gcol: int32 = cur
                        if g_grid_cstart >= 1:
                            # explicit start line (1-based); clamp into the row and
                            # place on the current row (lean: no forced row jump).
                            gcol = g_grid_cstart - 1
                            if gcol < 0:
                                gcol = 0
                            if gcol + sp0 > nt2:
                                gcol = nt2 - sp0
                            if gcol < 0:
                                gcol = 0
                        else:
                            if cur > 0 and cur + sp0 > nt2:
                                # wrap: open the next grid ROW below the current one
                                flex_growidx[top] = flex_growidx[top] + 1
                                flex_line_top[top] = flex_line_bot[top] + \
                                                     flex_rowgap[top]
                                flex_line_bot[top] = flex_line_top[top]
                                rh: int32 = _grid_row_h_rows(top, flex_growidx[top])
                                if rh > 0:
                                    flex_line_bot[top] = flex_line_top[top] + rh
                                    if flex_line_bot[top] > flex_max_bot[top]:
                                        flex_max_bot[top] = flex_line_bot[top]
                                gcol = 0
                        et: int32 = gcol + sp0 - 1
                        if et >= nt2:
                            et = nt2 - 1
                        coloff = flex_child_x[gbase + gcol]
                        ccw = flex_child_x[gbase + et] + flex_child_w[gbase + et] \
                              - coloff
                        cur_row = cast[uint64](flex_line_top[top])
                        flex_gcur[top] = gcol + sp0
                    elif flex_wrap_on[top] != 0:
                        # ONLINE wrap: this item's box width is its resolved CSS
                        # `width` (cards) or its pre-measured natural content width
                        # (nav pills). Start a new line when it no longer fits.
                        cw: int32 = flex_meas_w[fcol]
                        if fwd >= 0:
                            cw = fwd
                        if cw < CELL_W:
                            cw = CELL_W
                        if flex_cur_x[top] > 0 and \
                           flex_cur_x[top] + cw > flex_avail[top]:
                            # New flex line: drop below the previous line's bottom
                            # plus the container's row-gap (0 when unset).
                            flex_line_top[top] = flex_line_bot[top] + flex_rowgap[top]
                            flex_line_bot[top] = flex_line_top[top]
                            flex_cur_x[top] = 0
                        coloff = flex_cur_x[top]
                        ccw = cw
                        flex_cur_x[top] = flex_cur_x[top] + cw + flex_rawgap[top]
                        cur_row = cast[uint64](flex_line_top[top])
                    elif flex_natural[top] != 0:
                        coloff = flex_child_x[top * FLEX_MAX + fcol]
                        ccw = flex_child_w[top * FLEX_MAX + fcol]
                        cur_row = cast[uint64](flex_top_row[top])
                    else:
                        cur_row = cast[uint64](flex_top_row[top])
                    pen_x = indent_x
                    row_dirty = 0
                    need_space = 0
                    _block_box_open(coloff, 0, ccw, 0, fbot, fbord, fbg)
                    is_item = 1
                    idx0: int32 = box_sp - 1
                    if idx0 >= 0:
                        box_flexitem_stack[idx0] = 1
                    # Cross-axis fixup bookkeeping (only when align-items >= center):
                    # remember where this item's emitted segs/fills/borders begin and
                    # which line row it sits on, so the container close can shift them.
                    if flex_align[top] >= 2:
                        fidx0: int32 = top * FLEX_MAX + fcol
                        flex_it_seg0[fidx0] = cast[int32](n_segs)
                        flex_it_bf0[fidx0]  = n_bfills
                        flex_it_bx0[fidx0]  = n_bboxes
                        flex_it_ltop[fidx0] = cast[int32](cur_row)
                if is_item == 0:
                    floated: int32 = 0
                    if ffloat != 0:
                        floated = _float_box_open(ffloat, fwd, ftop, fbot, fbord, fbg)
                    if floated == 0:
                        _block_box_open(fleft, frins, fwd, ftop, fbot, fbord, fbg)
                # This block itself declares display:flex/grid -> arm a flex row /
                # grid over its direct block children (its box is already open).
                if fdisp == 2 or fdisp == 6:
                    if _flex_container_open(te + 1, el_sp) != 0:
                        idx1: int32 = box_sp - 1
                        if idx1 >= 0:
                            box_flexcont_stack[idx1] = 1
                # A flex-item <a> column that reached this generic-block path
                # (blockified navbar link) keeps its href + link colour so the
                # anchor is still clickable/blue. A flex-item <li> column simply
                # drops its bullet (the li handler is bypassed) — the list-style:
                # none navbar shape.
                if is_item != 0 and _name_eq(np, nlen, cast[Ptr[uint8]]("a")) != 0:
                    g_link = _capture_href(ne, te)
                    g_link_rgb = _own_color(ne, te)
                # RELATIVE: stays in flow; register its run + a positioning
                # context so absolute descendants resolve against it.
                if fpos == 1:
                    runr: int32 = _register_pos(ps_before, 1, cbx, cbr, cbrow, \
                                                pleftv, ptopv, prightv, pbotv, pzv)
                    ridx: int32 = box_sp - 1
                    if ridx >= 0:
                        box_pos_stack[ridx]     = 1
                        box_posrun_stack[ridx]  = runr
                        box_pushedctx_stack[ridx] = 1
                        _posctx_push(indent_x, blk_right_cur, \
                                     box_srow_stack[ridx])
        else:
            cidx: int32 = box_sp - 1
            was_item: int32 = 0
            was_cont: int32 = 0
            was_pos: int32 = 0
            posrun: int32 = -1
            abs_ret2: int32 = 0
            pushed: int32 = 0
            if cidx >= 0:
                was_item = box_flexitem_stack[cidx]
                was_cont = box_flexcont_stack[cidx]
                was_pos  = box_pos_stack[cidx]
                posrun   = box_posrun_stack[cidx]
                abs_ret2 = box_pretrow_stack[cidx]
                pushed   = box_pushedctx_stack[cidx]
            if was_cont != 0:
                _flex_container_close()                  # drop to tallest column
            fs: int32 = _float_box_close()
            _close_style()
            if posrun >= 0:
                # finalise the box's last text segment so the run spans it.
                _word_flush()
                _close_seg()
                pos_seg1[posrun] = cast[int32](n_segs)
                pos_bf1[posrun]  = n_bfills
            if pushed != 0:
                _posctx_pop()
            if was_pos == 2:
                cur_row = cast[uint64](abs_ret2)         # out of flow: rewind
                pen_x = indent_x
                row_dirty = 0
                need_space = 0
            elif was_item != 0:
                _flex_item_close()                       # rewind for next column
            elif fs == 0:                                # in-flow box: para gap
                _para_break()
            # A blockified flex-item <a> column drops its link scope on close.
            if _name_eq(np, nlen, cast[Ptr[uint8]]("a")) != 0:
                g_link = -1
                g_link_rgb = -1
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("h1")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("h2")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("h3")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("h4")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("h5")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("h6")) != 0:
        _word_flush()
        lvl: int32 = cast[int32](src_ptr[np + 1] - 48)
        if is_close == 0:
            _soft_newline()
            # UA-stylesheet section spacing: a top-level heading gets extra air
            # above it so sections breathe (like a browser's larger heading
            # margins). Suppressed at the very top of the document (no leading
            # blank), and only for h1/h2/h3 so deep sub-headings stay tight.
            if cur_row > 0 and lvl <= 3:
                _bump_row()
            g_heading = lvl
            _open_style(ne, te)
            _style_break()
        else:
            # rule under the heading's last content row, then a gap
            hr: uint64 = cur_row
            if row_dirty != 0 and lvl <= 2 and hr < MAX_ROWS:
                row_rule[hr] = 1
            g_heading = 0
            _close_style()
            _style_break()
            _para_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("b")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("strong")) != 0:
        _word_flush()
        if is_close == 0:
            g_bold_n = g_bold_n + 1
        else:
            if g_bold_n > 0:
                g_bold_n = g_bold_n - 1
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("i")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("em")) != 0:
        # parsed but rendered plain (no italic glyph set) — strip the tag.
        _word_flush()
        return
    # ---- UA-default inline styling for the common low-frequency tags ----
    # <kbd>/<samp>/<var>: monospace face (like <code>) so keystrokes, program
    # output and variables stand out from body text. Author CSS (colour/bg) can
    # still override via _open_style pushed on top.
    if _name_eq(np, nlen, cast[Ptr[uint8]]("kbd")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("samp")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("var")) != 0:
        _word_flush()
        if is_close == 0:
            g_mono_n = g_mono_n + 1
            _open_style(ne, te)
        else:
            _close_style()
            if g_mono_n > 0:
                g_mono_n = g_mono_n - 1
        _style_break()
        return
    # <mark>: yellow highlight background. Pushed BELOW the author cascade so
    # `mark { background: … }` still wins (lowest specificity UA default).
    if _name_eq(np, nlen, cast[Ptr[uint8]]("mark")) != 0:
        _word_flush()
        if is_close == 0:
            _bg_push(MARK_BG)
            _open_style(ne, te)
        else:
            _close_style()
            _bg_pop()
        _style_break()
        return
    # <small>: ~0.8x the current effective font size. Pushed UNDER the author
    # cascade so an explicit font-size on <small> still overrides.
    if _name_eq(np, nlen, cast[Ptr[uint8]]("small")) != 0:
        _word_flush()
        if is_close == 0:
            base_px: int32 = g_font_px
            if base_px <= 0:
                base_px = EM_PX
            sm: int32 = base_px * 13 / 16
            if sm < 8:
                sm = 8
            _fontpx_push(sm)
            _open_style(ne, te)
        else:
            _close_style()
            _fontpx_pop()
        _style_break()
        return
    # <sub>/<sup>: smaller font + a raised/lowered baseline (seg_yoff). The font
    # push sits under the author cascade so an explicit font-size still wins; the
    # vertical shift is a UA-only effect (no CSS vertical-align support).
    if _name_eq(np, nlen, cast[Ptr[uint8]]("sub")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("sup")) != 0:
        is_sup: int32 = _name_eq(np, nlen, cast[Ptr[uint8]]("sup"))
        _word_flush()
        if is_close == 0:
            if is_sup != 0:
                sup_depth = sup_depth + 1
            else:
                sub_depth = sub_depth + 1
            g_yoff = sub_depth * SUB_DROP - sup_depth * SUP_RISE
            base_px2: int32 = g_font_px
            if base_px2 <= 0:
                base_px2 = EM_PX
            ss: int32 = base_px2 * 10 / 13
            if ss < 8:
                ss = 8
            _fontpx_push(ss)
            _open_style(ne, te)
        else:
            _close_style()
            _fontpx_pop()
            if is_sup != 0:
                if sup_depth > 0:
                    sup_depth = sup_depth - 1
            else:
                if sub_depth > 0:
                    sub_depth = sub_depth - 1
            g_yoff = sub_depth * SUB_DROP - sup_depth * SUP_RISE
        _style_break()
        return
    # <u>/<ins>: underline. UA default pushed under the author cascade so
    # text-decoration:none still strips it.
    if _name_eq(np, nlen, cast[Ptr[uint8]]("u")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("ins")) != 0:
        _word_flush()
        if is_close == 0:
            _deco_push(1)                    # 1 = underline
            _open_style(ne, te)
        else:
            _close_style()
            _deco_pop()
        _style_break()
        return
    # <s>/<del>/<strike>: strike-through (line through the run's x-height).
    if _name_eq(np, nlen, cast[Ptr[uint8]]("s")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("del")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("strike")) != 0:
        _word_flush()
        if is_close == 0:
            g_strike_n = g_strike_n + 1
            _open_style(ne, te)
        else:
            _close_style()
            if g_strike_n > 0:
                g_strike_n = g_strike_n - 1
        _style_break()
        return
    # <dl>: description list — a block that opens/closes its own vertical gap.
    if _name_eq(np, nlen, cast[Ptr[uint8]]("dl")) != 0:
        _word_flush()
        if is_close == 0:
            _soft_newline()
        else:
            _para_break()
        pen_x = indent_x
        return
    # <dt>: term — on its own line, bold-ish (UA default).
    if _name_eq(np, nlen, cast[Ptr[uint8]]("dt")) != 0:
        _word_flush()
        if is_close == 0:
            _soft_newline()
            g_bold_n = g_bold_n + 1
        else:
            if g_bold_n > 0:
                g_bold_n = g_bold_n - 1
            _soft_newline()
        pen_x = indent_x
        _style_break()
        return
    # <dd>: definition — on its own line, indented ~40px (browser default).
    if _name_eq(np, nlen, cast[Ptr[uint8]]("dd")) != 0:
        _word_flush()
        if is_close == 0:
            _soft_newline()
            dd_depth = dd_depth + 1
        else:
            if dd_depth > 0:
                dd_depth = dd_depth - 1
            _soft_newline()
        _recompute_indent()
        pen_x = indent_x
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("img")) != 0:
        # Pixel <img>: decode + blit a real image box (rung 5). The layout
        # reserves a bw2 x bh2 pixel box (natural size, or the width/height
        # attributes, or a broken-image placeholder); the pixel renderer blits
        # the decoded RGBA into it. See _handle_img.
        if is_close != 0:
            return
        _handle_img(ne, te)
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("a")) != 0:
        _word_flush()
        if is_close == 0:
            lid: int32 = _capture_href(ne, te)
            g_link = lid
            _open_style(ne, te)
            g_link_rgb = _own_color(ne, te)
        else:
            g_link = -1
            g_link_rgb = -1
            _close_style()
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("ul")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("ol")) != 0:
        is_ol: int32 = _name_eq(np, nlen, cast[Ptr[uint8]]("ol"))
        ul_lvl: int32 = list_depth                       # this list's own level
        _word_flush()
        if is_close == 0:
            _soft_newline()
            if list_depth < MAX_LIST_DEPTH:
                list_flex[list_depth] = 0
                list_box[list_depth]  = 0
                list_supp[list_depth] = 0
                list_type[list_depth] = is_ol
                # <ol start="N"> seeds the counter (default 1).
                start_n: int32 = 1
                if is_ol != 0 and \
                   _find_attr(ne, te, cast[Ptr[uint8]]("start")) != 0 and \
                   g_attr_end > g_attr_start:
                    v: int32 = 0
                    p: uint64 = g_attr_start
                    while p < g_attr_end:
                        d: uint8 = src_ptr[p]
                        if d >= 48 and d <= 57:
                            v = v * 10 + cast[int32](d - 48)
                        p = p + 1
                    if v > 0:
                        start_n = v
                list_count[list_depth] = start_n
            list_depth = list_depth + 1
        else:
            if list_depth > 0:
                list_depth = list_depth - 1
            # A `<ul style=flex>`/`<ol style=flex>` armed a horizontal flex row
            # over its <li> columns; the matching close pops that frame (dropping
            # cur_row to the tallest column) before the list's paragraph gap.
            if list_depth >= 0 and list_depth < MAX_LIST_DEPTH and \
               list_flex[list_depth] != 0:
                _flex_container_close()
                list_flex[list_depth] = 0
            # gap #3: the flex list's own container box closes here (painting its
            # background/border bar over the full flex-row height, which the flex
            # close above just resolved). gap #4: restore the suppressed indent.
            if list_depth >= 0 and list_depth < MAX_LIST_DEPTH:
                if list_box[list_depth] != 0:
                    _block_box_close()
                    list_box[list_depth] = 0
                if list_supp[list_depth] != 0:
                    list_indent_drop = list_indent_drop - LIST_STEP
                    list_supp[list_depth] = 0
            _para_break()
        _recompute_indent()
        pen_x = indent_x
        # display:flex on the list itself columnises its <li> children (a navbar
        # `<ul style=flex>`): arm a flex row now that indent_x is the list's
        # content column. Row direction only (column == default vertical stack).
        if is_close == 0 and g_eff_disp == 2 and ul_lvl >= 0 and \
           ul_lvl < MAX_LIST_DEPTH:
            # gap #4: a flex list resets its left padding — suppress this level's
            # LIST_STEP indent so the bar sits flush at the content edge.
            list_indent_drop = list_indent_drop + LIST_STEP
            list_supp[ul_lvl] = 1
            _recompute_indent()
            pen_x = indent_x
            # gap #3: open a CONTAINER BOX so `ul{background}`/`border` paints as a
            # bar spanning the whole flex row (a bare <ul>, unlike a <div>/<nav>,
            # otherwise opens no box). Only when a bg/border is actually set.
            ul_bg: int32 = m_bg
            ul_ibg: int32 = _tag_bgcolor(ne, te)
            if ul_ibg >= 0:
                ul_bg = ul_ibg
            ul_bord: int32 = 0
            if m_bd >= 0:
                ul_bord = m_bd
            if d_bd >= 0:
                ul_bord = d_bd
            if ul_bg >= 0 or ul_bord != 0:
                _block_box_open(0, 0, -1, 0, 0, ul_bord, ul_bg)
                list_box[ul_lvl] = 1
            if _flex_container_open(te + 1, el_sp) != 0:
                list_flex[ul_lvl] = 1
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("li")) != 0:
        _word_flush()
        # display:inline on a list item (the classic `li{display:inline}` reset
        # for a horizontal nav) drops the line break + bullet and flows the item
        # inline, separated from its predecessor by a space. No box, no marker.
        if g_eff_disp == 5:
            if is_close == 0:
                if row_dirty != 0:
                    need_space = 1
            return
        if is_close == 0:
            _soft_newline()
            _recompute_indent()
            # Marker hangs in this level's gutter [indent_x - LIST_STEP,
            # indent_x); the item text then flows at indent_x so wrapped
            # continuation lines align under the text (hanging indent).
            lvl: int32 = list_depth - 1
            gutter_x: int32 = indent_x - LIST_STEP
            if gutter_x < _left_margin():
                gutter_x = _left_margin()
            pen_x = gutter_x
            if lvl >= 0 and lvl < MAX_LIST_DEPTH and list_type[lvl] != 0:
                # Ordered list: render the running number then '.'.
                num: int32 = list_count[lvl]
                list_count[lvl] = num + 1
                _seg_putc_dec(num)
                _seg_putc(46)                        # '.'
            else:
                # Unordered list: a bullet marker. The '-' placeholder is what
                # the monospace-grid text dump paints; the pixel renderer sees
                # seg_marker and draws a real round disc in the gutter instead.
                _seg_putc(45)                        # '-'
                seg_marker[n_segs] = 1               # flag: draw a bullet disc
            _close_seg()                             # marker is its own segment
            pen_x = indent_x                         # item text hangs here
            _pending_indjump = 1                     # next text seg keeps the gutter
            row_dirty = 1
            need_space = 0
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("pre")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("code")) != 0:
        is_pre: int32 = _name_eq(np, nlen, cast[Ptr[uint8]]("pre"))
        _word_flush()
        if is_pre != 0:
            if is_close == 0:
                _soft_newline()
                pre_mode = 1
                _bg_push(CODE_BG)              # light code-block background
            else:
                _bg_pop()
                pre_mode = 0
                _para_break()
        else:
            # inline <code>: teal monospace tint on a light code background so
            # inline code stands out from body text (UA default).
            if is_close == 0:
                _color_push(0x0a6b5a)
                _bg_push(CODE_BG)
                g_mono_n = g_mono_n + 1
            else:
                _bg_pop()
                _color_pop()
                if g_mono_n > 0:
                    g_mono_n = g_mono_n - 1
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("table")) != 0:
        _word_flush()
        if is_close == 0:
            # A <table> already inside a cell is a NESTED table: it lays out as
            # its own table box within the parent cell. Push the parent column
            # model so the shared col_x/n_cols/cur_col globals can be reused.
            nested: int32 = 0
            if table_active != 0 and cell_active != 0:
                nested = 1
            _table_push()
            e: int32 = tbl_sp - 1
            if nested != 0:
                _soft_newline()             # inner table starts inside the cell
            else:
                _cell_close()
                _soft_newline()
            rgn_start: uint64 = te + 1
            rgn_end: uint64 = _table_region_end(rgn_start)
            _measure_table(rgn_start, rgn_end)
            # Cascade first (need m_float/d_float + margins/border), then — if the
            # table floats — open a float box sized to its natural grid width so
            # the columns compute inside the pinned box and the body wraps beside.
            _open_style(ne, te)
            # Does this table stroke a border? CSS border, or the HTML border=.
            tbord: int32 = 0
            if m_bd == 1:
                tbord = 1
            if d_bd == 1:
                tbord = 1
            if _attr_int(ne, te, cast[Ptr[uint8]]("border"), 0) >= 1:
                tbord = 1
            tfloat: int32 = 0
            if m_float != 0:
                tfloat = m_float
            if d_float != 0:
                tfloat = d_float
            table_floated = 0
            if tfloat != 0 and nested == 0:
                ttop: int32 = 0
                if m_mt >= 0:
                    ttop = m_mt
                if d_mt >= 0:
                    ttop = d_mt
                tbot: int32 = 0
                if m_mb >= 0:
                    tbot = m_mb
                if d_mb >= 0:
                    tbot = d_mb
                fbord: int32 = 1                        # infoboxes read as boxed
                if m_bd == 0:
                    fbord = 0
                if d_bd == 0:
                    fbord = 0
                natw: int32 = _table_natural_width()
                if _float_box_open(tfloat, natw, ttop, tbot, fbord, -1) != 0:
                    table_floated = 1
            if table_floated == 0 and e >= 0:
                # In-flow table: reserve a top-rule row so its border strokes as
                # a real rectangle (a FLOATED table draws its own border through
                # _float_box_close, so only the in-flow path registers here).
                tbl_lx_st[e]  = indent_x
                tbl_rgb_st[e] = 0
                if tbord != 0:
                    tbl_srow_st[e]   = cast[int32](cur_row)
                    tbl_border_st[e] = 1
                    _bump_row()
            _compute_cols()
            table_active = 1
            cur_col = 0
            cell_active = 0
        else:
            _cell_close()
            e2: int32 = tbl_sp - 1
            didfloat: int32 = table_floated
            if table_floated != 0:
                table_floated = 0
                _close_style()
                fst: int32 = _float_box_close()
                _recompute_indent()
                pen_x = indent_x
                if fst == 0:                            # fell back to in-flow
                    _para_break()
            else:
                # Stroke THIS table's border as a real rectangle: bottom-rule row
                # is the fresh row after the last content, matching the reserved
                # top row so nested tables each register their own box.
                if e2 >= 0 and tbl_border_st[e2] != 0:
                    _soft_newline()
                    if n_bboxes < BBOX_MAX:
                        bbox_lx[n_bboxes]  = tbl_lx_st[e2]
                        bbox_rx[n_bboxes]  = col_x[n_cols]
                        bbox_top[n_bboxes] = tbl_srow_st[e2]
                        bbox_bot[n_bboxes] = cast[int32](cur_row)
                        bbox_rgb[n_bboxes] = tbl_rgb_st[e2]
                        n_bboxes = n_bboxes + 1
                    _bump_row()
                _close_style()
            _table_pop()
            if tbl_sp > 0:
                # Back inside an enclosing table cell: resume the parent table.
                table_active = 1
                pen_x = indent_x
                row_dirty = 1
            else:
                table_active = 0
                if didfloat == 0:
                    _recompute_indent()
                    pen_x = indent_x
                    _para_break()
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("tr")) != 0:
        _word_flush()
        if table_active != 0:
            _cell_close()
            if is_close == 0:
                _soft_newline()
                cur_col = 0
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("td")) != 0 or \
       _name_eq(np, nlen, cast[Ptr[uint8]]("th")) != 0:
        is_th: int32 = _name_eq(np, nlen, cast[Ptr[uint8]]("th"))
        _word_flush()
        if table_active == 0:
            return
        _cell_close()                         # close the previous cell first
        if is_close != 0:
            return
        cc: int32 = cur_col
        if cc >= n_cols:
            cc = n_cols - 1
        if cc < 0:
            cc = 0
        # colspan: the cell spans [cc, cc+span); its right edge is the LEFT
        # edge of the first column past the span, so its text flows across
        # the whole spanned width.
        span: int32 = _attr_int(ne, te, cast[Ptr[uint8]]("colspan"), 1)
        endc: int32 = cc + span
        if endc > n_cols:
            endc = n_cols
        # Inset the cell's content from BOTH the left border (col_x[cc], where a
        # pen with no inset would draw text straight onto/over the border) and
        # the right border, so text sits inside a padded cell instead of colliding
        # with the frame. The column model reserved CELL_PAD (2) char-cells of gap
        # per column, ample for these px insets.
        indent_x = col_x[cc] + CELL_PADX
        pen_x = col_x[cc] + CELL_PADX
        cell_right = col_x[endc] - CELL_PADX
        cell_active = 1
        cell_is_th = is_th
        need_space = 0
        row_dirty = 1                         # the cell's row is now occupied
        _open_style(ne, te)
        if is_th != 0:
            g_bold_n = g_bold_n + 1
        cur_col = endc
        _style_break()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("input")) != 0:
        if is_close != 0:
            return
        _emit_input(ne, te)
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("textarea")) != 0:
        _word_flush()
        if is_close == 0:
            # Draw the textarea's current content as a single-line box, then
            # skip the literal content so it is not also rendered as flow text.
            _word_push(91)                            # '['
            cs: uint64 = te + 1
            ce: uint64 = cs
            while ce < src_len:
                if src_ptr[ce] == 60 and ce + 1 < src_len and \
                   src_ptr[ce + 1] == 47 and \
                   _tagname_is(ce + 2, cast[Ptr[uint8]]("textarea")) != 0:
                    break
                ce = ce + 1
            ilen: int32 = 0
            p: uint64 = cs
            while p < ce:
                c2: uint8 = src_ptr[p]
                if c2 == 10 or c2 == 13 or c2 == 9:
                    c2 = 32
                _word_push(c2)
                ilen = ilen + 1
                p = p + 1
            while ilen < 8:
                _word_push(95)                        # '_'
                ilen = ilen + 1
            _word_push(93)                            # ']'
            _word_flush()
            # The close </textarea> is consumed by skip mode (never reaches
            # _handle_tag), so pop the scope we pushed at the top to keep the
            # element stack balanced.
            _el_pop(np, nlen)
            _enter_skip(np, nlen)
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("button")) != 0:
        _word_flush()
        if is_close == 0:
            _word_push(91)                            # '['
            _word_push(32)
            _word_flush()
            need_space = 0
        else:
            _word_push(32)
            _word_push(93)                            # ']'
            _word_flush()
        return
    if _name_eq(np, nlen, cast[Ptr[uint8]]("select")) != 0:
        _word_flush()
        if is_close == 0:
            _word_push(91)                            # '['
            _word_push(32)
            sn: int32 = _select_text(te + 1)
            if sn > 0:
                _wpush_cstr(&fbuf[0])
            _word_push(32)
            _word_push(118)                           # 'v'
            _word_push(93)                            # ']'
            _word_flush()
            _el_pop(np, nlen)                          # balance the pushed scope
            _enter_skip(np, nlen)
        return
    # <option>/<label>/<form>/<fieldset>/<legend>: no direct box — options are
    # consumed by <select>; label/form/fieldset are transparent containers whose
    # inner text flows normally (handled by the unknown-tag fallthrough).
    # Unknown tag: ignore it, keep surrounding text.
    return


# ====================================================================
# LAYOUT — parse src_ptr/src_len into segments.
# ====================================================================
def _reset_layout():
    n_segs = 0
    n_bboxes = 0
    n_bfills = 0
    seg_text_len = 0
    n_eimg = 0
    eimg_name_used = 0
    n_links = 0
    link_href_len = 0
    cur_row = 0
    pen_x = _left_margin()
    indent_x = _left_margin()
    row_dirty = 0
    need_space = 0
    seg_open = 0
    seg_curlen = 0
    _pending_indjump = 0
    g_color = 0
    g_page_bg = -1
    gblk_sp = 0
    g_bold = 0
    g_uline = 0
    g_link = -1
    g_link_rgb = -1
    g_bold_n = 0
    g_mono_n = 0
    g_heading = 0
    g_strike_n = 0
    g_yoff = 0
    sub_depth = 0
    sup_depth = 0
    dd_depth = 0
    list_depth = 0
    list_indent_drop = 0
    bq_depth = 0
    blk_indent_sp = 0
    blk_indent_sum = 0
    blk_right_sp = 0
    blk_right_cur = _content_right()
    box_sp = 0
    float_active = 0
    float_side = 0
    float_bottom = 0
    float_left_pad = 0
    float_redge = 0
    flex_sp = 0
    inlb_sp = 0
    g_inlb_floor = 0
    pos_n = 0
    posctx_sp = 0
    table_active = 0
    cell_active = 0
    cell_is_th = 0
    cur_col = 0
    n_cols = 0
    table_floated = 0
    tbl_sp = 0
    pre_mode = 0
    skip_active = 0
    skip_nlen = 0
    word_len = 0
    top_line = 0
    color_sp = 0
    g_rgb = -1
    bg_sp = 0
    g_bg = -1
    el_sp = 0
    el_slen = 0
    weight_sp = 0
    g_css_bold = 0
    fontpx_sp = 0
    g_font_px = 0
    lineh_sp = 0
    g_lineh = 0
    align_sp = 0
    g_align = 0
    deco_sp = 0
    g_css_uline = 0
    r: uint64 = 0
    while r < MAX_ROWS:
        row_rule[r] = 0
        row_align[r] = 0
        r = r + 1


# ---- CSS position bookkeeping ---------------------------------------
def _register_pos(seg0: int32, mode: int32, ox: int32, ort: int32, \
                  orow: int32, pl: int32, pt: int32, pr: int32, \
                  pb: int32, pz: int32) -> int32:
    if pos_n >= POS_MAX:
        return -1
    ri: int32 = pos_n
    pos_seg0[ri] = seg0
    pos_seg1[ri] = seg0
    pos_mode[ri] = mode
    pos_ox[ri]   = ox
    pos_ort[ri]  = ort
    pos_orow[ri] = orow
    pos_l[ri]    = pl
    pos_t[ri]    = pt
    pos_r[ri]    = pr
    pos_b[ri]    = pb
    pos_z[ri]    = pz
    pos_bf0[ri]  = n_bfills            # backgrounds of this box start here
    pos_bf1[ri]  = n_bfills
    pos_n = pos_n + 1
    return ri


def _posctx_push(x: int32, rt: int32, row: int32):
    if posctx_sp < 64:
        posctx_x[posctx_sp]   = x
        posctx_rt[posctx_sp]  = rt
        posctx_row[posctx_sp] = row
        posctx_sp = posctx_sp + 1


def _posctx_pop():
    if posctx_sp > 0:
        posctx_sp = posctx_sp - 1


# Post-layout pass: relocate each positioned element's segment run. `relative`
# offsets the box from its in-flow spot by left/top (or pulls it back by
# right/bottom); `absolute` places it against its containing-block origin. Runs
# are only registered for elements that declare `position`, so a page with none
# leaves this a no-op (byte-identical layout).
def _apply_positioned():
    i: int32 = 0
    while i < pos_n:
        s0: int32 = pos_seg0[i]
        s1: int32 = pos_seg1[i]
        # current pixel/row extent of the run's text (the box's in-flow origin).
        minx: int32 = 0x7fffffff
        maxx: int32 = -1
        minrow: int32 = 0x7fffffff
        k: int32 = s0
        while k < s1:
            x0: int32 = seg_x[k]
            x1: int32 = x0 + seg_len[k] * CELL_W
            if x0 < minx:
                minx = x0
            if x1 > maxx:
                maxx = x1
            if seg_line[k] < minrow:
                minrow = seg_line[k]
            k = k + 1
        # An out-of-flow box with a background but no text: fall back to the
        # box's background rectangle for the in-flow origin so it still moves.
        if maxx < 0 and pos_bf1[i] > pos_bf0[i]:
            minx = bfill_lx[pos_bf0[i]]
            maxx = bfill_rx[pos_bf0[i]]
            minrow = bfill_top[pos_bf0[i]]
        dx: int32 = 0
        drow: int32 = 0
        if maxx >= 0:
            elemw: int32 = maxx - minx
            if pos_mode[i] == 1:                           # relative
                if pos_l[i] >= 0:
                    dx = pos_l[i]
                elif pos_r[i] >= 0:
                    dx = -pos_r[i]
                dpy: int32 = 0
                if pos_t[i] >= 0:
                    dpy = pos_t[i]
                elif pos_b[i] >= 0:
                    dpy = -pos_b[i]
                drow = dpy / LINE_H
            else:                                          # absolute / fixed
                tx: int32 = minx
                if pos_l[i] >= 0:
                    tx = pos_ox[i] + pos_l[i]
                elif pos_r[i] >= 0:
                    tx = pos_ort[i] - pos_r[i] - elemw
                trow: int32 = minrow
                if pos_t[i] >= 0:
                    trow = pos_orow[i] + pos_t[i] / LINE_H
                elif pos_b[i] >= 0:
                    trow = pos_orow[i]
                dx = tx - minx
                drow = trow - minrow
        # Relocate the text segments.
        if dx != 0 or drow != 0:
            j: int32 = s0
            while j < s1:
                nx: int32 = seg_x[j] + dx
                if nx < 0:
                    nx = 0
                seg_x[j] = nx
                nr: int32 = seg_line[j] + drow
                if nr < 0:
                    nr = 0
                if cast[uint64](nr) >= MAX_ROWS:
                    nr = cast[int32](MAX_ROWS) - 1
                seg_line[j] = nr
                if cast[uint64](nr) + 1 > total_rows:
                    total_rows = cast[uint64](nr) + 1
                j = j + 1
        # Relocate the box's background fill(s) by the same delta and stamp the
        # stacking order so the paint pass can sort positioned boxes by z-index.
        bf: int32 = pos_bf0[i]
        while bf < pos_bf1[i]:
            if dx != 0:
                bfill_lx[bf] = bfill_lx[bf] + dx
                bfill_rx[bf] = bfill_rx[bf] + dx
                if bfill_lx[bf] < 0:
                    bfill_lx[bf] = 0
            if drow != 0:
                nt: int32 = bfill_top[bf] + drow
                nb: int32 = bfill_bot[bf] + drow
                if nt < 0:
                    nt = 0
                if nb < 0:
                    nb = 0
                if cast[uint64](nb) >= MAX_ROWS:
                    nb = cast[int32](MAX_ROWS) - 1
                bfill_top[bf] = nt
                bfill_bot[bf] = nb
                if cast[uint64](nb) > total_rows:
                    total_rows = cast[uint64](nb)
            bfill_z[bf] = pos_z[i]
            bf = bf + 1
        i = i + 1


# Post-layout pass: shift each row's segments for text-align center/right.
def _apply_alignment():
    right: int32 = _content_right()
    r: uint64 = 0
    while r < total_rows:
        a: uint8 = row_align[r]
        if a == 2 or a == 3:
            minx: int32 = 0x7fffffff
            maxr: int32 = -1
            si: uint64 = 0
            while si < n_segs:
                if cast[uint64](seg_line[si]) == r:
                    x0: int32 = seg_x[si]
                    x1: int32 = x0 + seg_len[si] * CELL_W
                    if x0 < minx:
                        minx = x0
                    if x1 > maxr:
                        maxr = x1
                si = si + 1
            if maxr >= 0:
                shift: int32 = 0
                if a == 2:                            # center in [left,right]
                    width: int32 = maxr - minx
                    lm: int32 = _left_margin()
                    newmin: int32 = lm + (right - lm - width) / 2
                    shift = newmin - minx
                else:                                 # right-align
                    shift = right - maxr
                if shift > 0:
                    si2: uint64 = 0
                    while si2 < n_segs:
                        if cast[uint64](seg_line[si2]) == r:
                            seg_x[si2] = seg_x[si2] + shift
                        si2 = si2 + 1
        r = r + 1


def _layout():
    _collect_css()
    _reset_layout()
    i: uint64 = 0
    while i < src_len:
        c: uint8 = src_ptr[i]
        if skip_active != 0:
            if c == 60:                              # '<'
                if i + 1 < src_len and src_ptr[i + 1] == 47:     # '</'
                    if _name_eq(i + 2, skip_nlen, &skip_name[0]) != 0:
                        skip_active = 0
                # advance past '>'
                while i < src_len and src_ptr[i] != 62:
                    i = i + 1
                if i < src_len:
                    i = i + 1
                continue
            i = i + 1
            continue
        if c == 60:                                  # '<'
            ts: uint64 = i + 1
            j: uint64 = ts
            while j < src_len and src_ptr[j] != 62:
                j = j + 1
            _word_flush()
            _handle_tag(ts, j)
            if j < src_len:
                i = j + 1
            else:
                i = j
            continue
        if c == 38:                                  # '&'
            consumed: uint64 = _entity(i)
            if consumed > 0:
                k: int32 = 0
                while k < g_ent_len:
                    _word_push(g_ent_buf[k])
                    k = k + 1
                i = i + consumed
                continue
            _word_push(38)
            i = i + 1
            continue
        # Whitespace is PRESERVED when the <pre>/<code> element is active
        # (pre_mode, monospace grid) OR CSS white-space set a preserving mode
        # (g_ws 2 = pre, 3 = pre-wrap; proportional flow). Otherwise runs of
        # whitespace collapse to a single inter-word space (normal / nowrap).
        ws_preserve: int32 = pre_mode
        if g_ws == 2 or g_ws == 3:
            ws_preserve = 1
        if ws_preserve == 0:
            if c == 32 or c == 9 or c == 10 or c == 13:
                _word_flush()
                need_space = 1
                i = i + 1
                continue
            _word_push(c)
            i = i + 1
            continue
        # preformatted: preserve whitespace, honor newlines.
        if c == 10:
            _word_flush()
            _newline()
            i = i + 1
            continue
        if c == 13:
            i = i + 1
            continue
        if c == 9:
            _word_push(32)
            _word_push(32)
            i = i + 1
            continue
        _word_push(c)
        i = i + 1
    _word_flush()
    _close_seg()
    _float_flush()                                       # drop below any trailing float
    total_rows = cur_row + 1
    _apply_alignment()
    _apply_positioned()


# ====================================================================
# JAVASCRIPT + minimal DOM.
#
# At layout time we run every <script> body through lib/jsengine.ad (js_eval),
# sharing ONE JS context across a page's scripts so later scripts see earlier
# globals. A minimal DOM is exposed to those scripts through jsengine's
# host-object seam (js_set_host_dispatch + the value constructors) — NO edits
# to the engine. `document.getElementById(id)` returns a plain JS object whose
# `textContent`, `style.color`, and `style.display` are ordinary data
# properties; the script mutates them with normal assignment. After all scripts
# finish we READ those properties back and, for every element the script
# actually changed, record an override. If any override exists we rebuild a
# copy of the source HTML with the overrides baked in (replaced text, an inline
# colour wrapper, or a hidden element dropped) and lay THAT out — so the visual
# result reflects the JS. Pages with no <script> skip all of this and lay out
# the original source byte-for-byte (zero behavioural change, zero jsengine
# touch — which also sidesteps the native float-division #DE, task #51).
# ====================================================================
DOM_MAX:     int32  = 64
DOM_ID_CAP:  int32  = 4096
DOM_TXT_CAP: int32  = 65536
DOM_OV_CAP:  int32  = 65536

dom_idbuf:   Array[4096, uint8]      # concatenated element ids (case-sensitive)
dom_idbuf_len: int32 = 0
dom_id_off:  Array[64, int32]
dom_id_len:  Array[64, int32]
dom_obj:     Array[64, int32]        # JS object value-handle per element
dom_clsobj:  Array[64, int32]        # the element's classList object handle (-1 none)
dom_anchor:  Array[64, int32]        # source offset of the element's '<' (-1 = none)
dom_cstart:  Array[64, int32]        # inner-content span in the source
dom_cend:    Array[64, int32]
dom_ns:      Array[64, int32]        # tag-name span in the source
dom_nl:      Array[64, int32]
dom_orig_off: Array[64, int32]       # original textContent (in dom_txtbuf)
dom_orig_len: Array[64, int32]
dom_html_off: Array[64, int32]       # original innerHTML (raw markup, in dom_txtbuf)
dom_html_len: Array[64, int32]
dom_origcls_off: Array[64, int32]    # original class attribute value
dom_origcls_len: Array[64, int32]
dom_txtbuf:  Array[65536, uint8]
dom_txt_len: int32 = 0
dom_n:       int32 = 0

# ---- DOM tree index (task #324, browser round 2) -------------------
# The DOM was flat/source-anchored (round 1): each element carried its source
# span but no parent/child links, so tree-walking (`el.parentNode.children[0]
# .nextElementSibling`) and true selector combinators (`a > b`, `a + b`)
# could not work. This is a compact INTEGER tree overlay computed ONCE per
# page from the source spans every element already records: element B is a
# child of A iff B's '<' sits inside A's content span [cstart,cend) and A is
# the innermost such container. A single left-to-right pass with a span stack
# recovers the whole nesting. It is ints-only (no JS objects), so it can index
# far more elements (TX_MAX) than the JS-object cap (DOM_MAX); JS element
# objects are still registered lazily and their traversal properties are wired
# from this index (see _dom_wire_tree). tx_parent[i] = -1 for a root.
TX_MAX:     int32 = 512
tx_anchor:  Array[512, int32]        # source offset of the element's '<'
tx_cs:      Array[512, int32]        # inner-content start (just past '>')
tx_ce:      Array[512, int32]        # inner-content end (the matching '</')
tx_ns:      Array[512, int32]        # tag-name span start
tx_nl:      Array[512, int32]        # tag-name span length
tx_parent:  Array[512, int32]        # parent tx index, or -1 for a root
tx_stack:   Array[512, int32]        # scratch: open-element stack while building
tx_n:       int32 = 0
tx_built:   int32 = 0

# event handlers (parallel to 0..dom_n)
dom_onclick_fn:  Array[64, int32]    # stored JS function value, or -1
dom_onclick_src: Array[64, int32]    # inline onclick="..." source off, or -1
dom_onclick_srclen: Array[64, int32]
dom_oninput_fn:  Array[64, int32]    # oninput handler fn value, or -1
dom_oninput_src: Array[64, int32]
dom_oninput_srclen: Array[64, int32]
dom_onchange_fn: Array[64, int32]    # onchange handler fn value, or -1
dom_onchange_src: Array[64, int32]
dom_onchange_srclen: Array[64, int32]
dom_onsubmit_fn: Array[64, int32]    # onsubmit handler fn value, or -1 (forms)
dom_onsubmit_src: Array[64, int32]
dom_onsubmit_srclen: Array[64, int32]

# addEventListener registry — MULTIPLE listeners per (element,kind), fired in
# registration order (round 8). The el.on<evt> property + inline on<evt>=""
# handler stay in the dom_on*_fn/src slots (a single "attribute handler") and
# fire AFTER these, so `addEventListener('click',a); addEventListener('click',b);
# el.onclick=c` fires a, b, c. Independent slots => onclick + addEventListener
# both fire (real pages rely on this).
EVL_MAX:  int32 = 256
evl_el:   Array[256, int32]          # dom element index the listener is on
evl_kind: Array[256, int32]          # 0 click 1 input 2 change 3 submit
evl_fn:   Array[256, int32]          # JS function value
evl_dead: Array[256, int32]          # 1 = removed via removeEventListener
evl_n:    int32 = 0

g_stop_prop: int32 = 0               # set by event.stopPropagation() in a handler
g_cur_event: int32 = -1              # the JS event object of the in-flight dispatch

# ---- <canvas> registry ---------------------------------------------
# Maps each source <canvas> to a lib/htmlcanvas index + its lib/htmlimg backing
# slot. Populated on the FIRST getContext('2d') during the script phase, and
# looked up again during layout (by element id, else by source anchor) so the
# <canvas> box blits the drawn pixels. Identity survives a JS-driven source
# rewrite because ids are preserved (anchor is a best-effort no-rewrite path).
CANV_MAX:    int32 = 8
canv_ci:     Array[8, int32]         # lib/htmlcanvas index
canv_slot:   Array[8, int32]         # lib/htmlimg backing slot
canv_w:      Array[8, int32]
canv_h:      Array[8, int32]
canv_anchor: Array[8, int32]         # source '<' offset at registration
canv_idoff:  Array[8, int32]         # id string in dom_idbuf (canv_idlen bytes)
canv_idlen:  Array[8, int32]
canv_ctxobj: Array[8, int32]         # cached 2D-context JS object handle
canv_el:     Array[8, int32]         # owning dom element index
canv_n:      int32 = 0

# form-control metadata (parallel to 0..dom_n). dom_kind: 0 generic, 1 input,
# 2 textarea, 3 select, 4 button, 5 form.
dom_kind:      Array[64, int32]
dom_origval_off: Array[64, int32]    # original value (input/textarea/select)
dom_origval_len: Array[64, int32]
dom_origchecked: Array[64, int32]    # original checked state (0/1), else -1

# resolved form overrides (parallel to 0..dom_n). off/len/flag == -1 = unset.
dom_ov_val_off:  Array[64, int32]    # replacement value string
dom_ov_val_len:  Array[64, int32]
dom_ov_checked:  Array[64, int32]    # 1 checked, 0 unchecked, -1 unchanged

# form submission serialization result ("?a=1&b=2"), + last-navigated URL.
dom_nav_buf:  Array[2048, uint8]
dom_nav_len:  int32 = 0
dom_nav_present: int32 = 0
g_prevent_default: int32 = 0         # set by event.preventDefault() in a handler
g_nmtmp: Array[128, uint8]           # scratch for a field name during serialize
g_radioname: Array[128, uint8]       # scratch for a radio group name during exclusivity
g_radioname_len: int32 = 0

# appended created children: flat (source-element-idx, created-node-id)
# records — the TOP-LEVEL mount points where a script-built subtree attaches
# under an existing source element. ap_removed marks an edge unlinked
# (removeChild / node.remove()).
APPEND_MAX:  int32 = 256
ap_parent:   Array[256, int32]
ap_child:    Array[256, int32]
ap_removed:  Array[256, int32]
ap_n:        int32 = 0

# createElement / createTextNode nodes (not in source): a tag + a JS object we
# read back. cre_is_text marks a text node (no tag; textContent only).
# cre_gone marks a node detached from the tree (node.remove()/removeChild),
# so the emitter skips it wherever it is referenced.
CRE_MAX:     int32 = 256
cre_obj:     Array[256, int32]
cre_tag_off: Array[256, int32]       # tag name in dom_idbuf
cre_tag_len: Array[256, int32]
cre_is_text: Array[256, int32]       # 1 = text node (emit escaped text only)
cre_gone:    Array[256, int32]       # 1 = detached (skip when emitting)
cre_n:       int32 = 0

# created-node -> created-node child edges (nesting): a script can build a
# whole subtree (table > tr > td) before mounting its root. Ordered by
# insertion; cc_removed marks an unlinked edge.
CC_MAX:      int32 = 1024
cc_owner:    Array[1024, int32]      # parent created-node id
cc_child:    Array[1024, int32]      # child created-node id
cc_removed:  Array[1024, int32]
cc_n:        int32 = 0

# innerHTML-setter fragment parser scratch (see _parse_fragment). A bounded
# open-element stack + a linear text buffer used to accrue each open element's
# textContent (a shared linear write cursor means an ancestor's [start..close)
# span naturally includes its descendants' text, matching DOM textContent).
FRAG_STACK_MAX: int32 = 64
frag_st_cid:  Array[64, int32]       # open element's cre id (-1 = the root target)
frag_st_arr:  Array[64, int32]       # its live childNodes/children JS array
frag_st_txt:  Array[64, int32]       # frag_txt offset where its text began
FRAG_TXT_CAP: int32 = 16384
frag_txt:     Array[16384, uint8]
frag_txt_w:   int32 = 0

# resolved overrides (parallel to 0..dom_n). off/len == -1 means "not set".
dom_ov_inner_off: Array[64, int32]   # replacement inner (text OR html)
dom_ov_inner_len: Array[64, int32]
dom_ov_inner_html: Array[64, int32]  # 1 = emit raw (innerHTML), 0 = escape (textContent)
dom_ov_col_off:  Array[64, int32]    # colour (raw CSS value)
dom_ov_col_len:  Array[64, int32]
dom_ov_bg_off:   Array[64, int32]    # background-color
dom_ov_bg_len:   Array[64, int32]
dom_ov_wt_off:   Array[64, int32]    # font-weight
dom_ov_wt_len:   Array[64, int32]
dom_ov_al_off:   Array[64, int32]    # text-align
dom_ov_al_len:   Array[64, int32]
dom_ov_wd_off:   Array[64, int32]    # width (CSS length string, e.g. "100px")
dom_ov_wd_len:   Array[64, int32]
dom_ov_cls_off:  Array[64, int32]    # className
dom_ov_cls_len:  Array[64, int32]
dom_ov_hide:     Array[64, int32]    # 1 = display:none (drop the element)
dom_ovbuf:   Array[65536, uint8]
dom_ov_len:  int32 = 0
dom_n_overrides: int32 = 0           # count of elements with ANY override

dom_title_buf: Array[256, uint8]
dom_title_len: int32 = 0
dom_title_present: int32 = 0

js_con_buf:  Array[8192, uint8]      # captured console.log output
js_con_len:  int32 = 0
js_had_error: int32 = 0
js_ctx_live: int32 = 0               # a persistent JS context exists this render
he_click_links: int32 = 0           # native: wrap handler elements in #__evt_N links

# rewritten source (only built when overrides exist)
RW_CAP:  uint64 = 262144
rw_buf:  Array[262144, uint8]
rw_len:  uint64 = 0

# Comment-stripped source. Real pages routinely hide markup inside HTML
# comments — a <script> demo wrapped in <!-- -->, a legacy `<!-- <script>…
# //--> ` guard, or an IE conditional `<!--[if IE]>…<![endif]-->`. The tag
# tokenizers below only scan for the next '>', so a '>' or a whole <script>
# sitting INSIDE a comment used to leak: the comment body rendered as page
# text and (worse) a commented-out <script> was detected + executed. We strip
# `<!-- … -->` spans ONCE up front and repoint src at the stripped copy, so
# every downstream scanner (CSS harvest, script run, DOM build, layout,
# rewrite) sees comment-free source. `<!DOCTYPE …>` is NOT a comment (it does
# not open with `<!--`) and is left intact for _handle_tag to ignore.
CS_CAP:  uint64 = 262144
cs_buf:  Array[262144, uint8]
cs_done: int32 = 0


def _strip_comments():
    # Idempotent: safe to call again on an already-stripped buffer.
    if src_len == 0:
        return
    w: uint64 = 0
    i: uint64 = 0
    while i < src_len and w < CS_CAP - 1:
        # A comment opens with the exact 4-byte lead-in "<!--".
        if src_ptr[i] == 60 and i + 3 < src_len and \
           src_ptr[i + 1] == 33 and src_ptr[i + 2] == 45 and \
           src_ptr[i + 3] == 45:                            # '<' '!' '-' '-'
            j: uint64 = i + 4
            # Skip to the closing "-->" (first occurrence wins, per HTML: a
            # conditional `<!--[if IE]>…<![endif]-->` is one comment). An
            # unterminated comment swallows the rest of the document.
            while j + 2 < src_len:
                if src_ptr[j] == 45 and src_ptr[j + 1] == 45 and \
                   src_ptr[j + 2] == 62:                     # '-' '-' '>'
                    j = j + 3
                    break
                j = j + 1
            if j + 2 >= src_len:
                j = src_len                                  # unterminated
            i = j
            continue
        cs_buf[w] = src_ptr[i]
        w = w + 1
        i = i + 1
    cs_buf[w] = 0
    src_ptr = &cs_buf[0]
    src_len = w
    cs_done = 1

js_hbase: int32 = 0
js_doc:   int32 = 0
dom_idtmp: Array[256, uint8]

# native method ids (offsets from js_host_base()).
NID_GETBYID:  int32 = 0
NID_CREATE:   int32 = 1
NID_ADDEVT:   int32 = 2
NID_APPEND:   int32 = 3
NID_GETATTR:  int32 = 4
NID_SETATTR:  int32 = 5
NID_QUERY:    int32 = 6
NID_PREVENT:  int32 = 7               # event.preventDefault()
NID_CLSADD:   int32 = 8               # element.classList.add(name)
NID_CLSREM:   int32 = 9               # element.classList.remove(name)
NID_CLSTOG:   int32 = 10              # element.classList.toggle(name)
NID_CLSHAS:   int32 = 11             # element.classList.contains(name)
NID_CTEXT:    int32 = 12             # document.createTextNode(s)
NID_REMOVE:   int32 = 13             # element.remove()
NID_REMCHILD: int32 = 14             # parent.removeChild(child)
NID_INSBEF:   int32 = 15             # parent.insertBefore(new, ref)
NID_GETCTX:   int32 = 16             # canvas.getContext('2d')
NID_CV_FILLRECT:   int32 = 17        # ctx.fillRect(x,y,w,h)
NID_CV_CLEARRECT:  int32 = 18        # ctx.clearRect(x,y,w,h)
NID_CV_STROKERECT: int32 = 19        # ctx.strokeRect(x,y,w,h)
NID_CV_BEGIN:      int32 = 20        # ctx.beginPath()
NID_CV_MOVETO:     int32 = 21        # ctx.moveTo(x,y)
NID_CV_LINETO:     int32 = 22        # ctx.lineTo(x,y)
NID_CV_CLOSE:      int32 = 23        # ctx.closePath()
NID_CV_STROKE:     int32 = 24        # ctx.stroke()
NID_CV_FILL:       int32 = 25        # ctx.fill()
NID_CV_ARC:        int32 = 26        # ctx.arc(x,y,r,a0,a1)
NID_CV_FILLTEXT:   int32 = 27        # ctx.fillText(s,x,y)
NID_CV_STROKETEXT: int32 = 28        # ctx.strokeText(s,x,y)
NID_CV_MEASURE:    int32 = 29        # ctx.measureText(s)
NID_QUERYALL:  int32 = 30            # (document|element).querySelectorAll(sel)
NID_GETBYCLASS: int32 = 31           # (document|element).getElementsByClassName(c)
NID_GETBYTAG:  int32 = 32            # (document|element).getElementsByTagName(t)
NID_HASATTR:   int32 = 33            # element.hasAttribute(name)
NID_REMATTR:   int32 = 34            # element.removeAttribute(name)
NID_REMEVT:    int32 = 35            # element.removeEventListener(type, fn)
NID_DISPATCH:  int32 = 36            # element.dispatchEvent(ev)
NID_STOPPROP:  int32 = 37            # event.stopPropagation()
NID_CLONE:     int32 = 38            # element.cloneNode(deep)
NID_REPLCHILD: int32 = 39            # parent.replaceChild(new, old)
NID_SUBMIT:   int32 = 40             # form.submit() (programmatic form submit)

# close-tag scan results
g_close_lt:  uint64 = 0
g_close_end: uint64 = 0
# element-scan results: anchor '<', content span, tag-name span
g_el_lt: uint64 = 0
g_el_cs: uint64 = 0
g_el_ce: uint64 = 0
g_el_ns: uint64 = 0
g_el_nl: uint64 = 0


def _dom_reset():
    dom_n = 0
    dom_idbuf_len = 0
    dom_txt_len = 0
    dom_ov_len = 0
    dom_n_overrides = 0
    dom_title_len = 0
    dom_title_present = 0
    js_con_len = 0
    js_had_error = 0
    js_ctx_live = 0
    ap_n = 0
    cre_n = 0
    cc_n = 0
    rw_len = 0
    dom_nav_len = 0
    dom_nav_present = 0
    g_prevent_default = 0
    g_stop_prop = 0
    g_cur_event = -1
    evl_n = 0
    canv_n = 0
    tx_n = 0
    tx_built = 0
    htmlcanvas_reset()


def _cstr_len(p: Ptr[uint8]) -> int32:
    n: int32 = 0
    while p[n] != 0:
        n = n + 1
    return n


def _bytes_eq(a: Ptr[uint8], an: int32, b: Ptr[uint8], bn: int32) -> int32:
    if an != bn:
        return 0
    i: int32 = 0
    while i < an:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# compare a src span [a,b) to a byte string idp[0..idn), case-insensitive.
def _idbytes_eq(a: uint64, b: uint64, idp: Ptr[uint8], idn: int32) -> int32:
    if cast[int32](b - a) != idn:
        return 0
    i: int32 = 0
    while i < idn:
        if _lower(src_ptr[a + cast[uint64](i)]) != _lower(idp[i]):
            return 0
        i = i + 1
    return 1


# does the tag name at src[at] equal the src name span [ns, ns+nl), bounded?
def _srcname_eq(at: uint64, ns: uint64, nl: uint64) -> int32:
    k: uint64 = 0
    while k < nl:
        if at + k >= src_len:
            return 0
        if _lower(src_ptr[at + k]) != _lower(src_ptr[ns + k]):
            return 0
        k = k + 1
    if _alnum_at(at + nl) != 0:
        return 0
    return 1


# Find the matching close tag </name> for an element opened with tag name
# span [ns, ns+nl), scanning from `from`. Sets g_close_lt (the '<' of the
# close tag) and g_close_end (index just past its '>'). Returns 1 if a close
# tag was found; on miss both are set to `from` (empty content, no close).
def _find_close(ns: uint64, nl: uint64, frm: uint64) -> int32:
    depth: int32 = 0
    i: uint64 = frm
    while i < src_len:
        if src_ptr[i] == 60:                              # '<'
            if i + 1 < src_len and src_ptr[i + 1] == 47:  # '</'
                if _srcname_eq(i + 2, ns, nl) != 0:
                    if depth == 0:
                        g_close_lt = i
                        j: uint64 = i
                        while j < src_len and src_ptr[j] != 62:
                            j = j + 1
                        if j < src_len:
                            j = j + 1
                        g_close_end = j
                        return 1
                    depth = depth - 1
            elif src_ptr[i + 1] != 33 and src_ptr[i + 1] != 63:
                if _srcname_eq(i + 1, ns, nl) != 0:
                    depth = depth + 1
        i = i + 1
    g_close_lt = frm
    g_close_end = frm
    return 0


# Extract the text content of src span [cs,ce) (tags stripped) into out[oo..].
# Returns the number of bytes written.
def _extract_text(cs: uint64, ce: uint64, oo: int32) -> int32:
    n: int32 = 0
    i: uint64 = cs
    while i < ce:
        c: uint8 = src_ptr[i]
        if c == 60:                                       # '<' — skip a tag
            while i < ce and src_ptr[i] != 62:
                i = i + 1
            if i < ce:
                i = i + 1
            continue
        if oo + n < DOM_TXT_CAP:
            dom_txtbuf[oo + n] = c
            n = n + 1
        i = i + 1
    return n


# Copy the RAW markup of src span [cs,ce) into out[oo..] (innerHTML).
def _extract_html(cs: uint64, ce: uint64, oo: int32) -> int32:
    n: int32 = 0
    i: uint64 = cs
    while i < ce:
        if oo + n < DOM_TXT_CAP:
            dom_txtbuf[oo + n] = src_ptr[i]
            n = n + 1
        i = i + 1
    return n


# Scan a start tag at src[i]=='<'. Sets g_el_lt/cs/ce/ns/nl for the element
# and returns 1; caller has already checked src[i]=='<' + not close/comment.
def _scan_start_tag(i: uint64) -> int32:
    ts: uint64 = i + 1
    je: uint64 = ts
    while je < src_len and src_ptr[je] != 62:
        je = je + 1
    ne: uint64 = ts
    while ne < je and _alnum_at(ne) != 0:
        ne = ne + 1
    _find_close(ts, ne - ts, je + 1)
    g_el_lt = i
    g_el_ns = ts
    g_el_nl = ne - ts
    g_el_cs = je + 1
    g_el_ce = g_close_lt
    return 1


# Raw-text (CDATA) elements: the bodies of <script> and <style> are NOT HTML.
# Their text (JS string literals like innerHTML = '<p class="para">', CSS rules)
# must never be scanned for elements / ids / classes, or phantom nodes appear
# (round-5 .para count of 4 instead of 2). Given a start tag whose name span is
# [ts,ne) and whose '>' is at `je`, if it opens a script/style element return
# the source offset just PAST its matching close tag ('>'+1) so the source-text
# scanners resume AFTER the raw body. Returns 0 when the tag is not raw-text
# (0 is never a valid resume point: any tag at ts>=1 resumes past its own '>').
# Raw text has no element nesting — the body ends at the FIRST literal </name>.
def _rawtext_skip(ts: uint64, ne: uint64, je: uint64) -> uint64:
    nl: uint64 = ne - ts
    isrt: int32 = 0
    if _name_eq(ts, nl, cast[Ptr[uint8]]("script")) != 0:
        isrt = 1
    elif _name_eq(ts, nl, cast[Ptr[uint8]]("style")) != 0:
        isrt = 1
    if isrt == 0:
        return 0
    if je > ts and src_ptr[je - 1] == 47:                 # '<script .../>' self-close
        return 0
    i: uint64 = je + 1
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and src_ptr[i + 1] == 47:
            if _srcname_eq(i + 2, ts, nl) != 0:           # matched </script>|</style>
                j: uint64 = i + 2
                while j < src_len and src_ptr[j] != 62:
                    j = j + 1
                if j < src_len:
                    j = j + 1
                return j
        i = i + 1
    return src_len                                        # unterminated: skip to EOF


# Locate the FIRST element whose id attribute equals idp[0..idn). Sets the
# g_el_* element globals and returns 1 on a hit.
def _dom_find_by_id(idp: Ptr[uint8], idn: int32) -> int32:
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           src_ptr[i + 1] != 47 and src_ptr[i + 1] != 33 and \
           src_ptr[i + 1] != 63:
            ts: uint64 = i + 1
            je: uint64 = ts
            while je < src_len and src_ptr[je] != 62:
                je = je + 1
            ne: uint64 = ts
            while ne < je and _alnum_at(ne) != 0:
                ne = ne + 1
            rt: uint64 = _rawtext_skip(ts, ne, je)        # skip <script>/<style> body
            if rt != 0:
                i = rt
                continue
            if _find_attr(ts, je, cast[Ptr[uint8]]("id")) != 0:
                if _idbytes_eq(g_attr_start, g_attr_end, idp, idn) != 0:
                    return _scan_start_tag(i)
            i = je
        i = i + 1
    return 0


# Does class-attr span [a,b) contain the whitespace-delimited token tok[0..tn)?
def _cls_has_token(a: uint64, b: uint64, tok: Ptr[uint8], tn: int32) -> int32:
    i: uint64 = a
    while i < b:
        while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9):
            i = i + 1
        s: uint64 = i
        while i < b and src_ptr[i] != 32 and src_ptr[i] != 9:
            i = i + 1
        if _idbytes_eq(s, i, tok, tn) != 0:
            return 1
    return 0


# Is `c` a CSS identifier byte (letter / digit / '-' / '_')?
def _sel_isname(c: uint8) -> int32:
    if c >= 97 and c <= 122:
        return 1
    if c >= 65 and c <= 90:
        return 1
    if c >= 48 and c <= 57:
        return 1
    if c == 45 or c == 95:
        return 1
    return 0


g_selattr: Array[64, uint8]           # scratch: an attribute name from a selector


# Does the start tag whose name span is [ts,ne) and whose body ends at the '>'
# `je` match the SINGLE compound selector sel[0..seln)? Supports an optional
# leading tag name (or '*'), then any run of `.class`, `#id`, and `[attr]` /
# `[attr="v"]` components (all must hold). A descendant combinator (space) is
# handled by the callers, which pass only the rightmost compound here.
def _sel_match_at(ts: uint64, je: uint64, ne: uint64, sel: Ptr[uint8], \
                  seln: int32) -> int32:
    if seln == 0:
        return 0
    i: int32 = 0
    if sel[0] == 42:                                      # '*' — any tag
        i = 1
    else:
        while i < seln and _sel_isname(sel[i]) != 0:
            i = i + 1
        if i > 0:
            if _idbytes_eq(ts, ne, sel, i) == 0:
                return 0
    while i < seln:
        c: uint8 = sel[i]
        if c == 46:                                       # '.class'
            i = i + 1
            s0: int32 = i
            while i < seln and _sel_isname(sel[i]) != 0:
                i = i + 1
            if _find_attr(ts, je, cast[Ptr[uint8]]("class")) == 0:
                return 0
            if _cls_has_token(g_attr_start, g_attr_end, &sel[s0], i - s0) == 0:
                return 0
        elif c == 35:                                     # '#id'
            i = i + 1
            s1: int32 = i
            while i < seln and _sel_isname(sel[i]) != 0:
                i = i + 1
            if _find_attr(ts, je, cast[Ptr[uint8]]("id")) == 0:
                return 0
            if _idbytes_eq(g_attr_start, g_attr_end, &sel[s1], i - s1) == 0:
                return 0
        elif c == 91:                                     # '[attr]' / '[attr=v]'
            i = i + 1
            ns0: int32 = i
            while i < seln and sel[i] != 93 and sel[i] != 61:
                i = i + 1
            nn: int32 = i - ns0
            k: int32 = 0
            while k < nn and k < 63:
                g_selattr[k] = sel[ns0 + k]
                k = k + 1
            g_selattr[k] = 0
            hasval: int32 = 0
            vs0: int32 = 0
            vn: int32 = 0
            if i < seln and sel[i] == 61:                 # '='
                i = i + 1
                q: uint8 = 0
                if i < seln and (sel[i] == 34 or sel[i] == 39):
                    q = sel[i]
                    i = i + 1
                vs0 = i
                while i < seln and sel[i] != 93 and (q == 0 or sel[i] != q):
                    i = i + 1
                vn = i - vs0
                if q != 0 and i < seln and sel[i] == q:
                    i = i + 1
                hasval = 1
            if i < seln and sel[i] == 93:                 # ']'
                i = i + 1
            if _find_attr(ts, je, &g_selattr[0]) == 0:
                return 0
            if hasval != 0:
                if _idbytes_eq(g_attr_start, g_attr_end, &sel[vs0], vn) == 0:
                    return 0
        else:
            break                                         # e.g. a stray space
    return 1


# The rightmost compound of a (possibly descendant) selector: sets g_sel_off so
# callers use sel[g_sel_off .. seln). `A B C` degrades to matching `C` (the
# ancestor constraint is dropped — a documented round-1 approximation).
g_sel_off: int32 = 0


def _sel_rightmost(sel: Ptr[uint8], seln: int32):
    g_sel_off = 0
    j: int32 = 0
    while j < seln:
        if sel[j] == 32:                                  # ' '
            g_sel_off = j + 1
        j = j + 1


# ====================================================================
# DOM tree index build + true selector combinators (task #324).
# ====================================================================

# Build the integer tree overlay for the current (comment-stripped) source.
# One left-to-right pass over every start tag; a span stack recovers nesting
# (an element's parent is the innermost still-open enclosing element). Void /
# self-closing elements get an empty content span (_find_close returns `from`
# on a miss) so nothing nests inside them. Idempotent per page.
def _dom_build_tree_index():
    tx_n = 0
    sp: int32 = 0
    i: uint64 = 0
    while i < src_len and tx_n < TX_MAX:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           src_ptr[i + 1] != 47 and src_ptr[i + 1] != 33 and \
           src_ptr[i + 1] != 63:
            ts: uint64 = i + 1
            je: uint64 = ts
            while je < src_len and src_ptr[je] != 62:
                je = je + 1
            ne: uint64 = ts
            while ne < je and _alnum_at(ne) != 0:
                ne = ne + 1
            if ne > ts:                                   # a real named element
                _find_close(ts, ne - ts, je + 1)
                cs: int32 = cast[int32](je + 1)
                ce: int32 = cast[int32](g_close_lt)
                if ce < cs:
                    ce = cs
                anchor: int32 = cast[int32](i)
                while sp > 0 and tx_ce[tx_stack[sp - 1]] <= anchor:
                    sp = sp - 1
                par: int32 = -1
                if sp > 0:
                    par = tx_stack[sp - 1]
                k: int32 = tx_n
                tx_anchor[k] = anchor
                tx_cs[k] = cs
                tx_ce[k] = ce
                tx_ns[k] = cast[int32](ts)
                tx_nl[k] = cast[int32](ne - ts)
                tx_parent[k] = par
                tx_n = k + 1
                if sp < TX_MAX:
                    tx_stack[sp] = k
                    sp = sp + 1
            rt: uint64 = _rawtext_skip(ts, ne, je)        # index the script/style
            if rt != 0:                                   # node, but skip its body
                i = rt
                continue
            i = je
        i = i + 1
    tx_built = 1


# tx index whose '<' is at source offset `anchor`, or -1.
def _tx_by_anchor(anchor: int32) -> int32:
    j: int32 = 0
    while j < tx_n:
        if tx_anchor[j] == anchor:
            return j
        j = j + 1
    return -1


# Previous / next ELEMENT sibling of tx entry `t` (same parent, doc order).
def _tx_prev_sibling(t: int32) -> int32:
    par: int32 = tx_parent[t]
    r: int32 = -1
    j: int32 = 0
    while j < t:
        if tx_parent[j] == par:
            r = j
        j = j + 1
    return r


def _tx_next_sibling(t: int32) -> int32:
    par: int32 = tx_parent[t]
    j: int32 = t + 1
    while j < tx_n:
        if tx_parent[j] == par:
            return j
        j = j + 1
    return -1


# 1-based element-child index of `t` under its parent (for :nth-child).
def _tx_child_index(t: int32) -> int32:
    par: int32 = tx_parent[t]
    n: int32 = 0
    j: int32 = 0
    while j <= t:
        if tx_parent[j] == par:
            n = n + 1
        j = j + 1
    return n


# Parse a signed decimal integer from g_selbuf[s..e); leading spaces tolerated.
# A bare sign / empty span reads as 0 (callers special-case those).
def _parse_sint(s: int32, e: int32) -> int32:
    i: int32 = s
    while i < e and g_selbuf[i] == 32:
        i = i + 1
    neg: int32 = 0
    if i < e and (g_selbuf[i] == 43 or g_selbuf[i] == 45):
        if g_selbuf[i] == 45:
            neg = 1
        i = i + 1
    v: int32 = 0
    while i < e and g_selbuf[i] >= 48 and g_selbuf[i] <= 57:
        v = v * 10 + cast[int32](g_selbuf[i] - 48)
        i = i + 1
    if neg != 0:
        return 0 - v
    return v


# :nth-child(An+B) micro-syntax parser over g_selbuf[s..e). Sets g_nth_a/g_nth_b.
# Accepts: even (2n), odd (2n+1), a bare integer B (A=0), and the [±][d]n[±d]
# forms — n, -n, 2n, 2n+1, n+3, -n+3, 3n-2 — with whitespace tolerated.
g_nth_a: int32 = 0
g_nth_b: int32 = 0
def _parse_nth(s: int32, e: int32):
    g_nth_a = 0
    g_nth_b = 0
    i: int32 = s
    while i < e and g_selbuf[i] == 32:
        i = i + 1
    j: int32 = e
    while j > i and g_selbuf[j - 1] == 32:
        j = j - 1
    if _bytes_eq(&g_selbuf[i], j - i, cast[Ptr[uint8]]("even"), 4) != 0:
        g_nth_a = 2
        g_nth_b = 0
        return
    if _bytes_eq(&g_selbuf[i], j - i, cast[Ptr[uint8]]("odd"), 3) != 0:
        g_nth_a = 2
        g_nth_b = 1
        return
    # locate the 'n'/'N' (if any)
    npos: int32 = -1
    k: int32 = i
    while k < j:
        if g_selbuf[k] == 110 or g_selbuf[k] == 78:       # 'n' 'N'
            npos = k
            k = j
        else:
            k = k + 1
    if npos < 0:
        # a plain integer B (A stays 0)
        g_nth_b = _parse_sint(i, j)
        return
    # coefficient A: span [i, npos), trimmed
    ca: int32 = i
    ce: int32 = npos
    while ca < ce and g_selbuf[ca] == 32:
        ca = ca + 1
    while ce > ca and g_selbuf[ce - 1] == 32:
        ce = ce - 1
    if ce == ca:
        g_nth_a = 1
    elif ce - ca == 1 and g_selbuf[ca] == 43:             # bare '+'
        g_nth_a = 1
    elif ce - ca == 1 and g_selbuf[ca] == 45:             # bare '-'
        g_nth_a = -1
    else:
        g_nth_a = _parse_sint(ca, ce)
    # offset B: span (npos, j)
    bs: int32 = npos + 1
    while bs < j and g_selbuf[bs] == 32:
        bs = bs + 1
    if bs >= j:
        g_nth_b = 0
    else:
        g_nth_b = _parse_sint(bs, j)


# Does the 1-based child index `idx` satisfy idx == A*k + B for some integer
# k >= 0? Divisibility + non-negative quotient covers both signs of A.
def _nth_match(idx: int32, a: int32, b: int32) -> int32:
    if a == 0:
        if idx == b:
            return 1
        return 0
    d: int32 = idx - b
    if d == 0:
        return 1
    kk: int32 = d / a
    if kk >= 0 and a * kk == d:
        return 1
    return 0


# ---- selector parse: split into compound[] + combinator[] ----------
# g_comb[c] is the combinator LINKING compound c-1 (left) to compound c
# (right): 32 ' ' descendant, 62 '>' child, 43 '+' adjacent, 126 '~' general.
# g_comb[0] is unused. The selector bytes are copied into g_selbuf so the
# matchers are re-entrancy-safe against the query scan. g_sel_adv is set when the
# selector needs the tree (a combinator, or a structural pseudo-class).
g_selbuf:   Array[256, uint8]
g_seln:     int32 = 0
g_nc:       int32 = 0
g_comp_off: Array[8, int32]
g_comp_len: Array[8, int32]
g_comb:     Array[8, uint8]
g_sel_adv:      int32 = 0


def _sel_parse(sel: Ptr[uint8], seln: int32):
    n: int32 = seln
    if n > 255:
        n = 255
    k: int32 = 0
    while k < n:
        g_selbuf[k] = sel[k]
        k = k + 1
    g_seln = n
    g_nc = 0
    g_sel_adv = 0
    i: int32 = 0
    pending: uint8 = 0
    while i < n and g_nc < 8:
        sawspace: int32 = 0
        while i < n and g_selbuf[i] == 32:
            sawspace = 1
            i = i + 1
        if i >= n:
            break
        c: uint8 = g_selbuf[i]
        if c == 62 or c == 43 or c == 126:                # '>' '+' '~'
            pending = c
            i = i + 1
            while i < n and g_selbuf[i] == 32:
                i = i + 1
        elif sawspace != 0 and g_nc > 0:
            pending = 32                                  # descendant
        s: int32 = i
        while i < n:
            ch: uint8 = g_selbuf[i]
            if ch == 32 or ch == 62 or ch == 43 or ch == 126:
                break
            if ch == 91:                                  # '[' — skip to ']'
                while i < n and g_selbuf[i] != 93:
                    i = i + 1
            elif ch == 40:                                # '(' — skip a functional
                while i < n and g_selbuf[i] != 41:        # pseudo arg (e.g.
                    i = i + 1                             # :nth-child(2n+1)) to ')'
            if i < n and g_selbuf[i] == 58:               # ':' pseudo present
                g_sel_adv = 1
            i = i + 1
        if i > s:
            g_comp_off[g_nc] = s
            g_comp_len[g_nc] = i - s
            if g_nc == 0:
                g_comb[0] = 0
            else:
                g_comb[g_nc] = pending
                g_sel_adv = 1
            g_nc = g_nc + 1
            pending = 0


# Does compound `c` (base + optional structural pseudo) match tx entry `t`?
def _compound_matches_tx(t: int32, c: int32) -> int32:
    off: int32 = g_comp_off[c]
    ln: int32 = g_comp_len[c]
    bl: int32 = 0
    while bl < ln and g_selbuf[off + bl] != 58:           # up to ':'
        bl = bl + 1
    ts: uint64 = cast[uint64](tx_ns[t])
    ne: uint64 = ts + cast[uint64](tx_nl[t])
    je: uint64 = cast[uint64](tx_cs[t]) - 1
    if bl > 0:
        if _sel_match_at(ts, je, ne, &g_selbuf[off], bl) == 0:
            return 0
    # structural pseudo-classes
    p: int32 = off + bl
    while p < off + ln and g_selbuf[p] == 58:             # ':'
        p = p + 1
        ps: int32 = p
        while p < off + ln and _sel_isname(g_selbuf[p]) != 0:
            p = p + 1
        pl: int32 = p - ps
        if _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("first-child"), 11) != 0:
            if _tx_prev_sibling(t) >= 0:
                return 0
        elif _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("last-child"), 10) != 0:
            if _tx_next_sibling(t) >= 0:
                return 0
        elif _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("nth-child"), 9) != 0:
            if p < off + ln and g_selbuf[p] == 40:        # '('
                p = p + 1
                ncs: int32 = p
                while p < off + ln and g_selbuf[p] != 41:  # up to ')'
                    p = p + 1
                _parse_nth(ncs, p)
                if p < off + ln and g_selbuf[p] == 41:    # ')'
                    p = p + 1
                if _nth_match(_tx_child_index(t), g_nth_a, g_nth_b) == 0:
                    return 0
            else:
                return 0                                   # :nth-child with no arg
        else:
            return 0                                      # unknown pseudo -> no match
    return 1


# Match tx entry `cur` against compound `c` AND its left chain (combinators).
def _match_chain(cur: int32, c: int32) -> int32:
    if _compound_matches_tx(cur, c) == 0:
        return 0
    if c == 0:
        return 1
    cb: uint8 = g_comb[c]
    if cb == 62:                                          # '>' parent
        pp: int32 = tx_parent[cur]
        if pp < 0:
            return 0
        return _match_chain(pp, c - 1)
    if cb == 32:                                          # ' ' ancestor
        a: int32 = tx_parent[cur]
        while a >= 0:
            if _match_chain(a, c - 1) != 0:
                return 1
            a = tx_parent[a]
        return 0
    if cb == 43:                                          # '+' adjacent sibling
        ps: int32 = _tx_prev_sibling(cur)
        if ps < 0:
            return 0
        return _match_chain(ps, c - 1)
    if cb == 126:                                         # '~' general sibling
        s: int32 = _tx_prev_sibling(cur)
        while s >= 0:
            if _match_chain(s, c - 1) != 0:
                return 1
            s = _tx_prev_sibling(s)
        return 0
    return 0


# The full selector matches the source element anchored at offset `anchor`
# (only reached when g_sel_adv != 0). Verifies the whole compound/combinator chain
# against the tree index.
def _sel_adv_match(anchor: int32) -> int32:
    t: int32 = _tx_by_anchor(anchor)
    if t < 0:
        return 0
    return _match_chain(t, g_nc - 1)


# Locate the FIRST element in source span [lo,hi) matching selector sel. Sets
# the g_el_* globals; returns 1 on a hit.
def _dom_find_selector_scoped(sel: Ptr[uint8], seln: int32, lo: uint64, \
                              hi: uint64) -> int32:
    if seln == 0:
        return 0
    _sel_parse(sel, seln)
    if g_nc == 0:
        return 0
    rc: int32 = g_nc - 1                                   # rightmost compound
    rbl: int32 = 0
    while rbl < g_comp_len[rc] and g_selbuf[g_comp_off[rc] + rbl] != 58:
        rbl = rbl + 1
    ssel: Ptr[uint8] = &g_selbuf[g_comp_off[rc]]
    i: uint64 = lo
    while i < hi:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           src_ptr[i + 1] != 47 and src_ptr[i + 1] != 33 and \
           src_ptr[i + 1] != 63:
            ts: uint64 = i + 1
            je: uint64 = ts
            while je < src_len and src_ptr[je] != 62:
                je = je + 1
            ne: uint64 = ts
            while ne < je and _alnum_at(ne) != 0:
                ne = ne + 1
            hit: int32 = 0
            if rbl == 0:
                hit = 1                                    # bare pseudo (e.g. :first-child)
            elif _sel_match_at(ts, je, ne, ssel, rbl) != 0:
                hit = 1
            if hit != 0 and (g_sel_adv == 0 or _sel_adv_match(cast[int32](i)) != 0):
                return _scan_start_tag(i)
            i = je
        i = i + 1
    return 0


# Whole-document convenience (used by the id-less resolver paths).
def _dom_find_selector(sel: Ptr[uint8], seln: int32) -> int32:
    return _dom_find_selector_scoped(sel, seln, 0, src_len)


# Push EVERY element in source span [lo,hi) matching selector sel onto the JS
# array `arr` (each registered via _dom_register_el so it is a live element).
def _dom_collect_selector(sel: Ptr[uint8], seln: int32, lo: uint64, \
                          hi: uint64, arr: int32):
    if seln == 0:
        return
    _sel_parse(sel, seln)
    if g_nc == 0:
        return
    rc: int32 = g_nc - 1                                   # rightmost compound
    rbl: int32 = 0
    while rbl < g_comp_len[rc] and g_selbuf[g_comp_off[rc] + rbl] != 58:
        rbl = rbl + 1
    ssel: Ptr[uint8] = &g_selbuf[g_comp_off[rc]]
    i: uint64 = lo
    while i < hi:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           src_ptr[i + 1] != 47 and src_ptr[i + 1] != 33 and \
           src_ptr[i + 1] != 63:
            ts: uint64 = i + 1
            je: uint64 = ts
            while je < src_len and src_ptr[je] != 62:
                je = je + 1
            ne: uint64 = ts
            while ne < je and _alnum_at(ne) != 0:
                ne = ne + 1
            hit: int32 = 0
            if rbl == 0:
                hit = 1
            elif _sel_match_at(ts, je, ne, ssel, rbl) != 0:
                hit = 1
            if hit != 0 and (g_sel_adv == 0 or _sel_adv_match(cast[int32](i)) != 0):
                _scan_start_tag(i)
                js_array_push(arr, _dom_register_el())
            rt: uint64 = _rawtext_skip(ts, ne, je)        # skip <script>/<style> body
            if rt != 0:
                i = rt
                continue
            i = je
        i = i + 1


# Resolve the source span a query runs over: the calling element's inner content
# when `this` is a registered source element, else the whole document. Sets
# g_qlo/g_qhi. A created-node `this` (no source span) yields an empty scope.
g_qlo: uint64 = 0
g_qhi: uint64 = 0

# Parallel created-node query scope (round 5): a query rooted at a source
# element sees that element's created subtree; one rooted at a created node sees
# its created descendants; a document-level query sees the whole created forest.
g_cre_scope_el:  int32 = -1
g_cre_scope_cid: int32 = -1
g_cre_scope_doc: int32 = 1


def _set_query_scope():
    el: int32 = _find_el_by_obj(js_this())
    if el >= 0:
        g_qlo = cast[uint64](dom_cstart[el])
        g_qhi = cast[uint64](dom_cend[el])
        g_cre_scope_el = el
        g_cre_scope_cid = -1
        g_cre_scope_doc = 0
        return
    cid: int32 = _find_cre_by_obj(js_this())
    if cid >= 0:
        g_qlo = 0                                          # created node: empty src
        g_qhi = 0
        g_cre_scope_el = -1
        g_cre_scope_cid = cid
        g_cre_scope_doc = 0
        return
    g_qlo = 0                                              # document: whole page
    g_qhi = src_len
    g_cre_scope_el = -1
    g_cre_scope_cid = -1
    g_cre_scope_doc = 1


def _upper(c: uint8) -> uint8:
    if c >= 97 and c <= 122:
        return c - 32
    return c


g_dskey: Array[64, uint8]             # scratch: a camelCased data-* key


# Populate `o.dataset` from the element's data-* attributes in tag body [abody,je).
# `data-foo-bar="v"` -> dataset.fooBar == "v". Missing values -> "".
def _build_dataset(o: int32, abody: uint64, je: uint64):
    ds: int32 = js_new_object_v()
    i: uint64 = abody
    while i < je:
        boundary: int32 = 0
        if i == abody:
            boundary = 1
        elif src_ptr[i - 1] == 32 or src_ptr[i - 1] == 9 or src_ptr[i - 1] == 10:
            boundary = 1
        if boundary != 0 and i + 5 <= je and \
           _lower(src_ptr[i]) == 100 and _lower(src_ptr[i + 1]) == 97 and \
           _lower(src_ptr[i + 2]) == 116 and _lower(src_ptr[i + 3]) == 97 and \
           src_ptr[i + 4] == 45:                           # 'd' 'a' 't' 'a' '-'
            ks: uint64 = i + 5
            ke: uint64 = ks
            while ke < je and src_ptr[ke] != 61 and src_ptr[ke] != 32 and \
                  src_ptr[ke] != 9 and src_ptr[ke] != 62 and src_ptr[ke] != 47:
                ke = ke + 1
            kw: int32 = 0
            p: uint64 = ks
            while p < ke and kw < 63:
                if src_ptr[p] == 45 and p + 1 < ke:        # '-x' -> 'X' (camel)
                    p = p + 1
                    g_dskey[kw] = _upper(src_ptr[p])
                else:
                    g_dskey[kw] = src_ptr[p]
                kw = kw + 1
                p = p + 1
            g_dskey[kw] = 0
            if ke < je and src_ptr[ke] == 61:              # '=' value
                q: uint8 = 0
                vp: uint64 = ke + 1
                if vp < je and (src_ptr[vp] == 34 or src_ptr[vp] == 39):
                    q = src_ptr[vp]
                    vp = vp + 1
                vstart: uint64 = vp
                while vp < je and (q != 0 and src_ptr[vp] != q or \
                      q == 0 and src_ptr[vp] != 32 and src_ptr[vp] != 9 and \
                      src_ptr[vp] != 62):
                    vp = vp + 1
                js_set_prop(ds, &g_dskey[0], kw, \
                            js_new_string(&src_ptr[vstart], vp - vstart))
                i = vp
            else:
                js_set_prop(ds, &g_dskey[0], kw, js_new_string(&dom_txtbuf[0], 0))
                i = ke
        i = i + 1
    js_set_prop(o, cast[Ptr[uint8]]("dataset"), 7, ds)


def _dom_lookup_anchor(off: int32) -> int32:
    e: int32 = 0
    while e < dom_n:
        if dom_anchor[e] == off:
            return e
        e = e + 1
    return -1


def _dom_lookup_id(idp: Ptr[uint8], idn: int32) -> int32:
    e: int32 = 0
    while e < dom_n:
        if _bytes_eq(&dom_idbuf[dom_id_off[e]], dom_id_len[e], idp, idn) != 0:
            return e
        e = e + 1
    return -1


def _find_el_by_obj(objv: int32) -> int32:
    e: int32 = 0
    while e < dom_n:
        if dom_obj[e] == objv:
            return e
        e = e + 1
    return -1


def _find_cre_by_obj(objv: int32) -> int32:
    e: int32 = 0
    while e < cre_n:
        if cre_obj[e] == objv:
            return e
        e = e + 1
    return -1


# Append a source-element -> created-node mount edge. `at` = -1 appends at the
# end; otherwise the new edge is inserted just before ap index `at` (insertBefore).
def _ap_add(parent_el: int32, child_cid: int32, at: int32):
    if ap_n >= APPEND_MAX:
        return
    pos: int32 = ap_n
    if at >= 0 and at < ap_n:
        pos = at
        m: int32 = ap_n
        while m > pos:
            ap_parent[m] = ap_parent[m - 1]
            ap_child[m] = ap_child[m - 1]
            ap_removed[m] = ap_removed[m - 1]
            m = m - 1
    ap_parent[pos] = parent_el
    ap_child[pos] = child_cid
    ap_removed[pos] = 0
    ap_n = ap_n + 1


# Append a created-node -> created-node child edge (nesting). `at` = -1 appends
# at the end; otherwise insert just before cc index `at`.
def _cc_add(owner_cid: int32, child_cid: int32, at: int32):
    if cc_n >= CC_MAX:
        return
    pos: int32 = cc_n
    if at >= 0 and at < cc_n:
        pos = at
        m: int32 = cc_n
        while m > pos:
            cc_owner[m] = cc_owner[m - 1]
            cc_child[m] = cc_child[m - 1]
            cc_removed[m] = cc_removed[m - 1]
            m = m - 1
    cc_owner[pos] = owner_cid
    cc_child[pos] = child_cid
    cc_removed[pos] = 0
    cc_n = cc_n + 1


# Find the ap edge index for (parent_el, child_cid); -1 if none.
def _ap_find(parent_el: int32, child_cid: int32) -> int32:
    a: int32 = 0
    while a < ap_n:
        if ap_removed[a] == 0 and ap_parent[a] == parent_el and \
           ap_child[a] == child_cid:
            return a
        a = a + 1
    return -1


# Find the cc edge index for (owner_cid, child_cid); -1 if none.
def _cc_find(owner_cid: int32, child_cid: int32) -> int32:
    a: int32 = 0
    while a < cc_n:
        if cc_removed[a] == 0 and cc_owner[a] == owner_cid and \
           cc_child[a] == child_cid:
            return a
        a = a + 1
    return -1


# ====================================================================
# Created-node selector traversal (round 5).
# ====================================================================
# querySelector/All, getElementById/ByClassName/ByTagName scan the SOURCE
# text (above). Elements built at runtime via createElement+appendChild or an
# innerHTML= setter live in the cre_*/ap_*/cc_* model and JS childNodes arrays,
# invisible to that scan. We build a lightweight tree overlay (cx_*) of the
# MOUNTED created nodes each query, then run the same selector grammar over it,
# crossing up into the source tree at a created root so `.src .created` chains
# resolve. Results are appended after the source matches; a created node is
# never in the source text so the two result sets never overlap.
CX_MAX:    int32 = 256
cx_cid:    Array[256, int32]         # cre id at this cx slot
cx_parent: Array[256, int32]         # parent cx slot (-1 = root, source-mounted)
cx_src:    Array[256, int32]         # source el index if root, else -1
cx_eidx:   Array[256, int32]         # 1-based ELEMENT-child index (:nth-child)
cx_n:      int32 = 0
cx_slot:   Array[256, int32]         # cre id -> cx slot (dedup / visited), -1 none


# Register created node `cid` as a fresh cx slot under `parent_slot` (source el
# `src_el` when a root), element index `eidx`. Returns the slot, or -1 if the
# node is gone / already visited / the pool is full.
def _cx_reg(cid: int32, parent_slot: int32, src_el: int32, eidx: int32) -> int32:
    if cid < 0 or cid >= cre_n or cre_gone[cid] != 0:
        return -1
    if cx_slot[cid] >= 0:
        return -1
    if cx_n >= CX_MAX:
        return -1
    s: int32 = cx_n
    cx_cid[s] = cid
    cx_parent[s] = parent_slot
    cx_src[s] = src_el
    cx_eidx[s] = eidx
    cx_slot[cid] = s
    cx_n = s + 1
    return s


# Enumerate the created children of a parent (source el `pel` OR created id
# `pcid`, the other -1) in DOM order — its JS childNodes array first (covers
# innerHTML + source appendChild), then any ap/cc edge child not already seen
# (covers created->created appendChild, which does not touch the JS array) —
# registering each and recursing. Dedup by cre id keeps a node single.
def _cx_walk(parent_slot: int32, pel: int32, pcid: int32):
    pobj: int32 = 0
    if pel >= 0:
        pobj = dom_obj[pel]
    else:
        pobj = cre_obj[pcid]
    ec: int32 = 0
    arr: int32 = js_get_prop(pobj, cast[Ptr[uint8]]("childNodes"), 10)
    if js_is_array(arr) != 0:
        ln: int32 = js_array_len(arr)
        m: int32 = 0
        while m < ln:
            ccid: int32 = _find_cre_by_obj(js_array_get(arr, m))
            if ccid >= 0 and cre_gone[ccid] == 0 and cx_slot[ccid] < 0:
                ei: int32 = 0
                if cre_is_text[ccid] == 0:
                    ec = ec + 1
                    ei = ec
                cs: int32 = _cx_reg(ccid, parent_slot, pel, ei)
                if cs >= 0:
                    _cx_walk(cs, -1, ccid)
            m = m + 1
    if pel >= 0:
        a: int32 = 0
        while a < ap_n:
            if ap_removed[a] == 0 and ap_parent[a] == pel and ap_child[a] >= 0 \
               and cre_gone[ap_child[a]] == 0 and cx_slot[ap_child[a]] < 0:
                ei2: int32 = 0
                if cre_is_text[ap_child[a]] == 0:
                    ec = ec + 1
                    ei2 = ec
                cs2: int32 = _cx_reg(ap_child[a], parent_slot, pel, ei2)
                if cs2 >= 0:
                    _cx_walk(cs2, -1, ap_child[a])
            a = a + 1
    else:
        b: int32 = 0
        while b < cc_n:
            if cc_removed[b] == 0 and cc_owner[b] == pcid and cc_child[b] >= 0 \
               and cre_gone[cc_child[b]] == 0 and cx_slot[cc_child[b]] < 0:
                ei3: int32 = 0
                if cre_is_text[cc_child[b]] == 0:
                    ec = ec + 1
                    ei3 = ec
                cs3: int32 = _cx_reg(cc_child[b], parent_slot, -1, ei3)
                if cs3 >= 0:
                    _cx_walk(cs3, -1, cc_child[b])
            b = b + 1


# Rebuild the created-node overlay: every mounted created subtree, rooted at
# each registered source element.
def _cx_build():
    cx_n = 0
    z: int32 = 0
    while z < cre_n:
        cx_slot[z] = -1
        z = z + 1
    pel: int32 = 0
    while pel < dom_n:
        _cx_walk(-1, pel, -1)
        pel = pel + 1


# case-insensitive byte compare (class/id/tag/attr tokens across the JS heap).
def _ci_eq(a: Ptr[uint8], an: int32, b: Ptr[uint8], bn: int32) -> int32:
    if an != bn:
        return 0
    i: int32 = 0
    while i < an:
        if _lower(a[i]) != _lower(b[i]):
            return 0
        i = i + 1
    return 1


# Does whitespace-separated class string clsp[0..clsn) contain token tok[0..tn)?
def _cstr_cls_has(clsp: Ptr[uint8], clsn: int32, tok: Ptr[uint8], tn: int32) -> int32:
    i: int32 = 0
    while i < clsn:
        while i < clsn and (clsp[i] == 32 or clsp[i] == 9):
            i = i + 1
        s: int32 = i
        while i < clsn and clsp[i] != 32 and clsp[i] != 9:
            i = i + 1
        if _ci_eq(&clsp[s], i - s, tok, tn) != 0:
            return 1
    return 0


# Two cx slots share a parent (roots also require the same source parent el, so
# created roots under distinct source elements are not treated as siblings).
def _cx_same_parent(a: int32, b: int32) -> int32:
    if cx_parent[a] != cx_parent[b]:
        return 0
    if cx_parent[a] < 0 and cx_src[a] != cx_src[b]:
        return 0
    return 1


# Previous / next ELEMENT sibling cx slot of `slot`, or -1.
def _cx_prev_sib(slot: int32) -> int32:
    r: int32 = -1
    j: int32 = 0
    while j < slot:
        if cre_is_text[cx_cid[j]] == 0 and _cx_same_parent(j, slot) != 0:
            r = j
        j = j + 1
    return r


def _cx_next_sib(slot: int32) -> int32:
    j: int32 = slot + 1
    while j < cx_n:
        if cre_is_text[cx_cid[j]] == 0 and _cx_same_parent(j, slot) != 0:
            return j
        j = j + 1
    return -1


# Match the single compound-selector base sel[0..seln) (tag/'*', .class, #id,
# [attr]/[attr=v]) against created element at cx `slot`. Attributes/id/class are
# read from the node's live JS props (className for `class`).
def _cre_sel_match(slot: int32, sel: Ptr[uint8], seln: int32) -> int32:
    if seln == 0:
        return 0
    cid: int32 = cx_cid[slot]
    i: int32 = 0
    if sel[0] == 42:                                      # '*'
        i = 1
    else:
        while i < seln and _sel_isname(sel[i]) != 0:
            i = i + 1
        if i > 0:
            if _ci_eq(&dom_idbuf[cre_tag_off[cid]], cre_tag_len[cid], sel, i) == 0:
                return 0
    while i < seln:
        c: uint8 = sel[i]
        if c == 46:                                       # '.class'
            i = i + 1
            s0: int32 = i
            while i < seln and _sel_isname(sel[i]) != 0:
                i = i + 1
            clsv: int32 = js_get_prop(cre_obj[cid], cast[Ptr[uint8]]("className"), 9)
            clsp: Ptr[uint8] = js_str_ptr(clsv)
            clsn: int32 = _cstr_len(clsp)
            if _is_undef_str(clsp, clsn) != 0:
                clsn = 0
            if _cstr_cls_has(clsp, clsn, &sel[s0], i - s0) == 0:
                return 0
        elif c == 35:                                     # '#id'
            i = i + 1
            s1: int32 = i
            while i < seln and _sel_isname(sel[i]) != 0:
                i = i + 1
            idv: int32 = js_get_prop(cre_obj[cid], cast[Ptr[uint8]]("id"), 2)
            idp: Ptr[uint8] = js_str_ptr(idv)
            idn: int32 = _cstr_len(idp)
            if _is_undef_str(idp, idn) != 0:
                idn = 0
            if _ci_eq(idp, idn, &sel[s1], i - s1) == 0:
                return 0
        elif c == 91:                                     # '[attr]' / '[attr=v]'
            i = i + 1
            ns0: int32 = i
            while i < seln and sel[i] != 93 and sel[i] != 61:
                i = i + 1
            nn: int32 = i - ns0
            k: int32 = 0
            while k < nn and k < 63:
                g_selattr[k] = sel[ns0 + k]
                k = k + 1
            g_selattr[k] = 0
            hasval: int32 = 0
            vs0: int32 = 0
            vn: int32 = 0
            if i < seln and sel[i] == 61:                 # '='
                i = i + 1
                q: uint8 = 0
                if i < seln and (sel[i] == 34 or sel[i] == 39):
                    q = sel[i]
                    i = i + 1
                vs0 = i
                while i < seln and sel[i] != 93 and (q == 0 or sel[i] != q):
                    i = i + 1
                vn = i - vs0
                if q != 0 and i < seln and sel[i] == q:
                    i = i + 1
                hasval = 1
            if i < seln and sel[i] == 93:                 # ']'
                i = i + 1
            av: int32 = js_get_prop(cre_obj[cid], &g_selattr[0], cast[uint64](nn))
            ap: Ptr[uint8] = js_str_ptr(av)
            an: int32 = _cstr_len(ap)
            if an == 0 or _is_undef_str(ap, an) != 0:
                return 0
            if hasval != 0:
                if _ci_eq(ap, an, &sel[vs0], vn) == 0:
                    return 0
        else:
            break
    return 1


# Does compound `c` (base + structural pseudos) match created cx slot `slot`?
def _cre_compound_matches(slot: int32, c: int32) -> int32:
    if cre_is_text[cx_cid[slot]] != 0:
        return 0
    off: int32 = g_comp_off[c]
    ln: int32 = g_comp_len[c]
    bl: int32 = 0
    while bl < ln and g_selbuf[off + bl] != 58:
        bl = bl + 1
    if bl > 0:
        if _cre_sel_match(slot, &g_selbuf[off], bl) == 0:
            return 0
    p: int32 = off + bl
    while p < off + ln and g_selbuf[p] == 58:             # ':'
        p = p + 1
        ps: int32 = p
        while p < off + ln and _sel_isname(g_selbuf[p]) != 0:
            p = p + 1
        pl: int32 = p - ps
        if _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("first-child"), 11) != 0:
            if _cx_prev_sib(slot) >= 0:
                return 0
        elif _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("last-child"), 10) != 0:
            if _cx_next_sib(slot) >= 0:
                return 0
        elif _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("nth-child"), 9) != 0:
            if p < off + ln and g_selbuf[p] == 40:        # '('
                p = p + 1
                ncs: int32 = p
                while p < off + ln and g_selbuf[p] != 41:
                    p = p + 1
                _parse_nth(ncs, p)
                if p < off + ln and g_selbuf[p] == 41:
                    p = p + 1
                if _nth_match(cx_eidx[slot], g_nth_a, g_nth_b) == 0:
                    return 0
            else:
                return 0
        else:
            return 0
    return 1


# Source element `src_el` OR one of its source ancestors satisfies compound `c`
# with its own left chain — the ancestor half of a chain that started in a
# created subtree and crossed up into the source tree at a created root.
def _src_ancestor_match(src_el: int32, c: int32) -> int32:
    t: int32 = _tx_by_anchor(dom_anchor[src_el])
    while t >= 0:
        if _match_chain(t, c) != 0:
            return 1
        t = tx_parent[t]
    return 0


# Match created cx `slot` against compound `c` AND its left combinator chain,
# crossing into the source tree once a created root's source parent is reached.
def _cre_match_chain(slot: int32, c: int32) -> int32:
    if _cre_compound_matches(slot, c) == 0:
        return 0
    if c == 0:
        return 1
    cb: uint8 = g_comb[c]
    if cb == 62:                                          # '>' child
        par: int32 = cx_parent[slot]
        if par >= 0:
            return _cre_match_chain(par, c - 1)
        if cx_src[slot] >= 0:
            return _match_chain(_tx_by_anchor(dom_anchor[cx_src[slot]]), c - 1)
        return 0
    if cb == 32:                                          # ' ' descendant
        a: int32 = cx_parent[slot]
        while a >= 0:
            if _cre_match_chain(a, c - 1) != 0:
                return 1
            a = cx_parent[a]
        if cx_src[slot] >= 0:
            return _src_ancestor_match(cx_src[slot], c - 1)
        return 0
    if cb == 43:                                          # '+' adjacent sibling
        pv: int32 = _cx_prev_sib(slot)
        if pv < 0:
            return 0
        return _cre_match_chain(pv, c - 1)
    if cb == 126:                                         # '~' general sibling
        sv: int32 = _cx_prev_sib(slot)
        while sv >= 0:
            if _cre_match_chain(sv, c - 1) != 0:
                return 1
            sv = _cx_prev_sib(sv)
        return 0
    return 0


# Is cx `slot` within the active query scope (g_cre_scope_*)?
def _cx_in_scope(slot: int32) -> int32:
    if g_cre_scope_doc != 0:
        return 1
    if g_cre_scope_el >= 0:
        s: int32 = slot                                   # root's source el == scope el?
        while cx_parent[s] >= 0:
            s = cx_parent[s]
        if cx_src[s] == g_cre_scope_el:
            return 1
        return 0
    if g_cre_scope_cid >= 0:
        u: int32 = cx_parent[slot]                        # strict descendant of scope cid
        while u >= 0:
            if cx_cid[u] == g_cre_scope_cid:
                return 1
            u = cx_parent[u]
        return 0
    return 0


# Push every in-scope created node matching parsed selector (g_*) onto `arr`.
def _cre_collect(arr: int32):
    if g_nc == 0:
        return
    _cx_build()
    s: int32 = 0
    while s < cx_n:
        if cre_is_text[cx_cid[s]] == 0 and _cx_in_scope(s) != 0 \
           and _cre_match_chain(s, g_nc - 1) != 0:
            js_array_push(arr, cre_obj[cx_cid[s]])
        s = s + 1


# First in-scope created node matching parsed selector (g_*); its JS obj, else -1.
def _cre_find_first() -> int32:
    if g_nc == 0:
        return -1
    _cx_build()
    s: int32 = 0
    while s < cx_n:
        if cre_is_text[cx_cid[s]] == 0 and _cx_in_scope(s) != 0 \
           and _cre_match_chain(s, g_nc - 1) != 0:
            return cre_obj[cx_cid[s]]
        s = s + 1
    return -1


# First created element whose id prop == idp[0..idn); its JS obj, else -1.
def _cre_find_by_id(idp: Ptr[uint8], idn: int32) -> int32:
    _cx_build()
    s: int32 = 0
    while s < cx_n:
        cid: int32 = cx_cid[s]
        if cre_is_text[cid] == 0:
            idv: int32 = js_get_prop(cre_obj[cid], cast[Ptr[uint8]]("id"), 2)
            ip: Ptr[uint8] = js_str_ptr(idv)
            inn: int32 = _cstr_len(ip)
            if _is_undef_str(ip, inn) == 0 and _bytes_eq(ip, inn, idp, idn) != 0:
                return cre_obj[cid]
        s = s + 1
    return -1


# Build a fresh JS style object with the mutable props we honour, all "".
def _new_style_obj() -> int32:
    st: int32 = js_new_object_v()
    js_set_prop(st, cast[Ptr[uint8]]("color"), 5, js_new_string(&dom_txtbuf[0], 0))
    js_set_prop(st, cast[Ptr[uint8]]("backgroundColor"), 15, \
                js_new_string(&dom_txtbuf[0], 0))
    js_set_prop(st, cast[Ptr[uint8]]("fontWeight"), 10, \
                js_new_string(&dom_txtbuf[0], 0))
    js_set_prop(st, cast[Ptr[uint8]]("textAlign"), 9, \
                js_new_string(&dom_txtbuf[0], 0))
    js_set_prop(st, cast[Ptr[uint8]]("display"), 7, \
                js_new_string(&dom_txtbuf[0], 0))
    js_set_prop(st, cast[Ptr[uint8]]("width"), 5, \
                js_new_string(&dom_txtbuf[0], 0))
    return st


# ---- inline-style string <-> style-object routing -------------------------
# The routed properties: JS camelCase name + its length, and the CSS (kebab)
# name written into style="" / read from cssText. `background` is accepted as an
# input alias for backgroundColor. Only these participate in the cascade today;
# any other declaration is preserved on the JS object but not baked into layout.
STYLE_VAL_CAP: int32 = 256
g_stv_buf: Array[256, uint8]
g_stser:   Array[1024, uint8]
g_csst_in: Array[1024, uint8]     # stable copy of the css string being parsed


# Clear the routed camelCase props on a style object (cssText / setAttribute
# fully replace the inline style, so a re-parse starts from empty).
def _style_clear(st: int32):
    js_set_prop(st, cast[Ptr[uint8]]("color"), 5, js_new_string(&g_stv_buf[0], 0))
    js_set_prop(st, cast[Ptr[uint8]]("backgroundColor"), 15, \
                js_new_string(&g_stv_buf[0], 0))
    js_set_prop(st, cast[Ptr[uint8]]("fontWeight"), 10, \
                js_new_string(&g_stv_buf[0], 0))
    js_set_prop(st, cast[Ptr[uint8]]("textAlign"), 9, js_new_string(&g_stv_buf[0], 0))
    js_set_prop(st, cast[Ptr[uint8]]("display"), 7, js_new_string(&g_stv_buf[0], 0))
    js_set_prop(st, cast[Ptr[uint8]]("width"), 5, js_new_string(&g_stv_buf[0], 0))


# Parse a CSS declaration string p[0..n) ("color:red; display:none") into the
# style object's camelCase properties. Implements cssText / setAttribute('style')
# semantics (a full replace of the routed inline props).
def _style_apply_csstext(st: int32, pin: Ptr[uint8], nin: int32):
    # Copy the input into a stable buffer first: the parse below calls
    # js_new_string, which can move the JS string heap and dangle `pin`.
    n: int32 = nin
    if n > 1023:
        n = 1023
    ci: int32 = 0
    while ci < n:
        g_csst_in[ci] = pin[ci]
        ci = ci + 1
    p: Ptr[uint8] = &g_csst_in[0]
    _style_clear(st)
    i: int32 = 0
    while i < n:
        while i < n and (p[i] == 32 or p[i] == 9 or p[i] == 10 or \
                         p[i] == 13 or p[i] == 59):        # ws / ';'
            i = i + 1
        ps: int32 = i
        while i < n and p[i] != 58 and p[i] != 59:         # ':' or ';'
            i = i + 1
        pe: int32 = i
        while pe > ps and (p[pe - 1] == 32 or p[pe - 1] == 9):
            pe = pe - 1
        if i >= n or p[i] != 58:                           # no value -> skip
            while i < n and p[i] != 59:
                i = i + 1
            continue
        i = i + 1                                          # past ':'
        while i < n and (p[i] == 32 or p[i] == 9):
            i = i + 1
        vs: int32 = i
        while i < n and p[i] != 59:
            i = i + 1
        ve: int32 = i
        while ve > vs and (ve > 0 and (p[ve - 1] == 32 or p[ve - 1] == 9)):
            ve = ve - 1
        vl: int32 = ve - vs
        if vl > STYLE_VAL_CAP - 1:
            vl = STYLE_VAL_CAP - 1
        if vl < 0:
            vl = 0
        k: int32 = 0
        while k < vl:
            g_stv_buf[k] = p[vs + k]
            k = k + 1
        vstr: int32 = js_new_string(&g_stv_buf[0], cast[uint64](vl))
        pl: int32 = pe - ps
        if _bytes_eq(&p[ps], pl, cast[Ptr[uint8]]("color"), 5) != 0:
            js_set_prop(st, cast[Ptr[uint8]]("color"), 5, vstr)
        elif _bytes_eq(&p[ps], pl, cast[Ptr[uint8]]("background-color"), 16) != 0 \
             or _bytes_eq(&p[ps], pl, cast[Ptr[uint8]]("background"), 10) != 0:
            js_set_prop(st, cast[Ptr[uint8]]("backgroundColor"), 15, vstr)
        elif _bytes_eq(&p[ps], pl, cast[Ptr[uint8]]("font-weight"), 11) != 0:
            js_set_prop(st, cast[Ptr[uint8]]("fontWeight"), 10, vstr)
        elif _bytes_eq(&p[ps], pl, cast[Ptr[uint8]]("text-align"), 10) != 0:
            js_set_prop(st, cast[Ptr[uint8]]("textAlign"), 9, vstr)
        elif _bytes_eq(&p[ps], pl, cast[Ptr[uint8]]("display"), 7) != 0:
            js_set_prop(st, cast[Ptr[uint8]]("display"), 7, vstr)
        elif _bytes_eq(&p[ps], pl, cast[Ptr[uint8]]("width"), 5) != 0:
            js_set_prop(st, cast[Ptr[uint8]]("width"), 5, vstr)


# Append "kebab:value;" to g_stser if the style object's camelCase prop is set.
def _stser_prop(st: int32, camel: Ptr[uint8], cl: uint64, kebab: Ptr[uint8], \
                kl: int32, w: int32) -> int32:
    v: int32 = js_get_prop(st, camel, cl)
    p: Ptr[uint8] = js_str_ptr(v)
    n: int32 = _cstr_len(p)
    if n == 0 or _is_undef_str(p, n) != 0:
        return w
    i: int32 = 0
    while i < kl and w < 1023:
        g_stser[w] = kebab[i]
        w = w + 1
        i = i + 1
    if w < 1023:
        g_stser[w] = 58                                    # ':'
        w = w + 1
    j: int32 = 0
    while j < n and w < 1023:
        g_stser[w] = p[j]
        w = w + 1
        j = j + 1
    if w < 1023:
        g_stser[w] = 59                                    # ';'
        w = w + 1
    return w


# Serialize a style object's routed props back into a CSS string (getAttribute
# ('style') / a consistent read of the inline-style store). '' when none set.
def _style_serialize(st: int32) -> int32:
    w: int32 = 0
    w = _stser_prop(st, cast[Ptr[uint8]]("color"), 5, \
                    cast[Ptr[uint8]]("color"), 5, w)
    w = _stser_prop(st, cast[Ptr[uint8]]("backgroundColor"), 15, \
                    cast[Ptr[uint8]]("background-color"), 16, w)
    w = _stser_prop(st, cast[Ptr[uint8]]("fontWeight"), 10, \
                    cast[Ptr[uint8]]("font-weight"), 11, w)
    w = _stser_prop(st, cast[Ptr[uint8]]("textAlign"), 9, \
                    cast[Ptr[uint8]]("text-align"), 10, w)
    w = _stser_prop(st, cast[Ptr[uint8]]("display"), 7, \
                    cast[Ptr[uint8]]("display"), 7, w)
    w = _stser_prop(st, cast[Ptr[uint8]]("width"), 5, \
                    cast[Ptr[uint8]]("width"), 5, w)
    return js_new_string(&g_stser[0], cast[uint64](w))


# classList: a live token-list view of an element's class attribute. Each
# element gets its own classList object carrying add/remove/toggle/contains
# native methods; a parallel dom_clsobj[] maps that object back to the element
# so the dispatcher can mutate the element's className string, which the normal
# read-back path then bakes into the rewritten source (re-applying the CSS
# cascade). Real interactive pages toggle a class far more often than they
# assign a whole className string.
def _find_el_by_clsobj(objv: int32) -> int32:
    e: int32 = 0
    while e < dom_n:
        if dom_clsobj[e] == objv:
            return e
        e = e + 1
    return -1


def _new_classlist_obj() -> int32:
    cl: int32 = js_new_object_v()
    js_set_prop(cl, cast[Ptr[uint8]]("add"), 3, \
                js_new_native_fn(js_hbase + NID_CLSADD))
    js_set_prop(cl, cast[Ptr[uint8]]("remove"), 6, \
                js_new_native_fn(js_hbase + NID_CLSREM))
    js_set_prop(cl, cast[Ptr[uint8]]("toggle"), 6, \
                js_new_native_fn(js_hbase + NID_CLSTOG))
    js_set_prop(cl, cast[Ptr[uint8]]("contains"), 8, \
                js_new_native_fn(js_hbase + NID_CLSHAS))
    return cl


# scratch for classList string rebuilds
g_cls_scr: Array[1024, uint8]


# Does whitespace-delimited class string s[0..sn) contain the exact token
# tok[0..tn)?
def _clstr_has(s: Ptr[uint8], sn: int32, tok: Ptr[uint8], tn: int32) -> int32:
    if tn == 0:
        return 0
    i: int32 = 0
    while i < sn:
        while i < sn and (s[i] == 32 or s[i] == 9):
            i = i + 1
        st: int32 = i
        while i < sn and s[i] != 32 and s[i] != 9:
            i = i + 1
        if i - st == tn and _bytes_eq(&s[st], tn, tok, tn) != 0:
            return 1
    return 0


# Read element `el`'s current className into a NUL-terminated C-string,
# returning its length via g_cls_len. Reuses the element's JS "className" prop
# so successive classList ops compose.
g_cls_len: int32 = 0
g_cls_cur: Array[1024, uint8]


def _cls_read(el: int32) -> Ptr[uint8]:
    clv: int32 = js_get_prop(dom_obj[el], cast[Ptr[uint8]]("className"), 9)
    p: Ptr[uint8] = js_str_ptr(clv)
    n: int32 = _cstr_len(p)
    if n > 1023:
        n = 1023
    if _is_undef_str(p, n) != 0:
        n = 0
    i: int32 = 0
    while i < n:
        g_cls_cur[i] = p[i]
        i = i + 1
    g_cls_cur[n] = 0
    g_cls_len = n
    return &g_cls_cur[0]


# Write s[0..sn) back as element `el`'s className.
def _cls_write(el: int32, s: Ptr[uint8], sn: int32):
    js_set_prop(dom_obj[el], cast[Ptr[uint8]]("className"), 9, \
                js_new_string(s, cast[uint64](sn)))


# Copy class string cur[0..cn) into g_cls_scr, DROPPING every occurrence of
# token tok[0..tn); returns the new length. Tokens are re-joined by one space.
def _cls_build_without(cur: Ptr[uint8], cn: int32, tok: Ptr[uint8], \
                       tn: int32) -> int32:
    w: int32 = 0
    i: int32 = 0
    while i < cn:
        while i < cn and (cur[i] == 32 or cur[i] == 9):
            i = i + 1
        st: int32 = i
        while i < cn and cur[i] != 32 and cur[i] != 9:
            i = i + 1
        tl: int32 = i - st
        if tl == 0:
            continue
        if tl == tn and _bytes_eq(&cur[st], tl, tok, tn) != 0:
            continue                                          # drop it
        if w > 0 and w < 1023:
            g_cls_scr[w] = 32
            w = w + 1
        k: int32 = 0
        while k < tl and w < 1023:
            g_cls_scr[w] = cur[st + k]
            w = w + 1
            k = k + 1
    return w


# Append token tok[0..tn) to class string cur[0..cn) in g_cls_scr; returns len.
def _cls_build_with(cur: Ptr[uint8], cn: int32, tok: Ptr[uint8], \
                    tn: int32) -> int32:
    w: int32 = 0
    while w < cn and w < 1023:
        g_cls_scr[w] = cur[w]
        w = w + 1
    if w > 0 and w < 1023:
        g_cls_scr[w] = 32
        w = w + 1
    k: int32 = 0
    while k < tn and w < 1023:
        g_cls_scr[w] = tok[k]
        w = w + 1
        k = k + 1
    return w


# Attach the element-level native methods to a DOM element object.
def _attach_el_methods(o: int32):
    js_set_prop(o, cast[Ptr[uint8]]("addEventListener"), 16, \
                js_new_native_fn(js_hbase + NID_ADDEVT))
    js_set_prop(o, cast[Ptr[uint8]]("appendChild"), 11, \
                js_new_native_fn(js_hbase + NID_APPEND))
    js_set_prop(o, cast[Ptr[uint8]]("getAttribute"), 12, \
                js_new_native_fn(js_hbase + NID_GETATTR))
    js_set_prop(o, cast[Ptr[uint8]]("setAttribute"), 12, \
                js_new_native_fn(js_hbase + NID_SETATTR))
    js_set_prop(o, cast[Ptr[uint8]]("insertBefore"), 12, \
                js_new_native_fn(js_hbase + NID_INSBEF))
    js_set_prop(o, cast[Ptr[uint8]]("removeChild"), 11, \
                js_new_native_fn(js_hbase + NID_REMCHILD))
    js_set_prop(o, cast[Ptr[uint8]]("replaceChild"), 12, \
                js_new_native_fn(js_hbase + NID_REPLCHILD))
    js_set_prop(o, cast[Ptr[uint8]]("remove"), 6, \
                js_new_native_fn(js_hbase + NID_REMOVE))
    # canvas.getContext('2d') — meaningful only on a <canvas>; the dispatcher
    # returns null for any other tag, so attaching it universally is harmless.
    js_set_prop(o, cast[Ptr[uint8]]("getContext"), 10, \
                js_new_native_fn(js_hbase + NID_GETCTX))
    # element-scoped queries + the rest of the element API surface real pages
    # call. querySelector*/getElementsBy* scope to this element's subtree.
    js_set_prop(o, cast[Ptr[uint8]]("querySelector"), 13, \
                js_new_native_fn(js_hbase + NID_QUERY))
    js_set_prop(o, cast[Ptr[uint8]]("querySelectorAll"), 16, \
                js_new_native_fn(js_hbase + NID_QUERYALL))
    js_set_prop(o, cast[Ptr[uint8]]("getElementsByClassName"), 22, \
                js_new_native_fn(js_hbase + NID_GETBYCLASS))
    js_set_prop(o, cast[Ptr[uint8]]("getElementsByTagName"), 20, \
                js_new_native_fn(js_hbase + NID_GETBYTAG))
    js_set_prop(o, cast[Ptr[uint8]]("hasAttribute"), 12, \
                js_new_native_fn(js_hbase + NID_HASATTR))
    js_set_prop(o, cast[Ptr[uint8]]("removeAttribute"), 15, \
                js_new_native_fn(js_hbase + NID_REMATTR))
    js_set_prop(o, cast[Ptr[uint8]]("removeEventListener"), 19, \
                js_new_native_fn(js_hbase + NID_REMEVT))
    js_set_prop(o, cast[Ptr[uint8]]("dispatchEvent"), 13, \
                js_new_native_fn(js_hbase + NID_DISPATCH))
    js_set_prop(o, cast[Ptr[uint8]]("cloneNode"), 9, \
                js_new_native_fn(js_hbase + NID_CLONE))
    # form.submit() — meaningful on a <form> (or a control inside one; the
    # dispatcher resolves the enclosing form). Attached universally like
    # getContext; harmless on a non-form (the dispatcher no-ops there).
    js_set_prop(o, cast[Ptr[uint8]]("submit"), 6, \
                js_new_native_fn(js_hbase + NID_SUBMIT))


# Rebuild a parent object's live JS .children/.childNodes array with `childv`
# removed (identity match on the value handle). Keeps a readback after
# removeChild/replaceChild consistent with the mutated tree.
def _dom_children_drop(parentv: int32, childv: int32):
    old: int32 = js_get_prop(parentv, cast[Ptr[uint8]]("children"), 8)
    if js_is_array(old) == 0:
        return
    nw: int32 = js_new_array_v()
    i: int32 = 0
    ln: int32 = js_array_len(old)
    while i < ln:
        ev: int32 = js_array_get(old, i)
        if ev != childv:
            js_array_push(nw, ev)
        i = i + 1
    js_set_prop(parentv, cast[Ptr[uint8]]("children"), 8, nw)
    js_set_prop(parentv, cast[Ptr[uint8]]("childNodes"), 10, nw)


# Rebuild a parent object's live .children/.childNodes replacing the first
# occurrence of `oldv` with `newv` (in place). If `oldv` is absent, `newv` is
# appended so the array still reflects the mount.
def _dom_children_replace(parentv: int32, oldv: int32, newv: int32):
    old: int32 = js_get_prop(parentv, cast[Ptr[uint8]]("children"), 8)
    if js_is_array(old) == 0:
        return
    nw: int32 = js_new_array_v()
    did: int32 = 0
    i: int32 = 0
    ln: int32 = js_array_len(old)
    while i < ln:
        ev: int32 = js_array_get(old, i)
        if ev == oldv and did == 0:
            js_array_push(nw, newv)
            did = 1
        else:
            js_array_push(nw, ev)
        i = i + 1
    if did == 0:
        js_array_push(nw, newv)
    js_set_prop(parentv, cast[Ptr[uint8]]("children"), 8, nw)
    js_set_prop(parentv, cast[Ptr[uint8]]("childNodes"), 10, nw)


# Rebuild a parent object's live .children/.childNodes inserting `newv` just
# before the first occurrence of `refv`. `refv` == js_null() (or absent) appends.
def _dom_children_insert(parentv: int32, newv: int32, refv: int32):
    old: int32 = js_get_prop(parentv, cast[Ptr[uint8]]("children"), 8)
    if js_is_array(old) == 0:
        return
    nw: int32 = js_new_array_v()
    did: int32 = 0
    i: int32 = 0
    ln: int32 = js_array_len(old)
    while i < ln:
        ev: int32 = js_array_get(old, i)
        if ev == refv and did == 0 and refv != js_null():
            js_array_push(nw, newv)
            did = 1
        js_array_push(nw, ev)
        i = i + 1
    if did == 0:
        js_array_push(nw, newv)
    js_set_prop(parentv, cast[Ptr[uint8]]("children"), 8, nw)
    js_set_prop(parentv, cast[Ptr[uint8]]("childNodes"), 10, nw)


# Capture an inline event-handler attribute (onclick=/oninput=/...) source into
# dom_txtbuf. Sets g_ih_off (dom_txtbuf offset, -1 if absent) and g_ih_len.
g_ih_off: int32 = 0
g_ih_len: int32 = 0


def _idbuf_push_cstr(s: Ptr[uint8]):
    i: int32 = 0
    while s[i] != 0 and dom_idbuf_len < DOM_ID_CAP:
        dom_idbuf[dom_idbuf_len] = s[i]
        dom_idbuf_len = dom_idbuf_len + 1
        i = i + 1


def _capture_inline(te: uint64, name: Ptr[uint8]):
    g_ih_off = -1
    g_ih_len = 0
    if _find_attr(g_el_ns, te, name) != 0:
        os: int32 = dom_txt_len
        p: uint64 = g_attr_start
        osl: int32 = 0
        while p < g_attr_end and dom_txt_len < DOM_TXT_CAP:
            dom_txtbuf[dom_txt_len] = src_ptr[p]
            dom_txt_len = dom_txt_len + 1
            osl = osl + 1
            p = p + 1
        g_ih_off = os
        g_ih_len = osl


# Classify the current g_el_* element by tag name into a dom_kind code.
def _kind_of(ns: uint64, nl: int32) -> int32:
    if _idbytes_eq(ns, ns + cast[uint64](nl), cast[Ptr[uint8]]("input"), 5) != 0:
        return 1
    if _idbytes_eq(ns, ns + cast[uint64](nl), cast[Ptr[uint8]]("textarea"), 8) != 0:
        return 2
    if _idbytes_eq(ns, ns + cast[uint64](nl), cast[Ptr[uint8]]("select"), 6) != 0:
        return 3
    if _idbytes_eq(ns, ns + cast[uint64](nl), cast[Ptr[uint8]]("button"), 6) != 0:
        return 4
    if _idbytes_eq(ns, ns + cast[uint64](nl), cast[Ptr[uint8]]("form"), 4) != 0:
        return 5
    return 0


# Build a JS string of tag-name bytes p[0..n) upper-cased (spec-uppercase
# `.tagName`, e.g. `div` -> `DIV`). The internal lowercase tag names the layout
# engine reads (dom_ns/dom_nl, cre_tag) are untouched — only the JS view is
# normalized.
g_tagup: Array[64, uint8]


def _tagname_upper(p: Ptr[uint8], n: int32) -> int32:
    i: int32 = 0
    while i < n and i < 63:
        g_tagup[i] = _upper(p[i])
        i = i + 1
    return js_new_string(&g_tagup[0], cast[uint64](i))


# Register the source element at tree-index `txi` and return its JS object.
# Sets the g_el_* globals from the tree index, then defers to _dom_register_el
# (which dedups by anchor). Used to materialize a traversal neighbour.
def _dom_register_tx(txi: int32) -> int32:
    if txi < 0 or txi >= tx_n:
        return js_null()
    g_el_lt = cast[uint64](tx_anchor[txi])
    g_el_ns = cast[uint64](tx_ns[txi])
    g_el_nl = cast[uint64](tx_nl[txi])
    g_el_cs = cast[uint64](tx_cs[txi])
    g_el_ce = cast[uint64](tx_ce[txi])
    return _dom_register_el()


# Wire the live traversal properties of the just-registered element `idx` from
# the integer tree index: parentNode/parentElement, previous/nextElementSibling
# (+ firstChild/nextSibling aliases), children/childNodes, first/lastElement-
# Child. Each neighbour is materialized as a real element object via
# _dom_register_tx; the recursion is bounded by the DOM_MAX object cap and
# terminates because _dom_register_el dedups an already-registered anchor.
# childNodes is element-only here (text nodes are not modelled as nodes — a
# documented round-2 approximation), so firstChild==firstElementChild.
def _dom_wire_tree(idx: int32):
    if tx_built == 0:
        return
    t: int32 = _tx_by_anchor(dom_anchor[idx])
    if t < 0:
        return
    o: int32 = dom_obj[idx]
    # parent
    par: int32 = tx_parent[t]
    if par >= 0:
        pv: int32 = _dom_register_tx(par)
        js_set_prop(o, cast[Ptr[uint8]]("parentNode"), 10, pv)
        js_set_prop(o, cast[Ptr[uint8]]("parentElement"), 13, pv)
    else:
        js_set_prop(o, cast[Ptr[uint8]]("parentNode"), 10, js_null())
        js_set_prop(o, cast[Ptr[uint8]]("parentElement"), 13, js_null())
    # siblings (same parent, document order == tx order)
    prevs: int32 = _tx_prev_sibling(t)
    nexts: int32 = _tx_next_sibling(t)
    if prevs >= 0:
        pso: int32 = _dom_register_tx(prevs)
        js_set_prop(o, cast[Ptr[uint8]]("previousElementSibling"), 22, pso)
        js_set_prop(o, cast[Ptr[uint8]]("previousSibling"), 15, pso)
    else:
        js_set_prop(o, cast[Ptr[uint8]]("previousElementSibling"), 22, js_null())
        js_set_prop(o, cast[Ptr[uint8]]("previousSibling"), 15, js_null())
    if nexts >= 0:
        nso: int32 = _dom_register_tx(nexts)
        js_set_prop(o, cast[Ptr[uint8]]("nextElementSibling"), 18, nso)
        js_set_prop(o, cast[Ptr[uint8]]("nextSibling"), 11, nso)
    else:
        js_set_prop(o, cast[Ptr[uint8]]("nextElementSibling"), 18, js_null())
        js_set_prop(o, cast[Ptr[uint8]]("nextSibling"), 11, js_null())
    # children
    ch: int32 = js_new_array_v()
    havef: int32 = 0
    firsto: int32 = js_null()
    lasto: int32 = js_null()
    k: int32 = 0
    while k < tx_n:
        if tx_parent[k] == t:
            co: int32 = _dom_register_tx(k)
            js_array_push(ch, co)
            if havef == 0:
                firsto = co
                havef = 1
            lasto = co
        k = k + 1
    js_set_prop(o, cast[Ptr[uint8]]("children"), 8, ch)
    js_set_prop(o, cast[Ptr[uint8]]("childNodes"), 10, ch)
    js_set_prop(o, cast[Ptr[uint8]]("firstElementChild"), 17, firsto)
    js_set_prop(o, cast[Ptr[uint8]]("firstChild"), 10, firsto)
    js_set_prop(o, cast[Ptr[uint8]]("lastElementChild"), 16, lasto)
    # childNodes is element-only here (round-2 approximation), so the node-level
    # aliases mirror the element-level ones.
    js_set_prop(o, cast[Ptr[uint8]]("lastChild"), 9, lasto)


# Register (or return the existing record for) the element described by the
# current g_el_* globals. Returns its JS object value-handle.
def _dom_register_el() -> int32:
    anchor: int32 = cast[int32](g_el_lt)
    ex: int32 = _dom_lookup_anchor(anchor)
    if ex >= 0:
        return dom_obj[ex]
    if dom_n >= DOM_MAX:
        return js_undefined()
    idx: int32 = dom_n
    dom_anchor[idx] = anchor
    dom_cstart[idx] = cast[int32](g_el_cs)
    dom_cend[idx] = cast[int32](g_el_ce)
    dom_ns[idx] = cast[int32](g_el_ns)
    dom_nl[idx] = cast[int32](g_el_nl)
    te: uint64 = g_el_cs - 1                              # the '>' of the start tag
    # original text + html
    ot: int32 = dom_txt_len
    otl: int32 = _extract_text(g_el_cs, g_el_ce, ot)
    dom_txt_len = ot + otl
    dom_orig_off[idx] = ot
    dom_orig_len[idx] = otl
    oh: int32 = dom_txt_len
    ohl: int32 = _extract_html(g_el_cs, g_el_ce, oh)
    dom_txt_len = oh + ohl
    dom_html_off[idx] = oh
    dom_html_len[idx] = ohl
    # id attribute
    ido: int32 = dom_idbuf_len
    idl: int32 = 0
    if _find_attr(g_el_ns, te, cast[Ptr[uint8]]("id")) != 0:
        p: uint64 = g_attr_start
        while p < g_attr_end and dom_idbuf_len < DOM_ID_CAP:
            dom_idbuf[dom_idbuf_len] = src_ptr[p]
            dom_idbuf_len = dom_idbuf_len + 1
            idl = idl + 1
            p = p + 1
    dom_id_off[idx] = ido
    dom_id_len[idx] = idl
    # class attribute (original)
    oc: int32 = dom_txt_len
    ocl: int32 = 0
    if _find_attr(g_el_ns, te, cast[Ptr[uint8]]("class")) != 0:
        p2: uint64 = g_attr_start
        while p2 < g_attr_end and dom_txt_len < DOM_TXT_CAP:
            dom_txtbuf[dom_txt_len] = src_ptr[p2]
            dom_txt_len = dom_txt_len + 1
            ocl = ocl + 1
            p2 = p2 + 1
    dom_origcls_off[idx] = oc
    dom_origcls_len[idx] = ocl
    # inline event-handler attributes (source stored; run on the event)
    dom_onclick_fn[idx] = -1
    _capture_inline(te, cast[Ptr[uint8]]("onclick"))
    dom_onclick_src[idx] = g_ih_off
    dom_onclick_srclen[idx] = g_ih_len
    dom_oninput_fn[idx] = -1
    _capture_inline(te, cast[Ptr[uint8]]("oninput"))
    dom_oninput_src[idx] = g_ih_off
    dom_oninput_srclen[idx] = g_ih_len
    dom_onchange_fn[idx] = -1
    _capture_inline(te, cast[Ptr[uint8]]("onchange"))
    dom_onchange_src[idx] = g_ih_off
    dom_onchange_srclen[idx] = g_ih_len
    dom_onsubmit_fn[idx] = -1
    _capture_inline(te, cast[Ptr[uint8]]("onsubmit"))
    dom_onsubmit_src[idx] = g_ih_off
    dom_onsubmit_srclen[idx] = g_ih_len
    # form-control metadata: kind, original value, original checked state.
    kind: int32 = _kind_of(g_el_ns, cast[int32](g_el_nl))
    dom_kind[idx] = kind
    dom_origchecked[idx] = -1
    ovo: int32 = dom_txt_len
    ovl: int32 = 0
    if kind == 2:                                        # textarea: value = text
        k: int32 = 0
        while k < otl and dom_txt_len < DOM_TXT_CAP:
            dom_txtbuf[dom_txt_len] = dom_txtbuf[ot + k]
            dom_txt_len = dom_txt_len + 1
            ovl = ovl + 1
            k = k + 1
    elif kind == 3:                                      # select: selected option
        sl: int32 = _select_text(g_el_cs)
        sk: int32 = 0
        while sk < sl and dom_txt_len < DOM_TXT_CAP:
            dom_txtbuf[dom_txt_len] = fbuf[sk]
            dom_txt_len = dom_txt_len + 1
            ovl = ovl + 1
            sk = sk + 1
    elif kind == 1:                                      # input: value attribute
        if _find_attr(g_el_ns, te, cast[Ptr[uint8]]("value")) != 0:
            pv: uint64 = g_attr_start
            while pv < g_attr_end and dom_txt_len < DOM_TXT_CAP:
                dom_txtbuf[dom_txt_len] = src_ptr[pv]
                dom_txt_len = dom_txt_len + 1
                ovl = ovl + 1
                pv = pv + 1
        if _input_type_is(g_el_ns, te, cast[Ptr[uint8]]("checkbox")) != 0 or \
           _input_type_is(g_el_ns, te, cast[Ptr[uint8]]("radio")) != 0:
            if _has_word(g_el_ns, te, cast[Ptr[uint8]]("checked")) != 0:
                dom_origchecked[idx] = 1
            else:
                dom_origchecked[idx] = 0
    dom_origval_off[idx] = ovo
    dom_origval_len[idx] = ovl
    # the JS object
    o: int32 = js_new_object_v()
    js_set_prop(o, cast[Ptr[uint8]]("textContent"), 11, \
                js_new_string(&dom_txtbuf[ot], cast[uint64](otl)))
    js_set_prop(o, cast[Ptr[uint8]]("innerHTML"), 9, \
                js_new_string(&dom_txtbuf[oh], cast[uint64](ohl)))
    js_set_prop(o, cast[Ptr[uint8]]("id"), 2, \
                js_new_string(&dom_idbuf[ido], cast[uint64](idl)))
    js_set_prop(o, cast[Ptr[uint8]]("className"), 9, \
                js_new_string(&dom_txtbuf[oc], cast[uint64](ocl)))
    js_set_prop(o, cast[Ptr[uint8]]("tagName"), 7, \
                _tagname_upper(&src_ptr[g_el_ns], cast[int32](g_el_nl)))
    # node-identity properties (frameworks branch on node.nodeType === 1).
    # nodeName == tagName for elements; nodeValue is null (only text nodes carry
    # a value). ELEMENT_NODE = 1.
    js_set_prop(o, cast[Ptr[uint8]]("nodeType"), 8, js_number(cast[float64](1)))
    js_set_prop(o, cast[Ptr[uint8]]("nodeName"), 8, \
                _tagname_upper(&src_ptr[g_el_ns], cast[int32](g_el_nl)))
    js_set_prop(o, cast[Ptr[uint8]]("nodeValue"), 9, js_null())
    js_set_prop(o, cast[Ptr[uint8]]("style"), 5, _new_style_obj())
    # form-control DOM properties: value / checked / type / name (+ selectedIndex).
    if kind == 1 or kind == 2 or kind == 3 or kind == 4:
        js_set_prop(o, cast[Ptr[uint8]]("value"), 5, \
                    js_new_string(&dom_txtbuf[ovo], cast[uint64](ovl)))
        # name attribute
        nmo: int32 = dom_idbuf_len
        nml: int32 = 0
        if _find_attr(g_el_ns, te, cast[Ptr[uint8]]("name")) != 0:
            pn2: uint64 = g_attr_start
            while pn2 < g_attr_end and dom_idbuf_len < DOM_ID_CAP:
                dom_idbuf[dom_idbuf_len] = src_ptr[pn2]
                dom_idbuf_len = dom_idbuf_len + 1
                nml = nml + 1
                pn2 = pn2 + 1
        js_set_prop(o, cast[Ptr[uint8]]("name"), 4, \
                    js_new_string(&dom_idbuf[nmo], cast[uint64](nml)))
        # type (input: attr or "text"; else the tag name)
        tyo: int32 = dom_idbuf_len
        tyl: int32 = 0
        if kind == 1:
            if _find_attr(g_el_ns, te, cast[Ptr[uint8]]("type")) != 0:
                pt: uint64 = g_attr_start
                while pt < g_attr_end and dom_idbuf_len < DOM_ID_CAP:
                    dom_idbuf[dom_idbuf_len] = _lower(src_ptr[pt])
                    dom_idbuf_len = dom_idbuf_len + 1
                    tyl = tyl + 1
                    pt = pt + 1
            else:
                _idbuf_push_cstr(cast[Ptr[uint8]]("text"))
                tyl = 4
        js_set_prop(o, cast[Ptr[uint8]]("type"), 4, \
                    js_new_string(&dom_idbuf[tyo], cast[uint64](tyl)))
        if dom_origchecked[idx] >= 0:
            js_set_prop(o, cast[Ptr[uint8]]("checked"), 7, \
                        js_bool(dom_origchecked[idx]))
        if kind == 3:
            js_set_prop(o, cast[Ptr[uint8]]("selectedIndex"), 13, \
                        js_number(cast[float64](_select_index(g_el_cs))))
    _attach_el_methods(o)
    cl: int32 = _new_classlist_obj()
    js_set_prop(o, cast[Ptr[uint8]]("classList"), 9, cl)
    dom_clsobj[idx] = cl
    _build_dataset(o, g_el_ns + g_el_nl, te)
    dom_obj[idx] = o
    dom_n = idx + 1
    # Wire live traversal links. This recurses into _dom_register_el for each
    # neighbour, which CLOBBERS the g_el_* scan globals; save + restore them so
    # callers that read g_el_lt (e.g. _lookup_or_register, _radio_enforce_group)
    # right after this returns still see THIS element.
    s_lt: uint64 = g_el_lt
    s_ns: uint64 = g_el_ns
    s_nl: uint64 = g_el_nl
    s_cs: uint64 = g_el_cs
    s_ce: uint64 = g_el_ce
    _dom_wire_tree(idx)
    g_el_lt = s_lt
    g_el_ns = s_ns
    g_el_nl = s_nl
    g_el_cs = s_cs
    g_el_ce = s_ce
    return o


# Copy a JS-argument string into `buf`, capped at cap-1, NUL-terminated.
# Returns its length.
def _arg_bytes(argi: int32, buf: Ptr[uint8], cap: int32) -> int32:
    p: Ptr[uint8] = js_str_ptr(js_arg(argi))
    n: int32 = _cstr_len(p)
    if n > cap - 1:
        n = cap - 1
    i: int32 = 0
    while i < n:
        buf[i] = p[i]
        i = i + 1
    buf[n] = 0
    return n


# ====================================================================
# <canvas> 2D context — the JS-facing side. Style state (fillStyle/strokeStyle/
# lineWidth/font/globalAlpha) lives as plain properties on the context object;
# each draw reads them back here and forwards resolved ints/colours to
# lib/htmlcanvas, which owns the pixels. See that module's header for scope.
# ====================================================================
cv_txt: Array[512, uint8]                 # scratch for a fillText/measureText arg
g_cv_px:   int32 = 10
g_cv_bold: int32 = 0


# Integer value of numeric JS argument `argi` (canvas coords are px).
def _cvn(argi: int32) -> int32:
    return cast[int32](js_to_number(js_arg(argi)))


# Case-insensitive equality of buf[0..n) with NUL-terminated `lit`.
def _ci_word_eq(p: Ptr[uint8], n: int32, lit: Ptr[uint8]) -> int32:
    i: int32 = 0
    while lit[i] != 0:
        if i >= n:
            return 0
        if _lower(p[i]) != lit[i]:
            return 0
        i = i + 1
    if i != n:
        return 0
    return 1


# Does buf[0..n) contain NUL-terminated lowercase `lit` (case-insensitive)?
def _buf_contains(p: Ptr[uint8], n: int32, lit: Ptr[uint8]) -> int32:
    ll: int32 = 0
    while lit[ll] != 0:
        ll = ll + 1
    if ll == 0:
        return 0
    i: int32 = 0
    while i + ll <= n:
        k: int32 = 0
        while k < ll and _lower(p[i + k]) == lit[k]:
            k = k + 1
        if k == ll:
            return 1
        i = i + 1
    return 0


# Parse a canvas colour string (#rgb / #rrggbb / a common CSS name) to packed
# 0xRRGGBB; defaults to black. A scoped named subset — the rest fall back to
# black, matching a browser's "unknown keyword => unchanged" only loosely, which
# is fine for the delivered fill/stroke set.
def _canvas_color(p: Ptr[uint8], n: int32) -> int32:
    if n <= 0:
        return 0
    if p[0] == 35:                                    # '#'
        if n >= 7:
            r: int32 = _hexval(p[1]) * 16 + _hexval(p[2])
            g: int32 = _hexval(p[3]) * 16 + _hexval(p[4])
            b: int32 = _hexval(p[5]) * 16 + _hexval(p[6])
            if r >= 0 and g >= 0 and b >= 0:
                return (r << 16) | (g << 8) | b
        if n >= 4:
            r3: int32 = _hexval(p[1])
            g3: int32 = _hexval(p[2])
            b3: int32 = _hexval(p[3])
            if r3 >= 0 and g3 >= 0 and b3 >= 0:
                return ((r3 * 17) << 16) | ((g3 * 17) << 8) | (b3 * 17)
        return 0
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("white")) != 0:
        return 0xffffff
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("red")) != 0:
        return 0xff0000
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("green")) != 0:
        return 0x008000
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("lime")) != 0:
        return 0x00ff00
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("blue")) != 0:
        return 0x0000ff
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("navy")) != 0:
        return 0x000080
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("teal")) != 0:
        return 0x008080
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("aqua")) != 0:
        return 0x00ffff
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("cyan")) != 0:
        return 0x00ffff
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("olive")) != 0:
        return 0x808000
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("yellow")) != 0:
        return 0xffff00
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("orange")) != 0:
        return 0xffa500
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("gold")) != 0:
        return 0xffd700
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("purple")) != 0:
        return 0x800080
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("magenta")) != 0:
        return 0xff00ff
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("fuchsia")) != 0:
        return 0xff00ff
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("maroon")) != 0:
        return 0x800000
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("silver")) != 0:
        return 0xc0c0c0
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("gray")) != 0:
        return 0x808080
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("grey")) != 0:
        return 0x808080
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("pink")) != 0:
        return 0xffc0cb
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("brown")) != 0:
        return 0xa52a2a
    return 0                                           # black default


# Resolve a colour-string property (fillStyle/strokeStyle) on `ctx`.
def _canvas_style_rgb(ctx: int32, name: Ptr[uint8], nlen: uint64) -> int32:
    v: int32 = js_get_prop(ctx, name, nlen)
    p: Ptr[uint8] = js_str_ptr(v)
    n: int32 = _cstr_len(p)
    return _canvas_color(p, n)


# ctx.lineWidth as a >=1 integer.
def _canvas_line_width(ctx: int32) -> int32:
    v: int32 = js_get_prop(ctx, cast[Ptr[uint8]]("lineWidth"), 9)
    lw: int32 = cast[int32](js_to_number(v))
    if lw < 1:
        lw = 1
    return lw


# ctx.globalAlpha (0..1) as 0..255 coverage. Only the translucent case touches
# a float multiply; opaque/clear are integer fast-paths.
def _canvas_alpha(ctx: int32) -> int32:
    v: int32 = js_get_prop(ctx, cast[Ptr[uint8]]("globalAlpha"), 11)
    af: float64 = js_to_number(v)
    if af >= cast[float64](1):
        return 255
    if af <= cast[float64](0):
        return 0
    return cast[int32](af * cast[float64](255))


# Read ctx.font into g_cv_px / g_cv_bold (default 10px, non-bold).
def _canvas_read_font(ctx: int32):
    g_cv_px = 10
    g_cv_bold = 0
    v: int32 = js_get_prop(ctx, cast[Ptr[uint8]]("font"), 4)
    p: Ptr[uint8] = js_str_ptr(v)
    n: int32 = _cstr_len(p)
    if n <= 0:
        return
    if _buf_contains(p, n, cast[Ptr[uint8]]("bold")) != 0:
        g_cv_bold = 1
    num: int32 = 0
    seen: int32 = 0
    i: int32 = 0
    while i < n:
        c: uint8 = p[i]
        if c >= 48 and c <= 57:
            num = num * 10 + cast[int32](c - 48)
            seen = 1
        elif seen != 0:
            i = n
        i = i + 1
    if seen != 0 and num > 0:
        g_cv_px = num


# Map a JS radian angle argument to an integer step index (0..64 per turn).
def _canvas_ang_idx(argi: int32) -> int32:
    a: float64 = js_to_number(js_arg(argi))
    return cast[int32](a * cast[float64](10185916) / cast[float64](1000000) + \
                       cast[float64](5) / cast[float64](10))


# Does dom element `el`'s tag name equal NUL-terminated lowercase `lit`?
def _dom_tag_is(el: int32, lit: Ptr[uint8]) -> int32:
    nl: int32 = 0
    while lit[nl] != 0:
        nl = nl + 1
    if dom_nl[el] != nl:
        return 0
    k: int32 = 0
    while k < nl:
        if _lower(src_ptr[cast[uint64](dom_ns[el]) + cast[uint64](k)]) != lit[k]:
            return 0
        k = k + 1
    return 1


# Build a fresh 2D-context JS object bound to htmlcanvas index `ci`: default
# style properties + the native drawing methods.
def _canvas_make_ctx() -> int32:
    ctx: int32 = js_new_object_v()
    js_set_prop(ctx, cast[Ptr[uint8]]("fillStyle"), 9, \
                js_new_string(cast[Ptr[uint8]]("#000000"), 7))
    js_set_prop(ctx, cast[Ptr[uint8]]("strokeStyle"), 11, \
                js_new_string(cast[Ptr[uint8]]("#000000"), 7))
    js_set_prop(ctx, cast[Ptr[uint8]]("lineWidth"), 9, js_number(cast[float64](1)))
    js_set_prop(ctx, cast[Ptr[uint8]]("font"), 4, \
                js_new_string(cast[Ptr[uint8]]("10px sans-serif"), 15))
    js_set_prop(ctx, cast[Ptr[uint8]]("globalAlpha"), 11, \
                js_number(cast[float64](1)))
    js_set_prop(ctx, cast[Ptr[uint8]]("fillRect"), 8, \
                js_new_native_fn(js_hbase + NID_CV_FILLRECT))
    js_set_prop(ctx, cast[Ptr[uint8]]("clearRect"), 9, \
                js_new_native_fn(js_hbase + NID_CV_CLEARRECT))
    js_set_prop(ctx, cast[Ptr[uint8]]("strokeRect"), 10, \
                js_new_native_fn(js_hbase + NID_CV_STROKERECT))
    js_set_prop(ctx, cast[Ptr[uint8]]("beginPath"), 9, \
                js_new_native_fn(js_hbase + NID_CV_BEGIN))
    js_set_prop(ctx, cast[Ptr[uint8]]("moveTo"), 6, \
                js_new_native_fn(js_hbase + NID_CV_MOVETO))
    js_set_prop(ctx, cast[Ptr[uint8]]("lineTo"), 6, \
                js_new_native_fn(js_hbase + NID_CV_LINETO))
    js_set_prop(ctx, cast[Ptr[uint8]]("closePath"), 9, \
                js_new_native_fn(js_hbase + NID_CV_CLOSE))
    js_set_prop(ctx, cast[Ptr[uint8]]("stroke"), 6, \
                js_new_native_fn(js_hbase + NID_CV_STROKE))
    js_set_prop(ctx, cast[Ptr[uint8]]("fill"), 4, \
                js_new_native_fn(js_hbase + NID_CV_FILL))
    js_set_prop(ctx, cast[Ptr[uint8]]("arc"), 3, \
                js_new_native_fn(js_hbase + NID_CV_ARC))
    js_set_prop(ctx, cast[Ptr[uint8]]("fillText"), 8, \
                js_new_native_fn(js_hbase + NID_CV_FILLTEXT))
    js_set_prop(ctx, cast[Ptr[uint8]]("strokeText"), 10, \
                js_new_native_fn(js_hbase + NID_CV_STROKETEXT))
    js_set_prop(ctx, cast[Ptr[uint8]]("measureText"), 11, \
                js_new_native_fn(js_hbase + NID_CV_MEASURE))
    return ctx


# Find-or-create the canvas registration + 2D context for source element `el`.
# Returns the canv_* registry index, or -1.
def _canvas_get_for_el(el: int32) -> int32:
    i: int32 = 0
    while i < canv_n:
        if canv_el[i] == el:
            return i
        i = i + 1
    if canv_n >= CANV_MAX:
        return -1
    te: uint64 = cast[uint64](dom_ns[el])
    while te < src_len and src_ptr[te] != 62:
        te = te + 1
    aw: int32 = _attr_int(cast[uint64](dom_ns[el]), te, \
                          cast[Ptr[uint8]]("width"), 300)
    ah: int32 = _attr_int(cast[uint64](dom_ns[el]), te, \
                          cast[Ptr[uint8]]("height"), 150)
    if aw < 1:
        aw = 300
    if ah < 1:
        ah = 150
    if aw > 1000:
        aw = 1000
    if ah > 1000:
        ah = 1000
    slot: int32 = htmlimg_add_blank(cast[Ptr[uint8]]("canvas"), 6, aw, ah)
    if slot < 0:
        return -1
    cidx: int32 = htmlcanvas_new(slot, aw, ah)
    if cidx < 0:
        return -1
    ctx: int32 = _canvas_make_ctx()
    k: int32 = canv_n
    canv_ci[k] = cidx
    canv_slot[k] = slot
    canv_w[k] = aw
    canv_h[k] = ah
    canv_anchor[k] = dom_anchor[el]
    canv_idoff[k] = dom_id_off[el]
    canv_idlen[k] = dom_id_len[el]
    canv_ctxobj[k] = ctx
    canv_el[k] = el
    canv_n = k + 1
    return k


# Map a 2D-context JS object back to its lib/htmlcanvas index, or -1.
def _canvas_ci_of_ctx(ctx: int32) -> int32:
    i: int32 = 0
    while i < canv_n:
        if canv_ctxobj[i] == ctx:
            return canv_ci[i]
        i = i + 1
    return -1


# LAYOUT-side lookup: find the canvas registry entry for a <canvas> tag in body
# [ne,te) opened at source '<' offset `anchor`, matching by element id first
# (survives a JS source rewrite) then by anchor. Returns the index, or -1.
def _canvas_layout_find(anchor: int32, ne: uint64, te: uint64) -> int32:
    if _find_attr(ne, te, cast[Ptr[uint8]]("id")) != 0 and \
       g_attr_end > g_attr_start:
        ln: int32 = cast[int32](g_attr_end - g_attr_start)
        i: int32 = 0
        while i < canv_n:
            if canv_idlen[i] == ln:
                mtch: int32 = 1
                k: int32 = 0
                while k < ln:
                    if src_ptr[g_attr_start + cast[uint64](k)] != \
                       dom_idbuf[canv_idoff[i] + k]:
                        mtch = 0
                        k = ln
                    k = k + 1
                if mtch != 0:
                    return i
            i = i + 1
    j: int32 = 0
    while j < canv_n:
        if canv_anchor[j] == anchor:
            return j
        j = j + 1
    return -1


# LAYOUT-side <canvas> handler: reserve the pixel box that blits the drawn (or
# blank, if the script never drew) backing buffer, then skip fallback content.
# `ltp1` is the tag-name start (source '<' = ltp1-1).
def _handle_canvas(ltp1: uint64, np: uint64, nlen: uint64, ne: uint64,
                   te: uint64):
    _word_flush()
    anchor: int32 = cast[int32](ltp1) - 1
    ci_reg: int32 = _canvas_layout_find(anchor, ne, te)
    if ci_reg < 0:
        # A <canvas> the script never got a context for: reserve a blank box.
        aw: int32 = _attr_int(ne, te, cast[Ptr[uint8]]("width"), 300)
        ah: int32 = _attr_int(ne, te, cast[Ptr[uint8]]("height"), 150)
        if aw < 1:
            aw = 300
        if ah < 1:
            ah = 150
        if aw > 1000:
            aw = 1000
        if ah > 1000:
            ah = 1000
        if canv_n < CANV_MAX:
            slot0: int32 = htmlimg_add_blank(cast[Ptr[uint8]]("canvas"), 6,
                                             aw, ah)
            if slot0 >= 0:
                cidx0: int32 = htmlcanvas_new(slot0, aw, ah)
                if cidx0 >= 0:
                    k0: int32 = canv_n
                    canv_ci[k0] = cidx0
                    canv_slot[k0] = slot0
                    canv_w[k0] = aw
                    canv_h[k0] = ah
                    canv_anchor[k0] = anchor
                    canv_idoff[k0] = 0
                    canv_idlen[k0] = 0
                    canv_ctxobj[k0] = -1
                    canv_el[k0] = -1
                    canv_n = k0 + 1
                    ci_reg = k0
    if ci_reg < 0:
        _enter_skip(np, nlen)
        return
    slot: int32 = canv_slot[ci_reg]
    bw2: int32 = canv_w[ci_reg]
    bh2: int32 = canv_h[ci_reg]
    if bw2 > bw:
        if bw2 > 0:
            bh2 = bh2 * bw / bw2
        bw2 = bw
    if bh2 < 1:
        bh2 = 1
    # bracketed alt fallback "[canvas]" for the text-only paths.
    img_alt_buf[0] = 91                                # '['
    img_alt_buf[1] = 99                                # 'c'
    img_alt_buf[2] = 97                                # 'a'
    img_alt_buf[3] = 110                               # 'n'
    img_alt_buf[4] = 118                               # 'v'
    img_alt_buf[5] = 97                                # 'a'
    img_alt_buf[6] = 115                               # 's'
    img_alt_buf[7] = 93                                # ']'
    img_alt_len = 8
    _emit_img_seg(slot, bw2, bh2)
    _enter_skip(np, nlen)


# ---------------------------------------------------------------------------
# innerHTML SETTER — parse a fragment string into REAL created-node children.
# Assigning `el.innerHTML = "<b>hi</b> world"` must expose the fragment as real
# DOM nodes so a SUBSEQUENT `el.childNodes` / tree walk in the SAME script sees
# the new subtree (jsengine has no accessor properties, so we hook member_set).
# We build cre_* element/text node objects, mirroring appendChild's node shape,
# and replace the target's .children/.childNodes arrays. RENDER already reflects
# an innerHTML assignment via the raw-override path in the readback pass, so we
# deliberately do NOT add ap/cc render edges here (that would double-emit).
# querySelector still scans source text (a pre-existing limit shared with
# appendChild's created nodes) and is unaffected.
# ---------------------------------------------------------------------------

# A fragment element that never has children in HTML (no end tag). Kept short —
# the common voids that appear inside real innerHTML strings.
def _frag_is_void(tp: Ptr[uint8], tl: int32) -> int32:
    if _bytes_eq(tp, tl, cast[Ptr[uint8]]("br"), 2) != 0:
        return 1
    if _bytes_eq(tp, tl, cast[Ptr[uint8]]("img"), 3) != 0:
        return 1
    if _bytes_eq(tp, tl, cast[Ptr[uint8]]("hr"), 2) != 0:
        return 1
    if _bytes_eq(tp, tl, cast[Ptr[uint8]]("input"), 5) != 0:
        return 1
    if _bytes_eq(tp, tl, cast[Ptr[uint8]]("meta"), 4) != 0:
        return 1
    if _bytes_eq(tp, tl, cast[Ptr[uint8]]("link"), 4) != 0:
        return 1
    return 0


# Is byte run sp[a..b) entirely ASCII whitespace?
def _frag_ws_only(sp: Ptr[uint8], a: int32, b: int32) -> int32:
    i: int32 = a
    while i < b:
        c: uint8 = sp[i]
        if c != 32 and c != 9 and c != 10 and c != 13:
            return 0
        i = i + 1
    return 1


# Allocate a created ELEMENT node with (lowercased) tag bytes tp[0..tl); returns
# its cre id, or -1 if the pool is full. Mirrors NID_CREATE's object shape so
# the emitter and DOM-walk APIs treat it exactly like a createElement node.
def _cre_make_element(tp: Ptr[uint8], tl: int32) -> int32:
    if cre_n >= CRE_MAX:
        return -1
    cid: int32 = cre_n
    cre_tag_off[cid] = dom_idbuf_len
    k: int32 = 0
    while k < tl and dom_idbuf_len < DOM_ID_CAP:
        dom_idbuf[dom_idbuf_len] = _lower(tp[k])
        dom_idbuf_len = dom_idbuf_len + 1
        k = k + 1
    cre_tag_len[cid] = tl
    cre_is_text[cid] = 0
    cre_gone[cid] = 0
    co: int32 = js_new_object_v()
    js_set_prop(co, cast[Ptr[uint8]]("textContent"), 11, js_new_string(&dom_txtbuf[0], 0))
    js_set_prop(co, cast[Ptr[uint8]]("id"), 2, js_new_string(&dom_txtbuf[0], 0))
    js_set_prop(co, cast[Ptr[uint8]]("className"), 9, js_new_string(&dom_txtbuf[0], 0))
    js_set_prop(co, cast[Ptr[uint8]]("tagName"), 7, \
                _tagname_upper(&dom_idbuf[cre_tag_off[cid]], tl))
    js_set_prop(co, cast[Ptr[uint8]]("nodeType"), 8, js_number(cast[float64](1)))
    js_set_prop(co, cast[Ptr[uint8]]("nodeName"), 8, \
                _tagname_upper(&dom_idbuf[cre_tag_off[cid]], tl))
    js_set_prop(co, cast[Ptr[uint8]]("nodeValue"), 9, js_null())
    js_set_prop(co, cast[Ptr[uint8]]("style"), 5, _new_style_obj())
    _attach_el_methods(co)
    cre_obj[cid] = co
    cre_n = cid + 1
    return cid


# Allocate a created TEXT node carrying string value `sval`. Returns its node
# object (js value), ready to push into a childNodes array.
def _cre_make_text(sval: int32) -> int32:
    if cre_n >= CRE_MAX:
        return -1
    tcid: int32 = cre_n
    cre_tag_off[tcid] = dom_idbuf_len
    cre_tag_len[tcid] = 0
    cre_is_text[tcid] = 1
    cre_gone[tcid] = 0
    tco: int32 = js_new_object_v()
    js_set_prop(tco, cast[Ptr[uint8]]("textContent"), 11, sval)
    js_set_prop(tco, cast[Ptr[uint8]]("nodeType"), 8, js_number(cast[float64](3)))
    js_set_prop(tco, cast[Ptr[uint8]]("nodeName"), 8, \
                js_new_string(cast[Ptr[uint8]]("#text"), 5))
    js_set_prop(tco, cast[Ptr[uint8]]("nodeValue"), 9, sval)
    cre_obj[tcid] = tco
    cre_n = tcid + 1
    return tco


# Parse the attributes region sp[a..b) of a fragment start tag onto node obj
# `co`: class -> className, id -> id, everything else name->value verbatim.
def _frag_set_attrs(co: int32, sp: Ptr[uint8], a: int32, b: int32):
    i: int32 = a
    while i < b:
        while i < b and _frag_ws_only(sp, i, i + 1) != 0:
            i = i + 1
        if i >= b or sp[i] == 47:                        # '/' (self-close)
            return
        ns: int32 = i
        while i < b and _is_name_ch(sp[i]) != 0:
            i = i + 1
        ne: int32 = i
        if ne == ns:
            i = i + 1
            continue
        while i < b and _frag_ws_only(sp, i, i + 1) != 0:
            i = i + 1
        vs: int32 = ns
        vlen: int32 = 0
        if i < b and sp[i] == 61:                        # '='
            i = i + 1
            while i < b and _frag_ws_only(sp, i, i + 1) != 0:
                i = i + 1
            if i < b and (sp[i] == 34 or sp[i] == 39):   # quoted
                q: uint8 = sp[i]
                i = i + 1
                vs = i
                while i < b and sp[i] != q:
                    i = i + 1
                vlen = i - vs
                if i < b:
                    i = i + 1
            else:
                vs = i
                while i < b and _frag_ws_only(sp, i, i + 1) == 0:
                    i = i + 1
                vlen = i - vs
        av: int32 = js_new_string(&sp[vs], cast[uint64](vlen))
        if _bytes_eq(&sp[ns], ne - ns, cast[Ptr[uint8]]("class"), 5) != 0:
            js_set_prop(co, cast[Ptr[uint8]]("className"), 9, av)
        elif _bytes_eq(&sp[ns], ne - ns, cast[Ptr[uint8]]("id"), 2) != 0:
            js_set_prop(co, cast[Ptr[uint8]]("id"), 2, av)
        else:
            js_set_prop(co, &sp[ns], cast[uint64](ne - ns), av)


# Close the top open element on the fragment stack: finalize its textContent
# (the shared linear cursor spans its descendants too) and its child arrays.
def _frag_close_top(depth: int32):
    cid: int32 = frag_st_cid[depth]
    if cid < 0:
        return
    co: int32 = cre_obj[cid]
    ts: int32 = frag_st_txt[depth]
    js_set_prop(co, cast[Ptr[uint8]]("textContent"), 11, \
                js_new_string(&frag_txt[ts], cast[uint64](frag_txt_w - ts)))
    arr: int32 = frag_st_arr[depth]
    js_set_prop(co, cast[Ptr[uint8]]("children"), 8, arr)
    js_set_prop(co, cast[Ptr[uint8]]("childNodes"), 10, arr)


# Parse HTML fragment sp[0..sl) into created nodes; append the TOP-LEVEL child
# objects to js array `root`. The caller reads root's length for first/last.
def _parse_fragment(sp: Ptr[uint8], sl: int32, root: int32):
    frag_txt_w = 0
    depth: int32 = 0
    frag_st_cid[0] = -1
    frag_st_arr[0] = root
    frag_st_txt[0] = 0
    i: int32 = 0
    while i < sl:
        if sp[i] == 60:                                  # '<'
            if i + 1 < sl and sp[i + 1] == 47:           # '</' close
                j: int32 = i + 2
                while j < sl and sp[j] != 62:
                    j = j + 1
                if depth > 0:
                    _frag_close_top(depth)
                    depth = depth - 1
                if j < sl:
                    j = j + 1
                i = j
                continue
            # start tag: <name attrs...> or <name .../>
            j2: int32 = i + 1
            ns: int32 = j2
            while j2 < sl and _is_name_ch(sp[j2]) != 0:
                j2 = j2 + 1
            nlen: int32 = j2 - ns
            # scan to the matching '>'
            te: int32 = j2
            while te < sl and sp[te] != 62:
                te = te + 1
            selfclose: int32 = 0
            if te > ns and sp[te - 1] == 47:             # '<x .../>'
                selfclose = 1
            if nlen <= 0:
                i = te + 1
                continue
            cid: int32 = _cre_make_element(&sp[ns], nlen)
            if cid < 0:
                i = te + 1
                continue
            co: int32 = cre_obj[cid]
            attr_end: int32 = te
            if selfclose != 0:
                attr_end = te - 1
            _frag_set_attrs(co, sp, j2, attr_end)
            js_array_push(frag_st_arr[depth], co)
            js_set_prop(co, cast[Ptr[uint8]]("parentNode"), 10, js_null())
            if _frag_is_void(&sp[ns], nlen) == 0 and selfclose == 0:
                if depth + 1 < FRAG_STACK_MAX:
                    depth = depth + 1
                    frag_st_cid[depth] = cid
                    frag_st_arr[depth] = js_new_array_v()
                    frag_st_txt[depth] = frag_txt_w
            else:
                # void/self-closed: empty child arrays for API symmetry
                em: int32 = js_new_array_v()
                js_set_prop(co, cast[Ptr[uint8]]("children"), 8, em)
                js_set_prop(co, cast[Ptr[uint8]]("childNodes"), 10, em)
            i = te + 1
            continue
        # text run up to the next '<'
        ts: int32 = i
        while i < sl and sp[i] != 60:
            i = i + 1
        if _frag_ws_only(sp, ts, i) == 0:
            # copy bytes into the shared textContent buffer (for ancestors)
            k: int32 = ts
            tstart: int32 = frag_txt_w
            while k < i and frag_txt_w < FRAG_TXT_CAP:
                frag_txt[frag_txt_w] = sp[k]
                frag_txt_w = frag_txt_w + 1
                k = k + 1
            tv: int32 = js_new_string(&frag_txt[tstart], cast[uint64](frag_txt_w - tstart))
            tco: int32 = _cre_make_text(tv)
            js_array_push(frag_st_arr[depth], tco)
    # close any elements left open by malformed markup
    while depth > 0:
        _frag_close_top(depth)
        depth = depth - 1


# member_set hook (registered via js_set_member_hook): fires after every
# `obj.prop = val`. We act only on `el.innerHTML = <string>` for a registered
# source element or created node, parsing the fragment into real child nodes.
def _js_member_set_hook(dummy: int32) -> int32:
    kv: int32 = js_mset_key()
    kp: Ptr[uint8] = js_str_ptr(kv)
    kn: int32 = _cstr_len(kp)
    # `el.style.cssText = "color:red;display:none"` — `this` is the style object;
    # parse the string into its routed camelCase props so the cascade sees it.
    if _bytes_eq(kp, kn, cast[Ptr[uint8]]("cssText"), 7) != 0:
        csttv: int32 = js_mset_this()
        cvv: int32 = js_mset_val()
        cvp: Ptr[uint8] = js_str_ptr(cvv)
        cvn: int32 = _cstr_len(cvp)
        if _is_undef_str(cvp, cvn) == 0:
            _style_apply_csstext(csttv, cvp, cvn)
        return 0
    if _bytes_eq(kp, kn, cast[Ptr[uint8]]("innerHTML"), 9) == 0:
        return 0
    thisv: int32 = js_mset_this()
    if _find_el_by_obj(thisv) < 0 and _find_cre_by_obj(thisv) < 0:
        return 0                                          # not a DOM node yet
    valv: int32 = js_mset_val()
    vp: Ptr[uint8] = js_str_ptr(valv)
    vn: int32 = _cstr_len(vp)
    if _is_undef_str(vp, vn) != 0:
        return 0
    root: int32 = js_new_array_v()
    _parse_fragment(vp, vn, root)
    js_set_prop(thisv, cast[Ptr[uint8]]("children"), 8, root)
    js_set_prop(thisv, cast[Ptr[uint8]]("childNodes"), 10, root)
    # keep .textContent consistent with the new subtree (innerHTML raw-override
    # still wins in render, so this only affects a subsequent JS read).
    js_set_prop(thisv, cast[Ptr[uint8]]("textContent"), 11, \
                js_new_string(&frag_txt[0], cast[uint64](frag_txt_w)))
    fc: int32 = js_null()
    lc: int32 = js_null()
    if js_array_len(root) > 0:
        fc = js_array_get(root, 0)
        lc = js_array_get(root, js_array_len(root) - 1)
    js_set_prop(thisv, cast[Ptr[uint8]]("firstChild"), 10, fc)
    js_set_prop(thisv, cast[Ptr[uint8]]("firstElementChild"), 17, fc)
    js_set_prop(thisv, cast[Ptr[uint8]]("lastChild"), 9, lc)
    js_set_prop(thisv, cast[Ptr[uint8]]("lastElementChild"), 16, lc)
    return 0


# The host-object dispatcher jsengine calls for native ids >= js_host_base().
def _js_host_dispatch(id: int32) -> int32:
    rel: int32 = id - js_hbase
    if rel == NID_GETBYID:
        if js_arg_count() < 1:
            return js_null()
        n: int32 = _arg_bytes(0, &dom_idtmp[0], 256)
        if _dom_find_by_id(&dom_idtmp[0], n) != 0:
            return _dom_register_el()
        cidobj: int32 = _cre_find_by_id(&dom_idtmp[0], n)   # created-node fallback
        if cidobj >= 0:
            return cidobj
        return js_null()
    if rel == NID_QUERY:
        if js_arg_count() < 1:
            return js_null()
        n2: int32 = _arg_bytes(0, &dom_idtmp[0], 256)
        _set_query_scope()
        if _dom_find_selector_scoped(&dom_idtmp[0], n2, g_qlo, g_qhi) != 0:
            return _dom_register_el()
        _sel_parse(&dom_idtmp[0], n2)                       # created-node fallback
        cq: int32 = _cre_find_first()
        if cq >= 0:
            return cq
        return js_null()
    if rel == NID_QUERYALL:
        qarr: int32 = js_new_array_v()
        if js_arg_count() >= 1:
            qn: int32 = _arg_bytes(0, &dom_idtmp[0], 256)
            _set_query_scope()
            _dom_collect_selector(&dom_idtmp[0], qn, g_qlo, g_qhi, qarr)
            _sel_parse(&dom_idtmp[0], qn)                   # + created nodes
            _cre_collect(qarr)
        return qarr
    if rel == NID_GETBYCLASS:
        carr: int32 = js_new_array_v()
        if js_arg_count() >= 1:
            cnm: int32 = _arg_bytes(0, &dom_idtmp[1], 255)
            dom_idtmp[0] = 46                              # '.' + class name
            _set_query_scope()
            _dom_collect_selector(&dom_idtmp[0], cnm + 1, g_qlo, g_qhi, carr)
            _sel_parse(&dom_idtmp[0], cnm + 1)             # + created nodes
            _cre_collect(carr)
        return carr
    if rel == NID_GETBYTAG:
        tarr: int32 = js_new_array_v()
        if js_arg_count() >= 1:
            tnm: int32 = _arg_bytes(0, &dom_idtmp[0], 256)
            _set_query_scope()
            _dom_collect_selector(&dom_idtmp[0], tnm, g_qlo, g_qhi, tarr)
            _sel_parse(&dom_idtmp[0], tnm)                 # + created nodes
            _cre_collect(tarr)
        return tarr
    if rel == NID_HASATTR:
        if js_arg_count() >= 1:
            hn: Array[64, uint8]
            han: int32 = _arg_bytes(0, &hn[0], 64)
            hel: int32 = _find_el_by_obj(js_this())
            if hel >= 0:
                hte: uint64 = cast[uint64](dom_cstart[hel]) - 1
                if _find_attr(cast[uint64](dom_ns[hel]), hte, &hn[0]) != 0:
                    return js_bool(1)
                return js_bool(0)
            hcid: int32 = _find_cre_by_obj(js_this())
            if hcid >= 0:
                hv: int32 = js_get_prop(cre_obj[hcid], &hn[0], cast[uint64](han))
                hvp: Ptr[uint8] = js_str_ptr(hv)
                hvn: int32 = _cstr_len(hvp)
                if hvn > 0 and _is_undef_str(hvp, hvn) == 0:
                    return js_bool(1)
                return js_bool(0)
        return js_bool(0)
    if rel == NID_REMATTR:
        if js_arg_count() >= 1:
            rn: Array[64, uint8]
            ran: int32 = _arg_bytes(0, &rn[0], 64)
            rtgt: int32 = -1
            rel_i: int32 = _find_el_by_obj(js_this())
            if rel_i >= 0:
                rtgt = dom_obj[rel_i]
            else:
                rci: int32 = _find_cre_by_obj(js_this())
                if rci >= 0:
                    rtgt = cre_obj[rci]
            if rtgt >= 0:
                # Reflect the removal on the JS object so a later read + the
                # readback see it cleared. `class` clears className (which the
                # rewrite bakes back into the cascade).
                if _bytes_eq(&rn[0], ran, cast[Ptr[uint8]]("class"), 5) != 0:
                    js_set_prop(rtgt, cast[Ptr[uint8]]("className"), 9, \
                                js_new_string(&dom_txtbuf[0], 0))
                else:
                    js_set_prop(rtgt, &rn[0], cast[uint64](ran), \
                                js_new_string(&dom_txtbuf[0], 0))
        return js_undefined()
    if rel == NID_REMEVT:
        # element.removeEventListener(type, fn) — mark the matching registry
        # entry dead (round 8 multi-listener model); also clear a matching
        # attribute slot for back-compat. A no-op otherwise.
        if js_arg_count() >= 2:
            rvn: int32 = _arg_bytes(0, &dom_idtmp[0], 256)
            rvel: int32 = _find_el_by_obj(js_this())
            if rvel >= 0:
                rfn: int32 = js_arg(1)
                rk: int32 = -1
                if _bytes_eq(&dom_idtmp[0], rvn, cast[Ptr[uint8]]("click"), 5) != 0:
                    rk = 0
                    if dom_onclick_fn[rvel] == rfn:
                        dom_onclick_fn[rvel] = -1
                elif _bytes_eq(&dom_idtmp[0], rvn, cast[Ptr[uint8]]("input"), 5) != 0:
                    rk = 1
                    if dom_oninput_fn[rvel] == rfn:
                        dom_oninput_fn[rvel] = -1
                elif _bytes_eq(&dom_idtmp[0], rvn, cast[Ptr[uint8]]("change"), 6) != 0:
                    rk = 2
                    if dom_onchange_fn[rvel] == rfn:
                        dom_onchange_fn[rvel] = -1
                elif _bytes_eq(&dom_idtmp[0], rvn, cast[Ptr[uint8]]("submit"), 6) != 0:
                    rk = 3
                    if dom_onsubmit_fn[rvel] == rfn:
                        dom_onsubmit_fn[rvel] = -1
                ri: int32 = 0
                while ri < evl_n:
                    if evl_dead[ri] == 0 and evl_el[ri] == rvel and \
                       evl_kind[ri] == rk and evl_fn[ri] == rfn:
                        evl_dead[ri] = 1
                    ri = ri + 1
        return js_undefined()
    if rel == NID_DISPATCH:
        # element.dispatchEvent(ev) — fire the matching handler synchronously,
        # returning !defaultPrevented. Reads ev.type to pick the handler.
        dspel: int32 = _find_el_by_obj(js_this())
        if dspel >= 0 and js_arg_count() >= 1:
            evo: int32 = js_arg(0)
            tp: int32 = js_get_prop(evo, cast[Ptr[uint8]]("type"), 4)
            tpn: int32 = 0
            tpp: Ptr[uint8] = js_str_ptr(tp)
            tpn = _cstr_len(tpp)
            dk: int32 = -1
            if _bytes_eq(tpp, tpn, cast[Ptr[uint8]]("click"), 5) != 0:
                dk = 0
            elif _bytes_eq(tpp, tpn, cast[Ptr[uint8]]("input"), 5) != 0:
                dk = 1
            elif _bytes_eq(tpp, tpn, cast[Ptr[uint8]]("change"), 6) != 0:
                dk = 2
            elif _bytes_eq(tpp, tpn, cast[Ptr[uint8]]("submit"), 6) != 0:
                dk = 3
            # Enrich a plain {type:...} object into a usable Event: attach the
            # methods + props handlers read, so `el.dispatchEvent({type:'click'})`
            # works without an Event constructor. Idempotent for a reused event.
            js_set_prop(evo, cast[Ptr[uint8]]("preventDefault"), 14, \
                        js_new_native_fn(js_hbase + NID_PREVENT))
            js_set_prop(evo, cast[Ptr[uint8]]("stopPropagation"), 15, \
                        js_new_native_fn(js_hbase + NID_STOPPROP))
            js_set_prop(evo, cast[Ptr[uint8]]("defaultPrevented"), 16, js_bool(0))
            if dk >= 0:
                _dispatch_event(dspel, dk, evo)
            else:
                # unknown/custom type: fire same-element registrations only.
                g_prevent_default = 0
                g_stop_prop = 0
            if g_prevent_default != 0:
                return js_bool(0)
            return js_bool(1)
        return js_bool(1)
    if rel == NID_SUBMIT:
        # form.submit() — fire a cancelable, bubbling `submit` event on the form
        # (a preventDefault'd listener STOPS navigation — the behavior SPAs rely
        # on), then GET-serialize the form's named controls into the nav buffer.
        # `this` is normally the <form>; a control inside a form resolves to its
        # enclosing form so `input.form.submit()`-style calls also work.
        sbel: int32 = _find_el_by_obj(js_this())
        if sbel >= 0:
            if dom_kind[sbel] != 5:
                sbel = he_dom_field_form(sbel)
            if sbel >= 0:
                _do_submit(sbel)
        return js_undefined()
    if rel == NID_STOPPROP:
        # event.stopPropagation() — halt bubbling after the current element's
        # listeners finish (round 8).
        g_stop_prop = 1
        return js_undefined()
    if rel == NID_CLONE:
        # element.cloneNode(deep) -> a fresh created node mirroring tag +
        # reflected props. `deep` is honoured only for textContent/innerHTML
        # (round 1: no child-subtree duplication).
        if cre_n >= CRE_MAX:
            return js_null()
        src_obj: int32 = js_this()
        clsrc: int32 = _find_el_by_obj(src_obj)
        clcre: int32 = -1
        if clsrc < 0:
            clcre = _find_cre_by_obj(src_obj)
        if clsrc < 0 and clcre < 0:
            return js_null()
        base: int32 = src_obj
        clid: int32 = cre_n
        cre_tag_off[clid] = dom_idbuf_len
        tagv: int32 = js_get_prop(base, cast[Ptr[uint8]]("tagName"), 7)
        tagp: Ptr[uint8] = js_str_ptr(tagv)
        tagl: int32 = _cstr_len(tagp)
        kk: int32 = 0
        while kk < tagl and dom_idbuf_len < DOM_ID_CAP:
            dom_idbuf[dom_idbuf_len] = _lower(tagp[kk])
            dom_idbuf_len = dom_idbuf_len + 1
            kk = kk + 1
        cre_tag_len[clid] = tagl
        cre_is_text[clid] = 0
        cre_gone[clid] = 0
        clo: int32 = js_new_object_v()
        js_set_prop(clo, cast[Ptr[uint8]]("tagName"), 7, \
                    _tagname_upper(&dom_idbuf[cre_tag_off[clid]], tagl))
        js_set_prop(clo, cast[Ptr[uint8]]("id"), 2, \
                    js_get_prop(base, cast[Ptr[uint8]]("id"), 2))
        js_set_prop(clo, cast[Ptr[uint8]]("className"), 9, \
                    js_get_prop(base, cast[Ptr[uint8]]("className"), 9))
        js_set_prop(clo, cast[Ptr[uint8]]("textContent"), 11, \
                    js_get_prop(base, cast[Ptr[uint8]]("textContent"), 11))
        js_set_prop(clo, cast[Ptr[uint8]]("innerHTML"), 9, \
                    js_get_prop(base, cast[Ptr[uint8]]("innerHTML"), 9))
        js_set_prop(clo, cast[Ptr[uint8]]("style"), 5, _new_style_obj())
        _attach_el_methods(clo)
        cre_obj[clid] = clo
        cre_n = clid + 1
        return clo
    if rel == NID_CREATE:
        if js_arg_count() < 1 or cre_n >= CRE_MAX:
            return js_null()
        tn: int32 = _arg_bytes(0, &dom_idtmp[0], 256)
        cid: int32 = cre_n
        cre_tag_off[cid] = dom_idbuf_len
        k: int32 = 0
        while k < tn and dom_idbuf_len < DOM_ID_CAP:
            dom_idbuf[dom_idbuf_len] = _lower(dom_idtmp[k])
            dom_idbuf_len = dom_idbuf_len + 1
            k = k + 1
        cre_tag_len[cid] = tn
        cre_is_text[cid] = 0
        cre_gone[cid] = 0
        co: int32 = js_new_object_v()
        js_set_prop(co, cast[Ptr[uint8]]("textContent"), 11, \
                    js_new_string(&dom_txtbuf[0], 0))
        js_set_prop(co, cast[Ptr[uint8]]("id"), 2, js_new_string(&dom_txtbuf[0], 0))
        js_set_prop(co, cast[Ptr[uint8]]("className"), 9, \
                    js_new_string(&dom_txtbuf[0], 0))
        js_set_prop(co, cast[Ptr[uint8]]("tagName"), 7, \
                    _tagname_upper(&dom_idbuf[cre_tag_off[cid]], tn))
        js_set_prop(co, cast[Ptr[uint8]]("nodeType"), 8, js_number(cast[float64](1)))
        js_set_prop(co, cast[Ptr[uint8]]("nodeName"), 8, \
                    _tagname_upper(&dom_idbuf[cre_tag_off[cid]], tn))
        js_set_prop(co, cast[Ptr[uint8]]("nodeValue"), 9, js_null())
        js_set_prop(co, cast[Ptr[uint8]]("style"), 5, _new_style_obj())
        # created elements are first-class: appendChild / insertBefore /
        # removeChild / remove / set|getAttribute / addEventListener, so a
        # script can build + nest a whole subtree before mounting it.
        _attach_el_methods(co)
        cre_obj[cid] = co
        cre_n = cid + 1
        return co
    if rel == NID_CTEXT:
        # document.createTextNode(s) -> a text node (no tag; emits escaped text).
        if cre_n >= CRE_MAX:
            return js_null()
        tcid: int32 = cre_n
        cre_tag_off[tcid] = dom_idbuf_len
        cre_tag_len[tcid] = 0
        cre_is_text[tcid] = 1
        cre_gone[tcid] = 0
        tco: int32 = js_new_object_v()
        tval: int32 = js_new_string(&dom_txtbuf[0], 0)
        if js_arg_count() >= 1:
            tval = js_arg(0)
        js_set_prop(tco, cast[Ptr[uint8]]("textContent"), 11, tval)
        # a text node: nodeType 3 (TEXT_NODE), nodeName "#text", nodeValue == data.
        js_set_prop(tco, cast[Ptr[uint8]]("nodeType"), 8, js_number(cast[float64](3)))
        js_set_prop(tco, cast[Ptr[uint8]]("nodeName"), 8, \
                    js_new_string(cast[Ptr[uint8]]("#text"), 5))
        js_set_prop(tco, cast[Ptr[uint8]]("nodeValue"), 9, tval)
        cre_obj[tcid] = tco
        cre_n = tcid + 1
        return tco
    if rel == NID_ADDEVT:
        # element.addEventListener('click'|'input'|'change'|'submit', fn) —
        # APPEND to the multi-listener registry (round 8) so several handlers on
        # the same element+type all fire, in registration order. onclick / inline
        # handlers keep their own attribute slot and fire afterwards.
        if js_arg_count() >= 2:
            evn: int32 = _arg_bytes(0, &dom_idtmp[0], 256)
            el: int32 = _find_el_by_obj(js_this())
            if el >= 0 and js_is_callable(js_arg(1)) != 0:
                ek: int32 = -1
                if _bytes_eq(&dom_idtmp[0], evn, cast[Ptr[uint8]]("click"), 5) != 0:
                    ek = 0
                elif _bytes_eq(&dom_idtmp[0], evn, cast[Ptr[uint8]]("input"), 5) != 0:
                    ek = 1
                elif _bytes_eq(&dom_idtmp[0], evn, cast[Ptr[uint8]]("change"), 6) != 0:
                    ek = 2
                elif _bytes_eq(&dom_idtmp[0], evn, cast[Ptr[uint8]]("submit"), 6) != 0:
                    ek = 3
                if ek >= 0 and evl_n < EVL_MAX:
                    # de-dupe: the same (el,kind,fn) registered twice is one
                    # listener per the DOM spec.
                    dup: int32 = 0
                    di: int32 = 0
                    while di < evl_n:
                        if evl_dead[di] == 0 and evl_el[di] == el and \
                           evl_kind[di] == ek and evl_fn[di] == js_arg(1):
                            dup = 1
                        di = di + 1
                    if dup == 0:
                        evl_el[evl_n] = el
                        evl_kind[evl_n] = ek
                        evl_fn[evl_n] = js_arg(1)
                        evl_dead[evl_n] = 0
                        evl_n = evl_n + 1
        return js_undefined()
    if rel == NID_PREVENT:
        # event.preventDefault() — also reflect defaultPrevented on the in-flight
        # event object so a handler can read event.defaultPrevented.
        g_prevent_default = 1
        if g_cur_event >= 0:
            js_set_prop(g_cur_event, cast[Ptr[uint8]]("defaultPrevented"), 16, \
                        js_bool(1))
        return js_undefined()
    if rel == NID_CLSADD or rel == NID_CLSREM or rel == NID_CLSTOG or \
       rel == NID_CLSHAS:
        # element.classList.add/remove/toggle/contains(name)
        ce: int32 = _find_el_by_clsobj(js_this())
        if ce < 0 or js_arg_count() < 1:
            if rel == NID_CLSHAS or rel == NID_CLSTOG:
                return js_bool(0)
            return js_undefined()
        tk: Array[128, uint8]
        tn: int32 = _arg_bytes(0, &tk[0], 128)
        cur: Ptr[uint8] = _cls_read(ce)
        cn: int32 = g_cls_len
        present: int32 = _clstr_has(cur, cn, &tk[0], tn)
        if rel == NID_CLSHAS:
            return js_bool(present)
        if rel == NID_CLSADD:
            if present == 0 and tn > 0:
                nw: int32 = _cls_build_with(cur, cn, &tk[0], tn)
                _cls_write(ce, &g_cls_scr[0], nw)
            return js_undefined()
        if rel == NID_CLSREM:
            if present != 0:
                nw2: int32 = _cls_build_without(cur, cn, &tk[0], tn)
                _cls_write(ce, &g_cls_scr[0], nw2)
            return js_undefined()
        # NID_CLSTOG: flip membership, return the new state as a bool.
        if present != 0:
            nw3: int32 = _cls_build_without(cur, cn, &tk[0], tn)
            _cls_write(ce, &g_cls_scr[0], nw3)
            return js_bool(0)
        if tn > 0:
            nw4: int32 = _cls_build_with(cur, cn, &tk[0], tn)
            _cls_write(ce, &g_cls_scr[0], nw4)
        return js_bool(1)
    if rel == NID_APPEND:
        # parent.appendChild(childNode). The parent may be a SOURCE element (a
        # top-level mount) or another CREATED node (nesting: table.appendChild(tr)).
        if js_arg_count() >= 1:
            ch: int32 = _find_cre_by_obj(js_arg(0))
            if ch >= 0:
                cre_gone[ch] = 0                          # (re)attach
                par: int32 = _find_el_by_obj(js_this())
                if par >= 0:
                    _ap_add(par, ch, -1)
                    # keep the parent's live JS .children/.childNodes in sync so
                    # a subsequent read sees the appended node, and give the
                    # child a parentNode back-link (round 2 real-tree mutation).
                    pch: int32 = js_get_prop(dom_obj[par], \
                                             cast[Ptr[uint8]]("children"), 8)
                    if js_is_array(pch) != 0:
                        js_array_push(pch, js_arg(0))
                    js_set_prop(js_arg(0), cast[Ptr[uint8]]("parentNode"), 10, \
                                dom_obj[par])
                    js_set_prop(js_arg(0), cast[Ptr[uint8]]("parentElement"), 13, \
                                dom_obj[par])
                else:
                    pcid: int32 = _find_cre_by_obj(js_this())
                    if pcid >= 0:
                        _cc_add(pcid, ch, -1)
                        js_set_prop(js_arg(0), cast[Ptr[uint8]]("parentNode"), 10, \
                                    js_this())
                        js_set_prop(js_arg(0), \
                                    cast[Ptr[uint8]]("parentElement"), 13, js_this())
        return js_arg(0)
    if rel == NID_INSBEF:
        # parent.insertBefore(newNode, refNode) — refNode null => append.
        if js_arg_count() >= 1:
            nch: int32 = _find_cre_by_obj(js_arg(0))
            if nch >= 0:
                cre_gone[nch] = 0
                rch: int32 = -1
                if js_arg_count() >= 2:
                    rch = _find_cre_by_obj(js_arg(1))
                refv: int32 = js_null()
                if js_arg_count() >= 2:
                    refv = js_arg(1)
                par2: int32 = _find_el_by_obj(js_this())
                if par2 >= 0:
                    at: int32 = -1
                    if rch >= 0:
                        at = _ap_find(par2, rch)
                    _ap_add(par2, nch, at)
                    js_set_prop(js_arg(0), cast[Ptr[uint8]]("parentNode"), 10, \
                                dom_obj[par2])
                    js_set_prop(js_arg(0), \
                                cast[Ptr[uint8]]("parentElement"), 13, dom_obj[par2])
                    _dom_children_insert(js_this(), js_arg(0), refv)
                else:
                    pcid2: int32 = _find_cre_by_obj(js_this())
                    if pcid2 >= 0:
                        at2: int32 = -1
                        if rch >= 0:
                            at2 = _cc_find(pcid2, rch)
                        _cc_add(pcid2, nch, at2)
                        js_set_prop(js_arg(0), cast[Ptr[uint8]]("parentNode"), 10, \
                                    js_this())
                        js_set_prop(js_arg(0), \
                                    cast[Ptr[uint8]]("parentElement"), 13, js_this())
                        _dom_children_insert(js_this(), js_arg(0), refv)
        return js_arg(0)
    if rel == NID_REMCHILD:
        # parent.removeChild(child) — detach the child (created nodes only).
        if js_arg_count() >= 1:
            rc: int32 = _find_cre_by_obj(js_arg(0))
            if rc >= 0:
                cre_gone[rc] = 1
                # keep the parent's live JS .children/.childNodes in sync so a
                # subsequent read no longer sees the detached node.
                _dom_children_drop(js_this(), js_arg(0))
        return js_arg(0)
    if rel == NID_REPLCHILD:
        # parent.replaceChild(newNode, oldNode) — mount newNode at oldNode's
        # position, detach oldNode. Returns oldNode (spec). Both must be created
        # nodes (the same constraint appendChild/insertBefore already carry).
        if js_arg_count() >= 2:
            rnew: int32 = _find_cre_by_obj(js_arg(0))
            rold: int32 = _find_cre_by_obj(js_arg(1))
            if rnew >= 0 and rold >= 0:
                cre_gone[rnew] = 0
                rpar: int32 = _find_el_by_obj(js_this())
                if rpar >= 0:
                    rat: int32 = _ap_find(rpar, rold)
                    _ap_add(rpar, rnew, rat)
                    js_set_prop(js_arg(0), cast[Ptr[uint8]]("parentNode"), 10, \
                                dom_obj[rpar])
                    js_set_prop(js_arg(0), \
                                cast[Ptr[uint8]]("parentElement"), 13, dom_obj[rpar])
                    _dom_children_replace(js_this(), js_arg(1), js_arg(0))
                else:
                    rpc: int32 = _find_cre_by_obj(js_this())
                    if rpc >= 0:
                        rat2: int32 = _cc_find(rpc, rold)
                        _cc_add(rpc, rnew, rat2)
                        js_set_prop(js_arg(0), cast[Ptr[uint8]]("parentNode"), 10, \
                                    js_this())
                        js_set_prop(js_arg(0), \
                                    cast[Ptr[uint8]]("parentElement"), 13, js_this())
                        _dom_children_replace(js_this(), js_arg(1), js_arg(0))
                cre_gone[rold] = 1
        return js_arg(1)
    if rel == NID_REMOVE:
        # node.remove() — a created node detaches; a source element hides.
        rme: int32 = _find_cre_by_obj(js_this())
        if rme >= 0:
            cre_gone[rme] = 1
        else:
            sel: int32 = _find_el_by_obj(js_this())
            if sel >= 0:
                stvr: int32 = js_get_prop(dom_obj[sel], cast[Ptr[uint8]]("style"), 5)
                js_set_prop(stvr, cast[Ptr[uint8]]("display"), 7, \
                            js_new_string(cast[Ptr[uint8]]("none"), 4))
        return js_undefined()
    if rel == NID_GETATTR:
        if js_arg_count() >= 1:
            nm: Array[64, uint8]
            an: int32 = _arg_bytes(0, &nm[0], 64)
            # 'style' mirrors the .style store (serialized), so getAttribute and
            # .style stay consistent for both source and created nodes.
            if _bytes_eq(&nm[0], an, cast[Ptr[uint8]]("style"), 5) != 0:
                gsto: int32 = js_get_prop(js_this(), cast[Ptr[uint8]]("style"), 5)
                return _style_serialize(gsto)
            el2: int32 = _find_el_by_obj(js_this())
            if el2 >= 0:
                te2: uint64 = cast[uint64](dom_cstart[el2]) - 1
                if _find_attr(cast[uint64](dom_ns[el2]), te2, &nm[0]) != 0:
                    vlen: int32 = cast[int32](g_attr_end - g_attr_start)
                    return js_new_string(&src_ptr[g_attr_start], cast[uint64](vlen))
                return js_null()
            # created node: read the property we stashed (class -> className).
            gcid: int32 = _find_cre_by_obj(js_this())
            if gcid >= 0:
                if _bytes_eq(&nm[0], an, cast[Ptr[uint8]]("class"), 5) != 0:
                    return js_get_prop(cre_obj[gcid], \
                                       cast[Ptr[uint8]]("className"), 9)
                return js_get_prop(cre_obj[gcid], &nm[0], cast[uint64](an))
        return js_null()
    if rel == NID_SETATTR:
        if js_arg_count() >= 2:
            nm2: Array[64, uint8]
            an2: int32 = _arg_bytes(0, &nm2[0], 64)
            el3: int32 = _find_el_by_obj(js_this())
            tgt: int32 = -1
            if el3 >= 0:
                tgt = dom_obj[el3]
            else:
                scid: int32 = _find_cre_by_obj(js_this())
                if scid >= 0:
                    tgt = cre_obj[scid]
            if tgt >= 0:
                if _bytes_eq(&nm2[0], an2, cast[Ptr[uint8]]("class"), 5) != 0:
                    js_set_prop(tgt, cast[Ptr[uint8]]("className"), 9, js_arg(1))
                elif _bytes_eq(&nm2[0], an2, cast[Ptr[uint8]]("style"), 5) != 0:
                    # route into the .style store rather than clobbering the
                    # style OBJECT with a bare string (keeps .style live).
                    sto: int32 = js_get_prop(tgt, cast[Ptr[uint8]]("style"), 5)
                    sav: int32 = js_arg(1)
                    sap: Ptr[uint8] = js_str_ptr(sav)
                    san: int32 = _cstr_len(sap)
                    if _is_undef_str(sap, san) == 0:
                        _style_apply_csstext(sto, sap, san)
                else:
                    js_set_prop(tgt, &nm2[0], cast[uint64](an2), js_arg(1))
        return js_undefined()
    if rel == NID_GETCTX:
        # canvas.getContext('2d') -> a 2D context bound to a fresh backing slot.
        if js_arg_count() < 1:
            return js_null()
        cn: int32 = _arg_bytes(0, &dom_idtmp[0], 256)
        if cn != 2 or dom_idtmp[0] != 50 or _lower(dom_idtmp[1]) != 100:
            return js_null()                              # only '2d'
        cel: int32 = _find_el_by_obj(js_this())
        if cel < 0 or _dom_tag_is(cel, cast[Ptr[uint8]]("canvas")) == 0:
            return js_null()
        cregi: int32 = _canvas_get_for_el(cel)
        if cregi < 0:
            return js_null()
        return canv_ctxobj[cregi]
    if rel == NID_CV_FILLRECT:
        fci: int32 = _canvas_ci_of_ctx(js_this())
        if fci >= 0 and js_arg_count() >= 4:
            htmlcanvas_fill_rect(fci, _cvn(0), _cvn(1), _cvn(2), _cvn(3),
                                 _canvas_style_rgb(js_this(),
                                     cast[Ptr[uint8]]("fillStyle"), 9),
                                 _canvas_alpha(js_this()))
        return js_undefined()
    if rel == NID_CV_CLEARRECT:
        clci: int32 = _canvas_ci_of_ctx(js_this())
        if clci >= 0 and js_arg_count() >= 4:
            htmlcanvas_clear_rect(clci, _cvn(0), _cvn(1), _cvn(2), _cvn(3))
        return js_undefined()
    if rel == NID_CV_STROKERECT:
        sci: int32 = _canvas_ci_of_ctx(js_this())
        if sci >= 0 and js_arg_count() >= 4:
            htmlcanvas_stroke_rect(sci, _cvn(0), _cvn(1), _cvn(2), _cvn(3),
                                   _canvas_style_rgb(js_this(),
                                       cast[Ptr[uint8]]("strokeStyle"), 11),
                                   _canvas_line_width(js_this()))
        return js_undefined()
    if rel == NID_CV_BEGIN:
        bci: int32 = _canvas_ci_of_ctx(js_this())
        if bci >= 0:
            htmlcanvas_begin(bci)
        return js_undefined()
    if rel == NID_CV_MOVETO:
        mci: int32 = _canvas_ci_of_ctx(js_this())
        if mci >= 0 and js_arg_count() >= 2:
            htmlcanvas_moveto(mci, _cvn(0), _cvn(1))
        return js_undefined()
    if rel == NID_CV_LINETO:
        lci: int32 = _canvas_ci_of_ctx(js_this())
        if lci >= 0 and js_arg_count() >= 2:
            htmlcanvas_lineto(lci, _cvn(0), _cvn(1))
        return js_undefined()
    if rel == NID_CV_CLOSE:
        cpci: int32 = _canvas_ci_of_ctx(js_this())
        if cpci >= 0:
            htmlcanvas_closepath(cpci)
        return js_undefined()
    if rel == NID_CV_STROKE:
        stci: int32 = _canvas_ci_of_ctx(js_this())
        if stci >= 0:
            htmlcanvas_stroke(stci,
                              _canvas_style_rgb(js_this(),
                                  cast[Ptr[uint8]]("strokeStyle"), 11),
                              _canvas_line_width(js_this()))
        return js_undefined()
    if rel == NID_CV_FILL:
        flci: int32 = _canvas_ci_of_ctx(js_this())
        if flci >= 0:
            htmlcanvas_fill(flci,
                            _canvas_style_rgb(js_this(),
                                cast[Ptr[uint8]]("fillStyle"), 9))
        return js_undefined()
    if rel == NID_CV_ARC:
        aci: int32 = _canvas_ci_of_ctx(js_this())
        if aci >= 0 and js_arg_count() >= 5:
            htmlcanvas_arc(aci, _cvn(0), _cvn(1), _cvn(2),
                           _canvas_ang_idx(3), _canvas_ang_idx(4))
        return js_undefined()
    if rel == NID_CV_FILLTEXT or rel == NID_CV_STROKETEXT:
        tci: int32 = _canvas_ci_of_ctx(js_this())
        if tci >= 0 and js_arg_count() >= 3:
            tn3: int32 = _arg_bytes(0, &cv_txt[0], 512)
            _canvas_read_font(js_this())
            sname: Ptr[uint8] = cast[Ptr[uint8]]("fillStyle")
            snl: uint64 = 9
            if rel == NID_CV_STROKETEXT:
                sname = cast[Ptr[uint8]]("strokeStyle")
                snl = 11
            htmlcanvas_fill_text(tci, _cvn(1), _cvn(2),
                                 _canvas_style_rgb(js_this(), sname, snl),
                                 g_cv_px, g_cv_bold, &cv_txt[0], tn3)
        return js_undefined()
    if rel == NID_CV_MEASURE:
        eci: int32 = _canvas_ci_of_ctx(js_this())
        if eci >= 0 and js_arg_count() >= 1:
            mn: int32 = _arg_bytes(0, &cv_txt[0], 512)
            _canvas_read_font(js_this())
            mw: int32 = htmlcanvas_measure_text(g_cv_px, g_cv_bold,
                                                &cv_txt[0], mn)
            mo: int32 = js_new_object_v()
            js_set_prop(mo, cast[Ptr[uint8]]("width"), 5,
                        js_number(cast[float64](mw)))
            return mo
        return js_null()
    return js_undefined()


# copy the page <title> text into dom_title_buf; returns its length.
def _scan_title() -> int32:
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           _tagname_is(i + 1, cast[Ptr[uint8]]("title")) != 0:
            j: uint64 = i + 1
            while j < src_len and src_ptr[j] != 62:
                j = j + 1
            if j < src_len:
                j = j + 1
            n: int32 = 0
            while j < src_len and n < 255:
                if src_ptr[j] == 60:                      # '<' -> </title>
                    break
                if src_ptr[j] == 38:                      # '&' -> decode entity
                    consumed: uint64 = _entity(j)
                    if consumed > 0:
                        k: int32 = 0
                        while k < g_ent_len and n < 255:
                            dom_title_buf[n] = g_ent_buf[k]
                            n = n + 1
                            k = k + 1
                        j = j + consumed
                        continue
                dom_title_buf[n] = src_ptr[j]
                n = n + 1
                j = j + 1
            return n
        i = i + 1
    return 0


def _js_build_document():
    doc: int32 = js_new_object_v()
    js_doc = doc
    js_set_prop(doc, cast[Ptr[uint8]]("nodeType"), 8, js_number(cast[float64](9)))
    js_set_prop(doc, cast[Ptr[uint8]]("nodeName"), 8, \
                js_new_string(cast[Ptr[uint8]]("#document"), 9))
    js_set_prop(doc, cast[Ptr[uint8]]("getElementById"), 14, \
                js_new_native_fn(js_hbase + NID_GETBYID))
    js_set_prop(doc, cast[Ptr[uint8]]("createElement"), 13, \
                js_new_native_fn(js_hbase + NID_CREATE))
    js_set_prop(doc, cast[Ptr[uint8]]("createTextNode"), 14, \
                js_new_native_fn(js_hbase + NID_CTEXT))
    js_set_prop(doc, cast[Ptr[uint8]]("querySelector"), 13, \
                js_new_native_fn(js_hbase + NID_QUERY))
    js_set_prop(doc, cast[Ptr[uint8]]("querySelectorAll"), 16, \
                js_new_native_fn(js_hbase + NID_QUERYALL))
    js_set_prop(doc, cast[Ptr[uint8]]("getElementsByClassName"), 22, \
                js_new_native_fn(js_hbase + NID_GETBYCLASS))
    js_set_prop(doc, cast[Ptr[uint8]]("getElementsByTagName"), 20, \
                js_new_native_fn(js_hbase + NID_GETBYTAG))
    js_set_prop(doc, cast[Ptr[uint8]]("addEventListener"), 16, \
                js_new_native_fn(js_hbase + NID_ADDEVT))
    tl: int32 = _scan_title()
    dom_title_len = tl
    dom_title_present = 1
    js_set_prop(doc, cast[Ptr[uint8]]("title"), 5, \
                js_new_string(&dom_title_buf[0], cast[uint64](tl)))
    _build_forms(doc)
    js_global_set(cast[Ptr[uint8]]("document"), 8, doc)


# Eagerly register every <form> and its fields, exposing document.forms and
# each form's .elements array so a script can iterate them. Registering here
# means getElementById later returns the SAME element objects.
def _build_forms(doc: int32):
    forms: int32 = js_new_array_v()
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           _tagname_is(i + 1, cast[Ptr[uint8]]("form")) != 0:
            _scan_start_tag(i)
            fclose: uint64 = g_close_end
            fi: int32 = _dom_lookup_anchor(cast[int32](g_el_lt))
            if fi < 0:
                _dom_register_el()
                fi = _dom_lookup_anchor(cast[int32](g_el_lt))
            if fi >= 0:
                fobj: int32 = dom_obj[fi]
                elems: int32 = js_new_array_v()
                cs: uint64 = cast[uint64](dom_cstart[fi])
                ce: uint64 = cast[uint64](dom_cend[fi])
                j: uint64 = cs
                while j < ce:
                    if src_ptr[j] == 60 and j + 1 < ce and \
                       (_tagname_is(j + 1, cast[Ptr[uint8]]("input")) != 0 or \
                        _tagname_is(j + 1, cast[Ptr[uint8]]("select")) != 0 or \
                        _tagname_is(j + 1, cast[Ptr[uint8]]("textarea")) != 0):
                        _scan_start_tag(j)
                        jclose: uint64 = g_close_end
                        ei: int32 = _dom_lookup_anchor(cast[int32](g_el_lt))
                        if ei < 0:
                            _dom_register_el()
                            ei = _dom_lookup_anchor(cast[int32](g_el_lt))
                        if ei >= 0:
                            js_array_push(elems, dom_obj[ei])
                        j = jclose
                        continue
                    j = j + 1
                js_set_prop(fobj, cast[Ptr[uint8]]("elements"), 8, elems)
                js_array_push(forms, fobj)
            i = fclose
            continue
        i = i + 1
    js_set_prop(doc, cast[Ptr[uint8]]("forms"), 5, forms)


# Is `p[0..n)` the literal "undefined"? (a read of a never-set JS property).
def _is_undef_str(p: Ptr[uint8], n: int32) -> int32:
    return _bytes_eq(p, n, cast[Ptr[uint8]]("undefined"), 9)


# Read one JS string property `name` of object `o`; if non-empty and not
# "undefined", copy it into dom_ovbuf and set *off/*len via the returned pair
# encoded as: returns the length, and sets g_rb_off to the offset. -1 = unset.
g_rb_off: int32 = 0


def _readback_str(o: int32, name: Ptr[uint8], nlen: uint64) -> int32:
    v: int32 = js_get_prop(o, name, nlen)
    p: Ptr[uint8] = js_str_ptr(v)
    n: int32 = _cstr_len(p)
    if n == 0 or _is_undef_str(p, n) != 0:
        return -1
    g_rb_off = dom_ov_len
    k: int32 = 0
    while k < n and dom_ov_len < DOM_OV_CAP:
        dom_ovbuf[dom_ov_len] = p[k]
        dom_ov_len = dom_ov_len + 1
        k = k + 1
    return k


# Read the JS-mutated DOM back into the override tables. Idempotent: resets the
# override accumulators first, so it can run after the initial scripts AND
# again after an event handler mutates the DOM.
def _dom_readback():
    dom_ov_len = 0
    dom_n_overrides = 0
    idx: int32 = 0
    while idx < dom_n:
        o: int32 = dom_obj[idx]
        dom_ov_inner_off[idx] = -1
        dom_ov_inner_len[idx] = -1
        dom_ov_inner_html[idx] = 0
        dom_ov_col_off[idx] = -1
        dom_ov_col_len[idx] = -1
        dom_ov_bg_off[idx] = -1
        dom_ov_bg_len[idx] = -1
        dom_ov_wt_off[idx] = -1
        dom_ov_wt_len[idx] = -1
        dom_ov_al_off[idx] = -1
        dom_ov_al_len[idx] = -1
        dom_ov_wd_off[idx] = -1
        dom_ov_wd_len[idx] = -1
        dom_ov_cls_off[idx] = -1
        dom_ov_cls_len[idx] = -1
        dom_ov_hide[idx] = 0
        dom_ov_val_off[idx] = -1
        dom_ov_val_len[idx] = -1
        dom_ov_checked[idx] = -1
        changed: int32 = 0
        # innerHTML (raw) takes priority over textContent (escaped) as inner.
        hv: int32 = js_get_prop(o, cast[Ptr[uint8]]("innerHTML"), 9)
        hp: Ptr[uint8] = js_str_ptr(hv)
        hn: int32 = _cstr_len(hp)
        if _bytes_eq(hp, hn, &dom_txtbuf[dom_html_off[idx]], \
                     dom_html_len[idx]) == 0 and _is_undef_str(hp, hn) == 0:
            off: int32 = dom_ov_len
            k: int32 = 0
            while k < hn and dom_ov_len < DOM_OV_CAP:
                dom_ovbuf[dom_ov_len] = hp[k]
                dom_ov_len = dom_ov_len + 1
                k = k + 1
            dom_ov_inner_off[idx] = off
            dom_ov_inner_len[idx] = k
            dom_ov_inner_html[idx] = 1
            changed = 1
        else:
            tc: int32 = js_get_prop(o, cast[Ptr[uint8]]("textContent"), 11)
            tp: Ptr[uint8] = js_str_ptr(tc)
            tn: int32 = _cstr_len(tp)
            if _bytes_eq(tp, tn, &dom_txtbuf[dom_orig_off[idx]], \
                         dom_orig_len[idx]) == 0 and _is_undef_str(tp, tn) == 0:
                off2: int32 = dom_ov_len
                k2: int32 = 0
                while k2 < tn and dom_ov_len < DOM_OV_CAP:
                    dom_ovbuf[dom_ov_len] = tp[k2]
                    dom_ov_len = dom_ov_len + 1
                    k2 = k2 + 1
                dom_ov_inner_off[idx] = off2
                dom_ov_inner_len[idx] = k2
                dom_ov_inner_html[idx] = 0
                changed = 1
        # style props
        stv: int32 = js_get_prop(o, cast[Ptr[uint8]]("style"), 5)
        r: int32 = _readback_str(stv, cast[Ptr[uint8]]("color"), 5)
        if r >= 0:
            dom_ov_col_off[idx] = g_rb_off
            dom_ov_col_len[idx] = r
            changed = 1
        r = _readback_str(stv, cast[Ptr[uint8]]("backgroundColor"), 15)
        if r >= 0:
            dom_ov_bg_off[idx] = g_rb_off
            dom_ov_bg_len[idx] = r
            changed = 1
        r = _readback_str(stv, cast[Ptr[uint8]]("fontWeight"), 10)
        if r >= 0:
            dom_ov_wt_off[idx] = g_rb_off
            dom_ov_wt_len[idx] = r
            changed = 1
        r = _readback_str(stv, cast[Ptr[uint8]]("textAlign"), 9)
        if r >= 0:
            dom_ov_al_off[idx] = g_rb_off
            dom_ov_al_len[idx] = r
            changed = 1
        r = _readback_str(stv, cast[Ptr[uint8]]("width"), 5)
        if r >= 0:
            dom_ov_wd_off[idx] = g_rb_off
            dom_ov_wd_len[idx] = r
            changed = 1
        # display:none
        dv: int32 = js_get_prop(stv, cast[Ptr[uint8]]("display"), 7)
        dp: Ptr[uint8] = js_str_ptr(dv)
        dn: int32 = _cstr_len(dp)
        if _bytes_eq(dp, dn, cast[Ptr[uint8]]("none"), 4) != 0:
            dom_ov_hide[idx] = 1
            changed = 1
        # className
        clv: int32 = js_get_prop(o, cast[Ptr[uint8]]("className"), 9)
        clp: Ptr[uint8] = js_str_ptr(clv)
        cln: int32 = _cstr_len(clp)
        if _bytes_eq(clp, cln, &dom_txtbuf[dom_origcls_off[idx]], \
                     dom_origcls_len[idx]) == 0 and _is_undef_str(clp, cln) == 0:
            cco: int32 = dom_ov_len
            kc: int32 = 0
            while kc < cln and dom_ov_len < DOM_OV_CAP:
                dom_ovbuf[dom_ov_len] = clp[kc]
                dom_ov_len = dom_ov_len + 1
                kc = kc + 1
            dom_ov_cls_off[idx] = cco
            dom_ov_cls_len[idx] = kc
            changed = 1
        # form value / checked read-back (input / textarea / select).
        if dom_kind[idx] == 1 or dom_kind[idx] == 2 or dom_kind[idx] == 3:
            vv: int32 = js_get_prop(o, cast[Ptr[uint8]]("value"), 5)
            vp: Ptr[uint8] = js_str_ptr(vv)
            vn: int32 = _cstr_len(vp)
            if _bytes_eq(vp, vn, &dom_txtbuf[dom_origval_off[idx]], \
                         dom_origval_len[idx]) == 0 and _is_undef_str(vp, vn) == 0:
                voff: int32 = dom_ov_len
                kv: int32 = 0
                while kv < vn and dom_ov_len < DOM_OV_CAP:
                    dom_ovbuf[dom_ov_len] = vp[kv]
                    dom_ov_len = dom_ov_len + 1
                    kv = kv + 1
                dom_ov_val_off[idx] = voff
                dom_ov_val_len[idx] = kv
                changed = 1
        # select: a JS `selectedIndex = N` write with no matching value write
        # resolves to the Nth option's text so the control re-marks + re-renders.
        if dom_kind[idx] == 3 and dom_ov_val_len[idx] < 0:
            siv: int32 = js_get_prop(o, cast[Ptr[uint8]]("selectedIndex"), 13)
            si: int32 = cast[int32](js_to_number(siv))
            oi: int32 = _select_index(cast[uint64](dom_cstart[idx]))
            if si != oi and si >= 0:
                sn: int32 = _select_optext_at(cast[uint64](dom_cstart[idx]), si)
                if sn >= 0:
                    soff: int32 = dom_ov_len
                    ks: int32 = 0
                    while ks < sn and dom_ov_len < DOM_OV_CAP:
                        dom_ovbuf[dom_ov_len] = fbuf[ks]
                        dom_ov_len = dom_ov_len + 1
                        ks = ks + 1
                    dom_ov_val_off[idx] = soff
                    dom_ov_val_len[idx] = ks
                    js_set_prop(o, cast[Ptr[uint8]]("value"), 5, \
                                js_new_string(&fbuf[0], cast[uint64](ks)))
                    changed = 1
        if dom_origchecked[idx] >= 0:
            ckv: int32 = js_get_prop(o, cast[Ptr[uint8]]("checked"), 7)
            ckb: int32 = 0
            if js_to_bool(ckv) != 0:
                ckb = 1
            if ckb != dom_origchecked[idx]:
                dom_ov_checked[idx] = ckb
                changed = 1
        # assigned handler-function properties (el.onX = fn).
        ocv: int32 = js_get_prop(o, cast[Ptr[uint8]]("onclick"), 7)
        if js_is_callable(ocv) != 0:
            dom_onclick_fn[idx] = ocv
        oiv: int32 = js_get_prop(o, cast[Ptr[uint8]]("oninput"), 7)
        if js_is_callable(oiv) != 0:
            dom_oninput_fn[idx] = oiv
        ocgv: int32 = js_get_prop(o, cast[Ptr[uint8]]("onchange"), 8)
        if js_is_callable(ocgv) != 0:
            dom_onchange_fn[idx] = ocgv
        osv: int32 = js_get_prop(o, cast[Ptr[uint8]]("onsubmit"), 8)
        if js_is_callable(osv) != 0:
            dom_onsubmit_fn[idx] = osv
        # appended children force a rewrite of this element too.
        a: int32 = 0
        while a < ap_n:
            if ap_removed[a] == 0 and ap_parent[a] == idx:
                changed = 1
            a = a + 1
        if changed != 0:
            dom_n_overrides = dom_n_overrides + 1
        idx = idx + 1
    # document.title
    tv: int32 = js_get_prop(js_doc, cast[Ptr[uint8]]("title"), 5)
    pp: Ptr[uint8] = js_str_ptr(tv)
    pn: int32 = _cstr_len(pp)
    if pn > 255:
        pn = 255
    j: int32 = 0
    while j < pn:
        dom_title_buf[j] = pp[j]
        j = j + 1
    dom_title_len = pn
    dom_title_present = 1


def _js_capture_console():
    p: Ptr[uint8] = js_out_ptr()
    n: int32 = cast[int32](js_out_len())
    i: int32 = 0
    while i < n and i < 8191:
        js_con_buf[i] = p[i]
        i = i + 1
    js_con_buf[i] = 0
    js_con_len = i


# True if the source contains a <script> element OR any inline event-handler
# attribute (onclick=/oninput=/onchange=/onsubmit=/onkeyup=/...). A page whose
# only JS is inline handlers (no <script> block) — extremely common on real
# forms/buttons — still needs a live JS context so he_dom_click / set_value can
# fire those handlers and re-render. Attribute names are matched only at an
# attribute-name boundary (preceded by whitespace) inside a tag, so the word
# "onclick" in body text never triggers a spurious JS init.
def _page_has_js() -> int32:
    p: uint64 = 0
    while p < src_len:
        if src_ptr[p] != 60:                                 # '<'
            p = p + 1
            continue
        if p + 1 < src_len and \
           _tagname_is(p + 1, cast[Ptr[uint8]]("script")) != 0:
            return 1
        # scan this tag's attributes for an on<letters>= handler name
        q: uint64 = p + 1
        prev_ws: int32 = 0
        while q < src_len and src_ptr[q] != 62:              # up to '>'
            c: uint8 = src_ptr[q]
            if prev_ws != 0 and (c == 111 or c == 79) and \
               q + 2 < src_len and (src_ptr[q + 1] == 110 or src_ptr[q + 1] == 78):
                # "on" at a name boundary: require >=1 more letter then '='
                r: uint64 = q + 2
                nletters: int32 = 0
                while r < src_len and src_ptr[r] != 62 and \
                      ((src_ptr[r] >= 97 and src_ptr[r] <= 122) or \
                       (src_ptr[r] >= 65 and src_ptr[r] <= 90)):
                    r = r + 1
                    nletters = nletters + 1
                while r < src_len and \
                      (src_ptr[r] == 32 or src_ptr[r] == 9 or \
                       src_ptr[r] == 10 or src_ptr[r] == 13):
                    r = r + 1
                if nletters >= 1 and r < src_len and src_ptr[r] == 61:   # '='
                    return 1
            if c == 32 or c == 9 or c == 10 or c == 13:
                prev_ws = 1
            else:
                prev_ws = 0
            q = q + 1
        p = q
    return 0


# Run every <script> body. Returns 1 if at least one script ran (so the DOM
# overrides are meaningful), 0 if the page had no scripts at all.
def _run_scripts() -> int32:
    # A live JS context is needed if the page has a <script> element OR any
    # inline on<evt>="" handler (no <script> required for interactivity).
    has: int32 = _page_has_js()
    # A native front-end (he_click_links) needs a live JS context + registered
    # form fields even for a script-LESS page, so a plain <form> is still
    # pointer-focusable/typable/submittable. Host renders keep the old fast path.
    force_ctx: int32 = 0
    if has == 0 and he_click_links != 0 and _page_has_form() != 0:
        force_ctx = 1
    if has == 0 and force_ctx == 0:
        # No script, but the tab title still needs the page <title> (decoded).
        dom_title_len = _scan_title()
        if dom_title_len > 0:
            dom_title_present = 1
        return 0
    js_init()
    js_hbase = js_host_base()
    js_set_host_dispatch(cast[Fn[int32, int32]](cast[uint64](_js_host_dispatch)))
    js_set_member_hook(cast[Fn[int32, int32]](cast[uint64](_js_member_set_hook)))
    _js_build_document()
    _dom_build_tree_index()                               # parent/child overlay (round 2)
    js_ctx_live = 1
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           _tagname_is(i + 1, cast[Ptr[uint8]]("script")) != 0:
            # body starts after this start tag's '>'
            j: uint64 = i + 1
            while j < src_len and src_ptr[j] != 62:
                j = j + 1
            if j < src_len:
                j = j + 1
            bs: uint64 = j
            # body ends at </script>
            be: uint64 = bs
            while be < src_len:
                if src_ptr[be] == 60 and be + 1 < src_len and \
                   src_ptr[be + 1] == 47 and \
                   _tagname_is(be + 2, cast[Ptr[uint8]]("script")) != 0:
                    break
                be = be + 1
            if be > bs:
                js_eval(&src_ptr[bs], be - bs)
                if js_error() != 0:
                    js_had_error = 1
            # continue past </script>
            i = be
            while i < src_len and src_ptr[i] != 62:
                i = i + 1
            if i < src_len:
                i = i + 1
            continue
        i = i + 1
    _js_capture_console()
    _dom_readback()
    return 1


# ---- source rewrite (only when overrides exist) --------------------
def _rw_ch(c: uint8):
    if rw_len < RW_CAP:
        rw_buf[rw_len] = c
        rw_len = rw_len + 1


def _rw_range(a: uint64, b: uint64):
    i: uint64 = a
    while i < b:
        _rw_ch(src_ptr[i])
        i = i + 1


def _rw_cstr(s: Ptr[uint8]):
    i: int32 = 0
    while s[i] != 0:
        _rw_ch(s[i])
        i = i + 1


def _rw_ovbuf(off: int32, ln: int32):
    i: int32 = 0
    while i < ln:
        _rw_ch(dom_ovbuf[off + i])
        i = i + 1


# Emit `ln` raw bytes from a pointer (e.g. a created node's innerHTML markup).
def _rw_ovbuf_ptr(p: Ptr[uint8], ln: int32):
    i: int32 = 0
    while i < ln:
        _rw_ch(p[i])
        i = i + 1


# emit override bytes, escaping '<' and '&' so injected textContent renders as
# literal text (never re-parsed as markup).
def _rw_text_escaped(off: int32, ln: int32):
    i: int32 = 0
    while i < ln:
        c: uint8 = dom_ovbuf[off + i]
        if c == 60:
            _rw_cstr(cast[Ptr[uint8]]("&lt;"))
        elif c == 38:
            _rw_cstr(cast[Ptr[uint8]]("&amp;"))
        else:
            _rw_ch(c)
        i = i + 1


def _el_has_override(idx: int32) -> int32:
    if dom_ov_hide[idx] != 0 or dom_ov_inner_len[idx] >= 0 or \
       dom_ov_col_len[idx] >= 0 or dom_ov_bg_len[idx] >= 0 or \
       dom_ov_wt_len[idx] >= 0 or dom_ov_al_len[idx] >= 0 or \
       dom_ov_wd_len[idx] >= 0 or \
       dom_ov_cls_len[idx] >= 0 or dom_ov_val_len[idx] >= 0 or \
       dom_ov_checked[idx] >= 0:
        return 1
    # a click handler alone makes the element a rewrite target when the native
    # front-end wants clickable event-links.
    if he_click_links != 0 and _el_has_handler(idx) != 0:
        return 1
    # a focusable/submit form control is wrapped so a pointer click reaches it.
    if _is_wrappable_field(idx) != 0:
        return 1
    a: int32 = 0
    while a < ap_n:
        if ap_removed[a] == 0 and ap_parent[a] == idx:
            return 1
        a = a + 1
    return 0


def _rw_dec(v: int32):
    if v == 0:
        _rw_ch(48)
        return
    d: Array[12, uint8]
    n: int32 = 0
    x: int32 = v
    while x > 0:
        d[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _rw_ch(d[n])


# Emit escaped text (rewriting '<' and '&') from a JS string value.
def _rw_js_escaped(v: int32):
    p: Ptr[uint8] = js_str_ptr(v)
    n: int32 = _cstr_len(p)
    if _is_undef_str(p, n) != 0:
        return
    i: int32 = 0
    while i < n:
        c: uint8 = p[i]
        if c == 60:
            _rw_cstr(cast[Ptr[uint8]]("&lt;"))
        elif c == 38:
            _rw_cstr(cast[Ptr[uint8]]("&amp;"))
        else:
            _rw_ch(c)
        i = i + 1


# Emit ` name="value"` for a created node's JS property (skips empty/undefined).
# The value is attribute-escaped ('"' -> &quot;, '&' -> &amp;).
def _emit_cre_attr(co: int32, prop: Ptr[uint8], plen: uint64, aname: Ptr[uint8]):
    v: int32 = js_get_prop(co, prop, plen)
    p: Ptr[uint8] = js_str_ptr(v)
    n: int32 = _cstr_len(p)
    if n == 0 or _is_undef_str(p, n) != 0:
        return
    _rw_ch(32)
    _rw_cstr(aname)
    _rw_cstr(cast[Ptr[uint8]]("=\""))
    i: int32 = 0
    while i < n:
        c: uint8 = p[i]
        if c == 34:
            _rw_cstr(cast[Ptr[uint8]]("&quot;"))
        elif c == 38:
            _rw_cstr(cast[Ptr[uint8]]("&amp;"))
        else:
            _rw_ch(c)
        i = i + 1
    _rw_ch(34)


# Emit a script-created node's markup, RECURSIVELY: a text node emits only its
# escaped text; an element emits <tag id class style>inner</tag> where `inner`
# is innerHTML (raw) if set, else the escaped textContent followed by its nested
# created children (so a table > tr > td subtree built entirely in script
# renders with its full structure). Detached nodes (node.remove()) are skipped.
def _emit_created(cid: int32):
    if cre_gone[cid] != 0:
        return
    co: int32 = cre_obj[cid]
    if cre_is_text[cid] != 0:
        _rw_js_escaped(js_get_prop(co, cast[Ptr[uint8]]("textContent"), 11))
        return
    _rw_ch(60)                                            # '<'
    t: int32 = 0
    while t < cre_tag_len[cid]:
        _rw_ch(dom_idbuf[cre_tag_off[cid] + t])
        t = t + 1
    _emit_cre_attr(co, cast[Ptr[uint8]]("id"), 2, cast[Ptr[uint8]]("id"))
    _emit_cre_attr(co, cast[Ptr[uint8]]("className"), 9, cast[Ptr[uint8]]("class"))
    _rw_ch(62)                                            # '>'
    # Inline `.style.*` overrides are carried on an INNER <span> — some elements
    # (e.g. <li>, table cells) don't parse an inline style="" on their own tag,
    # whereas an inline <span> reliably honours color/bg/weight/align. className
    # (a real class) is emitted as a tag attribute above so the CSS cascade sees
    # it. The span wraps both the textContent and any nested created children.
    stv: int32 = js_get_prop(co, cast[Ptr[uint8]]("style"), 5)
    dom_ov_len_save: int32 = dom_ov_len
    cl: int32 = _readback_str(stv, cast[Ptr[uint8]]("color"), 5)
    col_off: int32 = g_rb_off
    bg: int32 = _readback_str(stv, cast[Ptr[uint8]]("backgroundColor"), 15)
    bg_off: int32 = g_rb_off
    wt: int32 = _readback_str(stv, cast[Ptr[uint8]]("fontWeight"), 10)
    wt_off: int32 = g_rb_off
    al: int32 = _readback_str(stv, cast[Ptr[uint8]]("textAlign"), 9)
    al_off: int32 = g_rb_off
    has_style: int32 = 0
    if cl >= 0 or bg >= 0 or wt >= 0 or al >= 0:
        has_style = 1
        _rw_cstr(cast[Ptr[uint8]]("<span style=\""))
        if cl >= 0:
            _rw_cstr(cast[Ptr[uint8]]("color:"))
            _rw_ovbuf(col_off, cl)
            _rw_ch(59)
        if bg >= 0:
            _rw_cstr(cast[Ptr[uint8]]("background-color:"))
            _rw_ovbuf(bg_off, bg)
            _rw_ch(59)
        if wt >= 0:
            _rw_cstr(cast[Ptr[uint8]]("font-weight:"))
            _rw_ovbuf(wt_off, wt)
            _rw_ch(59)
        if al >= 0:
            _rw_cstr(cast[Ptr[uint8]]("text-align:"))
            _rw_ovbuf(al_off, al)
            _rw_ch(59)
        _rw_cstr(cast[Ptr[uint8]]("\">"))
    dom_ov_len = dom_ov_len_save                          # scratch reclaim
    # inner: innerHTML (raw) wins; else textContent (escaped) + nested children.
    hv: int32 = js_get_prop(co, cast[Ptr[uint8]]("innerHTML"), 9)
    hp: Ptr[uint8] = js_str_ptr(hv)
    hn: int32 = _cstr_len(hp)
    if hn > 0 and _is_undef_str(hp, hn) == 0:
        _rw_ovbuf_ptr(hp, hn)
    else:
        _rw_js_escaped(js_get_prop(co, cast[Ptr[uint8]]("textContent"), 11))
        a: int32 = 0
        while a < cc_n:
            if cc_removed[a] == 0 and cc_owner[a] == cid:
                _emit_created(cc_child[a])
            a = a + 1
    if has_style != 0:
        _rw_cstr(cast[Ptr[uint8]]("</span>"))
    _rw_cstr(cast[Ptr[uint8]]("</"))
    t2: int32 = 0
    while t2 < cre_tag_len[cid]:
        _rw_ch(dom_idbuf[cre_tag_off[cid] + t2])
        t2 = t2 + 1
    _rw_ch(62)


# Emit the merged inline style="" for an element's style overrides (or nothing).
def _emit_merged_style(idx: int32):
    if dom_ov_col_len[idx] < 0 and dom_ov_bg_len[idx] < 0 and \
       dom_ov_wt_len[idx] < 0 and dom_ov_al_len[idx] < 0 and \
       dom_ov_wd_len[idx] < 0:
        return
    _rw_cstr(cast[Ptr[uint8]](" style=\""))
    if dom_ov_col_len[idx] >= 0:
        _rw_cstr(cast[Ptr[uint8]]("color:"))
        _rw_ovbuf(dom_ov_col_off[idx], dom_ov_col_len[idx])
        _rw_ch(59)
    if dom_ov_bg_len[idx] >= 0:
        _rw_cstr(cast[Ptr[uint8]]("background-color:"))
        _rw_ovbuf(dom_ov_bg_off[idx], dom_ov_bg_len[idx])
        _rw_ch(59)
    if dom_ov_wt_len[idx] >= 0:
        _rw_cstr(cast[Ptr[uint8]]("font-weight:"))
        _rw_ovbuf(dom_ov_wt_off[idx], dom_ov_wt_len[idx])
        _rw_ch(59)
    if dom_ov_al_len[idx] >= 0:
        _rw_cstr(cast[Ptr[uint8]]("text-align:"))
        _rw_ovbuf(dom_ov_al_off[idx], dom_ov_al_len[idx])
        _rw_ch(59)
    if dom_ov_wd_len[idx] >= 0:
        _rw_cstr(cast[Ptr[uint8]]("width:"))
        _rw_ovbuf(dom_ov_wd_off[idx], dom_ov_wd_len[idx])
        _rw_ch(59)
    _rw_ch(34)


# Copy tag-body attributes [a,b) into rw_buf, dropping any attribute named
# `s1` or `s2` (case-insensitive; both valued `name="v"` and bare `name` forms).
def _rw_copy_attrs_except(a: uint64, b: uint64, s1: Ptr[uint8], s2: Ptr[uint8]):
    l1: int32 = _cstr_len(s1)
    l2: int32 = _cstr_len(s2)
    i: uint64 = a
    while i < b:
        c: uint8 = src_ptr[i]
        if c == 32 or c == 9 or c == 10 or c == 13:
            _rw_ch(c)
            i = i + 1
            continue
        ns: uint64 = i
        while i < b and _is_name_ch(src_ptr[i]) != 0:
            i = i + 1
        ne2: uint64 = i
        # look ahead past spaces for '=' to find a valued attribute
        k: uint64 = i
        while k < b and (src_ptr[k] == 32 or src_ptr[k] == 9):
            k = k + 1
        attr_end: uint64 = ne2
        if k < b and src_ptr[k] == 61:                    # '='
            k = k + 1
            while k < b and (src_ptr[k] == 32 or src_ptr[k] == 9):
                k = k + 1
            if k < b and (src_ptr[k] == 34 or src_ptr[k] == 39):
                q: uint8 = src_ptr[k]
                k = k + 1
                while k < b and src_ptr[k] != q:
                    k = k + 1
                if k < b:
                    k = k + 1
            else:
                while k < b and src_ptr[k] != 32 and src_ptr[k] != 9:
                    k = k + 1
            attr_end = k
        skip: int32 = 0
        if _idbytes_eq(ns, ne2, s1, l1) != 0 or _idbytes_eq(ns, ne2, s2, l2) != 0:
            skip = 1
        if skip == 0:
            _rw_range(ns, attr_end)
        i = attr_end


# Does dom_ovbuf[off..off+len) equal src span [a,b) (byte-exact)?
def _ovbuf_eq_src(off: int32, ln: int32, a: uint64, b: uint64) -> int32:
    if cast[int32](b - a) != ln:
        return 0
    i: int32 = 0
    while i < ln:
        if dom_ovbuf[off + i] != src_ptr[a + cast[uint64](i)]:
            return 0
        i = i + 1
    return 1


# Re-emit a <select>'s option list [cs,ce), moving `selected` onto the option
# whose visible text equals the override value dom_ovbuf[voff..voff+vlen).
def _rw_select_options(cs: uint64, ce: uint64, voff: int32, vlen: int32):
    i: uint64 = cs
    while i < ce:
        if src_ptr[i] == 60 and _tagname_is(i + 1, cast[Ptr[uint8]]("option")) != 0:
            je: uint64 = i + 1
            while je < ce and src_ptr[je] != 62:
                je = je + 1
            ne: uint64 = i + 1
            while ne < je and _alnum_at(ne) != 0:
                ne = ne + 1
            ots: uint64 = je + 1
            ote: uint64 = ots
            while ote < ce and src_ptr[ote] != 60:
                ote = ote + 1
            _rw_ch(60)
            _rw_range(i + 1, ne)                          # 'option'
            _rw_copy_attrs_except(ne, je, cast[Ptr[uint8]]("selected"), \
                                  cast[Ptr[uint8]]("selected"))
            if _ovbuf_eq_src(voff, vlen, ots, ote) != 0:
                _rw_cstr(cast[Ptr[uint8]](" selected"))
            _rw_ch(62)
            i = je + 1
            continue
        _rw_ch(src_ptr[i])
        i = i + 1


# Build rw_buf: a copy of the source with each overridden element's mutations
# baked in. Overridden elements are matched by their source anchor offset, so
# id-less querySelector matches work too. Elements without overrides copy
# through byte-for-byte, so the rest of the page's layout is unchanged.
def _build_rewrite():
    rw_len = 0
    i: uint64 = 0
    while i < src_len:
        c: uint8 = src_ptr[i]
        if c == 60 and i + 1 < src_len and src_ptr[i + 1] != 47 and \
           src_ptr[i + 1] != 33 and src_ptr[i + 1] != 63:
            idx: int32 = _dom_lookup_anchor(cast[int32](i))
            if idx >= 0 and _el_has_override(idx) != 0:
                # A focusable/submit form control is wrapped OUTSIDE its tag
                # (<a ..><input></a>) so the input's own box word inherits the
                # link and the pointer hit-test resolves to it. Click-handler
                # elements keep the INNER wrap (their clickable content is the
                # element's text), so the two are mutually exclusive.
                wrap_outer: int32 = 0
                if _is_wrappable_field(idx) != 0:
                    wrap_outer = 1
                    _rw_cstr(cast[Ptr[uint8]]("<a href=\"#__evt_"))
                    _rw_dec(idx)
                    _rw_cstr(cast[Ptr[uint8]]("\">"))
                ts: uint64 = i + 1
                je: uint64 = ts
                while je < src_len and src_ptr[je] != 62:
                    je = je + 1
                ne: uint64 = ts
                while ne < je and _alnum_at(ne) != 0:
                    ne = ne + 1
                clt: uint64 = cast[uint64](dom_cend[idx])
                # locate the close tag end
                _find_close(ts, ne - ts, je + 1)
                cend: uint64 = g_close_end
                if dom_ov_hide[idx] != 0:
                    i = cend
                    continue
                # rebuild the start tag: <name [class] [style] original-attrs>
                _rw_ch(60)
                _rw_range(ts, ne)
                if dom_ov_cls_len[idx] >= 0:
                    _rw_cstr(cast[Ptr[uint8]](" class=\""))
                    _rw_ovbuf(dom_ov_cls_off[idx], dom_ov_cls_len[idx])
                    _rw_ch(34)
                _emit_merged_style(idx)
                if dom_kind[idx] == 1 and \
                   (dom_ov_val_len[idx] >= 0 or dom_ov_checked[idx] >= 0):
                    # input: re-emit attrs without value/checked, then the new
                    # value/checked so the control renders its updated state.
                    _rw_copy_attrs_except(ne, je, cast[Ptr[uint8]]("value"), \
                                          cast[Ptr[uint8]]("checked"))
                    if dom_ov_val_len[idx] >= 0:
                        _rw_cstr(cast[Ptr[uint8]](" value=\""))
                        _rw_ovbuf(dom_ov_val_off[idx], dom_ov_val_len[idx])
                        _rw_ch(34)
                    if dom_ov_checked[idx] == 1:
                        _rw_cstr(cast[Ptr[uint8]](" checked"))
                else:
                    _rw_range(ne, je)                     # original attributes
                _rw_ch(62)
                # native-only: wrap a click-handler element's content in a
                # synthetic "#__evt_IDX" link so the existing pointer link
                # hit-test can route the click to he_dom_click_index.
                wrap_evt: int32 = 0
                if wrap_outer == 0 and he_click_links != 0 and \
                   _el_has_handler(idx) != 0:
                    wrap_evt = 1
                    _rw_cstr(cast[Ptr[uint8]]("<a href=\"#__evt_"))
                    _rw_dec(idx)
                    _rw_cstr(cast[Ptr[uint8]]("\">"))
                # inner content
                if dom_kind[idx] == 2 and dom_ov_val_len[idx] >= 0:
                    # textarea value change = new (escaped) inner text.
                    _rw_text_escaped(dom_ov_val_off[idx], dom_ov_val_len[idx])
                elif dom_kind[idx] == 3 and dom_ov_val_len[idx] >= 0:
                    # select value change = re-mark the selected <option>.
                    _rw_select_options(je + 1, clt, dom_ov_val_off[idx], \
                                       dom_ov_val_len[idx])
                elif dom_ov_inner_len[idx] >= 0:
                    if dom_ov_inner_html[idx] != 0:
                        _rw_ovbuf(dom_ov_inner_off[idx], dom_ov_inner_len[idx])
                    else:
                        _rw_text_escaped(dom_ov_inner_off[idx], \
                                         dom_ov_inner_len[idx])
                else:
                    _rw_range(je + 1, clt)
                # appended created children, in insertion order
                a: int32 = 0
                while a < ap_n:
                    if ap_removed[a] == 0 and ap_parent[a] == idx:
                        _emit_created(ap_child[a])
                    a = a + 1
                if wrap_evt != 0:
                    _rw_cstr(cast[Ptr[uint8]]("</a>"))
                _rw_range(clt, cend)                      # original close tag
                if wrap_outer != 0:
                    _rw_cstr(cast[Ptr[uint8]]("</a>"))
                i = cend
                continue
        _rw_ch(c)
        i = i + 1


# ---- front-end accessors (console / title / error) ------------------
def he_js_console_ptr() -> Ptr[uint8]:
    js_con_buf[js_con_len] = 0
    return &js_con_buf[0]


def he_js_console_len() -> uint64:
    return cast[uint64](js_con_len)


def he_js_error() -> int32:
    return js_had_error


def he_dom_title_ptr() -> Ptr[uint8]:
    return &dom_title_buf[0]


def he_dom_title_len() -> uint64:
    return cast[uint64](dom_title_len)


def he_dom_title_present() -> int32:
    return dom_title_present


# Lay out either the original source or, when the DOM carries overrides, a
# rewritten copy with them baked in. Shared by he_layout and post-event
# re-layout (he_dom_click).
def _relayout():
    if dom_n_overrides > 0 or _n_wrappable() > 0:
        _build_rewrite()
        save_ptr: Ptr[uint8] = src_ptr
        save_len: uint64 = src_len
        src_ptr = &rw_buf[0]
        src_len = rw_len
        _layout()
        src_ptr = save_ptr
        src_len = save_len
    else:
        _layout()


# he_layout — public entry point (non-underscore so front-ends can call it
# without an underscore import). Runs the page's <script>s (if any) through
# the JS engine + minimal DOM, then lays out src_ptr/src_len into segments —
# re-laying-out a rewritten source when a script mutated the DOM. The JS
# context persists after this returns (until the next he_layout / js_init) so
# event handlers registered here stay live for he_dom_click().
def he_layout():
    _strip_comments()
    _dom_reset()
    _run_scripts()
    _relayout()


# Dispatch a click to the DOM record at `idx`: invoke its stored handler (an
# el.onclick / addEventListener('click', fn) function value, or an inline
# onclick="" source string) in the LIVE JS context, then read the DOM back and
# re-lay-out so the handler's mutations render. Returns 1 if a handler ran.
g_argv1: Array[1, int32]


# Compile an inline handler source string (the JS between the on<evt>="" quotes)
# into a callable function value, so it can be invoked with `this` bound to the
# element — real pages routinely use `this.value` / `this.checked` / `this.id`
# inside inline handlers. The body is wrapped as  function(event){ <src> }  so
# it also sees the event argument. Returns the function value, or -1 on a
# compile error (caller falls back to a bare global-scope eval).
HB_HWRAP_CAP: int32 = 8192
hb_hwrap: Array[8192, uint8]


def _compile_inline_handler(src: int32, srclen: int32) -> int32:
    pfx: Ptr[uint8] = cast[Ptr[uint8]]("var __hb_ev_fn__=function(event){\n")
    w: int32 = 0
    i: int32 = 0
    while pfx[i] != 0 and w < HB_HWRAP_CAP - 4:
        hb_hwrap[w] = pfx[i]
        w = w + 1
        i = i + 1
    j: int32 = 0
    while j < srclen and w < HB_HWRAP_CAP - 4:
        hb_hwrap[w] = dom_txtbuf[src + j]
        w = w + 1
        j = j + 1
    hb_hwrap[w] = 10                                          # '\n' (end any // comment)
    w = w + 1
    hb_hwrap[w] = 125                                         # '}'
    w = w + 1
    hb_hwrap[w] = 59                                          # ';'
    w = w + 1
    js_eval(&hb_hwrap[0], cast[uint64](w))
    if js_error() != 0:
        js_had_error = 1
        return -1
    return js_global_get(cast[Ptr[uint8]]("__hb_ev_fn__"), 12)


# Cache a just-compiled inline-handler function value into element `idx`'s slot
# for event `kind`, so subsequent events reuse it (no recompile).
def _store_handler_fn(idx: int32, kind: int32, fnval: int32):
    if kind == 0:
        dom_onclick_fn[idx] = fnval
    elif kind == 1:
        dom_oninput_fn[idx] = fnval
    elif kind == 2:
        dom_onchange_fn[idx] = fnval
    elif kind == 3:
        dom_onsubmit_fn[idx] = fnval


# Fire element `idx`'s handlers for event `kind` (0 click, 1 input, 2 change,
# 3 submit) in the live JS context, passing `evtobj` as the sole argument
# (-1 = call with no args). Fires, in order: every addEventListener registration
# for (idx,kind) in registration order, THEN the attribute handler (el.on<evt> /
# inline on<evt>="" — a stored function value wins over an inline source string).
# Returns 1 if at least one handler ran.
def _fire_handler(idx: int32, kind: int32, evtobj: int32) -> int32:
    ran: int32 = 0
    # An inline on<evt>="" handler (and legacy code) references a global `event`;
    # bind it once so every handler in this fire sees it.
    if evtobj >= 0:
        js_global_set(cast[Ptr[uint8]]("event"), 5, evtobj)
    # (1) addEventListener registrations, in registration order.
    li: int32 = 0
    while li < evl_n:
        if evl_dead[li] == 0 and evl_el[li] == idx and evl_kind[li] == kind:
            lfn: int32 = evl_fn[li]
            if js_is_callable(lfn) != 0:
                if evtobj >= 0:
                    g_argv1[0] = evtobj
                    js_call_fn(lfn, dom_obj[idx], &g_argv1[0], 1)
                else:
                    js_call_fn(lfn, dom_obj[idx], cast[Ptr[int32]](0), 0)
                ran = 1
        li = li + 1
    # (2) the attribute handler (el.on<evt> property or inline on<evt>="").
    fn: int32 = -1
    src: int32 = -1
    srclen: int32 = 0
    pnm: Ptr[uint8] = cast[Ptr[uint8]]("onclick")
    pnl: int32 = 7
    if kind == 0:
        fn = dom_onclick_fn[idx]
        src = dom_onclick_src[idx]
        srclen = dom_onclick_srclen[idx]
    elif kind == 1:
        fn = dom_oninput_fn[idx]
        src = dom_oninput_src[idx]
        srclen = dom_oninput_srclen[idx]
        pnm = cast[Ptr[uint8]]("oninput")
        pnl = 7
    elif kind == 2:
        fn = dom_onchange_fn[idx]
        src = dom_onchange_src[idx]
        srclen = dom_onchange_srclen[idx]
        pnm = cast[Ptr[uint8]]("onchange")
        pnl = 8
    elif kind == 3:
        fn = dom_onsubmit_fn[idx]
        src = dom_onsubmit_src[idx]
        srclen = dom_onsubmit_srclen[idx]
        pnm = cast[Ptr[uint8]]("onsubmit")
        pnl = 8
    # el.on<evt> = fn assigned by a still-running script is not synced to the
    # slot until _dom_readback; read it live so a load-time dispatch sees it.
    if fn < 0:
        pv: int32 = js_get_prop(dom_obj[idx], pnm, cast[uint64](pnl))
        if js_is_callable(pv) != 0:
            fn = pv
    if fn >= 0 and js_is_callable(fn) != 0:
        if evtobj >= 0:
            g_argv1[0] = evtobj
            js_call_fn(fn, dom_obj[idx], &g_argv1[0], 1)
        else:
            js_call_fn(fn, dom_obj[idx], cast[Ptr[int32]](0), 0)
        return 1
    if src >= 0:
        # Compile the inline source into a function so `this` binds to the
        # element (this.value / this.checked), then cache + call it.
        cfn: int32 = _compile_inline_handler(src, srclen)
        if cfn >= 0 and js_is_callable(cfn) != 0:
            _store_handler_fn(idx, kind, cfn)
            if evtobj >= 0:
                g_argv1[0] = evtobj
                js_call_fn(cfn, dom_obj[idx], &g_argv1[0], 1)
            else:
                js_call_fn(cfn, dom_obj[idx], cast[Ptr[int32]](0), 0)
            return 1
        # Fallback: run the raw source at global scope (legacy `this`==global).
        js_eval(&dom_txtbuf[src], cast[uint64](srclen))
        if js_error() != 0:
            js_had_error = 1
        return 1
    return ran


# The registered DOM element whose source anchor is `anchor`, or -1. Used to map
# a tx-tree ancestor back to a live dom element while bubbling.
def _dom_by_anchor(anchor: int32) -> int32:
    if anchor < 0:
        return -1
    j: int32 = 0
    while j < dom_n:
        if dom_anchor[j] == anchor:
            return j
        j = j + 1
    return -1


# Dispatch event `evtobj` (of kind 0 click / 1 input / 2 change / 3 submit) at
# target dom element `target_el`, bubbling target -> ancestors up the source
# tree. Fires each element's handlers via _fire_handler, sets event.target once
# and event.currentTarget per level, and stops when stopPropagation() was called.
# Resets g_prevent_default / g_stop_prop at the start. Returns 1 if any handler
# ran. Capture phase is not modelled (bubble phase only — see the gate notes).
def _dispatch_event(target_el: int32, kind: int32, evtobj: int32) -> int32:
    g_prevent_default = 0
    g_stop_prop = 0
    g_cur_event = evtobj
    ran: int32 = 0
    if evtobj >= 0:
        js_set_prop(evtobj, cast[Ptr[uint8]]("target"), 6, dom_obj[target_el])
    cur: int32 = target_el
    while cur >= 0:
        if evtobj >= 0:
            js_set_prop(evtobj, cast[Ptr[uint8]]("currentTarget"), 13, dom_obj[cur])
        if _fire_handler(cur, kind, evtobj) != 0:
            ran = 1
        if g_stop_prop != 0:
            cur = -1
        else:
            # climb to the nearest registered ancestor element in the source tree.
            tn: int32 = _tx_by_anchor(dom_anchor[cur])
            cur = -1
            if tn >= 0:
                t: int32 = tx_parent[tn]
                while t >= 0:
                    de: int32 = _dom_by_anchor(tx_anchor[t])
                    if de >= 0:
                        cur = de
                        t = -1
                    else:
                        t = tx_parent[t]
    g_cur_event = -1
    return ran


def he_dom_click_index(idx: int32) -> int32:
    if js_ctx_live == 0 or idx < 0 or idx >= dom_n:
        return 0
    # a real click routes through the same bubbling dispatch core as
    # el.dispatchEvent(), so ancestor click listeners fire.
    ev: int32 = _new_event_obj()
    js_set_prop(ev, cast[Ptr[uint8]]("type"), 4, \
                js_new_string(cast[Ptr[uint8]]("click"), 5))
    if _dispatch_event(idx, 0, ev) == 0:
        return 0
    _dom_readback()
    _js_capture_console()
    _relayout()
    return 1


# Look up a registered DOM element by id, registering it on demand (the JS
# context must be live). Returns its dom index, or -1.
# Locate a form control's start tag by its `name="..."` attribute (the id-less
# case). Real forms — google.com's `<input name="q">` — identify controls by
# `name`, not `id`, so field resolution must fall back to it. Returns 1 and sets
# g_el_lt (like _dom_find_by_id) when found.
def _dom_find_by_name(idp: Ptr[uint8], idn: int32) -> int32:
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           src_ptr[i + 1] != 47 and src_ptr[i + 1] != 33 and \
           src_ptr[i + 1] != 63:
            ts: uint64 = i + 1
            je: uint64 = ts
            while je < src_len and src_ptr[je] != 62:
                je = je + 1
            # only match form controls (input/textarea/select/button/form) so a
            # `<meta name=…>` or `<a name=…>` can't shadow the field.
            if _tagname_is(ts, cast[Ptr[uint8]]("input")) != 0 or \
               _tagname_is(ts, cast[Ptr[uint8]]("textarea")) != 0 or \
               _tagname_is(ts, cast[Ptr[uint8]]("select")) != 0 or \
               _tagname_is(ts, cast[Ptr[uint8]]("button")) != 0 or \
               _tagname_is(ts, cast[Ptr[uint8]]("form")) != 0:
                if _find_attr(ts, je, cast[Ptr[uint8]]("name")) != 0:
                    if _idbytes_eq(g_attr_start, g_attr_end, idp, idn) != 0:
                        return _scan_start_tag(i)
            i = je
        i = i + 1
    return 0


def _lookup_or_register(idp: Ptr[uint8], idn: int32) -> int32:
    e: int32 = _dom_lookup_id(idp, idn)
    if e >= 0:
        return e
    if _dom_find_by_id(idp, idn) != 0:
        _dom_register_el()
        return _dom_lookup_anchor(cast[int32](g_el_lt))
    # id-less form control (google uses `name="q"`, no id) -> resolve by name
    if _dom_find_by_name(idp, idn) != 0:
        _dom_register_el()
        return _dom_lookup_anchor(cast[int32](g_el_lt))
    return -1


# Build a minimal event object exposing preventDefault()/stopPropagation() and
# the type/target/defaultPrevented properties handlers read.
def _new_event_obj() -> int32:
    ev: int32 = js_new_object_v()
    js_set_prop(ev, cast[Ptr[uint8]]("preventDefault"), 14, \
                js_new_native_fn(js_hbase + NID_PREVENT))
    js_set_prop(ev, cast[Ptr[uint8]]("stopPropagation"), 15, \
                js_new_native_fn(js_hbase + NID_STOPPROP))
    js_set_prop(ev, cast[Ptr[uint8]]("defaultPrevented"), 16, js_bool(0))
    js_set_prop(ev, cast[Ptr[uint8]]("target"), 6, js_null())
    js_set_prop(ev, cast[Ptr[uint8]]("type"), 4, js_new_string(&dom_txtbuf[0], 0))
    return ev


# Programmatically set a form field's value (input/textarea/select) by element
# id, then fire its oninput + onchange handlers and re-lay-out so the change
# renders. The pointer-free equivalent of a user typing into a field. Returns 1
# on success (JS context live + element found).
def he_dom_set_value(idp: Ptr[uint8], idn: int32, valp: Ptr[uint8], \
                     valn: int32) -> int32:
    if js_ctx_live == 0:
        return 0
    idx: int32 = _lookup_or_register(idp, idn)
    if idx < 0:
        return 0
    js_set_prop(dom_obj[idx], cast[Ptr[uint8]]("value"), 5, \
                js_new_string(valp, cast[uint64](valn)))
    _fire_handler(idx, 1, -1)                             # oninput
    _fire_handler(idx, 2, -1)                             # onchange
    _dom_readback()
    _js_capture_console()
    _relayout()
    return 1


# Radio-group exclusivity: `keep` is a radio that just became checked; uncheck
# every OTHER radio sharing its `name`. Scans the whole source so all group
# members are registered (and thus re-rendered) even if the page never named
# them from JS. A no-op for non-radios or unnamed radios.
def _radio_enforce_group(keep: int32):
    kobj: int32 = dom_obj[keep]
    ktv: int32 = js_get_prop(kobj, cast[Ptr[uint8]]("type"), 4)
    ktp: Ptr[uint8] = js_str_ptr(ktv)
    if _bytes_eq(ktp, _cstr_len(ktp), cast[Ptr[uint8]]("radio"), 5) == 0:
        return
    knv: int32 = js_get_prop(kobj, cast[Ptr[uint8]]("name"), 4)
    knp: Ptr[uint8] = js_str_ptr(knv)
    knn: int32 = _cstr_len(knp)
    if knn == 0 or _is_undef_str(knp, knn) != 0:
        return
    # copy the name out of the shared JS scratch before further js_get_prop calls.
    kk: int32 = 0
    while kk < knn and kk < 127:
        g_radioname[kk] = knp[kk]
        kk = kk + 1
    g_radioname_len = kk
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           _tagname_is(i + 1, cast[Ptr[uint8]]("input")) != 0:
            _scan_start_tag(i)
            skip_to: uint64 = g_close_end
            ei: int32 = _dom_lookup_anchor(cast[int32](g_el_lt))
            if ei < 0:
                _dom_register_el()
                ei = _dom_lookup_anchor(cast[int32](g_el_lt))
            if ei >= 0 and ei != keep:
                eo: int32 = dom_obj[ei]
                etv: int32 = js_get_prop(eo, cast[Ptr[uint8]]("type"), 4)
                etp: Ptr[uint8] = js_str_ptr(etv)
                if _bytes_eq(etp, _cstr_len(etp), cast[Ptr[uint8]]("radio"), 5) != 0:
                    env: int32 = js_get_prop(eo, cast[Ptr[uint8]]("name"), 4)
                    enp: Ptr[uint8] = js_str_ptr(env)
                    if _bytes_eq(enp, _cstr_len(enp), &g_radioname[0], \
                                 g_radioname_len) != 0:
                        js_set_prop(eo, cast[Ptr[uint8]]("checked"), 7, js_bool(0))
            i = skip_to
            continue
        i = i + 1


# Set a checkbox/radio's checked state by id, fire oninput + onchange, re-lay.
def he_dom_set_checked(idp: Ptr[uint8], idn: int32, checked: int32) -> int32:
    if js_ctx_live == 0:
        return 0
    idx: int32 = _lookup_or_register(idp, idn)
    if idx < 0:
        return 0
    js_set_prop(dom_obj[idx], cast[Ptr[uint8]]("checked"), 7, js_bool(checked))
    if checked != 0:
        _radio_enforce_group(idx)
    _fire_handler(idx, 1, -1)
    _fire_handler(idx, 2, -1)
    _dom_readback()
    _js_capture_console()
    _relayout()
    return 1


# ---- form submission + GET serialization ---------------------------
def _nav_putc(c: uint8):
    if dom_nav_len < 2047:
        dom_nav_buf[dom_nav_len] = c
        dom_nav_len = dom_nav_len + 1


# Append `p[0..n)` URL-form-encoded: space -> '+', unreserved kept, else '_'.
def _nav_encoded(p: Ptr[uint8], n: int32):
    i: int32 = 0
    while i < n:
        c: uint8 = p[i]
        if c == 32:
            _nav_putc(43)                                # '+'
        elif (c >= 97 and c <= 122) or (c >= 65 and c <= 90) or \
             (c >= 48 and c <= 57) or c == 45 or c == 46 or c == 95:
            _nav_putc(c)
        else:
            _nav_putc(95)                                # '_'
        i = i + 1


# Serialize the form at dom index `fi` into dom_nav_buf as "?a=1&b=2", reading
# each named field's current value/checked from its (registered) JS object.
def _serialize_form(fi: int32):
    dom_nav_len = 0
    # Prepend the form's action target (raw, un-encoded — a path keeps its '/')
    # so a search submits to "/search?q=cats", not the current page's "?q=cats".
    # Empty/absent action serializes to a bare "?..." (submit to current URL,
    # which is the HTML default).
    ats: uint64 = cast[uint64](dom_anchor[fi])
    ate: uint64 = cast[uint64](dom_cstart[fi])
    act_has_q: int32 = 0
    if dom_anchor[fi] >= 0 and \
       _find_attr(ats, ate, cast[Ptr[uint8]]("action")) != 0 and \
       g_attr_end > g_attr_start:
        ap: uint64 = g_attr_start
        while ap < g_attr_end:
            ac: uint8 = src_ptr[ap]
            if ac == 63:                                 # action already has '?'
                act_has_q = 1
            _nav_putc(ac)
            ap = ap + 1
    # Separate the query from the path: '?' for the first param, '&' when the
    # action already carried a query string.
    if act_has_q != 0:
        _nav_putc(38)                                    # '&'
    else:
        _nav_putc(63)                                    # '?'
    first: int32 = 1
    cs: uint64 = cast[uint64](dom_cstart[fi])
    ce: uint64 = cast[uint64](dom_cend[fi])
    i: uint64 = cs
    while i < ce:
        if src_ptr[i] == 60 and i + 1 < ce and \
           (_tagname_is(i + 1, cast[Ptr[uint8]]("input")) != 0 or \
            _tagname_is(i + 1, cast[Ptr[uint8]]("select")) != 0 or \
            _tagname_is(i + 1, cast[Ptr[uint8]]("textarea")) != 0):
            _scan_start_tag(i)
            skip_to: uint64 = g_close_end
            ei: int32 = _dom_lookup_anchor(cast[int32](g_el_lt))
            if ei < 0:
                _dom_register_el()
                ei = _dom_lookup_anchor(cast[int32](g_el_lt))
            if ei >= 0:
                _serialize_field(ei, &first)
            i = skip_to
            continue
        i = i + 1
    dom_nav_present = 1


# Emit one field's name=value pair into the nav buffer (if it carries a name and
# is a successful control). *first tracks whether a '&' separator is needed.
def _serialize_field(ei: int32, first: Ptr[int32]):
    obj: int32 = dom_obj[ei]
    nmv: int32 = js_get_prop(obj, cast[Ptr[uint8]]("name"), 4)
    np: Ptr[uint8] = js_str_ptr(nmv)
    nn: int32 = _cstr_len(np)
    if nn == 0 or _is_undef_str(np, nn) != 0:
        return
    # copy the name out of the shared scratch before reading other props.
    kk: int32 = 0
    while kk < nn and kk < 127:
        g_nmtmp[kk] = np[kk]
        kk = kk + 1
    nn2: int32 = kk
    # a checkbox/radio contributes only when checked.
    if dom_origchecked[ei] >= 0:
        ckv: int32 = js_get_prop(obj, cast[Ptr[uint8]]("checked"), 7)
        if js_to_bool(ckv) == 0:
            return
    # submit/reset/button inputs are not serialized.
    tyv: int32 = js_get_prop(obj, cast[Ptr[uint8]]("type"), 4)
    typ: Ptr[uint8] = js_str_ptr(tyv)
    tyn: int32 = _cstr_len(typ)
    if _bytes_eq(typ, tyn, cast[Ptr[uint8]]("submit"), 6) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("reset"), 5) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("button"), 6) != 0:
        return
    if first[0] == 0:
        _nav_putc(38)                                    # '&'
    first[0] = 0
    _nav_encoded(&g_nmtmp[0], nn2)
    _nav_putc(61)                                        # '='
    vv: int32 = js_get_prop(obj, cast[Ptr[uint8]]("value"), 5)
    vp: Ptr[uint8] = js_str_ptr(vv)
    vn: int32 = _cstr_len(vp)
    if _is_undef_str(vp, vn) != 0:
        vn = 0
    _nav_encoded(vp, vn)


# Shared submit core: dispatch a cancelable `submit` event at form `idx` that
# BUBBLES to ancestor listeners (round 8 dispatch), and — only if no handler
# called preventDefault() — GET-serialize the form's named controls into the
# nav buffer. Used by the host entry points AND the JS form.submit() method.
def _do_submit(idx: int32):
    ev: int32 = _new_event_obj()
    js_set_prop(ev, cast[Ptr[uint8]]("type"), 4, \
                js_new_string(cast[Ptr[uint8]]("submit"), 6))
    _dispatch_event(idx, 3, ev)                          # resets g_prevent_default
    _dom_readback()
    _js_capture_console()
    if g_prevent_default == 0:
        _serialize_form(idx)
    _relayout()


def he_dom_submit(idp: Ptr[uint8], idn: int32) -> int32:
    if js_ctx_live == 0:
        return 0
    idx: int32 = _lookup_or_register(idp, idn)
    if idx < 0:
        return 0
    _do_submit(idx)
    return 1


def he_nav_ptr() -> Ptr[uint8]:
    dom_nav_buf[dom_nav_len] = 0
    return &dom_nav_buf[0]


def he_nav_len() -> uint64:
    return cast[uint64](dom_nav_len)


def he_nav_present() -> int32:
    return dom_nav_present


# Clear a consumed navigation request so the next poll doesn't re-fire it. The
# native front-end calls this immediately after it has read he_nav_ptr/len and
# started the fetch, so a stale request can't loop.
def he_nav_clear():
    dom_nav_present = 0
    dom_nav_len = 0


# ---- native pointer/keyboard field interaction (index-based) --------
# The native front-end hit-tests a pointer click to a DOM element index (via the
# synthetic "#__evt_N" link wrap + he_link_evt_index), then asks these whether
# that element is a typing target or a submit control, edits it per-keystroke,
# and submits its enclosing form on Enter / a submit-button click.

# Resolve an element id to its DOM index (registering on demand), or -1. The
# native front-end addresses fields by the index its pointer hit-test yields;
# the host gate uses this to drive the same index-based chain from an id.
def he_dom_id_index(idp: Ptr[uint8], idn: int32) -> int32:
    if js_ctx_live == 0:
        return -1
    return _lookup_or_register(idp, idn)


# Is element `idx` a text-typing control (a textarea, or an <input> that is not
# a checkbox/radio/submit/button/reset/hidden)? Requires a live JS context (the
# element's `type` is read from its DOM object).
def he_dom_is_textfield(idx: int32) -> int32:
    if js_ctx_live == 0 or idx < 0 or idx >= dom_n:
        return 0
    if dom_kind[idx] == 2:                                # <textarea>
        return 1
    if dom_kind[idx] != 1:                                # not <input>
        return 0
    if dom_origchecked[idx] >= 0:                         # checkbox / radio
        return 0
    tyv: int32 = js_get_prop(dom_obj[idx], cast[Ptr[uint8]]("type"), 4)
    typ: Ptr[uint8] = js_str_ptr(tyv)
    tyn: int32 = _cstr_len(typ)
    if _bytes_eq(typ, tyn, cast[Ptr[uint8]]("submit"), 6) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("button"), 6) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("reset"), 5) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("hidden"), 6) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("checkbox"), 8) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("radio"), 5) != 0:
        return 0
    return 1


# Is element `idx` a submit control (<input type=submit> or a <button>, whose
# default type is submit)? Such a click submits the enclosing form.
def he_dom_is_submit(idx: int32) -> int32:
    if js_ctx_live == 0 or idx < 0 or idx >= dom_n:
        return 0
    if dom_kind[idx] == 4:                                # <button>
        return 1
    if dom_kind[idx] != 1:
        return 0
    tyv: int32 = js_get_prop(dom_obj[idx], cast[Ptr[uint8]]("type"), 4)
    typ: Ptr[uint8] = js_str_ptr(tyv)
    tyn: int32 = _cstr_len(typ)
    if _bytes_eq(typ, tyn, cast[Ptr[uint8]]("submit"), 6) != 0:
        return 1
    return 0


# The dom index of the <form> enclosing element `idx` (the innermost form whose
# inner-content span contains the element's source anchor), or -1. Used to
# submit the form when Enter is pressed in a field or a submit button is clicked.
def he_dom_field_form(idx: int32) -> int32:
    if idx < 0 or idx >= dom_n:
        return -1
    a: int32 = dom_anchor[idx]
    if a < 0:
        return -1
    best: int32 = -1
    f: int32 = 0
    while f < dom_n:
        if dom_kind[f] == 5 and dom_cstart[f] <= a and a < dom_cend[f]:
            best = f                                      # innermost = last match
        f = f + 1
    return best


# Set element `idx`'s value to valp[0..valn) and fire its oninput handler, then
# re-lay-out so the typed text renders in the field box. The per-keystroke
# equivalent of he_dom_set_value but addressed by index (the front-end already
# has the hit-tested element index; no id string needed). onchange fires on
# submit/blur, not on every keystroke, so only oninput runs here.
def he_dom_set_value_index(idx: int32, valp: Ptr[uint8], valn: int32) -> int32:
    if js_ctx_live == 0 or idx < 0 or idx >= dom_n:
        return 0
    js_set_prop(dom_obj[idx], cast[Ptr[uint8]]("value"), 5, \
                js_new_string(valp, cast[uint64](valn)))
    _fire_handler(idx, 1, -1)                             # oninput
    _dom_readback()
    _js_capture_console()
    _relayout()
    return 1


# Copy element `idx`'s current value into out[0..cap) (NUL-terminated); return
# its length. The front-end seeds its per-field edit buffer from this when a
# field is focused so pre-filled text isn't lost on the first keystroke.
def he_dom_get_value(idx: int32, out: Ptr[uint8], cap: int32) -> int32:
    if js_ctx_live == 0 or idx < 0 or idx >= dom_n or cap <= 0:
        out[0] = 0
        return 0
    vv: int32 = js_get_prop(dom_obj[idx], cast[Ptr[uint8]]("value"), 5)
    vp: Ptr[uint8] = js_str_ptr(vv)
    vn: int32 = _cstr_len(vp)
    if _is_undef_str(vp, vn) != 0:
        vn = 0
    k: int32 = 0
    while k < vn and k < cap - 1:
        out[k] = vp[k]
        k = k + 1
    out[k] = 0
    return k


# Submit the form at dom index `idx` (fire onsubmit; GET-serialize into the nav
# buffer if not preventDefault'd). Index-based twin of he_dom_submit.
def he_dom_submit_index(idx: int32) -> int32:
    if js_ctx_live == 0 or idx < 0 or idx >= dom_n:
        return 0
    _do_submit(idx)
    return 1


# Dispatch a click to the element with id idp[0..idn). Returns 1 if a handler
# ran, 0 otherwise. This is the programmatic, pointer-free dispatch used by the
# host gate AND (via he_dom_click_index) the native pointer path.
def he_dom_click(idp: Ptr[uint8], idn: int32) -> int32:
    # Register the target on demand so an element whose only handler is an
    # inline onclick="" (never touched by a <script>) still gets its handler
    # captured before dispatch.
    if js_ctx_live == 0:
        return 0
    return he_dom_click_index(_lookup_or_register(idp, idn))


# Does the DOM element at `idx` carry a click handler?
def _el_has_handler(idx: int32) -> int32:
    if dom_onclick_fn[idx] >= 0 or dom_onclick_src[idx] >= 0:
        return 1
    return 0


# Native front-ends (he_click_links) make in-page form controls pointer-
# reachable by wrapping each in a synthetic "#__evt_N" link (the SAME hit-test
# path as click-handler elements), so a pointer click resolves to the control's
# DOM index. A "wrappable field" is a text-typing control or a submit button.
def _is_wrappable_field(idx: int32) -> int32:
    if he_click_links == 0:
        return 0
    if he_dom_is_textfield(idx) != 0:
        return 1
    if he_dom_is_submit(idx) != 0:
        return 1
    return 0


# Count elements the native rewrite must wrap in a "#__evt_N" link: click-
# handler elements AND focusable/submit form controls. Non-zero forces the
# rewrite path even when no script mutated the DOM (a plain form still needs its
# fields to be pointer-reachable). Host renders (he_click_links==0) return 0.
def _n_wrappable() -> int32:
    if he_click_links == 0:
        return 0
    c: int32 = 0
    i: int32 = 0
    while i < dom_n:
        if _el_has_handler(i) != 0 or _is_wrappable_field(i) != 0:
            c = c + 1
        i = i + 1
    return c


# Does the source contain a <form> (so a script-less page still warrants a live
# JS context + form registration for native pointer/type/submit)?
def _page_has_form() -> int32:
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           _tagname_is(i + 1, cast[Ptr[uint8]]("form")) != 0:
            return 1
        i = i + 1
    return 0


# If link `lid`'s href is the synthetic "#__evt_N" the native rewrite injects
# around a click-handler element, return the DOM record index N; else -1. The
# native front-end calls this on a hit-tested link to route a pointer click to
# he_dom_click_index instead of navigating.
def he_link_evt_index(lid: int32) -> int32:
    if lid < 0 or cast[uint64](lid) >= n_links:
        return -1
    o: uint64 = cast[uint64](link_off[lid])
    l: int32 = link_len[lid]
    pfx: Ptr[uint8] = cast[Ptr[uint8]]("#__evt_")
    k: int32 = 0
    while k < 7:
        if k >= l or link_href_buf[o + cast[uint64](k)] != pfx[k]:
            return -1
        k = k + 1
    v: int32 = 0
    while k < l:
        c: uint8 = link_href_buf[o + cast[uint64](k)]
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[int32](c) - 48
        k = k + 1
    return v


# Native front-ends set this to 1 so the rewrite wraps click-handler elements
# in a synthetic "#__evt_N" link, reusing the existing pointer link hit-test
# for event dispatch. Host/default stays 0 so its render is byte-for-byte the
# same as with no handlers (keeps the host gate output stable).
def he_set_click_links(v: int32):
    he_click_links = v


# Format a packed 0xRRGGBB into a "#rrggbb\0" string in `out` (>= 8 bytes).
def he_rgb_hex(rgb: int32, out: Ptr[uint8]):
    out[0] = 35                                       # '#'
    hexd: Ptr[uint8] = cast[Ptr[uint8]]("0123456789abcdef")
    k: int32 = 0
    while k < 6:
        shift: int32 = (5 - k) * 4
        nib: int32 = (rgb / (1 << shift)) & 15
        out[1 + k] = hexd[nib]
        k = k + 1
    out[7] = 0


# Resolve segment `si` to a "#rrggbb\0" colour string in the caller's buffer
# (>= 8 bytes). Explicit CSS colour wins; otherwise the role palette.
def he_seg_color_hex(si: uint64, out: Ptr[uint8]):
    rgb: int32 = seg_rgb[si]
    if rgb < 0:
        rgb = _palette_rgb(seg_color[si])
    he_rgb_hex(rgb, out)


# ---- accessors for the graphical (htmlpaint) pixel backend -----------
# The pixel renderer (lib/htmlpaint.ad, driven by user/hambrowse*_gfx) reads
# the laid-out segment table through these instead of reaching into globals,
# so the same engine feeds both the legacy monospace-grid dump and the new
# proportional-font pixel paint.
def he_n_segs() -> uint64:
    return n_segs


def he_total_rows() -> uint64:
    return total_rows


def he_page_width() -> int32:
    return bw


# Page-level background colour (0xRRGGBB) from <body>/<html>, or -1 for the
# default white. The pixel renderer clears the whole canvas to this (gap #3).
def he_page_bg() -> int32:
    return g_page_bg


def he_seg_line(si: uint64) -> int32:
    return seg_line[si]


def he_seg_x(si: uint64) -> int32:
    return seg_x[si]


def he_seg_off(si: uint64) -> int32:
    return seg_off[si]


def he_seg_len(si: uint64) -> int32:
    return seg_len[si]


def he_seg_text_ptr() -> Ptr[uint8]:
    return &seg_text_buf[0]


def he_seg_face(si: uint64) -> uint8:
    return seg_face[si]


def he_seg_gridx(si: uint64) -> int32:
    return cast[int32](seg_gridx[si])


# CSS font-size (px) for this segment, or 0 = use the face default.
def he_seg_pxsize(si: uint64) -> int32:
    return seg_pxsize[si]


# CSS line-height resolved to PIXELS (the line-box pitch) for this segment, or
# 0 = use the renderer's default vertical rhythm.
def he_seg_lineh(si: uint64) -> int32:
    return seg_lineh[si]


def he_seg_bold(si: uint64) -> int32:
    return cast[int32](seg_bold[si])


def he_seg_uline(si: uint64) -> int32:
    return cast[int32](seg_uline[si])


# Signed baseline offset (px): <0 raises (<sup>), >0 lowers (<sub>), 0 normal.
def he_seg_yoff(si: uint64) -> int32:
    return seg_yoff[si]


# 1 if segment si carries a line-through (<s>/<del>/<strike>).
def he_seg_strike(si: uint64) -> int32:
    return cast[int32](seg_strike[si])


def he_seg_link(si: uint64) -> int32:
    return seg_link[si]


def he_seg_bg(si: uint64) -> int32:
    return seg_bg[si]


# Effective 0xRRGGBB for segment si (explicit CSS colour, else role palette).
def he_seg_rgb(si: uint64) -> int32:
    rgb: int32 = seg_rgb[si]
    if rgb < 0:
        rgb = _palette_rgb(seg_color[si])
    return rgb


def he_row_rule(r: uint64) -> uint8:
    return row_rule[r]


# ---- <img> segment + src-registry accessors -------------------------
# he_seg_img: decoded-image slot for segment si, -1 = text seg, -2 = broken.
def he_seg_img(si: uint64) -> int32:
    return seg_img[si]


def he_seg_imgw(si: uint64) -> int32:
    return seg_imgw[si]


def he_seg_imgh(si: uint64) -> int32:
    return seg_imgh[si]


# 1 if segment si is ASCII box-art (border glyphs). The pixel renderer skips
# these and strokes real rectangles from the border-box registry instead.
def he_seg_boxart(si: uint64) -> int32:
    return cast[int32](seg_boxart[si])


# 1 if segment si is an unordered-list bullet marker. The pixel renderer draws
# a real round disc for it (in the gutter) instead of painting the placeholder.
def he_seg_marker(si: uint64) -> int32:
    return cast[int32](seg_marker[si])


# 1 if segment si is a list item's first text run: the pixel renderer jumps the
# pen forward to seg_x so the hanging indent (marker gutter) is preserved.
def he_seg_indjump(si: uint64) -> int32:
    return cast[int32](seg_indjump[si])


# ---- pixel border-box registry accessors ----------------------------
def he_n_bboxes() -> int32:
    return n_bboxes


def he_bbox_lx(i: int32) -> int32:
    return bbox_lx[i]


def he_bbox_rx(i: int32) -> int32:
    return bbox_rx[i]


def he_bbox_top(i: int32) -> int32:
    return bbox_top[i]


def he_bbox_bot(i: int32) -> int32:
    return bbox_bot[i]


def he_bbox_rgb(i: int32) -> int32:
    return bbox_rgb[i]


# ---- element background-fill registry accessors ---------------------
def he_n_bfills() -> int32:
    return n_bfills


def he_bfill_lx(i: int32) -> int32:
    return bfill_lx[i]


def he_bfill_rx(i: int32) -> int32:
    return bfill_rx[i]


def he_bfill_top(i: int32) -> int32:
    return bfill_top[i]


def he_bfill_bot(i: int32) -> int32:
    return bfill_bot[i]


def he_bfill_rgb(i: int32) -> int32:
    return bfill_rgb[i]


# Stacking order (z-index) of block background fill i; 0 = default flow order.
def he_bfill_z(i: int32) -> int32:
    return bfill_z[i]


# Number of distinct <img src> strings seen in the last layout — the host
# driver iterates these to slurp + decode each PNG before a second layout pass.
def he_n_images() -> uint64:
    return n_eimg


def he_img_name_ptr(i: uint64) -> Ptr[uint8]:
    return &eimg_name_buf[eimg_noff[i]]


def he_img_name_len(i: uint64) -> uint64:
    return eimg_nlen[i]


# ====================================================================
# SCROLL helpers.
# ====================================================================
def _max_top() -> uint64:
    vr: uint64 = _vis_rows()
    if total_rows > vr:
        return total_rows - vr
    return 0


def _scroll_to(t: int64):
    mt: int64 = cast[int64](_max_top())
    if t < 0:
        t = 0
    if t > mt:
        t = mt
    top_line = cast[uint64](t)


def _scroll_by(delta: int64):
    _scroll_to(cast[int64](top_line) + delta)

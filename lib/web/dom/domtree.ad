# lib/web/dom/domtree.ad — part of the modular web engine (extracted from htmlengine.ad).
# DOM tree index build + true CSS selector combinators (descendant/child/sibling).
#
# Behavior-preserving split (single-compilation-unit; byte-identical).

from lib.htmlengine import _alnum_at, _bytes_eq, _find_close, _hx_lower, _rawtext_skip, _scan_start_tag, _sel_isname, _sel_match_at

# ====================================================================
# DOM tree index build + true selector combinators (task #324).
# ====================================================================

# Build the integer tree overlay for the current (comment-stripped) source.
# One left-to-right pass over every start tag; a span stack recovers nesting
# (an element's parent is the innermost still-open enclosing element). Void /
# self-closing elements get an empty content span (_find_close returns `from`
# on a miss) so nothing nests inside them. Idempotent per page.
def _dom_build_tree_index():
    tx_n = 0
    sp: int32 = 0
    i: uint64 = 0
    while i < src_len and tx_n < TX_MAX:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           src_ptr[i + 1] != 47 and src_ptr[i + 1] != 33 and \
           src_ptr[i + 1] != 63:
            ts: uint64 = i + 1
            je: uint64 = ts
            while je < src_len and src_ptr[je] != 62:
                je = je + 1
            ne: uint64 = ts
            while ne < je and _alnum_at(ne) != 0:
                ne = ne + 1
            if ne > ts:                                   # a real named element
                _find_close(ts, ne - ts, je + 1)
                cs: int32 = cast[int32](je + 1)
                ce: int32 = cast[int32](g_close_lt)
                if ce < cs:
                    ce = cs
                anchor: int32 = cast[int32](i)
                while sp > 0 and tx_ce[tx_stack[sp - 1]] <= anchor:
                    sp = sp - 1
                par: int32 = -1
                if sp > 0:
                    par = tx_stack[sp - 1]
                k: int32 = tx_n
                tx_anchor[k] = anchor
                tx_cs[k] = cs
                tx_ce[k] = ce
                tx_ns[k] = cast[int32](ts)
                tx_nl[k] = cast[int32](ne - ts)
                tx_parent[k] = par
                tx_n = k + 1
                if sp < TX_MAX:
                    tx_stack[sp] = k
                    sp = sp + 1
            rt: uint64 = _rawtext_skip(ts, ne, je)        # index the script/style
            if rt != 0:                                   # node, but skip its body
                i = rt
                continue
            i = je
        i = i + 1
    tx_built = 1


# tx index whose '<' is at source offset `anchor`, or -1.
def _tx_by_anchor(anchor: int32) -> int32:
    j: int32 = 0
    while j < tx_n:
        if tx_anchor[j] == anchor:
            return j
        j = j + 1
    return -1


# Previous / next ELEMENT sibling of tx entry `t` (same parent, doc order).
def _tx_prev_sibling(t: int32) -> int32:
    par: int32 = tx_parent[t]
    r: int32 = -1
    j: int32 = 0
    while j < t:
        if tx_parent[j] == par:
            r = j
        j = j + 1
    return r


def _tx_next_sibling(t: int32) -> int32:
    par: int32 = tx_parent[t]
    j: int32 = t + 1
    while j < tx_n:
        if tx_parent[j] == par:
            return j
        j = j + 1
    return -1


# 1-based element-child index of `t` under its parent (for :nth-child).
def _tx_child_index(t: int32) -> int32:
    par: int32 = tx_parent[t]
    n: int32 = 0
    j: int32 = 0
    while j <= t:
        if tx_parent[j] == par:
            n = n + 1
        j = j + 1
    return n


# 1-based element-child index of `t` counted from the END (for :nth-last-child
# and :last-child fast-paths).
def _tx_child_index_from_end(t: int32) -> int32:
    par: int32 = tx_parent[t]
    n: int32 = 0
    j: int32 = t
    while j < tx_n:
        if tx_parent[j] == par:
            n = n + 1
        j = j + 1
    return n


# Case-insensitive tag-name equality between two tx entries (element type).
def _tx_type_eq(a: int32, b: int32) -> int32:
    la: int32 = tx_nl[a]
    if la != tx_nl[b]:
        return 0
    ai: uint64 = cast[uint64](tx_ns[a])
    bi: uint64 = cast[uint64](tx_ns[b])
    k: int32 = 0
    while k < la:
        if _hx_lower(src_ptr[ai + cast[uint64](k)]) != \
           _hx_lower(src_ptr[bi + cast[uint64](k)]):
            return 0
        k = k + 1
    return 1


# 1-based index of `t` among same-parent siblings of the SAME element type
# (for :nth-of-type / :first-of-type). Counted from document start.
def _tx_of_type_index(t: int32) -> int32:
    par: int32 = tx_parent[t]
    n: int32 = 0
    j: int32 = 0
    while j <= t:
        if tx_parent[j] == par and _tx_type_eq(j, t) != 0:
            n = n + 1
        j = j + 1
    return n


# Same-type index counted from the END (for :nth-last-of-type / :last-of-type).
def _tx_of_type_index_from_end(t: int32) -> int32:
    par: int32 = tx_parent[t]
    n: int32 = 0
    j: int32 = t
    while j < tx_n:
        if tx_parent[j] == par and _tx_type_eq(j, t) != 0:
            n = n + 1
        j = j + 1
    return n


# :empty — no element children and only-whitespace text content.
def _tx_is_empty(t: int32) -> int32:
    j: int32 = 0
    while j < tx_n:
        if tx_parent[j] == t:
            return 0
        j = j + 1
    a: uint64 = cast[uint64](tx_cs[t])
    b: uint64 = cast[uint64](tx_ce[t])
    while a < b:
        c: uint8 = src_ptr[a]
        if c != 32 and c != 9 and c != 10 and c != 13:
            return 0
        a = a + 1
    return 1


# Parse a signed decimal integer from g_selbuf[s..e); leading spaces tolerated.
# A bare sign / empty span reads as 0 (callers special-case those).
def _parse_sint(s: int32, e: int32) -> int32:
    i: int32 = s
    while i < e and g_selbuf[i] == 32:
        i = i + 1
    neg: int32 = 0
    if i < e and (g_selbuf[i] == 43 or g_selbuf[i] == 45):
        if g_selbuf[i] == 45:
            neg = 1
        i = i + 1
    v: int32 = 0
    while i < e and g_selbuf[i] >= 48 and g_selbuf[i] <= 57:
        v = v * 10 + cast[int32](g_selbuf[i] - 48)
        i = i + 1
    if neg != 0:
        return 0 - v
    return v


# :nth-child(An+B) micro-syntax parser over g_selbuf[s..e). Sets g_nth_a/g_nth_b.
# Accepts: even (2n), odd (2n+1), a bare integer B (A=0), and the [±][d]n[±d]
# forms — n, -n, 2n, 2n+1, n+3, -n+3, 3n-2 — with whitespace tolerated.
g_nth_a: int32 = 0
g_nth_b: int32 = 0
def _parse_nth(s: int32, e: int32):
    g_nth_a = 0
    g_nth_b = 0
    i: int32 = s
    while i < e and g_selbuf[i] == 32:
        i = i + 1
    j: int32 = e
    while j > i and g_selbuf[j - 1] == 32:
        j = j - 1
    if _bytes_eq(&g_selbuf[i], j - i, cast[Ptr[uint8]]("even"), 4) != 0:
        g_nth_a = 2
        g_nth_b = 0
        return
    if _bytes_eq(&g_selbuf[i], j - i, cast[Ptr[uint8]]("odd"), 3) != 0:
        g_nth_a = 2
        g_nth_b = 1
        return
    # locate the 'n'/'N' (if any)
    npos: int32 = -1
    k: int32 = i
    while k < j:
        if g_selbuf[k] == 110 or g_selbuf[k] == 78:       # 'n' 'N'
            npos = k
            k = j
        else:
            k = k + 1
    if npos < 0:
        # a plain integer B (A stays 0)
        g_nth_b = _parse_sint(i, j)
        return
    # coefficient A: span [i, npos), trimmed
    ca: int32 = i
    ce: int32 = npos
    while ca < ce and g_selbuf[ca] == 32:
        ca = ca + 1
    while ce > ca and g_selbuf[ce - 1] == 32:
        ce = ce - 1
    if ce == ca:
        g_nth_a = 1
    elif ce - ca == 1 and g_selbuf[ca] == 43:             # bare '+'
        g_nth_a = 1
    elif ce - ca == 1 and g_selbuf[ca] == 45:             # bare '-'
        g_nth_a = -1
    else:
        g_nth_a = _parse_sint(ca, ce)
    # offset B: span (npos, j)
    bs: int32 = npos + 1
    while bs < j and g_selbuf[bs] == 32:
        bs = bs + 1
    if bs >= j:
        g_nth_b = 0
    else:
        g_nth_b = _parse_sint(bs, j)


# Does the 1-based child index `idx` satisfy idx == A*k + B for some integer
# k >= 0? Divisibility + non-negative quotient covers both signs of A.
def _nth_match(idx: int32, a: int32, b: int32) -> int32:
    if a == 0:
        if idx == b:
            return 1
        return 0
    d: int32 = idx - b
    if d == 0:
        return 1
    kk: int32 = d / a
    if kk >= 0 and a * kk == d:
        return 1
    return 0


# ---- selector parse: split into compound[] + combinator[] ----------
# g_comb[c] is the combinator LINKING compound c-1 (left) to compound c
# (right): 32 ' ' descendant, 62 '>' child, 43 '+' adjacent, 126 '~' general.
# g_comb[0] is unused. The selector bytes are copied into g_selbuf so the
# matchers are re-entrancy-safe against the query scan. g_sel_adv is set when the
# selector needs the tree (a combinator, or a structural pseudo-class).
g_selbuf:   Array[256, uint8]
g_seln:     int32 = 0
g_nc:       int32 = 0
g_comp_off: Array[8, int32]
g_comp_len: Array[8, int32]
g_comb:     Array[8, uint8]
g_sel_adv:      int32 = 0


def _sel_parse(sel: Ptr[uint8], seln: int32):
    n: int32 = seln
    if n > 255:
        n = 255
    k: int32 = 0
    while k < n:
        g_selbuf[k] = sel[k]
        k = k + 1
    g_seln = n
    g_nc = 0
    g_sel_adv = 0
    i: int32 = 0
    pending: uint8 = 0
    while i < n and g_nc < 8:
        sawspace: int32 = 0
        while i < n and g_selbuf[i] == 32:
            sawspace = 1
            i = i + 1
        if i >= n:
            break
        c: uint8 = g_selbuf[i]
        if c == 62 or c == 43 or c == 126:                # '>' '+' '~'
            pending = c
            i = i + 1
            while i < n and g_selbuf[i] == 32:
                i = i + 1
        elif sawspace != 0 and g_nc > 0:
            pending = 32                                  # descendant
        s: int32 = i
        while i < n:
            ch: uint8 = g_selbuf[i]
            if ch == 32 or ch == 62 or ch == 43 or ch == 126:
                break
            if ch == 91:                                  # '[' — skip to ']'
                while i < n and g_selbuf[i] != 93:
                    i = i + 1
            elif ch == 40:                                # '(' — skip a functional
                while i < n and g_selbuf[i] != 41:        # pseudo arg (e.g.
                    i = i + 1                             # :nth-child(2n+1)) to ')'
            if i < n and g_selbuf[i] == 58:               # ':' pseudo present
                g_sel_adv = 1
            i = i + 1
        if i > s:
            g_comp_off[g_nc] = s
            g_comp_len[g_nc] = i - s
            if g_nc == 0:
                g_comb[0] = 0
            else:
                g_comb[g_nc] = pending
                g_sel_adv = 1
            g_nc = g_nc + 1
            pending = 0


# ---- selector LIST (comma) split ----------------------------------
# A selector list `a, b, c` matches the UNION: querySelector returns the first
# element (document order) matching ANY sub-selector; querySelectorAll returns
# every such element in document order with no duplicates. We split the raw
# selector at TOP-LEVEL commas (commas nested inside `[...]` or `(...)` stay part
# of the component) into byte ranges over the ORIGINAL selector buffer, then the
# scan tests each candidate element against every sub-selector (first hit wins) —
# so document order + uniqueness fall out of a single left-to-right source scan.
SEL_LIST_MAX: int32 = 16
g_sellist_off: Array[16, int32]
g_sellist_len: Array[16, int32]
g_sellist_n:   int32 = 0


def _sel_split(sel: Ptr[uint8], seln: int32):
    g_sellist_n = 0
    i: int32 = 0
    while i < seln and g_sellist_n < SEL_LIST_MAX:
        while i < seln and (sel[i] == 32 or sel[i] == 9):  # leading ws
            i = i + 1
        s: int32 = i
        depthb: int32 = 0                                  # '[' ']' nesting
        depthp: int32 = 0                                  # '(' ')' nesting
        while i < seln:
            ch: uint8 = sel[i]
            if ch == 91:
                depthb = depthb + 1
            elif ch == 93:
                if depthb > 0:
                    depthb = depthb - 1
            elif ch == 40:
                depthp = depthp + 1
            elif ch == 41:
                if depthp > 0:
                    depthp = depthp - 1
            elif ch == 44 and depthb == 0 and depthp == 0:  # ',' top-level split
                break
            i = i + 1
        e: int32 = i
        while e > s and (sel[e - 1] == 32 or sel[e - 1] == 9):
            e = e - 1
        if e > s:
            g_sellist_off[g_sellist_n] = s
            g_sellist_len[g_sellist_n] = e - s
            g_sellist_n = g_sellist_n + 1
        if i < seln and sel[i] == 44:
            i = i + 1


# Does source element at src offset `i` (start-tag name span [ts,ne), body ends
# at `je`) match the single COMPLEX sub-selector sel[subo..subo+subl)? Parses it
# into g_* and applies the rightmost-compound fast filter followed by the full
# combinator/pseudo chain when the selector needs the tree (g_sel_adv).
def _complex_hit_at(sel: Ptr[uint8], subo: int32, subl: int32, i: uint64, \
                    ts: uint64, je: uint64, ne: uint64) -> int32:
    _sel_parse(&sel[subo], subl)
    if g_nc == 0:
        return 0
    rc: int32 = g_nc - 1
    rbl: int32 = 0
    while rbl < g_comp_len[rc] and g_selbuf[g_comp_off[rc] + rbl] != 58:
        rbl = rbl + 1
    hit: int32 = 0
    if rbl == 0:
        hit = 1                                            # bare pseudo (:first-child)
    elif _sel_match_at(ts, je, ne, &g_selbuf[g_comp_off[rc]], rbl) != 0:
        hit = 1
    if hit == 0:
        return 0
    if g_sel_adv == 0:
        return 1
    return _sel_adv_match(cast[int32](i))


# Does compound `c` (base + optional structural pseudo) match tx entry `t`?
def _compound_matches_tx(t: int32, c: int32) -> int32:
    off: int32 = g_comp_off[c]
    ln: int32 = g_comp_len[c]
    bl: int32 = 0
    while bl < ln and g_selbuf[off + bl] != 58:           # up to ':'
        bl = bl + 1
    ts: uint64 = cast[uint64](tx_ns[t])
    ne: uint64 = ts + cast[uint64](tx_nl[t])
    je: uint64 = cast[uint64](tx_cs[t]) - 1
    if bl > 0:
        if _sel_match_at(ts, je, ne, &g_selbuf[off], bl) == 0:
            return 0
    # structural pseudo-classes
    p: int32 = off + bl
    while p < off + ln and g_selbuf[p] == 58:             # ':'
        p = p + 1
        ps: int32 = p
        while p < off + ln and _sel_isname(g_selbuf[p]) != 0:
            p = p + 1
        pl: int32 = p - ps
        if _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("first-child"), 11) != 0:
            if _tx_prev_sibling(t) >= 0:
                return 0
        elif _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("last-child"), 10) != 0:
            if _tx_next_sibling(t) >= 0:
                return 0
        elif _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("only-child"), 10) != 0:
            if _tx_prev_sibling(t) >= 0 or _tx_next_sibling(t) >= 0:
                return 0
        elif _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("empty"), 5) != 0:
            if _tx_is_empty(t) == 0:
                return 0
        elif _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("first-of-type"), 13) != 0:
            if _tx_of_type_index(t) != 1:
                return 0
        elif _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("last-of-type"), 12) != 0:
            if _tx_of_type_index_from_end(t) != 1:
                return 0
        elif _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("only-of-type"), 12) != 0:
            if _tx_of_type_index(t) != 1 or _tx_of_type_index_from_end(t) != 1:
                return 0
        elif _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("nth-child"), 9) != 0 or \
             _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("nth-last-child"), 14) != 0 or \
             _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("nth-of-type"), 11) != 0 or \
             _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("nth-last-of-type"), 16) != 0:
            kind: int32 = 0                                # 0 child,1 last-child,2 of-type,3 last-of-type
            if _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("nth-last-child"), 14) != 0:
                kind = 1
            elif _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("nth-of-type"), 11) != 0:
                kind = 2
            elif _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("nth-last-of-type"), 16) != 0:
                kind = 3
            if p < off + ln and g_selbuf[p] == 40:        # '('
                p = p + 1
                ncs: int32 = p
                while p < off + ln and g_selbuf[p] != 41:  # up to ')'
                    p = p + 1
                _parse_nth(ncs, p)
                if p < off + ln and g_selbuf[p] == 41:    # ')'
                    p = p + 1
                idx: int32 = _tx_child_index(t)
                if kind == 1:
                    idx = _tx_child_index_from_end(t)
                elif kind == 2:
                    idx = _tx_of_type_index(t)
                elif kind == 3:
                    idx = _tx_of_type_index_from_end(t)
                if _nth_match(idx, g_nth_a, g_nth_b) == 0:
                    return 0
            else:
                return 0                                   # :nth-*() with no arg
        elif _bytes_eq(&g_selbuf[ps], pl, cast[Ptr[uint8]]("not"), 3) != 0:
            if p < off + ln and g_selbuf[p] == 40:        # '('
                p = p + 1
                nots: int32 = p
                while p < off + ln and g_selbuf[p] != 41:  # arg up to ')'
                    p = p + 1
                note: int32 = p
                if p < off + ln and g_selbuf[p] == 41:    # ')'
                    p = p + 1
                # trim spaces inside :not(...)
                while nots < note and g_selbuf[nots] == 32:
                    nots = nots + 1
                while note > nots and g_selbuf[note - 1] == 32:
                    note = note - 1
                # negate a simple compound (tag/class/id/attr) via _sel_match_at
                if note > nots and \
                   _sel_match_at(ts, je, ne, &g_selbuf[nots], note - nots) != 0:
                    return 0
            else:
                return 0                                   # :not with no arg
        else:
            return 0                                      # unknown pseudo -> no match
    return 1


# Match tx entry `cur` against compound `c` AND its left chain (combinators).
def _match_chain(cur: int32, c: int32) -> int32:
    if _compound_matches_tx(cur, c) == 0:
        return 0
    if c == 0:
        return 1
    cb: uint8 = g_comb[c]
    if cb == 62:                                          # '>' parent
        pp: int32 = tx_parent[cur]
        if pp < 0:
            return 0
        return _match_chain(pp, c - 1)
    if cb == 32:                                          # ' ' ancestor
        a: int32 = tx_parent[cur]
        while a >= 0:
            if _match_chain(a, c - 1) != 0:
                return 1
            a = tx_parent[a]
        return 0
    if cb == 43:                                          # '+' adjacent sibling
        ps: int32 = _tx_prev_sibling(cur)
        if ps < 0:
            return 0
        return _match_chain(ps, c - 1)
    if cb == 126:                                         # '~' general sibling
        s: int32 = _tx_prev_sibling(cur)
        while s >= 0:
            if _match_chain(s, c - 1) != 0:
                return 1
            s = _tx_prev_sibling(s)
        return 0
    return 0


# The full selector matches the source element anchored at offset `anchor`
# (only reached when g_sel_adv != 0). Verifies the whole compound/combinator chain
# against the tree index.
def _sel_adv_match(anchor: int32) -> int32:
    t: int32 = _tx_by_anchor(anchor)
    if t < 0:
        return 0
    return _match_chain(t, g_nc - 1)


# Locate the FIRST element in source span [lo,hi) matching selector sel. Sets
# the g_el_* globals; returns 1 on a hit.
def _dom_find_selector_scoped(sel: Ptr[uint8], seln: int32, lo: uint64, \
                              hi: uint64) -> int32:
    if seln == 0:
        return 0
    _sel_split(sel, seln)
    if g_sellist_n == 0:
        return 0
    i: uint64 = lo
    while i < hi:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           src_ptr[i + 1] != 47 and src_ptr[i + 1] != 33 and \
           src_ptr[i + 1] != 63:
            ts: uint64 = i + 1
            je: uint64 = ts
            while je < src_len and src_ptr[je] != 62:
                je = je + 1
            ne: uint64 = ts
            while ne < je and _alnum_at(ne) != 0:
                ne = ne + 1
            k: int32 = 0
            hitk: int32 = 0
            while k < g_sellist_n and hitk == 0:
                if _complex_hit_at(sel, g_sellist_off[k], g_sellist_len[k], \
                                   i, ts, je, ne) != 0:
                    hitk = 1
                k = k + 1
            if hitk != 0:
                return _scan_start_tag(i)
            i = je
        i = i + 1
    return 0


# Whole-document convenience (used by the id-less resolver paths).
def _dom_find_selector(sel: Ptr[uint8], seln: int32) -> int32:
    return _dom_find_selector_scoped(sel, seln, 0, src_len)


# Push EVERY element in source span [lo,hi) matching selector sel onto the JS
# array `arr` (each registered via _dom_register_el so it is a live element).
def _dom_collect_selector(sel: Ptr[uint8], seln: int32, lo: uint64, \
                          hi: uint64, arr: int32):
    if seln == 0:
        return
    _sel_split(sel, seln)
    if g_sellist_n == 0:
        return
    i: uint64 = lo
    while i < hi:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           src_ptr[i + 1] != 47 and src_ptr[i + 1] != 33 and \
           src_ptr[i + 1] != 63:
            ts: uint64 = i + 1
            je: uint64 = ts
            while je < src_len and src_ptr[je] != 62:
                je = je + 1
            ne: uint64 = ts
            while ne < je and _alnum_at(ne) != 0:
                ne = ne + 1
            k: int32 = 0
            hitk: int32 = 0
            while k < g_sellist_n and hitk == 0:
                if _complex_hit_at(sel, g_sellist_off[k], g_sellist_len[k], \
                                   i, ts, je, ne) != 0:
                    hitk = 1
                k = k + 1
            if hitk != 0:
                _scan_start_tag(i)
                js_array_push(arr, _dom_register_el())
            rt: uint64 = _rawtext_skip(ts, ne, je)        # skip <script>/<style> body
            if rt != 0:
                i = rt
                continue
            i = je
        i = i + 1


# Resolve the source span a query runs over: the calling element's inner content
# when `this` is a registered source element, else the whole document. Sets
# g_qlo/g_qhi. A created-node `this` (no source span) yields an empty scope.
g_qlo: uint64 = 0
g_qhi: uint64 = 0

# Parallel created-node query scope (round 5): a query rooted at a source
# element sees that element's created subtree; one rooted at a created node sees
# its created descendants; a document-level query sees the whole created forest.
g_cre_scope_el:  int32 = -1
g_cre_scope_cid: int32 = -1
g_cre_scope_doc: int32 = 1


def _set_query_scope():
    el: int32 = _find_el_by_obj(js_this())
    if el >= 0:
        g_qlo = cast[uint64](dom_cstart[el])
        g_qhi = cast[uint64](dom_cend[el])
        g_cre_scope_el = el
        g_cre_scope_cid = -1
        g_cre_scope_doc = 0
        return
    cid: int32 = _find_cre_by_obj(js_this())
    if cid >= 0:
        g_qlo = 0                                          # created node: empty src
        g_qhi = 0
        g_cre_scope_el = -1
        g_cre_scope_cid = cid
        g_cre_scope_doc = 0
        return
    g_qlo = 0                                              # document: whole page
    g_qhi = src_len
    g_cre_scope_el = -1
    g_cre_scope_cid = -1
    g_cre_scope_doc = 1


def _upper(c: uint8) -> uint8:
    if c >= 97 and c <= 122:
        return c - 32
    return c


g_dskey: Array[64, uint8]             # scratch: a camelCased data-* key


# Populate `o.dataset` from the element's data-* attributes in tag body [abody,je).
# `data-foo-bar="v"` -> dataset.fooBar == "v". Missing values -> "".
def _build_dataset(o: int32, abody: uint64, je: uint64):
    ds: int32 = js_new_object_v()
    i: uint64 = abody
    while i < je:
        boundary: int32 = 0
        if i == abody:
            boundary = 1
        elif src_ptr[i - 1] == 32 or src_ptr[i - 1] == 9 or src_ptr[i - 1] == 10:
            boundary = 1
        if boundary != 0 and i + 5 <= je and \
           _hx_lower(src_ptr[i]) == 100 and _hx_lower(src_ptr[i + 1]) == 97 and \
           _hx_lower(src_ptr[i + 2]) == 116 and _hx_lower(src_ptr[i + 3]) == 97 and \
           src_ptr[i + 4] == 45:                           # 'd' 'a' 't' 'a' '-'
            ks: uint64 = i + 5
            ke: uint64 = ks
            while ke < je and src_ptr[ke] != 61 and src_ptr[ke] != 32 and \
                  src_ptr[ke] != 9 and src_ptr[ke] != 62 and src_ptr[ke] != 47:
                ke = ke + 1
            kw: int32 = 0
            p: uint64 = ks
            while p < ke and kw < 63:
                if src_ptr[p] == 45 and p + 1 < ke:        # '-x' -> 'X' (camel)
                    p = p + 1
                    g_dskey[kw] = _upper(src_ptr[p])
                else:
                    g_dskey[kw] = src_ptr[p]
                kw = kw + 1
                p = p + 1
            g_dskey[kw] = 0
            if ke < je and src_ptr[ke] == 61:              # '=' value
                q: uint8 = 0
                vp: uint64 = ke + 1
                if vp < je and (src_ptr[vp] == 34 or src_ptr[vp] == 39):
                    q = src_ptr[vp]
                    vp = vp + 1
                vstart: uint64 = vp
                while vp < je and (q != 0 and src_ptr[vp] != q or \
                      q == 0 and src_ptr[vp] != 32 and src_ptr[vp] != 9 and \
                      src_ptr[vp] != 62):
                    vp = vp + 1
                js_set_prop(ds, &g_dskey[0], kw, \
                            js_new_string(&src_ptr[vstart], vp - vstart))
                i = vp
            else:
                js_set_prop(ds, &g_dskey[0], kw, js_new_string(&dom_txtbuf[0], 0))
                i = ke
        i = i + 1
    js_set_prop(o, cast[Ptr[uint8]]("dataset"), 7, ds)


def _dom_lookup_anchor(off: int32) -> int32:
    e: int32 = 0
    while e < dom_n:
        if dom_anchor[e] == off:
            return e
        e = e + 1
    return -1


def _dom_lookup_id(idp: Ptr[uint8], idn: int32) -> int32:
    e: int32 = 0
    while e < dom_n:
        if _bytes_eq(&dom_idbuf[dom_id_off[e]], dom_id_len[e], idp, idn) != 0:
            return e
        e = e + 1
    return -1


def _find_el_by_obj(objv: int32) -> int32:
    e: int32 = 0
    while e < dom_n:
        if dom_obj[e] == objv:
            return e
        e = e + 1
    return -1


def _find_cre_by_obj(objv: int32) -> int32:
    e: int32 = 0
    while e < cre_n:
        if cre_obj[e] == objv:
            return e
        e = e + 1
    return -1


# Append a source-element -> created-node mount edge. `at` = -1 appends at the
# end; otherwise the new edge is inserted just before ap index `at` (insertBefore).
def _ap_add(parent_el: int32, child_cid: int32, at: int32):
    if ap_n >= APPEND_MAX:
        return
    pos: int32 = ap_n
    if at >= 0 and at < ap_n:
        pos = at
        m: int32 = ap_n
        while m > pos:
            ap_parent[m] = ap_parent[m - 1]
            ap_child[m] = ap_child[m - 1]
            ap_removed[m] = ap_removed[m - 1]
            m = m - 1
    ap_parent[pos] = parent_el
    ap_child[pos] = child_cid
    ap_removed[pos] = 0
    ap_n = ap_n + 1


# Append a created-node -> created-node child edge (nesting). `at` = -1 appends
# at the end; otherwise insert just before cc index `at`.
def _cc_add(owner_cid: int32, child_cid: int32, at: int32):
    if cc_n >= CC_MAX:
        return
    pos: int32 = cc_n
    if at >= 0 and at < cc_n:
        pos = at
        m: int32 = cc_n
        while m > pos:
            cc_owner[m] = cc_owner[m - 1]
            cc_child[m] = cc_child[m - 1]
            cc_removed[m] = cc_removed[m - 1]
            m = m - 1
    cc_owner[pos] = owner_cid
    cc_child[pos] = child_cid
    cc_removed[pos] = 0
    cc_n = cc_n + 1


# Find the ap edge index for (parent_el, child_cid); -1 if none.
def _ap_find(parent_el: int32, child_cid: int32) -> int32:
    a: int32 = 0
    while a < ap_n:
        if ap_removed[a] == 0 and ap_parent[a] == parent_el and \
           ap_child[a] == child_cid:
            return a
        a = a + 1
    return -1


# Find the cc edge index for (owner_cid, child_cid); -1 if none.
def _cc_find(owner_cid: int32, child_cid: int32) -> int32:
    a: int32 = 0
    while a < cc_n:
        if cc_removed[a] == 0 and cc_owner[a] == owner_cid and \
           cc_child[a] == child_cid:
            return a
        a = a + 1
    return -1



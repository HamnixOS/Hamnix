# lib/web/dom/canvas.ad — part of the modular web engine (extracted from htmlengine.ad).
# <canvas> 2D context — JS-facing drawing state + the canvas host-dispatch surface.
#
# Behavior-preserving split (single-compilation-unit; byte-identical).

from lib.web.dom.forms import _has_word
from lib.htmlengine import he_media_match
from lib.htmlengine import _alnum_at, _ap_add, _ap_find, _arg_bytes, _attach_el_methods, _attr_int, _bytes_eq, _cc_add, _cc_find, _cls_build_with, _cls_build_without, _cls_read, _cls_write, _clstr_has, _cre_collect, _cre_find_by_id, _cre_find_first, _cstr_len, _cx_walk, _dom_build_tree_index, _dom_children_drop, _dom_children_insert, _dom_children_replace, _dom_collect_selector, _dom_find_by_id, _dom_find_selector_scoped, _dom_lookup_anchor, _dom_lookup_id, _dom_register_el, _dom_reset, _el_bbox, _emit_img_seg, _enter_skip, _find_close, _find_cre_by_obj, _find_el_by_clsobj, _find_el_by_obj, _hx_find_attr, _hx_lower, _hx_tag_end_p, _idbytes_eq, _is_name_ch, _layout, _match_chain, _new_client_rects, _new_computed_style, _new_rect_obj, _new_style_obj, _palette_rgb, _scan_start_tag, _sel_match_at, _sel_parse, _sel_split, _select_index, _select_optext_at, _set_el_geom_props, _set_query_scope, _strip_comments, _style_apply_csstext, _style_serialize, _tagname_is, _tagname_upper, _tx_by_anchor, _word_flush

# ====================================================================
# <canvas> 2D context — the JS-facing side. Style state (fillStyle/strokeStyle/
# lineWidth/font/globalAlpha) lives as plain properties on the context object;
# each draw reads them back here and forwards resolved ints/colours to
# lib/htmlcanvas, which owns the pixels. See that module's header for scope.
# ====================================================================
cv_txt: Array[512, uint8]                 # scratch for a fillText/measureText arg
mq_scratch: Array[512, uint8]             # scratch for a window.matchMedia(query) arg
g_cv_px:   int32 = 10
g_cv_bold: int32 = 0


# Integer value of numeric JS argument `argi` (canvas coords are px).
def _cvn(argi: int32) -> int32:
    return cast[int32](js_to_number(js_arg(argi)))


# Case-insensitive equality of buf[0..n) with NUL-terminated `lit`.
def _ci_word_eq(p: Ptr[uint8], n: int32, lit: Ptr[uint8]) -> int32:
    i: int32 = 0
    while lit[i] != 0:
        if i >= n:
            return 0
        if _hx_lower(p[i]) != lit[i]:
            return 0
        i = i + 1
    if i != n:
        return 0
    return 1


# Does buf[0..n) contain NUL-terminated lowercase `lit` (case-insensitive)?
def _buf_contains(p: Ptr[uint8], n: int32, lit: Ptr[uint8]) -> int32:
    ll: int32 = 0
    while lit[ll] != 0:
        ll = ll + 1
    if ll == 0:
        return 0
    i: int32 = 0
    while i + ll <= n:
        k: int32 = 0
        while k < ll and _hx_lower(p[i + k]) == lit[k]:
            k = k + 1
        if k == ll:
            return 1
        i = i + 1
    return 0


# Parse a canvas colour string (#rgb / #rrggbb / a common CSS name) to packed
# 0xRRGGBB; defaults to black. A scoped named subset — the rest fall back to
# black, matching a browser's "unknown keyword => unchanged" only loosely, which
# is fine for the delivered fill/stroke set.
def _canvas_color(p: Ptr[uint8], n: int32) -> int32:
    if n <= 0:
        return 0
    if p[0] == 35:                                    # '#'
        if n >= 7:
            r: int32 = _hx_hexval(p[1]) * 16 + _hx_hexval(p[2])
            g: int32 = _hx_hexval(p[3]) * 16 + _hx_hexval(p[4])
            b: int32 = _hx_hexval(p[5]) * 16 + _hx_hexval(p[6])
            if r >= 0 and g >= 0 and b >= 0:
                return (r << 16) | (g << 8) | b
        if n >= 4:
            r3: int32 = _hx_hexval(p[1])
            g3: int32 = _hx_hexval(p[2])
            b3: int32 = _hx_hexval(p[3])
            if r3 >= 0 and g3 >= 0 and b3 >= 0:
                return ((r3 * 17) << 16) | ((g3 * 17) << 8) | (b3 * 17)
        return 0
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("white")) != 0:
        return 0xffffff
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("red")) != 0:
        return 0xff0000
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("green")) != 0:
        return 0x008000
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("lime")) != 0:
        return 0x00ff00
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("blue")) != 0:
        return 0x0000ff
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("navy")) != 0:
        return 0x000080
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("teal")) != 0:
        return 0x008080
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("aqua")) != 0:
        return 0x00ffff
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("cyan")) != 0:
        return 0x00ffff
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("olive")) != 0:
        return 0x808000
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("yellow")) != 0:
        return 0xffff00
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("orange")) != 0:
        return 0xffa500
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("gold")) != 0:
        return 0xffd700
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("purple")) != 0:
        return 0x800080
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("magenta")) != 0:
        return 0xff00ff
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("fuchsia")) != 0:
        return 0xff00ff
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("maroon")) != 0:
        return 0x800000
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("silver")) != 0:
        return 0xc0c0c0
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("gray")) != 0:
        return 0x808080
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("grey")) != 0:
        return 0x808080
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("pink")) != 0:
        return 0xffc0cb
    if _ci_word_eq(p, n, cast[Ptr[uint8]]("brown")) != 0:
        return 0xa52a2a
    return 0                                           # black default


# Resolve a colour-string property (fillStyle/strokeStyle) on `ctx`. If the
# property holds a gradient object (used as a paint for stroke/path-fill/text
# where per-pixel interpolation is not wired), fall back to the gradient's first
# colour stop instead of black.
def _canvas_style_rgb(ctx: int32, name: Ptr[uint8], nlen: uint64) -> int32:
    v: int32 = js_get_prop(ctx, name, nlen)
    if js_type_of(v) == 5:                                # object -> gradient?
        gv: int32 = js_get_prop(v, cast[Ptr[uint8]]("__cvgrad"), 8)
        if js_type_of(gv) == 3:
            return htmlcanvas_grad_first_rgb(cast[int32](js_to_number(gv)))
    p: Ptr[uint8] = js_str_ptr(v)
    n: int32 = _cstr_len(p)
    return _canvas_color(p, n)


# ctx.lineWidth as a >=1 integer.
def _canvas_line_width(ctx: int32) -> int32:
    v: int32 = js_get_prop(ctx, cast[Ptr[uint8]]("lineWidth"), 9)
    lw: int32 = cast[int32](js_to_number(v))
    if lw < 1:
        lw = 1
    return lw


# ctx.globalAlpha (0..1) as 0..255 coverage. Only the translucent case touches
# a float multiply; opaque/clear are integer fast-paths.
def _canvas_alpha(ctx: int32) -> int32:
    v: int32 = js_get_prop(ctx, cast[Ptr[uint8]]("globalAlpha"), 11)
    af: float64 = js_to_number(v)
    if af >= cast[float64](1):
        return 255
    if af <= cast[float64](0):
        return 0
    return cast[int32](af * cast[float64](255))


# Read ctx.font into g_cv_px / g_cv_bold (default 10px, non-bold).
def _canvas_read_font(ctx: int32):
    g_cv_px = 10
    g_cv_bold = 0
    v: int32 = js_get_prop(ctx, cast[Ptr[uint8]]("font"), 4)
    p: Ptr[uint8] = js_str_ptr(v)
    n: int32 = _cstr_len(p)
    if n <= 0:
        return
    if _buf_contains(p, n, cast[Ptr[uint8]]("bold")) != 0:
        g_cv_bold = 1
    num: int32 = 0
    seen: int32 = 0
    i: int32 = 0
    while i < n:
        c: uint8 = p[i]
        if c >= 48 and c <= 57:
            num = num * 10 + cast[int32](c - 48)
            seen = 1
        elif seen != 0:
            i = n
        i = i + 1
    if seen != 0 and num > 0:
        g_cv_px = num


# Map a JS radian angle argument to an integer step index (0..64 per turn).
def _canvas_ang_idx(argi: int32) -> int32:
    a: float64 = js_to_number(js_arg(argi))
    return cast[int32](a * cast[float64](10185916) / cast[float64](1000000) + \
                       cast[float64](5) / cast[float64](10))


# Does dom element `el`'s tag name equal NUL-terminated lowercase `lit`?
def _dom_tag_is(el: int32, lit: Ptr[uint8]) -> int32:
    nl: int32 = 0
    while lit[nl] != 0:
        nl = nl + 1
    if dom_nl[el] != nl:
        return 0
    k: int32 = 0
    while k < nl:
        if _hx_lower(src_ptr[cast[uint64](dom_ns[el]) + cast[uint64](k)]) != lit[k]:
            return 0
        k = k + 1
    return 1


# Build a fresh 2D-context JS object bound to htmlcanvas index `ci`: default
# style properties + the native drawing methods.
def _canvas_make_ctx() -> int32:
    ctx: int32 = js_new_object_v()
    js_set_prop(ctx, cast[Ptr[uint8]]("fillStyle"), 9, \
                js_new_string(cast[Ptr[uint8]]("#000000"), 7))
    js_set_prop(ctx, cast[Ptr[uint8]]("strokeStyle"), 11, \
                js_new_string(cast[Ptr[uint8]]("#000000"), 7))
    js_set_prop(ctx, cast[Ptr[uint8]]("lineWidth"), 9, js_number(cast[float64](1)))
    js_set_prop(ctx, cast[Ptr[uint8]]("font"), 4, \
                js_new_string(cast[Ptr[uint8]]("10px sans-serif"), 15))
    js_set_prop(ctx, cast[Ptr[uint8]]("globalAlpha"), 11, \
                js_number(cast[float64](1)))
    js_set_prop(ctx, cast[Ptr[uint8]]("fillRect"), 8, \
                js_new_native_fn(js_hbase + NID_CV_FILLRECT))
    js_set_prop(ctx, cast[Ptr[uint8]]("clearRect"), 9, \
                js_new_native_fn(js_hbase + NID_CV_CLEARRECT))
    js_set_prop(ctx, cast[Ptr[uint8]]("strokeRect"), 10, \
                js_new_native_fn(js_hbase + NID_CV_STROKERECT))
    js_set_prop(ctx, cast[Ptr[uint8]]("beginPath"), 9, \
                js_new_native_fn(js_hbase + NID_CV_BEGIN))
    js_set_prop(ctx, cast[Ptr[uint8]]("moveTo"), 6, \
                js_new_native_fn(js_hbase + NID_CV_MOVETO))
    js_set_prop(ctx, cast[Ptr[uint8]]("lineTo"), 6, \
                js_new_native_fn(js_hbase + NID_CV_LINETO))
    js_set_prop(ctx, cast[Ptr[uint8]]("closePath"), 9, \
                js_new_native_fn(js_hbase + NID_CV_CLOSE))
    js_set_prop(ctx, cast[Ptr[uint8]]("stroke"), 6, \
                js_new_native_fn(js_hbase + NID_CV_STROKE))
    js_set_prop(ctx, cast[Ptr[uint8]]("fill"), 4, \
                js_new_native_fn(js_hbase + NID_CV_FILL))
    js_set_prop(ctx, cast[Ptr[uint8]]("arc"), 3, \
                js_new_native_fn(js_hbase + NID_CV_ARC))
    js_set_prop(ctx, cast[Ptr[uint8]]("rect"), 4, \
                js_new_native_fn(js_hbase + NID_CV_RECT))
    js_set_prop(ctx, cast[Ptr[uint8]]("fillText"), 8, \
                js_new_native_fn(js_hbase + NID_CV_FILLTEXT))
    js_set_prop(ctx, cast[Ptr[uint8]]("strokeText"), 10, \
                js_new_native_fn(js_hbase + NID_CV_STROKETEXT))
    js_set_prop(ctx, cast[Ptr[uint8]]("measureText"), 11, \
                js_new_native_fn(js_hbase + NID_CV_MEASURE))
    js_set_prop(ctx, cast[Ptr[uint8]]("drawImage"), 9, \
                js_new_native_fn(js_hbase + NID_CV_DRAWIMAGE))
    js_set_prop(ctx, cast[Ptr[uint8]]("save"), 4, \
                js_new_native_fn(js_hbase + NID_CV_SAVE))
    js_set_prop(ctx, cast[Ptr[uint8]]("restore"), 7, \
                js_new_native_fn(js_hbase + NID_CV_RESTORE))
    js_set_prop(ctx, cast[Ptr[uint8]]("translate"), 9, \
                js_new_native_fn(js_hbase + NID_CV_TRANSLATE))
    js_set_prop(ctx, cast[Ptr[uint8]]("scale"), 5, \
                js_new_native_fn(js_hbase + NID_CV_SCALE))
    js_set_prop(ctx, cast[Ptr[uint8]]("rotate"), 6, \
                js_new_native_fn(js_hbase + NID_CV_ROTATE))
    js_set_prop(ctx, cast[Ptr[uint8]]("transform"), 9, \
                js_new_native_fn(js_hbase + NID_CV_TRANSFORM))
    js_set_prop(ctx, cast[Ptr[uint8]]("setTransform"), 12, \
                js_new_native_fn(js_hbase + NID_CV_SETTRANSFORM))
    js_set_prop(ctx, cast[Ptr[uint8]]("resetTransform"), 14, \
                js_new_native_fn(js_hbase + NID_CV_RESETTRANSFORM))
    js_set_prop(ctx, cast[Ptr[uint8]]("createLinearGradient"), 20, \
                js_new_native_fn(js_hbase + NID_CV_LINGRAD))
    js_set_prop(ctx, cast[Ptr[uint8]]("createRadialGradient"), 20, \
                js_new_native_fn(js_hbase + NID_CV_RADGRAD))
    js_set_prop(ctx, cast[Ptr[uint8]]("getImageData"), 12, \
                js_new_native_fn(js_hbase + NID_CV_GETIMGDATA))
    js_set_prop(ctx, cast[Ptr[uint8]]("putImageData"), 12, \
                js_new_native_fn(js_hbase + NID_CV_PUTIMGDATA))
    js_set_prop(ctx, cast[Ptr[uint8]]("createImageData"), 15, \
                js_new_native_fn(js_hbase + NID_CV_CREATEIMGDATA))
    return ctx


# ctx.fillStyle (or strokeStyle) resolved to a backend gradient index, or -1 if
# it is an ordinary colour string. A gradient object carries a numeric __cvgrad.
def _canvas_paint_grad(ctx: int32, name: Ptr[uint8], nlen: uint64) -> int32:
    v: int32 = js_get_prop(ctx, name, nlen)
    if js_type_of(v) != 5:                                # not an object
        return -1
    gv: int32 = js_get_prop(v, cast[Ptr[uint8]]("__cvgrad"), 8)
    if js_type_of(gv) != 3:                               # not a number
        return -1
    return cast[int32](js_to_number(gv))


# A float64 numeric JS argument (transform coefficients / gradient coords).
def _cvf(argi: int32) -> float64:
    return js_to_number(js_arg(argi))


# Find-or-create the canvas registration + 2D context for source element `el`.
# Returns the canv_* registry index, or -1.
def _canvas_get_for_el(el: int32) -> int32:
    i: int32 = 0
    while i < canv_n:
        if canv_el[i] == el:
            return i
        i = i + 1
    if canv_n >= CANV_MAX:
        return -1
    te: uint64 = cast[uint64](dom_ns[el])
    while te < src_len and src_ptr[te] != 62:
        te = te + 1
    aw: int32 = _attr_int(cast[uint64](dom_ns[el]), te, \
                          cast[Ptr[uint8]]("width"), 300)
    ah: int32 = _attr_int(cast[uint64](dom_ns[el]), te, \
                          cast[Ptr[uint8]]("height"), 150)
    if aw < 1:
        aw = 300
    if ah < 1:
        ah = 150
    if aw > 1000:
        aw = 1000
    if ah > 1000:
        ah = 1000
    slot: int32 = htmlimg_add_blank(cast[Ptr[uint8]]("canvas"), 6, aw, ah)
    if slot < 0:
        return -1
    cidx: int32 = htmlcanvas_new(slot, aw, ah)
    if cidx < 0:
        return -1
    cv_sstk_n[cidx] = 0
    ctx: int32 = _canvas_make_ctx()
    k: int32 = canv_n
    canv_ci[k] = cidx
    canv_slot[k] = slot
    canv_w[k] = aw
    canv_h[k] = ah
    canv_anchor[k] = dom_anchor[el]
    canv_idoff[k] = dom_id_off[el]
    canv_idlen[k] = dom_id_len[el]
    canv_ctxobj[k] = ctx
    canv_el[k] = el
    canv_n = k + 1
    return k


# Map a 2D-context JS object back to its lib/htmlcanvas index, or -1.
def _canvas_ci_of_ctx(ctx: int32) -> int32:
    i: int32 = 0
    while i < canv_n:
        if canv_ctxobj[i] == ctx:
            return canv_ci[i]
        i = i + 1
    return -1


# LAYOUT-side lookup: find the canvas registry entry for a <canvas> tag in body
# [ne,te) opened at source '<' offset `anchor`, matching by element id first
# (survives a JS source rewrite) then by anchor. Returns the index, or -1.
def _canvas_layout_find(anchor: int32, ne: uint64, te: uint64) -> int32:
    if _hx_find_attr(ne, te, cast[Ptr[uint8]]("id")) != 0 and \
       g_attr_end > g_attr_start:
        ln: int32 = cast[int32](g_attr_end - g_attr_start)
        i: int32 = 0
        while i < canv_n:
            if canv_idlen[i] == ln:
                mtch: int32 = 1
                k: int32 = 0
                while k < ln:
                    if src_ptr[g_attr_start + cast[uint64](k)] != \
                       dom_idbuf[canv_idoff[i] + k]:
                        mtch = 0
                        k = ln
                    k = k + 1
                if mtch != 0:
                    return i
            i = i + 1
    j: int32 = 0
    while j < canv_n:
        if canv_anchor[j] == anchor:
            return j
        j = j + 1
    return -1


# LAYOUT-side <canvas> handler: reserve the pixel box that blits the drawn (or
# blank, if the script never drew) backing buffer, then skip fallback content.
# `ltp1` is the tag-name start (source '<' = ltp1-1).
def _handle_canvas(ltp1: uint64, np: uint64, nlen: uint64, ne: uint64,
                   te: uint64):
    _word_flush()
    anchor: int32 = cast[int32](ltp1) - 1
    ci_reg: int32 = _canvas_layout_find(anchor, ne, te)
    if ci_reg < 0:
        # A <canvas> the script never got a context for: reserve a blank box.
        aw: int32 = _attr_int(ne, te, cast[Ptr[uint8]]("width"), 300)
        ah: int32 = _attr_int(ne, te, cast[Ptr[uint8]]("height"), 150)
        if aw < 1:
            aw = 300
        if ah < 1:
            ah = 150
        if aw > 1000:
            aw = 1000
        if ah > 1000:
            ah = 1000
        if canv_n < CANV_MAX:
            slot0: int32 = htmlimg_add_blank(cast[Ptr[uint8]]("canvas"), 6,
                                             aw, ah)
            if slot0 >= 0:
                cidx0: int32 = htmlcanvas_new(slot0, aw, ah)
                if cidx0 >= 0:
                    k0: int32 = canv_n
                    canv_ci[k0] = cidx0
                    canv_slot[k0] = slot0
                    canv_w[k0] = aw
                    canv_h[k0] = ah
                    canv_anchor[k0] = anchor
                    canv_idoff[k0] = 0
                    canv_idlen[k0] = 0
                    canv_ctxobj[k0] = -1
                    canv_el[k0] = -1
                    canv_n = k0 + 1
                    ci_reg = k0
    if ci_reg < 0:
        _enter_skip(np, nlen)
        return
    slot: int32 = canv_slot[ci_reg]
    bw2: int32 = canv_w[ci_reg]
    bh2: int32 = canv_h[ci_reg]
    if bw2 > bw:
        if bw2 > 0:
            bh2 = bh2 * bw / bw2
        bw2 = bw
    if bh2 < 1:
        bh2 = 1
    # bracketed alt fallback "[canvas]" for the text-only paths.
    img_alt_buf[0] = 91                                # '['
    img_alt_buf[1] = 99                                # 'c'
    img_alt_buf[2] = 97                                # 'a'
    img_alt_buf[3] = 110                               # 'n'
    img_alt_buf[4] = 118                               # 'v'
    img_alt_buf[5] = 97                                # 'a'
    img_alt_buf[6] = 115                               # 's'
    img_alt_buf[7] = 93                                # ']'
    img_alt_len = 8
    _emit_img_seg(slot, bw2, bh2)
    _enter_skip(np, nlen)


# ---------------------------------------------------------------------------
# innerHTML SETTER — parse a fragment string into REAL created-node children.
# Assigning `el.innerHTML = "<b>hi</b> world"` must expose the fragment as real
# DOM nodes so a SUBSEQUENT `el.childNodes` / tree walk in the SAME script sees
# the new subtree (jsengine has no accessor properties, so we hook member_set).
# We build cre_* element/text node objects, mirroring appendChild's node shape,
# and replace the target's .children/.childNodes arrays. RENDER already reflects
# an innerHTML assignment via the raw-override path in the readback pass, so we
# deliberately do NOT add ap/cc render edges here (that would double-emit).
# querySelector still scans source text (a pre-existing limit shared with
# appendChild's created nodes) and is unaffected.
# ---------------------------------------------------------------------------

# A fragment element that never has children in HTML (no end tag). Kept short —
# the common voids that appear inside real innerHTML strings.
def _frag_is_void(tp: Ptr[uint8], tl: int32) -> int32:
    if _bytes_eq(tp, tl, cast[Ptr[uint8]]("br"), 2) != 0:
        return 1
    if _bytes_eq(tp, tl, cast[Ptr[uint8]]("img"), 3) != 0:
        return 1
    if _bytes_eq(tp, tl, cast[Ptr[uint8]]("hr"), 2) != 0:
        return 1
    if _bytes_eq(tp, tl, cast[Ptr[uint8]]("input"), 5) != 0:
        return 1
    if _bytes_eq(tp, tl, cast[Ptr[uint8]]("meta"), 4) != 0:
        return 1
    if _bytes_eq(tp, tl, cast[Ptr[uint8]]("link"), 4) != 0:
        return 1
    return 0


# Is byte run sp[a..b) entirely ASCII whitespace?
def _frag_ws_only(sp: Ptr[uint8], a: int32, b: int32) -> int32:
    i: int32 = a
    while i < b:
        c: uint8 = sp[i]
        if c != 32 and c != 9 and c != 10 and c != 13:
            return 0
        i = i + 1
    return 1


# Allocate a created ELEMENT node with (lowercased) tag bytes tp[0..tl); returns
# its cre id, or -1 if the pool is full. Mirrors NID_CREATE's object shape so
# the emitter and DOM-walk APIs treat it exactly like a createElement node.
def _cre_make_element(tp: Ptr[uint8], tl: int32) -> int32:
    if cre_n >= CRE_MAX:
        return -1
    cid: int32 = cre_n
    cre_tag_off[cid] = dom_idbuf_len
    k: int32 = 0
    while k < tl and dom_idbuf_len < DOM_ID_CAP:
        dom_idbuf[dom_idbuf_len] = _hx_lower(tp[k])
        dom_idbuf_len = dom_idbuf_len + 1
        k = k + 1
    cre_tag_len[cid] = tl
    cre_is_text[cid] = 0
    cre_gone[cid] = 0
    co: int32 = js_new_object_v()
    js_set_prop(co, cast[Ptr[uint8]]("textContent"), 11, js_new_string(&dom_txtbuf[0], 0))
    js_set_prop(co, cast[Ptr[uint8]]("id"), 2, js_new_string(&dom_txtbuf[0], 0))
    js_set_prop(co, cast[Ptr[uint8]]("className"), 9, js_new_string(&dom_txtbuf[0], 0))
    js_set_prop(co, cast[Ptr[uint8]]("tagName"), 7, \
                _tagname_upper(&dom_idbuf[cre_tag_off[cid]], tl))
    js_set_prop(co, cast[Ptr[uint8]]("nodeType"), 8, js_number(cast[float64](1)))
    js_set_prop(co, cast[Ptr[uint8]]("nodeName"), 8, \
                _tagname_upper(&dom_idbuf[cre_tag_off[cid]], tl))
    js_set_prop(co, cast[Ptr[uint8]]("nodeValue"), 9, js_null())
    js_set_prop(co, cast[Ptr[uint8]]("style"), 5, _new_style_obj())
    _attach_el_methods(co)
    cre_obj[cid] = co
    cre_n = cid + 1
    return cid


# Allocate a created TEXT node carrying string value `sval`. Returns its node
# object (js value), ready to push into a childNodes array.
def _cre_make_text(sval: int32) -> int32:
    if cre_n >= CRE_MAX:
        return -1
    tcid: int32 = cre_n
    cre_tag_off[tcid] = dom_idbuf_len
    cre_tag_len[tcid] = 0
    cre_is_text[tcid] = 1
    cre_gone[tcid] = 0
    tco: int32 = js_new_object_v()
    js_set_prop(tco, cast[Ptr[uint8]]("textContent"), 11, sval)
    js_set_prop(tco, cast[Ptr[uint8]]("nodeType"), 8, js_number(cast[float64](3)))
    js_set_prop(tco, cast[Ptr[uint8]]("nodeName"), 8, \
                js_new_string(cast[Ptr[uint8]]("#text"), 5))
    js_set_prop(tco, cast[Ptr[uint8]]("nodeValue"), 9, sval)
    cre_obj[tcid] = tco
    cre_n = tcid + 1
    return tco


# Parse the attributes region sp[a..b) of a fragment start tag onto node obj
# `co`: class -> className, id -> id, everything else name->value verbatim.
def _frag_set_attrs(co: int32, sp: Ptr[uint8], a: int32, b: int32):
    i: int32 = a
    while i < b:
        while i < b and _frag_ws_only(sp, i, i + 1) != 0:
            i = i + 1
        if i >= b or sp[i] == 47:                        # '/' (self-close)
            return
        ns: int32 = i
        while i < b and _is_name_ch(sp[i]) != 0:
            i = i + 1
        ne: int32 = i
        if ne == ns:
            i = i + 1
            continue
        while i < b and _frag_ws_only(sp, i, i + 1) != 0:
            i = i + 1
        vs: int32 = ns
        vlen: int32 = 0
        if i < b and sp[i] == 61:                        # '='
            i = i + 1
            while i < b and _frag_ws_only(sp, i, i + 1) != 0:
                i = i + 1
            if i < b and (sp[i] == 34 or sp[i] == 39):   # quoted
                q: uint8 = sp[i]
                i = i + 1
                vs = i
                while i < b and sp[i] != q:
                    i = i + 1
                vlen = i - vs
                if i < b:
                    i = i + 1
            else:
                vs = i
                while i < b and _frag_ws_only(sp, i, i + 1) == 0:
                    i = i + 1
                vlen = i - vs
        av: int32 = js_new_string(&sp[vs], cast[uint64](vlen))
        if _bytes_eq(&sp[ns], ne - ns, cast[Ptr[uint8]]("class"), 5) != 0:
            js_set_prop(co, cast[Ptr[uint8]]("className"), 9, av)
        elif _bytes_eq(&sp[ns], ne - ns, cast[Ptr[uint8]]("id"), 2) != 0:
            js_set_prop(co, cast[Ptr[uint8]]("id"), 2, av)
        else:
            js_set_prop(co, &sp[ns], cast[uint64](ne - ns), av)


# Close the top open element on the fragment stack: finalize its textContent
# (the shared linear cursor spans its descendants too) and its child arrays.
def _frag_close_top(depth: int32):
    cid: int32 = frag_st_cid[depth]
    if cid < 0:
        return
    co: int32 = cre_obj[cid]
    ts: int32 = frag_st_txt[depth]
    js_set_prop(co, cast[Ptr[uint8]]("textContent"), 11, \
                js_new_string(&frag_txt[ts], cast[uint64](frag_txt_w - ts)))
    arr: int32 = frag_st_arr[depth]
    js_set_prop(co, cast[Ptr[uint8]]("children"), 8, arr)
    js_set_prop(co, cast[Ptr[uint8]]("childNodes"), 10, arr)


# Parse HTML fragment sp[0..sl) into created nodes; append the TOP-LEVEL child
# objects to js array `root`. The caller reads root's length for first/last.
def _parse_fragment(sp: Ptr[uint8], sl: int32, root: int32):
    frag_txt_w = 0
    depth: int32 = 0
    frag_st_cid[0] = -1
    frag_st_arr[0] = root
    frag_st_txt[0] = 0
    i: int32 = 0
    while i < sl:
        if sp[i] == 60:                                  # '<'
            if i + 1 < sl and sp[i + 1] == 47:           # '</' close
                j: int32 = i + 2
                while j < sl and sp[j] != 62:
                    j = j + 1
                if depth > 0:
                    _frag_close_top(depth)
                    depth = depth - 1
                if j < sl:
                    j = j + 1
                i = j
                continue
            # start tag: <name attrs...> or <name .../>
            j2: int32 = i + 1
            ns: int32 = j2
            while j2 < sl and _is_name_ch(sp[j2]) != 0:
                j2 = j2 + 1
            nlen: int32 = j2 - ns
            # scan to the matching '>' (quote-aware: a '>' inside a quoted
            # attribute value does not end the tag, e.g. title="a>b").
            te: int32 = cast[int32](_hx_tag_end_p(sp, cast[uint64](sl), \
                                                  cast[uint64](j2)))
            selfclose: int32 = 0
            if te > ns and sp[te - 1] == 47:             # '<x .../>'
                selfclose = 1
            if nlen <= 0:
                i = te + 1
                continue
            cid: int32 = _cre_make_element(&sp[ns], nlen)
            if cid < 0:
                i = te + 1
                continue
            co: int32 = cre_obj[cid]
            attr_end: int32 = te
            if selfclose != 0:
                attr_end = te - 1
            _frag_set_attrs(co, sp, j2, attr_end)
            js_array_push(frag_st_arr[depth], co)
            js_set_prop(co, cast[Ptr[uint8]]("parentNode"), 10, js_null())
            if _frag_is_void(&sp[ns], nlen) == 0 and selfclose == 0:
                if depth + 1 < FRAG_STACK_MAX:
                    depth = depth + 1
                    frag_st_cid[depth] = cid
                    frag_st_arr[depth] = js_new_array_v()
                    frag_st_txt[depth] = frag_txt_w
            else:
                # void/self-closed: empty child arrays for API symmetry
                em: int32 = js_new_array_v()
                js_set_prop(co, cast[Ptr[uint8]]("children"), 8, em)
                js_set_prop(co, cast[Ptr[uint8]]("childNodes"), 10, em)
            i = te + 1
            continue
        # text run up to the next '<'
        ts: int32 = i
        while i < sl and sp[i] != 60:
            i = i + 1
        if _frag_ws_only(sp, ts, i) == 0:
            # copy bytes into the shared textContent buffer (for ancestors)
            k: int32 = ts
            tstart: int32 = frag_txt_w
            while k < i and frag_txt_w < FRAG_TXT_CAP:
                frag_txt[frag_txt_w] = sp[k]
                frag_txt_w = frag_txt_w + 1
                k = k + 1
            tv: int32 = js_new_string(&frag_txt[tstart], cast[uint64](frag_txt_w - tstart))
            tco: int32 = _cre_make_text(tv)
            js_array_push(frag_st_arr[depth], tco)
    # close any elements left open by malformed markup
    while depth > 0:
        _frag_close_top(depth)
        depth = depth - 1


# Recursively mark a created subtree detached: the node itself and every cc_*
# (created->created) edge under it. Used by the innerHTML= setter so a wholesale
# replace does not leave stale created descendants live in the emitter/overlay.
def _cre_detach_subtree(cid: int32):
    if cid < 0 or cid >= cre_n or cre_gone[cid] != 0:
        return
    cre_gone[cid] = 1
    b: int32 = 0
    while b < cc_n:
        if cc_removed[b] == 0 and cc_owner[b] == cid:
            cc_removed[b] = 1
            _cre_detach_subtree(cc_child[b])
        b = b + 1


# Detach EVERY dynamically-created child of DOM node `thisv` from the RENDER
# tree, so an `innerHTML=` assignment fully replaces prior appendChild()/
# createElement() children (finding #3). The JS .children/.childNodes arrays are
# rebuilt by the caller, but the render walks the ap_*/cc_* created-node edges
# (_build_rewrite / _emit_created) and the selector overlay walks them too
# (_cx_walk) — without unlinking those edges the OLD created children re-emit
# ON TOP of the new fragment (the "7 lines for 4 tasks" doubling). A source
# element parents its created children via ap_* edges; a created node via cc_*.
def _innerhtml_detach_children(thisv: int32):
    el: int32 = _find_el_by_obj(thisv)
    if el >= 0:
        a: int32 = 0
        while a < ap_n:
            if ap_removed[a] == 0 and ap_parent[a] == el:
                ap_removed[a] = 1
                _cre_detach_subtree(ap_child[a])
            a = a + 1
        return
    pcid: int32 = _find_cre_by_obj(thisv)
    if pcid >= 0:
        c: int32 = 0
        while c < cc_n:
            if cc_removed[c] == 0 and cc_owner[c] == pcid:
                cc_removed[c] = 1
                _cre_detach_subtree(cc_child[c])
            c = c + 1


# member_set hook (registered via js_set_member_hook): fires after every
# `obj.prop = val`. We act only on `el.innerHTML = <string>` for a registered
# source element or created node, parsing the fragment into real child nodes.
def _js_member_set_hook(dummy: int32) -> int32:
    kv: int32 = js_mset_key()
    kp: Ptr[uint8] = js_str_ptr(kv)
    kn: int32 = _cstr_len(kp)
    # `location.href = "..."` re-parses the whole URL into location's components;
    # `location.hash = "#x"` updates the fragment (the assignment already stored
    # .hash) and rebuilds href, then fires a `hashchange` window event.
    if g_js_location >= 0 and js_mset_this() == g_js_location:
        if _bytes_eq(kp, kn, cast[Ptr[uint8]]("href"), 4) != 0:
            hv: int32 = js_mset_val()
            hvp: Ptr[uint8] = js_str_ptr(hv)
            hvn: int32 = _cstr_len(hvp)
            if _is_undef_str(hvp, hvn) == 0:
                _url_parse_into(g_js_location, hvp, hvn)
            return 0
        if _bytes_eq(kp, kn, cast[Ptr[uint8]]("hash"), 4) != 0:
            _loc_rebuild_href()
            _fire_win_event(cast[Ptr[uint8]]("hashchange"), 10, \
                            cast[Ptr[uint8]]("onhashchange"), 12, js_undefined(), 0)
            return 0
    # `el.style.cssText = "color:red;display:none"` — `this` is the style object;
    # parse the string into its routed camelCase props so the cascade sees it.
    if _bytes_eq(kp, kn, cast[Ptr[uint8]]("cssText"), 7) != 0:
        csttv: int32 = js_mset_this()
        cvv: int32 = js_mset_val()
        cvp: Ptr[uint8] = js_str_ptr(cvv)
        cvn: int32 = _cstr_len(cvp)
        if _is_undef_str(cvp, cvn) == 0:
            _style_apply_csstext(csttv, cvp, cvn)
        return 0
    # characterData: assigning textContent / nodeValue / data on a
    # MutationObserver-observed node queues a characterData record. Guarded by
    # a live registry so script-free pages and internal node-building pay
    # nothing (and produce no spurious records).
    if mreg_n != 0:
        if _bytes_eq(kp, kn, cast[Ptr[uint8]]("textContent"), 11) != 0 or \
           _bytes_eq(kp, kn, cast[Ptr[uint8]]("nodeValue"), 9) != 0 or \
           _bytes_eq(kp, kn, cast[Ptr[uint8]]("data"), 4) != 0:
            _mo_record_chardata(js_mset_this())
    if _bytes_eq(kp, kn, cast[Ptr[uint8]]("innerHTML"), 9) == 0:
        return 0
    thisv: int32 = js_mset_this()
    if _find_el_by_obj(thisv) < 0 and _find_cre_by_obj(thisv) < 0:
        return 0                                          # not a DOM node yet
    valv: int32 = js_mset_val()
    vp: Ptr[uint8] = js_str_ptr(valv)
    vn: int32 = _cstr_len(vp)
    if _is_undef_str(vp, vn) != 0:
        return 0
    _apply_inner_html(thisv, vp, vn)
    return 0


# Replace DOM node `thisv`'s inner content with the fragment parsed from
# vp[0..vn): detach prior created children, parse the fragment into real created
# child nodes, and refresh .children/.childNodes/.textContent/first-last child.
# The `.innerHTML` property itself is set by the caller (the member-set hook has
# it already assigned; insertAdjacentHTML assigns the concatenation) so the
# readback renders it via the raw-override path. Shared by innerHTML= and
# insertAdjacentHTML.
# Append p[0..n) into iah_buf at offset w; returns the new offset (bounded).
def _iah_append(w: int32, p: Ptr[uint8], n: int32) -> int32:
    i: int32 = 0
    while i < n and w < IAH_CAP:
        iah_buf[w] = p[i]
        w = w + 1
        i = i + 1
    return w


def _apply_inner_html(thisv: int32, vp: Ptr[uint8], vn: int32):
    # Detach prior createElement()/appendChild() children FIRST — clearing (or
    # replacing) innerHTML must remove the old created subtree from the render
    # tree, not just the JS .children array, or a re-render doubles content.
    _innerhtml_detach_children(thisv)
    root: int32 = js_new_array_v()
    _parse_fragment(vp, vn, root)
    js_set_prop(thisv, cast[Ptr[uint8]]("children"), 8, root)
    js_set_prop(thisv, cast[Ptr[uint8]]("childNodes"), 10, root)
    # keep .textContent consistent with the new subtree (innerHTML raw-override
    # still wins in render, so this only affects a subsequent JS read).
    js_set_prop(thisv, cast[Ptr[uint8]]("textContent"), 11, \
                js_new_string(&frag_txt[0], cast[uint64](frag_txt_w)))
    fc: int32 = js_null()
    lc: int32 = js_null()
    if js_array_len(root) > 0:
        fc = js_array_get(root, 0)
        lc = js_array_get(root, js_array_len(root) - 1)
    js_set_prop(thisv, cast[Ptr[uint8]]("firstChild"), 10, fc)
    js_set_prop(thisv, cast[Ptr[uint8]]("firstElementChild"), 17, fc)
    js_set_prop(thisv, cast[Ptr[uint8]]("lastChild"), 9, lc)
    js_set_prop(thisv, cast[Ptr[uint8]]("lastElementChild"), 16, lc)


# The host-object dispatcher jsengine calls for native ids >= js_host_base().
# Does source element `el`'s start tag match single/rightmost-compound selector
# selp[0..seln)? A descendant selector degrades to its rightmost compound (the
# documented round-1 approximation, shared with querySelector).
def _el_matches_sel(el: int32, selp: Ptr[uint8], seln: int32) -> int32:
    if el < 0 or seln <= 0:
        return 0
    t: int32 = _tx_by_anchor(dom_anchor[el])
    _sel_split(selp, seln)
    k: int32 = 0
    while k < g_sellist_n:
        _sel_parse(&selp[g_sellist_off[k]], g_sellist_len[k])
        if g_nc != 0:
            if t >= 0:
                if _match_chain(t, g_nc - 1) != 0:         # full combinator/pseudo chain
                    return 1
            else:
                # No tree index (matched before layout): fall back to a single
                # rightmost-compound base match (tag/class/id/[attr]).
                rc: int32 = g_nc - 1
                rbl: int32 = 0
                while rbl < g_comp_len[rc] and g_selbuf[g_comp_off[rc] + rbl] != 58:
                    rbl = rbl + 1
                ts: uint64 = cast[uint64](dom_ns[el])
                ne: uint64 = ts + cast[uint64](dom_nl[el])
                je: uint64 = cast[uint64](dom_cstart[el]) - 1
                if g_nc == 1 and rbl > 0 and \
                   _sel_match_at(ts, je, ne, &g_selbuf[g_comp_off[rc]], rbl) != 0:
                    return 1
        k = k + 1
    return 0


# Does tx-tree node `t` (used while climbing ancestors for closest()) match ANY
# sub-selector of the list selp[0..seln), full combinator/pseudo chain included?
def _tx_matches_sel(t: int32, selp: Ptr[uint8], seln: int32) -> int32:
    if seln <= 0:
        return 0
    _sel_split(selp, seln)
    k: int32 = 0
    while k < g_sellist_n:
        _sel_parse(&selp[g_sellist_off[k]], g_sellist_len[k])
        if g_nc != 0 and _match_chain(t, g_nc - 1) != 0:
            return 1
        k = k + 1
    return 0


# Is byte `c` a legal HTML attribute-name character (letters/digits/-/_/:/.)?
def _is_attr_name_ch(c: uint8) -> int32:
    lc: uint8 = _hx_lower(c)
    if (lc >= 97 and lc <= 122) or (c >= 48 and c <= 57) or \
       c == 45 or c == 95 or c == 58 or c == 46:
        return 1
    return 0


# Walk source element `el`'s start-tag attribute list. For each attribute name
# token, if `arr` >= 0 push it as a lower-cased JS string; always count it.
# Returns the number of attributes. Quote-aware (skips over `="..."` values).
def _scan_attr_names(el: int32, arr: int32) -> int32:
    if el < 0:
        return 0
    bs: uint64 = cast[uint64](dom_ns[el]) + cast[uint64](dom_nl[el])
    be: uint64 = cast[uint64](dom_cstart[el]) - 1          # the start tag's '>'
    n: int32 = 0
    i: uint64 = bs
    while i < be:
        c: uint8 = src_ptr[i]
        if c == 32 or c == 9 or c == 10 or c == 13 or c == 47:  # ws or '/'
            i = i + 1
            continue
        if _is_attr_name_ch(c) == 0:
            i = i + 1
            continue
        ns: uint64 = i
        while i < be and _is_attr_name_ch(src_ptr[i]) != 0:
            i = i + 1
        # emit the name (lower-cased) [ns, i)
        if arr >= 0:
            an: Array[64, uint8]
            w: int32 = 0
            p: uint64 = ns
            while p < i and w < 63:
                an[w] = _hx_lower(src_ptr[p])
                w = w + 1
                p = p + 1
            js_array_push(arr, js_new_string(&an[0], cast[uint64](w)))
        n = n + 1
        # skip an optional ="value" / =value so its bytes aren't mis-scanned
        while i < be and (src_ptr[i] == 32 or src_ptr[i] == 9):
            i = i + 1
        if i < be and src_ptr[i] == 61:                    # '='
            i = i + 1
            while i < be and (src_ptr[i] == 32 or src_ptr[i] == 9):
                i = i + 1
            if i < be and (src_ptr[i] == 34 or src_ptr[i] == 39):
                q: uint8 = src_ptr[i]
                i = i + 1
                while i < be and src_ptr[i] != q:
                    i = i + 1
                if i < be:
                    i = i + 1
            else:
                while i < be and src_ptr[i] != 32 and src_ptr[i] != 9:
                    i = i + 1
    return n


def _collect_attr_names(el: int32, arr: int32):
    _scan_attr_names(el, arr)


def _count_attrs(el: int32) -> int32:
    return _scan_attr_names(el, -1)


# ---- Constraint Validation helpers ---------------------------------
# A minimal, WHATWG-shaped e-mail check (a deliberate willful violation like the
# HTML spec's own): exactly one '@' with a non-empty local part and a non-empty,
# whitespace-free domain part. Rejects "abc" (no '@'); accepts "a@b" / "a@b.com".
def _is_valid_email(p: Ptr[uint8], n: int32) -> int32:
    at: int32 = -1
    i: int32 = 0
    while i < n:
        c: uint8 = p[i]
        if c == 32 or c == 9:
            return 0
        if c == 64:                                        # '@'
            if at >= 0:
                return 0                                    # two '@' -> invalid
            at = i
        i = i + 1
    if at <= 0 or at >= n - 1:
        return 0                                            # need a char on both sides
    return 1


# A url is accepted when it carries a "scheme://rest" shape (something before
# "://" and something after). Enough to reject a bare "abc".
def _is_valid_url(p: Ptr[uint8], n: int32) -> int32:
    i: int32 = 0
    while i + 2 < n:
        if p[i] == 58 and p[i + 1] == 47 and p[i + 2] == 47:   # "://"
            if i > 0 and i + 3 < n:
                return 1
            return 0
        i = i + 1
    return 0


# A floating-point literal per type=number: optional sign, digits, optional
# fractional part; the WHOLE string must be consumed. Rejects "abc".
def _is_number(p: Ptr[uint8], n: int32) -> int32:
    i: int32 = 0
    if i < n and (p[i] == 43 or p[i] == 45):               # '+' / '-'
        i = i + 1
    digits: int32 = 0
    while i < n and p[i] >= 48 and p[i] <= 57:
        i = i + 1
        digits = digits + 1
    if i < n and p[i] == 46:                               # '.'
        i = i + 1
        while i < n and p[i] >= 48 and p[i] <= 57:
            i = i + 1
            digits = digits + 1
    if digits == 0 or i != n:
        return 0
    return 1


# Signed integer part of a numeric literal (fraction ignored) — used for
# min/max range comparison.
def _num_int(p: Ptr[uint8], n: int32) -> int64:
    i: int32 = 0
    sign: int64 = 1
    if i < n and p[i] == 45:
        sign = -1
        i = i + 1
    elif i < n and p[i] == 43:
        i = i + 1
    v: int64 = 0
    while i < n and p[i] >= 48 and p[i] <= 57:
        v = v * 10 + cast[int64](p[i] - 48)
        i = i + 1
    return sign * v


# Read a signed-int attribute (min/max/maxlength) from tag body [ts,te). Sets
# present[0]=1 when the attribute exists, else 0.
def _attr_int64(ts: uint64, te: uint64, name: Ptr[uint8], present: Ptr[int32]) -> int64:
    present[0] = 0
    if _hx_find_attr(ts, te, name) == 0:
        return 0
    present[0] = 1
    return _num_int(&src_ptr[g_attr_start], cast[int32](g_attr_end - g_attr_start))


# Write the freshly-computed ValidityState booleans + validationMessage back onto
# the control's live JS object, so `el.validity.valueMissing` etc. read true.
def _write_validity(el: int32, obj: int32, vm: int32, vt: int32, vl: int32, \
                    vu: int32, vov: int32, vb: int32, vc: int32, valid: int32):
    vo: int32 = js_get_prop(obj, cast[Ptr[uint8]]("validity"), 8)
    js_set_prop(vo, cast[Ptr[uint8]]("valueMissing"), 12, js_bool(vm))
    js_set_prop(vo, cast[Ptr[uint8]]("typeMismatch"), 12, js_bool(vt))
    js_set_prop(vo, cast[Ptr[uint8]]("patternMismatch"), 15, js_bool(0))
    js_set_prop(vo, cast[Ptr[uint8]]("tooLong"), 7, js_bool(vl))
    js_set_prop(vo, cast[Ptr[uint8]]("tooShort"), 8, js_bool(0))
    js_set_prop(vo, cast[Ptr[uint8]]("rangeUnderflow"), 14, js_bool(vu))
    js_set_prop(vo, cast[Ptr[uint8]]("rangeOverflow"), 13, js_bool(vov))
    js_set_prop(vo, cast[Ptr[uint8]]("stepMismatch"), 12, js_bool(0))
    js_set_prop(vo, cast[Ptr[uint8]]("badInput"), 8, js_bool(vb))
    js_set_prop(vo, cast[Ptr[uint8]]("customError"), 11, js_bool(vc))
    js_set_prop(vo, cast[Ptr[uint8]]("valid"), 5, js_bool(valid))
    if vc != 0:
        js_set_prop(obj, cast[Ptr[uint8]]("validationMessage"), 17, \
            js_new_string(&dom_customval_buf[dom_customval_off[el]], \
                          dom_customval_len[el]))
    elif valid == 0:
        js_set_prop(obj, cast[Ptr[uint8]]("validationMessage"), 17, \
            js_new_string(cast[Ptr[uint8]]("Please fill in this field."), 26))
    else:
        js_set_prop(obj, cast[Ptr[uint8]]("validationMessage"), 17, \
            js_new_string(cast[Ptr[uint8]](""), 0))


# Constraint-Validation for one control. Computes valueMissing (required+empty),
# typeMismatch (email/url), badInput (type=number non-numeric), tooLong
# (maxlength), rangeUnderflow/Overflow (number min/max), and customError
# (setCustomValidity). Refreshes the control's .validity object + .validationMessage
# and returns 1 when valid, 0 when it blocks submission. Reads the live JS `.value`.
def _dom_control_valid(el: int32) -> int32:
    obj: int32 = dom_obj[el]
    ts: uint64 = cast[uint64](dom_ns[el])
    te: uint64 = cast[uint64](dom_cstart[el]) - 1
    vv: int32 = js_get_prop(obj, cast[Ptr[uint8]]("value"), 5)
    vp: Ptr[uint8] = js_str_ptr(vv)
    vn: int32 = _cstr_len(vp)
    if _is_undef_str(vp, vn) != 0:
        vn = 0
    tyv: int32 = js_get_prop(obj, cast[Ptr[uint8]]("type"), 4)
    typ: Ptr[uint8] = js_str_ptr(tyv)
    tyn: int32 = _cstr_len(typ)
    is_num: int32 = _bytes_eq(typ, tyn, cast[Ptr[uint8]]("number"), 6)
    v_missing: int32 = 0
    if _has_word(ts, te, cast[Ptr[uint8]]("required")) != 0 and vn == 0:
        v_missing = 1
    v_type: int32 = 0
    if vn > 0:
        if _bytes_eq(typ, tyn, cast[Ptr[uint8]]("email"), 5) != 0 and \
           _is_valid_email(vp, vn) == 0:
            v_type = 1
        elif _bytes_eq(typ, tyn, cast[Ptr[uint8]]("url"), 3) != 0 and \
             _is_valid_url(vp, vn) == 0:
            v_type = 1
    v_badinput: int32 = 0
    if vn > 0 and is_num != 0 and _is_number(vp, vn) == 0:
        v_badinput = 1
    v_toolong: int32 = 0
    mlp: int32 = 0
    ml: int64 = _attr_int64(ts, te, cast[Ptr[uint8]]("maxlength"), &mlp)
    if mlp != 0 and cast[int64](vn) > ml:
        v_toolong = 1
    v_under: int32 = 0
    v_over: int32 = 0
    if vn > 0 and is_num != 0 and v_badinput == 0:
        val: int64 = _num_int(vp, vn)
        minp: int32 = 0
        mn: int64 = _attr_int64(ts, te, cast[Ptr[uint8]]("min"), &minp)
        if minp != 0 and val < mn:
            v_under = 1
        maxp: int32 = 0
        mx: int64 = _attr_int64(ts, te, cast[Ptr[uint8]]("max"), &maxp)
        if maxp != 0 and val > mx:
            v_over = 1
    v_custom: int32 = 0
    if dom_customval_len[el] > 0:
        v_custom = 1
    valid: int32 = 1
    if v_missing != 0 or v_type != 0 or v_badinput != 0 or v_toolong != 0 or \
       v_under != 0 or v_over != 0 or v_custom != 0:
        valid = 0
    _write_validity(el, obj, v_missing, v_type, v_toolong, v_under, v_over, \
                    v_badinput, v_custom, valid)
    return valid


# Validate every control in form `formel`'s .elements list, refreshing each
# control's .validity object. Returns 1 when ALL are valid, 0 otherwise. Does not
# short-circuit, so a whole-form check leaves every control's state up to date.
def _form_check_all(formel: int32) -> int32:
    els: int32 = js_get_prop(dom_obj[formel], cast[Ptr[uint8]]("elements"), 8)
    if js_is_array(els) == 0:
        return 1
    ok: int32 = 1
    ei: int32 = 0
    eln: int32 = js_array_len(els)
    while ei < eln:
        cel: int32 = _find_el_by_obj(js_array_get(els, ei))
        if cel >= 0 and _dom_control_valid(cel) == 0:
            ok = 0
        ei = ei + 1
    return ok


# ---- History API + Location (window.history / window.location) --------------
# Set object `o`'s string property `name` to the byte slice p[s..e).
def _loc_set_slice(o: int32, name: Ptr[uint8], nlen: uint64, p: Ptr[uint8], s: int32, e: int32):
    m: int32 = 0
    i: int32 = s
    while i < e and m < 2047:
        url_scratch[m] = p[i]
        m = m + 1
        i = i + 1
    js_set_prop(o, name, nlen, js_new_string(&url_scratch[0], cast[uint64](m)))


def _loc_set_empty(o: int32, name: Ptr[uint8], nlen: uint64):
    js_set_prop(o, name, nlen, js_new_string(cast[Ptr[uint8]](""), cast[uint64](0)))


# Parse URL bytes p[0..n) into location object `loc`'s WHATWG-URL components:
# href / protocol / host / hostname / port / pathname / search / hash / origin.
# Hierarchical (scheme://authority/path) and opaque (scheme:opaque) URLs are both
# handled; a relative reference (no scheme) fills pathname/search/hash only.
def _url_parse_into(loc: int32, p: Ptr[uint8], n: int32):
    if loc < 0:
        return
    js_set_prop(loc, cast[Ptr[uint8]]("href"), cast[uint64](4), \
                js_new_string(p, cast[uint64](n)))
    # scheme: bytes up to the first ':' (must precede any '/', '?' or '#').
    ci: int32 = 0
    while ci < n and p[ci] != 58 and p[ci] != 47 and p[ci] != 63 and p[ci] != 35:
        ci = ci + 1
    has_scheme: int32 = 0
    scheme_end: int32 = 0
    hier: int32 = 0
    rest_start: int32 = 0
    if ci < n and p[ci] == 58:
        has_scheme = 1
        scheme_end = ci
        if ci + 2 < n and p[ci + 1] == 47 and p[ci + 2] == 47:
            hier = 1
            rest_start = ci + 3
        else:
            rest_start = ci + 1
    # protocol = scheme + ':'  (empty for a relative reference).
    if has_scheme != 0:
        pm: int32 = 0
        pi: int32 = 0
        while pi < scheme_end and pm < 2047:
            url_scratch[pm] = p[pi]
            pm = pm + 1
            pi = pi + 1
        url_scratch[pm] = 58
        pm = pm + 1
        js_set_prop(loc, cast[Ptr[uint8]]("protocol"), cast[uint64](8), \
                    js_new_string(&url_scratch[0], cast[uint64](pm)))
    else:
        _loc_set_empty(loc, cast[Ptr[uint8]]("protocol"), cast[uint64](8))
    # authority (hierarchical only): [userinfo@]host[:port]
    host_real: int32 = rest_start
    host_end: int32 = rest_start
    if hier != 0:
        he: int32 = rest_start
        while he < n and p[he] != 47 and p[he] != 63 and p[he] != 35:
            he = he + 1
        host_end = he
        rest_start = he
        # strip userinfo before an '@'
        ak: int32 = host_real
        while ak < host_end:
            if p[ak] == 64:
                host_real = ak + 1
            ak = ak + 1
        _loc_set_slice(loc, cast[Ptr[uint8]]("host"), cast[uint64](4), p, host_real, host_end)
        # hostname / port split on the LAST ':'
        colon: int32 = -1
        ck: int32 = host_real
        while ck < host_end:
            if p[ck] == 58:
                colon = ck
            ck = ck + 1
        if colon >= 0:
            _loc_set_slice(loc, cast[Ptr[uint8]]("hostname"), cast[uint64](8), p, host_real, colon)
            _loc_set_slice(loc, cast[Ptr[uint8]]("port"), cast[uint64](4), p, colon + 1, host_end)
        else:
            _loc_set_slice(loc, cast[Ptr[uint8]]("hostname"), cast[uint64](8), p, host_real, host_end)
            _loc_set_empty(loc, cast[Ptr[uint8]]("port"), cast[uint64](4))
        # origin = protocol + "//" + host
        om: int32 = 0
        oi: int32 = 0
        while oi < scheme_end and om < 598:
            origin_scratch[om] = p[oi]
            om = om + 1
            oi = oi + 1
        origin_scratch[om] = 58
        om = om + 1
        origin_scratch[om] = 47
        om = om + 1
        origin_scratch[om] = 47
        om = om + 1
        oi = host_real
        while oi < host_end and om < 599:
            origin_scratch[om] = p[oi]
            om = om + 1
            oi = oi + 1
        js_set_prop(loc, cast[Ptr[uint8]]("origin"), cast[uint64](6), \
                    js_new_string(&origin_scratch[0], cast[uint64](om)))
    else:
        _loc_set_empty(loc, cast[Ptr[uint8]]("host"), cast[uint64](4))
        _loc_set_empty(loc, cast[Ptr[uint8]]("hostname"), cast[uint64](8))
        _loc_set_empty(loc, cast[Ptr[uint8]]("port"), cast[uint64](4))
        js_set_prop(loc, cast[Ptr[uint8]]("origin"), cast[uint64](6), \
                    js_new_string(cast[Ptr[uint8]]("null"), cast[uint64](4)))
    # split remainder into pathname / search / hash
    hpos: int32 = -1
    hi: int32 = rest_start
    while hi < n:
        if p[hi] == 35:
            hpos = hi
            hi = n
        else:
            hi = hi + 1
    qlim: int32 = n
    if hpos >= 0:
        qlim = hpos
    qpos: int32 = -1
    qi: int32 = rest_start
    while qi < qlim:
        if p[qi] == 63:
            qpos = qi
            qi = qlim
        else:
            qi = qi + 1
    path_end: int32 = n
    if qpos >= 0:
        path_end = qpos
    elif hpos >= 0:
        path_end = hpos
    if hier != 0 and path_end == rest_start:
        js_set_prop(loc, cast[Ptr[uint8]]("pathname"), cast[uint64](8), \
                    js_new_string(cast[Ptr[uint8]]("/"), cast[uint64](1)))
    else:
        _loc_set_slice(loc, cast[Ptr[uint8]]("pathname"), cast[uint64](8), p, rest_start, path_end)
    if qpos >= 0:
        se: int32 = n
        if hpos >= 0:
            se = hpos
        _loc_set_slice(loc, cast[Ptr[uint8]]("search"), cast[uint64](6), p, qpos, se)
    else:
        _loc_set_empty(loc, cast[Ptr[uint8]]("search"), cast[uint64](6))
    if hpos >= 0:
        _loc_set_slice(loc, cast[Ptr[uint8]]("hash"), cast[uint64](4), p, hpos, n)
    else:
        _loc_set_empty(loc, cast[Ptr[uint8]]("hash"), cast[uint64](4))


# Rebuild location.href from its parts after a `location.hash = ...` write, so
# href stays consistent (origin + pathname + search + hash). Skips a "null"
# origin (opaque/relative) — those keep their prior href.
def _loc_append_prop(name: Ptr[uint8], nlen: uint64, m: int32) -> int32:
    v: int32 = js_get_prop(g_js_location, name, nlen)
    vp: Ptr[uint8] = js_str_ptr(v)
    i: int32 = 0
    while vp[i] != 0 and m < 2047:
        url_scratch2[m] = vp[i]
        m = m + 1
        i = i + 1
    return m


def _loc_rebuild_href():
    if g_js_location < 0:
        return
    ov: int32 = js_get_prop(g_js_location, cast[Ptr[uint8]]("origin"), cast[uint64](6))
    op: Ptr[uint8] = js_str_ptr(ov)
    m: int32 = 0
    if _bytes_eq(op, _cstr_len(op), cast[Ptr[uint8]]("null"), 4) == 0:
        m = _loc_append_prop(cast[Ptr[uint8]]("origin"), cast[uint64](6), m)
    m = _loc_append_prop(cast[Ptr[uint8]]("pathname"), cast[uint64](8), m)
    m = _loc_append_prop(cast[Ptr[uint8]]("search"), cast[uint64](6), m)
    m = _loc_append_prop(cast[Ptr[uint8]]("hash"), cast[uint64](4), m)
    js_set_prop(g_js_location, cast[Ptr[uint8]]("href"), cast[uint64](4), \
                js_new_string(&url_scratch2[0], cast[uint64](m)))


# Dispatch a non-bubbling window event (popstate / hashchange): build the event
# object, fire every window-registered addEventListener(type) (they record under
# the DOC_EL sentinel with GEN_KIND), then the window.on<type> handler property.
# When has_state != 0 the event carries event.state (popstate).
def _fire_win_event(typp: Ptr[uint8], typn: int32, onname: Ptr[uint8], onlen: int32, \
                    stateval: int32, has_state: int32):
    ev: int32 = js_new_object_v()
    js_set_prop(ev, cast[Ptr[uint8]]("type"), cast[uint64](4), \
                js_new_string(typp, cast[uint64](typn)))
    js_set_prop(ev, cast[Ptr[uint8]]("target"), cast[uint64](6), js_win)
    js_set_prop(ev, cast[Ptr[uint8]]("currentTarget"), cast[uint64](13), js_win)
    js_set_prop(ev, cast[Ptr[uint8]]("bubbles"), cast[uint64](7), js_bool(0))
    js_set_prop(ev, cast[Ptr[uint8]]("cancelable"), cast[uint64](10), js_bool(0))
    if has_state != 0:
        js_set_prop(ev, cast[Ptr[uint8]]("state"), cast[uint64](5), stateval)
    js_global_set(cast[Ptr[uint8]]("event"), cast[uint64](5), ev)
    li: int32 = 0
    while li < evl_n:
        if evl_dead[li] == 0 and evl_el[li] == DOC_EL and evl_kind[li] == GEN_KIND and \
           _evl_type_eq(li, typp, typn) != 0:
            lfn: int32 = evl_fn[li]
            if js_is_callable(lfn) != 0:
                g_argv1[0] = ev
                js_call_fn(lfn, js_win, &g_argv1[0], 1)
                if evl_once[li] != 0:
                    evl_dead[li] = 1
        li = li + 1
    ofn: int32 = js_get_prop(js_win, onname, cast[uint64](onlen))
    if js_is_callable(ofn) != 0:
        g_argv1[0] = ev
        js_call_fn(ofn, js_win, &g_argv1[0], 1)


# Mirror the session-history model onto the JS `history` object.
def _hist_sync():
    if g_js_history < 0:
        return
    js_set_prop(g_js_history, cast[Ptr[uint8]]("length"), cast[uint64](6), \
                js_number(cast[float64](jshist_len)))
    js_set_prop(g_js_history, cast[Ptr[uint8]]("state"), cast[uint64](5), jshist_state[jshist_idx])


# Record entry `idx`'s URL bytes into the append-only ring (best-effort; drops on
# overflow, which cannot happen within a single headless page's script budget).
def _hist_store_url(idx: int32, p: Ptr[uint8], n: int32):
    if n <= 0 or jshist_urlbuf_w + n > JSHIST_URLBUF_CAP:
        jshist_url_off[idx] = -1
        jshist_url_len[idx] = 0
        return
    jshist_url_off[idx] = jshist_urlbuf_w
    i: int32 = 0
    while i < n:
        jshist_urlbuf[jshist_urlbuf_w] = p[i]
        jshist_urlbuf_w = jshist_urlbuf_w + 1
        i = i + 1
    jshist_url_len[idx] = n


# Restore location.href/components from entry `idx`'s stored URL (if any).
def _hist_restore_url(idx: int32):
    if jshist_url_off[idx] >= 0 and jshist_url_len[idx] > 0:
        _url_parse_into(g_js_location, &jshist_urlbuf[jshist_url_off[idx]], jshist_url_len[idx])


# history.pushState(state,title,url) — advance the index, truncate the forward
# tail, store state + optional URL; replaceState overwrites the current entry.
def _hist_push(replace: int32) -> int32:
    stv: int32 = js_null()
    if js_arg_count() >= 1:
        stv = js_arg(0)
    if replace == 0:
        jshist_idx = jshist_idx + 1
        if jshist_idx >= JSHIST_MAX:
            jshist_idx = JSHIST_MAX - 1
        jshist_len = jshist_idx + 1
    jshist_state[jshist_idx] = stv
    jshist_url_off[jshist_idx] = -1
    jshist_url_len[jshist_idx] = 0
    if js_arg_count() >= 3 and js_type_of(js_arg(2)) == 4:      # 4 == string tag
        un: int32 = _arg_bytes(2, &url_scratch2[0], 2048)
        if un > 0:
            _hist_store_url(jshist_idx, &url_scratch2[0], un)
            _url_parse_into(g_js_location, &url_scratch2[0], un)
    _hist_sync()
    return js_undefined()


# Wire the `history` global + augment the `location` global (created by the JS
# engine's install_builtins) with methods, then reset the session-history model
# to a single current entry. Called at the end of _js_build_document, after the
# window/location/document globals exist.
def _wire_history_location():
    loc: int32 = js_global_get(cast[Ptr[uint8]]("location"), cast[uint64](8))
    if js_type_of(loc) == 5:                                   # 5 == object tag
        g_js_location = loc
        js_set_prop(loc, cast[Ptr[uint8]]("assign"), cast[uint64](6), \
                    js_new_native_fn(js_hbase + NID_LOC_ASSIGN))
        js_set_prop(loc, cast[Ptr[uint8]]("replace"), cast[uint64](7), \
                    js_new_native_fn(js_hbase + NID_LOC_ASSIGN))
        js_set_prop(loc, cast[Ptr[uint8]]("reload"), cast[uint64](6), \
                    js_new_native_fn(js_hbase + NID_LOC_RELOAD))
        js_set_prop(loc, cast[Ptr[uint8]]("toString"), cast[uint64](8), \
                    js_new_native_fn(js_hbase + NID_LOC_TOSTRING))
    h: int32 = js_new_object_v()
    g_js_history = h
    js_set_prop(h, cast[Ptr[uint8]]("pushState"), cast[uint64](9), \
                js_new_native_fn(js_hbase + NID_HIST_PUSH))
    js_set_prop(h, cast[Ptr[uint8]]("replaceState"), cast[uint64](12), \
                js_new_native_fn(js_hbase + NID_HIST_REPLACE))
    js_set_prop(h, cast[Ptr[uint8]]("back"), cast[uint64](4), \
                js_new_native_fn(js_hbase + NID_HIST_BACK))
    js_set_prop(h, cast[Ptr[uint8]]("forward"), cast[uint64](7), \
                js_new_native_fn(js_hbase + NID_HIST_FORWARD))
    js_set_prop(h, cast[Ptr[uint8]]("go"), cast[uint64](2), \
                js_new_native_fn(js_hbase + NID_HIST_GO))
    js_set_prop(h, cast[Ptr[uint8]]("scrollRestoration"), cast[uint64](17), \
                js_new_string(cast[Ptr[uint8]]("auto"), cast[uint64](4)))
    jshist_len = 1
    jshist_idx = 0
    jshist_urlbuf_w = 0
    jshist_state[0] = js_null()
    jshist_url_off[0] = -1
    jshist_url_len[0] = 0
    _hist_sync()
    js_global_set(cast[Ptr[uint8]]("history"), cast[uint64](7), h)
    js_global_set(cast[Ptr[uint8]]("__setLocation"), cast[uint64](13), \
                  js_new_native_fn(js_hbase + NID_SET_LOCATION))


# window.matchMedia(query) — build a MediaQueryList. `.matches` is the LIVE
# evaluation of the query against the viewport (he_media_match, the same subset
# the @media cascade uses); `.media` echoes the (serialized) query. Listener
# registration (addListener/removeListener/addEventListener/removeEventListener/
# dispatchEvent) accepts args and is a best-effort no-op: the headless engine
# does one layout, so a `change` never fires. `onchange` starts null.
def _match_media() -> int32:
    qn: int32 = 0
    if js_arg_count() >= 1:
        qn = _arg_bytes(0, &mq_scratch[0], 512)
    m: int32 = 0
    if qn > 0:
        m = he_media_match(&mq_scratch[0], cast[uint64](qn))
    mql: int32 = js_new_object_v()
    js_set_prop(mql, cast[Ptr[uint8]]("matches"), 7, js_bool(m))
    js_set_prop(mql, cast[Ptr[uint8]]("media"), 5, \
                js_new_string(&mq_scratch[0], cast[uint64](qn)))
    js_set_prop(mql, cast[Ptr[uint8]]("onchange"), 8, js_null())
    js_set_prop(mql, cast[Ptr[uint8]]("addListener"), 11, \
                js_new_native_fn(js_hbase + NID_MQL_NOOP))
    js_set_prop(mql, cast[Ptr[uint8]]("removeListener"), 14, \
                js_new_native_fn(js_hbase + NID_MQL_NOOP))
    js_set_prop(mql, cast[Ptr[uint8]]("addEventListener"), 16, \
                js_new_native_fn(js_hbase + NID_MQL_NOOP))
    js_set_prop(mql, cast[Ptr[uint8]]("removeEventListener"), 19, \
                js_new_native_fn(js_hbase + NID_MQL_NOOP))
    js_set_prop(mql, cast[Ptr[uint8]]("dispatchEvent"), 13, \
                js_new_native_fn(js_hbase + NID_MQL_NOOP))
    return mql


def _js_host_dispatch(id: int32) -> int32:
    rel: int32 = id - js_hbase
    if rel >= NID_MO_CTOR and rel <= NID_OBS_DELIVER:
        return _obs_dispatch(rel)
    if rel == NID_MATCHMEDIA:
        return _match_media()
    if rel == NID_MQL_NOOP:
        return js_bool(0)                    # dispatchEvent -> false; add/remove -> falsy
    if rel == NID_HIST_PUSH:
        return _hist_push(0)
    if rel == NID_HIST_REPLACE:
        return _hist_push(1)
    if rel == NID_HIST_BACK:
        if jshist_idx > 0:
            jshist_idx = jshist_idx - 1
            _hist_restore_url(jshist_idx)
            _hist_sync()
            _fire_win_event(cast[Ptr[uint8]]("popstate"), 8, \
                            cast[Ptr[uint8]]("onpopstate"), 10, jshist_state[jshist_idx], 1)
        return js_undefined()
    if rel == NID_HIST_FORWARD:
        if jshist_idx < jshist_len - 1:
            jshist_idx = jshist_idx + 1
            _hist_restore_url(jshist_idx)
            _hist_sync()
            _fire_win_event(cast[Ptr[uint8]]("popstate"), 8, \
                            cast[Ptr[uint8]]("onpopstate"), 10, jshist_state[jshist_idx], 1)
        return js_undefined()
    if rel == NID_HIST_GO:
        delta: int32 = 0
        if js_arg_count() >= 1:
            delta = cast[int32](js_to_number(js_arg(0)))
        ni: int32 = jshist_idx + delta
        if ni < 0:
            ni = 0
        if ni >= jshist_len:
            ni = jshist_len - 1
        if ni != jshist_idx:
            jshist_idx = ni

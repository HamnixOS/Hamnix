                disv: int32 = js_get_prop(disrc, cast[Ptr[uint8]]("src"), 3)
                disp: Ptr[uint8] = js_str_ptr(disv)
                disn: int32 = _cstr_len(disp)
                if disn > 0 and _is_undef_str(disp, disn) == 0:
                    dislot = htmlimg_find(disp, cast[uint64](disn))
            if dislot >= 0:
                if disw <= 0:
                    disw = htmlimg_w(dislot)
                if dish <= 0:
                    dish = htmlimg_h(dislot)
                didx: int32 = _cvn(1)
                didy: int32 = _cvn(2)
                didw: int32 = disw
                didh: int32 = dish
                if js_arg_count() >= 5:
                    didw = _cvn(3)
                    didh = _cvn(4)
                htmlcanvas_draw_image(dici, dislot, disw, dish, didx, didy,
                                      didw, didh, _canvas_alpha(js_this()))
        return js_undefined()
    if rel == NID_CV_MEASURE:
        eci: int32 = _canvas_ci_of_ctx(js_this())
        if eci >= 0 and js_arg_count() >= 1:
            mn: int32 = _arg_bytes(0, &cv_txt[0], 512)
            _canvas_read_font(js_this())
            mw: int32 = htmlcanvas_measure_text(g_cv_px, g_cv_bold,
                                                &cv_txt[0], mn)
            mo: int32 = js_new_object_v()
            js_set_prop(mo, cast[Ptr[uint8]]("width"), 5,
                        js_number(cast[float64](mw)))
            return mo
        return js_null()
    if rel == NID_CV_SAVE:
        svci: int32 = _canvas_ci_of_ctx(js_this())
        if svci >= 0:
            htmlcanvas_save(svci)
            d: int32 = cv_sstk_n[svci]
            if d < CV_SSTK_MAX:
                o: int32 = svci * CV_SSTK_MAX + d
                cv_sstk_fill[o] = js_get_prop(js_this(),
                                              cast[Ptr[uint8]]("fillStyle"), 9)
                cv_sstk_strk[o] = js_get_prop(js_this(),
                                              cast[Ptr[uint8]]("strokeStyle"), 11)
                cv_sstk_lw[o] = js_get_prop(js_this(),
                                            cast[Ptr[uint8]]("lineWidth"), 9)
                cv_sstk_font[o] = js_get_prop(js_this(),
                                              cast[Ptr[uint8]]("font"), 4)
                cv_sstk_alpha[o] = js_get_prop(js_this(),
                                               cast[Ptr[uint8]]("globalAlpha"), 11)
                cv_sstk_n[svci] = d + 1
        return js_undefined()
    if rel == NID_CV_RESTORE:
        rsci: int32 = _canvas_ci_of_ctx(js_this())
        if rsci >= 0:
            htmlcanvas_restore(rsci)
            d2: int32 = cv_sstk_n[rsci]
            if d2 > 0:
                d2 = d2 - 1
                o2: int32 = rsci * CV_SSTK_MAX + d2
                js_set_prop(js_this(), cast[Ptr[uint8]]("fillStyle"), 9,
                            cv_sstk_fill[o2])
                js_set_prop(js_this(), cast[Ptr[uint8]]("strokeStyle"), 11,
                            cv_sstk_strk[o2])
                js_set_prop(js_this(), cast[Ptr[uint8]]("lineWidth"), 9,
                            cv_sstk_lw[o2])
                js_set_prop(js_this(), cast[Ptr[uint8]]("font"), 4,
                            cv_sstk_font[o2])
                js_set_prop(js_this(), cast[Ptr[uint8]]("globalAlpha"), 11,
                            cv_sstk_alpha[o2])
                cv_sstk_n[rsci] = d2
        return js_undefined()
    if rel == NID_CV_TRANSLATE:
        tlci: int32 = _canvas_ci_of_ctx(js_this())
        if tlci >= 0 and js_arg_count() >= 2:
            htmlcanvas_translate(tlci, _cvf(0), _cvf(1))
        return js_undefined()
    if rel == NID_CV_SCALE:
        scci: int32 = _canvas_ci_of_ctx(js_this())
        if scci >= 0 and js_arg_count() >= 2:
            htmlcanvas_scale(scci, _cvf(0), _cvf(1))
        return js_undefined()
    if rel == NID_CV_ROTATE:
        rtci: int32 = _canvas_ci_of_ctx(js_this())
        if rtci >= 0 and js_arg_count() >= 1:
            htmlcanvas_rotate(rtci, _cvf(0))
        return js_undefined()
    if rel == NID_CV_TRANSFORM:
        tfci: int32 = _canvas_ci_of_ctx(js_this())
        if tfci >= 0 and js_arg_count() >= 6:
            htmlcanvas_transform(tfci, _cvf(0), _cvf(1), _cvf(2), _cvf(3),
                                 _cvf(4), _cvf(5))
        return js_undefined()
    if rel == NID_CV_SETTRANSFORM:
        smci: int32 = _canvas_ci_of_ctx(js_this())
        if smci >= 0 and js_arg_count() >= 6:
            htmlcanvas_set_transform(smci, _cvf(0), _cvf(1), _cvf(2), _cvf(3),
                                     _cvf(4), _cvf(5))
        return js_undefined()
    if rel == NID_CV_RESETTRANSFORM:
        rmci: int32 = _canvas_ci_of_ctx(js_this())
        if rmci >= 0:
            htmlcanvas_reset_transform(rmci)
        return js_undefined()
    if rel == NID_CV_LINGRAD or rel == NID_CV_RADGRAD:
        ggci: int32 = _canvas_ci_of_ctx(js_this())
        if ggci < 0:
            return js_null()
        gnew: int32 = -1
        if rel == NID_CV_LINGRAD:
            if js_arg_count() < 4:
                return js_null()
            gnew = htmlcanvas_grad_new(0, _cvf(0), _cvf(1), cast[float64](0),
                                       _cvf(2), _cvf(3), cast[float64](0))
        else:
            if js_arg_count() < 6:
                return js_null()
            gnew = htmlcanvas_grad_new(1, _cvf(0), _cvf(1), _cvf(2),
                                       _cvf(3), _cvf(4), _cvf(5))
        if gnew < 0:
            return js_null()
        go: int32 = js_new_object_v()
        js_set_prop(go, cast[Ptr[uint8]]("__cvgrad"), 8,
                    js_number(cast[float64](gnew)))
        js_set_prop(go, cast[Ptr[uint8]]("addColorStop"), 12,
                    js_new_native_fn(js_hbase + NID_CV_ADDSTOP))
        return go
    if rel == NID_CV_ADDSTOP:
        gsv: int32 = js_get_prop(js_this(), cast[Ptr[uint8]]("__cvgrad"), 8)
        if js_type_of(gsv) == 3 and js_arg_count() >= 2:
            gsi: int32 = cast[int32](js_to_number(gsv))
            cbytes: int32 = _arg_bytes(1, &cv_txt[0], 512)
            grgb: int32 = _canvas_color(&cv_txt[0], cbytes)
            htmlcanvas_grad_addstop(gsi, _cvf(0), grgb)
        return js_undefined()
    if rel == NID_CV_GETIMGDATA:
        gici: int32 = _canvas_ci_of_ctx(js_this())
        if gici < 0 or js_arg_count() < 4:
            return js_null()
        gix: int32 = _cvn(0)
        giy: int32 = _cvn(1)
        giw: int32 = _cvn(2)
        gih: int32 = _cvn(3)
        if giw < 0:
            giw = 0
        if gih < 0:
            gih = 0
        gidat: int32 = js_new_array_v()
        gyy: int32 = 0
        while gyy < gih:
            gxx: int32 = 0
            while gxx < giw:
                gpk: int32 = htmlcanvas_read_rgba(gici, gix + gxx, giy + gyy)
                js_array_push(gidat, js_number(cast[float64]((gpk >> 24) & 255)))
                js_array_push(gidat, js_number(cast[float64]((gpk >> 16) & 255)))
                js_array_push(gidat, js_number(cast[float64]((gpk >> 8) & 255)))
                js_array_push(gidat, js_number(cast[float64](gpk & 255)))
                gxx = gxx + 1
            gyy = gyy + 1
        gido: int32 = js_new_object_v()
        js_set_prop(gido, cast[Ptr[uint8]]("width"), 5,
                    js_number(cast[float64](giw)))
        js_set_prop(gido, cast[Ptr[uint8]]("height"), 6,
                    js_number(cast[float64](gih)))
        js_set_prop(gido, cast[Ptr[uint8]]("data"), 4, gidat)
        return gido
    if rel == NID_CV_CREATEIMGDATA:
        cici: int32 = _canvas_ci_of_ctx(js_this())
        if cici < 0 or js_arg_count() < 1:
            return js_null()
        ciw: int32 = 0
        cih: int32 = 0
        if js_arg_count() >= 2:
            ciw = _cvn(0)
            cih = _cvn(1)
        else:
            a0: int32 = js_arg(0)
            ciw = cast[int32](js_to_number(js_get_prop(a0,
                              cast[Ptr[uint8]]("width"), 5)))
            cih = cast[int32](js_to_number(js_get_prop(a0,
                              cast[Ptr[uint8]]("height"), 6)))
        if ciw < 0:
            ciw = 0
        if cih < 0:
            cih = 0
        cidat: int32 = js_new_array_v()
        ctot: int32 = ciw * cih * 4
        ck: int32 = 0
        while ck < ctot:
            js_array_push(cidat, js_number(cast[float64](0)))
            ck = ck + 1
        cido: int32 = js_new_object_v()
        js_set_prop(cido, cast[Ptr[uint8]]("width"), 5,
                    js_number(cast[float64](ciw)))
        js_set_prop(cido, cast[Ptr[uint8]]("height"), 6,
                    js_number(cast[float64](cih)))
        js_set_prop(cido, cast[Ptr[uint8]]("data"), 4, cidat)
        return cido
    if rel == NID_CV_PUTIMGDATA:
        pici: int32 = _canvas_ci_of_ctx(js_this())
        if pici >= 0 and js_arg_count() >= 3:
            pidat: int32 = js_arg(0)
            piw: int32 = cast[int32](js_to_number(js_get_prop(pidat,
                             cast[Ptr[uint8]]("width"), 5)))
            pih: int32 = cast[int32](js_to_number(js_get_prop(pidat,
                             cast[Ptr[uint8]]("height"), 6)))
            parr: int32 = js_get_prop(pidat, cast[Ptr[uint8]]("data"), 4)
            pdx: int32 = _cvn(1)
            pdy: int32 = _cvn(2)
            if js_is_array(parr) != 0 and piw > 0 and pih > 0:
                pyy: int32 = 0
                while pyy < pih:
                    pxx: int32 = 0
                    while pxx < piw:
                        pbase: int32 = (pyy * piw + pxx) * 4
                        pr: int32 = cast[int32](js_to_number(
                                    js_array_get(parr, pbase)))
                        pg: int32 = cast[int32](js_to_number(
                                    js_array_get(parr, pbase + 1)))
                        pb: int32 = cast[int32](js_to_number(
                                    js_array_get(parr, pbase + 2)))
                        pa: int32 = cast[int32](js_to_number(
                                    js_array_get(parr, pbase + 3)))
                        htmlcanvas_write_rgba(pici, pdx + pxx, pdy + pyy,
                                              pr, pg, pb, pa)
                        pxx = pxx + 1
                    pyy = pyy + 1
        return js_undefined()
    return js_undefined()


# copy the page <title> text into dom_title_buf; returns its length.
def _scan_title() -> int32:
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           _tagname_is(i + 1, cast[Ptr[uint8]]("title")) != 0:
            j: uint64 = i + 1
            while j < src_len and src_ptr[j] != 62:
                j = j + 1
            if j < src_len:
                j = j + 1
            n: int32 = 0
            while j < src_len and n < 255:
                if src_ptr[j] == 60:                      # '<' -> </title>
                    break
                if src_ptr[j] == 38:                      # '&' -> decode entity
                    consumed: uint64 = _entity(j)
                    if consumed > 0:
                        k: int32 = 0
                        while k < g_ent_len and n < 255:
                            dom_title_buf[n] = g_ent_buf[k]
                            n = n + 1
                            k = k + 1
                        j = j + consumed
                        continue
                dom_title_buf[n] = src_ptr[j]
                n = n + 1
                j = j + 1
            return n
        i = i + 1
    return 0


# Resolve the FIRST start tag named `name` in the source, register it as a live
# DOM element (dedup via anchor lookup — same object getElementById returns), and
# store it as `doc.prop`. If the page has no such tag the property is left unset
# (source-anchored parser: html/head/body are not synthesized when absent).
def _doc_set_el(doc: int32, prop: Ptr[uint8], plen: uint64, name: Ptr[uint8]):
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and src_ptr[i + 1] != 47 and \
           _tagname_is(i + 1, name) != 0:
            _scan_start_tag(i)
            o: int32 = _dom_register_el()
            js_set_prop(doc, prop, plen, o)
            return
        i = i + 1


def _js_build_document():
    doc: int32 = js_new_object_v()
    js_doc = doc
    js_set_prop(doc, cast[Ptr[uint8]]("nodeType"), 8, js_number(cast[float64](9)))
    js_set_prop(doc, cast[Ptr[uint8]]("nodeName"), 8, \
                js_new_string(cast[Ptr[uint8]]("#document"), 9))
    js_set_prop(doc, cast[Ptr[uint8]]("getElementById"), 14, \
                js_new_native_fn(js_hbase + NID_GETBYID))
    js_set_prop(doc, cast[Ptr[uint8]]("createElement"), 13, \
                js_new_native_fn(js_hbase + NID_CREATE))
    js_set_prop(doc, cast[Ptr[uint8]]("createTextNode"), 14, \
                js_new_native_fn(js_hbase + NID_CTEXT))
    js_set_prop(doc, cast[Ptr[uint8]]("querySelector"), 13, \
                js_new_native_fn(js_hbase + NID_QUERY))
    js_set_prop(doc, cast[Ptr[uint8]]("querySelectorAll"), 16, \
                js_new_native_fn(js_hbase + NID_QUERYALL))
    js_set_prop(doc, cast[Ptr[uint8]]("getElementsByClassName"), 22, \
                js_new_native_fn(js_hbase + NID_GETBYCLASS))
    js_set_prop(doc, cast[Ptr[uint8]]("getElementsByTagName"), 20, \
                js_new_native_fn(js_hbase + NID_GETBYTAG))
    js_set_prop(doc, cast[Ptr[uint8]]("addEventListener"), 16, \
                js_new_native_fn(js_hbase + NID_ADDEVT))
    tl: int32 = _scan_title()
    dom_title_len = tl
    dom_title_present = 1
    js_set_prop(doc, cast[Ptr[uint8]]("title"), 5, \
                js_new_string(&dom_title_buf[0], cast[uint64](tl)))
    _build_forms(doc)
    # document.documentElement / body / head resolve to the <html> / <body> /
    # <head> element nodes so `document.body.appendChild(...)`, `.style`,
    # `.classList` and `document.documentElement.classList` work. Each is the
    # SAME registered object getElementById/querySelector return, so mutations
    # (appendChild, style, className) reach the live tree + render.
    _doc_set_el(doc, cast[Ptr[uint8]]("documentElement"), 15, \
                cast[Ptr[uint8]]("html"))
    _doc_set_el(doc, cast[Ptr[uint8]]("body"), 4, cast[Ptr[uint8]]("body"))
    _doc_set_el(doc, cast[Ptr[uint8]]("head"), 4, cast[Ptr[uint8]]("head"))
    js_global_set(cast[Ptr[uint8]]("document"), 8, doc)
    # window.addEventListener('load'|'DOMContentLoaded'|…, fn) — the `window`
    # object is the JS global; give it the same listener methods as `document` so
    # `window.addEventListener('load', …)` and `window.onload = fn` (real pages'
    # dominant init hook) fire at load time. window-registered listeners record
    # under the DOC_EL sentinel (the headless model fires the window + document
    # load lifecycle together — see _fire_document / the _run_scripts tail).
    js_win = js_global_get(cast[Ptr[uint8]]("window"), 6)
    if js_type_of(js_win) == 5:                           # 5 == object tag
        js_set_prop(js_win, cast[Ptr[uint8]]("addEventListener"), 16, \
                    js_new_native_fn(js_hbase + NID_ADDEVT))
        js_set_prop(js_win, cast[Ptr[uint8]]("removeEventListener"), 19, \
                    js_new_native_fn(js_hbase + NID_REMEVT))
    # Global event constructors: `new Event('x',{bubbles})`, `new CustomEvent
    # ('x',{detail})`, plus MouseEvent/KeyboardEvent (extra fields). Each returns
    # a fresh event object usable with dispatchEvent (which reads ev.type).
    js_global_set(cast[Ptr[uint8]]("Event"), 5, \
                  js_new_native_fn(js_hbase + NID_EVENT_CTOR))
    js_global_set(cast[Ptr[uint8]]("CustomEvent"), 11, \
                  js_new_native_fn(js_hbase + NID_CUSTOMEVENT))
    js_global_set(cast[Ptr[uint8]]("MouseEvent"), 10, \
                  js_new_native_fn(js_hbase + NID_MOUSEEVENT))
    js_global_set(cast[Ptr[uint8]]("KeyboardEvent"), 13, \
                  js_new_native_fn(js_hbase + NID_KEYBDEVENT))
    # `new Image()` constructor — a common preload/beacon global (round: google).
    js_global_set(cast[Ptr[uint8]]("Image"), 5, \
                  js_new_native_fn(js_hbase + NID_IMAGE_CTOR))
    # getComputedStyle(el) — a window/global function returning a resolved-style
    # object (dropdown/tooltip/carousel code reads .display / .width off it).
    js_global_set(cast[Ptr[uint8]]("getComputedStyle"), 16, \
                  js_new_native_fn(js_hbase + NID_GETCOMPSTYLE))
    # window.matchMedia(query) — a MediaQueryList whose `.matches` re-uses the
    # engine's @media evaluator (he_media_match) against the LIVE viewport. Both
    # `window.matchMedia` and the bare global resolve (like getComputedStyle).
    js_global_set(cast[Ptr[uint8]]("matchMedia"), 10, \
                  js_new_native_fn(js_hbase + NID_MATCHMEDIA))
    if js_type_of(js_win) == 5:
        js_set_prop(js_win, cast[Ptr[uint8]]("matchMedia"), 10, \
                    js_new_native_fn(js_hbase + NID_MATCHMEDIA))
    # Observer constructors modern frameworks depend on. Each is a native
    # constructor; `new X(cb)` runs the ctor NID handler with the fresh instance
    # as `this` (see _obs_dispatch). Reset the (per-page) observer registries so a
    # fresh js_init starts clean.
    _obs_reset()
    js_global_set(cast[Ptr[uint8]]("MutationObserver"), 16, \
                  js_new_native_fn(js_hbase + NID_MO_CTOR))
    js_global_set(cast[Ptr[uint8]]("IntersectionObserver"), 20, \
                  js_new_native_fn(js_hbase + NID_IO_CTOR))
    js_global_set(cast[Ptr[uint8]]("ResizeObserver"), 14, \
                  js_new_native_fn(js_hbase + NID_RO_CTOR))
    # window.history + window.location methods (History API / Location).
    _wire_history_location()


# Eagerly register every <form> and its fields, exposing document.forms and
# each form's .elements array so a script can iterate them. Registering here
# means getElementById later returns the SAME element objects.
def _build_forms(doc: int32):
    forms: int32 = js_new_array_v()
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           _tagname_is(i + 1, cast[Ptr[uint8]]("form")) != 0:
            _scan_start_tag(i)
            fclose: uint64 = g_close_end
            fi: int32 = _dom_lookup_anchor(cast[int32](g_el_lt))
            if fi < 0:
                _dom_register_el()
                fi = _dom_lookup_anchor(cast[int32](g_el_lt))
            if fi >= 0:
                fobj: int32 = dom_obj[fi]
                elems: int32 = js_new_array_v()
                cs: uint64 = cast[uint64](dom_cstart[fi])
                ce: uint64 = cast[uint64](dom_cend[fi])
                j: uint64 = cs
                while j < ce:
                    if src_ptr[j] == 60 and j + 1 < ce and \
                       (_tagname_is(j + 1, cast[Ptr[uint8]]("input")) != 0 or \
                        _tagname_is(j + 1, cast[Ptr[uint8]]("select")) != 0 or \
                        _tagname_is(j + 1, cast[Ptr[uint8]]("textarea")) != 0):
                        _scan_start_tag(j)
                        jclose: uint64 = g_close_end
                        ei: int32 = _dom_lookup_anchor(cast[int32](g_el_lt))
                        if ei < 0:
                            _dom_register_el()
                            ei = _dom_lookup_anchor(cast[int32](g_el_lt))
                        if ei >= 0:
                            js_array_push(elems, dom_obj[ei])
                        j = jclose
                        continue
                    j = j + 1
                js_set_prop(fobj, cast[Ptr[uint8]]("elements"), 8, elems)
                js_array_push(forms, fobj)
            i = fclose
            continue
        i = i + 1
    js_set_prop(doc, cast[Ptr[uint8]]("forms"), 5, forms)


# Is `p[0..n)` the literal "undefined"? (a read of a never-set JS property).
def _is_undef_str(p: Ptr[uint8], n: int32) -> int32:
    return _bytes_eq(p, n, cast[Ptr[uint8]]("undefined"), 9)


# Read one JS string property `name` of object `o`; if non-empty and not
# "undefined", copy it into dom_ovbuf and set *off/*len via the returned pair
# encoded as: returns the length, and sets g_rb_off to the offset. -1 = unset.
g_rb_off: int32 = 0


def _readback_str(o: int32, name: Ptr[uint8], nlen: uint64) -> int32:
    v: int32 = js_get_prop(o, name, nlen)
    p: Ptr[uint8] = js_str_ptr(v)
    n: int32 = _cstr_len(p)
    if n == 0 or _is_undef_str(p, n) != 0:
        return -1
    g_rb_off = dom_ov_len
    k: int32 = 0
    while k < n and dom_ov_len < DOM_OV_CAP:
        dom_ovbuf[dom_ov_len] = p[k]
        dom_ov_len = dom_ov_len + 1
        k = k + 1
    return k


# Read the JS-mutated DOM back into the override tables. Idempotent: resets the
# override accumulators first, so it can run after the initial scripts AND
# again after an event handler mutates the DOM.
def _dom_readback():
    dom_ov_len = 0
    dom_n_overrides = 0
    idx: int32 = 0
    while idx < dom_n:
        o: int32 = dom_obj[idx]
        dom_ov_inner_off[idx] = -1
        dom_ov_inner_len[idx] = -1
        dom_ov_inner_html[idx] = 0
        dom_ov_col_off[idx] = -1
        dom_ov_col_len[idx] = -1
        dom_ov_bg_off[idx] = -1
        dom_ov_bg_len[idx] = -1
        dom_ov_wt_off[idx] = -1
        dom_ov_wt_len[idx] = -1
        dom_ov_al_off[idx] = -1
        dom_ov_al_len[idx] = -1
        dom_ov_wd_off[idx] = -1
        dom_ov_wd_len[idx] = -1
        dom_ov_cls_off[idx] = -1
        dom_ov_cls_len[idx] = -1
        dom_ov_hide[idx] = 0
        dom_ov_val_off[idx] = -1
        dom_ov_val_len[idx] = -1
        dom_ov_checked[idx] = -1
        changed: int32 = 0
        # innerHTML (raw) takes priority over textContent (escaped) as inner.
        hv: int32 = js_get_prop(o, cast[Ptr[uint8]]("innerHTML"), 9)
        hp: Ptr[uint8] = js_str_ptr(hv)
        hn: int32 = _cstr_len(hp)
        if _bytes_eq(hp, hn, &dom_txtbuf[dom_html_off[idx]], \
                     dom_html_len[idx]) == 0 and _is_undef_str(hp, hn) == 0:
            off: int32 = dom_ov_len
            k: int32 = 0
            while k < hn and dom_ov_len < DOM_OV_CAP:
                dom_ovbuf[dom_ov_len] = hp[k]
                dom_ov_len = dom_ov_len + 1
                k = k + 1
            dom_ov_inner_off[idx] = off
            dom_ov_inner_len[idx] = k
            dom_ov_inner_html[idx] = 1
            changed = 1
        else:
            tc: int32 = js_get_prop(o, cast[Ptr[uint8]]("textContent"), 11)
            tp: Ptr[uint8] = js_str_ptr(tc)
            tn: int32 = _cstr_len(tp)
            if _bytes_eq(tp, tn, &dom_txtbuf[dom_orig_off[idx]], \
                         dom_orig_len[idx]) == 0 and _is_undef_str(tp, tn) == 0:
                off2: int32 = dom_ov_len
                k2: int32 = 0
                while k2 < tn and dom_ov_len < DOM_OV_CAP:
                    dom_ovbuf[dom_ov_len] = tp[k2]
                    dom_ov_len = dom_ov_len + 1
                    k2 = k2 + 1
                dom_ov_inner_off[idx] = off2
                dom_ov_inner_len[idx] = k2
                dom_ov_inner_html[idx] = 0
                changed = 1
        # style props
        stv: int32 = js_get_prop(o, cast[Ptr[uint8]]("style"), 5)
        r: int32 = _readback_str(stv, cast[Ptr[uint8]]("color"), 5)
        if r >= 0:
            dom_ov_col_off[idx] = g_rb_off
            dom_ov_col_len[idx] = r
            changed = 1
        r = _readback_str(stv, cast[Ptr[uint8]]("backgroundColor"), 15)
        if r >= 0:
            dom_ov_bg_off[idx] = g_rb_off
            dom_ov_bg_len[idx] = r
            changed = 1
        r = _readback_str(stv, cast[Ptr[uint8]]("fontWeight"), 10)
        if r >= 0:
            dom_ov_wt_off[idx] = g_rb_off
            dom_ov_wt_len[idx] = r
            changed = 1
        r = _readback_str(stv, cast[Ptr[uint8]]("textAlign"), 9)
        if r >= 0:
            dom_ov_al_off[idx] = g_rb_off
            dom_ov_al_len[idx] = r
            changed = 1
        r = _readback_str(stv, cast[Ptr[uint8]]("width"), 5)
        if r >= 0:
            dom_ov_wd_off[idx] = g_rb_off
            dom_ov_wd_len[idx] = r
            changed = 1
        # display:none
        dv: int32 = js_get_prop(stv, cast[Ptr[uint8]]("display"), 7)
        dp: Ptr[uint8] = js_str_ptr(dv)
        dn: int32 = _cstr_len(dp)
        if _bytes_eq(dp, dn, cast[Ptr[uint8]]("none"), 4) != 0:
            dom_ov_hide[idx] = 1
            changed = 1
        # className
        clv: int32 = js_get_prop(o, cast[Ptr[uint8]]("className"), 9)
        clp: Ptr[uint8] = js_str_ptr(clv)
        cln: int32 = _cstr_len(clp)
        if _bytes_eq(clp, cln, &dom_txtbuf[dom_origcls_off[idx]], \
                     dom_origcls_len[idx]) == 0 and _is_undef_str(clp, cln) == 0:
            cco: int32 = dom_ov_len
            kc: int32 = 0
            while kc < cln and dom_ov_len < DOM_OV_CAP:
                dom_ovbuf[dom_ov_len] = clp[kc]
                dom_ov_len = dom_ov_len + 1
                kc = kc + 1
            dom_ov_cls_off[idx] = cco
            dom_ov_cls_len[idx] = kc
            changed = 1
        # form value / checked read-back (input / textarea / select).
        if dom_kind[idx] == 1 or dom_kind[idx] == 2 or dom_kind[idx] == 3:
            vv: int32 = js_get_prop(o, cast[Ptr[uint8]]("value"), 5)
            vp: Ptr[uint8] = js_str_ptr(vv)
            vn: int32 = _cstr_len(vp)
            if _bytes_eq(vp, vn, &dom_txtbuf[dom_origval_off[idx]], \
                         dom_origval_len[idx]) == 0 and _is_undef_str(vp, vn) == 0:
                voff: int32 = dom_ov_len
                kv: int32 = 0
                while kv < vn and dom_ov_len < DOM_OV_CAP:
                    dom_ovbuf[dom_ov_len] = vp[kv]
                    dom_ov_len = dom_ov_len + 1
                    kv = kv + 1
                dom_ov_val_off[idx] = voff
                dom_ov_val_len[idx] = kv
                changed = 1
        # select: a JS `selectedIndex = N` write with no matching value write
        # resolves to the Nth option's text so the control re-marks + re-renders.
        if dom_kind[idx] == 3 and dom_ov_val_len[idx] < 0:
            siv: int32 = js_get_prop(o, cast[Ptr[uint8]]("selectedIndex"), 13)
            si: int32 = cast[int32](js_to_number(siv))
            oi: int32 = _select_index(cast[uint64](dom_cstart[idx]))
            if si != oi and si >= 0:
                sn: int32 = _select_optext_at(cast[uint64](dom_cstart[idx]), si)
                if sn >= 0:
                    soff: int32 = dom_ov_len
                    ks: int32 = 0
                    while ks < sn and dom_ov_len < DOM_OV_CAP:
                        dom_ovbuf[dom_ov_len] = fbuf[ks]
                        dom_ov_len = dom_ov_len + 1
                        ks = ks + 1
                    dom_ov_val_off[idx] = soff
                    dom_ov_val_len[idx] = ks
                    js_set_prop(o, cast[Ptr[uint8]]("value"), 5, \
                                js_new_string(&fbuf[0], cast[uint64](ks)))
                    changed = 1
        if dom_origchecked[idx] >= 0:
            ckv: int32 = js_get_prop(o, cast[Ptr[uint8]]("checked"), 7)
            ckb: int32 = 0
            if js_to_bool(ckv) != 0:
                ckb = 1
            if ckb != dom_origchecked[idx]:
                dom_ov_checked[idx] = ckb
                changed = 1
        # assigned handler-function properties (el.onX = fn).
        ocv: int32 = js_get_prop(o, cast[Ptr[uint8]]("onclick"), 7)
        if js_is_callable(ocv) != 0:
            dom_onclick_fn[idx] = ocv
        oiv: int32 = js_get_prop(o, cast[Ptr[uint8]]("oninput"), 7)
        if js_is_callable(oiv) != 0:
            dom_oninput_fn[idx] = oiv
        ocgv: int32 = js_get_prop(o, cast[Ptr[uint8]]("onchange"), 8)
        if js_is_callable(ocgv) != 0:
            dom_onchange_fn[idx] = ocgv
        osv: int32 = js_get_prop(o, cast[Ptr[uint8]]("onsubmit"), 8)
        if js_is_callable(osv) != 0:
            dom_onsubmit_fn[idx] = osv
        # appended children force a rewrite of this element too.
        a: int32 = 0
        while a < ap_n:
            if ap_removed[a] == 0 and ap_parent[a] == idx:
                changed = 1
            a = a + 1
        if changed != 0:
            dom_n_overrides = dom_n_overrides + 1
        idx = idx + 1
    # document.title
    tv: int32 = js_get_prop(js_doc, cast[Ptr[uint8]]("title"), 5)
    pp: Ptr[uint8] = js_str_ptr(tv)
    pn: int32 = _cstr_len(pp)
    if pn > 255:
        pn = 255
    j: int32 = 0
    while j < pn:
        dom_title_buf[j] = pp[j]
        j = j + 1
    dom_title_len = pn
    dom_title_present = 1


def _js_capture_console():
    p: Ptr[uint8] = js_out_ptr()
    n: int32 = cast[int32](js_out_len())
    i: int32 = 0
    while i < n and i < 1048575:
        js_con_buf[i] = p[i]
        i = i + 1
    js_con_buf[i] = 0
    js_con_len = i


# True if the source contains a <script> element OR any inline event-handler
# attribute (onclick=/oninput=/onchange=/onsubmit=/onkeyup=/...). A page whose
# only JS is inline handlers (no <script> block) — extremely common on real
# forms/buttons — still needs a live JS context so he_dom_click / set_value can
# fire those handlers and re-render. Attribute names are matched only at an
# attribute-name boundary (preceded by whitespace) inside a tag, so the word
# "onclick" in body text never triggers a spurious JS init.
def _page_has_js() -> int32:
    p: uint64 = 0
    while p < src_len:
        if src_ptr[p] != 60:                                 # '<'
            p = p + 1
            continue
        if p + 1 < src_len and \
           _tagname_is(p + 1, cast[Ptr[uint8]]("script")) != 0:
            return 1
        # scan this tag's attributes for an on<letters>= handler name
        q: uint64 = p + 1
        prev_ws: int32 = 0
        while q < src_len and src_ptr[q] != 62:              # up to '>'
            c: uint8 = src_ptr[q]
            if prev_ws != 0 and (c == 111 or c == 79) and \
               q + 2 < src_len and (src_ptr[q + 1] == 110 or src_ptr[q + 1] == 78):
                # "on" at a name boundary: require >=1 more letter then '='
                r: uint64 = q + 2
                nletters: int32 = 0
                while r < src_len and src_ptr[r] != 62 and \
                      ((src_ptr[r] >= 97 and src_ptr[r] <= 122) or \
                       (src_ptr[r] >= 65 and src_ptr[r] <= 90)):
                    r = r + 1
                    nletters = nletters + 1
                while r < src_len and \
                      (src_ptr[r] == 32 or src_ptr[r] == 9 or \
                       src_ptr[r] == 10 or src_ptr[r] == 13):
                    r = r + 1
                if nletters >= 1 and r < src_len and src_ptr[r] == 61:   # '='
                    return 1
            if c == 32 or c == 9 or c == 10 or c == 13:
                prev_ws = 1
            else:
                prev_ws = 0
            q = q + 1
        p = q
    return 0


# True if a <script> start tag [ts,te) carries `type="module"` (case-insensitive)
# — the trigger to evaluate its body as an ES module rather than a classic script.
def _script_type_is_module(ts: uint64, te: uint64) -> int32:
    if _hx_find_attr(ts, te, cast[Ptr[uint8]]("type")) == 0:
        return 0
    want: Ptr[uint8] = cast[Ptr[uint8]]("module")
    n: int32 = 0
    p: uint64 = g_attr_start
    while p < g_attr_end:
        if want[n] == 0:
            return 0                              # value longer than "module"
        if _hx_lower(src_ptr[p]) != want[n]:
            return 0
        n = n + 1
        p = p + 1
    if want[n] != 0:
        return 0                                  # value shorter than "module"
    return 1


# A unique specifier for an inline module, keyed off its source byte offset so
# two distinct <script type=module> blocks never collide in the module cache.
inline_spec_buf: Array[24, uint8]
_inline_spec_len: uint64 = 0

def _inline_module_spec(off: uint64) -> Ptr[uint8]:
    inline_spec_buf[0] = 105                       # 'i'
    inline_spec_buf[1] = 110                       # 'n'
    inline_spec_buf[2] = 58                        # ':'
    n: int32 = 3
    # decimal of off (offset 0 -> "in:0")
    if off == 0:
        inline_spec_buf[n] = 48
        n = n + 1
    else:
        start: int32 = n
        v: uint64 = off
        while v > 0:
            inline_spec_buf[n] = cast[uint8](48 + cast[int32](v % 10))
            v = v / 10
            n = n + 1
        # reverse the digits in place
        a: int32 = start
        b: int32 = n - 1
        while a < b:
            t: uint8 = inline_spec_buf[a]
            inline_spec_buf[a] = inline_spec_buf[b]
            inline_spec_buf[b] = t
            a = a + 1
            b = b - 1
    inline_spec_buf[n] = 0
    _inline_spec_len = cast[uint64](n)
    return &inline_spec_buf[0]


# Run every <script> body. Returns 1 if at least one script ran (so the DOM
# overrides are meaningful), 0 if the page had no scripts at all.
# Refresh the geometry data properties (offset*/client*/scroll*) of every
# already-registered element from the current layout. Called after the
# pre-layout pass so elements registered before layout (e.g. form fields wired
# up in _js_build_document) still report correct box metrics to scripts.
def _refresh_all_geom():
    i: int32 = 0
    while i < dom_n:
        _set_el_geom_props(dom_obj[i], i)
        i = i + 1


def _run_scripts() -> int32:
    # A live JS context is needed if the page has a <script> element OR any
    # inline on<evt>="" handler (no <script> required for interactivity).
    has: int32 = _page_has_js()
    # A native front-end (he_click_links) needs a live JS context + registered
    # form fields even for a script-LESS page, so a plain <form> is still
    # pointer-focusable/typable/submittable. Host renders keep the old fast path.
    force_ctx: int32 = 0
    if has == 0 and he_click_links != 0 and _page_has_form() != 0:
        force_ctx = 1
    if has == 0 and force_ctx == 0:
        # No script, but the tab title still needs the page <title> (decoded).
        dom_title_len = _scan_title()
        if dom_title_len > 0:
            dom_title_present = 1
        return 0
    js_init()
    js_hbase = js_host_base()
    js_set_host_dispatch(cast[Fn[int32, int32]](cast[uint64](_js_host_dispatch)))
    js_set_member_hook(cast[Fn[int32, int32]](cast[uint64](_js_member_set_hook)))
    _js_build_document()
    _dom_build_tree_index()                               # parent/child overlay (round 2)
    js_ctx_live = 1
    # PRE-LAYOUT: lay out the (pre-script) source once so a page's <script>s can
    # read box geometry (getBoundingClientRect / offsetWidth / getComputedStyle).
    # The final _relayout() after scripts rebuilds the segment table with any DOM
    # overrides baked in, so this pass is invisible to the rendered output — it
    # only makes layout coordinates available to script code (as browsers do).
    _layout()
    _refresh_all_geom()
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           _tagname_is(i + 1, cast[Ptr[uint8]]("script")) != 0:
            # body starts after this start tag's '>'
            j: uint64 = i + 1
            while j < src_len and src_ptr[j] != 62:
                j = j + 1
            tagclose: uint64 = j                 # position of the start tag's '>'
            if j < src_len:
                j = j + 1
            bs: uint64 = j
            is_mod: int32 = _script_type_is_module(i, tagclose)
            # body ends at </script>
            be: uint64 = bs
            while be < src_len:
                if src_ptr[be] == 60 and be + 1 < src_len and \
                   src_ptr[be + 1] == 47 and \
                   _tagname_is(be + 2, cast[Ptr[uint8]]("script")) != 0:
                    break
                be = be + 1
            if be > bs:
                if is_mod != 0:
                    # `<script type=module>`: evaluate as an ES module (own scope,
                    # deferred-style, imports resolved through the browser's module
                    # resolver). A unique specifier per inline module keeps the
                    # module cache from collapsing distinct blocks together.
                    js_run_module(&src_ptr[bs], be - bs, _inline_module_spec(bs), _inline_spec_len)
                else:
                    js_eval(&src_ptr[bs], be - bs)
                if js_error() != 0:
                    js_had_error = 1
            # continue past </script>
            i = be
            while i < src_len and src_ptr[i] != 62:
                i = i + 1
            if i < src_len:
                i = i + 1
            continue
        i = i + 1
    # All page <script>s have run and the DOM is fully parsed: fire the document
    # lifecycle events in spec order — DOMContentLoaded, then load — so page code
    # that defers init to `document.addEventListener('DOMContentLoaded', …)` (the
    # dominant framework/analytics pattern) actually runs. No-ops when nothing
    # registered for the type (fast pre-scan in _fire_document).
    _fire_document(cast[Ptr[uint8]]("DOMContentLoaded"), 16)
    _fire_document(cast[Ptr[uint8]]("load"), 4)
    # window.onload = fn (an IDL event-handler attribute on the window/global,
    # not an addEventListener registration) fires as part of the load event, once,
    # after the addEventListener('load') listeners. It is the single most common
    # page init hook, so honour it explicitly: read the global `onload` binding
    # (writing window.onload defines a global) and invoke it if callable.
    _fire_window_onload()
    _js_capture_console()
    _dom_readback()
    return 1


# Fire window.onload once, if the page assigned a callable to it. A fresh load
# event (type=load, target=document) is passed. Idempotent-safe: only runs when
# `onload` resolves to a callable global.
def _fire_window_onload() -> int32:
    ofn: int32 = js_global_get(cast[Ptr[uint8]]("onload"), 6)
    if js_is_callable(ofn) == 0:
        return 0
    ev: int32 = js_new_object_v()
    js_set_prop(ev, cast[Ptr[uint8]]("type"), 4, \
                js_new_string(cast[Ptr[uint8]]("load"), 4))
    js_set_prop(ev, cast[Ptr[uint8]]("target"), 6, js_doc)
    js_set_prop(ev, cast[Ptr[uint8]]("currentTarget"), 13, js_doc)
    js_set_prop(ev, cast[Ptr[uint8]]("eventPhase"), 10, js_number(cast[float64](2)))
    js_set_prop(ev, cast[Ptr[uint8]]("bubbles"), 7, js_bool(0))
    js_set_prop(ev, cast[Ptr[uint8]]("defaultPrevented"), 16, js_bool(0))
    js_set_prop(ev, cast[Ptr[uint8]]("preventDefault"), 14, \
                js_new_native_fn(js_hbase + NID_PREVENT))
    js_global_set(cast[Ptr[uint8]]("event"), 5, ev)
    thisv: int32 = js_win
    if js_type_of(thisv) != 5:
        thisv = js_doc
    g_argv1[0] = ev
    js_call_fn(ofn, thisv, &g_argv1[0], 1)
    return 1


# ---- source rewrite (only when overrides exist) --------------------
def _rw_ch(c: uint8):
    if rw_len < RW_CAP:
        rw_buf[rw_len] = c
        rw_len = rw_len + 1


def _rw_range(a: uint64, b: uint64):
    i: uint64 = a
    while i < b:
        _rw_ch(src_ptr[i])
        i = i + 1


def _rw_cstr(s: Ptr[uint8]):
    i: int32 = 0
    while s[i] != 0:
        _rw_ch(s[i])
        i = i + 1


def _rw_ovbuf(off: int32, ln: int32):
    i: int32 = 0
    while i < ln:
        _rw_ch(dom_ovbuf[off + i])
        i = i + 1


# Emit `ln` raw bytes from a pointer (e.g. a created node's innerHTML markup).
def _rw_ovbuf_ptr(p: Ptr[uint8], ln: int32):
    i: int32 = 0
    while i < ln:
        _rw_ch(p[i])
        i = i + 1


# emit override bytes, escaping '<' and '&' so injected textContent renders as
# literal text (never re-parsed as markup).
def _rw_text_escaped(off: int32, ln: int32):
    i: int32 = 0
    while i < ln:
        c: uint8 = dom_ovbuf[off + i]
        if c == 60:
            _rw_cstr(cast[Ptr[uint8]]("&lt;"))
        elif c == 38:
            _rw_cstr(cast[Ptr[uint8]]("&amp;"))
        else:
            _rw_ch(c)
        i = i + 1


def _el_has_override(idx: int32) -> int32:
    if dom_ov_hide[idx] != 0 or dom_ov_inner_len[idx] >= 0 or \
       dom_ov_col_len[idx] >= 0 or dom_ov_bg_len[idx] >= 0 or \
       dom_ov_wt_len[idx] >= 0 or dom_ov_al_len[idx] >= 0 or \
       dom_ov_wd_len[idx] >= 0 or \
       dom_ov_cls_len[idx] >= 0 or dom_ov_val_len[idx] >= 0 or \
       dom_ov_checked[idx] >= 0:
        return 1
    # a click handler alone makes the element a rewrite target when the native
    # front-end wants clickable event-links.
    if he_click_links != 0 and _el_has_handler(idx) != 0:
        return 1
    # a focusable/submit form control is wrapped so a pointer click reaches it.
    if _is_wrappable_field(idx) != 0:
        return 1
    a: int32 = 0
    while a < ap_n:
        if ap_removed[a] == 0 and ap_parent[a] == idx:
            return 1
        a = a + 1
    return 0


def _rw_dec(v: int32):
    if v == 0:
        _rw_ch(48)
        return
    d: Array[12, uint8]
    n: int32 = 0
    x: int32 = v
    while x > 0:
        d[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _rw_ch(d[n])


# Emit escaped text (rewriting '<' and '&') from a JS string value.
def _rw_js_escaped(v: int32):
    p: Ptr[uint8] = js_str_ptr(v)
    n: int32 = _cstr_len(p)
    if _is_undef_str(p, n) != 0:
        return
    i: int32 = 0
    while i < n:
        c: uint8 = p[i]
        if c == 60:
            _rw_cstr(cast[Ptr[uint8]]("&lt;"))
        elif c == 38:
            _rw_cstr(cast[Ptr[uint8]]("&amp;"))
        else:
            _rw_ch(c)
        i = i + 1


# Emit ` name="value"` for a created node's JS property (skips empty/undefined).
# The value is attribute-escaped ('"' -> &quot;, '&' -> &amp;).
def _emit_cre_attr(co: int32, prop: Ptr[uint8], plen: uint64, aname: Ptr[uint8]):
    v: int32 = js_get_prop(co, prop, plen)
    p: Ptr[uint8] = js_str_ptr(v)
    n: int32 = _cstr_len(p)
    if n == 0 or _is_undef_str(p, n) != 0:
        return
    _rw_ch(32)
    _rw_cstr(aname)
    _rw_cstr(cast[Ptr[uint8]]("=\""))
    i: int32 = 0
    while i < n:
        c: uint8 = p[i]
        if c == 34:
            _rw_cstr(cast[Ptr[uint8]]("&quot;"))
        elif c == 38:
            _rw_cstr(cast[Ptr[uint8]]("&amp;"))
        else:
            _rw_ch(c)
        i = i + 1
    _rw_ch(34)


# Emit a script-created node's markup, RECURSIVELY: a text node emits only its
# escaped text; an element emits <tag id class style>inner</tag> where `inner`
# is innerHTML (raw) if set, else the escaped textContent followed by its nested
# created children (so a table > tr > td subtree built entirely in script
# renders with its full structure). Detached nodes (node.remove()) are skipped.
def _emit_created(cid: int32):
    if cre_gone[cid] != 0:
        return
    co: int32 = cre_obj[cid]
    if cre_is_text[cid] != 0:
        _rw_js_escaped(js_get_prop(co, cast[Ptr[uint8]]("textContent"), 11))
        return
    _rw_ch(60)                                            # '<'
    t: int32 = 0
    while t < cre_tag_len[cid]:
        _rw_ch(dom_idbuf[cre_tag_off[cid] + t])
        t = t + 1
    _emit_cre_attr(co, cast[Ptr[uint8]]("id"), 2, cast[Ptr[uint8]]("id"))
    _emit_cre_attr(co, cast[Ptr[uint8]]("className"), 9, cast[Ptr[uint8]]("class"))
    _rw_ch(62)                                            # '>'
    # Inline `.style.*` overrides are carried on an INNER <span> — some elements
    # (e.g. <li>, table cells) don't parse an inline style="" on their own tag,
    # whereas an inline <span> reliably honours color/bg/weight/align. className
    # (a real class) is emitted as a tag attribute above so the CSS cascade sees
    # it. The span wraps both the textContent and any nested created children.
    stv: int32 = js_get_prop(co, cast[Ptr[uint8]]("style"), 5)
    dom_ov_len_save: int32 = dom_ov_len
    cl: int32 = _readback_str(stv, cast[Ptr[uint8]]("color"), 5)
    col_off: int32 = g_rb_off
    bg: int32 = _readback_str(stv, cast[Ptr[uint8]]("backgroundColor"), 15)
    bg_off: int32 = g_rb_off
    wt: int32 = _readback_str(stv, cast[Ptr[uint8]]("fontWeight"), 10)
    wt_off: int32 = g_rb_off
    al: int32 = _readback_str(stv, cast[Ptr[uint8]]("textAlign"), 9)
    al_off: int32 = g_rb_off
    has_style: int32 = 0
    if cl >= 0 or bg >= 0 or wt >= 0 or al >= 0:
        has_style = 1
        _rw_cstr(cast[Ptr[uint8]]("<span style=\""))
        if cl >= 0:
            _rw_cstr(cast[Ptr[uint8]]("color:"))
            _rw_ovbuf(col_off, cl)
            _rw_ch(59)
        if bg >= 0:
            _rw_cstr(cast[Ptr[uint8]]("background-color:"))
            _rw_ovbuf(bg_off, bg)
            _rw_ch(59)
        if wt >= 0:
            _rw_cstr(cast[Ptr[uint8]]("font-weight:"))
            _rw_ovbuf(wt_off, wt)
            _rw_ch(59)
        if al >= 0:
            _rw_cstr(cast[Ptr[uint8]]("text-align:"))
            _rw_ovbuf(al_off, al)
            _rw_ch(59)
        _rw_cstr(cast[Ptr[uint8]]("\">"))
    dom_ov_len = dom_ov_len_save                          # scratch reclaim
    # inner: innerHTML (raw) wins; else textContent (escaped) + nested children.
    hv: int32 = js_get_prop(co, cast[Ptr[uint8]]("innerHTML"), 9)
    hp: Ptr[uint8] = js_str_ptr(hv)
    hn: int32 = _cstr_len(hp)
    if hn > 0 and _is_undef_str(hp, hn) == 0:
        _rw_ovbuf_ptr(hp, hn)
    else:
        _rw_js_escaped(js_get_prop(co, cast[Ptr[uint8]]("textContent"), 11))
        a: int32 = 0
        while a < cc_n:
            if cc_removed[a] == 0 and cc_owner[a] == cid:
                _emit_created(cc_child[a])
            a = a + 1
    if has_style != 0:
        _rw_cstr(cast[Ptr[uint8]]("</span>"))
    _rw_cstr(cast[Ptr[uint8]]("</"))
    t2: int32 = 0
    while t2 < cre_tag_len[cid]:
        _rw_ch(dom_idbuf[cre_tag_off[cid] + t2])
        t2 = t2 + 1
    _rw_ch(62)


# Emit the merged inline style="" for an element's style overrides (or nothing).
def _emit_merged_style(idx: int32):
    if dom_ov_col_len[idx] < 0 and dom_ov_bg_len[idx] < 0 and \
       dom_ov_wt_len[idx] < 0 and dom_ov_al_len[idx] < 0 and \
       dom_ov_wd_len[idx] < 0:
        return
    _rw_cstr(cast[Ptr[uint8]](" style=\""))
    if dom_ov_col_len[idx] >= 0:
        _rw_cstr(cast[Ptr[uint8]]("color:"))
        _rw_ovbuf(dom_ov_col_off[idx], dom_ov_col_len[idx])
        _rw_ch(59)
    if dom_ov_bg_len[idx] >= 0:
        _rw_cstr(cast[Ptr[uint8]]("background-color:"))
        _rw_ovbuf(dom_ov_bg_off[idx], dom_ov_bg_len[idx])
        _rw_ch(59)
    if dom_ov_wt_len[idx] >= 0:
        _rw_cstr(cast[Ptr[uint8]]("font-weight:"))
        _rw_ovbuf(dom_ov_wt_off[idx], dom_ov_wt_len[idx])
        _rw_ch(59)
    if dom_ov_al_len[idx] >= 0:
        _rw_cstr(cast[Ptr[uint8]]("text-align:"))
        _rw_ovbuf(dom_ov_al_off[idx], dom_ov_al_len[idx])
        _rw_ch(59)
    if dom_ov_wd_len[idx] >= 0:
        _rw_cstr(cast[Ptr[uint8]]("width:"))
        _rw_ovbuf(dom_ov_wd_off[idx], dom_ov_wd_len[idx])
        _rw_ch(59)
    _rw_ch(34)


# Copy tag-body attributes [a,b) into rw_buf, dropping any attribute named
# `s1` or `s2` (case-insensitive; both valued `name="v"` and bare `name` forms).
def _rw_copy_attrs_except(a: uint64, b: uint64, s1: Ptr[uint8], s2: Ptr[uint8]):
    l1: int32 = _cstr_len(s1)
    l2: int32 = _cstr_len(s2)
    i: uint64 = a
    while i < b:
        c: uint8 = src_ptr[i]
        if c == 32 or c == 9 or c == 10 or c == 13:
            _rw_ch(c)
            i = i + 1
            continue
        ns: uint64 = i
        while i < b and _is_name_ch(src_ptr[i]) != 0:
            i = i + 1
        ne2: uint64 = i
        # look ahead past spaces for '=' to find a valued attribute
        k: uint64 = i
        while k < b and (src_ptr[k] == 32 or src_ptr[k] == 9):
            k = k + 1
        attr_end: uint64 = ne2
        if k < b and src_ptr[k] == 61:                    # '='
            k = k + 1
            while k < b and (src_ptr[k] == 32 or src_ptr[k] == 9):
                k = k + 1
            if k < b and (src_ptr[k] == 34 or src_ptr[k] == 39):
                q: uint8 = src_ptr[k]
                k = k + 1
                while k < b and src_ptr[k] != q:
                    k = k + 1
                if k < b:
                    k = k + 1
            else:
                while k < b and src_ptr[k] != 32 and src_ptr[k] != 9:
                    k = k + 1
            attr_end = k
        skip: int32 = 0
        if _idbytes_eq(ns, ne2, s1, l1) != 0 or _idbytes_eq(ns, ne2, s2, l2) != 0:
            skip = 1
        if skip == 0:
            _rw_range(ns, attr_end)
        i = attr_end


# Does dom_ovbuf[off..off+len) equal src span [a,b) (byte-exact)?
def _ovbuf_eq_src(off: int32, ln: int32, a: uint64, b: uint64) -> int32:
    if cast[int32](b - a) != ln:
        return 0
    i: int32 = 0
    while i < ln:
        if dom_ovbuf[off + i] != src_ptr[a + cast[uint64](i)]:
            return 0
        i = i + 1
    return 1


# Re-emit a <select>'s option list [cs,ce), moving `selected` onto the option
# whose visible text equals the override value dom_ovbuf[voff..voff+vlen).
def _rw_select_options(cs: uint64, ce: uint64, voff: int32, vlen: int32):
    i: uint64 = cs
    while i < ce:
        if src_ptr[i] == 60 and _tagname_is(i + 1, cast[Ptr[uint8]]("option")) != 0:
            je: uint64 = i + 1
            while je < ce and src_ptr[je] != 62:
                je = je + 1
            ne: uint64 = i + 1
            while ne < je and _alnum_at(ne) != 0:
                ne = ne + 1
            ots: uint64 = je + 1
            ote: uint64 = ots
            while ote < ce and src_ptr[ote] != 60:
                ote = ote + 1
            _rw_ch(60)
            _rw_range(i + 1, ne)                          # 'option'
            _rw_copy_attrs_except(ne, je, cast[Ptr[uint8]]("selected"), \
                                  cast[Ptr[uint8]]("selected"))
            if _ovbuf_eq_src(voff, vlen, ots, ote) != 0:
                _rw_cstr(cast[Ptr[uint8]](" selected"))
            _rw_ch(62)
            i = je + 1
            continue
        _rw_ch(src_ptr[i])
        i = i + 1


# Build rw_buf: a copy of the source with each overridden element's mutations
# baked in. Overridden elements are matched by their source anchor offset, so
# id-less querySelector matches work too. Elements without overrides copy
# through byte-for-byte, so the rest of the page's layout is unchanged.
def _build_rewrite():
    rw_len = 0
    _rewrite_range(0, src_len)


# Emit the source range [lo,hi) into rw_buf, baking in each overridden element's
# mutations. Recursive: an element whose inner content is NOT wholly replaced
# (only class/style/attr/appended-child overrides) re-processes its own inner
# range so descendant overrides still apply — e.g. document.body.appendChild()
# alongside a mutation on a node INSIDE body (the flat copy dropped the latter).
def _rewrite_range(lo: uint64, hi: uint64):
    i: uint64 = lo
    while i < hi:
        c: uint8 = src_ptr[i]
        if c == 60 and i + 1 < src_len and src_ptr[i + 1] != 47 and \
           src_ptr[i + 1] != 33 and src_ptr[i + 1] != 63:
            idx: int32 = _dom_lookup_anchor(cast[int32](i))
            if idx >= 0 and _el_has_override(idx) != 0:
                # A focusable/submit form control is wrapped OUTSIDE its tag
                # (<a ..><input></a>) so the input's own box word inherits the
                # link and the pointer hit-test resolves to it. Click-handler
                # elements keep the INNER wrap (their clickable content is the
                # element's text), so the two are mutually exclusive.
                wrap_outer: int32 = 0
                if _is_wrappable_field(idx) != 0:
                    wrap_outer = 1
                    _rw_cstr(cast[Ptr[uint8]]("<a href=\"#__evt_"))
                    _rw_dec(idx)
                    _rw_cstr(cast[Ptr[uint8]]("\">"))
                ts: uint64 = i + 1
                je: uint64 = ts
                while je < src_len and src_ptr[je] != 62:
                    je = je + 1
                ne: uint64 = ts
                while ne < je and _alnum_at(ne) != 0:
                    ne = ne + 1
                clt: uint64 = cast[uint64](dom_cend[idx])
                # locate the close tag end
                _find_close(ts, ne - ts, je + 1)
                cend: uint64 = g_close_end
                if dom_ov_hide[idx] != 0:
                    i = cend
                    continue
                # rebuild the start tag: <name [class] [style] original-attrs>
                _rw_ch(60)
                _rw_range(ts, ne)
                if dom_ov_cls_len[idx] >= 0:
                    _rw_cstr(cast[Ptr[uint8]](" class=\""))
                    _rw_ovbuf(dom_ov_cls_off[idx], dom_ov_cls_len[idx])
                    _rw_ch(34)
                _emit_merged_style(idx)
                if dom_kind[idx] == 1 and \
                   (dom_ov_val_len[idx] >= 0 or dom_ov_checked[idx] >= 0):
                    # input: re-emit attrs without value/checked, then the new
                    # value/checked so the control renders its updated state.
                    _rw_copy_attrs_except(ne, je, cast[Ptr[uint8]]("value"), \
                                          cast[Ptr[uint8]]("checked"))
                    if dom_ov_val_len[idx] >= 0:
                        _rw_cstr(cast[Ptr[uint8]](" value=\""))
                        _rw_ovbuf(dom_ov_val_off[idx], dom_ov_val_len[idx])
                        _rw_ch(34)
                    if dom_ov_checked[idx] == 1:
                        _rw_cstr(cast[Ptr[uint8]](" checked"))
                else:
                    _rw_range(ne, je)                     # original attributes
                _rw_ch(62)
                # native-only: wrap a click-handler element's content in a
                # synthetic "#__evt_IDX" link so the existing pointer link
                # hit-test can route the click to he_dom_click_index.
                wrap_evt: int32 = 0
                if wrap_outer == 0 and he_click_links != 0 and \
                   _el_has_handler(idx) != 0:
                    wrap_evt = 1
                    _rw_cstr(cast[Ptr[uint8]]("<a href=\"#__evt_"))
                    _rw_dec(idx)
                    _rw_cstr(cast[Ptr[uint8]]("\">"))
                # inner content
                if dom_kind[idx] == 2 and dom_ov_val_len[idx] >= 0:
                    # textarea value change = new (escaped) inner text.
                    _rw_text_escaped(dom_ov_val_off[idx], dom_ov_val_len[idx])
                elif dom_kind[idx] == 3 and dom_ov_val_len[idx] >= 0:
                    # select value change = re-mark the selected <option>.
                    _rw_select_options(je + 1, clt, dom_ov_val_off[idx], \
                                       dom_ov_val_len[idx])
                elif dom_ov_inner_len[idx] >= 0:
                    if dom_ov_inner_html[idx] != 0:
                        _rw_ovbuf(dom_ov_inner_off[idx], dom_ov_inner_len[idx])
                    else:
                        _rw_text_escaped(dom_ov_inner_off[idx], \
                                         dom_ov_inner_len[idx])
                else:
                    # No inner-content override: re-process the original inner
                    # range so descendant overrides (a mutation on a node nested
                    # under this appended-to / restyled element) still bake in.
                    _rewrite_range(je + 1, clt)
                # appended created children, in insertion order
                a: int32 = 0
                while a < ap_n:
                    if ap_removed[a] == 0 and ap_parent[a] == idx:
                        _emit_created(ap_child[a])
                    a = a + 1
                if wrap_evt != 0:
                    _rw_cstr(cast[Ptr[uint8]]("</a>"))
                _rw_range(clt, cend)                      # original close tag
                if wrap_outer != 0:
                    _rw_cstr(cast[Ptr[uint8]]("</a>"))
                i = cend
                continue
        _rw_ch(c)
        i = i + 1


# ---- front-end accessors (console / title / error) ------------------
def he_js_console_ptr() -> Ptr[uint8]:
    js_con_buf[js_con_len] = 0
    return &js_con_buf[0]


def he_js_console_len() -> uint64:
    return cast[uint64](js_con_len)


def he_js_error() -> int32:
    return js_had_error


def he_dom_title_ptr() -> Ptr[uint8]:
    return &dom_title_buf[0]


def he_dom_title_len() -> uint64:
    return cast[uint64](dom_title_len)


def he_dom_title_present() -> int32:
    return dom_title_present


# Lay out either the original source or, when the DOM carries overrides, a
# rewritten copy with them baked in. Shared by he_layout and post-event
# re-layout (he_dom_click).
def _relayout():
    if dom_n_overrides > 0 or _n_wrappable() > 0:
        _build_rewrite()
        save_ptr: Ptr[uint8] = src_ptr
        save_len: uint64 = src_len
        src_ptr = &rw_buf[0]
        src_len = rw_len
        _layout()
        src_ptr = save_ptr
        src_len = save_len
    else:
        _layout()


# he_layout — public entry point (non-underscore so front-ends can call it
# without an underscore import). Runs the page's <script>s (if any) through
# the JS engine + minimal DOM, then lays out src_ptr/src_len into segments —
# re-laying-out a rewritten source when a script mutated the DOM. The JS
# context persists after this returns (until the next he_layout / js_init) so
# event handlers registered here stay live for he_dom_click().
def he_layout():
    _strip_comments()
    _dom_reset()
    _run_scripts()
    _relayout()


# he_set_scroll_rows — set the STATIC scroll offset (whole rows) the positioned
# resolver assumes for `position:sticky`/`position:fixed`. Call BEFORE he_layout
# to ask "with the page scrolled down N rows, where do sticky/fixed boxes pin?".
# Default 0 leaves every page byte-identical; the resolver only consults it for
# sticky/fixed runs. NOT cleared by he_layout, so the caller fully owns it.
def he_set_scroll_rows(n: int32):
    if n < 0:
        n = 0
    pos_scroll_y = n


# Dispatch a click to the DOM record at `idx`: invoke its stored handler (an
# el.onclick / addEventListener('click', fn) function value, or an inline
# onclick="" source string) in the LIVE JS context, then read the DOM back and
# re-lay-out so the handler's mutations render. Returns 1 if a handler ran.
g_argv1: Array[1, int32]

# ---- History API + Location state (browser round: web storage / history) ----
# The session-history stack, mirrored to the JS `history` object. Each entry
# carries a serialized `state` (the JS value handle passed to push/replaceState)
# and the entry's URL bytes (kept in an append-only ring so back()/forward() can
# restore location.href). pushState advances the index and truncates the forward
# tail (classic browser semantics); replaceState overwrites the current entry
# without growing. `history.state`/`history.length` are re-synced after every op.
JSHIST_MAX:        int32 = 128
jshist_state:      Array[128, int32]   # per-entry serialized state (JS value handle)
jshist_url_off:    Array[128, int32]   # entry URL: offset into jshist_urlbuf (-1 = none)
jshist_url_len:    Array[128, int32]
JSHIST_URLBUF_CAP: int32 = 8192
jshist_urlbuf:     Array[8192, uint8]
jshist_urlbuf_w:   int32 = 0
jshist_len:        int32 = 1           # >=1: the current document is entry 0
jshist_idx:        int32 = 0
g_js_history:    int32 = -1          # the JS `history` object handle
g_js_location:   int32 = -1          # the JS `location` object handle (from setup.ad)
url_scratch:     Array[2048, uint8]  # URL-component build scratch
url_scratch2:    Array[2048, uint8]  # incoming URL bytes
origin_scratch:  Array[600, uint8]   # protocol+"//"+host build scratch (origin/href)


# Compile an inline handler source string (the JS between the on<evt>="" quotes)
# into a callable function value, so it can be invoked with `this` bound to the
# element — real pages routinely use `this.value` / `this.checked` / `this.id`
# inside inline handlers. The body is wrapped as  function(event){ <src> }  so
# it also sees the event argument. Returns the function value, or -1 on a
# compile error (caller falls back to a bare global-scope eval).
HB_HWRAP_CAP: int32 = 8192
hb_hwrap: Array[8192, uint8]


def _compile_inline_handler(src: int32, srclen: int32) -> int32:
    pfx: Ptr[uint8] = cast[Ptr[uint8]]("var __hb_ev_fn__=function(event){\n")
    w: int32 = 0
    i: int32 = 0
    while pfx[i] != 0 and w < HB_HWRAP_CAP - 4:
        hb_hwrap[w] = pfx[i]
        w = w + 1
        i = i + 1
    j: int32 = 0
    while j < srclen and w < HB_HWRAP_CAP - 4:
        hb_hwrap[w] = dom_txtbuf[src + j]
        w = w + 1
        j = j + 1
    hb_hwrap[w] = 10                                          # '\n' (end any // comment)
    w = w + 1
    hb_hwrap[w] = 125                                         # '}'
    w = w + 1
    hb_hwrap[w] = 59                                          # ';'
    w = w + 1
    js_eval(&hb_hwrap[0], cast[uint64](w))
    if js_error() != 0:
        js_had_error = 1
        return -1
    return js_global_get(cast[Ptr[uint8]]("__hb_ev_fn__"), 12)


# Cache a just-compiled inline-handler function value into element `idx`'s slot
# for event `kind`, so subsequent events reuse it (no recompile).
def _store_handler_fn(idx: int32, kind: int32, fnval: int32):
    if kind == 0:
        dom_onclick_fn[idx] = fnval
    elif kind == 1:
        dom_oninput_fn[idx] = fnval
    elif kind == 2:
        dom_onchange_fn[idx] = fnval
    elif kind == 3:
        dom_onsubmit_fn[idx] = fnval


# Fire element `idx`'s handlers for event `kind` (0 click, 1 input, 2 change,
# 3 submit) in the live JS context, passing `evtobj` as the sole argument
# (-1 = call with no args). Fires, in order: every addEventListener registration
# for (idx,kind) in registration order, THEN the attribute handler (el.on<evt> /
# inline on<evt>="" — a stored function value wins over an inline source string).
# Returns 1 if at least one handler ran.
# Map an event-type string to one of the 4 attribute-backed kinds, or -1 for
# any other ("generic") type that lives in the string-typed listener table.
def _evt_std_kind(p: Ptr[uint8], n: int32) -> int32:
    if _bytes_eq(p, n, cast[Ptr[uint8]]("click"), 5) != 0:
        return 0
    if _bytes_eq(p, n, cast[Ptr[uint8]]("input"), 5) != 0:
        return 1
    if _bytes_eq(p, n, cast[Ptr[uint8]]("change"), 6) != 0:
        return 2
    if _bytes_eq(p, n, cast[Ptr[uint8]]("submit"), 6) != 0:
        return 3
    return -1


# Intern a generic event-type string into evt_tybuf; returns its offset, or -1
# if the buffer is full. Interning is de-duplicated so removeEventListener can
# compare by offset OR by bytes (we compare by bytes to stay robust).
def _evt_intern(p: Ptr[uint8], n: int32) -> int32:
    if evt_tybuf_len + n >= EVT_TYBUF_CAP:
        return -1
    off: int32 = evt_tybuf_len
    i: int32 = 0
    while i < n:
        evt_tybuf[off + i] = p[i]
        i = i + 1
    evt_tybuf_len = off + n
    return off


# Does GEN_KIND listener `li`'s stored type string equal p[0..n)?
def _evl_type_eq(li: int32, p: Ptr[uint8], n: int32) -> int32:
    if evl_type_len[li] != n:
        return 0
    return _bytes_eq(&evt_tybuf[evl_type_off[li]], n, p, n)


# Does listener `li` fire in propagation phase `phase`? A capture:true listener
# fires in the CAPTURE and TARGET phases; a capture:false listener fires in the
# TARGET and BUBBLE phases. At the target every listener fires (registration
# order), matching the DOM "at target" rule.
def _phase_wants(li: int32, phase: int32) -> int32:
    if phase == EPHASE_TARGET:
        return 1
    if phase == EPHASE_CAPTURE:
        if evl_capture[li] != 0:
            return 1
        return 0
    if evl_capture[li] == 0:                               # EPHASE_BUBBLE
        return 1
    return 0


# Fire every live string-typed (GEN_KIND) listener on element `idx` whose type
# equals typp[0..typn) AND whose capture flag matches propagation `phase`, in
# registration order. Returns 1 if any ran. Generic types have no
# attribute-handler slot (there is no dom_onkeydown_*), so only addEventListener
# registrations fire — which is exactly the DOM behaviour.
def _fire_generic(idx: int32, typp: Ptr[uint8], typn: int32, \
                  evtobj: int32, phase: int32) -> int32:
    ran: int32 = 0
    if evtobj >= 0:
        js_global_set(cast[Ptr[uint8]]("event"), 5, evtobj)
    li: int32 = 0
    while li < evl_n:
        if evl_dead[li] == 0 and evl_el[li] == idx and \
           evl_kind[li] == GEN_KIND and _evl_type_eq(li, typp, typn) != 0 and \
           _phase_wants(li, phase) != 0:
            lfn: int32 = evl_fn[li]
            if js_is_callable(lfn) != 0:
                if evtobj >= 0:
                    g_argv1[0] = evtobj
                    js_call_fn(lfn, dom_obj[idx], &g_argv1[0], 1)
                else:
                    js_call_fn(lfn, dom_obj[idx], cast[Ptr[int32]](0), 0)
                ran = 1
                if evl_once[li] != 0:
                    evl_dead[li] = 1
                if g_stop_immediate != 0:
                    return ran
        li = li + 1
    return ran


# Fire every live document-level (evl_el == DOC_EL) string-typed listener whose
# type equals typp[0..typn), in registration order. Used for DOMContentLoaded /
# load after the page scripts run, and for any document.dispatchEvent(type). A
# fresh event object (type + document target + no-op preventDefault/
# stopPropagation) is passed so handlers reading event.type / event.target work.
# Returns 1 if any listener ran.
def _fire_document(typp: Ptr[uint8], typn: int32) -> int32:
    # Fast out: no document listener registered at all.
    any: int32 = 0
    li0: int32 = 0
    while li0 < evl_n:
        if evl_dead[li0] == 0 and evl_el[li0] == DOC_EL and \
           evl_kind[li0] == GEN_KIND and _evl_type_eq(li0, typp, typn) != 0:
            any = 1
        li0 = li0 + 1
    if any == 0:
        return 0
    ev: int32 = js_new_object_v()
    js_set_prop(ev, cast[Ptr[uint8]]("type"), 4, js_new_string(typp, cast[uint64](typn)))
    js_set_prop(ev, cast[Ptr[uint8]]("target"), 6, js_doc)
    js_set_prop(ev, cast[Ptr[uint8]]("currentTarget"), 13, js_doc)
    js_set_prop(ev, cast[Ptr[uint8]]("bubbles"), 7, js_bool(0))
    js_set_prop(ev, cast[Ptr[uint8]]("cancelable"), 10, js_bool(0))
    js_set_prop(ev, cast[Ptr[uint8]]("defaultPrevented"), 16, js_bool(0))
    js_set_prop(ev, cast[Ptr[uint8]]("preventDefault"), 14, \
                js_new_native_fn(js_hbase + NID_PREVENT))
    js_set_prop(ev, cast[Ptr[uint8]]("stopPropagation"), 15, \
                js_new_native_fn(js_hbase + NID_STOPPROP))
    js_global_set(cast[Ptr[uint8]]("event"), 5, ev)
    ran: int32 = 0
    li: int32 = 0
    while li < evl_n:
        if evl_dead[li] == 0 and evl_el[li] == DOC_EL and \
           evl_kind[li] == GEN_KIND and _evl_type_eq(li, typp, typn) != 0:
            lfn: int32 = evl_fn[li]
            if js_is_callable(lfn) != 0:
                g_argv1[0] = ev
                js_call_fn(lfn, js_doc, &g_argv1[0], 1)
                ran = 1
                if evl_once[li] != 0:
                    evl_dead[li] = 1
        li = li + 1
    return ran


def _fire_handler(idx: int32, kind: int32, evtobj: int32, phase: int32) -> int32:
    ran: int32 = 0
    # An inline on<evt>="" handler (and legacy code) references a global `event`;
    # bind it once so every handler in this fire sees it.
    if evtobj >= 0:
        js_global_set(cast[Ptr[uint8]]("event"), 5, evtobj)
    # (1) addEventListener registrations, in registration order, whose capture
    # flag matches this propagation phase.
    li: int32 = 0
    while li < evl_n:
        if evl_dead[li] == 0 and evl_el[li] == idx and evl_kind[li] == kind and \
           _phase_wants(li, phase) != 0:
            lfn: int32 = evl_fn[li]
            if js_is_callable(lfn) != 0:
                if evtobj >= 0:
                    g_argv1[0] = evtobj
                    js_call_fn(lfn, dom_obj[idx], &g_argv1[0], 1)
                else:
                    js_call_fn(lfn, dom_obj[idx], cast[Ptr[int32]](0), 0)
                ran = 1
                # once:true listeners fire at most once (DOM addEventListener opt).
                if evl_once[li] != 0:
                    evl_dead[li] = 1
                # stopImmediatePropagation(): no further listeners on this element.
                if g_stop_immediate != 0:
                    return ran
        li = li + 1
    # (2) the attribute handler (el.on<evt> property or inline on<evt>="") — an
    # event-handler content/IDL attribute is a bubble-side listener, so it never
    # fires during the CAPTURE phase (only at-target and bubbling).
    if phase == EPHASE_CAPTURE:
        return ran
    fn: int32 = -1
    src: int32 = -1
    srclen: int32 = 0
    pnm: Ptr[uint8] = cast[Ptr[uint8]]("onclick")
    pnl: int32 = 7
    if kind == 0:
        fn = dom_onclick_fn[idx]
        src = dom_onclick_src[idx]
        srclen = dom_onclick_srclen[idx]
    elif kind == 1:
        fn = dom_oninput_fn[idx]
        src = dom_oninput_src[idx]
        srclen = dom_oninput_srclen[idx]
        pnm = cast[Ptr[uint8]]("oninput")
        pnl = 7
    elif kind == 2:
        fn = dom_onchange_fn[idx]
        src = dom_onchange_src[idx]
        srclen = dom_onchange_srclen[idx]
        pnm = cast[Ptr[uint8]]("onchange")
        pnl = 8
    elif kind == 3:
        fn = dom_onsubmit_fn[idx]
        src = dom_onsubmit_src[idx]
        srclen = dom_onsubmit_srclen[idx]
        pnm = cast[Ptr[uint8]]("onsubmit")
        pnl = 8
    # el.on<evt> = fn assigned by a still-running script is not synced to the
    # slot until _dom_readback; read it live so a load-time dispatch sees it.
    if fn < 0:
        pv: int32 = js_get_prop(dom_obj[idx], pnm, cast[uint64](pnl))
        if js_is_callable(pv) != 0:
            fn = pv
    if fn >= 0 and js_is_callable(fn) != 0:
        if evtobj >= 0:
            g_argv1[0] = evtobj
            js_call_fn(fn, dom_obj[idx], &g_argv1[0], 1)
        else:
            js_call_fn(fn, dom_obj[idx], cast[Ptr[int32]](0), 0)
        return 1
    if src >= 0:
        # Compile the inline source into a function so `this` binds to the
        # element (this.value / this.checked), then cache + call it.
        cfn: int32 = _compile_inline_handler(src, srclen)
        if cfn >= 0 and js_is_callable(cfn) != 0:
            _store_handler_fn(idx, kind, cfn)
            if evtobj >= 0:
                g_argv1[0] = evtobj
                js_call_fn(cfn, dom_obj[idx], &g_argv1[0], 1)
            else:
                js_call_fn(cfn, dom_obj[idx], cast[Ptr[int32]](0), 0)
            return 1
        # Fallback: run the raw source at global scope (legacy `this`==global).
        js_eval(&dom_txtbuf[src], cast[uint64](srclen))
        if js_error() != 0:
            js_had_error = 1
        return 1
    return ran


# The registered DOM element whose source anchor is `anchor`, or -1. Used to map
# a tx-tree ancestor back to a live dom element while bubbling.
def _dom_by_anchor(anchor: int32) -> int32:
    if anchor < 0:
        return -1
    j: int32 = 0
    while j < dom_n:
        if dom_anchor[j] == anchor:
            return j
        j = j + 1
    return -1


# Materialize the propagation path for a dispatch at `target_el`: disp_path[0]
# is the target and each higher slot the nearest registered ancestor element up
# the source (tx) tree, disp_path[disp_n-1] being the outermost. Returns disp_n.
def _build_disp_path(target_el: int32) -> int32:
    disp_n = 0
    cur: int32 = target_el
    while cur >= 0 and disp_n < DISP_PATH_MAX:
        disp_path[disp_n] = cur
        disp_n = disp_n + 1
        tn: int32 = _tx_by_anchor(dom_anchor[cur])
        cur = -1
        if tn >= 0:
            t: int32 = tx_parent[tn]
            while t >= 0:
                de: int32 = _dom_by_anchor(tx_anchor[t])
                if de >= 0:
                    cur = de
                    t = -1
                else:
                    t = tx_parent[t]
    return disp_n


# Set event.eventPhase (a no-op when there is no event object).
def _set_ephase(evtobj: int32, ph: int32):
    if evtobj >= 0:
        js_set_prop(evtobj, cast[Ptr[uint8]]("eventPhase"), 10, \
                    js_number(cast[float64](ph)))


# Does the event object bubble? Defaults to true (legacy plain {type:'click'}
# objects carry no `bubbles` field yet must bubble); only an explicit bubbles ==
# false (a `new Event(type)` with bubbles unset, or {bubbles:false}) suppresses
# the bubble phase.
def _evt_bubbles(evtobj: int32) -> int32:
    if evtobj < 0:
        return 1
    bv: int32 = js_get_prop(evtobj, cast[Ptr[uint8]]("bubbles"), 7)
    if js_type_of(bv) != 0 and js_to_bool(bv) == 0:       # 0 == undefined tag
        return 0
    return 1


# Dispatch event `evtobj` (of kind 0 click / 1 input / 2 change / 3 submit) at
# target dom element `target_el` through the real DOM three-phase propagation:
# CAPTURE (root->target's parent, capture:true listeners), TARGET (all listeners
# on the target), then — if the event bubbles — BUBBLE (target's parent->root,
# capture:false listeners). Sets event.target once, event.currentTarget +
# event.eventPhase per hop, and honours stop(Immediate)Propagation between and
# within hops. Resets g_prevent_default / g_stop_prop at the start. Returns 1 if
# any handler ran.
def _dispatch_event(target_el: int32, kind: int32, evtobj: int32) -> int32:
    g_prevent_default = 0
    g_stop_prop = 0
    g_stop_immediate = 0
    g_cur_event = evtobj
    ran: int32 = 0
    if evtobj >= 0:
        js_set_prop(evtobj, cast[Ptr[uint8]]("target"), 6, dom_obj[target_el])
    n: int32 = _build_disp_path(target_el)
    bub: int32 = _evt_bubbles(evtobj)
    # --- capture phase: root -> target's parent ---
    _set_ephase(evtobj, EPHASE_CAPTURE)
    i: int32 = n - 1
    while i >= 1 and g_stop_prop == 0:
        g_stop_immediate = 0
        if evtobj >= 0:
            js_set_prop(evtobj, cast[Ptr[uint8]]("currentTarget"), 13, \
                        dom_obj[disp_path[i]])
        if _fire_handler(disp_path[i], kind, evtobj, EPHASE_CAPTURE) != 0:
            ran = 1
        i = i - 1
    # --- target phase ---
    if g_stop_prop == 0:
        g_stop_immediate = 0
        _set_ephase(evtobj, EPHASE_TARGET)
        if evtobj >= 0:
            js_set_prop(evtobj, cast[Ptr[uint8]]("currentTarget"), 13, \
                        dom_obj[target_el])
        if _fire_handler(target_el, kind, evtobj, EPHASE_TARGET) != 0:
            ran = 1
    # --- bubble phase: target's parent -> root ---
    if bub != 0:
        _set_ephase(evtobj, EPHASE_BUBBLE)
        i = 1
        while i < n and g_stop_prop == 0:
            g_stop_immediate = 0
            if evtobj >= 0:
                js_set_prop(evtobj, cast[Ptr[uint8]]("currentTarget"), 13, \
                            dom_obj[disp_path[i]])
            if _fire_handler(disp_path[i], kind, evtobj, EPHASE_BUBBLE) != 0:
                ran = 1
            i = i + 1
    _set_ephase(evtobj, EPHASE_NONE)
    if evtobj >= 0:
        js_set_prop(evtobj, cast[Ptr[uint8]]("currentTarget"), 13, js_null())
    g_cur_event = -1
    return ran


# Dispatch a string-typed event (type typp[0..typn)) at `target_el` through the
# same three-phase propagation as _dispatch_event, firing each hop's GEN_KIND
# listeners whose capture flag matches the phase. Honours bubbles + stop
# propagation. Returns 1 if any listener ran.
def _dispatch_generic(target_el: int32, typp: Ptr[uint8], typn: int32, \
                      evtobj: int32) -> int32:
    g_prevent_default = 0
    g_stop_prop = 0
    g_stop_immediate = 0
    g_cur_event = evtobj
    ran: int32 = 0
    if evtobj >= 0:
        js_set_prop(evtobj, cast[Ptr[uint8]]("target"), 6, dom_obj[target_el])
    n: int32 = _build_disp_path(target_el)
    bub: int32 = _evt_bubbles(evtobj)
    # --- capture phase ---
    _set_ephase(evtobj, EPHASE_CAPTURE)
    i: int32 = n - 1
    while i >= 1 and g_stop_prop == 0:
        g_stop_immediate = 0
        if evtobj >= 0:
            js_set_prop(evtobj, cast[Ptr[uint8]]("currentTarget"), 13, \
                        dom_obj[disp_path[i]])
        if _fire_generic(disp_path[i], typp, typn, evtobj, EPHASE_CAPTURE) != 0:
            ran = 1
        i = i - 1
    # --- target phase ---
    if g_stop_prop == 0:
        g_stop_immediate = 0
        _set_ephase(evtobj, EPHASE_TARGET)
        if evtobj >= 0:
            js_set_prop(evtobj, cast[Ptr[uint8]]("currentTarget"), 13, \
                        dom_obj[target_el])
        if _fire_generic(target_el, typp, typn, evtobj, EPHASE_TARGET) != 0:
            ran = 1
    # --- bubble phase ---
    if bub != 0:
        _set_ephase(evtobj, EPHASE_BUBBLE)
        i = 1
        while i < n and g_stop_prop == 0:
            g_stop_immediate = 0
            if evtobj >= 0:
                js_set_prop(evtobj, cast[Ptr[uint8]]("currentTarget"), 13, \
                            dom_obj[disp_path[i]])
            if _fire_generic(disp_path[i], typp, typn, evtobj, EPHASE_BUBBLE) != 0:
                ran = 1
            i = i + 1
    _set_ephase(evtobj, EPHASE_NONE)
    if evtobj >= 0:
        js_set_prop(evtobj, cast[Ptr[uint8]]("currentTarget"), 13, js_null())
    g_cur_event = -1
    return ran


def he_dom_click_index(idx: int32) -> int32:
    if js_ctx_live == 0 or idx < 0 or idx >= dom_n:
        return 0
    # a real click routes through the same bubbling dispatch core as
    # el.dispatchEvent(), so ancestor click listeners fire.
    ev: int32 = _new_event_obj()
    js_set_prop(ev, cast[Ptr[uint8]]("type"), 4, \
                js_new_string(cast[Ptr[uint8]]("click"), 5))
    if _dispatch_event(idx, 0, ev) == 0:
        return 0
    _dom_readback()
    _js_capture_console()
    _relayout()
    return 1


# Look up a registered DOM element by id, registering it on demand (the JS
# context must be live). Returns its dom index, or -1.
# Locate a form control's start tag by its `name="..."` attribute (the id-less
# case). Real forms — google.com's `<input name="q">` — identify controls by
# `name`, not `id`, so field resolution must fall back to it. Returns 1 and sets
# g_el_lt (like _dom_find_by_id) when found.
def _dom_find_by_name(idp: Ptr[uint8], idn: int32) -> int32:
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           src_ptr[i + 1] != 47 and src_ptr[i + 1] != 33 and \
           src_ptr[i + 1] != 63:
            ts: uint64 = i + 1
            je: uint64 = ts
            while je < src_len and src_ptr[je] != 62:
                je = je + 1
            # only match form controls (input/textarea/select/button/form) so a
            # `<meta name=…>` or `<a name=…>` can't shadow the field.
            if _tagname_is(ts, cast[Ptr[uint8]]("input")) != 0 or \
               _tagname_is(ts, cast[Ptr[uint8]]("textarea")) != 0 or \
               _tagname_is(ts, cast[Ptr[uint8]]("select")) != 0 or \
               _tagname_is(ts, cast[Ptr[uint8]]("button")) != 0 or \
               _tagname_is(ts, cast[Ptr[uint8]]("form")) != 0:
                if _hx_find_attr(ts, je, cast[Ptr[uint8]]("name")) != 0:
                    if _idbytes_eq(g_attr_start, g_attr_end, idp, idn) != 0:
                        return _scan_start_tag(i)
            i = je
        i = i + 1
    return 0


# Build a form's `.elements` HTMLFormControlsCollection (+ `.length`): scan the
# form's content span for control start tags (input/select/textarea/button),
# register each, and expose the array. Real forms iterate form.elements and read
# form.elements.length / form.length. Called once at form registration; saves +
# restores the g_el_* scan globals it clobbers so the caller is unaffected.
def _lookup_or_register(idp: Ptr[uint8], idn: int32) -> int32:
    e: int32 = _dom_lookup_id(idp, idn)
    if e >= 0:
        return e
    if _dom_find_by_id(idp, idn) != 0:
        _dom_register_el()
        return _dom_lookup_anchor(cast[int32](g_el_lt))
    # id-less form control (google uses `name="q"`, no id) -> resolve by name
    if _dom_find_by_name(idp, idn) != 0:
        _dom_register_el()
        return _dom_lookup_anchor(cast[int32](g_el_lt))
    return -1


# Build a minimal event object exposing preventDefault()/stopPropagation() and
# the type/target/defaultPrevented properties handlers read.
def _new_event_obj() -> int32:
    ev: int32 = js_new_object_v()
    js_set_prop(ev, cast[Ptr[uint8]]("preventDefault"), 14, \
                js_new_native_fn(js_hbase + NID_PREVENT))
    js_set_prop(ev, cast[Ptr[uint8]]("stopPropagation"), 15, \
                js_new_native_fn(js_hbase + NID_STOPPROP))
    js_set_prop(ev, cast[Ptr[uint8]]("stopImmediatePropagation"), 24, \
                js_new_native_fn(js_hbase + NID_STOPIMMED))
    js_set_prop(ev, cast[Ptr[uint8]]("defaultPrevented"), 16, js_bool(0))
    js_set_prop(ev, cast[Ptr[uint8]]("target"), 6, js_null())
    js_set_prop(ev, cast[Ptr[uint8]]("currentTarget"), 13, js_null())
    js_set_prop(ev, cast[Ptr[uint8]]("eventPhase"), 10, js_number(cast[float64](0)))
    js_set_prop(ev, cast[Ptr[uint8]]("type"), 4, js_new_string(&dom_txtbuf[0], 0))
    return ev


# Construct an Event / CustomEvent / MouseEvent / KeyboardEvent from the JS
# argument list. `flavor`: 0 Event, 1 CustomEvent, 2 MouseEvent, 3 KeyboardEvent.
# Reads the type string (arg0) and an options object (arg1): bubbles / cancelable
# (all), detail (CustomEvent), plus a few basic MouseEvent/KeyboardEvent fields.
# Returns a fresh object usable as an event (dispatchEvent reads .type).
def _make_event(flavor: int32) -> int32:
    ev: int32 = js_new_object_v()
    # type (arg0) — copied into a stable buffer first (js_str_ptr shares scratch).
    tn: int32 = 0
    if js_arg_count() >= 1:
        tn = _arg_bytes(0, &dom_idtmp[0], 256)
        if _is_undef_str(&dom_idtmp[0], tn) != 0:
            tn = 0
    js_set_prop(ev, cast[Ptr[uint8]]("type"), 4, \
                js_new_string(&dom_idtmp[0], cast[uint64](tn)))
    js_set_prop(ev, cast[Ptr[uint8]]("bubbles"), 7, js_bool(0))
    js_set_prop(ev, cast[Ptr[uint8]]("cancelable"), 10, js_bool(0))
    js_set_prop(ev, cast[Ptr[uint8]]("defaultPrevented"), 16, js_bool(0))
    js_set_prop(ev, cast[Ptr[uint8]]("detail"), 6, js_null())
    js_set_prop(ev, cast[Ptr[uint8]]("target"), 6, js_null())
    js_set_prop(ev, cast[Ptr[uint8]]("currentTarget"), 13, js_null())
    js_set_prop(ev, cast[Ptr[uint8]]("eventPhase"), 10, js_number(cast[float64](0)))
    js_set_prop(ev, cast[Ptr[uint8]]("preventDefault"), 14, \
                js_new_native_fn(js_hbase + NID_PREVENT))
    js_set_prop(ev, cast[Ptr[uint8]]("stopPropagation"), 15, \
                js_new_native_fn(js_hbase + NID_STOPPROP))
    js_set_prop(ev, cast[Ptr[uint8]]("stopImmediatePropagation"), 24, \
                js_new_native_fn(js_hbase + NID_STOPIMMED))
    if flavor == 2:
        # basic MouseEvent geometry (defaults 0)
        js_set_prop(ev, cast[Ptr[uint8]]("clientX"), 7, js_number(cast[float64](0)))
        js_set_prop(ev, cast[Ptr[uint8]]("clientY"), 7, js_number(cast[float64](0)))
        js_set_prop(ev, cast[Ptr[uint8]]("button"), 6, js_number(cast[float64](0)))
    if flavor == 3:
        js_set_prop(ev, cast[Ptr[uint8]]("key"), 3, \
                    js_new_string(cast[Ptr[uint8]](""), 0))
    # options object (arg1)
    if js_arg_count() >= 2:
        opt: int32 = js_arg(1)
        js_set_prop(ev, cast[Ptr[uint8]]("bubbles"), 7, \
                    js_bool(js_to_bool(js_get_prop(opt, cast[Ptr[uint8]]("bubbles"), 7))))
        js_set_prop(ev, cast[Ptr[uint8]]("cancelable"), 10, \
                    js_bool(js_to_bool(js_get_prop(opt, cast[Ptr[uint8]]("cancelable"), 10))))
        if flavor == 1:
            js_set_prop(ev, cast[Ptr[uint8]]("detail"), 6, \
                        js_get_prop(opt, cast[Ptr[uint8]]("detail"), 6))
        if flavor == 2:
            js_set_prop(ev, cast[Ptr[uint8]]("clientX"), 7, \
                        js_number(js_to_number(js_get_prop(opt, cast[Ptr[uint8]]("clientX"), 7))))
            js_set_prop(ev, cast[Ptr[uint8]]("clientY"), 7, \
                        js_number(js_to_number(js_get_prop(opt, cast[Ptr[uint8]]("clientY"), 7))))
            js_set_prop(ev, cast[Ptr[uint8]]("button"), 6, \
                        js_number(js_to_number(js_get_prop(opt, cast[Ptr[uint8]]("button"), 6))))
        if flavor == 3:
            kv: int32 = js_get_prop(opt, cast[Ptr[uint8]]("key"), 3)
            if js_type_of(kv) == 4:
                js_set_prop(ev, cast[Ptr[uint8]]("key"), 3, kv)
    return ev


# `new Image()` / `new Image(w, h)` -> a minimal HTMLImageElement stub. Real
# pages use this for preloading + analytics beacons (assign .src to a URL). We
# do not fetch it (Plan 9-shape: no side-channel loads), but the object must
# exist so scripts that construct one don't throw "Image is not defined".
# Carries the settable src/width/height/complete fields and a no-op
# addEventListener so listener wiring (onload/onerror) does not fault.
def _make_image() -> int32:
    img: int32 = js_new_object_v()
    js_set_prop(img, cast[Ptr[uint8]]("src"), 3, \
                js_new_string(cast[Ptr[uint8]](""), 0))
    js_set_prop(img, cast[Ptr[uint8]]("alt"), 3, \
                js_new_string(cast[Ptr[uint8]](""), 0))
    w: float64 = 0.0
    h: float64 = 0.0
    if js_arg_count() >= 1:
        w = js_to_number(js_arg(0))
    if js_arg_count() >= 2:
        h = js_to_number(js_arg(1))
    js_set_prop(img, cast[Ptr[uint8]]("width"), 5, js_number(w))
    js_set_prop(img, cast[Ptr[uint8]]("height"), 6, js_number(h))
    js_set_prop(img, cast[Ptr[uint8]]("naturalWidth"), 12, js_number(cast[float64](0)))
    js_set_prop(img, cast[Ptr[uint8]]("naturalHeight"), 13, js_number(cast[float64](0)))
    js_set_prop(img, cast[Ptr[uint8]]("complete"), 8, js_bool(0))
    js_set_prop(img, cast[Ptr[uint8]]("onload"), 6, js_null())
    js_set_prop(img, cast[Ptr[uint8]]("onerror"), 7, js_null())
    js_set_prop(img, cast[Ptr[uint8]]("addEventListener"), 16, \
                js_new_native_fn(js_hbase + NID_ADDEVT))
    js_set_prop(img, cast[Ptr[uint8]]("removeEventListener"), 19, \
                js_new_native_fn(js_hbase + NID_REMEVT))
    return img


# Programmatically set a form field's value (input/textarea/select) by element
# id, then fire its oninput + onchange handlers and re-lay-out so the change
# renders. The pointer-free equivalent of a user typing into a field. Returns 1
# on success (JS context live + element found).
def he_dom_set_value(idp: Ptr[uint8], idn: int32, valp: Ptr[uint8], \
                     valn: int32) -> int32:
    if js_ctx_live == 0:
        return 0
    idx: int32 = _lookup_or_register(idp, idn)
    if idx < 0:
        return 0
    js_set_prop(dom_obj[idx], cast[Ptr[uint8]]("value"), 5, \
                js_new_string(valp, cast[uint64](valn)))
    _fire_handler(idx, 1, -1, EPHASE_TARGET)                             # oninput
    _fire_handler(idx, 2, -1, EPHASE_TARGET)                             # onchange
    _dom_readback()
    _js_capture_console()
    _relayout()
    return 1


# Radio-group exclusivity: `keep` is a radio that just became checked; uncheck
# every OTHER radio sharing its `name`. Scans the whole source so all group
# members are registered (and thus re-rendered) even if the page never named
# them from JS. A no-op for non-radios or unnamed radios.
def _radio_enforce_group(keep: int32):
    kobj: int32 = dom_obj[keep]
    ktv: int32 = js_get_prop(kobj, cast[Ptr[uint8]]("type"), 4)
    ktp: Ptr[uint8] = js_str_ptr(ktv)
    if _bytes_eq(ktp, _cstr_len(ktp), cast[Ptr[uint8]]("radio"), 5) == 0:
        return
    knv: int32 = js_get_prop(kobj, cast[Ptr[uint8]]("name"), 4)
    knp: Ptr[uint8] = js_str_ptr(knv)
    knn: int32 = _cstr_len(knp)
    if knn == 0 or _is_undef_str(knp, knn) != 0:
        return
    # copy the name out of the shared JS scratch before further js_get_prop calls.
    kk: int32 = 0
    while kk < knn and kk < 127:
        g_radioname[kk] = knp[kk]
        kk = kk + 1
    g_radioname_len = kk
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           _tagname_is(i + 1, cast[Ptr[uint8]]("input")) != 0:
            _scan_start_tag(i)
            skip_to: uint64 = g_close_end
            ei: int32 = _dom_lookup_anchor(cast[int32](g_el_lt))
            if ei < 0:
                _dom_register_el()
                ei = _dom_lookup_anchor(cast[int32](g_el_lt))
            if ei >= 0 and ei != keep:
                eo: int32 = dom_obj[ei]
                etv: int32 = js_get_prop(eo, cast[Ptr[uint8]]("type"), 4)
                etp: Ptr[uint8] = js_str_ptr(etv)
                if _bytes_eq(etp, _cstr_len(etp), cast[Ptr[uint8]]("radio"), 5) != 0:
                    env: int32 = js_get_prop(eo, cast[Ptr[uint8]]("name"), 4)
                    enp: Ptr[uint8] = js_str_ptr(env)
                    if _bytes_eq(enp, _cstr_len(enp), &g_radioname[0], \
                                 g_radioname_len) != 0:
                        js_set_prop(eo, cast[Ptr[uint8]]("checked"), 7, js_bool(0))
            i = skip_to
            continue
        i = i + 1


# Set a checkbox/radio's checked state by id, fire oninput + onchange, re-lay.
def he_dom_set_checked(idp: Ptr[uint8], idn: int32, checked: int32) -> int32:
    if js_ctx_live == 0:
        return 0
    idx: int32 = _lookup_or_register(idp, idn)
    if idx < 0:
        return 0
    js_set_prop(dom_obj[idx], cast[Ptr[uint8]]("checked"), 7, js_bool(checked))
    if checked != 0:
        _radio_enforce_group(idx)
    _fire_handler(idx, 1, -1, EPHASE_TARGET)
    _fire_handler(idx, 2, -1, EPHASE_TARGET)
    _dom_readback()
    _js_capture_console()
    _relayout()
    return 1


# ---- form submission (GET query-string / POST request body) --------
def _nav_putc(c: uint8):
    if dom_nav_len < 2047:
        dom_nav_buf[dom_nav_len] = c
        dom_nav_len = dom_nav_len + 1


# Append one byte to whichever serialization target is active: the POST request
# body (dom_body_buf) when post != 0, else the GET nav/query buffer.
def _sfld_putc(post: int32, c: uint8):
    if post != 0:
        if dom_body_len < 2047:
            dom_body_buf[dom_body_len] = c
            dom_body_len = dom_body_len + 1
    else:
        _nav_putc(c)


# Append `p[0..n)` URL-form-encoded (space -> '+', unreserved kept, else '_')
# to the active target (GET query or POST body).
def _sfld_encoded(post: int32, p: Ptr[uint8], n: int32):
    i: int32 = 0
    while i < n:
        c: uint8 = p[i]
        if c == 32:
            _sfld_putc(post, 43)                         # '+'
        elif (c >= 97 and c <= 122) or (c >= 65 and c <= 90) or \
             (c >= 48 and c <= 57) or c == 45 or c == 46 or c == 95:
            _sfld_putc(post, c)
        else:
            _sfld_putc(post, 95)                         # '_'
        i = i + 1


# Append `p[0..n)` URL-form-encoded to the GET nav buffer (kept for callers that
# encode directly into the query string).
def _nav_encoded(p: Ptr[uint8], n: int32):
    _sfld_encoded(0, p, n)


# Does the form at `fi` request method=POST? (case-insensitive `method` attr).
def _form_is_post(fi: int32) -> int32:
    if dom_anchor[fi] < 0:
        return 0
    ts: uint64 = cast[uint64](dom_anchor[fi])
    te: uint64 = cast[uint64](dom_cstart[fi])
    if _hx_find_attr(ts, te, cast[Ptr[uint8]]("method")) == 0:
        return 0
    if g_attr_end - g_attr_start != 4:
        return 0
    if _hx_lower(src_ptr[g_attr_start]) == 112 and \
       _hx_lower(src_ptr[g_attr_start + 1]) == 111 and \
       _hx_lower(src_ptr[g_attr_start + 2]) == 115 and \
       _hx_lower(src_ptr[g_attr_start + 3]) == 116:        # "post"
        return 1
    return 0


# Serialize the form at dom index `fi`. For method=GET dom_nav_buf becomes
# "action?a=1&b=2" (dom_nav_method 0). For method=POST dom_nav_buf carries the
# bare action target and the application/x-www-form-urlencoded body "a=1&b=2"
# lands in dom_body_buf (dom_nav_method 1) — enctype is urlencoded (the default;
# multipart/FormData is not yet modelled). Each field's value/checked is read
# live from its registered JS object.
def _serialize_form(fi: int32):
    dom_nav_len = 0
    dom_body_len = 0
    post: int32 = _form_is_post(fi)
    dom_nav_method = post
    # Prepend the form's action target (raw, un-encoded — a path keeps its '/')
    # so a search submits to "/search?q=cats", not the current page's "?q=cats".
    # Empty/absent action serializes to a bare "?..." (submit to current URL,
    # which is the HTML default).
    ats: uint64 = cast[uint64](dom_anchor[fi])
    ate: uint64 = cast[uint64](dom_cstart[fi])
    act_has_q: int32 = 0
    if dom_anchor[fi] >= 0 and \
       _hx_find_attr(ats, ate, cast[Ptr[uint8]]("action")) != 0 and \
       g_attr_end > g_attr_start:
        ap: uint64 = g_attr_start
        while ap < g_attr_end:
            ac: uint8 = src_ptr[ap]
            if ac == 63:                                 # action already has '?'
                act_has_q = 1
            _nav_putc(ac)
            ap = ap + 1
    # GET separates the query from the path in the nav buffer: '?' for the first
    # param, '&' when the action already carried a query string. POST leaves the
    # nav buffer at the bare action and builds the body separately.
    if post == 0:
        if act_has_q != 0:
            _nav_putc(38)                                # '&'
        else:
            _nav_putc(63)                                # '?'
    first: int32 = 1
    cs: uint64 = cast[uint64](dom_cstart[fi])
    ce: uint64 = cast[uint64](dom_cend[fi])
    i: uint64 = cs
    while i < ce:
        if src_ptr[i] == 60 and i + 1 < ce and \
           (_tagname_is(i + 1, cast[Ptr[uint8]]("input")) != 0 or \
            _tagname_is(i + 1, cast[Ptr[uint8]]("select")) != 0 or \
            _tagname_is(i + 1, cast[Ptr[uint8]]("textarea")) != 0):
            _scan_start_tag(i)
            skip_to: uint64 = g_close_end
            ei: int32 = _dom_lookup_anchor(cast[int32](g_el_lt))
            if ei < 0:
                _dom_register_el()
                ei = _dom_lookup_anchor(cast[int32](g_el_lt))
            if ei >= 0:
                _serialize_field(ei, &first, post)
            i = skip_to
            continue
        i = i + 1
    dom_nav_present = 1


# Emit one field's name=value pair into the active target (GET query / POST body)
# when it carries a name and is a successful control. *first tracks whether a '&'
# separator is needed. `post` selects the body vs the query buffer.
def _serialize_field(ei: int32, first: Ptr[int32], post: int32):
    obj: int32 = dom_obj[ei]
    nmv: int32 = js_get_prop(obj, cast[Ptr[uint8]]("name"), 4)
    np: Ptr[uint8] = js_str_ptr(nmv)
    nn: int32 = _cstr_len(np)
    if nn == 0 or _is_undef_str(np, nn) != 0:
        return
    # copy the name out of the shared scratch before reading other props.
    kk: int32 = 0
    while kk < nn and kk < 127:
        g_nmtmp[kk] = np[kk]
        kk = kk + 1
    nn2: int32 = kk
    # a checkbox/radio contributes only when checked.
    if dom_origchecked[ei] >= 0:
        ckv: int32 = js_get_prop(obj, cast[Ptr[uint8]]("checked"), 7)
        if js_to_bool(ckv) == 0:
            return
    # submit/reset/button inputs are not serialized.
    tyv: int32 = js_get_prop(obj, cast[Ptr[uint8]]("type"), 4)
    typ: Ptr[uint8] = js_str_ptr(tyv)
    tyn: int32 = _cstr_len(typ)
    if _bytes_eq(typ, tyn, cast[Ptr[uint8]]("submit"), 6) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("reset"), 5) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("button"), 6) != 0:
        return
    if first[0] == 0:
        _sfld_putc(post, 38)                             # '&'
    first[0] = 0
    _sfld_encoded(post, &g_nmtmp[0], nn2)
    _sfld_putc(post, 61)                                 # '='
    vv: int32 = js_get_prop(obj, cast[Ptr[uint8]]("value"), 5)
    vp: Ptr[uint8] = js_str_ptr(vv)
    vn: int32 = _cstr_len(vp)
    if _is_undef_str(vp, vn) != 0:
        vn = 0
    _sfld_encoded(post, vp, vn)


# Shared submit core: dispatch a cancelable `submit` event at form `idx` that
# BUBBLES to ancestor listeners (round 8 dispatch). If no handler called
# preventDefault() AND the form passes Constraint Validation (unless it carries
# `novalidate`), serialize the named controls (GET query / POST body) into the
# nav buffer. An invalid form blocks the navigation, exactly like a real browser.
# Used by the host entry points AND the JS form.submit() method.
def _do_submit(idx: int32):
    ev: int32 = _new_event_obj()
    js_set_prop(ev, cast[Ptr[uint8]]("type"), 4, \
                js_new_string(cast[Ptr[uint8]]("submit"), 6))
    _dispatch_event(idx, 3, ev)                          # resets g_prevent_default
    _dom_readback()
    _js_capture_console()
    if g_prevent_default == 0:
        novalid: int32 = 0
        if dom_kind[idx] == 5:
            nts: uint64 = cast[uint64](dom_ns[idx])
            nte: uint64 = cast[uint64](dom_cstart[idx]) - 1
            if _has_word(nts, nte, cast[Ptr[uint8]]("novalidate")) != 0:
                novalid = 1
        if novalid != 0 or dom_kind[idx] != 5 or _form_check_all(idx) != 0:
            _serialize_form(idx)
    _relayout()


def he_dom_submit(idp: Ptr[uint8], idn: int32) -> int32:
    if js_ctx_live == 0:
        return 0
    idx: int32 = _lookup_or_register(idp, idn)
    if idx < 0:
        return 0
    _do_submit(idx)
    return 1


def he_nav_ptr() -> Ptr[uint8]:
    dom_nav_buf[dom_nav_len] = 0
    return &dom_nav_buf[0]


def he_nav_len() -> uint64:
    return cast[uint64](dom_nav_len)


def he_nav_present() -> int32:
    return dom_nav_present


# The submit method of the pending navigation: 0 = GET (target is he_nav_ptr with
# its query string), 1 = POST (target is he_nav_ptr, body is he_nav_body_ptr with
# Content-Type application/x-www-form-urlencoded).
def he_nav_method() -> int32:
    return dom_nav_method


# The POST request body ("a=1&b=2"), NUL-terminated. Empty for a GET submit.
def he_nav_body_ptr() -> Ptr[uint8]:
    dom_body_buf[dom_body_len] = 0
    return &dom_body_buf[0]


def he_nav_body_len() -> uint64:
    return cast[uint64](dom_body_len)


# Clear a consumed navigation request so the next poll doesn't re-fire it. The
# native front-end calls this immediately after it has read he_nav_ptr/len and
# started the fetch, so a stale request can't loop.
def he_nav_clear():
    dom_nav_present = 0
    dom_nav_len = 0
    dom_nav_method = 0
    dom_body_len = 0


# ---- native pointer/keyboard field interaction (index-based) --------
# The native front-end hit-tests a pointer click to a DOM element index (via the
# synthetic "#__evt_N" link wrap + he_link_evt_index), then asks these whether
# that element is a typing target or a submit control, edits it per-keystroke,
# and submits its enclosing form on Enter / a submit-button click.

# Resolve an element id to its DOM index (registering on demand), or -1. The
# native front-end addresses fields by the index its pointer hit-test yields;
# the host gate uses this to drive the same index-based chain from an id.
def he_dom_id_index(idp: Ptr[uint8], idn: int32) -> int32:
    if js_ctx_live == 0:
        return -1
    return _lookup_or_register(idp, idn)


# Is element `idx` a text-typing control (a textarea, or an <input> that is not
# a checkbox/radio/submit/button/reset/hidden)? Requires a live JS context (the
# element's `type` is read from its DOM object).
def he_dom_is_textfield(idx: int32) -> int32:
    if js_ctx_live == 0 or idx < 0 or idx >= dom_n:
        return 0
    if dom_kind[idx] == 2:                                # <textarea>
        return 1
    if dom_kind[idx] != 1:                                # not <input>
        return 0
    if dom_origchecked[idx] >= 0:                         # checkbox / radio
        return 0
    tyv: int32 = js_get_prop(dom_obj[idx], cast[Ptr[uint8]]("type"), 4)
    typ: Ptr[uint8] = js_str_ptr(tyv)
    tyn: int32 = _cstr_len(typ)
    if _bytes_eq(typ, tyn, cast[Ptr[uint8]]("submit"), 6) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("button"), 6) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("reset"), 5) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("hidden"), 6) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("checkbox"), 8) != 0 or \
       _bytes_eq(typ, tyn, cast[Ptr[uint8]]("radio"), 5) != 0:
        return 0
    return 1


# Is element `idx` a submit control (<input type=submit> or a <button>, whose
# default type is submit)? Such a click submits the enclosing form.
def he_dom_is_submit(idx: int32) -> int32:
    if js_ctx_live == 0 or idx < 0 or idx >= dom_n:
        return 0
    if dom_kind[idx] == 4:                                # <button>
        return 1
    if dom_kind[idx] != 1:
        return 0
    tyv: int32 = js_get_prop(dom_obj[idx], cast[Ptr[uint8]]("type"), 4)
    typ: Ptr[uint8] = js_str_ptr(tyv)
    tyn: int32 = _cstr_len(typ)
    if _bytes_eq(typ, tyn, cast[Ptr[uint8]]("submit"), 6) != 0:
        return 1
    return 0


# The dom index of the <form> enclosing element `idx` (the innermost form whose
# inner-content span contains the element's source anchor), or -1. Used to
# submit the form when Enter is pressed in a field or a submit button is clicked.
def he_dom_field_form(idx: int32) -> int32:
    if idx < 0 or idx >= dom_n:
        return -1
    a: int32 = dom_anchor[idx]
    if a < 0:
        return -1
    best: int32 = -1
    f: int32 = 0
    while f < dom_n:
        if dom_kind[f] == 5 and dom_cstart[f] <= a and a < dom_cend[f]:
            best = f                                      # innermost = last match
        f = f + 1
    return best


# Set element `idx`'s value to valp[0..valn) and fire its oninput handler, then
# re-lay-out so the typed text renders in the field box. The per-keystroke
# equivalent of he_dom_set_value but addressed by index (the front-end already
# has the hit-tested element index; no id string needed). onchange fires on
# submit/blur, not on every keystroke, so only oninput runs here.
def he_dom_set_value_index(idx: int32, valp: Ptr[uint8], valn: int32) -> int32:
    if js_ctx_live == 0 or idx < 0 or idx >= dom_n:
        return 0
    js_set_prop(dom_obj[idx], cast[Ptr[uint8]]("value"), 5, \
                js_new_string(valp, cast[uint64](valn)))
    _fire_handler(idx, 1, -1, EPHASE_TARGET)                             # oninput
    _dom_readback()
    _js_capture_console()
    _relayout()
    return 1


# Copy element `idx`'s current value into out[0..cap) (NUL-terminated); return
# its length. The front-end seeds its per-field edit buffer from this when a
# field is focused so pre-filled text isn't lost on the first keystroke.
def he_dom_get_value(idx: int32, out: Ptr[uint8], cap: int32) -> int32:
    if js_ctx_live == 0 or idx < 0 or idx >= dom_n or cap <= 0:
        out[0] = 0
        return 0
    vv: int32 = js_get_prop(dom_obj[idx], cast[Ptr[uint8]]("value"), 5)
    vp: Ptr[uint8] = js_str_ptr(vv)
    vn: int32 = _cstr_len(vp)
    if _is_undef_str(vp, vn) != 0:
        vn = 0
    k: int32 = 0
    while k < vn and k < cap - 1:
        out[k] = vp[k]
        k = k + 1
    out[k] = 0
    return k


# Submit the form at dom index `idx` (fire onsubmit; GET-serialize into the nav
# buffer if not preventDefault'd). Index-based twin of he_dom_submit.
def he_dom_submit_index(idx: int32) -> int32:
    if js_ctx_live == 0 or idx < 0 or idx >= dom_n:
        return 0
    _do_submit(idx)
    return 1


# Dispatch a click to the element with id idp[0..idn). Returns 1 if a handler
# ran, 0 otherwise. This is the programmatic, pointer-free dispatch used by the
# host gate AND (via he_dom_click_index) the native pointer path.
def he_dom_click(idp: Ptr[uint8], idn: int32) -> int32:
    # Register the target on demand so an element whose only handler is an
    # inline onclick="" (never touched by a <script>) still gets its handler
    # captured before dispatch.
    if js_ctx_live == 0:
        return 0
    return he_dom_click_index(_lookup_or_register(idp, idn))


# Does the DOM element at `idx` carry a click handler?
def _el_has_handler(idx: int32) -> int32:
    if dom_onclick_fn[idx] >= 0 or dom_onclick_src[idx] >= 0:
        return 1
    return 0


# Native front-ends (he_click_links) make in-page form controls pointer-
# reachable by wrapping each in a synthetic "#__evt_N" link (the SAME hit-test
# path as click-handler elements), so a pointer click resolves to the control's
# DOM index. A "wrappable field" is a text-typing control or a submit button.
def _is_wrappable_field(idx: int32) -> int32:
    if he_click_links == 0:
        return 0
    if he_dom_is_textfield(idx) != 0:
        return 1
    if he_dom_is_submit(idx) != 0:
        return 1
    return 0


# Count elements the native rewrite must wrap in a "#__evt_N" link: click-
# handler elements AND focusable/submit form controls. Non-zero forces the
# rewrite path even when no script mutated the DOM (a plain form still needs its
# fields to be pointer-reachable). Host renders (he_click_links==0) return 0.
def _n_wrappable() -> int32:
    if he_click_links == 0:
        return 0
    c: int32 = 0
    i: int32 = 0
    while i < dom_n:
        if _el_has_handler(i) != 0 or _is_wrappable_field(i) != 0:
            c = c + 1
        i = i + 1
    return c


# Does the source contain a <form> (so a script-less page still warrants a live
# JS context + form registration for native pointer/type/submit)?
def _page_has_form() -> int32:
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and i + 1 < src_len and \
           _tagname_is(i + 1, cast[Ptr[uint8]]("form")) != 0:
            return 1
        i = i + 1
    return 0


# If link `lid`'s href is the synthetic "#__evt_N" the native rewrite injects
# around a click-handler element, return the DOM record index N; else -1. The
# native front-end calls this on a hit-tested link to route a pointer click to
# he_dom_click_index instead of navigating.
def he_link_evt_index(lid: int32) -> int32:
    if lid < 0 or cast[uint64](lid) >= n_links:
        return -1
    o: uint64 = cast[uint64](link_off[lid])
    l: int32 = link_len[lid]
    pfx: Ptr[uint8] = cast[Ptr[uint8]]("#__evt_")
    k: int32 = 0
    while k < 7:
        if k >= l or link_href_buf[o + cast[uint64](k)] != pfx[k]:
            return -1
        k = k + 1
    v: int32 = 0
    while k < l:
        c: uint8 = link_href_buf[o + cast[uint64](k)]
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[int32](c) - 48
        k = k + 1
    return v


# Native front-ends set this to 1 so the rewrite wraps click-handler elements
# in a synthetic "#__evt_N" link, reusing the existing pointer link hit-test
# for event dispatch. Host/default stays 0 so its render is byte-for-byte the
# same as with no handlers (keeps the host gate output stable).
def he_set_click_links(v: int32):
    he_click_links = v


# Register the ES-module resolver the browser uses to fetch `<script type=module>`
# dependencies (import specifiers). The embedder (native hambrowse via http9, or
# a host test harness reading files) supplies the source bytes; the engine opens
# no sockets itself. Registered once before layout — js_init preserves it across
# per-page resets, so inline modules can import through it.
def he_set_module_resolver(fn: Fn[Ptr[uint8], int32, Ptr[int32], Ptr[uint8]]):
    js_set_module_resolver(fn)


# Format a packed 0xRRGGBB into a "#rrggbb\0" string in `out` (>= 8 bytes).
def he_rgb_hex(rgb: int32, out: Ptr[uint8]):
    out[0] = 35                                       # '#'
    hexd: Ptr[uint8] = cast[Ptr[uint8]]("0123456789abcdef")
    k: int32 = 0
    while k < 6:
        shift: int32 = (5 - k) * 4
        nib: int32 = (rgb / (1 << shift)) & 15
        out[1 + k] = hexd[nib]
        k = k + 1
    out[7] = 0


# Resolve segment `si` to a "#rrggbb\0" colour string in the caller's buffer
# (>= 8 bytes). Explicit CSS colour wins; otherwise the role palette.
def he_seg_color_hex(si: uint64, out: Ptr[uint8]):
    rgb: int32 = seg_rgb[si]
    if rgb < 0:
        rgb = _palette_rgb(seg_color[si])
    he_rgb_hex(rgb, out)


# ---- accessors for the graphical (htmlpaint) pixel backend -----------
# The pixel renderer (lib/htmlpaint.ad, driven by user/hambrowse*_gfx) reads
# the laid-out segment table through these instead of reaching into globals,
# so the same engine feeds both the legacy monospace-grid dump and the new
# proportional-font pixel paint.
def he_n_segs() -> uint64:
    return n_segs


def he_total_rows() -> uint64:
    return total_rows


def he_page_width() -> int32:
    return bw


# Page-level background colour (0xRRGGBB) from <body>/<html>, or -1 for the
# default white. The pixel renderer clears the whole canvas to this (gap #3).
def he_page_bg() -> int32:
    return g_page_bg


def he_seg_line(si: uint64) -> int32:
    return seg_line[si]


def he_seg_x(si: uint64) -> int32:
    return seg_x[si]


def he_seg_off(si: uint64) -> int32:
    return seg_off[si]


def he_seg_len(si: uint64) -> int32:
    return seg_len[si]


def he_seg_text_ptr() -> Ptr[uint8]:
    return &seg_text_buf[0]


def he_seg_face(si: uint64) -> uint8:
    return seg_face[si]


def he_seg_gridx(si: uint64) -> int32:
    return cast[int32](seg_gridx[si])


# CSS font-size (px) for this segment, or 0 = use the face default.
def he_seg_pxsize(si: uint64) -> int32:
    return seg_pxsize[si]


# CSS line-height resolved to PIXELS (the line-box pitch) for this segment, or
# 0 = use the renderer's default vertical rhythm.
def he_seg_lineh(si: uint64) -> int32:
    return seg_lineh[si]


def he_seg_bold(si: uint64) -> int32:
    return cast[int32](seg_bold[si])


def he_seg_uline(si: uint64) -> int32:
    return cast[int32](seg_uline[si])


# Signed baseline offset (px): <0 raises (<sup>), >0 lowers (<sub>), 0 normal.
def he_seg_yoff(si: uint64) -> int32:
    return seg_yoff[si]


# 1 if segment si carries a line-through (<s>/<del>/<strike>).
def he_seg_strike(si: uint64) -> int32:
    return cast[int32](seg_strike[si])


# 1 if segment si is italic (<em>/<i> or CSS font-style:italic) and should be
# painted as a FAUX-OBLIQUE (horizontal shear of the upright bitmap glyphs).
def he_seg_italic(si: uint64) -> int32:
    return cast[int32](seg_italic[si])


def he_seg_link(si: uint64) -> int32:
    return seg_link[si]


def he_seg_bg(si: uint64) -> int32:
    return seg_bg[si]


# 1 = segment si is a text-like <input> field (draw a real bordered box); 0 = no.
def he_seg_field(si: uint64) -> int32:
    return cast[int32](seg_field[si])


# For a seg_field segment, the count of real content chars after the '[' (the
# value / placeholder / masked '*' run) the pixel renderer should draw.
def he_seg_fieldlen(si: uint64) -> int32:
    return seg_fieldlen[si]


# For a checkbox/radio segment (seg_field 3/4), the resolved CSS accent-color
# (0xRRGGBB) or -1 to use the UA default accent blue.
def he_seg_accent(si: uint64) -> int32:
    return seg_accent[si]


# For a form-control segment (seg_field 1/2), 1 = CSS `appearance:none` is in
# effect (the painter suppresses the default field/button chrome), else 0.
def he_seg_appear(si: uint64) -> int32:
    return cast[int32](seg_appear[si])


# For a form-control segment (seg_field 1/2), the control's CSS `height` in whole
# text rows (>=1), or 0 for the default single-row height.
def he_seg_ctrlrows(si: uint64) -> int32:
    return seg_ctrlrows[si]


# Effective 0xRRGGBB for segment si (explicit CSS colour, else role palette).
def he_seg_rgb(si: uint64) -> int32:
    rgb: int32 = seg_rgb[si]
    if rgb < 0:
        rgb = _palette_rgb(seg_color[si])
    return rgb


def he_row_rule(r: uint64) -> uint8:
    return row_rule[r]


# ---- <img> segment + src-registry accessors -------------------------
# he_seg_img: decoded-image slot for segment si, -1 = text seg, -2 = broken.
def he_seg_img(si: uint64) -> int32:
    return seg_img[si]


def he_seg_imgw(si: uint64) -> int32:
    return seg_imgw[si]


def he_seg_imgh(si: uint64) -> int32:
    return seg_imgh[si]


# 1 if segment si is ASCII box-art (border glyphs). The pixel renderer skips
# these and strokes real rectangles from the border-box registry instead.
def he_seg_boxart(si: uint64) -> int32:
    return cast[int32](seg_boxart[si])


# 1 if segment si is an unordered-list bullet marker. The pixel renderer draws
# a real round disc for it (in the gutter) instead of painting the placeholder.
def he_seg_marker(si: uint64) -> int32:
    return cast[int32](seg_marker[si])


# 1 if segment si is a list item's first text run: the pixel renderer jumps the
# pen forward to seg_x so the hanging indent (marker gutter) is preserved.
def he_seg_indjump(si: uint64) -> int32:
    return cast[int32](seg_indjump[si])


# ---- pixel border-box registry accessors ----------------------------
def he_n_bboxes() -> int32:
    return n_bboxes


def he_bbox_lx(i: int32) -> int32:
    return bbox_lx[i]


def he_bbox_rx(i: int32) -> int32:
    return bbox_rx[i]


def he_bbox_top(i: int32) -> int32:
    return bbox_top[i]


def he_bbox_bot(i: int32) -> int32:
    return bbox_bot[i]


def he_bbox_rgb(i: int32) -> int32:
    return bbox_rgb[i]


# Per-side border colours (0xRRGGBB) of bordered box i: right / bottom / left.
# The TOP colour (and the uniform fallback) is he_bbox_rgb. Each already resolves
# to its own declared colour or the uniform fallback.
def he_bbox_rgb_r(i: int32) -> int32:
    return bbox_rgb_r[i]


def he_bbox_rgb_b(i: int32) -> int32:
    return bbox_rgb_b[i]


def he_bbox_rgb_l(i: int32) -> int32:
    return bbox_rgb_l[i]


# border-radius px of bordered box i (0 = square corners).
def he_bbox_radius(i: int32) -> int32:
    return bbox_rad[i]


# ---- element background-fill registry accessors ---------------------
def he_n_bfills() -> int32:
    return n_bfills


def he_bfill_lx(i: int32) -> int32:
    return bfill_lx[i]


def he_bfill_rx(i: int32) -> int32:
    return bfill_rx[i]


def he_bfill_top(i: int32) -> int32:
    return bfill_top[i]


def he_bfill_bot(i: int32) -> int32:
    return bfill_bot[i]


def he_bfill_rgb(i: int32) -> int32:
    return bfill_rgb[i]


# Stacking order (z-index) of block background fill i; 0 = default flow order.
def he_bfill_z(i: int32) -> int32:
    return bfill_z[i]


# border-radius px of background fill i (0 = square corners).
def he_bfill_radius(i: int32) -> int32:
    return bfill_rad[i]


# CSS filter of background fill i, packed as (type << 20) | amount (0 = none).
# See lib/web/css/cascade.ad _filter_value for the encoding. The renderer applies
# it as a per-pixel post-pass over the fill's rectangle (htmlpaint_filter_rect).
def he_bfill_filter(i: int32) -> int32:
    return bfill_filter[i]


# Number of distinct <img src> strings seen in the last layout — the host
# driver iterates these to slurp + decode each PNG before a second layout pass.
def he_n_images() -> uint64:
    return n_eimg


def he_img_name_ptr(i: uint64) -> Ptr[uint8]:
    return &eimg_name_buf[eimg_noff[i]]


def he_img_name_len(i: uint64) -> uint64:
    return eimg_nlen[i]



# ====================================================================
# OBSERVER APIs — MutationObserver / IntersectionObserver / ResizeObserver.
# ====================================================================
# The three observer surfaces modern frameworks (React, Vue, lazy-load libs,
# auto-resizing widgets) depend on. All callbacks are delivered as MICROTASKS
# on the shared JS microtask queue (via the global queueMicrotask), so:
#
#   * MutationObserver batches every mutation made during the current script and
#     fires its callback ONCE, as a microtask, AFTER the script finishes — the
#     spec's microtask-checkpoint "notify mutation observers" step. Records made
#     while the callback runs schedule a fresh microtask (the queued flag is
#     cleared before callbacks fire), so chained observers compose.
#
#   * IntersectionObserver / ResizeObserver deliver ONCE after observe(), against
#     the single (headless) layout the engine produced. There is NO live scroll
#     or resize loop in the headless single-layout render model: an entry is a
#     one-shot snapshot of the element's laid-out box vs the viewport. This is
#     documented honestly in docs/browser_w3c_conformance.md.
#
# Delivery is coalesced: the FIRST queued observer work schedules one
# NID_OBS_DELIVER microtask; that job flushes MutationObserver record batches,
# then IntersectionObserver entries, then ResizeObserver entries.

MO_MAX:      int32 = 64
MO_REG_MAX:  int32 = 256
MO_REC_MAX:  int32 = 512
MO_FILT_CAP: int32 = 4096

# MutationObserver instances (indexed by observer).
mo_this:  Array[64, int32]        # observer object value (identity key)
mo_cb:    Array[64, int32]        # callback fn value
mo_used:  Array[64, uint8]        # 1 = live
mo_n:     int32 = 0               # high-water of allocated observers

# MutationObserver observe() registrations (observer x target x options).
mreg_oidx:     Array[256, int32]  # owning observer index
mreg_target:   Array[256, int32]  # observed node object value
mreg_childlist: Array[256, uint8]
mreg_attr:     Array[256, uint8]
mreg_chardata: Array[256, uint8]
mreg_subtree:  Array[256, uint8]
mreg_attr_oldv: Array[256, uint8]
mreg_char_oldv: Array[256, uint8]
mreg_filt_off: Array[256, int32]  # offset into mo_filt_pool (-1 = no attributeFilter)
mreg_filt_len: Array[256, int32]  # byte length of the NUL-separated filter list
mreg_active:   Array[256, uint8]  # 1 = live (disconnect flips to 0)
mreg_n:        int32 = 0          # allocated registration count (also the live-registry gate)
mo_filt_pool:  Array[4096, uint8] # NUL-separated lowercase attribute names
mo_filt_w:     int32 = 0

# MutationObserver pending records (a shared FIFO tagged by observer).
mrec_oidx:    Array[512, int32]
mrec_type:    Array[512, int32]   # 0=childList 1=attributes 2=characterData
mrec_target:  Array[512, int32]
mrec_added:   Array[512, int32]   # JS array value
mrec_removed: Array[512, int32]   # JS array value
mrec_attr:    Array[512, int32]   # attributeName string value (or js_null)
mrec_oldv:    Array[512, int32]   # oldValue string value (or js_null)
mrec_pending: Array[512, uint8]   # 1 = not yet delivered/taken
mrec_n:       int32 = 0

# IntersectionObserver instances + registrations.
io_this: Array[64, int32]
io_cb:   Array[64, int32]
io_used: Array[64, uint8]
io_n:    int32 = 0
ioreg_oidx:   Array[256, int32]
ioreg_target: Array[256, int32]
ioreg_active: Array[256, uint8]
ioreg_n:      int32 = 0

# ResizeObserver instances + registrations.
ro_this: Array[64, int32]
ro_cb:   Array[64, int32]
ro_used: Array[64, uint8]
ro_n:    int32 = 0
roreg_oidx:   Array[256, int32]
roreg_target: Array[256, int32]
roreg_active: Array[256, uint8]
roreg_n:      int32 = 0

g_obs_micro_queued: int32 = 0     # 1 = a NID_OBS_DELIVER microtask is pending
g_obs_argv2: Array[2, int32]      # scratch arg vector for callback / queueMicrotask


# Reset every observer registry (called once per page from _js_build_document,
# i.e. after each js_init) so a fresh page starts with no observers/records.
def _obs_reset():
    mo_n = 0
    mreg_n = 0
    mrec_n = 0
    mo_filt_w = 0
    io_n = 0
    ioreg_n = 0
    ro_n = 0
    roreg_n = 0
    g_obs_micro_queued = 0


# Schedule the single coalesced delivery microtask, if not already pending. Runs
# the delivery job through the ENGINE microtask queue (global queueMicrotask) so
# it fires after the current script at the microtask checkpoint — no host-side
# timer plumbing, and it composes with Promise/queueMicrotask ordering.
def _obs_schedule():
    if g_obs_micro_queued != 0:
        return
    qm: int32 = js_global_get(cast[Ptr[uint8]]("queueMicrotask"), 14)
    if js_is_callable(qm) == 0:
        return
    g_obs_micro_queued = 1
    deliver: int32 = js_new_native_fn(js_hbase + NID_OBS_DELIVER)
    g_obs_argv2[0] = deliver
    js_call_fn(qm, js_undefined(), &g_obs_argv2[0], 1)


# Does the mutation on `mut_node` fall within registration `reg`'s scope? True
# when the observed target IS the node, or (subtree) an ancestor of it. Ancestor
# lookup walks the live parentNode back-links the mutation handlers maintain.
def _mo_scope_hit(mut_node: int32, reg: int32) -> int32:
    if mut_node == mreg_target[reg]:
        return 1
    if cast[int32](mreg_subtree[reg]) == 0:
        return 0
    cur: int32 = js_get_prop(mut_node, cast[Ptr[uint8]]("parentNode"), 10)
    d: int32 = 0
    while d < 64 and js_type_of(cur) == 5:
        if cur == mreg_target[reg]:
            return 1
        cur = js_get_prop(cur, cast[Ptr[uint8]]("parentNode"), 10)
        d = d + 1
    return 0


# Lowercase ascii byte.
def _obs_lc(c: uint8) -> uint8:
    if c >= 65 and c <= 90:
        return c + 32
    return c


# Does registration `reg`'s attributeFilter admit attribute `name`? A registration
# with no filter admits every attribute; otherwise the (case-insensitive) name
# must appear in the NUL-separated pool slice.
def _mo_filter_allows(reg: int32, name: Ptr[uint8], nlen: int32) -> int32:
    if mreg_filt_len[reg] == 0:
        return 1
    off: int32 = mreg_filt_off[reg]
    endp: int32 = off + mreg_filt_len[reg]
    i: int32 = off
    while i < endp:
        # one filter token runs to the next NUL
        ts: int32 = i
        while i < endp and mo_filt_pool[i] != 0:
            i = i + 1
        tlen: int32 = i - ts
        if tlen == nlen:
            k: int32 = 0
            eq: int32 = 1
            while k < tlen:
                if mo_filt_pool[ts + k] != _obs_lc(name[k]):
                    eq = 0
                    k = tlen
                k = k + 1
            if eq != 0:
                return 1
        i = i + 1                                # skip the NUL
    return 0


# Wrap a single node value (or js_null when `node` < 0, the "none" sentinel) as a
# fresh JS array, so addedNodes/removedNodes are always NodeList-shaped arrays.
def _mo_node_list(node: int32) -> int32:
    a: int32 = js_new_array_v()
    if node != -1 and node != js_null():
        js_array_push(a, node)
    return a


# Queue one record for every MutationObserver registration matching (mut_node,
# type). `added`/`removed` are node values or -1; `attr`/`oldv` are string values
# or js_null. Also (re)schedules the delivery microtask.
def _mo_queue(mut_node: int32, mtype: int32, added: int32, removed: int32, \
              attr: int32, aname: Ptr[uint8], anlen: int32):
    if mreg_n == 0:
        return
    queued: int32 = 0
    r: int32 = 0
    while r < mreg_n:
        take: int32 = 0
        if cast[int32](mreg_active[r]) != 0 and _mo_scope_hit(mut_node, r) != 0:
            if mtype == 0 and cast[int32](mreg_childlist[r]) != 0:
                take = 1
            elif mtype == 1 and cast[int32](mreg_attr[r]) != 0:
                if _mo_filter_allows(r, aname, anlen) != 0:
                    take = 1
            elif mtype == 2 and cast[int32](mreg_chardata[r]) != 0:
                take = 1
        if take != 0 and mrec_n < MO_REC_MAX:
            reci: int32 = mrec_n
            mrec_n = mrec_n + 1
            mrec_oidx[reci] = mreg_oidx[r]
            mrec_type[reci] = mtype
            mrec_target[reci] = mut_node
            mrec_added[reci] = _mo_node_list(added)
            mrec_removed[reci] = _mo_node_list(removed)
            mrec_attr[reci] = js_null()
            mrec_oldv[reci] = js_null()
            if mtype == 1:
                # `attr` carries the captured PRE-mutation value; the name comes
                # from aname[0..anlen). oldValue is exposed only when the matching
                # registration requested attributeOldValue.
                mrec_attr[reci] = js_new_string(aname, cast[uint64](anlen))
                if cast[int32](mreg_attr_oldv[r]) != 0:
                    mrec_oldv[reci] = attr
            mrec_pending[reci] = cast[uint8](1)
            queued = 1
        r = r + 1
    if queued != 0:
        _obs_schedule()


# Read a node's CURRENT value of attribute name[0..nlen) as a string value, for
# an attributeOldValue snapshot taken BEFORE the write. `tgt` is the JS object.
# class -> className; style -> serialized; else the reflected property (js_null
# when absent).
def _mo_attr_oldvalue(tgt: int32, name: Ptr[uint8], nlen: int32) -> int32:
    if _bytes_eq(name, nlen, cast[Ptr[uint8]]("class"), 5) != 0:
        return js_get_prop(tgt, cast[Ptr[uint8]]("className"), 9)
    if _bytes_eq(name, nlen, cast[Ptr[uint8]]("style"), 5) != 0:
        sto: int32 = js_get_prop(tgt, cast[Ptr[uint8]]("style"), 5)
        return _style_serialize(sto)
    return js_get_prop(tgt, name, cast[uint64](nlen))


# ---- mutation-point recording entrypoints (called from the NID handlers) ----
def _mo_record_childlist(parent: int32, added: int32, removed: int32):
    _mo_queue(parent, 0, added, removed, js_null(), cast[Ptr[uint8]](""), 0)


def _mo_record_attr(el: int32, name: Ptr[uint8], nlen: int32, oldv: int32):
    _mo_queue(el, 1, -1, -1, oldv, name, nlen)


def _mo_record_chardata(node: int32):
    _mo_queue(node, 2, -1, -1, js_null(), cast[Ptr[uint8]](""), 0)


# Find the observer index whose instance object is `thisobj`, or -1.
def _mo_find(thisobj: int32) -> int32:
    i: int32 = 0
    while i < mo_n:
        if cast[int32](mo_used[i]) != 0 and mo_this[i] == thisobj:
            return i
        i = i + 1
    return -1


# Build one MutationRecord JS object from pending-record slot `reci`.
def _mo_build_record(reci: int32) -> int32:
    r: int32 = js_new_object_v()
    t: int32 = mrec_type[reci]
    if t == 0:
        js_set_prop(r, cast[Ptr[uint8]]("type"), 4, \
                    js_new_string(cast[Ptr[uint8]]("childList"), 9))
    elif t == 1:
        js_set_prop(r, cast[Ptr[uint8]]("type"), 4, \
                    js_new_string(cast[Ptr[uint8]]("attributes"), 10))
    else:
        js_set_prop(r, cast[Ptr[uint8]]("type"), 4, \
                    js_new_string(cast[Ptr[uint8]]("characterData"), 13))
    js_set_prop(r, cast[Ptr[uint8]]("target"), 6, mrec_target[reci])
    js_set_prop(r, cast[Ptr[uint8]]("addedNodes"), 10, mrec_added[reci])
    js_set_prop(r, cast[Ptr[uint8]]("removedNodes"), 12, mrec_removed[reci])
    js_set_prop(r, cast[Ptr[uint8]]("previousSibling"), 15, js_null())
    js_set_prop(r, cast[Ptr[uint8]]("nextSibling"), 11, js_null())
    js_set_prop(r, cast[Ptr[uint8]]("attributeName"), 13, mrec_attr[reci])
    js_set_prop(r, cast[Ptr[uint8]]("attributeNamespace"), 18, js_null())
    js_set_prop(r, cast[Ptr[uint8]]("oldValue"), 8, mrec_oldv[reci])
    return r


# Drain pending records for observer `oidx` into a fresh JS array (FIFO), marking
# them delivered. Shared by takeRecords() and the delivery microtask.
def _mo_take(oidx: int32) -> int32:
    arr: int32 = js_new_array_v()
    i: int32 = 0
    while i < mrec_n:
        if cast[int32](mrec_pending[i]) != 0 and mrec_oidx[i] == oidx:
            js_array_push(arr, _mo_build_record(i))
            mrec_pending[i] = cast[uint8](0)
        i = i + 1
    return arr


# ---- IntersectionObserver -------------------------------------------------
def _io_find(thisobj: int32) -> int32:
    i: int32 = 0
    while i < io_n:
        if cast[int32](io_used[i]) != 0 and io_this[i] == thisobj:
            return i
        i = i + 1
    return -1


def _obs_viewport_w() -> float64:
    v: float64 = js_to_number(js_global_get(cast[Ptr[uint8]]("innerWidth"), 10))
    if v > 0.0:
        return v
    return 1024.0


def _obs_viewport_h() -> float64:
    v: float64 = js_to_number(js_global_get(cast[Ptr[uint8]]("innerHeight"), 11))
    if v > 0.0:
        return v
    return 768.0


# Build one IntersectionObserverEntry for `target` against the viewport root,
# from the element's laid-out box (single-layout snapshot).
def _io_build_entry(target: int32) -> int32:
    e: int32 = js_new_object_v()
    el: int32 = _find_el_by_obj(target)
    _el_bbox(el)
    rect: int32 = _new_rect_obj()
    left: float64 = js_to_number(js_get_prop(rect, cast[Ptr[uint8]]("left"), 4))
    top: float64 = js_to_number(js_get_prop(rect, cast[Ptr[uint8]]("top"), 3))
    w: float64 = js_to_number(js_get_prop(rect, cast[Ptr[uint8]]("width"), 5))
    h: float64 = js_to_number(js_get_prop(rect, cast[Ptr[uint8]]("height"), 6))
    vw: float64 = _obs_viewport_w()
    vh: float64 = _obs_viewport_h()
    ix0: float64 = left
    if 0.0 > ix0:
        ix0 = 0.0
    iy0: float64 = top
    if 0.0 > iy0:
        iy0 = 0.0
    ix1: float64 = left + w
    if vw < ix1:
        ix1 = vw
    iy1: float64 = top + h
    if vh < iy1:
        iy1 = vh
    iw: float64 = ix1 - ix0
    ih: float64 = iy1 - iy0
    if iw < 0.0:
        iw = 0.0
    if ih < 0.0:
        ih = 0.0
    inter: float64 = iw * ih
    area: float64 = w * h
    ratio: float64 = 0.0
    if area > 0.0:
        ratio = inter / area
    isect: int32 = 0
    if inter > 0.0:
        isect = 1
    js_set_prop(e, cast[Ptr[uint8]]("target"), 6, target)
    js_set_prop(e, cast[Ptr[uint8]]("isIntersecting"), 14, js_bool(isect))
    js_set_prop(e, cast[Ptr[uint8]]("intersectionRatio"), 17, js_number(ratio))
    js_set_prop(e, cast[Ptr[uint8]]("boundingClientRect"), 18, rect)
    js_set_prop(e, cast[Ptr[uint8]]("intersectionRect"), 16, rect)
    js_set_prop(e, cast[Ptr[uint8]]("time"), 4, js_number(0.0))
    return e


# ---- ResizeObserver -------------------------------------------------------
def _ro_find(thisobj: int32) -> int32:
    i: int32 = 0
    while i < ro_n:
        if cast[int32](ro_used[i]) != 0 and ro_this[i] == thisobj:
            return i
        i = i + 1
    return -1


# Build one ResizeObserverEntry for `target` with its laid-out content box.
def _ro_build_entry(target: int32) -> int32:
    e: int32 = js_new_object_v()
    el: int32 = _find_el_by_obj(target)
    _el_bbox(el)
    rect: int32 = _new_rect_obj()
    w: float64 = js_to_number(js_get_prop(rect, cast[Ptr[uint8]]("width"), 5))
    h: float64 = js_to_number(js_get_prop(rect, cast[Ptr[uint8]]("height"), 6))
    cr: int32 = js_new_object_v()
    js_set_prop(cr, cast[Ptr[uint8]]("x"), 1, js_number(0.0))
    js_set_prop(cr, cast[Ptr[uint8]]("y"), 1, js_number(0.0))
    js_set_prop(cr, cast[Ptr[uint8]]("left"), 4, js_number(0.0))
    js_set_prop(cr, cast[Ptr[uint8]]("top"), 3, js_number(0.0))
    js_set_prop(cr, cast[Ptr[uint8]]("width"), 5, js_number(w))
    js_set_prop(cr, cast[Ptr[uint8]]("height"), 6, js_number(h))
    js_set_prop(cr, cast[Ptr[uint8]]("right"), 5, js_number(w))
    js_set_prop(cr, cast[Ptr[uint8]]("bottom"), 6, js_number(h))
    js_set_prop(e, cast[Ptr[uint8]]("target"), 6, target)
    js_set_prop(e, cast[Ptr[uint8]]("contentRect"), 11, cr)
    bs: int32 = js_new_object_v()
    js_set_prop(bs, cast[Ptr[uint8]]("inlineSize"), 10, js_number(w))
    js_set_prop(bs, cast[Ptr[uint8]]("blockSize"), 9, js_number(h))
    bsl: int32 = js_new_array_v()
    js_array_push(bsl, bs)
    js_set_prop(e, cast[Ptr[uint8]]("contentBoxSize"), 14, bsl)
    js_set_prop(e, cast[Ptr[uint8]]("borderBoxSize"), 13, bsl)
    return e


# ---- coalesced delivery (the NID_OBS_DELIVER microtask body) ---------------
# Clear the queued flag FIRST (so callbacks that mutate/observe schedule a fresh
# microtask), then deliver MutationObserver batches, IntersectionObserver
# entries, then ResizeObserver entries. Each observer fires at most once here.
def _obs_deliver_all():
    g_obs_micro_queued = 0
    # MutationObservers: one batched callback per observer that has records.
    oi: int32 = 0
    while oi < mo_n:
        if cast[int32](mo_used[oi]) != 0:
            recs: int32 = _mo_take(oi)
            if js_array_len(recs) > 0:
                g_obs_argv2[0] = recs
                g_obs_argv2[1] = mo_this[oi]
                js_call_fn(mo_cb[oi], mo_this[oi], &g_obs_argv2[0], 2)
        oi = oi + 1
    # IntersectionObservers.
    ii: int32 = 0
    while ii < io_n:
        if cast[int32](io_used[ii]) != 0:
            entries: int32 = js_new_array_v()
            rr: int32 = 0
            while rr < ioreg_n:
                if cast[int32](ioreg_active[rr]) != 0 and ioreg_oidx[rr] == ii:
                    js_array_push(entries, _io_build_entry(ioreg_target[rr]))
                rr = rr + 1
            if js_array_len(entries) > 0:
                g_obs_argv2[0] = entries
                g_obs_argv2[1] = io_this[ii]
                js_call_fn(io_cb[ii], io_this[ii], &g_obs_argv2[0], 2)
        ii = ii + 1
    # ResizeObservers.
    ri: int32 = 0
    while ri < ro_n:
        if cast[int32](ro_used[ri]) != 0:
            rentries: int32 = js_new_array_v()
            qr: int32 = 0
            while qr < roreg_n:
                if cast[int32](roreg_active[qr]) != 0 and roreg_oidx[qr] == ri:
                    js_array_push(rentries, _ro_build_entry(roreg_target[qr]))
                qr = qr + 1
            if js_array_len(rentries) > 0:
                g_obs_argv2[0] = rentries
                g_obs_argv2[1] = ro_this[ri]
                js_call_fn(ro_cb[ri], ro_this[ri], &g_obs_argv2[0], 2)
        ri = ri + 1


# Attach the observe/disconnect/takeRecords (or unobserve) methods on a freshly
# constructed observer instance.
def _mo_attach_methods(inst: int32):
    js_set_prop(inst, cast[Ptr[uint8]]("observe"), 7, \
                js_new_native_fn(js_hbase + NID_MO_OBSERVE))
    js_set_prop(inst, cast[Ptr[uint8]]("disconnect"), 10, \
                js_new_native_fn(js_hbase + NID_MO_DISCONNECT))
    js_set_prop(inst, cast[Ptr[uint8]]("takeRecords"), 11, \
                js_new_native_fn(js_hbase + NID_MO_TAKEREC))


def _io_attach_methods(inst: int32):
    js_set_prop(inst, cast[Ptr[uint8]]("observe"), 7, \
                js_new_native_fn(js_hbase + NID_IO_OBSERVE))
    js_set_prop(inst, cast[Ptr[uint8]]("unobserve"), 9, \
                js_new_native_fn(js_hbase + NID_IO_UNOBSERVE))
    js_set_prop(inst, cast[Ptr[uint8]]("disconnect"), 10, \
                js_new_native_fn(js_hbase + NID_IO_DISCONNECT))
    js_set_prop(inst, cast[Ptr[uint8]]("takeRecords"), 11, js_new_array_v())


def _ro_attach_methods(inst: int32):
    js_set_prop(inst, cast[Ptr[uint8]]("observe"), 7, \
                js_new_native_fn(js_hbase + NID_RO_OBSERVE))
    js_set_prop(inst, cast[Ptr[uint8]]("unobserve"), 9, \
                js_new_native_fn(js_hbase + NID_RO_UNOBSERVE))
    js_set_prop(inst, cast[Ptr[uint8]]("disconnect"), 10, \
                js_new_native_fn(js_hbase + NID_RO_DISCONNECT))


# Parse a MutationObserver observe() options object into a fresh registration
# `reg`. attributeFilter (or attributeOldValue/attributes-absent-with-filter)
# implies attributes; attributeFilter names are stored NUL-separated, lowercased.
def _mo_parse_options(reg: int32, opts: int32):
    cl: int32 = js_to_bool(js_get_prop(opts, cast[Ptr[uint8]]("childList"), 9))
    at: int32 = js_to_bool(js_get_prop(opts, cast[Ptr[uint8]]("attributes"), 10))
    cd: int32 = js_to_bool(js_get_prop(opts, cast[Ptr[uint8]]("characterData"), 13))
    st: int32 = js_to_bool(js_get_prop(opts, cast[Ptr[uint8]]("subtree"), 7))
    aov: int32 = js_to_bool(js_get_prop(opts, cast[Ptr[uint8]]("attributeOldValue"), 17))
    cov: int32 = js_to_bool(js_get_prop(opts, cast[Ptr[uint8]]("characterDataOldValue"), 21))
    filt: int32 = js_get_prop(opts, cast[Ptr[uint8]]("attributeFilter"), 15)
    mreg_filt_off[reg] = -1
    mreg_filt_len[reg] = 0
    if js_is_array(filt) != 0:
        at = 1                                   # attributeFilter implies attributes
        start: int32 = mo_filt_w
        n: int32 = js_array_len(filt)
        fi: int32 = 0
        while fi < n:
            sv: int32 = js_array_get(filt, fi)
            sp: Ptr[uint8] = js_str_ptr(sv)
            sl: int32 = _cstr_len(sp)
            k: int32 = 0
            while k < sl and mo_filt_w < MO_FILT_CAP:
                mo_filt_pool[mo_filt_w] = _obs_lc(sp[k])
                mo_filt_w = mo_filt_w + 1
                k = k + 1
            if mo_filt_w < MO_FILT_CAP:
                mo_filt_pool[mo_filt_w] = 0       # NUL separator
                mo_filt_w = mo_filt_w + 1
            fi = fi + 1
        mreg_filt_off[reg] = start
        mreg_filt_len[reg] = mo_filt_w - start
    # attributeOldValue/characterDataOldValue with no explicit attributes/
    # characterData still turn the respective observation on (spec).
    if aov != 0:
        at = 1
    if cov != 0:
        cd = 1
    mreg_childlist[reg] = cast[uint8](cl)
    mreg_attr[reg] = cast[uint8](at)
    mreg_chardata[reg] = cast[uint8](cd)
    mreg_subtree[reg] = cast[uint8](st)
    mreg_attr_oldv[reg] = cast[uint8](aov)
    mreg_char_oldv[reg] = cast[uint8](cov)


# The observer-API host dispatch arm (rel in [NID_MO_CTOR .. NID_OBS_DELIVER]).
def _obs_dispatch(rel: int32) -> int32:
    if rel == NID_MO_CTOR:
        inst: int32 = js_this()
        if mo_n < MO_MAX:
            idx: int32 = mo_n
            mo_n = mo_n + 1
            mo_this[idx] = inst
            mo_cb[idx] = js_arg(0)
            mo_used[idx] = cast[uint8](1)
        _mo_attach_methods(inst)
        return js_undefined()
    if rel == NID_MO_OBSERVE:
        oidx: int32 = _mo_find(js_this())
        if oidx >= 0 and js_arg_count() >= 1 and mreg_n < MO_REG_MAX:
            reg: int32 = mreg_n
            mreg_n = mreg_n + 1
            mreg_oidx[reg] = oidx
            mreg_target[reg] = js_arg(0)
            mreg_active[reg] = cast[uint8](1)
            _mo_parse_options(reg, js_arg(1))
        return js_undefined()
    if rel == NID_MO_DISCONNECT:
        doidx: int32 = _mo_find(js_this())
        if doidx >= 0:
            r: int32 = 0
            while r < mreg_n:
                if mreg_oidx[r] == doidx:
                    mreg_active[r] = cast[uint8](0)
                r = r + 1
            # disconnect() empties the observer's record queue (spec).
            q: int32 = 0
            while q < mrec_n:
                if mrec_oidx[q] == doidx:
                    mrec_pending[q] = cast[uint8](0)
                q = q + 1
        return js_undefined()
    if rel == NID_MO_TAKEREC:
        toidx: int32 = _mo_find(js_this())
        if toidx >= 0:
            return _mo_take(toidx)
        return js_new_array_v()
    if rel == NID_IO_CTOR:
        ioinst: int32 = js_this()
        if io_n < MO_MAX:
            iidx: int32 = io_n
            io_n = io_n + 1
            io_this[iidx] = ioinst
            io_cb[iidx] = js_arg(0)
            io_used[iidx] = cast[uint8](1)
        _io_attach_methods(ioinst)
        return js_undefined()
    if rel == NID_IO_OBSERVE:
        ioo: int32 = _io_find(js_this())
        if ioo >= 0 and js_arg_count() >= 1 and ioreg_n < MO_REG_MAX:
            ir: int32 = ioreg_n
            ioreg_n = ioreg_n + 1
            ioreg_oidx[ir] = ioo
            ioreg_target[ir] = js_arg(0)
            ioreg_active[ir] = cast[uint8](1)
            _obs_schedule()
        return js_undefined()
    if rel == NID_IO_UNOBSERVE:
        iou: int32 = _io_find(js_this())
        if iou >= 0 and js_arg_count() >= 1:
            k: int32 = 0
            while k < ioreg_n:
                if ioreg_oidx[k] == iou and ioreg_target[k] == js_arg(0):
                    ioreg_active[k] = cast[uint8](0)
                k = k + 1
        return js_undefined()
    if rel == NID_IO_DISCONNECT:
        iod: int32 = _io_find(js_this())
        if iod >= 0:
            k2: int32 = 0
            while k2 < ioreg_n:
                if ioreg_oidx[k2] == iod:
                    ioreg_active[k2] = cast[uint8](0)
                k2 = k2 + 1
        return js_undefined()
    if rel == NID_RO_CTOR:
        roinst: int32 = js_this()
        if ro_n < MO_MAX:
            ridx: int32 = ro_n
            ro_n = ro_n + 1
            ro_this[ridx] = roinst
            ro_cb[ridx] = js_arg(0)
            ro_used[ridx] = cast[uint8](1)
        _ro_attach_methods(roinst)
        return js_undefined()
    if rel == NID_RO_OBSERVE:
        roo: int32 = _ro_find(js_this())
        if roo >= 0 and js_arg_count() >= 1 and roreg_n < MO_REG_MAX:
            rr2: int32 = roreg_n
            roreg_n = roreg_n + 1
            roreg_oidx[rr2] = roo
            roreg_target[rr2] = js_arg(0)
            roreg_active[rr2] = cast[uint8](1)
            _obs_schedule()
        return js_undefined()
    if rel == NID_RO_UNOBSERVE:
        rou: int32 = _ro_find(js_this())
        if rou >= 0 and js_arg_count() >= 1:
            m: int32 = 0
            while m < roreg_n:
                if roreg_oidx[m] == rou and roreg_target[m] == js_arg(0):
                    roreg_active[m] = cast[uint8](0)
                m = m + 1
        return js_undefined()
    if rel == NID_RO_DISCONNECT:
        rod: int32 = _ro_find(js_this())
        if rod >= 0:
            m2: int32 = 0
            while m2 < roreg_n:
                if roreg_oidx[m2] == rod:
                    roreg_active[m2] = cast[uint8](0)
                m2 = m2 + 1
        return js_undefined()
    if rel == NID_OBS_DELIVER:
        _obs_deliver_all()
        return js_undefined()
    return js_undefined()

# Override advance in FONT UNITS (DejaVu 2048 upm) for glyph `cp` in `ttface`.
# Returns -1 when no override applies (non-prose face, or cp outside ASCII) so
# the caller falls back to font_ttf_adv_fu and stays byte-identical there.
def hb_adv_fu_ov(ttface: int32, cp: int32) -> int64:
    if ttface != 0 and ttface != 1:
        return -1
    if cp < FA_LO or cp > FA_HI:
        return -1
    _fa_init()
    idx: int32 = cp - FA_LO
    if ttface == 1:
        return fa_bold[idx]
    return fa_sans[idx]


# Override advance in PIXELS at size `px`, rounded once (same rounding as
# font_ttf_fu_to_px so the integer body path matches the fu display path).
# Returns -1 when no override applies.
def hb_adv_px_ov(ttface: int32, cp: int32, px: int32) -> int32:
    fu: int64 = hb_adv_fu_ov(ttface, cp)
    if fu < 0:
        return -1
    return cast[int32]((fu * cast[int64](px) + FA_UPM / 2) / FA_UPM)

# lib/web/js/consts.ad — part of the modular web engine (extracted from jsengine.ad).
# constant tables: value tags, token kinds, AST node kinds, regex opcodes.
#
# Behavior-preserving split: Adder is a single-compilation-unit language
# (merge_programs merges all imported files into one Program), so every
# public top-level name here resolves globally across the merged engine.

# ====================================================================
# Value tags.
# ====================================================================
TAG_UNDEF: int32 = 0
TAG_NULL:  int32 = 1
TAG_BOOL:  int32 = 2
TAG_NUM:   int32 = 3
TAG_STR:   int32 = 4
TAG_OBJ:   int32 = 5
TAG_BIGINT: int32 = 6      # arbitrary-precision integer (v_ref = bigint record id)

# Object kinds.
OK_PLAIN: int32 = 0
OK_ARRAY: int32 = 1
OK_FUNC:  int32 = 2
OK_SYMBOL: int32 = 3       # a Symbol primitive (typeof -> "symbol"; unique identity)

# ====================================================================
# Token kinds.
# ====================================================================
TK_EOF:    int32 = 0
TK_NUM:    int32 = 1
TK_STR:    int32 = 2
TK_IDENT:  int32 = 3

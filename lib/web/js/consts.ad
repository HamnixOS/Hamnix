# Promise (Promise/A+ shaped; reactions scheduled as MICROTASKS on the #178
# deferred-callback queue). Per-instance state (which promise a resolver is
# bound to; a combinator's shared cell + element index) is carried on the
# native function OBJECT via obj_p_a/obj_p_b, recovered through native_self.
NAT_PROMISE:          int32 = 90    # the Promise constructor (executor)
NAT_PROMISE_RESOLVE_FN: int32 = 91  # resolve(value) passed to executor/thenable
NAT_PROMISE_REJECT_FN:  int32 = 92  # reject(reason) passed to executor/thenable
NAT_PROMISE_JOB:      int32 = 93    # microtask body: run one settled reaction
NAT_PROMISE_RESOLVE:  int32 = 94    # Promise.resolve(v)
NAT_PROMISE_REJECT:   int32 = 95    # Promise.reject(r)
NAT_PROMISE_ALL:      int32 = 96    # Promise.all([...])
NAT_PROMISE_RACE:     int32 = 97    # Promise.race([...])
NAT_PROMISE_ALLSETTLED: int32 = 98  # Promise.allSettled([...])
NAT_PROMISE_THEN:     int32 = 99    # Promise.prototype.then
NAT_PROMISE_CATCH:    int32 = 100   # Promise.prototype.catch
NAT_PROMISE_FINALLY:  int32 = 101   # Promise.prototype.finally
NAT_COMB_FUL:         int32 = 102   # combinator per-element fulfilled hook
NAT_COMB_REJ:         int32 = 103   # combinator per-element rejected hook
NAT_FINALLY_FUL:      int32 = 104   # finally() fulfilled wrapper (pass value through)
NAT_FINALLY_REJ:      int32 = 105   # finally() rejected wrapper (re-throw reason)
# fetch() + Response (deterministic: resolved from a JS-settable FIXTURE table,
# NOT wall-clock network — jsengine stays extern-free + dual-target). fetch(url)
# returns a Promise<Response>; the Response body methods each return a Promise
# that settles on the SAME #178 microtask queue, so await/.then compose.
NAT_FETCH:            int32 = 110   # fetch(url[, options]) -> Promise<Response>
NAT_SET_FETCH_FIXTURE: int32 = 111 # __setFetchFixture(url, {status,body,...}) test hook
NAT_RESPONSE_TEXT:    int32 = 112   # Response.prototype.text() -> Promise<string>
NAT_RESPONSE_JSON:    int32 = 113   # Response.prototype.json() -> Promise<parsed>
NAT_RESPONSE_ARRAYBUF: int32 = 114  # Response.prototype.arrayBuffer() -> Promise<array>
NAT_HEADERS_GET:      int32 = 115   # Headers.prototype.get(name) -> string | null
NAT_STORAGE_GET:      int32 = 120   # Storage.prototype.getItem(key) -> string | null
NAT_STORAGE_SET:      int32 = 121   # Storage.prototype.setItem(key, value)
NAT_STORAGE_REMOVE:   int32 = 122   # Storage.prototype.removeItem(key)
NAT_STORAGE_CLEAR:    int32 = 123   # Storage.prototype.clear()
NAT_STORAGE_KEY:      int32 = 124   # Storage.prototype.key(n) -> string | null
# Map: constructor + prototype methods (ES2015 collections).
NAT_MAP:          int32 = 130   # Map constructor (optional iterable of [k,v])
NAT_MAP_GET:      int32 = 131
NAT_MAP_SET:      int32 = 132
NAT_MAP_HAS:      int32 = 133
NAT_MAP_DELETE:   int32 = 134
NAT_MAP_CLEAR:    int32 = 135
NAT_MAP_FOREACH:  int32 = 136
NAT_MAP_KEYS:     int32 = 137
NAT_MAP_VALUES:   int32 = 138
NAT_MAP_ENTRIES:  int32 = 139
# Set: constructor + prototype methods.
NAT_SET:          int32 = 140   # Set constructor (optional iterable of values)
NAT_SET_ADD:      int32 = 141
NAT_SET_HAS:      int32 = 142
NAT_SET_DELETE:   int32 = 143
NAT_SET_CLEAR:    int32 = 144
NAT_SET_FOREACH:  int32 = 145
NAT_SET_VALUES:   int32 = 146
# Object statics (ES5/ES2015/ES2017).
NAT_OBJECT_CREATE:      int32 = 150
NAT_OBJECT_GETPROTO:    int32 = 151
NAT_OBJECT_SETPROTO:    int32 = 152
NAT_OBJECT_GETOWNNAMES: int32 = 153
NAT_OBJECT_DEFINEPROP:  int32 = 154
NAT_OBJECT_ISFROZEN:    int32 = 155
NAT_OBJECT_GETOWNDESC:  int32 = 156
NAT_OBJECT_GETOWNDESCS: int32 = 157
NAT_OBJECT_DEFINEPROPS: int32 = 158
# Number static + Array.from.
NAT_NUMBER_ISSAFEINT: int32 = 160
NAT_ARRAY_FROM:       int32 = 161
# Round-2 conformance batch: String static helpers.
NAT_STRING_RAW:         int32 = 162   # String.raw(strings, ...subs) — cooked-template raw assembly
NAT_STRING_FROMCHARCODE: int32 = 163  # String.fromCharCode(...codes)
NAT_STRING_FROMCODEPOINT: int32 = 164 # String.fromCodePoint(...cps)
HOST_NATIVE_BASE: int32 = 1000

# ====================================================================
# Regex instruction opcodes (backtracking bytecode VM).
# ====================================================================
RI_CHAR:    int32 = 0          # re_x = char byte
RI_ANY:     int32 = 1          # . (any char except newline)
RI_CLASS:   int32 = 2          # re_x = class index
RI_MATCH:   int32 = 3          # accept
RI_JMP:     int32 = 4          # re_x = target pc
RI_SPLIT:   int32 = 5          # try re_x first, then re_y
RI_SAVE:    int32 = 6          # re_x = capture slot; record sp
RI_BOL:     int32 = 7          # ^
RI_EOL:     int32 = 8          # $
RI_WORDB:   int32 = 9          # \b
RI_NWORDB:  int32 = 10         # \B
RI_BACKREF: int32 = 11         # re_x = group index
RI_LAHEAD:  int32 = 12         # lookahead:  re_x = pc after child block, re_y = neg
RI_LADONE:  int32 = 13         # lookahead child terminator (accept the assertion)
RI_LBEHIND: int32 = 14         # lookbehind: re_x = pc after child block, re_y = neg
RI_LBDONE:  int32 = 15         # lookbehind child terminator (accept iff sp == lb_target)

# Regex AST node ops (scratch AST between parse and codegen).
RN_CHAR:   int32 = 0           # rn_a = char
RN_ANY:    int32 = 1
RN_CLASS:  int32 = 2           # rn_a = class index
RN_BOL:    int32 = 3
RN_EOL:    int32 = 4
RN_WORDB:  int32 = 5
RN_NWORDB: int32 = 6
RN_BACKREF: int32 = 7          # rn_a = group index
RN_GROUP:  int32 = 8           # rn_d = child (alt), rn_a = capture index (-1 = non-capturing)
RN_STAR:   int32 = 9           # rn_d = child, rn_b = greedy
RN_PLUS:   int32 = 10          # rn_d = child, rn_b = greedy
RN_QUEST:  int32 = 11          # rn_d = child, rn_b = greedy
RN_REPEAT: int32 = 12          # rn_d = child, rn_b = min, rn_c = max(-1=inf), rn_a = greedy
RN_SEQ:    int32 = 13          # rn_a = head of item list (rn_next chained)
RN_ALT:    int32 = 14          # rn_a = head of branch list (rn_next chained)
RN_LOOK:   int32 = 15          # lookahead:  rn_d = child, rn_a = neg (0 =, 1 !)
RN_LOOKB:  int32 = 16          # lookbehind: rn_d = child, rn_a = neg (0 <=, 1 <!)


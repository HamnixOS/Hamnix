# Promise (Promise/A+ shaped; reactions scheduled as MICROTASKS on the #178
# deferred-callback queue). Per-instance state (which promise a resolver is
# bound to; a combinator's shared cell + element index) is carried on the
# native function OBJECT via obj_p_a/obj_p_b, recovered through native_self.
NAT_PROMISE:          int32 = 90    # the Promise constructor (executor)
NAT_PROMISE_RESOLVE_FN: int32 = 91  # resolve(value) passed to executor/thenable
NAT_PROMISE_REJECT_FN:  int32 = 92  # reject(reason) passed to executor/thenable
NAT_PROMISE_JOB:      int32 = 93    # microtask body: run one settled reaction
NAT_PROMISE_RESOLVE:  int32 = 94    # Promise.resolve(v)
NAT_PROMISE_REJECT:   int32 = 95    # Promise.reject(r)
NAT_PROMISE_ALL:      int32 = 96    # Promise.all([...])
NAT_PROMISE_RACE:     int32 = 97    # Promise.race([...])
NAT_PROMISE_ALLSETTLED: int32 = 98  # Promise.allSettled([...])
NAT_PROMISE_THEN:     int32 = 99    # Promise.prototype.then
NAT_PROMISE_CATCH:    int32 = 100   # Promise.prototype.catch
NAT_PROMISE_FINALLY:  int32 = 101   # Promise.prototype.finally
NAT_COMB_FUL:         int32 = 102   # combinator per-element fulfilled hook
NAT_COMB_REJ:         int32 = 103   # combinator per-element rejected hook
NAT_FINALLY_FUL:      int32 = 104   # finally() fulfilled wrapper (pass value through)
NAT_FINALLY_REJ:      int32 = 105   # finally() rejected wrapper (re-throw reason)
# fetch() + Response. With an embedder-registered TRANSPORT (js_set_fetch_transport
# — the browser's kernel /net http9 client), fetch(url) performs a REAL over-the-
# wire HTTP request; with NO transport (host / dual-target) it resolves from a
# JS-settable FIXTURE table. The engine stays extern-free either way (it only
# calls back into the embedder's transport; it opens no sockets). fetch(url)
# returns a Promise<Response>; the Response body methods each return a Promise
# that settles on the SAME #178 microtask queue, so await/.then compose.
NAT_FETCH:            int32 = 110   # fetch(url[, options]) -> Promise<Response>
NAT_SET_FETCH_FIXTURE: int32 = 111 # __setFetchFixture(url, {status,body,...}) test hook
NAT_RESPONSE_TEXT:    int32 = 112   # Response.prototype.text() -> Promise<string>
NAT_RESPONSE_JSON:    int32 = 113   # Response.prototype.json() -> Promise<parsed>
NAT_RESPONSE_ARRAYBUF: int32 = 114  # Response.prototype.arrayBuffer() -> Promise<array>
NAT_HEADERS_GET:      int32 = 115   # Headers.prototype.get(name) -> string | null
NAT_HEADERS_HAS:      int32 = 116   # Headers.prototype.has(name) -> bool
NAT_HEADERS_ENTRIES:  int32 = 117   # Headers.prototype.entries() -> [[name,value],...]
NAT_STORAGE_GET:      int32 = 120   # Storage.prototype.getItem(key) -> string | null
NAT_STORAGE_SET:      int32 = 121   # Storage.prototype.setItem(key, value)
NAT_STORAGE_REMOVE:   int32 = 122   # Storage.prototype.removeItem(key)
NAT_STORAGE_CLEAR:    int32 = 123   # Storage.prototype.clear()
NAT_STORAGE_KEY:      int32 = 124   # Storage.prototype.key(n) -> string | null
# Map: constructor + prototype methods (ES2015 collections).

TK_PERCENT: int32 = 46
TK_LT:     int32 = 47
TK_GT:     int32 = 48
TK_LE:     int32 = 49
TK_GE:     int32 = 50
TK_EQ:     int32 = 51
TK_NE:     int32 = 52
TK_SEQ:    int32 = 53
TK_SNE:    int32 = 54
TK_ANDAND: int32 = 55
TK_OROR:   int32 = 56
TK_NOT:    int32 = 57
TK_BAND:   int32 = 58
TK_BOR:    int32 = 59
TK_BXOR:   int32 = 60
TK_BNOT:   int32 = 61
TK_SHL:    int32 = 62
TK_SHR:    int32 = 63
TK_USHR:   int32 = 64
TK_INC:    int32 = 65
TK_DEC:    int32 = 66
TK_PLUSEQ: int32 = 67
TK_MINUSEQ: int32 = 68
TK_STAREQ: int32 = 69
TK_SLASHEQ: int32 = 70
TK_PERCENTEQ: int32 = 71
TK_ARROW:  int32 = 72
TK_CLASS:  int32 = 73
TK_EXTENDS: int32 = 74
TK_SUPER:  int32 = 75
TK_TRY:    int32 = 76
TK_CATCH:  int32 = 77
TK_FINALLY: int32 = 78
TK_THROW:  int32 = 79
TK_STATIC: int32 = 80
TK_ELLIPSIS: int32 = 81
TK_REGEX:  int32 = 82          # regex literal; tk_str = source sid, tk_str2 = flags sid
TK_VOID:   int32 = 83          # `void` unary operator
TK_DELETE: int32 = 84          # `delete` unary operator
TK_SWITCH: int32 = 85          # `switch`
TK_CASE:   int32 = 86          # `case`
TK_DEFAULT: int32 = 87         # `default` (switch)
TK_OREQ:   int32 = 88          # |=
TK_ANDEQ:  int32 = 89          # &=
TK_XOREQ:  int32 = 90          # ^=
TK_SHLEQ:  int32 = 91          # <<=
TK_SHREQ:  int32 = 92          # >>=
TK_USHREQ: int32 = 93          # >>>=
TK_QDOT:   int32 = 94          # ?.  optional chaining
TK_QQ:     int32 = 95          # ??  nullish coalescing
TK_QQEQ:   int32 = 96          # ??= nullish assignment
TK_OROREQ: int32 = 97          # ||= logical-or assignment
TK_ANDANDEQ: int32 = 98        # &&= logical-and assignment
TK_STARSTAR: int32 = 99        # **  exponentiation
TK_STARSTAREQ: int32 = 100     # **= exponentiation assignment
# Template-literal tokens. Each carries tk_str = COOKED chunk sid and
# tk_str2 = RAW chunk sid (verbatim source, for String.raw / tag.raw).
TK_TMPL_FULL: int32 = 101      # `no substitutions`  -> whole template, one chunk
TK_TMPL_HEAD: int32 = 102      # `head${            -> chunk before the 1st subst
TK_TMPL_MID:  int32 = 103      # }mid${             -> chunk between substitutions
TK_TMPL_TAIL: int32 = 104      # }tail`             -> chunk after the last subst
TK_PRIVATE:   int32 = 105      # #name  -> class private identifier (tk_str = "#name")
TK_BIGINT:    int32 = 106      # 123n  -> BigInt literal (tk_str = source digits sid, sans the `n`)

# ====================================================================
# AST node kinds.
# ====================================================================
ND_NUM:    int32 = 0
ND_STR:    int32 = 1
ND_TRUE:   int32 = 2
ND_FALSE:  int32 = 3
ND_NULL:   int32 = 4
ND_UNDEF:  int32 = 5
ND_IDENT:  int32 = 6
ND_THIS:   int32 = 7
ND_ARRAY:  int32 = 8
ND_OBJECT: int32 = 9
ND_PROP:   int32 = 10
ND_FUNC:   int32 = 11
ND_CALL:   int32 = 12
ND_NEW:    int32 = 13
ND_MEMBER: int32 = 14
ND_INDEX:  int32 = 15
ND_ASSIGN: int32 = 16
ND_BINOP:  int32 = 17
ND_LOGICAL: int32 = 18
ND_UNARY:  int32 = 19
ND_UPDATE: int32 = 20
ND_TERNARY: int32 = 21
ND_VAR:    int32 = 22
ND_DECLTOR: int32 = 23
ND_EXPRSTMT: int32 = 24
ND_BLOCK:  int32 = 25
ND_IF:     int32 = 26
ND_WHILE:  int32 = 27
ND_DOWHILE: int32 = 28
ND_FOR:    int32 = 29
ND_FORIN:  int32 = 30
ND_RETURN: int32 = 31
ND_BREAK:  int32 = 32
ND_CONTINUE: int32 = 33
ND_FUNCDECL: int32 = 34
ND_EMPTY:  int32 = 35
ND_PARAM:  int32 = 36
ND_ARROW:  int32 = 37
ND_TRY:    int32 = 38
ND_THROW:  int32 = 39
ND_CLASS:  int32 = 40
ND_METHOD: int32 = 41
ND_SUPER:  int32 = 42
ND_SPREAD: int32 = 43
ND_CLASSDECL: int32 = 44
ND_ARRPAT: int32 = 45          # array destructuring pattern
ND_OBJPAT: int32 = 46          # object destructuring pattern
ND_PATELEM: int32 = 47         # one element of a pattern (n_str=name, n_a=default, n_b=nested pattern)
ND_REGEX:  int32 = 48          # regex literal (n_str = source sid, n_a = flags sid)
ND_AWAIT:  int32 = 49          # `await expr` (n_a = operand); valid inside async fns
ND_LABELED: int32 = 50         # `label: stmt` (n_str = label sid, n_a = body)
ND_SWITCH: int32 = 51          # `switch(disc){cases}` (n_a = disc, n_b = first ND_CASE)
ND_CASE:   int32 = 52          # one case (n_a = test expr or -1 for default, n_b = first stmt, n_next = next case)
ND_OPTCHAIN: int32 = 53        # optional-chain boundary wrapper (n_a = inner chain expr)
ND_FOROF:  int32 = 54          # `for(x of iter) body` (n_a = target decl/expr, n_b = iterable, n_c = body, n_op = is_decl)
ND_TMPL:   int32 = 55          # template literal / tagged template. n_a = parts chain (ND_TMPLPART), n_b = tag expr or -1, n_c = substitution count
ND_TMPLPART: int32 = 56        # one template part. n_op=0 quasi (n_str=cooked sid, n_d=raw sid); n_op=1 subst (n_a=expr); n_next=next part
ND_YIELD:  int32 = 57          # `yield expr` / `yield* expr` (n_a = operand or -1, n_op = 1 => delegate yield*)
# ---- ES modules (import / export) ----
ND_IMPORT: int32 = 58          # `import ... from "spec"` (n_str = specifier sid, n_a = ND_IMPSPEC chain or -1 for side-effect import)
ND_IMPSPEC: int32 = 59         # one imported binding. n_op: 0=named, 1=default, 2=namespace. n_str = imported name sid (named); n_d = local name sid; n_next = next.
ND_EXPORT: int32 = 60          # `export ...`. n_op: 0=decl (n_a=inner decl stmt); 1=named list (n_a=ND_EXPSPEC chain); 2=default (n_a=expr-or-decl); 3=re-export from (n_str=specifier, n_a=ND_EXPSPEC chain or -1 for `export *`).
ND_EXPSPEC: int32 = 61         # one exported binding. n_str = local name sid; n_d = exported name sid; n_next = next.
ND_PRIVNAME: int32 = 62        # bare class private name `#x` (only valid as LHS of `in`; n_str = "#x")
ND_BIGINT: int32 = 63          # BigInt literal `123n` (n_str = source digits sid, sans the `n`)
ND_HOLE:   int32 = 64          # array-literal elision (a `,,` hole); reads as undefined, skipped as an assignment target
ND_SEQ:    int32 = 65          # comma sequence expression `a, b, c`: eval n_a (for side effects), then n_b; value is n_b. Left-associative.


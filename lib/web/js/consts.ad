NAT_URLSP_SET:         int32 = 227   # set(name, value)
NAT_URLSP_APPEND:      int32 = 228   # append(name, value)
NAT_URLSP_DELETE:      int32 = 229   # delete(name)
NAT_URLSP_TOSTRING:    int32 = 230   # toString() -> form-urlencoded serialization
NAT_URLSP_FOREACH:     int32 = 231   # forEach(cb[, thisArg])
NAT_URLSP_ENTRIES:     int32 = 232   # entries() -> array of [k,v]
NAT_URLSP_KEYS:        int32 = 233   # keys() -> array of names
NAT_URLSP_VALUES:      int32 = 234   # values() -> array of values
NAT_URLSP_SORT:        int32 = 235   # sort() — stable sort by name
NAT_BTOA:              int32 = 236   # btoa(str) -> base64 (RFC 4648)
NAT_ATOB:              int32 = 237   # atob(b64) -> binary string
NAT_URLSP_ITER:        int32 = 238   # [Symbol.iterator]() -> entries iterator
NAT_URLSP_ITNEXT:      int32 = 239   # the iterator's next() -> {value,done}
# ---- Intl (formatting/i18n) + Date-locale/parse/UTC extensions (round 9) -----
# Minimal, en-US-oriented Intl. Locale is accepted but only en-US grouping/
# separators / month+weekday names are implemented (documented simplification).
NAT_INTL_NUMBERFORMAT:  int32 = 240   # new Intl.NumberFormat(locales, options)
NAT_INTL_NF_FORMAT:     int32 = 241   # NumberFormat.prototype.format(n)
NAT_INTL_DATETIMEFORMAT: int32 = 242  # new Intl.DateTimeFormat(locales, options)
NAT_INTL_DTF_FORMAT:    int32 = 243   # DateTimeFormat.prototype.format(date)
NAT_DATE_PARSE:         int32 = 244   # Date.parse(isoString) -> epoch-ms | NaN
NAT_DATE_UTC:           int32 = 245   # Date.UTC(y, mo, d, h, mi, s, ms) -> epoch-ms
NAT_DATE_TZOFFSET:      int32 = 246   # getTimezoneOffset() -> 0 (engine is UTC)
NAT_DATE_SETTIME:       int32 = 247   # setTime(ms)
NAT_DATE_SETFULLYEAR:   int32 = 248   # setUTCFullYear/setFullYear(y)
NAT_DATE_SETMONTH:      int32 = 249   # setUTCMonth/setMonth(m0)
NAT_DATE_SETDATE:       int32 = 250   # setUTCDate/setDate(d)
NAT_DATE_SETHOURS:      int32 = 251   # setUTCHours/setHours(h)
NAT_DATE_SETMINUTES:    int32 = 252   # setUTCMinutes/setMinutes(mi)
NAT_DATE_SETSECONDS:    int32 = 253   # setUTCSeconds/setSeconds(s)
NAT_DATE_SETMS:         int32 = 254   # setUTCMilliseconds/setMilliseconds(ms)
NAT_DATE_TOLOCALEDATESTRING: int32 = 255  # toLocaleDateString([locale[, opts]])
NAT_DATE_TOLOCALETIMESTRING: int32 = 256  # toLocaleTimeString([locale[, opts]])
NAT_DATE_TOLOCALESTRING: int32 = 257  # toLocaleString([locale[, opts]])
# ---- FormData (multipart/urlencoded form multimap) ---------------------------
# Storage + methods are shared with URLSearchParams (parallel @@k/@@v arrays),
# so only the constructor needs its own id; the prototype binds the NAT_URLSP_*
# method ids, which operate on the same @@k/@@v layout.
NAT_FORMDATA:          int32 = 258   # new FormData([obj]) — empty | object init
NAT_FUNCTION_CTOR:     int32 = 259   # the Function global (identity for `instanceof Function`)
# ---- Real builtin-prototype method VALUES (round 10) --------------------------
# One dispatch id per prototype; the specific method NAME is carried on the
# native function OBJECT via obj_p_a (recovered through native_self), so a single
# id backs every method of that prototype. `this` is the receiver passed by
# normal dispatch or by .call/.apply/.bind. These make `X.prototype.m` a real
# callable value (the dominant transpiled/minified idiom).
NAT_OP_METHOD:         int32 = 300   # Object.prototype.*   (toString/hasOwnProperty/...)
NAT_FP_METHOD:         int32 = 301   # Function.prototype.* (call/apply/bind/toString)
NAT_AP_METHOD:         int32 = 302   # Array.prototype.*    (slice/push/map/forEach/...)
NAT_SP_METHOD:         int32 = 303   # String.prototype.*   (delegates to string_method)
NAT_NP_METHOD:         int32 = 304   # Number.prototype.*   (toString/toFixed/valueOf)
NAT_BP_METHOD:         int32 = 305   # Boolean.prototype.*  (toString/valueOf)
HOST_NATIVE_BASE: int32 = 1000

# ====================================================================
# Regex instruction opcodes (backtracking bytecode VM).
# ====================================================================
RI_CHAR:    int32 = 0          # re_x = char byte
RI_ANY:     int32 = 1          # . (any char except newline)
RI_CLASS:   int32 = 2          # re_x = class index
RI_MATCH:   int32 = 3          # accept
RI_JMP:     int32 = 4          # re_x = target pc
RI_SPLIT:   int32 = 5          # try re_x first, then re_y
RI_SAVE:    int32 = 6          # re_x = capture slot; record sp
RI_BOL:     int32 = 7          # ^
RI_EOL:     int32 = 8          # $
RI_WORDB:   int32 = 9          # \b
RI_NWORDB:  int32 = 10         # \B
RI_BACKREF: int32 = 11         # re_x = group index
RI_LAHEAD:  int32 = 12         # lookahead:  re_x = pc after child block, re_y = neg
RI_LADONE:  int32 = 13         # lookahead child terminator (accept the assertion)
RI_LBEHIND: int32 = 14         # lookbehind: re_x = pc after child block, re_y = neg
RI_LBDONE:  int32 = 15         # lookbehind child terminator (accept iff sp == lb_target)

# Regex AST node ops (scratch AST between parse and codegen).
RN_CHAR:   int32 = 0           # rn_a = char
RN_ANY:    int32 = 1
RN_CLASS:  int32 = 2           # rn_a = class index
RN_BOL:    int32 = 3
RN_EOL:    int32 = 4
RN_WORDB:  int32 = 5
RN_NWORDB: int32 = 6
RN_BACKREF: int32 = 7          # rn_a = group index
RN_GROUP:  int32 = 8           # rn_d = child (alt), rn_a = capture index (-1 = non-capturing)
RN_STAR:   int32 = 9           # rn_d = child, rn_b = greedy
RN_PLUS:   int32 = 10          # rn_d = child, rn_b = greedy
RN_QUEST:  int32 = 11          # rn_d = child, rn_b = greedy
RN_REPEAT: int32 = 12          # rn_d = child, rn_b = min, rn_c = max(-1=inf), rn_a = greedy
RN_SEQ:    int32 = 13          # rn_a = head of item list (rn_next chained)
RN_ALT:    int32 = 14          # rn_a = head of branch list (rn_next chained)
RN_LOOK:   int32 = 15          # lookahead:  rn_d = child, rn_a = neg (0 =, 1 !)
RN_LOOKB:  int32 = 16          # lookbehind: rn_d = child, rn_a = neg (0 <=, 1 <!)


NAT_MAP_GET:      int32 = 131
NAT_MAP_SET:      int32 = 132
NAT_MAP_HAS:      int32 = 133
NAT_MAP_DELETE:   int32 = 134
NAT_MAP_CLEAR:    int32 = 135
NAT_MAP_FOREACH:  int32 = 136
NAT_MAP_KEYS:     int32 = 137
NAT_MAP_VALUES:   int32 = 138
NAT_MAP_ENTRIES:  int32 = 139
# Set: constructor + prototype methods.
NAT_SET:          int32 = 140   # Set constructor (optional iterable of values)
NAT_SET_ADD:      int32 = 141
NAT_SET_HAS:      int32 = 142
NAT_SET_DELETE:   int32 = 143
NAT_SET_CLEAR:    int32 = 144
NAT_SET_FOREACH:  int32 = 145
NAT_SET_VALUES:   int32 = 146
# Object statics (ES5/ES2015/ES2017).
NAT_OBJECT_CREATE:      int32 = 150
NAT_OBJECT_GETPROTO:    int32 = 151
NAT_OBJECT_SETPROTO:    int32 = 152
NAT_OBJECT_GETOWNNAMES: int32 = 153
NAT_OBJECT_DEFINEPROP:  int32 = 154
NAT_OBJECT_ISFROZEN:    int32 = 155
NAT_OBJECT_GETOWNDESC:  int32 = 156
NAT_OBJECT_GETOWNDESCS: int32 = 157
NAT_OBJECT_DEFINEPROPS: int32 = 158
NAT_OBJECT_HASOWN:      int32 = 216   # Object.hasOwn(obj, key) — ES2022
NAT_OBJECT_IS:          int32 = 217   # Object.is(a, b) — SameValue (NaN eq, +0/-0 distinct)
# Number static + Array.from.
NAT_NUMBER_ISSAFEINT: int32 = 160
NAT_ARRAY_FROM:       int32 = 161
# Round-2 conformance batch: String static helpers.
NAT_STRING_RAW:         int32 = 162   # String.raw(strings, ...subs) — cooked-template raw assembly
NAT_STRING_FROMCHARCODE: int32 = 163  # String.fromCharCode(...codes)
NAT_STRING_FROMCODEPOINT: int32 = 164 # String.fromCodePoint(...cps)
NAT_SYMBOL:             int32 = 168   # Symbol([description]) — unique primitive
# Generator object prototype methods (bounded/eager generator model — see interp.ad).
NAT_GEN_NEXT:           int32 = 169   # gen.next([v]) -> {value, done}
NAT_GEN_RETURN:         int32 = 170   # gen.return([v]) -> {value:v, done:true}
NAT_GEN_THROW:          int32 = 171   # gen.throw(e) -> mark done, throw e
NAT_GEN_ITER:           int32 = 172   # gen[Symbol.iterator]() -> the generator itself
# Reflect — thin wrappers over the engine's existing object operations (round 7).
NAT_REFLECT_GET:        int32 = 180   # Reflect.get(target, key[, receiver])
NAT_REFLECT_SET:        int32 = 181   # Reflect.set(target, key, value[, receiver]) -> bool
NAT_REFLECT_HAS:        int32 = 182   # Reflect.has(target, key) -> bool  (the `in` op)
NAT_REFLECT_OWNKEYS:    int32 = 183   # Reflect.ownKeys(target) -> array of own keys
NAT_REFLECT_GETPROTO:   int32 = 184   # Reflect.getPrototypeOf(target)
NAT_REFLECT_SETPROTO:   int32 = 185   # Reflect.setPrototypeOf(target, proto) -> bool
NAT_REFLECT_DEFINEPROP: int32 = 186   # Reflect.defineProperty(target, key, desc) -> bool
NAT_REFLECT_DELETEPROP: int32 = 187   # Reflect.deleteProperty(target, key) -> bool
NAT_REFLECT_APPLY:      int32 = 188   # Reflect.apply(target, thisArg, argsList)
NAT_REFLECT_CONSTRUCT:  int32 = 189   # Reflect.construct(target, argsList[, newTarget])
# Proxy — new Proxy(target, handler) with common traps (round 7).
NAT_PROXY:              int32 = 190   # the Proxy constructor
# Typed arrays + ArrayBuffer (byte-backed; little-endian; round 7).
NAT_ARRAYBUFFER:        int32 = 200   # new ArrayBuffer(byteLength)
NAT_TYPEDARRAY:         int32 = 201   # every TypedArray ctor (elem type via obj_p_a on the ctor fn)
NAT_TA_SET:             int32 = 202   # TypedArray.prototype.set(src[, offset])
NAT_TA_SUBARRAY:        int32 = 203   # TypedArray.prototype.subarray([begin[, end]])
NAT_TA_SLICE:           int32 = 204   # TypedArray.prototype.slice([begin[, end]])
NAT_TA_FILL:            int32 = 205   # TypedArray.prototype.fill(value[, start[, end]])
NAT_TA_ITER:            int32 = 206   # TypedArray.prototype[Symbol.iterator] / values
NAT_TA_OF:              int32 = 207   # TypedArray.of(...items)
NAT_TA_FROM:            int32 = 208   # TypedArray.from(arrayLike[, mapFn])
NAT_STRUCTURED_CLONE:   int32 = 210   # structuredClone(value) — deep clone (round 7)
NAT_SYMBOL_FOR:         int32 = 211   # Symbol.for(key) — global symbol registry
NAT_SYMBOL_KEYFOR:      int32 = 212   # Symbol.keyFor(sym) — reverse registry lookup
# BigInt (arbitrary precision) — round 8.
NAT_BIGINT:            int32 = 213    # the BigInt(value) conversion function
NAT_BIGINT_ASINTN:     int32 = 214   # BigInt.asIntN(bits, x)  — sign-extend into [-2^(n-1), 2^(n-1))
NAT_BIGINT_ASUINTN:    int32 = 215   # BigInt.asUintN(bits, x) — wrap into [0, 2^n)
# ---- URL / URLSearchParams / base64 (self-contained Web-platform APIs) -------
NAT_URL:               int32 = 220   # new URL(url[, base]) — WHATWG URL parser

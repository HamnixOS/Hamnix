ND_CALL:   int32 = 12
ND_NEW:    int32 = 13
ND_MEMBER: int32 = 14
ND_INDEX:  int32 = 15
ND_ASSIGN: int32 = 16
ND_BINOP:  int32 = 17
ND_LOGICAL: int32 = 18
ND_UNARY:  int32 = 19
ND_UPDATE: int32 = 20
ND_TERNARY: int32 = 21

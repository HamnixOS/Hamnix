# lib/web/js/value.ad — part of the modular web engine (extracted from jsengine.ad).
# string pool, JS value constructors/accessors, objects (props/array), environments (scope chain), and the catchable runtime-exception mechanism.
#
# Behavior-preserving split: Adder is a single-compilation-unit language
# (merge_programs merges all imported files into one Program), so every
# public top-level name here resolves globally across the merged engine.

# ====================================================================
# STRING pool.
# ====================================================================
def str_new(p: Ptr[uint8], n: int32) -> int32:
    # Guard the string pool + id table: an unchecked overflow wrote past sp_buf /
    # st_off / st_len into adjacent BSS. Fail cleanly (empty string id) instead.
    if sp_top + n >= SP_CAP or n_strs >= MAX_STR:
        set_error(cast[Ptr[uint8]]("string pool exhausted"))
        if n_strs < MAX_STR:
            st_off[n_strs] = sp_top
            st_len[n_strs] = 0
            n_strs = n_strs + 1
            return n_strs - 1
        return MAX_STR - 1
    off: int32 = sp_top
    i: int32 = 0
    while i < n:
        sp_buf[sp_top] = p[i]
        sp_top = sp_top + 1
        i = i + 1
    id: int32 = n_strs
    st_off[id] = off
    st_len[id] = n
    n_strs = n_strs + 1
    return id


def str_len(id: int32) -> int32:
    return st_len[id]


def str_ptr(id: int32) -> Ptr[uint8]:
    return &sp_buf[st_off[id]]


def str_char(id: int32, i: int32) -> uint8:
    return sp_buf[st_off[id] + i]


def str_eq(a: int32, b: int32) -> int32:
    if st_len[a] != st_len[b]:
        return 0
    n: int32 = st_len[a]
    i: int32 = 0
    oa: int32 = st_off[a]
    ob: int32 = st_off[b]
    while i < n:
        if sp_buf[oa + i] != sp_buf[ob + i]:
            return 0
        i = i + 1
    return 1


def str_eq_cstr(a: int32, s: Ptr[uint8]) -> int32:
    n: int32 = st_len[a]
    oa: int32 = st_off[a]
    i: int32 = 0
    while i < n:
        if s[i] == 0:
            return 0
        if sp_buf[oa + i] != s[i]:
            return 0
        i = i + 1
    if s[i] != 0:
        return 0
    return 1


def cstr_len(s: Ptr[uint8]) -> int32:
    n: int32 = 0
    while s[n] != 0:
        n = n + 1
    return n


def str_from_cstr(s: Ptr[uint8]) -> int32:
    return str_new(s, cstr_len(s))


# ---- build a string / write output through emit_c ----
_bld_start: int32 = 0

def bld_begin():
    _bld_start = sp_top


def bld_end() -> int32:
    id: int32 = n_strs
    st_off[id] = _bld_start
    st_len[id] = sp_top - _bld_start
    n_strs = n_strs + 1
    return id


def emit_c(c: uint8):
    if emit_tgt == 1:
        if out_top < OUT_CAP - 1:
            out_buf[out_top] = c
            out_top = out_top + 1
    else:
        if sp_top < SP_CAP - 1:
            sp_buf[sp_top] = c
            sp_top = sp_top + 1


def emit_cstr(s: Ptr[uint8]):
    i: int32 = 0
    while s[i] != 0:
        emit_c(s[i])
        i = i + 1


def emit_strid(id: int32):
    n: int32 = st_len[id]
    off: int32 = st_off[id]
    i: int32 = 0
    while i < n:
        emit_c(sp_buf[off + i])
        i = i + 1


def emit_u64(v: uint64):
    if v == 0:
        emit_c(48)
        return
    digs: Array[24, uint8]
    n: int32 = 0
    while v > 0:
        digs[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    while n > 0:
        n = n - 1
        emit_c(digs[n])


def emit_i64(v: int64):
    if v < 0:
        emit_c(45)
        emit_u64(cast[uint64](0 - v))
    else:
        emit_u64(cast[uint64](v))


def emit_num(x: float64):
    if is_nan(x) != 0:
        emit_cstr(cast[Ptr[uint8]]("NaN"))
        return
    if is_inf(x) != 0:
        if x < 0.0:
            emit_c(45)
        emit_cstr(cast[Ptr[uint8]]("Infinity"))
        return
    if x == 0.0:
        emit_c(48)
        return
    neg: int32 = 0
    if x < 0.0:
        neg = 1
        x = 0.0 - x
    ip: float64 = f_floor(x)
    frac: float64 = x - ip
    if neg != 0:
        emit_c(45)
    # integer part
    if ip < 9.0e18:
        emit_u64(cast[uint64](ip))
    else:
        emit_cstr(cast[Ptr[uint8]]("1e19"))     # absurdly large; rare
    if frac > 0.0:
        emit_c(46)                               # '.'
        # up to 12 significant fractional digits, trailing zeros trimmed
        fbuf: Array[16, uint8]
        fn: int32 = 0
        k: int32 = 0
        while k < 12:
            frac = frac * 10.0
            d: int32 = cast[int32](f_floor(frac))
            if d > 9:
                d = 9
            fbuf[fn] = cast[uint8](d) + 48
            fn = fn + 1
            frac = frac - cast[float64](d)
            k = k + 1
            if frac <= 0.0:
                break
        # trim trailing zeros
        while fn > 1 and fbuf[fn - 1] == 48:
            fn = fn - 1
        j: int32 = 0
        while j < fn:
            emit_c(fbuf[j])
            j = j + 1


# ---- number-string helper making a fresh string value ----
def num_to_strid(x: float64) -> int32:
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    emit_num(x)
    id: int32 = bld_end()
    emit_tgt = save
    return id


# parse a JS numeric literal / string to float64
def parse_num_bytes(p: Ptr[uint8], n: int32) -> float64:
    i: int32 = 0
    while i < n and is_ws(p[i]) != 0:
        i = i + 1
    sign: float64 = 1.0
    if i < n and p[i] == 43:
        i = i + 1
    elif i < n and p[i] == 45:
        sign = -1.0
        i = i + 1
    # hex
    if i + 1 < n and p[i] == 48 and (p[i + 1] == 120 or p[i + 1] == 88):
        i = i + 2
        hv: float64 = 0.0
        any: int32 = 0
        while i < n and is_hexdig(p[i]) != 0:
            c: uint8 = p[i]
            d: int32 = 0
            if c >= 48 and c <= 57:
                d = cast[int32](c) - 48
            elif c >= 97 and c <= 102:
                d = cast[int32](c) - 87
            else:
                d = cast[int32](c) - 55
            hv = hv * 16.0 + cast[float64](d)
            any = 1
            i = i + 1
        if any == 0:
            return 0.0 / 0.0
        return sign * hv
    val: float64 = 0.0
    any2: int32 = 0
    while i < n and is_digit(p[i]) != 0:
        val = val * 10.0 + cast[float64](cast[int32](p[i]) - 48)
        any2 = 1
        i = i + 1
    if i < n and p[i] == 46:
        i = i + 1
        scale: float64 = 0.1
        while i < n and is_digit(p[i]) != 0:
            val = val + cast[float64](cast[int32](p[i]) - 48) * scale
            scale = scale * 0.1
            any2 = 1
            i = i + 1
    if any2 == 0:
        return 0.0 / 0.0
    if i < n and (p[i] == 101 or p[i] == 69):    # e / E
        i = i + 1
        esign: int32 = 1
        if i < n and p[i] == 43:
            i = i + 1
        elif i < n and p[i] == 45:
            esign = -1
            i = i + 1
        ev: int32 = 0
        while i < n and is_digit(p[i]) != 0:
            ev = ev * 10 + (cast[int32](p[i]) - 48)
            i = i + 1
        k: int32 = 0
        while k < ev:
            if esign > 0:
                val = val * 10.0
            else:
                val = val * 0.1
            k = k + 1
    return sign * val


# ====================================================================
# VALUE constructors / accessors.
# ====================================================================
def mk_val(tag: int32) -> int32:
    # Guard the value pool: overflowing n_vals used to write past v_tag/v_num/
    # v_ref into adjacent BSS, silently corrupting globals/env (spurious
    # "x is not defined") or crashing. Fail cleanly instead, reusing the last
    # slot so callers get a valid (if meaningless) handle rather than an OOB one.
    if n_vals >= MAX_VAL:
        set_error(cast[Ptr[uint8]]("value pool exhausted"))
        return MAX_VAL - 1
    h: int32 = n_vals
    v_tag[h] = cast[uint8](tag)
    v_ref[h] = 0
    v_num[h] = 0.0
    n_vals = n_vals + 1
    return h


def v_undef() -> int32:
    return 0


def v_null() -> int32:
    return 1


def v_true() -> int32:
    return 2


def v_false() -> int32:
    return 3


def v_boolv(b: int32) -> int32:
    if b != 0:
        return 2
    return 3


def v_number(x: float64) -> int32:
    h: int32 = mk_val(TAG_NUM)
    v_num[h] = x
    return h


def v_string_id(sid: int32) -> int32:
    h: int32 = mk_val(TAG_STR)
    v_ref[h] = sid
    return h


def v_string_bytes(p: Ptr[uint8], n: int32) -> int32:
    return v_string_id(str_new(p, n))


def v_string_cstr(s: Ptr[uint8]) -> int32:
    return v_string_id(str_from_cstr(s))


def tag_of(h: int32) -> int32:
    return cast[int32](v_tag[h])


def num_of(h: int32) -> float64:
    return v_num[h]


def strid_of(h: int32) -> int32:
    return v_ref[h]


def objid_of(h: int32) -> int32:
    return v_ref[h]


# ====================================================================
# OBJECTS.
# ====================================================================
def obj_new(kind: int32) -> int32:
    o: int32 = n_objs
    obj_kind[o] = cast[uint8](kind)
    obj_head[o] = -1
    obj_fn_node[o] = -1
    obj_fn_env[o] = -1
    obj_fn_native[o] = -1
    arr_len[o] = 0
    arr_cap[o] = 0
    arr_base[o] = -1
    obj_proto[o] = -1
    obj_fn_this[o] = -2
    obj_fn_home[o] = -1
    obj_fn_super[o] = -1
    obj_fn_btarget[o] = -1
    obj_fn_bthis[o] = 0
    obj_fn_bargs[o] = -1
    obj_class[o] = 0
    obj_class_node[o] = -1
    obj_re_prog[o] = -1
    obj_re_ncap[o] = 0
    obj_re_flags[o] = 0
    obj_is_date[o] = cast[uint8](0)
    obj_date_ms[o] = 0.0
    obj_is_prom[o] = cast[uint8](0)
    prom_alreadyres[o] = cast[uint8](0)
    obj_frozen[o] = cast[uint8](0)
    obj_map_kind[o] = cast[uint8](MAP_KIND_NONE)
    obj_ms_head[o] = -1
    obj_ms_tail[o] = -1
    obj_ms_size[o] = 0
    n_objs = n_objs + 1
    return o


def v_new_object() -> int32:
    h: int32 = mk_val(TAG_OBJ)
    v_ref[h] = obj_new(OK_PLAIN)
    return h


def v_new_array() -> int32:
    h: int32 = mk_val(TAG_OBJ)
    v_ref[h] = obj_new(OK_ARRAY)
    return h


def v_new_native(native_id: int32) -> int32:
    h: int32 = mk_val(TAG_OBJ)
    o: int32 = obj_new(OK_FUNC)
    obj_fn_native[o] = native_id
    v_ref[h] = o
    return h


def v_new_closure(node: int32, env: int32) -> int32:
    h: int32 = mk_val(TAG_OBJ)
    o: int32 = obj_new(OK_FUNC)
    obj_fn_node[o] = node
    obj_fn_env[o] = env
    v_ref[h] = o
    return h


# A break/continue's target label (a string id) matches a loop/label's own
# label. Label ids are compared by TEXT (str_eq), not by ==: the same source
# identifier can carry different string ids at its definition and use sites.
def label_eq(target: int32, own: int32) -> int32:
    if target < 0 or own < 0:
        return 0
    return str_eq(target, own)


def is_callable(h: int32) -> int32:
    if tag_of(h) != TAG_OBJ:
        return 0
    if cast[int32](obj_kind[objid_of(h)]) == OK_FUNC:
        return 1
    return 0


def is_array(h: int32) -> int32:
    if tag_of(h) != TAG_OBJ:
        return 0
    if cast[int32](obj_kind[objid_of(h)]) == OK_ARRAY:
        return 1
    return 0


def is_symbol(h: int32) -> int32:
    if tag_of(h) != TAG_OBJ:
        return 0
    if cast[int32](obj_kind[objid_of(h)]) == OK_SYMBOL:
        return 1
    return 0


# A Symbol primitive: unique identity (a distinct object) with an optional
# `description` own property. typeof -> "symbol". Used as an object property key
# via symbol_key() which derives a stable, collision-free string from its id.
def v_new_symbol(desc: int32) -> int32:
    h: int32 = mk_val(TAG_OBJ)
    o: int32 = obj_new(OK_SYMBOL)
    v_ref[h] = o
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("description")), desc)
    return h


# Stable private property-key string for a symbol used as a computed key:
# "@@sym:<objid>" — unique per symbol, never collides with a normal string key
# that a script would write (those don't start with @@sym:).
def symbol_key(h: int32) -> int32:
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    emit_cstr(cast[Ptr[uint8]]("@@sym:"))
    emit_u64(cast[uint64](objid_of(h)))
    id: int32 = bld_end()
    emit_tgt = save
    return id


# ---- named property get/set (string-keyed) on an object id ----
def obj_find_prop(o: int32, key: int32) -> int32:
    p: int32 = obj_head[o]
    while p >= 0:
        if str_eq(p_key[p], key) != 0:
            return p
        p = p_next[p]
    return -1


# allocation-free lookup by C-string key (safe to call mid string-build)
def obj_find_prop_cstr(o: int32, s: Ptr[uint8]) -> int32:
    p: int32 = obj_head[o]
    while p >= 0:
        if str_eq_cstr(p_key[p], s) != 0:
            return p
        p = p_next[p]
    return -1


def obj_get_cstr(o: int32, s: Ptr[uint8]) -> int32:
    p: int32 = obj_find_prop_cstr(o, s)
    if p >= 0:
        return p_val[p]
    return v_undef()


def obj_set(o: int32, key: int32, val: int32):
    if obj_frozen[o] != 0:             # Object.freeze: writes and additions are no-ops
        return
    p: int32 = obj_find_prop(o, key)
    if p >= 0:
        p_acc[p] = cast[uint8](0)      # a plain data write demotes any accessor
        p_get[p] = -1
        p_set[p] = -1
        p_val[p] = val
        return
    np: int32 = n_props
    p_key[np] = key
    p_val[np] = val
    p_acc[np] = cast[uint8](0)
    p_get[np] = -1
    p_set[np] = -1
    p_next[np] = obj_head[o]
    obj_head[o] = np
    n_props = n_props + 1


# Define an accessor property (getter/setter) on object `o`. A -1 fn leaves that
# half unchanged if the property already exists as an accessor (so `get x`/`set x`
# for the same key compose); otherwise it installs a fresh accessor slot.
def obj_define_accessor(o: int32, key: int32, getter: int32, setter: int32):
    if obj_frozen[o] != 0:
        return
    p: int32 = obj_find_prop(o, key)
    if p < 0:
        p = n_props
        p_key[p] = key
        p_val[p] = v_undef()
        p_get[p] = -1
        p_set[p] = -1
        p_next[p] = obj_head[o]
        obj_head[o] = p
        n_props = n_props + 1
    elif p_acc[p] == 0:                 # was a data property: convert
        p_get[p] = -1
        p_set[p] = -1
    p_acc[p] = cast[uint8](1)
    if getter >= 0:
        p_get[p] = getter
    if setter >= 0:
        p_set[p] = setter


def obj_del_prop(o: int32, key: int32) -> int32:
    # Unlink the own property `key` from o's chain. Returns 1 if removed.
    prev: int32 = -1
    p: int32 = obj_head[o]
    while p >= 0:
        if str_eq(p_key[p], key) != 0:
            if prev < 0:
                obj_head[o] = p_next[p]
            else:
                p_next[prev] = p_next[p]
            return 1
        prev = p
        p = p_next[p]
    return 0


def obj_get(o: int32, key: int32) -> int32:
    p: int32 = obj_find_prop(o, key)
    if p >= 0:
        return p_val[p]
    return v_undef()


# copy own (enumerable) props of src into dst, preserving insertion order
def copy_own_props(src: int32, dst: int32):
    copy_own_props_rec(obj_head[src], dst)


def copy_own_props_rec(p: int32, dst: int32):
    if p < 0:
        return
    copy_own_props_rec(p_next[p], dst)
    obj_set(dst, p_key[p], p_val[p])


# ---- array element storage ----
def arr_grow(o: int32, need: int32):
    if need <= arr_cap[o]:
        return
    ncap: int32 = arr_cap[o] * 2
    if ncap < 4:
        ncap = 4
    while ncap < need:
        ncap = ncap * 2
    ob: int32 = arr_base[o]
    # Fast path: this array's backing chunk is the MOST-RECENT bump allocation
    # (its end coincides with ax_top), so grow it IN PLACE — just extend the
    # bump cursor. No copy, and crucially NO abandoned old chunk. The old code
    # allocated a fresh chunk on every doubling and leaked the previous one
    # (~2x waste, never reclaimed until js_init); building one array in a loop —
    # or the many small arrays a DOM build / re-entrant callback churns — then
    # overran ax_val and silently corrupted or dropped a later array's elements.
    if ob >= 0 and ob + arr_cap[o] == ax_top:
        add: int32 = ncap - arr_cap[o]
        if ax_top + add > MAX_AX:
            set_error(cast[Ptr[uint8]]("array storage exhausted"))
            return
        j: int32 = arr_cap[o]
        while j < ncap:
            ax_val[ob + j] = v_undef()
            j = j + 1
        ax_top = ax_top + add
        arr_cap[o] = ncap
        return
    # Slow path: the array is not on top of the bump (something was allocated
    # after it), so it must move — allocate a fresh chunk and copy.
    if ax_top + ncap > MAX_AX:
        set_error(cast[Ptr[uint8]]("array storage exhausted"))
        return
    nbase: int32 = ax_top
    ax_top = ax_top + ncap
    # copy old elements
    i: int32 = 0
    while i < arr_len[o]:
        ax_val[nbase + i] = ax_val[ob + i]
        i = i + 1
    # fill remainder with undefined
    while i < ncap:
        ax_val[nbase + i] = v_undef()
        i = i + 1
    arr_base[o] = nbase
    arr_cap[o] = ncap


def arr_set(o: int32, idx: int32, val: int32):
    if idx < 0:
        return
    if idx >= arr_cap[o]:
        arr_grow(o, idx + 1)
    if idx >= arr_len[o]:
        # fill holes with undefined
        i: int32 = arr_len[o]
        while i < idx:
            ax_val[arr_base[o] + i] = v_undef()
            i = i + 1
        arr_len[o] = idx + 1
    ax_val[arr_base[o] + idx] = val


def arr_get(o: int32, idx: int32) -> int32:
    if idx < 0 or idx >= arr_len[o]:
        return v_undef()
    return ax_val[arr_base[o] + idx]


def arr_push(o: int32, val: int32):
    arr_set(o, arr_len[o], val)


# ====================================================================
# ENVIRONMENTS.
# ====================================================================
def env_new(parent: int32, is_func: int32) -> int32:
    e: int32 = n_envs
    env_parent[e] = parent
    env_head[e] = -1
    if is_func != 0:
        env_is_func[e] = 1
    else:
        env_is_func[e] = 0
    n_envs = n_envs + 1
    return e


def env_find_local(e: int32, name: int32) -> int32:
    b: int32 = env_head[e]
    while b >= 0:
        if str_eq(b_name[b], name) != 0:
            return b
        b = b_next[b]
    return -1


def env_define(e: int32, name: int32, val: int32, is_const: int32):
    b: int32 = env_find_local(e, name)
    if b >= 0:
        b_val[b] = val
        return
    nb: int32 = n_binds
    b_name[nb] = name
    b_val[nb] = val
    if is_const != 0:
        b_const[nb] = 1
    else:
        b_const[nb] = 0
    b_next[nb] = env_head[e]
    env_head[e] = nb
    n_binds = n_binds + 1


def env_lookup_bind(e: int32, name: int32) -> int32:
    while e >= 0:
        b: int32 = env_find_local(e, name)
        if b >= 0:
            return b
        e = env_parent[e]
    return -1


def env_func_scope(e: int32) -> int32:
    while e >= 0:
        if env_is_func[e] != 0:
            return e
        if env_parent[e] < 0:
            return e
        e = env_parent[e]
    return e


# ====================================================================
# error handling
# ====================================================================
# A catchable runtime exception: builds an Error-like object and unwinds via
# CTL_THROW (as opposed to set_error, which is a fatal parse/engine error).
def throw_error(name: Ptr[uint8], msg: Ptr[uint8]):
    if ctl == CTL_THROW or err_flag != 0:
        return
    ev: int32 = v_new_object()
    o: int32 = objid_of(ev)
    obj_set(o, str_from_cstr(name_key()), v_string_cstr(name))
    obj_set(o, str_from_cstr(msg_key()), v_string_cstr(msg))
    throw_val = ev
    ctl = CTL_THROW


def name_key() -> Ptr[uint8]:
    return cast[Ptr[uint8]]("name")


def msg_key() -> Ptr[uint8]:
    return cast[Ptr[uint8]]("message")


def set_error(msg: Ptr[uint8]):
    if err_flag != 0:
        return
    err_flag = 1
    i: int32 = 0
    while msg[i] != 0 and i < 255:
        err_str[i] = msg[i]
        i = i + 1
    err_str[i] = 0
    ctl = CTL_RETURN
    ctl_val = v_undef()



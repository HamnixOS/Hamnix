# lib/web/js/builtins/r7.ad — Round-7 W3C/ECMAScript builtins for the modular
# JS engine: Proxy (common traps) and byte-backed typed arrays + ArrayBuffer.
#
# Behavior-preserving split: Adder merges all imported files into one Program,
# so every public top-level name here resolves globally across the merged engine.
#
# call_native_r7 is the overflow arm of call_native (collections.ad): the round-7
# native ids dispatch here to keep the primary switch readable.

def call_native_r7(id: int32, thisv: int32, base: int32, argc: int32) -> int32:
    return v_undef()

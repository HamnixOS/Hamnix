# lib/web/js/builtins/r7.ad — Round-7 W3C/ECMAScript builtins for the modular
# JS engine: Proxy (common traps) and byte-backed typed arrays + ArrayBuffer.
#
# Behavior-preserving split: Adder merges all imported files into one Program,
# so every public top-level name here resolves globally across the merged engine.
#
# call_native_r7 is the overflow arm of call_native (collections.ad): the round-7
# native ids dispatch here to keep the primary switch readable.

def call_native_r7(id: int32, thisv: int32, base: int32, argc: int32) -> int32:
    if id == NAT_PROXY:
        return proxy_construct(thisv, arg_or(base, argc, 0), arg_or(base, argc, 1))
    if id == NAT_ARRAYBUFFER:
        return arraybuffer_construct(thisv, arg_or(base, argc, 0))
    if id == NAT_TYPEDARRAY:
        return typedarray_construct(native_self, thisv, base, argc)
    if id == NAT_TA_SET:
        return typedarray_set(thisv, arg_or(base, argc, 0), arg_or(base, argc, 1), argc)
    if id == NAT_TA_SUBARRAY:
        return typedarray_subarray(thisv, base, argc, 0)
    if id == NAT_TA_SLICE:
        return typedarray_subarray(thisv, base, argc, 1)
    if id == NAT_TA_FILL:
        return typedarray_fill(thisv, base, argc)
    if id == NAT_TA_ITER:
        return typedarray_to_array(thisv)
    if id == NAT_TA_OF:
        return typedarray_of(native_self, base, argc)
    if id == NAT_TA_FROM:
        return typedarray_from(native_self, arg_or(base, argc, 0), arg_or(base, argc, 1), argc)
    return v_undef()


# ====================================================================
# PROXY — new Proxy(target, handler) with common traps.
# ====================================================================
# A Proxy is an ordinary object flagged by obj_proxy_target (a target VALUE
# handle) + obj_proxy_handler (a handler VALUE handle). The engine's member-get,
# member-set, `in`, `delete`, and own-key enumeration route through the handler's
# get/set/has/deleteProperty/ownKeys traps when present, else forward to target.
# NOT wired (deferred): apply/construct/defineProperty/getOwnPropertyDescriptor/
# getPrototypeOf/setPrototypeOf traps, and revocable proxies.
def proxy_construct(thisv: int32, targetv: int32, handlerv: int32) -> int32:
    if tag_of(targetv) != TAG_OBJ or tag_of(handlerv) != TAG_OBJ:
        throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("Cannot create proxy with a non-object as target or handler"))
        return thisv
    po: int32 = objid_of(thisv)
    obj_proxy_target[po] = targetv
    obj_proxy_handler[po] = handlerv
    return thisv


# Look up a callable trap named `name` on the handler; -1 if absent/not callable.
def proxy_trap(handlerv: int32, name: Ptr[uint8]) -> int32:
    t: int32 = member_get(handlerv, str_from_cstr(name))
    if is_callable(t) != 0:
        return t
    return -1


# invoke a trap fn with up to 4 args pushed onto the call stack
def trap_invoke4(fnv: int32, thisv: int32, a0: int32, a1: int32, a2: int32, a3: int32, n: int32) -> int32:
    b: int32 = call_top
    if n > 0:
        call_args[call_top] = a0
        call_top = call_top + 1
    if n > 1:
        call_args[call_top] = a1
        call_top = call_top + 1
    if n > 2:
        call_args[call_top] = a2
        call_top = call_top + 1
    if n > 3:
        call_args[call_top] = a3
        call_top = call_top + 1
    r: int32 = invoke(fnv, thisv, b, n)
    call_top = b
    return r


def proxy_get(proxyv: int32, key_sid: int32) -> int32:
    po: int32 = objid_of(proxyv)
    tgt: int32 = obj_proxy_target[po]
    h: int32 = obj_proxy_handler[po]
    trap: int32 = proxy_trap(h, cast[Ptr[uint8]]("get"))
    if trap >= 0:
        return trap_invoke4(trap, h, tgt, v_string_id(key_sid), proxyv, 0, 3)
    return member_get(tgt, key_sid)


def proxy_set(proxyv: int32, key_sid: int32, val: int32):
    po: int32 = objid_of(proxyv)
    tgt: int32 = obj_proxy_target[po]
    h: int32 = obj_proxy_handler[po]
    trap: int32 = proxy_trap(h, cast[Ptr[uint8]]("set"))
    if trap >= 0:
        ign: int32 = trap_invoke4(trap, h, tgt, v_string_id(key_sid), val, proxyv, 4)
        return
    member_set(tgt, key_sid, val)


def proxy_has(proxyv: int32, key_sid: int32) -> int32:
    po: int32 = objid_of(proxyv)
    tgt: int32 = obj_proxy_target[po]
    h: int32 = obj_proxy_handler[po]
    trap: int32 = proxy_trap(h, cast[Ptr[uint8]]("has"))
    if trap >= 0:
        return to_bool(trap_invoke4(trap, h, tgt, v_string_id(key_sid), 0, 0, 2))
    return op_in(v_string_id(key_sid), tgt)


def proxy_delete(proxyv: int32, key_sid: int32) -> int32:
    po: int32 = objid_of(proxyv)
    tgt: int32 = obj_proxy_target[po]
    h: int32 = obj_proxy_handler[po]
    trap: int32 = proxy_trap(h, cast[Ptr[uint8]]("deleteProperty"))
    if trap >= 0:
        return to_bool(trap_invoke4(trap, h, tgt, v_string_id(key_sid), 0, 0, 2))
    if tag_of(tgt) == TAG_OBJ:
        return obj_del_prop(objid_of(tgt), key_sid)
    return 0


def proxy_own_keys(proxyv: int32) -> int32:
    po: int32 = objid_of(proxyv)
    tgt: int32 = obj_proxy_target[po]
    h: int32 = obj_proxy_handler[po]
    trap: int32 = proxy_trap(h, cast[Ptr[uint8]]("ownKeys"))
    if trap >= 0:
        r: int32 = trap_invoke4(trap, h, tgt, 0, 0, 0, 1)
        if is_array(r) != 0:
            return r
    return object_keys(tgt)


# ====================================================================
# TYPED ARRAYS + ArrayBuffer — byte-backed, little-endian (host arch order).
# ====================================================================
def ta_elem_size(kind: int32) -> int32:
    if kind == TA_INT8 or kind == TA_UINT8 or kind == TA_UINT8C:
        return 1
    if kind == TA_INT16 or kind == TA_UINT16:
        return 2
    if kind == TA_INT32 or kind == TA_UINT32 or kind == TA_FLOAT32:
        return 4
    if kind == TA_FLOAT64:
        return 8
    return 1


# absolute byte offset of element `idx` within the shared ta_bytes pool
def ta_byte_addr(view_o: int32, idx: int32) -> int32:
    bufv: int32 = obj_ta_buf[view_o]
    abo: int32 = objid_of(bufv)
    kind: int32 = cast[int32](obj_ta_kind[view_o])
    return obj_ab_off[abo] + obj_ta_off[view_o] + idx * ta_elem_size(kind)


def ta_load(view_o: int32, idx: int32) -> int32:
    kind: int32 = cast[int32](obj_ta_kind[view_o])
    off: int32 = ta_byte_addr(view_o, idx)
    if kind == TA_FLOAT64:
        return v_number(cast[Ptr[float64]](&ta_bytes[off])[0])
    if kind == TA_FLOAT32:
        return v_number(cast[float64](cast[Ptr[float32]](&ta_bytes[off])[0]))
    if kind == TA_INT8:
        return v_number(cast[float64](cast[Ptr[int8]](&ta_bytes[off])[0]))
    if kind == TA_UINT8 or kind == TA_UINT8C:
        return v_number(cast[float64](cast[Ptr[uint8]](&ta_bytes[off])[0]))
    if kind == TA_INT16:
        return v_number(cast[float64](cast[Ptr[int16]](&ta_bytes[off])[0]))
    if kind == TA_UINT16:
        return v_number(cast[float64](cast[Ptr[uint16]](&ta_bytes[off])[0]))
    if kind == TA_INT32:
        return v_number(cast[float64](cast[Ptr[int32]](&ta_bytes[off])[0]))
    if kind == TA_UINT32:
        return v_number(cast[float64](cast[Ptr[uint32]](&ta_bytes[off])[0]))
    return v_number(0.0)


# store a JS value into element `idx`, applying the type's ToInt/clamp coercion.
def ta_store_val(view_o: int32, idx: int32, valh: int32):
    kind: int32 = cast[int32](obj_ta_kind[view_o])
    off: int32 = ta_byte_addr(view_o, idx)
    if kind == TA_FLOAT64:
        cast[Ptr[float64]](&ta_bytes[off])[0] = to_number(valh)
        return
    if kind == TA_FLOAT32:
        cast[Ptr[float32]](&ta_bytes[off])[0] = cast[float32](to_number(valh))
        return
    if kind == TA_UINT8C:
        x: float64 = to_number(valh)
        if is_nan(x) != 0:
            x = 0.0
        if x < 0.0:
            x = 0.0
        if x > 255.0:
            x = 255.0
        cast[Ptr[uint8]](&ta_bytes[off])[0] = cast[uint8](f_floor(x + 0.5))
        return
    iv: int32 = to_int32(valh)
    if kind == TA_INT8 or kind == TA_UINT8:
        cast[Ptr[uint8]](&ta_bytes[off])[0] = cast[uint8](iv & 255)
        return
    if kind == TA_INT16 or kind == TA_UINT16:
        cast[Ptr[uint16]](&ta_bytes[off])[0] = cast[uint16](iv & 65535)
        return
    # 32-bit: store the full low word (bit pattern shared by Int32/Uint32)
    cast[Ptr[int32]](&ta_bytes[off])[0] = iv


def is_arraybuffer(h: int32) -> int32:
    if tag_of(h) != TAG_OBJ:
        return 0
    if obj_ab_off[objid_of(h)] >= 0:
        return 1
    return 0


# allocate `bytelen` zeroed bytes in the shared pool; return an ArrayBuffer value
def ta_alloc_buffer(bytelen: int32) -> int32:
    if bytelen < 0:
        bytelen = 0
    v: int32 = v_new_object()
    o: int32 = objid_of(v)
    if ta_bytes_top + bytelen > TA_BYTES_CAP:
        set_error(cast[Ptr[uint8]]("typed-array byte storage exhausted"))
        obj_ab_off[o] = ta_bytes_top
        obj_ab_len[o] = 0
        return v
    off: int32 = ta_bytes_top
    i: int32 = 0
    while i < bytelen:
        ta_bytes[off + i] = cast[uint8](0)
        i = i + 1
    ta_bytes_top = ta_bytes_top + bytelen
    obj_ab_off[o] = off
    obj_ab_len[o] = bytelen
    return v


def arraybuffer_construct(thisv: int32, lenv: int32) -> int32:
    n: int32 = to_int32(lenv)
    if n < 0:
        n = 0
    o: int32 = objid_of(thisv)
    if ta_bytes_top + n > TA_BYTES_CAP:
        set_error(cast[Ptr[uint8]]("typed-array byte storage exhausted"))
        obj_ab_off[o] = ta_bytes_top
        obj_ab_len[o] = 0
        return thisv
    off: int32 = ta_bytes_top
    i: int32 = 0
    while i < n:
        ta_bytes[off + i] = cast[uint8](0)
        i = i + 1
    ta_bytes_top = ta_bytes_top + n
    obj_ab_off[o] = off
    obj_ab_len[o] = n
    return thisv


# fresh typed-array view of `n` elements over a NEW zeroed backing buffer
def make_typed_array(kind: int32, n: int32) -> int32:
    if n < 0:
        n = 0
    v: int32 = v_new_object()
    vo: int32 = objid_of(v)
    buf: int32 = ta_alloc_buffer(n * ta_elem_size(kind))
    obj_ta_kind[vo] = cast[uint8](kind)
    obj_ta_buf[vo] = buf
    obj_ta_off[vo] = 0
    obj_ta_len[vo] = n
    if g_ta_proto[kind] != 0:
        obj_proto[vo] = objid_of(g_ta_proto[kind])
    return v


# new Uint8Array(...) etc. ctor_o is the ctor fn object id (obj_p_a = TA_* kind).
def typedarray_construct(ctor_o: int32, thisv: int32, base: int32, argc: int32) -> int32:
    kind: int32 = obj_p_a[ctor_o]
    esz: int32 = ta_elem_size(kind)
    vo: int32 = objid_of(thisv)
    obj_ta_kind[vo] = cast[uint8](kind)
    arg0: int32 = arg_or(base, argc, 0)
    if argc == 0:
        obj_ta_buf[vo] = ta_alloc_buffer(0)
        obj_ta_off[vo] = 0
        obj_ta_len[vo] = 0
        return thisv
    # new TA(arrayBuffer[, byteOffset[, length]]) — a SHARED view (no copy)
    if is_arraybuffer(arg0) != 0:
        byteoff: int32 = 0
        if argc > 1:
            byteoff = to_int32(arg_or(base, argc, 1))
        ablen: int32 = obj_ab_len[objid_of(arg0)]
        nlen: int32 = (ablen - byteoff) / esz
        if argc > 2:
            nlen = to_int32(arg_or(base, argc, 2))
        obj_ta_buf[vo] = arg0
        obj_ta_off[vo] = byteoff
        obj_ta_len[vo] = nlen
        return thisv
    # new TA(number) — length; new TA(typedArray | array | iterable) — copy
    if tag_of(arg0) == TAG_NUM:
        n: int32 = to_int32(arg0)
        if n < 0:
            n = 0
        obj_ta_buf[vo] = ta_alloc_buffer(n * esz)
        obj_ta_off[vo] = 0
        obj_ta_len[vo] = n
        return thisv
    # source sequence: materialize into a plain array first, then copy elements
    srca: int32 = v_new_array()
    if collect_iterable_into(arg0, objid_of(srca)) < 0:
        # array-like with .length (best-effort)
        if tag_of(arg0) == TAG_OBJ:
            lv: int32 = member_get(arg0, str_from_cstr(cast[Ptr[uint8]]("length")))
            ln: int32 = to_int32(lv)
            k: int32 = 0
            while k < ln:
                arr_push(objid_of(srca), member_get(arg0, num_to_strid(cast[float64](k))))
                k = k + 1
    sao: int32 = objid_of(srca)
    cnt: int32 = arr_len[sao]
    obj_ta_buf[vo] = ta_alloc_buffer(cnt * esz)
    obj_ta_off[vo] = 0
    obj_ta_len[vo] = cnt
    i: int32 = 0
    while i < cnt:
        ta_store_val(vo, i, arr_get(sao, i))
        i = i + 1
    return thisv


# TypedArray.prototype.set(source[, offset]) — copy elements from an array /
# typed array / iterable into this view starting at `offset`.
def typedarray_set(thisv: int32, srcv: int32, offv: int32, argc: int32) -> int32:
    if is_typed_array(thisv) == 0:
        return v_undef()
    to: int32 = objid_of(thisv)
    off: int32 = 0
    if argc > 1:
        off = to_int32(offv)
    tmp: int32 = v_new_array()
    tmpo: int32 = objid_of(tmp)
    if is_typed_array(srcv) != 0:
        so: int32 = objid_of(srcv)
        i: int32 = 0
        while i < obj_ta_len[so]:
            arr_push(tmpo, ta_load(so, i))
            i = i + 1
    else:
        collect_iterable_into(srcv, tmpo)
    j: int32 = 0
    while j < arr_len[tmpo]:
        if off + j >= 0 and off + j < obj_ta_len[to]:
            ta_store_val(to, off + j, arr_get(tmpo, j))
        j = j + 1
    return v_undef()


# subarray(begin,end): a SHARED view over the same buffer.
# slice(begin,end): a COPY into a fresh buffer. `docopy` selects.
def typedarray_subarray(thisv: int32, base: int32, argc: int32, docopy: int32) -> int32:
    if is_typed_array(thisv) == 0:
        return v_undef()
    to: int32 = objid_of(thisv)
    kind: int32 = cast[int32](obj_ta_kind[to])
    esz: int32 = ta_elem_size(kind)
    len: int32 = obj_ta_len[to]
    begin: int32 = 0
    if argc > 0:
        begin = to_int32(arg_or(base, argc, 0))
    endv: int32 = len
    if argc > 1:
        endv = to_int32(arg_or(base, argc, 1))
    if begin < 0:
        begin = len + begin
    if endv < 0:
        endv = len + endv
    if begin < 0:
        begin = 0
    if begin > len:
        begin = len
    if endv < begin:
        endv = begin
    if endv > len:
        endv = len
    count: int32 = endv - begin
    if docopy != 0:
        out: int32 = make_typed_array(kind, count)
        oo: int32 = objid_of(out)
        i: int32 = 0
        while i < count:
            ta_store_val(oo, i, ta_load(to, begin + i))
            i = i + 1
        return out
    # subarray: share the backing buffer, adjust offset/length
    v: int32 = v_new_object()
    vo: int32 = objid_of(v)
    obj_ta_kind[vo] = cast[uint8](kind)
    obj_ta_buf[vo] = obj_ta_buf[to]
    obj_ta_off[vo] = obj_ta_off[to] + begin * esz
    obj_ta_len[vo] = count
    if g_ta_proto[kind] != 0:
        obj_proto[vo] = objid_of(g_ta_proto[kind])
    return v


def typedarray_fill(thisv: int32, base: int32, argc: int32) -> int32:
    if is_typed_array(thisv) == 0:
        return thisv
    to: int32 = objid_of(thisv)
    len: int32 = obj_ta_len[to]
    valh: int32 = arg_or(base, argc, 0)
    start: int32 = 0
    if argc > 1:
        start = to_int32(arg_or(base, argc, 1))
    endv: int32 = len
    if argc > 2:
        endv = to_int32(arg_or(base, argc, 2))
    if start < 0:
        start = len + start
    if endv < 0:
        endv = len + endv
    if start < 0:
        start = 0
    if endv > len:
        endv = len
    i: int32 = start
    while i < endv:
        ta_store_val(to, i, valh)
        i = i + 1
    return thisv


# snapshot the view's elements into a plain JS array (used by iteration/values)
def typedarray_to_array(thisv: int32) -> int32:
    res: int32 = v_new_array()
    if is_typed_array(thisv) == 0:
        return res
    to: int32 = objid_of(thisv)
    ro: int32 = objid_of(res)
    i: int32 = 0
    while i < obj_ta_len[to]:
        arr_push(ro, ta_load(to, i))
        i = i + 1
    return res


# TypedArray.of(...items) — a new view from the argument list. fn_o carries kind.
def typedarray_of(fn_o: int32, base: int32, argc: int32) -> int32:
    kind: int32 = obj_p_a[fn_o]
    out: int32 = make_typed_array(kind, argc)
    oo: int32 = objid_of(out)
    i: int32 = 0
    while i < argc:
        ta_store_val(oo, i, call_args[base + i])
        i = i + 1
    return out


# TypedArray.from(source[, mapFn]) — a new view from an iterable/array-like.
def typedarray_from(fn_o: int32, srcv: int32, mapfn: int32, argc: int32) -> int32:
    kind: int32 = obj_p_a[fn_o]
    tmp: int32 = v_new_array()
    tmpo: int32 = objid_of(tmp)
    if collect_iterable_into(srcv, tmpo) < 0:
        if tag_of(srcv) == TAG_OBJ:
            lv: int32 = member_get(srcv, str_from_cstr(cast[Ptr[uint8]]("length")))
            ln: int32 = to_int32(lv)
            k: int32 = 0
            while k < ln:
                arr_push(tmpo, member_get(srcv, num_to_strid(cast[float64](k))))
                k = k + 1
    cnt: int32 = arr_len[tmpo]
    out: int32 = make_typed_array(kind, cnt)
    oo: int32 = objid_of(out)
    usemap: int32 = 0
    if argc > 1 and is_callable(mapfn) != 0:
        usemap = 1
    i: int32 = 0
    while i < cnt:
        ev: int32 = arr_get(tmpo, i)
        if usemap != 0:
            mb: int32 = call_top
            call_args[call_top] = ev
            call_args[call_top + 1] = v_number(cast[float64](i))
            call_top = call_top + 2
            ev = invoke(mapfn, v_undef(), mb, 2)
            call_top = mb
        ta_store_val(oo, i, ev)
        i = i + 1
    return out


# member_get helper: typed-array own accessors (length/byteLength/byteOffset/
# buffer/BYTES_PER_ELEMENT) and numeric-index reads. Returns -1 to signal "not a
# typed-array-own key" so the caller falls through to the prototype walk.
def ta_member_get(objv: int32, key_sid: int32) -> int32:
    to: int32 = objid_of(objv)
    kind: int32 = cast[int32](obj_ta_kind[to])
    if str_eq_cstr(key_sid, cast[Ptr[uint8]]("length")) != 0:
        return v_number(cast[float64](obj_ta_len[to]))
    if str_eq_cstr(key_sid, cast[Ptr[uint8]]("byteLength")) != 0:
        return v_number(cast[float64](obj_ta_len[to] * ta_elem_size(kind)))
    if str_eq_cstr(key_sid, cast[Ptr[uint8]]("byteOffset")) != 0:
        return v_number(cast[float64](obj_ta_off[to]))
    if str_eq_cstr(key_sid, cast[Ptr[uint8]]("BYTES_PER_ELEMENT")) != 0:
        return v_number(cast[float64](ta_elem_size(kind)))
    if str_eq_cstr(key_sid, cast[Ptr[uint8]]("buffer")) != 0:
        return obj_ta_buf[to]
    idx: int32 = str_as_index(key_sid)
    if idx >= 0:
        if idx < obj_ta_len[to]:
            return ta_load(to, idx)
        return v_undef()
    return -1


# ---- setup: install ArrayBuffer + one TypedArray family per element type ----
def install_typed_array(name: Ptr[uint8], kind: int32):
    ctor: int32 = v_new_native(NAT_TYPEDARRAY)
    obj_p_a[objid_of(ctor)] = kind
    proto: int32 = v_new_object()
    obj_add_native(proto, cast[Ptr[uint8]]("set"), NAT_TA_SET)
    obj_add_native(proto, cast[Ptr[uint8]]("subarray"), NAT_TA_SUBARRAY)
    obj_add_native(proto, cast[Ptr[uint8]]("slice"), NAT_TA_SLICE)
    obj_add_native(proto, cast[Ptr[uint8]]("fill"), NAT_TA_FILL)
    obj_add_native(proto, cast[Ptr[uint8]]("values"), NAT_TA_ITER)
    if g_sym_iterator != 0:
        obj_set(objid_of(proto), symbol_key(g_sym_iterator), v_new_native(NAT_TA_ITER))
    obj_set(objid_of(proto), str_from_cstr(cast[Ptr[uint8]]("constructor")), ctor)
    obj_set(objid_of(ctor), str_from_cstr(cast[Ptr[uint8]]("prototype")), proto)
    obj_set(objid_of(ctor), str_from_cstr(cast[Ptr[uint8]]("BYTES_PER_ELEMENT")), v_number(cast[float64](ta_elem_size(kind))))
    of_fn: int32 = v_new_native(NAT_TA_OF)
    obj_p_a[objid_of(of_fn)] = kind
    obj_set(objid_of(ctor), str_from_cstr(cast[Ptr[uint8]]("of")), of_fn)
    from_fn: int32 = v_new_native(NAT_TA_FROM)
    obj_p_a[objid_of(from_fn)] = kind
    obj_set(objid_of(ctor), str_from_cstr(cast[Ptr[uint8]]("from")), from_fn)
    g_ta_proto[kind] = proto
    env_define(g_env, str_from_cstr(name), ctor, 0)


def install_typed_arrays():
    def_global_native(cast[Ptr[uint8]]("ArrayBuffer"), NAT_ARRAYBUFFER)
    install_typed_array(cast[Ptr[uint8]]("Int8Array"), TA_INT8)
    install_typed_array(cast[Ptr[uint8]]("Uint8Array"), TA_UINT8)

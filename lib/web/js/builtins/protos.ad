# lib/web/js/builtins/protos.ad — part of the modular web engine.
# REAL builtin prototype OBJECTS whose methods are genuine native-function VALUES.
#
# Transpiled / minified bundles (Google's included) lean hard on reading a
# prototype method as a first-class value and re-dispatching it with an explicit
# receiver:
#     Array.prototype.slice.call(arguments)
#     Object.prototype.toString.call(x)          -> "[object Array]"
#     Object.prototype.hasOwnProperty.call(o, k)
#     Function.prototype.call.bind(fn)
# The engine already fast-dispatches direct calls (`arr.slice(...)`) by NAME, but
# before this file `Array.prototype` / `Object.prototype` / `Function.prototype`
# / `String.prototype` had no real method VALUES, so `.slice.call` couldn't
# resolve. Here we build those prototype objects with native method values that
# read `this` (the receiver from .call/.apply/.bind or normal dispatch) and wire
# array instances' [[Prototype]] to Array.prototype so `[].slice ===
# Array.prototype.slice`. The existing fast direct-dispatch is preserved as an
# optimization (eval_call still intercepts `arr.m(...)` before member_get).
#
# Behavior-preserving split: Adder is a single-compilation-unit language, so
# every public name here resolves globally across the merged engine.


# ---- one dispatch entry point for every prototype method value --------------
# The specific method NAME is stored on the native fn object (obj_p_a), recovered
# via native_self, so a single native id backs all methods of a prototype.
def call_native_proto(id: int32, thisv: int32, base: int32, argc: int32) -> int32:
    name: int32 = obj_p_a[native_self]
    if id == NAT_SP_METHOD:
        if str_eq_cstr(name, cast[Ptr[uint8]]("valueOf")) != 0:
            return to_string_val(thisv)
        return string_method(to_string_val(thisv), name, base, argc)
    if id == NAT_OP_METHOD:
        return object_proto_method(thisv, name, base, argc)
    if id == NAT_FP_METHOD:
        return function_proto_method(thisv, name, base, argc)
    if id == NAT_AP_METHOD:
        return array_proto_method(thisv, name, base, argc)
    if id == NAT_NP_METHOD:
        return number_proto_method(thisv, name, base, argc)
    if id == NAT_BP_METHOD:
        return boolean_proto_method(thisv, name, base, argc)
    return v_undef()


# ---- Object.prototype -------------------------------------------------------
def object_tag_string(thisv: int32) -> int32:
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    emit_cstr(cast[Ptr[uint8]]("[object "))
    t: int32 = tag_of(thisv)
    if t == TAG_UNDEF:
        emit_cstr(cast[Ptr[uint8]]("Undefined"))
    elif t == TAG_NULL:
        emit_cstr(cast[Ptr[uint8]]("Null"))
    elif t == TAG_NUM:
        emit_cstr(cast[Ptr[uint8]]("Number"))
    elif t == TAG_STR:
        emit_cstr(cast[Ptr[uint8]]("String"))
    elif t == TAG_BOOL:
        emit_cstr(cast[Ptr[uint8]]("Boolean"))
    elif t == TAG_OBJ:
        o: int32 = objid_of(thisv)
        if cast[int32](obj_kind[o]) == OK_ARRAY:
            emit_cstr(cast[Ptr[uint8]]("Array"))
        elif cast[int32](obj_kind[o]) == OK_FUNC:
            emit_cstr(cast[Ptr[uint8]]("Function"))
        elif obj_is_date[o] != 0:
            emit_cstr(cast[Ptr[uint8]]("Date"))
        elif obj_re_prog[o] >= 0:
            emit_cstr(cast[Ptr[uint8]]("RegExp"))
        else:
            emit_cstr(cast[Ptr[uint8]]("Object"))
    else:
        emit_cstr(cast[Ptr[uint8]]("Object"))
    emit_c(93)                      # ']'
    id: int32 = bld_end()
    emit_tgt = save
    return v_string_id(id)


def object_proto_method(thisv: int32, name: int32, base: int32, argc: int32) -> int32:
    if str_eq_cstr(name, cast[Ptr[uint8]]("toString")) != 0:
        return object_tag_string(thisv)
    if str_eq_cstr(name, cast[Ptr[uint8]]("toLocaleString")) != 0:
        return to_string_val(thisv)
    if str_eq_cstr(name, cast[Ptr[uint8]]("valueOf")) != 0:
        return thisv
    if str_eq_cstr(name, cast[Ptr[uint8]]("isPrototypeOf")) != 0:
        arg0: int32 = arg_or(base, argc, 0)
        if tag_of(thisv) != TAG_OBJ or tag_of(arg0) != TAG_OBJ:
            return v_false()
        target: int32 = objid_of(thisv)
        c2: int32 = obj_proto[objid_of(arg0)]
        while c2 >= 0:
            if c2 == target:
                return v_true()
            c2 = obj_proto[c2]
        return v_false()
    # hasOwnProperty / propertyIsEnumerable: own-key membership.
    is_pie: int32 = str_eq_cstr(name, cast[Ptr[uint8]]("propertyIsEnumerable"))
    if str_eq_cstr(name, cast[Ptr[uint8]]("hasOwnProperty")) != 0 or is_pie != 0:
        if tag_of(thisv) != TAG_OBJ:
            return v_false()
        o: int32 = objid_of(thisv)
        ks: int32 = strid_of(to_string_val(arg_or(base, argc, 0)))
        if cast[int32](obj_kind[o]) == OK_ARRAY:
            idx: int32 = str_as_index(ks)
            if idx >= 0 and idx < arr_len[o]:
                return v_true()
            # `length` is own but non-enumerable
            if is_pie == 0 and str_eq_cstr(ks, cast[Ptr[uint8]]("length")) != 0:
                return v_true()
        if obj_find_prop(o, ks) >= 0:
            if is_pie != 0 and is_hidden_key(ks) != 0:
                return v_false()
            return v_true()
        return v_false()
    return v_undef()


# ---- Function.prototype -----------------------------------------------------
def function_proto_method(fnv: int32, name: int32, base: int32, argc: int32) -> int32:
    if str_eq_cstr(name, cast[Ptr[uint8]]("toString")) != 0:
        return v_string_cstr(cast[Ptr[uint8]]("function () { [native code] }"))
    if is_callable(fnv) == 0:
        throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("Function.prototype method called on non-function"))
        return v_undef()
    if str_eq_cstr(name, cast[Ptr[uint8]]("call")) != 0:
        this_arg: int32 = arg_or(base, argc, 0)
        if argc >= 1:
            return invoke(fnv, this_arg, base + 1, argc - 1)
        return invoke(fnv, this_arg, base, 0)
    if str_eq_cstr(name, cast[Ptr[uint8]]("apply")) != 0:
        this_arg2: int32 = arg_or(base, argc, 0)
        spreadbase: int32 = call_top
        nsp: int32 = 0
        arrv: int32 = arg_or(base, argc, 1)
        if is_array(arrv) != 0:
            ao: int32 = objid_of(arrv)
            i: int32 = 0
            while i < arr_len[ao]:
                call_args[call_top] = arr_get(ao, i)
                call_top = call_top + 1
                nsp = nsp + 1
                i = i + 1
        r2: int32 = invoke(fnv, this_arg2, spreadbase, nsp)
        call_top = spreadbase
        return r2
    if str_eq_cstr(name, cast[Ptr[uint8]]("bind")) != 0:
        bthis: int32 = arg_or(base, argc, 0)
        pre: int32 = -1
        if argc >= 2:
            pre = v_new_array()
            pao: int32 = objid_of(pre)
            j: int32 = 1
            while j < argc:
                arr_push(pao, call_args[base + j])
                j = j + 1
        bf: int32 = v_new_native(-1)     # callable object, no native id
        bo: int32 = objid_of(bf)
        obj_fn_btarget[bo] = fnv
        obj_fn_bthis[bo] = bthis
        obj_fn_bargs[bo] = pre
        return bf
    return v_undef()


# ---- Array.prototype --------------------------------------------------------
# Coerce a receiver to a real array to READ from: real arrays pass through; an
# array-like (own numeric length + indices, e.g. a host NodeList) is copied.
# Returns -1 for a value with no array shape.
def arraylike_of(v: int32) -> int32:
    if is_array(v) != 0:
        return v
    if tag_of(v) != TAG_OBJ:
        return -1
    lenv: int32 = member_get(v, str_from_cstr(cast[Ptr[uint8]]("length")))
    if tag_of(lenv) != TAG_NUM:
        return -1
    n: int32 = cast[int32](to_number(lenv))
    if n < 0:
        n = 0
    res: int32 = v_new_array()
    ro: int32 = objid_of(res)
    i: int32 = 0
    while i < n:
        arr_push(ro, member_get(v, strid_of(to_string_val(v_number(cast[float64](i))))))
        i = i + 1
    return res


# invoke a (callback, thisArg) style array iteration callback: cb(elem, idx, arr)
def ap_invoke_cb(fn: int32, thisArg: int32, elem: int32, idx: int32, arrv: int32) -> int32:
    cb: int32 = call_top
    call_args[call_top] = elem
    call_args[call_top + 1] = v_number(cast[float64](idx))
    call_args[call_top + 2] = arrv
    call_top = call_top + 3
    r: int32 = invoke(fn, thisArg, cb, 3)
    call_top = cb
    return r


def array_proto_method(thisv: int32, name: int32, base: int32, argc: int32) -> int32:
    # ---- mutators operate on the receiver in place (must be a real array) ----
    if str_eq_cstr(name, cast[Ptr[uint8]]("push")) != 0:
        if is_array(thisv) == 0:
            return v_number(0.0)
        mo: int32 = objid_of(thisv)
        pi: int32 = 0
        while pi < argc:
            arr_push(mo, call_args[base + pi])
            pi = pi + 1
        return v_number(cast[float64](arr_len[mo]))
    if str_eq_cstr(name, cast[Ptr[uint8]]("pop")) != 0:
        if is_array(thisv) == 0:
            return v_undef()
        po: int32 = objid_of(thisv)
        if arr_len[po] == 0:
            return v_undef()
        pv: int32 = arr_get(po, arr_len[po] - 1)
        arr_len[po] = arr_len[po] - 1
        return pv
    if str_eq_cstr(name, cast[Ptr[uint8]]("shift")) != 0:
        if is_array(thisv) == 0:
            return v_undef()
        so: int32 = objid_of(thisv)
        if arr_len[so] == 0:
            return v_undef()
        sv0: int32 = arr_get(so, 0)
        si: int32 = 1
        while si < arr_len[so]:
            arr_set(so, si - 1, arr_get(so, si))
            si = si + 1
        arr_len[so] = arr_len[so] - 1
        return sv0
    if str_eq_cstr(name, cast[Ptr[uint8]]("unshift")) != 0:
        if is_array(thisv) == 0:
            return v_number(0.0)
        uo: int32 = objid_of(thisv)
        old: int32 = arr_len[uo]
        k: int32 = old - 1
        while k >= 0:
            arr_set(uo, k + argc, arr_get(uo, k))
            k = k - 1
        ui: int32 = 0
        while ui < argc:
            arr_set(uo, ui, call_args[base + ui])
            ui = ui + 1
        return v_number(cast[float64](arr_len[uo]))
    if str_eq_cstr(name, cast[Ptr[uint8]]("reverse")) != 0:
        if is_array(thisv) == 0:
            return thisv
        vo: int32 = objid_of(thisv)
        lo: int32 = 0
        hi: int32 = arr_len[vo] - 1
        while lo < hi:
            t: int32 = arr_get(vo, lo)
            arr_set(vo, lo, arr_get(vo, hi))
            arr_set(vo, hi, t)
            lo = lo + 1
            hi = hi - 1
        return thisv
    if str_eq_cstr(name, cast[Ptr[uint8]]("fill")) != 0:
        if is_array(thisv) == 0:
            return thisv
        fo: int32 = objid_of(thisv)
        fval: int32 = arg_or(base, argc, 0)
        fst: int32 = 0
        fen: int32 = arr_len[fo]
        if argc > 1:
            fst = cast[int32](to_number(call_args[base + 1]))
        if argc > 2:
            fen = cast[int32](to_number(call_args[base + 2]))
        if fst < 0:
            fst = arr_len[fo] + fst
        if fen < 0:
            fen = arr_len[fo] + fen
        while fst < fen:
            if fst >= 0 and fst < arr_len[fo]:
                arr_set(fo, fst, fval)
            fst = fst + 1
        return thisv
    # ---- read-only methods work over an array (copy of an array-like) ----
    srcv: int32 = arraylike_of(thisv)
    if srcv < 0:
        throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("Array.prototype method called on non-array-like"))
        return v_undef()
    o: int32 = objid_of(srcv)
    if str_eq_cstr(name, cast[Ptr[uint8]]("slice")) != 0:
        st: int32 = 0
        en: int32 = arr_len[o]
        if argc > 0:
            st = cast[int32](to_number(call_args[base]))
        if argc > 1:
            en = cast[int32](to_number(call_args[base + 1]))
        if st < 0:
            st = arr_len[o] + st
            if st < 0:
                st = 0
        if en < 0:
            en = arr_len[o] + en
        if en > arr_len[o]:
            en = arr_len[o]
        res: int32 = v_new_array()
        ro: int32 = objid_of(res)
        i: int32 = st
        while i < en:
            arr_push(ro, arr_get(o, i))
            i = i + 1
        return res
    if str_eq_cstr(name, cast[Ptr[uint8]]("join")) != 0:
        sepid: int32 = -1
        if argc > 0 and tag_of(call_args[base]) != TAG_UNDEF:
            sepid = strid_of(to_string_val(call_args[base]))
        return array_join(o, sepid)
    if str_eq_cstr(name, cast[Ptr[uint8]]("indexOf")) != 0:
        tgt: int32 = arg_or(base, argc, 0)
        i2: int32 = 0
        while i2 < arr_len[o]:
            if strict_eq(arr_get(o, i2), tgt) != 0:
                return v_number(cast[float64](i2))
            i2 = i2 + 1
        return v_number(-1.0)
    if str_eq_cstr(name, cast[Ptr[uint8]]("lastIndexOf")) != 0:
        tgtL: int32 = arg_or(base, argc, 0)
        iL: int32 = arr_len[o] - 1
        while iL >= 0:
            if strict_eq(arr_get(o, iL), tgtL) != 0:
                return v_number(cast[float64](iL))
            iL = iL - 1
        return v_number(-1.0)
    if str_eq_cstr(name, cast[Ptr[uint8]]("includes")) != 0:
        tgtI: int32 = arg_or(base, argc, 0)
        iI: int32 = 0
        while iI < arr_len[o]:
            if strict_eq(arr_get(o, iI), tgtI) != 0:
                return v_boolv(1)
            iI = iI + 1
        return v_boolv(0)
    if str_eq_cstr(name, cast[Ptr[uint8]]("concat")) != 0:
        cres: int32 = v_new_array()
        cro: int32 = objid_of(cres)
        ci: int32 = 0
        while ci < arr_len[o]:
            arr_push(cro, arr_get(o, ci))
            ci = ci + 1
        ai: int32 = 0
        while ai < argc:
            av: int32 = call_args[base + ai]
            if is_array(av) != 0:
                ako: int32 = objid_of(av)
                aj: int32 = 0
                while aj < arr_len[ako]:
                    arr_push(cro, arr_get(ako, aj))
                    aj = aj + 1
            else:
                arr_push(cro, av)
            ai = ai + 1
        return cres
    # ---- callback methods ----
    fn: int32 = arg_or(base, argc, 0)
    thisArg: int32 = arg_or(base, argc, 1)
    if str_eq_cstr(name, cast[Ptr[uint8]]("forEach")) != 0:
        fi: int32 = 0
        while fi < arr_len[o] and err_flag == 0 and ctl != CTL_THROW:
            ap_invoke_cb(fn, thisArg, arr_get(o, fi), fi, srcv)
            fi = fi + 1
        return v_undef()
    if str_eq_cstr(name, cast[Ptr[uint8]]("map")) != 0:
        mres: int32 = v_new_array()
        mro: int32 = objid_of(mres)
        mi: int32 = 0
        while mi < arr_len[o] and err_flag == 0 and ctl != CTL_THROW:
            arr_push(mro, ap_invoke_cb(fn, thisArg, arr_get(o, mi), mi, srcv))
            mi = mi + 1
        return mres
    if str_eq_cstr(name, cast[Ptr[uint8]]("filter")) != 0:
        fres: int32 = v_new_array()
        fro: int32 = objid_of(fres)
        fmi: int32 = 0
        while fmi < arr_len[o] and err_flag == 0 and ctl != CTL_THROW:
            if to_bool(ap_invoke_cb(fn, thisArg, arr_get(o, fmi), fmi, srcv)) != 0:
                arr_push(fro, arr_get(o, fmi))
            fmi = fmi + 1
        return fres
    if str_eq_cstr(name, cast[Ptr[uint8]]("some")) != 0:
        sei: int32 = 0
        while sei < arr_len[o] and err_flag == 0 and ctl != CTL_THROW:
            if to_bool(ap_invoke_cb(fn, thisArg, arr_get(o, sei), sei, srcv)) != 0:
                return v_boolv(1)
            sei = sei + 1
        return v_boolv(0)
    if str_eq_cstr(name, cast[Ptr[uint8]]("every")) != 0:
        evi: int32 = 0
        while evi < arr_len[o] and err_flag == 0 and ctl != CTL_THROW:
            if to_bool(ap_invoke_cb(fn, thisArg, arr_get(o, evi), evi, srcv)) == 0:
                return v_boolv(0)
            evi = evi + 1
        return v_boolv(1)
    if str_eq_cstr(name, cast[Ptr[uint8]]("find")) != 0:
        fdi: int32 = 0
        while fdi < arr_len[o] and err_flag == 0 and ctl != CTL_THROW:
            el: int32 = arr_get(o, fdi)
            if to_bool(ap_invoke_cb(fn, thisArg, el, fdi, srcv)) != 0:
                return el
            fdi = fdi + 1
        return v_undef()
    if str_eq_cstr(name, cast[Ptr[uint8]]("findIndex")) != 0:
        fxi: int32 = 0
        while fxi < arr_len[o] and err_flag == 0 and ctl != CTL_THROW:
            if to_bool(ap_invoke_cb(fn, thisArg, arr_get(o, fxi), fxi, srcv)) != 0:
                return v_number(cast[float64](fxi))
            fxi = fxi + 1
        return v_number(-1.0)
    if str_eq_cstr(name, cast[Ptr[uint8]]("reduce")) != 0:
        acc: int32 = v_undef()
        ri: int32 = 0
        if argc > 1:
            acc = call_args[base + 1]
        else:
            if arr_len[o] > 0:
                acc = arr_get(o, 0)
                ri = 1
        while ri < arr_len[o] and err_flag == 0 and ctl != CTL_THROW:
            rb: int32 = call_top
            call_args[call_top] = acc
            call_args[call_top + 1] = arr_get(o, ri)
            call_args[call_top + 2] = v_number(cast[float64](ri))
            call_args[call_top + 3] = srcv
            call_top = call_top + 4
            acc = invoke(fn, v_undef(), rb, 4)
            call_top = rb
            ri = ri + 1
        return acc
    return v_undef()


# ---- Number.prototype / Boolean.prototype -----------------------------------
def number_proto_method(nv: int32, name: int32, base: int32, argc: int32) -> int32:
    x: float64 = to_number(nv)
    if str_eq_cstr(name, cast[Ptr[uint8]]("toFixed")) != 0:
        d: int32 = 0
        if argc > 0:
            d = cast[int32](to_number(call_args[base]))
        return num_tofixed(x, d)
    if str_eq_cstr(name, cast[Ptr[uint8]]("toString")) != 0:
        radix: int32 = 10
        if argc > 0:
            radix = cast[int32](to_number(call_args[base]))
        return num_tostring_radix(x, radix)
    if str_eq_cstr(name, cast[Ptr[uint8]]("toLocaleString")) != 0:
        return num_tostring_radix(x, 10)
    if str_eq_cstr(name, cast[Ptr[uint8]]("valueOf")) != 0:
        return v_number(x)
    return v_undef()


def boolean_proto_method(bv: int32, name: int32, base: int32, argc: int32) -> int32:
    if str_eq_cstr(name, cast[Ptr[uint8]]("valueOf")) != 0:
        return bv
    if str_eq_cstr(name, cast[Ptr[uint8]]("toString")) != 0:
        return to_string_val(bv)
    if str_eq_cstr(name, cast[Ptr[uint8]]("toLocaleString")) != 0:
        return to_string_val(bv)
    return v_undef()


# ---- installation -----------------------------------------------------------
def proto_add_method(protov: int32, name: Ptr[uint8], dispatch_id: int32):
    fv: int32 = v_new_native(dispatch_id)
    obj_p_a[objid_of(fv)] = str_from_cstr(name)
    obj_set(objid_of(protov), str_from_cstr(name), fv)


# Wire g_ctor.prototype = protov and protov.constructor = g_ctor (both cheap).
def proto_link_ctor(ctorv: int32, protov: int32):
    if ctorv == 0:
        return
    obj_set(objid_of(ctorv), str_from_cstr(cast[Ptr[uint8]]("prototype")), protov)
    obj_set(objid_of(protov), str_from_cstr(cast[Ptr[uint8]]("constructor")), ctorv)


# Build the real builtin prototype objects. Called at the end of install_builtins
# once Object/Array/Function/Number/String globals exist. The prototypes are left
# with a null [[Prototype]] (obj_proto = -1) so nothing new leaks into member
# reads on them; only array INSTANCES chain to Array.prototype (via v_new_array).
def install_prototypes(string_ctor: int32, boolean_ctor: int32):
    # Object.prototype
    g_object_proto = v_new_object()
    proto_add_method(g_object_proto, cast[Ptr[uint8]]("toString"), NAT_OP_METHOD)
    proto_add_method(g_object_proto, cast[Ptr[uint8]]("toLocaleString"), NAT_OP_METHOD)
    proto_add_method(g_object_proto, cast[Ptr[uint8]]("valueOf"), NAT_OP_METHOD)
    proto_add_method(g_object_proto, cast[Ptr[uint8]]("hasOwnProperty"), NAT_OP_METHOD)
    proto_add_method(g_object_proto, cast[Ptr[uint8]]("isPrototypeOf"), NAT_OP_METHOD)
    proto_add_method(g_object_proto, cast[Ptr[uint8]]("propertyIsEnumerable"), NAT_OP_METHOD)
    proto_link_ctor(g_object, g_object_proto)

    # Function.prototype
    g_func_proto = v_new_object()
    proto_add_method(g_func_proto, cast[Ptr[uint8]]("call"), NAT_FP_METHOD)
    proto_add_method(g_func_proto, cast[Ptr[uint8]]("apply"), NAT_FP_METHOD)
    proto_add_method(g_func_proto, cast[Ptr[uint8]]("bind"), NAT_FP_METHOD)
    proto_add_method(g_func_proto, cast[Ptr[uint8]]("toString"), NAT_FP_METHOD)
    proto_link_ctor(g_function, g_func_proto)

    # Array.prototype
    g_array_proto = v_new_object()
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("push"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("pop"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("shift"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("unshift"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("reverse"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("fill"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("slice"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("join"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("indexOf"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("lastIndexOf"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("includes"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("concat"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("forEach"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("map"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("filter"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("some"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("every"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("find"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("findIndex"), NAT_AP_METHOD)
    proto_add_method(g_array_proto, cast[Ptr[uint8]]("reduce"), NAT_AP_METHOD)
    proto_link_ctor(g_array, g_array_proto)

    # String.prototype — delegates to the shared string_method dispatcher.
    g_string_proto = v_new_object()
    install_string_proto_methods(g_string_proto)
    proto_link_ctor(string_ctor, g_string_proto)

    # Number.prototype
    g_number_proto = v_new_object()
    proto_add_method(g_number_proto, cast[Ptr[uint8]]("toString"), NAT_NP_METHOD)
    proto_add_method(g_number_proto, cast[Ptr[uint8]]("toLocaleString"), NAT_NP_METHOD)
    proto_add_method(g_number_proto, cast[Ptr[uint8]]("toFixed"), NAT_NP_METHOD)
    proto_add_method(g_number_proto, cast[Ptr[uint8]]("valueOf"), NAT_NP_METHOD)
    proto_link_ctor(g_number, g_number_proto)

    # Boolean.prototype
    g_boolean_proto = v_new_object()
    proto_add_method(g_boolean_proto, cast[Ptr[uint8]]("toString"), NAT_BP_METHOD)
    proto_add_method(g_boolean_proto, cast[Ptr[uint8]]("toLocaleString"), NAT_BP_METHOD)
    proto_add_method(g_boolean_proto, cast[Ptr[uint8]]("valueOf"), NAT_BP_METHOD)
    proto_link_ctor(boolean_ctor, g_boolean_proto)


def install_string_proto_methods(protov: int32):
    proto_add_method(protov, cast[Ptr[uint8]]("charAt"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("charCodeAt"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("codePointAt"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("at"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("indexOf"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("lastIndexOf"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("includes"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("startsWith"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("endsWith"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("slice"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("substring"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("substr"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("toUpperCase"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("toLowerCase"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("trim"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("trimStart"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("trimEnd"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("split"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("replace"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("replaceAll"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("match"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("matchAll"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("search"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("concat"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("repeat"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("padStart"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("padEnd"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("localeCompare"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("normalize"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("toString"), NAT_SP_METHOD)
    proto_add_method(protov, cast[Ptr[uint8]]("valueOf"), NAT_SP_METHOD)

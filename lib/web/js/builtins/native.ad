# lib/web/js/builtins/native.ad — part of the modular web engine (extracted from jsengine.ad).
# native global builtins: Math, JSON, console, parseInt/parseFloat, eval, and their registration.
#
# Behavior-preserving split: Adder is a single-compilation-unit language
# (merge_programs merges all imported files into one Program), so every
# public top-level name here resolves globally across the merged engine.


# ====================================================================
# NATIVE builtins (Math, JSON, console, parseInt, ...).
# ====================================================================
# eval(src): parse and run `src` as a fresh program in the GLOBAL scope
# (indirect-eval semantics, which is what real sites' `(0,eval)(...)` and
# feature-detection probes use). A non-string argument is returned unchanged
# (per spec). A parse error becomes a catchable SyntaxError throw rather than a
# fatal engine error, so one page script's `try { eval(...) } catch {}` guard
# behaves like a browser and does not blank the page. Re-entrant tokenize/parse
# is safe here: the enclosing script already finished parsing and exec walks the
# persistent AST, never the token buffer, so re-tokenizing cannot corrupt it.
eval_depth: int32 = 0
# Scratch for the thrown SyntaxError message: "eval: " + the parser's SPECIFIC
# diagnostic (which token/construct failed), so a page that eval()s unsupported
# syntax reports WHAT it choked on rather than a generic "parse error".
eval_errmsg: Array[256, uint8]

def native_eval(argv: int32) -> int32:
    if tag_of(argv) != TAG_STR:
        return argv
    # Bound re-entrant eval (eval'd code that itself eval()s) so a hostile or
    # machine-generated page cannot blow the native C stack.
    if eval_depth >= 16:
        throw_error(cast[Ptr[uint8]]("RangeError"), cast[Ptr[uint8]]("eval nesting too deep"))
        return v_undef()
    eval_depth = eval_depth + 1
    sid: int32 = strid_of(argv)
    sp: Ptr[uint8] = str_ptr(sid)
    sn: int32 = str_len(sid)
    save_ctl: int32 = ctl
    save_ctl_label: int32 = ctl_label
    save_pending: int32 = pending_label
    save_throw: int32 = throw_val
    save_ctlval: int32 = ctl_val
    tokenize(sp, sn)
    prog: int32 = parse_program()
    if err_flag != 0:
        # Preserve the parser's specific message ("...: unexpected token", etc.)
        # for the thrown SyntaxError so the console names the failing construct.
        ei: int32 = 0
        pfx: Ptr[uint8] = cast[Ptr[uint8]]("eval: ")
        while pfx[ei] != 0 and ei < 240:
            eval_errmsg[ei] = pfx[ei]
            ei = ei + 1
        ek: int32 = 0
        while err_str[ek] != 0 and ei < 254:
            eval_errmsg[ei] = err_str[ek]
            ei = ei + 1
            ek = ek + 1
        eval_errmsg[ei] = 0
        err_flag = 0
        ctl = save_ctl
        ctl_label = save_ctl_label
        pending_label = save_pending
        eval_depth = eval_depth - 1
        throw_error(cast[Ptr[uint8]]("SyntaxError"), &eval_errmsg[0])
        return v_undef()
    ctl = CTL_NONE
    ctl_label = -1
    pending_label = -1
    hoist_scan(prog, g_env)
    result: int32 = v_undef()
    head: int32 = n_a[prog]
    if head >= 0 and n_next[head] < 0 and cast[int32](n_kind[head]) == ND_EXPRSTMT:
        result = eval_expr(n_a[head], g_env)
    else:
        exec_stmt(prog, g_env)
    eval_depth = eval_depth - 1
    if ctl == CTL_THROW or err_flag != 0:
        # propagate the exception to eval's caller (leave ctl/throw_val set)
        return v_undef()
    ctl = save_ctl
    ctl_label = save_ctl_label
    pending_label = save_pending
    throw_val = save_throw
    ctl_val = save_ctlval
    return result


# ---- Storage (localStorage / sessionStorage) --------------------------------
# An in-memory Web Storage: the facade object carries the native methods plus a
# hidden "@s" property whose value is a backing object where items live keyed by
# their string key. Real sites universally feature-detect + use localStorage; a
# missing global is a ReferenceError that aborts the whole inline script.
def storage_backing(thisv: int32) -> int32:
    return objid_of(obj_get_cstr(objid_of(thisv), cast[Ptr[uint8]]("@s")))


def storage_prop_count(o: int32) -> int32:
    n: int32 = 0
    p: int32 = obj_head[o]
    while p >= 0:
        n = n + 1
        p = p_next[p]
    return n


def storage_sync_len(thisv: int32, bk: int32):
    obj_set(objid_of(thisv), str_from_cstr(cast[Ptr[uint8]]("length")), \
            v_number(cast[float64](storage_prop_count(bk))))


def make_storage() -> int32:
    fac: int32 = v_new_object()
    fo: int32 = objid_of(fac)
    bk: int32 = v_new_object()
    obj_set(fo, str_from_cstr(cast[Ptr[uint8]]("@s")), bk)
    obj_add_native(fac, cast[Ptr[uint8]]("getItem"), NAT_STORAGE_GET)
    obj_add_native(fac, cast[Ptr[uint8]]("setItem"), NAT_STORAGE_SET)
    obj_add_native(fac, cast[Ptr[uint8]]("removeItem"), NAT_STORAGE_REMOVE)
    obj_add_native(fac, cast[Ptr[uint8]]("clear"), NAT_STORAGE_CLEAR)
    obj_add_native(fac, cast[Ptr[uint8]]("key"), NAT_STORAGE_KEY)
    obj_set(fo, str_from_cstr(cast[Ptr[uint8]]("length")), v_number(0.0))
    return fac



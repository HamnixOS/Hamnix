# lib/web/js/builtins/promise.ad — part of the modular web engine (extracted from jsengine.ad).
# Promise/A+ state machine, microtask draining, then/catch/all/race.
#
# Behavior-preserving split: Adder is a single-compilation-unit language
# (merge_programs merges all imported files into one Program), so every
# public top-level name here resolves globally across the merged engine.


# ====================================================================
# PROMISE — Promise/A+ shaped. State machine pending -> fulfilled/rejected
# (settle-once). Reaction callbacks registered by .then run as MICROTASKS on
# the SAME #178 deferred-callback queue (drain_timers) — a settled promise
# enqueues a microtask job (g_promise_job) carrying the reaction record id; the
# drain runs all microtasks before any setTimeout macrotask, so chained .then
# callbacks fire in order and ahead of timers, matching node semantics. There
# is no wall-clock async: everything resolves during the end-of-script drain.
# ====================================================================

# Invoke a callable with zero / one positional arg via the call_args stack.
def invoke0(fnv: int32) -> int32:
    b: int32 = call_top
    r: int32 = invoke(fnv, v_undef(), b, 0)
    call_top = b
    return r


def invoke1(fnv: int32, a0: int32) -> int32:
    b: int32 = call_top
    call_args[call_top] = a0
    call_top = call_top + 1
    r: int32 = invoke(fnv, v_undef(), b, 1)
    call_top = b
    return r


# Allocate a fresh pending promise object, linked to Promise.prototype.
def new_promise() -> int32:
    h: int32 = v_new_object()
    o: int32 = objid_of(h)
    obj_is_prom[o] = cast[uint8](1)
    prom_state[o] = cast[uint8](0)
    prom_result[o] = v_undef()
    prom_react[o] = -1
    prom_alreadyres[o] = cast[uint8](0)
    if tag_of(g_promise_proto) == TAG_OBJ:
        obj_proto[o] = objid_of(g_promise_proto)
    return h


def is_promise(v: int32) -> int32:
    if tag_of(v) != TAG_OBJ:
        return 0
    return cast[int32](obj_is_prom[objid_of(v)])


# Enqueue a reaction record as a microtask on the #178 queue.
def schedule_reaction(rid: int32):
    if timer_next >= TIMER_CAP:
        return
    reg: int32 = timer_next
    timer_next = timer_next + 1
    timer_fn[reg] = g_promise_job
    timer_delay[reg] = 0.0
    timer_seq[reg] = timer_seq_ctr
    timer_seq_ctr = timer_seq_ctr + 1
    timer_active[reg] = cast[uint8](1)
    timer_interval[reg] = cast[uint8](0)
    timer_micro[reg] = cast[uint8](1)
    timer_argc[reg] = 1
    timer_args[reg * TIMER_MAX_ARGS + 0] = v_number(cast[float64](rid))


# Low-level settle primitives (guarded by state==pending). On settle, every
# queued reaction becomes a microtask, in registration (FIFO) order.
def promise_fulfill(o: int32, val: int32):
    if cast[int32](prom_state[o]) != 0:
        return
    prom_state[o] = cast[uint8](1)
    prom_result[o] = val
    r: int32 = prom_react[o]
    while r >= 0:
        schedule_reaction(r)
        r = pr_next[r]
    prom_react[o] = -1


def promise_reject(o: int32, reason: int32):
    if cast[int32](prom_state[o]) != 0:
        return
    prom_state[o] = cast[uint8](2)
    prom_result[o] = reason
    r: int32 = prom_react[o]
    while r >= 0:
        schedule_reaction(r)
        r = pr_next[r]
    prom_react[o] = -1


# The [[Resolve]](promise, x) resolution procedure: assimilate a thenable /
# promise, else fulfill. Settle-once is enforced at the state level by
# promise_fulfill/promise_reject; the guard against a misbehaving thenable
# calling back twice lives on the resolver CLOSURE pair (res_flag), NOT here —
# so the inner adoption resolver can still settle `o` after this returns.
def resolve_promise(o: int32, x: int32):
    if tag_of(x) == TAG_OBJ and objid_of(x) == o:
        promise_reject(o, make_type_error(cast[Ptr[uint8]]("Chaining cycle detected")))
        return
    if tag_of(x) == TAG_OBJ:
        # thenable? (a native promise's prototype .then also qualifies, so our
        # own promises are adopted through this same path)
        thenv: int32 = member_get(x, str_from_cstr(cast[Ptr[uint8]]("then")))
        if is_callable(thenv) != 0:
            slot: int32 = alloc_res_flag()
            resfn: int32 = make_resolver(o, NAT_PROMISE_RESOLVE_FN, slot)
            rejfn: int32 = make_resolver(o, NAT_PROMISE_REJECT_FN, slot)
            b: int32 = call_top
            call_args[call_top] = resfn
            call_args[call_top + 1] = rejfn
            call_top = call_top + 2
            invoke(thenv, x, b, 2)
            call_top = b
            if ctl == CTL_THROW:
                reason: int32 = throw_val
                ctl = CTL_NONE
                if cast[int32](res_flag[slot]) == 0:
                    res_flag[slot] = cast[uint8](1)
                    promise_reject(o, reason)
            return
    # not a thenable: fulfill with x
    promise_fulfill(o, x)


def alloc_res_flag() -> int32:
    s: int32 = res_flag_n
    res_flag_n = res_flag_n + 1
    res_flag[s] = cast[uint8](0)
    return s


# Create a resolve/reject closure bound to promise `o`, sharing flag cell `slot`
# with its partner so only the first of the pair to fire wins.
def make_resolver(o: int32, nat: int32, slot: int32) -> int32:
    fv: int32 = v_new_native(nat)
    obj_p_a[objid_of(fv)] = o
    obj_p_b[objid_of(fv)] = slot
    return fv


# Run one settled reaction (the microtask body). rid indexes the reaction pool;
# the source promise is already settled, so read its state + value now.
def run_reaction(rid: int32):
    src: int32 = pr_source[rid]
    st: int32 = cast[int32](prom_state[src])
    val: int32 = prom_result[src]
    result: int32 = pr_result[rid]
    ro: int32 = objid_of(result)
    handler: int32 = -1
    if st == 1:
        handler = pr_onful[rid]
    else:
        handler = pr_onrej[rid]
    if is_callable(handler) == 0:
        # no handler: pass the settled value/reason straight through.
        if st == 1:
            resolve_promise(ro, val)
        else:
            promise_reject(ro, val)
        return
    res: int32 = invoke1(handler, val)
    if ctl == CTL_THROW:
        reason: int32 = throw_val
        ctl = CTL_NONE
        promise_reject(ro, reason)
        return
    resolve_promise(ro, res)     # assimilate a returned promise/thenable


# Register a reaction on `src_val` (a promise) and return the dependent promise.
# onful/onrej are handler values (or a non-callable => pass through).
def promise_then(src_val: int32, onful: int32, onrej: int32) -> int32:
    result: int32 = new_promise()
    if is_promise(src_val) == 0:
        return result             # non-promise receiver: never settles
    o: int32 = objid_of(src_val)
    if pr_n >= PROM_REACT_CAP:
        return result
    rid: int32 = pr_n
    pr_n = pr_n + 1
    pr_onful[rid] = onful
    pr_onrej[rid] = onrej
    pr_result[rid] = result
    pr_source[rid] = o
    pr_next[rid] = -1
    st: int32 = cast[int32](prom_state[o])
    if st == 0:
        # pending: append at the TAIL so reactions fire in registration order.
        if prom_react[o] < 0:
            prom_react[o] = rid
        else:
            t: int32 = prom_react[o]
            while pr_next[t] >= 0:
                t = pr_next[t]
            pr_next[t] = rid
    else:
        # already settled: schedule immediately as a microtask.
        schedule_reaction(rid)
    return result


# Promise.resolve(v): pass a native promise through unchanged; otherwise wrap
# (assimilating a thenable).
def promise_resolve_static(v: int32) -> int32:
    if is_promise(v) != 0:
        return v
    p: int32 = new_promise()
    resolve_promise(objid_of(p), v)
    return p


def promise_reject_static(r: int32) -> int32:
    p: int32 = new_promise()
    promise_reject(objid_of(p), r)
    return p


# ---- async/await runtime ----------------------------------------------------
# `await expr`: resolve expr to a native promise (passing a promise through,
# assimilating a thenable, or wrapping a plain value), DRAIN the deterministic
# microtask/timer queue until it settles, then either return its fulfilled
# value or re-throw its rejection reason (so a surrounding try/catch sees it).
# This leans on the engine's deterministic drain instead of suspending the call
# stack — correct for the overwhelmingly-common real-page await patterns.
def do_await(v: int32) -> int32:
    p: int32 = promise_resolve_static(v)   # promise passthrough / thenable adopt / value wrap
    po: int32 = objid_of(p)
    drain_until_settled(po)
    st: int32 = cast[int32](prom_state[po])
    if st == 1:
        return prom_result[po]             # fulfilled -> the value
    if st == 2:
        # rejected -> throw the reason (unless a foreign task already faulted)
        if ctl != CTL_THROW and err_flag == 0:
            throw_val = prom_result[po]
            ctl = CTL_THROW
        return v_undef()
    # never settled in the deterministic model (e.g. a promise that only a real
    # external event could resolve): yield undefined rather than hang.
    return v_undef()


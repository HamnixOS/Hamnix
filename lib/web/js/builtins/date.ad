# lib/web/js/builtins/date.ad — part of the modular web engine (extracted from jsengine.ad).
# Date — UTC-based, monotonic Date.now cursor, get/set field accessors.
#
# Behavior-preserving split: Adder is a single-compilation-unit language
# (merge_programs merges all imported files into one Program), so every
# public top-level name here resolves globally across the merged engine.


# ====================================================================
# DATE — UTC-based. All get* accessors return UTC fields (getUTC* aliases are
# registered to the same natives). Civil<->days conversion uses Howard
# Hinnant's exact days_from_civil / civil_from_days algorithm (no 365.25
# approximation), so leap years and century rules are correct across all years.
# The epoch-ms is stored out-of-band in obj_date_ms so it never enumerates.
# There is no wall-clock source in this extern-free engine, so Date.now() /
# new Date() return a MONOTONIC COUNTER (seeded near a 2020 epoch) — plausible
# and strictly increasing, but NOT real wall-clock. Explicit-ms and
# component constructors are exact and are what the gate asserts.
# ====================================================================
date_mono: int64 = 1600000000000   # monotonic Date.now() cursor (~2020-09-13)

# decomposed UTC fields, filled by date_decompose()
dt_year:  int32 = 0
dt_month: int32 = 0                 # 1..12
dt_day:   int32 = 0                 # 1..31
dt_dow:   int32 = 0                 # 0=Sun .. 6=Sat
dt_hour:  int32 = 0
dt_min:   int32 = 0
dt_sec:   int32 = 0
dt_msf:   int32 = 0                 # milliseconds 0..999

# floor division for b > 0 (Adder integer div truncates toward zero)
def date_fdiv(a: int64, b: int64) -> int64:
    q: int64 = a / b
    r: int64 = a - q * b
    if r < 0:
        q = q - 1
    return q


# Howard Hinnant civil_from_days: z = days since 1970-01-01 -> fills dt_year,
# dt_month (1..12), dt_day (1..31).
def date_civil_from_days(z: int64):
    zz: int64 = z + cast[int64](719468)
    era: int64 = 0
    if zz >= 0:
        era = zz / cast[int64](146097)
    else:
        era = (zz - cast[int64](146096)) / cast[int64](146097)
    doe: int64 = zz - era * cast[int64](146097)                     # [0, 146096]
    yoe: int64 = (doe - doe / cast[int64](1460) + doe / cast[int64](36524) - doe / cast[int64](146096)) / cast[int64](365)
    y: int64 = yoe + era * cast[int64](400)
    doy: int64 = doe - (cast[int64](365) * yoe + yoe / cast[int64](4) - yoe / cast[int64](100))  # [0, 365]
    mp: int64 = (cast[int64](5) * doy + cast[int64](2)) / cast[int64](153)                        # [0, 11]
    d: int64 = doy - (cast[int64](153) * mp + cast[int64](2)) / cast[int64](5) + cast[int64](1)    # [1, 31]
    m: int64 = mp + cast[int64](3)
    if mp >= 10:
        m = mp - cast[int64](9)
    if m <= 2:
        y = y + 1
    dt_year = cast[int32](y)
    dt_month = cast[int32](m)
    dt_day = cast[int32](d)


# Howard Hinnant days_from_civil: (year, month 1..12, day) -> days since epoch.
def date_days_from_civil(y: int64, m: int64, d: int64) -> int64:
    yy: int64 = y
    if m <= 2:
        yy = yy - 1
    era: int64 = 0
    if yy >= 0:
        era = yy / cast[int64](400)
    else:
        era = (yy - cast[int64](399)) / cast[int64](400)
    yoe: int64 = yy - era * cast[int64](400)                        # [0, 399]
    mp: int64 = m - cast[int64](3)
    if m <= 2:
        mp = m + cast[int64](9)
    doy: int64 = (cast[int64](153) * mp + cast[int64](2)) / cast[int64](5) + d - cast[int64](1)   # [0, 365]
    doe: int64 = yoe * cast[int64](365) + yoe / cast[int64](4) - yoe / cast[int64](100) + doy      # [0, 146096]
    return era * cast[int64](146097) + doe - cast[int64](719468)


# split epoch-ms into dt_* UTC fields
def date_decompose(msf: float64):
    ms: int64 = cast[int64](msf)
    day_ms: int64 = cast[int64](86400000)
    days: int64 = date_fdiv(ms, day_ms)
    tod: int64 = ms - days * day_ms                # [0, 86399999]
    dt_msf = cast[int32](tod % cast[int64](1000))
    s: int64 = tod / cast[int64](1000)
    dt_sec = cast[int32](s % cast[int64](60))
    mn: int64 = s / cast[int64](60)
    dt_min = cast[int32](mn % cast[int64](60))
    dt_hour = cast[int32](mn / cast[int64](60))
    # 1970-01-01 was a Thursday (4). Normalize into 0..6.
    w: int64 = (cast[int64](4) + days % cast[int64](7)) % cast[int64](7)
    if w < 0:
        w = w + cast[int64](7)
    dt_dow = cast[int32](w)
    date_civil_from_days(days)


# epoch-ms of the Date instance `thisv` (0 if not a date)
def date_ms_of(thisv: int32) -> float64:
    if tag_of(thisv) != TAG_OBJ:
        return 0.0
    return obj_date_ms[objid_of(thisv)]


def date_now_ms() -> float64:
    v: float64 = cast[float64](date_mono)
    date_mono = date_mono + 1
    return v


# emit a non-negative integer zero-padded to `width` digits
def date_emit_pad(v: int32, width: int32):
    digs: Array[16, uint8]
    n: int32 = 0
    vv: int32 = v
    if vv == 0:
        digs[0] = cast[uint8](48)
        n = 1
    else:
        while vv > 0:
            digs[n] = cast[uint8](vv % 10) + cast[uint8](48)
            vv = vv / 10
            n = n + 1
    pad: int32 = width - n
    while pad > 0:
        emit_c(cast[uint8](48))
        pad = pad - 1
    while n > 0:
        n = n - 1
        emit_c(digs[n])


# emit "YYYY-MM-DDTHH:MM:SS.sssZ" into the CURRENT emit target (build-safe: no
# nested bld_begin/bld_end, so it can run inside an outer string build such as
# JSON serialization). Caller must have run date_decompose(msf) already OR use
# date_iso_strid below.
def date_emit_iso_fields():
    date_emit_pad(dt_year, 4)
    emit_c(cast[uint8](45))              # '-'
    date_emit_pad(dt_month, 2)
    emit_c(cast[uint8](45))
    date_emit_pad(dt_day, 2)
    emit_c(cast[uint8](84))              # 'T'
    date_emit_pad(dt_hour, 2)
    emit_c(cast[uint8](58))              # ':'
    date_emit_pad(dt_min, 2)
    emit_c(cast[uint8](58))
    date_emit_pad(dt_sec, 2)
    emit_c(cast[uint8](46))              # '.'
    date_emit_pad(dt_msf, 3)
    emit_c(cast[uint8](90))              # 'Z'


# emit a JSON-quoted ISO string for `msf` into the current build (used by
# json_emit so Date.prototype.toJSON is honored on the fast path, build-safely).
def date_emit_json_iso(msf: float64):
    date_decompose(msf)
    emit_c(cast[uint8](34))              # '"'
    date_emit_iso_fields()
    emit_c(cast[uint8](34))


# build "YYYY-MM-DDTHH:MM:SS.sssZ" as a fresh string id
def date_iso_strid(msf: float64) -> int32:
    date_decompose(msf)
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    date_emit_iso_fields()
    id: int32 = bld_end()
    emit_tgt = save
    return id


# emit the toString / display form: "YYYY-MM-DD HH:MM:SS UTC"
def date_emit_string(msf: float64):
    date_decompose(msf)
    date_emit_pad(dt_year, 4)
    emit_c(cast[uint8](45))
    date_emit_pad(dt_month, 2)
    emit_c(cast[uint8](45))
    date_emit_pad(dt_day, 2)
    emit_c(cast[uint8](32))              # ' '
    date_emit_pad(dt_hour, 2)
    emit_c(cast[uint8](58))
    date_emit_pad(dt_min, 2)
    emit_c(cast[uint8](58))
    date_emit_pad(dt_sec, 2)
    emit_cstr(cast[Ptr[uint8]](" UTC"))


def date_string_strid(msf: float64) -> int32:
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    date_emit_string(msf)
    id: int32 = bld_end()
    emit_tgt = save
    return id


# the Date constructor body: fill the fresh `this` object's epoch-ms
def date_construct(thisv: int32, base: int32, argc: int32) -> int32:
    if tag_of(thisv) != TAG_OBJ:
        # Date(...) called without `new` -> a string of "now"
        return v_string_id(date_string_strid(date_now_ms()))
    o: int32 = objid_of(thisv)
    obj_is_date[o] = cast[uint8](1)
    ms: float64 = 0.0
    if argc == 0:
        ms = date_now_ms()
    elif argc == 1:
        a0: int32 = call_args[base]
        if tag_of(a0) == TAG_OBJ and obj_is_date[objid_of(a0)] != cast[uint8](0):
            ms = obj_date_ms[objid_of(a0)]           # copy constructor
        elif tag_of(a0) == TAG_STR:
            ms = date_parse_iso(strid_of(a0))        # new Date("2021-01-01T…") — ISO parse
        else:
            ms = to_number(a0)                       # epoch-ms
    else:
        # new Date(y, monthIndex, day?, h?, m?, s?, ms?) — treated as UTC
        y: int64 = cast[int64](to_number(call_args[base]))
        moi: int64 = cast[int64](to_number(call_args[base + 1]))
        d: int64 = cast[int64](1)
        if argc > 2:
            d = cast[int64](to_number(call_args[base + 2]))
        hh: int64 = 0
        if argc > 3:
            hh = cast[int64](to_number(call_args[base + 3]))
        mm: int64 = 0
        if argc > 4:
            mm = cast[int64](to_number(call_args[base + 4]))
        ss: int64 = 0
        if argc > 5:
            ss = cast[int64](to_number(call_args[base + 5]))
        msc: int64 = 0
        if argc > 6:
            msc = cast[int64](to_number(call_args[base + 6]))
        # normalize month index (may be out of 0..11) into year + month
        yadj: int64 = date_fdiv(moi, cast[int64](12))
        moi = moi - yadj * cast[int64](12)           # [0, 11]
        y = y + yadj
        days: int64 = date_days_from_civil(y, moi + cast[int64](1), d)
        ms = cast[float64](days * cast[int64](86400000) + hh * cast[int64](3600000) + mm * cast[int64](60000) + ss * cast[int64](1000) + msc)
    obj_date_ms[o] = ms
    return v_undef()


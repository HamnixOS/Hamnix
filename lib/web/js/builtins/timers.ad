# lib/web/js/builtins/timers.ad — part of the modular web engine (extracted from jsengine.ad).
# deferred-callback task queue: setTimeout/setInterval/clearTimeout/queueMicrotask + the run loop.
#
# Behavior-preserving split: Adder is a single-compilation-unit language
# (merge_programs merges all imported files into one Program), so every
# public top-level name here resolves globally across the merged engine.


# ====================================================================
# Deferred-callback task queue (setTimeout/setInterval/queueMicrotask).
# ====================================================================
# Register one pending callback. `base`/`argc` are the native call frame:
# arg0 = callback, arg1 = delay (skipped for microtasks), rest = captured args.
# Returns the numeric timer id (reg+1) — non-zero + monotonic while allocating.
def timer_schedule(base: int32, argc: int32, is_interval: int32, is_micro: int32) -> int32:
    if timer_next >= TIMER_CAP:
        return v_number(0.0)                # table full — drop silently
    reg: int32 = timer_next
    timer_next = timer_next + 1
    fnv: int32 = v_undef()
    if argc > 0:
        fnv = call_args[base]
    dl: float64 = 0.0
    argstart: int32 = 2                      # setTimeout(fn, delay, ...args)
    if is_micro != 0:
        argstart = 1                         # queueMicrotask(fn, ...args)
    else:
        if argc > 1:
            dl = to_number(call_args[base + 1])
            if is_nan(dl) != 0:
                dl = 0.0
    timer_fn[reg] = fnv
    timer_delay[reg] = dl
    timer_seq[reg] = timer_seq_ctr
    timer_seq_ctr = timer_seq_ctr + 1
    timer_active[reg] = cast[uint8](1)
    timer_interval[reg] = cast[uint8](is_interval)
    timer_micro[reg] = cast[uint8](is_micro)
    timer_raf[reg] = cast[uint8](0)
    na: int32 = argc - argstart
    if na < 0:
        na = 0
    if na > TIMER_MAX_ARGS:
        na = TIMER_MAX_ARGS
    timer_argc[reg] = na
    i: int32 = 0
    while i < na:
        timer_args[reg * TIMER_MAX_ARGS + i] = call_args[base + argstart + i]
        i = i + 1
    return v_number(cast[float64](reg + 1))


# clearTimeout(id) / clearInterval(id): cancel a pending registration by id.
def timer_clear(idval: int32):
    idn: int32 = cast[int32](to_number(idval))
    reg: int32 = idn - 1
    if reg >= 0 and reg < timer_next:
        timer_active[reg] = cast[uint8](0)


# requestAnimationFrame(cb): register a one-shot frame callback on the shared
# timer table (timer_raf=1). Its ordering "delay" is the virtual timestamp of
# the frame it enqueues into — (raf_sched_gen+1)*FRAME_MS_VC — so it drains as a
# macrotask AFTER any pending microtasks and after earlier-timestamp timers. The
# callback receives that timestamp (a simulated DOMHighResTimeStamp) at fire
# time. Returns the numeric request id (reg+1); cancelAnimationFrame reuses
# timer_clear. NOT wall-clock — the frame counter IS the clock.
def raf_schedule(base: int32, argc: int32) -> int32:
    if timer_next >= TIMER_CAP:
        return v_number(0.0)                # table full — drop silently
    reg: int32 = timer_next
    timer_next = timer_next + 1
    fnv: int32 = v_undef()
    if argc > 0:
        fnv = call_args[base]
    timer_fn[reg] = fnv
    timer_delay[reg] = cast[float64](raf_sched_gen + 1) * FRAME_MS_VC
    timer_seq[reg] = timer_seq_ctr
    timer_seq_ctr = timer_seq_ctr + 1
    timer_active[reg] = cast[uint8](1)
    timer_interval[reg] = cast[uint8](0)
    timer_micro[reg] = cast[uint8](0)
    timer_raf[reg] = cast[uint8](1)
    timer_argc[reg] = 0                      # timestamp is injected at fire time
    return v_number(cast[float64](reg + 1))


# Drain the task queue: pop due callbacks in (microtask-first, delay, insertion)
# order and invoke them, capped at TIMER_DRAIN_CAP total invocations so a
# self-re-enqueuing setInterval cannot spin forever. NOT wall-clock async.
# Pop and run ONE due callback (microtask-first, then delay, then insertion).
# Returns 1 if a task ran, 0 if the queue was empty. Shared by drain_timers
# (the end-of-turn drain) and drain_until_settled (the await drain) so both use
# the exact same ordering and re-arm logic.
def run_one_task() -> int32:
    best: int32 = -1
    best_micro: int32 = 0
    i: int32 = 0
    while i < timer_next:
        if cast[int32](timer_active[i]) != 0:
            cm: int32 = cast[int32](timer_micro[i])
            take: int32 = 0
            if best < 0:
                take = 1
            else:
                if cm > best_micro:
                    take = 1
                else:
                    if cm == best_micro:
                        if cm != 0:
                            if timer_seq[i] < timer_seq[best]:
                                take = 1
                        else:
                            if timer_delay[i] < timer_delay[best]:
                                take = 1
                            else:
                                if timer_delay[i] == timer_delay[best] and timer_seq[i] < timer_seq[best]:
                                    take = 1
            if take != 0:
                best = i
                best_micro = cm
        i = i + 1
    if best < 0:
        return 0
    reg: int32 = best
    # A requestAnimationFrame callback: the moment the FIRST callback of the
    # current pending frame fires, bump raf_sched_gen so any rAF scheduled from
    # inside a frame callback lands in the NEXT frame (not this one — that would
    # spin the animation loop within a single drain). Callbacks already queued
    # for this frame share its delay and still fire before the bumped frame.
    if cast[int32](timer_raf[reg]) != 0:
        pending: float64 = cast[float64](raf_sched_gen + 1) * FRAME_MS_VC
        if timer_delay[reg] == pending:
            raf_sched_gen = raf_sched_gen + 1
    fnv: int32 = timer_fn[reg]
    if is_callable(fnv) != 0:
        b: int32 = call_top
        na: int32 = timer_argc[reg]
        if cast[int32](timer_raf[reg]) != 0:
            # hand the callback the frame's virtual DOMHighResTimeStamp.
            call_args[call_top] = v_number(timer_delay[reg])
            call_top = call_top + 1
            na = 1
        else:
            j: int32 = 0
            while j < na:
                call_args[call_top] = timer_args[reg * TIMER_MAX_ARGS + j]
                call_top = call_top + 1
                j = j + 1
        invoke(fnv, v_undef(), b, na)
        call_top = b
    # re-arm intervals / retire one-shots — but only if not cancelled by the
    # callback itself (clearInterval(id) inside the handler flips active=0).
    if cast[int32](timer_active[reg]) != 0:
        if cast[int32](timer_interval[reg]) != 0:
            timer_seq[reg] = timer_seq_ctr    # to the back among equal delays
            timer_seq_ctr = timer_seq_ctr + 1
        else:
            timer_active[reg] = cast[uint8](0)
    return 1


# Drain the queue until the promise `po` (object id) settles, or the queue is
# empty, capped like the end-of-turn drain. This is the engine of `await`: the
# deterministic microtask/timer drain stands in for suspending the call stack.
def drain_until_settled(po: int32):
    count: int32 = 0
    while count < TIMER_DRAIN_CAP:
        if cast[int32](prom_state[po]) != 0:
            break
        if run_one_task() == 0:
            break
        count = count + 1
        # an uncaught throw from an unrelated task ends the turn (rare; a promise
        # reaction converts its own throw into a rejection and never leaks CTL_THROW).
        if ctl == CTL_THROW or err_flag != 0:
            break


# End-of-turn drain toggle. Default ON. A host/front-end may flip it OFF (via
# js_set_drain(0)) to observe the PRE-drain DOM — used by the browser dynamic-
# page gate as a CONTROL: with the drain disabled, a Promise/setTimeout/fetch
# callback's DOM mutation never runs, so the page still shows its synchronous
# placeholder. NOT reset by js_init(), so a caller can set it once before the
# page pipeline runs and have it persist across he_layout()'s internal js_init.
drain_enabled: int32 = 1


def js_set_drain(on: int32):
    drain_enabled = on


def drain_timers():
    count: int32 = 0
    while count < TIMER_DRAIN_CAP:
        if run_one_task() == 0:
            break
        count = count + 1
        # a callback that threw stops the drain, like a host runtime's turn.
        if ctl == CTL_THROW or err_flag != 0:
            break


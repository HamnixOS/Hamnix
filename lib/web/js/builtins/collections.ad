# lib/web/js/builtins/collections.ad — part of the modular web engine (extracted from jsengine.ad).
# Map / Set — ES2015 keyed collections with insertion-order iteration.
#
# Behavior-preserving split: Adder is a single-compilation-unit language
# (merge_programs merges all imported files into one Program), so every
# public top-level name here resolves globally across the merged engine.

# ====================================================================
# Map / Set — ES2015 keyed collections with insertion-order iteration and
# SameValueZero key equality.
# ====================================================================
def ms_samevaluezero(a: int32, b: int32) -> int32:
    # === plus (NaN, NaN) -> equal, which is the Map/Set key equality.
    if tag_of(a) == TAG_NUM and tag_of(b) == TAG_NUM:
        na: float64 = v_num[a]
        nb: float64 = v_num[b]
        if na != na and nb != nb:
            return 1
    return strict_eq(a, b)


def ms_find(o: int32, keyv: int32) -> int32:
    e: int32 = obj_ms_head[o]
    while e >= 0:
        if mse_used[e] != 0 and ms_samevaluezero(mse_key[e], keyv) != 0:
            return e
        e = mse_next[e]
    return -1


def ms_put(o: int32, keyv: int32, valv: int32):
    e: int32 = ms_find(o, keyv)
    if e >= 0:
        mse_val[e] = valv
        return
    if mse_n >= MS_CAP:
        return                         # pool exhausted: drop silently (bounded)
    idx: int32 = mse_n
    mse_n = mse_n + 1
    mse_key[idx] = keyv
    mse_val[idx] = valv
    mse_used[idx] = cast[uint8](1)
    mse_next[idx] = -1
    if obj_ms_head[o] < 0:
        obj_ms_head[o] = idx
    else:
        mse_next[obj_ms_tail[o]] = idx
    obj_ms_tail[o] = idx
    obj_ms_size[o] = obj_ms_size[o] + 1


def ms_delete(o: int32, keyv: int32) -> int32:
    e: int32 = ms_find(o, keyv)
    if e < 0:
        return 0
    mse_used[e] = cast[uint8](0)
    obj_ms_size[o] = obj_ms_size[o] - 1
    return 1


def ms_clear(o: int32):
    obj_ms_head[o] = -1
    obj_ms_tail[o] = -1
    obj_ms_size[o] = 0


# Seed a Map/Set from an optional iterable argument (array or string).
def ms_init_from(o: int32, srcv: int32, is_map: int32):
    if tag_of(srcv) == TAG_UNDEF or tag_of(srcv) == TAG_NULL:
        return
    if is_array(srcv) != 0:
        so: int32 = objid_of(srcv)
        i: int32 = 0
        while i < arr_len[so]:
            elv: int32 = arr_get(so, i)
            if is_map != 0:
                kk: int32 = v_undef()
                vv: int32 = v_undef()
                if is_array(elv) != 0:
                    eo: int32 = objid_of(elv)
                    if arr_len[eo] >= 1:
                        kk = arr_get(eo, 0)
                    if arr_len[eo] >= 2:
                        vv = arr_get(eo, 1)
                ms_put(o, kk, vv)
            else:
                ms_put(o, elv, elv)
            i = i + 1
    elif tag_of(srcv) == TAG_STR and is_map == 0:
        sid: int32 = strid_of(srcv)
        j: int32 = 0
        while j < str_len(sid):
            ch: int32 = v_string_bytes(&sp_buf[st_off[sid] + j], 1)
            ms_put(o, ch, ch)
            j = j + 1
    elif tag_of(srcv) == TAG_OBJ:
        # any other iterable (Map/Set/generator/[Symbol.iterator] object):
        # materialize its values, then ingest as the array case does.
        tmp: int32 = v_new_array()
        to: int32 = objid_of(tmp)
        if collect_iterable_into(srcv, to) == 0:
            ms_init_from(o, tmp, is_map)


# keys/values/entries snapshots (returned as arrays: for-of / forEach friendly).
def ms_snapshot(o: int32, which: int32) -> int32:
    # which: 0 keys, 1 values, 2 entries
    av: int32 = v_new_array()
    ao: int32 = objid_of(av)
    e: int32 = obj_ms_head[o]
    while e >= 0:
        if mse_used[e] != 0:
            if which == 0:
                arr_push(ao, mse_key[e])
            elif which == 1:
                arr_push(ao, mse_val[e])
            else:
                pv: int32 = v_new_array()
                po: int32 = objid_of(pv)
                arr_push(po, mse_key[e])
                arr_push(po, mse_val[e])
                arr_push(ao, pv)
        e = mse_next[e]
    return av


def ms_foreach(o: int32, cb: int32, this_arg: int32, coll: int32):
    e: int32 = obj_ms_head[o]
    while e >= 0:
        if mse_used[e] != 0 and ctl == CTL_NONE:
            nb: int32 = call_top
            # callback(value, key, collection)
            call_args[call_top] = mse_val[e]
            call_args[call_top + 1] = mse_key[e]
            call_args[call_top + 2] = coll
            call_top = call_top + 3
            ignore_fe: int32 = invoke(cb, this_arg, nb, 3)
            call_top = nb
        e = mse_next[e]


def call_native(id: int32, thisv: int32, base: int32, argc: int32) -> int32:
    if id >= HOST_NATIVE_BASE:
        if host_dispatch_set != 0:
            # expose args + receiver for the host dispatcher via globals
            hostcall_base = base
            hostcall_argc = argc
            hostcall_this = thisv
            hf: Fn[int32, int32] = cast[Fn[int32, int32]](host_dispatch_addr)
            return hf(id)
        return v_undef()
    if id == NAT_FUNCTION_CTOR:
        # `Function` exists for identity/instanceof; building code from a string
        # is not supported by this engine — fail clearly rather than silently.
        throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("Function constructor (dynamic code) is not supported"))
        return v_undef()
    if id == NAT_CONSOLE_LOG:
        emit_tgt = 1
        i: int32 = 0
        while i < argc:
            if i > 0:
                emit_c(32)
            display_val(call_args[base + i])
            i = i + 1
        emit_c(10)
        return v_undef()
    if id == NAT_PARSEINT:
        return native_parseint(base, argc)
    if id == NAT_PARSEFLOAT:
        s: int32 = to_string_val(arg_or(base, argc, 0))
        return v_number(parse_num_bytes(str_ptr(strid_of(s)), str_len(strid_of(s))))
    if id == NAT_ISNAN:
        return v_boolv(is_nan(to_number(arg_or(base, argc, 0))))
    if id == NAT_STRING:
        if argc == 0:
            return v_string_cstr(cast[Ptr[uint8]](""))
        return to_string_val(call_args[base])
    if id == NAT_NUMBER:
        if argc == 0:
            return v_number(0.0)
        return v_number(to_number(call_args[base]))
    if id == NAT_BIGINT:
        if argc == 0:
            return v_bigint(bi_zero())
        return v_bigint(bi_from_value(call_args[base]))
    if id == NAT_BIGINT_ASINTN:
        bits_i: int32 = cast[int32](to_number(arg_or(base, argc, 0)))
        return v_bigint(bi_as_intn(bits_i, bi_from_value(arg_or(base, argc, 1))))
    if id == NAT_BIGINT_ASUINTN:
        bits_u: int32 = cast[int32](to_number(arg_or(base, argc, 0)))
        return v_bigint(bi_as_uintn(bits_u, bi_from_value(arg_or(base, argc, 1))))
    if id == NAT_BOOLEAN:
        return v_boolv(to_bool(arg_or(base, argc, 0)))
    if id == NAT_EVAL:
        return native_eval(arg_or(base, argc, 0))
    if id == NAT_MATH_FLOOR:
        return v_number(f_floor(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_CEIL:
        return v_number(f_ceil(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_ROUND:
        return v_number(f_floor(to_number(arg_or(base, argc, 0)) + 0.5))
    if id == NAT_MATH_ABS:
        return v_number(f_abs(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_SQRT:
        return v_number(f_sqrt(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_TRUNC:
        return v_number(f_trunc(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_POW:
        return v_number(f_pow(to_number(arg_or(base, argc, 0)), to_number(arg_or(base, argc, 1))))
    if id == NAT_MATH_MIN:
        return native_minmax(base, argc, 0)
    if id == NAT_MATH_MAX:
        return native_minmax(base, argc, 1)
    if id == NAT_MATH_SIGN:
        return v_number(f_sign(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_CBRT:
        return v_number(f_cbrt(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_HYPOT:
        return v_number(f_hypot(to_number(arg_or(base, argc, 0)), to_number(arg_or(base, argc, 1))))
    if id == NAT_MATH_LOG:
        return v_number(f_ln(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_LOG2:
        return v_number(f_ln(to_number(arg_or(base, argc, 0))) / 0.6931471805599453)
    if id == NAT_MATH_LOG10:
        return v_number(f_ln(to_number(arg_or(base, argc, 0))) / 2.302585092994046)
    if id == NAT_MATH_EXP:
        return v_number(f_exp(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_SIN:
        return v_number(f_sin(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_COS:
        return v_number(f_cos(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_TAN:
        tx: float64 = to_number(arg_or(base, argc, 0))
        return v_number(f_sin(tx) / f_cos(tx))
    if id == NAT_MATH_RANDOM:
        return v_number(f_random())
    if id == NAT_ISFINITE:
        fx: float64 = to_number(arg_or(base, argc, 0))
        if is_nan(fx) != 0 or is_inf(fx) != 0:
            return v_boolv(0)
        return v_boolv(1)
    if id == NAT_NUMBER_ISNAN:
        v0: int32 = arg_or(base, argc, 0)
        if tag_of(v0) != TAG_NUM:
            return v_boolv(0)
        return v_boolv(is_nan(v_num[v0]))
    if id == NAT_NUMBER_ISFINITE:
        v1: int32 = arg_or(base, argc, 0)
        if tag_of(v1) != TAG_NUM:
            return v_boolv(0)
        if is_nan(v_num[v1]) != 0 or is_inf(v_num[v1]) != 0:
            return v_boolv(0)
        return v_boolv(1)
    if id == NAT_NUMBER_ISINTEGER:
        v2: int32 = arg_or(base, argc, 0)
        if tag_of(v2) != TAG_NUM:
            return v_boolv(0)
        nx: float64 = v_num[v2]
        if is_nan(nx) != 0 or is_inf(nx) != 0:
            return v_boolv(0)
        if f_trunc(nx) == nx:
            return v_boolv(1)
        return v_boolv(0)
    if id == NAT_SET_TIMEOUT:
        return timer_schedule(base, argc, 0, 0)
    if id == NAT_SET_INTERVAL:
        return timer_schedule(base, argc, 1, 0)
    if id == NAT_CLEAR_TIMEOUT:
        timer_clear(arg_or(base, argc, 0))
        return v_undef()
    if id == NAT_CLEAR_INTERVAL:
        timer_clear(arg_or(base, argc, 0))
        return v_undef()
    if id == NAT_QUEUE_MICROTASK:
        return timer_schedule(base, argc, 0, 1)
    if id == NAT_REQUEST_ANIM_FRAME:
        return raf_schedule(base, argc)
    if id == NAT_CANCEL_ANIM_FRAME:
        timer_clear(arg_or(base, argc, 0))
        return v_undef()
    if id == NAT_PROMISE:
        pv: int32 = thisv
        if tag_of(pv) != TAG_OBJ:
            pv = new_promise()                      # lenient Promise(...) w/o new
        po: int32 = objid_of(pv)
        obj_is_prom[po] = cast[uint8](1)
        prom_state[po] = cast[uint8](0)
        prom_result[po] = v_undef()
        prom_react[po] = -1
        prom_alreadyres[po] = cast[uint8](0)
        if tag_of(g_promise_proto) == TAG_OBJ and obj_proto[po] < 0:
            obj_proto[po] = objid_of(g_promise_proto)
        execu: int32 = arg_or(base, argc, 0)
        if is_callable(execu) != 0:
            eslot: int32 = alloc_res_flag()
            resfn: int32 = make_resolver(po, NAT_PROMISE_RESOLVE_FN, eslot)
            rejfn: int32 = make_resolver(po, NAT_PROMISE_REJECT_FN, eslot)
            eb: int32 = call_top
            call_args[call_top] = resfn
            call_args[call_top + 1] = rejfn
            call_top = call_top + 2
            invoke(execu, v_undef(), eb, 2)
            call_top = eb
            if ctl == CTL_THROW:
                exr: int32 = throw_val
                ctl = CTL_NONE
                if cast[int32](res_flag[eslot]) == 0:
                    res_flag[eslot] = cast[uint8](1)
                    promise_reject(po, exr)
        return pv
    if id == NAT_PROMISE_RESOLVE_FN:
        rfo: int32 = native_self
        rslot: int32 = obj_p_b[rfo]
        if cast[int32](res_flag[rslot]) != 0:
            return v_undef()
        res_flag[rslot] = cast[uint8](1)
        resolve_promise(obj_p_a[rfo], arg_or(base, argc, 0))
        return v_undef()
    if id == NAT_PROMISE_REJECT_FN:
        jfo: int32 = native_self
        jslot: int32 = obj_p_b[jfo]
        if cast[int32](res_flag[jslot]) != 0:
            return v_undef()
        res_flag[jslot] = cast[uint8](1)
        promise_reject(obj_p_a[jfo], arg_or(base, argc, 0))
        return v_undef()
    if id == NAT_PROMISE_JOB:
        run_reaction(cast[int32](to_number(arg_or(base, argc, 0))))
        return v_undef()
    if id == NAT_PROMISE_RESOLVE:
        return promise_resolve_static(arg_or(base, argc, 0))
    if id == NAT_PROMISE_REJECT:
        return promise_reject_static(arg_or(base, argc, 0))
    if id == NAT_PROMISE_ALL:
        return promise_combinator(arg_or(base, argc, 0), 0)
    if id == NAT_PROMISE_RACE:
        return promise_combinator(arg_or(base, argc, 0), 1)
    if id == NAT_PROMISE_ALLSETTLED:
        return promise_combinator(arg_or(base, argc, 0), 2)
    if id == NAT_PROMISE_THEN:
        return promise_then(thisv, arg_or(base, argc, 0), arg_or(base, argc, 1))
    if id == NAT_PROMISE_CATCH:
        return promise_then(thisv, v_undef(), arg_or(base, argc, 0))
    if id == NAT_PROMISE_FINALLY:
        finfn: int32 = arg_or(base, argc, 0)
        fw: int32 = v_new_native(NAT_FINALLY_FUL)
        obj_p_a[objid_of(fw)] = finfn
        rw: int32 = v_new_native(NAT_FINALLY_REJ)
        obj_p_a[objid_of(rw)] = finfn
        return promise_then(thisv, fw, rw)
    if id == NAT_FINALLY_FUL:
        ffn: int32 = obj_p_a[native_self]
        fval: int32 = arg_or(base, argc, 0)
        if is_callable(ffn) != 0:
            invoke0(ffn)
            if ctl == CTL_THROW:
                return v_undef()             # finally cb threw -> that wins
        return fval
    if id == NAT_FINALLY_REJ:
        rfn: int32 = obj_p_a[native_self]
        rreason: int32 = arg_or(base, argc, 0)
        if is_callable(rfn) != 0:
            invoke0(rfn)
            if ctl == CTL_THROW:
                return v_undef()             # finally cb threw -> that wins
        ctl = CTL_THROW                       # otherwise re-throw the reason
        throw_val = rreason
        return v_undef()
    if id == NAT_FETCH:
        return do_fetch(base, argc)
    if id == NAT_SET_FETCH_FIXTURE:
        set_fetch_fixture(strid_of(to_string_val(arg_or(base, argc, 0))), arg_or(base, argc, 1))
        return v_undef()
    if id == NAT_RESPONSE_TEXT:
        return response_text(thisv)
    if id == NAT_RESPONSE_JSON:
        return response_json(thisv)
    if id == NAT_RESPONSE_ARRAYBUF:
        return response_arraybuffer(thisv)
    if id == NAT_HEADERS_GET:
        return headers_get(thisv, strid_of(to_string_val(arg_or(base, argc, 0))))
    if id == NAT_HEADERS_HAS:
        return headers_has(thisv, strid_of(to_string_val(arg_or(base, argc, 0))))
    if id == NAT_HEADERS_ENTRIES:
        return headers_entries(thisv)
    if id == NAT_STORAGE_GET:
        bk: int32 = storage_backing(thisv)
        ks: int32 = strid_of(to_string_val(arg_or(base, argc, 0)))
        gv: int32 = obj_get(bk, ks)
        if tag_of(gv) == TAG_UNDEF:
            return v_null()
        return gv
    if id == NAT_STORAGE_SET:
        bks: int32 = storage_backing(thisv)
        kss: int32 = strid_of(to_string_val(arg_or(base, argc, 0)))
        vs: int32 = to_string_val(arg_or(base, argc, 1))
        obj_set(bks, kss, vs)
        storage_sync_len(thisv, bks)
        return v_undef()
    if id == NAT_STORAGE_REMOVE:
        bkr: int32 = storage_backing(thisv)
        ksr: int32 = strid_of(to_string_val(arg_or(base, argc, 0)))
        obj_del_prop(bkr, ksr)
        storage_sync_len(thisv, bkr)
        return v_undef()
    if id == NAT_STORAGE_CLEAR:
        bkc: int32 = storage_backing(thisv)
        obj_head[bkc] = -1
        storage_sync_len(thisv, bkc)
        return v_undef()
    if id == NAT_STORAGE_KEY:
        bkk: int32 = storage_backing(thisv)
        nrq: int32 = cast[int32](to_number(arg_or(base, argc, 0)))
        # props chain is newest-first; index oldest-first to match insertion.
        cnt: int32 = storage_prop_count(bkk)
        if nrq < 0 or nrq >= cnt:
            return v_null()
        target: int32 = cnt - 1 - nrq
        p2: int32 = obj_head[bkk]
        idx2: int32 = 0
        while p2 >= 0:
            if idx2 == target:
                return v_string_id(p_key[p2])
            idx2 = idx2 + 1
            p2 = p_next[p2]
        return v_null()
    if id == NAT_COMB_FUL:
        comb_on_fulfilled(native_self, arg_or(base, argc, 0))
        return v_undef()
    if id == NAT_COMB_REJ:
        comb_on_rejected(native_self, arg_or(base, argc, 0))
        return v_undef()
    if id == NAT_MAP:
        mo: int32 = objid_of(thisv)
        obj_map_kind[mo] = cast[uint8](MAP_KIND_MAP)
        ms_init_from(mo, arg_or(base, argc, 0), 1)
        return v_undef()
    if id == NAT_SET:
        so2: int32 = objid_of(thisv)
        obj_map_kind[so2] = cast[uint8](MAP_KIND_SET)
        ms_init_from(so2, arg_or(base, argc, 0), 0)
        return v_undef()
    if id == NAT_MAP_GET:
        e0: int32 = ms_find(objid_of(thisv), arg_or(base, argc, 0))
        if e0 < 0:
            return v_undef()
        return mse_val[e0]
    if id == NAT_MAP_SET:
        ms_put(objid_of(thisv), arg_or(base, argc, 0), arg_or(base, argc, 1))
        return thisv                   # chainable
    if id == NAT_SET_ADD:
        va: int32 = arg_or(base, argc, 0)
        ms_put(objid_of(thisv), va, va)
        return thisv                   # chainable
    if id == NAT_MAP_HAS or id == NAT_SET_HAS:
        if ms_find(objid_of(thisv), arg_or(base, argc, 0)) >= 0:
            return v_boolv(1)
        return v_boolv(0)
    if id == NAT_MAP_DELETE or id == NAT_SET_DELETE:
        return v_boolv(ms_delete(objid_of(thisv), arg_or(base, argc, 0)))
    if id == NAT_MAP_CLEAR or id == NAT_SET_CLEAR:
        ms_clear(objid_of(thisv))
        return v_undef()
    if id == NAT_MAP_FOREACH or id == NAT_SET_FOREACH:
        cbv: int32 = arg_or(base, argc, 0)
        if is_callable(cbv) != 0:
            ms_foreach(objid_of(thisv), cbv, arg_or(base, argc, 1), thisv)
        return v_undef()
    if id == NAT_MAP_KEYS:
        return ms_snapshot(objid_of(thisv), 0)
    if id == NAT_MAP_VALUES or id == NAT_SET_VALUES:
        return ms_snapshot(objid_of(thisv), 1)
    if id == NAT_MAP_ENTRIES:
        return ms_snapshot(objid_of(thisv), 2)
    if id == NAT_OBJECT_CREATE:
        proto_arg: int32 = arg_or(base, argc, 0)
        newov: int32 = v_new_object()
        if tag_of(proto_arg) == TAG_OBJ:
            obj_proto[objid_of(newov)] = objid_of(proto_arg)
        return newov
    if id == NAT_OBJECT_GETPROTO:
        garg: int32 = arg_or(base, argc, 0)
        if tag_of(garg) == TAG_OBJ:
            pp0: int32 = obj_proto[objid_of(garg)]
            if pp0 >= 0:
                hh: int32 = mk_val(TAG_OBJ)
                v_ref[hh] = pp0
                return hh
        return v_null()
    if id == NAT_OBJECT_SETPROTO:
        sarg: int32 = arg_or(base, argc, 0)
        parg: int32 = arg_or(base, argc, 1)
        if tag_of(sarg) == TAG_OBJ:
            if tag_of(parg) == TAG_OBJ:
                obj_proto[objid_of(sarg)] = objid_of(parg)
            elif tag_of(parg) == TAG_NULL:
                obj_proto[objid_of(sarg)] = -1
        return sarg
    if id == NAT_OBJECT_GETOWNNAMES:
        return object_keys(arg_or(base, argc, 0))
    if id == NAT_OBJECT_ISFROZEN:
        farg: int32 = arg_or(base, argc, 0)
        if tag_of(farg) != TAG_OBJ:
            return v_boolv(1)          # primitives are frozen
        return v_boolv(cast[int32](obj_frozen[objid_of(farg)]))
    if id == NAT_OBJECT_DEFINEPROP:
        return object_define_property(arg_or(base, argc, 0), arg_or(base, argc, 1), arg_or(base, argc, 2))
    if id == NAT_OBJECT_DEFINEPROPS:
        return object_define_properties(arg_or(base, argc, 0), arg_or(base, argc, 1))
    if id == NAT_OBJECT_GETOWNDESC:
        return object_get_own_descriptor(arg_or(base, argc, 0), arg_or(base, argc, 1))
    if id == NAT_OBJECT_GETOWNDESCS:
        return object_get_own_descriptors(arg_or(base, argc, 0))
    if id == NAT_OBJECT_HASOWN:
        return object_has_own(arg_or(base, argc, 0), arg_or(base, argc, 1))
    if id == NAT_OBJECT_IS:
        return v_boolv(same_value(arg_or(base, argc, 0), arg_or(base, argc, 1)))
    if id == NAT_NUMBER_ISSAFEINT:
        nv: int32 = arg_or(base, argc, 0)
        if tag_of(nv) != TAG_NUM:
            return v_boolv(0)
        x: float64 = v_num[nv]
        if x != x:
            return v_boolv(0)
        if f_trunc(x) != x:
            return v_boolv(0)
        if x > 9007199254740991.0 or x < 0.0 - 9007199254740991.0:
            return v_boolv(0)
        return v_boolv(1)
    if id == NAT_ARRAY_FROM:
        return array_from(arg_or(base, argc, 0), arg_or(base, argc, 1), argc)
    if id == NAT_GEN_NEXT:
        return gen_native_next(thisv)
    if id == NAT_GEN_RETURN:
        return gen_native_return(thisv, arg_or(base, argc, 0))
    if id == NAT_GEN_THROW:
        return gen_native_throw(thisv, arg_or(base, argc, 0))
    if id == NAT_GEN_ITER:
        return thisv
    if id == NAT_DATE:
        return date_construct(thisv, base, argc)
    if id == NAT_DATE_NOW:
        return v_number(date_now_ms())
    if id == NAT_DATE_GETTIME or id == NAT_DATE_VALUEOF:
        return v_number(date_ms_of(thisv))
    if id == NAT_DATE_GETFULLYEAR:
        date_decompose(date_ms_of(thisv))
        return v_number(cast[float64](dt_year))
    if id == NAT_DATE_GETMONTH:
        date_decompose(date_ms_of(thisv))
        return v_number(cast[float64](dt_month - 1))     # 0-based
    if id == NAT_DATE_GETDATE:
        date_decompose(date_ms_of(thisv))
        return v_number(cast[float64](dt_day))
    if id == NAT_DATE_GETDAY:
        date_decompose(date_ms_of(thisv))
        return v_number(cast[float64](dt_dow))
    if id == NAT_DATE_GETHOURS:
        date_decompose(date_ms_of(thisv))
        return v_number(cast[float64](dt_hour))
    if id == NAT_DATE_GETMINUTES:
        date_decompose(date_ms_of(thisv))
        return v_number(cast[float64](dt_min))
    if id == NAT_DATE_GETSECONDS:
        date_decompose(date_ms_of(thisv))
        return v_number(cast[float64](dt_sec))
    if id == NAT_DATE_GETMS:
        date_decompose(date_ms_of(thisv))
        return v_number(cast[float64](dt_msf))
    if id == NAT_DATE_TOISO:
        return v_string_id(date_iso_strid(date_ms_of(thisv)))
    if id == NAT_DATE_TOSTRING:
        return v_string_id(date_string_strid(date_ms_of(thisv)))
    if id == NAT_OBJECT_ENTRIES:
        return object_entries(arg_or(base, argc, 0))
    if id == NAT_OBJECT_FROMENTRIES:
        return object_fromentries(arg_or(base, argc, 0))
    if id == NAT_OBJECT_FREEZE:
        frv: int32 = arg_or(base, argc, 0)
        if tag_of(frv) == TAG_OBJ:
            obj_frozen[objid_of(frv)] = cast[uint8](1)
        return frv
    if id == NAT_JSON_STRINGIFY:
        js_rep: int32 = arg_or(base, argc, 1)
        js_ind: int32 = json_indent_of(arg_or(base, argc, 2))
        # honor a function or array-allowlist replacer; the no-replacer path stays
        # on the fast direct emitter (behavior-identical to before).
        if is_callable(js_rep) != 0 or is_array(js_rep) != 0:
            return json_stringify_full(arg_or(base, argc, 0), js_rep, js_ind)
        return json_stringify(arg_or(base, argc, 0), js_ind)
    if id == NAT_JSON_PARSE:
        return json_parse_val(arg_or(base, argc, 0), arg_or(base, argc, 1))
    if id == NAT_OBJECT_KEYS:
        return object_keys(arg_or(base, argc, 0))
    if id == NAT_ARRAY_ISARRAY:
        return v_boolv(is_array(arg_or(base, argc, 0)))
    if id == NAT_ERROR or id == NAT_TYPEERROR or id == NAT_RANGEERROR or id == NAT_SYNTAXERROR or id == NAT_REFERENCEERROR:
        return make_error(id, thisv, base, argc)
    if id == NAT_OBJECT_ASSIGN:
        return object_assign(base, argc)
    if id == NAT_OBJECT_VALUES:
        return object_values(arg_or(base, argc, 0))
    if id == NAT_ARRAY_CTOR or id == NAT_ARRAY_OF:
        return array_ctor(id, base, argc)
    if id == NAT_REGEXP:
        pat: int32 = arg_or(base, argc, 0)
        src_sid: int32 = 0
        if is_regex(pat) != 0:
            src_sid = strid_of(obj_get_cstr(objid_of(pat), cast[Ptr[uint8]]("source")))
        elif tag_of(pat) == TAG_UNDEF:
            src_sid = str_from_cstr(cast[Ptr[uint8]](""))
        else:
            src_sid = strid_of(to_string_val(pat))
        flags_sid: int32 = str_from_cstr(cast[Ptr[uint8]](""))
        if argc > 1 and tag_of(call_args[base + 1]) != TAG_UNDEF:
            flags_sid = strid_of(to_string_val(call_args[base + 1]))
        elif is_regex(pat) != 0:
            flags_sid = strid_of(obj_get_cstr(objid_of(pat), cast[Ptr[uint8]]("flags")))
        return js_make_regex(src_sid, flags_sid)
    if id == NAT_SYMBOL:
        d: int32 = v_undef()
        if argc > 0 and tag_of(call_args[base]) != TAG_UNDEF:
            d = to_string_val(call_args[base])
        return v_new_symbol(d)
    if id == NAT_STRING_RAW:
        return string_raw(base, argc)
    if id == NAT_STRING_FROMCHARCODE:
        return string_fromcharcode(base, argc)
    if id == NAT_STRING_FROMCODEPOINT:
        return string_fromcharcode(base, argc)
    if id == NAT_REFLECT_GET:
        rt: int32 = arg_or(base, argc, 0)
        return member_get(rt, prop_key_of(arg_or(base, argc, 1)))
    if id == NAT_REFLECT_SET:
        st: int32 = arg_or(base, argc, 0)
        if tag_of(st) != TAG_OBJ:
            throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("Reflect.set called on non-object"))
            return v_boolv(0)
        member_set(st, prop_key_of(arg_or(base, argc, 1)), arg_or(base, argc, 2))
        return v_boolv(1)
    if id == NAT_REFLECT_HAS:
        return v_boolv(op_in(arg_or(base, argc, 1), arg_or(base, argc, 0)))
    if id == NAT_REFLECT_OWNKEYS:
        rk: int32 = arg_or(base, argc, 0)
        if tag_of(rk) != TAG_OBJ:
            throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("Reflect.ownKeys called on non-object"))
            return v_new_array()
        return object_keys(rk)
    if id == NAT_REFLECT_GETPROTO:
        rg: int32 = arg_or(base, argc, 0)
        if tag_of(rg) == TAG_OBJ:
            rgp: int32 = obj_proto[objid_of(rg)]
            if rgp >= 0:
                rgh: int32 = mk_val(TAG_OBJ)
                v_ref[rgh] = rgp
                return rgh
        return v_null()
    if id == NAT_REFLECT_SETPROTO:
        rs: int32 = arg_or(base, argc, 0)
        rsp: int32 = arg_or(base, argc, 1)
        if tag_of(rs) != TAG_OBJ:
            return v_boolv(0)
        if tag_of(rsp) == TAG_OBJ:
            obj_proto[objid_of(rs)] = objid_of(rsp)
        elif tag_of(rsp) == TAG_NULL:
            obj_proto[objid_of(rs)] = -1
        return v_boolv(1)
    if id == NAT_REFLECT_DEFINEPROP:
        rd: int32 = arg_or(base, argc, 0)
        if tag_of(rd) != TAG_OBJ:
            throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("Reflect.defineProperty called on non-object"))
            return v_boolv(0)
        object_define_property(rd, arg_or(base, argc, 1), arg_or(base, argc, 2))
        return v_boolv(1)
    if id == NAT_REFLECT_DELETEPROP:
        rdl: int32 = arg_or(base, argc, 0)
        if tag_of(rdl) != TAG_OBJ:
            return v_boolv(0)
        return v_boolv(obj_del_prop(objid_of(rdl), prop_key_of(arg_or(base, argc, 1))))
    if id == NAT_REFLECT_APPLY:
        return reflect_apply(arg_or(base, argc, 0), arg_or(base, argc, 1), arg_or(base, argc, 2))
    if id == NAT_REFLECT_CONSTRUCT:
        return reflect_construct(arg_or(base, argc, 0), arg_or(base, argc, 1))
    if id >= NAT_OP_METHOD and id <= NAT_BP_METHOD:
        return call_native_proto(id, thisv, base, argc)
    return call_native_r7(id, thisv, base, argc)


# ---- Reflect.apply / Reflect.construct: spread an args-list array + invoke ----
def reflect_apply(target: int32, thisarg: int32, argslist: int32) -> int32:
    if is_callable(target) == 0:
        throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("Reflect.apply target is not a function"))
        return v_undef()
    ab: int32 = call_top
    n: int32 = 0
    if is_array(argslist) != 0:
        ao: int32 = objid_of(argslist)
        i: int32 = 0
        while i < arr_len[ao]:
            call_args[call_top] = arr_get(ao, i)
            call_top = call_top + 1
            i = i + 1
        n = arr_len[ao]
    r: int32 = invoke(target, thisarg, ab, n)
    call_top = ab
    return r


def reflect_construct(target: int32, argslist: int32) -> int32:
    if is_callable(target) == 0:
        throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("Reflect.construct target is not a constructor"))
        return v_undef()
    self_obj: int32 = v_new_object()
    so: int32 = objid_of(self_obj)
    protov: int32 = obj_get(objid_of(target), str_from_cstr(cast[Ptr[uint8]]("prototype")))
    if tag_of(protov) == TAG_OBJ:
        obj_proto[so] = objid_of(protov)
    init_instance_fields(target, self_obj)
    ab: int32 = call_top
    n: int32 = 0
    if is_array(argslist) != 0:
        ao: int32 = objid_of(argslist)
        i: int32 = 0
        while i < arr_len[ao]:
            call_args[call_top] = arr_get(ao, i)
            call_top = call_top + 1
            i = i + 1
        n = arr_len[ao]
    r: int32 = run_constructor(target, self_obj, ab, n)
    call_top = ab
    if ctl == CTL_THROW:
        return v_undef()
    if tag_of(r) == TAG_OBJ:
        return r
    return self_obj


# String.raw(strings, ...subs): concatenate the RAW (verbatim, un-escape-cooked)
# template chunks interleaved with the stringified substitutions.
def string_raw(base: int32, argc: int32) -> int32:
    strings: int32 = arg_or(base, argc, 0)
    if tag_of(strings) != TAG_OBJ:
        return v_string_cstr(cast[Ptr[uint8]](""))
    raw: int32 = obj_get_cstr(objid_of(strings), cast[Ptr[uint8]]("raw"))
    if is_array(raw) == 0:
        raw = strings                    # spec falls back to ToObject(strings) list
    ro: int32 = objid_of(raw)
    n: int32 = arr_len[ro]
    # Pre-stringify every chunk + substitution FIRST — to_string_val allocates
    # into the string pool, which must not interleave with the result build.
    tbase: int32 = call_top
    i: int32 = 0
    while i < n:                          # raw chunk string values at tbase+i
        call_args[call_top] = to_string_val(arr_get(ro, i))
        call_top = call_top + 1
        i = i + 1
    j: int32 = 1
    while j < argc:                       # substitution string values at tbase+n+(j-1)
        call_args[call_top] = to_string_val(call_args[base + j])
        call_top = call_top + 1
        j = j + 1
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    k: int32 = 0
    while k < n:
        emit_strid(strid_of(call_args[tbase + k]))
        if k + 1 < n and k + 1 < argc:    # substitution k follows chunk k (except the last)
            emit_strid(strid_of(call_args[tbase + n + k]))
        k = k + 1
    rid: int32 = bld_end()
    emit_tgt = save
    call_top = tbase
    return v_string_id(rid)


# String.fromCharCode / fromCodePoint: build a string from numeric code units.
# The engine is byte-oriented; a code point < 256 becomes one byte, otherwise
# its low byte (sufficient for the ASCII/Latin-1 range these tests exercise).
def string_fromcharcode(base: int32, argc: int32) -> int32:
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    i: int32 = 0
    while i < argc:
        code: int32 = cast[int32](to_number(call_args[base + i]))
        emit_c(cast[uint8](code & 255))
        i = i + 1
    rid: int32 = bld_end()
    emit_tgt = save
    return v_string_id(rid)


def err_name_of(id: int32) -> Ptr[uint8]:
    if id == NAT_TYPEERROR:
        return cast[Ptr[uint8]]("TypeError")
    if id == NAT_RANGEERROR:
        return cast[Ptr[uint8]]("RangeError")
    if id == NAT_SYNTAXERROR:
        return cast[Ptr[uint8]]("SyntaxError")
    if id == NAT_REFERENCEERROR:
        return cast[Ptr[uint8]]("ReferenceError")
    return cast[Ptr[uint8]]("Error")


def make_error(id: int32, thisv: int32, base: int32, argc: int32) -> int32:
    ev: int32 = thisv
    if tag_of(ev) != TAG_OBJ:
        ev = v_new_object()             # allow `Error(...)` without `new`
    o: int32 = objid_of(ev)
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("name")), v_string_cstr(err_name_of(id)))
    msg: int32 = v_string_cstr(cast[Ptr[uint8]](""))
    if argc > 0:
        msg = to_string_val(call_args[base])
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("message")), msg)
    return ev


def object_assign(base: int32, argc: int32) -> int32:
    if argc == 0:
        return v_new_object()
    tgt: int32 = call_args[base]
    if tag_of(tgt) != TAG_OBJ:
        tgt = v_new_object()
    i: int32 = 1
    while i < argc:
        src: int32 = call_args[base + i]
        if tag_of(src) == TAG_OBJ:
            copy_own_props(objid_of(src), objid_of(tgt))
        i = i + 1
    return tgt


def object_values(v: int32) -> int32:
    ro: int32 = v_new_array()
    if tag_of(v) != TAG_OBJ:
        return ro
    o: int32 = objid_of(v)
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        i: int32 = 0
        while i < arr_len[o]:
            arr_push(objid_of(ro), arr_get(o, i))
            i = i + 1
        return ro
    object_values_rec(obj_head[o], objid_of(ro))
    return ro


def object_values_rec(p: int32, ro: int32):
    if p < 0:
        return
    object_values_rec(p_next[p], ro)
    arr_push(ro, p_val[p])


# Object.entries -> array of [key, value] pairs (insertion order).
def object_entries(v: int32) -> int32:
    res: int32 = v_new_array()
    ro: int32 = objid_of(res)
    if tag_of(v) != TAG_OBJ:
        return res
    o: int32 = objid_of(v)
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        i: int32 = 0
        while i < arr_len[o]:
            pair: int32 = v_new_array()
            arr_push(objid_of(pair), v_string_id(num_to_strid(cast[float64](i))))
            arr_push(objid_of(pair), arr_get(o, i))
            arr_push(ro, pair)
            i = i + 1
        return res
    object_entries_rec(obj_head[o], ro)
    return res


def object_entries_rec(p: int32, ro: int32):
    if p < 0:
        return
    object_entries_rec(p_next[p], ro)
    pair: int32 = v_new_array()
    arr_push(objid_of(pair), v_string_id(p_key[p]))
    arr_push(objid_of(pair), p_val[p])
    arr_push(ro, pair)


# Object.fromEntries([[k,v],...]) -> object.
def object_fromentries(v: int32) -> int32:
    res: int32 = v_new_object()
    if is_array(v) == 0:
        return res
    ro: int32 = objid_of(res)
    o: int32 = objid_of(v)
    i: int32 = 0
    while i < arr_len[o]:
        e: int32 = arr_get(o, i)
        if is_array(e) != 0:
            eo: int32 = objid_of(e)
            kv: int32 = v_undef()
            vv: int32 = v_undef()
            if arr_len[eo] > 0:
                kv = arr_get(eo, 0)
            if arr_len[eo] > 1:
                vv = arr_get(eo, 1)
            obj_set(ro, strid_of(to_string_val(kv)), vv)
        i = i + 1
    return res


def array_ctor(id: int32, base: int32, argc: int32) -> int32:
    av: int32 = v_new_array()
    o: int32 = objid_of(av)
    if id == NAT_ARRAY_CTOR and argc == 1 and tag_of(call_args[base]) == TAG_NUM:
        n: int32 = cast[int32](v_num[call_args[base]])
        i: int32 = 0
        while i < n:
            arr_push(o, v_undef())
            i = i + 1
        return av
    j: int32 = 0
    while j < argc:
        arr_push(o, call_args[base + j])
        j = j + 1
    return av


hostcall_base: int32 = 0
hostcall_argc: int32 = 0
hostcall_this: int32 = 0


def native_parseint(base: int32, argc: int32) -> int32:
    s: int32 = strid_of(to_string_val(arg_or(base, argc, 0)))
    p: Ptr[uint8] = str_ptr(s)
    n: int32 = str_len(s)
    i: int32 = 0
    while i < n and is_ws(p[i]) != 0:
        i = i + 1
    sign: float64 = 1.0
    if i < n and p[i] == 43:
        i = i + 1
    elif i < n and p[i] == 45:
        sign = -1.0
        i = i + 1
    radix: int32 = 10
    if argc > 1:
        radix = cast[int32](to_number(call_args[base + 1]))
        if radix == 0:
            radix = 10
    if radix == 16 and i + 1 < n and p[i] == 48 and (p[i + 1] == 120 or p[i + 1] == 88):
        i = i + 2
    elif i + 1 < n and p[i] == 48 and (p[i + 1] == 120 or p[i + 1] == 88):
        radix = 16
        i = i + 2
    val: float64 = 0.0
    any: int32 = 0
    while i < n:
        c: uint8 = p[i]
        d: int32 = -1
        if c >= 48 and c <= 57:
            d = cast[int32](c) - 48
        elif c >= 97 and c <= 122:
            d = cast[int32](c) - 87
        elif c >= 65 and c <= 90:
            d = cast[int32](c) - 55
        if d < 0 or d >= radix:
            break
        val = val * cast[float64](radix) + cast[float64](d)
        any = 1
        i = i + 1
    if any == 0:
        return v_number(0.0 / 0.0)
    return v_number(sign * val)


def native_minmax(base: int32, argc: int32, ismax: int32) -> int32:
    if argc == 0:
        if ismax != 0:
            return v_number(-1.0e309)   # -Infinity approx
        return v_number(1.0e309)
    r: float64 = to_number(call_args[base])
    i: int32 = 1
    while i < argc:
        x: float64 = to_number(call_args[base + i])
        if ismax != 0:
            if x > r:
                r = x
        else:
            if x < r:
                r = x
        i = i + 1
    return v_number(r)


def object_keys(v: int32) -> int32:
    res: int32 = v_new_array()
    ro: int32 = objid_of(res)
    if tag_of(v) != TAG_OBJ:
        return res
    o: int32 = objid_of(v)
    if obj_proxy_target[o] >= 0:       # Proxy: route through the ownKeys trap
        return proxy_own_keys(v)
    if cast[int32](obj_ta_kind[o]) != 0:   # typed array: keys are the indices
        ti: int32 = 0
        while ti < obj_ta_len[o]:
            arr_push(ro, v_string_id(num_to_strid(cast[float64](ti))))
            ti = ti + 1
        return res
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        i: int32 = 0
        while i < arr_len[o]:
            arr_push(ro, v_string_id(num_to_strid(cast[float64](i))))
            i = i + 1
        return res
    object_keys_rec(obj_head[o], ro)
    return res


def object_keys_rec(p: int32, ro: int32):
    if p < 0:
        return
    object_keys_rec(p_next[p], ro)
    if is_hidden_key(p_key[p]) != 0:
        return
    arr_push(ro, v_string_id(p_key[p]))


# Object.defineProperty(obj, key, descriptor). We honor a data descriptor's
# `value` (the common case); an accessor descriptor's `get` is invoked once to
# seed the value (no live getter storage — a pragmatic approximation).
def object_define_property(objv: int32, keyv: int32, descv: int32) -> int32:
    if tag_of(objv) != TAG_OBJ:
        throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("Object.defineProperty called on non-object"))
        return objv
    o: int32 = objid_of(objv)
    key_sid: int32 = strid_of(to_string_val(keyv))
    val: int32 = v_undef()
    if tag_of(descv) == TAG_OBJ:
        d: int32 = objid_of(descv)
        vp: int32 = obj_find_prop(d, str_from_cstr(cast[Ptr[uint8]]("value")))
        if vp >= 0:
            val = p_val[vp]
        else:
            # accessor descriptor: install a LIVE getter/setter
            gp: int32 = obj_find_prop(d, str_from_cstr(cast[Ptr[uint8]]("get")))
            sp0: int32 = obj_find_prop(d, str_from_cstr(cast[Ptr[uint8]]("set")))
            if gp >= 0 or sp0 >= 0:
                getter: int32 = -1
                setter: int32 = -1
                if gp >= 0 and is_callable(p_val[gp]) != 0:
                    getter = p_val[gp]
                if sp0 >= 0 and is_callable(p_val[sp0]) != 0:
                    setter = p_val[sp0]
                fsave: uint8 = obj_frozen[o]
                obj_frozen[o] = cast[uint8](0)
                obj_define_accessor(o, key_sid, getter, setter)
                obj_frozen[o] = fsave
                return objv
    frozen_save: uint8 = obj_frozen[o]
    obj_frozen[o] = cast[uint8](0)     # defineProperty bypasses a prior freeze intent for this write
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        idx: int32 = str_as_index(key_sid)
        if idx >= 0:
            arr_set(o, idx, val)
        else:
            obj_set(o, key_sid, val)
    else:
        obj_set(o, key_sid, val)
    obj_frozen[o] = frozen_save
    return objv


def object_define_properties(objv: int32, propsv: int32) -> int32:
    if tag_of(propsv) == TAG_OBJ:
        p: int32 = obj_head[objid_of(propsv)]
        # obj_head is newest-first; order is not observable for defineProperties
        while p >= 0:
            object_define_property(objv, v_string_id(p_key[p]), p_val[p])
            p = p_next[p]
    return objv


# Object.getOwnPropertyDescriptor(obj, key) -> {value, writable, enumerable, configurable} | undefined
def make_data_descriptor(val: int32, writable: int32) -> int32:
    dv: int32 = v_new_object()
    dobj: int32 = objid_of(dv)
    obj_set(dobj, str_from_cstr(cast[Ptr[uint8]]("value")), val)
    obj_set(dobj, str_from_cstr(cast[Ptr[uint8]]("writable")), v_boolv(writable))
    obj_set(dobj, str_from_cstr(cast[Ptr[uint8]]("enumerable")), v_boolv(1))
    obj_set(dobj, str_from_cstr(cast[Ptr[uint8]]("configurable")), v_boolv(writable))
    return dv


def object_get_own_descriptor(objv: int32, keyv: int32) -> int32:
    if tag_of(objv) != TAG_OBJ:
        return v_undef()
    o: int32 = objid_of(objv)
    key_sid: int32 = strid_of(to_string_val(keyv))
    writable: int32 = 1
    if obj_frozen[o] != 0:
        writable = 0
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        idx: int32 = str_as_index(key_sid)
        if idx >= 0 and idx < arr_len[o]:
            return make_data_descriptor(arr_get(o, idx), writable)
    pp: int32 = obj_find_prop(o, key_sid)
    if pp >= 0:
        return make_data_descriptor(p_val[pp], writable)
    return v_undef()


def object_get_own_descriptors(objv: int32) -> int32:
    res: int32 = v_new_object()
    if tag_of(objv) != TAG_OBJ:
        return res
    ro: int32 = objid_of(res)
    keys: int32 = object_keys(objv)
    ko: int32 = objid_of(keys)
    i: int32 = 0
    while i < arr_len[ko]:
        kv: int32 = arr_get(ko, i)
        obj_set(ro, strid_of(kv), object_get_own_descriptor(objv, kv))
        i = i + 1
    return res


# Object.hasOwn(obj, key) — ES2022 static form of hasOwnProperty. Coerces the
# key to a property name and reports an OWN (not inherited) property, including
# array indices and the array `length`.
def object_has_own(objv: int32, keyv: int32) -> int32:
    if tag_of(objv) != TAG_OBJ:
        return v_false()
    o: int32 = objid_of(objv)
    ks: int32 = strid_of(to_string_val(keyv))
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        idx: int32 = str_as_index(ks)
        if idx >= 0 and idx < arr_len[o]:
            return v_true()
        if str_eq_cstr(ks, cast[Ptr[uint8]]("length")) != 0:
            return v_true()
    if obj_find_prop(o, ks) >= 0:
        return v_true()
    return v_false()


# Object.is(a, b) — the SameValue algorithm: like === except NaN is equal to
# itself and +0 is distinct from -0.
def same_value(a: int32, b: int32) -> int32:
    if tag_of(a) == TAG_NUM and tag_of(b) == TAG_NUM:
        x: float64 = v_num[a]
        y: float64 = v_num[b]
        if x != x and y != y:
            return 1                          # NaN, NaN -> true
        if x == 0.0 and y == 0.0:
            # distinguish +0 from -0 via 1/x sign
            if (1.0 / x) != (1.0 / y):
                return 0
            return 1
        if x == y:
            return 1
        return 0
    return strict_eq(a, b)


# Object.prototype.{hasOwnProperty,propertyIsEnumerable,isPrototypeOf} — the
# defensive/library trio. Dispatched as a method fallback for any TAG_OBJ
# receiver (including arrays) that does not itself define an own/inherited
# property of the same name (a user override wins). Returns -2 when `name` is
# none of these so the caller falls through to normal property dispatch.
def try_object_method(objv: int32, name: int32, argnode: int32, env: int32) -> int32:
    o: int32 = objid_of(objv)
    is_hop: int32 = str_eq_cstr(name, cast[Ptr[uint8]]("hasOwnProperty"))
    is_pie: int32 = str_eq_cstr(name, cast[Ptr[uint8]]("propertyIsEnumerable"))
    is_ipo: int32 = str_eq_cstr(name, cast[Ptr[uint8]]("isPrototypeOf"))
    if is_hop == 0 and is_pie == 0 and is_ipo == 0:
        return -2
    # defer to a user-defined own/inherited property of the same name
    cur: int32 = o
    while cur >= 0:
        if obj_find_prop(cur, name) >= 0:
            return -2
        cur = obj_proto[cur]
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    arg0: int32 = v_undef()
    if argc > 0:
        arg0 = call_args[base]
    call_top = base
    if is_ipo != 0:
        # objv.isPrototypeOf(arg0): is objv anywhere in arg0's [[Prototype]] chain?
        if tag_of(arg0) != TAG_OBJ:
            return v_false()
        c2: int32 = obj_proto[objid_of(arg0)]
        while c2 >= 0:
            if c2 == o:
                return v_true()
            c2 = obj_proto[c2]
        return v_false()
    ks: int32 = strid_of(to_string_val(arg0))
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        idx: int32 = str_as_index(ks)
        if idx >= 0 and idx < arr_len[o]:
            return v_true()               # own index (enumerable)
        if is_hop != 0 and str_eq_cstr(ks, cast[Ptr[uint8]]("length")) != 0:
            return v_true()               # arrays own a (non-enumerable) length
    if obj_find_prop(o, ks) >= 0:
        return v_true()
    return v_false()


# Array.from(iterable[, mapFn]) — arrays, strings, Map/Set, and array-likes.
def array_from(srcv: int32, mapfn: int32, argc: int32) -> int32:
    res: int32 = v_new_array()
    ro: int32 = objid_of(res)
    have_map: int32 = 0
    if argc >= 2 and is_callable(mapfn) != 0:
        have_map = 1
    if is_array(srcv) != 0:
        so: int32 = objid_of(srcv)
        i: int32 = 0
        while i < arr_len[so]:
            array_from_push(ro, arr_get(so, i), i, have_map, mapfn)
            i = i + 1
        return res
    if tag_of(srcv) == TAG_STR:
        sid: int32 = strid_of(srcv)
        j: int32 = 0
        while j < str_len(sid):
            ch: int32 = v_string_bytes(&sp_buf[st_off[sid] + j], 1)
            array_from_push(ro, ch, j, have_map, mapfn)
            j = j + 1
        return res
    if tag_of(srcv) == TAG_OBJ:
        o: int32 = objid_of(srcv)
        if cast[int32](obj_ta_kind[o]) != 0:   # typed array -> plain array
            ti: int32 = 0
            while ti < obj_ta_len[o]:
                array_from_push(ro, ta_load(o, ti), ti, have_map, mapfn)
                ti = ti + 1
            return res
        mk: int32 = cast[int32](obj_map_kind[o])
        if mk == MAP_KIND_MAP or mk == MAP_KIND_SET:
            snap: int32 = -1
            if mk == MAP_KIND_SET:
                snap = ms_snapshot(o, 1)
            else:
                snap = ms_snapshot(o, 2)
            sno: int32 = objid_of(snap)
            k: int32 = 0
            while k < arr_len[sno]:
                array_from_push(ro, arr_get(sno, k), k, have_map, mapfn)
                k = k + 1
            return res
        # generators and generic protocol iterables (has [Symbol.iterator]/.next)
        git: int32 = iter_get(srcv)
        if git >= 0:
            guard: int32 = 0
            while guard < GEN_YIELD_CAP:
                iv: int32 = iter_next(git, v_undef())
                if ctl == CTL_THROW or err_flag != 0:
                    return res
                if iter_result_done != 0:
                    return res
                array_from_push(ro, iv, guard, have_map, mapfn)
                guard = guard + 1
            return res
        # array-like: {length, 0, 1, ...}
        lenv: int32 = member_get(srcv, str_from_cstr(cast[Ptr[uint8]]("length")))
        if tag_of(lenv) == TAG_NUM:
            n: int32 = cast[int32](v_num[lenv])
            a: int32 = 0
            while a < n:
                ev: int32 = member_get(srcv, num_to_strid(cast[float64](a)))
                array_from_push(ro, ev, a, have_map, mapfn)
                a = a + 1
    return res


def array_from_push(ro: int32, val: int32, idx: int32, have_map: int32, mapfn: int32):
    if have_map != 0:
        nb: int32 = call_top
        call_args[call_top] = val
        call_args[call_top + 1] = v_number(cast[float64](idx))
        call_top = call_top + 2
        mv: int32 = invoke(mapfn, v_undef(), nb, 2)
        call_top = nb
        arr_push(ro, mv)
    else:
        arr_push(ro, val)


# ---- JSON ----
# json_indent = spaces per level for the pretty-print (0 = compact single line).
# json_depth  = current nesting depth, used to size the indentation runs.
json_indent: int32 = 0
json_depth:  int32 = 0


# Resolve the 3rd stringify arg (the `space` reviver) into a spaces-per-level
# count. JS accepts a number (clamped 0..10) or a string (its length); we honor
# the numeric form (the common `JSON.stringify(v, null, 2)`) and treat a string
# by its length.
def json_indent_of(sp: int32) -> int32:
    t: int32 = tag_of(sp)
    n: int32 = 0
    if t == TAG_NUM:
        n = cast[int32](v_num[sp])
    elif t == TAG_STR:
        n = str_len(strid_of(sp))
    if n < 0:
        n = 0
    if n > 10:
        n = 10
    return n


def json_nl():
    emit_c(10)
    total: int32 = json_depth * json_indent
    k: int32 = 0
    while k < total:
        emit_c(32)
        k = k + 1


# ---- JSON.stringify replacer (2nd arg) --------------------------------------
# When JSON.stringify gets a 2nd arg, we PRE-TRANSFORM the value tree into a fresh
# tree BEFORE the string builder runs, then hand that to plain json_emit. This is
# required because a replacer function does its own string-building (to_string_val
# etc.), which cannot run while the shared build cursor is held by json_emit — the
# same two-phase discipline used by String.replace. A function replacer is invoked
# fn.call(holder, key, value) per property; an array replacer is an allowlist of
# object keys to include.
json_rep_fn: int32 = -1              # active function replacer VALUE handle, or -1
json_rep_allow: int32 = -1           # active allowlist array object id, or -1


# Is `key_sid` permitted by the active array allowlist? (No allowlist => always.)
def json_key_allowed(key_sid: int32) -> int32:
    if json_rep_allow < 0:
        return 1
    n: int32 = arr_len[json_rep_allow]
    i: int32 = 0
    while i < n:
        el: int32 = arr_get(json_rep_allow, i)
        ks: int32 = -1
        if tag_of(el) == TAG_STR:
            ks = strid_of(el)
        elif tag_of(el) == TAG_NUM:
            ks = num_to_strid(v_num[el])
        if ks >= 0 and str_eq(ks, key_sid) != 0:
            return 1
        i = i + 1
    return 0


# Resolve holder[key]=value through value.toJSON(key) then the function replacer,
# returning the value to serialize at this position (before recursing into it).
def json_rep_value(holder: int32, key_sid: int32, value: int32) -> int32:
    v: int32 = value
    if tag_of(v) == TAG_OBJ:
        tj: int32 = member_get(v, str_from_cstr(cast[Ptr[uint8]]("toJSON")))
        if is_callable(tj) != 0:
            b: int32 = call_top
            call_args[call_top] = v_string_id(key_sid)
            call_top = call_top + 1
            v = invoke(tj, v, b, 1)
            call_top = b
            if ctl == CTL_THROW or err_flag != 0:
                return v_undef()
    if json_rep_fn >= 0:
        b2: int32 = call_top
        call_args[call_top] = v_string_id(key_sid)
        call_args[call_top + 1] = v
        call_top = call_top + 2
        v = invoke(json_rep_fn, holder, b2, 2)
        call_top = b2
        if ctl == CTL_THROW or err_flag != 0:
            return v_undef()
    return v


# Recursively rebuild `value` into a fresh tree with the replacer applied at every
# level, so the subsequent plain json_emit needs no user callbacks. Undefined /
# function results are left in place — json_emit already omits object keys and
# renders array holes as null for them.
def json_transform(value: int32) -> int32:
    if tag_of(value) != TAG_OBJ:
        return value
    if is_callable(value) != 0:
        return value
    o: int32 = objid_of(value)
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        na: int32 = v_new_array()
        nao: int32 = objid_of(na)
        i: int32 = 0
        while i < arr_len[o]:
            ev: int32 = json_rep_value(value, num_to_strid(cast[float64](i)), arr_get(o, i))
            if ctl == CTL_THROW or err_flag != 0:
                return na
            arr_push(nao, json_transform(ev))
            i = i + 1
        return na
    no: int32 = v_new_object()
    json_transform_props(obj_head[o], value, objid_of(no))
    return no


# Transform an object's own properties in insertion order (recurse tail-first so
# the oldest property is emitted first, matching JSON enumeration order).
def json_transform_props(p: int32, holder: int32, dst: int32):
    if p < 0:
        return
    json_transform_props(p_next[p], holder, dst)
    if ctl == CTL_THROW or err_flag != 0:
        return
    if is_hidden_key(p_key[p]) != 0:      # private/#... and @@symbol keys never serialize
        return
    if json_key_allowed(p_key[p]) == 0:
        return
    tv: int32 = json_rep_value(holder, p_key[p], p_val[p])
    if ctl == CTL_THROW or err_flag != 0:
        return
    obj_set(dst, p_key[p], json_transform(tv))


# JSON.stringify(value, replacer, space) with the replacer honored. Sets up the
# active replacer, builds the root holder {"": value}, transforms, then serializes.
def json_stringify_full(v: int32, replacer: int32, indent: int32) -> int32:
    save_fn: int32 = json_rep_fn
    save_allow: int32 = json_rep_allow
    json_rep_fn = -1
    json_rep_allow = -1
    if is_callable(replacer) != 0:
        json_rep_fn = replacer
    elif is_array(replacer) != 0:
        json_rep_allow = objid_of(replacer)
    empty_sid: int32 = str_from_cstr(cast[Ptr[uint8]](""))
    holder: int32 = v_new_object()
    obj_set(objid_of(holder), empty_sid, v)
    result: int32 = v_undef()
    rootv: int32 = json_rep_value(holder, empty_sid, v)
    if ctl != CTL_THROW and err_flag == 0:
        tv: int32 = json_transform(rootv)
        if ctl != CTL_THROW and err_flag == 0:
            result = json_stringify(tv, indent)
    json_rep_fn = save_fn
    json_rep_allow = save_allow
    return result


def json_stringify(v: int32, indent: int32) -> int32:
    save: int32 = emit_tgt
    save_ind: int32 = json_indent
    save_dep: int32 = json_depth
    emit_tgt = 0
    json_indent = indent
    json_depth = 0
    bld_begin()
    json_emit(v)
    id: int32 = bld_end()
    emit_tgt = save
    json_indent = save_ind
    json_depth = save_dep
    if st_len[id] == 0:
        return v_undef()
    return v_string_id(id)


def json_emit(v: int32):
    t: int32 = tag_of(v)
    if t == TAG_UNDEF:
        return                         # undefined -> omitted (caller-handled)
    if t == TAG_NULL:
        emit_cstr(cast[Ptr[uint8]]("null"))
        return
    if t == TAG_BOOL:
        if v == 2:
            emit_cstr(cast[Ptr[uint8]]("true"))
        else:
            emit_cstr(cast[Ptr[uint8]]("false"))
        return
    if t == TAG_NUM:
        if is_nan(v_num[v]) != 0 or is_inf(v_num[v]) != 0:
            emit_cstr(cast[Ptr[uint8]]("null"))
        else:
            emit_num(v_num[v])
        return
    if t == TAG_STR:
        json_emit_string(strid_of(v))
        return
    if t == TAG_BIGINT:
        throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("Do not know how to serialize a BigInt"))
        return
    o: int32 = objid_of(v)
    # Honor Date.prototype.toJSON (== toISOString) on the fast path. Emitting the
    # ISO text directly (no nested string build, no invoke) is build-safe inside
    # the outer json_emit build. Without this a Date serializes as "{}".
    if obj_is_date[o] != cast[uint8](0):
        date_emit_json_iso(obj_date_ms[o])
        return
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        emit_c(91)
        n_el: int32 = arr_len[o]
        if n_el > 0 and json_indent > 0:
            json_depth = json_depth + 1
        i: int32 = 0
        while i < n_el:
            if i > 0:
                emit_c(44)
            if json_indent > 0:
                json_nl()
            el: int32 = arr_get(o, i)
            if tag_of(el) == TAG_UNDEF or is_callable(el) != 0:
                emit_cstr(cast[Ptr[uint8]]("null"))
            else:
                json_emit(el)
            i = i + 1
        if n_el > 0 and json_indent > 0:
            json_depth = json_depth - 1
            json_nl()
        emit_c(93)
        return
    if cast[int32](obj_kind[o]) == OK_FUNC:
        return
    emit_c(123)
    save_any: int32 = json_emitted_any
    json_emitted_any = 0
    if json_indent > 0:
        json_depth = json_depth + 1
    json_emit_props(obj_head[o], 1)
    printed: int32 = json_emitted_any
    if json_indent > 0:
        json_depth = json_depth - 1
        if printed != 0:
            json_nl()
    json_emitted_any = save_any
    emit_c(125)


def json_emit_props(p: int32, is_last: int32):
    if p < 0:
        return
    json_emit_props(p_next[p], 0)
    v: int32 = p_val[p]
    if tag_of(v) == TAG_UNDEF or is_callable(v) != 0:
        return
    if is_hidden_key(p_key[p]) != 0:      # private/#... and @@symbol keys never serialize
        return
    # emit comma if something was printed before this (deeper recursion did)
    if json_emitted_any != 0:
        emit_c(44)
    if json_indent > 0:
        json_nl()
    json_emitted_any = 1
    json_emit_string(p_key[p])
    emit_c(58)
    if json_indent > 0:
        emit_c(32)
    json_emit(v)


json_emitted_any: int32 = 0


def json_emit_string(sid: int32):
    emit_c(34)
    n: int32 = str_len(sid)
    i: int32 = 0
    while i < n:
        c: uint8 = str_char(sid, i)
        if c == 34:
            emit_c(92)
            emit_c(34)
        elif c == 92:
            emit_c(92)
            emit_c(92)
        elif c == 10:
            emit_c(92)
            emit_c(110)
        elif c == 9:
            emit_c(92)
            emit_c(116)
        elif c == 13:
            emit_c(92)
            emit_c(114)
        elif c == 8:
            emit_c(92)
            emit_c(98)
        elif c == 12:
            emit_c(92)
            emit_c(102)
        elif c < 32:
            # other control chars -> \u00XX
            emit_c(92)
            emit_c(117)
            emit_c(48)
            emit_c(48)
            emit_hex_nibble(cast[int32](c) / 16)
            emit_hex_nibble(cast[int32](c) & 15)
        else:
            emit_c(c)
        i = i + 1
    emit_c(34)


def emit_hex_nibble(d: int32):
    if d < 10:
        emit_c(cast[uint8](48 + d))
    else:
        emit_c(cast[uint8](87 + d))


# JSON.parse — parse a JS string value into a JS value.
jp_p: Ptr[uint8] = 0
jp_n: int32 = 0
jp_i: int32 = 0


def json_syntax_error():
    throw_error(cast[Ptr[uint8]]("SyntaxError"), cast[Ptr[uint8]]("Unexpected token in JSON"))


def json_parse_val(sv: int32, reviver: int32) -> int32:
    s: int32 = strid_of(to_string_val(sv))
    jp_p = str_ptr(s)
    jp_n = str_len(s)
    jp_i = 0
    r: int32 = jp_value()
    if ctl == CTL_THROW:
        return v_undef()
    # reject trailing garbage after the top-level value
    jp_ws()
    if jp_i < jp_n:
        json_syntax_error()
        return v_undef()
    # ES: JSON.parse(text, reviver) — if reviver is callable, walk the tree
    # bottom-up, calling reviver.call(holder, key, value) at each node; a result
    # of `undefined` deletes the property. The root is held in {"": <parsed>}.
    if is_callable(reviver) != 0:
        holder: int32 = v_new_object()
        empty_key: int32 = str_from_cstr(cast[Ptr[uint8]](""))
        obj_set(objid_of(holder), empty_key, r)
        return json_internalize(reviver, holder, v_string_id(empty_key), r)
    return r


# InternalizeJSONProperty(holder, name): recurse into children of `val` first
# (arrays by index, objects by own key), replacing/deleting per the reviver
# result, then return reviver.call(holder, name, val). `val` is passed in
# already-fetched from holder[name].
def json_internalize(reviver: int32, holder_val: int32, keyv: int32, val: int32) -> int32:
    if tag_of(val) == TAG_OBJ:
        o: int32 = objid_of(val)
        if cast[int32](obj_kind[o]) == OK_ARRAY:
            i: int32 = 0
            while i < arr_len[o]:
                ik: int32 = v_string_id(num_to_strid(cast[float64](i)))
                nv: int32 = json_internalize(reviver, val, ik, arr_get(o, i))
                arr_set(o, i, nv)          # undefined result => hole (approx)
                i = i + 1
        else:
            json_intern_props(reviver, val, o, obj_head[o])
    return json_reviver_call(reviver, holder_val, keyv, val)


# Walk an object's own-property chain tail-first (source order), internalizing
# each. Capture p_next BEFORE the recursive call so a delete in a deeper frame
# can't corrupt this traversal.
def json_intern_props(reviver: int32, holder_val: int32, o: int32, p: int32):
    if p < 0:
        return
    nextp: int32 = p_next[p]
    json_intern_props(reviver, holder_val, o, nextp)
    key_sid: int32 = p_key[p]
    nv: int32 = json_internalize(reviver, holder_val, v_string_id(key_sid), p_val[p])
    if tag_of(nv) == TAG_UNDEF:
        obj_del_prop(o, key_sid)
    else:
        obj_set(o, key_sid, nv)


def json_reviver_call(fn: int32, holder_val: int32, keyv: int32, val: int32) -> int32:
    b: int32 = call_top
    call_args[call_top] = keyv
    call_args[call_top + 1] = val
    call_top = call_top + 2
    r: int32 = invoke(fn, holder_val, b, 2)
    call_top = b
    return r


# Match a bare literal (true/false/null) exactly; throw on any mismatch.
def jp_lit(word: Ptr[uint8], wlen: int32) -> int32:
    k: int32 = 0
    while k < wlen:
        if jp_i + k >= jp_n or jp_p[jp_i + k] != word[k]:
            json_syntax_error()
            return 0
        k = k + 1
    jp_i = jp_i + wlen
    return 1


def jp_ws():
    while jp_i < jp_n and is_ws(jp_p[jp_i]) != 0:
        jp_i = jp_i + 1


def jp_value() -> int32:
    jp_ws()
    if jp_i >= jp_n:
        json_syntax_error()
        return v_undef()
    c: uint8 = jp_p[jp_i]
    if c == 123:
        return jp_object()
    if c == 91:
        return jp_array()
    if c == 34:
        return v_string_id(jp_string())
    if c == 116:                       # true
        if jp_lit(cast[Ptr[uint8]]("true"), 4) != 0:
            return v_true()
        return v_undef()
    if c == 102:                       # false
        if jp_lit(cast[Ptr[uint8]]("false"), 5) != 0:
            return v_false()
        return v_undef()
    if c == 110:                       # null
        if jp_lit(cast[Ptr[uint8]]("null"), 4) != 0:
            return v_null()
        return v_undef()
    # number: optional '-', at least one digit, optional fraction/exponent
    if c != 45 and is_digit(c) == 0:
        json_syntax_error()
        return v_undef()
    start: int32 = jp_i
    if c == 45:
        jp_i = jp_i + 1
    ndig: int32 = 0
    while jp_i < jp_n and (is_digit(jp_p[jp_i]) != 0 or jp_p[jp_i] == 46 or jp_p[jp_i] == 101 or jp_p[jp_i] == 69 or jp_p[jp_i] == 43 or jp_p[jp_i] == 45):
        if is_digit(jp_p[jp_i]) != 0:
            ndig = ndig + 1
        jp_i = jp_i + 1
    if ndig == 0:
        json_syntax_error()
        return v_undef()
    return v_number(parse_num_bytes(&jp_p[start], jp_i - start))


def jp_string() -> int32:
    if jp_i >= jp_n or jp_p[jp_i] != 34:
        json_syntax_error()
        return str_from_cstr(cast[Ptr[uint8]](""))
    jp_i = jp_i + 1                    # opening quote
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    while jp_i < jp_n and jp_p[jp_i] != 34:
        c: uint8 = jp_p[jp_i]
        if c == 92:
            jp_i = jp_i + 1
            if jp_i >= jp_n:
                break
            e: uint8 = jp_p[jp_i]
            if e == 110:
                emit_c(10)
            elif e == 116:
                emit_c(9)
            elif e == 114:
                emit_c(13)
            elif e == 98:
                emit_c(8)
            elif e == 102:
                emit_c(12)
            elif e == 34:
                emit_c(34)
            elif e == 92:
                emit_c(92)
            elif e == 47:
                emit_c(47)
            elif e == 117:
                # \uXXXX -> emit low byte only (ASCII subset)
                emit_c(jp_hex4())
            else:
                emit_c(e)
            jp_i = jp_i + 1
        else:
            emit_c(c)
            jp_i = jp_i + 1
    id: int32 = bld_end()
    emit_tgt = save
    if jp_i >= jp_n:                   # ran off the end with no closing quote
        json_syntax_error()
        return id
    jp_i = jp_i + 1                    # closing quote
    return id


def jp_hex4() -> uint8:
    v: int32 = 0
    k: int32 = 0
    while k < 4:
        c: uint8 = jp_p[jp_i + 1 + k]
        d: int32 = 0
        if c >= 48 and c <= 57:
            d = cast[int32](c) - 48
        elif c >= 97 and c <= 102:
            d = cast[int32](c) - 87
        elif c >= 65 and c <= 70:
            d = cast[int32](c) - 55
        v = v * 16 + d
        k = k + 1
    jp_i = jp_i + 4
    return cast[uint8](v & 255)


def jp_array() -> int32:
    jp_i = jp_i + 1                    # [
    v: int32 = v_new_array()
    o: int32 = objid_of(v)
    jp_ws()
    if jp_i < jp_n and jp_p[jp_i] == 93:  # empty []
        jp_i = jp_i + 1
        return v
    while jp_i < jp_n and ctl != CTL_THROW:
        arr_push(o, jp_value())
        if ctl == CTL_THROW:
            return v
        jp_ws()
        if jp_i < jp_n and jp_p[jp_i] == 44:
            jp_i = jp_i + 1
            continue
        if jp_i < jp_n and jp_p[jp_i] == 93:
            jp_i = jp_i + 1
            return v
        json_syntax_error()             # neither ',' nor ']' -> malformed
        return v
    return v


def jp_object() -> int32:
    jp_i = jp_i + 1                    # {
    v: int32 = v_new_object()
    o: int32 = objid_of(v)
    jp_ws()
    if jp_i < jp_n and jp_p[jp_i] == 125:  # empty {}
        jp_i = jp_i + 1
        return v
    while jp_i < jp_n and ctl != CTL_THROW:
        jp_ws()
        key: int32 = jp_string()        # throws unless a "..." key
        if ctl == CTL_THROW:
            return v
        jp_ws()
        if jp_i < jp_n and jp_p[jp_i] == 58:
            jp_i = jp_i + 1
        else:
            json_syntax_error()         # missing ':'
            return v
        val: int32 = jp_value()
        if ctl == CTL_THROW:
            return v
        obj_set(o, key, val)
        jp_ws()
        if jp_i < jp_n and jp_p[jp_i] == 44:
            jp_i = jp_i + 1
            continue
        if jp_i < jp_n and jp_p[jp_i] == 125:
            jp_i = jp_i + 1
            return v
        json_syntax_error()             # neither ',' nor '}' -> malformed
        return v
    return v



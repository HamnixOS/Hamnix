# lib/web/js/builtins/intl.ad — part of the modular web engine.
# Intl.NumberFormat + Intl.DateTimeFormat (minimal, en-US oriented) plus the
# Date.prototype.toLocale*String methods and the Date.parse / Date.UTC /
# getTimezoneOffset / setTime / setUTC* extensions.
#
# LOCALE-SIMPLIFICATION SCOPE (documented, intentional):
#   * Any `locales` argument is ACCEPTED but ignored beyond en-US: grouping
#     uses ',' , the decimal point uses '.', and month/weekday names are the
#     English long/short forms. Non-en digit shaping, separators, and calendars
#     are NOT implemented.
#   * The engine has no wall-clock timezone; all dates are UTC, so
#     getTimezoneOffset() is 0 and toLocale*String render UTC fields.
#   * Number rounding uses ties-away-from-zero (spec default "halfExpand").
#
# Behavior-preserving split: Adder merges all imported files into one Program,
# so every public name here resolves globally across the merged engine.
# The native dispatch chain (call_native -> ... -> call_native_url) tail-calls
# call_native_intl for these ids.


# prototype objects for the Intl formatter instances (installed by install_intl)
g_intl_nf_proto: int32 = -1
g_intl_dtf_proto: int32 = -1


# ---- small numeric helpers ----
def intl_pow10(k: int32) -> int64:
    r: int64 = cast[int64](1)
    i: int32 = 0
    while i < k:
        r = r * cast[int64](10)
        i = i + 1
    return r


# read a named property off an options handle; v_undef if absent / not an object
def intl_opt(opts: int32, name: Ptr[uint8]) -> int32:
    if tag_of(opts) != TAG_OBJ:
        return v_undef()
    return obj_get_cstr(objid_of(opts), name)


# true if the option value is a string equal to `s`
def intl_opt_is(opts: int32, name: Ptr[uint8], s: Ptr[uint8]) -> int32:
    v: int32 = intl_opt(opts, name)
    if tag_of(v) != TAG_STR:
        return 0
    return str_eq_cstr(strid_of(v), s)


# ====================================================================
# Intl.NumberFormat
# ====================================================================
# Options honored: style ('decimal'|'currency'|'percent'), currency (code),
# minimumFractionDigits, maximumFractionDigits, useGrouping (bool, default on).
# The formatter object stores its resolved options as ordinary hidden-ish
# properties (read back by format()).

def intl_nf_construct(thisv: int32, base: int32, argc: int32) -> int32:
    o: int32 = objid_of(thisv)
    if tag_of(thisv) != TAG_OBJ:
        # called without `new` — mint an object anyway (spec allows both)
        thisv = v_new_object()
        o = objid_of(thisv)
    if g_intl_nf_proto >= 0:
        obj_proto[o] = objid_of(g_intl_nf_proto)
    opts: int32 = arg_or(base, argc, 1)
    # style
    style: int32 = 0                          # 0 decimal, 1 currency, 2 percent
    if intl_opt_is(opts, cast[Ptr[uint8]]("style"), cast[Ptr[uint8]]("currency")) != 0:
        style = 1
    elif intl_opt_is(opts, cast[Ptr[uint8]]("style"), cast[Ptr[uint8]]("percent")) != 0:
        style = 2
    # default fraction digits by style
    defmin: int32 = 0
    defmax: int32 = 3
    if style == 1:
        defmin = 2
        defmax = 2
    elif style == 2:
        defmin = 0
        defmax = 0
    minv: int32 = intl_opt(opts, cast[Ptr[uint8]]("minimumFractionDigits"))
    maxv: int32 = intl_opt(opts, cast[Ptr[uint8]]("maximumFractionDigits"))
    minf: int32 = defmin
    if tag_of(minv) != TAG_UNDEF:
        minf = cast[int32](to_number(minv))
    maxf: int32 = defmax
    if tag_of(maxv) != TAG_UNDEF:
        maxf = cast[int32](to_number(maxv))
    elif tag_of(minv) != TAG_UNDEF and minf > maxf:
        maxf = minf                            # max defaults up to at least min
    if maxf < minf:
        maxf = minf
    # useGrouping: default true unless === false
    grp: int32 = 1
    gv: int32 = intl_opt(opts, cast[Ptr[uint8]]("useGrouping"))
    if tag_of(gv) == TAG_BOOL and to_bool(gv) == 0:
        grp = 0
    # currency code
    curv: int32 = intl_opt(opts, cast[Ptr[uint8]]("currency"))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_nfStyle")), v_number(cast[float64](style)))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_nfMin")), v_number(cast[float64](minf)))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_nfMax")), v_number(cast[float64](maxf)))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_nfGrp")), v_number(cast[float64](grp)))
    if tag_of(curv) == TAG_STR:
        obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_nfCur")), curv)
    return v_undef()


# emit the currency prefix symbol for a code ($, £, €, ¥, else "CODE ")
def intl_emit_currency(o: int32):
    cv: int32 = obj_get_cstr(o, cast[Ptr[uint8]]("_nfCur"))
    if tag_of(cv) != TAG_STR:
        emit_c(cast[uint8](36))              # default '$'
        return
    sid: int32 = strid_of(cv)
    if str_eq_cstr(sid, cast[Ptr[uint8]]("USD")) != 0 or str_eq_cstr(sid, cast[Ptr[uint8]]("CAD")) != 0 or str_eq_cstr(sid, cast[Ptr[uint8]]("AUD")) != 0 or str_eq_cstr(sid, cast[Ptr[uint8]]("NZD")) != 0 or str_eq_cstr(sid, cast[Ptr[uint8]]("USD")) != 0:
        emit_c(cast[uint8](36))              # '$'
        return
    if str_eq_cstr(sid, cast[Ptr[uint8]]("GBP")) != 0:
        emit_c(cast[uint8](194))             # £  = U+00A3 -> 0xC2 0xA3
        emit_c(cast[uint8](163))
        return
    if str_eq_cstr(sid, cast[Ptr[uint8]]("EUR")) != 0:
        emit_c(cast[uint8](226))             # €  = U+20AC -> 0xE2 0x82 0xAC
        emit_c(cast[uint8](130))
        emit_c(cast[uint8](172))
        return
    if str_eq_cstr(sid, cast[Ptr[uint8]]("JPY")) != 0 or str_eq_cstr(sid, cast[Ptr[uint8]]("CNY")) != 0:
        emit_c(cast[uint8](194))             # ¥  = U+00A5 -> 0xC2 0xA5
        emit_c(cast[uint8](165))
        return
    # unknown code: emit the literal code + a space (documented simplification)
    n: int32 = str_len(sid)
    i: int32 = 0
    while i < n:
        emit_c(str_char(sid, i))
        i = i + 1
    emit_c(cast[uint8](32))


# emit a non-negative int64 in base-10 with optional ',' grouping every 3
def intl_emit_grouped(v: int64, grp: int32):
    digs: Array[24, uint8]
    n: int32 = 0
    vv: int64 = v
    if vv == 0:
        digs[0] = cast[uint8](48)
        n = 1
    else:
        while vv > 0:
            digs[n] = cast[uint8](vv % cast[int64](10)) + cast[uint8](48)
            vv = vv / cast[int64](10)
            n = n + 1
    # digs[] holds least-significant first; emit most-significant with commas
    i: int32 = n
    while i > 0:
        i = i - 1
        emit_c(digs[i])
        if grp != 0 and i > 0 and (i % 3) == 0:
            emit_c(cast[uint8](44))          # ','


def intl_nf_format(thisv: int32, base: int32, argc: int32) -> int32:
    o: int32 = objid_of(thisv)
    n: float64 = to_number(arg_or(base, argc, 0))
    style: int32 = cast[int32](to_number(obj_get_cstr(o, cast[Ptr[uint8]]("_nfStyle"))))
    minf: int32 = cast[int32](to_number(obj_get_cstr(o, cast[Ptr[uint8]]("_nfMin"))))
    maxf: int32 = cast[int32](to_number(obj_get_cstr(o, cast[Ptr[uint8]]("_nfMax"))))
    grp: int32 = cast[int32](to_number(obj_get_cstr(o, cast[Ptr[uint8]]("_nfGrp"))))
    if style == 2:
        n = n * 100.0                        # percent
    neg: int32 = 0
    if n < 0.0:
        neg = 1
        n = -n
    if n != n:                               # NaN guard
        return v_string_cstr(cast[Ptr[uint8]]("NaN"))
    pw: int64 = intl_pow10(maxf)
    scaled: int64 = cast[int64](n * cast[float64](pw) + 0.5)   # ties away from zero
    intpart: int64 = scaled / pw
    fracpart: int64 = scaled - intpart * pw
    # decide how many fraction digits to actually show: maxf, trimmed of trailing
    # zeros down to minf.
    show: int32 = maxf
    if pw > cast[int64](1):
        while show > minf and (fracpart % cast[int64](10)) == 0:
            fracpart = fracpart / cast[int64](10)
            show = show - 1
    else:
        show = 0
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    if neg != 0:
        emit_c(cast[uint8](45))              # '-'
    if style == 1:
        intl_emit_currency(o)
    intl_emit_grouped(intpart, grp)
    if show > 0:
        emit_c(cast[uint8](46))              # '.'
        # emit fracpart zero-padded to `show` digits
        fd: Array[24, uint8]
        k: int32 = 0
        fv: int64 = fracpart
        if fv == 0:
            fd[0] = cast[uint8](48)
            k = 1
        else:
            while fv > 0:
                fd[k] = cast[uint8](fv % cast[int64](10)) + cast[uint8](48)
                fv = fv / cast[int64](10)
                k = k + 1
        pad: int32 = show - k
        while pad > 0:
            emit_c(cast[uint8](48))
            pad = pad - 1
        while k > 0:
            k = k - 1
            emit_c(fd[k])
    if style == 2:
        emit_c(cast[uint8](37))              # '%'
    id: int32 = bld_end()
    emit_tgt = save
    return v_string_id(id)


# ====================================================================
# Intl.DateTimeFormat + Date.prototype.toLocale*String
# ====================================================================
def intl_month_long(m: int32) -> Ptr[uint8]:
    if m == 1:
        return cast[Ptr[uint8]]("January")
    if m == 2:
        return cast[Ptr[uint8]]("February")
    if m == 3:
        return cast[Ptr[uint8]]("March")
    if m == 4:
        return cast[Ptr[uint8]]("April")
    if m == 5:
        return cast[Ptr[uint8]]("May")
    if m == 6:
        return cast[Ptr[uint8]]("June")
    if m == 7:
        return cast[Ptr[uint8]]("July")
    if m == 8:
        return cast[Ptr[uint8]]("August")
    if m == 9:
        return cast[Ptr[uint8]]("September")
    if m == 10:
        return cast[Ptr[uint8]]("October")
    if m == 11:
        return cast[Ptr[uint8]]("November")
    return cast[Ptr[uint8]]("December")


def intl_month_short(m: int32) -> Ptr[uint8]:
    if m == 1:
        return cast[Ptr[uint8]]("Jan")
    if m == 2:
        return cast[Ptr[uint8]]("Feb")
    if m == 3:
        return cast[Ptr[uint8]]("Mar")
    if m == 4:
        return cast[Ptr[uint8]]("Apr")
    if m == 5:
        return cast[Ptr[uint8]]("May")
    if m == 6:
        return cast[Ptr[uint8]]("Jun")
    if m == 7:
        return cast[Ptr[uint8]]("Jul")
    if m == 8:
        return cast[Ptr[uint8]]("Aug")
    if m == 9:
        return cast[Ptr[uint8]]("Sep")
    if m == 10:
        return cast[Ptr[uint8]]("Oct")
    if m == 11:
        return cast[Ptr[uint8]]("Nov")
    return cast[Ptr[uint8]]("Dec")


def intl_weekday_long(w: int32) -> Ptr[uint8]:
    if w == 0:
        return cast[Ptr[uint8]]("Sunday")
    if w == 1:
        return cast[Ptr[uint8]]("Monday")
    if w == 2:
        return cast[Ptr[uint8]]("Tuesday")
    if w == 3:
        return cast[Ptr[uint8]]("Wednesday")
    if w == 4:
        return cast[Ptr[uint8]]("Thursday")
    if w == 5:
        return cast[Ptr[uint8]]("Friday")
    return cast[Ptr[uint8]]("Saturday")


def intl_weekday_short(w: int32) -> Ptr[uint8]:
    if w == 0:
        return cast[Ptr[uint8]]("Sun")
    if w == 1:
        return cast[Ptr[uint8]]("Mon")
    if w == 2:
        return cast[Ptr[uint8]]("Tue")
    if w == 3:
        return cast[Ptr[uint8]]("Wed")
    if w == 4:
        return cast[Ptr[uint8]]("Thu")
    if w == 5:
        return cast[Ptr[uint8]]("Fri")
    return cast[Ptr[uint8]]("Sat")


# resolve a Date/number/undefined argument into epoch-ms
def intl_arg_ms(v: int32) -> float64:
    if tag_of(v) == TAG_OBJ and obj_is_date[objid_of(v)] != cast[uint8](0):
        return obj_date_ms[objid_of(v)]
    if tag_of(v) == TAG_UNDEF:
        return date_now_ms()
    return to_number(v)


# emit "M/D/YYYY" (en-US numeric date). dt_* must be filled by date_decompose.
def intl_emit_numeric_date():
    intl_emit_grouped(cast[int64](dt_month), 0)
    emit_c(cast[uint8](47))                  # '/'
    intl_emit_grouped(cast[int64](dt_day), 0)
    emit_c(cast[uint8](47))
    date_emit_pad(dt_year, 4)


# emit "h:mm:ss AM/PM" (en-US 12h) using dt_* fields; secs controls seconds.
def intl_emit_12h_time(with_secs: int32):
    h: int32 = dt_hour
    pm: int32 = 0
    if h >= 12:
        pm = 1
    h12: int32 = h % 12
    if h12 == 0:
        h12 = 12
    intl_emit_grouped(cast[int64](h12), 0)
    emit_c(cast[uint8](58))                  # ':'
    date_emit_pad(dt_min, 2)
    if with_secs != 0:
        emit_c(cast[uint8](58))
        date_emit_pad(dt_sec, 2)
    emit_c(cast[uint8](32))
    if pm != 0:
        emit_c(cast[uint8](80))              # 'P'
    else:
        emit_c(cast[uint8](65))              # 'A'
    emit_c(cast[uint8](77))                  # 'M'


# Build a Date.prototype.toLocale*String value. mode: 0 date, 1 time, 2 both.
def intl_locale_strid(ms: float64, mode: int32) -> int32:
    date_decompose(ms)
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    if mode == 0:
        intl_emit_numeric_date()
    elif mode == 1:
        intl_emit_12h_time(1)
    else:
        intl_emit_numeric_date()
        emit_c(cast[uint8](44))              # ','
        emit_c(cast[uint8](32))              # ' '
        intl_emit_12h_time(1)
    id: int32 = bld_end()
    emit_tgt = save
    return id


# DateTimeFormat.format(date) honoring a stored option bag. The option bag is
# stored on the formatter as _dtfHasDate / _dtfHasTime / _dtfMonth (0 num,1 2dig,
# 2 long,3 short) / _dtfWeekday (0 none,2 long,3 short) / _dtfSecs / _dtf12.
def intl_dtf_construct(thisv: int32, base: int32, argc: int32) -> int32:
    o: int32 = objid_of(thisv)
    if tag_of(thisv) != TAG_OBJ:
        thisv = v_new_object()
        o = objid_of(thisv)
    if g_intl_dtf_proto >= 0:
        obj_proto[o] = objid_of(g_intl_dtf_proto)
    opts: int32 = arg_or(base, argc, 1)
    has_year: int32 = 0
    if tag_of(intl_opt(opts, cast[Ptr[uint8]]("year"))) != TAG_UNDEF:
        has_year = 1
    has_month: int32 = 0
    if tag_of(intl_opt(opts, cast[Ptr[uint8]]("month"))) != TAG_UNDEF:
        has_month = 1
    has_day: int32 = 0
    if tag_of(intl_opt(opts, cast[Ptr[uint8]]("day"))) != TAG_UNDEF:
        has_day = 1
    has_hour: int32 = 0
    if tag_of(intl_opt(opts, cast[Ptr[uint8]]("hour"))) != TAG_UNDEF:
        has_hour = 1
    has_min: int32 = 0
    if tag_of(intl_opt(opts, cast[Ptr[uint8]]("minute"))) != TAG_UNDEF:
        has_min = 1
    has_sec: int32 = 0
    if tag_of(intl_opt(opts, cast[Ptr[uint8]]("second"))) != TAG_UNDEF:
        has_sec = 1
    # month style
    mstyle: int32 = 0
    if intl_opt_is(opts, cast[Ptr[uint8]]("month"), cast[Ptr[uint8]]("long")) != 0:
        mstyle = 2
    elif intl_opt_is(opts, cast[Ptr[uint8]]("month"), cast[Ptr[uint8]]("short")) != 0:
        mstyle = 3
    elif intl_opt_is(opts, cast[Ptr[uint8]]("month"), cast[Ptr[uint8]]("2-digit")) != 0:
        mstyle = 1
    # weekday
    wstyle: int32 = 0
    if intl_opt_is(opts, cast[Ptr[uint8]]("weekday"), cast[Ptr[uint8]]("long")) != 0:
        wstyle = 2
    elif intl_opt_is(opts, cast[Ptr[uint8]]("weekday"), cast[Ptr[uint8]]("short")) != 0:
        wstyle = 3
    # hour12: default true unless explicitly false
    h12: int32 = 1
    h12v: int32 = intl_opt(opts, cast[Ptr[uint8]]("hour12"))
    if tag_of(h12v) == TAG_BOOL and to_bool(h12v) == 0:
        h12 = 0
    has_date: int32 = 0
    if has_year != 0 or has_month != 0 or has_day != 0 or wstyle != 0:
        has_date = 1
    has_time: int32 = 0
    if has_hour != 0 or has_min != 0 or has_sec != 0:
        has_time = 1
    # empty option bag defaults to the numeric date (matches Intl default output)
    if has_date == 0 and has_time == 0:
        has_date = 1
        has_year = 1
        has_month = 1
        has_day = 1
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_dtfDate")), v_number(cast[float64](has_date)))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_dtfTime")), v_number(cast[float64](has_time)))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_dtfYear")), v_number(cast[float64](has_year)))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_dtfMon")), v_number(cast[float64](has_month)))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_dtfDay")), v_number(cast[float64](has_day)))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_dtfMStyle")), v_number(cast[float64](mstyle)))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_dtfWk")), v_number(cast[float64](wstyle)))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_dtfHour")), v_number(cast[float64](has_hour)))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_dtfMin")), v_number(cast[float64](has_min)))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_dtfSec")), v_number(cast[float64](has_sec)))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("_dtf12")), v_number(cast[float64](h12)))
    return v_undef()


def intl_dtf_geti(o: int32, name: Ptr[uint8]) -> int32:
    return cast[int32](to_number(obj_get_cstr(o, name)))


def intl_dtf_format(thisv: int32, base: int32, argc: int32) -> int32:
    o: int32 = objid_of(thisv)
    ms: float64 = intl_arg_ms(arg_or(base, argc, 0))
    date_decompose(ms)
    has_date: int32 = intl_dtf_geti(o, cast[Ptr[uint8]]("_dtfDate"))
    has_time: int32 = intl_dtf_geti(o, cast[Ptr[uint8]]("_dtfTime"))
    has_year: int32 = intl_dtf_geti(o, cast[Ptr[uint8]]("_dtfYear"))
    has_month: int32 = intl_dtf_geti(o, cast[Ptr[uint8]]("_dtfMon"))
    has_day: int32 = intl_dtf_geti(o, cast[Ptr[uint8]]("_dtfDay"))
    mstyle: int32 = intl_dtf_geti(o, cast[Ptr[uint8]]("_dtfMStyle"))
    wstyle: int32 = intl_dtf_geti(o, cast[Ptr[uint8]]("_dtfWk"))
    has_hour: int32 = intl_dtf_geti(o, cast[Ptr[uint8]]("_dtfHour"))
    has_min: int32 = intl_dtf_geti(o, cast[Ptr[uint8]]("_dtfMin"))
    has_sec: int32 = intl_dtf_geti(o, cast[Ptr[uint8]]("_dtfSec"))
    h12: int32 = intl_dtf_geti(o, cast[Ptr[uint8]]("_dtf12"))
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    if has_date != 0:
        # weekday prefix "Name, "
        if wstyle == 2:
            emit_cstr(intl_weekday_long(dt_dow))
            emit_c(cast[uint8](44))
            emit_c(cast[uint8](32))
        elif wstyle == 3:
            emit_cstr(intl_weekday_short(dt_dow))
            emit_c(cast[uint8](44))
            emit_c(cast[uint8](32))
        if mstyle >= 2:
            # long/short month:  "Month D, YYYY"  (pieces omitted if absent)
            wrote: int32 = 0
            if has_month != 0:
                if mstyle == 2:
                    emit_cstr(intl_month_long(dt_month))
                else:
                    emit_cstr(intl_month_short(dt_month))
                wrote = 1
            if has_day != 0:
                if wrote != 0:
                    emit_c(cast[uint8](32))
                intl_emit_grouped(cast[int64](dt_day), 0)
                wrote = 1
            if has_year != 0:
                if wrote != 0:
                    emit_c(cast[uint8](44))
                    emit_c(cast[uint8](32))
                date_emit_pad(dt_year, 4)
        else:
            # numeric M/D/YYYY, honoring which pieces are present
            need_slash: int32 = 0
            if has_month != 0:
                if mstyle == 1:
                    date_emit_pad(dt_month, 2)
                else:
                    intl_emit_grouped(cast[int64](dt_month), 0)
                need_slash = 1
            if has_day != 0:
                if need_slash != 0:
                    emit_c(cast[uint8](47))
                intl_emit_grouped(cast[int64](dt_day), 0)
                need_slash = 1
            if has_year != 0:
                if need_slash != 0:
                    emit_c(cast[uint8](47))
                date_emit_pad(dt_year, 4)
    if has_time != 0:
        if has_date != 0:
            emit_c(cast[uint8](44))
            emit_c(cast[uint8](32))
        if h12 != 0:
            intl_emit_12h_time(has_sec)
        else:
            date_emit_pad(dt_hour, 2)
            emit_c(cast[uint8](58))
            date_emit_pad(dt_min, 2)
            if has_sec != 0:
                emit_c(cast[uint8](58))
                date_emit_pad(dt_sec, 2)
    id: int32 = bld_end()
    emit_tgt = save
    return v_string_id(id)


# ====================================================================
# Date.parse / Date.UTC / setters
# ====================================================================
# Parse ISO 8601: YYYY-MM-DD[ T|space HH:MM[:SS[.sss]]][Z]. Trailing timezone
# offsets other than 'Z' are ignored (treated as UTC — documented). NaN on fail.
def date_parse_iso(sid: int32) -> float64:
    n: int32 = str_len(sid)
    if n < 10:
        return 0.0 / 0.0
    i: int32 = 0
    yr: int32 = 0
    k: int32 = 0
    while k < 4:
        c: uint8 = str_char(sid, i)
        if c < cast[uint8](48) or c > cast[uint8](57):
            return 0.0 / 0.0
        yr = yr * 10 + cast[int32](c - cast[uint8](48))
        i = i + 1
        k = k + 1
    if str_char(sid, i) != cast[uint8](45):
        return 0.0 / 0.0
    i = i + 1
    mo: int32 = cast[int32](str_char(sid, i) - cast[uint8](48)) * 10 + cast[int32](str_char(sid, i + 1) - cast[uint8](48))
    i = i + 2
    if str_char(sid, i) != cast[uint8](45):
        return 0.0 / 0.0
    i = i + 1
    da: int32 = cast[int32](str_char(sid, i) - cast[uint8](48)) * 10 + cast[int32](str_char(sid, i + 1) - cast[uint8](48))
    i = i + 2
    hh: int32 = 0
    mm: int32 = 0
    ss: int32 = 0
    msf: int32 = 0
    if i < n and (str_char(sid, i) == cast[uint8](84) or str_char(sid, i) == cast[uint8](32)):
        i = i + 1
        hh = cast[int32](str_char(sid, i) - cast[uint8](48)) * 10 + cast[int32](str_char(sid, i + 1) - cast[uint8](48))
        i = i + 2
        if i < n and str_char(sid, i) == cast[uint8](58):
            i = i + 1
            mm = cast[int32](str_char(sid, i) - cast[uint8](48)) * 10 + cast[int32](str_char(sid, i + 1) - cast[uint8](48))
            i = i + 2
        if i < n and str_char(sid, i) == cast[uint8](58):
            i = i + 1
            ss = cast[int32](str_char(sid, i) - cast[uint8](48)) * 10 + cast[int32](str_char(sid, i + 1) - cast[uint8](48))
            i = i + 2
        if i < n and str_char(sid, i) == cast[uint8](46):
            i = i + 1
            place: int32 = 100
            while i < n and str_char(sid, i) >= cast[uint8](48) and str_char(sid, i) <= cast[uint8](57):
                msf = msf + cast[int32](str_char(sid, i) - cast[uint8](48)) * place
                place = place / 10
                i = i + 1
    days: int64 = date_days_from_civil(cast[int64](yr), cast[int64](mo), cast[int64](da))
    return cast[float64](days * cast[int64](86400000) + cast[int64](hh) * cast[int64](3600000) + cast[int64](mm) * cast[int64](60000) + cast[int64](ss) * cast[int64](1000) + cast[int64](msf))


# recompute epoch-ms from the current dt_* fields (after a setter mutates one)
def date_recompose_ms() -> float64:
    days: int64 = date_days_from_civil(cast[int64](dt_year), cast[int64](dt_month), cast[int64](dt_day))
    return cast[float64](days * cast[int64](86400000) + cast[int64](dt_hour) * cast[int64](3600000) + cast[int64](dt_min) * cast[int64](60000) + cast[int64](dt_sec) * cast[int64](1000) + cast[int64](dt_msf))


def date_utc_of(base: int32, argc: int32) -> float64:
    y: int64 = cast[int64](to_number(call_args[base]))
    moi: int64 = cast[int64](0)
    if argc > 1:
        moi = cast[int64](to_number(call_args[base + 1]))
    d: int64 = cast[int64](1)
    if argc > 2:
        d = cast[int64](to_number(call_args[base + 2]))
    hh: int64 = 0
    if argc > 3:
        hh = cast[int64](to_number(call_args[base + 3]))
    mm: int64 = 0
    if argc > 4:
        mm = cast[int64](to_number(call_args[base + 4]))
    ss: int64 = 0
    if argc > 5:
        ss = cast[int64](to_number(call_args[base + 5]))
    msc: int64 = 0
    if argc > 6:
        msc = cast[int64](to_number(call_args[base + 6]))
    yadj: int64 = date_fdiv(moi, cast[int64](12))
    moi = moi - yadj * cast[int64](12)
    y = y + yadj
    days: int64 = date_days_from_civil(y, moi + cast[int64](1), d)
    return cast[float64](days * cast[int64](86400000) + hh * cast[int64](3600000) + mm * cast[int64](60000) + ss * cast[int64](1000) + msc)


# apply a single-field setter to the Date `thisv`; returns the new time value.
def date_set_field(thisv: int32, id: int32, base: int32, argc: int32) -> int32:
    if tag_of(thisv) != TAG_OBJ:
        return v_number(0.0 / 0.0)
    o: int32 = objid_of(thisv)
    if id == NAT_DATE_SETTIME:
        ms: float64 = to_number(arg_or(base, argc, 0))
        obj_date_ms[o] = ms
        return v_number(ms)
    date_decompose(obj_date_ms[o])
    v: int32 = cast[int32](to_number(arg_or(base, argc, 0)))
    if id == NAT_DATE_SETFULLYEAR:
        dt_year = v
    elif id == NAT_DATE_SETMONTH:
        # 0-based, may be out of range -> normalize into year+month
        yadj: int32 = 0
        mv: int32 = v
        while mv < 0:
            mv = mv + 12
            yadj = yadj - 1
        yadj = yadj + mv / 12
        mv = mv % 12
        dt_year = dt_year + yadj
        dt_month = mv + 1
    elif id == NAT_DATE_SETDATE:
        dt_day = v
    elif id == NAT_DATE_SETHOURS:
        dt_hour = v
    elif id == NAT_DATE_SETMINUTES:
        dt_min = v
    elif id == NAT_DATE_SETSECONDS:
        dt_sec = v
    elif id == NAT_DATE_SETMS:
        dt_msf = v
    nms: float64 = date_recompose_ms()
    obj_date_ms[o] = nms
    return v_number(nms)


# ---- native dispatch tail (chained from call_native_url) --------------------
def call_native_intl(id: int32, thisv: int32, base: int32, argc: int32) -> int32:
    if id == NAT_INTL_NUMBERFORMAT:
        return intl_nf_construct(thisv, base, argc)
    if id == NAT_INTL_NF_FORMAT:
        return intl_nf_format(thisv, base, argc)
    if id == NAT_INTL_DATETIMEFORMAT:
        return intl_dtf_construct(thisv, base, argc)
    if id == NAT_INTL_DTF_FORMAT:
        return intl_dtf_format(thisv, base, argc)
    if id == NAT_DATE_PARSE:
        pv: int32 = arg_or(base, argc, 0)
        return v_number(date_parse_iso(strid_of(to_string_val(pv))))
    if id == NAT_DATE_UTC:
        if argc < 1:
            return v_number(0.0 / 0.0)
        return v_number(date_utc_of(base, argc))
    if id == NAT_DATE_TZOFFSET:
        return v_number(0.0)
    if id == NAT_DATE_TOLOCALEDATESTRING:
        return v_string_id(intl_locale_strid(date_ms_of(thisv), 0))
    if id == NAT_DATE_TOLOCALETIMESTRING:
        return v_string_id(intl_locale_strid(date_ms_of(thisv), 1))
    if id == NAT_DATE_TOLOCALESTRING:
        return v_string_id(intl_locale_strid(date_ms_of(thisv), 2))
    if id == NAT_DATE_SETTIME or id == NAT_DATE_SETFULLYEAR or id == NAT_DATE_SETMONTH or id == NAT_DATE_SETDATE or id == NAT_DATE_SETHOURS or id == NAT_DATE_SETMINUTES or id == NAT_DATE_SETSECONDS or id == NAT_DATE_SETMS:
        return date_set_field(thisv, id, base, argc)
    return v_undef()


# ---- installer: Intl namespace + Date prototype/static extensions -----------
# Appends to the globals set up by install_builtins (called at its tail).
def install_intl():
    # Intl.NumberFormat
    g_intl_nf_proto = v_new_object()
    obj_add_native(g_intl_nf_proto, cast[Ptr[uint8]]("format"), NAT_INTL_NF_FORMAT)
    g_intl_nf: int32 = v_new_native(NAT_INTL_NUMBERFORMAT)
    obj_set(objid_of(g_intl_nf), str_from_cstr(cast[Ptr[uint8]]("prototype")), g_intl_nf_proto)
    obj_set(objid_of(g_intl_nf_proto), str_from_cstr(cast[Ptr[uint8]]("constructor")), g_intl_nf)
    # Intl.DateTimeFormat
    g_intl_dtf_proto = v_new_object()
    obj_add_native(g_intl_dtf_proto, cast[Ptr[uint8]]("format"), NAT_INTL_DTF_FORMAT)
    g_intl_dtf: int32 = v_new_native(NAT_INTL_DATETIMEFORMAT)
    obj_set(objid_of(g_intl_dtf), str_from_cstr(cast[Ptr[uint8]]("prototype")), g_intl_dtf_proto)
    obj_set(objid_of(g_intl_dtf_proto), str_from_cstr(cast[Ptr[uint8]]("constructor")), g_intl_dtf)
    g_intl: int32 = v_new_object()
    obj_set(objid_of(g_intl), str_from_cstr(cast[Ptr[uint8]]("NumberFormat")), g_intl_nf)
    obj_set(objid_of(g_intl), str_from_cstr(cast[Ptr[uint8]]("DateTimeFormat")), g_intl_dtf)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Intl")), g_intl, 0)

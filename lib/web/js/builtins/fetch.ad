# lib/web/js/builtins/fetch.ad — part of the modular web engine (extracted from jsengine.ad).
# fetch() + Response — deterministic, extern-free, dual-target.
#
# Behavior-preserving split: Adder is a single-compilation-unit language
# (merge_programs merges all imported files into one Program), so every
# public top-level name here resolves globally across the merged engine.


# ====================================================================
# fetch() + Response. Deterministic, extern-free, dual-target: fetch resolves
# from the JS-settable FIXTURE table (fx_*), NOT wall-clock network. It returns
# a Promise<Response>; each body method returns its OWN Promise settled on the
# #178 microtask queue, so `await fetch(u)` / `.then(r => r.json())` compose
# with #186 Promises + #187 async/await. An unmatched url (or a status-0 row =
# network error) REJECTS with a TypeError so `.catch` fires. On-device this same
# fixture path is the only data source (jsengine takes no externs); a front-end
# such as hambrowse is where real http9 traffic is wired.
# ====================================================================

# Scratch for lowercasing a header name during raw-response parse (top-level BSS
# per the compiler's 4 KiB-stack discipline; header names are short).
fh_name: Array[512, uint8]


# Register / overwrite a fixture row. opts = {status?, statusText?, body?,
# contentType?}. Missing fields default (200 / "OK" / "" / "text/plain").
def set_fetch_fixture(url_sid: int32, opts: int32):
    row: int32 = -1
    i: int32 = 0
    while i < fx_n:
        if str_eq(fx_url[i], url_sid) != 0:
            row = i
            i = fx_n
        else:
            i = i + 1
    if row < 0:
        if fx_n >= FETCH_FIXTURE_CAP:
            return
        row = fx_n
        fx_n = fx_n + 1
    fx_url[row] = url_sid
    # status (default 200)
    stv: int32 = 200
    bodysid: int32 = str_from_cstr(cast[Ptr[uint8]](""))
    stextsid: int32 = -1
    ctypesid: int32 = str_from_cstr(cast[Ptr[uint8]]("text/plain"))
    if tag_of(opts) == TAG_OBJ:
        oo: int32 = objid_of(opts)
        sv: int32 = obj_get_cstr(oo, cast[Ptr[uint8]]("status"))
        if tag_of(sv) == TAG_NUM:
            stv = cast[int32](to_number(sv))
        bv: int32 = obj_get_cstr(oo, cast[Ptr[uint8]]("body"))
        if tag_of(bv) != TAG_UNDEF:
            bodysid = strid_of(to_string_val(bv))
        tv: int32 = obj_get_cstr(oo, cast[Ptr[uint8]]("statusText"))
        if tag_of(tv) != TAG_UNDEF:
            stextsid = strid_of(to_string_val(tv))
        cv: int32 = obj_get_cstr(oo, cast[Ptr[uint8]]("contentType"))
        if tag_of(cv) != TAG_UNDEF:
            ctypesid = strid_of(to_string_val(cv))
    fx_status[row] = stv
    fx_body[row] = bodysid
    fx_ctype[row] = ctypesid
    if stextsid < 0:
        stextsid = str_from_cstr(status_text_default(stv))
    fx_stext[row] = stextsid


# A tiny default reason-phrase table (enough for the common statuses).
def status_text_default(s: int32) -> Ptr[uint8]:
    if s == 200:
        return cast[Ptr[uint8]]("OK")
    if s == 201:
        return cast[Ptr[uint8]]("Created")
    if s == 204:
        return cast[Ptr[uint8]]("No Content")
    if s == 301:
        return cast[Ptr[uint8]]("Moved Permanently")
    if s == 302:
        return cast[Ptr[uint8]]("Found")
    if s == 304:
        return cast[Ptr[uint8]]("Not Modified")
    if s == 400:
        return cast[Ptr[uint8]]("Bad Request")
    if s == 401:
        return cast[Ptr[uint8]]("Unauthorized")
    if s == 403:
        return cast[Ptr[uint8]]("Forbidden")
    if s == 404:
        return cast[Ptr[uint8]]("Not Found")
    if s == 500:
        return cast[Ptr[uint8]]("Internal Server Error")
    return cast[Ptr[uint8]]("")


# ---- Headers object -------------------------------------------------
# A Headers holds two parallel ordered arrays of string VALUES on hidden slots
# "__hn" (lowercased names) and "__hv" (raw values), plus case-insensitive
# get/has and an entries() view. This backs BOTH the fixture path (one synthetic
# content-type entry) and the real-network path (every parsed response header),
# so header reads behave identically on host and device.
def _new_headers() -> int32:
    hv: int32 = v_new_object()
    ho: int32 = objid_of(hv)
    obj_set(ho, str_from_cstr(cast[Ptr[uint8]]("__hn")), v_new_array())
    obj_set(ho, str_from_cstr(cast[Ptr[uint8]]("__hv")), v_new_array())
    obj_add_native(hv, cast[Ptr[uint8]]("get"), NAT_HEADERS_GET)
    obj_add_native(hv, cast[Ptr[uint8]]("has"), NAT_HEADERS_HAS)
    obj_add_native(hv, cast[Ptr[uint8]]("entries"), NAT_HEADERS_ENTRIES)
    return hv


def _headers_push(hv: int32, name_val: int32, val_val: int32):
    ho: int32 = objid_of(hv)
    hn: int32 = obj_get_cstr(ho, cast[Ptr[uint8]]("__hn"))
    hvv: int32 = obj_get_cstr(ho, cast[Ptr[uint8]]("__hv"))
    arr_push(objid_of(hn), name_val)
    arr_push(objid_of(hvv), val_val)


# Build a Response object from a fixture row's fields. Body is stashed on the
# hidden "__body" slot that the body methods read via `this`.
def make_response(status: int32, stext_sid: int32, body_sid: int32, ctype_sid: int32, url_sid: int32) -> int32:
    rv: int32 = v_new_object()
    o: int32 = objid_of(rv)
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("status")), v_number(cast[float64](status)))
    okb: int32 = 0
    if status >= 200 and status < 300:
        okb = 1
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("ok")), v_boolv(okb))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("statusText")), v_string_id(stext_sid))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("url")), v_string_id(url_sid))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("__body")), v_string_id(body_sid))
    hv: int32 = _new_headers()
    _headers_push(hv, v_string_cstr(cast[Ptr[uint8]]("content-type")), v_string_id(ctype_sid))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("headers")), hv)
    obj_add_native(rv, cast[Ptr[uint8]]("text"), NAT_RESPONSE_TEXT)
    obj_add_native(rv, cast[Ptr[uint8]]("json"), NAT_RESPONSE_JSON)
    obj_add_native(rv, cast[Ptr[uint8]]("arrayBuffer"), NAT_RESPONSE_ARRAYBUF)
    return rv


# A JS string value from raw[a..b).
def _raw_str(rawp: Ptr[uint8], a: int32, b: int32) -> int32:
    if b <= a:
        return v_string_cstr(cast[Ptr[uint8]](""))
    return v_string_id(str_new(cast[Ptr[uint8]](cast[uint64](rawp) + cast[uint64](a)), b - a))


# A JS string value from raw[a..b) with ASCII A-Z folded to lowercase (header
# names are compared case-insensitively; storing them lowercased makes entries()
# spec-shaped and get()/has() a plain compare).
def _raw_lstr(rawp: Ptr[uint8], a: int32, b: int32) -> int32:
    n: int32 = b - a
    if n <= 0:
        return v_string_cstr(cast[Ptr[uint8]](""))
    i: int32 = 0
    while i < n and i < 512:
        c: uint8 = rawp[a + i]
        if c >= cast[uint8](65) and c <= cast[uint8](90):
            c = c + cast[uint8](32)
        fh_name[i] = c
        i = i + 1
    return v_string_id(str_new(&fh_name[0], i))


# Build a Response from RAW HTTP response bytes (status line + headers + CRLFCRLF
# + body) returned by the embedder's transport. Parses the header block into a
# full Headers object and slices the body. This is the SAME parse whether the raw
# bytes came from the kernel http9 client on-device or a canned fixture in a host
# unit test, so the on-device path is exercised without a network.
def make_response_net(rawp: Ptr[uint8], rawlen: int32, status: int64, url_sid: int32) -> int32:
    # Header terminator -> body offset. Absent => the whole buffer is "headers"
    # (no body); tolerated for a malformed/short response.
    bodystart: int32 = rawlen
    hdr_block_end: int32 = rawlen
    p: int32 = 0
    while p + 3 < rawlen:
        if rawp[p] == cast[uint8](13) and rawp[p + 1] == cast[uint8](10) \
                and rawp[p + 2] == cast[uint8](13) and rawp[p + 3] == cast[uint8](10):
            hdr_block_end = p + 2
            bodystart = p + 4
            break
        p = p + 1

    # End of the status line (first CRLF, else the header-block end).
    line1_end: int32 = hdr_block_end
    q: int32 = 0
    while q + 1 < rawlen:
        if rawp[q] == cast[uint8](13) and rawp[q + 1] == cast[uint8](10):
            line1_end = q
            break
        q = q + 1

    rv: int32 = v_new_object()
    o: int32 = objid_of(rv)
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("status")), v_number(cast[float64](status)))
    okb: int32 = 0
    if status >= 200 and status < 300:
        okb = 1
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("ok")), v_boolv(okb))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("url")), v_string_id(url_sid))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("__body")), _raw_str(rawp, bodystart, rawlen))

    # statusText = the reason phrase after "HTTP/1.x NNN ".
    st_start: int32 = 0
    sp_seen: int32 = 0
    r: int32 = 0
    while r < line1_end:
        if rawp[r] == cast[uint8](32):
            sp_seen = sp_seen + 1
            if sp_seen == 2:
                st_start = r + 1
                r = line1_end
        r = r + 1
    stext_val: int32 = v_string_cstr(cast[Ptr[uint8]](""))
    if sp_seen >= 2 and st_start < line1_end:
        stext_val = _raw_str(rawp, st_start, line1_end)
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("statusText")), stext_val)

    # Parse each header line between the status line and the blank line.
    hv: int32 = _new_headers()
    line: int32 = line1_end + 2
    while line < hdr_block_end:
        le: int32 = line
        while le < hdr_block_end and rawp[le] != cast[uint8](10):
            le = le + 1
        # trim a trailing CR
        val_end: int32 = le
        if val_end > line and rawp[val_end - 1] == cast[uint8](13):
            val_end = val_end - 1
        if val_end <= line:
            line = le + 1
            continue
        colon: int32 = line
        while colon < val_end and rawp[colon] != cast[uint8](58):
            colon = colon + 1
        if colon < val_end:
            vstart: int32 = colon + 1
            while vstart < val_end and (rawp[vstart] == cast[uint8](32) or rawp[vstart] == cast[uint8](9)):
                vstart = vstart + 1
            _headers_push(hv, _raw_lstr(rawp, line, colon), _raw_str(rawp, vstart, val_end))
        line = le + 1
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("headers")), hv)

    obj_add_native(rv, cast[Ptr[uint8]]("text"), NAT_RESPONSE_TEXT)
    obj_add_native(rv, cast[Ptr[uint8]]("json"), NAT_RESPONSE_JSON)
    obj_add_native(rv, cast[Ptr[uint8]]("arrayBuffer"), NAT_RESPONSE_ARRAYBUF)
    return rv


# True if a URL string id begins with "http://" or "https://" (an absolute HTTP
# URL that the network transport can dial). Bare fixture keys ('u', 'nf', ...)
# are NOT absolute, so they route to the fixture table even with a transport set.
def _is_abs_http(url_sid: int32) -> int32:
    n: int32 = str_len(url_sid)
    p: Ptr[uint8] = str_ptr(url_sid)
    http: Ptr[uint8] = "http://"
    if n >= 7:
        ok: int32 = 1
        i: int32 = 0
        while i < 7:
            if p[i] != http[i]:
                ok = 0
                i = 7
            i = i + 1
        if ok != 0:
            return 1
    https: Ptr[uint8] = "https://"
    if n >= 8:
        ok2: int32 = 1
        j: int32 = 0
        while j < 8:
            if p[j] != https[j]:
                ok2 = 0
                j = 8
            j = j + 1
        if ok2 != 0:
            return 1
    return 0


# fetch(url[, init]) -> Promise<Response>.
#
# With a registered network transport AND an absolute http(s):// url, performs a
# REAL request through the embedder's kernel http9 client (Plan-9 /net; NO
# sockets in the engine) and settles from the returned raw bytes. init.method
# (default GET) and init.body (for POST) are forwarded. A transport/DNS/connect
# failure REJECTS (TypeError); a non-2xx HTTP status FULFILLS with ok=false, per
# the Fetch spec. Otherwise (no transport, or a non-absolute url) settles against
# the deterministic __setFetchFixture table. Settling synchronously is fine: a
# settled promise still schedules its .then reactions as microtasks.
def do_fetch(base: int32, argc: int32) -> int32:
    urlsid: int32 = strid_of(to_string_val(arg_or(base, argc, 0)))
    p: int32 = new_promise()
    po: int32 = objid_of(p)

    if fetch_transport_set != 0 and _is_abs_http(urlsid) != 0:
        # method / body from init (arg1)
        method_sid: int32 = str_from_cstr(cast[Ptr[uint8]]("GET"))
        body_sid: int32 = str_from_cstr(cast[Ptr[uint8]](""))
        init: int32 = arg_or(base, argc, 1)
        if tag_of(init) == TAG_OBJ:
            io: int32 = objid_of(init)
            mv: int32 = obj_get_cstr(io, cast[Ptr[uint8]]("method"))
            if tag_of(mv) != TAG_UNDEF:
                method_sid = strid_of(to_string_val(mv))
            bv: int32 = obj_get_cstr(io, cast[Ptr[uint8]]("body"))
            if tag_of(bv) != TAG_UNDEF:
                body_sid = strid_of(to_string_val(bv))
        outstatus: int64 = 0
        outlen: int32 = 0
        tfn: Fn[Ptr[uint8], int32, Ptr[uint8], int32, Ptr[uint8], int32, Ptr[int64], Ptr[int32], Ptr[uint8]] = \
            cast[Fn[Ptr[uint8], int32, Ptr[uint8], int32, Ptr[uint8], int32, Ptr[int64], Ptr[int32], Ptr[uint8]]](fetch_transport_addr)
        rawp: Ptr[uint8] = tfn(str_ptr(urlsid), str_len(urlsid), \
                               str_ptr(method_sid), str_len(method_sid), \
                               str_ptr(body_sid), str_len(body_sid), \
                               &outstatus, &outlen)
        if cast[uint64](rawp) == 0 or outlen <= 0:
            promise_reject(po, make_type_error(cast[Ptr[uint8]]("fetch failed: network error")))
            return p
        resp: int32 = make_response_net(rawp, outlen, outstatus, urlsid)
        promise_fulfill(po, resp)
        return p

    i: int32 = 0
    while i < fx_n:
        if str_eq(fx_url[i], urlsid) != 0:
            if fx_status[i] == 0:
                promise_reject(po, make_type_error(cast[Ptr[uint8]]("fetch failed: network error")))
                return p
            fresp: int32 = make_response(fx_status[i], fx_stext[i], fx_body[i], fx_ctype[i], urlsid)
            promise_fulfill(po, fresp)
            return p
        i = i + 1
    promise_reject(po, make_type_error(cast[Ptr[uint8]]("fetch failed: no fixture registered for url")))
    return p


# Response.prototype.text() -> Promise<string> (fulfilled with the body).
def response_text(thisv: int32) -> int32:
    p: int32 = new_promise()
    bodyv: int32 = v_string_cstr(cast[Ptr[uint8]](""))
    if tag_of(thisv) == TAG_OBJ:
        bodyv = obj_get_cstr(objid_of(thisv), cast[Ptr[uint8]]("__body"))
    promise_fulfill(objid_of(p), bodyv)
    return p


# Response.prototype.json() -> Promise<parsed> (reuses JSON.parse #157; a parse
# error rejects the promise so `.catch` fires).
def response_json(thisv: int32) -> int32:
    p: int32 = new_promise()
    bodyv: int32 = v_string_cstr(cast[Ptr[uint8]](""))
    if tag_of(thisv) == TAG_OBJ:
        bodyv = obj_get_cstr(objid_of(thisv), cast[Ptr[uint8]]("__body"))
    parsed: int32 = json_parse_val(bodyv, v_undef())
    if ctl == CTL_THROW:
        reason: int32 = throw_val
        ctl = CTL_NONE
        promise_reject(objid_of(p), reason)
        return p
    promise_fulfill(objid_of(p), parsed)
    return p


# Response.prototype.arrayBuffer() -> Promise<array of byte values> (a simple
# byte view of the body — enough for the common consume-then-inspect pattern).
def response_arraybuffer(thisv: int32) -> int32:
    p: int32 = new_promise()
    av: int32 = v_new_array()
    ao: int32 = objid_of(av)
    if tag_of(thisv) == TAG_OBJ:
        bv: int32 = obj_get_cstr(objid_of(thisv), cast[Ptr[uint8]]("__body"))
        if tag_of(bv) == TAG_STR:
            bsid: int32 = strid_of(bv)
            bp: Ptr[uint8] = str_ptr(bsid)
            bn: int32 = str_len(bsid)
            k: int32 = 0
            while k < bn:
                arr_push(ao, v_number(cast[float64](cast[int32](bp[k]))))
                k = k + 1
    promise_fulfill(objid_of(p), av)
    return p


# Find the index of a header (case-insensitive) in a Headers object, or -1.
def _headers_index(thisv: int32, name_sid: int32) -> int32:
    if tag_of(thisv) != TAG_OBJ:
        return -1
    ho: int32 = objid_of(thisv)
    hn: int32 = obj_get_cstr(ho, cast[Ptr[uint8]]("__hn"))
    if tag_of(hn) != TAG_OBJ:
        return -1
    hno: int32 = objid_of(hn)
    np: Ptr[uint8] = str_ptr(name_sid)
    nn: int32 = str_len(name_sid)
    n: int32 = arr_len[hno]
    i: int32 = 0
    while i < n:
        nv: int32 = arr_get(hno, i)
        if tag_of(nv) == TAG_STR:
            sid: int32 = strid_of(nv)
            if _ci_eq(str_ptr(sid), str_len(sid), np, nn) != 0:
                return i
        i = i + 1
    return -1


# Headers.prototype.get(name) -> value | null. Case-insensitive; scans every
# parsed response header (content-type, content-length, server, ...). Returns the
# FIRST match's value (duplicate-header combination is deferred). Unknown -> null.
def headers_get(thisv: int32, name_sid: int32) -> int32:
    idx: int32 = _headers_index(thisv, name_sid)
    if idx < 0:
        return v_null()
    hvv: int32 = obj_get_cstr(objid_of(thisv), cast[Ptr[uint8]]("__hv"))
    return arr_get(objid_of(hvv), idx)


# Headers.prototype.has(name) -> bool. Case-insensitive.
def headers_has(thisv: int32, name_sid: int32) -> int32:
    if _headers_index(thisv, name_sid) >= 0:
        return v_boolv(1)
    return v_boolv(0)


# Headers.prototype.entries() -> [[name, value], ...] (array is iterable, so it
# works with for-of / spread; a live iterator object is deferred). Names are the
# stored lowercased forms, matching the Fetch spec's header iteration order.
def headers_entries(thisv: int32) -> int32:
    out: int32 = v_new_array()
    if tag_of(thisv) != TAG_OBJ:
        return out
    ho: int32 = objid_of(thisv)
    hn: int32 = obj_get_cstr(ho, cast[Ptr[uint8]]("__hn"))
    hvv: int32 = obj_get_cstr(ho, cast[Ptr[uint8]]("__hv"))
    if tag_of(hn) != TAG_OBJ:
        return out
    hno: int32 = objid_of(hn)
    hvo: int32 = objid_of(hvv)
    n: int32 = arr_len[hno]
    i: int32 = 0
    while i < n:
        pair: int32 = v_new_array()
        arr_push(objid_of(pair), arr_get(hno, i))
        arr_push(objid_of(pair), arr_get(hvo, i))
        arr_push(objid_of(out), pair)
        i = i + 1
    return out


# Case-insensitive compare of two (ptr,len) ASCII strings.
def _ci_eq(p1: Ptr[uint8], n1: int32, p2: Ptr[uint8], n2: int32) -> int32:
    if n1 != n2:
        return 0
    i: int32 = 0
    while i < n1:
        a: uint8 = p1[i]
        b: uint8 = p2[i]
        if a >= cast[uint8](65) and a <= cast[uint8](90):
            a = a + cast[uint8](32)
        if b >= cast[uint8](65) and b <= cast[uint8](90):
            b = b + cast[uint8](32)
        if a != b:
            return 0
        i = i + 1
    return 1


# Called at the exit of an async function body to turn its outcome into the
# promise the call returned: a normal return / fall-through fulfills (assimilating
# a returned thenable), an uncaught throw rejects. Normalizes `ctl` back to NONE.
def async_wrap_return(rv: int32) -> int32:
    p: int32 = new_promise()
    po: int32 = objid_of(p)
    if ctl == CTL_THROW:
        reason: int32 = throw_val
        ctl = CTL_NONE
        promise_reject(po, reason)
    else:
        ctl = CTL_NONE
        resolve_promise(po, rv)            # assimilate a returned promise/thenable
    return p


# A TypeError value handle (for cycle detection) without going through `throw`.
def make_type_error(msg: Ptr[uint8]) -> int32:
    ev: int32 = v_new_object()
    o: int32 = objid_of(ev)
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("name")), v_string_cstr(cast[Ptr[uint8]]("TypeError")))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("message")), v_string_cstr(msg))
    return ev


# ---- combinators: Promise.all / race / allSettled ----
# Each element gets a native fulfilled/rejected hook carrying (comb cell, index)
# on its function object; the hooks drive the shared cell to settle the result.
def make_comb_cb(comb: int32, idx: int32, nat: int32) -> int32:
    fv: int32 = v_new_native(nat)
    obj_p_a[objid_of(fv)] = comb
    obj_p_b[objid_of(fv)] = idx
    return fv


def comb_alloc(kind: int32, result: int32, n: int32, results: int32) -> int32:
    c: int32 = comb_n
    comb_n = comb_n + 1
    comb_kind[c] = cast[uint8](kind)
    comb_result[c] = result
    comb_remaining[c] = n
    comb_results[c] = results
    return c


def promise_combinator(iterable: int32, kind: int32) -> int32:
    result: int32 = new_promise()
    if is_array(iterable) == 0:
        promise_reject(objid_of(result), make_type_error(cast[Ptr[uint8]]("argument is not iterable")))
        return result
    ao: int32 = objid_of(iterable)
    n: int32 = arr_len[ao]
    results: int32 = v_new_array()
    if kind != 1:                     # all / allSettled prefill result slots
        i0: int32 = 0
        while i0 < n:
            arr_set(objid_of(results), i0, v_undef())
            i0 = i0 + 1
    if n == 0:
        # all([]) / allSettled([]) fulfill immediately; race([]) stays pending.
        if kind != 1:
            promise_fulfill(objid_of(result), results)
        return result
    if comb_n >= COMB_CAP:
        return result
    comb: int32 = comb_alloc(kind, result, n, results)
    i: int32 = 0
    while i < n:
        elem: int32 = arr_get(ao, i)
        p: int32 = promise_resolve_static(elem)
        ff: int32 = make_comb_cb(comb, i, NAT_COMB_FUL)
        rf: int32 = make_comb_cb(comb, i, NAT_COMB_REJ)
        promise_then(p, ff, rf)
        i = i + 1
    return result


# A combinator element fulfilled: native_self carries (comb cell, index).
def comb_on_fulfilled(fo: int32, value: int32):
    comb: int32 = obj_p_a[fo]
    idx: int32 = obj_p_b[fo]
    kind: int32 = cast[int32](comb_kind[comb])
    result: int32 = comb_result[comb]
    if kind == 1:                     # race: first settle wins
        resolve_promise(objid_of(result), value)
        return
    if kind == 0:                     # all: collect, resolve when none remain
        arr_set(objid_of(comb_results[comb]), idx, value)
    else:                             # allSettled: {status:'fulfilled', value}
        rec: int32 = v_new_object()
        obj_set(objid_of(rec), str_from_cstr(cast[Ptr[uint8]]("status")), v_string_cstr(cast[Ptr[uint8]]("fulfilled")))
        obj_set(objid_of(rec), str_from_cstr(cast[Ptr[uint8]]("value")), value)
        arr_set(objid_of(comb_results[comb]), idx, rec)
    comb_remaining[comb] = comb_remaining[comb] - 1
    if comb_remaining[comb] == 0:
        promise_fulfill(objid_of(result), comb_results[comb])


def comb_on_rejected(fo: int32, reason: int32):
    comb: int32 = obj_p_a[fo]
    idx: int32 = obj_p_b[fo]
    kind: int32 = cast[int32](comb_kind[comb])
    result: int32 = comb_result[comb]
    if kind == 2:                     # allSettled: {status:'rejected', reason}
        rec: int32 = v_new_object()
        obj_set(objid_of(rec), str_from_cstr(cast[Ptr[uint8]]("status")), v_string_cstr(cast[Ptr[uint8]]("rejected")))
        obj_set(objid_of(rec), str_from_cstr(cast[Ptr[uint8]]("reason")), reason)
        arr_set(objid_of(comb_results[comb]), idx, rec)
        comb_remaining[comb] = comb_remaining[comb] - 1
        if comb_remaining[comb] == 0:
            promise_fulfill(objid_of(result), comb_results[comb])
        return
    # all / race: first rejection rejects the result (guarded, so once)
    promise_reject(objid_of(result), reason)


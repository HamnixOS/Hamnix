# lib/web/js/gc.ad — part of the modular web engine.
# GARBAGE COLLECTOR (Phase 1): a stop-the-world mark-sweep collector for the
# JS VALUE arena (v_tag/v_num/v_ref). Object/property/env/array-storage/string
# arenas stay bump-only this phase; reclaiming just the value arena is enough to
# unblock the numeric-loop class of scripts (which exhausted the arena at
# ~400-500k allocations) while keeping the audit small and sound.
#
# SOUNDNESS MODEL — "a GC that frees a live value is worse than a leak":
#   * WHOLESALE ROOTS. Every arena that can store a value handle is marked in
#     full, so any value reachable through an object property, array element,
#     env binding, Map/Set entry, promise reaction, timer, module namespace, or
#     builtin global is retained WITHOUT a transitive graph walk (which also
#     sidesteps cycles). This is deliberately conservative: it may retain some
#     floating garbage (e.g. a value still sitting in a since-orphaned slot), but
#     it can never free something still referenced anywhere.
#   * PINNED TRANSIENTS. The only values not covered wholesale are handles held
#     in Adder native locals across a nested allocation. The core interpreter
#     sites that do this pin them on the gc_root stack (gc_push/gc_popto).
#   * SUPPRESSION. Un-audited native/builtin calls run with gc_disabled > 0, so a
#     collection can never fire while their (un-pinned) locals are live.
#
# Because objects are never freed in Phase 1, marking a value that is "really" an
# object id (a few ambiguous native-closure payload fields) is harmless: it just
# pins the value cell with that index. It can never cause a live value to be
# swept.

# Mark a value handle as reachable. Singletons 0..3 are never swept, so marking
# them is a no-op; out-of-range handles (e.g. -1 sentinels, object ids past
# n_vals) are ignored.
def gc_m(h: int32):
    if h >= 0 and h < n_vals:
        v_mark[h] = cast[uint8](1)


# Stop-the-world mark-sweep of the value arena. Rebuilds the free list from every
# currently-unreachable cell. Safe to call at any allocation point: at that
# moment every live handle is reachable from one of the roots below (arena slot
# or gc_root pin) and the value about to be constructed does not exist yet.
def gc_collect():
    gc_collections = gc_collections + 1
    # ---- clear marks over the live extent ----
    i: int32 = 0
    while i < n_vals:
        v_mark[i] = cast[uint8](0)
        i = i + 1
    # ---- ROOTS (wholesale over every value-bearing arena) ----
    # explicit transient pins
    r: int32 = 0
    while r < gc_top:
        gc_m(gc_root[r])
        r = r + 1
    # environment bindings (envs are never freed in Phase 1, so all are live)
    r = 0
    while r < n_binds:
        gc_m(b_val[r])
        r = r + 1
    # object properties (data value + accessor getter/setter handles)
    r = 0
    while r < n_props:
        gc_m(p_val[r])
        gc_m(p_get[r])
        gc_m(p_set[r])
        r = r + 1
    # array element storage
    r = 0
    while r < ax_top:
        gc_m(ax_val[r])
        r = r + 1
    # in-flight call arguments
    r = 0
    while r < call_top:
        gc_m(call_args[r])
        r = r + 1
    # active call frames' `this` (home/curfn hold OBJECT ids, not value handles)
    r = 0
    while r < this_top:
        gc_m(this_stack[r])
        r = r + 1
    # control-flow + member-set-hook scratch values
    gc_m(ctl_val)
    gc_m(throw_val)
    gc_m(mset_this_v)
    gc_m(mset_key_v)
    gc_m(mset_val_v)
    # Map / Set entries
    r = 0
    while r < mse_n:
        gc_m(mse_key[r])
        gc_m(mse_val[r])
        r = r + 1
    # pending promise reactions
    r = 0
    while r < pr_n:
        gc_m(pr_onful[r])
        gc_m(pr_onrej[r])
        gc_m(pr_result[r])
        r = r + 1
    # promise combinator cells
    r = 0
    while r < comb_n:
        gc_m(comb_result[r])
        gc_m(comb_results[r])
        r = r + 1
    # deferred-callback (timer/microtask/raf) queue
    r = 0
    while r < timer_next:
        gc_m(timer_fn[r])
        r = r + 1
    r = 0
    while r < timer_next * TIMER_MAX_ARGS:
        gc_m(timer_args[r])
        r = r + 1
    # ES-module namespace objects
    r = 0
    while r < mod_n:
        gc_m(mod_ns[r])
        r = r + 1
    # per-object value-handle fields. Objects are never freed in Phase 1, so
    # every value ANY allocated object references is retained (conservative).
    # obj_p_a/obj_p_b are context-dependent (value OR object id depending on the
    # native-closure kind) — marking them as values is safe either way.
    r = 0
    while r < n_objs:
        gc_m(obj_fn_this[r])
        gc_m(obj_fn_super[r])
        gc_m(obj_fn_btarget[r])
        gc_m(obj_fn_bthis[r])
        gc_m(obj_fn_bargs[r])
        gc_m(obj_proxy_target[r])
        gc_m(obj_proxy_handler[r])
        gc_m(obj_ta_buf[r])
        gc_m(obj_p_a[r])
        gc_m(obj_p_b[r])
        gc_m(prom_result[r])
        gc_m(gen_buf[r])
        gc_m(gen_ret[r])
        r = r + 1
    # builtin globals + well-known singletons (each a value handle held only in a
    # global, so unreachable via any arena — must be marked explicitly)
    gc_m(g_global_obj)
    gc_m(g_math)
    gc_m(g_json)
    gc_m(g_object)
    gc_m(g_console)
    gc_m(g_array)
    gc_m(g_function)
    gc_m(g_number)
    gc_m(g_bigint)
    gc_m(g_promise)
    gc_m(g_promise_proto)
    gc_m(g_promise_job)
    gc_m(g_sym_iterator)
    gc_m(g_sym_async)
    gc_m(g_gen_proto)
    gc_m(g_object_proto)
    gc_m(g_array_proto)
    gc_m(g_func_proto)
    gc_m(g_string_proto)
    gc_m(g_number_proto)
    gc_m(g_boolean_proto)
    r = 0
    while r < 16:
        gc_m(g_ta_proto[r])
        r = r + 1
    # Intl / URL / FormData prototypes (values; -1 while uninstalled)
    gc_m(g_intl_nf_proto)
    gc_m(g_intl_dtf_proto)
    gc_m(g_url_proto)
    gc_m(g_urlsp_proto)
    gc_m(g_formdata_proto)
    gc_m(g_xhr_proto)
    # ---- SWEEP: every unmarked cell (incl. cells already on the old free list)
    # goes on a freshly-rebuilt intrusive free list, chained through v_ref. Reset
    # the head first so a still-free cell is added exactly once (no duplication).
    gc_free_head = -1
    freed: int32 = 0
    h: int32 = n_vals - 1
    while h >= 4:
        if v_mark[h] == 0:
            v_tag[h] = cast[uint8](TAG_FREE)
            v_ref[h] = gc_free_head
            gc_free_head = h
            freed = freed + 1
        h = h - 1
    gc_last_freed = freed
    # ---- ENV arena reclamation (Phase 3): a value collection is a natural
    # stop-the-world point where EVERY active env is pinned (env_root) exactly
    # as the value roots are, so piggyback the env mark-sweep here. It never
    # frees a value cell (only envs/binds), so it cannot disturb the value sweep
    # above regardless of order.
    gc_collect_envs()
    # ---- trigger policy: pick the next high-water mark ----
    # Stress: keep collecting on a tiny gap so roots are exercised constantly.
    # Otherwise: if we freed enough, stay at the base water; if not, RAISE the
    # water (the fixed BSS arena cannot literally grow) so we don't thrash — we
    # bump toward MAX_VAL and mk_val surfaces a clean "value pool exhausted".
    if gc_stress != 0:
        nw2: int32 = n_vals + GC_STRESS_GAP
        if nw2 > MAX_VAL:
            nw2 = MAX_VAL
        gc_hi_water = nw2
    elif freed >= GC_MIN_FREE:
        gc_hi_water = gc_base_water
    else:
        nw: int32 = n_vals + GC_GROW
        if nw > MAX_VAL:
            nw = MAX_VAL
        gc_hi_water = nw


# Mark an env id as reachable (guards -1 sentinels and out-of-range ids).
def env_gc_m(e: int32):
    if e >= 0 and e < n_envs:
        env_mark[e] = cast[uint8](1)


# Stop-the-world mark-sweep of the ENV (scope) arena — reclaims dead scope envs
# and their binding chains onto free lists that env_new / env_define pop before
# bumping. SOUND at any point where every ACTIVE env is pinned on env_root: at a
# value-collection trigger (mk_val, deep in eval) and at an env-pressure trigger
# (env_new), the whole dynamic call/block/loop stack is pinned by construction.
def gc_collect_envs():
    env_collections = env_collections + 1
    # ---- clear marks over the live extent ----
    i: int32 = 0
    while i < n_envs:
        env_mark[i] = cast[uint8](0)
        i = i + 1
    # ---- ROOTS ----
    env_gc_m(g_env)                        # global scope
    r: int32 = 0
    while r < mod_n:                       # every module scope
        env_gc_m(mod_env[r])
        r = r + 1
    # Every live closure's captured env. Objects are never freed, so marking ALL
    # obj_fn_env wholesale retains every scope any function value can resume into
    # (-1 for non-function objects is ignored by env_gc_m).
    r = 0
    while r < n_objs:
        env_gc_m(obj_fn_env[r])
        r = r + 1
    # Every currently-active env threaded through the interpreter recursion.
    r = 0
    while r < env_gc_top:
        env_gc_m(env_root[r])
        r = r + 1
    # ---- transitive closure: parent id < child id makes ONE descending pass
    # complete (marking a marked env's parent can only mark a SMALLER id we have
    # not yet visited). A freed env is never marked (unreachable), so its
    # repurposed env_parent free-link is never dereferenced here.
    e: int32 = n_envs - 1
    while e >= 0:
        if env_mark[e] != 0 and env_parent[e] >= 0:
            env_mark[env_parent[e]] = cast[uint8](1)
        e = e - 1
    # ---- SWEEP: every live-but-unmarked env is freed exactly once (env_freed
    # guards against re-freeing an env already on the free list). Its bindings
    # splice onto the binding free list; env_head is cleared and env_parent is
    # repurposed as the free-env link.
    freed: int32 = 0
    e2: int32 = n_envs - 1
    while e2 >= 0:
        if env_mark[e2] == 0 and env_freed[e2] == 0:
            b: int32 = env_head[e2]
            while b >= 0:
                nb: int32 = b_next[b]
                b_next[b] = bind_free_head
                bind_free_head = b
                b = nb
            env_head[e2] = -1
            env_freed[e2] = cast[uint8](1)
            env_parent[e2] = env_free_head
            env_free_head = e2
            freed = freed + 1
        e2 = e2 - 1
    env_last_freed = freed
    # ---- trigger policy for the NEXT env collection (mirrors gc_collect) ----
    if gc_stress != 0:
        nw2: int32 = n_envs + ENV_STRESS_GAP
        if nw2 > MAX_ENV:
            nw2 = MAX_ENV
        env_hi_water = nw2
    elif freed >= ENV_MIN_FREE:
        env_hi_water = env_base_water
    else:
        nw: int32 = n_envs + ENV_GROW
        if nw > MAX_ENV:
            nw = MAX_ENV
        env_hi_water = nw


# Mark a string id as reachable (guards -1 sentinels and out-of-range ids).
def str_gc_m(s: int32):
    if s >= 0 and s < n_strs:
        str_mark[s] = cast[uint8](1)


# Stop-the-world mark-sweep of the STRING ID TABLE (Phase 4, NON-MOVING).
# Rebuilds the free list from every currently-unreachable id. sp_buf BYTES are
# NEVER touched (a reclaimed id's bytes leak), which is exactly what makes this
# safe to call at any string allocation point: at that moment every live id is
# reachable from a wholesale root (an arena slot) or protected by gc_disabled
# suppression, NO byte moves (so every raw sp_buf offset/pointer in flight stays
# valid), and the id about to be recorded does not exist yet.
def gc_collect_strings():
    str_collections = str_collections + 1
    # ---- clear marks over the live extent ----
    i: int32 = 0
    while i < n_strs:
        str_mark[i] = cast[uint8](0)
        i = i + 1
    # ---- ROOTS (wholesale over every string-id-bearing arena) ----
    # value cells that are strings (v_ref of a TAG_STR cell is a string id;
    # a TAG_FREE / TAG_OBJ / etc. cell's v_ref is NOT a string id, so gate on tag)
    r: int32 = 0
    while r < n_vals:
        if cast[int32](v_tag[r]) == TAG_STR:
            str_gc_m(v_ref[r])
        r = r + 1
    # property keys
    r = 0
    while r < n_props:
        str_gc_m(p_key[r])
        r = r + 1
    # binding names
    r = 0
    while r < n_binds:
        str_gc_m(b_name[r])
        r = r + 1
    # PERMANENT AST string ids. n_str is a sid (or unused) across every node kind;
    # the parser also stores sids in the secondary fields — n_a (regex flags),
    # n_d (template raw / import-export local+exported names), n_c (some object /
    # for-of keys). Marking n_str/n_a/n_b/n_c/n_d WHOLESALE cannot miss an AST sid;
    # a field that actually holds a child-node id just pins that string id (a
    # harmless leak — the AST is permanent and re-executed, so this is always live
    # anyway).
    r = 0
    while r < n_nodes:
        str_gc_m(n_str[r])
        str_gc_m(n_a[r])
        str_gc_m(n_b[r])
        str_gc_m(n_c[r])
        str_gc_m(n_d[r])
        r = r + 1
    # tokens (stale between parses; marking them is a harmless leak of low ids)
    r = 0
    while r < n_toks:
        str_gc_m(tk_str[r])
        str_gc_m(tk_str2[r])
        r = r + 1
    # module specifiers
    r = 0
    while r < mod_n:
        str_gc_m(mod_spec[r])
        r = r + 1
    # fetch fixtures (url key + statusText + body + content-type string ids)
    r = 0
    while r < fx_n:
        str_gc_m(fx_url[r])
        str_gc_m(fx_stext[r])
        str_gc_m(fx_body[r])
        str_gc_m(fx_ctype[r])
        r = r + 1
    # native method-name payloads. obj_p_a carries a method-name sid for real
    # prototype-method function objects; obj_p_b is marked too for safety margin
    # (a non-sid payload only pins whatever id equals that small int).
    r = 0
    while r < n_objs:
        str_gc_m(obj_p_a[r])
        str_gc_m(obj_p_b[r])
        r = r + 1
    # break/continue labels
    str_gc_m(ctl_label)
    str_gc_m(pending_label)
    # ---- SWEEP: rebuild the free list from every unmarked id (an unmarked id is
    # dead — no root references it — OR was already free; either way it is a valid
    # free id). Reset the head first so a still-free id is added exactly once. The
    # link is threaded through st_off (its byte offset is meaningless once dead).
    str_free_head = -1
    freed: int32 = 0
    s: int32 = n_strs - 1
    while s >= 0:
        if str_mark[s] == 0:
            st_off[s] = str_free_head
            st_len[s] = 0
            str_free_head = s
            freed = freed + 1
        s = s - 1
    str_last_freed = freed
    # ---- trigger policy for the NEXT string collection ----
    # Reclamation is COUPLED to the value collector: a string id stays marked as
    # long as ANY value cell references it (v_ref of a TAG_STR cell). A dead
    # string whose value cell has not YET been swept is therefore un-reclaimable
    # here. So an INEFFECTIVE string collection almost always means "the dead
    # string ids are pinned by dead-but-uncollected VALUE cells" — the remedy is a
    # VALUE collection, which we must NOT run from this string-allocation site
    # (an unpinned value transient could be live across it). Instead we DROP the
    # value high-water so the very next mk_val — a proven-safe value-GC point —
    # sweeps the value arena, releasing those cells; we keep the string water low
    # so the next string collection re-fires right after and reclaims the now-
    # unpinned ids. Within one string-producing operation the pair converges.
    if gc_stress != 0:
        nw2: int32 = n_strs + STR_STRESS_GAP
        if nw2 > MAX_STR:
            nw2 = MAX_STR
        str_hi_water = nw2
    elif freed >= STR_MIN_FREE:
        str_hi_water = str_base_water      # effective: back to the 80% water mark
    else:
        # Ineffective: provoke a value sweep at the next mk_val, then re-fire.
        gc_hi_water = n_vals
        str_hi_water = str_base_water


# Test-only: force a full collection now (backs the JS `gc()` builtin). Sweeps
# ALL THREE arenas — value + env (gc_collect piggybacks the env sweep) and the
# string id table — so a forced gc() reclaims dead scope envs AND dead strings.
# The retain gates rely on this to prove live envs/strings survive a collection.
# Safe to sweep strings here: gc() is an explicit, quiescent call site (the
# script is not mid-build and holds no un-rooted transient sid).
def gc_force():
    gc_collect()
    gc_collect_strings()


# Test-only: enable stress mode (a very low high-water mark that forces a
# collection roughly every GC_STRESS_GAP allocations), to shake out missing
# roots. Default-off; production behavior is unaffected.
def js_set_gc_stress(on: int32):
    if on != 0:
        gc_stress = 1
        nw: int32 = n_vals + GC_STRESS_GAP
        if nw > MAX_VAL:
            nw = MAX_VAL
        gc_hi_water = nw
        enw: int32 = n_envs + ENV_STRESS_GAP     # force frequent ENV collection too
        if enw > MAX_ENV:
            enw = MAX_ENV
        env_hi_water = enw
        snw: int32 = n_strs + STR_STRESS_GAP     # force frequent STRING collection too
        if snw > MAX_STR:
            snw = MAX_STR
        str_hi_water = snw
    else:
        gc_stress = 0
        gc_hi_water = gc_base_water
        env_hi_water = env_base_water
        str_hi_water = str_base_water

# lib/web/js/api.ad — part of the modular web engine (extracted from jsengine.ad).
# PUBLIC API — the 41 js_* names the browser/host embedder + htmlengine call (js_init/js_eval/js_out_*/js_set_host_dispatch/...).
#
# Behavior-preserving split: Adder is a single-compilation-unit language
# (merge_programs merges all imported files into one Program), so every
# public top-level name here resolves globally across the merged engine.

# ====================================================================
# PUBLIC API — the embedder (host driver, native tool, browser) calls these.
# ====================================================================
def js_init():
    # reset all pools
    n_vals = 4
    sp_top = 0
    n_strs = 0
    n_nodes = 0
    n_toks = 0
    n_objs = 0
    n_props = 0
    mse_n = 0
    n_envs = 0
    n_binds = 0
    ax_top = 0
    out_top = 0
    call_top = 0
    this_top = 0
    err_flag = 0
    err_str[0] = 0
    ctl = CTL_NONE
    ctl_val = 0
    throw_val = 0
    tmpl_sp = 0
    re_n = 0
    rn_n = 0
    n_cls = 0
    gname_n = 0
    gname_buf_n = 0
    json_emitted_any = 0
    timer_next = 0
    timer_seq_ctr = 0
    raf_sched_gen = 0
    pr_n = 0
    comb_n = 0
    res_flag_n = 0
    fx_n = 0
    native_self = -1
    scratch_slot = 0
    emit_tgt = 1
    # Reset the builtin PROTOTYPE-object handles. These are part of the object
    # pool (n_objs was just zeroed), so a stale handle from a previous js_init
    # now points at a REUSED slot. v_new_object/v_new_native/v_new_array and the
    # Promise/typed-array/Intl/URL constructors gate on these being their initial
    # sentinel ("not yet installed"); if they carried over non-sentinel, the fresh
    # Object.prototype would be wired to a stale/reused object and the
    # [[Prototype]] chain would form a CYCLE — member reads then spin forever.
    # (Sentinel is 0 for the state.ad protos, -1 for the intl/url ones.)
    g_object_proto = 0
    g_array_proto = 0
    g_func_proto = 0
    g_string_proto = 0
    g_number_proto = 0
    g_boolean_proto = 0
    g_promise_proto = 0
    g_gen_proto = 0
    g_intl_nf_proto = -1
    g_intl_dtf_proto = -1
    g_url_proto = -1
    g_urlsp_proto = -1
    g_formdata_proto = -1
    tap: int32 = 0
    while tap < 16:
        g_ta_proto[tap] = 0
        tap = tap + 1
    # ES-module registry (import/export). The resolver address persists across
    # js_init so an embedder that registered it once keeps working; the graph
    # cache itself is cleared for each fresh program.
    mod_n = 0
    mod_src_top = 0
    mod_load_err = 0
    mod_cur_base = -1
    # singleton values
    v_tag[0] = cast[uint8](TAG_UNDEF)
    v_tag[1] = cast[uint8](TAG_NULL)
    v_tag[2] = cast[uint8](TAG_BOOL)
    v_tag[3] = cast[uint8](TAG_BOOL)
    v_ref[2] = 1
    v_ref[3] = 0
    # global env + object
    g_env = env_new(-1, 1)
    g_global_obj = v_new_object()
    install_builtins()


# Run a program. Returns a pointer to the NUL-terminated output buffer
# (accumulated console.log output). js_out_len() gives its length; js_error()
# is nonzero on a parse/runtime error and js_error_msg() the message.
def js_eval(src: Ptr[uint8], slen: uint64) -> Ptr[uint8]:
    # Each top-level eval (a <script> element or an inline event handler) runs
    # INDEPENDENTLY, exactly like a browser: a parse error or uncaught throw in
    # one <script> must NOT abort the scripts that follow. Clear the error and
    # control-flow latches so the shared context (globals/DOM) is reused but the
    # previous script's failure does not leak forward.
    err_flag = 0
    ctl = CTL_NONE
    ctl_label = -1
    pending_label = -1
    tokenize(src, cast[int32](slen))
    prog: int32 = parse_program()
    if err_flag == 0:
        hoist_scan(prog, g_env)
        exec_stmt(prog, g_env)
        # drain deferred callbacks (setTimeout(f,0) etc.) so they run before
        # rendering — only if the top-level script did not itself throw.
        if err_flag == 0 and ctl != CTL_THROW and drain_enabled != 0:
            drain_timers()
    if err_flag == 0 and ctl == CTL_THROW:
        # uncaught exception -> print like a host runtime
        emit_tgt = 1
        emit_cstr(cast[Ptr[uint8]]("Uncaught "))
        display_val(throw_val)
        emit_c(10)
        ctl = CTL_NONE
    if err_flag != 0:
        # append the error message to the output for visibility
        emit_tgt = 1
        emit_cstr(&err_str[0])
        emit_c(10)
    out_buf[out_top] = 0
    return &out_buf[0]


# ---- ES modules ----
# Register the module resolver: given a specifier and its length, plus an out
# pointer for the length, it returns the module's source bytes (or NULL if the
# specifier cannot be resolved). Fetch happens on the EMBEDDER side (browser
# http9 / host file read) — the engine itself opens no sockets. Call after
# js_init(); the address persists across js_init so one registration suffices.
def js_set_module_resolver(fn: Fn[Ptr[uint8], int32, Ptr[int32], Ptr[uint8]]):
    module_resolver_addr = cast[uint64](fn)
    module_resolver_set = 1


# ---- fetch() transport ----
# Register a REAL over-the-wire HTTP transport for fetch(). The embedder (the
# browser front-end) supplies a function that performs the actual request via the
# kernel's Plan-9 /net http9 client (DNS via sys_resolve, connect via net_dial /
# net_dial_tls) and returns the RAW HTTP response bytes; fetch() parses status /
# headers / body out of them. The engine opens NO sockets — it only calls back
# into the embedder's transport. Call after js_init(); the address persists
# across js_init so one registration suffices. With no transport registered,
# fetch() resolves from the __setFetchFixture table (host / dual-target).
# Signature: fn(url, url_len, method, method_len, body, body_len,
#               content_type, content_type_len,
#               out_status: Ptr[int64], out_len: Ptr[int32]) -> Ptr[uint8]
# content_type is the request Content-Type for a body (empty => the transport
# applies the Fetch string-body default); the transport forwards method + body
# + content_type to the kernel http9 client (http_get for GET, http_post for
# POST). No sockets — the engine only calls back into this function.
def js_set_fetch_transport(fn: Fn[Ptr[uint8], int32, Ptr[uint8], int32, Ptr[uint8], int32, Ptr[uint8], int32, Ptr[int64], Ptr[int32], Ptr[uint8]]):
    fetch_transport_addr = cast[uint64](fn)
    fetch_transport_set = 1


# Evaluate ENTRY as an ES module: parse it, resolve + load its dependency graph
# through the registered resolver, then evaluate the graph in dependency order.
# `spec` is the entry's own specifier (its base for relative resolution).
# Returns the accumulated console output like js_eval (js_out_len / js_error).
def js_run_module(src: Ptr[uint8], slen: uint64, spec: Ptr[uint8], spec_len: uint64) -> Ptr[uint8]:
    err_flag = 0
    ctl = CTL_NONE
    ctl_label = -1
    pending_label = -1
    entry_spec: int32 = str_new(spec, cast[int32](spec_len))
    idx: int32 = module_intern(entry_spec, src, cast[int32](slen))
    if idx >= 0:
        module_load(idx)
    if err_flag == 0 and mod_load_err == 0 and idx >= 0:
        module_evaluate(idx)
        if err_flag == 0 and ctl != CTL_THROW and drain_enabled != 0:
            drain_timers()
    if err_flag == 0 and ctl == CTL_THROW:
        emit_tgt = 1
        emit_cstr(cast[Ptr[uint8]]("Uncaught "))
        display_val(throw_val)
        emit_c(10)
        ctl = CTL_NONE
    if mod_load_err != 0 and err_flag == 0:
        set_error(cast[Ptr[uint8]]("Error: module specifier could not be resolved"))
    if err_flag != 0:
        emit_tgt = 1
        emit_cstr(&err_str[0])
        emit_c(10)
    out_buf[out_top] = 0
    return &out_buf[0]


# The specifier of the module whose imports the resolver is currently being
# asked to resolve (its base, for interpreting a relative specifier). Valid only
# inside the resolver callback.
def js_module_base() -> Ptr[uint8]:
    if mod_cur_base < 0:
        return cast[Ptr[uint8]]("")
    return str_ptr(mod_cur_base)


def js_out_len() -> uint64:
    return cast[uint64](out_top)


def js_out_ptr() -> Ptr[uint8]:
    out_buf[out_top] = 0
    return &out_buf[0]


def js_error() -> int32:
    return err_flag


def js_error_msg() -> Ptr[uint8]:
    return &err_str[0]


# ---- value constructors for embedders ----
def js_undefined() -> int32:
    return v_undef()


def js_null() -> int32:
    return v_null()


def js_bool(b: int32) -> int32:
    return v_boolv(b)


def js_number(x: float64) -> int32:
    return v_number(x)


def js_new_string(p: Ptr[uint8], n: uint64) -> int32:
    return v_string_bytes(p, cast[int32](n))


def js_new_object_v() -> int32:
    return v_new_object()


def js_new_array_v() -> int32:
    return v_new_array()


def js_new_native_fn(native_id: int32) -> int32:
    return v_new_native(native_id)


# ---- object / global manipulation ----
def js_set_prop(objv: int32, name: Ptr[uint8], n: uint64, val: int32):
    member_set(objv, str_new(name, cast[int32](n)), val)


def js_get_prop(objv: int32, name: Ptr[uint8], n: uint64) -> int32:
    return member_get(objv, str_new(name, cast[int32](n)))


def js_array_push(arrv: int32, val: int32):
    if is_array(arrv) != 0:
        arr_push(objid_of(arrv), val)


def js_global_set(name: Ptr[uint8], n: uint64, val: int32):
    env_define(g_env, str_new(name, cast[int32](n)), val, 0)


# Read a global binding's current value by name (the mirror of js_global_set).
# Returns undefined if the name is not bound. Lets an embedder recover a value
# that a js_eval'd snippet stored in the global scope (e.g. a function compiled
# from inline-handler source).
def js_global_get(name: Ptr[uint8], n: uint64) -> int32:
    b: int32 = env_lookup_bind(g_env, str_new(name, cast[int32](n)))
    if b < 0:
        return v_undef()
    return b_val[b]


# ---- value inspection (for host dispatch) ----
def js_type_of(val: int32) -> int32:
    return tag_of(val)


def js_to_number(val: int32) -> float64:
    return to_number(val)


def js_to_bool(val: int32) -> int32:
    return to_bool(val)


def js_is_array(val: int32) -> int32:
    return is_array(val)


def js_array_len(val: int32) -> int32:
    if is_array(val) != 0:
        return arr_len[objid_of(val)]
    return 0


def js_array_get(val: int32, i: int32) -> int32:
    if is_array(val) != 0:
        return arr_get(objid_of(val), i)
    return v_undef()


# Copy a value's string form into a scratch buffer (NUL-terminated). Hands out
# the NEXT buffer in the ring (see state.ad) so consecutive calls do not clobber
# each other's result — an embedder can hold SCRATCH_RING recent pointers live.
def js_to_display(val: int32) -> Ptr[uint8]:
    save: int32 = emit_tgt
    save_out: int32 = out_top
    # render into out_buf temporarily then copy into this call's ring slot.
    emit_tgt = 1
    tmpstart: int32 = out_top
    display_val(val)
    ln: int32 = out_top - tmpstart
    slot: int32 = scratch_slot
    scratch_slot = scratch_slot + 1
    if scratch_slot >= SCRATCH_RING:
        scratch_slot = 0
    dbase: int32 = slot * SCRATCH_SZ
    i: int32 = 0
    while i < ln and i < SCRATCH_SZ - 1:
        scratch[dbase + i] = out_buf[tmpstart + i]
        i = i + 1
    scratch[dbase + i] = 0
    out_top = save_out                 # roll back the temporary render
    emit_tgt = save
    return &scratch[dbase]


def js_str_ptr(val: int32) -> Ptr[uint8]:
    return js_to_display(val)


# ---- host native dispatch seam ----
# The embedder registers fn(native_id) -> value-handle. Inside it, the embedder
# reads arguments via js_arg_count()/js_arg(i) and returns any value handle
# (build with js_number/js_new_string/js_new_object/...). Route calls to your
# host object's native methods (e.g. a future `document`) here. Host natives
# MUST use ids >= HOST_NATIVE_BASE (1000).
def js_set_host_dispatch(fn: Fn[int32, int32]):
    host_dispatch_addr = cast[uint64](fn)
    host_dispatch_set = 1


# ---- member-set notification seam (see member_set) ----
def js_set_member_hook(fn: Fn[int32, int32]):
    member_set_hook_addr = cast[uint64](fn)
    member_set_hook_set = 1


def js_mset_this() -> int32:
    return mset_this_v


def js_mset_key() -> int32:
    return mset_key_v


def js_mset_val() -> int32:
    return mset_val_v


def js_arg_count() -> int32:
    return hostcall_argc


def js_arg(i: int32) -> int32:
    if i < hostcall_argc:
        return call_args[hostcall_base + i]
    return v_undef()


def js_host_base() -> int32:
    return HOST_NATIVE_BASE


# The receiver (`this`) of the native method currently being dispatched, so a
# host method like element.addEventListener / element.appendChild can identify
# which host object it was invoked on. Valid only inside the dispatch fn.
def js_this() -> int32:
    return hostcall_this


# Is `val` a callable JS function value? (For an embedder deciding whether a
# stored event handler can be invoked.)
def js_is_callable(val: int32) -> int32:
    return is_callable(val)


# Invoke a JS function VALUE from native/embedder code with `argc` argument
# value-handles (argv[0..argc), built via js_number/js_new_string/...), and
# `thisval` as the receiver. Returns the call's result value-handle. This is
# the seam that lets native code call a stored JS event handler AFTER the
# initial js_eval has returned — the JS context persists until the next
# js_init(), so handler function values stay live across a page's lifetime.
def js_call_fn(fnval: int32, thisval: int32, argv: Ptr[int32], argc: int32) -> int32:
    if is_callable(fnval) == 0:
        return v_undef()
    base: int32 = call_top
    i: int32 = 0
    while i < argc:
        call_args[call_top] = argv[i]
        call_top = call_top + 1
        i = i + 1
    r: int32 = invoke(fnval, thisval, base, argc)
    call_top = base
    return r


# Drain the deferred-callback task queue on demand. js_eval already drains at
# end-of-script; an embedder that dispatches DOM events via js_call_fn should
# call this AFTER each event turn so setTimeout(f,0) handlers scheduled by the
# event fire before the next render.
def js_drain_timers():
    drain_timers()

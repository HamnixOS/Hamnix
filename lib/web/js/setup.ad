# lib/web/js/setup.ad — part of the modular web engine (extracted from jsengine.ad).
# SETUP — build the global environment + all builtin objects/prototypes.
#
# Behavior-preserving split: Adder is a single-compilation-unit language
# (merge_programs merges all imported files into one Program), so every
# public top-level name here resolves globally across the merged engine.

# ====================================================================
# SETUP — build the global environment + builtin objects.
# ====================================================================
# ====================================================================
# REGULAR EXPRESSIONS
#   source -> recursive-descent parse -> regex AST -> backtracking bytecode
#   -> a recursive backtracking VM (correct over fast; supports backrefs).
# Supported: literals, `.`, classes [a-z]/[^..], anchors ^ $ (m), quantifiers
# * + ? {n} {n,} {n,m} (greedy + lazy `?`), groups ( ) capture + (?:..),
# alternation |, backrefs \1..\9, escapes \d \w \s \b and negations, flags g i m.
# lookahead (?=)(?!), lookbehind (?<=)(?<!), named groups (?<name>..) with .groups
# and \k<name> backrefs, plus `s` dotAll (`.` matches newline), `y` sticky
# (anchor at lastIndex), and `d` indices (match-result `.indices` [start,end)
# pairs + `.indices.groups`, `hasIndices` reflected). Deferred: `u`/`v` Unicode.
# ====================================================================

def re_fold(c: uint8) -> uint8:
    if c >= 65 and c <= 90:
        return c + 32
    return c


def re_is_word_byte(c: uint8) -> int32:
    if c >= 97 and c <= 122:
        return 1
    if c >= 65 and c <= 90:
        return 1
    if c >= 48 and c <= 57:
        return 1
    if c == 95:
        return 1
    return 0


def re_is_digit_byte(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return 1
    return 0


def re_is_space_byte(c: uint8) -> int32:
    if c == 32 or c == 9 or c == 10 or c == 13 or c == 12 or c == 11:
        return 1
    return 0


# ---- program emit / AST alloc ----
def re_emit(op: int32, x: int32, y: int32) -> int32:
    pc: int32 = re_n
    re_op[pc] = op
    re_x[pc] = x
    re_y[pc] = y
    re_n = re_n + 1
    return pc


def rn_new(op: int32) -> int32:
    i: int32 = rn_n
    rn_op[i] = op
    rn_a[i] = -1
    rn_b[i] = -1
    rn_c[i] = -1
    rn_d[i] = -1
    rn_next[i] = -1
    rn_n = rn_n + 1
    return i


# ---- char classes ----
def cls_new(negate: int32) -> int32:
    idx: int32 = n_cls
    i: int32 = 0
    while i < 32:
        cls_bits[idx * 32 + i] = 0
        i = i + 1
    cls_neg[idx] = cast[uint8](negate)
    n_cls = n_cls + 1
    return idx


def cls_add_raw(idx: int32, ch: int32):
    if ch < 0 or ch > 255:
        return
    cls_bits[idx * 32 + (ch >> 3)] = cls_bits[idx * 32 + (ch >> 3)] | cast[uint8](1 << (ch & 7))


def cls_add(idx: int32, ch: int32):
    cls_add_raw(idx, ch)
    if re_ic != 0:
        if ch >= 65 and ch <= 90:
            cls_add_raw(idx, ch + 32)
        elif ch >= 97 and ch <= 122:
            cls_add_raw(idx, ch - 32)


def cls_add_range(idx: int32, lo: int32, hi: int32):
    c: int32 = lo
    while c <= hi:
        cls_add(idx, c)
        c = c + 1


# which: 0=digit 1=word 2=space ; negate adds the complement set instead.
def cls_add_set(idx: int32, which: int32, negate: int32):
    c: int32 = 0
    while c < 256:
        inset: int32 = 0
        if which == 0:
            inset = re_is_digit_byte(cast[uint8](c))
        elif which == 1:
            inset = re_is_word_byte(cast[uint8](c))
        else:
            inset = re_is_space_byte(cast[uint8](c))
        if negate != 0:
            if inset == 0:
                cls_add_raw(idx, c)
        else:
            if inset != 0:
                cls_add_raw(idx, c)
        c = c + 1


def cls_test(idx: int32, ch: uint8) -> int32:
    c: int32 = cast[int32](ch)
    bit: int32 = cast[int32](cls_bits[idx * 32 + (c >> 3)] >> (c & 7)) & 1
    return bit


# ---- source cursor ----
def rc_at(i: int32) -> uint8:
    if i >= rc_len:
        return 0
    return sp_buf[rc_off + i]


def rc_peek() -> uint8:
    return rc_at(rc_i)


def rc_peek1() -> uint8:
    return rc_at(rc_i + 1)


# ---- regex parser (returns AST node id) ----
def re_parse_alt() -> int32:
    first: int32 = re_parse_seq()
    if rc_peek() != 124:                     # not '|'
        return first
    alt: int32 = rn_new(RN_ALT)
    rn_a[alt] = first
    tail: int32 = first
    while rc_peek() == 124:
        rc_i = rc_i + 1                       # consume '|'
        nb: int32 = re_parse_seq()
        rn_next[tail] = nb
        tail = nb
    return alt


def re_parse_seq() -> int32:
    seq: int32 = rn_new(RN_SEQ)
    head: int32 = -1
    tail: int32 = -1
    while rc_i < rc_len:
        c: uint8 = rc_peek()
        if c == 124 or c == 41:              # '|' or ')'
            break
        item: int32 = re_parse_repeat()
        if item < 0:
            break
        if head < 0:
            head = item
            tail = item
        else:
            rn_next[tail] = item
            tail = item
    rn_a[seq] = head
    return seq


def re_parse_repeat() -> int32:
    atom: int32 = re_parse_atom()
    if atom < 0:
        return atom
    c: uint8 = rc_peek()
    q: int32 = -1
    if c == 42:                              # *
        q = rn_new(RN_STAR)
        rc_i = rc_i + 1
    elif c == 43:                            # +
        q = rn_new(RN_PLUS)
        rc_i = rc_i + 1
    elif c == 63:                            # ?
        q = rn_new(RN_QUEST)
        rc_i = rc_i + 1
    elif c == 123:                           # { — maybe a bounded quantifier
        q = re_parse_brace(atom)
        if q < 0:
            return atom                      # `{` was a literal (handled as char by atom? no)
    else:
        return atom
    if q < 0:
        return atom
    rn_d[q] = atom
    # greedy unless followed by '?'
    greedy: int32 = 1
    if rc_peek() == 63:
        greedy = 0
        rc_i = rc_i + 1
    if rn_op[q] == RN_REPEAT:
        rn_a[q] = greedy
    else:
        rn_b[q] = greedy
    return q


# Try to parse {n} {n,} {n,m} starting at rc_i (a '{'). Returns an RN_REPEAT
# node (child unset) on success (consuming through '}'), or -1 without consuming.
def re_parse_brace(atom: int32) -> int32:
    j: int32 = rc_i + 1
    if is_digit(rc_at(j)) == 0:
        return -1
    lo: int32 = 0
    while is_digit(rc_at(j)) != 0:
        lo = lo * 10 + (cast[int32](rc_at(j)) - 48)
        j = j + 1
    hi: int32 = lo
    if rc_at(j) == 44:                       # ','
        j = j + 1
        if rc_at(j) == 125:                  # {n,}
            hi = -1
        else:
            if is_digit(rc_at(j)) == 0:
                return -1
            hi = 0
            while is_digit(rc_at(j)) != 0:
                hi = hi * 10 + (cast[int32](rc_at(j)) - 48)
                j = j + 1
    if rc_at(j) != 125:                      # need closing '}'
        return -1
    rc_i = j + 1                             # consume through '}'
    rep: int32 = rn_new(RN_REPEAT)
    rn_b[rep] = lo
    rn_c[rep] = hi
    return rep


def re_parse_atom() -> int32:
    c: uint8 = rc_peek()
    if c == 40:                              # (
        rc_i = rc_i + 1
        capidx: int32 = -1
        look: int32 = 0                      # 0 none, 1 lookahead, 2 lookbehind
        lookneg: int32 = 0
        if rc_peek() == 63:                  # (?  — group modifier
            n1: uint8 = rc_peek1()
            if n1 == 58:                     # (?:  non-capturing
                rc_i = rc_i + 2
            elif n1 == 61:                   # (?=  positive lookahead
                rc_i = rc_i + 2
                look = 1
            elif n1 == 33:                   # (?!  negative lookahead
                rc_i = rc_i + 2
                look = 1
                lookneg = 1
            elif n1 == 60:                   # (?<  lookbehind or named group
                n2: uint8 = rc_at(rc_i + 2)
                if n2 == 61:                 # (?<=  positive lookbehind
                    rc_i = rc_i + 3
                    look = 2
                elif n2 == 33:               # (?<!  negative lookbehind
                    rc_i = rc_i + 3
                    look = 2
                    lookneg = 1
                else:                        # (?<name>  named capture group
                    rc_i = rc_i + 2          # past '(?<'
                    nst: int32 = gname_buf_n
                    while rc_peek() != 62 and rc_peek() != 0:
                        if gname_buf_n < 8191:
                            gname_buf[gname_buf_n] = rc_peek()
                            gname_buf_n = gname_buf_n + 1
                        rc_i = rc_i + 1
                    if rc_peek() == 62:      # '>'
                        rc_i = rc_i + 1
                    re_gcount = re_gcount + 1
                    capidx = re_gcount
                    if gname_n < RE_GNAME_CAP:
                        gname_idx[gname_n] = capidx
                        gname_soff[gname_n] = nst
                        gname_slen[gname_n] = gname_buf_n - nst
                        gname_n = gname_n + 1
            else:                            # unknown (?X — treat as non-capturing
                rc_i = rc_i + 2
        else:
            re_gcount = re_gcount + 1
            capidx = re_gcount
        child: int32 = re_parse_alt()
        if rc_peek() == 41:                  # )
            rc_i = rc_i + 1
        if look != 0:
            lk: int32 = rn_new(RN_LOOK)
            if look == 2:
                rn_op[lk] = RN_LOOKB
            rn_a[lk] = lookneg
            rn_d[lk] = child
            return lk
        g: int32 = rn_new(RN_GROUP)
        rn_a[g] = capidx
        rn_d[g] = child
        return g
    if c == 91:                              # [
        return re_parse_class()
    if c == 46:                              # .
        rc_i = rc_i + 1
        return rn_new(RN_ANY)
    if c == 94:                              # ^
        rc_i = rc_i + 1
        return rn_new(RN_BOL)
    if c == 36:                              # $
        rc_i = rc_i + 1
        return rn_new(RN_EOL)
    if c == 92:                              # backslash
        return re_parse_escape()
    if c == 41 or c == 124 or c == 0:        # ) | end — empty atom
        return -1
    # ordinary literal char
    rc_i = rc_i + 1
    ch: int32 = rn_new(RN_CHAR)
    rn_a[ch] = cast[int32](c)
    return ch


# Resolve a `\k<name>` reference: compare the source name span [soff,soff+slen)
# against the named groups recorded for THIS compile. Returns the capture index,
# or -1 if the name is unknown.
def re_lookup_gname_src(soff: int32, slen: int32) -> int32:
    r: int32 = gname_compile_start
    while r < gname_n:
        if gname_slen[r] == slen:
            k: int32 = 0
            same: int32 = 1
            while k < slen:
                if gname_buf[gname_soff[r] + k] != rc_at(soff + k):
                    same = 0
                    break
                k = k + 1
            if same != 0:
                return gname_idx[r]
        r = r + 1
    return -1


def re_parse_escape() -> int32:
    rc_i = rc_i + 1                          # skip backslash
    e: uint8 = rc_peek()
    rc_i = rc_i + 1
    if e == 107 and rc_peek() == 60:         # \k<name>  named backreference
        rc_i = rc_i + 1                      # past '<'
        nsoff: int32 = rc_i
        while rc_peek() != 62 and rc_peek() != 0:
            rc_i = rc_i + 1
        nslen: int32 = rc_i - nsoff
        if rc_peek() == 62:                  # '>'
            rc_i = rc_i + 1
        ki: int32 = re_lookup_gname_src(nsoff, nslen)
        if ki < 0:                           # unknown name: match empty (lenient)
            eg: int32 = rn_new(RN_GROUP)
            rn_a[eg] = -1
            rn_d[eg] = -1
            return eg
        kbr: int32 = rn_new(RN_BACKREF)
        rn_a[kbr] = ki
        return kbr
    # ---- u-mode (`u`/`v`): `\u{CP}` code-point escapes + surrogate pairs ----
    if re_uni != 0 and e == 117:
        cp: int32 = re_parse_u_cp()
        if cp >= 0:
            return re_utf8_atom(cp)
        # invalid \u form: fall through to the legacy literal-'u' handling.
    # ---- u-mode `\p{Name}` / `\P{Name}` Unicode property class (ASCII-range) ----
    if re_uni != 0 and (e == 112 or e == 80):
        pneg: int32 = 0
        if e == 80:
            pneg = 1
        if rc_peek() == 123:                     # '{'
            rc_i = rc_i + 1
            psoff: int32 = rc_i
            while rc_peek() != 125 and rc_peek() != 0:
                rc_i = rc_i + 1
            pslen: int32 = rc_i - psoff
            if rc_peek() == 125:                 # '}'
                rc_i = rc_i + 1
            pw: int32 = re_prop_which(psoff, pslen)
            cnp: int32 = cls_new(0)
            if pw >= 0:
                cls_add_prop(cnp, pw, pneg)
            return re_class_node(cnp)
    # predefined sets
    if e == 100:                             # \d
        cn: int32 = cls_new(0)
        cls_add_set(cn, 0, 0)
        return re_class_node(cn)
    if e == 68:                              # \D
        cn2: int32 = cls_new(0)
        cls_add_set(cn2, 0, 1)
        return re_class_node(cn2)
    if e == 119:                             # \w
        cn3: int32 = cls_new(0)
        cls_add_set(cn3, 1, 0)
        return re_class_node(cn3)
    if e == 87:                              # \W
        cn4: int32 = cls_new(0)
        cls_add_set(cn4, 1, 1)
        return re_class_node(cn4)
    if e == 115:                             # \s
        cn5: int32 = cls_new(0)
        cls_add_set(cn5, 2, 0)
        return re_class_node(cn5)
    if e == 83:                              # \S
        cn6: int32 = cls_new(0)
        cls_add_set(cn6, 2, 1)
        return re_class_node(cn6)
    if e == 98:                              # \b
        return rn_new(RN_WORDB)
    if e == 66:                              # \B
        return rn_new(RN_NWORDB)
    if e >= 49 and e <= 57:                  # \1..\9 backreference
        gi: int32 = cast[int32](e) - 48
        br: int32 = rn_new(RN_BACKREF)
        rn_a[br] = gi
        return br
    # single-char escapes
    lit: int32 = re_escape_char(e)
    ch2: int32 = rn_new(RN_CHAR)
    rn_a[ch2] = lit
    return ch2


def re_escape_char(e: uint8) -> int32:
    if e == 110:
        return 10                            # \n
    if e == 116:
        return 9                             # \t
    if e == 114:
        return 13                            # \r
    if e == 102:
        return 12                            # \f
    if e == 118:
        return 11                            # \v
    if e == 48:
        return 0                             # \0
    if e == 120:                             # \xHH
        h1: int32 = hexval(rc_peek())
        h2: int32 = hexval(rc_peek1())
        if h1 >= 0 and h2 >= 0:
            rc_i = rc_i + 2
            return h1 * 16 + h2
        return 120
    if e == 117:                             # \uHHHH -> low byte (byte engine)
        u1: int32 = hexval(rc_at(rc_i))
        u2: int32 = hexval(rc_at(rc_i + 1))
        u3: int32 = hexval(rc_at(rc_i + 2))
        u4: int32 = hexval(rc_at(rc_i + 3))
        if u1 >= 0 and u2 >= 0 and u3 >= 0 and u4 >= 0:
            rc_i = rc_i + 4
            return (u3 * 16 + u4)
        return 117
    return cast[int32](e)                    # \. \/ \\ \* ... literal


def hexval(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return cast[int32](c) - 48
    if c >= 97 and c <= 102:
        return cast[int32](c) - 87
    if c >= 65 and c <= 70:
        return cast[int32](c) - 55
    return -1


def re_class_node(clsidx: int32) -> int32:
    n: int32 = rn_new(RN_CLASS)
    rn_a[n] = clsidx
    return n


# ---- unicode (`u`/`v`) helpers ---------------------------------------------
# Append one RN_CHAR(byte) atom to an RN_SEQ under construction. `tailp` holds
# the current tail node id (-1 for the first append); returns the new tail.
def re_seq_append_byte(seq: int32, tailp: int32, byte: int32) -> int32:
    ch: int32 = rn_new(RN_CHAR)
    rn_a[ch] = byte
    if tailp < 0:
        rn_a[seq] = ch
    else:
        rn_next[tailp] = ch
    return ch


# Emit an atom that matches `cp` (a Unicode code point) as its UTF-8 byte
# sequence: a single RN_CHAR for cp < 0x80, otherwise an RN_SEQ of the 2/3/4
# UTF-8 continuation bytes. Because JS strings are stored as UTF-8 byte buffers,
# this makes u-mode `\u{...}` escapes + combined surrogate pairs match ASTRAL
# characters in the subject correctly, byte-for-byte.
def re_utf8_atom(cp: int32) -> int32:
    if cp < 128:
        ch: int32 = rn_new(RN_CHAR)
        rn_a[ch] = cp
        return ch
    seq: int32 = rn_new(RN_SEQ)
    tail: int32 = -1
    if cp < 2048:
        tail = re_seq_append_byte(seq, tail, 192 + (cp >> 6))
        tail = re_seq_append_byte(seq, tail, 128 + (cp & 63))
    elif cp < 65536:
        tail = re_seq_append_byte(seq, tail, 224 + (cp >> 12))
        tail = re_seq_append_byte(seq, tail, 128 + ((cp >> 6) & 63))
        tail = re_seq_append_byte(seq, tail, 128 + (cp & 63))
    else:
        tail = re_seq_append_byte(seq, tail, 240 + (cp >> 18))
        tail = re_seq_append_byte(seq, tail, 128 + ((cp >> 12) & 63))
        tail = re_seq_append_byte(seq, tail, 128 + ((cp >> 6) & 63))
        tail = re_seq_append_byte(seq, tail, 128 + (cp & 63))
    return seq


# Parse a `\u` escape body (the cursor sits just past the 'u'). In u-mode this
# handles `\u{CP}` braced code points and combines a `\uHHHH` high surrogate with
# a following `\uHHHH` low surrogate into one code point. Returns the code point,
# or -1 if no valid \u form is present (caller falls back to literal 'u').
def re_parse_u_cp() -> int32:
    if rc_peek() == 123:                         # \u{ ... }
        rc_i = rc_i + 1                          # past '{'
        cp: int32 = 0
        seen: int32 = 0
        while hexval(rc_peek()) >= 0:
            cp = cp * 16 + hexval(rc_peek())
            rc_i = rc_i + 1
            seen = 1
        if rc_peek() == 125:                     # '}'
            rc_i = rc_i + 1
        if seen == 0:
            return -1
        return cp
    # \uHHHH
    h1: int32 = hexval(rc_at(rc_i))
    h2: int32 = hexval(rc_at(rc_i + 1))
    h3: int32 = hexval(rc_at(rc_i + 2))
    h4: int32 = hexval(rc_at(rc_i + 3))
    if h1 < 0 or h2 < 0 or h3 < 0 or h4 < 0:
        return -1
    rc_i = rc_i + 4
    cp2: int32 = ((h1 * 16 + h2) * 16 + h3) * 16 + h4
    # High surrogate followed by \uHHHH low surrogate -> combine to astral cp.
    if cp2 >= 55296 and cp2 <= 56319 and rc_at(rc_i) == 92 and rc_at(rc_i + 1) == 117:
        l1: int32 = hexval(rc_at(rc_i + 2))
        l2: int32 = hexval(rc_at(rc_i + 3))
        l3: int32 = hexval(rc_at(rc_i + 4))
        l4: int32 = hexval(rc_at(rc_i + 5))
        if l1 >= 0 and l2 >= 0 and l3 >= 0 and l4 >= 0:
            lo: int32 = ((l1 * 16 + l2) * 16 + l3) * 16 + l4
            if lo >= 56320 and lo <= 57343:
                rc_i = rc_i + 6
                return 65536 + ((cp2 - 55296) << 10) + (lo - 56320)
    return cp2


# Fill class `idx` with a Unicode property set (u-mode `\p{Name}`/`\P{Name}`).
# The byte engine covers the ASCII range faithfully; astral/Latin-1 property
# matching is deferred (documented). `which`: 0=L 1=N 2=Lu 3=Ll 4=White_Space
# 5=ASCII 6=Any. `negate` adds the complement over 0..255 instead.
def cls_add_prop(idx: int32, which: int32, negate: int32):
    c: int32 = 0
    while c < 256:
        inset: int32 = 0
        if which == 0:                           # L : ASCII letters
            if (c >= 65 and c <= 90) or (c >= 97 and c <= 122):
                inset = 1
        elif which == 1:                         # N / Nd : ASCII digits
            if c >= 48 and c <= 57:
                inset = 1
        elif which == 2:                         # Lu : ASCII uppercase
            if c >= 65 and c <= 90:
                inset = 1
        elif which == 3:                         # Ll : ASCII lowercase
            if c >= 97 and c <= 122:
                inset = 1
        elif which == 4:                         # White_Space
            inset = re_is_space_byte(cast[uint8](c))
        elif which == 5:                         # ASCII
            if c < 128:
                inset = 1
        else:                                    # Any / unknown -> match anything
            inset = 1
        if negate != 0:
            if inset == 0:
                cls_add_raw(idx, c)
        else:
            if inset != 0:
                cls_add_raw(idx, c)
        c = c + 1


# Map a `\p{...}` property name span (source bytes [soff, soff+slen)) to a
# cls_add_prop `which` code, or -1 if unrecognised. Accepts the common general
# categories + a couple of long aliases.
def re_prop_which(soff: int32, slen: int32) -> int32:
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("L")) != 0:
        return 0
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("Letter")) != 0:
        return 0
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("Alphabetic")) != 0:
        return 0
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("N")) != 0:
        return 1
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("Nd")) != 0:
        return 1
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("Number")) != 0:
        return 1
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("Lu")) != 0:
        return 2
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("Uppercase")) != 0:
        return 2
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("Uppercase_Letter")) != 0:
        return 2
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("Ll")) != 0:
        return 3
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("Lowercase")) != 0:
        return 3
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("Lowercase_Letter")) != 0:
        return 3
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("White_Space")) != 0:
        return 4
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("space")) != 0:
        return 4
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("ASCII")) != 0:
        return 5
    if re_name_eq(soff, slen, cast[Ptr[uint8]]("Any")) != 0:
        return 6
    return -1


# Compare a source-byte span [soff, soff+slen) in the regex source against a
# NUL-terminated C string. Returns 1 on exact match.
def re_name_eq(soff: int32, slen: int32, s: Ptr[uint8]) -> int32:
    k: int32 = 0
    while k < slen:
        if s[k] == 0:
            return 0
        if rc_at(soff + k) != s[k]:
            return 0
        k = k + 1
    if s[slen] != 0:
        return 0
    return 1


def re_parse_class() -> int32:
    rc_i = rc_i + 1                          # skip [
    neg: int32 = 0
    if rc_peek() == 94:                      # ^
        neg = 1
        rc_i = rc_i + 1
    idx: int32 = cls_new(neg)
    while rc_i < rc_len and rc_peek() != 93:  # until ]
        lo: int32 = re_class_item(idx)
        if lo < 0:
            continue                          # a set (\d etc) was folded in
        # range?
        if rc_peek() == 45 and rc_peek1() != 93 and rc_peek1() != 0:
            rc_i = rc_i + 1                    # consume '-'
            hi: int32 = re_class_item(idx)
            if hi < 0:
                cls_add(idx, 45)              # stray set after '-': treat '-' literal
            else:
                cls_add_range(idx, lo, hi)
        else:
            cls_add(idx, lo)
    if rc_peek() == 93:
        rc_i = rc_i + 1                       # skip ]
    return re_class_node(idx)


# Parse one class item; returns its char code, or -1 if it was a predefined
# set escape (\d \w \s + negations) already merged into the class bitmap.
def re_class_item(idx: int32) -> int32:
    c: uint8 = rc_peek()
    if c == 92:                              # escape
        rc_i = rc_i + 1
        e: uint8 = rc_peek()
        rc_i = rc_i + 1
        if e == 100:
            cls_add_set(idx, 0, 0)
            return -1
        if e == 68:
            cls_add_set(idx, 0, 1)
            return -1
        if e == 119:
            cls_add_set(idx, 1, 0)
            return -1
        if e == 87:
            cls_add_set(idx, 1, 1)
            return -1
        if e == 115:
            cls_add_set(idx, 2, 0)
            return -1
        if e == 83:
            cls_add_set(idx, 2, 1)
            return -1
        if e == 98:                          # \b inside class = backspace (8)
            return 8
        if re_uni != 0 and (e == 112 or e == 80):   # \p{..}/\P{..} in class
            cpneg: int32 = 0
            if e == 80:
                cpneg = 1
            if rc_peek() == 123:
                rc_i = rc_i + 1
                csoff: int32 = rc_i
                while rc_peek() != 125 and rc_peek() != 0:
                    rc_i = rc_i + 1
                cslen: int32 = rc_i - csoff
                if rc_peek() == 125:
                    rc_i = rc_i + 1
                cw: int32 = re_prop_which(csoff, cslen)
                if cw >= 0:
                    cls_add_prop(idx, cw, cpneg)
            return -1
        if re_uni != 0 and e == 117:         # \u{CP}/\uHHHH in class
            # cursor already sits just past the 'u' — exactly re_parse_u_cp's entry.
            ucp: int32 = re_parse_u_cp()
            # a byte class holds 0..255; astral members can't be represented
            # (byte engine) — add cp when it fits, else silently drop (documented).
            if ucp >= 0 and ucp <= 255:
                return ucp
            return -1
        return re_escape_char(e)
    rc_i = rc_i + 1
    return cast[int32](c)


# ---- compile AST -> program ----
def re_compile(node: int32):
    if node < 0:
        return
    op: int32 = rn_op[node]
    if op == RN_SEQ:
        it: int32 = rn_a[node]
        while it >= 0:
            re_compile(it)
            it = rn_next[it]
        return
    if op == RN_CHAR:
        re_emit(RI_CHAR, rn_a[node], 0)
        return
    if op == RN_ANY:
        re_emit(RI_ANY, 0, 0)
        return
    if op == RN_CLASS:
        re_emit(RI_CLASS, rn_a[node], 0)
        return
    if op == RN_BOL:
        re_emit(RI_BOL, 0, 0)
        return
    if op == RN_EOL:
        re_emit(RI_EOL, 0, 0)
        return
    if op == RN_WORDB:
        re_emit(RI_WORDB, 0, 0)
        return
    if op == RN_NWORDB:
        re_emit(RI_NWORDB, 0, 0)
        return
    if op == RN_BACKREF:
        re_emit(RI_BACKREF, rn_a[node], 0)
        return
    if op == RN_GROUP:
        if rn_a[node] >= 0:
            re_emit(RI_SAVE, 2 * rn_a[node], 0)
            re_compile(rn_d[node])
            re_emit(RI_SAVE, 2 * rn_a[node] + 1, 0)
        else:
            re_compile(rn_d[node])
        return
    if op == RN_ALT:
        re_compile_alt(rn_a[node])
        return
    if op == RN_LOOK:
        la: int32 = re_emit(RI_LAHEAD, 0, rn_a[node])
        re_compile(rn_d[node])
        re_emit(RI_LADONE, 0, 0)
        re_x[la] = re_n
        return
    if op == RN_LOOKB:
        lb: int32 = re_emit(RI_LBEHIND, 0, rn_a[node])
        re_compile(rn_d[node])
        re_emit(RI_LBDONE, 0, 0)
        re_x[lb] = re_n
        return
    if op == RN_STAR:
        re_emit_star(rn_d[node], rn_b[node])
        return
    if op == RN_PLUS:
        re_emit_plus(rn_d[node], rn_b[node])
        return
    if op == RN_QUEST:
        re_emit_opt(rn_d[node], 1, rn_b[node])
        return
    if op == RN_REPEAT:
        lo: int32 = rn_b[node]
        hi: int32 = rn_c[node]
        greedy: int32 = rn_a[node]
        i: int32 = 0
        while i < lo:
            re_compile(rn_d[node])
            i = i + 1
        if hi < 0:
            re_emit_star(rn_d[node], greedy)
        else:
            re_emit_opt(rn_d[node], hi - lo, greedy)
        return


def re_compile_alt(branch: int32):
    nxt: int32 = rn_next[branch]
    if nxt < 0:
        re_compile(branch)
        return
    s: int32 = re_emit(RI_SPLIT, 0, 0)
    bstart: int32 = re_n
    re_compile(branch)
    j: int32 = re_emit(RI_JMP, 0, 0)
    reststart: int32 = re_n
    re_compile_alt(nxt)
    endp: int32 = re_n
    re_x[s] = bstart
    re_y[s] = reststart
    re_x[j] = endp


def re_emit_star(child: int32, greedy: int32):
    s: int32 = re_emit(RI_SPLIT, 0, 0)
    cstart: int32 = re_n
    re_compile(child)
    re_emit(RI_JMP, s, 0)
    endp: int32 = re_n
    if greedy != 0:
        re_x[s] = cstart
        re_y[s] = endp
    else:
        re_x[s] = endp
        re_y[s] = cstart


def re_emit_plus(child: int32, greedy: int32):
    cstart: int32 = re_n
    re_compile(child)
    s: int32 = re_emit(RI_SPLIT, 0, 0)
    endp: int32 = re_n
    if greedy != 0:
        re_x[s] = cstart
        re_y[s] = endp
    else:
        re_x[s] = endp
        re_y[s] = cstart


# emit `child{0,count}` (bounded optional) as right-nested SPLITs
def re_emit_opt(child: int32, count: int32, greedy: int32):
    if count <= 0:
        return
    s: int32 = re_emit(RI_SPLIT, 0, 0)
    cstart: int32 = re_n
    re_compile(child)
    re_emit_opt(child, count - 1, greedy)
    endp: int32 = re_n
    if greedy != 0:
        re_x[s] = cstart
        re_y[s] = endp
    else:
        re_x[s] = endp
        re_y[s] = cstart


# ---- matcher (backtracking VM) ----
def re_eqc(a: uint8, b: uint8) -> int32:
    if a == b:
        return 1
    if re_ic != 0:
        if re_fold(a) == re_fold(b):
            return 1
    return 0


def re_inclass(idx: int32, ch: uint8) -> int32:
    hit: int32 = cls_test(idx, ch)
    if cast[int32](cls_neg[idx]) != 0:
        if hit != 0:
            return 0
        return 1
    return hit


def re_subj(sp: int32) -> uint8:
    return sp_buf[rx_off + sp]


def re_is_bol(sp: int32) -> int32:
    if sp == 0:
        return 1
    if re_ml != 0 and re_subj(sp - 1) == 10:
        return 1
    return 0


def re_is_eol(sp: int32) -> int32:
    if sp == rx_len:
        return 1
    if re_ml != 0 and re_subj(sp) == 10:
        return 1
    return 0


def re_is_wordb(sp: int32) -> int32:
    left: int32 = 0
    right: int32 = 0
    if sp > 0 and re_is_word_byte(re_subj(sp - 1)) != 0:
        left = 1
    if sp < rx_len and re_is_word_byte(re_subj(sp)) != 0:
        right = 1
    if left != right:
        return 1
    return 0


def re_run(pc0: int32, sp0: int32) -> int32:
    pc: int32 = pc0
    sp: int32 = sp0
    while re_op[pc] >= 0:
        op: int32 = re_op[pc]
        if op == RI_CHAR:
            if sp < rx_len and re_eqc(re_subj(sp), cast[uint8](re_x[pc])) != 0:
                pc = pc + 1
                sp = sp + 1
                continue
            return 0
        elif op == RI_ANY:
            if sp < rx_len and (re_da != 0 or re_subj(sp) != 10):
                pc = pc + 1
                sp = sp + 1
                continue
            return 0
        elif op == RI_CLASS:
            if sp < rx_len and re_inclass(re_x[pc], re_subj(sp)) != 0:
                pc = pc + 1
                sp = sp + 1
                continue
            return 0
        elif op == RI_MATCH:
            rx_matchend = sp
            return 1
        elif op == RI_JMP:
            pc = re_x[pc]
            continue
        elif op == RI_SPLIT:
            if re_run(re_x[pc], sp) != 0:
                return 1
            pc = re_y[pc]
            continue
        elif op == RI_SAVE:
            slot: int32 = re_x[pc]
            old: int32 = re_cap[slot]
            re_cap[slot] = sp
            if re_run(pc + 1, sp) != 0:
                return 1
            re_cap[slot] = old
            return 0
        elif op == RI_BOL:
            if re_is_bol(sp) != 0:
                pc = pc + 1
                continue
            return 0
        elif op == RI_EOL:
            if re_is_eol(sp) != 0:
                pc = pc + 1
                continue
            return 0
        elif op == RI_WORDB:
            if re_is_wordb(sp) != 0:
                pc = pc + 1
                continue
            return 0
        elif op == RI_NWORDB:
            if re_is_wordb(sp) == 0:
                pc = pc + 1
                continue
            return 0
        elif op == RI_LAHEAD:
            # Zero-width: does the child block match starting at sp? The child
            # ends in RI_LADONE (returns 1). Positive succeeds on a match,
            # negative on no match; either way sp does not advance.
            m: int32 = re_run(pc + 1, sp)
            if re_y[pc] == 0:
                if m != 0:
                    pc = re_x[pc]
                    continue
                return 0
            if m == 0:
                pc = re_x[pc]
                continue
            return 0
        elif op == RI_LADONE:
            return 1
        elif op == RI_LBEHIND:
            # Zero-width: is there a start j <= sp such that the child matches
            # exactly [j, sp)? RI_LBDONE accepts only when the child ends at sp.
            saved_t: int32 = lb_target
            lb_target = sp
            found: int32 = 0
            j: int32 = sp
            while j >= 0:
                if re_run(pc + 1, j) != 0:
                    found = 1
                    break
                j = j - 1
            lb_target = saved_t
            if re_y[pc] == 0:
                if found != 0:
                    pc = re_x[pc]
                    continue
                return 0
            if found == 0:
                pc = re_x[pc]
                continue
            return 0
        elif op == RI_LBDONE:
            if sp == lb_target:
                return 1
            return 0
        elif op == RI_BACKREF:
            g: int32 = re_x[pc]
            s0: int32 = re_cap[2 * g]
            e0: int32 = re_cap[2 * g + 1]
            if s0 < 0 or e0 < 0:
                pc = pc + 1
                continue
            blen: int32 = e0 - s0
            if sp + blen > rx_len:
                return 0
            k: int32 = 0
            ok: int32 = 1
            while k < blen:
                if re_eqc(re_subj(sp + k), re_subj(s0 + k)) == 0:
                    ok = 0
                    break
                k = k + 1
            if ok == 0:
                return 0
            sp = sp + blen
            pc = pc + 1
            continue
        return 0
    return 0


# Search for a match at or after `startpos`; returns match-start index (>=0) with
# re_cap[] populated and rx_matchend set, or -1 if none.
def regex_search(prog_start: int32, ncap: int32, sid: int32, startpos: int32, ic: int32, ml: int32, da: int32, sticky: int32) -> int32:
    re_ic = ic
    re_ml = ml
    re_da = da
    rx_off = st_off[sid]
    rx_len = str_len(sid)
    pos: int32 = startpos
    while pos <= rx_len:
        i: int32 = 0
        while i < 2 * (ncap + 1):
            re_cap[i] = -1
            i = i + 1
        if re_run(prog_start, pos) != 0:
            return pos
        # sticky (`y`): the match must begin exactly at startpos — no forward scan.
        if sticky != 0:
            return -1
        pos = pos + 1
    return -1


# ---- construction ----
def js_make_regex(src_sid: int32, flags_sid: int32) -> int32:
    gflag: int32 = 0
    iflag: int32 = 0
    mflag: int32 = 0
    sflag: int32 = 0          # s : dotAll
    yflag: int32 = 0          # y : sticky
    dflag: int32 = 0          # d : hasIndices (match-result .indices)
    uflag: int32 = 0          # u : unicode (\u{cp}, surrogate pairs, \p{..})
    vflag: int32 = 0          # v : unicodeSets (treated as a u superset here)
    fn: int32 = str_len(flags_sid)
    fi: int32 = 0
    while fi < fn:
        fc: uint8 = str_char(flags_sid, fi)
        if fc == 103:
            gflag = 1
        elif fc == 105:
            iflag = 1
        elif fc == 109:
            mflag = 1
        elif fc == 115:                          # 's'
            sflag = 1
        elif fc == 121:                          # 'y'
            yflag = 1
        elif fc == 100:                          # 'd'
            dflag = 1
        elif fc == 117:                          # 'u'
            uflag = 1
        elif fc == 118:                          # 'v'
            vflag = 1
        fi = fi + 1
    re_ic = iflag
    re_ml = mflag
    re_da = sflag
    re_uni = uflag | vflag
    rn_n = 0
    re_gcount = 0
    gname_compile_start = gname_n
    rc_off = st_off[src_sid]
    rc_len = str_len(src_sid)
    rc_i = 0
    root: int32 = re_parse_alt()
    prog_start: int32 = re_n
    re_emit(RI_SAVE, 0, 0)
    re_compile(root)
    re_emit(RI_SAVE, 1, 0)
    re_emit(RI_MATCH, 0, 0)
    rv: int32 = v_new_object()
    o: int32 = objid_of(rv)
    obj_re_prog[o] = prog_start
    obj_re_ncap[o] = re_gcount
    obj_re_gnstart[o] = gname_compile_start
    obj_re_gncount[o] = gname_n - gname_compile_start
    bits: int32 = 0
    if gflag != 0:
        bits = bits | 1
    if iflag != 0:
        bits = bits | 2
    if mflag != 0:
        bits = bits | 4
    if sflag != 0:
        bits = bits | 8
    if yflag != 0:
        bits = bits | 16
    if dflag != 0:
        bits = bits | 32
    if uflag != 0:
        bits = bits | 64
    if vflag != 0:
        bits = bits | 128
    obj_re_flags[o] = bits
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("source")), v_string_id(src_sid))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("flags")), v_string_id(flags_sid))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("global")), v_boolv(gflag))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("ignoreCase")), v_boolv(iflag))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("multiline")), v_boolv(mflag))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("dotAll")), v_boolv(sflag))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("sticky")), v_boolv(yflag))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("hasIndices")), v_boolv(dflag))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("unicode")), v_boolv(uflag))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("unicodeSets")), v_boolv(vflag))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("lastIndex")), v_number(0.0))
    return rv


def is_regex(v: int32) -> int32:
    if tag_of(v) != TAG_OBJ:
        return 0
    if obj_re_prog[objid_of(v)] >= 0:
        return 1
    return 0


# Coerce a value into a RegExp (pass regexes through; strings/others compile).
def to_regex(v: int32) -> int32:
    if is_regex(v) != 0:
        return v
    sid: int32 = strid_of(to_string_val(v))
    return js_make_regex(sid, str_from_cstr(cast[Ptr[uint8]]("")))


# Build the exec()-style result array for the current re_cap[] over subject sid.
def regex_result_array(sid: int32, ncap: int32, start: int32, gnstart: int32, gncount: int32, dflag: int32) -> int32:
    res: int32 = v_new_array()
    ao: int32 = objid_of(res)
    g: int32 = 0
    while g <= ncap:
        s0: int32 = re_cap[2 * g]
        e0: int32 = re_cap[2 * g + 1]
        if s0 < 0 or e0 < 0:
            arr_push(ao, v_undef())
        else:
            arr_push(ao, v_string_bytes(&sp_buf[st_off[sid] + s0], e0 - s0))
        g = g + 1
    obj_set(ao, str_from_cstr(cast[Ptr[uint8]]("index")), v_number(cast[float64](start)))
    obj_set(ao, str_from_cstr(cast[Ptr[uint8]]("input")), v_string_id(sid))
    # .groups — an object of {name: capture} for `(?<name>...)` groups, else
    # undefined (per spec).
    if gncount > 0:
        grp: int32 = v_new_object()
        go: int32 = objid_of(grp)
        gi: int32 = 0
        while gi < gncount:
            row: int32 = gnstart + gi
            ci: int32 = gname_idx[row]
            ks: int32 = strid_of(v_string_bytes(&gname_buf[gname_soff[row]], gname_slen[row]))
            cs0: int32 = re_cap[2 * ci]
            ce0: int32 = re_cap[2 * ci + 1]
            if cs0 < 0 or ce0 < 0:
                obj_set(go, ks, v_undef())
            else:
                obj_set(go, ks, v_string_bytes(&sp_buf[st_off[sid] + cs0], ce0 - cs0))
            gi = gi + 1
        obj_set(ao, str_from_cstr(cast[Ptr[uint8]]("groups")), grp)
    else:
        obj_set(ao, str_from_cstr(cast[Ptr[uint8]]("groups")), v_undef())
    # .indices (ES2022 `d` flag) — a parallel array of [start,end) pairs per
    # capture (undefined for a non-participating group), plus an `.indices.groups`
    # object of the same pairs keyed by named group. Only present when `d` is set.
    if dflag != 0:
        idx: int32 = v_new_array()
        io: int32 = objid_of(idx)
        gk: int32 = 0
        while gk <= ncap:
            cs: int32 = re_cap[2 * gk]
            ce: int32 = re_cap[2 * gk + 1]
            if cs < 0 or ce < 0:
                arr_push(io, v_undef())
            else:
                pair: int32 = v_new_array()
                po: int32 = objid_of(pair)
                arr_push(po, v_number(cast[float64](cs)))
                arr_push(po, v_number(cast[float64](ce)))
                arr_push(io, pair)
            gk = gk + 1
        if gncount > 0:
            ig: int32 = v_new_object()
            igo: int32 = objid_of(ig)
            gj: int32 = 0
            while gj < gncount:
                row2: int32 = gnstart + gj
                ci2: int32 = gname_idx[row2]
                ks2: int32 = strid_of(v_string_bytes(&gname_buf[gname_soff[row2]], gname_slen[row2]))
                gs: int32 = re_cap[2 * ci2]
                ge: int32 = re_cap[2 * ci2 + 1]
                if gs < 0 or ge < 0:
                    obj_set(igo, ks2, v_undef())
                else:
                    gpair: int32 = v_new_array()
                    gpo: int32 = objid_of(gpair)
                    arr_push(gpo, v_number(cast[float64](gs)))
                    arr_push(gpo, v_number(cast[float64](ge)))
                    obj_set(igo, ks2, gpair)
                gj = gj + 1
            obj_set(io, str_from_cstr(cast[Ptr[uint8]]("groups")), ig)
        else:
            obj_set(io, str_from_cstr(cast[Ptr[uint8]]("groups")), v_undef())
        obj_set(ao, str_from_cstr(cast[Ptr[uint8]]("indices")), idx)
    return res


# re.exec(str): returns a match array (with .index/.input + capture groups) or
# null; advances/reads .lastIndex when the `g` flag is set.
def regex_exec(rev: int32, strv: int32) -> int32:
    o: int32 = objid_of(rev)
    sid: int32 = strid_of(to_string_val(strv))
    gflag: int32 = obj_re_flags[o] & 1
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    da: int32 = (obj_re_flags[o] >> 3) & 1
    yflag: int32 = (obj_re_flags[o] >> 4) & 1
    # Both `g` and `y` read/advance .lastIndex (a sticky match must begin exactly
    # at lastIndex; regex_search enforces the anchor when sticky != 0).
    use_li: int32 = gflag | yflag
    li: int32 = 0
    if use_li != 0:
        li = cast[int32](to_number(obj_get_cstr(o, cast[Ptr[uint8]]("lastIndex"))))
    if li < 0:
        li = 0
    if li > str_len(sid):
        obj_set(o, str_from_cstr(cast[Ptr[uint8]]("lastIndex")), v_number(0.0))
        return v_null()
    start: int32 = regex_search(obj_re_prog[o], obj_re_ncap[o], sid, li, ic, ml, da, yflag)
    if start < 0:
        if use_li != 0:
            obj_set(o, str_from_cstr(cast[Ptr[uint8]]("lastIndex")), v_number(0.0))
        return v_null()
    if use_li != 0:
        obj_set(o, str_from_cstr(cast[Ptr[uint8]]("lastIndex")), v_number(cast[float64](rx_matchend)))
    return regex_result_array(sid, obj_re_ncap[o], start, obj_re_gnstart[o], obj_re_gncount[o], (obj_re_flags[o] >> 5) & 1)


def regex_test(rev: int32, strv: int32) -> int32:
    r: int32 = regex_exec(rev, strv)
    if tag_of(r) == TAG_NULL:
        return v_false()
    return v_true()


# re.test / re.exec dispatch (called from eval_call on a regex receiver).
# Returns -2 if `name` is not a regex method.
def try_regex_method(rev: int32, name: int32, argnode: int32, env: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    if ctl == CTL_THROW:
        call_top = base
        return v_undef()
    r: int32 = -2
    if str_eq_cstr(name, cast[Ptr[uint8]]("test")) != 0:
        r = regex_test(rev, arg_or(base, argc, 0))
    elif str_eq_cstr(name, cast[Ptr[uint8]]("exec")) != 0:
        r = regex_exec(rev, arg_or(base, argc, 0))
    elif str_eq_cstr(name, cast[Ptr[uint8]]("toString")) != 0:
        r = to_string_val(rev)
    call_top = base
    return r


# ---- String.prototype regex methods (subject sid + a regex value) ----
# str.search(re): index of first match or -1 (ignores g/lastIndex).
def str_regex_search(sid: int32, rev: int32) -> int32:
    o: int32 = objid_of(rev)
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    da: int32 = (obj_re_flags[o] >> 3) & 1
    return v_number(cast[float64](regex_search(obj_re_prog[o], obj_re_ncap[o], sid, 0, ic, ml, da, 0)))


# str.match(re): non-global -> exec-style array or null; global -> array of all
# matched substrings (or null).
def str_regex_match(sid: int32, rev: int32) -> int32:
    o: int32 = objid_of(rev)
    gflag: int32 = obj_re_flags[o] & 1
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    da: int32 = (obj_re_flags[o] >> 3) & 1
    yflag: int32 = (obj_re_flags[o] >> 4) & 1
    if gflag == 0:
        strv: int32 = v_string_id(sid)
        return regex_exec(rev, strv)
    res: int32 = v_new_array()
    ao: int32 = objid_of(res)
    pos: int32 = 0
    n: int32 = str_len(sid)
    any: int32 = 0
    while pos <= n:
        start: int32 = regex_search(obj_re_prog[o], obj_re_ncap[o], sid, pos, ic, ml, da, yflag)
        if start < 0:
            break
        any = 1
        mend: int32 = rx_matchend
        arr_push(ao, v_string_bytes(&sp_buf[st_off[sid] + start], mend - start))
        if mend > start:
            pos = mend
        else:
            pos = mend + 1                   # zero-width: advance to avoid a loop
    if any == 0:
        return v_null()
    return res


# str.matchAll(re): array of exec-style match arrays (each with groups+index).
def str_regex_matchall(sid: int32, rev: int32) -> int32:
    o: int32 = objid_of(rev)
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    da: int32 = (obj_re_flags[o] >> 3) & 1
    yflag: int32 = (obj_re_flags[o] >> 4) & 1
    ncap: int32 = obj_re_ncap[o]
    res: int32 = v_new_array()
    ao: int32 = objid_of(res)
    pos: int32 = 0
    n: int32 = str_len(sid)
    while pos <= n:
        start: int32 = regex_search(obj_re_prog[o], ncap, sid, pos, ic, ml, da, yflag)
        if start < 0:
            break
        mend: int32 = rx_matchend
        arr_push(ao, regex_result_array(sid, ncap, start, obj_re_gnstart[o], obj_re_gncount[o], (obj_re_flags[o] >> 5) & 1))
        if mend > start:
            pos = mend
        else:
            pos = mend + 1
    return res


# str.split(re[, limit]): split on regex separators; captured groups from the
# separator are spliced into the result (per spec).
def str_regex_split(sid: int32, rev: int32) -> int32:
    o: int32 = objid_of(rev)
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    da: int32 = (obj_re_flags[o] >> 3) & 1
    ncap: int32 = obj_re_ncap[o]
    res: int32 = v_new_array()
    ao: int32 = objid_of(res)
    n: int32 = str_len(sid)
    if n == 0:
        return res                           # "".split(re) -> [] (unless re matches "")
    last: int32 = 0
    pos: int32 = 0
    while pos < n:
        start: int32 = regex_search(obj_re_prog[o], ncap, sid, pos, ic, ml, da, 0)
        if start < 0:
            break
        mend: int32 = rx_matchend
        if mend == start:
            # zero-width separator: skip to keep progress
            if start >= n:
                break
            pos = start + 1
            continue
        arr_push(ao, v_string_bytes(&sp_buf[st_off[sid] + last], start - last))
        g: int32 = 1
        while g <= ncap:
            s0: int32 = re_cap[2 * g]
            e0: int32 = re_cap[2 * g + 1]
            if s0 < 0 or e0 < 0:
                arr_push(ao, v_undef())
            else:
                arr_push(ao, v_string_bytes(&sp_buf[st_off[sid] + s0], e0 - s0))
            g = g + 1
        last = mend
        pos = mend
    arr_push(ao, v_string_bytes(&sp_buf[st_off[sid] + last], n - last))
    return res


# str.replace(re, repl): repl is a string ($1/$&/$$/$`/$') or a function.
# Two-phase: resolve each replacement to a string id first (so a replacer
# function can safely build strings), then assemble the result in one pass.
def str_regex_replace(sid: int32, rev: int32, replv: int32) -> int32:
    o: int32 = objid_of(rev)
    gflag: int32 = obj_re_flags[o] & 1
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    da: int32 = (obj_re_flags[o] >> 3) & 1
    yflag: int32 = (obj_re_flags[o] >> 4) & 1
    ncap: int32 = obj_re_ncap[o]
    is_fn: int32 = is_callable(replv)
    n: int32 = str_len(sid)
    count: int32 = 0
    pos: int32 = 0
    # phase 1: find matches + resolve replacement string ids
    while pos <= n and count < MAX_REP:
        start: int32 = regex_search(obj_re_prog[o], ncap, sid, pos, ic, ml, da, yflag)
        if start < 0:
            break
        mend: int32 = rx_matchend
        rid0: int32 = 0
        if is_fn != 0:
            rid0 = re_fn_repl_id(sid, replv, start, mend, ncap)
        else:
            rid0 = re_str_repl_id(sid, replv, start, mend, ncap, obj_re_gnstart[o], obj_re_gncount[o])
        rep_start[count] = start
        rep_end[count] = mend
        rep_id[count] = rid0
        count = count + 1
        if mend > start:
            pos = mend
        else:
            pos = mend + 1
        if gflag == 0:
            break
    # phase 2: assemble
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    last: int32 = 0
    i: int32 = 0
    while i < count:
        j: int32 = last
        while j < rep_start[i]:
            emit_c(str_char(sid, j))
            j = j + 1
        emit_strid(rep_id[i])
        last = rep_end[i]
        i = i + 1
    j2: int32 = last
    while j2 < n:
        emit_c(str_char(sid, j2))
        j2 = j2 + 1
    rid: int32 = bld_end()
    emit_tgt = save
    return v_string_id(rid)


# Build a string-replacement into a fresh string id (handles $&, $$, $1..$99,
# $`, $'). Self-contained; no user code runs, so the shared builder is safe.
# Resolve a `$<name>` replacement token: find the capture index for `name`
# (chars [nstart,nend) of replacement string `rsid`) among the regex's named
# groups (rows [gnstart, gnstart+gncount)). -1 if unknown.
def re_gname_lookup_repl(rsid: int32, nstart: int32, nend: int32, gnstart: int32, gncount: int32) -> int32:
    slen: int32 = nend - nstart
    r: int32 = 0
    while r < gncount:
        row: int32 = gnstart + r
        if gname_slen[row] == slen:
            k: int32 = 0
            same: int32 = 1
            while k < slen:
                if gname_buf[gname_soff[row] + k] != str_char(rsid, nstart + k):
                    same = 0
                    break
                k = k + 1
            if same != 0:
                return gname_idx[row]
        r = r + 1
    return -1


def re_str_repl_id(sid: int32, replv: int32, start: int32, mend: int32, ncap: int32, gnstart: int32, gncount: int32) -> int32:
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    rsid: int32 = strid_of(to_string_val(replv))
    rn: int32 = str_len(rsid)
    i: int32 = 0
    while i < rn:
        c: uint8 = str_char(rsid, i)
        if c == 36 and i + 1 < rn:           # '$'
            d: uint8 = str_char(rsid, i + 1)
            if d == 36:                      # $$ -> literal $
                emit_c(36)
                i = i + 2
                continue
            if d == 38:                      # $& whole match
                k: int32 = start
                while k < mend:
                    emit_c(str_char(sid, k))
                    k = k + 1
                i = i + 2
                continue
            if d == 96:                      # $` prefix
                k2: int32 = 0
                while k2 < start:
                    emit_c(str_char(sid, k2))
                    k2 = k2 + 1
                i = i + 2
                continue
            if d == 39:                      # $' suffix
                k3: int32 = mend
                slen: int32 = str_len(sid)
                while k3 < slen:
                    emit_c(str_char(sid, k3))
                    k3 = k3 + 1
                i = i + 2
                continue
            if d == 60:                      # $<name>  named-capture reference
                ni: int32 = i + 2
                while ni < rn and str_char(rsid, ni) != 62:   # up to '>'
                    ni = ni + 1
                if ni < rn:                  # found closing '>'
                    gni: int32 = re_gname_lookup_repl(rsid, i + 2, ni, gnstart, gncount)
                    if gni >= 1 and gni <= ncap:
                        gs: int32 = re_cap[2 * gni]
                        ge: int32 = re_cap[2 * gni + 1]
                        if gs >= 0 and ge >= 0:
                            kn: int32 = gs
                            while kn < ge:
                                emit_c(str_char(sid, kn))
                                kn = kn + 1
                    i = ni + 1               # skip past '>' (unknown name -> empty)
                    continue
            if d >= 48 and d <= 57:          # $n or $nn
                gi: int32 = cast[int32](d) - 48
                adv: int32 = 2
                if i + 2 < rn:
                    d2: uint8 = str_char(rsid, i + 2)
                    if d2 >= 48 and d2 <= 57:
                        gi2: int32 = gi * 10 + (cast[int32](d2) - 48)
                        if gi2 <= ncap:
                            gi = gi2
                            adv = 3
                if gi >= 1 and gi <= ncap:
                    s0: int32 = re_cap[2 * gi]
                    e0: int32 = re_cap[2 * gi + 1]
                    if s0 >= 0 and e0 >= 0:
                        kk: int32 = s0
                        while kk < e0:
                            emit_c(str_char(sid, kk))
                            kk = kk + 1
                    i = i + adv
                    continue
            emit_c(36)                       # unrecognized -> literal '$'
            i = i + 1
        else:
            emit_c(c)
            i = i + 1
    rid: int32 = bld_end()
    emit_tgt = save
    return rid


# Call a replacer function fn(match, p1.., offset, str); return its result's
# string id. Args are snapshotted from re_cap before invoking.
def re_fn_repl_id(sid: int32, fnv: int32, start: int32, mend: int32, ncap: int32) -> int32:
    base: int32 = call_top
    call_args[call_top] = v_string_bytes(&sp_buf[st_off[sid] + start], mend - start)
    call_top = call_top + 1
    g: int32 = 1
    while g <= ncap:
        s0: int32 = re_cap[2 * g]
        e0: int32 = re_cap[2 * g + 1]
        if s0 < 0 or e0 < 0:
            call_args[call_top] = v_undef()
        else:
            call_args[call_top] = v_string_bytes(&sp_buf[st_off[sid] + s0], e0 - s0)
        call_top = call_top + 1
        g = g + 1
    call_args[call_top] = v_number(cast[float64](start))
    call_top = call_top + 1
    call_args[call_top] = v_string_id(sid)
    call_top = call_top + 1
    argc: int32 = call_top - base
    rv: int32 = invoke(fnv, v_undef(), base, argc)
    call_top = base
    return strid_of(to_string_val(rv))


def def_global_native(name: Ptr[uint8], native_id: int32):
    env_define(g_env, str_from_cstr(name), v_new_native(native_id), 0)


def obj_add_native(objv: int32, name: Ptr[uint8], native_id: int32):
    obj_set(objid_of(objv), str_from_cstr(name), v_new_native(native_id))


def obj_add_num(objv: int32, name: Ptr[uint8], x: float64):
    obj_set(objid_of(objv), str_from_cstr(name), v_number(x))


# Create an Error-family constructor with a .prototype. Returns the ctor value.
# `super_ctor` is the base Error ctor value (-1 for Error itself) so subclass
# prototypes chain to Error.prototype.
def install_error(name: Ptr[uint8], native_id: int32, super_ctor: int32) -> int32:
    fv: int32 = v_new_native(native_id)
    proto: int32 = v_new_object()
    obj_set(objid_of(proto), str_from_cstr(cast[Ptr[uint8]]("name")), v_string_cstr(name))
    if super_ctor >= 0:
        basep: int32 = obj_get(objid_of(super_ctor), str_from_cstr(cast[Ptr[uint8]]("prototype")))
        if tag_of(basep) == TAG_OBJ:
            obj_proto[objid_of(proto)] = objid_of(basep)
    obj_set(objid_of(fv), str_from_cstr(cast[Ptr[uint8]]("prototype")), proto)
    env_define(g_env, str_from_cstr(name), fv, 0)
    return fv


def install_builtins():
    # console
    g_console = v_new_object()
    obj_add_native(g_console, cast[Ptr[uint8]]("log"), NAT_CONSOLE_LOG)
    obj_add_native(g_console, cast[Ptr[uint8]]("error"), NAT_CONSOLE_LOG)
    obj_add_native(g_console, cast[Ptr[uint8]]("warn"), NAT_CONSOLE_LOG)
    obj_add_native(g_console, cast[Ptr[uint8]]("info"), NAT_CONSOLE_LOG)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("console")), g_console, 0)
    # Math
    g_math = v_new_object()
    obj_add_native(g_math, cast[Ptr[uint8]]("floor"), NAT_MATH_FLOOR)
    obj_add_native(g_math, cast[Ptr[uint8]]("ceil"), NAT_MATH_CEIL)
    obj_add_native(g_math, cast[Ptr[uint8]]("round"), NAT_MATH_ROUND)
    obj_add_native(g_math, cast[Ptr[uint8]]("abs"), NAT_MATH_ABS)
    obj_add_native(g_math, cast[Ptr[uint8]]("sqrt"), NAT_MATH_SQRT)
    obj_add_native(g_math, cast[Ptr[uint8]]("pow"), NAT_MATH_POW)
    obj_add_native(g_math, cast[Ptr[uint8]]("min"), NAT_MATH_MIN)
    obj_add_native(g_math, cast[Ptr[uint8]]("max"), NAT_MATH_MAX)
    obj_add_native(g_math, cast[Ptr[uint8]]("trunc"), NAT_MATH_TRUNC)
    obj_add_native(g_math, cast[Ptr[uint8]]("sign"), NAT_MATH_SIGN)
    obj_add_native(g_math, cast[Ptr[uint8]]("cbrt"), NAT_MATH_CBRT)
    obj_add_native(g_math, cast[Ptr[uint8]]("hypot"), NAT_MATH_HYPOT)
    obj_add_native(g_math, cast[Ptr[uint8]]("log"), NAT_MATH_LOG)
    obj_add_native(g_math, cast[Ptr[uint8]]("log2"), NAT_MATH_LOG2)
    obj_add_native(g_math, cast[Ptr[uint8]]("log10"), NAT_MATH_LOG10)
    obj_add_native(g_math, cast[Ptr[uint8]]("exp"), NAT_MATH_EXP)
    obj_add_native(g_math, cast[Ptr[uint8]]("sin"), NAT_MATH_SIN)
    obj_add_native(g_math, cast[Ptr[uint8]]("cos"), NAT_MATH_COS)
    obj_add_native(g_math, cast[Ptr[uint8]]("tan"), NAT_MATH_TAN)
    obj_add_native(g_math, cast[Ptr[uint8]]("asin"), NAT_MATH_ASIN)
    obj_add_native(g_math, cast[Ptr[uint8]]("acos"), NAT_MATH_ACOS)
    obj_add_native(g_math, cast[Ptr[uint8]]("atan"), NAT_MATH_ATAN)
    obj_add_native(g_math, cast[Ptr[uint8]]("atan2"), NAT_MATH_ATAN2)
    obj_add_native(g_math, cast[Ptr[uint8]]("random"), NAT_MATH_RANDOM)
    obj_add_num(g_math, cast[Ptr[uint8]]("PI"), 3.141592653589793)
    obj_add_num(g_math, cast[Ptr[uint8]]("E"), 2.718281828459045)
    obj_add_num(g_math, cast[Ptr[uint8]]("LN2"), 0.6931471805599453)
    obj_add_num(g_math, cast[Ptr[uint8]]("LN10"), 2.302585092994046)
    obj_add_num(g_math, cast[Ptr[uint8]]("LOG2E"), 1.4426950408889634)
    obj_add_num(g_math, cast[Ptr[uint8]]("LOG10E"), 0.4342944819032518)
    obj_add_num(g_math, cast[Ptr[uint8]]("SQRT2"), 1.4142135623730951)
    obj_add_num(g_math, cast[Ptr[uint8]]("SQRT1_2"), 0.7071067811865476)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Math")), g_math, 0)
    # JSON
    g_json = v_new_object()
    obj_add_native(g_json, cast[Ptr[uint8]]("stringify"), NAT_JSON_STRINGIFY)
    obj_add_native(g_json, cast[Ptr[uint8]]("parse"), NAT_JSON_PARSE)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("JSON")), g_json, 0)
    # Object
    g_object = v_new_object()
    obj_add_native(g_object, cast[Ptr[uint8]]("keys"), NAT_OBJECT_KEYS)
    obj_add_native(g_object, cast[Ptr[uint8]]("assign"), NAT_OBJECT_ASSIGN)
    obj_add_native(g_object, cast[Ptr[uint8]]("values"), NAT_OBJECT_VALUES)
    obj_add_native(g_object, cast[Ptr[uint8]]("entries"), NAT_OBJECT_ENTRIES)
    obj_add_native(g_object, cast[Ptr[uint8]]("fromEntries"), NAT_OBJECT_FROMENTRIES)
    obj_add_native(g_object, cast[Ptr[uint8]]("freeze"), NAT_OBJECT_FREEZE)
    obj_add_native(g_object, cast[Ptr[uint8]]("create"), NAT_OBJECT_CREATE)
    obj_add_native(g_object, cast[Ptr[uint8]]("getPrototypeOf"), NAT_OBJECT_GETPROTO)
    obj_add_native(g_object, cast[Ptr[uint8]]("setPrototypeOf"), NAT_OBJECT_SETPROTO)
    obj_add_native(g_object, cast[Ptr[uint8]]("getOwnPropertyNames"), NAT_OBJECT_GETOWNNAMES)
    obj_add_native(g_object, cast[Ptr[uint8]]("defineProperty"), NAT_OBJECT_DEFINEPROP)
    obj_add_native(g_object, cast[Ptr[uint8]]("defineProperties"), NAT_OBJECT_DEFINEPROPS)
    obj_add_native(g_object, cast[Ptr[uint8]]("getOwnPropertyDescriptor"), NAT_OBJECT_GETOWNDESC)
    obj_add_native(g_object, cast[Ptr[uint8]]("getOwnPropertyDescriptors"), NAT_OBJECT_GETOWNDESCS)
    obj_add_native(g_object, cast[Ptr[uint8]]("isFrozen"), NAT_OBJECT_ISFROZEN)
    obj_add_native(g_object, cast[Ptr[uint8]]("isExtensible"), NAT_OBJECT_ISEXT)
    obj_add_native(g_object, cast[Ptr[uint8]]("preventExtensions"), NAT_OBJECT_PREVENTEXT)
    obj_add_native(g_object, cast[Ptr[uint8]]("seal"), NAT_OBJECT_SEAL)
    obj_add_native(g_object, cast[Ptr[uint8]]("isSealed"), NAT_OBJECT_ISSEALED)
    obj_add_native(g_object, cast[Ptr[uint8]]("hasOwn"), NAT_OBJECT_HASOWN)
    obj_add_native(g_object, cast[Ptr[uint8]]("is"), NAT_OBJECT_IS)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Object")), g_object, 0)
    # Array
    g_array = v_new_native(NAT_ARRAY_CTOR)
    obj_add_native(g_array, cast[Ptr[uint8]]("isArray"), NAT_ARRAY_ISARRAY)
    obj_add_native(g_array, cast[Ptr[uint8]]("of"), NAT_ARRAY_OF)
    obj_add_native(g_array, cast[Ptr[uint8]]("from"), NAT_ARRAY_FROM)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Array")), g_array, 0)
    # Function — provided so `x instanceof Function` resolves (and gives a clear
    # error if code tries to build code from a string, which we don't support).
    g_function = v_new_native(NAT_FUNCTION_CTOR)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Function")), g_function, 0)
    # Number (static helpers + constants)
    g_number = v_new_native(NAT_NUMBER)
    obj_add_native(g_number, cast[Ptr[uint8]]("isInteger"), NAT_NUMBER_ISINTEGER)
    obj_add_native(g_number, cast[Ptr[uint8]]("isNaN"), NAT_NUMBER_ISNAN)
    obj_add_native(g_number, cast[Ptr[uint8]]("isFinite"), NAT_NUMBER_ISFINITE)
    obj_add_native(g_number, cast[Ptr[uint8]]("isSafeInteger"), NAT_NUMBER_ISSAFEINT)
    obj_add_native(g_number, cast[Ptr[uint8]]("parseFloat"), NAT_PARSEFLOAT)
    obj_add_native(g_number, cast[Ptr[uint8]]("parseInt"), NAT_PARSEINT)
    nobj: int32 = objid_of(g_number)
    obj_set(nobj, str_from_cstr(cast[Ptr[uint8]]("MAX_SAFE_INTEGER")), v_number(9007199254740991.0))
    obj_set(nobj, str_from_cstr(cast[Ptr[uint8]]("MIN_SAFE_INTEGER")), v_number(0.0 - 9007199254740991.0))
    obj_set(nobj, str_from_cstr(cast[Ptr[uint8]]("MAX_VALUE")), v_number(1.7976931348623157e308))
    obj_set(nobj, str_from_cstr(cast[Ptr[uint8]]("MIN_VALUE")), v_number(5.0e-324))

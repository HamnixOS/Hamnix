    obj_set(loc_o, str_from_cstr(cast[Ptr[uint8]]("hostname")), v_string_cstr(cast[Ptr[uint8]]("")))
    obj_set(loc_o, str_from_cstr(cast[Ptr[uint8]]("port")), v_string_cstr(cast[Ptr[uint8]]("")))
    obj_set(loc_o, str_from_cstr(cast[Ptr[uint8]]("pathname")), v_string_cstr(cast[Ptr[uint8]]("blank")))
    obj_set(loc_o, str_from_cstr(cast[Ptr[uint8]]("search")), v_string_cstr(cast[Ptr[uint8]]("")))
    obj_set(loc_o, str_from_cstr(cast[Ptr[uint8]]("hash")), v_string_cstr(cast[Ptr[uint8]]("")))
    obj_set(loc_o, str_from_cstr(cast[Ptr[uint8]]("origin")), v_string_cstr(cast[Ptr[uint8]]("null")))
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("location")), g_location, 0)
    # A screen object is likewise read ungated for viewport feature-detection.
    g_screen: int32 = v_new_object()
    scr_o: int32 = objid_of(g_screen)
    obj_set(scr_o, str_from_cstr(cast[Ptr[uint8]]("width")), v_number(1024.0))
    obj_set(scr_o, str_from_cstr(cast[Ptr[uint8]]("height")), v_number(768.0))
    obj_set(scr_o, str_from_cstr(cast[Ptr[uint8]]("availWidth")), v_number(1024.0))
    obj_set(scr_o, str_from_cstr(cast[Ptr[uint8]]("availHeight")), v_number(768.0))
    obj_set(scr_o, str_from_cstr(cast[Ptr[uint8]]("colorDepth")), v_number(24.0))
    obj_set(scr_o, str_from_cstr(cast[Ptr[uint8]]("pixelDepth")), v_number(24.0))
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("screen")), g_screen, 0)
    # Intl namespace (NumberFormat + DateTimeFormat) — builtins/intl.ad
    install_intl()



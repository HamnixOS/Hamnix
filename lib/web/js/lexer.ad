# lib/web/js/lexer.ad — part of the modular web engine (extracted from jsengine.ad).
# LEXER — tokenizes src_ptr/src_len into the token arrays.
#
# Behavior-preserving split: Adder is a single-compilation-unit language
# (merge_programs merges all imported files into one Program), so every
# public top-level name here resolves globally across the merged engine.

# ====================================================================
# LEXER — source in src_ptr/src_len; produces token arrays.
# ====================================================================
lex_p: Ptr[uint8] = 0
lex_n: int32 = 0
lex_i: int32 = 0


def push_tok(kind: int32):
    tk_kind[n_toks] = cast[uint8](kind)
    tk_num[n_toks] = 0.0
    tk_str[n_toks] = -1
    n_toks = n_toks + 1


def push_tok_num(x: float64):
    tk_kind[n_toks] = cast[uint8](TK_NUM)
    tk_num[n_toks] = x
    tk_str[n_toks] = -1
    n_toks = n_toks + 1


def push_tok_str(kind: int32, sid: int32):
    tk_kind[n_toks] = cast[uint8](kind)
    tk_num[n_toks] = 0.0
    tk_str[n_toks] = sid
    tk_str2[n_toks] = -1
    n_toks = n_toks + 1


def push_tok_regex(src_sid: int32, flags_sid: int32):
    tk_kind[n_toks] = cast[uint8](TK_REGEX)
    tk_num[n_toks] = 0.0
    tk_str[n_toks] = src_sid
    tk_str2[n_toks] = flags_sid
    n_toks = n_toks + 1


def push_tok_tmpl(kind: int32, cooked_sid: int32, raw_sid: int32):
    tk_kind[n_toks] = cast[uint8](kind)
    tk_num[n_toks] = 0.0
    tk_str[n_toks] = cooked_sid
    tk_str2[n_toks] = raw_sid
    n_toks = n_toks + 1


# A leading `/` starts a regex literal only in expression-start position — i.e.
# NOT right after a value-producing token (identifier, literal, `)`, `]`, `++`,
# `--`, this/super, etc.). Everything else (operators, `(`, `,`, `=`, `return`,
# `{`, `;`, start-of-input, ...) means an expression is expected -> regex.
def prev_is_value() -> int32:
    if n_toks == 0:
        return 0
    k: int32 = cast[int32](tk_kind[n_toks - 1])
    if k == TK_IDENT or k == TK_NUM or k == TK_STR or k == TK_REGEX:
        return 1
    if k == TK_TMPL_FULL or k == TK_TMPL_TAIL:   # a completed template is a value
        return 1
    if k == TK_RPAREN or k == TK_RBRACK:
        return 1
    if k == TK_THIS or k == TK_SUPER:
        return 1
    if k == TK_TRUE or k == TK_FALSE or k == TK_NULL or k == TK_UNDEFINED:
        return 1
    if k == TK_INC or k == TK_DEC:
        return 1
    return 0


# Lex a regex literal beginning at the opening `/` (lex_i points at it). Scans
# the pattern (tracking `\`-escapes and `[...]` classes so an inner `/` is not
# mistaken for the terminator), then the trailing flag letters.
def lex_regex():
    lex_i = lex_i + 1                     # skip opening /
    start: int32 = lex_i
    inclass: int32 = 0
    while lex_i < lex_n:
        c: uint8 = lex_p[lex_i]
        if c == 92:                       # backslash: escape next char
            lex_i = lex_i + 2
            continue
        if c == 91:                       # [
            inclass = 1
        elif c == 93:                     # ]
            inclass = 0
        elif c == 47 and inclass == 0:    # / terminator
            break
        elif c == 10:                     # unterminated at newline
            break
        lex_i = lex_i + 1
    src_sid: int32 = str_new(&lex_p[start], lex_i - start)
    if lex_i < lex_n and lex_p[lex_i] == 47:
        lex_i = lex_i + 1                 # skip closing /
    # flags
    fstart: int32 = lex_i
    while lex_i < lex_n and is_idpart(lex_p[lex_i]) != 0:
        lex_i = lex_i + 1
    flags_sid: int32 = str_new(&lex_p[fstart], lex_i - fstart)
    push_tok_regex(src_sid, flags_sid)


def kw_kind(sid: int32) -> int32:
    if str_eq_cstr(sid, cast[Ptr[uint8]]("var")) != 0:
        return TK_VAR
    if str_eq_cstr(sid, cast[Ptr[uint8]]("let")) != 0:
        return TK_LET
    if str_eq_cstr(sid, cast[Ptr[uint8]]("const")) != 0:
        return TK_CONST
    if str_eq_cstr(sid, cast[Ptr[uint8]]("function")) != 0:
        return TK_FUNCTION
    if str_eq_cstr(sid, cast[Ptr[uint8]]("return")) != 0:
        return TK_RETURN
    if str_eq_cstr(sid, cast[Ptr[uint8]]("if")) != 0:
        return TK_IF
    if str_eq_cstr(sid, cast[Ptr[uint8]]("else")) != 0:
        return TK_ELSE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("while")) != 0:
        return TK_WHILE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("for")) != 0:
        return TK_FOR
    if str_eq_cstr(sid, cast[Ptr[uint8]]("do")) != 0:
        return TK_DO
    if str_eq_cstr(sid, cast[Ptr[uint8]]("break")) != 0:
        return TK_BREAK
    if str_eq_cstr(sid, cast[Ptr[uint8]]("continue")) != 0:
        return TK_CONTINUE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("true")) != 0:
        return TK_TRUE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("false")) != 0:
        return TK_FALSE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("null")) != 0:
        return TK_NULL
    if str_eq_cstr(sid, cast[Ptr[uint8]]("undefined")) != 0:
        return TK_UNDEFINED
    if str_eq_cstr(sid, cast[Ptr[uint8]]("typeof")) != 0:
        return TK_TYPEOF
    if str_eq_cstr(sid, cast[Ptr[uint8]]("instanceof")) != 0:
        return TK_INSTANCEOF
    if str_eq_cstr(sid, cast[Ptr[uint8]]("in")) != 0:
        return TK_IN
    if str_eq_cstr(sid, cast[Ptr[uint8]]("new")) != 0:
        return TK_NEW
    if str_eq_cstr(sid, cast[Ptr[uint8]]("this")) != 0:
        return TK_THIS
    if str_eq_cstr(sid, cast[Ptr[uint8]]("class")) != 0:
        return TK_CLASS
    if str_eq_cstr(sid, cast[Ptr[uint8]]("extends")) != 0:
        return TK_EXTENDS
    if str_eq_cstr(sid, cast[Ptr[uint8]]("super")) != 0:
        return TK_SUPER
    if str_eq_cstr(sid, cast[Ptr[uint8]]("try")) != 0:
        return TK_TRY
    if str_eq_cstr(sid, cast[Ptr[uint8]]("catch")) != 0:
        return TK_CATCH
    if str_eq_cstr(sid, cast[Ptr[uint8]]("finally")) != 0:
        return TK_FINALLY
    if str_eq_cstr(sid, cast[Ptr[uint8]]("throw")) != 0:
        return TK_THROW
    if str_eq_cstr(sid, cast[Ptr[uint8]]("void")) != 0:
        return TK_VOID
    if str_eq_cstr(sid, cast[Ptr[uint8]]("delete")) != 0:
        return TK_DELETE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("switch")) != 0:
        return TK_SWITCH
    if str_eq_cstr(sid, cast[Ptr[uint8]]("case")) != 0:
        return TK_CASE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("default")) != 0:
        return TK_DEFAULT
    return TK_IDENT


def lch(off: int32) -> uint8:
    if lex_i + off >= lex_n:
        return 0
    return lex_p[lex_i + off]


def emit_utf8(cp: int32):
    # Encode a Unicode code point as UTF-8 into the current build target.
    if cp < 128:
        emit_c(cast[uint8](cp))
    elif cp < 2048:
        emit_c(cast[uint8](192 + (cp >> 6)))
        emit_c(cast[uint8](128 + (cp & 63)))
    elif cp < 65536:
        emit_c(cast[uint8](224 + (cp >> 12)))
        emit_c(cast[uint8](128 + ((cp >> 6) & 63)))
        emit_c(cast[uint8](128 + (cp & 63)))
    else:
        emit_c(cast[uint8](240 + (cp >> 18)))
        emit_c(cast[uint8](128 + ((cp >> 12) & 63)))
        emit_c(cast[uint8](128 + ((cp >> 6) & 63)))
        emit_c(cast[uint8](128 + (cp & 63)))


def lex_emit_hexesc(ndig: int32):
    # lex_i is AT the 'x' or 'u'. Read up to ndig hex digits following it,
    # emit the resulting code point as UTF-8, and leave lex_i at the LAST
    # consumed digit (the caller advances one past it). Malformed (zero
    # digits) emits nothing.
    cp: int32 = 0
    k: int32 = 0
    while k < ndig:
        hv: int32 = hexval(lch(1))
        if hv < 0:
            break
        cp = cp * 16 + hv
        lex_i = lex_i + 1
        k = k + 1
    if k > 0:
        emit_utf8(cp)


def lex_string(q: uint8):
    lex_i = lex_i + 1                 # skip opening quote
    bld_begin()
    save: int32 = emit_tgt
    emit_tgt = 0
    while lex_i < lex_n and lex_p[lex_i] != q:
        c: uint8 = lex_p[lex_i]
        if c == 92:                   # backslash
            lex_i = lex_i + 1
            e: uint8 = lch(0)
            if e == 110:                  # \n
                emit_c(10)
            elif e == 116:                # \t
                emit_c(9)
            elif e == 114:                # \r
                emit_c(13)
            elif e == 98:                 # \b -> backspace
                emit_c(8)
            elif e == 102:                # \f -> form feed
                emit_c(12)
            elif e == 118:                # \v -> vertical tab
                emit_c(11)
            elif e == 92:                 # \\
                emit_c(92)
            elif e == 39:                 # \'
                emit_c(39)
            elif e == 34:                 # \"
                emit_c(34)
            elif e == 48:                 # \0 -> NUL
                emit_c(0)
            elif e == 120:                # \xHH
                lex_emit_hexesc(2)
            elif e == 117:                # \uHHHH
                lex_emit_hexesc(4)
            elif e == 10:                 # line continuation \<LF> -> nothing
                pass
            elif e == 13:                 # line continuation \<CR>[<LF>]
                if lch(1) == 10:
                    lex_i = lex_i + 1
            else:                         # unknown escape -> literal char
                emit_c(e)
            lex_i = lex_i + 1
        else:
            emit_c(c)
            lex_i = lex_i + 1
    lex_i = lex_i + 1                 # skip closing quote
    emit_tgt = save
    sid: int32 = bld_end()
    push_tok_str(TK_STR, sid)


def lex_number():
    # ES2015+ numeric literals: hex (0x), binary (0b), octal (0o), decimal with
    # fraction/exponent, and ES2021 numeric separators `_` between digits (e.g.
    # 1_000_000, 0xFF_FF, 1_000.5). Separators are scanned here and stripped in
    # parse_num_bytes. A trailing BigInt `n` suffix is consumed and ignored (the
    # value is kept as a float64 Number — good enough to keep scripts running).
    start: int32 = lex_i
    c1: uint8 = lch(1)
    if lex_p[lex_i] == 48 and (c1 == 120 or c1 == 88):          # 0x hex
        lex_i = lex_i + 2
        while lex_i < lex_n and (is_hexdig(lex_p[lex_i]) != 0 or lex_p[lex_i] == 95):
            lex_i = lex_i + 1
    elif lex_p[lex_i] == 48 and (c1 == 98 or c1 == 66):         # 0b binary
        lex_i = lex_i + 2
        while lex_i < lex_n and ((lex_p[lex_i] >= 48 and lex_p[lex_i] <= 49) or lex_p[lex_i] == 95):
            lex_i = lex_i + 1
    elif lex_p[lex_i] == 48 and (c1 == 111 or c1 == 79):        # 0o octal
        lex_i = lex_i + 2
        while lex_i < lex_n and ((lex_p[lex_i] >= 48 and lex_p[lex_i] <= 55) or lex_p[lex_i] == 95):
            lex_i = lex_i + 1
    else:
        while lex_i < lex_n and (is_digit(lex_p[lex_i]) != 0 or lex_p[lex_i] == 95):
            lex_i = lex_i + 1
        if lex_i < lex_n and lex_p[lex_i] == 46:
            lex_i = lex_i + 1
            while lex_i < lex_n and (is_digit(lex_p[lex_i]) != 0 or lex_p[lex_i] == 95):
                lex_i = lex_i + 1
        if lex_i < lex_n and (lex_p[lex_i] == 101 or lex_p[lex_i] == 69):
            lex_i = lex_i + 1
            if lex_i < lex_n and (lex_p[lex_i] == 43 or lex_p[lex_i] == 45):
                lex_i = lex_i + 1
            while lex_i < lex_n and (is_digit(lex_p[lex_i]) != 0 or lex_p[lex_i] == 95):
                lex_i = lex_i + 1
    x: float64 = parse_num_bytes(&lex_p[start], lex_i - start)
    if lex_i < lex_n and lex_p[lex_i] == 110:                   # BigInt `n` suffix
        lex_i = lex_i + 1
    push_tok_num(x)


def lex_ident():
    start: int32 = lex_i
    while lex_i < lex_n and is_idpart(lex_p[lex_i]) != 0:
        lex_i = lex_i + 1
    sid: int32 = str_new(&lex_p[start], lex_i - start)
    k: int32 = kw_kind(sid)
    # keywords carry their source text too, so they can be used as property
    # names after `.` (e.g. `.catch`, `.finally`, `.in`) — valid JS.
    push_tok_str(k, sid)


# ---- template literals ----
# A template `a${x}b` is lexed into an ordinary parenthesised concat expression:
#   ( "a" + ( x ) + "b" )
# The leading string chunk makes the whole `+` chain coerce to a string, so no
# new parser node is needed. Nested templates / interpolations use tmpl_bdepth.
def lex_tmpl_chunk() -> int32:
    # Cook a template chunk into the string pool; stop at ` or ${ or EOF,
    # leaving lex_i AT the terminator (not consumed).
    bld_begin()
    save: int32 = emit_tgt
    emit_tgt = 0
    while lex_i < lex_n:
        c: uint8 = lex_p[lex_i]
        if c == 96:                       # backtick -> end of template
            break
        if c == 36 and lch(1) == 123:     # ${ -> interpolation
            break
        if c == 92:                       # backslash escape
            lex_i = lex_i + 1
            e: uint8 = lch(0)
            if e == 110:                  # \n
                emit_c(10)
            elif e == 116:                # \t
                emit_c(9)
            elif e == 114:                # \r
                emit_c(13)
            elif e == 98:                 # \b -> backspace
                emit_c(8)
            elif e == 102:                # \f -> form feed
                emit_c(12)
            elif e == 118:                # \v -> vertical tab
                emit_c(11)
            elif e == 92:                 # \\
                emit_c(92)
            elif e == 96:                 # \`
                emit_c(96)
            elif e == 36:                 # \$
                emit_c(36)
            elif e == 39:                 # \'
                emit_c(39)
            elif e == 34:                 # \"
                emit_c(34)
            elif e == 48:                 # \0 -> NUL
                emit_c(0)
            elif e == 120:                # \xHH
                lex_emit_hexesc(2)
            elif e == 117:                # \uHHHH
                lex_emit_hexesc(4)
            elif e == 10:                 # line continuation \<LF> -> nothing
                pass
            elif e == 13:                 # line continuation \<CR>[<LF>]
                if lch(1) == 10:
                    lex_i = lex_i + 1
            else:                         # unknown escape -> literal char
                emit_c(e)
            lex_i = lex_i + 1
        else:
            emit_c(c)
            lex_i = lex_i + 1
    emit_tgt = save
    return bld_end()


def lex_tmpl_continue(is_open: int32):
    # Emit ONE template-chunk token (cooked + raw). is_open=1 just past the
    # opening backtick (this chunk is the HEAD or a whole FULL template); 0 when
    # resuming just past a substitution's closing '}' (a MID or TAIL chunk).
    # The parser (parse_primary / parse_call_member) reassembles the parts into
    # an ND_TMPL node, so tagged templates receive (strings, ...values) intact.
    rawstart: int32 = lex_i
    cooked: int32 = lex_tmpl_chunk()      # cooks escapes; leaves lex_i AT terminator
    raw: int32 = str_new(&lex_p[rawstart], lex_i - rawstart)   # verbatim source slice
    c: uint8 = lch(0)
    if c == 96:                           # backtick -> end of template
        lex_i = lex_i + 1
        if is_open != 0:
            push_tok_tmpl(TK_TMPL_FULL, cooked, raw)
        else:
            push_tok_tmpl(TK_TMPL_TAIL, cooked, raw)
    elif c == 36 and lch(1) == 123:       # ${  -> begin an interpolation
        lex_i = lex_i + 2
        if is_open != 0:
            push_tok_tmpl(TK_TMPL_HEAD, cooked, raw)
        else:
            push_tok_tmpl(TK_TMPL_MID, cooked, raw)
        tmpl_bdepth[tmpl_sp] = 0
        tmpl_sp = tmpl_sp + 1
    else:                                 # unterminated: close defensively
        if is_open != 0:
            push_tok_tmpl(TK_TMPL_FULL, cooked, raw)
        else:
            push_tok_tmpl(TK_TMPL_TAIL, cooked, raw)


def tokenize(p: Ptr[uint8], n: int32):
    lex_p = p
    lex_n = n
    lex_i = 0
    n_toks = 0
    tmpl_sp = 0
    # Cap the token stream so a pathological / machine-generated script (real
    # sites ship megabytes of minified JS and eval() giant generated strings)
    # can never overrun the fixed token arrays and segfault the browser. Leave
    # headroom for the trailing TK_EOF + any multi-token lexeme in flight.
    while lex_i < lex_n and n_toks < MAX_TOK - 8:
        c: uint8 = lex_p[lex_i]
        if is_ws(c) != 0:
            lex_i = lex_i + 1
            continue
        # comments
        if c == 47 and lch(1) == 47:              # //
            while lex_i < lex_n and lex_p[lex_i] != 10:
                lex_i = lex_i + 1
            continue
        if c == 47 and lch(1) == 42:              # /* */
            lex_i = lex_i + 2
            while lex_i < lex_n and not (lex_p[lex_i] == 42 and lch(1) == 47):
                lex_i = lex_i + 1
            lex_i = lex_i + 2
            continue
        # regex literal: `/` in expression-start position
        if c == 47 and prev_is_value() == 0:
            lex_regex()
            continue
        if c == 34 or c == 39:                    # " '
            lex_string(c)
            continue
        if c == 96:                               # ` template literal
            lex_i = lex_i + 1
            lex_tmpl_continue(1)
            continue
        if is_digit(c) != 0:
            lex_number()
            continue
        if c == 46 and is_digit(lch(1)) != 0:     # .5
            lex_number()
            continue
        if is_idstart(c) != 0:
            lex_ident()
            continue
        # operators / punctuation (longest match first)
        c1: uint8 = lch(1)
        c2: uint8 = lch(2)
        c3: uint8 = lch(3)
        okind: int32 = -1
        olen: int32 = 1
        if c == 62 and c1 == 62 and c2 == 62 and c3 == 61:
            okind = TK_USHREQ           # >>>=
            olen = 4
        elif c == 63 and c1 == 63 and c2 == 61:
            okind = TK_QQEQ             # ??=
            olen = 3
        elif c == 124 and c1 == 124 and c2 == 61:
            okind = TK_OROREQ           # ||=
            olen = 3
        elif c == 38 and c1 == 38 and c2 == 61:
            okind = TK_ANDANDEQ         # &&=
            olen = 3
        elif c == 42 and c1 == 42 and c2 == 61:
            okind = TK_STARSTAREQ       # **=
            olen = 3
        elif c == 46 and c1 == 46 and c2 == 46:
            okind = TK_ELLIPSIS
            olen = 3
        elif c == 61 and c1 == 61 and c2 == 61:
            okind = TK_SEQ
            olen = 3
        elif c == 33 and c1 == 61 and c2 == 61:
            okind = TK_SNE
            olen = 3
        elif c == 60 and c1 == 60 and c2 == 61:
            okind = TK_SHLEQ            # <<=
            olen = 3
        elif c == 62 and c1 == 62 and c2 == 61:
            okind = TK_SHREQ            # >>=
            olen = 3
        elif c == 62 and c1 == 62 and c2 == 62:
            okind = TK_USHR
            olen = 3
        elif c == 61 and c1 == 61:
            okind = TK_EQ
            olen = 2
        elif c == 33 and c1 == 61:
            okind = TK_NE
            olen = 2
        elif c == 60 and c1 == 61:
            okind = TK_LE
            olen = 2
        elif c == 62 and c1 == 61:
            okind = TK_GE
            olen = 2
        elif c == 60 and c1 == 60:
            okind = TK_SHL
            olen = 2
        elif c == 62 and c1 == 62:
            okind = TK_SHR
            olen = 2
        elif c == 38 and c1 == 38:
            okind = TK_ANDAND
            olen = 2
        elif c == 124 and c1 == 124:
            okind = TK_OROR
            olen = 2
        elif c == 42 and c1 == 42:
            okind = TK_STARSTAR         # **
            olen = 2
        elif c == 63 and c1 == 63:
            okind = TK_QQ               # ??
            olen = 2
        elif c == 63 and c1 == 46 and is_digit(c2) == 0:
            okind = TK_QDOT             # ?.  (not ?.digit which is ternary)
            olen = 2
        elif c == 43 and c1 == 43:
            okind = TK_INC
            olen = 2
        elif c == 45 and c1 == 45:
            okind = TK_DEC
            olen = 2
        elif c == 43 and c1 == 61:
            okind = TK_PLUSEQ
            olen = 2
        elif c == 45 and c1 == 61:
            okind = TK_MINUSEQ
            olen = 2
        elif c == 42 and c1 == 61:
            okind = TK_STAREQ
            olen = 2
        elif c == 47 and c1 == 61:
            okind = TK_SLASHEQ
            olen = 2
        elif c == 37 and c1 == 61:
            okind = TK_PERCENTEQ
            olen = 2
        elif c == 124 and c1 == 61:
            okind = TK_OREQ            # |=
            olen = 2
        elif c == 38 and c1 == 61:
            okind = TK_ANDEQ           # &=
            olen = 2
        elif c == 94 and c1 == 61:
            okind = TK_XOREQ           # ^=
            olen = 2
        elif c == 61 and c1 == 62:
            okind = TK_ARROW
            olen = 2
        elif c == 40:
            okind = TK_LPAREN
        elif c == 41:
            okind = TK_RPAREN
        elif c == 123:
            okind = TK_LBRACE
        elif c == 125:
            okind = TK_RBRACE
        elif c == 91:
            okind = TK_LBRACK
        elif c == 93:
            okind = TK_RBRACK
        elif c == 59:
            okind = TK_SEMI
        elif c == 44:
            okind = TK_COMMA
        elif c == 46:
            okind = TK_DOT
        elif c == 58:
            okind = TK_COLON
        elif c == 63:
            okind = TK_QUESTION
        elif c == 61:
            okind = TK_ASSIGN
        elif c == 43:
            okind = TK_PLUS
        elif c == 45:
            okind = TK_MINUS
        elif c == 42:
            okind = TK_STAR
        elif c == 47:
            okind = TK_SLASH
        elif c == 37:
            okind = TK_PERCENT
        elif c == 60:
            okind = TK_LT
        elif c == 62:
            okind = TK_GT
        elif c == 33:
            okind = TK_NOT
        elif c == 38:
            okind = TK_BAND
        elif c == 124:
            okind = TK_BOR
        elif c == 94:
            okind = TK_BXOR
        elif c == 126:
            okind = TK_BNOT
        if okind < 0:
            lex_i = lex_i + 1
            continue
        # template interpolation: a '}' at brace-depth 0 closes `${ ... }` and
        # resumes the template chunk (emits a MID or TAIL token, no wrapper).
        if okind == TK_RBRACE and tmpl_sp > 0 and tmpl_bdepth[tmpl_sp - 1] == 0:
            lex_i = lex_i + 1
            tmpl_sp = tmpl_sp - 1
            lex_tmpl_continue(0)
            continue
        if tmpl_sp > 0:
            if okind == TK_LBRACE:
                tmpl_bdepth[tmpl_sp - 1] = tmpl_bdepth[tmpl_sp - 1] + 1
            elif okind == TK_RBRACE:
                tmpl_bdepth[tmpl_sp - 1] = tmpl_bdepth[tmpl_sp - 1] - 1
        push_tok(okind)
        lex_i = lex_i + olen
    push_tok(TK_EOF)



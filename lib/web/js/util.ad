# lib/web/js/util.ad — part of the modular web engine (extracted from jsengine.ad).
# low-level char classifiers + libm-free float helpers + PRNG.
#
# Behavior-preserving split: Adder is a single-compilation-unit language
# (merge_programs merges all imported files into one Program), so every
# public top-level name here resolves globally across the merged engine.


# ====================================================================
# Low-level char helpers.
# ====================================================================
def is_digit(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return 1
    return 0


def is_hexdig(c: uint8) -> int32:
    if is_digit(c) != 0:
        return 1
    if c >= 97 and c <= 102:
        return 1
    if c >= 65 and c <= 70:
        return 1
    return 0


def is_idstart(c: uint8) -> int32:
    if c >= 97 and c <= 122:
        return 1
    if c >= 65 and c <= 90:
        return 1
    if c == 95 or c == 36:            # _ or $
        return 1
    return 0


def is_idpart(c: uint8) -> int32:
    if is_idstart(c) != 0:
        return 1
    if is_digit(c) != 0:
        return 1
    return 0


def is_ws(c: uint8) -> int32:
    if c == 32 or c == 9 or c == 13 or c == 10:
        return 1
    return 0


# ====================================================================
# Float helpers (avoid libm).
# ====================================================================
def f_trunc(x: float64) -> float64:
    # truncate toward zero; exact for |x| < 9e18
    if x != x:
        return x
    if x < 0.0:
        i: int64 = cast[int64](0.0 - x)
        return 0.0 - cast[float64](i)
    i2: int64 = cast[int64](x)
    return cast[float64](i2)


def f_floor(x: float64) -> float64:
    t: float64 = f_trunc(x)
    if t > x:
        return t - 1.0
    return t


def f_ceil(x: float64) -> float64:
    t: float64 = f_trunc(x)
    if t < x:
        return t + 1.0
    return t


def f_abs(x: float64) -> float64:
    if x < 0.0:
        return 0.0 - x
    return x


def f_fmod(a: float64, b: float64) -> float64:
    if b == 0.0:
        return 0.0 / 0.0            # NaN
    q: float64 = f_trunc(a / b)
    return a - q * b


def f_sqrt(x: float64) -> float64:
    if x < 0.0:
        return 0.0 / 0.0
    if x == 0.0:
        return 0.0
    g: float64 = x
    if g < 1.0:
        g = 1.0
    i: int32 = 0
    while i < 60:
        g = 0.5 * (g + x / g)
        i = i + 1
    return g


def f_pow(base: float64, exp: float64) -> float64:
    # Integer exponent fast path (covers Math.pow / ** in the gate).
    e: float64 = f_trunc(exp)
    if e == exp:
        neg: int32 = 0
        n: int64 = cast[int64](e)
        if n < 0:
            neg = 1
            n = 0 - n
        r: float64 = 1.0
        b: float64 = base
        while n > 0:
            if n % 2 == 1:
                r = r * b
            b = b * b
            n = n / 2
        if neg != 0:
            return 1.0 / r
        return r
    # General real exponent: x^y = exp(y*ln(x)) for x>0. (f_ln/f_exp are defined
    # below in this module.) x<0 with a non-integer exponent is NaN in JS; x==0
    # is 0 for y>0 and Infinity for y<0.
    if base == 0.0:
        if exp > 0.0:
            return 0.0
        return 1.0e309
    if base > 0.0:
        return f_exp(exp * f_ln(base))
    # base < 0, non-integer exponent
    return 0.0 / 0.0


def is_nan(x: float64) -> int32:
    if x != x:
        return 1
    return 0


def is_inf(x: float64) -> int32:
    # NOTE: the negative large-magnitude float literal `-1.0e308` is miscompiled
    # by the Adder backend (it lands near a small negative), which made every
    # finite value below ~-9e15 read as -Infinity (isFinite, console.log, +/-).
    # Comparing the magnitude against the POSITIVE literal (which compiles
    # correctly) sidesteps the bug.
    if x > 1.0e308:
        return 1
    if 0.0 - x > 1.0e308:
        return 1
    return 0


# --- transcendental helpers (range-reduced series; extern-free) ---
# (module-level float globals aren't supported by the x86 backend, so the
# constants live inside the helpers below as literals.)
def f_ln2() -> float64:
    return 0.6931471805599453


def f_twopi() -> float64:
    return 6.283185307179586


def f_sign(x: float64) -> float64:
    if x != x:
        return x
    if x > 0.0:
        return 1.0
    if x < 0.0:
        return -1.0
    return x                       # +0 / -0 pass through


def f_cbrt(x: float64) -> float64:
    if x == 0.0:
        return x
    neg: int32 = 0
    a: float64 = x
    if a < 0.0:
        neg = 1
        a = 0.0 - a
    g: float64 = a
    if g < 1.0:
        g = 1.0
    i: int32 = 0
    while i < 80:
        g = (2.0 * g + a / (g * g)) / 3.0
        i = i + 1
    if neg != 0:
        return 0.0 - g
    return g


def f_hypot(a: float64, b: float64) -> float64:
    return f_sqrt(a * a + b * b)


def f_pi() -> float64:
    return 3.141592653589793


# atan via argument-halving (atan(x)=2*atan(x/(1+sqrt(1+x^2)))) down to a small
# residual, then a Maclaurin series. Extern-free; converges fast for all x.
def f_atan(x: float64) -> float64:
    if x != x:
        return x
    neg: int32 = 0
    a: float64 = x
    if a < 0.0:
        neg = 1
        a = 0.0 - a
    if is_inf(x) != 0:
        if neg != 0:
            return 0.0 - f_pi() / 2.0
        return f_pi() / 2.0
    k: int32 = 0
    while a > 0.2 and k < 60:
        a = a / (1.0 + f_sqrt(1.0 + a * a))
        k = k + 1
    a2: float64 = a * a
    term: float64 = a
    sum: float64 = a
    n: int32 = 1
    while n < 30:
        term = 0.0 - term * a2
        sum = sum + term / cast[float64](2 * n + 1)
        n = n + 1
    r: float64 = sum * f_pow(2.0, cast[float64](k))
    if neg != 0:
        return 0.0 - r
    return r


def f_asin(x: float64) -> float64:
    if x != x:
        return x
    if x >= 1.0:
        return f_pi() / 2.0
    if x <= -1.0:
        return 0.0 - f_pi() / 2.0
    return f_atan(x / f_sqrt(1.0 - x * x))


def f_acos(x: float64) -> float64:
    return f_pi() / 2.0 - f_asin(x)


def f_atan2(y: float64, x: float64) -> float64:
    if x > 0.0:
        return f_atan(y / x)
    if x < 0.0:
        if y >= 0.0:
            return f_atan(y / x) + f_pi()
        return f_atan(y / x) - f_pi()
    # x == 0
    if y > 0.0:
        return f_pi() / 2.0
    if y < 0.0:
        return 0.0 - f_pi() / 2.0
    return 0.0


def f_ln(x: float64) -> float64:
    if x != x or x < 0.0:
        return 0.0 / 0.0
    if x == 0.0:
        return -1.0e309            # -Infinity
    if is_inf(x) != 0:
        return x
    k: int32 = 0
    m: float64 = x
    while m >= 2.0:
        m = m / 2.0
        k = k + 1
    while m < 1.0:
        m = m * 2.0
        k = k - 1
    # m in [1,2): ln(m) = 2*(t + t^3/3 + t^5/5 + ...), t=(m-1)/(m+1)
    t: float64 = (m - 1.0) / (m + 1.0)
    t2: float64 = t * t
    term: float64 = t
    sum: float64 = 0.0
    n: int32 = 1
    while n < 60:
        sum = sum + term / cast[float64](n)
        term = term * t2
        n = n + 2
    return 2.0 * sum + cast[float64](k) * f_ln2()


def f_exp(x: float64) -> float64:
    if x != x:
        return x
    if x > 709.0:
        return 1.0e309            # Infinity
    if x < -745.0:
        return 0.0
    # range-reduce: x = k*ln2 + r, r in [-ln2/2, ln2/2]
    k: int32 = cast[int32](f_floor(x / f_ln2() + 0.5))
    r: float64 = x - cast[float64](k) * f_ln2()
    term: float64 = 1.0
    sum: float64 = 1.0
    n: int32 = 1
    while n < 25:
        term = term * r / cast[float64](n)
        sum = sum + term
        n = n + 1
    return sum * f_pow(2.0, cast[float64](k))


def f_sin(x: float64) -> float64:
    if x != x or is_inf(x) != 0:
        return 0.0 / 0.0
    # reduce mod 2pi
    n: float64 = f_floor(x / f_twopi() + 0.5)
    r: float64 = x - n * f_twopi()
    term: float64 = r
    sum: float64 = r
    r2: float64 = r * r
    i: int32 = 1
    while i < 20:
        term = 0.0 - term * r2 / cast[float64]((2 * i) * (2 * i + 1))
        sum = sum + term
        i = i + 1
    return sum


def f_cos(x: float64) -> float64:
    if x != x or is_inf(x) != 0:
        return 0.0 / 0.0
    n: float64 = f_floor(x / f_twopi() + 0.5)
    r: float64 = x - n * f_twopi()
    term: float64 = 1.0
    sum: float64 = 1.0
    r2: float64 = r * r
    i: int32 = 1
    while i < 20:
        term = 0.0 - term * r2 / cast[float64]((2 * i - 1) * (2 * i))
        sum = sum + term
        i = i + 1
    return sum


# deterministic LCG-backed Math.random (no true entropy source in the engine).
rng_state: uint64 = 88172645463325252


def f_random() -> float64:
    rng_state = rng_state * 6364136223846793005 + 1442695040888963407
    # take the top 53 bits for a [0,1) double
    top: uint64 = rng_state >> 11
    return cast[float64](top) / 9007199254740992.0


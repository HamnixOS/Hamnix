# lib/web/js/state.ad — part of the modular web engine (extracted from jsengine.ad).
# POOLS: all engine BSS pools (value/string/object/env/token/AST/regex), bump-allocated. The state-owner module every consumer imports.
#
# Behavior-preserving split: Adder is a single-compilation-unit language
# (merge_programs merges all imported files into one Program), so every
# public top-level name here resolves globally across the merged engine.

# ====================================================================
# POOLS (all BSS; bump-allocated).
# ====================================================================
MAX_VAL:  int32 = 1000000
v_tag: Array[1000000, uint8]
v_num: Array[1000000, float64]
v_ref: Array[1000000, int32]
n_vals: int32 = 4                 # 0..3 reserved for the singletons

MAX_STR: int32 = 60000
SP_CAP:  int32 = 1048576
sp_buf: Array[1048576, uint8]
sp_top: int32 = 0
st_off: Array[60000, int32]
st_len: Array[60000, int32]
n_strs: int32 = 0

MAX_NODE: int32 = 30000
n_kind: Array[30000, uint8]
n_a:    Array[30000, int32]
n_b:    Array[30000, int32]
n_c:    Array[30000, int32]
n_d:    Array[30000, int32]
n_next: Array[30000, int32]
n_str:  Array[30000, int32]
n_op:   Array[30000, int32]
n_num:  Array[30000, float64]
n_nodes: int32 = 0

MAX_TOK: int32 = 30000
tk_kind: Array[30000, uint8]
tk_num:  Array[30000, float64]
tk_str:  Array[30000, int32]
tk_str2: Array[30000, int32]       # secondary string id (regex flags)
n_toks:  int32 = 0
tk_pos:  int32 = 0

# ---- REGEX pools (all BSS; compiled programs persist for the run) ----
MAX_REPROG: int32 = 40000
re_op: Array[40000, int32]
re_x:  Array[40000, int32]
re_y:  Array[40000, int32]
re_n:  int32 = 0                   # next free program slot

MAX_RENODE: int32 = 20000          # regex AST scratch (reset per compile)
rn_op:   Array[20000, int32]
rn_a:    Array[20000, int32]
rn_b:    Array[20000, int32]
rn_c:    Array[20000, int32]
rn_d:    Array[20000, int32]
rn_next: Array[20000, int32]
rn_n: int32 = 0

MAX_RECLS: int32 = 4096            # char classes; 32-byte (256-bit) bitmap each
cls_bits: Array[131072, uint8]     # 4096 * 32
cls_neg:  Array[4096, uint8]
n_cls: int32 = 0

RE_CAP_MAX: int32 = 128            # 64 groups * 2 slots
re_cap: Array[128, int32]

# ---- named capture groups `(?<name>...)` (persist for the run) ----
# One row per named group across ALL compiled regexes (bump-allocated); each
# regex object records its [start,count) slice so exec() can build `.groups`.
RE_GNAME_CAP: int32 = 512
gname_idx:  Array[512, int32]      # capture index of this named group
gname_soff: Array[512, int32]      # name bytes: offset into gname_buf
gname_slen: Array[512, int32]      # name length
gname_n:    int32 = 0
gname_buf:  Array[8192, uint8]
gname_buf_n: int32 = 0
gname_compile_start: int32 = 0     # gname_n at the start of the current compile
lb_target:  int32 = 0              # lookbehind: subject pos the child must end at

# replace() is two-phase: resolve every replacement string id FIRST (a user
# replacer function does its own string-building, which cannot run while our
# result builder holds the shared build cursor), then assemble in one pass.
MAX_REP: int32 = 16384
rep_start: Array[16384, int32]
rep_end:   Array[16384, int32]
rep_id:    Array[16384, int32]

# regex compile/match transient state
rc_off: int32 = 0                  # source byte offset (into sp_buf)
rc_len: int32 = 0                  # source length
rc_i:   int32 = 0                  # source cursor
re_gcount: int32 = 0               # capture groups seen during compile
re_ic:  int32 = 0                  # ignore-case (compile + match)
re_ml:  int32 = 0                  # multiline
rx_off: int32 = 0                  # subject byte offset (into sp_buf)
rx_len: int32 = 0                  # subject length
rx_matchend: int32 = 0             # end position set by a successful match

MAX_OBJ: int32 = 40000
obj_kind: Array[40000, uint8]
obj_head: Array[40000, int32]     # prop chain head (-1)
obj_fn_node:   Array[40000, int32]
obj_fn_env:    Array[40000, int32]
obj_fn_native: Array[40000, int32]
arr_len:  Array[40000, int32]
arr_cap:  Array[40000, int32]
arr_base: Array[40000, int32]     # offset into ax_val
obj_proto:    Array[40000, int32] # [[Prototype]] chain: another object id, or -1
obj_fn_this:  Array[40000, int32] # arrow: captured lexical `this` handle; -2 = not-arrow
obj_fn_home:  Array[40000, int32] # method/ctor: home prototype object id (for `super`); -1 none
obj_fn_super: Array[40000, int32] # class constructor: superclass function VALUE handle; -1 none
obj_fn_btarget: Array[40000, int32] # bound function (.bind): target function VALUE handle; -1 = not bound
obj_fn_bthis:  Array[40000, int32] # bound function: the bound `this` VALUE handle
obj_fn_bargs:  Array[40000, int32] # bound function: JS array handle of pre-applied args, or -1
obj_class:    Array[40000, uint8] # bit0 = class constructor, bit1 = default (implicit) constructor
obj_class_node: Array[40000, int32] # class constructor: ND_CLASS node id (for instance-field init), else -1
obj_re_prog:  Array[40000, int32] # regex object: start pc of compiled program, else -1
obj_re_ncap:  Array[40000, int32] # regex object: number of capture groups
obj_re_flags: Array[40000, int32] # regex object: bit0=g, bit1=i, bit2=m
obj_re_gnstart: Array[40000, int32] # regex object: first named-group row (gname_*)
obj_re_gncount: Array[40000, int32] # regex object: number of named groups
obj_is_date:  Array[40000, uint8] # 1 if this object is a Date instance
obj_date_ms:  Array[40000, float64] # Date instance: epoch-ms as float64 (exact for integer ms)
# ---- Map / Set state (indexed by object id; obj_map_kind gates the rest) ----
obj_frozen:   Array[40000, uint8]  # 1 if Object.freeze'd (writes/adds are dropped)
obj_map_kind: Array[40000, uint8]  # 0 none, 1 Map, 2 Set
obj_ms_head:  Array[40000, int32]  # first entry index in the mse_* pool (-1)
obj_ms_tail:  Array[40000, int32]  # last entry index (O(1) append), -1
obj_ms_size:  Array[40000, int32]  # live (non-deleted) entry count
# ---- Promise state (indexed by object id; obj_is_prom gates the rest) ----
obj_is_prom:  Array[40000, uint8] # 1 if this object is a Promise instance
prom_state:   Array[40000, uint8] # 0 pending, 1 fulfilled, 2 rejected
prom_result:  Array[40000, int32] # settled value (fulfilled) / reason (rejected)
prom_react:   Array[40000, int32] # head of the pending-reaction list (-1 = none)
prom_alreadyres: Array[40000, uint8] # resolution-procedure guard (settle-once)
# generic per-native-function-object payload: for a resolve/reject closure it is
# the target promise obj id; for a combinator hook it is (comb cell id, index);
# for a finally wrapper it is the user callback value handle.
obj_p_a:      Array[40000, int32]
obj_p_b:      Array[40000, int32]
n_objs: int32 = 0

# ---- Promise reaction records (a pending .then registration) ----
PROM_REACT_CAP: int32 = 16384
pr_onful:  Array[16384, int32]    # onFulfilled handler value (-1 = pass through)
pr_onrej:  Array[16384, int32]    # onRejected handler value (-1 = pass through)
pr_result: Array[16384, int32]    # dependent (result) promise VALUE handle
pr_source: Array[16384, int32]    # source promise obj id (read for state+value)
pr_next:   Array[16384, int32]    # next reaction in the source's pending list
pr_n: int32 = 0

# ---- Promise combinator cells (Promise.all / race / allSettled shared state) ----
COMB_CAP: int32 = 4096
comb_result:    Array[4096, int32]   # result promise VALUE handle
comb_remaining: Array[4096, int32]   # count still to settle (all / allSettled)
comb_results:   Array[4096, int32]   # results ARRAY value (all / allSettled)
comb_kind:      Array[4096, uint8]   # 0 = all, 1 = race, 2 = allSettled
comb_n: int32 = 0

# ---- resolver "alreadyCalled" cells shared by a resolve/reject closure pair ----
RES_FLAG_CAP: int32 = 16384
res_flag: Array[16384, uint8]
res_flag_n: int32 = 0

# ---- fetch() fixture table (deterministic data source; no network) ----
# Each __setFetchFixture(url, {...}) registration is one row keyed by the url
# STRING id. fetch(url) scans for a matching url and settles a Response from the
# row; an unmatched url REJECTS (so .catch fires). A row with status 0 models a
# network error (reject). This is the sole data source on BOTH targets — the
# engine is extern-free by mandate, so on-device http lives in a front-end.
FETCH_FIXTURE_CAP: int32 = 512
fx_url:    Array[512, int32]   # url string id (key)
fx_status: Array[512, int32]   # HTTP status number (0 = network error -> reject)
fx_stext:  Array[512, int32]   # statusText string id
fx_body:   Array[512, int32]   # response body string id
fx_ctype:  Array[512, int32]   # content-type header string id
fx_n: int32 = 0

# ---- Map/Set entry pool (append-only; insertion order preserved; delete marks
# an entry unused so iteration order is stable and `.size` stays exact). ----
MS_CAP: int32 = 131072
mse_key:  Array[131072, int32]    # entry key value handle
mse_val:  Array[131072, int32]    # entry value handle (Set: same as key)
mse_used: Array[131072, uint8]    # 1 = live, 0 = deleted
mse_next: Array[131072, int32]    # next entry index in insertion order (-1)
mse_n: int32 = 0

MAP_KIND_NONE: int32 = 0
MAP_KIND_MAP:  int32 = 1
MAP_KIND_SET:  int32 = 2

MAX_PROP: int32 = 150000
p_next: Array[150000, int32]
p_key:  Array[150000, int32]      # string id
p_val:  Array[150000, int32]
p_acc:  Array[150000, uint8]      # 1 = accessor property (p_get/p_set), 0 = data (p_val)
p_get:  Array[150000, int32]      # accessor getter function VALUE handle, or -1
p_set:  Array[150000, int32]      # accessor setter function VALUE handle, or -1
n_props: int32 = 0

MAX_ENV: int32 = 80000
env_parent:  Array[80000, int32]
env_head:    Array[80000, int32]
env_is_func: Array[80000, uint8]
n_envs: int32 = 0

MAX_BIND: int32 = 250000
b_next:  Array[250000, int32]
b_name:  Array[250000, int32]
b_val:   Array[250000, int32]
b_const: Array[250000, uint8]
n_binds: int32 = 0

MAX_AX: int32 = 1000000
ax_val: Array[1000000, int32]      # array element storage (bump; grows on top in place)
ax_top: int32 = 0

OUT_CAP: int32 = 262144
out_buf: Array[262144, uint8]
out_top: int32 = 0

MAX_CALLARG: int32 = 8192
call_args: Array[8192, int32]
call_top: int32 = 0

MAX_THIS: int32 = 20000
this_stack: Array[20000, int32]
home_stack: Array[20000, int32]   # home prototype (for `super`) per active frame
curfn_stack: Array[20000, int32]  # object id of the function currently executing
this_top: int32 = 0

# thrown value (CTL_THROW). throw_val holds the exception handle.
throw_val: int32 = 0

# ---- async/await parse state ----
# in_async is nonzero while parsing an async function body, so `await` is only
# treated as a keyword there (elsewhere `await` stays a plain identifier).
# pending_async is set by a caller immediately before a function/arrow parse to
# tell the parse routine that the function it is about to build is `async`.
in_async: int32 = 0
pending_async: int32 = 0

# template-literal lexer state (nested interpolations)
MAX_TMPL: int32 = 64
tmpl_bdepth: Array[64, int32]     # object-brace depth inside the top interpolation
tmpl_sp: int32 = 0

SRC_CAP: int32 = 262144

# global roots / state
g_env:    int32 = 0               # global environment id
g_global_obj: int32 = 0           # the global object (host bindings)
g_math:   int32 = 0
g_json:   int32 = 0
g_object: int32 = 0
g_console: int32 = 0
g_array:  int32 = 0
g_number: int32 = 0
g_promise: int32 = 0               # the Promise constructor value
g_promise_proto: int32 = 0         # Promise.prototype (holds then/catch/finally)
g_promise_job: int32 = 0           # shared native fn value for a reaction microtask
native_self: int32 = -1            # obj id of the native fn currently being invoked

ctl:      int32 = 0               # CTL_*
ctl_val:  int32 = 0               # return value handle
ctl_label: int32 = -1             # target label sid for CTL_BREAK/CTL_CONTINUE (-1 = none)
pending_label: int32 = -1         # label sid to hand to the next loop it wraps (-1 = none)
no_in: int32 = 0                   # parser: suppress `in` as a binop (for-header init)
oc_short: int32 = 0                 # eval: optional-chain `?.` short-circuit latch (nullish base seen)
st_buf_z: Array[96, uint8]


# Build "<name><suffix>" into st_buf_z and return it, so errors can name the
# offending identifier ("google is not defined", "x.call is not a function")
# the way a real engine does. `name_sid` may be -1 (name omitted).
def named_error_msg(prefix: Ptr[uint8], name_sid: int32, suffix: Ptr[uint8]) -> Ptr[uint8]:
    i: int32 = 0
    p: int32 = 0
    while prefix[p] != 0 and i < 40:
        st_buf_z[i] = prefix[p]
        i = i + 1
        p = p + 1
    if name_sid >= 0:
        n: int32 = st_len[name_sid]
        o: int32 = st_off[name_sid]
        j: int32 = 0
        while j < n and i < 78:
            st_buf_z[i] = sp_buf[o + j]
            i = i + 1
            j = j + 1
    k: int32 = 0
    while suffix[k] != 0 and i < 94:
        st_buf_z[i] = suffix[k]
        i = i + 1
        k = k + 1
    st_buf_z[i] = 0
    return &st_buf_z[0]

err_flag: int32 = 0
err_str:  Array[256, uint8]

# Host dispatch is stored as a raw address (cast to Fn at call time). A Fn-typed
# GLOBAL initialized to a function name would emit a 64-bit relocation the
# native elf32-i386 wrapper cannot represent; a runtime uint64 avoids that.
host_dispatch_addr: uint64 = 0
host_dispatch_set: int32 = 0

# ---- member-set notification seam ----
# An embedder may register a hook that fires AFTER every `obj.prop = val` on a
# plain object (not arrays/globals). The browser uses it so assigning
# `el.innerHTML = "…"` parses the fragment into real child nodes eagerly, so a
# SUBSEQUENT `el.childNodes[…]` read in the same script sees the new subtree
# (jsengine has no accessor properties). The hook reads the receiver/key/value
# through js_mset_this()/js_mset_key()/js_mset_val(); its int32 return is
# ignored. Default OFF — pure JS scripts never touch it.
member_set_hook_addr: uint64 = 0
member_set_hook_set: int32 = 0
mset_this_v: int32 = 0
mset_key_v: int32 = 0
mset_val_v: int32 = 0
mset_in_hook: int32 = 0

# ---- deferred-callback task queue (setTimeout/setInterval/queueMicrotask) ----
# The interpreter is a synchronous tree-walk; there is NO wall-clock async
# runtime. Timers are modelled as a bounded QUEUE of pending callbacks that the
# engine DRAINS after the top-level script (and after each embedder event
# dispatch). Each registration is one slot: a callback fn value-handle, its
# captured args, a requested delay (used only for ordering), an insertion
# sequence, and flags for interval / microtask / active. The drain pops due
# callbacks in (microtask-first, then delay, then insertion) order and invokes
# them, capping total invocations so a self-re-enqueuing setInterval cannot spin
# forever. This is enough for the deferred-init / "run after load" patterns real
# pages use — it is explicitly NOT wall-clock async.
TIMER_CAP: int32 = 4096            # max distinct registrations per js_init
TIMER_MAX_ARGS: int32 = 4          # captured extra args per timer
TIMER_DRAIN_CAP: int32 = 10000     # max total callback invocations per drain
timer_fn:       Array[4096, int32]     # callback fn value-handle
timer_delay:    Array[4096, float64]   # requested delay (ordering only)
timer_seq:      Array[4096, int32]     # insertion order key (re-bumped on re-arm)
timer_argc:     Array[4096, int32]     # captured arg count
timer_args:     Array[16384, int32]    # TIMER_CAP * TIMER_MAX_ARGS flat pool
timer_active:   Array[4096, uint8]     # 1 = pending, 0 = fired/cancelled
timer_interval: Array[4096, uint8]     # 1 = re-arms after firing
timer_micro:    Array[4096, uint8]     # 1 = microtask (runs before macrotasks)
timer_next:     int32 = 0              # next free registration slot
timer_seq_ctr:  int32 = 0             # monotonic insertion counter

# Scratch buffers for js_str_ptr / js_to_display (each a NUL-terminated C
# string). A RING of buffers, not one shared buffer: an embedder routinely reads
# two (or more) JS strings back-to-back — e.g. `ktp = js_str_ptr(kt); knp =
# js_str_ptr(kn)` — and with a single buffer the second call clobbered the first,
# corrupting the earlier pointer. The ring keeps the SCRATCH_RING most-recent
# results simultaneously valid so those adjacent reads no longer alias.
SCRATCH_RING: int32 = 8
SCRATCH_SZ:   int32 = 65536
scratch: Array[524288, uint8]      # SCRATCH_RING * SCRATCH_SZ
scratch_slot: int32 = 0            # next ring slot to hand out

# emit target: 0 = string-pool build (bld_*), 1 = out_buf
emit_tgt: int32 = 1


# lib/web/html/entities.ad — part of the modular web engine (extracted from htmlengine.ad).
# HTML entity decoding — &name; / &#NN; / &#xHH; -> g_ent_char.
#
# Behavior-preserving split: Adder is single-compilation-unit (merge_programs
# merges all imports into one Program), so this is byte-identical. Private
# helpers crossing the new boundary are promoted via explicit imports.

# ====================================================================
# ENTITY DECODE — &name; / &#NN; / &#xHH;.  Returns bytes consumed from
# src starting at `&` (0 if not a recognised entity), and sets g_ent_char.
# ====================================================================
def _ent_named_is(start: uint64, lit: Ptr[uint8]) -> int32:
    # `lit` already includes the trailing ';' — a full match consumes it.
    i: uint64 = 0
    while lit[i] != 0:
        if start + i >= src_len:
            return 0
        if src_ptr[start + i] != lit[i]:
            return 0
        i = i + 1
    return cast[int32](i)


# Encode one Unicode code point into g_ent_buf as UTF-8; sets g_ent_len.
# (The renderer already emits UTF-8 text, so decoded entities go out as UTF-8.)
def _ent_emit_cp(cp: uint32):
    if cp == 0:
        cp = 63                                       # NUL -> '?'
    if cp < 0x80:
        g_ent_buf[0] = cast[uint8](cp)
        g_ent_len = 1
    elif cp < 0x800:
        g_ent_buf[0] = cast[uint8](0xC0 | (cp >> 6))
        g_ent_buf[1] = cast[uint8](0x80 | (cp & 0x3F))
        g_ent_len = 2
    elif cp < 0x10000:
        g_ent_buf[0] = cast[uint8](0xE0 | (cp >> 12))
        g_ent_buf[1] = cast[uint8](0x80 | ((cp >> 6) & 0x3F))
        g_ent_buf[2] = cast[uint8](0x80 | (cp & 0x3F))
        g_ent_len = 3
    else:
        g_ent_buf[0] = cast[uint8](0xF0 | (cp >> 18))
        g_ent_buf[1] = cast[uint8](0x80 | ((cp >> 12) & 0x3F))
        g_ent_buf[2] = cast[uint8](0x80 | ((cp >> 6) & 0x3F))
        g_ent_buf[3] = cast[uint8](0x80 | (cp & 0x3F))
        g_ent_len = 4


# If src at `body` matches the named-entity literal `lit` (trailing ';'
# included), emit code point `cp` and return the bytes consumed AFTER the '&'
# (i.e. len(lit)); otherwise return 0.
def _ent_try(body: uint64, lit: Ptr[uint8], cp: uint32) -> uint64:
    n: int32 = _ent_named_is(body, lit)
    if n > 0:
        _ent_emit_cp(cp)
        return cast[uint64](n)
    return 0


# Legacy semicolon-less named references (HTML "named character reference"
# state): a fixed historical set (&amp &lt &gt &copy &reg &nbsp …) is allowed
# WITHOUT a trailing ';'. `lit` here carries NO ';'. To avoid eating the '&' in
# query strings / identifiers (e.g. "?a=1&reg=2", "AT&Tea"), the match is
# suppressed when the character immediately after the name is alphanumeric or
# '=' — mirroring the spec's ambiguous-ampersand rule. On success emits `cp`
# and returns the bytes consumed AFTER the '&' (the name length, no ';').
def _ent_try_legacy(body: uint64, lit: Ptr[uint8], cp: uint32) -> uint64:
    n: int32 = _ent_named_is(body, lit)
    if n <= 0:
        return 0
    nx: uint64 = body + cast[uint64](n)
    if nx < src_len:
        c: uint8 = src_ptr[nx]
        if (c >= 48 and c <= 57) or (c >= 65 and c <= 90) \
           or (c >= 97 and c <= 122) or c == 61:         # 0-9 A-Z a-z '='
            return 0
    _ent_emit_cp(cp)
    return cast[uint64](n)


# Numeric character reference sanitisation (HTML "numeric character reference
# end" state): NUL / out-of-range (>0x10FFFF) / lone surrogates map to U+FFFD;
# the C1 range 0x80-0x9F is remapped through the Windows-1252 table (so the
# ubiquitous legacy &#151; renders as an em dash, &#133; as an ellipsis, etc).
def _ent_num_remap(val: uint32) -> uint32:
    if val == 0 or val > 0x10FFFF:
        return 0xFFFD
    if val >= 0xD800 and val <= 0xDFFF:                   # lone surrogate
        return 0xFFFD
    if val >= 0x80 and val <= 0x9F:
        if val == 0x80:
            return 0x20AC
        elif val == 0x82:
            return 0x201A
        elif val == 0x83:
            return 0x0192
        elif val == 0x84:
            return 0x201E
        elif val == 0x85:
            return 0x2026
        elif val == 0x86:
            return 0x2020
        elif val == 0x87:
            return 0x2021
        elif val == 0x88:
            return 0x02C6
        elif val == 0x89:
            return 0x2030
        elif val == 0x8A:
            return 0x0160
        elif val == 0x8B:
            return 0x2039
        elif val == 0x8C:
            return 0x0152
        elif val == 0x8E:
            return 0x017D
        elif val == 0x91:
            return 0x2018
        elif val == 0x92:
            return 0x2019
        elif val == 0x93:
            return 0x201C
        elif val == 0x94:
            return 0x201D
        elif val == 0x95:
            return 0x2022
        elif val == 0x96:
            return 0x2013
        elif val == 0x97:
            return 0x2014
        elif val == 0x98:
            return 0x02DC
        elif val == 0x99:
            return 0x2122
        elif val == 0x9A:
            return 0x0161
        elif val == 0x9B:
            return 0x203A
        elif val == 0x9C:
            return 0x0153
        elif val == 0x9E:
            return 0x017E
        elif val == 0x9F:
            return 0x0178
        return val                                        # 0x81/8D/8F/90/9D: as-is
    return val


def _entity(at: uint64) -> uint64:
    # `at` points at '&'. On success fills g_ent_buf/g_ent_len with the decoded
    # UTF-8 bytes and returns the number of source bytes consumed (including the
    # '&' and any trailing ';'). Returns 0 for a bare/unknown '&' — the caller
    # then passes the '&' through unchanged.
    body: uint64 = at + 1
    if body >= src_len:
        return 0
    if src_ptr[body] == 35:                          # '#': numeric
        p: uint64 = body + 1
        base: uint32 = 10
        if p < src_len and (src_ptr[p] == 120 or src_ptr[p] == 88):   # x/X
            base = 16
            p = p + 1
        val: uint32 = 0
        digits: int32 = 0
        while p < src_len and digits < 8:
            c: uint8 = src_ptr[p]
            d: int32 = -1
            if c >= 48 and c <= 57:
                d = cast[int32](c - 48)
            elif base == 16 and c >= 97 and c <= 102:
                d = cast[int32](c - 97) + 10
            elif base == 16 and c >= 65 and c <= 70:
                d = cast[int32](c - 65) + 10
            else:
                break
            val = val * base + cast[uint32](d)
            digits = digits + 1
            p = p + 1
        if digits == 0:
            return 0
        if p < src_len and src_ptr[p] == 59:
            p = p + 1
        _ent_emit_cp(_ent_num_remap(val))
        return p - at
    # Named entities. Each literal carries its trailing ';', so a match consumes
    # it; unknown names fall through and the '&' is emitted literally.
    r: uint64 = 0
    r = _ent_try(body, cast[Ptr[uint8]]("amp;"), 38)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("lt;"), 60)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("gt;"), 62)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("quot;"), 34)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("apos;"), 39)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("nbsp;"), 32)   # -> normal space
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("copy;"), 0xA9)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("reg;"), 0xAE)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("trade;"), 0x2122)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("mdash;"), 0x2014)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ndash;"), 0x2013)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("hellip;"), 0x2026)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("lsquo;"), 0x2018)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("rsquo;"), 0x2019)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ldquo;"), 0x201C)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("rdquo;"), 0x201D)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("middot;"), 0xB7)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("deg;"), 0xB0)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("times;"), 0xD7)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("divide;"), 0xF7)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("bull;"), 0x2022)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("dagger;"), 0x2020)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("laquo;"), 0xAB)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("raquo;"), 0xBB)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("euro;"), 0x20AC)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("pound;"), 0xA3)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("cent;"), 0xA2)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("yen;"), 0xA5)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("sect;"), 0xA7)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("para;"), 0xB6)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("plusmn;"), 0xB1)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("micro;"), 0xB5)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("frac12;"), 0xBD)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("frac14;"), 0xBC)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("frac34;"), 0xBE)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("sup2;"), 0xB2)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("sup3;"), 0xB3)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("szlig;"), 0xDF)
    # --- accented Latin-1 letters (À-ÿ). Case-sensitive names (Auml != auml);
    # _ent_named_is matches raw bytes so case is preserved. Ubiquitous in
    # names/loanwords (café, résumé, naïve, Señor, Zürich, Ångström). ---
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Agrave;"), 0xC0)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Aacute;"), 0xC1)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Acirc;"), 0xC2)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Atilde;"), 0xC3)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Auml;"), 0xC4)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Aring;"), 0xC5)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("AElig;"), 0xC6)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Ccedil;"), 0xC7)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Egrave;"), 0xC8)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Eacute;"), 0xC9)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Ecirc;"), 0xCA)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Euml;"), 0xCB)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Igrave;"), 0xCC)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Iacute;"), 0xCD)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Icirc;"), 0xCE)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Iuml;"), 0xCF)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ETH;"), 0xD0)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Ntilde;"), 0xD1)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Ograve;"), 0xD2)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Oacute;"), 0xD3)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Ocirc;"), 0xD4)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Otilde;"), 0xD5)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Ouml;"), 0xD6)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Oslash;"), 0xD8)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Ugrave;"), 0xD9)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Uacute;"), 0xDA)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Ucirc;"), 0xDB)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Uuml;"), 0xDC)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Yacute;"), 0xDD)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("THORN;"), 0xDE)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("agrave;"), 0xE0)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("aacute;"), 0xE1)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("acirc;"), 0xE2)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("atilde;"), 0xE3)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("auml;"), 0xE4)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("aring;"), 0xE5)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("aelig;"), 0xE6)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ccedil;"), 0xE7)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("egrave;"), 0xE8)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("eacute;"), 0xE9)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ecirc;"), 0xEA)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("euml;"), 0xEB)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("igrave;"), 0xEC)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("iacute;"), 0xED)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("icirc;"), 0xEE)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("iuml;"), 0xEF)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("eth;"), 0xF0)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ntilde;"), 0xF1)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ograve;"), 0xF2)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("oacute;"), 0xF3)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ocirc;"), 0xF4)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("otilde;"), 0xF5)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ouml;"), 0xF6)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("oslash;"), 0xF8)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ugrave;"), 0xF9)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("uacute;"), 0xFA)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ucirc;"), 0xFB)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("uuml;"), 0xFC)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("yacute;"), 0xFD)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("thorn;"), 0xFE)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("yuml;"), 0xFF)
    # --- extended punctuation / spaces / format controls ---
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ensp;"), 0x2002)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("emsp;"), 0x2003)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("thinsp;"), 0x2009)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("zwnj;"), 0x200C)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("zwj;"), 0x200D)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("shy;"), 0xAD)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("sbquo;"), 0x201A)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("bdquo;"), 0x201E)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("lsaquo;"), 0x2039)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("rsaquo;"), 0x203A)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Dagger;"), 0x2021)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("permil;"), 0x2030)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("oline;"), 0x203E)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("frasl;"), 0x2044)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("prime;"), 0x2032)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("Prime;"), 0x2033)
    # --- arrows ---
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("larr;"), 0x2190)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("uarr;"), 0x2191)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("rarr;"), 0x2192)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("darr;"), 0x2193)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("harr;"), 0x2194)
    # --- math operators / relations ---
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("minus;"), 0x2212)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("lowast;"), 0x2217)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("sdot;"), 0x22C5)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("radic;"), 0x221A)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("infin;"), 0x221E)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("asymp;"), 0x2248)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("equiv;"), 0x2261)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ne;"), 0x2260)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("le;"), 0x2264)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("ge;"), 0x2265)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("sum;"), 0x2211)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("prod;"), 0x220F)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("part;"), 0x2202)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("int;"), 0x222B)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("fnof;"), 0x0192)
    # --- double-struck arrows (⇐ ⇑ ⇒ ⇓ ⇔) + carriage-return arrow ---
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("lArr;"), 0x21D0)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("uArr;"), 0x21D1)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("rArr;"), 0x21D2)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("dArr;"), 0x21D3)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("hArr;"), 0x21D4)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("crarr;"), 0x21B5)
    # --- set theory / logic relations (∀ ∃ ∅ ∇ ∈ ∉ ∋ ∝ ∠ ∧ ∨ ∩ ∪ ∴ ∼ ≅
    # ⊂ ⊃ ⊆ ⊇ ⊕ ⊗ ⊥). Each ';'-anchored literal keeps sub;/sube;, sup;/supe;/
    # sup1; etc. distinct. ---
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("forall;"), 0x2200)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("exist;"), 0x2203)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("empty;"), 0x2205)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("nabla;"), 0x2207)
    if r == 0:
        r = _ent_try(body, cast[Ptr[uint8]]("isin;"), 0x2208)

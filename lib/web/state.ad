# lib/web/state.ad — part of the modular web engine (extracted from htmlengine.ad).
# front-end-shared engine state: window geometry (bw/bh/TITLE_H/...) + readable-measure gutter + the SOURCE buffer pointers (src_ptr/src_len).
#
# Behavior-preserving split (single-compilation-unit; byte-identical).

# ====================================================================
# WINDOW geometry (mutable — a resize re-lays-out from the stored source).
# These live in the engine because layout wraps to bw and _vis_rows depends
# on bh; the front-ends read/write them directly (shared globals).
# ====================================================================
TITLE_H:   int32 = 18
ADDR_H:    int32 = 20           # editable address/URL bar (below the title)
ADDR_Y:    int32 = 18           # == TITLE_H
GO_W:      int32 = 30           # "Go" button width in the address bar
NAV_BTN_W: int32 = 22           # Back / Forward button width (left of the URL box)
NAV_BAR_W: int32 = 48           # 2*NAV_BTN_W + 4 left pad: URL box starts here
CONTENT_X: int32 = 8
CONTENT_Y: int32 = 38           # == TITLE_H + ADDR_H (page content starts here)
STATUS_H:  int32 = 16
LINE_H:    int32 = 16
CELL_W:    int32 = 8
bw: int32 = 880                 # window content width  (px; native default)
bh: int32 = 600                 # window content height (px)


# READABLE-MEASURE default (UA stylesheet): a plain page should not let body
# text span an arbitrarily wide window edge-to-edge — long lines are tiring to
# read. We cap the content column at MEASURE_MAX px and CENTRE it, leaving a
# symmetric page gutter on wide windows (exactly like a browser's default body
# max-width). MEASURE_MAX == 584 px == 73 character cells, chosen so that at the
# 600 px unit-test / legacy window the gutter is ZERO and geometry is byte-for-
# byte identical (avail = 600 - 2*8 = 584 == MEASURE_MAX): the cap only engages
# once the window is wider than 600 px, so all existing 600 px assertions hold.
MEASURE_MAX: int32 = 584


# Symmetric page gutter (px) added to CONTENT_X on wide windows so the content
# column is centred at its readable measure. 0 at bw <= 600.
def _page_gutter() -> int32:
    avail: int32 = bw - 2 * CONTENT_X
    if avail <= MEASURE_MAX:
        return 0
    return (avail - MEASURE_MAX) / 2


# Left edge of the body content column (CONTENT_X + centring gutter).
def _left_margin() -> int32:
    return CONTENT_X + _page_gutter()


def _content_right() -> int32:
    return bw - CONTENT_X - _page_gutter()


def _vis_rows() -> uint64:
    r: int32 = (bh - CONTENT_Y - STATUS_H) / LINE_H
    if r < 1:
        r = 1
    return cast[uint64](r)


# ====================================================================
# SOURCE — src_ptr/src_len point at the HTML the front-end wants parsed.
# ====================================================================
src_ptr:  Ptr[uint8] = 0
src_len:  uint64 = 0

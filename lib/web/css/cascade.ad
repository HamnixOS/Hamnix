# lib/web/css/cascade.ad — part of the modular web engine (extracted from htmlengine.ad).
# CSS cascade — <style>/inline rule parsing + matching + the box helpers (flex/grid/float/positioned/block) driven by computed style.
#
# Behavior-preserving split (single-compilation-unit; byte-identical).

from lib.htmlengine import _bg_pop, _bg_push, _color_pop, _color_push, _content_right, _css_ws, _hx_lower, _left_margin, _recompute_style
# opacity / rgba-alpha helpers live in the colour-value module; import the
# underscore-private ones explicitly so they are linked for the fold at rule
# store time (see _pack_fill_rgb / the `opacity` declaration handler).
from lib.web.css.values import _parse_alpha_frac, g_cv_alpha

# ====================================================================
# CSS CASCADE — <style> blocks + inline style="" for the properties that
# map onto this monospace-grid engine: color, background-color, font-weight
# (bold), text-align (center/right, baked into seg_x post-layout), and
# display:none (content skipped). A stylesheet is parsed once per page into a
# flat rule table; selectors support element / .class / #id and a single
# descendant combinator (`A B`), ordered by simple specificity
# (id=100, class=10, element=1; inline style wins over all).
# ====================================================================
MAX_RULES:   int32  = 256
CSS_STR_CAP: uint64 = 8192
css_sbuf: Array[8192, uint8]
css_slen: uint64 = 0

# target (rightmost) compound of each rule
r_tag_off: Array[256, int32]
r_tag_len: Array[256, int32]
r_cls_off: Array[256, int32]
r_cls_len: Array[256, int32]
r_id_off:  Array[256, int32]
r_id_len:  Array[256, int32]
# attribute selector on the target compound (one per compound). r_att_op:
# 0 none / 1 [attr] (exists) / 2 [attr=v] / 3 [attr~=v] / 4 [attr^=v] /
# 5 [attr$=v] / 6 [attr*=v] / 7 [attr|=v]. Name + value are css_sbuf spans.
r_att_off: Array[256, int32]
r_att_len: Array[256, int32]
r_att_op:  Array[256, int32]
r_atv_off: Array[256, int32]
r_atv_len: Array[256, int32]
# pseudo-class / pseudo-element on the target compound (0 = none). See
# _pseudo_code for the code mapping (:root/:checked/:disabled/:required/
# :enabled/:first-child/:nth-child even|odd, dynamic-inert, pseudo-element).
r_pseudo:  Array[256, int32]
# ancestor compound (present only for a descendant selector)
r_has_anc:  Array[256, int32]
r_atag_off: Array[256, int32]
r_atag_len: Array[256, int32]
r_acls_off: Array[256, int32]
r_acls_len: Array[256, int32]
r_aid_off:  Array[256, int32]
r_aid_len:  Array[256, int32]
# attribute selector on the ancestor compound
r_aatt_off: Array[256, int32]
r_aatt_len: Array[256, int32]
r_aatt_op:  Array[256, int32]
r_aatv_off: Array[256, int32]
r_aatv_len: Array[256, int32]
# pseudo-class / pseudo-element on the ancestor compound (0 = none).
r_apseudo:  Array[256, int32]
# resolved declarations
r_color:  Array[256, int32]
r_bg:     Array[256, int32]
r_weight: Array[256, int32]     # 0 none, 1 bold, 2 normal
r_align:  Array[256, int32]     # 0 none, 1 left, 2 center, 3 right
r_deco:   Array[256, int32]     # text-decoration: 0 none-set, 1 underline, 2 none, 3 line-through
r_fstyle: Array[256, int32]     # font-style: 0 none-set, 1 italic/oblique, 2 normal
r_nomark: Array[256, int32]     # list-style[-type]:none -> 1 (suppress <li> markers)
r_disp:   Array[256, int32]     # display: 1=none 2=flex 3=block 4=inline-block 5=inline
r_flexdir: Array[256, int32]    # flex-direction: 0 unset / 1 column / 2 row
r_justify: Array[256, int32]    # justify-content: 0 unset / 1..5 (see _justify_value)
r_aitems: Array[256, int32]     # align-items: 0 unset / 1 flex-start / 2 center / 3 flex-end / 4 stretch
r_acontent: Array[256, int32]   # align-content: 0 unset / 1..7 (see _align_content_value)
r_flexgap: Array[256, int32]    # flex column gap px: -1 unset (default FLEX_GAP)
r_rowgap: Array[256, int32]     # flex row gap px: -1 unset (0 => no inter-line gap)
r_flexwrap: Array[256, int32]   # flex-wrap: 0 unset/nowrap / 1 wrap
r_gaflow: Array[256, int32]     # grid-auto-flow bitfield: 0 unset, else 4|col1|dense2
# grid-template-columns: r_gtcn[ri] tracks (0 = unset), each encoded track in
# r_gtc[ri*GRID_MAXTRACK + c] (>= 0 fixed px / < 0 fr weight negated).
r_gtcn: Array[256, int32]
r_gtc:  Array[2048, int32]      # 256 rules * GRID_MAXTRACK tracks
# grid-template-rows (fixed px row heights); same shape as grid-template-columns.
r_gtrn: Array[256, int32]
r_gtr:  Array[2048, int32]      # 256 rules * GRID_MAXTRACK rows
# per-ITEM grid-column line placement: r_gcspan[ri] tracks spanned (0 = unset =>
# a single track), r_gcstart[ri] explicit 1-based start line (0 = auto-flow).
r_gcspan:  Array[256, int32]
r_gcstart: Array[256, int32]
# per-ITEM grid-row line placement: the ROW analogue of r_gcspan/r_gcstart.
r_grspan:  Array[256, int32]
r_grstart: Array[256, int32]
# grid-template-areas (W3C css-grid §7.3): a per-CONTAINER named-area map. Each
# `"a a b" "a a c"` string is a grid row; each space-separated token names the
# cell (a `.` cell is empty/unnamed). A name's cells must form a rectangle; we
# record its bounding box. r_gan[ri] = number of distinct named areas the rule
# declares (0 = unset); for area k of rule ri (flat index ri*GAREA_MAX+k):
# r_ga_name = interned name id (via _kf_intern's shared string registry),
# r_ga_r0/c0 = 0-based top-left cell, r_ga_rsp/csp = row/col span. r_gacols[ri]
# = the column count implied by the template (widest row), used to synthesise
# equal 1fr tracks when `grid-template-columns` is absent.
GAREA_MAX: int32 = 12
r_gan:      Array[256, int32]
r_ga_name:  Array[3072, int32]   # 256 rules * GAREA_MAX areas
r_ga_r0:    Array[3072, int32]
r_ga_c0:    Array[3072, int32]
r_ga_rsp:   Array[3072, int32]
r_ga_csp:   Array[3072, int32]
r_gacols:   Array[256, int32]
# per-ITEM `grid-area: name`: interned area name id (-1 = none / line-based form).
r_gareaname: Array[256, int32]
# box model (px; -1 = the rule does not set this axis). ml/mr fold margin+
# padding on that side into one left/right inset; mt/mb are the top/bottom
# gaps; wd is the content width; bd is 0 (border:none) / 1 (border on) / -1.
r_ml:     Array[256, int32]
r_mr:     Array[256, int32]
r_mt:     Array[256, int32]
r_mb:     Array[256, int32]
r_wd:     Array[256, int32]
r_bd:     Array[256, int32]
r_bordc:  Array[256, int32]     # border colour (0xRRGGBB; -1 unset)
r_accent: Array[256, int32]     # accent-color for form controls (0xRRGGBB; -1)
r_bordr:  Array[256, int32]     # border-radius px (0 = square)
r_filter: Array[256, int32]     # CSS filter packed (see _filter_value; 0 = none)
r_xform:  Array[256, int32]     # transform template id (-1 = none)
# CSS animations (static-render END-STATE model). r_kfname tags a @keyframes
# DEFINITION pseudo-rule with the interned keyframe name (>=0 => the rule is
# inert in selector matching; it only carries the settled end-state props). For
# a NORMAL rule, r_kfname is -1 and r_animref holds the interned name of the
# `animation`/`animation-name` it declares (-1 = none) so the element inherits
# that keyframe's end-state. See _store_keyframe / _cascade_match_current.
r_kfname:  Array[256, int32]     # keyframe-def name id (-1 = normal rule)
r_animref: Array[256, int32]     # animation-name id a normal rule sets (-1 none)
# r_kf_from tags WHICH edge of the timeline a keyframe pseudo-rule captured:
# 0 = the SETTLED end frame (`100%`/`to`, or the last frame), 1 = the FROM
# frame (`0%`/`from`, or the first frame). The overlay picks the end frame for
# animation-fill-mode forwards/both (and the unspecified legacy default) and
# the FROM frame for an explicit `none`/`backwards`. See _store_keyframe /
# _cascade_match_current.
r_kf_from: Array[256, int32]     # 0 = end-frame pseudo-rule, 1 = from-frame
r_center: Array[256, int32]     # 1 = margin-left+right:auto (centre the box)
r_fontpx: Array[256, int32]     # CSS font-size in px (-1 = rule sets no size)
# CSS line-height. 0 = rule sets none; >0 = absolute PX (from px/em); <0 =
# unitless/percentage multiplier in milli, negated (e.g. 1.5 -> -1500, 150% ->
# -1500) resolved against the element's font-size when the style scope opens.
r_lineh:  Array[256, int32]
# CSS white-space, encoded mode+1 (0 = rule sets none): 1 normal, 2 nowrap,
# 3 pre, 4 pre-wrap.
r_ws:     Array[256, int32]
# CSS overflow-wrap / word-wrap / word-break, encoded mode+1 (0 = rule sets
# none): 1 normal (never break inside a word — over-wide words overflow),
# 2 break (overflow-wrap:break-word / word-wrap:break-word / word-break:break-all
# — an over-wide word may be split mid-run so it fits the measure).
r_ovw:    Array[256, int32]
r_float:  Array[256, int32]     # CSS float: 0 none / 1 left / 2 right
r_clear:  Array[256, int32]     # CSS clear: 0 none / 1 left / 2 right / 3 both
# CSS position: 0 none, 1 relative (in-flow, shift rendered box), 2 absolute
# (out-of-flow, placed against the nearest positioned ancestor). top/left/right/
# bottom offsets in px, -1 = that edge is auto.
r_pos:    Array[256, int32]
r_top:    Array[256, int32]
r_left:   Array[256, int32]
r_right:  Array[256, int32]
r_bottom: Array[256, int32]
r_zidx:   Array[256, int32]     # z-index (ZIDX_UNSET = auto/unset)
# ROUND-2 box-model resolved values the LAYOUT module consumes (px; -1 = unset).
# min-width additionally floors r_wd so the current width path honours it; the
# raw axes below are carried through for the future layout pass.
r_minw:   Array[256, int32]     # min-width (px; -1 unset)
r_ht:     Array[256, int32]     # height (px; -1 unset)
r_minh:   Array[256, int32]     # min-height (px; -1 unset)
r_maxh:   Array[256, int32]     # max-height (px; -1 unset)
r_boxsz:  Array[256, int32]     # box-sizing: 0 unset / 1 content-box / 2 border-box
r_appear: Array[256, int32]     # appearance: 0 unset/auto / 1 none (suppress control chrome)
r_padx:   Array[256, int32]     # horizontal padding sum px (0 = rule sets none)
r_pady:   Array[256, int32]     # vertical padding sum px (0 = rule sets none)
r_bordw:  Array[256, int32]     # border width px per side (0 = rule sets none)
# True per-side border (W3C css-backgrounds §4). Two PACKED ints per rule
# (0 = unset -> the box uses the uniform 1px legacy stroke, byte-identical to
# before). Widths: 8 bits/side top|right<<8|bottom<<16|left<<24 (px, 0..120).
# Styles: 4 bits/side top|right<<4|bottom<<8|left<<12, each (code+1) where
# code 0=solid 1=dashed 2=dotted 3=double 4=none; nibble 0 => default solid.
r_bordps: Array[256, int32]     # packed per-side border widths (0 = none/uniform)
r_bordss: Array[256, int32]     # packed per-side border styles (0 = all default solid)
# TRUE PER-SIDE border COLOURS (W3C css-backgrounds §4): each side's declared
# colour (0xRRGGBB) or -1 (=> fall back to the uniform border colour / black).
# A per-rule group carried on ONE specificity slot (sbcs), like the width/style
# pair — a `border-*-color` / `border-color` TRBL decl sets them together.
r_bctop:  Array[256, int32]
r_bcrt:   Array[256, int32]
r_bcbot:  Array[256, int32]
r_bclft:  Array[256, int32]
r_flexg:  Array[256, int32]     # flex-grow * 1000 (-1 unset)
r_flexs:  Array[256, int32]     # flex-shrink * 1000 (-1 unset)
r_flexb:  Array[256, int32]     # flex-basis px (-1 unset / auto)
r_posfx:  Array[256, int32]     # position sub-kind: 0 none / 1 fixed / 2 sticky
r_valign: Array[256, int32]     # vertical-align: 0 unset / 1..6 (see _valign_value)
r_tindent: Array[256, int32]    # text-indent (px; TINDENT_UNSET = unset)
r_ovfx:   Array[256, int32]     # overflow-x: 0 visible / 1 hidden / 2 scroll / 3 auto / 4 clip
r_ovfy:   Array[256, int32]     # overflow-y (same encoding)
r_txtovf: Array[256, int32]     # text-overflow: 0 unset / 1 clip / 2 ellipsis
# object-fit for replaced elements (<img>): 0 unset (default fill) / 1 fill /
# 2 contain / 3 cover / 4 none / 5 scale-down. object-position gives the drawn
# bitmap's placement within the content box: a `set` flag + x/y (value+percent
# flag, mirroring background-position's encoding: p==1 percent-of-free-space).
r_objfit:  Array[256, int32]    # object-fit (0 unset .. 5 scale-down)
r_objpos:  Array[256, int32]    # object-position set flag (0 unset / 1 set)
r_objposx: Array[256, int32]    # object-position X value
r_objposxp: Array[256, int32]   # object-position X percent flag (1 %, 0 px)
r_objposy: Array[256, int32]    # object-position Y value
r_objposyp: Array[256, int32]   # object-position Y percent flag
# aspect-ratio <w>/<h> (or a single number): milli-scaled numerator/denominator.
# r_asph == 0 => unset. When a box has a definite width and auto height, the
# height is derived as width * asph / aspw (see _block_box_open).
r_aspw:   Array[256, int32]     # aspect-ratio numerator (milli), 0 = unset
r_asph:   Array[256, int32]     # aspect-ratio denominator (milli), 0 = unset
r_spec:   Array[256, int32]
n_rules:  int32 = 0

# element stack (open elements) for descendant matching
MAX_EL:     int32  = 64
EL_STR_CAP: uint64 = 4096
el_sbuf: Array[4096, uint8]
el_slen: uint64 = 0
el_tag_off: Array[64, int32]
el_tag_len: Array[64, int32]
el_cls_off: Array[64, int32]
el_cls_len: Array[64, int32]
el_id_off:  Array[64, int32]
el_id_len:  Array[64, int32]
# raw tag-body src span [ne,te) of each open element, so attribute selectors can
# look up arbitrary attributes live (the document src stays resident during the
# whole layout pass that drives cascade matching).
el_body_s:  Array[64, uint64]
el_body_e:  Array[64, uint64]
# 1-based position of each open element among its parent's element children,
# and the running element-child count opened so far under the element at each
# stack level (indexed by PARENT level). Together these drive :nth-child /
# :first-child in the static (streaming) cascade. :last-child cannot be known
# during a forward pass and is treated as inert.
el_childidx: Array[64, int32]
el_nchild:   Array[64, int32]
el_rootcnt:  int32 = 0        # element children seen at depth 0 (document root)
el_sp: int32 = 0

# cascade match results (filled by _cascade_match_current)
m_col:    int32 = -1
m_bg:     int32 = -1
m_weight: int32 = 0
m_align:  int32 = 0
m_deco:   int32 = 0
m_fstyle: int32 = 0        # font-style cascade winner (0 unset, 1 italic, 2 normal)
m_nomark: int32 = 0        # list-style:none cascade winner (1 = suppress markers)
m_disp:   int32 = 0
m_flexdir: int32 = 0       # flex-direction cascade winner: 0 unset / 1 col / 2 row
m_justify: int32 = 0       # justify-content cascade winner: 0 unset / 1..5
m_aitems: int32 = 0        # align-items cascade winner: 0 unset / 1..4
m_acontent: int32 = 0      # align-content cascade winner: 0 unset / 1..7
m_flexgap: int32 = -1      # flex column-gap cascade winner px: -1 unset
m_rowgap: int32 = -1       # flex row-gap cascade winner px: -1 unset
m_flexwrap: int32 = 0      # flex-wrap cascade winner: 0 nowrap / 1 wrap
# grid-auto-flow cascade winner. 0 = unset (row, sparse). Else bit2(4)=explicitly
# set, bit0(1)=column axis, bit1(2)=dense packing. Read at grid container open.
m_gaflow: int32 = 0
m_gtcn: int32 = 0          # grid-template-columns cascade winner: track count
m_gtc:  Array[8, int32]    # winning template's encoded tracks
m_gtrn: int32 = 0          # grid-template-rows cascade winner: row count
m_gtr:  Array[8, int32]    # winning row template's encoded rows
m_gcspan:  int32 = 0       # grid-column cascade winner: span (0 = unset => 1)
m_gcstart: int32 = 0       # grid-column cascade winner: explicit start (0 = auto)
m_grspan:  int32 = 0       # grid-row cascade winner: span (0 = unset => 1)
m_grstart: int32 = 0       # grid-row cascade winner: explicit start (0 = auto)
# grid-template-areas cascade winners (the container's named-area rectangles).
m_gan: int32 = 0
m_ga_name: Array[12, int32]
m_ga_r0:   Array[12, int32]
m_ga_c0:   Array[12, int32]
m_ga_rsp:  Array[12, int32]
m_ga_csp:  Array[12, int32]
m_gacols:  int32 = 0
m_gareaname: int32 = -1    # grid-area name cascade winner (-1 = none)
# box-model cascade winners (-1 = no matching rule set this axis)
m_ml:     int32 = -1
m_mr:     int32 = -1
m_mt:     int32 = -1
m_mb:     int32 = -1
m_wd:     int32 = -1
m_bd:     int32 = -1
m_bordc:  int32 = -1       # border colour cascade winner (0xRRGGBB; -1 = default)
m_accent: int32 = -1       # accent-color cascade winner (0xRRGGBB; -1 = UA default)
m_bordr:  int32 = 0        # border-radius cascade winner (px; 0 = square corners)
m_bordps: int32 = 0        # packed per-side border widths cascade winner (0 = uniform)
m_bordss: int32 = 0        # packed per-side border styles cascade winner (0 = solid)
m_bctop:  int32 = -1       # per-side border colour cascade winners (0xRRGGBB; -1 none)
m_bcrt:   int32 = -1
m_bcbot:  int32 = -1
m_bclft:  int32 = -1
m_filter: int32 = 0        # CSS filter cascade winner (packed; 0 = none)
m_xform:  int32 = -1       # transform template id cascade winner (-1 = none)
m_animname: int32 = -1     # animation-name cascade winner (interned id; -1 none)
# animation-fill-mode cascade winner: -1 unspecified (legacy: paint settled end
# frame), 0 = none, 1 = forwards, 2 = backwards, 3 = both. forwards/both/(unset)
# overlay the END frame; none/backwards overlay the FROM (0%) frame.
m_animfill: int32 = -1
m_center: int32 = 0        # 1 = auto side margins (centre the box in its parent)
m_fontpx: int32 = -1
m_lineh:  int32 = 0        # CSS line-height cascade winner (see r_lineh encoding)
m_ws:     int32 = 0        # CSS white-space cascade winner (mode+1; 0 = unset)
m_ovw:    int32 = 0        # CSS overflow-wrap/word-break winner (mode+1; 0 = unset)
m_float:  int32 = 0
# CSS clear cascade winner: 0 none / 1 left / 2 right / 3 both. A block that
# `clear`s drops below the bottom of any active same-side float exclusion before
# it lays out (see box.ad _apply_clear). 0 for the overwhelming majority of
# elements, so float-free/clear-free pages stay byte-identical.
m_clear:  int32 = 0
# CSS position cascade winners (m_pos 0/1/2; offsets px, -1 = auto).
m_pos:    int32 = 0
m_top:    int32 = -1
m_left:   int32 = -1
m_right:  int32 = -1
m_bottom: int32 = -1
m_zidx:   int32 = -2000000000       # z-index cascade winner (ZIDX_UNSET = unset)
# ROUND-2 box/flex/position cascade winners (consumed by the layout module).
m_minw:   int32 = -1
m_ht:     int32 = -1
m_minh:   int32 = -1
m_maxh:   int32 = -1
m_boxsz:  int32 = 0            # 0 unset / 1 content-box / 2 border-box
m_appear: int32 = 0           # appearance cascade winner: 0 unset/auto / 1 none
m_padx:   int32 = 0           # horizontal padding sum px (border-box width calc)
m_pady:   int32 = 0           # vertical padding sum px (border-box height calc)
m_bordw:  int32 = 0           # border width px per side (border-box calc)
m_flexg:  int32 = -1          # flex-grow * 1000
m_flexs:  int32 = -1          # flex-shrink * 1000
m_flexb:  int32 = -1          # flex-basis px
m_posfx:  int32 = 0           # 0 none / 1 fixed / 2 sticky
m_valign: int32 = 0           # 0 unset / 1..6
m_tindent: int32 = -2000000000       # text-indent px (TINDENT_UNSET = unset)
# CSS overflow cascade winners (per axis): 0 visible (default, no clip) / 1 hidden
# / 2 scroll / 3 auto / 4 clip. Any value >= 1 establishes a clip rect at the
# box's padding edge (the layout module clips descendant segments/fills to it).
m_ovfx:   int32 = 0
m_ovfy:   int32 = 0
# CSS text-overflow cascade winner: 0 unset (default clip) / 1 clip / 2 ellipsis.
# Only `ellipsis` (2) alters paint — the overflow-x clip renders a `…` (as "...")
# at the truncation point instead of a hard cut. Single-line idiom only.
m_txtovf: int32 = 0
# object-fit / object-position cascade winners (see r_objfit et al. above) and
# aspect-ratio (milli w/h; m_asph == 0 => unset).
m_objfit:  int32 = 0
m_objpos:  int32 = 0
m_objposx: int32 = 0
m_objposxp: int32 = 1
m_objposy: int32 = 0
m_objposyp: int32 = 1
m_aspw:   int32 = 0
m_asph:   int32 = 0

# ---- CSS position (relative/absolute) ------------------------------------
# Positioned elements are laid out in normal flow, then a post-layout pass
# (_apply_positioned) shifts their whole segment run. `relative` keeps the
# element's in-flow space and offsets the rendered box by top/left (or pulls it
# back by right/bottom). `absolute` is out of flow: after laying its box out we
# REWIND cur_row (like a float) so following content reclaims the space, and the
# box is placed against the nearest positioned ancestor's origin (or the page
# top-left). A per-element context stack records each positioned ancestor's
# top-left/right so an absolute child resolves top/left/right against it. Pages
# that use no `position` add zero runs, so layout is byte-identical.
POS_MAX:  int32 = 64
pos_seg0: Array[64, int32]       # first segment of the positioned run
pos_seg1: Array[64, int32]       # one past the last segment
pos_mode: Array[64, int32]       # 1 relative, 2 absolute
pos_fx:   Array[64, int32]       # sub-kind: 0 plain / 1 fixed (viewport) / 2 sticky
pos_ox:   Array[64, int32]       # containing-block left x (absolute)
pos_ort:  Array[64, int32]       # containing-block right x (absolute)
pos_orow: Array[64, int32]       # containing-block top row (absolute)
pos_l:    Array[64, int32]       # left/top/right/bottom offsets (px, -1 auto)
pos_t:    Array[64, int32]
pos_r:    Array[64, int32]
pos_b:    Array[64, int32]
pos_z:    Array[64, int32]       # z-index (stacking order; 0 = auto/default)
pos_bf0:  Array[64, int32]       # first bfill (block background) of the run
pos_bf1:  Array[64, int32]       # one past the last bfill of the run
# width:auto marker (1) for an absolute/fixed box: with no explicit width the box
# SHRINK-TO-FITs its content (CSS 10.3.7) instead of taking the containing-block
# width, so a `top;right`-anchored auto-width badge is a small top-right box, not
# a full-width bar overlapping the heading. 0 (default) = explicit width, no change.
pos_wauto: Array[64, int32]
# For an `absolute` box: the pos-run index of its containing block (nearest
# positioned ancestor), or -1 for `fixed`/no ancestor (page/viewport). Lets the
# resolver read the ancestor's padding-box RIGHT/BOTTOM edge (its own background
# fill, painted at close) so `right:`/`bottom:` anchor to the correct reference.
pos_cbrun: Array[64, int32]
# Containing-block padding-box RIGHT x / BOTTOM row for a positioned ancestor's
# OWN run, captured from its LAID-OUT BOX GEOMETRY (not any paint/background
# record): the right edge is recorded when the ancestor pushes its positioning
# context (blk_right_cur + CELL_W = the ancestor's padding-box right), the bottom
# row when it pops (cur_row + row_dirty = its padding-box bottom). This makes
# `right:`/`bottom:` anchoring independent of whether/how the ancestor is painted
# (gradient, transparent, image, or solid). -1 = unset (fall back to page edges).
pos_cb_rx:  Array[64, int32]
pos_cb_bot: Array[64, int32]
pos_n:    int32 = 0

# STATIC scroll offset (whole rows) assumed by the sticky/fixed resolver. The
# host render paints the WHOLE page canvas (no live viewport crop), so a first
# paint has no scroll state; a front-end/test sets this (he_set_scroll_rows) to
# ask "if the page were scrolled down N rows, where do position:sticky/fixed
# boxes resolve?". 0 (the default) leaves layout byte-identical for every page
# that never touches it. `fixed` pins to the viewport top (= this scroll row);
# `sticky` pins to it once its in-flow row scrolls above the threshold. Live
# per-frame recompute on real scroll is the documented follow-up.
pos_scroll_y: int32 = 0

# nearest-positioned-ancestor origin stack (containing block for `absolute`).
posctx_x:   Array[64, int32]
posctx_rt:  Array[64, int32]
posctx_row: Array[64, int32]
posctx_run: Array[64, int32]     # pos-run index of the ancestor owning this frame
posctx_sp:  int32 = 0
# The pos-run index most recently registered (_register_pos), so the matching
# _posctx_push that follows can record which ancestor run owns the frame it opens.
g_last_posrun: int32 = -1

# font-weight (bold) scope — parallels the colour stack.
weight_stack: Array[64, int32]
weight_sp:  int32 = 0
g_css_bold: int32 = 0

# text-decoration scope — parallels the weight stack. A level pushes 0 when it
# sets no decoration, so the effective decoration INHERITS the nearest ancestor
# that did (CSS text-decoration is NOT inherited per spec, but propagating the
# underline down matches how it renders in practice for the common cases:
# <u>/underlined blocks). 1 = underline, 2 = none (an explicit reset, e.g. to
# strip a link's default underline). g_css_uline folds into g_uline.
deco_stack: Array[64, int32]
deco_sp:  int32 = 0
g_css_uline: int32 = 0
# CSS `text-decoration: line-through` (deco value 3) folds into seg_strike the
# same way <s>/<del>/<strike> (g_strike_n) does. Recomputed with g_css_uline.
g_css_strike: int32 = 0

# font-style scope — parallels the weight stack. A level pushes 0 when it sets no
# font-style, so the effective style INHERITS the nearest ancestor that set one
# (CSS font-style IS inherited). 1 = italic/oblique, 2 = normal (explicit reset).
# g_css_italic folds into seg_italic exactly like g_italic_n (<em>/<i>).
fstyle_stack: Array[64, int32]
fstyle_sp:  int32 = 0
g_css_italic: int32 = 0

# font-size (px) scope — parallels the weight stack. A level pushes 0 when it
# sets no size, so the effective size INHERITS the nearest ancestor that did
# (CSS font-size inheritance). g_font_px 0 = "use the face default".
fontpx_stack: Array[64, int32]
fontpx_sp: int32 = 0
g_font_px: int32 = 0

# line-height (px) scope — parallels the font-size stack. A level pushes 0 when
# it sets no line-height, so the effective pitch INHERITS the nearest ancestor
# that did (CSS line-height inherits). g_lineh 0 = "use the default rhythm".
# Values are already resolved to PIXELS at the point the scope is opened.
lineh_stack: Array[64, int32]
lineh_sp: int32 = 0
g_lineh: int32 = 0

# white-space scope — parallels the line-height stack. CSS `white-space`
# INHERITS, so a level pushes 0 when it sets none and the effective mode
# inherits the nearest ancestor that did. Stack/decl/rule/winner entries are
# ENCODED as mode+1 (0 = unset): 1 normal, 2 nowrap, 3 pre, 4 pre-wrap. The
# resolved effective mode g_ws is 0..3 (0 normal = the default flow):
#   0 normal   -> collapse whitespace runs to one space, soft-wrap at measure
#   1 nowrap   -> collapse, but never soft-wrap (line overflows the measure)
#   2 pre      -> preserve spaces + newlines, never soft-wrap
#   3 pre-wrap -> preserve spaces + newlines, but DO soft-wrap at the measure
# g_ws only takes effect through the CSS property; the <pre>/<code> ELEMENT
# keeps its own monospace-grid pre_mode path untouched, so unstyled pages are
# byte-identical (every level pushes 0 -> g_ws stays 0 -> normal flow).
ws_stack: Array[64, int32]
ws_sp: int32 = 0
g_ws: int32 = 0

# overflow-wrap / word-break scope — parallels the white-space stack, and like
# white-space this property INHERITS. Entries are ENCODED mode+1 (0 = level sets
# none): 1 normal, 2 break. The resolved flag g_break_word is 1 when the nearest
# ancestor that set the property chose a breaking mode (overflow-wrap:break-word,
# word-wrap:break-word, or word-break:break-all), else 0. Default 0 = normal, so
# an over-wide word OVERFLOWS its box rather than splitting mid-run (matching
# real browsers); the mid-word char-break in box.ad::_emit_word only fires when
# this flag is set.
ovw_stack: Array[64, int32]
ovw_sp: int32 = 0
g_break_word: int32 = 0

# text-align scope + per-row alignment record (post-pass shifts seg_x).
align_stack: Array[64, int32]
align_sp: int32 = 0
g_align:  int32 = 0
row_align: Array[12000, uint8]

# selector/declaration parse scratch (globals — the compiler has no tuples).
c_tag_off: int32 = -1
c_tag_len: int32 = 0
c_cls_off: int32 = -1
c_cls_len: int32 = 0
c_id_off:  int32 = -1
c_id_len:  int32 = 0
c_att_off: int32 = -1
c_att_len: int32 = 0
c_att_op:  int32 = 0
c_atv_off: int32 = -1
c_atv_len: int32 = 0
c_spec:    int32 = 0
# pseudo-class / pseudo-element code parsed onto this compound (0 = none). See
# _pseudo_code for the mapping. Pseudo-classes add +10 specificity (like a
# class); pseudo-elements add +1 (like an element); dynamic/unsupported states
# render inert (they never match a live element in a static layout pass).
c_pseudo:  int32 = 0
g_store_off: int32 = 0
g_store_len: int32 = 0
d_color:  int32 = -1
d_bg:     int32 = -1
d_weight: int32 = 0
d_align:  int32 = 0
d_deco:   int32 = 0
d_fstyle: int32 = 0         # font-style: 0 unset, 1 italic/oblique, 2 normal
d_nomark: int32 = 0         # list-style[-type]: 1 = none (suppress <li> markers)
d_disp:   int32 = 0
d_flexdir: int32 = 0        # flex-direction: 0 unset / 1 column / 2 row
d_justify: int32 = 0        # justify-content: 0 unset / 1..5
d_aitems: int32 = 0         # align-items: 0 unset / 1..4
d_acontent: int32 = 0       # align-content: 0 unset / 1..7
d_flexgap: int32 = -1       # flex column-gap px: -1 unset
d_rowgap: int32 = -1        # flex row-gap px: -1 unset
d_flexwrap: int32 = 0       # flex-wrap: 0 nowrap / 1 wrap
d_gaflow: int32 = 0         # grid-auto-flow bitfield (0 unset; 4=set|1 col|2 dense)
d_gtcn: int32 = 0           # grid-template-columns: track count (0 = unset)
d_gtc:  Array[8, int32]     # parsed encoded tracks for this rule / inline style
d_gtrn: int32 = 0           # grid-template-rows: row count (0 = unset)
d_gtr:  Array[8, int32]     # parsed encoded rows for this rule / inline style
d_gcspan:  int32 = 0        # grid-column span (0 = unset => single track)
d_gcstart: int32 = 0        # grid-column explicit 1-based start line (0 = auto)
d_grspan:  int32 = 0        # grid-row span (0 = unset => single row)
d_grstart: int32 = 0        # grid-row explicit 1-based start line (0 = auto)
# grid-template-areas / grid-area parsed for this rule / inline style.
d_gan: int32 = 0
d_ga_name: Array[12, int32]
d_ga_r0:   Array[12, int32]
d_ga_c0:   Array[12, int32]
d_ga_rsp:  Array[12, int32]
d_ga_csp:  Array[12, int32]
d_gacols:  int32 = 0
d_gareaname: int32 = -1     # grid-area: name (interned; -1 = none)
# box-model declaration scratch (per rule / per inline style="", -1 = unset).
# ml/mr fold the left/right margin+padding; mt/mb the top/bottom gaps (px);
# wd the content width (px); bd is 0 (none) / 1 (on) for a border.
d_ml:     int32 = -1
d_mr:     int32 = -1
d_mt:     int32 = -1
d_mb:     int32 = -1
d_wd:     int32 = -1
d_bd:     int32 = -1
d_bordc:  int32 = -1        # border colour (0xRRGGBB; -1 = unset => default)
d_accent: int32 = -1        # accent-color for form controls (0xRRGGBB; -1 unset)
d_bordr:  int32 = 0         # border-radius px (0 = square corners)
# Per-side border scratch (parsed from border-<side>/-width/-style [shorthands]).
# -1 = that side unset. Packed into d_bordps/d_bordss (the globals box.ad reads,
# inline-wins-over-sheet exactly like d_bordc). d_bordps/ss stay 0 for a plain
# uniform `border:` so that case renders on the legacy 1px stroke path unchanged.
d_bw_t:   int32 = -1
d_bw_r:   int32 = -1
d_bw_b:   int32 = -1
d_bw_l:   int32 = -1
d_bs_t:   int32 = -1
d_bs_r:   int32 = -1
d_bs_b:   int32 = -1
d_bs_l:   int32 = -1
d_bordps: int32 = 0         # packed per-side widths (0 = uniform legacy stroke)
d_bordss: int32 = 0         # packed per-side styles (0 = all default solid)
d_bc_t:   int32 = -1        # per-side border colour scratch (0xRRGGBB; -1 unset)
d_bc_r:   int32 = -1
d_bc_b:   int32 = -1
d_bc_l:   int32 = -1
d_filter: int32 = 0         # CSS filter packed (see _filter_value; 0 = none)
# opacity / rgba-alpha / box-shadow declaration scratch. d_bg_alpha carries the
# rgba()/hsla()/#rrggbbaa alpha of the declared background (0..255; 255 opaque).
# d_opacity is the element `opacity` (0..255; 255 = unset/opaque). d_boxshadow
# is a coarse box-shadow size class (0 none / 1 small / 2 medium / 3 large).
# All three are folded into the packed r_bg / r_bordc colour at rule-store time
# (see _pack_fill_rgb) so no new per-rule/per-element arrays are needed.
d_bg_alpha:  int32 = 255
d_opacity:   int32 = 255
d_boxshadow: int32 = 0
# d_bg_grad: registry ID (>=0) of a linear/radial-gradient declared for this
# rule's background, or -1 for none. A gradient carries more state (direction +
# 2..N colour stops) than the single packed r_bg int can hold, so it lives in
# the side registry below and r_bg stores only the ID under a marker (see
# _pack_gradient). A gradient WINS over any solid d_bg on the same rule.
d_bg_grad:   int32 = -1
# ---- gradient registry ----------------------------------------------------
# Populated at CSS-parse time (one entry per gradient-bearing rule), read at
# paint time (htmlpage) via the grad_* accessors. Reset per page in
# _collect_css. GRAD_MARK is stored in the packed r_bg where a solid fill would
# keep its alpha level: bits 24-28 == 31 is a translucency level _pack_fill_rgb
# never emits (max reachable a5 is 30), so it unambiguously flags a gradient and
# the low 24 bits carry the registry ID.
GRAD_MAX:    int32 = 64
GRAD_NSTOP:  int32 = 8          # max colour stops kept per gradient
GRAD_MARK:   int32 = 520093696  # 31 << 24
grad_type:   Array[64, int32]   # 0 linear, 1 radial, 2 conic, 3 url(image)
grad_angle:  Array[64, int32]   # linear line angle / conic `from` angle (deg)
grad_nstop:  Array[64, int32]   # number of colour stops (2..GRAD_NSTOP)
grad_scol:   Array[512, int32]  # GRAD_MAX*GRAD_NSTOP stop colours (0xRRGGBB)
grad_spos:   Array[512, int32]  # stop positions in permille (0..1000; -1 auto)
grad_repeat: Array[64, int32]   # 1 = repeating-* variant (tile the stops)
n_grads:     int32 = 0
# url(...) background registry — a gtype==3 entry stores the resolved image name
# (matched against the decoded-image store at paint time) instead of colour
# stops. Shares the GRAD_MARK packing so it flows through r_bg like a gradient.
GRAD_URL_CAP: int32 = 2048
grad_url_off: Array[64, uint64]  # byte offset of this url's name in grad_url_buf
grad_url_len: Array[64, int32]   # name length
grad_url_buf: Array[2048, uint8]
grad_url_used: uint64 = 0
# ---- per-gid background placement (background-size / -position / -repeat) ----
# Attached to a url (gtype==3) registry entry at rule-store time; read at paint
# time (htmlpage -> htmlpaint_blit_image_bg) to size, position and tile the
# decoded image inside the padding box.
#   szmode : 0 fill/stretch (default, no background-size) / 1 cover / 2 contain
#            / 3 explicit (auto components -> natural size, keeping aspect)
#   szw/szh: explicit component values; szwp/szhp encode the unit:
#            2 = auto (derive from the other axis, keep aspect), 1 = percent (of
#            the box), 0 = px.
#   posx/posy with posxp/posyp: 1 = percent (of the free space box-tile), 0 = px
#   rep    : 0 repeat (tile both axes) / 1 no-repeat / 2 repeat-x / 3 repeat-y
grad_bg_szmode: Array[64, int32]
grad_bg_szw:    Array[64, int32]
grad_bg_szwp:   Array[64, int32]
grad_bg_szh:    Array[64, int32]
grad_bg_szhp:   Array[64, int32]
grad_bg_posx:   Array[64, int32]
grad_bg_posxp:  Array[64, int32]
grad_bg_posy:   Array[64, int32]
grad_bg_posyp:  Array[64, int32]
grad_bg_rep:    Array[64, int32]
# declaration-scope background placement, reset per rule in _parse_decls and
# folded onto the rule's url gid at rule-store time. Defaults: size mode 0
# (legacy fill/stretch, preserving pre-background-size rendering), position
# 0% 0% (top-left), repeat.
d_bgsz_mode: int32 = 0
d_bgsz_w:    int32 = 0
d_bgsz_wp:   int32 = 2
d_bgsz_h:    int32 = 0
d_bgsz_hp:   int32 = 2
d_bgpos_x:   int32 = 0
d_bgpos_xp:  int32 = 1
d_bgpos_y:   int32 = 0
d_bgpos_yp:  int32 = 1
d_bgrep:     int32 = 0
# scratch for the numeric-token parser (_bg_num): value + percent flag.
g_bg_val: int32 = 0
g_bg_pct: int32 = 0


# ===================================================================
# COMPUTED-VALUE COLOUR RESOLUTION (getComputedStyle / CSSOM).
# css_color_rgb parses an arbitrary CSS colour STRING buffer p[0..n) — #rgb /
# #rrggbb / #rrggbbaa / rgb()/rgba() / a common named-colour subset — into a
# packed 0xRRGGBB, leaving the resolved 0..255 alpha in g_gcs_alpha. Returns -1
# when the string is not a recognised colour (the caller then keeps the CSS
# default). This is the string-buffer twin of values.ad's _color_value (which
# scans the shared source buffer src_ptr): getComputedStyle must resolve the
# script-set inline colours that live in JS strings (el.style.color = 'red'),
# not in the HTML source. "transparent" resolves to 0x000000 with alpha 0.
# ===================================================================
g_gcs_alpha: int32 = 255


def _gcs_hex1(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return cast[int32](c) - 48
    lc: uint8 = _hx_lower(c)
    if lc >= 97 and lc <= 102:
        return cast[int32](lc) - 97 + 10
    return -1


# Whole-token case-insensitive compare of p[0..n) against a lowercase literal.
def _gcs_word(p: Ptr[uint8], n: int32, lit: Ptr[uint8]) -> int32:
    i: int32 = 0
    while lit[i] != 0:
        if i >= n:
            return 0
        if _hx_lower(p[i]) != lit[i]:
            return 0
        i = i + 1
    if i != n:
        return 0
    return 1


# Named CSS colour (common subset) -> 0xRRGGBB, or -1. Alpha stays 255.
def _gcs_named(p: Ptr[uint8], n: int32) -> int32:
    if _gcs_word(p, n, cast[Ptr[uint8]]("black")) != 0:
        return 0x000000
    if _gcs_word(p, n, cast[Ptr[uint8]]("white")) != 0:
        return 0xffffff
    if _gcs_word(p, n, cast[Ptr[uint8]]("red")) != 0:
        return 0xff0000
    if _gcs_word(p, n, cast[Ptr[uint8]]("green")) != 0:
        return 0x008000
    if _gcs_word(p, n, cast[Ptr[uint8]]("lime")) != 0:
        return 0x00ff00
    if _gcs_word(p, n, cast[Ptr[uint8]]("blue")) != 0:
        return 0x0000ff
    if _gcs_word(p, n, cast[Ptr[uint8]]("navy")) != 0:
        return 0x000080
    if _gcs_word(p, n, cast[Ptr[uint8]]("teal")) != 0:
        return 0x008080
    if _gcs_word(p, n, cast[Ptr[uint8]]("aqua")) != 0:
        return 0x00ffff
    if _gcs_word(p, n, cast[Ptr[uint8]]("cyan")) != 0:
        return 0x00ffff
    if _gcs_word(p, n, cast[Ptr[uint8]]("olive")) != 0:
        return 0x808000
    if _gcs_word(p, n, cast[Ptr[uint8]]("yellow")) != 0:
        return 0xffff00
    if _gcs_word(p, n, cast[Ptr[uint8]]("orange")) != 0:
        return 0xffa500
    if _gcs_word(p, n, cast[Ptr[uint8]]("gold")) != 0:
        return 0xffd700
    if _gcs_word(p, n, cast[Ptr[uint8]]("purple")) != 0:
        return 0x800080
    if _gcs_word(p, n, cast[Ptr[uint8]]("magenta")) != 0:
        return 0xff00ff
    if _gcs_word(p, n, cast[Ptr[uint8]]("fuchsia")) != 0:
        return 0xff00ff
    if _gcs_word(p, n, cast[Ptr[uint8]]("maroon")) != 0:
        return 0x800000
    if _gcs_word(p, n, cast[Ptr[uint8]]("silver")) != 0:
        return 0xc0c0c0
    if _gcs_word(p, n, cast[Ptr[uint8]]("gray")) != 0:
        return 0x808080
    if _gcs_word(p, n, cast[Ptr[uint8]]("grey")) != 0:
        return 0x808080
    if _gcs_word(p, n, cast[Ptr[uint8]]("pink")) != 0:
        return 0xffc0cb
    if _gcs_word(p, n, cast[Ptr[uint8]]("brown")) != 0:
        return 0xa52a2a
    return -1


# Read a base-10 unsigned integer from p starting at *ip (advancing it); returns
# the value (0 if no digit). Skips nothing — caller positions *ip on a digit.
def _gcs_uint(p: Ptr[uint8], n: int32, ip: Ptr[int32]) -> int32:
    i: int32 = ip[0]
    v: int32 = 0
    while i < n and p[i] >= 48 and p[i] <= 57:
        v = v * 10 + (cast[int32](p[i]) - 48)
        i = i + 1
    ip[0] = i
    return v


# Parse an alpha fraction "0.NNN" (or an integer 0/1) at p[i..) into 0..255.
def _gcs_alpha_frac(p: Ptr[uint8], n: int32, i: int32) -> int32:
    whole: int32 = 0
    j: int32 = i
    while j < n and p[j] >= 48 and p[j] <= 57:
        whole = whole * 10 + (cast[int32](p[j]) - 48)
        j = j + 1
    if whole >= 1:
        return 255
    milli: int32 = 0
    scale: int32 = 100
    if j < n and p[j] == 46:                              # '.'
        j = j + 1
        while j < n and p[j] >= 48 and p[j] <= 57 and scale >= 1:
            milli = milli + (cast[int32](p[j]) - 48) * scale
            scale = scale / 10
            j = j + 1
    # milli is 0..999 -> 0..255
    return milli * 255 / 1000


# Parse a colour string p[0..n) into packed 0xRRGGBB (+ g_gcs_alpha). -1 if
# unrecognised. Leading/trailing ASCII whitespace is tolerated.
def css_color_rgb(pin: Ptr[uint8], nin: int32) -> int32:
    g_gcs_alpha = 255
    # trim whitespace
    s: int32 = 0
    e: int32 = nin
    while s < e and (pin[s] == 32 or pin[s] == 9):
        s = s + 1
    while e > s and (pin[e - 1] == 32 or pin[e - 1] == 9):
        e = e - 1
    n: int32 = e - s
    if n <= 0:
        return -1
    p: Ptr[uint8] = &pin[s]
    if p[0] == 35:                                        # '#'
        # count hex digits
        nd: int32 = 0
        while nd + 1 < n and _gcs_hex1(p[nd + 1]) >= 0:
            nd = nd + 1
        if nd >= 6:
            r: int32 = _gcs_hex1(p[1]) * 16 + _gcs_hex1(p[2])
            g: int32 = _gcs_hex1(p[3]) * 16 + _gcs_hex1(p[4])
            b: int32 = _gcs_hex1(p[5]) * 16 + _gcs_hex1(p[6])
            if nd >= 8:
                g_gcs_alpha = _gcs_hex1(p[7]) * 16 + _gcs_hex1(p[8])
            return (r << 16) | (g << 8) | b
        if nd >= 3:
            r3: int32 = _gcs_hex1(p[1])
            g3: int32 = _gcs_hex1(p[2])
            b3: int32 = _gcs_hex1(p[3])
            if nd >= 4:
                a4: int32 = _gcs_hex1(p[4])
                g_gcs_alpha = a4 * 16 + a4
            return ((r3 * 17) << 16) | ((g3 * 17) << 8) | (b3 * 17)
        return -1
    if _gcs_word(p, n, cast[Ptr[uint8]]("transparent")) != 0:
        g_gcs_alpha = 0
        return 0x000000
    # rgb()/rgba(...)
    if (_hx_lower(p[0]) == 114):                          # 'r'
        # find '('
        i: int32 = 0
        while i < n and p[i] != 40:
            i = i + 1
        if i < n:
            i = i + 1
            # r
            while i < n and (p[i] == 32 or p[i] == 9):
                i = i + 1
            rr: int32 = _gcs_uint(p, n, &i)
            while i < n and (p[i] == 32 or p[i] == 9 or p[i] == 44):
                i = i + 1
            gg: int32 = _gcs_uint(p, n, &i)
            while i < n and (p[i] == 32 or p[i] == 9 or p[i] == 44):
                i = i + 1
            bb: int32 = _gcs_uint(p, n, &i)
            # optional alpha
            while i < n and (p[i] == 32 or p[i] == 9 or p[i] == 44 or p[i] == 47):
                i = i + 1
            if i < n and ((p[i] >= 48 and p[i] <= 57) or p[i] == 46):
                g_gcs_alpha = _gcs_alpha_frac(p, n, i)
            if rr > 255:
                rr = 255
            if gg > 255:
                gg = 255
            if bb > 255:
                bb = 255
            return (rr << 16) | (gg << 8) | bb
    return _gcs_named(p, n)


# ===================================================================
# CSS 2D `transform` — paint-stage affine (translate/scale/rotate/matrix).
# ===================================================================
# A `transform:` declaration is composed left-to-right into a 2x3 affine matrix
# (a,b,c,d,e,f), stored in a TEMPLATE registry (one entry per rule / inline
# block, created at CSS-collect / inline-parse time). `transform-origin` (default
# 50% 50% = box centre) rides on the same entry. Matrix coefficients a,b,c,d are
# 12-bit fixed point (XF_FX); translate e,f are whole px; a percent translate
# (translate(50%)) is resolved against the box size at PAINT time so it is kept
# separately in xt_epct/xt_fpct (permille of w/h).
#
# At element-open, the winning template is BOUND into a second (xb_*) registry
# together with the fill the box would otherwise paint (its background colour or
# gradient id). The bound-entry id is packed through r_bg / bfill_rgb under
# XFORM_MARK (a5==31, shadow-bits==1 — a pattern _pack_fill_rgb never emits and
# distinct from a gradient's a5==31/shadow==0) so it flows to htmlpage UNCHANGED
# through box.ad, which treats the packed int as opaque. htmlpage reads it back
# via xform_* and paints the box as a transformed quad (htmlpaint_fill_box_xform)
# with the inner fill's colour.
XF_FX:      int32 = 4096           # 1.0 in matrix fixed point (a,b,c,d)
XFORM_MARK: int32 = 1056964608     # (31<<24)|(1<<29): flags a transform ref
XFORM_MAX:  int32 = 256
# ---- template registry (per rule/inline, matrix + origin) ----
xt_a:    Array[256, int32]         # 2x3 affine, a,d default XF_FX (identity)
xt_b:    Array[256, int32]
xt_c:    Array[256, int32]
xt_d:    Array[256, int32]
xt_e:    Array[256, int32]         # translate x (whole px, non-percent part)
xt_f:    Array[256, int32]         # translate y (whole px)
xt_epct: Array[256, int32]         # translate x percent (permille of box w)
xt_fpct: Array[256, int32]         # translate y percent (permille of box h)
xt_ox:   Array[256, int32]         # transform-origin x value
xt_oxp:  Array[256, int32]         # 1 = ox is permille of w, 0 = px
xt_oy:   Array[256, int32]         # transform-origin y value
xt_oyp:  Array[256, int32]         # 1 = oy is permille of h, 0 = px
n_xtempl: int32 = 0
# ---- bound registry (per transformed box: template + inner fill) ----
xb_tid:   Array[256, int32]        # template index this binding uses
xb_inner: Array[256, int32]        # packed fill the box paints under the xform
n_xbind:  int32 = 0
# declaration-scope transform scratch (reset per rule / inline block).
d_xform:  int32 = -1               # template id parsed for this block (-1 none)
# CSS animations: the interned `animation`/`animation-name` this block declares
# (-1 = none). Interned into the keyframe-name table below so it can be matched
# against a @keyframes definition regardless of source order.
d_animname: int32 = -1
# animation-fill-mode declared by this block (-1 unset / 0 none / 1 forwards /
# 2 backwards / 3 both). Detected in the `animation` shorthand and the
# `animation-fill-mode` longhand; rides the cascade via r_animfill/m_animfill.
d_animfill: int32 = -1
# r_animfill: the animation-fill-mode a NORMAL rule sets (-1 = unset).
r_animfill: Array[256, int32]
# ---- @keyframes NAME registry (interned names + settled end-states) ----------
# Both a @keyframes definition's NAME and a rule's animation-name are interned
# here (exact byte match, case-sensitive per CSS custom-ident rules) so the
# cascade can pair an element with its keyframe end-state by id. Reset each
# _collect_css pass. Names are appended into kf_namebuf.
KF_MAX_NAMES:  int32 = 64
KF_NAMEBUF:    uint64 = 2048
kf_name_off:   Array[64, uint64]
kf_name_len:   Array[64, uint64]
kf_namebuf:    Array[2048, uint8]
kf_namebuf_w:  uint64 = 0
n_kf_names:    int32 = 0
# numeric-token cursor for the transform value parser.
_xf_i:   uint64 = 0
_xf_e:   uint64 = 0
_xf_bad: int32 = 0


# sin(deg)*XF_FX via the Bhaskara I approximation (max error ~0.16%; EXACT at the
# cardinal angles 0/90/180/270). deg is reduced to [0,360).
def _xf_sin_deg(deg: int32) -> int32:
    d: int32 = deg
    d = d % 360
    if d < 0:
        d = d + 360
    sign: int32 = 1
    if d > 180:
        d = d - 180
        sign = -1
    # d in [0,180]: sin = 4d(180-d) / (40500 - d(180-d))
    t: int32 = d * (180 - d)
    den: int32 = 40500 - t
    if den == 0:
        return 0
    v: int32 = 4 * t * XF_FX / den
    return sign * v


def _xf_cos_deg(deg: int32) -> int32:
    return _xf_sin_deg(deg + 90)


# Post-multiply the block's working matrix (d_x* accumulator) by F(a,b,c,d,e,f).
# Coefficients in XF_FX; translate ea/fa in whole px. R = M . F.
_xm_a: int32 = 4096
_xm_b: int32 = 0
_xm_c: int32 = 0
_xm_d: int32 = 4096
_xm_e: int32 = 0
_xm_f: int32 = 0


def _xm_reset():
    _xm_a = XF_FX
    _xm_b = 0
    _xm_c = 0
    _xm_d = XF_FX
    _xm_e = 0
    _xm_f = 0


def _xm_mul(fa: int32, fb: int32, fc: int32, fd: int32, fe: int32, ff: int32):
    na: int32 = (_xm_a * fa + _xm_c * fb) / XF_FX
    nb: int32 = (_xm_b * fa + _xm_d * fb) / XF_FX
    nc: int32 = (_xm_a * fc + _xm_c * fd) / XF_FX
    nd: int32 = (_xm_b * fc + _xm_d * fd) / XF_FX
    ne: int32 = (_xm_a * fe + _xm_c * ff) / XF_FX + _xm_e
    nf: int32 = (_xm_b * fe + _xm_d * ff) / XF_FX + _xm_f
    _xm_a = na
    _xm_b = nb
    _xm_c = nc
    _xm_d = nd
    _xm_e = ne
    _xm_f = nf


# Parse a signed decimal starting at _xf_i (skipping spaces); return value*XF_FX
# and advance _xf_i. Sets _xf_bad=1 if no digit seen.
def _xf_num_fx() -> int32:
    i: uint64 = _xf_i
    e: uint64 = _xf_e
    _xf_bad = 0
    while i < e and (src_ptr[i] == 32 or src_ptr[i] == 9 or src_ptr[i] == 44):
        i = i + 1
    neg: int32 = 0
    if i < e and src_ptr[i] == 43:
        i = i + 1
    elif i < e and src_ptr[i] == 45:
        neg = 1
        i = i + 1
    seen: int32 = 0
    whole: int32 = 0
    while i < e and src_ptr[i] >= 48 and src_ptr[i] <= 57:
        whole = whole * 10 + cast[int32](src_ptr[i] - 48)
        seen = 1
        i = i + 1
    fracfx: int32 = 0
    if i < e and src_ptr[i] == 46:
        i = i + 1
        place: int32 = XF_FX / 10
        while i < e and src_ptr[i] >= 48 and src_ptr[i] <= 57:
            if place > 0:
                fracfx = fracfx + cast[int32](src_ptr[i] - 48) * place
                place = place / 10
            seen = 1
            i = i + 1
    _xf_i = i
    if seen == 0:
        _xf_bad = 1
        return 0
    v: int32 = whole * XF_FX + fracfx
    if neg != 0:
        return 0 - v
    return v


# Skip spaces/commas at _xf_i.
def _xf_skip():
    while _xf_i < _xf_e and (src_ptr[_xf_i] == 32 or src_ptr[_xf_i] == 9 or \
                             src_ptr[_xf_i] == 44):
        _xf_i = _xf_i + 1


# Skip a trailing ASCII-letter length unit (px/em/rem/vw/…) at _xf_i so the next
# component/number parses cleanly. Leaves '%' (handled separately) untouched.
def _xf_skip_unit():
    while _xf_i < _xf_e and ((src_ptr[_xf_i] >= 97 and src_ptr[_xf_i] <= 122) or \
                             (src_ptr[_xf_i] >= 65 and src_ptr[_xf_i] <= 90)):
        _xf_i = _xf_i + 1


# True if the lowercased token at _xf_i matches lit (advancing past it).
def _xf_word(lit: Ptr[uint8]) -> int32:
    _xf_skip()
    i: uint64 = _xf_i
    k: int32 = 0
    while lit[k] != 0:
        if i >= _xf_e:
            return 0
        c: uint8 = src_ptr[i]
        if c >= 65 and c <= 90:
            c = c + 32
        if c != cast[uint8](lit[k]):
            return 0
        i = i + 1
        k = k + 1
    _xf_i = i
    return 1


# Allocate a fresh identity template; returns its id or -1 if the pool is full.
def _xt_new() -> int32:
    if n_xtempl >= XFORM_MAX:
        return -1
    t: int32 = n_xtempl
    xt_a[t] = XF_FX
    xt_b[t] = 0
    xt_c[t] = 0
    xt_d[t] = XF_FX
    xt_e[t] = 0
    xt_f[t] = 0
    xt_epct[t] = 0
    xt_fpct[t] = 0
    xt_ox[t] = 500                 # default transform-origin 50% 50%
    xt_oxp[t] = 1
    xt_oy[t] = 500
    xt_oyp[t] = 1
    n_xtempl = n_xtempl + 1
    return t


# Parse a `transform:` value (src[vs..ve)) into a template; returns its id (-1 on
# empty/failure). Supports translate/translateX/translateY, scale/scaleX/scaleY,
# rotate (deg/rad/turn), matrix(a,b,c,d,e,f), and space/whitespace-separated
# composition applied left-to-right. Percent translate is kept separate (resolved
# against the box at paint time); px translate folds into the matrix.
def _xf_parse_transform(vs: uint64, ve: uint64) -> int32:
    _xf_i = vs
    _xf_e = ve
    if _xf_word(cast[Ptr[uint8]]("none")) != 0:
        return -1
    _xm_reset()
    epct: int32 = 0
    fpct: int32 = 0
    got: int32 = 0
    guard: int32 = 0
    while _xf_i < ve and guard < 64:
        guard = guard + 1
        _xf_skip()
        if _xf_i >= ve:
            break
        # translateX / translateY / translate
        if _xf_word(cast[Ptr[uint8]]("translatex")) != 0:
            if _xf_word(cast[Ptr[uint8]]("(")) != 0:
                v: int32 = _xf_num_fx()
                if _xf_word(cast[Ptr[uint8]]("%")) != 0:
                    epct = epct + v / (XF_FX / 1000)
                else:
                    _xf_skip_unit()
                    _xm_mul(XF_FX, 0, 0, XF_FX, v / XF_FX, 0)
                _xf_word(cast[Ptr[uint8]](")"))
                got = 1
        elif _xf_word(cast[Ptr[uint8]]("translatey")) != 0:
            if _xf_word(cast[Ptr[uint8]]("(")) != 0:
                v2: int32 = _xf_num_fx()
                if _xf_word(cast[Ptr[uint8]]("%")) != 0:
                    fpct = fpct + v2 / (XF_FX / 1000)
                else:
                    _xf_skip_unit()
                    _xm_mul(XF_FX, 0, 0, XF_FX, 0, v2 / XF_FX)
                _xf_word(cast[Ptr[uint8]](")"))
                got = 1
        elif _xf_word(cast[Ptr[uint8]]("translate")) != 0:
            if _xf_word(cast[Ptr[uint8]]("(")) != 0:
                tx: int32 = _xf_num_fx()
                txp: int32 = _xf_word(cast[Ptr[uint8]]("%"))
                if txp == 0:
                    _xf_skip_unit()
                ty: int32 = 0
                typ: int32 = 0
                _xf_skip()
                if _xf_i < ve and src_ptr[_xf_i] != 41:
                    ty = _xf_num_fx()
                    typ = _xf_word(cast[Ptr[uint8]]("%"))
                    if typ == 0:
                        _xf_skip_unit()
                # fold the px components as one translate, percents kept aside.
                pxx: int32 = 0
                pxy: int32 = 0
                if txp != 0:
                    epct = epct + tx / (XF_FX / 1000)
                else:
                    pxx = tx / XF_FX
                if typ != 0:
                    fpct = fpct + ty / (XF_FX / 1000)
                else:
                    pxy = ty / XF_FX
                _xm_mul(XF_FX, 0, 0, XF_FX, pxx, pxy)
                _xf_word(cast[Ptr[uint8]](")"))
                got = 1
        elif _xf_word(cast[Ptr[uint8]]("scalex")) != 0:
            if _xf_word(cast[Ptr[uint8]]("(")) != 0:
                sx: int32 = _xf_num_fx()
                _xm_mul(sx, 0, 0, XF_FX, 0, 0)
                _xf_word(cast[Ptr[uint8]](")"))
                got = 1
        elif _xf_word(cast[Ptr[uint8]]("scaley")) != 0:
            if _xf_word(cast[Ptr[uint8]]("(")) != 0:
                sy: int32 = _xf_num_fx()
                _xm_mul(XF_FX, 0, 0, sy, 0, 0)
                _xf_word(cast[Ptr[uint8]](")"))
                got = 1
        elif _xf_word(cast[Ptr[uint8]]("scale")) != 0:
            if _xf_word(cast[Ptr[uint8]]("(")) != 0:
                sa: int32 = _xf_num_fx()
                sb: int32 = sa
                _xf_skip()
                if _xf_i < ve and src_ptr[_xf_i] != 41:
                    sb = _xf_num_fx()
                _xm_mul(sa, 0, 0, sb, 0, 0)
                _xf_word(cast[Ptr[uint8]](")"))
                got = 1
        elif _xf_word(cast[Ptr[uint8]]("rotate")) != 0:
            if _xf_word(cast[Ptr[uint8]]("(")) != 0:
                ang: int32 = _xf_num_fx()          # value * XF_FX
                deg: int32 = 0
                if _xf_word(cast[Ptr[uint8]]("deg")) != 0:
                    deg = ang / XF_FX
                elif _xf_word(cast[Ptr[uint8]]("turn")) != 0:
                    deg = ang * 360 / XF_FX
                elif _xf_word(cast[Ptr[uint8]]("rad")) != 0:
                    # rad -> deg: *180/pi ; pi ~ 3.14159 -> *180000/314159
                    deg = ang * 180000 / 314159 / XF_FX
                else:
                    deg = ang / XF_FX
                cs: int32 = _xf_cos_deg(deg)
                sn: int32 = _xf_sin_deg(deg)
                _xm_mul(cs, sn, 0 - sn, cs, 0, 0)
                _xf_word(cast[Ptr[uint8]](")"))
                got = 1
        elif _xf_word(cast[Ptr[uint8]]("matrix")) != 0:
            if _xf_word(cast[Ptr[uint8]]("(")) != 0:
                ma: int32 = _xf_num_fx()
                mb: int32 = _xf_num_fx()
                mc: int32 = _xf_num_fx()
                md: int32 = _xf_num_fx()
                me: int32 = _xf_num_fx()
                mf: int32 = _xf_num_fx()
                _xm_mul(ma, mb, mc, md, me / XF_FX, mf / XF_FX)
                _xf_word(cast[Ptr[uint8]](")"))
                got = 1
        else:
            # unknown token — skip one char to make progress.
            _xf_i = _xf_i + 1
    if got == 0:
        return -1
    t: int32 = _xt_new()
    if t < 0:
        return -1
    xt_a[t] = _xm_a
    xt_b[t] = _xm_b
    xt_c[t] = _xm_c
    xt_d[t] = _xm_d
    xt_e[t] = _xm_e
    xt_f[t] = _xm_f
    xt_epct[t] = epct
    xt_fpct[t] = fpct
    return t


# Parse a `transform-origin` value into (ox,oxp,oy,oyp) via out params folded
# onto template `t` (already created). Keywords left/center/right/top/bottom plus
# %/px. One or two components; a single component sets x, y stays centre.
def _xf_parse_origin(t: int32, vs: uint64, ve: uint64):
    if t < 0:
        return
    _xf_i = vs
    _xf_e = ve
    # X component
    if _xf_word(cast[Ptr[uint8]]("left")) != 0:
        xt_ox[t] = 0
        xt_oxp[t] = 1
    elif _xf_word(cast[Ptr[uint8]]("right")) != 0:
        xt_ox[t] = 1000
        xt_oxp[t] = 1
    elif _xf_word(cast[Ptr[uint8]]("center")) != 0:
        xt_ox[t] = 500
        xt_oxp[t] = 1
    elif _xf_word(cast[Ptr[uint8]]("top")) != 0:
        xt_oy[t] = 0
        xt_oyp[t] = 1
        return
    elif _xf_word(cast[Ptr[uint8]]("bottom")) != 0:
        xt_oy[t] = 1000
        xt_oyp[t] = 1
        return
    else:
        v: int32 = _xf_num_fx()
        if _xf_bad == 0:
            if _xf_word(cast[Ptr[uint8]]("%")) != 0:
                xt_ox[t] = v / (XF_FX / 1000)
                xt_oxp[t] = 1
            else:
                xt_ox[t] = v / XF_FX
                xt_oxp[t] = 0
    # Y component (optional)
    _xf_skip()
    if _xf_i >= ve:
        return
    if _xf_word(cast[Ptr[uint8]]("top")) != 0:
        xt_oy[t] = 0
        xt_oyp[t] = 1
    elif _xf_word(cast[Ptr[uint8]]("bottom")) != 0:
        xt_oy[t] = 1000
        xt_oyp[t] = 1
    elif _xf_word(cast[Ptr[uint8]]("center")) != 0:
        xt_oy[t] = 500
        xt_oyp[t] = 1
    else:
        v2: int32 = _xf_num_fx()
        if _xf_bad == 0:
            if _xf_word(cast[Ptr[uint8]]("%")) != 0:
                xt_oy[t] = v2 / (XF_FX / 1000)
                xt_oyp[t] = 1
            else:
                xt_oy[t] = v2 / XF_FX
                xt_oyp[t] = 0


# Bind template `tid` with the inner fill `inner` into the xb_* pool; returns a
# packed XFORM_MARK value for r_bg / bfill_rgb, or `inner` unchanged on overflow.
def _xf_bind(tid: int32, inner: int32) -> int32:
    if tid < 0 or tid >= n_xtempl:
        return inner
    slot: int32 = n_xbind % XFORM_MAX
    xb_tid[slot] = tid
    xb_inner[slot] = inner
    n_xbind = n_xbind + 1
    return XFORM_MARK | (slot & 16777215)


# ---- paint-time accessors (read by htmlpage) ----
def xform_is(pv: int32) -> int32:
    if pv < 0:
        return 0
    if (pv / 16777216) & 31 == 31 and (pv / 536870912) & 3 == 1:
        return 1
    return 0

def xform_id_of(pv: int32) -> int32:
    return pv & 16777215

def xform_inner_of(bx: int32) -> int32:
    if bx < 0 or bx >= XFORM_MAX:
        return -1
    return xb_inner[bx]

def _xf_tid(bx: int32) -> int32:
    if bx < 0 or bx >= XFORM_MAX:
        return 0
    return xb_tid[bx]

def xform_a_of(bx: int32) -> int32:
    return xt_a[_xf_tid(bx)]

def xform_b_of(bx: int32) -> int32:
    return xt_b[_xf_tid(bx)]

def xform_c_of(bx: int32) -> int32:
    return xt_c[_xf_tid(bx)]

def xform_d_of(bx: int32) -> int32:
    return xt_d[_xf_tid(bx)]

def xform_e_of(bx: int32) -> int32:
    return xt_e[_xf_tid(bx)]

def xform_f_of(bx: int32) -> int32:
    return xt_f[_xf_tid(bx)]

def xform_epct_of(bx: int32) -> int32:
    return xt_epct[_xf_tid(bx)]

def xform_fpct_of(bx: int32) -> int32:
    return xt_fpct[_xf_tid(bx)]

def xform_ox_of(bx: int32) -> int32:
    return xt_ox[_xf_tid(bx)]

def xform_oxp_of(bx: int32) -> int32:
    return xt_oxp[_xf_tid(bx)]

def xform_oy_of(bx: int32) -> int32:
    return xt_oy[_xf_tid(bx)]

def xform_oyp_of(bx: int32) -> int32:
    return xt_oyp[_xf_tid(bx)]


d_center: int32 = 0         # 1 = auto side margins (centre the box)
d_fontpx: int32 = -1        # CSS font-size in px (-1 = declaration sets none)
d_lineh:  int32 = 0         # CSS line-height (0 none; >0 px; <0 -milli mult.)
d_ws:     int32 = 0         # CSS white-space (mode+1; 0 = declaration sets none)
d_ovw:    int32 = 0         # CSS overflow-wrap/word-break (mode+1; 0 = decl sets none)
d_float:  int32 = 0         # CSS float: 0 none / 1 left / 2 right
d_clear:  int32 = 0         # CSS clear: 0 none / 1 left / 2 right / 3 both
d_pos:    int32 = 0         # CSS position: 0 none / 1 relative / 2 absolute
d_top:    int32 = -1        # top/left/right/bottom offsets (px, -1 = auto)
d_left:   int32 = -1
d_right:  int32 = -1
d_bottom: int32 = -1
# CSS z-index (stacking order for positioned boxes). ZIDX_UNSET = auto/unset;
# any real integer (incl. negative) is an explicit stacking level.
ZIDX_UNSET: int32 = -2000000000
d_zidx:   int32 = -2000000000
# ROUND-2 box/flex/position declaration scratch (parsed per rule / inline style).
TINDENT_UNSET: int32 = -2000000000
d_minw:   int32 = -1          # min-width px (-1 unset)
d_ht:     int32 = -1          # height px (-1 unset)
d_minh:   int32 = -1          # min-height px (-1 unset)
d_maxh:   int32 = -1          # max-height px (-1 unset)
d_boxsz:  int32 = 0           # box-sizing: 0 unset / 1 content-box / 2 border-box
d_appear: int32 = 0           # appearance: 0 unset/auto / 1 none (this rule's value)
d_padx:   int32 = 0           # horizontal padding sum (for border-box width calc)
d_pady:   int32 = 0           # vertical padding sum (for border-box height calc)
d_bordw:  int32 = 0           # border width px PER SIDE (for border-box calc)
d_flexg:  int32 = -1          # flex-grow * 1000 (-1 unset)
d_flexs:  int32 = -1          # flex-shrink * 1000 (-1 unset)
d_flexb:  int32 = -1          # flex-basis px (-1 unset / auto)
d_posfx:  int32 = 0           # position sub-kind: 0 none / 1 fixed / 2 sticky
d_valign: int32 = 0           # vertical-align: 0 unset / 1..6
d_tindent: int32 = -2000000000       # text-indent px (TINDENT_UNSET = unset)
# CSS overflow declaration scratch (per axis): 0 visible / 1 hidden / 2 scroll /
# 3 auto / 4 clip.
d_ovfx:   int32 = 0
d_ovfy:   int32 = 0
# CSS text-overflow declaration scratch: 0 unset / 1 clip / 2 ellipsis.
d_txtovf: int32 = 0
# object-fit / object-position / aspect-ratio inline declaration scratch.
d_objfit: int32 = 0
d_objpos: int32 = 0
d_objposx: int32 = 0
d_objposxp: int32 = 1
d_objposy: int32 = 0
d_objposyp: int32 = 1
d_aspw:   int32 = 0
d_asph:   int32 = 0
# multi-length shorthand scratch (margin/padding: t r b l).
box_lens: Array[4, int32]
n_box_lens: int32 = 0


# ---- CSS length units + calc() --------------------------------------
# A cursor-based length scanner shared by _style_len and the calc() evaluator.
# _len_i walks src_ptr within [_len_i, _len_end); each _len_number() consumes one
# numeric term (optional sign, digits, optional .fraction, optional unit) and
# returns its resolved PIXEL value, advancing _len_i past the token+unit.
_len_i:   uint64 = 0
_len_end: uint64 = 0
_len_bad: int32  = 0        # set by _len_number when no numeric token was found


# Does src[i..] begin with the (already-lowercase) literal `lit`, within [i,e)?
def _unit_at(i: uint64, e: uint64, lit: Ptr[uint8]) -> int32:
    k: int32 = 0
    while lit[k] != 0:
        if i + cast[uint64](k) >= e:
            return 0
        if _hx_lower(src_ptr[i + cast[uint64](k)]) != lit[k]:
            return 0
        k = k + 1
    return 1


# Resolve a milli-length (value * 1000) with the CSS unit at src[_len_i..] to
# PIXELS, advancing _len_i past the unit. Longest units are tested first so
# `rem`/`vmin`/`vmax` are not shadowed by their shorter prefixes.
def _len_apply_unit(milli: int32) -> int32:
    i: uint64 = _len_i
    e: uint64 = _len_end
    if i < e and src_ptr[i] == 37:                   # '%' of the content column
        base: int32 = _content_right() - _left_margin()
        if base < 0:
            base = 0
        _len_i = i + 1
        return milli * base / 100000
    if _unit_at(i, e, cast[Ptr[uint8]]("vmin")) != 0:
        _len_i = i + 4
        mn: int32 = bw
        if bh < mn:
            mn = bh
        return milli * mn / 100000
    if _unit_at(i, e, cast[Ptr[uint8]]("vmax")) != 0:
        _len_i = i + 4
        mx: int32 = bw
        if bh > mx:
            mx = bh
        return milli * mx / 100000
    if _unit_at(i, e, cast[Ptr[uint8]]("rem")) != 0:
        _len_i = i + 3
        return milli * EM_PX / 1000
    if _unit_at(i, e, cast[Ptr[uint8]]("em")) != 0:
        _len_i = i + 2
        return milli * EM_PX / 1000
    if _unit_at(i, e, cast[Ptr[uint8]]("px")) != 0:
        _len_i = i + 2
        return milli / 1000
    if _unit_at(i, e, cast[Ptr[uint8]]("vw")) != 0:
        _len_i = i + 2
        return milli * bw / 100000
    if _unit_at(i, e, cast[Ptr[uint8]]("vh")) != 0:
        _len_i = i + 2
        return milli * bh / 100000
    if _unit_at(i, e, cast[Ptr[uint8]]("ch")) != 0:  # ~ one monospace cell
        _len_i = i + 2
        return milli * (EM_PX / 2) / 1000
    if _unit_at(i, e, cast[Ptr[uint8]]("pt")) != 0:  # 1pt == 4/3 px
        _len_i = i + 2
        return milli * 4 / 3 / 1000
    return milli / 1000                               # px / unitless


# Consume ONE numeric term at src[_len_i..] (optional sign, digits, optional
# .fraction to milli precision, optional unit) and return its pixel value,
# advancing _len_i. Sets _len_bad=1 (and returns 0) if no digits were present.
def _len_number() -> int32:
    i: uint64 = _len_i
    e: uint64 = _len_end
    while i < e and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    neg: int32 = 0
    if i < e and src_ptr[i] == 43:                   # '+'
        i = i + 1
    elif i < e and src_ptr[i] == 45:                 # '-'
        neg = 1
        i = i + 1
    seen: int32 = 0
    whole: int32 = 0
    while i < e and src_ptr[i] >= 48 and src_ptr[i] <= 57:
        whole = whole * 10 + cast[int32](src_ptr[i] - 48)
        seen = 1
        i = i + 1
    frac: int32 = 0
    scale: int32 = 100
    if i < e and src_ptr[i] == 46:                   # '.'
        i = i + 1
        while i < e and scale > 0 and src_ptr[i] >= 48 and src_ptr[i] <= 57:
            frac = frac + cast[int32](src_ptr[i] - 48) * scale
            scale = scale / 10
            seen = 1
            i = i + 1
    if seen == 0:
        _len_i = i
        _len_bad = 1
        return 0
    milli: int32 = whole * 1000 + frac
    _len_i = i
    px: int32 = _len_apply_unit(milli)
    if neg != 0:
        return 0 - px
    return px


# calc() recursive-descent over [_len_i, _len_end): expr := term (('+'|'-') term)*
# term := factor (('*'|'/') factor)*; factor := '(' expr ')' | number. Lengths
# resolve to px; bare numbers stay unitless so `calc(100%/3)` and `calc(2*8px)`
# both work. No unit typechecking (mixing is treated numerically).
# Evaluate a comma-separated math function whose args start at _len_i (just past
# '('): kind 0 = min(), 1 = max(), 2 = clamp(MIN,VAL,MAX). Each arg is a full
# calc expression, so min(50%, 300px) and clamp(1rem, 2vw, 2rem) both work, and
# they nest inside calc() and each other. Advances _len_i past the closing ')'.
def _len_mathfn(kind: int32) -> int32:
    acc: int32 = 0
    lo: int32 = 0
    val: int32 = 0
    hi: int32 = 0
    n: int32 = 0
    more: int32 = 1
    while more != 0:
        a: int32 = _calc_expr()
        if kind == 0:                                # min
            if n == 0 or a < acc:
                acc = a
        elif kind == 1:                              # max
            if n == 0 or a > acc:
                acc = a
        else:                                        # clamp(lo, val, hi)
            if n == 0:
                lo = a
            elif n == 1:
                val = a
            elif n == 2:
                hi = a
        n = n + 1
        while _len_i < _len_end and (src_ptr[_len_i] == 32 or \
                                     src_ptr[_len_i] == 9):
            _len_i = _len_i + 1
        if _len_i < _len_end and src_ptr[_len_i] == 44:  # ','
            _len_i = _len_i + 1
        else:
            more = 0
    while _len_i < _len_end and src_ptr[_len_i] != 41:    # to ')'
        _len_i = _len_i + 1
    if _len_i < _len_end:
        _len_i = _len_i + 1                               # past ')'
    if kind == 2:
        r: int32 = val
        if r > hi:
            r = hi
        if r < lo:
            r = lo
        return r
    return acc


def _calc_factor() -> int32:
    while _len_i < _len_end and (src_ptr[_len_i] == 32 or src_ptr[_len_i] == 9):
        _len_i = _len_i + 1
    if _unit_at(_len_i, _len_end, cast[Ptr[uint8]]("min(")) != 0:
        _len_i = _len_i + 4
        return _len_mathfn(0)
    if _unit_at(_len_i, _len_end, cast[Ptr[uint8]]("max(")) != 0:
        _len_i = _len_i + 4
        return _len_mathfn(1)
    if _unit_at(_len_i, _len_end, cast[Ptr[uint8]]("clamp(")) != 0:
        _len_i = _len_i + 6
        return _len_mathfn(2)
    if _len_i < _len_end and src_ptr[_len_i] == 40:  # '('
        _len_i = _len_i + 1
        v: int32 = _calc_expr()
        while _len_i < _len_end and src_ptr[_len_i] != 41:
            _len_i = _len_i + 1
        if _len_i < _len_end:
            _len_i = _len_i + 1                       # past ')'
        return v
    return _len_number()


def _calc_term() -> int32:
    v: int32 = _calc_factor()
    while _len_i < _len_end:
        while _len_i < _len_end and (src_ptr[_len_i] == 32 or \
                                     src_ptr[_len_i] == 9):
            _len_i = _len_i + 1
        if _len_i < _len_end and src_ptr[_len_i] == 42:      # '*'
            _len_i = _len_i + 1
            v = v * _calc_factor()
        elif _len_i < _len_end and src_ptr[_len_i] == 47:    # '/'
            _len_i = _len_i + 1
            d: int32 = _calc_factor()
            if d != 0:
                v = v / d
        else:
            break
    return v


def _calc_expr() -> int32:
    v: int32 = _calc_term()
    while _len_i < _len_end:
        while _len_i < _len_end and (src_ptr[_len_i] == 32 or \
                                     src_ptr[_len_i] == 9):
            _len_i = _len_i + 1
        if _len_i < _len_end and src_ptr[_len_i] == 43:      # '+'
            _len_i = _len_i + 1
            v = v + _calc_term()
        elif _len_i < _len_end and src_ptr[_len_i] == 45:    # '-'
            _len_i = _len_i + 1
            v = v - _calc_term()
        else:
            break
    return v


# Parse a CSS length from src[vs..ve) into PIXELS. Honours px / em / rem / % / vw
# / vh / vmin / vmax / ch / pt units, decimal values, a leading sign, and
# `calc(...)`. % is of the body content column (bw - 2*CONTENT_X); em/rem ==
# EM_PX px. Returns the pixel value, or -1 when there is no numeric prefix
# (auto/none/inherit/...).
def _style_len(vs: uint64, ve: uint64) -> int32:
    i: uint64 = vs
    while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    if _unit_at(i, ve, cast[Ptr[uint8]]("calc(")) != 0:
        j: uint64 = i + 5
        _len_i = j
        _len_end = ve
        return _calc_expr()
    # bare math functions as a whole length value: min()/max()/clamp().
    if _unit_at(i, ve, cast[Ptr[uint8]]("min(")) != 0:
        _len_i = i + 4
        _len_end = ve
        return _len_mathfn(0)
    if _unit_at(i, ve, cast[Ptr[uint8]]("max(")) != 0:
        _len_i = i + 4
        _len_end = ve
        return _len_mathfn(1)
    if _unit_at(i, ve, cast[Ptr[uint8]]("clamp(")) != 0:
        _len_i = i + 6
        _len_end = ve
        return _len_mathfn(2)
    _len_i = i
    _len_end = ve
    _len_bad = 0
    v: int32 = _len_number()
    if _len_bad != 0:
        return -1
    return v


# Parse a CSS z-index: an optional-sign integer (may be negative). Returns the
# value, or ZIDX_UNSET when the value is `auto`/empty/non-numeric.
def _zindex_value(vs: uint64, ve: uint64) -> int32:
    i: uint64 = vs
    while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    neg: int32 = 0
    if i < ve and src_ptr[i] == 45:                      # '-'
        neg = 1
        i = i + 1
    seen: int32 = 0
    v: int32 = 0
    while i < ve:
        d: uint8 = src_ptr[i]
        if d >= 48 and d <= 57:
            v = v * 10 + cast[int32](d - 48)
            seen = 1
            i = i + 1
        else:
            break
    if seen == 0:
        return ZIDX_UNSET
    if neg != 0:
        return 0 - v
    return v


# Parse a CSS line-height value from src[vs..ve) into the r_lineh/d_lineh
# encoding: 0 = none/normal/unparseable; >0 = absolute PIXELS (px/em); <0 =
# unitless number or percentage as a milli-multiplier, negated, resolved against
# the element font-size later (1.5 -> -1500; 1.4em -> +22px; 150% -> -1500;
# 24px -> +24). Handles up to 3 fractional digits so "1.5"/"2.0" round-trip.
def _lineh_value(vs: uint64, ve: uint64) -> int32:
    i: uint64 = vs
    while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    seen: int32 = 0
    whole: int32 = 0
    while i < ve:
        d: uint8 = src_ptr[i]
        if d >= 48 and d <= 57:
            whole = whole * 10 + cast[int32](d - 48)
            seen = 1
            i = i + 1
        else:
            break
    frac: int32 = 0          # milli fraction (0..999)
    scale: int32 = 100
    if i < ve and src_ptr[i] == 46:                  # '.'
        i = i + 1
        while i < ve and scale > 0:
            d2: uint8 = src_ptr[i]
            if d2 >= 48 and d2 <= 57:
                frac = frac + cast[int32](d2 - 48) * scale
                scale = scale / 10
                seen = 1
                i = i + 1
            else:
                break
    if seen == 0:
        return 0                                      # "normal" / unparseable
    milli: int32 = whole * 1000 + frac
    if i < ve and src_ptr[i] == 37:                  # '%' of font-size
        return -(milli / 100)
    if i + 1 < ve and _hx_lower(src_ptr[i]) == 112 and _hx_lower(src_ptr[i + 1]) == 120:
        return milli / 1000                           # 'px' -> px
    if i + 1 < ve and _hx_lower(src_ptr[i]) == 101 and _hx_lower(src_ptr[i + 1]) == 109:
        return milli * EM_PX / 1000                   # 'em' -> px
    return -milli                                     # unitless multiplier


# Resolve the r_lineh/d_lineh encoding to absolute PIXELS given the element's
# effective font-size (0 = use EM_PX default). 0 in -> 0 out (unset).
def _lineh_resolve(enc: int32, font_px: int32) -> int32:
    if enc == 0:
        return 0
    if enc > 0:
        return enc                                    # already px
    base: int32 = font_px
    if base <= 0:
        base = EM_PX
    return (-enc) * base / 1000                       # unitless/% multiplier


# Parse a CSS `white-space` keyword from src[vs..ve) into the mode+1 encoding
# (0 = unrecognised / sets none): 1 normal, 2 nowrap, 3 pre, 4 pre-wrap. Longer
# keywords are tested before their prefixes so "pre-wrap" is not eaten by "pre".
# `pre-line` (collapse spaces, keep newlines) has no dedicated flow mode here;
# we treat it as `normal` so it does NOT wrongly preserve the spaces.
def _ws_value(vs: uint64, ve: uint64) -> int32:
    s: uint64 = _val_start(vs, ve)
    if _val_starts(s, ve, cast[Ptr[uint8]]("pre-wrap")) != 0:
        return 4
    if _val_starts(s, ve, cast[Ptr[uint8]]("pre-line")) != 0:
        return 1
    if _val_starts(s, ve, cast[Ptr[uint8]]("pre")) != 0:
        return 3
    if _val_starts(s, ve, cast[Ptr[uint8]]("nowrap")) != 0:
        return 2
    if _val_starts(s, ve, cast[Ptr[uint8]]("normal")) != 0:
        return 1
    return 0


# Parse a CSS overflow-wrap / word-wrap / word-break value from src[vs..ve) into
# the mode+1 encoding (0 = unrecognised / sets none): 1 normal, 2 break. The
# breaking keywords (`break-word`, `anywhere` for overflow-wrap/word-wrap;
# `break-all` for word-break) all map to 2; `normal` / `keep-all` map to 1.
def _ovw_value(vs: uint64, ve: uint64) -> int32:
    s: uint64 = _val_start(vs, ve)
    if _val_starts(s, ve, cast[Ptr[uint8]]("break-word")) != 0:
        return 2
    if _val_starts(s, ve, cast[Ptr[uint8]]("break-all")) != 0:
        return 2
    if _val_starts(s, ve, cast[Ptr[uint8]]("anywhere")) != 0:
        return 2
    if _val_starts(s, ve, cast[Ptr[uint8]]("keep-all")) != 0:
        return 1
    if _val_starts(s, ve, cast[Ptr[uint8]]("normal")) != 0:
        return 1
    return 0


def _is_alpha(c: uint8) -> int32:
    lc: uint8 = _hx_lower(c)
    if lc >= 97 and lc <= 122:
        return 1
    return 0


def _is_name_ch(c: uint8) -> int32:
    lc: uint8 = _hx_lower(c)
    if (lc >= 97 and lc <= 122) or (c >= 48 and c <= 57) or c == 45 or c == 95:
        return 1
    return 0


# Copy src[a..b) lowercased into css_sbuf; sets g_store_off/g_store_len.
def _css_store(a: uint64, b: uint64):
    g_store_off = cast[int32](css_slen)
    i: uint64 = a
    while i < b and css_slen < CSS_STR_CAP - 1:
        css_sbuf[css_slen] = _hx_lower(src_ptr[i])
        css_slen = css_slen + 1
        i = i + 1
    g_store_len = cast[int32](css_slen) - g_store_off


# Compare src[a..b) (whitespace-trimmed, lowercased) against literal `lit`.
def _prop_is(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    while a < b and _css_ws(src_ptr[a]) != 0:
        a = a + 1
    while b > a and _css_ws(src_ptr[b - 1]) != 0:
        b = b - 1
    i: uint64 = 0
    while lit[i] != 0:
        if a + i >= b:
            return 0
        if _hx_lower(src_ptr[a + i]) != lit[i]:
            return 0
        i = i + 1
    if a + i != b:
        return 0
    return 1


# Does the value src[a..b) begin (after whitespace) with literal `lit`?
def _val_starts(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    while a < b and _css_ws(src_ptr[a]) != 0:
        a = a + 1
    return _srcword_is(a, lit)


# Does the value src[a..b) contain the token `auto` (e.g. `margin: 0 auto`, or a
# bare `margin-left: auto`)? Drives centred-block detection.
def _val_has_auto(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i + 4 <= b:
        if _hx_lower(src_ptr[i]) == 97 and _hx_lower(src_ptr[i + 1]) == 117 and \
           _hx_lower(src_ptr[i + 2]) == 116 and _hx_lower(src_ptr[i + 3]) == 111:
            return 1
        i = i + 1
    return 0


# Does the value src[a..b) contain `lit` as a whole space-delimited word? Used
# for shorthand values like `list-style: none inside` where the keyword we care
# about is not necessarily first.
def _val_has_word(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    i: uint64 = a
    while i < b:
        while i < b and _css_ws(src_ptr[i]) != 0:
            i = i + 1
        s: uint64 = i
        while i < b and _css_ws(src_ptr[i]) == 0:
            i = i + 1
        if i > s and _srcword_is(s, lit) != 0:
            return 1
    return 0


# Parse a `grid-auto-flow` value src[a..b) into the packed bitfield: bit2(4) is
# always set (marks it explicitly authored so `!= 0` means "set"), bit0(1) when the
# `column` axis token is present, bit1(2) when the `dense` packing token is present.
# Tokens may appear in either order (`row dense`, `dense column`, `column`, `dense`).
def _grid_auto_flow_value(a: uint64, b: uint64) -> int32:
    v: int32 = 4
    if _val_has_word(a, b, cast[Ptr[uint8]]("column")) != 0:
        v = v | 1
    if _val_has_word(a, b, cast[Ptr[uint8]]("dense")) != 0:
        v = v | 2
    return v


# Does property name src[a..b) (trimmed) start with literal `lit`? Used to tell
# `margin` (shorthand) / `margin-left` (side) apart without over-matching.
def _prop_prefix(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    while a < b and _css_ws(src_ptr[a]) != 0:
        a = a + 1
    while b > a and _css_ws(src_ptr[b - 1]) != 0:
        b = b - 1
    i: uint64 = 0
    while lit[i] != 0:
        if a + i >= b:
            return 0
        if _hx_lower(src_ptr[a + i]) != lit[i]:
            return 0
        i = i + 1
    return 1


# Does the trimmed property name src[a..b) END with literal `lit`? (Used to tell
# a per-side border shorthand `border-top` from its `-width`/`-style`/`-color`/
# `-radius` longhands.)
def _prop_suffix(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    while a < b and _css_ws(src_ptr[a]) != 0:
        a = a + 1
    while b > a and _css_ws(src_ptr[b - 1]) != 0:
        b = b - 1
    n: uint64 = 0
    while lit[n] != 0:
        n = n + 1
    if b - a < n:
        return 0
    i: uint64 = 0
    while i < n:
        if _hx_lower(src_ptr[b - n + i]) != lit[i]:
            return 0
        i = i + 1
    return 1


# Accumulate one side inset (margin/padding on that side sum into one column).
def _box_add_l(px: int32):
    if px < 0:
        return
    if d_ml < 0:
        d_ml = 0
    d_ml = d_ml + px


def _box_add_r(px: int32):
    if px < 0:
        return
    if d_mr < 0:
        d_mr = 0
    d_mr = d_mr + px


def _box_add_t(px: int32):
    if px < 0:
        return
    if d_mt < 0:
        d_mt = 0
    d_mt = d_mt + px


def _box_add_b(px: int32):
    if px < 0:
        return
    if d_mb < 0:
        d_mb = 0
    d_mb = d_mb + px


# Parse the space-separated length list of a margin/padding shorthand into
# box_lens[0..n_box_lens); non-length tokens (should not occur here) are skipped.
def _parse_box_lens(vs: uint64, ve: uint64):
    n_box_lens = 0
    i: uint64 = vs
    while i < ve and n_box_lens < 4:
        while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
            i = i + 1
        if i >= ve:
            break
        ts: uint64 = i
        while i < ve and src_ptr[i] != 32 and src_ptr[i] != 9:
            i = i + 1
        px: int32 = _style_len(ts, i)
        if px >= 0:
            box_lens[n_box_lens] = px
            n_box_lens = n_box_lens + 1


# Apply a `margin:`/`padding:` shorthand (1..4 lengths, CSS TRBL rules) into the
# left/right/top/bottom insets.
def _box_shorthand(vs: uint64, ve: uint64):
    _parse_box_lens(vs, ve)
    if n_box_lens == 0:
        return
    t: int32 = box_lens[0]
    r: int32 = box_lens[0]
    bo: int32 = box_lens[0]
    l: int32 = box_lens[0]
    if n_box_lens >= 2:
        r = box_lens[1]
        l = box_lens[1]
    if n_box_lens >= 3:
        bo = box_lens[2]
    if n_box_lens >= 4:
        l = box_lens[3]
    _box_add_t(t)
    _box_add_r(r)
    _box_add_b(bo)
    _box_add_l(l)


# ---- ROUND-2 flex / vertical-align helpers --------------------------
# Parse a unitless flex factor src[a..b) (e.g. "1", "0", "2.5") to milli
# (1 -> 1000, 0.5 -> 500). No token -> 0.
def _flexnum_milli(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    whole: int32 = 0
    seen: int32 = 0
    while i < b and src_ptr[i] >= 48 and src_ptr[i] <= 57:
        whole = whole * 10 + cast[int32](src_ptr[i] - 48)
        seen = 1
        i = i + 1
    frac: int32 = 0
    scale: int32 = 100
    if i < b and src_ptr[i] == 46:                       # '.'
        i = i + 1
        while i < b and scale > 0 and src_ptr[i] >= 48 and src_ptr[i] <= 57:
            frac = frac + cast[int32](src_ptr[i] - 48) * scale
            scale = scale / 10
            seen = 1
            i = i + 1
    if seen == 0:
        return 0
    return whole * 1000 + frac


# Does token src[a..b) carry a unit/percent letter (i.e. is a LENGTH, not a bare
# flex factor)? `auto`/`content` are handled by the caller before this.
def _tok_has_unit(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i < b:
        c: uint8 = src_ptr[i]
        if _is_alpha(c) != 0 or c == 37:                 # letter or '%'
            return 1
        i = i + 1
    return 0


# flex-basis: a length pins the item main-size (and, so the current width path
# shows it, seeds d_wd when no explicit width is set). `auto`/`content` leave the
# basis unset (-1).
def _flex_basis_set(vs: uint64, ve: uint64):
    if _val_starts(vs, ve, cast[Ptr[uint8]]("auto")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("content")) != 0:
        return
    px: int32 = _style_len(vs, ve)
    if px >= 0:
        d_flexb = px
        if d_wd < 0:
            d_wd = px


# `flex` shorthand: `none` | `auto` | <grow> [<shrink>] [<basis>] | <basis>.
# Unitless numbers fill grow then shrink; a length (or the special keywords) is
# the basis.
def _flex_shorthand(vs: uint64, ve: uint64):
    if _val_starts(vs, ve, cast[Ptr[uint8]]("none")) != 0:
        d_flexg = 0
        d_flexs = 0
        return
    if _val_starts(vs, ve, cast[Ptr[uint8]]("auto")) != 0:
        d_flexg = 1000
        d_flexs = 1000
        return
    numi: int32 = 0
    basis_set: int32 = 0
    i: uint64 = vs
    while i < ve:
        while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
            i = i + 1
        if i >= ve:
            break
        ts: uint64 = i
        while i < ve and src_ptr[i] != 32 and src_ptr[i] != 9:
            i = i + 1
        te: uint64 = i
        if _val_starts(ts, te, cast[Ptr[uint8]]("auto")) != 0 or \
           _val_starts(ts, te, cast[Ptr[uint8]]("content")) != 0:
            basis_set = 1                                 # explicit auto basis
            continue
        if _tok_has_unit(ts, te) != 0:
            _flex_basis_set(ts, te)
            basis_set = 1
        else:
            m: int32 = _flexnum_milli(ts, te)
            if numi == 0:
                d_flexg = m
                numi = 1
            elif numi == 1:
                d_flexs = m
                numi = 2
    # A numeric-only `flex:<grow>` (no basis token) resolves flex-basis to 0 per
    # spec (`flex:1` == `1 1 0`), so equal grow factors yield EQUAL widths — the
    # same resolution the inline-style path (_flx_parse_shorthand) applies.
    if numi >= 1 and basis_set == 0:
        d_flexb = 0


# vertical-align keyword -> 1 baseline / 2 top / 3 middle / 4 bottom / 5 sub /
# 6 super (text-top -> top, text-bottom -> bottom). 0 = unrecognised/unset.
def _valign_value(vs: uint64, ve: uint64) -> int32:
    if _val_starts(vs, ve, cast[Ptr[uint8]]("baseline")) != 0:
        return 1
    if _val_starts(vs, ve, cast[Ptr[uint8]]("top")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("text-top")) != 0:
        return 2
    if _val_starts(vs, ve, cast[Ptr[uint8]]("middle")) != 0:
        return 3
    if _val_starts(vs, ve, cast[Ptr[uint8]]("bottom")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("text-bottom")) != 0:
        return 4
    if _val_starts(vs, ve, cast[Ptr[uint8]]("sub")) != 0:
        return 5
    if _val_starts(vs, ve, cast[Ptr[uint8]]("super")) != 0:
        return 6
    return 0


# Map an `overflow`/`overflow-x`/`overflow-y` value to its code: 0 visible
# (default, no clip) / 1 hidden / 2 scroll / 3 auto / 4 clip. `overlay` (a legacy
# alias of auto) folds to auto. Anything else (incl. `visible`) is 0.
def _overflow_value(vs: uint64, ve: uint64) -> int32:
    if _val_starts(vs, ve, cast[Ptr[uint8]]("hidden")) != 0:
        return 1
    if _val_starts(vs, ve, cast[Ptr[uint8]]("scroll")) != 0:
        return 2
    if _val_starts(vs, ve, cast[Ptr[uint8]]("auto")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("overlay")) != 0:
        return 3
    if _val_starts(vs, ve, cast[Ptr[uint8]]("clip")) != 0:
        return 4
    return 0                                          # visible / unknown


# ---- CSS filter --------------------------------------------------------------
# Parse a CSS `filter` value src[vs..ve) into a packed int32: (type << 20) |
# amount. type: 0 none, 1 grayscale, 2 brightness, 3 invert, 4 sepia,
# 5 contrast, 6 blur, 7 saturate, 8 opacity, 9 drop-shadow, 10 hue-rotate.
# amount is a percent 0..~1000 for the colour filters (grayscale(0.5)==
# grayscale(50%)==50), a pixel radius for blur, or degrees (0..360) for
# hue-rotate. A filter FUNCTION LIST (`filter: grayscale(1) brightness(1.2)`)
# now CHAINS: multiple functions are interned into a small registry and the value
# carries FILT_LIST_MARK|index; a SINGLE function still returns its bare packed
# int (byte-identical to before). `none`/unknown => 0. drop-shadow is recognised
# but still painted as a no-op (its offset/blur/colour args are not modelled).
FILT_GRAYSCALE: int32 = 1
FILT_BRIGHTNESS: int32 = 2
FILT_INVERT: int32 = 3
FILT_SEPIA: int32 = 4
FILT_CONTRAST: int32 = 5
FILT_BLUR: int32 = 6
FILT_SATURATE: int32 = 7
FILT_OPACITY: int32 = 8
FILT_DROPSHADOW: int32 = 9
FILT_HUEROTATE: int32 = 10
# filter FUNCTION-LIST registry: a chained `filter:` value ( >= 2 functions) is
# interned here; the packed value carries FILT_LIST_MARK|regindex. FILT_LIST_MARK
# is bit 28 — above the 4-bit type (bits 20-23) + 20-bit amount, so it can never
# collide with a single packed filter. htmlpage reads the list back (he_filter_*)
# and applies each function in order (chaining is sequential over the rect).
FILT_LIST_MARK: int32 = 268435456           # 1 << 28
FILT_MAX: int32 = 8                          # functions per chained filter
FILT_REG_CAP: int32 = 64                     # distinct chained-filter values / page
filt_reg_items: Array[512, int32]            # FILT_REG_CAP * FILT_MAX packed funcs
filt_reg_len:   Array[64, int32]             # function count per interned list
filt_reg_n:     int32 = 0                     # next free registry slot (per page)


# Is a packed filter value a chained LIST (vs a single function / 0 none)?
def he_filter_is_list(fpk: int32) -> int32:
    if (fpk & FILT_LIST_MARK) != 0:
        return 1
    return 0


# Number of functions in the chained filter list `fpk` carries.
def he_filter_list_len(fpk: int32) -> int32:
    idx: int32 = fpk & 65535
    if idx < 0 or idx >= FILT_REG_CAP:
        return 0
    return filt_reg_len[idx]


# The k-th packed function of the chained filter list `fpk` carries.
def he_filter_list_at(fpk: int32, k: int32) -> int32:
    idx: int32 = fpk & 65535
    if idx < 0 or idx >= FILT_REG_CAP or k < 0 or k >= FILT_MAX:
        return 0
    return filt_reg_items[idx * FILT_MAX + k]


# Parse a numeric argument at src[i..ve): returns amount as PERCENT (a bare
# number is *100, a %-suffixed number is as-written) unless as_px!=0, in which
# case the integer pixel value is returned. Handles one decimal place.
def _filter_num(i: uint64, ve: uint64, as_px: int32) -> int32:
    while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    whole: int32 = 0
    frac: int32 = 0        # first two decimal digits, 0..99
    fdigits: int32 = 0
    seen: int32 = 0
    dot: int32 = 0
    while i < ve:
        c: uint8 = src_ptr[i]
        if c >= 48 and c <= 57:
            if dot == 0:
                whole = whole * 10 + cast[int32](c - 48)
            else:
                if fdigits < 2:
                    frac = frac * 10 + cast[int32](c - 48)
                    fdigits = fdigits + 1
            seen = 1
            i = i + 1
        elif c == 46:                                    # '.'
            dot = 1
            i = i + 1
        else:
            break
    if seen == 0:
        return -1
    while fdigits < 2:
        frac = frac * 10
        fdigits = fdigits + 1
    # is there a '%' after the number?
    j: uint64 = i
    while j < ve and (src_ptr[j] == 32 or src_ptr[j] == 9):
        j = j + 1
    is_pct: int32 = 0
    if j < ve and src_ptr[j] == 37:                      # '%'
        is_pct = 1
    if as_px != 0:
        return whole                                     # blur px (ignore frac)
    # percent result. hundredths = whole*100 + frac.
    if is_pct != 0:
        return whole                                     # "50%" => 50
    # bare number: grayscale(0.5) => 50%, grayscale(1) => 100%.
    return whole * 100 + frac


# Recognise ONE filter function at src[i..ve): match `name(` then parse its arg.
# Returns the packed (type<<20)|amount, or -1 if `i` is not at a known function.
def _filter_one(i: uint64, ve: uint64) -> int32:
    if _unit_at(i, ve, cast[Ptr[uint8]]("grayscale(")) != 0:
        return (FILT_GRAYSCALE << 20) | (_filter_num(i + 10, ve, 0) & 0xFFFFF)
    if _unit_at(i, ve, cast[Ptr[uint8]]("brightness(")) != 0:
        return (FILT_BRIGHTNESS << 20) | (_filter_num(i + 11, ve, 0) & 0xFFFFF)
    if _unit_at(i, ve, cast[Ptr[uint8]]("invert(")) != 0:
        return (FILT_INVERT << 20) | (_filter_num(i + 7, ve, 0) & 0xFFFFF)
    if _unit_at(i, ve, cast[Ptr[uint8]]("sepia(")) != 0:
        return (FILT_SEPIA << 20) | (_filter_num(i + 6, ve, 0) & 0xFFFFF)
    if _unit_at(i, ve, cast[Ptr[uint8]]("contrast(")) != 0:
        return (FILT_CONTRAST << 20) | (_filter_num(i + 9, ve, 0) & 0xFFFFF)
    if _unit_at(i, ve, cast[Ptr[uint8]]("saturate(")) != 0:
        return (FILT_SATURATE << 20) | (_filter_num(i + 9, ve, 0) & 0xFFFFF)
    if _unit_at(i, ve, cast[Ptr[uint8]]("opacity(")) != 0:
        return (FILT_OPACITY << 20) | (_filter_num(i + 8, ve, 0) & 0xFFFFF)
    if _unit_at(i, ve, cast[Ptr[uint8]]("blur(")) != 0:
        return (FILT_BLUR << 20) | (_filter_num(i + 5, ve, 1) & 0xFFFFF)
    if _unit_at(i, ve, cast[Ptr[uint8]]("hue-rotate(")) != 0:
        deg: int32 = _filter_num(i + 11, ve, 1) & 0xFFFFF     # integer degrees
        while deg < 0:
            deg = deg + 360
        while deg >= 360:
            deg = deg - 360
        return (FILT_HUEROTATE << 20) | deg
    if _unit_at(i, ve, cast[Ptr[uint8]]("drop-shadow(")) != 0:
        return FILT_DROPSHADOW << 20
    return -1


# Parse a CSS `filter` value src[vs..ve): a whitespace-separated LIST of filter
# functions. A SINGLE function returns its bare packed int (byte-identical to the
# pre-list behaviour); TWO OR MORE intern into the registry and return
# FILT_LIST_MARK|regindex so htmlpage chains them. `none` / no recognised
# function => 0.
def _filter_value(vs: uint64, ve: uint64) -> int32:
    i: uint64 = vs
    while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    if _unit_at(i, ve, cast[Ptr[uint8]]("none")) != 0:
        return 0
    first: int32 = 0
    cnt: int32 = 0
    slot: int32 = filt_reg_n
    have_slot: int32 = 0
    if slot < FILT_REG_CAP:
        have_slot = 1
    while i < ve and cnt < FILT_MAX:
        while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9):
            i = i + 1
        if i >= ve:
            break
        pk: int32 = _filter_one(i, ve)
        # advance the cursor past this function's closing ')'.
        while i < ve and src_ptr[i] != 41:
            i = i + 1
        if i < ve:
            i = i + 1
        if pk >= 0:
            if cnt == 0:
                first = pk
            if have_slot != 0:
                filt_reg_items[slot * FILT_MAX + cnt] = pk
            cnt = cnt + 1
    if cnt == 0:
        return 0
    if cnt == 1:
        return first                                 # single function (legacy)
    if have_slot == 0:
        return first                                 # registry full — degrade
    filt_reg_len[slot] = cnt
    filt_reg_n = slot + 1
    return FILT_LIST_MARK | slot


# ---- true per-side border (W3C css-backgrounds §4) -------------------
# Map a border-style keyword found ANYWHERE in the value to a code, else -1:
#   0 solid  1 dashed  2 dotted  3 double  4 none/hidden.
# groove/ridge/inset/outset are accepted but rendered as solid (no bevel model).
def _bord_style_code(vs: uint64, ve: uint64) -> int32:
    if _val_has_word(vs, ve, cast[Ptr[uint8]]("none")) != 0 or \
       _val_has_word(vs, ve, cast[Ptr[uint8]]("hidden")) != 0:
        return 4
    if _val_has_word(vs, ve, cast[Ptr[uint8]]("dashed")) != 0:
        return 1
    if _val_has_word(vs, ve, cast[Ptr[uint8]]("dotted")) != 0:
        return 2
    if _val_has_word(vs, ve, cast[Ptr[uint8]]("double")) != 0:
        return 3
    if _val_has_word(vs, ve, cast[Ptr[uint8]]("solid")) != 0 or \
       _val_has_word(vs, ve, cast[Ptr[uint8]]("groove")) != 0 or \
       _val_has_word(vs, ve, cast[Ptr[uint8]]("ridge")) != 0 or \
       _val_has_word(vs, ve, cast[Ptr[uint8]]("inset")) != 0 or \
       _val_has_word(vs, ve, cast[Ptr[uint8]]("outset")) != 0:
        return 0
    return -1


# Clamp a border width to the 0..120 byte range the packed value carries (keeps
# the packed int positive so extraction can divide, dodging signed >>).
def _bordw_clamp(w: int32) -> int32:
    if w < 0:
        return 0
    if w > 120:
        return 120
    return w


# Pack the per-side width scratch (d_bw_*) into one int: top | right<<8 |
# bottom<<16 | left<<24. An unset (<0) or zero side contributes 0 (not drawn).
def _packed_bordw() -> int32:
    p: int32 = 0
    if d_bw_t > 0:
        p = p | _bordw_clamp(d_bw_t)
    if d_bw_r > 0:
        p = p | (_bordw_clamp(d_bw_r) << 8)
    if d_bw_b > 0:
        p = p | (_bordw_clamp(d_bw_b) << 16)
    if d_bw_l > 0:
        p = p | (_bordw_clamp(d_bw_l) << 24)
    return p


# One side's style nibble: (code+1) so 0 reads as "unset -> default solid".
def _bord_style_nib(code: int32) -> int32:
    if code < 0:
        return 0
    return (code + 1) & 15


# Pack the per-side style scratch (d_bs_*): top | right<<4 | bottom<<8 | left<<12.
def _packed_bords() -> int32:
    p: int32 = 0
    p = p | _bord_style_nib(d_bs_t)
    p = p | (_bord_style_nib(d_bs_r) << 4)
    p = p | (_bord_style_nib(d_bs_b) << 8)
    p = p | (_bord_style_nib(d_bs_l) << 12)
    return p


# Recompute the packed per-side globals box.ad reads (inline wins over sheet the
# same way d_bordc does). Called after any per-side longhand mutates the scratch.
def _sync_bordps():
    d_bordps = _packed_bordw()
    d_bordss = _packed_bords()


# Set width `w` on side s (0=top 1=right 2=bottom 3=left). w<0 leaves it unset.
def _set_side_w(s: int32, w: int32):
    if s == 0:
        d_bw_t = w
    elif s == 1:
        d_bw_r = w
    elif s == 2:
        d_bw_b = w
    elif s == 3:
        d_bw_l = w


def _set_side_s(s: int32, code: int32):
    if s == 0:
        d_bs_t = code
    elif s == 1:
        d_bs_r = code
    elif s == 2:
        d_bs_b = code
    elif s == 3:
        d_bs_l = code


# Set border colour `c` (0xRRGGBB) on side s (0=top 1=right 2=bottom 3=left).
def _set_side_bc(s: int32, c: int32):
    if s == 0:
        d_bc_t = c
    elif s == 1:
        d_bc_r = c
    elif s == 2:
        d_bc_b = c
    elif s == 3:
        d_bc_l = c


# When the FIRST per-side longhand of a declaration block runs and a uniform
# `border:` already turned the box on (d_bd==1) with a width, seed the OTHER
# sides from that uniform so `border:2px solid; border-bottom:5px dashed` keeps
# 2px solid on the untouched three sides. No-op when only per-side is declared.
def _seed_sides_from_uniform():
    if d_bordps == 0 and d_bd == 1:
        uw: int32 = d_bordw
        if uw <= 0:
            uw = 1
        if d_bw_t < 0:
            d_bw_t = uw
        if d_bw_r < 0:
            d_bw_r = uw
        if d_bw_b < 0:
            d_bw_b = uw
        if d_bw_l < 0:
            d_bw_l = uw
        if d_bs_t < 0:
            d_bs_t = 0
        if d_bs_r < 0:
            d_bs_r = 0
        if d_bs_b < 0:
            d_bs_b = 0
        if d_bs_l < 0:
            d_bs_l = 0


# Split a `border-width` shorthand (1..4 lengths, CSS TRBL) into d_bw_*.
def _border_width_shorthand(vs: uint64, ve: uint64) -> int32:
    _seed_sides_from_uniform()
    _parse_box_lens(vs, ve)
    if n_box_lens == 0:
        return 1
    t: int32 = box_lens[0]
    r: int32 = box_lens[0]
    bo: int32 = box_lens[0]
    l: int32 = box_lens[0]
    if n_box_lens >= 2:
        r = box_lens[1]
        l = box_lens[1]
    if n_box_lens >= 3:
        bo = box_lens[2]
    if n_box_lens >= 4:
        l = box_lens[3]
    d_bw_t = t
    d_bw_r = r
    d_bw_b = bo
    d_bw_l = l
    if t > 0 or r > 0 or bo > 0 or l > 0:
        d_bd = 1
        if d_bordw <= 0:
            d_bordw = t
    _sync_bordps()
    return 1


# Split a `border-style` shorthand (1..4 keywords, CSS TRBL) into d_bs_*. A side
# whose style is `none` also zeroes that side's width.
def _border_style_shorthand(vs: uint64, ve: uint64) -> int32:
    _seed_sides_from_uniform()
    # tokenise up to 4 style words.
    n: int32 = 0
    c0: int32 = 0
    c1: int32 = 0
    c2: int32 = 0
    c3: int32 = 0
    i: uint64 = vs
    while i < ve and n < 4:
        while i < ve and _css_ws(src_ptr[i]) != 0:
            i = i + 1
        if i >= ve:
            break
        ts: uint64 = i
        while i < ve and _css_ws(src_ptr[i]) == 0:
            i = i + 1
        code: int32 = _bord_style_code(ts, i)
        if code < 0:
            code = 0
        if n == 0:
            c0 = code
        elif n == 1:
            c1 = code
        elif n == 2:
            c2 = code
        else:
            c3 = code
        n = n + 1
    if n == 0:
        return 1
    st: int32 = c0
    sr: int32 = c0
    sb: int32 = c0
    sl: int32 = c0
    if n >= 2:
        sr = c1
        sl = c1
    if n >= 3:
        sb = c2
    if n >= 4:
        sl = c3
    _apply_side_style(0, st)
    _apply_side_style(1, sr)
    _apply_side_style(2, sb)
    _apply_side_style(3, sl)
    _sync_bordps()
    return 1


# Split a `border-color` shorthand (1..4 colours, CSS TRBL) into d_bc_*. Tokens
# are whitespace-separated but PAREN-AWARE so an `rgb(0, 0, 0)` stays one token.
# The first colour also seeds the uniform fallback (d_bordc) so a legacy uniform
# stroke keeps its colour; unrecognised tokens are skipped (leave that side unset).
def _border_color_shorthand(vs: uint64, ve: uint64) -> int32:
    _seed_sides_from_uniform()
    c0: int32 = -1
    c1: int32 = -1
    c2: int32 = -1
    c3: int32 = -1
    n: int32 = 0
    i: uint64 = vs
    while i < ve and n < 4:
        while i < ve and _css_ws(src_ptr[i]) != 0:
            i = i + 1
        if i >= ve:
            break
        ts: uint64 = i
        depth: int32 = 0
        while i < ve and (depth != 0 or _css_ws(src_ptr[i]) == 0):
            if src_ptr[i] == 40:                 # '('
                depth = depth + 1
            elif src_ptr[i] == 41:               # ')'
                depth = depth - 1
            i = i + 1
        col: int32 = _bg_shorthand_color(ts, i)
        if n == 0:
            c0 = col
        elif n == 1:
            c1 = col
        elif n == 2:
            c2 = col
        else:
            c3 = col
        n = n + 1
    if n == 0:
        return 1
    ct: int32 = c0
    cr: int32 = c0
    cb: int32 = c0
    cl: int32 = c0
    if n >= 2:
        cr = c1
        cl = c1
    if n >= 3:
        cb = c2
    if n >= 4:
        cl = c3
    _set_side_bc(0, ct)
    _set_side_bc(1, cr)
    _set_side_bc(2, cb)
    _set_side_bc(3, cl)
    if c0 >= 0:
        d_bordc = c0                             # uniform fallback (legacy stroke)
    return 1


# Apply a resolved style code to side s: `none` (4) kills the side's width; any
# drawn style with no width yet defaults to the CSS `medium` (~3px) and turns the
# box on.
def _apply_side_style(s: int32, code: int32):
    _set_side_s(s, code)
    if code == 4:
        _set_side_w(s, 0)
    else:
        if _side_w(s) < 0:
            _set_side_w(s, 3)
        d_bd = 1


def _side_w(s: int32) -> int32:
    if s == 0:
        return d_bw_t
    if s == 1:
        return d_bw_r
    if s == 2:
        return d_bw_b
    return d_bw_l


# border-<side>[-width|-style|-color] longhand. `sub`: 0 shorthand, 1 width,
# 2 style, 3 color.
def _border_side_decl(side: int32, sub: int32, vs: uint64, ve: uint64) -> int32:
    _seed_sides_from_uniform()
    if sub == 1:
        w: int32 = _style_len(vs, ve)
        if w >= 0:
            _set_side_w(side, w)
            if w > 0:
                d_bd = 1
                if d_bordw <= 0:
                    d_bordw = w
        _sync_bordps()
        return 1
    if sub == 2:
        code: int32 = _bord_style_code(vs, ve)
        if code < 0:
            code = 0
        _apply_side_style(side, code)
        _sync_bordps()
        return 1
    if sub == 3:
        cc: int32 = _bg_shorthand_color(vs, ve)
        if cc >= 0:
            _set_side_bc(side, cc)                # this side's own colour
            if d_bordc < 0:                       # seed uniform fallback ONLY if
                d_bordc = cc                      # no uniform colour set yet
        return 1
    # shorthand: `border-<side>: <width> || <style> || <color>`.
    if _val_starts(vs, ve, cast[Ptr[uint8]]("none")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("hidden")) != 0:
        _set_side_w(side, 0)
        _set_side_s(side, 4)
        _sync_bordps()
        return 1
    scode: int32 = _bord_style_code(vs, ve)
    if scode == 4:
        _set_side_w(side, 0)
        _set_side_s(side, 4)
        _sync_bordps()
        return 1
    sw: int32 = _style_len(vs, ve)
    if sw >= 0:
        _set_side_w(side, sw)
    elif _side_w(side) < 0:
        _set_side_w(side, 3)                      # style-only => CSS `medium`
    if scode >= 0:
        _set_side_s(side, scode)
    scc: int32 = _bg_shorthand_color(vs, ve)
    if scc >= 0:
        _set_side_bc(side, scc)                   # this side's own colour
        if d_bordc < 0:
            d_bordc = scc
    if _side_w(side) > 0:
        d_bd = 1
        if d_bordw <= 0:
            d_bordw = _side_w(side)
    _sync_bordps()
    return 1


# border-<side>* dispatch: pick the -width/-style/-color longhand (or the bare
# shorthand) from the property tail. A per-corner `border-<side>-*-radius` is
# routed to d_bordr, NOT a border (fixes it spuriously drawing a side too).
def _border_side_dispatch(side: int32, ps: uint64, pe: uint64, \
                          vs: uint64, ve: uint64) -> int32:
    if _prop_suffix(ps, pe, cast[Ptr[uint8]]("-radius")) != 0:
        rr: int32 = _style_len(vs, ve)
        if rr >= 0:
            d_bordr = rr
        return 1
    sub: int32 = 0
    if _prop_suffix(ps, pe, cast[Ptr[uint8]]("-width")) != 0:
        sub = 1
    elif _prop_suffix(ps, pe, cast[Ptr[uint8]]("-style")) != 0:
        sub = 2
    elif _prop_suffix(ps, pe, cast[Ptr[uint8]]("-color")) != 0:
        sub = 3
    return _border_side_decl(side, sub, vs, ve)


# Route ONE box-model declaration (property src[ps..pe) : value src[vs..ve))
# into the d_* box scratch. Shared by the stylesheet (_apply_decl) and inline
# style="" paths so classes and inline styles cascade identically. Returns 1 if
# the property was a box property (handled), else 0.
def _box_decl(ps: uint64, pe: uint64, vs: uint64, ve: uint64) -> int32:
    # CSS filter: pack the first recognised filter function into d_filter. The
    # renderer applies it as a post-pass over the element's background fill.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("filter")) != 0:
        d_filter = _filter_value(vs, ve)
        return 1
    # accent-color: <color> — the accent used to paint checkbox/radio (and other
    # form controls). `auto`/`currentcolor` fall back to the UA accent (-1).
    # Shared between the stylesheet and inline style="" paths.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("accent-color")) != 0:
        av: uint64 = _val_start(vs, ve)
        if _val_starts(av, ve, cast[Ptr[uint8]]("auto")) == 0 and \
           _val_starts(av, ve, cast[Ptr[uint8]]("currentcolor")) == 0:
            acv: int32 = _color_value(av)
            if acv >= 0:
                d_accent = acv
        return 1
    # border-radius: parse the corner radius (first length token). Does NOT turn
    # the 1px frame on — it is ubiquitous on backgrounded cards/buttons that have
    # no border — but it DOES round the background fill + any border stroke.
    if _prop_prefix(ps, pe, cast[Ptr[uint8]]("border-radius")) != 0:
        rr: int32 = _style_len(vs, ve)
        if rr >= 0:
            d_bordr = rr
        else:
            d_bordr = 0
        return 1
    # transform-origin: fold onto the block's transform template (create a bare
    # identity one first if the transform declaration has not been seen yet, so
    # the origin survives either source order).
    if _prop_is(ps, pe, cast[Ptr[uint8]]("transform-origin")) != 0:
        if d_xform < 0:
            d_xform = _xt_new()
        _xf_parse_origin(d_xform, vs, ve)
        return 1
    # transform: parse the function list into a template. When an origin was
    # already parsed (template exists), reparse folds the matrix onto it.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("transform")) != 0:
        oxid: int32 = d_xform
        tid: int32 = _xf_parse_transform(vs, ve)
        if tid >= 0 and oxid >= 0:
            # carry a previously-set origin onto the freshly built matrix.
            xt_ox[tid]  = xt_ox[oxid]
            xt_oxp[tid] = xt_oxp[oxid]
            xt_oy[tid]  = xt_oy[oxid]
            xt_oyp[tid] = xt_oyp[oxid]
        if tid >= 0:
            d_xform = tid
        return 1
    # border-image / border-collapse / border-spacing are NOT box borders — they
    # must never switch the 1px frame on. Swallow them here so the generic
    # `border` prefix below does not draw a hard rectangle around every card.
    if _prop_prefix(ps, pe, cast[Ptr[uint8]]("border-image")) != 0 or \
       _prop_prefix(ps, pe, cast[Ptr[uint8]]("border-collapse")) != 0 or \
       _prop_prefix(ps, pe, cast[Ptr[uint8]]("border-spacing")) != 0:
        return 1
    # TRUE PER-SIDE borders (W3C css-backgrounds §4) — intercepted BEFORE the
    # uniform `border` catch-all. `border-width`/`border-style` (1..4 TRBL) and
    # each `border-<side>[-width|-style|-color]` longhand drive distinct per-side
    # widths + styles (solid/dashed/dotted/double/none) through the packed
    # d_bordps/d_bordss globals. A plain uniform `border:` leaves those 0 so it
    # still renders on the legacy 1px stroke path (byte-identical).
    if _prop_is(ps, pe, cast[Ptr[uint8]]("border-width")) != 0:
        return _border_width_shorthand(vs, ve)
    if _prop_is(ps, pe, cast[Ptr[uint8]]("border-style")) != 0:
        return _border_style_shorthand(vs, ve)
    if _prop_is(ps, pe, cast[Ptr[uint8]]("border-color")) != 0:
        return _border_color_shorthand(vs, ve)
    if _prop_prefix(ps, pe, cast[Ptr[uint8]]("border-top")) != 0:
        return _border_side_dispatch(0, ps, pe, vs, ve)
    if _prop_prefix(ps, pe, cast[Ptr[uint8]]("border-right")) != 0:
        return _border_side_dispatch(1, ps, pe, vs, ve)
    if _prop_prefix(ps, pe, cast[Ptr[uint8]]("border-bottom")) != 0:
        return _border_side_dispatch(2, ps, pe, vs, ve)
    if _prop_prefix(ps, pe, cast[Ptr[uint8]]("border-left")) != 0:
        return _border_side_dispatch(3, ps, pe, vs, ve)
    # Border: uniform `border` / `border-color` turns the box on unless the value
    # is none/hidden. The DECLARED colour (if any token parses as a colour —
    # `border:3px solid #c00`, `border-color:red`) is captured into d_bordc so the
    # box paints its real colour instead of hardcoded black. The uniform width +
    # solid style are ALSO seeded onto every side (d_bw_*/d_bs_*) — but NOT packed
    # into d_bordps — so a following per-side longhand composes over them while a
    # plain uniform border stays on the legacy 1px stroke path.
    if _prop_prefix(ps, pe, cast[Ptr[uint8]]("border")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("none")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("hidden")) != 0:
            d_bd = 0
            d_bordw = 0
            _set_side_w(0, 0)
            _set_side_w(1, 0)
            _set_side_w(2, 0)
            _set_side_w(3, 0)
            _set_side_s(0, 4)
            _set_side_s(1, 4)
            _set_side_s(2, 4)
            _set_side_s(3, 4)
            d_bc_t = -1
            d_bc_r = -1
            d_bc_b = -1
            d_bc_l = -1
            d_bordps = 0
            d_bordss = 0
        else:
            d_bd = 1
            bc: int32 = _bg_shorthand_color(vs, ve)
            if bc >= 0:
                d_bordc = bc
            # border width for box-sizing:border-box: the leading length token of
            # `border:5px solid` / `border-width:5px` / `border-left:2px ...`.
            # A colour/style-only value (`border-color:red`) has no leading length
            # (_style_len -> -1) and leaves the width untouched.
            bw: int32 = _style_len(vs, ve)
            if bw >= 0:
                d_bordw = bw
            # `border` (with a length OR a style keyword) is a SHORTHAND that resets
            # all four sides; `border-color` (no length, no style) only recolours,
            # so it must NOT clobber a per-side width already set.
            uw: int32 = bw
            if uw < 0:
                uw = 1
            ust: int32 = _bord_style_code(vs, ve)
            if bw >= 0 or ust >= 0:
                sc: int32 = ust
                if sc < 0:
                    sc = 0
                # a full `border` shorthand resets each side's colour to the
                # shorthand's colour (via the uniform d_bordc fallback) — drop any
                # earlier per-side colour so red-top does not survive `border:...`.
                d_bc_t = -1
                d_bc_r = -1
                d_bc_b = -1
                d_bc_l = -1
                _set_side_w(0, uw)
                _set_side_w(1, uw)
                _set_side_w(2, uw)
                _set_side_w(3, uw)
                _set_side_s(0, sc)
                _set_side_s(1, sc)
                _set_side_s(2, sc)
                _set_side_s(3, sc)
                # A uniform SOLID border keeps d_bordps 0 -> the legacy 1px stroke
                # path (byte-identical to before). A uniform NON-solid style
                # (dashed/dotted/double) DOES route to the per-side painter so
                # `border:1px dashed` actually renders dashes.
                if sc >= 1:
                    _sync_bordps()
                else:
                    d_bordps = 0
                    d_bordss = 0
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("width")) != 0:
        w: int32 = _style_len(vs, ve)
        if w >= 0:
            d_wd = w
        return 1
    # max-width caps the content column; for our layout it pins the wrap width
    # like `width` (the common centred-container idiom `max-width:Npx;margin:0
    # auto`). A later explicit `width` still overrides via d_wd.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("max-width")) != 0:
        mw: int32 = _style_len(vs, ve)
        if mw >= 0:
            d_wd = mw
        return 1
    # min-width floors the content column: record the raw axis AND (so the
    # existing width path honours it immediately) raise d_wd to the floor when
    # no larger width is set. `min-width:Npx` alone therefore pins an N-px box.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("min-width")) != 0:
        mnw: int32 = _style_len(vs, ve)
        if mnw >= 0:
            d_minw = mnw
            if d_wd < mnw:
                d_wd = mnw
        return 1
    # height / min-height / max-height: no vertical-sizing pass yet, so these are
    # recorded as resolved axes for the layout module to consume next round.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("height")) != 0:
        hh: int32 = _style_len(vs, ve)
        if hh >= 0:
            d_ht = hh
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("min-height")) != 0:
        mnh: int32 = _style_len(vs, ve)
        if mnh >= 0:
            d_minh = mnh
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("max-height")) != 0:
        mxh: int32 = _style_len(vs, ve)
        if mxh >= 0:
            d_maxh = mxh
        return 1
    # appearance: none suppresses the UA control chrome (the default field border,
    # button face, checkbox/radio glyph) so author CSS fully styles the control.
    # `auto`/anything else leaves the default chrome (d_appear stays 0). Only
    # `none` (and the `-webkit-`/`-moz-` prefixed spellings sites still ship) sets
    # the flag; a control WITHOUT this declaration is byte-identical.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("appearance")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("-webkit-appearance")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("-moz-appearance")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("none")) != 0:
            d_appear = 1
        else:
            d_appear = 0
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("box-sizing")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("border-box")) != 0:
            d_boxsz = 2
        else:
            d_boxsz = 1                              # content-box (the default)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("overflow")) != 0:
        ov: int32 = _overflow_value(vs, ve)
        d_ovfx = ov                                  # shorthand sets BOTH axes
        d_ovfy = ov
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("overflow-x")) != 0:
        d_ovfx = _overflow_value(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("overflow-y")) != 0:
        d_ovfy = _overflow_value(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("text-overflow")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("ellipsis")) != 0:
            d_txtovf = 2
        else:
            d_txtovf = 1                             # clip (the default), or `""`
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("object-fit")) != 0:
        of: int32 = _objfit_value(vs, ve)
        if of != 0:
            d_objfit = of
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("object-position")) != 0:
        _parse_obj_pos(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("aspect-ratio")) != 0:
        _parse_aspect_ratio(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("float")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("left")) != 0:
            d_float = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("right")) != 0:
            d_float = 2
        else:
            d_float = 0                                  # none / inline-start...
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("clear")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("both")) != 0:
            d_clear = 3
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("left")) != 0:
            d_clear = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("right")) != 0:
            d_clear = 2
        else:
            d_clear = 0                                  # none
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("position")) != 0:
        d_posfx = 0
        if _val_starts(vs, ve, cast[Ptr[uint8]]("relative")) != 0:
            d_pos = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("fixed")) != 0:
            # fixed shares absolute's out-of-flow layout for now, but records a
            # distinct sub-kind so the layout module can pin it to the VIEWPORT.
            d_pos = 2
            d_posfx = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("absolute")) != 0:
            d_pos = 2
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("sticky")) != 0:
            # sticky behaves like relative until scrolled (no scroll model here),
            # so apply relative offsets now + flag the sub-kind for the layout
            # module. Previously sticky fell through to static (offsets ignored).
            d_pos = 1
            d_posfx = 2
        else:
            d_pos = 0                                    # static
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("top")) != 0:
        d_top = _style_len(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("left")) != 0:
        d_left = _style_len(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("right")) != 0:
        d_right = _style_len(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("bottom")) != 0:
        d_bottom = _style_len(vs, ve)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("z-index")) != 0:
        d_zidx = _zindex_value(vs, ve)
        return 1
    # side-specific first (longer names) so the shorthand check does not eat them
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-left")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-left")) != 0:
        if _val_has_auto(vs, ve) != 0:
            d_center = 1
        plx: int32 = _style_len(vs, ve)
        if plx >= 0 and _prop_is(ps, pe, cast[Ptr[uint8]]("padding-left")) != 0:
            d_padx = d_padx + plx                        # for box-sizing:border-box
        _box_add_l(plx)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-right")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-right")) != 0:
        if _val_has_auto(vs, ve) != 0:
            d_center = 1
        prx: int32 = _style_len(vs, ve)
        if prx >= 0 and _prop_is(ps, pe, cast[Ptr[uint8]]("padding-right")) != 0:
            d_padx = d_padx + prx                        # for box-sizing:border-box
        _box_add_r(prx)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-top")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-top")) != 0:
        pty: int32 = _style_len(vs, ve)
        if pty >= 0 and _prop_is(ps, pe, cast[Ptr[uint8]]("padding-top")) != 0:
            d_pady = d_pady + pty                        # for box-sizing:border-box
        _box_add_t(pty)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin-bottom")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding-bottom")) != 0:
        pby: int32 = _style_len(vs, ve)
        if pby >= 0 and _prop_is(ps, pe, cast[Ptr[uint8]]("padding-bottom")) != 0:
            d_pady = d_pady + pby                        # for box-sizing:border-box
        _box_add_b(pby)
        return 1
    if _prop_is(ps, pe, cast[Ptr[uint8]]("margin")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("padding")) != 0:
        # `margin: <v> auto` (or `margin: auto`) centres the box in its parent.
        if _prop_is(ps, pe, cast[Ptr[uint8]]("margin")) != 0 and \
           _val_has_auto(vs, ve) != 0:
            d_center = 1
        is_pad: int32 = _prop_is(ps, pe, cast[Ptr[uint8]]("padding"))
        _box_shorthand(vs, ve)
        # padding shorthand: accumulate the left+right columns (border-box width)
        # and the top+bottom columns (border-box height). box_lens order is
        # T R B L (n=4) / T R -> TB LR (n=2) / T -> all sides (n=1).
        if is_pad != 0 and n_box_lens > 0:
            padt: int32 = box_lens[0]
            padr: int32 = box_lens[0]
            padb: int32 = box_lens[0]
            padl: int32 = box_lens[0]
            if n_box_lens >= 2:
                padr = box_lens[1]
                padl = box_lens[1]
            if n_box_lens >= 3:
                padb = box_lens[2]
            if n_box_lens >= 4:
                padl = box_lens[3]
            if padl > 0:
                d_padx = d_padx + padl
            if padr > 0:
                d_padx = d_padx + padr
            if padt > 0:
                d_pady = d_pady + padt
            if padb > 0:
                d_pady = d_pady + padb
        return 1
    return 0


# First non-space offset in [a,b) — where a colour value begins.
def _val_start(a: uint64, b: uint64) -> uint64:
    while a < b and _css_ws(src_ptr[a]) != 0:
        a = a + 1
    return a


# ---- byte-buffer compares -------------------------------------------
def _buf_eq(a: Ptr[uint8], alen: int32, b: Ptr[uint8], blen: int32) -> int32:
    if alen != blen:
        return 0
    i: int32 = 0
    while i < alen:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# Does the element's class list (el_sbuf[coff..coff+clen)) contain the token
# css_sbuf[koff..koff+klen) (space-separated)?
def _cls_contains(coff: int32, clen: int32, koff: int32, klen: int32) -> int32:
    i: int32 = 0
    while i < clen:
        while i < clen and el_sbuf[coff + i] == 32:
            i = i + 1
        s: int32 = i
        while i < clen and el_sbuf[coff + i] != 32:
            i = i + 1
        tlen: int32 = i - s
        if tlen == klen and _buf_eq(&el_sbuf[coff + s], tlen, \
                                    &css_sbuf[koff], klen) != 0:
            return 1
    return 0


# ---- selector parsing -----------------------------------------------
def _read_name(i: uint64, b: uint64) -> uint64:
    while i < b and _is_name_ch(src_ptr[i]) != 0:
        i = i + 1
    return i


# Parse an attribute selector body starting just past '[' at src[i..b) into the
# c_att_* globals ([attr], [attr=v], [attr~=v], [attr^=v], [attr$=v], [attr*=v],
# [attr|=v]; the value may be quoted). Adds +10 specificity (attribute selectors
# rank with classes). Returns the offset just past the closing ']'.
def _parse_attr_sel(i: uint64, b: uint64) -> uint64:
    while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    ns: uint64 = i
    while i < b and _is_name_ch(src_ptr[i]) != 0:
        i = i + 1
    if i > ns:
        _css_store(ns, i)
        c_att_off = g_store_off
        c_att_len = g_store_len
        c_att_op = 1                                 # [attr] exists (default)
        c_spec = c_spec + 10
    while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    # operator: '=', or one of ~ ^ $ * | immediately followed by '='.
    op: int32 = 0
    if i < b and src_ptr[i] == 61:                   # '='
        op = 2
        i = i + 1
    elif i + 1 < b and src_ptr[i + 1] == 61:
        oc: uint8 = src_ptr[i]
        if oc == 126:                                # '~='
            op = 3
        elif oc == 94:                               # '^='
            op = 4
        elif oc == 36:                               # '$='
            op = 5
        elif oc == 42:                               # '*='
            op = 6
        elif oc == 124:                              # '|='
            op = 7
        if op != 0:
            i = i + 2
    if op != 0:
        c_att_op = op
        while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9):
            i = i + 1
        quote: uint8 = 0
        if i < b and (src_ptr[i] == 34 or src_ptr[i] == 39):
            quote = src_ptr[i]
            i = i + 1
        vs: uint64 = i
        while i < b:
            c: uint8 = src_ptr[i]
            if quote != 0:
                if c == quote:
                    break
            else:
                if c == 93 or c == 32 or c == 9:     # ']' / ws
                    break
            i = i + 1
        _css_store(vs, i)
        c_atv_off = g_store_off
        c_atv_len = g_store_len
        if quote != 0 and i < b and src_ptr[i] == quote:
            i = i + 1
    # advance past the closing ']'
    while i < b and src_ptr[i] != 93:
        i = i + 1
    if i < b:
        i = i + 1
    return i


# ---- pseudo-classes / pseudo-elements -------------------------------
# Is the pseudo name src[ns..ne) a CSS pseudo-ELEMENT (::before etc.)? These
# target generated content we do not synthesise, so the rule renders inert.
def _pseudo_is_element(ns: uint64, ne: uint64) -> int32:
    if _prop_is(ns, ne, cast[Ptr[uint8]]("before")) != 0:
        return 1
    if _prop_is(ns, ne, cast[Ptr[uint8]]("after")) != 0:
        return 1
    if _prop_is(ns, ne, cast[Ptr[uint8]]("first-line")) != 0:
        return 1
    if _prop_is(ns, ne, cast[Ptr[uint8]]("first-letter")) != 0:
        return 1
    if _prop_is(ns, ne, cast[Ptr[uint8]]("marker")) != 0:
        return 1
    if _prop_is(ns, ne, cast[Ptr[uint8]]("selection")) != 0:
        return 1
    if _prop_is(ns, ne, cast[Ptr[uint8]]("placeholder")) != 0:
        return 1
    if _prop_is(ns, ne, cast[Ptr[uint8]]("backdrop")) != 0:
        return 1
    return 0


# Map an :nth-child(...) argument src[as_..ae) to a pseudo code: 8 (even) for
# `even`/`2n`, 9 (odd) for `odd`/`2n+1`, else 6 (inert — an+b form we do not
# evaluate yet).
def _nth_child_code(as_: uint64, ae: uint64) -> int32:
    if _prop_is(as_, ae, cast[Ptr[uint8]]("even")) != 0 or \
       _prop_is(as_, ae, cast[Ptr[uint8]]("2n")) != 0:
        return 8
    if _prop_is(as_, ae, cast[Ptr[uint8]]("odd")) != 0 or \
       _prop_is(as_, ae, cast[Ptr[uint8]]("2n+1")) != 0:
        return 9
    return 6


# Map a pseudo-CLASS name src[ns..ne) (+ optional arg [as_..ae)) to its code:
# 1 :root / 2 :checked / 3 :disabled / 4 :required / 5 :enabled /
# 7 :first-child / 8 :nth-child(even) / 9 :nth-child(odd). Dynamic states
# (:hover/:focus/:active/:target/:visited/:link/…) and anything unknown map to
# 6 (inert) — they never match a live element in a static layout pass.
def _pseudo_class_code(ns: uint64, ne: uint64, as_: uint64, ae: uint64) -> int32:
    if _prop_is(ns, ne, cast[Ptr[uint8]]("root")) != 0:
        return 1
    if _prop_is(ns, ne, cast[Ptr[uint8]]("checked")) != 0:
        return 2
    if _prop_is(ns, ne, cast[Ptr[uint8]]("disabled")) != 0:
        return 3
    if _prop_is(ns, ne, cast[Ptr[uint8]]("required")) != 0:
        return 4
    if _prop_is(ns, ne, cast[Ptr[uint8]]("enabled")) != 0:
        return 5
    if _prop_is(ns, ne, cast[Ptr[uint8]]("first-child")) != 0:
        return 7
    if _prop_is(ns, ne, cast[Ptr[uint8]]("nth-child")) != 0:
        return _nth_child_code(as_, ae)
    return 6


# Parse a pseudo at src[i] (src_ptr[i]==':') into c_pseudo; return the index
# just past the pseudo token and any parenthesised argument. `::x` is a
# pseudo-element (inert); a single ':' is a pseudo-class.
def _parse_pseudo(i: uint64, b: uint64) -> uint64:
    is_el: int32 = 0
    i = i + 1                                        # past first ':'
    if i < b and src_ptr[i] == 58:                   # '::' pseudo-element
        is_el = 1
        i = i + 1
    ns: uint64 = i
    while i < b and _is_name_ch(src_ptr[i]) != 0:
        i = i + 1
    ne: uint64 = i
    as_: uint64 = i
    ae: uint64 = i
    if i < b and src_ptr[i] == 40:                   # '(' argument
        i = i + 1
        as_ = i
        depth: int32 = 1
        while i < b and depth > 0:
            if src_ptr[i] == 40:
                depth = depth + 1
                i = i + 1
            elif src_ptr[i] == 41:
                depth = depth - 1
                if depth == 0:
                    break
                i = i + 1
            else:
                i = i + 1
        ae = i
        if i < b and src_ptr[i] == 41:
            i = i + 1
    if is_el != 0 or _pseudo_is_element(ns, ne) != 0:
        c_pseudo = 10                                # pseudo-element => inert
        c_spec = c_spec + 1
        return i
    c_pseudo = _pseudo_class_code(ns, ne, as_, ae)
    c_spec = c_spec + 10
    return i


# Parse one compound selector at src[a..b) into c_* globals; c_spec gets its
# specificity contribution.
def _parse_compound(a: uint64, b: uint64):
    c_tag_off = -1
    c_tag_len = 0
    c_cls_off = -1
    c_cls_len = 0
    c_id_off = -1
    c_id_len = 0
    c_att_off = -1
    c_att_len = 0
    c_att_op = 0
    c_atv_off = -1
    c_atv_len = 0
    c_pseudo = 0
    c_spec = 0
    i: uint64 = a
    if i < b and src_ptr[i] == 42:                   # '*' universal
        i = i + 1
    elif i < b and _is_alpha(src_ptr[i]) != 0:
        j: uint64 = _read_name(i, b)
        _css_store(i, j)
        c_tag_off = g_store_off
        c_tag_len = g_store_len
        c_spec = c_spec + 1
        i = j
    while i < b:
        if src_ptr[i] == 46:                         # '.class'
            j2: uint64 = _read_name(i + 1, b)
            # A compound may chain several classes (`.a.b`): store them all as
            # one space-joined token string so matching can require EVERY class
            # (and specificity grows +10 per class). The first class seeds
            # c_cls_off; each subsequent one appends " <name>" and extends len.
            if c_cls_off < 0:
                _css_store(i + 1, j2)
                c_cls_off = g_store_off
                c_cls_len = g_store_len
            else:
                if css_slen < CSS_STR_CAP - 1:
                    css_sbuf[css_slen] = 32          # separator space
                    css_slen = css_slen + 1
                _css_store(i + 1, j2)
                c_cls_len = g_store_off + g_store_len - c_cls_off
            c_spec = c_spec + 10
            i = j2
        elif src_ptr[i] == 35:                       # '#id'
            j3: uint64 = _read_name(i + 1, b)
            _css_store(i + 1, j3)
            c_id_off = g_store_off
            c_id_len = g_store_len
            c_spec = c_spec + 100
            i = j3
        elif src_ptr[i] == 91:                       # '[attr...]'
            i = _parse_attr_sel(i + 1, b)
        elif src_ptr[i] == 58:                       # ':pseudo' / '::pseudo'
            i = _parse_pseudo(i, b)
        else:
            i = i + 1


# Parse a full selector src[a..b) into rule `ri`. Keeps the rightmost compound
# as the target and the nearest preceding compound as the ancestor.
def _parse_selector(a: uint64, b: uint64, ri: int32):
    # trim
    while a < b and (src_ptr[a] == 32 or src_ptr[a] == 9 or src_ptr[a] == 10 \
                     or src_ptr[a] == 13 or src_ptr[a] == 62):
        a = a + 1
    while b > a and (src_ptr[b - 1] == 32 or src_ptr[b - 1] == 9 or \
                     src_ptr[b - 1] == 10 or src_ptr[b - 1] == 13):
        b = b - 1
    r_has_anc[ri] = 0
    spec: int32 = 0
    # walk compounds left->right; remember previous compound as ancestor.
    i: uint64 = a
    prev_present: int32 = 0
    while i < b:
        while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9 or \
                         src_ptr[i] == 62 or src_ptr[i] == 10 or \
                         src_ptr[i] == 13):
            i = i + 1
        if i >= b:
            break
        cs: uint64 = i
        while i < b and src_ptr[i] != 32 and src_ptr[i] != 9 and \
              src_ptr[i] != 62 and src_ptr[i] != 10 and src_ptr[i] != 13:
            i = i + 1
        # a compound occupies [cs,i); shift current target -> ancestor.
        if prev_present != 0:
            r_has_anc[ri] = 1
            r_atag_off[ri] = r_tag_off[ri]
            r_atag_len[ri] = r_tag_len[ri]
            r_acls_off[ri] = r_cls_off[ri]
            r_acls_len[ri] = r_cls_len[ri]
            r_aid_off[ri]  = r_id_off[ri]
            r_aid_len[ri]  = r_id_len[ri]
            r_aatt_off[ri] = r_att_off[ri]
            r_aatt_len[ri] = r_att_len[ri]
            r_aatt_op[ri]  = r_att_op[ri]
            r_aatv_off[ri] = r_atv_off[ri]
            r_aatv_len[ri] = r_atv_len[ri]
            r_apseudo[ri]  = r_pseudo[ri]
        _parse_compound(cs, i)
        r_tag_off[ri] = c_tag_off
        r_tag_len[ri] = c_tag_len
        r_cls_off[ri] = c_cls_off
        r_cls_len[ri] = c_cls_len
        r_id_off[ri]  = c_id_off
        r_id_len[ri]  = c_id_len
        r_att_off[ri] = c_att_off
        r_att_len[ri] = c_att_len
        r_att_op[ri]  = c_att_op
        r_atv_off[ri] = c_atv_off
        r_atv_len[ri] = c_atv_len
        r_pseudo[ri]  = c_pseudo
        spec = spec + c_spec
        prev_present = 1
    r_spec[ri] = spec


# ---- declaration parsing --------------------------------------------
# Map a `display:` value span to the engine's display code (shared by the
# stylesheet and inline-style parsers). inline-block/inline-flex are tested
# before the bare "inline" prefix; flex covers inline-flex too.
def _disp_value(vs: uint64, ve: uint64) -> int32:
    if _val_starts(vs, ve, cast[Ptr[uint8]]("none")) != 0:
        return 1
    if _val_starts(vs, ve, cast[Ptr[uint8]]("inline-block")) != 0:
        return 4
    if _val_starts(vs, ve, cast[Ptr[uint8]]("inline-flex")) != 0:
        return 2
    if _val_starts(vs, ve, cast[Ptr[uint8]]("inline-grid")) != 0:
        return 6
    if _val_starts(vs, ve, cast[Ptr[uint8]]("inline")) != 0:
        return 5
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex")) != 0:
        return 2
    if _val_starts(vs, ve, cast[Ptr[uint8]]("grid")) != 0:
        return 6
    if _val_starts(vs, ve, cast[Ptr[uint8]]("block")) != 0:
        return 3
    return 0


# justify-content value -> 1 flex-start, 2 center, 3 flex-end, 4 space-between,
# 5 space-around (space-evenly maps to around). 0 for unrecognised/unset.
def _justify_value(vs: uint64, ve: uint64) -> int32:
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex-start")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("start")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("left")) != 0:
        return 1
    if _val_starts(vs, ve, cast[Ptr[uint8]]("center")) != 0:
        return 2
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex-end")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("end")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("right")) != 0:
        return 3
    if _val_starts(vs, ve, cast[Ptr[uint8]]("space-between")) != 0:
        return 4
    if _val_starts(vs, ve, cast[Ptr[uint8]]("space-around")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("space-evenly")) != 0:
        return 5
    return 0


# align-items (cross axis) value -> 1 flex-start (== top-aligned default),
# 2 center, 3 flex-end, 4 stretch. `baseline` approximates to flex-start. 0 for
# unrecognised/unset (which keeps the engine's existing top-aligned behaviour).
def _align_items_value(vs: uint64, ve: uint64) -> int32:
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex-start")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("start")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("baseline")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("self-start")) != 0:
        return 1
    if _val_starts(vs, ve, cast[Ptr[uint8]]("center")) != 0:
        return 2
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex-end")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("end")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("self-end")) != 0:
        return 3
    if _val_starts(vs, ve, cast[Ptr[uint8]]("stretch")) != 0:
        return 4
    return 0


# align-content (multi-line cross-axis distribution) value -> 1 flex-start,
# 2 center, 3 flex-end, 4 space-between, 5 space-around, 6 space-evenly,
# 7 stretch. `normal` maps to 0 (unset) so a wrapped container with no explicit
# cross-size stays byte-identical to today's line-packed layout. Applied only to
# a MULTI-LINE (flex-wrap) container that has cross-axis free space to distribute.
def _align_content_value(vs: uint64, ve: uint64) -> int32:
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex-start")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("start")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("baseline")) != 0:
        return 1
    if _val_starts(vs, ve, cast[Ptr[uint8]]("center")) != 0:
        return 2
    if _val_starts(vs, ve, cast[Ptr[uint8]]("flex-end")) != 0 or \
       _val_starts(vs, ve, cast[Ptr[uint8]]("end")) != 0:
        return 3
    if _val_starts(vs, ve, cast[Ptr[uint8]]("space-between")) != 0:
        return 4
    if _val_starts(vs, ve, cast[Ptr[uint8]]("space-around")) != 0:
        return 5
    if _val_starts(vs, ve, cast[Ptr[uint8]]("space-evenly")) != 0:
        return 6
    if _val_starts(vs, ve, cast[Ptr[uint8]]("stretch")) != 0:
        return 7
    return 0


# Encode ONE SIMPLE (non-minmax) track token src[a..b) into the compact form:
#   <n>fr  -> negative fr weight (-n; a bare `fr` == -1)
#   <len>  -> a fixed px length (px/em/% via _style_len)
#   auto / min-content / max-content / other keyword -> a flexible 1fr track
# (a lean approximation — this round has no intrinsic sizing). fr is detected
# BEFORE _style_len so "1fr" is not mistaken for 1px.
def _grid_simple_track(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    seen: int32 = 0
    v: int32 = 0
    j: uint64 = i
    while j < b and src_ptr[j] >= 48 and src_ptr[j] <= 57:
        v = v * 10 + cast[int32](src_ptr[j] - 48)
        seen = 1
        j = j + 1
    # trailing "fr" -> fractional track
    if j + 1 < b and _hx_lower(src_ptr[j]) == 102 and _hx_lower(src_ptr[j + 1]) == 114:
        w: int32 = v
        if seen == 0 or w <= 0:
            w = 1
        return -w
    # trailing "%" -> PERCENTAGE track, encoded as -(100000 + pct). Resolved to px
    # against the GRID CONTAINER'S inline size at track-resolution time (box.ad
    # _grid_resolve_tracks), NOT here against the viewport — a nested `50% 50%`
    # grid must split its own container, not the page. Sentinel range -100000..
    # -100100 never collides with fr weights (-1..) or fixed px (>= 0).
    if seen != 0 and j < b and src_ptr[j] == 37:     # '%'
        p: int32 = v
        if p < 0:
            p = 0
        return 0 - (100000 + p)
    if seen == 0:
        return -1                                    # auto / *-content -> 1fr
    px: int32 = _style_len(a, b)
    if px < 0:
        px = 0
    return px


# Encode ONE track token, understanding `minmax(MIN, MAX)` on top of the simple
# forms. We have no intrinsic-sizing pass, so approximate: a fixed MAX pins the
# track to MAX px; a flexible MAX (fr/auto) with a fixed MIN pins the track to
# its MIN px floor (the ubiquitous `minmax(200px, 1fr)` responsive idiom); two
# flexible bounds fall back to the MAX fr weight. Everything else routes to the
# simple encoder unchanged (so non-minmax templates stay byte-identical).
def _grid_one_track(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    if _val_starts(i, b, cast[Ptr[uint8]]("minmax")) != 0:
        p: uint64 = i
        while p < b and src_ptr[p] != 40:            # '('
            p = p + 1
        if p < b:
            p = p + 1                                # past '('
        ms: uint64 = p
        while p < b and src_ptr[p] != 44 and src_ptr[p] != 41:   # ',' ')'
            p = p + 1
        me: uint64 = p
        if p < b and src_ptr[p] == 44:
            p = p + 1
        xs: uint64 = p
        while p < b and src_ptr[p] != 41:            # ')'
            p = p + 1
        xe: uint64 = p
        maxv: int32 = _grid_simple_track(xs, xe)
        minv: int32 = _grid_simple_track(ms, me)
        if maxv >= 0:                                # fixed upper bound wins
            return maxv
        if minv >= 0:                                # fr max, fixed min floor
            return minv
        return maxv                                  # both flexible -> the fr
    return _grid_simple_track(a, b)


# Scratch the shared track parser writes into; a caller copies it into the column
# (d_gtc) or row (d_gtr) destination so `grid-template-columns` and
# `grid-template-rows` in the same ruleset don't clobber each other.
gts_enc: Array[8, int32]


# Does token src[a..b) (leading ws skipped) contain the keyword `span`?
def _grid_tok_isspan(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i + 4 <= b:
        if _hx_lower(src_ptr[i]) == 115 and _hx_lower(src_ptr[i + 1]) == 112 and \
           _hx_lower(src_ptr[i + 2]) == 97 and _hx_lower(src_ptr[i + 3]) == 110:
            return 1
        i = i + 1
    return 0


# The first run of decimal digits in src[a..b) as an int (0 if none).
def _grid_tok_num(a: uint64, b: uint64) -> int32:
    v: int32 = 0
    seen: int32 = 0
    i: uint64 = a
    while i < b:
        c: uint8 = src_ptr[i]
        if c >= 48 and c <= 57:
            v = v * 10 + cast[int32](c - 48)
            seen = 1
        elif seen != 0:
            i = b                                        # stop at first non-digit run end
        i = i + 1
    return v


# Parse a per-ITEM `grid-column` value src[vs..ve) into d_gcstart (1-based start
# line; 0 = auto) and d_gcspan (track count; default 1). Handles `span N`,
# `A / B` (span = B-A), `A / span N`, and a bare `A` (start only). Row placement
# (`grid-row`) uses the identical grammar via _grid_row_parse.
def _grid_column_parse(vs: uint64, ve: uint64):
    d_gcstart = 0
    d_gcspan = 1
    slash: uint64 = ve
    i: uint64 = vs
    while i < ve:
        if src_ptr[i] == 47:                             # '/'
            slash = i
            break
        i = i + 1
    lsp: int32 = _grid_tok_isspan(vs, slash)
    lnum: int32 = _grid_tok_num(vs, slash)
    if slash < ve:
        rsp: int32 = _grid_tok_isspan(slash + 1, ve)
        rnum: int32 = _grid_tok_num(slash + 1, ve)
        if lsp == 0 and lnum > 0:
            d_gcstart = lnum
        if rsp != 0 and rnum > 0:
            d_gcspan = rnum
        elif lsp != 0 and lnum > 0:
            d_gcspan = lnum
        elif lnum > 0 and rnum > lnum:
            d_gcspan = rnum - lnum
    else:
        if lsp != 0 and lnum > 0:
            d_gcspan = lnum
        elif lnum > 0:
            d_gcstart = lnum


# Parse a per-ITEM `grid-row` value src[vs..ve) into d_grstart (1-based start row
# line; 0 = auto) and d_grspan (row count; default 1). Identical grammar to
# `grid-column` — `span N`, `A / B` (span = B-A), `A / span N`, bare `A`.
def _grid_row_parse(vs: uint64, ve: uint64):
    d_grstart = 0
    d_grspan = 1
    slash: uint64 = ve
    i: uint64 = vs
    while i < ve:
        if src_ptr[i] == 47:                             # '/'
            slash = i
            break
        i = i + 1
    lsp: int32 = _grid_tok_isspan(vs, slash)
    lnum: int32 = _grid_tok_num(vs, slash)
    if slash < ve:
        rsp: int32 = _grid_tok_isspan(slash + 1, ve)
        rnum: int32 = _grid_tok_num(slash + 1, ve)
        if lsp == 0 and lnum > 0:
            d_grstart = lnum
        if rsp != 0 and rnum > 0:
            d_grspan = rnum
        elif lsp != 0 and lnum > 0:
            d_grspan = lnum
        elif lnum > 0 and rnum > lnum:
            d_grspan = rnum - lnum
    else:
        if lsp != 0 and lnum > 0:
            d_grspan = lnum
        elif lnum > 0:
            d_grstart = lnum


# End of the track token starting at src[i..ve): stops at top-level whitespace or
# ',' but NOT inside parentheses, so a `minmax(120px, 1fr)` (which carries an
# internal space + comma) reads as ONE token.
def _grid_tok_end(i: uint64, ve: uint64) -> uint64:
    depth: int32 = 0
    while i < ve:
        c: uint8 = src_ptr[i]
        if c == 40:                                  # '('
            depth = depth + 1
        elif c == 41:                                # ')'
            if depth > 0:
                depth = depth - 1
        elif depth == 0 and (c == 32 or c == 9 or c == 10 or c == 13 or c == 44):
            break
        i = i + 1
    return i


# Available inline size (px) for a grid container, used to resolve the
# auto-fill/auto-fit repeat count. The content column if known, else the viewport.
def _grid_avail_px() -> int32:
    avail: int32 = _content_right() - _left_margin()
    if avail <= 0:
        avail = bw
    if avail <= 0:
        avail = 1
    return avail


# Parse a `grid-template-columns`/`grid-template-rows` value src[vs..ve) into the
# compact per-track encoding, written into the shared gts_enc[0..) scratch (the
# caller copies it out). Understands `repeat(N, <track>)`, the responsive
# `repeat(auto-fill|auto-fit, <track>)` form (count derived from the container
# width / the track's min size), `minmax(min,max)` tracks, explicit space-
# separated track lists ("200px 1fr 1fr"), and bare single tracks. Caps at
# GRID_MAXTRACK tracks (extra dropped). Returns the track count (0 = nothing
# parseable). Still deferred: grid-template-areas, subgrid.
def _grid_parse_template(vs: uint64, ve: uint64) -> int32:
    n: int32 = 0
    i: uint64 = vs
    while i < ve and n < GRID_MAXTRACK:
        c: uint8 = src_ptr[i]
        if c == 32 or c == 9 or c == 10 or c == 13 or c == 44:   # ws or ','
            i = i + 1
            continue
        if _val_starts(i, ve, cast[Ptr[uint8]]("repeat")) != 0:
            j: uint64 = i
            while j < ve and src_ptr[j] != 40:       # '('
                j = j + 1
            j = j + 1
            while j < ve and (src_ptr[j] == 32 or src_ptr[j] == 9):
                j = j + 1
            # count: an integer, or auto-fill / auto-fit (resolved below).
            autofit: int32 = 0
            cnt: int32 = 0
            if _val_starts(j, ve, cast[Ptr[uint8]]("auto-fill")) != 0 or \
               _val_starts(j, ve, cast[Ptr[uint8]]("auto-fit")) != 0:
                autofit = 1
            else:
                while j < ve and src_ptr[j] >= 48 and src_ptr[j] <= 57:
                    cnt = cnt * 10 + cast[int32](src_ptr[j] - 48)
                    j = j + 1
            while j < ve and src_ptr[j] != 44:       # ',' before the track
                j = j + 1
            j = j + 1
            while j < ve and (src_ptr[j] == 32 or src_ptr[j] == 9):
                j = j + 1
            ts: uint64 = j
            # inner track runs to the repeat's matching ')' (paren-depth aware so
            # minmax(...) inside repeat() is not truncated at its own ')').
            te2: uint64 = j
            depth: int32 = 0
            while te2 < ve:
                cc: uint8 = src_ptr[te2]
                if cc == 40:
                    depth = depth + 1
                elif cc == 41:
                    if depth == 0:
                        break
                    depth = depth - 1
                te2 = te2 + 1
            enc: int32 = _grid_one_track(ts, te2)
            if autofit != 0:
                # derive the repeat count from how many min-sized tracks fit the
                # container inline size. A flexible (fr) inner track has no fixed
                # width to fit against -> a single flexible track.
                trackpx: int32 = enc
                if trackpx <= 0:
                    cnt = 1
                else:
                    cnt = _grid_avail_px() / trackpx
                    if cnt < 1:
                        cnt = 1
                if cnt > GRID_MAXTRACK:
                    cnt = GRID_MAXTRACK
            k: int32 = 0
            while k < cnt and n < GRID_MAXTRACK:
                gts_enc[n] = enc
                n = n + 1
                k = k + 1
            i = te2
            if i < ve:
                i = i + 1                            # past ')'
            continue
        te3: uint64 = _grid_tok_end(i, ve)
        gts_enc[n] = _grid_one_track(i, te3)
        n = n + 1
        i = te3
    return n


# ---- grid-template-areas parse (W3C css-grid §7.3) ------------------
# Shared scratch the areas parser fills; a caller copies it into the rule
# (r_ga_*) or inline (d_ga_*) destination. ga_s_min/max track each named area's
# bounding box as the strings are scanned row-major; spans are derived on copy.
ga_s_name: Array[12, int32]
ga_s_minr: Array[12, int32]
ga_s_minc: Array[12, int32]
ga_s_maxr: Array[12, int32]
ga_s_maxc: Array[12, int32]
ga_s_n:    int32 = 0
ga_s_cols: int32 = 0


# Record cell (row,col) as belonging to interned area `nid`, growing that area's
# bounding box (or starting a new area entry). Cells for a name that don't form a
# rectangle are tolerated — we keep the bounding box (matches how browsers reject
# such templates, but degrading to the box is the useful static-render behaviour).
def _ga_add_cell(nid: int32, row: int32, col: int32):
    k: int32 = 0
    while k < ga_s_n:
        if ga_s_name[k] == nid:
            if row < ga_s_minr[k]:
                ga_s_minr[k] = row
            if col < ga_s_minc[k]:
                ga_s_minc[k] = col
            if row > ga_s_maxr[k]:
                ga_s_maxr[k] = row
            if col > ga_s_maxc[k]:
                ga_s_maxc[k] = col
            return
        k = k + 1
    if ga_s_n >= GAREA_MAX:
        return
    ga_s_name[ga_s_n] = nid
    ga_s_minr[ga_s_n] = row
    ga_s_minc[ga_s_n] = col
    ga_s_maxr[ga_s_n] = row
    ga_s_maxc[ga_s_n] = col
    ga_s_n = ga_s_n + 1


# Parse a `grid-template-areas` value src[vs..ve) — a run of quoted strings, each
# a grid ROW of space-separated cell names ('.' = an empty cell) — into the
# ga_s_* scratch. ga_s_n = distinct named areas, ga_s_cols = widest row's column
# count. Names are interned through _kf_intern's shared string registry so a
# `grid-area: NAME` item can match by the same id.
def _grid_parse_areas(vs: uint64, ve: uint64):
    ga_s_n = 0
    ga_s_cols = 0
    row: int32 = 0
    i: uint64 = vs
    while i < ve:
        c: uint8 = src_ptr[i]
        if c != 34 and c != 39:                          # opening '"' or '\''
            i = i + 1
            continue
        q: uint8 = c
        i = i + 1
        col: int32 = 0
        while i < ve and src_ptr[i] != q:
            while i < ve and src_ptr[i] != q and \
                  (src_ptr[i] == 32 or src_ptr[i] == 9):  # skip inter-token ws
                i = i + 1
            if i >= ve or src_ptr[i] == q:
                break
            ts: uint64 = i
            while i < ve and src_ptr[i] != q and src_ptr[i] != 32 and \
                  src_ptr[i] != 9:
                i = i + 1
            te: uint64 = i
            if te - ts == 1 and src_ptr[ts] == 46:        # '.' -> empty cell
                col = col + 1
                continue
            nid: int32 = _kf_intern(ts, te)
            if nid >= 0:
                _ga_add_cell(nid, row, col)
            col = col + 1
        if col > ga_s_cols:
            ga_s_cols = col
        if i < ve and src_ptr[i] == q:
            i = i + 1                                     # past closing quote
        row = row + 1


# Parse a per-ITEM `grid-area` value src[vs..ve). Two forms (W3C css-grid §8.5):
# a single custom-ident NAME (`grid-area: header`), or the line-based shorthand
# `row-start / col-start / row-end / col-end` (numbers/`span`). A name form sets
# d_gareaname (resolved against the container's template at placement); the
# line-based form desugars into d_grstart/d_gcstart + d_grspan/d_gcspan.
def _grid_area_parse(vs: uint64, ve: uint64):
    d_gareaname = -1
    s: uint64 = vs
    while s < ve and (src_ptr[s] == 32 or src_ptr[s] == 9):
        s = s + 1
    if s >= ve:
        return
    has_slash: int32 = 0
    j: uint64 = s
    while j < ve:
        if src_ptr[j] == 47:                              # '/'
            has_slash = 1
            break
        j = j + 1
    c0: uint8 = src_ptr[s]
    is_ident: int32 = 0
    if (c0 >= 65 and c0 <= 90) or (c0 >= 97 and c0 <= 122) or c0 == 95:
        is_ident = 1
    if has_slash == 0 and is_ident != 0 and _grid_tok_isspan(s, ve) == 0:
        d_gareaname = _kf_intern(s, ve)
        return
    # line-based: split on '/', assign row-start/col-start/row-end/col-end.
    p0s: uint64 = s
    p0e: uint64 = s
    while p0e < ve and src_ptr[p0e] != 47:
        p0e = p0e + 1
    p1s: uint64 = ve
    p1e: uint64 = ve
    p2s: uint64 = ve
    p2e: uint64 = ve
    p3s: uint64 = ve
    p3e: uint64 = ve
    if p0e < ve:
        p1s = p0e + 1
        p1e = p1s
        while p1e < ve and src_ptr[p1e] != 47:
            p1e = p1e + 1
        if p1e < ve:
            p2s = p1e + 1
            p2e = p2s
            while p2e < ve and src_ptr[p2e] != 47:
                p2e = p2e + 1
            if p2e < ve:
                p3s = p2e + 1
                p3e = ve
    rstart: int32 = _grid_tok_num(p0s, p0e)
    cstart: int32 = _grid_tok_num(p1s, p1e)
    d_grstart = 0
    d_grspan = 1
    d_gcstart = 0
    d_gcspan = 1
    if rstart > 0:
        d_grstart = rstart
    if cstart > 0:
        d_gcstart = cstart
    if p2s < ve:
        rend: int32 = _grid_tok_num(p2s, p2e)
        if _grid_tok_isspan(p2s, p2e) != 0 and rend > 0:
            d_grspan = rend
        elif rend > rstart and rstart > 0:
            d_grspan = rend - rstart
    if p3s < ve:
        cend: int32 = _grid_tok_num(p3s, p3e)
        if _grid_tok_isspan(p3s, p3e) != 0 and cend > 0:
            d_gcspan = cend
        elif cend > cstart and cstart > 0:
            d_gcspan = cend - cstart


# ---- CSS custom properties (var()) ----------------------------------
# `--name: value` declarations are harvested (name + raw value bytes copied out
# of whatever buffer is being parsed) into a flat token table BEFORE the rules
# are cascaded, so `prop: var(--name[, fallback])` resolves regardless of source
# order. Resolution (in _apply_decl) re-points the parser at the copied value and
# re-dispatches, so a token can carry any value type (colour, length, keyword)
# and even nest another var().
CVAR_MAX: int32 = 96
cvar_name_off: Array[96, int32]
cvar_name_len: Array[96, int32]
cvar_val_off:  Array[96, int32]
cvar_val_len:  Array[96, int32]
cvar_namebuf:  Array[4096, uint8]
cvar_namelen:  int32 = 0
cvar_valbuf:   Array[16384, uint8]
cvar_vallen:   int32 = 0
n_cvar: int32 = 0
# scratch for splicing "<property>:<tokenvalue>" during var() re-dispatch.
CVAR_SCRATCH: int32 = 1024
cvar_scratch: Array[1024, uint8]


def _cvar_reset():
    n_cvar = 0
    cvar_namelen = 0
    cvar_vallen = 0


# Store a `--name` (src[ns..ne), leading dashes included) -> value (src[vs..ve))
# token, trimming surrounding whitespace and copying both out of src_ptr.
def _cvar_store(ns: uint64, ne: uint64, vs: uint64, ve: uint64):
    if n_cvar >= CVAR_MAX:
        return
    while vs < ve and (src_ptr[vs] == 32 or src_ptr[vs] == 9):
        vs = vs + 1
    while ve > vs and (src_ptr[ve - 1] == 32 or src_ptr[ve - 1] == 9 or \
                       src_ptr[ve - 1] == 10 or src_ptr[ve - 1] == 13):
        ve = ve - 1
    while ns < ne and (src_ptr[ns] == 32 or src_ptr[ns] == 9):
        ns = ns + 1
    while ne > ns and (src_ptr[ne - 1] == 32 or src_ptr[ne - 1] == 9):
        ne = ne - 1
    nl: int32 = cast[int32](ne - ns)
    vl: int32 = cast[int32](ve - vs)
    if nl <= 0 or vl < 0:
        return
    if cvar_namelen + nl > 4096 or cvar_vallen + vl > 16384:
        return
    cvar_name_off[n_cvar] = cvar_namelen
    cvar_name_len[n_cvar] = nl
    ci: int32 = 0
    while ci < nl:
        cvar_namebuf[cvar_namelen + ci] = src_ptr[ns + cast[uint64](ci)]
        ci = ci + 1
    cvar_namelen = cvar_namelen + nl
    cvar_val_off[n_cvar] = cvar_vallen
    cvar_val_len[n_cvar] = vl
    vi: int32 = 0
    while vi < vl:
        cvar_valbuf[cvar_vallen + vi] = src_ptr[vs + cast[uint64](vi)]
        vi = vi + 1
    cvar_vallen = cvar_vallen + vl
    n_cvar = n_cvar + 1


# Find the token whose name matches src[ns..ne); later definitions win, so scan
# from the most recent. Returns the token index or -1.
def _cvar_find(ns: uint64, ne: uint64) -> int32:
    nl: int32 = cast[int32](ne - ns)
    idx: int32 = n_cvar - 1
    while idx >= 0:
        if cvar_name_len[idx] == nl:
            ok: int32 = 1
            k: int32 = 0
            while k < nl:
                if cvar_namebuf[cvar_name_off[idx] + k] != \
                   src_ptr[ns + cast[uint64](k)]:
                    ok = 0
                    break
                k = k + 1
            if ok != 0:
                return idx
        idx = idx - 1
    return -1


# Harvest every `--name: value` declaration in the CSS region src[a..b) into the
# token table. A `--` only counts at a declaration start (previous non-space is
# '{' or ';' or the region start), so `var(--x)` usages are not mistaken for
# definitions.
def _scan_cvars(a: uint64, b: uint64):
    i: uint64 = a
    while i + 1 < b:
        if src_ptr[i] == 45 and src_ptr[i + 1] == 45:        # '--'
            atstart: int32 = 0
            p: uint64 = i
            found: int32 = 0
            while p > a and found == 0:
                p = p - 1
                c2: uint8 = src_ptr[p]
                if c2 != 32 and c2 != 9 and c2 != 10 and c2 != 13:
                    found = 1
                    if c2 == 123 or c2 == 59:                # '{' ';'
                        atstart = 1
            if found == 0:
                atstart = 1                                  # region start
            if atstart != 0:
                ns: uint64 = i
                j: uint64 = i
                while j < b and src_ptr[j] != 58 and src_ptr[j] != 59 and \
                      src_ptr[j] != 125:                     # ':' ';' '}'
                    j = j + 1
                if j < b and src_ptr[j] == 58:
                    ne: uint64 = j
                    vsx: uint64 = j + 1
                    vex: uint64 = vsx
                    while vex < b and src_ptr[vex] != 59 and src_ptr[vex] != 125:
                        vex = vex + 1
                    _cvar_store(ns, ne, vsx, vex)
                    i = vex
                    continue
        i = i + 1


# Scan a `background:` shorthand value src[vs..ve) for a colour, testing each
# space/'/'-separated token (position/repeat/size keywords, url()/gradient()
# tokens all fail _color_value cleanly). Returns the first colour found (0xRRGGBB)
# or -1. _color_value reads past internal spaces/commas itself (rgb(...)/hsl(...))
# so a token boundary at the function name still parses the whole functional
# colour.
def _bg_shorthand_color(vs: uint64, ve: uint64) -> int32:
    i: uint64 = vs
    while i < ve:
        while i < ve and (src_ptr[i] == 32 or src_ptr[i] == 9 or src_ptr[i] == 47):
            i = i + 1
        if i >= ve:
            break
        ts: uint64 = i
        while i < ve and src_ptr[i] != 32 and src_ptr[i] != 9 and src_ptr[i] != 47:
            i = i + 1
        cv: int32 = _color_value(ts)
        if cv >= 0:
            return cv
    return -1


# Classify a `box-shadow` value into a coarse size class (0 none / 1 small /
# 2 medium / 3 large) from the largest length token it carries (offset/blur/
# spread), so a bigger declared shadow renders a bigger drop shadow. `none`
# yields 0. This is deliberately lossy — the paint pass only receives 2 bits.
def _box_shadow_class(vs: uint64, ve: uint64) -> int32:
    # `none` anywhere => no shadow.
    i: uint64 = vs
    while i + 4 <= ve:
        if (src_ptr[i] == 110 or src_ptr[i] == 78) and \
           _unit_at(i, ve, cast[Ptr[uint8]]("none")) != 0:
            return 0
        i = i + 1
    maxpx: int32 = 0
    j: uint64 = vs
    while j < ve:
        if src_ptr[j] >= 48 and src_ptr[j] <= 57:
            v: int32 = 0
            while j < ve and src_ptr[j] >= 48 and src_ptr[j] <= 57:
                v = v * 10 + cast[int32](src_ptr[j] - 48)
                j = j + 1
            if v > maxpx:
                maxpx = v
        else:
            j = j + 1
    if maxpx <= 0:
        return 1                                     # e.g. "0 0 0 #000" => faint
    if maxpx <= 6:
        return 1
    if maxpx <= 14:
        return 2
    return 3


# Pack a background colour with its effective alpha + a box-shadow class into a
# single int that flows unchanged through the layout record set (bfill_rgb).
# Layout: bits 0-23 RGB, bits 24-28 a5 (0 = opaque, 1..31 = translucency level),
# bits 29-30 shadow class, bit 31 always 0 (so the value stays >= 0 and never
# collides with the -1 "unset" sentinel). rgb < 0 (unset) passes through as -1.
# alpha255 is the rgba() channel; opacity255 the element opacity; the two
# multiply. The paint side (htmlpage) unpacks with _unpack_alpha / shadow class.
def _pack_fill_rgb(rgb: int32, alpha255: int32, opacity255: int32,
                   shadow: int32) -> int32:
    if rgb < 0:
        return -1
    eff: int32 = alpha255 * opacity255 / 255
    a5: int32 = 0
    if eff < 255:
        a5 = eff * 31 / 255
        if a5 < 1:
            a5 = 1
    sh: int32 = shadow
    if sh < 0:
        sh = 0
    if sh > 3:
        sh = 3
    return (rgb & 16777215) | (a5 * 16777216) | (sh * 536870912)


# Pack a border colour with the element opacity folded into its alpha (no shadow
# on borders). rgb < 0 (unset => default black) passes through as -1.
def _pack_bordc(rgb: int32, opacity255: int32) -> int32:
    if rgb < 0:
        return -1
    a5: int32 = 0
    if opacity255 < 255:
        a5 = opacity255 * 31 / 255
        if a5 < 1:
            a5 = 1
    return (rgb & 16777215) | (a5 * 16777216)


# Pack a gradient registry ID into the value that flows through r_bg / bfill_rgb
# in place of a solid colour. GRAD_MARK sets bits 24-28 to 31 (a translucency
# level _pack_fill_rgb never emits), so htmlpage reads it back as a gradient.
def _pack_gradient(gid: int32) -> int32:
    return GRAD_MARK | (gid & 16777215)


# ---- gradient accessors (read at paint time by htmlpage) ------------------
# grad_is: is this packed background value a gradient reference (not a solid)?
# a5==31 flags a gradient OR a transform; the shadow bits (29-30) disambiguate —
# 0 for a gradient, 1 for a transform (see XFORM_MARK). Require shadow==0 here so
# a transform-marked fill is NOT mistaken for a gradient.
def grad_is(pv: int32) -> int32:
    if pv < 0:
        return 0
    if (pv / 16777216) & 31 == 31 and (pv / 536870912) & 3 == 0:
        return 1
    return 0

def grad_id_of(pv: int32) -> int32:
    return pv & 16777215

def grad_type_of(gid: int32) -> int32:
    if gid < 0 or gid >= n_grads:
        return 0
    return grad_type[gid]

def grad_angle_of(gid: int32) -> int32:
    if gid < 0 or gid >= n_grads:
        return 180
    return grad_angle[gid]

def grad_nstop_of(gid: int32) -> int32:
    if gid < 0 or gid >= n_grads:
        return 0
    return grad_nstop[gid]

def grad_stop_color(gid: int32, k: int32) -> int32:
    if gid < 0 or gid >= n_grads or k < 0 or k >= GRAD_NSTOP:
        return 0
    return grad_scol[gid * GRAD_NSTOP + k]

def grad_stop_pos(gid: int32, k: int32) -> int32:
    if gid < 0 or gid >= n_grads or k < 0 or k >= GRAD_NSTOP:
        return -1
    return grad_spos[gid * GRAD_NSTOP + k]

# 1 if this is a repeating-* gradient (its stop pattern tiles across the axis).
def grad_repeat_of(gid: int32) -> int32:
    if gid < 0 or gid >= n_grads:
        return 0
    return grad_repeat[gid]

# For a gtype==3 (url) entry: pointer/length of the resolved image name, matched
# against the decoded-image store (htmlimg) by the paint pass.
def grad_url_ptr(gid: int32) -> Ptr[uint8]:
    if gid < 0 or gid >= n_grads:
        return cast[Ptr[uint8]](0)
    return &grad_url_buf[grad_url_off[gid]]

def grad_url_len_of(gid: int32) -> int32:
    if gid < 0 or gid >= n_grads:
        return 0
    return grad_url_len[gid]


# Parse a top-level word run [as,ae) as a `<side>*` / `<angle>deg` gradient
# direction, returning the gradient-line angle in degrees (0 = to top, 90 = to
# right, 180 = to bottom, 270 = to left) or -1 if it is not a direction (i.e.
# the first argument is actually a colour stop).
def _grad_dir(asx: uint64, aex: uint64) -> int32:
    i: uint64 = asx
    while i < aex and _css_ws(src_ptr[i]) != 0:
        i = i + 1
    if i >= aex:
        return -1
    # `to <side> [<side>]`
    if _srcword_is(i, cast[Ptr[uint8]]("to")) != 0:
        htop: int32 = 0
        hbot: int32 = 0
        hlft: int32 = 0
        hrgt: int32 = 0
        j: uint64 = i + 2
        while j < aex:
            while j < aex and _css_ws(src_ptr[j]) != 0:
                j = j + 1
            if j >= aex:
                break
            if _srcword_is(j, cast[Ptr[uint8]]("top")) != 0:
                htop = 1
            elif _srcword_is(j, cast[Ptr[uint8]]("bottom")) != 0:
                hbot = 1
            elif _srcword_is(j, cast[Ptr[uint8]]("left")) != 0:
                hlft = 1
            elif _srcword_is(j, cast[Ptr[uint8]]("right")) != 0:
                hrgt = 1
            while j < aex and _css_ws(src_ptr[j]) == 0:
                j = j + 1
        if htop != 0 and hrgt != 0:
            return 45
        if hbot != 0 and hrgt != 0:
            return 135
        if hbot != 0 and hlft != 0:
            return 225
        if htop != 0 and hlft != 0:
            return 315
        if htop != 0:
            return 0
        if hbot != 0:
            return 180
        if hlft != 0:
            return 270
        if hrgt != 0:
            return 90
        return 180
    # `<number>deg` (also accept a bare number followed by deg). A leading digit
    # or sign that resolves to `<n>deg` is an angle; anything else is a colour.
    neg: int32 = 0
    k: uint64 = i
    if k < aex and src_ptr[k] == 45:
        neg = 1
        k = k + 1
    if k >= aex or src_ptr[k] < 48 or src_ptr[k] > 57:
        return -1
    v: int32 = 0
    while k < aex and src_ptr[k] >= 48 and src_ptr[k] <= 57:
        v = v * 10 + cast[int32](src_ptr[k] - 48)
        k = k + 1
    if k < aex and src_ptr[k] == 46:                     # skip a fractional part
        k = k + 1
        while k < aex and src_ptr[k] >= 48 and src_ptr[k] <= 57:
            k = k + 1
    while k < aex and _css_ws(src_ptr[k]) != 0:
        k = k + 1
    if _srcword_is(k, cast[Ptr[uint8]]("deg")) == 0:
        return -1                                        # e.g. a `10px`-less form
    if neg != 0:
        v = -v
    v = v % 360
    if v < 0:
        v = v + 360
    return v


# Conic first-argument: `[from <angle>] [at <position>]`. Returns the `from`
# angle in degrees (0 if omitted) when the span is a conic direction, or -2 when
# the span is actually a colour stop (so the caller treats it as stop 0). `at
# <pos>` is accepted but the centre offset is not yet applied.
def _conic_dir(asx: uint64, aex: uint64) -> int32:
    i: uint64 = asx
    while i < aex and _css_ws(src_ptr[i]) != 0:
        i = i + 1
    if i >= aex:
        return -2
    is_from: int32 = _srcword_is(i, cast[Ptr[uint8]]("from"))
    is_at: int32 = _srcword_is(i, cast[Ptr[uint8]]("at"))
    if is_from == 0 and is_at == 0:
        return -2                                        # a colour stop
    ang: int32 = 0
    if is_from != 0:
        j: uint64 = i + 4
        while j < aex and _css_ws(src_ptr[j]) != 0:
            j = j + 1
        neg: int32 = 0
        if j < aex and src_ptr[j] == 45:
            neg = 1
            j = j + 1
        v: int32 = 0
        got: int32 = 0
        while j < aex and src_ptr[j] >= 48 and src_ptr[j] <= 57:
            v = v * 10 + cast[int32](src_ptr[j] - 48)
            j = j + 1
            got = 1
        if got != 0:
            if neg != 0:
                v = -v
            v = v % 360
            if v < 0:
                v = v + 360
            ang = v
    return ang


# Parse one gradient argument span [asx,aex) as `<color> [<pos>%]` into stop slot
# `slot` of gradient `gid`. Returns 1 on a valid colour stop, 0 otherwise.
def _grad_stop(gid: int32, slot: int32, asx: uint64, aex: uint64) -> int32:
    cs: uint64 = asx
    while cs < aex and _css_ws(src_ptr[cs]) != 0:
        cs = cs + 1
    col: int32 = _color_value(cs)
    if col < 0:
        return 0
    # position: a depth-0 digit-run immediately followed by '%' (so a percentage
    # inside rgb(...) does not leak in). -1 => auto (spaced evenly at paint).
    pos: int32 = -1
    depth: int32 = 0
    p: uint64 = asx
    while p < aex:
        c: uint8 = src_ptr[p]
        if c == 40:
            depth = depth + 1
        elif c == 41:
            if depth > 0:
                depth = depth - 1
        elif depth == 0 and c >= 48 and c <= 57:
            nv: int32 = 0
            q: uint64 = p
            while q < aex and src_ptr[q] >= 48 and src_ptr[q] <= 57:
                nv = nv * 10 + cast[int32](src_ptr[q] - 48)
                q = q + 1
            if q < aex and src_ptr[q] == 37:              # '%'
                pos = nv * 10                            # percent -> permille
                if pos > 1000:
                    pos = 1000
                p = q
        p = p + 1
    grad_scol[gid * GRAD_NSTOP + slot] = col
    grad_spos[gid * GRAD_NSTOP + slot] = pos
    return 1


# Parse a `linear-gradient(...)` / `radial-gradient(...)` value [vs,ve). On
# success registers it and returns the gradient ID (>=0); returns -1 otherwise.
def _parse_gradient(vs: uint64, ve: uint64) -> int32:
    s: uint64 = vs
    while s < ve and _css_ws(src_ptr[s]) != 0:
        s = s + 1
    gtype: int32 = -1
    grepeat: int32 = 0
    if _unit_at(s, ve, cast[Ptr[uint8]]("repeating-linear-gradient(")) != 0:
        gtype = 0
        grepeat = 1
        s = s + 26
    elif _unit_at(s, ve, cast[Ptr[uint8]]("repeating-radial-gradient(")) != 0:
        gtype = 1
        grepeat = 1
        s = s + 26
    elif _unit_at(s, ve, cast[Ptr[uint8]]("repeating-conic-gradient(")) != 0:
        gtype = 2
        grepeat = 1
        s = s + 25
    elif _unit_at(s, ve, cast[Ptr[uint8]]("linear-gradient(")) != 0:
        gtype = 0
        s = s + 16
    elif _unit_at(s, ve, cast[Ptr[uint8]]("radial-gradient(")) != 0:
        gtype = 1
        s = s + 16
    elif _unit_at(s, ve, cast[Ptr[uint8]]("conic-gradient(")) != 0:
        gtype = 2
        s = s + 15
    else:
        return -1
    if n_grads >= GRAD_MAX:
        return -1
    # find the matching close paren (track nesting for rgb()/hsl()).
    depth: int32 = 1
    e: uint64 = s
    while e < ve and depth > 0:
        if src_ptr[e] == 40:
            depth = depth + 1
        elif src_ptr[e] == 41:
            depth = depth - 1
            if depth == 0:
                break
        e = e + 1
    # e now indexes the close paren (or ve). args live in [s, e).
    gid: int32 = n_grads
    grad_type[gid] = gtype
    grad_repeat[gid] = grepeat
    if gtype == 2:
        grad_angle[gid] = 0                              # conic default: from 0deg
    else:
        grad_angle[gid] = 180                            # linear default: to bottom
    nst: int32 = 0
    first: int32 = 1
    ap: uint64 = s
    while ap < e:
        # arg span [ap, ac) up to the next depth-0 comma.
        ac: uint64 = ap
        d2: int32 = 0
        while ac < e:
            c2: uint8 = src_ptr[ac]
            if c2 == 40:
                d2 = d2 + 1
            elif c2 == 41:
                if d2 > 0:
                    d2 = d2 - 1
            elif c2 == 44 and d2 == 0:
                break
            ac = ac + 1
        if first != 0:
            if gtype == 2:
                # conic first arg: `[from <angle>] [at <pos>]` or a colour stop.
                cd: int32 = _conic_dir(ap, ac)
                if cd != -2:
                    grad_angle[gid] = cd
                    first = 0
                    ap = ac + 1
                    continue
                first = 0
            else:
                dir: int32 = _grad_dir(ap, ac)
                if dir >= 0:
                    if gtype == 0:
                        grad_angle[gid] = dir
                    first = 0
                    ap = ac + 1
                    continue
                first = 0
        if nst < GRAD_NSTOP:
            if _grad_stop(gid, nst, ap, ac) != 0:
                nst = nst + 1
        ap = ac + 1
    if nst < 2:
        return -1                                        # need >=2 stops
    grad_nstop[gid] = nst
    n_grads = n_grads + 1
    return gid


# Parse a `background-image: url(<path>)` value [vs,ve). On success stores the
# resolved name in the url registry (as a gtype==3 gradient entry so it flows
# through r_bg under GRAD_MARK) and returns its ID; -1 otherwise. Quotes around
# the path are stripped. The paint pass matches the name against the decoded
# image store (htmlimg); if the image is not decoded the element stays empty.
def _parse_bg_url(vs: uint64, ve: uint64) -> int32:
    s: uint64 = vs
    while s < ve and _css_ws(src_ptr[s]) != 0:
        s = s + 1
    if _unit_at(s, ve, cast[Ptr[uint8]]("url(")) == 0:
        return -1
    if n_grads >= GRAD_MAX:
        return -1
    p: uint64 = s + 4
    while p < ve and _css_ws(src_ptr[p]) != 0:
        p = p + 1
    # optional single/double quote
    q: uint8 = 0
    if p < ve and (src_ptr[p] == 34 or src_ptr[p] == 39):
        q = src_ptr[p]
        p = p + 1
    ns: uint64 = p
    while p < ve and src_ptr[p] != 41:
        if q != 0 and src_ptr[p] == q:
            break
        p = p + 1
    ne: uint64 = p
    # trim trailing whitespace (unquoted form)
    while ne > ns and _css_ws(src_ptr[ne - 1]) != 0:
        ne = ne - 1
    slen: int32 = cast[int32](ne - ns)
    if slen <= 0 or grad_url_used + cast[uint64](slen) > cast[uint64](GRAD_URL_CAP):
        return -1
    gid: int32 = n_grads
    grad_type[gid] = 3
    grad_repeat[gid] = 0
    grad_nstop[gid] = 0
    grad_url_off[gid] = grad_url_used
    grad_url_len[gid] = slen
    k: int32 = 0
    while k < slen:
        grad_url_buf[grad_url_used + cast[uint64](k)] = src_ptr[ns + cast[uint64](k)]
        k = k + 1
    grad_url_used = grad_url_used + cast[uint64](slen)
    n_grads = n_grads + 1
    return gid


# Parse a bare numeric background token src[s..e) (e.g. "40px", "50%", "0").
# Returns 1 and sets g_bg_val (rounded integer) + g_bg_pct (1 = '%', else 0) on
# success; returns 0 for a non-numeric token (auto / keyword / empty).
def _bg_num(s: uint64, e: uint64) -> int32:
    i: uint64 = s
    while i < e and _css_ws(src_ptr[i]) != 0:
        i = i + 1
    neg: int32 = 0
    if i < e and src_ptr[i] == 45:                       # '-'
        neg = 1
        i = i + 1
    elif i < e and src_ptr[i] == 43:                     # '+'
        i = i + 1
    seen: int32 = 0
    whole: int32 = 0
    while i < e and src_ptr[i] >= 48 and src_ptr[i] <= 57:
        whole = whole * 10 + cast[int32](src_ptr[i] - 48)
        seen = 1
        i = i + 1
    if i < e and src_ptr[i] == 46:                       # '.' fractional (round)
        i = i + 1
        f0: int32 = -1
        if i < e and src_ptr[i] >= 48 and src_ptr[i] <= 57:
            f0 = cast[int32](src_ptr[i] - 48)
            seen = 1
        while i < e and src_ptr[i] >= 48 and src_ptr[i] <= 57:
            i = i + 1
        if f0 >= 5:
            whole = whole + 1
    if seen == 0:
        return 0
    if neg != 0:
        whole = 0 - whole
    g_bg_val = whole
    g_bg_pct = 0
    if i < e and src_ptr[i] == 37:                       # '%'
        g_bg_pct = 1
    return 1


# Advance past one whitespace-separated token in src[*ps..e): returns the token
# span via the caller reading _bg_tok_s/_bg_tok_e, and the next scan position.
_bg_tok_s: uint64 = 0
_bg_tok_e: uint64 = 0
def _bg_next_tok(p: uint64, e: uint64) -> uint64:
    while p < e and _css_ws(src_ptr[p]) != 0:
        p = p + 1
    _bg_tok_s = p
    while p < e and _css_ws(src_ptr[p]) == 0:
        p = p + 1
    _bg_tok_e = p
    return p


# background-size: cover | contain | <w> [<h>] | auto. Each explicit component is
# `auto` or a px/percent length. A single value sets the width; the height is
# auto (derived from the aspect ratio at paint time).
def _parse_bg_size(vs: uint64, ve: uint64):
    s: uint64 = _val_start(vs, ve)
    if _val_starts(s, ve, cast[Ptr[uint8]]("cover")) != 0:
        d_bgsz_mode = 1
        return
    if _val_starts(s, ve, cast[Ptr[uint8]]("contain")) != 0:
        d_bgsz_mode = 2
        return
    # component 1 (width)
    p: uint64 = _bg_next_tok(s, ve)
    t1s: uint64 = _bg_tok_s
    t1e: uint64 = _bg_tok_e
    if t1e <= t1s:
        return
    d_bgsz_mode = 3
    if _prop_is(t1s, t1e, cast[Ptr[uint8]]("auto")) != 0:
        d_bgsz_wp = 2
    elif _bg_num(t1s, t1e) != 0:
        d_bgsz_w = g_bg_val
        d_bgsz_wp = g_bg_pct
    else:
        d_bgsz_wp = 2
    # component 2 (height), optional
    p = _bg_next_tok(p, ve)
    t2s: uint64 = _bg_tok_s
    t2e: uint64 = _bg_tok_e
    if t2e <= t2s:
        d_bgsz_hp = 2                                     # single value -> auto
        return
    if _prop_is(t2s, t2e, cast[Ptr[uint8]]("auto")) != 0:
        d_bgsz_hp = 2
    elif _bg_num(t2s, t2e) != 0:
        d_bgsz_h = g_bg_val
        d_bgsz_hp = g_bg_pct
    else:
        d_bgsz_hp = 2


# Assign one background-position token to the x or y axis. akw: 0 x-only keyword
# (left/right), 1 y-only keyword (top/bottom), else a positional value/center.
def _parse_bg_pos(vs: uint64, ve: uint64):
    # engaging position implies the CSS default size (auto/natural), not the
    # legacy stretch-to-fill — but only if background-size was not itself set.
    if d_bgsz_mode == 0:
        d_bgsz_mode = 3
        d_bgsz_wp = 2
        d_bgsz_hp = 2
    s: uint64 = _val_start(vs, ve)
    # explicit-axis keywords first; positional (center/number) collected in order
    xset: int32 = 0
    yset: int32 = 0
    # free positional values (max 2): value + percent flag
    fv0: int32 = 0
    fp0: int32 = 0
    fv1: int32 = 0
    fp1: int32 = 0
    nfree: int32 = 0
    ntok: int32 = 0
    p: uint64 = s
    while ntok < 2:
        p = _bg_next_tok(p, ve)
        ts: uint64 = _bg_tok_s
        te: uint64 = _bg_tok_e
        if te <= ts:
            break
        ntok = ntok + 1
        if _prop_is(ts, te, cast[Ptr[uint8]]("left")) != 0:
            d_bgpos_x = 0
            d_bgpos_xp = 1
            xset = 1
        elif _prop_is(ts, te, cast[Ptr[uint8]]("right")) != 0:
            d_bgpos_x = 100
            d_bgpos_xp = 1
            xset = 1
        elif _prop_is(ts, te, cast[Ptr[uint8]]("top")) != 0:
            d_bgpos_y = 0
            d_bgpos_yp = 1
            yset = 1
        elif _prop_is(ts, te, cast[Ptr[uint8]]("bottom")) != 0:
            d_bgpos_y = 100
            d_bgpos_yp = 1
            yset = 1
        elif _prop_is(ts, te, cast[Ptr[uint8]]("center")) != 0:
            if nfree == 0:
                fv0 = 50
                fp0 = 1
            else:
                fv1 = 50
                fp1 = 1
            nfree = nfree + 1
        elif _bg_num(ts, te) != 0:
            if nfree == 0:
                fv0 = g_bg_val
                fp0 = g_bg_pct
            else:
                fv1 = g_bg_val
                fp1 = g_bg_pct
            nfree = nfree + 1
    # assign free positional values to unfixed axes, x then y
    fi: int32 = 0
    if xset == 0 and fi < nfree:
        if fi == 0:
            d_bgpos_x = fv0
            d_bgpos_xp = fp0
        else:
            d_bgpos_x = fv1
            d_bgpos_xp = fp1
        xset = 1
        fi = fi + 1
    if yset == 0 and fi < nfree:
        if fi == 0:
            d_bgpos_y = fv0
            d_bgpos_yp = fp0
        else:
            d_bgpos_y = fv1
            d_bgpos_yp = fp1
        yset = 1
        fi = fi + 1
    # a single-token value leaves the other axis at center (CSS rule)
    if ntok == 1:
        if xset == 0:
            d_bgpos_x = 50
            d_bgpos_xp = 1
        if yset == 0:
            d_bgpos_y = 50
            d_bgpos_yp = 1


# object-position: same 1-or-2 token grammar as background-position (keywords
# left/right/top/bottom/center, <percent>, <px>), writing d_objpos{x,y}{,p} and
# arming the set flag. A single token leaves the other axis at center. Default
# (property absent) is 50% 50%.
def _parse_obj_pos(vs: uint64, ve: uint64):
    d_objpos = 1
    s: uint64 = _val_start(vs, ve)
    xset: int32 = 0
    yset: int32 = 0
    fv0: int32 = 0
    fp0: int32 = 0
    fv1: int32 = 0
    fp1: int32 = 0
    nfree: int32 = 0
    ntok: int32 = 0
    p: uint64 = s
    while ntok < 2:
        p = _bg_next_tok(p, ve)
        ts: uint64 = _bg_tok_s
        te: uint64 = _bg_tok_e
        if te <= ts:
            break
        ntok = ntok + 1
        if _prop_is(ts, te, cast[Ptr[uint8]]("left")) != 0:
            d_objposx = 0
            d_objposxp = 1
            xset = 1
        elif _prop_is(ts, te, cast[Ptr[uint8]]("right")) != 0:
            d_objposx = 100
            d_objposxp = 1
            xset = 1
        elif _prop_is(ts, te, cast[Ptr[uint8]]("top")) != 0:
            d_objposy = 0
            d_objposyp = 1
            yset = 1
        elif _prop_is(ts, te, cast[Ptr[uint8]]("bottom")) != 0:
            d_objposy = 100
            d_objposyp = 1
            yset = 1
        elif _prop_is(ts, te, cast[Ptr[uint8]]("center")) != 0:
            if nfree == 0:
                fv0 = 50
                fp0 = 1
            else:
                fv1 = 50
                fp1 = 1
            nfree = nfree + 1
        elif _bg_num(ts, te) != 0:
            if nfree == 0:
                fv0 = g_bg_val
                fp0 = g_bg_pct
            else:
                fv1 = g_bg_val
                fp1 = g_bg_pct
            nfree = nfree + 1
    fi: int32 = 0
    if xset == 0 and fi < nfree:
        if fi == 0:
            d_objposx = fv0
            d_objposxp = fp0
        else:
            d_objposx = fv1
            d_objposxp = fp1
        xset = 1
        fi = fi + 1
    if yset == 0 and fi < nfree:
        if fi == 0:
            d_objposy = fv0
            d_objposyp = fp0
        else:
            d_objposy = fv1
            d_objposyp = fp1
        yset = 1
        fi = fi + 1
    if ntok == 1:
        if xset == 0:
            d_objposx = 50
            d_objposxp = 1
        if yset == 0:
            d_objposy = 50
            d_objposyp = 1


# object-fit keyword -> code: 1 fill / 2 contain / 3 cover / 4 none /
# 5 scale-down. Unknown -> 0 (unset, treated as the fill default).
def _objfit_value(vs: uint64, ve: uint64) -> int32:
    s: uint64 = _val_start(vs, ve)
    if _val_starts(s, ve, cast[Ptr[uint8]]("scale-down")) != 0:
        return 5
    if _val_starts(s, ve, cast[Ptr[uint8]]("contain")) != 0:
        return 2
    if _val_starts(s, ve, cast[Ptr[uint8]]("cover")) != 0:
        return 3
    if _val_starts(s, ve, cast[Ptr[uint8]]("none")) != 0:
        return 4
    if _val_starts(s, ve, cast[Ptr[uint8]]("fill")) != 0:
        return 1
    return 0


# aspect-ratio: `<w> / <h>` or a single `<number>`. Fills d_aspw/d_asph (milli).
# `auto` (or unparseable) leaves them 0 (unset). A single number N means N/1.
def _parse_aspect_ratio(vs: uint64, ve: uint64):
    s: uint64 = _val_start(vs, ve)
    # find a '/' separator (if any)
    slash: uint64 = s
    found: int32 = 0
    while slash < ve:
        if src_ptr[slash] == 47:                         # '/'
            found = 1
            break
        slash = slash + 1
    if found != 0:
        w: int32 = _flexnum_milli(s, slash)
        h: int32 = _flexnum_milli(slash + 1, ve)
        if w > 0 and h > 0:
            d_aspw = w
            d_asph = h
    else:
        w2: int32 = _flexnum_milli(s, ve)
        if w2 > 0:
            d_aspw = w2
            d_asph = 1000                                # N / 1


# background-repeat: repeat (0) | no-repeat (1) | repeat-x (2) | repeat-y (3).
# `space`/`round` are approximated as no-repeat / repeat respectively.
def _parse_bg_repeat(vs: uint64, ve: uint64):
    # engaging repeat implies the CSS default size (auto/natural) unless
    # background-size was set — otherwise a stretch-fill hides all tiling.
    if d_bgsz_mode == 0:
        d_bgsz_mode = 3
        d_bgsz_wp = 2
        d_bgsz_hp = 2
    s: uint64 = _val_start(vs, ve)
    if _val_starts(s, ve, cast[Ptr[uint8]]("no-repeat")) != 0:
        d_bgrep = 1
    elif _val_starts(s, ve, cast[Ptr[uint8]]("repeat-x")) != 0:
        d_bgrep = 2
    elif _val_starts(s, ve, cast[Ptr[uint8]]("repeat-y")) != 0:
        d_bgrep = 3
    elif _val_starts(s, ve, cast[Ptr[uint8]]("space")) != 0:
        d_bgrep = 1
    elif _val_starts(s, ve, cast[Ptr[uint8]]("round")) != 0:
        d_bgrep = 0
    else:
        d_bgrep = 0


# Fold the declaration-scope background placement onto a url gid (bounds-checked).
def _bg_store_place(gid: int32):
    if gid < 0 or gid >= GRAD_MAX:
        return
    grad_bg_szmode[gid] = d_bgsz_mode
    grad_bg_szw[gid] = d_bgsz_w
    grad_bg_szwp[gid] = d_bgsz_wp
    grad_bg_szh[gid] = d_bgsz_h
    grad_bg_szhp[gid] = d_bgsz_hp
    grad_bg_posx[gid] = d_bgpos_x
    grad_bg_posxp[gid] = d_bgpos_xp
    grad_bg_posy[gid] = d_bgpos_y
    grad_bg_posyp[gid] = d_bgpos_yp
    grad_bg_rep[gid] = d_bgrep


# ---- paint-time accessors for per-gid background placement -------------------
def grad_bg_szmode_of(gid: int32) -> int32:
    if gid < 0 or gid >= n_grads:
        return 0
    return grad_bg_szmode[gid]

def grad_bg_szw_of(gid: int32) -> int32:
    if gid < 0 or gid >= n_grads:
        return 0
    return grad_bg_szw[gid]

def grad_bg_szwp_of(gid: int32) -> int32:
    if gid < 0 or gid >= n_grads:
        return 2
    return grad_bg_szwp[gid]

def grad_bg_szh_of(gid: int32) -> int32:
    if gid < 0 or gid >= n_grads:
        return 0
    return grad_bg_szh[gid]

def grad_bg_szhp_of(gid: int32) -> int32:
    if gid < 0 or gid >= n_grads:
        return 2
    return grad_bg_szhp[gid]

def grad_bg_posx_of(gid: int32) -> int32:
    if gid < 0 or gid >= n_grads:
        return 0
    return grad_bg_posx[gid]

def grad_bg_posxp_of(gid: int32) -> int32:
    if gid < 0 or gid >= n_grads:
        return 1
    return grad_bg_posxp[gid]

def grad_bg_posy_of(gid: int32) -> int32:
    if gid < 0 or gid >= n_grads:
        return 0
    return grad_bg_posy[gid]

def grad_bg_posyp_of(gid: int32) -> int32:
    if gid < 0 or gid >= n_grads:
        return 1
    return grad_bg_posyp[gid]

def grad_bg_rep_of(gid: int32) -> int32:
    if gid < 0 or gid >= n_grads:
        return 0
    return grad_bg_rep[gid]


# Exact (case-insensitive) equality of src[a,e) with NUL-terminated lit.
def _tok_eq(a: uint64, e: uint64, lit: Ptr[uint8]) -> int32:
    i: uint64 = a
    j: int32 = 0
    while lit[j] != 0:
        if i >= e or _hx_lower(src_ptr[i]) != lit[j]:
            return 0
        i = i + 1
        j = j + 1
    if i != e:
        return 0
    return 1


# Is src[a,e) a known `animation` shorthand keyword (NOT an animation-name)?
# Timing functions, iteration counts, directions, fill-modes, play-states.
def _anim_kw_skip(a: uint64, e: uint64) -> int32:
    if _tok_eq(a, e, cast[Ptr[uint8]]("infinite")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("normal")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("reverse")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("alternate")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("alternate-reverse")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("forwards")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("backwards")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("both")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("paused")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("running")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("linear")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("ease")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("ease-in")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("ease-out")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("ease-in-out")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("step-start")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("step-end")) != 0:
        return 1
    return 0


# Map an animation-fill-mode token src[a,e) to a code (0 none / 1 forwards /
# 2 backwards / 3 both), or -1 if the token is not a fill-mode keyword.
def _anim_fill_kw(a: uint64, e: uint64) -> int32:
    if _tok_eq(a, e, cast[Ptr[uint8]]("none")) != 0:
        return 0
    if _tok_eq(a, e, cast[Ptr[uint8]]("forwards")) != 0:
        return 1
    if _tok_eq(a, e, cast[Ptr[uint8]]("backwards")) != 0:
        return 2
    if _tok_eq(a, e, cast[Ptr[uint8]]("both")) != 0:
        return 3
    return -1


def _apply_decl(ps: uint64, pe: uint64, vs: uint64, ve: uint64):
    # var(--name[, fallback]): resolve the custom property, then re-dispatch this
    # declaration against the token's value (or, if unset, the fallback).
    vstart: uint64 = _val_start(vs, ve)
    if _unit_at(vstart, ve, cast[Ptr[uint8]]("var(")) != 0:
        q: uint64 = vstart + 4
        while q < ve and (src_ptr[q] == 32 or src_ptr[q] == 9):
            q = q + 1
        ns: uint64 = q
        while q < ve and src_ptr[q] != 44 and src_ptr[q] != 41:
            q = q + 1
        ne: uint64 = q
        while ne > ns and (src_ptr[ne - 1] == 32 or src_ptr[ne - 1] == 9):
            ne = ne - 1
        idx: int32 = _cvar_find(ns, ne)
        if idx >= 0:
            # Re-dispatch against the token's value. The property span (ps..pe)
            # lives in the current buffer while the value lives in cvar_valbuf,
            # so splice "<property>:<value>" into one scratch buffer and parse
            # that — otherwise the swapped src_ptr would misread the property.
            plen: int32 = cast[int32](pe - ps)
            v2s: uint64 = cast[uint64](cvar_val_off[idx])
            vlen: int32 = cvar_val_len[idx]
            if plen > 0 and plen + vlen + 1 <= CVAR_SCRATCH:
                w: int32 = 0
                while w < plen:
                    cvar_scratch[w] = src_ptr[ps + cast[uint64](w)]
                    w = w + 1
                cvar_scratch[plen] = 58                       # ':'
                w2: int32 = 0
                while w2 < vlen:
                    cvar_scratch[plen + 1 + w2] = cvar_valbuf[cast[int32](v2s) + w2]
                    w2 = w2 + 1
                sp: Ptr[uint8] = src_ptr
                sl: uint64 = src_len
                src_ptr = &cvar_scratch[0]
                src_len = cast[uint64](plen + 1 + vlen)
                _apply_decl(0, cast[uint64](plen), cast[uint64](plen + 1), \
                            cast[uint64](plen + 1 + vlen))
                src_ptr = sp
                src_len = sl
            return
        if q < ve and src_ptr[q] == 44:                      # ', fallback'
            fbs: uint64 = q + 1
            while fbs < ve and (src_ptr[fbs] == 32 or src_ptr[fbs] == 9):
                fbs = fbs + 1
            fbe: uint64 = ve
            while fbe > fbs and src_ptr[fbe - 1] != 41:      # trim to ')'
                fbe = fbe - 1
            if fbe > fbs:
                fbe = fbe - 1                                # drop the ')'
            if fbe > fbs:
                _apply_decl(ps, pe, fbs, fbe)
        return
    if _box_decl(ps, pe, vs, ve) != 0:
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("color")) != 0:
        d_color = _color_value(_val_start(vs, ve))
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("background-color")) != 0:
        cv: int32 = _color_value(_val_start(vs, ve))
        if cv >= 0:
            d_bg = cv
            d_bg_alpha = g_cv_alpha                   # rgba()/#rrggbbaa translucency
        return
    # background-size / -position / -repeat: fold onto the rule's url gid at
    # rule-store time (they place/size/tile the background image at paint time).
    if _prop_is(ps, pe, cast[Ptr[uint8]]("background-size")) != 0:
        _parse_bg_size(vs, ve)
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("background-position")) != 0:
        _parse_bg_pos(vs, ve)
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("background-repeat")) != 0:
        _parse_bg_repeat(vs, ve)
        return
    # background-image: a linear-/radial-gradient() paints a real gradient; a
    # url() (raster image) is not resolvable here and falls through unchanged.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("background-image")) != 0:
        gi: int32 = _parse_gradient(vs, ve)
        if gi >= 0:
            d_bg_grad = gi
            return
        ui: int32 = _parse_bg_url(vs, ve)
        if ui >= 0:
            d_bg_grad = ui
        return
    # `background:` shorthand — the colour may appear at ANY position (`background:
    # no-repeat #333`, `background: center/cover #333`), not just first, so scan
    # every space/'/'-separated token for the first one that parses as a colour.
    # A linear-/radial-gradient() token is recognised first and wins.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("background")) != 0:
        gib: int32 = _parse_gradient(_val_start(vs, ve), ve)
        if gib >= 0:
            d_bg_grad = gib
            return
        uib: int32 = _parse_bg_url(_val_start(vs, ve), ve)
        if uib >= 0:
            d_bg_grad = uib
            return
        cvb: int32 = _bg_shorthand_color(vs, ve)
        if cvb >= 0:
            d_bg = cvb
            d_bg_alpha = g_cv_alpha
        return
    # opacity: a 0..1 fraction (or NN%) dimming the element's own fill + border.
    # Folded into the packed background/border alpha at rule-store time.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("opacity")) != 0:
        d_opacity = _parse_alpha_frac(_val_start(vs, ve))
        return
    # animation-name: <name> — the keyframes to settle to. `none` clears it.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("animation-name")) != 0:
        ns2: uint64 = _val_start(vs, ve)
        if _val_starts(ns2, ve, cast[Ptr[uint8]]("none")) == 0:
            d_animname = _kf_intern(ns2, ve)
        return
    # animation-fill-mode: <none|forwards|backwards|both> — which frame the
    # settled render overlays (forwards/both = end, none/backwards = 0% frame).
    if _prop_is(ps, pe, cast[Ptr[uint8]]("animation-fill-mode")) != 0:
        fs2: uint64 = _val_start(vs, ve)
        fe2: uint64 = fs2
        while fe2 < ve and src_ptr[fe2] != 32 and src_ptr[fe2] != 9 and \
              src_ptr[fe2] != 44:
            fe2 = fe2 + 1
        fk: int32 = _anim_fill_kw(fs2, fe2)
        if fk >= 0:
            d_animfill = fk
        return
    # animation: <shorthand> — the animation-name may sit at ANY position among
    # durations/timing-functions/keywords. Scan whitespace/comma tokens for the
    # first CUSTOM ident (a name that is not a known animation keyword, a number/
    # time, or a function like steps()/cubic-bezier()).
    if _prop_is(ps, pe, cast[Ptr[uint8]]("animation")) != 0:
        i2: uint64 = _val_start(vs, ve)
        got_name: int32 = 0
        while i2 < ve:
            if src_ptr[i2] == 32 or src_ptr[i2] == 9 or src_ptr[i2] == 44:
                i2 = i2 + 1
                continue
            ts: uint64 = i2
            has_paren: int32 = 0
            while i2 < ve and src_ptr[i2] != 32 and src_ptr[i2] != 9 and \
                  src_ptr[i2] != 44:
                if src_ptr[i2] == 40:
                    has_paren = 1
                i2 = i2 + 1
            te: uint64 = i2
            fc: uint8 = src_ptr[ts]
            is_num: int32 = 0
            if (fc >= 48 and fc <= 57) or fc == 46 or fc == 45 or fc == 43:
                is_num = 1
            # A fill-mode keyword inside the shorthand (`forwards`/`backwards`/
            # `both`) records the fill mode. `none` is ambiguous (could be
            # animation-name:none OR fill-mode:none); treat a bare `none` as the
            # name reset and only capture the unambiguous fill-mode keywords.
            fk2: int32 = _anim_fill_kw(ts, te)
            if fk2 >= 1:
                d_animfill = fk2
            if has_paren == 0 and is_num == 0 and got_name == 0 and \
               _anim_kw_skip(ts, te) == 0:
                if _val_starts(ts, te, cast[Ptr[uint8]]("none")) == 0:
                    d_animname = _kf_intern(ts, te)
                got_name = 1
                # keep scanning: a fill-mode keyword may follow the name.
        return
    # box-shadow: recognise the property and derive a coarse size class from the
    # blur radius (2nd/3rd length). `none` clears it. The offset/blur/spread/
    # colour are approximated by a default drop shadow in the paint pass (the
    # per-element geometry cannot be plumbed through the layout record set).
    if _prop_is(ps, pe, cast[Ptr[uint8]]("box-shadow")) != 0:
        d_boxshadow = _box_shadow_class(vs, ve)
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("font-weight")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("bold")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("700")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("800")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("900")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("600")) != 0:
            d_weight = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("normal")) != 0:
            d_weight = 2
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("text-align")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("center")) != 0:
            d_align = 2
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("right")) != 0:
            d_align = 3
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("left")) != 0:
            d_align = 1
        return
    # text-decoration / text-decoration-line: the value is a space list that may
    # carry a style/colour (e.g. "underline dotted red"); we honour the LINE
    # keyword. "underline" -> draw a rule; "none" -> suppress (strip link u-line).
    if _prop_is(ps, pe, cast[Ptr[uint8]]("text-decoration")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("text-decoration-line")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("underline")) != 0:
            d_deco = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("line-through")) != 0:
            d_deco = 3
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("none")) != 0:
            d_deco = 2
        return
    # font-style: italic/oblique -> faux-oblique shear (1); normal -> upright (2).
    if _prop_is(ps, pe, cast[Ptr[uint8]]("font-style")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("italic")) != 0 or \
           _val_starts(vs, ve, cast[Ptr[uint8]]("oblique")) != 0:
            d_fstyle = 1
        elif _val_starts(vs, ve, cast[Ptr[uint8]]("normal")) != 0:
            d_fstyle = 2
        return
    # list-style / list-style-type: only `none` is honoured (suppress the <li>
    # bullet/number). Any list-style shorthand carrying `none` counts — the
    # shorthand rarely names a different type alongside none on real menus.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("list-style")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("list-style-type")) != 0:
        if _val_has_word(vs, ve, cast[Ptr[uint8]]("none")) != 0:
            d_nomark = 1
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("display")) != 0:
        d_disp = _disp_value(vs, ve)
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("flex-direction")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("column")) != 0:
            d_flexdir = 1
        else:
            d_flexdir = 2
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("justify-content")) != 0:
        jv: int32 = _justify_value(vs, ve)
        if jv != 0:
            d_justify = jv
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("align-items")) != 0:
        av: int32 = _align_items_value(vs, ve)
        if av != 0:
            d_aitems = av
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("align-content")) != 0:
        acv: int32 = _align_content_value(vs, ve)
        if acv != 0:
            d_acontent = acv
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("flex-wrap")) != 0:
        if _val_starts(vs, ve, cast[Ptr[uint8]]("wrap")) != 0:
            d_flexwrap = 1
        else:
            d_flexwrap = 0                            # nowrap / wrap-reverse->off
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("grid-auto-flow")) != 0:
        d_gaflow = _grid_auto_flow_value(vs, ve)
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("grid-template-columns")) != 0:
        d_gtcn = _grid_parse_template(vs, ve)
        gc: int32 = 0
        while gc < d_gtcn and gc < GRID_MAXTRACK:
            d_gtc[gc] = gts_enc[gc]
            gc = gc + 1
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("grid-template-rows")) != 0:
        d_gtrn = _grid_parse_template(vs, ve)
        gr: int32 = 0
        while gr < d_gtrn and gr < GRID_MAXTRACK:
            d_gtr[gr] = gts_enc[gr]
            gr = gr + 1
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("grid-column")) != 0:
        _grid_column_parse(vs, ve)
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("grid-row")) != 0:
        _grid_row_parse(vs, ve)
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("grid-template-areas")) != 0:
        _grid_parse_areas(vs, ve)
        d_gan = ga_s_n
        d_gacols = ga_s_cols
        ga: int32 = 0
        while ga < ga_s_n and ga < GAREA_MAX:
            d_ga_name[ga] = ga_s_name[ga]
            d_ga_r0[ga]   = ga_s_minr[ga]
            d_ga_c0[ga]   = ga_s_minc[ga]
            d_ga_rsp[ga]  = ga_s_maxr[ga] - ga_s_minr[ga] + 1
            d_ga_csp[ga]  = ga_s_maxc[ga] - ga_s_minc[ga] + 1
            ga = ga + 1
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("grid-area")) != 0:
        _grid_area_parse(vs, ve)
        return
    # flex gaps. `gap: <row> [<col>]` shorthand sets both (one value => both);
    # `row-gap` / `column-gap` set one axis.
    if _prop_is(ps, pe, cast[Ptr[uint8]]("gap")) != 0:
        _parse_box_lens(vs, ve)
        if n_box_lens >= 1:
            d_rowgap = box_lens[0]
            if n_box_lens >= 2:
                d_flexgap = box_lens[1]
            else:
                d_flexgap = box_lens[0]
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("column-gap")) != 0:
        gp: int32 = _style_len(vs, ve)
        if gp >= 0:
            d_flexgap = gp
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("row-gap")) != 0:
        rgp: int32 = _style_len(vs, ve)
        if rgp >= 0:
            d_rowgap = rgp
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("font-size")) != 0:
        fp: int32 = _style_len(vs, ve)
        if fp > 0:
            d_fontpx = fp
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("line-height")) != 0:
        lh: int32 = _lineh_value(_val_start(vs, ve), ve)
        if lh != 0:
            d_lineh = lh
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("white-space")) != 0:
        ws: int32 = _ws_value(vs, ve)
        if ws != 0:
            d_ws = ws
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("overflow-wrap")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("word-wrap")) != 0 or \
       _prop_is(ps, pe, cast[Ptr[uint8]]("word-break")) != 0:
        ow: int32 = _ovw_value(vs, ve)
        if ow != 0:
            d_ovw = ow
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("flex-grow")) != 0:
        d_flexg = _flexnum_milli(vs, ve)
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("flex-shrink")) != 0:
        d_flexs = _flexnum_milli(vs, ve)
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("flex-basis")) != 0:
        _flex_basis_set(vs, ve)
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("flex")) != 0:
        _flex_shorthand(vs, ve)
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("vertical-align")) != 0:
        vv: int32 = _valign_value(vs, ve)
        if vv != 0:
            d_valign = vv
        return
    if _prop_is(ps, pe, cast[Ptr[uint8]]("text-indent")) != 0:
        ti: int32 = _style_len(vs, ve)
        if ti >= 0:
            d_tindent = ti
        return


# Parse a declaration block src[a..b) into d_* globals.
def _parse_decls(a: uint64, b: uint64):
    d_color = -1
    d_bg = -1
    d_bg_grad = -1
    d_bgsz_mode = 0
    d_bgsz_w = 0
    d_bgsz_wp = 2
    d_bgsz_h = 0
    d_bgsz_hp = 2
    d_bgpos_x = 0
    d_bgpos_xp = 1
    d_bgpos_y = 0
    d_bgpos_yp = 1
    d_bgrep = 0
    d_weight = 0
    d_align = 0
    d_deco = 0
    d_fstyle = 0
    d_nomark = 0
    d_disp = 0
    d_flexdir = 0
    d_justify = 0
    d_aitems = 0
    d_acontent = 0
    d_flexgap = -1
    d_rowgap = -1
    d_flexwrap = 0
    d_gaflow = 0
    d_gtcn = 0
    d_gtrn = 0
    d_gcspan = 0
    d_gcstart = 0
    d_grspan = 0
    d_grstart = 0
    d_gan = 0
    d_gacols = 0
    d_gareaname = -1
    d_ml = -1
    d_mr = -1
    d_mt = -1
    d_mb = -1
    d_wd = -1
    d_bd = -1
    d_bordc = -1
    d_accent = -1
    d_bordr = 0
    d_bw_t = -1
    d_bw_r = -1
    d_bw_b = -1
    d_bw_l = -1
    d_bs_t = -1
    d_bs_r = -1
    d_bs_b = -1
    d_bs_l = -1
    d_bordps = 0
    d_bordss = 0
    d_bc_t = -1
    d_bc_r = -1
    d_bc_b = -1
    d_bc_l = -1
    d_filter = 0
    d_xform = -1
    d_animname = -1
    d_animfill = -1
    d_bg_alpha = 255
    d_opacity = 255
    d_boxshadow = 0
    d_center = 0
    d_fontpx = -1
    d_lineh = 0
    d_ws = 0
    d_ovw = 0
    d_float = 0
    d_clear = 0
    d_pos = 0
    d_top = -1
    d_left = -1
    d_right = -1
    d_bottom = -1
    d_zidx = ZIDX_UNSET
    d_minw = -1
    d_ht = -1
    d_minh = -1
    d_maxh = -1
    d_boxsz = 0
    d_appear = 0
    d_padx = 0
    d_pady = 0
    d_bordw = 0
    d_flexg = -1
    d_flexs = -1
    d_flexb = -1
    d_posfx = 0
    d_valign = 0
    d_tindent = TINDENT_UNSET
    d_ovfx = 0
    d_ovfy = 0
    d_txtovf = 0
    d_objfit = 0
    d_objpos = 0
    d_objposx = 0
    d_objposxp = 1
    d_objposy = 0
    d_objposyp = 1
    d_aspw = 0
    d_asph = 0
    i: uint64 = a
    while i < b:
        ps: uint64 = i
        while i < b and src_ptr[i] != 58 and src_ptr[i] != 59:   # ':' ';'
            i = i + 1
        if i < b and src_ptr[i] == 58:
            pe: uint64 = i
            i = i + 1
            vs: uint64 = i
            while i < b and src_ptr[i] != 59:
                i = i + 1
            _apply_decl(ps, pe, vs, i)
        if i < b and src_ptr[i] == 59:
            i = i + 1
    # NOTE: box-sizing:border-box reduction is NOT applied here. A stylesheet
    # rule stores its RAW width (r_wd) plus its padding/border (r_padx/r_pady/
    # r_bordw); the reduction runs once at cascade-match time against the winning
    # values, so `*{box-sizing:border-box}` in one rule composes correctly with a
    # `width`/`padding` declared in a different rule (the ubiquitous reset).


# ---- stylesheet collection ------------------------------------------
# Parse selector-list { decls } starting at src[a]; returns offset just past
# the closing '}'. Emits one rule per comma-separated selector.
def _parse_ruleset(a: uint64, rgn_end: uint64) -> uint64:
    # selector list up to '{'
    sel_s: uint64 = a
    i: uint64 = a
    while i < rgn_end and src_ptr[i] != 123 and src_ptr[i] != 60:   # '{' '<'
        i = i + 1
    if i >= rgn_end or src_ptr[i] != 123:
        return i
    sel_e: uint64 = i
    i = i + 1
    dec_s: uint64 = i
    while i < rgn_end and src_ptr[i] != 125:                        # '}'
        i = i + 1
    dec_e: uint64 = i
    if i < rgn_end:
        i = i + 1
    _parse_decls(dec_s, dec_e)
    # Nothing we honour -> skip emitting rules entirely.
    if d_color < 0 and d_bg < 0 and d_weight == 0 and d_align == 0 and \
       d_deco == 0 and d_fstyle == 0 and d_nomark == 0 and \
       d_disp == 0 and d_flexdir == 0 and d_justify == 0 and d_aitems == 0 and \
       d_acontent == 0 and \
       d_flexgap < 0 and d_rowgap < 0 and d_flexwrap == 0 and d_gaflow == 0 and \
       d_gtcn == 0 and \
       d_gtrn == 0 and d_gcspan == 0 and d_gcstart == 0 and \
       d_grspan == 0 and d_grstart == 0 and \
       d_gan == 0 and d_gareaname < 0 and \
       d_ml < 0 and d_mr < 0 and d_mt < 0 and d_mb < 0 and \
       d_wd < 0 and d_bd < 0 and d_center == 0 and d_fontpx < 0 and \
       d_lineh == 0 and \
       d_ws == 0 and \
       d_float == 0 and d_clear == 0 and \
       d_pos == 0 and d_top < 0 and d_left < 0 and d_right < 0 and d_bottom < 0 and \
       d_zidx == ZIDX_UNSET and \
       d_minw < 0 and d_ht < 0 and d_minh < 0 and d_maxh < 0 and d_boxsz == 0 and \
       d_appear == 0 and \
       d_flexg < 0 and d_flexs < 0 and d_flexb < 0 and d_posfx == 0 and \
       d_valign == 0 and d_tindent == TINDENT_UNSET and \
       d_ovfx == 0 and d_ovfy == 0 and d_txtovf == 0 and \
       d_objfit == 0 and d_objpos == 0 and d_asph == 0 and d_animname < 0 and \
       d_animfill < 0 and d_accent < 0:
        return i
    # one rule per comma-separated selector
    ss: uint64 = sel_s
    k: uint64 = sel_s
    while k <= sel_e:
        if k == sel_e or src_ptr[k] == 44:           # ',' or end
            if n_rules < MAX_RULES and k > ss:
                ri: int32 = n_rules
                _parse_selector(ss, k, ri)
                r_color[ri]  = d_color
                # Fold rgba()/#rrggbbaa alpha, element opacity, and a box-shadow
                # class into the packed background colour (see _pack_fill_rgb).
                # A gradient background wins over any solid colour and packs a
                # registry ID (marked so htmlpage reads it as a gradient).
                if d_bg_grad >= 0:
                    r_bg[ri]     = _pack_gradient(d_bg_grad)
                    _bg_store_place(d_bg_grad)
                else:
                    r_bg[ri]     = _pack_fill_rgb(d_bg, d_bg_alpha, d_opacity, \
                                                 d_boxshadow)
                r_weight[ri] = d_weight
                r_align[ri]  = d_align
                r_deco[ri]   = d_deco
                r_fstyle[ri] = d_fstyle
                r_nomark[ri] = d_nomark
                r_disp[ri]   = d_disp
                r_flexdir[ri] = d_flexdir
                r_justify[ri] = d_justify
                r_aitems[ri] = d_aitems
                r_acontent[ri] = d_acontent
                r_flexgap[ri] = d_flexgap
                r_rowgap[ri] = d_rowgap
                r_flexwrap[ri] = d_flexwrap
                r_gaflow[ri] = d_gaflow
                r_gtcn[ri] = d_gtcn
                gtc: int32 = 0
                while gtc < d_gtcn and gtc < GRID_MAXTRACK:
                    r_gtc[ri * GRID_MAXTRACK + gtc] = d_gtc[gtc]
                    gtc = gtc + 1
                r_gtrn[ri] = d_gtrn
                gtr: int32 = 0
                while gtr < d_gtrn and gtr < GRID_MAXTRACK:
                    r_gtr[ri * GRID_MAXTRACK + gtr] = d_gtr[gtr]
                    gtr = gtr + 1
                r_gcspan[ri]  = d_gcspan
                r_gcstart[ri] = d_gcstart
                r_grspan[ri]  = d_grspan
                r_grstart[ri] = d_grstart
                r_gan[ri]     = d_gan
                r_gacols[ri]  = d_gacols
                r_gareaname[ri] = d_gareaname
                gaa: int32 = 0
                while gaa < d_gan and gaa < GAREA_MAX:
                    r_ga_name[ri * GAREA_MAX + gaa] = d_ga_name[gaa]
                    r_ga_r0[ri * GAREA_MAX + gaa]   = d_ga_r0[gaa]
                    r_ga_c0[ri * GAREA_MAX + gaa]   = d_ga_c0[gaa]
                    r_ga_rsp[ri * GAREA_MAX + gaa]  = d_ga_rsp[gaa]
                    r_ga_csp[ri * GAREA_MAX + gaa]  = d_ga_csp[gaa]
                    gaa = gaa + 1
                r_ml[ri]     = d_ml
                r_mr[ri]     = d_mr
                r_mt[ri]     = d_mt
                r_mb[ri]     = d_mb
                r_wd[ri]     = d_wd
                r_bd[ri]     = d_bd
                # Fold element opacity into the border colour's alpha.
                r_bordc[ri]  = _pack_bordc(d_bordc, d_opacity)
                r_accent[ri] = d_accent
                r_bordr[ri]  = d_bordr
                r_bordps[ri] = d_bordps
                r_bordss[ri] = d_bordss
                r_bctop[ri] = d_bc_t
                r_bcrt[ri]  = d_bc_r
                r_bcbot[ri] = d_bc_b
                r_bclft[ri] = d_bc_l
                r_filter[ri] = d_filter
                r_xform[ri]  = d_xform
                r_kfname[ri]  = -1
                r_kf_from[ri] = 0
                r_animref[ri] = d_animname
                r_animfill[ri] = d_animfill
                r_center[ri] = d_center
                r_fontpx[ri] = d_fontpx
                r_lineh[ri]  = d_lineh
                r_ws[ri]     = d_ws
                r_ovw[ri]    = d_ovw
                r_float[ri]  = d_float
                r_clear[ri]  = d_clear
                r_pos[ri]    = d_pos
                r_top[ri]    = d_top
                r_left[ri]   = d_left
                r_right[ri]  = d_right
                r_bottom[ri] = d_bottom
                r_zidx[ri]   = d_zidx
                r_minw[ri]   = d_minw
                r_ht[ri]     = d_ht
                r_minh[ri]   = d_minh
                r_maxh[ri]   = d_maxh
                r_boxsz[ri]  = d_boxsz
                r_appear[ri] = d_appear
                r_padx[ri]   = d_padx
                r_pady[ri]   = d_pady
                r_bordw[ri]  = d_bordw
                r_flexg[ri]  = d_flexg
                r_flexs[ri]  = d_flexs
                r_flexb[ri]  = d_flexb
                r_posfx[ri]  = d_posfx
                r_valign[ri] = d_valign
                r_tindent[ri] = d_tindent
                r_ovfx[ri]   = d_ovfx
                r_ovfy[ri]   = d_ovfy
                r_txtovf[ri] = d_txtovf
                r_objfit[ri] = d_objfit
                r_objpos[ri] = d_objpos
                r_objposx[ri] = d_objposx
                r_objposxp[ri] = d_objposxp
                r_objposy[ri] = d_objposy
                r_objposyp[ri] = d_objposyp
                r_aspw[ri]   = d_aspw
                r_asph[ri]   = d_asph
                n_rules = n_rules + 1
            ss = k + 1
        k = k + 1
    return i


# ---- external stylesheets (<link rel=stylesheet href=...>) ----------
# The engine is PURE (no fetch): a front-end resolves each linked sheet's href
# against the page URL, fetches it over its existing http9/file path, and hands
# the raw CSS bytes to he_css_append(); _collect_css() then parses them through
# the SAME cascade as inline <style>. he_css_reset() clears the buffer per page.
# The link-scan (he_css_scan_links) hands the front-end the hrefs to fetch.
HE_CSS_CAP:   uint64 = 262144
he_css_buf:   Array[262144, uint8]
he_css_len:   uint64 = 0
MAX_CSS_LINKS: int32 = 16
css_link_off: Array[16, uint64]      # href value offset into the loaded src
css_link_len: Array[16, int32]
n_css_links:  int32 = 0


def he_css_reset():
    he_css_len = 0


# Append raw CSS bytes (a fetched external sheet) to the cascade buffer. Silently
# truncates past the cap so a pathological megasheet can't run the engine away.
def he_css_append(p: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n and he_css_len < HE_CSS_CAP:
        he_css_buf[he_css_len] = p[i]
        he_css_len = he_css_len + 1
        i = i + 1
    # a declaration separator so back-to-back sheets never fuse a rule
    if he_css_len < HE_CSS_CAP:
        he_css_buf[he_css_len] = 10
        he_css_len = he_css_len + 1


# ---- @media queries (responsive CSS) -------------------------------
# A self-contained CSS Media Queries Level 4 subset evaluated against the live
# viewport (bw × bh). Supports media types (screen/all match; print/speech do
# not), `and`/comma(OR)/`not`/`only`, and the dominant range/discrete features:
# min/max-width, min/max-height, width/height, orientation, prefers-color-scheme
# (light — the engine renders light). Unknown features match permissively so a
# block gated on a feature we don't model still contributes its rules.

# Case-insensitive compare of src[i..i+ln) against a lowercase literal.
def _mq_ci(i: uint64, lit: Ptr[uint8], ln: uint64) -> int32:
    k: uint64 = 0
    while k < ln:
        if i + k >= src_len:
            return 0
        if _hx_lower(src_ptr[i + k]) != lit[k]:
            return 0
        k = k + 1
    return 1


# Parse a length token at src[a,b) → px (em/rem ×16, fraction truncated).
def _mq_len(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    v: int32 = 0
    while i < b and src_ptr[i] >= 48 and src_ptr[i] <= 57:
        v = v * 10 + cast[int32](src_ptr[i] - 48)
        i = i + 1
    if i < b and src_ptr[i] == 46:                    # skip fraction
        i = i + 1
        while i < b and src_ptr[i] >= 48 and src_ptr[i] <= 57:
            i = i + 1
    if i < b and (src_ptr[i] == 101 or src_ptr[i] == 69 or \
                  src_ptr[i] == 114 or src_ptr[i] == 82):   # e/E em, r/R rem
        v = v * 16
    return v


# Evaluate a media feature `name` / `name: value` (region src[a,b), no parens).
def _mq_feature(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    ns: uint64 = i
    while i < b and src_ptr[i] != 58 and src_ptr[i] != 32 and src_ptr[i] != 9:
        i = i + 1
    ne: uint64 = i
    nlen: uint64 = ne - ns
    while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9):
        i = i + 1
    vs: uint64 = b
    if i < b and src_ptr[i] == 58:                    # ':'
        i = i + 1
        while i < b and (src_ptr[i] == 32 or src_ptr[i] == 9):
            i = i + 1
        vs = i
    if nlen == 9 and _mq_ci(ns, cast[Ptr[uint8]]("min-width"), 9) != 0:
        if bw >= _mq_len(vs, b):
            return 1
        return 0
    if nlen == 9 and _mq_ci(ns, cast[Ptr[uint8]]("max-width"), 9) != 0:
        if bw <= _mq_len(vs, b):
            return 1
        return 0
    if nlen == 5 and _mq_ci(ns, cast[Ptr[uint8]]("width"), 5) != 0:
        if bw == _mq_len(vs, b):
            return 1
        return 0
    if nlen == 10 and _mq_ci(ns, cast[Ptr[uint8]]("min-height"), 10) != 0:
        if bh >= _mq_len(vs, b):
            return 1
        return 0
    if nlen == 10 and _mq_ci(ns, cast[Ptr[uint8]]("max-height"), 10) != 0:
        if bh <= _mq_len(vs, b):
            return 1
        return 0
    if nlen == 6 and _mq_ci(ns, cast[Ptr[uint8]]("height"), 6) != 0:
        if bh == _mq_len(vs, b):
            return 1
        return 0
    if nlen == 11 and _mq_ci(ns, cast[Ptr[uint8]]("orientation"), 11) != 0:
        if _mq_ci(vs, cast[Ptr[uint8]]("portrait"), 8) != 0:
            if bh > bw:
                return 1
            return 0
        if bw >= bh:
            return 1
        return 0
    if nlen == 20 and \
       _mq_ci(ns, cast[Ptr[uint8]]("prefers-color-scheme"), 20) != 0:
        if _mq_ci(vs, cast[Ptr[uint8]]("dark"), 4) != 0:
            return 0
        return 1
    return 1                                          # unknown feature: permissive


# Evaluate one media query term (one comma-separated segment) src[a,b).
def _mq_query(a: uint64, b: uint64) -> int32:
    res: int32 = 1
    neg: int32 = 0
    i: uint64 = a
    while i < b:
        c: uint8 = src_ptr[i]
        if c == 32 or c == 9 or c == 10 or c == 13:
            i = i + 1
            continue
        if c == 40:                                   # '(' — a feature test
            j: uint64 = i + 1
            depth: int32 = 1
            while j < b and depth > 0:
                if src_ptr[j] == 40:
                    depth = depth + 1
                elif src_ptr[j] == 41:
                    depth = depth - 1
                    if depth == 0:
                        break
                j = j + 1
            if _mq_feature(i + 1, j) == 0:
                res = 0
            i = j + 1
            continue
        ws: uint64 = i                                # bare identifier word
        while i < b and src_ptr[i] != 32 and src_ptr[i] != 9 and \
              src_ptr[i] != 40 and src_ptr[i] != 10 and src_ptr[i] != 13:
            i = i + 1
        wl: uint64 = i - ws
        known: int32 = 0
        if wl == 3 and _mq_ci(ws, cast[Ptr[uint8]]("not"), 3) != 0:
            neg = 1
            known = 1
        if wl == 4 and _mq_ci(ws, cast[Ptr[uint8]]("only"), 4) != 0:
            known = 1
        if wl == 3 and _mq_ci(ws, cast[Ptr[uint8]]("and"), 3) != 0:
            known = 1
        if wl == 6 and _mq_ci(ws, cast[Ptr[uint8]]("screen"), 6) != 0:
            known = 1
        if wl == 3 and _mq_ci(ws, cast[Ptr[uint8]]("all"), 3) != 0:
            known = 1
        if known == 0:                                # print/speech/unknown type
            res = 0
    if neg != 0:
        return 1 - res
    return res


# Evaluate a full media query list src[a,b) (comma = OR). Empty = matches all.
def _media_matches(a: uint64, b: uint64) -> int32:
    ss: uint64 = a
    i: uint64 = a
    depth: int32 = 0
    while i <= b:
        if i < b and src_ptr[i] == 40:
            depth = depth + 1
        elif i < b and src_ptr[i] == 41:
            if depth > 0:
                depth = depth - 1
        if i == b or (i < b and src_ptr[i] == 44 and depth == 0):
            if _mq_query(ss, i) != 0:
                return 1
            ss = i + 1
        i = i + 1
    return 0


# PUBLIC: evaluate a media query STRING p[0..n) against the LIVE viewport
# (bw x bh). Temporarily points the shared source cursor at the query bytes and
# runs the exact _media_matches used by @media, then restores. Backs
# window.matchMedia(query).matches (dom/canvas.ad) — so a script queries the
# same breakpoints the stylesheet's @media blocks were evaluated against.
def he_media_match(p: Ptr[uint8], n: uint64) -> int32:
    sp: Ptr[uint8] = src_ptr
    sl: uint64 = src_len
    src_ptr = p
    src_len = n
    rr: int32 = _media_matches(0, n)
    src_ptr = sp
    src_len = sl
    return rr


# ---- @keyframes NAME interning + end-state pseudo-rules ----------------------
# Trim ASCII whitespace/quotes from src[a,b) and return the interned id of that
# name (append if new). Case-SENSITIVE (CSS custom-ident). -1 if empty/overflow.
def _kf_intern(a: uint64, b: uint64) -> int32:
    s: uint64 = a
    e: uint64 = b
    while s < e and (src_ptr[s] == 32 or src_ptr[s] == 9 or src_ptr[s] == 10 or \
                     src_ptr[s] == 13 or src_ptr[s] == 34 or src_ptr[s] == 39):
        s = s + 1
    while e > s and (src_ptr[e - 1] == 32 or src_ptr[e - 1] == 9 or \
                     src_ptr[e - 1] == 10 or src_ptr[e - 1] == 13 or \
                     src_ptr[e - 1] == 34 or src_ptr[e - 1] == 39):
        e = e - 1
    ln: uint64 = e - s
    if ln == 0:
        return -1
    k: int32 = 0
    while k < n_kf_names:
        if kf_name_len[k] == ln:
            j: uint64 = 0
            same: int32 = 1
            while j < ln:
                if kf_namebuf[kf_name_off[k] + j] != src_ptr[s + j]:
                    same = 0
                    break
                j = j + 1
            if same != 0:
                return k
        k = k + 1
    if n_kf_names >= KF_MAX_NAMES or kf_namebuf_w + ln > KF_NAMEBUF:
        return -1
    off: uint64 = kf_namebuf_w
    j2: uint64 = 0
    while j2 < ln:
        kf_namebuf[off + j2] = src_ptr[s + j2]
        j2 = j2 + 1
    kf_namebuf_w = off + ln
    kf_name_off[n_kf_names] = off
    kf_name_len[n_kf_names] = ln
    r: int32 = n_kf_names
    n_kf_names = n_kf_names + 1
    return r


# Does the keyframe selector src[a,b) name the SETTLED (end) frame — `100%`/`to`?
def _kf_sel_is_end(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i < b:
        if src_ptr[i] == 49 and i + 3 < b and src_ptr[i + 1] == 48 and \
           src_ptr[i + 2] == 48 and src_ptr[i + 3] == 37:      # "100%"
            return 1
        if (src_ptr[i] == 116 or src_ptr[i] == 84):            # 't'/'T'
            if i + 1 < b and (src_ptr[i + 1] == 111 or src_ptr[i + 1] == 79):
                return 1                                       # "to"
        i = i + 1
    return 0


# Does the keyframe selector src[a,b) name the FROM (start) frame — `0%`/`from`?
def _kf_sel_is_from(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i < b:
        # "0%" — but NOT the trailing 0 of "100%": require no preceding digit.
        if src_ptr[i] == 48 and i + 1 < b and src_ptr[i + 1] == 37 and \
           (i == a or src_ptr[i - 1] < 48 or src_ptr[i - 1] > 57):
            return 1
        if (src_ptr[i] == 102 or src_ptr[i] == 70):            # 'f'/'F'
            if i + 3 < b and (src_ptr[i + 1] == 114 or src_ptr[i + 1] == 82) and \
               (src_ptr[i + 2] == 111 or src_ptr[i + 2] == 79) and \
               (src_ptr[i + 3] == 109 or src_ptr[i + 3] == 77):
                return 1                                       # "from"
        i = i + 1
    return 0


# Emit a @keyframes DEFINITION pseudo-rule carrying a captured frame's props
# (already parsed into d_* by _parse_decls). It is INERT in selector matching
# (r_kfname >= 0 => _rule_matches returns 0); the cascade only reads its packed
# background/colour/transform/border/geometry props when an element's
# animation-name resolves to `nameid`. `isfrom` = 0 for the SETTLED end frame
# (animation-fill-mode forwards/both / the visually settled end of a finite
# animation — the honest static-render default), 1 for the FROM (0%) frame that
# an explicit fill-mode none/backwards paints instead. Beyond background/colour/
# transform/border-colour the overlay now also widens to width/height/margins
# (opacity rides the packed background alpha).
def _store_keyframe(nameid: int32, isfrom: int32):
    if n_rules >= MAX_RULES or nameid < 0:
        return
    ri: int32 = n_rules
    r_kfname[ri]  = nameid
    r_kf_from[ri] = isfrom
    r_animref[ri] = -1
    r_animfill[ri] = -1
    if d_bg_grad >= 0:
        r_bg[ri] = _pack_gradient(d_bg_grad)
        _bg_store_place(d_bg_grad)
    else:
        r_bg[ri] = _pack_fill_rgb(d_bg, d_bg_alpha, d_opacity, d_boxshadow)
    r_color[ri] = d_color
    r_xform[ri] = d_xform
    r_bordc[ri] = _pack_bordc(d_bordc, d_opacity)
    r_accent[ri] = -1
    # widened end-state geometry: width/height/margins (-1 = frame declares none,
    # so the overlay leaves the cascade winner untouched).
    r_wd[ri] = d_wd
    r_ht[ri] = d_ht
    r_ml[ri] = d_ml
    r_mr[ri] = d_mr
    r_mt[ri] = d_mt
    r_mb[ri] = d_mb
    # keyframe pseudo-rules carry no per-side border colours (sentinel -1 so the
    # merge's ">= 0" adoption never picks a stale/zero (black) side colour).
    r_bctop[ri] = -1
    r_bcrt[ri]  = -1
    r_bcbot[ri] = -1
    r_bclft[ri] = -1
    r_has_anc[ri] = 0
    n_rules = ri + 1


# Parse a @keyframes body src[blk_s,blk_e) and store its edge frames under
# `nameid`. The END frame prefers the `100%`/`to` frame (else the LAST frame);
# the FROM frame prefers the `0%`/`from` frame (else the FIRST frame). Both are
# emitted as pseudo-rules so the overlay can pick per animation-fill-mode.
def _parse_keyframes_body(blk_s: uint64, blk_e: uint64, nameid: int32):
    p: uint64 = blk_s
    end_ds: uint64 = 0
    end_de: uint64 = 0
    have_end: int32 = 0
    from_ds: uint64 = 0
    from_de: uint64 = 0
    have_from: int32 = 0
    first_ds: uint64 = 0
    first_de: uint64 = 0
    have_first: int32 = 0
    last_ds: uint64 = 0
    last_de: uint64 = 0
    have_last: int32 = 0
    while p < blk_e:
        c: uint8 = src_ptr[p]
        if c == 32 or c == 9 or c == 10 or c == 13:
            p = p + 1
            continue
        ksel_s: uint64 = p
        while p < blk_e and src_ptr[p] != 123 and src_ptr[p] != 125:
            p = p + 1
        if p >= blk_e or src_ptr[p] != 123:
            break
        ksel_e: uint64 = p
        p = p + 1
        kds: uint64 = p
        while p < blk_e and src_ptr[p] != 125:
            p = p + 1
        kde: uint64 = p
        if p < blk_e:
            p = p + 1
        if _kf_sel_is_end(ksel_s, ksel_e) != 0:
            end_ds = kds
            end_de = kde
            have_end = 1
        if _kf_sel_is_from(ksel_s, ksel_e) != 0:
            from_ds = kds
            from_de = kde
            have_from = 1
        if have_first == 0:
            first_ds = kds
            first_de = kde
            have_first = 1
        last_ds = kds
        last_de = kde
        have_last = 1
    # END frame (isfrom=0): 100%/to, else the last frame.
    if have_end != 0:
        _parse_decls(end_ds, end_de)
        _store_keyframe(nameid, 0)
    elif have_last != 0:
        _parse_decls(last_ds, last_de)
        _store_keyframe(nameid, 0)
    # FROM frame (isfrom=1): 0%/from, else the first frame.
    if have_from != 0:
        _parse_decls(from_ds, from_de)
        _store_keyframe(nameid, 1)
    elif have_first != 0:
        _parse_decls(first_ds, first_de)
        _store_keyframe(nameid, 1)


# Handle a CSS at-rule beginning at src[a] ('@'). Returns the position to resume.
# `@media <query> { ...rulesets... }` recurses into its block IFF the query
# matches the viewport; `@keyframes NAME { ... }` records the settled end-state
# (see _parse_keyframes_body); every other at-rule (@font-face/@supports/
# @page block forms, and @import/@charset/@namespace statement forms) is skipped.
def _parse_at_rule(a: uint64, b: uint64) -> uint64:
    kw: uint64 = a + 1
    ke: uint64 = kw
    while ke < b and ((src_ptr[ke] >= 97 and src_ptr[ke] <= 122) or \
                      (src_ptr[ke] >= 65 and src_ptr[ke] <= 90) or \
                      src_ptr[ke] == 45):
        ke = ke + 1
    is_media: int32 = 0
    if (ke - kw) == 5 and _mq_ci(kw, cast[Ptr[uint8]]("media"), 5) != 0:
        is_media = 1
    is_kf: int32 = 0
    if (ke - kw) == 9 and _mq_ci(kw, cast[Ptr[uint8]]("keyframes"), 9) != 0:
        is_kf = 1
    if (ke - kw) == 17 and \
       _mq_ci(kw, cast[Ptr[uint8]]("-webkit-keyframes"), 17) != 0:
        is_kf = 1
    q: uint64 = ke                                    # prelude → '{' or ';'
    while q < b and src_ptr[q] != 123 and src_ptr[q] != 59:
        q = q + 1
    if q >= b:
        return b
    if src_ptr[q] == 59:                              # statement at-rule
        return q + 1
    blk_s: uint64 = q + 1                             # block at-rule: brace-match
    depth: int32 = 1
    r: uint64 = blk_s
    while r < b and depth > 0:
        if src_ptr[r] == 123:
            depth = depth + 1
        elif src_ptr[r] == 125:
            depth = depth - 1
            if depth == 0:
                break
        r = r + 1
    if is_media != 0 and _media_matches(ke, q) != 0:
        _parse_sheet(blk_s, r)
    elif is_kf != 0:
        kfid: int32 = _kf_intern(ke, q)
        if kfid >= 0:
            _parse_keyframes_body(blk_s, r, kfid)
    if r < b:
        return r + 1
    return b


# Parse a sheet region src[a,b) as a sequence of rulesets (skipping /* */ + ws).
# Shared by the <style> scan and the external he_css_buf parse.
def _parse_sheet(a: uint64, b: uint64):
    p: uint64 = a
    while p < b:
        if p + 1 < b and src_ptr[p] == 47 and src_ptr[p + 1] == 42:
            p = p + 2
            while p + 1 < b and not (src_ptr[p] == 42 and src_ptr[p + 1] == 47):
                p = p + 1
            p = p + 2
            continue
        if src_ptr[p] == 32 or src_ptr[p] == 9 or \
           src_ptr[p] == 10 or src_ptr[p] == 13:
            p = p + 1
            continue
        if src_ptr[p] == 64:                          # '@' at-rule
            p = _parse_at_rule(p, b)
            continue
        np: uint64 = _parse_ruleset(p, b)
        if np <= p:
            p = p + 1
        else:
            p = np


# Does the rel="..." value region src[a,b) contain the token "stylesheet"?
def _rel_is_stylesheet(a: uint64, b: uint64) -> int32:
    i: uint64 = a
    while i < b:
        if _hx_lower(src_ptr[i]) == 115:                # 's'
            lit: Ptr[uint8] = cast[Ptr[uint8]]("stylesheet")
            j: int32 = 0
            ok: int32 = 1
            while lit[j] != 0:
                if i + cast[uint64](j) >= b or \
                   _hx_lower(src_ptr[i + cast[uint64](j)]) != lit[j]:
                    ok = 0
                    break
                j = j + 1
            if ok != 0:
                return 1
        i = i + 1
    return 0


# Scan the loaded HTML for <link rel=stylesheet href=...> and record each href
# (offset+len into src) so the front-end can fetch them. Front-end-agnostic +
# pure; the front-end resolves the URL and calls he_css_append() with the bytes.
def he_css_scan_links():
    n_css_links = 0
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60:                         # '<'
            k: uint64 = i + 1
            if _tagname_is(k, cast[Ptr[uint8]]("link")) != 0:
                te: uint64 = k
                while te < src_len and src_ptr[te] != 62:
                    te = te + 1
                is_ss: int32 = 0
                if _hx_find_attr(k, te, cast[Ptr[uint8]]("rel")) != 0:
                    is_ss = _rel_is_stylesheet(g_attr_start, g_attr_end)
                if is_ss != 0 and n_css_links < MAX_CSS_LINKS and \
                   _hx_find_attr(k, te, cast[Ptr[uint8]]("href")) != 0 and \
                   g_attr_end > g_attr_start:
                    css_link_off[n_css_links] = g_attr_start
                    css_link_len[n_css_links] = \
                        cast[int32](g_attr_end - g_attr_start)
                    n_css_links = n_css_links + 1
                i = te
                continue
        i = i + 1


def he_css_link_count() -> int32:
    return n_css_links


def he_css_link_off(i: int32) -> uint64:
    return css_link_off[i]


def he_css_link_len(i: int32) -> int32:
    return css_link_len[i]


# Pre-sweep: harvest every custom property (--name: value) from all <style>
# blocks and fetched external sheets BEFORE the rules are cascaded, so var()
# resolves independent of where the token is defined relative to its use.
def _collect_cvars():
    _cvar_reset()
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and _tagname_is(i + 1, cast[Ptr[uint8]]("style")) != 0:
            while i < src_len and src_ptr[i] != 62:
                i = i + 1
            if i < src_len:
                i = i + 1
            body: uint64 = i
            e: uint64 = body
            while e < src_len:
                if src_ptr[e] == 60 and e + 1 < src_len and \
                   src_ptr[e + 1] == 47 and \
                   _tagname_is(e + 2, cast[Ptr[uint8]]("style")) != 0:
                    break
                e = e + 1
            _scan_cvars(body, e)
            i = e
            continue
        i = i + 1
    if he_css_len > 0:
        sp: Ptr[uint8] = src_ptr
        sl: uint64 = src_len
        src_ptr = &he_css_buf[0]
        src_len = he_css_len
        _scan_cvars(0, he_css_len)
        src_ptr = sp
        src_len = sl


# Scan the whole page for <style> blocks and parse their rules.
def _collect_css():
    n_rules = 0
    n_grads = 0
    n_xtempl = 0
    n_xbind = 0
    grad_url_used = 0
    css_slen = 0
    el_rootcnt = 0                                    # reset :nth-child root counter
    n_kf_names = 0                                     # reset @keyframes registry
    kf_namebuf_w = 0
    filt_reg_n = 0                                     # reset filter-list registry
    _collect_cvars()
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60:                         # '<'
            k: uint64 = i + 1
            if _tagname_is(k, cast[Ptr[uint8]]("style")) != 0:
                # advance to end of the opening tag
                while i < src_len and src_ptr[i] != 62:
                    i = i + 1
                if i < src_len:
                    i = i + 1
                body: uint64 = i
                # region ends at </style>
                e: uint64 = body
                while e < src_len:
                    if src_ptr[e] == 60 and e + 1 < src_len and \
                       src_ptr[e + 1] == 47 and \
                       _tagname_is(e + 2, cast[Ptr[uint8]]("style")) != 0:
                        break
                    e = e + 1
                # parse rulesets within [body,e)
                _parse_sheet(body, e)
                i = e
                continue
        i = i + 1
    # External <link rel=stylesheet> sheets the front-end fetched (he_css_append)
    # cascade through the SAME ruleset path: temporarily point the parser at the
    # CSS buffer so _parse_ruleset/_parse_selector read from it, then restore.
    if he_css_len > 0:
        save_p: Ptr[uint8] = src_ptr
        save_l: uint64 = src_len
        src_ptr = &he_css_buf[0]
        src_len = he_css_len
        _parse_sheet(0, he_css_len)
        src_ptr = save_p
        src_len = save_l


# ---- element stack + cascade matching -------------------------------
def _el_copy(a: uint64, b: uint64) -> int32:
    n: int32 = 0
    i: uint64 = a
    while i < b and el_slen < EL_STR_CAP - 1:
        el_sbuf[el_slen] = _hx_lower(src_ptr[i])
        el_slen = el_slen + 1
        n = n + 1
        i = i + 1
    return n


def _el_push(np: uint64, nlen: uint64, ne: uint64, te: uint64):
    if el_sp >= MAX_EL:
        return
    s: int32 = cast[int32](el_slen)
    el_tag_off[el_sp] = s
    el_tag_len[el_sp] = _el_copy(np, np + nlen)
    el_cls_off[el_sp] = cast[int32](el_slen)
    el_cls_len[el_sp] = 0
    if _hx_find_attr(ne, te, cast[Ptr[uint8]]("class")) != 0:
        el_cls_len[el_sp] = _el_copy(g_attr_start, g_attr_end)
    el_id_off[el_sp] = cast[int32](el_slen)
    el_id_len[el_sp] = 0
    if _hx_find_attr(ne, te, cast[Ptr[uint8]]("id")) != 0:
        el_id_len[el_sp] = _el_copy(g_attr_start, g_attr_end)
    el_body_s[el_sp] = ne
    el_body_e[el_sp] = te
    # sibling position among element children (1-based) for :nth-child /
    # :first-child. The parent is the element one level down; depth-0 roots use
    # el_rootcnt. A fresh element starts its own child count at 0.
    if el_sp > 0:
        el_nchild[el_sp - 1] = el_nchild[el_sp - 1] + 1
        el_childidx[el_sp] = el_nchild[el_sp - 1]
    else:
        el_rootcnt = el_rootcnt + 1
        el_childidx[el_sp] = el_rootcnt
    el_nchild[el_sp] = 0
    el_sp = el_sp + 1


def _el_pop(np: uint64, nlen: uint64):
    # forgiving: pop the nearest matching open element (tolerates unclosed
    # inner tags), else leave the stack unchanged.
    k: int32 = el_sp - 1
    while k >= 0:
        if _buf_eq(&el_sbuf[el_tag_off[k]], el_tag_len[k], \
                   &src_ptr[np], cast[int32](nlen)) != 0:
            el_slen = cast[uint64](el_tag_off[k])
            el_sp = k
            return
        k = k - 1


# As _el_pop, but matches against a literal tag-name buffer instead of a slice
# of the source. Used for SYNTHESISED implied end tags (e.g. an omitted </p>),
# where there is no `</p>` token in the source to name the element being popped.
def _el_pop_lit(lit: Ptr[uint8], nlen: int32):
    k: int32 = el_sp - 1
    while k >= 0:
        if _buf_eq(&el_sbuf[el_tag_off[k]], el_tag_len[k], lit, nlen) != 0:
            el_slen = cast[uint64](el_tag_off[k])
            el_sp = k
            return
        k = k - 1


# Does compound (target of rule ri) match the element at stack index e?
# Every class token in the selector's (space-joined) class string
# css_sbuf[koff..koff+klen) must be present in the element's class list — a
# compound `.a.b` matches only an element carrying BOTH `a` and `b`.
def _all_cls_match(coff: int32, clen: int32, koff: int32, klen: int32) -> int32:
    i: int32 = 0
    while i < klen:
        while i < klen and css_sbuf[koff + i] == 32:
            i = i + 1
        s: int32 = i
        while i < klen and css_sbuf[koff + i] != 32:
            i = i + 1
        tlen: int32 = i - s
        if tlen > 0:
            if _cls_contains(coff, clen, koff + s, tlen) == 0:
                return 0
    return 1


# src[vs..ve) vs css_sbuf[voff..voff+vlen), case-insensitive (css_sbuf already
# lowercased). Exact-equality test for [attr=v].
def _av_eq(vs: uint64, ve: uint64, voff: int32, vlen: int32) -> int32:
    if cast[int32](ve - vs) != vlen:
        return 0
    k: int32 = 0
    while k < vlen:
        if _hx_lower(src_ptr[vs + cast[uint64](k)]) != css_sbuf[voff + k]:
            return 0
        k = k + 1
    return 1


# Does src[vs..ve) contain css_sbuf[voff..voff+vlen) at offset `at`? (ci)
def _av_at(vs: uint64, ve: uint64, at: int32, voff: int32, vlen: int32) -> int32:
    k: int32 = 0
    while k < vlen:
        p: uint64 = vs + cast[uint64](at + k)
        if p >= ve:
            return 0
        if _hx_lower(src_ptr[p]) != css_sbuf[voff + k]:
            return 0
        k = k + 1
    return 1


# Match attribute selector (name css_sbuf[noff..], op, value css_sbuf[voff..])
# against the element tag body [ts,te). Returns 1 on match, else 0. Value ops
# with an EMPTY selector value never match (per spec [a=""], [a^=""] are false).
def _attr_match(ts: uint64, te: uint64, noff: int32, nlen: int32, op: int32, \
                voff: int32, vlen: int32) -> int32:
    i: uint64 = ts
    while i + cast[uint64](nlen) <= te:
        prev_alnum: int32 = 0
        if i > ts:
            pc: uint8 = _hx_lower(src_ptr[i - 1])
            if (pc >= 97 and pc <= 122) or (pc >= 48 and pc <= 57) or pc == 45:
                prev_alnum = 1
        matched: int32 = 0
        if prev_alnum == 0:
            k: int32 = 0
            matched = 1
            while k < nlen:
                if _hx_lower(src_ptr[i + cast[uint64](k)]) != css_sbuf[noff + k]:
                    matched = 0
                    break
                k = k + 1
            # the name must end at a non-name char (so `data-x` != `data-xy`)
            if matched != 0 and i + cast[uint64](nlen) < te and \
               _is_name_ch(src_ptr[i + cast[uint64](nlen)]) != 0:
                matched = 0
        if matched != 0:
            # locate the value span (empty if the attribute is valueless)
            j: uint64 = i + cast[uint64](nlen)
            while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
                j = j + 1
            vs: uint64 = j
            ve: uint64 = j
            if j < te and src_ptr[j] == 61:              # '='
                j = j + 1
                while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
                    j = j + 1
                q: uint8 = 0
                if j < te and (src_ptr[j] == 34 or src_ptr[j] == 39):
                    q = src_ptr[j]
                    j = j + 1
                vs = j
                while j < te:
                    c: uint8 = src_ptr[j]
                    if q != 0:
                        if c == q:
                            break
                    else:
                        if c == 32 or c == 9:
                            break
                    j = j + 1
                ve = j
            if op == 1:                                  # [attr] exists
                return 1
            if vlen == 0:                                # empty value never matches
                return 0
            if op == 2:                                  # =
                if _av_eq(vs, ve, voff, vlen) != 0:
                    return 1
            elif op == 3:                                # ~= whitespace token
                p: uint64 = vs
                while p < ve:
                    while p < ve and (src_ptr[p] == 32 or src_ptr[p] == 9):
                        p = p + 1
                    ws0: uint64 = p
                    while p < ve and src_ptr[p] != 32 and src_ptr[p] != 9:
                        p = p + 1
                    if p > ws0 and _av_eq(ws0, p, voff, vlen) != 0:
                        return 1
            elif op == 4:                                # ^= prefix
                if ve - vs >= cast[uint64](vlen) and \
                   _av_at(vs, ve, 0, voff, vlen) != 0:
                    return 1
            elif op == 5:                                # $= suffix
                if ve - vs >= cast[uint64](vlen) and \
                   _av_at(vs, ve, cast[int32](ve - vs) - vlen, voff, vlen) != 0:
                    return 1
            elif op == 6:                                # *= substring
                span: int32 = cast[int32](ve - vs)
                a2: int32 = 0
                while a2 + vlen <= span:
                    if _av_at(vs, ve, a2, voff, vlen) != 0:
                        return 1
                    a2 = a2 + 1
            elif op == 7:                                # |= exact or v-'-' prefix
                if _av_eq(vs, ve, voff, vlen) != 0:
                    return 1
                if ve - vs > cast[uint64](vlen) and \
                   _av_at(vs, ve, 0, voff, vlen) != 0 and \
                   src_ptr[vs + cast[uint64](vlen)] == 45:
                    return 1
            return 0
        i = i + 1
    return 0


# Whole-word boolean-attribute presence test on the tag body src[ts..te): the
# name `lit` must sit at an attribute-name position (preceded by start/space/
# '/', ended by a non-name char), so `value="checked"` and `data-checked` do
# NOT match. Drives :checked/:disabled/:required/:enabled.
def _body_has_attr(ts: uint64, te: uint64, lit: Ptr[uint8]) -> int32:
    nlen: uint64 = 0
    while lit[nlen] != 0:
        nlen = nlen + 1
    if nlen == 0:
        return 0
    i: uint64 = ts
    while i + nlen <= te:
        boundary: int32 = 0
        if i == ts:
            boundary = 1
        else:
            pc: uint8 = src_ptr[i - 1]
            if pc == 32 or pc == 9 or pc == 10 or pc == 13 or pc == 47:
                boundary = 1
        if boundary != 0:
            k: uint64 = 0
            m: int32 = 1
            while k < nlen:
                if _hx_lower(src_ptr[i + k]) != lit[k]:
                    m = 0
                    break
                k = k + 1
            if m != 0:
                nc: uint8 = 0
                if i + nlen < te:
                    nc = src_ptr[i + nlen]
                if _is_name_ch(nc) == 0:
                    return 1
        i = i + 1
    return 0


# Is the element at stack index e a form control (input/button/select/textarea/
# fieldset/optgroup/option)? Used to scope :enabled/:disabled sensibly.
def _el_is_control(e: int32) -> int32:
    t: Ptr[uint8] = &el_sbuf[el_tag_off[e]]
    n: int32 = el_tag_len[e]
    if _buf_eq(t, n, cast[Ptr[uint8]]("input"), 5) != 0:
        return 1
    if _buf_eq(t, n, cast[Ptr[uint8]]("button"), 6) != 0:
        return 1
    if _buf_eq(t, n, cast[Ptr[uint8]]("select"), 6) != 0:
        return 1
    if _buf_eq(t, n, cast[Ptr[uint8]]("textarea"), 8) != 0:
        return 1
    if _buf_eq(t, n, cast[Ptr[uint8]]("fieldset"), 8) != 0:
        return 1
    if _buf_eq(t, n, cast[Ptr[uint8]]("optgroup"), 8) != 0:
        return 1
    if _buf_eq(t, n, cast[Ptr[uint8]]("option"), 6) != 0:
        return 1
    return 0


# Evaluate a pseudo-class/element `code` against the element at stack index e.
# Code 0 = none (always matches); 6/10 = inert (never matches). See
# _pseudo_class_code for the mapping.
def _pseudo_matches(code: int32, e: int32) -> int32:
    if code == 0:
        return 1
    if code == 1:                                    # :root => the <html> element
        return _buf_eq(&el_sbuf[el_tag_off[e]], el_tag_len[e], \
                       cast[Ptr[uint8]]("html"), 4)
    if code == 2:                                    # :checked
        return _body_has_attr(el_body_s[e], el_body_e[e], \
                              cast[Ptr[uint8]]("checked"))
    if code == 3:                                    # :disabled
        return _body_has_attr(el_body_s[e], el_body_e[e], \
                              cast[Ptr[uint8]]("disabled"))
    if code == 4:                                    # :required
        return _body_has_attr(el_body_s[e], el_body_e[e], \
                              cast[Ptr[uint8]]("required"))
    if code == 5:                                    # :enabled (control, not disabled)
        if _el_is_control(e) == 0:
            return 0
        if _body_has_attr(el_body_s[e], el_body_e[e], \
                          cast[Ptr[uint8]]("disabled")) != 0:
            return 0
        return 1
    if code == 7:                                    # :first-child
        if el_childidx[e] == 1:
            return 1
        return 0
    if code == 8:                                    # :nth-child(even)
        if el_childidx[e] % 2 == 0:
            return 1
        return 0
    if code == 9:                                    # :nth-child(odd)
        if el_childidx[e] % 2 == 1:
            return 1
        return 0
    return 0                                          # 6 dynamic / 10 element => inert


def _tgt_matches(ri: int32, e: int32) -> int32:
    if r_tag_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_tag_off[e]], el_tag_len[e], \
                   &css_sbuf[r_tag_off[ri]], r_tag_len[ri]) == 0:
            return 0
    if r_cls_len[ri] > 0:
        if _all_cls_match(el_cls_off[e], el_cls_len[e], \
                          r_cls_off[ri], r_cls_len[ri]) == 0:
            return 0
    if r_id_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_id_off[e]], el_id_len[e], \
                   &css_sbuf[r_id_off[ri]], r_id_len[ri]) == 0:
            return 0
    if r_att_op[ri] != 0:
        if _attr_match(el_body_s[e], el_body_e[e], r_att_off[ri], r_att_len[ri], \
                       r_att_op[ri], r_atv_off[ri], r_atv_len[ri]) == 0:
            return 0
    if r_pseudo[ri] != 0:
        if _pseudo_matches(r_pseudo[ri], e) == 0:
            return 0
    return 1


def _anc_matches(ri: int32, e: int32) -> int32:
    if r_atag_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_tag_off[e]], el_tag_len[e], \
                   &css_sbuf[r_atag_off[ri]], r_atag_len[ri]) == 0:
            return 0
    if r_acls_len[ri] > 0:
        if _all_cls_match(el_cls_off[e], el_cls_len[e], \
                          r_acls_off[ri], r_acls_len[ri]) == 0:
            return 0
    if r_aid_len[ri] > 0:
        if _buf_eq(&el_sbuf[el_id_off[e]], el_id_len[e], \
                   &css_sbuf[r_aid_off[ri]], r_aid_len[ri]) == 0:
            return 0
    if r_aatt_op[ri] != 0:
        if _attr_match(el_body_s[e], el_body_e[e], r_aatt_off[ri], r_aatt_len[ri], \
                       r_aatt_op[ri], r_aatv_off[ri], r_aatv_len[ri]) == 0:
            return 0
    if r_apseudo[ri] != 0:
        if _pseudo_matches(r_apseudo[ri], e) == 0:
            return 0
    return 1


def _rule_matches(ri: int32, top: int32) -> int32:
    if r_kfname[ri] >= 0:                    # @keyframes end-state pseudo-rule:
        return 0                             # inert in selector matching
    if _tgt_matches(ri, top) == 0:
        return 0
    if r_has_anc[ri] == 0:
        return 1
    a: int32 = top - 1
    while a >= 0:
        if _anc_matches(ri, a) != 0:
            return 1
        a = a - 1
    return 0


# Resolve the cascade for the current (topmost) open element into m_*.
def _cascade_match_current():
    m_col = -1
    m_bg = -1
    m_weight = 0
    m_align = 0
    m_deco = 0
    m_fstyle = 0
    m_nomark = 0
    m_disp = 0
    m_flexdir = 0
    m_justify = 0
    m_aitems = 0
    m_acontent = 0
    m_flexgap = -1
    m_rowgap = -1
    m_flexwrap = 0
    m_gaflow = 0
    m_gtcn = 0
    m_gtrn = 0
    m_gcspan = 0
    m_gcstart = 0
    m_grspan = 0
    m_grstart = 0
    m_gan = 0
    m_gacols = 0
    m_gareaname = -1
    m_ml = -1
    m_mr = -1
    m_mt = -1
    m_mb = -1
    m_wd = -1
    m_bd = -1
    m_bordc = -1
    m_accent = -1
    m_bordr = 0
    m_bordps = 0
    m_bordss = 0
    m_bctop = -1
    m_bcrt = -1
    m_bcbot = -1
    m_bclft = -1
    m_filter = 0
    m_xform = -1
    m_animname = -1
    m_animfill = -1
    m_center = 0
    m_fontpx = -1
    m_lineh = 0
    m_ws = 0
    m_ovw = 0
    m_float = 0
    m_clear = 0
    m_pos = 0
    m_top = -1
    m_left = -1
    m_right = -1
    m_bottom = -1
    m_zidx = ZIDX_UNSET
    m_minw = -1
    m_ht = -1
    m_minh = -1
    m_maxh = -1
    m_boxsz = 0
    m_appear = 0
    m_padx = 0
    m_pady = 0
    m_bordw = 0
    m_flexg = -1
    m_flexs = -1
    m_flexb = -1
    m_posfx = 0
    m_valign = 0
    m_tindent = TINDENT_UNSET
    m_ovfx = 0
    m_ovfy = 0
    m_txtovf = 0
    m_objfit = 0
    m_objpos = 0
    m_objposx = 0
    m_objposxp = 1
    m_objposy = 0
    m_objposyp = 1
    m_aspw = 0
    m_asph = 0
    if el_sp == 0:
        return
    top: int32 = el_sp - 1
    bc: int32 = -1
    bb: int32 = -1
    bw: int32 = -1
    ba: int32 = -1
    bde: int32 = -1
    bfs: int32 = -1
    bd: int32 = -1
    bfd: int32 = -1
    bjc: int32 = -1
    bai: int32 = -1
    bac: int32 = -1
    bjg: int32 = -1
    brg: int32 = -1
    bfw: int32 = -1
    bgaf: int32 = -1
    bgt: int32 = -1
    bgr: int32 = -1
    bgp: int32 = -1
    bgpr: int32 = -1                       # best-spec tracker for grid-row
    bga: int32 = -1                        # best-spec tracker for grid-template-areas
    bgan: int32 = -1                       # best-spec tracker for grid-area name
    # best-spec trackers for the six box axes
    sml: int32 = -1
    smr: int32 = -1
    smt: int32 = -1
    smb: int32 = -1
    swd: int32 = -1
    sbd: int32 = -1
    sbc: int32 = -1
    sacc: int32 = -1
    sbr: int32 = -1
    sbps: int32 = -1
    sbcs: int32 = -1
    sflt: int32 = -1
    sxf: int32 = -1
    sanm: int32 = -1
    sfp: int32 = -1
    slh: int32 = -1
    sws: int32 = -1
    sow: int32 = -1
    sfl: int32 = -1
    scl: int32 = -1
    spo: int32 = -1
    stp: int32 = -1
    slf: int32 = -1
    srt: int32 = -1
    sbt: int32 = -1
    szi: int32 = -1
    # round-2 axis best-spec trackers
    smnw: int32 = -1
    sht: int32 = -1
    smnh: int32 = -1
    smxh: int32 = -1
    sbsz: int32 = -1
    sappear: int32 = -1
    spdx: int32 = -1
    spdy: int32 = -1
    sbdw: int32 = -1
    sfg: int32 = -1
    sfs: int32 = -1
    sfb: int32 = -1
    spx: int32 = -1
    sva: int32 = -1
    sti: int32 = -1
    sovx: int32 = -1
    sovy: int32 = -1
    stovf: int32 = -1
    sofit: int32 = -1
    sopos: int32 = -1
    sasp: int32 = -1
    ri: int32 = 0
    while ri < n_rules:
        if _rule_matches(ri, top) != 0:
            sp: int32 = r_spec[ri]
            if r_color[ri] >= 0 and sp >= bc:
                bc = sp
                m_col = r_color[ri]
            if r_bg[ri] >= 0 and sp >= bb:
                bb = sp
                m_bg = r_bg[ri]
            if r_weight[ri] != 0 and sp >= bw:
                bw = sp
                m_weight = r_weight[ri]
            if r_align[ri] != 0 and sp >= ba:
                ba = sp
                m_align = r_align[ri]
            if r_deco[ri] != 0 and sp >= bde:
                bde = sp
                m_deco = r_deco[ri]
            if r_fstyle[ri] != 0 and sp >= bfs:
                bfs = sp
                m_fstyle = r_fstyle[ri]
            if r_nomark[ri] != 0:
                m_nomark = 1                              # only `none` is honoured
            if r_disp[ri] != 0 and sp >= bd:
                bd = sp
                m_disp = r_disp[ri]
            if r_flexdir[ri] != 0 and sp >= bfd:
                bfd = sp
                m_flexdir = r_flexdir[ri]
            if r_justify[ri] != 0 and sp >= bjc:
                bjc = sp
                m_justify = r_justify[ri]
            if r_aitems[ri] != 0 and sp >= bai:
                bai = sp
                m_aitems = r_aitems[ri]
            if r_acontent[ri] != 0 and sp >= bac:
                bac = sp
                m_acontent = r_acontent[ri]
            if r_flexgap[ri] >= 0 and sp >= bjg:
                bjg = sp
                m_flexgap = r_flexgap[ri]
            if r_rowgap[ri] >= 0 and sp >= brg:
                brg = sp
                m_rowgap = r_rowgap[ri]
            if r_flexwrap[ri] != 0 and sp >= bfw:
                bfw = sp
                m_flexwrap = r_flexwrap[ri]
            if r_gaflow[ri] != 0 and sp >= bgaf:
                bgaf = sp
                m_gaflow = r_gaflow[ri]
            if r_gtcn[ri] != 0 and sp >= bgt:
                bgt = sp
                m_gtcn = r_gtcn[ri]
                gm: int32 = 0
                while gm < r_gtcn[ri] and gm < GRID_MAXTRACK:
                    m_gtc[gm] = r_gtc[ri * GRID_MAXTRACK + gm]
                    gm = gm + 1
            if r_gtrn[ri] != 0 and sp >= bgr:
                bgr = sp
                m_gtrn = r_gtrn[ri]
                gmr: int32 = 0
                while gmr < r_gtrn[ri] and gmr < GRID_MAXTRACK:
                    m_gtr[gmr] = r_gtr[ri * GRID_MAXTRACK + gmr]
                    gmr = gmr + 1
            if (r_gcspan[ri] != 0 or r_gcstart[ri] != 0) and sp >= bgp:
                bgp = sp
                m_gcspan  = r_gcspan[ri]
                m_gcstart = r_gcstart[ri]
            if (r_grspan[ri] != 0 or r_grstart[ri] != 0) and sp >= bgpr:
                bgpr = sp
                m_grspan  = r_grspan[ri]
                m_grstart = r_grstart[ri]
            if r_gan[ri] != 0 and sp >= bga:
                bga = sp
                m_gan = r_gan[ri]
                m_gacols = r_gacols[ri]
                gaw: int32 = 0
                while gaw < r_gan[ri] and gaw < GAREA_MAX:
                    m_ga_name[gaw] = r_ga_name[ri * GAREA_MAX + gaw]
                    m_ga_r0[gaw]   = r_ga_r0[ri * GAREA_MAX + gaw]
                    m_ga_c0[gaw]   = r_ga_c0[ri * GAREA_MAX + gaw]
                    m_ga_rsp[gaw]  = r_ga_rsp[ri * GAREA_MAX + gaw]
                    m_ga_csp[gaw]  = r_ga_csp[ri * GAREA_MAX + gaw]
                    gaw = gaw + 1
            if r_gareaname[ri] >= 0 and sp >= bgan:
                bgan = sp
                m_gareaname = r_gareaname[ri]
            if r_ml[ri] >= 0 and sp >= sml:
                sml = sp
                m_ml = r_ml[ri]
            if r_mr[ri] >= 0 and sp >= smr:
                smr = sp
                m_mr = r_mr[ri]
            if r_mt[ri] >= 0 and sp >= smt:
                smt = sp
                m_mt = r_mt[ri]
            if r_mb[ri] >= 0 and sp >= smb:
                smb = sp
                m_mb = r_mb[ri]
            if r_wd[ri] >= 0 and sp >= swd:
                swd = sp
                m_wd = r_wd[ri]
            if r_bd[ri] >= 0 and sp >= sbd:
                sbd = sp
                m_bd = r_bd[ri]
            if r_bordc[ri] >= 0 and sp >= sbc:
                sbc = sp
                m_bordc = r_bordc[ri]
            if r_accent[ri] >= 0 and sp >= sacc:
                sacc = sp
                m_accent = r_accent[ri]
            if r_bordr[ri] != 0 and sp >= sbr:
                sbr = sp
                m_bordr = r_bordr[ri]
            # true per-side border: the packed width + style ride together on one
            # specificity slot (a single `border-*` decl set both).
            if r_bordps[ri] != 0 and sp >= sbps:
                sbps = sp
                m_bordps = r_bordps[ri]
                m_bordss = r_bordss[ri]
            # per-side border COLOURS ride ONE specificity slot (sbcs): the
            # highest-specificity rule that declares ANY per-side colour wins all
            # four (an unset side stays -1 -> falls back to the uniform colour).
            if (r_bctop[ri] >= 0 or r_bcrt[ri] >= 0 or r_bcbot[ri] >= 0 or \
                r_bclft[ri] >= 0) and sp >= sbcs:
                sbcs = sp
                m_bctop = r_bctop[ri]
                m_bcrt  = r_bcrt[ri]
                m_bcbot = r_bcbot[ri]
                m_bclft = r_bclft[ri]
            if r_filter[ri] != 0 and sp >= sflt:
                sflt = sp
                m_filter = r_filter[ri]
            if r_xform[ri] >= 0 and sp >= sxf:
                sxf = sp
                m_xform = r_xform[ri]
            if r_animref[ri] >= 0 and sp >= sanm:
                sanm = sp
                m_animname = r_animref[ri]
            if r_animfill[ri] >= 0 and sp >= sanm:
                m_animfill = r_animfill[ri]
            if r_center[ri] != 0:
                m_center = 1
            if r_fontpx[ri] >= 0 and sp >= sfp:
                sfp = sp
                m_fontpx = r_fontpx[ri]
            if r_lineh[ri] != 0 and sp >= slh:
                slh = sp
                m_lineh = r_lineh[ri]
            if r_ws[ri] != 0 and sp >= sws:
                sws = sp
                m_ws = r_ws[ri]
            if r_ovw[ri] != 0 and sp >= sow:
                sow = sp
                m_ovw = r_ovw[ri]
            if r_float[ri] != 0 and sp >= sfl:
                sfl = sp
                m_float = r_float[ri]
            if r_clear[ri] != 0 and sp >= scl:
                scl = sp
                m_clear = r_clear[ri]
            if r_pos[ri] != 0 and sp >= spo:
                spo = sp
                m_pos = r_pos[ri]
            if r_top[ri] >= 0 and sp >= stp:
                stp = sp
                m_top = r_top[ri]
            if r_left[ri] >= 0 and sp >= slf:
                slf = sp
                m_left = r_left[ri]
            if r_right[ri] >= 0 and sp >= srt:
                srt = sp
                m_right = r_right[ri]
            if r_bottom[ri] >= 0 and sp >= sbt:
                sbt = sp
                m_bottom = r_bottom[ri]
            if r_zidx[ri] != ZIDX_UNSET and sp >= szi:
                szi = sp
                m_zidx = r_zidx[ri]
            if r_minw[ri] >= 0 and sp >= smnw:
                smnw = sp
                m_minw = r_minw[ri]
            if r_ht[ri] >= 0 and sp >= sht:
                sht = sp
                m_ht = r_ht[ri]
            if r_minh[ri] >= 0 and sp >= smnh:
                smnh = sp
                m_minh = r_minh[ri]
            if r_maxh[ri] >= 0 and sp >= smxh:
                smxh = sp
                m_maxh = r_maxh[ri]
            if r_boxsz[ri] != 0 and sp >= sbsz:
                sbsz = sp
                m_boxsz = r_boxsz[ri]
            if r_appear[ri] != 0 and sp >= sappear:
                sappear = sp
                m_appear = r_appear[ri]
            # padding/border winners for the border-box content reduction. Only a
            # rule that actually declares horizontal/vertical padding or a border
            # width participates (0 = sets none), so the `*{box-sizing:border-box}`
            # reset rule does not clobber the padding a class rule contributed.
            if r_padx[ri] > 0 and sp >= spdx:
                spdx = sp
                m_padx = r_padx[ri]
            if r_pady[ri] > 0 and sp >= spdy:
                spdy = sp
                m_pady = r_pady[ri]
            if r_bordw[ri] > 0 and sp >= sbdw:
                sbdw = sp
                m_bordw = r_bordw[ri]
            if r_flexg[ri] >= 0 and sp >= sfg:
                sfg = sp
                m_flexg = r_flexg[ri]
            if r_flexs[ri] >= 0 and sp >= sfs:
                sfs = sp
                m_flexs = r_flexs[ri]
            if r_flexb[ri] >= 0 and sp >= sfb:
                sfb = sp
                m_flexb = r_flexb[ri]
            if r_posfx[ri] != 0 and sp >= spx:
                spx = sp
                m_posfx = r_posfx[ri]
            if r_valign[ri] != 0 and sp >= sva:
                sva = sp
                m_valign = r_valign[ri]
            if r_tindent[ri] != TINDENT_UNSET and sp >= sti:
                sti = sp
                m_tindent = r_tindent[ri]
            if r_ovfx[ri] != 0 and sp >= sovx:
                sovx = sp
                m_ovfx = r_ovfx[ri]
            if r_ovfy[ri] != 0 and sp >= sovy:
                sovy = sp
                m_ovfy = r_ovfy[ri]
            if r_txtovf[ri] != 0 and sp >= stovf:
                stovf = sp
                m_txtovf = r_txtovf[ri]
            if r_objfit[ri] != 0 and sp >= sofit:
                sofit = sp
                m_objfit = r_objfit[ri]
            if r_objpos[ri] != 0 and sp >= sopos:
                sopos = sp
                m_objpos = r_objpos[ri]
                m_objposx = r_objposx[ri]
                m_objposxp = r_objposxp[ri]
                m_objposy = r_objposy[ri]
                m_objposyp = r_objposyp[ri]
            if r_asph[ri] != 0 and sp >= sasp:
                sasp = sp
                m_aspw = r_aspw[ri]
                m_asph = r_asph[ri]
        ri = ri + 1
    # CSS animations (static END-STATE model): if the element resolves an
    # animation-name to a @keyframes definition, OVERLAY that keyframe's captured
    # frame (background / colour / transform / border colour / width / height /
    # margins — opacity rides the packed background alpha) over the cascade
    # winners. WHICH frame depends on animation-fill-mode: forwards/both (and the
    # unspecified LEGACY default) paint the SETTLED end frame; an explicit
    # none/backwards paints the FROM (0%) frame. This is the honest static-render
    # choice since a headless single render has no timeline (see
    # docs/browser_w3c_conformance.md). A later @keyframes def of the same name
    # wins (scan forward). want_from selects the FROM (r_kf_from==1) pseudo-rules.
    if m_animname >= 0:
        want_from: int32 = 0
        if m_animfill == 0 or m_animfill == 2:      # none / backwards
            want_from = 1
        kri: int32 = 0
        while kri < n_rules:
            if r_kfname[kri] == m_animname and r_kf_from[kri] == want_from:
                if r_bg[kri] >= 0:
                    m_bg = r_bg[kri]
                if r_color[kri] >= 0:
                    m_col = r_color[kri]
                if r_xform[kri] >= 0:
                    m_xform = r_xform[kri]
                if r_bordc[kri] >= 0:
                    m_bordc = r_bordc[kri]
                if r_wd[kri] >= 0:
                    m_wd = r_wd[kri]
                if r_ht[kri] >= 0:
                    m_ht = r_ht[kri]
                if r_ml[kri] >= 0:
                    m_ml = r_ml[kri]
                if r_mr[kri] >= 0:
                    m_mr = r_mr[kri]
                if r_mt[kri] >= 0:
                    m_mt = r_mt[kri]
                if r_mb[kri] >= 0:
                    m_mb = r_mb[kri]
            kri = kri + 1
    # box-sizing:border-box -> the specified width/height INCLUDE padding+border,
    # so the content box shrinks by both. Applied ONCE here against the resolved
    # cascade winners, so a `*{box-sizing:border-box}` rule composes correctly
    # with `width`/`padding`/`border` declared in other (class/id) rules. Inline
    # style="" resolves its own copy in _parse_inline_wa and overrides m_wd/m_ht.
    if m_boxsz == 2:
        if m_wd >= 0:
            m_wd = m_wd - m_padx - 2 * m_bordw
            if m_wd < 0:
                m_wd = 0
        if m_ht >= 0:
            m_ht = m_ht - m_pady - 2 * m_bordw
            if m_ht < 0:
                m_ht = 0
        if m_flexb >= 0:
            m_flexb = m_flexb - m_padx - 2 * m_bordw
            if m_flexb < 0:
                m_flexb = 0
    # UA default: <figure> is inset ~40px on each side (real browsers use the
    # `figure { margin: 1em 40px }` UA rule). Apply ONLY when the author cascade
    # left the horizontal margins unset (m_ml/m_mr == -1), so any stylesheet or
    # inline margin still wins. Vertical margin keeps the generic block gap.
    if _buf_eq(&el_sbuf[el_tag_off[top]], el_tag_len[top], \
               cast[Ptr[uint8]]("figure"), 6) != 0:
        if m_ml < 0:
            m_ml = 40
        if m_mr < 0:
            m_mr = 40
    # CSS transform (stylesheet cascade): bind the winning affine template with
    # the fill this element paints and re-pack it through m_bg. Every background
    # consumer — block boxes (forms.ad reads m_bg directly), inline-block chips
    # (_open_style bgv=m_bg) — then carries the reference verbatim to htmlpage,
    # which repaints the box as a transformed quad. Binding here (not per paint
    # path) is what makes a plain block <div transform:...> actually transform.
    if m_xform >= 0:
        m_bg = _xf_bind(m_xform, m_bg)


# Resolve the CASCADE flex-grow/shrink/basis winners for a flex-item child whose
# tag name is src[np..np+nlen) and whose open-tag body (attrs) spans [ne,te). The
# child is temporarily pushed onto the element stack so class/id/tag selectors —
# and any descendant/ancestor combinator relative to the flex container already
# on the stack — resolve exactly as they would when the element is really laid
# out. The push is unwound WITHOUT disturbing the parent's sibling counters
# (el_nchild / el_rootcnt), so the subsequent REAL element push still numbers
# :nth-child correctly. On return m_flexg / m_flexs / m_flexb hold the winners
# (milli grow, milli shrink, px basis; -1 = unset). The flex layout (box.ad
# _flex_grow_scan) reads these for class-styled items (`.col{flex:1}`), letting
# an inline style="" override them afterwards.
def _flx_child_cascade(np: uint64, nlen: uint64, ne: uint64, te: uint64):
    save_sp: int32 = el_sp
    save_slen: uint64 = el_slen
    save_root: int32 = el_rootcnt
    save_nc: int32 = 0
    if el_sp > 0:
        save_nc = el_nchild[el_sp - 1]
    _el_push(np, nlen, ne, te)
    _cascade_match_current()
    el_sp = save_sp
    el_slen = save_slen
    el_rootcnt = save_root
    if el_sp > 0:
        el_nchild[el_sp - 1] = save_nc


# ---- font-weight (bold) scope ---------------------------------------
def _css_weight_effective() -> int32:
    i: int32 = weight_sp - 1
    while i >= 0:
        if weight_stack[i] != 0:
            return weight_stack[i]
        i = i - 1
    return 0


def _weight_push(w: int32):
    if weight_sp < 64:
        weight_stack[weight_sp] = w
        weight_sp = weight_sp + 1
    if _css_weight_effective() == 1:
        g_css_bold = 1
    else:
        g_css_bold = 0


def _weight_pop():
    if weight_sp > 0:
        weight_sp = weight_sp - 1
    if _css_weight_effective() == 1:
        g_css_bold = 1
    else:
        g_css_bold = 0


# ---- font-style (italic) scope --------------------------------------
def _css_fstyle_effective() -> int32:
    i: int32 = fstyle_sp - 1
    while i >= 0:
        if fstyle_stack[i] != 0:
            return fstyle_stack[i]
        i = i - 1
    return 0


def _fstyle_push(s: int32):
    if fstyle_sp < 64:
        fstyle_stack[fstyle_sp] = s
        fstyle_sp = fstyle_sp + 1
    if _css_fstyle_effective() == 1:
        g_css_italic = 1
    else:
        g_css_italic = 0


def _fstyle_pop():
    if fstyle_sp > 0:
        fstyle_sp = fstyle_sp - 1
    if _css_fstyle_effective() == 1:
        g_css_italic = 1
    else:
        g_css_italic = 0


# ---- font-size (px) scope — inherits the nearest ancestor that set one ----
def _fontpx_effective() -> int32:
    i: int32 = fontpx_sp - 1
    while i >= 0:
        if fontpx_stack[i] > 0:
            return fontpx_stack[i]
        i = i - 1
    return 0


def _fontpx_push(px: int32):
    if fontpx_sp < 64:
        fontpx_stack[fontpx_sp] = px
        fontpx_sp = fontpx_sp + 1
    g_font_px = _fontpx_effective()


def _fontpx_pop():
    if fontpx_sp > 0:
        fontpx_sp = fontpx_sp - 1
    g_font_px = _fontpx_effective()


# ---- line-height (px) scope — inherits the nearest ancestor that set one ----
def _lineh_effective() -> int32:
    i: int32 = lineh_sp - 1
    while i >= 0:
        if lineh_stack[i] > 0:
            return lineh_stack[i]
        i = i - 1
    return 0


def _lineh_push(px: int32):
    if lineh_sp < 64:
        lineh_stack[lineh_sp] = px
        lineh_sp = lineh_sp + 1
    g_lineh = _lineh_effective()


def _lineh_pop():
    if lineh_sp > 0:
        lineh_sp = lineh_sp - 1
    g_lineh = _lineh_effective()


# ---- white-space scope — inherits the nearest ancestor that set one --------
# Entries are mode+1 (0 = level sets none). Effective g_ws is the nearest
# non-zero entry minus 1 (0..3), or 0 (normal) when nothing on the stack set it.
def _ws_effective() -> int32:
    i: int32 = ws_sp - 1
    while i >= 0:
        if ws_stack[i] != 0:
            return ws_stack[i] - 1
        i = i - 1
    return 0


def _ws_push(enc: int32):
    if ws_sp < 64:
        ws_stack[ws_sp] = enc
        ws_sp = ws_sp + 1
    g_ws = _ws_effective()


def _ws_pop():
    if ws_sp > 0:
        ws_sp = ws_sp - 1
    g_ws = _ws_effective()


# ---- overflow-wrap / word-break scope — inherits like white-space ----------
# Entries are mode+1 (0 = level sets none). g_break_word is 1 when the nearest
# non-zero entry is a breaking mode (encoding 2), else 0.
def _ovw_effective() -> int32:
    i: int32 = ovw_sp - 1
    while i >= 0:
        if ovw_stack[i] != 0:
            if ovw_stack[i] == 2:
                return 1
            return 0
        i = i - 1
    return 0


def _ovw_push(enc: int32):
    if ovw_sp < 64:
        ovw_stack[ovw_sp] = enc
        ovw_sp = ovw_sp + 1
    g_break_word = _ovw_effective()


def _ovw_pop():
    if ovw_sp > 0:
        ovw_sp = ovw_sp - 1
    g_break_word = _ovw_effective()


# ---- text-align scope -----------------------------------------------
def _align_effective() -> int32:
    i: int32 = align_sp - 1
    while i >= 0:
        if align_stack[i] != 0:
            return align_stack[i]
        i = i - 1
    return 0


def _align_push(a: int32):
    if align_sp < 64:
        align_stack[align_sp] = a
        align_sp = align_sp + 1
    g_align = _align_effective()


def _align_pop():
    if align_sp > 0:
        align_sp = align_sp - 1
    g_align = _align_effective()


# ---- text-decoration (underline) scope ------------------------------
# Inherits the nearest ancestor that set a decoration, so an underlined block
# carries the rule down to its inline text. 1 = underline, 2 = none.
def _deco_effective() -> int32:
    i: int32 = deco_sp - 1
    while i >= 0:
        if deco_stack[i] != 0:
            return deco_stack[i]
        i = i - 1
    return 0


def _deco_push(d: int32):
    if deco_sp < 64:
        deco_stack[deco_sp] = d
        deco_sp = deco_sp + 1
    g_css_uline = _deco_effective()
    _recompute_style()


def _deco_pop():
    if deco_sp > 0:
        deco_sp = deco_sp - 1
    g_css_uline = _deco_effective()
    _recompute_style()


# The colour an element specifies for ITSELF: its matched-cascade colour (m_col,
# valid right after the element's _cascade_match_current) overridden by an inline
# style="color:…". Returns -1 when the element sets no colour of its own (an
# inherited ancestor colour is NOT its own). Used to let a styled anchor override
# the default link blue without an inherited body colour leaking onto plain links.
def _own_color(ne: uint64, te: uint64) -> int32:
    c: int32 = m_col
    ic: int32 = _tag_color(ne, te)
    if ic >= 0:
        c = ic
    return c


# Resolve the cascade winners (m_*) + inline declaration scratch (d_*) for a
# VOID replaced element (e.g. <img>) that is NOT pushed onto the element stack by
# the normal flow. The element is transiently pushed so tag/class/id selectors
# match it, the cascade + inline style are resolved, then it is popped and the
# parent's nth-child counters are RESTORED — so counting an image here does not
# perturb :nth-child of following siblings. After this, m_objfit/d_objfit (etc.)
# hold this element's resolved object-fit/object-position. `np`/`nlen` name the
# element in the source (for _el_push/_el_pop's tag comparison).
def _img_cascade(np: uint64, nlen: uint64, ne: uint64, te: uint64):
    saved_root: int32 = el_rootcnt
    saved_nchild: int32 = 0
    if el_sp > 0:
        saved_nchild = el_nchild[el_sp - 1]
    _el_push(np, nlen, ne, te)
    _cascade_match_current()
    _parse_inline_wa(ne, te)
    _el_pop(np, nlen)
    el_rootcnt = saved_root
    if el_sp > 0:
        el_nchild[el_sp - 1] = saved_nchild


# Open/close a full style scope for a stylable element. The cascade is matched
# from el_stack (already pushed) and merged with the inline style="" overrides.
def _open_style(ne: uint64, te: uint64):
    _cascade_match_current()
    col: int32 = m_col
    ic: int32 = _tag_color(ne, te)
    if ic >= 0:
        col = ic
    bgv: int32 = m_bg
    ib: int32 = _tag_bgcolor(ne, te)
    if ib >= 0:
        bgv = ib
    wt: int32 = m_weight
    al: int32 = m_align
    dec: int32 = m_deco
    fst: int32 = m_fstyle
    fpx: int32 = m_fontpx
    # inline style="" font-weight / text-align / text-decoration / font-size
    # override the cascade.
    _parse_inline_wa(ne, te)
    if d_weight != 0:
        wt = d_weight
    if d_align != 0:
        al = d_align
    if d_deco != 0:
        dec = d_deco
    if d_fstyle != 0:
        fst = d_fstyle
    if d_fontpx >= 0:
        fpx = d_fontpx
    push_px: int32 = 0
    if fpx >= 0:
        push_px = fpx
    # line-height: inline overrides the cascade; resolve unitless/% against this
    # element's effective font-size (its own if set, else the inherited one).
    lh_enc: int32 = m_lineh
    if d_lineh != 0:
        lh_enc = d_lineh
    lh_base: int32 = push_px
    if lh_base <= 0:
        lh_base = g_font_px
    lh_px: int32 = _lineh_resolve(lh_enc, lh_base)
    # white-space: inline declaration wins over the cascade (both mode+1 encoded).
    ws_enc: int32 = m_ws
    if d_ws != 0:
        ws_enc = d_ws
    # The presentational HTML `nowrap` attribute (e.g. <td nowrap>) maps to
    # white-space:nowrap, unless an inline `white-space` style overrides it.
    # Real pages (google.com's footer cells) rely on this to keep a short label
    # like "Advanced search" on one line inside a narrow table column instead of
    # collapsing to one glyph per row.
    if d_ws == 0 and _hx_find_attr(ne, te, cast[Ptr[uint8]]("nowrap")) != 0:
        ws_enc = 2
    # overflow-wrap / word-break: inline declaration wins over the cascade.
    ovw_enc: int32 = m_ovw
    if d_ovw != 0:
        ovw_enc = d_ovw
    # CSS transform via INLINE style="" (the stylesheet cascade is already folded
    # into m_bg/bgv by _cascade_match_current). Only bind here when an inline
    # transform is present and no cascade transform already marked the fill.
    if d_xform >= 0 and xform_is(bgv) == 0:
        bgv = _xf_bind(d_xform, bgv)
    _color_push(col)
    _bg_push(bgv)
    _weight_push(wt)
    _align_push(al)
    _deco_push(dec)
    _fstyle_push(fst)
    _fontpx_push(push_px)
    _lineh_push(lh_px)
    _ws_push(ws_enc)
    _ovw_push(ovw_enc)


def _close_style():
    _color_pop()
    _bg_pop()
    _weight_pop()
    _align_pop()
    _deco_pop()
    _fstyle_pop()
    _fontpx_pop()
    _lineh_pop()
    _ws_pop()
    _ovw_pop()


# Synthesise the implicit `</li>` for the list item currently open at level `lvl`
# — pop its _open_style() scope exactly once and clear the flag. Called at the
# next <li>/</ul>/</ol> boundary at this level (and on an explicit </li>) so the
# style stack stays balanced whether or not the author wrote </li>. Idempotent:
# a no-op when no styled item is open, so a double close (explicit </li> then
# </ul>) can't over-pop the stack.
def _li_close_lvl(lvl: int32):
    if lvl >= 0 and lvl < MAX_LIST_DEPTH and li_styled[lvl] != 0:
        _close_style()
        li_styled[lvl] = 0


# Scan an inline style="" attribute for font-weight/text-align/display + the
# full box model (margin/padding/width/border); sets d_weight/d_align/d_disp
# and the d_* box scratch (d_color/d_bg come from _tag_color/_tag_bgcolor).
# Inline declarations here override any stylesheet/class rule (highest priority).
def _parse_inline_wa(ne: uint64, te: uint64):
    d_weight = 0
    d_align = 0
    d_deco = 0
    d_fstyle = 0
    d_nomark = 0
    d_disp = 0
    d_flexdir = 0
    d_justify = 0
    d_aitems = 0
    d_acontent = 0
    d_flexgap = -1
    d_rowgap = -1
    d_flexwrap = 0
    d_gaflow = 0
    d_gtcn = 0
    d_gtrn = 0
    d_gcspan = 0
    d_gcstart = 0
    d_grspan = 0
    d_grstart = 0
    d_gan = 0
    d_gacols = 0
    d_gareaname = -1
    d_ml = -1
    d_mr = -1
    d_mt = -1
    d_mb = -1
    d_wd = -1
    d_bd = -1
    d_bordc = -1
    d_accent = -1
    d_bordr = 0
    d_bw_t = -1
    d_bw_r = -1
    d_bw_b = -1
    d_bw_l = -1
    d_bs_t = -1
    d_bs_r = -1
    d_bs_b = -1
    d_bs_l = -1
    d_bordps = 0
    d_bordss = 0
    d_bc_t = -1
    d_bc_r = -1
    d_bc_b = -1
    d_bc_l = -1
    d_filter = 0
    d_xform = -1
    d_animname = -1
    d_animfill = -1
    d_bg_alpha = 255
    d_opacity = 255
    d_boxshadow = 0
    d_center = 0
    d_fontpx = -1
    d_lineh = 0
    d_ws = 0
    d_ovw = 0
    d_float = 0
    d_clear = 0
    d_pos = 0
    d_top = -1
    d_left = -1
    d_right = -1
    d_bottom = -1
    d_zidx = ZIDX_UNSET
    d_minw = -1
    d_ht = -1
    d_minh = -1
    d_maxh = -1
    d_boxsz = 0
    d_appear = 0
    d_padx = 0
    d_pady = 0
    d_bordw = 0
    d_flexg = -1
    d_flexs = -1
    d_flexb = -1
    d_posfx = 0
    d_valign = 0
    d_tindent = TINDENT_UNSET
    d_ovfx = 0
    d_ovfy = 0
    d_txtovf = 0
    d_objfit = 0
    d_objpos = 0
    d_objposx = 0
    d_objposxp = 1
    d_objposy = 0
    d_objposyp = 1
    d_aspw = 0
    d_asph = 0
    if _hx_find_attr(ne, te, cast[Ptr[uint8]]("style")) == 0:
        return
    a: uint64 = g_attr_start
    b: uint64 = g_attr_end
    i: uint64 = a
    while i < b:
        ps: uint64 = i
        while i < b and src_ptr[i] != 58 and src_ptr[i] != 59:
            i = i + 1
        if i < b and src_ptr[i] == 58:
            pe: uint64 = i
            i = i + 1
            vs: uint64 = i
            while i < b and src_ptr[i] != 59:
                i = i + 1
            # box model (margin/padding/width/border) — shared with the sheet.
            if _box_decl(ps, pe, vs, i) != 0:
                pass
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("font-weight")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("bold")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("700")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("800")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("900")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("600")) != 0:
                    d_weight = 1
                elif _val_starts(vs, i, cast[Ptr[uint8]]("normal")) != 0:
                    d_weight = 2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("text-align")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("center")) != 0:
                    d_align = 2
                elif _val_starts(vs, i, cast[Ptr[uint8]]("right")) != 0:
                    d_align = 3
                elif _val_starts(vs, i, cast[Ptr[uint8]]("left")) != 0:
                    d_align = 1
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("text-decoration")) != 0 or \
                 _prop_is(ps, pe, cast[Ptr[uint8]]("text-decoration-line")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("underline")) != 0:
                    d_deco = 1
                elif _val_starts(vs, i, cast[Ptr[uint8]]("none")) != 0:
                    d_deco = 2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("font-style")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("italic")) != 0 or \
                   _val_starts(vs, i, cast[Ptr[uint8]]("oblique")) != 0:
                    d_fstyle = 1
                elif _val_starts(vs, i, cast[Ptr[uint8]]("normal")) != 0:
                    d_fstyle = 2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("display")) != 0:
                d_disp = _disp_value(vs, i)
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("flex-direction")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("column")) != 0:
                    d_flexdir = 1
                else:
                    d_flexdir = 2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("justify-content")) != 0:
                jv2: int32 = _justify_value(vs, i)
                if jv2 != 0:
                    d_justify = jv2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("align-items")) != 0:
                av2: int32 = _align_items_value(vs, i)
                if av2 != 0:
                    d_aitems = av2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("align-content")) != 0:
                acv2: int32 = _align_content_value(vs, i)
                if acv2 != 0:
                    d_acontent = acv2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("flex-wrap")) != 0:
                if _val_starts(vs, i, cast[Ptr[uint8]]("wrap")) != 0:
                    d_flexwrap = 1
                else:
                    d_flexwrap = 0
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("grid-auto-flow")) != 0:
                d_gaflow = _grid_auto_flow_value(vs, i)
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("grid-template-columns")) != 0:
                d_gtcn = _grid_parse_template(vs, i)
                gci: int32 = 0
                while gci < d_gtcn and gci < GRID_MAXTRACK:
                    d_gtc[gci] = gts_enc[gci]
                    gci = gci + 1
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("grid-template-rows")) != 0:
                d_gtrn = _grid_parse_template(vs, i)
                gri: int32 = 0
                while gri < d_gtrn and gri < GRID_MAXTRACK:
                    d_gtr[gri] = gts_enc[gri]
                    gri = gri + 1
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("grid-column")) != 0:
                _grid_column_parse(vs, i)
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("grid-row")) != 0:
                _grid_row_parse(vs, i)
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("grid-template-areas")) != 0:
                _grid_parse_areas(vs, i)
                d_gan = ga_s_n
                d_gacols = ga_s_cols
                gia: int32 = 0
                while gia < ga_s_n and gia < GAREA_MAX:
                    d_ga_name[gia] = ga_s_name[gia]
                    d_ga_r0[gia]   = ga_s_minr[gia]
                    d_ga_c0[gia]   = ga_s_minc[gia]
                    d_ga_rsp[gia]  = ga_s_maxr[gia] - ga_s_minr[gia] + 1
                    d_ga_csp[gia]  = ga_s_maxc[gia] - ga_s_minc[gia] + 1
                    gia = gia + 1
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("grid-area")) != 0:
                _grid_area_parse(vs, i)
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("gap")) != 0:
                _parse_box_lens(vs, i)
                if n_box_lens >= 1:
                    d_rowgap = box_lens[0]
                    if n_box_lens >= 2:
                        d_flexgap = box_lens[1]
                    else:
                        d_flexgap = box_lens[0]
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("column-gap")) != 0:
                gp2: int32 = _style_len(vs, i)
                if gp2 >= 0:
                    d_flexgap = gp2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("row-gap")) != 0:
                rgp2: int32 = _style_len(vs, i)
                if rgp2 >= 0:
                    d_rowgap = rgp2
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("font-size")) != 0:
                fp: int32 = _style_len(vs, i)
                if fp > 0:
                    d_fontpx = fp
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("line-height")) != 0:
                lh: int32 = _lineh_value(_val_start(vs, i), i)
                if lh != 0:
                    d_lineh = lh
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("white-space")) != 0:
                wsv: int32 = _ws_value(vs, i)
                if wsv != 0:
                    d_ws = wsv
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("overflow-wrap")) != 0 or \
                 _prop_is(ps, pe, cast[Ptr[uint8]]("word-wrap")) != 0 or \
                 _prop_is(ps, pe, cast[Ptr[uint8]]("word-break")) != 0:
                owv: int32 = _ovw_value(vs, i)
                if owv != 0:
                    d_ovw = owv
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("flex-grow")) != 0:
                d_flexg = _flexnum_milli(vs, i)
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("flex-shrink")) != 0:
                d_flexs = _flexnum_milli(vs, i)
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("flex-basis")) != 0:
                _flex_basis_set(vs, i)
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("flex")) != 0:
                _flex_shorthand(vs, i)
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("vertical-align")) != 0:
                vv: int32 = _valign_value(vs, i)
                if vv != 0:
                    d_valign = vv
            elif _prop_is(ps, pe, cast[Ptr[uint8]]("text-indent")) != 0:
                ti: int32 = _style_len(vs, i)
                if ti >= 0:
                    d_tindent = ti
        if i < b and src_ptr[i] == 59:
            i = i + 1
    # box-sizing:border-box -> the declared width/height already INCLUDE padding
    # and border, so the content box shrinks by both. An all-inline style="" block
    # is self-contained (width, padding, box-sizing all here), so resolving it now
    # is correct; the cascade path resolves the same reduction against the winners.
    if d_boxsz == 2:
        if d_wd >= 0:
            d_wd = d_wd - d_padx - 2 * d_bordw
            if d_wd < 0:
                d_wd = 0
        if d_ht >= 0:
            d_ht = d_ht - d_pady - 2 * d_bordw
            if d_ht < 0:
                d_ht = 0
        # flex-basis is a main-size: under border-box it too already includes the
        # (inline-axis) padding+border, so the resolved base content-size shrinks.
        if d_flexb >= 0:
            d_flexb = d_flexb - d_padx - 2 * d_bordw
            if d_flexb < 0:
                d_flexb = 0


# Resolve whether the element being opened is display:none (cascade or inline).
def _is_display_none(ne: uint64, te: uint64) -> int32:
    _parse_inline_wa(ne, te)
    if d_disp == 1:                                  # inline display:none
        return 1
    if d_disp >= 2:                                  # any explicit inline display (shown)
        return 0
    if m_disp == 1:                                  # cascade display:none
        return 1
    return 0



# lib/web/css/values.ad — part of the modular web engine (extracted from htmlengine.ad).
# CSS colour-value parsing — #rgb/#rrggbb/named colours from style/color attributes.
#
# Behavior-preserving split (single-compilation-unit; byte-identical).

from lib.htmlengine import _hx_lower, _is_alpha

# Alpha (0..255) of the colour most recently parsed by _color_value / _rgb_func
# / _hsl_func. _color_value returns only the packed 0xRRGGBB (its contract is
# unchanged for every existing caller); a caller that also wants the rgba()/
# hsla()/#rrggbbaa alpha reads this side-channel immediately afterwards. 255 for
# opaque forms (named / #rgb / #rrggbb / rgb() / hsl()).
g_cv_alpha: int32 = 255

# ====================================================================
# COLOUR PARSING — extract a text colour from a tag body src[ts..te).
# Handles  style="…color:VALUE…"  and  color="VALUE" / color=VALUE
# (the <font> attribute). VALUE is #rgb, #rrggbb, or a named colour.
# Returns packed 0xRRGGBB, or -1 if none / unparseable.
# ====================================================================
def _hx_hexval(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return cast[int32](c - 48)
    lc: uint8 = _hx_lower(c)
    if lc >= 97 and lc <= 102:
        return cast[int32](lc - 97) + 10
    return -1


# Compare src[at..] against a lowercase literal; returns 1 on full match.
def _srcword_is(at: uint64, lit: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while lit[i] != 0:
        if at + i >= src_len:
            return 0
        if _hx_lower(src_ptr[at + i]) != lit[i]:
            return 0
        i = i + 1
    return 1


# Named colours (the CSS/HTML basics). Returns 0xRRGGBB or -1.
def _named_color(at: uint64) -> int32:
    if _srcword_is(at, cast[Ptr[uint8]]("black")) != 0:
        return 0x000000
    if _srcword_is(at, cast[Ptr[uint8]]("white")) != 0:
        return 0xffffff
    if _srcword_is(at, cast[Ptr[uint8]]("red")) != 0:
        return 0xff0000
    if _srcword_is(at, cast[Ptr[uint8]]("green")) != 0:
        return 0x008000
    if _srcword_is(at, cast[Ptr[uint8]]("lime")) != 0:
        return 0x00ff00
    if _srcword_is(at, cast[Ptr[uint8]]("blue")) != 0:
        return 0x0000ff
    if _srcword_is(at, cast[Ptr[uint8]]("navy")) != 0:
        return 0x000080
    if _srcword_is(at, cast[Ptr[uint8]]("teal")) != 0:
        return 0x008080
    if _srcword_is(at, cast[Ptr[uint8]]("aqua")) != 0:
        return 0x00ffff
    if _srcword_is(at, cast[Ptr[uint8]]("olive")) != 0:
        return 0x808000
    if _srcword_is(at, cast[Ptr[uint8]]("yellow")) != 0:
        return 0xffff00
    if _srcword_is(at, cast[Ptr[uint8]]("orange")) != 0:
        return 0xffa500
    if _srcword_is(at, cast[Ptr[uint8]]("purple")) != 0:
        return 0x800080
    if _srcword_is(at, cast[Ptr[uint8]]("fuchsia")) != 0:
        return 0xff00ff
    if _srcword_is(at, cast[Ptr[uint8]]("maroon")) != 0:
        return 0x800000
    if _srcword_is(at, cast[Ptr[uint8]]("silver")) != 0:
        return 0xc0c0c0
    if _srcword_is(at, cast[Ptr[uint8]]("gray")) != 0:
        return 0x808080
    if _srcword_is(at, cast[Ptr[uint8]]("grey")) != 0:
        return 0x808080
    # Extended CSS named colours common on hand-written pages.
    if _srcword_is(at, cast[Ptr[uint8]]("magenta")) != 0:
        return 0xff00ff
    if _srcword_is(at, cast[Ptr[uint8]]("cyan")) != 0:
        return 0x00ffff
    if _srcword_is(at, cast[Ptr[uint8]]("pink")) != 0:
        return 0xffc0cb
    if _srcword_is(at, cast[Ptr[uint8]]("brown")) != 0:
        return 0xa52a2a
    if _srcword_is(at, cast[Ptr[uint8]]("gold")) != 0:
        return 0xffd700
    if _srcword_is(at, cast[Ptr[uint8]]("indigo")) != 0:
        return 0x4b0082
    if _srcword_is(at, cast[Ptr[uint8]]("violet")) != 0:
        return 0xee82ee
    if _srcword_is(at, cast[Ptr[uint8]]("crimson")) != 0:
        return 0xdc143c
    if _srcword_is(at, cast[Ptr[uint8]]("coral")) != 0:
        return 0xff7f50
    if _srcword_is(at, cast[Ptr[uint8]]("salmon")) != 0:
        return 0xfa8072
    if _srcword_is(at, cast[Ptr[uint8]]("tomato")) != 0:
        return 0xff6347
    if _srcword_is(at, cast[Ptr[uint8]]("khaki")) != 0:
        return 0xf0e68c
    if _srcword_is(at, cast[Ptr[uint8]]("tan")) != 0:
        return 0xd2b48c
    if _srcword_is(at, cast[Ptr[uint8]]("turquoise")) != 0:
        return 0x40e0d0
    if _srcword_is(at, cast[Ptr[uint8]]("skyblue")) != 0:
        return 0x87ceeb
    if _srcword_is(at, cast[Ptr[uint8]]("darkblue")) != 0:
        return 0x00008b
    if _srcword_is(at, cast[Ptr[uint8]]("darkgreen")) != 0:
        return 0x006400
    if _srcword_is(at, cast[Ptr[uint8]]("darkred")) != 0:
        return 0x8b0000
    if _srcword_is(at, cast[Ptr[uint8]]("lightblue")) != 0:
        return 0xadd8e6
    if _srcword_is(at, cast[Ptr[uint8]]("lightgreen")) != 0:
        return 0x90ee90
    if _srcword_is(at, cast[Ptr[uint8]]("lightgray")) != 0:
        return 0xd3d3d3
    if _srcword_is(at, cast[Ptr[uint8]]("lightgrey")) != 0:
        return 0xd3d3d3
    if _srcword_is(at, cast[Ptr[uint8]]("darkgray")) != 0:
        return 0xa9a9a9
    if _srcword_is(at, cast[Ptr[uint8]]("darkgrey")) != 0:
        return 0xa9a9a9
    if _srcword_is(at, cast[Ptr[uint8]]("beige")) != 0:
        return 0xf5f5dc
    if _srcword_is(at, cast[Ptr[uint8]]("ivory")) != 0:
        return 0xfffff0
    if _srcword_is(at, cast[Ptr[uint8]]("lavender")) != 0:
        return 0xe6e6fa
    if _srcword_is(at, cast[Ptr[uint8]]("rebeccapurple")) != 0:
        return 0x663399
    if _srcword_is(at, cast[Ptr[uint8]]("whitesmoke")) != 0:
        return 0xf5f5f5
    if _srcword_is(at, cast[Ptr[uint8]]("gainsboro")) != 0:
        return 0xdcdcdc
    if _srcword_is(at, cast[Ptr[uint8]]("dimgray")) != 0 or \
       _srcword_is(at, cast[Ptr[uint8]]("dimgrey")) != 0:
        return 0x696969
    if _srcword_is(at, cast[Ptr[uint8]]("slategray")) != 0 or \
       _srcword_is(at, cast[Ptr[uint8]]("slategrey")) != 0:
        return 0x708090
    if _srcword_is(at, cast[Ptr[uint8]]("steelblue")) != 0:
        return 0x4682b4
    if _srcword_is(at, cast[Ptr[uint8]]("dodgerblue")) != 0:
        return 0x1e90ff
    if _srcword_is(at, cast[Ptr[uint8]]("royalblue")) != 0:
        return 0x4169e1
    if _srcword_is(at, cast[Ptr[uint8]]("midnightblue")) != 0:
        return 0x191970
    if _srcword_is(at, cast[Ptr[uint8]]("seagreen")) != 0:
        return 0x2e8b57
    if _srcword_is(at, cast[Ptr[uint8]]("forestgreen")) != 0:
        return 0x228b22
    if _srcword_is(at, cast[Ptr[uint8]]("chocolate")) != 0:
        return 0xd2691e
    if _srcword_is(at, cast[Ptr[uint8]]("sienna")) != 0:
        return 0xa0522d
    if _srcword_is(at, cast[Ptr[uint8]]("firebrick")) != 0:
        return 0xb22222
    if _srcword_is(at, cast[Ptr[uint8]]("orchid")) != 0:
        return 0xda70d6
    if _srcword_is(at, cast[Ptr[uint8]]("plum")) != 0:
        return 0xdda0dd
    if _srcword_is(at, cast[Ptr[uint8]]("goldenrod")) != 0:
        return 0xdaa520
    return -1


# Parse a CSS alpha value at src[at] — a 0..1 fraction ("0.3", ".3", "1") or an
# NN% form — into 0..255. Reads one number token; used for the rgba()/hsla()
# alpha channel. A bare "0.3" is scaled ×255; "30%" is scaled ×255/100.
def _parse_alpha_frac(at: uint64) -> int32:
    j: uint64 = at
    whole: int32 = 0
    while j < src_len and src_ptr[j] >= 48 and src_ptr[j] <= 57:
        whole = whole * 10 + cast[int32](src_ptr[j] - 48)
        j = j + 1
    # fraction digits, scaled to thousandths (0.abc -> abc)
    frac: int32 = 0
    scale: int32 = 1
    if j < src_len and src_ptr[j] == 46:             # '.'
        j = j + 1
        while j < src_len and src_ptr[j] >= 48 and src_ptr[j] <= 57 and scale < 1000:
            frac = frac * 10 + cast[int32](src_ptr[j] - 48)
            scale = scale * 10
            j = j + 1
    if j < src_len and src_ptr[j] == 37:             # 'NN%'
        a: int32 = whole * 255 / 100
        if a > 255:
            a = 255
        return a
    # value in milli (0..1000+): whole*1000 + frac normalised to /1000.
    milli: int32 = whole * 1000 + frac * 1000 / scale
    a2: int32 = milli * 255 / 1000
    if a2 > 255:
        a2 = 255
    if a2 < 0:
        a2 = 0
    return a2


# Parse an `rgb(r,g,b)` / `rgb(r, g, b)` functional colour at src[at].
# Returns packed 0xRRGGBB, or -1 if not an rgb() form. rgba()'s 4th component is
# captured into g_cv_alpha (0..255) for callers that honour translucency.
def _rgb_func(at: uint64) -> int32:
    if _srcword_is(at, cast[Ptr[uint8]]("rgb")) == 0:
        return -1
    j: uint64 = at + 3
    # Accept the rgba() spelling too — the alpha component is simply ignored
    # (we render opaque), so rgba(r,g,b,a) yields the same colour as rgb(r,g,b).
    if j < src_len and (src_ptr[j] == 97 or src_ptr[j] == 65):   # 'a'/'A'
        j = j + 1
    while j < src_len and (src_ptr[j] == 32 or src_ptr[j] == 9):
        j = j + 1
    if j >= src_len or src_ptr[j] != 40:             # '('
        return -1
    j = j + 1
    comp: int32 = 0
    parts: Array[3, int32]
    while comp < 3:
        while j < src_len and (src_ptr[j] == 32 or src_ptr[j] == 9):
            j = j + 1
        v: int32 = 0
        nd: int32 = 0
        while j < src_len and src_ptr[j] >= 48 and src_ptr[j] <= 57:
            v = v * 10 + cast[int32](src_ptr[j] - 48)
            nd = nd + 1
            j = j + 1
        if nd == 0:
            return -1
        # A percentage component scales 0..100 -> 0..255.
        if j < src_len and src_ptr[j] == 37:         # '%'
            v = v * 255 / 100
            j = j + 1
        if v > 255:
            v = 255
        parts[comp] = v
        comp = comp + 1
        while j < src_len and (src_ptr[j] == 32 or src_ptr[j] == 9):
            j = j + 1
        if comp < 3:
            if j < src_len and src_ptr[j] == 44:     # ','
                j = j + 1
    # optional 4th component: the alpha (rgba). Accept ',' or '/' separator,
    # then a 0..1 fraction ("0.3", ".3") or an NN% form -> map to 0..255.
    while j < src_len and (src_ptr[j] == 32 or src_ptr[j] == 9 or \
                           src_ptr[j] == 44 or src_ptr[j] == 47):     # ',' '/'
        j = j + 1
    if j < src_len and ((src_ptr[j] >= 48 and src_ptr[j] <= 57) or src_ptr[j] == 46):
        g_cv_alpha = _parse_alpha_frac(j)
    return (parts[0] * 65536) + (parts[1] * 256) + parts[2]


# Convert an HSL triple (h in degrees, s/l in 0..100) to packed 0xRRGGBB using
# the CSS Color 3 algorithm in fixed-point (all fractions scaled by 1000).
def _hsl_to_rgb(h: int32, s: int32, l: int32) -> int32:
    hh: int32 = h
    while hh < 0:
        hh = hh + 360
    while hh >= 360:
        hh = hh - 360
    ss: int32 = s
    if ss < 0:
        ss = 0
    if ss > 100:
        ss = 100
    ll: int32 = l
    if ll < 0:
        ll = 0
    if ll > 100:
        ll = 100
    L1: int32 = ll * 10                              # 0..1000
    S1: int32 = ss * 10                              # 0..1000
    two_l: int32 = 2 * L1 - 1000
    if two_l < 0:
        two_l = 0 - two_l
    c: int32 = (1000 - two_l) * S1 / 1000            # chroma, 0..1000
    hp: int32 = hh * 1000 / 60                       # hue' * 1000, 0..6000
    hmod: int32 = hp
    while hmod >= 2000:
        hmod = hmod - 2000
    xm: int32 = hmod - 1000
    if xm < 0:
        xm = 0 - xm
    x: int32 = c * (1000 - xm) / 1000
    m: int32 = L1 - c / 2
    r1: int32 = 0
    g1: int32 = 0
    b1: int32 = 0
    if hp < 1000:
        r1 = c
        g1 = x
    elif hp < 2000:
        r1 = x
        g1 = c
    elif hp < 3000:
        g1 = c
        b1 = x
    elif hp < 4000:
        g1 = x
        b1 = c
    elif hp < 5000:
        r1 = x
        b1 = c
    else:
        r1 = c
        b1 = x
    rr: int32 = (r1 + m) * 255 / 1000
    gg: int32 = (g1 + m) * 255 / 1000
    bb: int32 = (b1 + m) * 255 / 1000
    if rr < 0:
        rr = 0
    if rr > 255:
        rr = 255
    if gg < 0:
        gg = 0
    if gg > 255:
        gg = 255
    if bb < 0:
        bb = 0
    if bb > 255:
        bb = 255
    return rr * 65536 + gg * 256 + bb


# Parse an `hsl(h, s%, l%)` / `hsl(h s% l%)` (and hsla, alpha ignored) colour at
# src[at]. Returns packed 0xRRGGBB, or -1 if not an hsl() form.
def _hsl_func(at: uint64) -> int32:
    if _srcword_is(at, cast[Ptr[uint8]]("hsl")) == 0:
        return -1
    j: uint64 = at + 3
    if j < src_len and (src_ptr[j] == 97 or src_ptr[j] == 65):   # 'a'/'A'
        j = j + 1
    while j < src_len and (src_ptr[j] == 32 or src_ptr[j] == 9):
        j = j + 1
    if j >= src_len or src_ptr[j] != 40:             # '('
        return -1
    j = j + 1
    while j < src_len and (src_ptr[j] == 32 or src_ptr[j] == 9):
        j = j + 1
    # hue (integer part; a fractional/deg suffix is consumed and dropped)
    hue: int32 = 0
    hd: int32 = 0
    while j < src_len and src_ptr[j] >= 48 and src_ptr[j] <= 57:
        hue = hue * 10 + cast[int32](src_ptr[j] - 48)
        hd = hd + 1
        j = j + 1
    if hd == 0:
        return -1
    while j < src_len and ((src_ptr[j] >= 48 and src_ptr[j] <= 57) or \
                           src_ptr[j] == 46 or _is_alpha(src_ptr[j]) != 0):
        j = j + 1
    # saturation and lightness percentages (alpha, if present, is ignored)
    parts: Array[2, int32]
    pc: int32 = 0
    while pc < 2 and j < src_len and src_ptr[j] != 41:
        while j < src_len and (src_ptr[j] < 48 or src_ptr[j] > 57) and \
              src_ptr[j] != 41:
            j = j + 1
        if j >= src_len or src_ptr[j] == 41:
            break
        val: int32 = 0
        while j < src_len and src_ptr[j] >= 48 and src_ptr[j] <= 57:
            val = val * 10 + cast[int32](src_ptr[j] - 48)
            j = j + 1
        if j < src_len and src_ptr[j] == 46:         # drop the fraction
            j = j + 1
            while j < src_len and src_ptr[j] >= 48 and src_ptr[j] <= 57:
                j = j + 1
        parts[pc] = val
        pc = pc + 1
    if pc < 2:
        return -1
    # optional 4th component: hsla() alpha (0..1 fraction or NN%), before ')'.
    while j < src_len and (src_ptr[j] == 32 or src_ptr[j] == 9 or \
                           src_ptr[j] == 44 or src_ptr[j] == 47):     # ',' '/'
        j = j + 1
    if j < src_len and ((src_ptr[j] >= 48 and src_ptr[j] <= 57) or src_ptr[j] == 46):
        g_cv_alpha = _parse_alpha_frac(j)
    return _hsl_to_rgb(hue, parts[0], parts[1])


# Parse a colour VALUE starting at src[at]. Returns 0xRRGGBB or -1.
def _color_value(at: uint64) -> int32:
    g_cv_alpha = 255                                 # opaque unless a form sets it
    if at >= src_len:
        return -1
    if src_ptr[at] == 114 or src_ptr[at] == 82:      # 'r'/'R' -> maybe rgb(
        rv: int32 = _rgb_func(at)
        if rv >= 0:
            return rv
    if src_ptr[at] == 104 or src_ptr[at] == 72:      # 'h'/'H' -> maybe hsl(
        hv: int32 = _hsl_func(at)
        if hv >= 0:
            return hv
    if src_ptr[at] == 35:                            # '#rgb'/#rgba/#rrggbb/#rrggbbaa
        # count hex digits
        p: uint64 = at + 1
        nd: int32 = 0
        while p < src_len and _hx_hexval(src_ptr[p]) >= 0:
            nd = nd + 1
            p = p + 1
        if nd >= 6:
            r: int32 = _hx_hexval(src_ptr[at + 1]) * 16 + _hx_hexval(src_ptr[at + 2])
            g: int32 = _hx_hexval(src_ptr[at + 3]) * 16 + _hx_hexval(src_ptr[at + 4])
            b: int32 = _hx_hexval(src_ptr[at + 5]) * 16 + _hx_hexval(src_ptr[at + 6])
            if nd >= 8:                              # #rrggbbaa -> capture alpha
                g_cv_alpha = _hx_hexval(src_ptr[at + 7]) * 16 + \
                             _hx_hexval(src_ptr[at + 8])
            return (r * 65536) + (g * 256) + b
        if nd >= 3:
            r3: int32 = _hx_hexval(src_ptr[at + 1])
            g3: int32 = _hx_hexval(src_ptr[at + 2])
            b3: int32 = _hx_hexval(src_ptr[at + 3])
            return ((r3 * 16 + r3) * 65536) + ((g3 * 16 + g3) * 256) + \
                   (b3 * 16 + b3)
        return -1
    return _named_color(at)


# Find a text-colour value in the tag body [ts,te). Looks for a `color`
# keyword at a word boundary (so `bgcolor` is NOT matched) followed by ':'
# (style syntax) or '=' (attribute syntax), then parses the value.
def _tag_color(ts: uint64, te: uint64) -> int32:
    i: uint64 = ts
    while i + 5 <= te:
        # word boundary: previous char must not be a letter (rejects bgcolor)
        prev_alpha: int32 = 0
        if i > ts:
            pc: uint8 = _hx_lower(src_ptr[i - 1])
            if (pc >= 97 and pc <= 122) or pc == 45:   # letter or '-'
                prev_alpha = 1
        if prev_alpha == 0 and _srcword_is(i, cast[Ptr[uint8]]("color")) != 0:
            j: uint64 = i + 5
            while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
                j = j + 1
            if j < te and (src_ptr[j] == 58 or src_ptr[j] == 61):   # ':' '='
                j = j + 1
                while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9 or \
                                  src_ptr[j] == 34 or src_ptr[j] == 39):
                    j = j + 1
                cv: int32 = _color_value(j)
                if cv >= 0:
                    return cv
        i = i + 1
    return -1


# Skip whitespace + a ':'/'=' separator + opening quote, then parse a colour
# value starting at src[j]. Returns 0xRRGGBB or -1.
def _prop_value_at(j: uint64, te: uint64) -> int32:
    while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
        j = j + 1
    if j < te and (src_ptr[j] == 58 or src_ptr[j] == 61):        # ':' '='
        j = j + 1
    else:
        return -1
    while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9 or \
                      src_ptr[j] == 34 or src_ptr[j] == 39):
        j = j + 1
    return _color_value(j)


# Find a BACKGROUND colour in the tag body [ts,te): the `bgcolor` attribute
# or a `background-color:` style declaration. A word boundary before the
# keyword keeps `color`/other props from matching. Returns 0xRRGGBB or -1.
def _tag_bgcolor(ts: uint64, te: uint64) -> int32:
    i: uint64 = ts
    while i < te:
        prev_alpha: int32 = 0
        if i > ts:
            pc: uint8 = _hx_lower(src_ptr[i - 1])
            if (pc >= 97 and pc <= 122) or pc == 45:             # letter / '-'
                prev_alpha = 1
        if prev_alpha == 0:
            if _srcword_is(i, cast[Ptr[uint8]]("background-color")) != 0:
                v: int32 = _prop_value_at(i + 16, te)
                if v >= 0:
                    return v
            # `background:` shorthand (first token a colour) -- checked AFTER
            # background-color so the longer property wins its own value.
            if _srcword_is(i, cast[Ptr[uint8]]("background")) != 0:
                vb: int32 = _prop_value_at(i + 10, te)
                if vb >= 0:
                    return vb
            if _srcword_is(i, cast[Ptr[uint8]]("bgcolor")) != 0:
                v2: int32 = _prop_value_at(i + 7, te)
                if v2 >= 0:
                    return v2
        i = i + 1
    return -1



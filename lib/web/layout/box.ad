# lib/web/layout/box.ad — part of the modular web engine (extracted from htmlengine.ad).
# LAYOUT MODEL — the flat styled-segment pools (he_seg_*) + word/line/box emit helpers. The layout state-owner.
#
# Behavior-preserving split (single-compilation-unit; byte-identical).

from lib.htmlengine import _content_right, _left_margin

# ====================================================================
# LAYOUT MODEL — the parsed page becomes a flat list of styled SEGMENTS.
# A segment is a run of same-styled text on one visual ROW at a pixel X.
# ====================================================================
MAX_SEGS:     uint64 = 6000
SEG_TEXT_CAP: uint64 = 131072
MAX_ROWS:     uint64 = 12000

seg_text_buf: Array[131072, uint8]
seg_text_len: uint64 = 0
seg_x:    Array[6000, int32]
seg_line: Array[6000, int32]
seg_off:  Array[6000, int32]
seg_len:  Array[6000, int32]
seg_color: Array[6000, uint8]    # palette index (role colour)
seg_rgb:  Array[6000, int32]     # explicit 0xRRGGBB, or -1 to use the palette
seg_bg:   Array[6000, int32]     # background 0xRRGGBB behind the text, or -1
seg_bold:  Array[6000, uint8]
seg_uline: Array[6000, uint8]
seg_link:  Array[6000, int32]    # link id or -1
# seg_face — pixel-render font FACE hint for the graphical (htmlpaint) backend.
# The legacy monospace-grid dump ignores it; the pixel engine maps it onto the
# available BDF faces/scales:
#   0 = body proportional sans
#   1 = monospace  (<pre>/<code>)
#   2..7 = heading h1..h6  (integer-scaled + bold sans)
seg_face:  Array[6000, uint8]
# seg_gridx — 1 = this segment is GRID-POSITIONED: the pixel renderer must
# honour its absolute seg_x column (tables, <pre>, box art) instead of the
# proportional inline reflow used for prose. 0 = flow proportionally.
seg_gridx: Array[6000, uint8]
# seg_pxsize — CSS font-size in PIXELS for this segment, or 0 = "use the face
# default". Consumed by the scalable (TrueType) pixel renderer so that
# font-size:14px/18px prose renders at its true continuous size. The legacy
# monospace-grid dump ignores it.
seg_pxsize: Array[6000, int32]
# seg_lineh — CSS line-height for this segment resolved to PIXELS (the line-box
# pitch), or 0 = "use the face default rhythm". Consumed by the pixel renderer
# (lib/htmlpage) to loosen inter-line spacing on a block that sets line-height;
# 0 keeps the default vertical rhythm so unstyled pages are byte-for-byte
# unchanged. The legacy monospace-grid dump ignores it.
seg_lineh: Array[6000, int32]
# seg_img — decoded-image slot (lib/htmlimg) for an <img> segment, or -1 for a
# normal text segment. When >= 0 the pixel renderer BLITS the image into the box
# (seg_imgw x seg_imgh px at seg_x/row-top) instead of drawing text; a value of
# -2 means the src was present but undecodable → draw a broken-image placeholder.
seg_img:   Array[6000, int32]
seg_imgw:  Array[6000, int32]     # image box width  (px)
seg_imgh:  Array[6000, int32]     # image box height (px)
# seg_boxart — 1 for the ASCII box-art border glyphs ('+'/'-'/'|') emitted by
# _emit_box_run/_emit_box_bar, 0 for real content. The monospace-grid text dump
# still paints these glyphs (its gates assert on them), but the PIXEL renderer
# SKIPS them and draws a true 1px border rectangle from the border-box registry
# below instead — so a CSS border looks like a drawn line, not typed characters.
seg_boxart: Array[6000, uint8]
# seg_marker — 1 for the UNORDERED-list ('<ul>') item bullet segment. The
# monospace-grid dump paints the '-' placeholder char it carries, but the PIXEL
# renderer draws a real round bullet DISC in the gutter instead (like a browser's
# default list-style-type:disc), so a list reads as a list and not a run of
# hyphens glued to the text. 0 = normal content.
seg_marker: Array[6000, uint8]
# seg_indjump — 1 for the FIRST text segment of a list item. The pixel renderer
# flows same-row prose contiguously from the pen, which would otherwise collapse
# the marker's hanging indent (packing the item text right after the bullet). A
# set flag tells the renderer to JUMP the pen forward to this segment's seg_x
# (indent_x), preserving the gutter between the marker and the item text.
seg_indjump: Array[6000, uint8]
# seg_yoff — signed VERTICAL pixel offset applied to this segment's baseline by
# the pixel renderer: negative RAISES the run (<sup>), positive LOWERS it
# (<sub>). 0 = on the row baseline (the default for all normal text, so
# unstyled pages are byte-for-byte unchanged).
seg_yoff: Array[6000, int32]
# seg_strike — 1 = draw a horizontal LINE-THROUGH the run (<s>/<del>/<strike>),
# 0 = none. The pixel renderer strokes a 1px rule across the seg's x-height.
seg_strike: Array[6000, uint8]
n_segs:   uint64 = 0
# Pending: mark the next opened segment as a list-item's first text seg so the
# pixel renderer honours its left indent. Set by the <li> handler after the
# marker is emitted; consumed (and cleared) by _seg_ensure.
_pending_indjump: int32 = 0

# ---- pixel border-box registry --------------------------------------
# Each bordered block/float box records its geometry here on close so the PIXEL
# renderer (lib/htmlpage) can stroke a real 1px rectangle with htmlpaint_fill_
# rect instead of leaning on the box-art glyphs. top_row carries the top rule,
# bot_row the bottom rule; lx/rx are the left/right bar pixel columns (char
# grid); rgb is the border colour (0xRRGGBB). Reset each layout with n_segs.
BBOX_MAX:  int32 = 256
bbox_lx:   Array[256, int32]
bbox_rx:   Array[256, int32]
bbox_top:  Array[256, int32]
bbox_bot:  Array[256, int32]
bbox_rgb:  Array[256, int32]
n_bboxes:  int32 = 0

# ---- element background-fill registry -------------------------------
# A block-level box with a `background-color` (or `background`) records its FULL
# box rectangle here on close, so the renderer paints the whole element box —
# header bars, footers, section/card panels, coloured nav strips — not just the
# strip behind each text run (seg_bg). This is the single biggest "looks like a
# real site" gap: virtually every modern page paints a coloured header/footer/
# card. lx/rx are the box's left/right pixel columns; top_row/bot_row bound the
# rows the fill covers [top_row, bot_row); rgb is 0xRRGGBB. Painted BEFORE the
# text segments so glyphs land on top. Reset each layout with n_segs.
BFILL_MAX:  int32 = 256
bfill_lx:   Array[256, int32]
bfill_rx:   Array[256, int32]
bfill_top:  Array[256, int32]
bfill_bot:  Array[256, int32]
bfill_rgb:  Array[256, int32]
bfill_z:    Array[256, int32]   # stacking order (z-index); 0 = default flow
n_bfills:   int32 = 0

# ---- <img> src registry (for the host driver to enumerate + decode) ----
# Every <img src="..."> seen during layout records its src string here so the
# file-reading host can slurp+decode each PNG and register it in lib/htmlimg
# BEFORE a second layout pass resolves natural sizes. Deduplicated by string.
EIMG_MAX:       uint64 = 64
EIMG_NAME_CAP:  uint64 = 8192
eimg_noff: Array[64, uint64]
eimg_nlen: Array[64, uint64]
n_eimg:    uint64 = 0
eimg_name_buf: Array[8192, uint8]
eimg_name_used: uint64 = 0

# broken-image placeholder box (px) when src is absent/undecodable.
IMG_BROKEN_W: int32 = 40
IMG_BROKEN_H: int32 = 32

row_rule: Array[12000, uint8]    # 0 none, 1 heading rule on this row
total_rows: uint64 = 0
top_line:   uint64 = 0

# LINKS — href targets + the spans that point to them.
MAX_LINKS:    uint64 = 1024
LINK_HREF_CAP: uint64 = 32768
link_off: Array[1024, int32]
link_len: Array[1024, int32]
link_href_buf: Array[32768, uint8]
link_href_len: uint64 = 0
n_links: uint64 = 0

# parse-time "pen" + style state
cur_row:  uint64 = 0
pen_x:    int32 = 8
indent_x: int32 = 8
row_dirty: int32 = 0
need_space: int32 = 0
seg_open:  int32 = 0
seg_curlen: uint64 = 0
g_color: int32 = 0
# Page-level background (gap #3): a <body>/<html> `background(-color)` fills the
# WHOLE viewport, not just element boxes. -1 = default white. The pixel renderer
# clears the canvas to this colour instead of white.
g_page_bg: int32 = -1
# Effective display of the element currently being dispatched (0 unset / 1 none
# / 2 flex / 3 block / 4 inline-block / 5 inline), and whether it should be laid
# out as a block box (the generic display:block / flex-item blockification path).
g_eff_disp: int32 = 0
g_treat_as_block: int32 = 0
# flex-direction of the container currently being opened (0 row / 1 column),
# read by _flex_container_open to stack (column) vs. columnise (row).
g_flex_dir: int32 = 0
# justify-content of the container currently being opened (0 unset/default,
# 1 flex-start, 2 center, 3 flex-end, 4 space-between, 5 space-around). Read by
# _flex_container_open: when SET it switches from the equal-column approximation
# to a natural-content-width row with real free-space distribution.
g_flex_just: int32 = 0
# column-gap (px) of the flex container currently being opened, or -1 to use the
# FLEX_GAP default. Read by _flex_container_open as the inter-column gutter.
g_flex_gap: int32 = -1
# row-gap (px) of the flex container currently being opened, or -1 to use no
# inter-line gap. Read by _flex_container_open: a wrapping flex row inserts this
# many px (rounded to whole LINE_H rows) of vertical space between wrapped lines.
g_flex_rowgap: int32 = -1
# flex-wrap of the container currently being opened (0 nowrap / 1 wrap). Read by
# _flex_container_open: when set, overflowing items WRAP onto additional flex
# lines instead of being crammed into one equal-column row.
g_flex_wrap: int32 = 0
# align-items (cross-axis) of the container currently being opened: 0 unset /
# 1 flex-start (== the default, top-aligned) / 2 center / 3 flex-end / 4 stretch.
# Read by _flex_container_open; a value >= 2 arms a deferred cross-axis fixup that
# shifts each already-emitted flex item's segments/fills within its line's height.
g_flex_align: int32 = 0
# ---- CSS grid (display:grid) ------------------------------------------------
# 1 when the container currently being opened is a `display:grid` box. Read by
# _flex_container_open, which lays the container's direct children out in the
# grid TRACK model (a fixed count of columns whose widths come from grid-
# template-columns; items auto-place left-to-right and wrap to the next row every
# ntrack items) instead of a flex row. Grid REUSES the flex frame machinery — it
# is a constrained flex-wrap with fixed per-track widths. Zero-cost when 0.
g_flex_grid: int32 = 0
# Nesting depth of OPEN flex items (a direct block child of a flex container that
# was columnised). Bumped when a flex-item box opens, dropped when it closes, so
# _emit_word can tell it is laying text inside a flex track. A flex item's CSS
# automatic minimum size is min-content: its column must never be shrunk below
# the widest unbreakable word it contains, so a word wider than the (monospace-
# estimated) track must NOT be hard char-broken — it stays intact and overflows
# the track (min-content floor) instead of splitting mid-word ("Nimbus" -> "Nim"
# "bus"). Zero-cost off the flex path: stays 0, so the guard short-circuits.
g_flex_item_depth: int32 = 0
# Nesting depth of open NATURAL-path flex items (justify-content nav/chip rows
# whose tracks are sized to each child's CONTENT, i.e. max-content). Such a track
# is content-sized, so its text is not meant to wrap at all — the child was
# allotted its whole run. The track width is a CELL_W monospace ESTIMATE, so a
# proportional two-word link ("Log in") whose real width exceeds the estimate
# would otherwise wrap between its words. Treat a natural-path item like
# white-space:nowrap so the link/label stays on one line (overflowing into the
# row's free space rather than wrapping). Only the natural path sets this; the
# equal-column fallback (content-heavy flex: article beside sidebar) keeps normal
# word wrap. Zero-cost off the flex path: stays 0.
g_flex_nowrap_depth: int32 = 0
# grid-template-columns of the container being opened, parsed to a compact per-
# track encoding: g_grid_n tracks, each g_grid_enc[c] >= 0 => a FIXED track of
# that many px; < 0 => an `fr` track of weight (-value). Resolved to pixel widths
# at container open (fr shares the free space). Filled at dispatch from the
# cascade winner (m_gtc[]) then the inline style (d_gtc[]). 0 tracks => no grid.
GRID_MAXTRACK: int32 = 8       # max grid columns (tracks) we resolve
GRID_MAXITEM:  int32 = 64      # max auto-placed grid items per container
g_grid_n:   int32 = 0
g_grid_enc: Array[8, int32]
# grid-template-rows of the container being opened, parsed to the SAME compact
# encoding as g_grid_enc but interpreted for ROWS: g_grid_renc[r] >= 0 => a FIXED
# row of that many px (fr rows are ignored — a grid row with no fixed height stays
# content-sized). Gives explicit, non-content row heights (the dashboard case).
g_grid_rn:   int32 = 0
g_grid_renc: Array[8, int32]
# Per-ITEM grid line placement, carried from the child's cascade/inline style to
# the grid item-open path: g_grid_cspan is how many TRACKS the item occupies
# (`grid-column: span N`, or `A / B` => B-A); g_grid_cstart is an explicit 1-based
# start line (`grid-column: A` / `A / B`), 0 = auto-flow into the next free track.
g_grid_cspan:  int32 = 1
g_grid_cstart: int32 = 0
# Stack of el-stack depths at which a GENERIC block box was opened (display:
# block/inline-block/flex, or a flex-item span). A close tag carries no style=""
# attribute, so its display cannot be recomputed from it; instead the matching
# close is recognised by comparing the current el-stack depth against this
# stack's top. This keeps open/close routing symmetric for inline-style blocks.
GBLK_MAX:   int32 = 64
gblk_sp:    int32 = 0
gblk_stack: Array[64, int32]
g_bold:  int32 = 0
g_uline: int32 = 0
g_link:  int32 = -1
# An explicit author colour specified ON the current anchor (a matched `a{}` /
# `.nav a{}` rule or an inline style=""), or -1 when the anchor sets no colour of
# its own. A link keeps its default blue role colour UNLESS this is >= 0, so a
# styled `<a style=color:…>` / `.nav a{color:…}` wins while an inherited ancestor
# colour (e.g. body{color:#333}) still leaves plain links blue.
g_link_rgb: int32 = -1
g_bold_n: int32 = 0          # nested <b>/<strong> depth
g_mono_n: int32 = 0          # nested inline <code>/<kbd>/<samp>/<var> depth
g_heading: int32 = 0        # 0 none, else 1..6
g_strike_n: int32 = 0        # nested <s>/<del>/<strike> depth (line-through)
# <sub>/<sup> vertical shift: g_yoff is the live signed baseline offset (px)
# folded into every opened segment. sub_depth lowers text, sup_depth raises it;
# g_yoff = sub_depth*SUB_DROP - sup_depth*SUP_RISE so nesting composes.
g_yoff: int32 = 0
sub_depth: int32 = 0
sup_depth: int32 = 0
SUB_DROP: int32 = 4          # px a <sub> baseline drops
SUP_RISE: int32 = 6          # px a <sup> baseline rises
list_depth: int32 = 0
bq_depth: int32 = 0         # <blockquote> nesting depth (left indent)
BQ_INDENT: int32 = 24       # px of left indent per blockquote level
dd_depth: int32 = 0         # <dd> nesting depth (left indent under a <dl>)
DD_INDENT: int32 = 40       # px of left indent per <dd> level (browser default)
# Implied / optional end-tag tracking (WHATWG "generate implied end tags").
# p_open is set while a <p> whose </p> may be omitted is on the flow; the tag
# scanner synthesises its close when the next block-level start tag (or another
# <p>) opens. dl_item tracks the currently-open <dt> (1) / <dd> (2) so a sibling
# <dt>/<dd> — or the enclosing </dl> — implicitly closes the previous item.
p_open: int32 = 0           # a <p> is open with its </p> not yet seen
dl_item: int32 = 0          # 0 none, 1 <dt> open, 2 <dd> open
MARK_BG: int32 = 0xfff275   # <mark> highlight background (yellow)
pre_mode: int32 = 0

# LIST layout — <ul>/<ol>/<li> with markers, ordered numbering + nesting.
# One entry per open list level (list_depth): list_type is 0 for <ul>
# (bullet marker) or 1 for <ol> (running number), list_count is the <ol>
# item counter (the NEXT item's number). LIST_STEP is the per-level left
# indent (in px); it is exactly wide enough to be the marker gutter so item
# markers hang in the parent level's left margin and wrapped continuation
# lines align under the item TEXT (a proper hanging indent).
MAX_LIST_DEPTH: int32 = 16
LIST_STEP:  int32 = 32       # px of left indent per list level (= 4 cells)
list_type:  Array[16, int32]
list_count: Array[16, int32]
# 1 for a list level whose <ul>/<ol> armed a horizontal flex row (display:flex)
# over its <li> columns, so the matching </ul>/</ol> pops the flex frame.
list_flex:  Array[16, int32]
# 1 for a list level whose flex <ul>/<ol> opened its OWN container box (so its
# background/border paints as a bar over the whole flex row); the close pops it.
list_box:   Array[16, int32]
# 1 for a list level that SUPPRESSED its LIST_STEP indent (a flex list resets its
# left padding, so the navbar sits flush); the close restores list_indent_drop.
list_supp:  Array[16, int32]
# 1 for a list level whose <ul>/<ol> set list-style[-type]:none — its <li>
# children draw no bullet/number marker (the ubiquitous navbar/menu reset).
list_nomarker: Array[16, int32]
# 1 for a list level whose CURRENT <li> opened an _open_style() scope (its own
# class/inline cascade — colour, text-decoration, font-weight, …). Real HTML
# routinely omits </li> (`<li>a<li>b<li>c`), so the scope is balanced by an
# IMPLICIT </li> synthesised at the next <li> / </ul> / </ol> at this level (or
# by an explicit </li>). This keeps the colour/deco style stack balanced even
# when </li> is absent — see _li_close_lvl and the <li> handler.
li_styled: Array[16, int32]
# px of LIST_STEP indent currently suppressed by open flex lists (subtracted in
# _recompute_indent). Accumulator so nested flex lists compose correctly.
list_indent_drop: int32 = 0

# BLOCK left-indent from CSS margin-left/padding-left (inline style OR a
# stylesheet/class rule). A stack of px deltas parallel to open <p>/<div>
# blocks; blk_indent_sum is the live total folded into indent_x by
# _recompute_indent(). This makes margin/padding actually shift a block's
# content column (not just decorate it).
blk_indent_stack: Array[64, int32]
blk_indent_sp:  int32 = 0
blk_indent_sum: int32 = 0

# BLOCK right edge (px) — the live wrap boundary a block flows against, folded
# in by _flow_right(). margin-right/padding-right shrink it from the parent's
# edge and `width` pins it to indent_x+width; a border steals one more cell.
# Parallel stack to the left indent so nested blocks restore the parent edge.
blk_right_stack: Array[64, int32]
blk_right_sp:   int32 = 0
blk_right_cur:  int32 = 0        # current right edge; reset to _content_right()

# BOX unit mapping (char-grid model): 1em == EM_PX px == 2 character cells wide
# (CELL_W=8) and one text line tall (LINE_H=16); `%` is taken of the body
# content width (bw - 2*CONTENT_X). Vertical margin/padding px are quantised to
# blank text lines at LINE_H granularity.
EM_PX: int32 = 16

# UA default background for <pre>/<code> so code stands out from body text
# (a light neutral panel behind the monospace run).
CODE_BG: int32 = 0xeef0f3

# Per-open-block state carried from _block_box_open() to _block_box_close():
# the bottom vertical gap (blank lines), whether a border is drawn, and the
# border box geometry (left/right pixel columns + the first content row) so the
# closing side/bottom glyphs land in the right place.
box_botg_stack: Array[64, int32]
box_bord_stack: Array[64, int32]
box_lx_stack:   Array[64, int32]
box_rx_stack:   Array[64, int32]
box_srow_stack: Array[64, int32]
box_bg_stack:   Array[64, int32]      # element background-color (0xRRGGBB) or -1
box_sp: int32 = 0

# ---- CSS float --------------------------------------------------------------
# A `float: left|right` block is laid out as a NARROW box pinned to the left or
# right edge; the following in-flow content then RE-FLOWS beside it (the pixel
# renderer sorts segs by row-then-x, so the float on one side and the body text
# on the other share the same rows). The single-pass source walker makes this
# work without a second layout pass: the float's own content is emitted first
# (in source order), then on the float's close we REWIND cur_row to the float's
# top and set an exclusion so subsequent lines wrap in the remaining width until
# they clear the float's bottom. TWO exclusions can be active AT ONCE — one LEFT
# and one RIGHT — so a `float:left` figure and a `float:right` pullquote/aside
# pair sandwich the body text (the common two-float layout). A SECOND float on an
# already-occupied side still falls back to a normal in-flow block.
#
# Zero-cost for float-free pages: both channels stay inactive and float_left_pad /
# float_redge stay 0, so _recompute_indent()/_flow_right() are byte-identical.
FLOAT_GAP:      int32 = 8        # px gutter between a float and the body text
FLOAT_DEF_W:    int32 = 240      # default float width (px) when none is given
# LEFT exclusion channel.
floatL_active:  int32 = 0        # a left float exclusion is in effect
floatL_bottom:  int32 = 0        # first row at/after which the left exclusion ends
float_left_pad: int32 = 0        # left float: px added to indent_x while active
# RIGHT exclusion channel (independent of the left one).
floatR_active:  int32 = 0        # a right float exclusion is in effect
floatR_bottom:  int32 = 0        # first row at/after which the right exclusion ends
float_redge:    int32 = 0        # right float: right wrap boundary while active
# Per-open-block: which side THIS block floats (0 = in-flow), its top row (to
# rewind to on close), and its exclusion geometry (redge for right / pad for
# left). Parallel to the box_*_stack.
box_float_stack:  Array[64, int32]
box_ftop_stack:   Array[64, int32]
box_fgeom_stack:  Array[64, int32]

# ---- CSS flexbox (display:flex, row direction) ------------------------------
# A `display:flex` block lays its DIRECT-CHILD block boxes out HORIZONTALLY:
# each child becomes a column whose width is an equal share of the container's
# content width (minus inter-column gaps). This is the single most common
# real-page layout that the old block-stacking model got wrong — a Wikipedia
# article body beside its infobox, a card row, a two-column landing hero.
#
# Implementation reuses the same single-pass "rewind" trick the floats use: the
# container records its top row; each child column is opened as a normal block
# box pinned to its column x (left inset = column offset, width = column width),
# its content flows down, and on the child's close cur_row is REWOUND to the
# container top so the next sibling column starts level with it. The container's
# close advances cur_row past the TALLEST column. A pre-scan counts the direct
# block children so the column width is known before the first child is placed.
#
# Zero-cost for flex-free pages: flex_sp stays 0, so every guard short-circuits
# and the block path is byte-identical to before.
FLEX_MAX:      int32 = 8          # max flex frames / columns we handle
FLEX_GAP:      int32 = 8          # px gutter between flex columns
flex_sp:       int32 = 0
flex_top_row:  Array[8, int32]    # container top row (children rewind here)
flex_max_bot:  Array[8, int32]    # deepest child bottom row seen so far
flex_left:     Array[8, int32]    # container content-left px
flex_colw:     Array[8, int32]    # per-column width px
flex_gap:      Array[8, int32]    # per-column advance = colw + FLEX_GAP
flex_ncol:     Array[8, int32]    # number of child columns
flex_next:     Array[8, int32]    # index of the next child column to place
flex_eldepth:  Array[8, int32]    # el-stack depth of the container element
# justify-content NATURAL-width mode: when a container has an explicit
# justify-content and its children's natural content widths fit the row, each
# child is placed at its own pre-computed x with its own natural width (real
# free-space distribution) instead of the equal-column approximation.
flex_natural:  Array[8, int32]    # 1 => use flex_child_x/_w, not equal columns
flex_child_x:  Array[64, int32]   # [frame*FLEX_MAX+col] x offset from flex_left
flex_child_w:  Array[64, int32]   # [frame*FLEX_MAX+col] natural content width px
flex_meas_w:   Array[8, int32]    # scratch: per-child measured natural widths
# flex-wrap MULTI-LINE mode: an overflowing flex row wraps its items onto extra
# lines (modern card grids / responsive navbars). Placement is ONLINE — each item
# is measured at its own open (its resolved CSS `width`, else its pre-measured
# natural content width) and, if it no longer fits on the current line, starts a
# NEW line below the tallest item of the previous one. This reuses the same
# single-pass rewind trick as single-line flex, so line heights need no 2nd pass.
flex_wrap_on:  Array[8, int32]    # 1 => this frame wraps onto multiple lines
flex_avail:    Array[8, int32]    # content width the items wrap within (px)
flex_rawgap:   Array[8, int32]    # inter-item gap px (author gap / FLEX_GAP)
flex_rowgap:   Array[8, int32]    # inter-LINE gap in ROWS (row-gap px / LINE_H)
flex_cur_x:    Array[8, int32]    # running x cursor within the line (from flex_left)
flex_line_top: Array[8, int32]    # top row of the current line
flex_line_bot: Array[8, int32]    # running bottom (first free row) of cur line
# align-items (cross-axis) CROSS-AXIS FIXUP. The engine emits each flex item's
# glyphs/fills top-aligned at the line top during its single online pass; but the
# line's cross-axis extent (its tallest item) is only known once every item on the
# line has been placed. Rather than a full second layout pass, we record — per
# item, ONLY when flex_align >= 2 (so flex-start stays byte-identical, zero writes)
# — the [seg,bfill,bbox) index ranges it emitted plus its line-top and bottom rows,
# then at the container's close SHIFT those already-emitted coordinates down by the
# per-item cross-axis offset (center/flex-end) or STRETCH its box fill/border to the
# full line height. A deferred coordinate fixup, O(items + flex segs), not a re-pass.
flex_align:    Array[8, int32]    # 0/1 flex-start / 2 center / 3 flex-end / 4 stretch
flex_it_seg0:  Array[64, int32]   # [frame*FLEX_MAX+col] n_segs at item open
flex_it_seg1:  Array[64, int32]   # [frame*FLEX_MAX+col] n_segs at item close
flex_it_bf0:   Array[64, int32]   # [frame*FLEX_MAX+col] n_bfills at item open
flex_it_bf1:   Array[64, int32]   # [frame*FLEX_MAX+col] n_bfills at item close
flex_it_bx0:   Array[64, int32]   # [frame*FLEX_MAX+col] n_bboxes at item open
flex_it_bx1:   Array[64, int32]   # [frame*FLEX_MAX+col] n_bboxes at item close
flex_it_ltop:  Array[64, int32]   # [frame*FLEX_MAX+col] line-top row the item sat at
flex_it_bot:   Array[64, int32]   # [frame*FLEX_MAX+col] item's exclusive bottom row
# CSS GRID reuse of the flex frame: a `display:grid` container places its items
# into fixed TRACK columns (widths resolved from grid-template-columns into the
# shared flex_child_x/_w arrays; fr distributes free space) and auto-wraps to the
# next row every flex_ntrack items. The current row uses flex_line_top/_bot (the
# same seam flex-wrap uses). Zero-cost: flex_grid stays 0 for non-grid frames.
flex_grid:     Array[8, int32]    # 1 => this frame is a grid (track auto-placement)
flex_ntrack:   Array[8, int32]    # number of grid columns (tracks) <= GRID_MAXTRACK
# Grid explicit-placement + explicit-row-height state (all zero for non-grid /
# auto frames). flex_gcur is the next FREE track column (0-based) the auto-flow
# cursor will place into — reused in place of a modulo of the item index so that
# multi-track spans (grid-column) advance the cursor by their width. The grid-
# template-rows fixed heights are stored per row into flex_growh (px; 0 =
# content-sized) with flex_growidx tracking which grid row is currently open.
flex_gcur:     Array[8, int32]    # next free track column for auto-placement
flex_gridrn:   Array[8, int32]    # grid-template-rows count (0 => all content-sized)
flex_growidx:  Array[8, int32]    # current grid row index (0-based)
flex_growh:    Array[64, int32]   # [frame*FLEX_MAX+row] fixed row height px (0=content)
# Per-open-block markers (parallel to box_*_stack): 1 if THIS block box is a
# flex item (a column) / a flex container (owns a frame).
box_flexitem_stack: Array[64, int32]
box_flexcont_stack: Array[64, int32]
# Per-open-block CSS-position bookkeeping (parallel to box_*_stack): the box's
# position mode (0/1/2), the segment index at its open, the row to rewind to on
# close (absolute = out of flow), and whether this box pushed a posctx frame.
box_pos_stack:    Array[64, int32]
box_posrun_stack: Array[64, int32]   # index into the positioned-run table (-1)
box_pretrow_stack: Array[64, int32]  # row to rewind to on close (absolute)
box_pushedctx_stack: Array[64, int32]
# ROUND-3 CSS vertical sizing (px, -1 unset) captured at box open, applied on
# close: height pins the box's row span, min-height floors it (pad blank rows),
# max-height clamps it (pull the flow cursor up, overflow not reflowed).
box_ht_stack:   Array[64, int32]
box_minh_stack: Array[64, int32]
box_maxh_stack: Array[64, int32]

# ---- CSS inline-block (inline-level box in the line grid) --------------------
# `display:inline-block` chips/badges/buttons/nav-pills flow INLINE on a text
# line (advancing pen_x) and WRAP to the next line when they overflow — unlike a
# block, they do NOT each claim their own full-width row. Each open chip is a
# fixed-width box (its collapsed inner-text width + 2*INLB_PADX) that paints a
# narrow background FILL over its box and insets its text by the left padding;
# its close snaps pen_x to the box's right edge + INLB_GAP so the next chip
# flows after it. Zero-cost for chip-free pages: inlb_sp stays 0.
INLB_MAX:   int32 = 64
INLB_PADX:  int32 = 6         # px inner horizontal padding each side of a chip
INLB_GAP:   int32 = 6         # px gutter after a chip before the next inline box
inlb_sp:    int32 = 0
inlb_startx:  Array[64, int32]   # left px of the chip box (before padding)
inlb_boxw:    Array[64, int32]   # total chip box width px (text + 2*INLB_PADX)
inlb_row:     Array[64, int32]   # the row the chip sits on
inlb_eldepth: Array[64, int32]   # el-stack depth of the chip element (close match)
inlb_yoff:    Array[64, int32]   # baseline shift (px) applied to centre a TALL chip
inlb_vashift: Array[64, int32]   # rows the chip text was dropped by vertical-align
# Set in the tag-dispatch preamble when the element being opened/closed is an
# inline-block box handled by the inline-flow path (routes it AROUND the generic
# block-box blockification).
g_inlb: int32 = 0
# When an inline-block chip grows TALLER than one text line (vertical padding or
# min-height), this holds the first free row BELOW the tallest such chip on the
# current line (0 = no tall chip). The next line break (_bump_row) snaps cur_row
# down to it so following content clears the box, then clears it. Zero-cost for
# one-row chips: it stays 0 and every guard short-circuits.
g_inlb_floor: int32 = 0

# ROUND-3 CSS text-indent: px to inset the FIRST line of the block that armed it.
# Set on _block_box_open from the resolved cascade winner; consumed once by the
# first word emitted on the block's opening line, then cleared. 0 = none.
g_tindent_pending: int32 = 0

# TABLE layout — two-pass column model. Pass 1 (_measure_table) walks the
# table source and records the widest cell (in characters) per column; pass 2
# (_compute_cols) turns those into pixel column x-positions. During the normal
# linear parse each <tr> is one visual row and each <td>/<th> places its text
# at its column's x, clamped to the column's right edge (cell_right) so a wide
# cell wraps inside its column instead of bleeding across the table.
MAX_COLS:    int32 = 32
CELL_PAD:    int32 = 2       # inter-column gap, in character cells
# CELL_PADX: per-side content inset (px) between a cell's border and its text,
# so header/body text never touches or overlaps the column/table border the way
# an inset-less pen (text drawn straight from col_x, i.e. the border) does. The
# UA default is ~1px border-spacing + a couple px cell padding; 6px reads right
# at CELL_W=8. Applied to BOTH edges (left inset on open, right clamp on close).
CELL_PADX:   int32 = 6
col_x:    Array[33, int32]   # pixel x of each column (index n_cols = right edge)
col_chars: Array[32, int32]  # widest cell per column, in characters
n_cols:      int32 = 0
table_active: int32 = 0
cell_active:  int32 = 0      # inside a <td>/<th> (drives cell_right + styling)
cell_is_th:   int32 = 0      # current cell is a <th> (bold)
cell_right:   int32 = 0      # right edge (px) of the current cell's column
cur_col:      int32 = 0
# A <table style="float:right|left"> (the Wikipedia infobox) is laid out inside
# the SAME float exclusion block containers use: the table's grid is measured to
# its natural width, a float box of that width is pinned to the edge, and the
# body text re-flows beside it. 1 while the current table floated (its close
# must go through _float_box_close instead of the in-flow para break).
table_floated: int32 = 0

# NESTED-TABLE context stack. A <table> inside a <td> is laid out as its own
# table box within the parent cell: on open the parent's column model + cell
# scope is pushed here (so _measure_table/_compute_cols may overwrite the shared
# col_x/col_chars/n_cols globals) and restored on the inner </table>, letting
# tables nest to arbitrary depth. Each entry also records THIS table's border
# geometry (left x, top row) so its border strokes as a real rectangle via the
# same bbox registry, independent of the outer table's border.
TBL_MAX:  int32 = 8
tbl_sp:   int32 = 0
tbl_ncols_st:     Array[8, int32]
tbl_curcol_st:    Array[8, int32]
tbl_cellact_st:   Array[8, int32]
tbl_cellright_st: Array[8, int32]
tbl_cellisth_st:  Array[8, int32]
tbl_indentx_st:   Array[8, int32]
tbl_floated_st:   Array[8, int32]
tbl_colx_st:      Array[264, int32]   # 8 * 33 saved col_x snapshots
tbl_srow_st:      Array[8, int32]     # this table's top-rule row
tbl_lx_st:        Array[8, int32]     # this table's left x (border left edge)
tbl_border_st:    Array[8, int32]     # 1 if this table strokes an in-flow border
tbl_rgb_st:       Array[8, int32]     # this table's border colour (0xRRGGBB)

skip_active: int32 = 0
skip_name: Array[16, uint8]
skip_nlen: uint64 = 0

# CSS colour state — a stack of explicit colours pushed by colour-bearing
# elements (span/font/p/div/h1-h3). g_rgb is the effective colour (topmost
# non-sentinel entry), or -1 when no explicit colour applies.
COLOR_STACK_CAP: int32 = 64
color_stack: Array[64, int32]
color_sp: int32 = 0
g_rgb: int32 = -1

# CSS background-colour state — a parallel stack to the text-colour stack.
# Pushed by bgcolor / background-color-bearing elements (body-less: p/div/
# span/font/h*/blockquote/table/tr/td/th). g_bg is the effective (topmost
# non-sentinel) background, or -1 when none applies.
bg_stack: Array[64, int32]
bg_sp: int32 = 0
g_bg: int32 = -1

# inline word accumulator
WORD_CAP: uint64 = 2048
word_buf: Array[2048, uint8]
word_len: uint64 = 0
# Decoded-entity output: up to 4 UTF-8 bytes for one code point.
g_ent_buf: Array[4, uint8]
g_ent_len: int32 = 0


def _palette(idx: uint8) -> Ptr[uint8]:
    if idx == 1:
        return cast[Ptr[uint8]]("#1a4fd0")          # link blue
    if idx == 2:
        return cast[Ptr[uint8]]("#14306e")          # heading dark blue
    if idx == 3:
        return cast[Ptr[uint8]]("#0a6b5a")          # pre/code teal
    return cast[Ptr[uint8]]("#101010")              # body text


# Palette index -> packed 0xRRGGBB (mirrors _palette; used to resolve a
# segment to a concrete colour for rendering / dumping).
def _palette_rgb(idx: uint8) -> int32:
    if idx == 1:
        return 0x1a4fd0
    if idx == 2:
        return 0x14306e
    if idx == 3:
        return 0x0a6b5a
    return 0x101010


# ---- CSS colour stack ----------------------------------------------
def _color_effective() -> int32:
    i: int32 = color_sp - 1
    while i >= 0:
        if color_stack[i] >= 0:
            return color_stack[i]
        i = i - 1
    return -1


def _color_push(rgb: int32):
    if color_sp < COLOR_STACK_CAP:
        color_stack[color_sp] = rgb
        color_sp = color_sp + 1
    g_rgb = _color_effective()


def _color_pop():
    if color_sp > 0:
        color_sp = color_sp - 1
    g_rgb = _color_effective()


# ---- CSS background-colour stack (mirrors the text-colour stack) -----
def _bg_effective() -> int32:
    i: int32 = bg_sp - 1
    while i >= 0:
        if bg_stack[i] >= 0:
            return bg_stack[i]
        i = i - 1
    return -1


def _bg_push(rgb: int32):
    if bg_sp < COLOR_STACK_CAP:
        bg_stack[bg_sp] = rgb
        bg_sp = bg_sp + 1
    g_bg = _bg_effective()


def _bg_pop():
    if bg_sp > 0:
        bg_sp = bg_sp - 1
    g_bg = _bg_effective()


def _base_color() -> int32:
    if g_heading != 0:
        return 2
    if pre_mode != 0:
        return 3
    return 0


def _recompute_style():
    if g_link >= 0:
        g_color = 1
        # Links default to underlined, but text-decoration:none (g_css_uline==2)
        # on the link (or an ancestor) strips it — the common nav/button pattern.
        if g_css_uline == 2:
            g_uline = 0
        else:
            g_uline = 1
    else:
        g_color = _base_color()
        # Non-link text underlines only when CSS text-decoration:underline set it.
        if g_css_uline == 1:
            g_uline = 1
        else:
            g_uline = 0
    if g_bold_n > 0 or g_heading != 0 or g_css_bold != 0:
        g_bold = 1
    else:
        g_bold = 0
    # text-decoration:line-through (deco 3) — separate from underline (1)/none (2).
    if g_css_uline == 3:
        g_css_strike = 1
    else:
        g_css_strike = 0


# ---- segment building -----------------------------------------------
# Pixel-render FACE hint for the segment currently being opened. Heading wins
# (headings are never <pre>/<code>); then monospace; else body sans.
def _cur_face() -> uint8:
    if g_heading != 0:
        h: int32 = g_heading
        if h > 6:
            h = 6
        return cast[uint8](1 + h)                     # 2..7 = h1..h6
    if pre_mode != 0 or g_mono_n > 0:
        return 1                                       # monospace
    return 0                                           # body sans


def _seg_ensure():
    if seg_open != 0:
        return
    if n_segs >= MAX_SEGS:
        return
    seg_open = 1
    seg_x[n_segs]    = pen_x
    seg_line[n_segs] = cast[int32](cur_row)
    seg_off[n_segs]  = cast[int32](seg_text_len)
    seg_color[n_segs] = cast[uint8](g_color)
    # An explicit CSS colour overrides the role palette, EXCEPT on links,
    # which keep their blue role colour.
    if g_link < 0:
        seg_rgb[n_segs] = g_rgb
    else:
        # Links keep their blue role colour, EXCEPT when the anchor specifies its
        # own colour (author `a{color:…}` / inline) — then that colour wins.
        seg_rgb[n_segs] = g_link_rgb
    seg_bg[n_segs]    = g_bg
    seg_bold[n_segs]  = cast[uint8](g_bold)
    seg_uline[n_segs] = cast[uint8](g_uline)
    seg_link[n_segs]  = g_link
    seg_face[n_segs]  = _cur_face()
    seg_pxsize[n_segs] = g_font_px
    seg_lineh[n_segs] = g_lineh
    seg_img[n_segs]   = -1
    seg_boxart[n_segs] = 0
    seg_marker[n_segs] = 0
    seg_yoff[n_segs]  = g_yoff
    if g_strike_n > 0 or g_css_strike != 0:
        seg_strike[n_segs] = 1
    else:
        seg_strike[n_segs] = 0
    # A list-item's first text seg claims the pending hanging-indent jump.
    if _pending_indjump != 0:
        seg_indjump[n_segs] = 1
        _pending_indjump = 0
    else:
        seg_indjump[n_segs] = 0
    # Table cells + <pre> are laid out on absolute grid columns; the pixel
    # renderer honours seg_x for them so columns/alignment survive.
    if table_active != 0 or pre_mode != 0:
        seg_gridx[n_segs] = 1
    else:
        seg_gridx[n_segs] = 0
    seg_curlen = 0
    # Record the row's text-alignment (a post-layout pass shifts seg_x).
    # Table/pre rows keep their computed geometry (no re-alignment).
    if g_align != 0 and table_active == 0 and pre_mode == 0 and \
       cur_row < MAX_ROWS:
        row_align[cur_row] = cast[uint8](g_align)


def _seg_putc(c: uint8):
    _seg_ensure()
    if seg_open == 0:
        return
    if seg_text_len < SEG_TEXT_CAP - 1:
        seg_text_buf[seg_text_len] = c
        seg_text_len = seg_text_len + 1
        seg_curlen = seg_curlen + 1
    row_dirty = 1


# Emit a non-negative decimal integer into the current segment (marker use).
def _seg_putc_dec(v: int32):
    if v < 0:
        v = 0
    if v >= 10:
        _seg_putc_dec(v / 10)
    _seg_putc(cast[uint8](48 + (v - (v / 10) * 10)))


def _close_seg():
    if seg_open == 0:
        return
    if seg_curlen > 0 and n_segs < MAX_SEGS:
        seg_len[n_segs] = cast[int32](seg_curlen)
        n_segs = n_segs + 1
    seg_open = 0
    seg_curlen = 0


# A style change closes the current segment so the next text opens a fresh
# one carrying the new attributes.
def _style_break():
    _close_seg()
    _recompute_style()


# ---- line breaks ----------------------------------------------------
def _bump_row():
    cur_row = cur_row + 1
    if cur_row >= MAX_ROWS:
        cur_row = MAX_ROWS - 1
    # Clear a tall inline-block chip: the first line break after it drops past the
    # box's reserved rows so following content does not overlap it. 0 => no-op.
    if g_inlb_floor != 0:
        if cur_row < cast[uint64](g_inlb_floor):
            cur_row = cast[uint64](g_inlb_floor)
        g_inlb_floor = 0


def _soft_newline():
    # Move to a fresh line ONLY if the current one has content.
    _close_seg()
    if row_dirty != 0:
        _bump_row()
    _maybe_clear_float()
    pen_x = indent_x
    row_dirty = 0
    need_space = 0


def _newline():
    # Unconditional line break (<br>, pre newline).
    _close_seg()
    _bump_row()
    _maybe_clear_float()
    pen_x = indent_x
    row_dirty = 0
    need_space = 0


def _para_break():
    # End the current line + leave a single blank gap.
    _soft_newline()
    _bump_row()
    _maybe_clear_float()
    pen_x = indent_x
    need_space = 0


# Left indent = list nesting + blockquote nesting. Both front-ends flow to
# indent_x, so this is the single left-margin knob for block structure.
def _recompute_indent():
    indent_x = _left_margin() + list_depth * LIST_STEP - list_indent_drop + \
               bq_depth * BQ_INDENT + \
               dd_depth * DD_INDENT + blk_indent_sum + float_left_pad


# Drop an active float exclusion once flow has passed the float's bottom row.
# Called at every line start; a no-op (single compare) when no float is active.
def _maybe_clear_float():
    # Right channel: drop the right-edge exclusion once flow clears its bottom.
    if floatR_active != 0 and cast[int32](cur_row) >= floatR_bottom:
        floatR_active = 0
        float_redge = 0
    # Left channel: drop the left-pad exclusion + restore the indent.
    if floatL_active != 0 and cast[int32](cur_row) >= floatL_bottom:
        floatL_active = 0
        if float_left_pad != 0:
            float_left_pad = 0
            _recompute_indent()


# Push/pop a block's CSS left indent (margin-left+padding-left). Always paired
# per <p>/<div> open/close (a 0-px block still pushes, to stay balanced), and
# both refresh indent_x + the pen so content flows at the new left column.
def _blk_indent_push(px: int32):
    if blk_indent_sp < 64:
        blk_indent_stack[blk_indent_sp] = px
        blk_indent_sp = blk_indent_sp + 1
        blk_indent_sum = blk_indent_sum + px
    _recompute_indent()
    pen_x = indent_x


def _blk_indent_pop():
    if blk_indent_sp > 0:
        blk_indent_sp = blk_indent_sp - 1
        blk_indent_sum = blk_indent_sum - blk_indent_stack[blk_indent_sp]
    _recompute_indent()
    pen_x = indent_x


# ---- CSS border box (char-grid glyphs) ------------------------------
# Emit `ncells` copies of glyph `ch` as one standalone segment at (row, x).
# Used for the horizontal top/bottom border rules; writes the seg arrays
# directly (bypassing the pen) so it can target an arbitrary row.
def _emit_box_run(row: int32, x: int32, ch: uint8, ncells: int32):
    if ncells <= 0 or n_segs >= MAX_SEGS:
        return
    seg_x[n_segs]     = x
    seg_line[n_segs]  = row
    seg_off[n_segs]   = cast[int32](seg_text_len)
    seg_color[n_segs] = 0
    seg_rgb[n_segs]   = -1
    seg_bg[n_segs]    = -1
    seg_bold[n_segs]  = 0
    seg_uline[n_segs] = 0
    seg_link[n_segs]  = -1
    seg_face[n_segs]  = 1                              # box art = monospace
    seg_gridx[n_segs] = 1
    seg_img[n_segs]   = -1
    seg_boxart[n_segs] = 1
    seg_yoff[n_segs]  = 0
    seg_strike[n_segs] = 0
    k: int32 = 0
    while k < ncells and seg_text_len < SEG_TEXT_CAP - 1:
        c: uint8 = ch
        if k == 0 or k == ncells - 1:
            c = 43                                    # '+' corners/ends
        seg_text_buf[seg_text_len] = c
        seg_text_len = seg_text_len + 1
        k = k + 1
    seg_len[n_segs] = k
    n_segs = n_segs + 1


# Emit a single vertical bar '|' glyph at (row, x).
def _emit_box_bar(row: int32, x: int32):
    if n_segs >= MAX_SEGS or seg_text_len >= SEG_TEXT_CAP - 1:
        return
    seg_x[n_segs]     = x
    seg_line[n_segs]  = row
    seg_off[n_segs]   = cast[int32](seg_text_len)
    seg_color[n_segs] = 0
    seg_rgb[n_segs]   = -1
    seg_bg[n_segs]    = -1
    seg_bold[n_segs]  = 0
    seg_uline[n_segs] = 0
    seg_link[n_segs]  = -1
    seg_face[n_segs]  = 1                              # box art = monospace
    seg_gridx[n_segs] = 1
    seg_img[n_segs]   = -1
    seg_boxart[n_segs] = 1
    seg_yoff[n_segs]  = 0
    seg_strike[n_segs] = 0
    seg_text_buf[seg_text_len] = 124                  # '|'
    seg_text_len = seg_text_len + 1
    seg_len[n_segs] = 1
    n_segs = n_segs + 1


# ---- <img> pixel box ------------------------------------------------
# Record an <img>'s src string (src_ptr[soff..soff+slen)) in the registry the
# host driver reads to decode PNGs. Deduplicated; a no-op if src is empty/full.
def _eimg_record(soff: uint64, slen: uint64):
    if slen == 0:
        return
    i: uint64 = 0
    while i < n_eimg:
        if eimg_nlen[i] == slen:
            same: int32 = 1
            k: uint64 = 0
            while k < slen:
                if eimg_name_buf[eimg_noff[i] + k] != src_ptr[soff + k]:
                    same = 0
                    break
                k = k + 1
            if same != 0:
                return
        i = i + 1
    if n_eimg >= EIMG_MAX or eimg_name_used + slen > EIMG_NAME_CAP:
        return
    eimg_noff[n_eimg] = eimg_name_used
    eimg_nlen[n_eimg] = slen
    k2: uint64 = 0
    while k2 < slen:
        eimg_name_buf[eimg_name_used + k2] = src_ptr[soff + k2]
        k2 = k2 + 1
    eimg_name_used = eimg_name_used + slen
    n_eimg = n_eimg + 1


# alt-text placeholder for the current <img> (bracketed, e.g. "[Hamnix logo]").
img_alt_buf: Array[256, uint8]
img_alt_len: uint64 = 0


# Emit a standalone image segment: a block box of `bw2`x`bh2` px at the current
# left indent, carrying the decoded-image slot (or -2 = broken placeholder). The
# segment ALSO holds the bracketed alt text (img_alt_buf) so the legacy
# monospace-grid dump and the native text path have a meaningful glyph fallback;
# the PIXEL renderer ignores that text and blits the image box instead. The
# image owns its own visual row so following content flows below it.
def _emit_img_seg(slot: int32, bw2: int32, bh2: int32):
    _close_seg()
    _soft_newline()
    if n_segs >= MAX_SEGS:
        return
    seg_x[n_segs]     = indent_x
    seg_line[n_segs]  = cast[int32](cur_row)
    seg_off[n_segs]   = cast[int32](seg_text_len)
    seg_color[n_segs] = 0
    seg_rgb[n_segs]   = -1
    seg_bg[n_segs]    = -1
    seg_bold[n_segs]  = 0
    seg_uline[n_segs] = 0
    seg_link[n_segs]  = g_link
    seg_face[n_segs]  = 0
    seg_pxsize[n_segs] = 0
    seg_lineh[n_segs] = g_lineh
    seg_gridx[n_segs] = 1                              # absolute x, no reflow
    seg_img[n_segs]   = slot
    seg_boxart[n_segs] = 0
    seg_yoff[n_segs]  = 0
    seg_strike[n_segs] = 0
    seg_imgw[n_segs]  = bw2
    seg_imgh[n_segs]  = bh2
    # copy the bracketed alt text into the segment's glyph run.
    k: uint64 = 0
    while k < img_alt_len and seg_text_len < SEG_TEXT_CAP - 1:
        seg_text_buf[seg_text_len] = img_alt_buf[k]
        seg_text_len = seg_text_len + 1
        k = k + 1
    seg_len[n_segs]   = cast[int32](k)
    n_segs = n_segs + 1
    row_dirty = 1
    _soft_newline()                                   # content below the image


# Handle an <img> open tag: resolve src + width/height, compute the box size
# (natural size from a decoded image if available, else attribute size, else a
# broken-image placeholder), record the src for the host, and emit the box.
def _handle_img(ne: uint64, te: uint64):
    _word_flush()
    soff: uint64 = 0
    slen: uint64 = 0
    if _hx_find_attr(ne, te, cast[Ptr[uint8]]("src")) != 0 and g_attr_end > g_attr_start:
        soff = g_attr_start
        slen = g_attr_end - g_attr_start
    _eimg_record(soff, slen)
    # Build the bracketed alt placeholder ("[alt]" or "[img]") NOW, before the
    # width/height _attr_int calls clobber g_attr_start/end.
    img_alt_len = 0
    img_alt_buf[img_alt_len] = 91                      # '['
    img_alt_len = img_alt_len + 1
    if _hx_find_attr(ne, te, cast[Ptr[uint8]]("alt")) != 0 and g_attr_end > g_attr_start:
        p: uint64 = g_attr_start
        while p < g_attr_end and img_alt_len < 254:
            c: uint8 = src_ptr[p]
            if c == 9 or c == 10 or c == 13:
                c = 32
            img_alt_buf[img_alt_len] = c
            img_alt_len = img_alt_len + 1
            p = p + 1
    else:
        img_alt_buf[img_alt_len] = 105                 # 'i'
        img_alt_buf[img_alt_len + 1] = 109             # 'm'
        img_alt_buf[img_alt_len + 2] = 103             # 'g'
        img_alt_len = img_alt_len + 3
    img_alt_buf[img_alt_len] = 93                      # ']'
    img_alt_len = img_alt_len + 1
    slot: int32 = -1
    natw: int32 = 0
    nath: int32 = 0
    if slen > 0:
        slot = htmlimg_find(&src_ptr[soff], slen)
        if slot >= 0:
            natw = htmlimg_w(slot)
            nath = htmlimg_h(slot)
    aw: int32 = _attr_int(ne, te, cast[Ptr[uint8]]("width"), -1)
    ah: int32 = _attr_int(ne, te, cast[Ptr[uint8]]("height"), -1)
    bw2: int32 = 0
    bh2: int32 = 0
    if aw > 0 and ah > 0:
        bw2 = aw
        bh2 = ah
    elif aw > 0:
        bw2 = aw
        if natw > 0:
            bh2 = nath * aw / natw
        else:
            bh2 = aw
    elif ah > 0:
        bh2 = ah
        if nath > 0:
            bw2 = natw * ah / nath
        else:
            bw2 = ah
    else:
        if natw > 0:
            bw2 = natw
            bh2 = nath
    if bw2 <= 0 or bh2 <= 0:
        # no decoded image AND no usable attributes -> broken placeholder box.
        slot = -2
        bw2 = IMG_BROKEN_W
        bh2 = IMG_BROKEN_H
    elif slot < 0:
        slot = -2                                     # sized but undecodable
    # clamp the box so a pathological width can't blow up the canvas.
    if bw2 > bw:
        # scale height with width to preserve aspect when clamping.
        if bw2 > 0:
            bh2 = bh2 * bw / bw2
        bw2 = bw
    if bh2 < 1:
        bh2 = 1
    _emit_img_seg(slot, bw2, bh2)


# ---- inline <svg> ---------------------------------------------------
# A synthetic src-name buffer keying each inline <svg>'s rasterised RGBA in the
# lib/htmlimg store. The name is "svg@<byte-offset>" so a given <svg> in the
# source resolves to the SAME slot across the engine's two layout passes (no
# duplicate copies), yet two distinct <svg> elements never collide.
isvg_name: Array[24, uint8]


def _isvg_name(off: uint64) -> uint64:
    isvg_name[0] = 115                                 # 's'
    isvg_name[1] = 118                                 # 'v'
    isvg_name[2] = 103                                 # 'g'
    isvg_name[3] = 64                                  # '@'
    # decimal offset (max 20 digits fits uint64), written LSB-first then reversed
    n: uint64 = 4
    v: uint64 = off
    d0: uint64 = n
    if v == 0:
        isvg_name[n] = 48                              # '0'
        n = n + 1
    while v > 0 and n < 23:
        isvg_name[n] = cast[uint8](48 + cast[uint8](v % 10))
        v = v / 10
        n = n + 1
    # reverse the digits in place
    a: uint64 = d0
    b: uint64 = n - 1
    while a < b:
        t: uint8 = isvg_name[a]
        isvg_name[a] = isvg_name[b]
        isvg_name[b] = t
        a = a + 1
        b = b - 1
    return n


# Handle an inline <svg ...> element: rasterise the whole <svg>...</svg> subtree
# through the SHARED lib/svg rasterizer (the same one that decodes <img
# src=*.svg>), copy its RGBA into the lib/htmlimg store, and emit a replaced
# image box so the pixel renderer blits it exactly like an <img>. `ts` is the
# byte just after '<'; `te` is the '>' of the opening tag. Returns 1 if the
# element was consumed (caller must then _enter_skip past its children), 0 if it
# was self-closing / empty (nothing to skip).
def _handle_inline_svg(ts: uint64, te: uint64) -> int32:
    _word_flush()
    # self-closing "<svg .../>" carries no shapes — draw nothing, skip nothing.
    self_close: int32 = 0
    if te > ts and src_ptr[te - 1] == 47:              # '/'
        self_close = 1
    # Feed the rasterizer from the '<' of <svg> to end-of-source; svg_decode
    # finds the <svg> root at offset 0 and stops at the first </svg>.
    start: uint64 = ts - 1
    rc: int32 = svg_decode(&src_ptr[start], src_len - start)
    if rc != 0:
        # unsized / unparseable inline <svg> -> broken-image placeholder box.
        img_alt_len = 0
        img_alt_buf[0] = 91                            # '['
        img_alt_buf[1] = 115                           # 's'
        img_alt_buf[2] = 118                           # 'v'
        img_alt_buf[3] = 103                           # 'g'
        img_alt_buf[4] = 93                            # ']'
        img_alt_len = 5
        _emit_img_seg(-2, IMG_BROKEN_W, IMG_BROKEN_H)
        if self_close != 0:
            return 0
        return 1
    w: int32 = svg_width()
    h: int32 = svg_height()
    nl: uint64 = _isvg_name(start)
    slot: int32 = htmlimg_add(&isvg_name[0], nl, w, h, svg_rgba_ptr())
    bw2: int32 = w
    bh2: int32 = h
    if slot < 0:
        slot = -2                                      # store full -> placeholder
    # clamp to the content width, preserving aspect.
    if bw2 > bw:
        if bw2 > 0:
            bh2 = bh2 * bw / bw2
        bw2 = bw
    if bh2 < 1:
        bh2 = 1
    img_alt_len = 0
    img_alt_buf[0] = 91                                # '['
    img_alt_buf[1] = 115                               # 's'
    img_alt_buf[2] = 118                               # 'v'
    img_alt_buf[3] = 103                               # 'g'
    img_alt_buf[4] = 93                                # ']'
    img_alt_len = 5
    _emit_img_seg(slot, bw2, bh2)
    if self_close != 0:
        return 0
    return 1


# Advance `n` blank visual rows (top/bottom vertical margin+padding gap).
def _blank_rows(n: int32):
    k: int32 = 0
    while k < n:
        _bump_row()
        k = k + 1


# Open a block box for a <p>/<div>. `left`/`rins` are the left/right insets
# (margin+padding, px); `wd` the content width (px, -1 none); `topg`/`botg` the
# top/bottom gaps (px); `bord` 1 to draw a border. Pushes the left-indent and
# right-edge stacks + records close-side state on box_*_stack.
def _block_box_open(left: int32, rins: int32, wd: int32, topg: int32, \
                    botg: int32, bord: int32, bgc: int32):
    # top gap: quantise px -> blank lines.
    if topg > 0:
        _blank_rows((topg + LINE_H / 2) / LINE_H)
    # left inset (+ a cell for the border) shifts the content column.
    li: int32 = left
    if bord != 0:
        li = li + CELL_W
    _blk_indent_push(li)
    # right edge: shrink from the parent by the right inset (+ border cell), or
    # pin to indent_x + width when a width is set. Clamp to a sane range.
    parent_right: int32 = blk_right_cur
    if parent_right <= 0:
        parent_right = _content_right()
    new_right: int32 = parent_right - rins
    if bord != 0:
        new_right = new_right - CELL_W
    if wd >= 0:
        wr: int32 = indent_x + wd
        if wr < new_right:
            new_right = wr
    if new_right < indent_x + CELL_W:
        new_right = indent_x + CELL_W
    if new_right > _content_right():
        new_right = _content_right()
    if blk_right_sp < 64:
        blk_right_stack[blk_right_sp] = parent_right
        blk_right_sp = blk_right_sp + 1
    blk_right_cur = new_right
    # border: draw the top rule now, on a fresh row, then start content below.
    lx: int32 = indent_x - CELL_W                     # left bar column
    rx: int32 = new_right                             # right bar column
    if bord != 0:
        _soft_newline()
        row_dirty = 0
        span: int32 = (rx - lx) / CELL_W + 1
        _emit_box_run(cast[int32](cur_row), lx, 45, span)   # '-' top
        _bump_row()
        pen_x = indent_x
        row_dirty = 0
    # push close-side state.
    if box_sp < 64:
        box_botg_stack[box_sp] = botg
        box_bord_stack[box_sp] = bord
        box_lx_stack[box_sp]   = lx
        box_rx_stack[box_sp]   = rx
        box_srow_stack[box_sp] = cast[int32](cur_row)
        box_bg_stack[box_sp]   = bgc
        box_float_stack[box_sp] = 0                     # in-flow unless floated
        box_ftop_stack[box_sp]  = 0
        box_fgeom_stack[box_sp] = 0
        box_flexitem_stack[box_sp] = 0                  # set by the caller
        box_flexcont_stack[box_sp] = 0
        box_pos_stack[box_sp] = 0                        # set by the caller
        box_posrun_stack[box_sp] = -1
        box_pretrow_stack[box_sp] = 0
        box_pushedctx_stack[box_sp] = 0
        # ROUND-3 vertical sizing: capture the resolved cascade winners (inline
        # d_* wins over the stylesheet m_*) so the close can pin/floor/clamp the
        # box's row span. border-box height also swallows vertical padding, but
        # this box model has no vertical padding so height == content height.
        eff_ht: int32 = m_ht
        if d_ht >= 0:
            eff_ht = d_ht
        eff_minh: int32 = m_minh
        if d_minh >= 0:
            eff_minh = d_minh
        eff_maxh: int32 = m_maxh
        if d_maxh >= 0:
            eff_maxh = d_maxh
        box_ht_stack[box_sp]   = eff_ht
        box_minh_stack[box_sp] = eff_minh
        box_maxh_stack[box_sp] = eff_maxh
        box_sp = box_sp + 1
    # ROUND-3 text-indent: arm the first-line inset for this block (inline over
    # sheet). Consumed once by the first word on the opening line.
    eff_ti: int32 = m_tindent
    if d_tindent != TINDENT_UNSET:
        eff_ti = d_tindent
    if eff_ti != TINDENT_UNSET and eff_ti != 0:
        g_tindent_pending = eff_ti


# Close the block box opened by _block_box_open (pops both stacks; draws the
# bottom border rule + left/right bars over the content rows when bordered;
# emits the bottom gap as blank lines).
def _block_box_close():
    botg: int32 = 0
    bord: int32 = 0
    lx: int32 = 0
    rx: int32 = 0
    srow: int32 = 0
    bgc: int32 = -1
    ehc: int32 = -1
    eminh: int32 = -1
    emaxh: int32 = -1
    if box_sp > 0:
        box_sp = box_sp - 1
        botg = box_botg_stack[box_sp]
        bord = box_bord_stack[box_sp]
        lx   = box_lx_stack[box_sp]
        rx   = box_rx_stack[box_sp]
        srow = box_srow_stack[box_sp]
        bgc  = box_bg_stack[box_sp]
        ehc  = box_ht_stack[box_sp]
        eminh = box_minh_stack[box_sp]
        emaxh = box_maxh_stack[box_sp]
    # ROUND-3 CSS vertical sizing: pin/floor/clamp the box's row span before the
    # background/border paint so both track the resolved height. Quantise px to
    # whole LINE_H rows. `height` pins; `min-height` floors (pad blank rows);
    # `max-height` clamps (pull the flow cursor up — overflow is not reflowed).
    if ehc >= 0 or eminh >= 0 or emaxh >= 0:
        _word_flush()
        natbot: int32 = cast[int32](cur_row)
        if row_dirty != 0:
            natbot = natbot + 1
        natrows: int32 = natbot - srow
        if natrows < 0:
            natrows = 0
        tgtpx: int32 = natrows * LINE_H
        if ehc >= 0:
            tgtpx = ehc
        if eminh >= 0 and tgtpx < eminh:
            tgtpx = eminh
        if emaxh >= 0 and tgtpx > emaxh:
            tgtpx = emaxh
        tgtrows: int32 = (tgtpx + LINE_H / 2) / LINE_H
        if tgtrows < 1 and tgtpx > 0:
            tgtrows = 1
        newbot: int32 = srow + tgtrows
        # Drive the flow cursor to the exclusive box bottom (newbot) with a clean
        # row so the bg/border paint spans [srow, newbot). Growing bumps blank
        # rows; clamping (max-height) pulls the cursor up over the overflow.
        if newbot >= natbot:
            while cast[int32](cur_row) < newbot:
                _bump_row()
            row_dirty = 0
        else:
            cur_row = cast[uint64](newbot)
            row_dirty = 0
    # element background: paint the WHOLE box rectangle (not just behind text).
    # Flush the pen so the box's last content row is counted, then register a
    # fill spanning [srow, bottom) at the box's left/right columns.
    if bgc >= 0 and n_bfills < BFILL_MAX:
        _word_flush()
        bfbot: int32 = cast[int32](cur_row)
        if row_dirty != 0:
            bfbot = bfbot + 1
        if bfbot > srow:
            bfill_lx[n_bfills]  = lx
            bfill_rx[n_bfills]  = rx + CELL_W
            bfill_top[n_bfills] = srow
            bfill_bot[n_bfills] = bfbot
            bfill_rgb[n_bfills] = bgc
            bfill_z[n_bfills]   = 0
            n_bfills = n_bfills + 1
    if bord != 0:
        _soft_newline()
        brow: int32 = cast[int32](cur_row)
        # side bars over every content row [srow, brow).
        r: int32 = srow
        while r < brow:
            _emit_box_bar(r, lx)
            _emit_box_bar(r, rx)
            r = r + 1
        span: int32 = (rx - lx) / CELL_W + 1
        _emit_box_run(brow, lx, 45, span)             # '-' bottom
        # Register the box for the pixel renderer to stroke a real 1px border
        # (the glyphs above are consumed only by the monospace-grid text dump).
        # top rule sits on srow-1 (open bumped a row past it); bottom on brow.
        if n_bboxes < BBOX_MAX:
            bbox_lx[n_bboxes]  = lx
            bbox_rx[n_bboxes]  = rx
            bbox_top[n_bboxes] = srow - 1
            bbox_bot[n_bboxes] = brow
            bbox_rgb[n_bboxes] = 0
            n_bboxes = n_bboxes + 1
        _bump_row()
        row_dirty = 0
    # restore the parent right edge + pop the left indent.
    if blk_right_sp > 0:
        blk_right_sp = blk_right_sp - 1
        blk_right_cur = blk_right_stack[blk_right_sp]
    _blk_indent_pop()
    if botg > 0:
        _blank_rows((botg + LINE_H / 2) / LINE_H)
    pen_x = indent_x


# Open a FLOATED block (side 1=left, 2=right). Lays the float out as a narrow
# box pinned to that edge (reusing the bordered-box machinery), recording the
# bookkeeping the close needs to set the wrap exclusion. Returns 1 if it opened
# as a real float (caller must not also open an in-flow box), 0 to fall back to
# a normal in-flow block (no room / a float already active).
def _float_box_open(side: int32, wd: int32, topg: int32, botg: int32, \
                    bord: int32, bgc: int32) -> int32:
    # One float per SIDE: a second float on an already-occupied side falls back
    # to an in-flow block, but a left+right pair may both be active at once.
    if side == 2 and floatR_active != 0:
        return 0
    if side != 2 and floatL_active != 0:
        return 0
    _word_flush()
    _soft_newline()
    fstart: int32 = cast[int32](cur_row)
    fw: int32 = wd
    if fw <= 0:
        fw = FLOAT_DEF_W
    left0: int32 = indent_x
    right0: int32 = _flow_right()
    avail: int32 = right0 - left0
    # cap the float so a readable body column (>= 4 cells) survives beside it.
    if fw > avail - 4 * CELL_W:
        fw = avail - 4 * CELL_W
    if fw < 6 * CELL_W:
        return 0                                        # too little room
    li: int32 = 0
    if side == 2:                                       # right: pin to right edge
        li = right0 - fw - left0
        if li < 0:
            li = 0
    _block_box_open(li, 0, fw, topg, botg, bord, bgc)
    idx: int32 = box_sp - 1
    if idx >= 0:
        box_float_stack[idx] = side
        box_ftop_stack[idx]  = fstart
        if side == 2:
            box_fgeom_stack[idx] = left0 + li - FLOAT_GAP    # right wrap edge
        else:
            box_fgeom_stack[idx] = fw + FLOAT_GAP            # left indent pad
    return 1


# Close a block that may be a float. Draws the box (via _block_box_close), then
# — if it floated — rewinds cur_row to the float's top and arms the exclusion so
# the following in-flow content re-flows beside it. Returns the float side
# (0 = it was a normal in-flow block, so the caller still emits its para gap).
def _float_box_close() -> int32:
    idx: int32 = box_sp - 1
    side: int32 = 0
    fstart: int32 = 0
    geom: int32 = 0
    if idx >= 0:
        side = box_float_stack[idx]
        fstart = box_ftop_stack[idx]
        geom = box_fgeom_stack[idx]
    _block_box_close()
    if side == 0:
        return 0
    fbot: int32 = cast[int32](cur_row)
    if fbot <= fstart:
        fbot = fstart + 1
    if side == 2:
        floatR_bottom = fbot
        floatR_active = 1
        float_redge = geom
    else:
        floatL_bottom = fbot
        floatL_active = 1
        float_left_pad = geom
        _recompute_indent()
    cur_row = cast[uint64](fstart)                       # rewind: flow beside
    pen_x = indent_x
    row_dirty = 0
    need_space = 0
    return side


# Drop any active float and drop flow below it (called at document end so the
# scroll height covers a trailing float taller than the beside-content).
def _float_flush():
    if floatL_active != 0 or floatR_active != 0:
        # Drop below the DEEPEST of the two active floats.
        fbot: int32 = floatL_bottom
        if floatR_bottom > fbot:
            fbot = floatR_bottom
        if cast[int32](cur_row) < fbot:
            cur_row = cast[uint64](fbot)
        floatL_active = 0
        floatR_active = 0
        float_redge = 0
        if float_left_pad != 0:
            float_left_pad = 0
            _recompute_indent()
        pen_x = indent_x
        row_dirty = 0


# ---- CSS flexbox ------------------------------------------------------------
# Is src[a..b) the name of a block-level element that opens a box (and so can be
# a flex column)? Mirrors the block set in _handle_tag's <p>/<div> branch.
def _is_flexblk(a: uint64, b: uint64) -> int32:
    n: uint64 = b - a
    if _hx_name_eq(a, n, cast[Ptr[uint8]]("div")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("p")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("section")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("aside")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("article")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("header")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("footer")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("main")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("nav")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("figure")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("figcaption")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("span")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("a")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("li")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("ul")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("ol")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("label")) != 0:
        return 1
    return 0


# Tags that own a dedicated layout/styling handler whose semantics must survive
# a stray `display:block`/`inline-block`/`flex` (or a flex-item context): links,
# headings, lists, tables, form controls, void tags, page structure. Everything
# NOT here is free to be blockified into a generic block box (the display:block
# and flex-item-blockification paths). Keeps `label{display:block}` +
# span-flex-navbars working without breaking tables/lists/links.
def _blk_dedicated(a: uint64, n: uint64) -> int32:
    if _hx_name_eq(a, n, cast[Ptr[uint8]]("a")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("ul")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("ol")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("li")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("dl")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("dt")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("dd")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("table")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("tr")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("td")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("th")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("thead")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("tbody")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("tfoot")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("caption")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("img")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("input")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("br")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("hr")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("pre")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("code")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("blockquote")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("textarea")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("select")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("option")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("button")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("mark")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("small")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("sub")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("sup")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("h1")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("h2")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("h3")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("h4")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("h5")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("h6")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("body")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("html")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("script")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("style")) != 0:
        return 1
    return 0


# Should the element currently being dispatched be laid out as a generic block
# box? True when (a) it is a direct child of an active flex container (flex-item
# blockification -> a column) or (b) its effective display is flex/block/
# inline-block -- provided it is not a dedicated-handler tag (see _blk_dedicated).
def _generic_block_wanted(a: uint64, n: uint64) -> int32:
    fitem: int32 = 0
    if _flex_item_col(el_sp) >= 0:
        fitem = 1
    if _blk_dedicated(a, n) != 0:
        # A DIRECT <a>/<li> child of an active flex row still columnises (the
        # canonical `<nav style=flex><a>…` / `<ul style=flex><li>…` navbar): the
        # generic-block path opens its column box, and the link/marker hook there
        # re-adds the href / bullet so link + list semantics survive. Every other
        # dedicated-handler tag stays dedicated (tables, headings, forms, …).
        if fitem != 0 and (_hx_name_eq(a, n, cast[Ptr[uint8]]("a")) != 0 or \
                           _hx_name_eq(a, n, cast[Ptr[uint8]]("li")) != 0):
            return 1
        return 0
    if fitem != 0:
        return 1
    if g_eff_disp == 2 or g_eff_disp == 3 or g_eff_disp == 4 or g_eff_disp == 6:
        return 1
    return 0


# Pre-scan the source from `after` (just past a flex container's '>') to its
# matching close tag, counting the number of DIRECT-CHILD block boxes (the flex
# items). Depth tracks nesting of the same block set; a direct child is one
# opened at relative depth 0. Returns the child count.
def _flex_count_children(after: uint64) -> int32:
    depth: int32 = 0
    n: int32 = 0
    i: uint64 = after
    while i < src_len:
        if src_ptr[i] != 60:                         # not '<'
            i = i + 1
            continue
        j: uint64 = i + 1
        closing: int32 = 0
        if j < src_len and src_ptr[j] == 47:         # '/'
            closing = 1
            j = j + 1
        ns: uint64 = j
        while j < src_len and _alnum_at(j) != 0:
            j = j + 1
        blk: int32 = _is_flexblk(ns, j)
        # advance to this tag's '>'
        k: uint64 = j
        while k < src_len and src_ptr[k] != 62:
            k = k + 1
        selfclose: int32 = 0
        if k > 0 and src_ptr[k - 1] == 47:
            selfclose = 1
        if closing == 0:
            if blk != 0:
                if depth == 0:
                    n = n + 1
                if selfclose == 0:
                    depth = depth + 1
        else:
            if blk != 0:
                if depth == 0:
                    return n                          # container's own close
                depth = depth - 1
        if k < src_len:
            i = k + 1
        else:
            i = k
    return n


# Measure the NATURAL content width (px) of each direct-child flex item, filling
# flex_meas_w[0..nc). A child's natural width is its collapsed visible-text run
# length in the CELL_W grid (the same grid the renderer places text on), so a
# nav link "Home" measures 4*CELL_W. Nested tag structure is skipped; interior
# whitespace collapses to one space; leading/trailing space is dropped. Returns
# the summed natural width of all children (0 if nothing measurable).
def _flex_measure_children(after: uint64, nc: int32) -> int32:
    depth: int32 = 0
    ci: int32 = -1                    # current direct-child index (-1 none open)
    chars: int32 = 0                  # visible chars in the current child
    pend_sp: int32 = 0                # a collapsed space is pending before next word
    total: int32 = 0
    i: uint64 = after
    while i < src_len:
        c: uint8 = src_ptr[i]
        if c == 60:                                  # '<'
            j: uint64 = i + 1
            closing: int32 = 0
            if j < src_len and src_ptr[j] == 47:     # '/'
                closing = 1
                j = j + 1
            ns: uint64 = j
            while j < src_len and _alnum_at(j) != 0:
                j = j + 1
            blk: int32 = _is_flexblk(ns, j)
            k: uint64 = j
            while k < src_len and src_ptr[k] != 62:  # '>'
                k = k + 1
            selfclose: int32 = 0
            if k > 0 and src_ptr[k - 1] == 47:
                selfclose = 1
            if closing == 0:
                if blk != 0:
                    if depth == 0:
                        ci = ci + 1                  # a new direct child opens
                        chars = 0
                        pend_sp = 0
                    if selfclose == 0:
                        depth = depth + 1
            else:
                if blk != 0:
                    if depth == 0:
                        return total                 # container's own close
                    depth = depth - 1
                    if depth == 0 and ci >= 0 and ci < nc:
                        w: int32 = chars * CELL_W
                        flex_meas_w[ci] = w
                        total = total + w
            if k < src_len:
                i = k + 1
            else:
                i = k
            continue
        if depth >= 1 and ci >= 0:
            if c == 32 or c == 9 or c == 10 or c == 13:
                if chars > 0:
                    pend_sp = 1
            else:
                if pend_sp != 0:
                    chars = chars + 1
                    pend_sp = 0
                chars = chars + 1
        i = i + 1
    return total


# Distribute the free space of a natural-width flex row per justify-content,
# writing each child's x offset (from flex_left) into flex_child_x[frame*..+col]
# and its width into flex_child_w. `just` is g_flex_just (1..5). Widths are read
# from flex_meas_w[0..nc). Free = avail - sum(widths).
def _flex_layout_natural(frame: int32, nc: int32, avail: int32, just: int32, \
                         gp: int32):
    base: int32 = frame * FLEX_MAX
    sumw: int32 = 0
    c: int32 = 0
    while c < nc:
        sumw = sumw + flex_meas_w[c]
        c = c + 1
    free: int32 = avail - sumw
    if free < 0:
        free = 0
    lead: int32 = 0                # x of the first item
    step_extra: int32 = gp         # inter-item gap beyond each item's width
    if just == 1:                                    # flex-start
        lead = 0
    elif just == 2:                                  # center
        lead = (free - (nc - 1) * gp) / 2
        if lead < 0:
            lead = 0
    elif just == 3:                                  # flex-end
        lead = free - (nc - 1) * gp
        if lead < 0:
            lead = 0
    elif just == 4:                                  # space-between
        lead = 0
        if nc > 1:
            step_extra = free / (nc - 1)
        else:
            lead = free / 2
    elif just == 5:                                  # space-around
        gap: int32 = free / nc
        lead = gap / 2
        step_extra = gap
    x: int32 = lead
    c = 0
    while c < nc:
        flex_child_x[base + c] = x
        flex_child_w[base + c] = flex_meas_w[c]
        x = x + flex_meas_w[c] + step_extra
        c = c + 1


# Resolve a grid frame's TRACK x-positions + widths into the shared flex_child_x/
# flex_child_w[frame*FLEX_MAX + c] from the parsed grid-template-columns encoding
# (g_grid_n tracks, g_grid_enc[c] >= 0 => fixed px; < 0 => fr weight negated).
# `avail` is the container content width, `gp` the column-gap. The fr tracks share
# the free space left after the fixed tracks and the (nt-1) gaps, split by weight.
# Returns the resolved track count (0 if nothing to resolve).
def _grid_resolve_tracks(frame: int32, avail: int32, gp: int32) -> int32:
    nt: int32 = g_grid_n
    if nt > GRID_MAXTRACK:
        nt = GRID_MAXTRACK
    if nt < 1:
        return 0
    sumfix: int32 = 0
    sumfr:  int32 = 0
    c: int32 = 0
    while c < nt:
        e: int32 = g_grid_enc[c]
        if e >= 0:
            sumfix = sumfix + e
        else:
            sumfr = sumfr - e                        # -e = fr weight
        c = c + 1
    free: int32 = avail - sumfix - (nt - 1) * gp
    if free < 0:
        free = 0
    base: int32 = frame * FLEX_MAX
    # First pass: resolve each track's PIXEL width (fr shares the free space).
    occ: int32 = 0
    c = 0
    while c < nt:
        e2: int32 = g_grid_enc[c]
        w: int32 = 0
        if e2 >= 0:
            w = e2                                    # fixed px track
        else:
            if sumfr > 0:
                w = free * (-e2) / sumfr              # fr share of free space
        if w < CELL_W:
            w = CELL_W
        flex_child_w[base + c] = w
        occ = occ + w
        c = c + 1
    occ = occ + (nt - 1) * gp                          # total track+gap extent
    # justify-content in the INLINE axis: when the resolved tracks do NOT fill the
    # container (all-fixed grids that underflow), distribute the leftover space per
    # justify-content — center / flex-end / space-between / space-around. fr grids
    # consume the free space so leftover is ~0 and every branch collapses to a
    # start-aligned lay-out (lead 0 / extra 0), keeping them byte-identical.
    lead: int32 = 0
    extra: int32 = 0                                    # inter-track spacing beyond gp
    leftover: int32 = avail - occ
    if leftover > 0 and g_flex_just >= 2:
        if g_flex_just == 2:                            # center
            lead = leftover / 2
        elif g_flex_just == 3:                          # flex-end
            lead = leftover
        elif g_flex_just == 4:                          # space-between
            if nt > 1:
                extra = leftover / (nt - 1)
            else:
                lead = leftover / 2
        elif g_flex_just == 5:                          # space-around / evenly
            unit: int32 = leftover / nt
            lead = unit / 2
            extra = unit
    # Second pass: lay each track at its x (lead + cumulative width + gp + extra).
    x: int32 = lead
    c = 0
    while c < nt:
        flex_child_x[base + c] = x
        x = x + flex_child_w[base + c] + gp + extra
        c = c + 1
    return nt


# Fixed height (in whole character ROWS) of grid row `ridx` for frame `frame`,
# from the parsed grid-template-rows px stored in flex_growh (0 = content-sized:
# no explicit height, or a row past the template / an fr row). px -> rows rounds
# to nearest LINE_H, mirroring the row-gap conversion.
def _grid_row_h_rows(frame: int32, ridx: int32) -> int32:
    if ridx >= flex_gridrn[frame]:
        return 0
    px: int32 = flex_growh[frame * FLEX_MAX + ridx]
    if px <= 0:
        return 0
    return (px + LINE_H / 2) / LINE_H


# Open a flex container: the box is already open (indent_x/blk_right_cur set to
# the container's content column). Compute the equal column width from the
# child count and push a frame. `eldepth` is the el-stack depth of the container
# element (its direct children sit at eldepth+1). Returns 1 if a real flex row
# was armed, 0 to fall back to normal block stacking (too few/many columns or
# too little width per column). A `display:grid` container (g_flex_grid) reuses
# this same frame in the fixed-track auto-placement model.
def _flex_container_open(content_after: uint64, eldepth: int32) -> int32:
    if flex_sp >= FLEX_MAX:
        return 0
    # flex-direction: column stacks children vertically -- that IS the default
    # block flow, so DON'T arm a horizontal column row; fall back to block
    # stacking (each child a normal full-width block). Only row flex columnises.
    # (grid ignores flex-direction — a grid always lays out in tracks.)
    if g_flex_grid == 0 and g_flex_dir == 1:
        return 0
    nc: int32 = _flex_count_children(content_after)
    if nc < 2:
        return 0
    # A flex row is capped at FLEX_MAX columns; a grid auto-places many items into
    # a fixed track count, so it allows up to GRID_MAXITEM children per container.
    if g_flex_grid == 0 and nc > FLEX_MAX:
        return 0
    if g_flex_grid != 0 and nc > GRID_MAXITEM:
        return 0
    left0: int32 = indent_x
    right0: int32 = blk_right_cur
    if right0 <= 0:
        right0 = _content_right()
    avail: int32 = right0 - left0
    # Inter-column gutter: an author `gap`/`column-gap` overrides the default.
    gp: int32 = FLEX_GAP
    if g_flex_gap >= 0:
        gp = g_flex_gap
    # NATURAL-width path: an EXPLICIT justify-content whose children's natural
    # content widths fit the row gets real free-space distribution (nav bars,
    # button/chip rows). Falls through to the equal-column approximation when the
    # items overflow (content-heavy flex: article beside infobox) or no explicit
    # justify was given (preserves the legacy spread).
    use_nat: int32 = 0
    use_wrap: int32 = 0
    use_grid: int32 = 0
    nt: int32 = 0
    # GRID path: `display:grid` resolves grid-template-columns into fixed track
    # widths (fr distributing free space) up front; items auto-place into those
    # tracks and wrap to the next row every `nt` items. A grid with no parseable
    # template falls back to normal block stacking.
    if g_flex_grid != 0:
        nt = _grid_resolve_tracks(flex_sp, avail, gp)
        if nt < 1:
            return 0
        use_grid = 1
    elif g_flex_wrap != 0:
        # WRAP path: `flex-wrap:wrap` places items ONLINE and wraps overflow onto
        # new lines. Pre-measure natural content widths so width-less items (nav
        # pills) size to content; items with an explicit CSS width use it.
        _flex_measure_children(content_after, nc)
        use_wrap = 1
    elif g_flex_just != 0:
        tot: int32 = _flex_measure_children(content_after, nc)
        if tot > 0 and tot + (nc - 1) * gp <= avail:
            _flex_layout_natural(flex_sp, nc, avail, g_flex_just, gp)
            use_nat = 1
    colw: int32 = (avail - (nc - 1) * gp) / nc
    if use_nat == 0 and use_wrap == 0 and use_grid == 0 and \
       colw < 6 * CELL_W:                            # columns too narrow
        return 0
    flex_top_row[flex_sp] = cast[int32](cur_row)
    flex_max_bot[flex_sp] = cast[int32](cur_row)
    flex_left[flex_sp]    = left0
    flex_colw[flex_sp]    = colw
    flex_gap[flex_sp]     = colw + gp
    flex_ncol[flex_sp]    = nc
    flex_next[flex_sp]    = 0
    flex_eldepth[flex_sp] = eldepth
    flex_natural[flex_sp] = use_nat
    flex_wrap_on[flex_sp] = use_wrap
    flex_grid[flex_sp]    = use_grid
    flex_ntrack[flex_sp]  = nt
    flex_avail[flex_sp]   = avail
    flex_rawgap[flex_sp]  = gp
    # row-gap: whole LINE_H rows between wrapped flex lines (rounded to nearest).
    rgr: int32 = 0
    if g_flex_rowgap > 0:
        rgr = (g_flex_rowgap + LINE_H / 2) / LINE_H
    flex_rowgap[flex_sp] = rgr
    flex_cur_x[flex_sp]   = 0
    flex_line_top[flex_sp] = cast[int32](cur_row)
    flex_line_bot[flex_sp] = cast[int32](cur_row)
    # Grid auto-flow cursor + explicit-row-height state (all no-ops for non-grid).
    flex_gcur[flex_sp]    = 0
    flex_growidx[flex_sp] = 0
    flex_gridrn[flex_sp]  = 0
    if use_grid != 0:
        nr: int32 = g_grid_rn
        if nr > GRID_MAXTRACK:
            nr = GRID_MAXTRACK
        flex_gridrn[flex_sp] = nr
        rr: int32 = 0
        while rr < nr:
            hpx: int32 = g_grid_renc[rr]
            if hpx < 0:
                hpx = 0                              # fr rows stay content-sized
            flex_growh[flex_sp * FLEX_MAX + rr] = hpx
            rr = rr + 1
        # A fixed row-0 height makes the first row occupy its track height even if
        # its content is shorter (the row is a floor; taller content still grows).
        h0: int32 = _grid_row_h_rows(flex_sp, 0)
        if h0 > 0:
            flex_line_bot[flex_sp] = flex_line_top[flex_sp] + h0
            if flex_line_bot[flex_sp] > flex_max_bot[flex_sp]:
                flex_max_bot[flex_sp] = flex_line_bot[flex_sp]
    # align-items: only 2 (center) / 3 (flex-end) / 4 (stretch) arm the deferred
    # cross-axis fixup; 0/1 (unset / flex-start) keep the byte-identical top-align.
    # NEVER armed for a grid (its item count can exceed FLEX_MAX, which the fixup's
    # per-column bookkeeping arrays do not size for) — grid rows stay top-aligned.
    fa: int32 = g_flex_align
    if fa < 2 or use_grid != 0:
        fa = 0
    flex_align[flex_sp] = fa
    flex_sp = flex_sp + 1
    return 1


# Would a block opening at el-stack depth `eldepth` be a direct child (flex
# item) of the current flex container? Returns the 0-based column index, or -1.
def _flex_item_col(eldepth: int32) -> int32:
    if flex_sp <= 0:
        return -1
    top: int32 = flex_sp - 1
    if eldepth != flex_eldepth[top] + 1:
        return -1
    if flex_next[top] >= flex_ncol[top]:
        return -1                                    # more children than counted
    return flex_next[top]


# Called on a flex item's close: record the column's bottom row into the frame's
# running max, then REWIND cur_row to the container top so the next sibling
# column starts level. pen/row state reset for the next column.
def _flex_item_close():
    top: int32 = flex_sp - 1
    if top < 0:
        return
    # Exclusive bottom (first free row): if the column left content on its
    # current row, that row is occupied, so the column's bottom is the row
    # BELOW it. Without the +1 a single-row column reports a zero-height span,
    # which collapses the container's background fill to nothing.
    bot: int32 = cast[int32](cur_row)
    if row_dirty != 0:
        bot = bot + 1
    if bot > flex_max_bot[top]:
        flex_max_bot[top] = bot
    # Cross-axis fixup: close this item's recorded seg/fill/border ranges (the box
    # background + border were already emitted by the preceding _block_box_close),
    # and stamp its bottom row. Only armed for align-items >= center. Commit any
    # still-open trailing text segment FIRST — a segment reserves seg_line at open
    # but only bumps n_segs at _close_seg, so an uncommitted tail would fall past
    # the recorded [seg0,seg1) range and escape the cross-axis shift.
    if flex_align[top] >= 2 and flex_next[top] < FLEX_MAX:
        _word_flush()
        _close_seg()
        fidx1: int32 = top * FLEX_MAX + flex_next[top]
        flex_it_seg1[fidx1] = cast[int32](n_segs)
        flex_it_bf1[fidx1]  = n_bfills
        flex_it_bx1[fidx1]  = n_bboxes
        flex_it_bot[fidx1]  = bot
    flex_next[top] = flex_next[top] + 1
    # WRAP/GRID: this item belongs to the current line/row — grow the line's
    # bottom and rewind to the LINE top (so the next item on the same line starts
    # level; a grid row advance is triggered at the next item's open).
    if flex_wrap_on[top] != 0 or flex_grid[top] != 0:
        if bot > flex_line_bot[top]:
            flex_line_bot[top] = bot
        cur_row = cast[uint64](flex_line_top[top])
    else:
        cur_row = cast[uint64](flex_top_row[top])
    pen_x = indent_x
    row_dirty = 0
    need_space = 0


# Shift one flex item's already-emitted segments/fills/borders DOWN by `dy` rows
# (center / flex-end cross-axis alignment). Rows clamp into [0, MAX_ROWS) and grow
# total_rows, mirroring _apply_positioned's relocation.
def _flex_shift_item(fidx: int32, dy: int32):
    if dy <= 0:
        return
    j: int32 = flex_it_seg0[fidx]
    s1: int32 = flex_it_seg1[fidx]
    while j < s1:
        nr: int32 = seg_line[j] + dy
        if cast[uint64](nr) >= MAX_ROWS:
            nr = cast[int32](MAX_ROWS) - 1
        seg_line[j] = nr
        if cast[uint64](nr) + 1 > total_rows:
            total_rows = cast[uint64](nr) + 1
        j = j + 1
    bf: int32 = flex_it_bf0[fidx]
    bf1: int32 = flex_it_bf1[fidx]
    while bf < bf1:
        bfill_top[bf] = bfill_top[bf] + dy
        bfill_bot[bf] = bfill_bot[bf] + dy
        bf = bf + 1
    bx: int32 = flex_it_bx0[fidx]
    bx1: int32 = flex_it_bx1[fidx]
    while bx < bx1:
        bbox_top[bx] = bbox_top[bx] + dy
        bbox_bot[bx] = bbox_bot[bx] + dy
        bx = bx + 1


# STRETCH one flex item: content stays top-aligned, but the item's OWN box
# background fill + border (the fill spanning exactly [ltop, item_bot) over the
# whole column) grows to the line's cross-axis extent `line_bot`.
def _flex_stretch_item(fidx: int32, line_bot: int32):
    ltop: int32 = flex_it_ltop[fidx]
    ibot: int32 = flex_it_bot[fidx]
    if line_bot <= ibot:
        return
    bf: int32 = flex_it_bf0[fidx]
    bf1: int32 = flex_it_bf1[fidx]
    while bf < bf1:
        if bfill_top[bf] == ltop and bfill_bot[bf] == ibot:
            bfill_bot[bf] = line_bot
        bf = bf + 1
    bx: int32 = flex_it_bx0[fidx]
    bx1: int32 = flex_it_bx1[fidx]
    while bx < bx1:
        if bbox_top[bx] == ltop - 1 and bbox_bot[bx] == ibot:
            bbox_bot[bx] = line_bot
        bx = bx + 1


# Deferred cross-axis (align-items) fixup, run at container close once every
# item's line-top/bottom is known. For each item, the line's cross extent is the
# tallest item sharing its line-top (so single-line AND wrapped lines both work);
# center/flex-end offset the item down within that extent, stretch grows its box.
def _flex_align_fixup(top: int32):
    mode: int32 = flex_align[top]
    if mode < 2:
        return
    nc: int32 = flex_next[top]
    if nc > flex_ncol[top]:
        nc = flex_ncol[top]
    c: int32 = 0
    while c < nc:
        fidx: int32 = top * FLEX_MAX + c
        ltop: int32 = flex_it_ltop[fidx]
        line_bot: int32 = flex_it_bot[fidx]
        k: int32 = 0
        while k < nc:
            kidx: int32 = top * FLEX_MAX + k
            if flex_it_ltop[kidx] == ltop and flex_it_bot[kidx] > line_bot:
                line_bot = flex_it_bot[kidx]
            k = k + 1
        line_h: int32 = line_bot - ltop
        item_h: int32 = flex_it_bot[fidx] - ltop
        if mode == 4:
            _flex_stretch_item(fidx, line_bot)
        elif mode == 2:
            _flex_shift_item(fidx, (line_h - item_h) / 2)
        elif mode == 3:
            _flex_shift_item(fidx, line_h - item_h)
        c = c + 1


# Called on a flex container's close (BEFORE its box closes): drop cur_row to the
# tallest column so the container spans the full flex-row height, then pop the
# frame.
def _flex_container_close():
    top: int32 = flex_sp - 1
    if top < 0:
        return
    _flex_align_fixup(top)
    if flex_max_bot[top] > cast[int32](cur_row):
        cur_row = cast[uint64](flex_max_bot[top])
    flex_sp = flex_sp - 1
    pen_x = indent_x
    row_dirty = 0


# ---- CSS inline-block (inline-level box flow) -------------------------------
# Void (self-closing) tags never open a nesting scope; used by the inline-block
# text measurer so its depth counter is not thrown off by <br>/<img>/<input>.
def _is_void_name(a: uint64, n: uint64) -> int32:
    if _hx_name_eq(a, n, cast[Ptr[uint8]]("br")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("hr")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("img")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("input")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("meta")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("link")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("area")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("col")) != 0:
        return 1
    return 0


# Which tags get inline-block INLINE-FLOW treatment (a chip/badge/button/pill)
# rather than the generic block-box blockification. Restricted to inline-level
# and neutral containers; dedicated block machinery (tables/lists/headings/
# forms/pre) keeps its own layout even under `display:inline-block`.
def _inlb_tag(a: uint64, n: uint64) -> int32:
    if _hx_name_eq(a, n, cast[Ptr[uint8]]("span")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("font")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("a")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("small")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("b")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("strong")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("em")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("i")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("label")) != 0 or \
       _hx_name_eq(a, n, cast[Ptr[uint8]]("div")) != 0:
        return 1
    return 0


# Collapsed visible-text width (px, CELL_W grid) of an inline-block element whose
# content starts at `after` (just past its opening '>'), stopping at the element's
# matching close tag. Interior whitespace collapses to one space; leading/trailing
# space is dropped. Nested tag structure is skipped (only its text counts).
def _inlb_text_w(after: uint64) -> int32:
    depth: int32 = 0
    chars: int32 = 0
    pend: int32 = 0
    i: uint64 = after
    while i < src_len:
        c: uint8 = src_ptr[i]
        if c == 60:                                  # '<'
            j: uint64 = i + 1
            closing: int32 = 0
            if j < src_len and src_ptr[j] == 47:     # '/'
                closing = 1
                j = j + 1
            ns: uint64 = j
            while j < src_len and _alnum_at(j) != 0:
                j = j + 1
            k: uint64 = j
            while k < src_len and src_ptr[k] != 62:  # '>'
                k = k + 1
            selfclose: int32 = 0
            if k > 0 and src_ptr[k - 1] == 47:
                selfclose = 1
            if closing != 0:
                if depth == 0:
                    return chars * CELL_W             # this element's own close
                depth = depth - 1
            else:
                if selfclose == 0 and _is_void_name(ns, j) == 0:
                    depth = depth + 1
            if k < src_len:
                i = k + 1
            else:
                i = k
            continue
        if c == 32 or c == 9 or c == 10 or c == 13:
            if chars > 0:
                pend = 1
        else:
            if pend != 0:
                chars = chars + 1
                pend = 0
            chars = chars + 1
        i = i + 1
    return chars * CELL_W


# Open an inline-block chip: place any pending text, wrap the whole box to a
# fresh line if it would overflow, push the element's style, paint the box's
# background FILL, then inset the pen by the left padding so its text flows
# inside the box. The chip's own text streams normally into the following segs.
def _inlb_open(ne: uint64, te: uint64, np: uint64, nlen: uint64):
    _word_flush()
    _close_seg()
    tw: int32 = _inlb_text_w(te + 1)
    boxw: int32 = tw + 2 * INLB_PADX
    right: int32 = _flow_right()
    # Wrap the whole chip to the next line if it does not fit after current flow.
    if pen_x > indent_x and pen_x + boxw > right:
        _bump_row()
        _maybe_clear_float()
        pen_x = indent_x
        row_dirty = 0
        need_space = 0
    _open_style(ne, te)                              # pushes colour + background
    _recompute_style()
    startx: int32 = pen_x
    row0: int32 = cast[int32](cur_row)
    # Vertical box growth: honour top+bottom padding (the badge/button/pill idiom)
    # so a chip is a real BOX, not one text-line tall. The resolved cascade/inline
    # top+bottom insets (m_mt/m_mb, d_mt/d_mb overriding) grow the box; the single
    # text line is centred within it and the box reserves the extra whole rows so
    # following content clears it. One-row chips (no vertical padding) are byte-
    # identical to before: boxrows stays 1 and every guard below short-circuits.
    padt: int32 = 0
    if m_mt > 0:
        padt = m_mt
    if d_mt > 0:
        padt = d_mt
    padb: int32 = 0
    if m_mb > 0:
        padb = m_mb
    if d_mb > 0:
        padb = d_mb
    boxrows: int32 = 1
    chip_yoff: int32 = 0
    # ROUND-3 CSS vertical-align on an inline-block: pick where the single text
    # line sits inside a TALL chip. middle/baseline/unset keep the byte-identical
    # centring; `top` pins it to the first row, `bottom` to the last row (a whole-
    # row drop, observable in the segment's line). Only bites when boxrows > 1.
    eff_va: int32 = m_valign
    if d_valign != 0:
        eff_va = d_valign
    va_rowshift: int32 = 0
    if padt + padb > 0:
        boxh: int32 = LINE_H + padt + padb
        boxrows = (boxh + LINE_H - 1) / LINE_H
        if boxrows > 8:
            boxrows = 8
        if eff_va == 2:                              # top
            chip_yoff = 0
        elif eff_va == 4:                            # bottom
            chip_yoff = 0
            va_rowshift = boxrows - 1
        else:                                        # middle / baseline / unset
            chip_yoff = (boxrows - 1) * LINE_H / 2   # centre the text line
    if inlb_sp < INLB_MAX:
        inlb_startx[inlb_sp]  = startx
        inlb_boxw[inlb_sp]    = boxw
        inlb_row[inlb_sp]     = row0
        inlb_eldepth[inlb_sp] = el_sp
        inlb_yoff[inlb_sp]    = chip_yoff
        inlb_vashift[inlb_sp] = va_rowshift
        inlb_sp = inlb_sp + 1
    # A tall chip reserves the rows below it: the next line break snaps past them.
    if boxrows > 1 and row0 + boxrows > g_inlb_floor:
        g_inlb_floor = row0 + boxrows
    # Paint the chip box (a narrow FILL over exactly its box, boxrows tall).
    if g_bg >= 0 and n_bfills < BFILL_MAX and row0 < MAX_ROWS:
        bfill_lx[n_bfills]  = startx
        bfill_rx[n_bfills]  = startx + boxw
        bfill_top[n_bfills] = row0
        bfill_bot[n_bfills] = row0 + boxrows
        bfill_rgb[n_bfills] = g_bg
        bfill_z[n_bfills]   = 0
        n_bfills = n_bfills + 1
    # Drop the text baseline to the vertical centre of a tall box.
    g_yoff = g_yoff + chip_yoff
    # vertical-align:bottom drops the text line to the chip's LAST row (the fill
    # already spans every row, so the box is unchanged — only the glyph row moves).
    if va_rowshift > 0:
        cur_row = cast[uint64](row0 + va_rowshift)
    # A chip that is an <a> keeps its href + own link colour (clickable pill).
    if _hx_name_eq(np, nlen, cast[Ptr[uint8]]("a")) != 0:
        g_link = _capture_href(ne, te)
        g_link_rgb = _own_color(ne, te)
        _recompute_style()
    pen_x = startx + INLB_PADX
    need_space = 0
    row_dirty = 1


# Close an inline-block chip: snap the pen to the box's right edge + gutter so
# the next inline content flows after it, then pop the element's style.
def _inlb_close(np: uint64, nlen: uint64):
    _word_flush()
    _close_seg()
    if inlb_sp > 0:
        inlb_sp = inlb_sp - 1
        pen_x = inlb_startx[inlb_sp] + inlb_boxw[inlb_sp] + INLB_GAP
        g_yoff = g_yoff - inlb_yoff[inlb_sp]         # undo the tall-chip centring
        # vertical-align:bottom dropped the text to a lower row; snap the flow
        # cursor back to the chip's baseline row so following inline content
        # continues on the line, not on the chip's last row.
        if inlb_vashift[inlb_sp] > 0:
            cur_row = cast[uint64](inlb_row[inlb_sp])
    if _hx_name_eq(np, nlen, cast[Ptr[uint8]]("a")) != 0:
        g_link = -1
        g_link_rgb = -1
    _close_style()
    _recompute_style()
    need_space = 0
    row_dirty = 1


# The right edge the current flow wraps against: a table cell clamps to its
# column, everything else to the content area.
def _flow_right() -> int32:
    r: int32 = _content_right()
    # A block width / right margin / padding shrinks the wrap boundary.
    if blk_right_cur > 0 and blk_right_cur < r:
        r = blk_right_cur
    # A right-floated box excludes its column: body text wraps to its left for
    # every row above the float's bottom.
    if floatR_active != 0 and \
       cast[int32](cur_row) < floatR_bottom and float_redge < r:
        if float_redge > indent_x + CELL_W:
            r = float_redge
    if cell_active != 0:
        cr: int32 = cell_right
        if cr > r:
            cr = r
        if cr < indent_x + CELL_W:
            cr = indent_x + CELL_W
        return cr
    return r


# ---- PIXEL-MEASURE line-break hook ----------------------------------
# The engine stays PURE (no font/htmlpaint import): the pixel front-end
# registers a callback that returns the real TrueType advance width (px) of the
# pending run, so the line-breaker can wrap prose to the true viewport measure
# instead of the 8px monospace CHARACTER GRID. When NO hook is registered the
# breaker falls back to CELL_W cells, so the legacy monospace-grid dump
# (user/hambrowse_host.ad) stays byte-for-byte identical. The hook reads the
# pending run through the he_meas_* accessors below (same globals-passing seam
# jsengine uses for host dispatch — Adder has no multi-arg Fn convention here).
#
# GRID segments (tables + <pre>) always use CELL_W so their absolute columns
# survive regardless of the hook — real reflow is prose-only.
he_meas_set:  int32 = 0
he_meas_addr: uint64 = 0
he_meas_face: uint8 = 0
he_meas_bold: int32 = 0
he_meas_px:   int32 = 0
he_meas_txt:  Ptr[uint8] = 0
he_meas_len:  int32 = 0
_he_sp_buf:   Array[1, uint8]        # one-space scratch for space-advance query


def he_set_measure_hook(fn: Fn[int32, int32]):
    he_meas_addr = cast[uint64](fn)
    he_meas_set = 1


def he_clear_measure_hook():
    he_meas_set = 0


# Accessors the registered hook reads to learn the pending run + its style.
def he_meas_face_get() -> uint8:
    return he_meas_face


def he_meas_bold_get() -> int32:
    return he_meas_bold


def he_meas_px_get() -> int32:
    return he_meas_px


def he_meas_txt_get() -> Ptr[uint8]:
    return he_meas_txt


def he_meas_len_get() -> int32:
    return he_meas_len


# Pixel width of a run in the CURRENT inline style. Falls back to CELL_W cells
# when no hook is set OR the run is grid-positioned (table/<pre>), so those keep
# their absolute char-grid columns.
def _run_px(ptr: Ptr[uint8], ln: uint64) -> int32:
    if he_meas_set == 0 or table_active != 0 or pre_mode != 0 or ln == 0:
        return cast[int32](ln) * CELL_W
    he_meas_face = _cur_face()
    he_meas_bold = g_bold
    he_meas_px   = g_font_px
    he_meas_txt  = ptr
    he_meas_len  = cast[int32](ln)
    hf: Fn[int32, int32] = cast[Fn[int32, int32]](he_meas_addr)
    w: int32 = hf(0)
    if w < 1:
        w = 1
    return w


# Pixel advance of a single inter-word space in the current style.
def _space_px() -> int32:
    if he_meas_set == 0 or table_active != 0 or pre_mode != 0:
        return CELL_W
    _he_sp_buf[0] = 32
    return _run_px(&_he_sp_buf[0], 1)


# ---- word placement (block+inline flow with word wrap) --------------
def _emit_word(wptr: Ptr[uint8], wlen: uint64):
    if wlen == 0:
        return
    # ROUND-3 text-indent: inset the FIRST line of the armed block. Apply once, at
    # the head of the opening line (nothing placed yet), then disarm so wrapped
    # continuation lines and following blocks are not indented.
    if g_tindent_pending != 0 and pen_x <= indent_x and row_dirty == 0:
        pen_x = indent_x + g_tindent_pending
        g_tindent_pending = 0
    right: int32 = _flow_right()
    avail: int32 = right - indent_x
    wpx: int32 = _run_px(wptr, wlen)
    spx: int32 = _space_px()
    # CSS white-space:nowrap / white-space:pre (g_ws 1 / 2) suppress ALL soft
    # wrapping — the line runs past the measure and overflows. (The <pre>/<code>
    # ELEMENT keeps its own grid path; this only fires for the CSS property.)
    ws_nowrap: int32 = 0
    if g_ws == 1 or g_ws == 2:
        ws_nowrap = 1
    # A natural-path flex item's track is content-sized (max-content); its text is
    # not meant to wrap, so treat it as nowrap — a proportional link wider than the
    # monospace track estimate stays on one line instead of splitting between its
    # words ("Log in" -> "Log"/"in").
    if g_flex_nowrap_depth > 0:
        ws_nowrap = 1
    # Decide a word-wrap (only when the word fits on a fresh line).
    if pen_x > indent_x and ws_nowrap == 0:
        extra: int32 = wpx
        if need_space != 0:
            extra = extra + spx
        if pen_x + extra > right and wpx <= avail:
            _close_seg()
            _bump_row()
            _maybe_clear_float()
            right = _flow_right()
            avail = right - indent_x
            pen_x = indent_x
            need_space = 0
            row_dirty = 0
    # Inter-word space.
    if need_space != 0 and pen_x > indent_x:
        _seg_putc(32)
        pen_x = pen_x + spx
        need_space = 0
    # A word longer than a whole line: hard char-break it (measured per glyph).
    # Suppressed under nowrap/pre — the run must overflow the measure intact.
    # ALSO suppressed inside a flex item: a flex item's automatic minimum size is
    # min-content, so its track must not shrink below the widest word — an
    # over-wide word stays intact (overflows the track) rather than splitting
    # mid-run. The track width was estimated on the CELL_W monospace grid at
    # container-open; under the proportional measure hook the real word can exceed
    # it, which pre-fix char-broke brand/nav text ("Nimbus" -> "Nim"/"bus").
    if wpx > avail and ws_nowrap == 0 and g_flex_item_depth == 0:
        k: uint64 = 0
        while k < wlen:
            cpx: int32 = _run_px(&wptr[k], 1)
            if pen_x + cpx > right and pen_x > indent_x:
                _close_seg()
                _bump_row()
                _maybe_clear_float()
                right = _flow_right()
                pen_x = indent_x
                row_dirty = 0
            _seg_putc(wptr[k])
            pen_x = pen_x + cpx
            k = k + 1
        need_space = 0
        return
    # Normal: whole word into the current segment.
    k2: uint64 = 0
    while k2 < wlen:
        _seg_putc(wptr[k2])
        k2 = k2 + 1
    pen_x = pen_x + wpx
    need_space = 0


def _word_push(c: uint8):
    if word_len < WORD_CAP - 1:
        word_buf[word_len] = c
        word_len = word_len + 1


def _word_flush():
    if word_len > 0:
        _emit_word(&word_buf[0], word_len)
        word_len = 0


# ====================================================================
# GENERATED CONTENT — CSS ::before / ::after (W3C conformance round 4).
#
# The cascade (lib/web/css/cascade.ad) recognises ::before/::after selectors
# but marks them INERT (pseudo code 10) and does not retain the `content`
# value, so generated inline content is produced entirely here on the LAYOUT
# side. Supported subset:
#   content:"string"   — emit the literal string as an inline box
#   content:attr(x)    — emit the element's `x` attribute value
#   content:""         — empty inline box (clearfix/spacing; emits nothing
#                        visible but consumes the declaration)
# The pseudo-element's own color / font-weight (bold, >=600) / font-size (px)
# cascade onto the generated box. DEFERRED (noted): counters (counter()),
# content:url() images, quotes/open-quote, combinator/descendant selectors
# (only a single subject compound tag/.class/#id/[attr] is matched), and
# ::before/::after nested inside @media (those blocks are skipped).
#
# Selector matching + the raw `content` value both need the stylesheet text,
# which the cascade splits across two places: inline <style> blocks (parsed
# straight from the page source) and external <link> sheets (he_css_buf). We
# concatenate BOTH into gc_css once per layout (_gc_collect_css, called from
# flow.ad::_layout) so the rest of this code scans one uniform buffer.
# ====================================================================
GC_CAP:     uint64 = 1024
GC_CSS_CAP: uint64 = 262144
GC_AF_MAX:  int32  = 64
GC_AF_TCAP: int32  = 8192

gc_css:     Array[262144, uint8]
gc_css_len: uint64 = 0
gc_buf:     Array[1024, uint8]     # scratch for one built content string
gc_len:     uint64 = 0
gc_name:    Array[128, uint8]      # scratch attr-name C string
# -1 unknown / 0 none present / 1 present. Reset per layout in _gc_collect_css.
gc_present: int32 = -1
# body span (offsets into gc_css) of the LAST matching rule found by _gc_find_rule.
gc_fbs:     uint64 = 0
gc_fbe:     uint64 = 0
# ::after content is resolved at element OPEN (attributes are on the open tag,
# not the </close> tag) and stashed keyed by el-stack depth, then emitted at
# close in _gencontent_close.
gc_af_eldepth: Array[64, int32]
gc_af_off:     Array[64, int32]
gc_af_len:     Array[64, int32]
gc_af_col:     Array[64, int32]
gc_af_bold:    Array[64, int32]
gc_af_px:      Array[64, int32]
gc_af_sp:      int32 = 0
gc_af_text:    Array[8192, uint8]
gc_af_tlen:    int32 = 0


def _gc_is_ws(c: uint8) -> int32:
    if c == 32 or c == 9 or c == 10 or c == 13:
        return 1
    return 0


def _gc_is_namestart(c: uint8) -> int32:
    if (c >= 97 and c <= 122) or (c >= 65 and c <= 90) or c == 95 or c == 45:
        return 1
    return 0


def _gc_is_namechar(c: uint8) -> int32:
    if _gc_is_namestart(c) != 0 or (c >= 48 and c <= 57):
        return 1
    return 0


# src_ptr[at..) begins with lowercase page-source tag literal (ci) at a name
# boundary? (used to find <style>/</style> in the page source).
def _gc_srctag_is(at: uint64, lit: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while lit[i] != 0:
        if at + i >= src_len:
            return 0
        if _hx_lower(src_ptr[at + i]) != lit[i]:
            return 0
        i = i + 1
    c: uint8 = src_ptr[at + i]
    if (c >= 97 and c <= 122) or (c >= 65 and c <= 90) or (c >= 48 and c <= 57):
        return 0
    return 1


def _gc_css_put(c: uint8):
    if gc_css_len < GC_CSS_CAP - 1:
        gc_css[gc_css_len] = c
        gc_css_len = gc_css_len + 1


# Concatenate every stylesheet source (inline <style> bodies + external
# he_css_buf) into gc_css. Called once per layout from flow.ad::_layout.
def _gc_collect_css():
    gc_css_len = 0
    gc_present = -1
    gc_af_sp = 0
    gc_af_tlen = 0
    i: uint64 = 0
    while i < src_len:
        if src_ptr[i] == 60 and _gc_srctag_is(i + 1, cast[Ptr[uint8]]("style")) != 0:
            j: uint64 = i + 1
            while j < src_len and src_ptr[j] != 62:      # end of opening tag
                j = j + 1
            if j < src_len:
                j = j + 1
            body: uint64 = j
            e: uint64 = body
            while e < src_len:
                if src_ptr[e] == 60 and e + 1 < src_len and src_ptr[e + 1] == 47 and \
                   _gc_srctag_is(e + 2, cast[Ptr[uint8]]("style")) != 0:
                    break
                e = e + 1
            p: uint64 = body
            while p < e:
                _gc_css_put(src_ptr[p])
                p = p + 1
            _gc_css_put(10)                              # separator newline
            i = e
            continue
        i = i + 1
    k: uint64 = 0
    while k < he_css_len:
        _gc_css_put(he_css_buf[k])
        k = k + 1
    # Strip /* … */ comments in place so their text can't pollute selectors.
    r: uint64 = 0
    w: uint64 = 0
    while r < gc_css_len:
        if gc_css[r] == 47 and r + 1 < gc_css_len and gc_css[r + 1] == 42:   # '/*'
            r = r + 2
            while r + 1 < gc_css_len:
                if gc_css[r] == 42 and gc_css[r + 1] == 47:                  # '*/'
                    break
                r = r + 1
            r = r + 2
        else:
            gc_css[w] = gc_css[r]
            w = w + 1
            r = r + 1
    gc_css_len = w


# gc_css[a..) starts with lowercase literal `lit` (ci)?
def _gc_kw(a: uint64, b: uint64, lit: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while lit[i] != 0:
        if a + i >= b:
            return 0
        if _hx_lower(gc_css[a + i]) != lit[i]:
            return 0
        i = i + 1
    return 1


# gc_css[a..a+n) == src_ptr[s..s+n) case-insensitively (tag names).
def _gc_ci_eq_src(a: uint64, n: uint64, s: uint64, slen: uint64) -> int32:
    if n != slen:
        return 0
    k: uint64 = 0
    while k < n:
        if _hx_lower(gc_css[a + k]) != _hx_lower(src_ptr[s + k]):
            return 0
        k = k + 1
    return 1


# gc_css[a..a+n) == src_ptr[s..s+n) exactly (class / id tokens are case-sensitive).
def _gc_eq_src(a: uint64, n: uint64, s: uint64) -> int32:
    k: uint64 = 0
    while k < n:
        if gc_css[a + k] != src_ptr[s + k]:
            return 0
        k = k + 1
    return 1


def _gc_put(c: uint8):
    if gc_len < GC_CAP - 1:
        gc_buf[gc_len] = c
        gc_len = gc_len + 1


# Does the current element (tag body ne..te) carry class token gc_css[s..e)?
def _gc_el_has_class(s: uint64, e: uint64, ne: uint64, te: uint64) -> int32:
    if e <= s:
        return 0
    if _hx_find_attr(ne, te, cast[Ptr[uint8]]("class")) == 0:
        return 0
    tlen: uint64 = e - s
    p: uint64 = g_attr_start
    while p < g_attr_end:
        while p < g_attr_end and _gc_is_ws(src_ptr[p]) != 0:
            p = p + 1
        w0: uint64 = p
        while p < g_attr_end and _gc_is_ws(src_ptr[p]) == 0:
            p = p + 1
        if p - w0 == tlen and _gc_eq_src(s, tlen, w0) != 0:
            return 1
    return 0


def _gc_el_id_is(s: uint64, e: uint64, ne: uint64, te: uint64) -> int32:
    if e <= s:
        return 0
    if _hx_find_attr(ne, te, cast[Ptr[uint8]]("id")) == 0:
        return 0
    if g_attr_end - g_attr_start != e - s:
        return 0
    return _gc_eq_src(s, e - s, g_attr_start)


# Copy gc_css[s..e) lowercased into gc_name (C string); does the element carry
# that attribute? Also leaves g_attr_start/g_attr_end set to its value span.
def _gc_el_has_attr(s: uint64, e: uint64, ne: uint64, te: uint64) -> int32:
    n: uint64 = 0
    i: uint64 = s
    while i < e and n < 126:
        gc_name[n] = _hx_lower(gc_css[i])
        n = n + 1
        i = i + 1
    gc_name[n] = 0
    if n == 0:
        return 0
    if _hx_find_attr(ne, te, &gc_name[0]) != 0:
        return 1
    return 0


# Match a single subject compound gc_css[cs..ce) (tag / .class / #id / [attr])
# against the element (tag src_ptr[np..np+nlen), body ne..te). Any unsupported
# byte (combinator/space) fails the match => the rule is safely deferred.
def _gc_compound_matches(cs: uint64, ce: uint64, np: uint64, nlen: uint64, \
                         ne: uint64, te: uint64) -> int32:
    i: uint64 = cs
    if i < ce and gc_css[i] == 42:                       # '*' universal
        i = i + 1
    elif i < ce and _gc_is_namestart(gc_css[i]) != 0:
        t0: uint64 = i
        while i < ce and _gc_is_namechar(gc_css[i]) != 0:
            i = i + 1
        if _gc_ci_eq_src(t0, i - t0, np, nlen) == 0:
            return 0
    while i < ce:
        c: uint8 = gc_css[i]
        if c == 46:                                      # '.' class
            i = i + 1
            s0: uint64 = i
            while i < ce and _gc_is_namechar(gc_css[i]) != 0:
                i = i + 1
            if _gc_el_has_class(s0, i, ne, te) == 0:
                return 0
        elif c == 35:                                    # '#' id
            i = i + 1
            s1: uint64 = i
            while i < ce and _gc_is_namechar(gc_css[i]) != 0:
                i = i + 1
            if _gc_el_id_is(s1, i, ne, te) == 0:
                return 0
        elif c == 91:                                    # '[' attr-presence
            i = i + 1
            s2: uint64 = i
            while i < ce and gc_css[i] != 93 and gc_css[i] != 61:
                i = i + 1
            aend: uint64 = i
            hasval: int32 = 0
            while i < ce and gc_css[i] != 93:
                if gc_css[i] == 61:
                    hasval = 1
                i = i + 1
            if i < ce:
                i = i + 1                                 # past ']'
            if hasval != 0:
                return 0                                 # [a=v] deferred
            if _gc_el_has_attr(s2, aend, ne, te) == 0:
                return 0
        else:
            return 0
    return 1


# gc_css[p..e) is exactly `[::]before` -> 1, `[::]after` -> 2, else 0.
def _gc_pseudo_side(p: uint64, e: uint64) -> int32:
    q: uint64 = p
    if q < e and gc_css[q] == 58:
        q = q + 1
    if q < e and gc_css[q] == 58:
        q = q + 1
    side: int32 = 0
    if _gc_kw(q, e, cast[Ptr[uint8]]("before")) != 0:
        side = 1
        q = q + 6
    elif _gc_kw(q, e, cast[Ptr[uint8]]("after")) != 0:
        side = 2
        q = q + 5
    else:
        return 0
    if q < e:                                            # trailing junk => reject
        return 0
    return side


# Does a single selector gc_css[s..e) target this element with the wanted
# pseudo (side 0 => ::before, else ::after)?
def _gc_selector_matches(s: uint64, e: uint64, np: uint64, nlen: uint64, \
                         ne: uint64, te: uint64, side: int32) -> int32:
    while s < e and _gc_is_ws(gc_css[s]) != 0:
        s = s + 1
    while e > s and _gc_is_ws(gc_css[e - 1]) != 0:
        e = e - 1
    if s >= e:
        return 0
    p: uint64 = s
    while p < e and gc_css[p] != 58:                     # first ':'
        p = p + 1
    if p >= e:
        return 0                                         # no pseudo => not ours
    want: int32 = 1
    if side != 0:
        want = 2
    if _gc_pseudo_side(p, e) != want:
        return 0
    ce: uint64 = p
    while ce > s and _gc_is_ws(gc_css[ce - 1]) != 0:
        ce = ce - 1
    if ce <= s:
        return 1                                         # bare ::before => any el
    return _gc_compound_matches(s, ce, np, nlen, ne, te)


# Selector list gc_css[ss..se): match any comma-separated selector.
def _gc_sel_list_matches(ss: uint64, se: uint64, np: uint64, nlen: uint64, \
                         ne: uint64, te: uint64, side: int32) -> int32:
    a: uint64 = ss
    i: uint64 = ss
    while i < se:
        if gc_css[i] == 44:                              # ','
            if _gc_selector_matches(a, i, np, nlen, ne, te, side) != 0:
                return 1
            a = i + 1
        i = i + 1
    if _gc_selector_matches(a, se, np, nlen, ne, te, side) != 0:
        return 1
    return 0


# Parse a `content:` VALUE at gc_css[j..be) into gc_buf. Returns 1 when a
# generated box is produced (string/attr/empty), 0 for none/normal/url (no box).
def _gc_parse_value(j: uint64, be: uint64, ne: uint64, te: uint64) -> int32:
    while j < be and _gc_is_ws(gc_css[j]) != 0:
        j = j + 1
    if j >= be:
        return 0
    c: uint8 = gc_css[j]
    if c == 34 or c == 39:                               # "…" / '…'
        q: uint8 = c
        j = j + 1
        while j < be and gc_css[j] != q:
            if gc_css[j] == 92 and j + 1 < be:           # backslash escape
                j = j + 1
                _gc_put(gc_css[j])
            else:
                _gc_put(gc_css[j])
            j = j + 1
        return 1
    if _gc_kw(j, be, cast[Ptr[uint8]]("attr(")) != 0:
        j = j + 5
        while j < be and _gc_is_ws(gc_css[j]) != 0:
            j = j + 1
        ns: uint64 = j
        while j < be and gc_css[j] != 41 and gc_css[j] != 44 and \
              _gc_is_ws(gc_css[j]) == 0:
            j = j + 1
        n: uint64 = 0
        kk: uint64 = ns
        while kk < j and n < 126:
            gc_name[n] = _hx_lower(gc_css[kk])
            n = n + 1
            kk = kk + 1
        gc_name[n] = 0
        if n > 0 and _hx_find_attr(ne, te, &gc_name[0]) != 0:
            p: uint64 = g_attr_start
            while p < g_attr_end:
                _gc_put(src_ptr[p])
                p = p + 1
        return 1                                         # missing attr => empty box
    if _gc_kw(j, be, cast[Ptr[uint8]]("none")) != 0:
        return 0
    if _gc_kw(j, be, cast[Ptr[uint8]]("normal")) != 0:
        return 0
    if _gc_kw(j, be, cast[Ptr[uint8]]("url(")) != 0:
        return 0                                         # image content deferred
    return 0


# Find the `content` declaration in body gc_css[bs..be) and build gc_buf.
def _gc_build(bs: uint64, be: uint64, ne: uint64, te: uint64) -> int32:
    gc_len = 0
    i: uint64 = bs
    while i < be:
        prev: int32 = 0
        if i > bs:
            pc: uint8 = _hx_lower(gc_css[i - 1])
            if (pc >= 97 and pc <= 122) or pc == 45:
                prev = 1
        if prev == 0 and _gc_kw(i, be, cast[Ptr[uint8]]("content")) != 0:
            j: uint64 = i + 7
            endok: int32 = 1
            if j < be:
                nc: uint8 = _hx_lower(gc_css[j])
                if (nc >= 97 and nc <= 122) or nc == 45:  # content-visibility etc.
                    endok = 0
            if endok != 0:
                while j < be and _gc_is_ws(gc_css[j]) != 0:
                    j = j + 1
                if j < be and gc_css[j] == 58:
                    return _gc_parse_value(j + 1, be, ne, te)
        i = i + 1
    return 0


# font-weight in body => bold? (bold/bolder or numeric >= 600).
def _gc_body_bold(bs: uint64, be: uint64) -> int32:
    i: uint64 = bs
    while i < be:
        prev: int32 = 0
        if i > bs:
            pc: uint8 = _hx_lower(gc_css[i - 1])
            if (pc >= 97 and pc <= 122) or pc == 45:
                prev = 1
        if prev == 0 and _gc_kw(i, be, cast[Ptr[uint8]]("font-weight")) != 0:
            j: uint64 = i + 11
            while j < be and (_gc_is_ws(gc_css[j]) != 0 or gc_css[j] == 58):
                j = j + 1
            if j < be:
                v: uint8 = _hx_lower(gc_css[j])
                if v == 98:                              # 'b' bold/bolder
                    return 1
                if v >= 54 and v <= 57:                  # 600..900
                    return 1
            return 0
        i = i + 1
    return 0


# font-size:Npx in body => N (px), else -1.
def _gc_body_px(bs: uint64, be: uint64) -> int32:
    i: uint64 = bs
    while i < be:
        prev: int32 = 0
        if i > bs:
            pc: uint8 = _hx_lower(gc_css[i - 1])
            if (pc >= 97 and pc <= 122) or pc == 45:
                prev = 1
        if prev == 0 and _gc_kw(i, be, cast[Ptr[uint8]]("font-size")) != 0:
            j: uint64 = i + 9
            while j < be and (_gc_is_ws(gc_css[j]) != 0 or gc_css[j] == 58):
                j = j + 1
            v: int32 = 0
            has: int32 = 0
            while j < be and gc_css[j] >= 48 and gc_css[j] <= 57:
                v = v * 10 + cast[int32](gc_css[j] - 48)
                has = 1
                j = j + 1
            if has != 0 and _gc_kw(j, be, cast[Ptr[uint8]]("px")) != 0:
                return v
            return 0 - 1
        i = i + 1
    return 0 - 1


def _gc_word(c: uint8):
    _word_push(c)


# Emit `ln` bytes at ptr[0..ln) as inline words carrying the pseudo's style.
def _gc_emit_run(ptr: Ptr[uint8], ln: uint64, pcol: int32, pbold: int32, ppx: int32):
    _word_flush()
    _close_seg()
    save_bold: int32 = g_bold
    save_px:   int32 = g_font_px
    save_lrgb: int32 = g_link_rgb
    pushed: int32 = 0
    if pcol >= 0:
        _color_push(pcol)
        pushed = 1
        # Generated content inside an <a> keeps the link's clickable identity but
        # the pseudo's own `color` overrides the link role colour.
        if g_link >= 0:
            g_link_rgb = pcol
    if pbold != 0:
        g_bold = 1
    if ppx > 0:
        g_font_px = ppx
    k: uint64 = 0
    while k < ln:
        c: uint8 = ptr[k]
        if _gc_is_ws(c) != 0:
            _word_flush()
            need_space = 1
        else:
            _gc_word(c)
        k = k + 1
    _word_flush()
    _close_seg()
    if pushed != 0:
        _color_pop()
    g_bold = save_bold
    g_font_px = save_px
    g_link_rgb = save_lrgb


# Pseudo colour: reuse the CSS colour parser, pointed at the gc_css body span.
def _gc_body_color(bs: uint64, be: uint64) -> int32:
    sp: Ptr[uint8] = src_ptr
    sl: uint64 = src_len
    src_ptr = &gc_css[0]
    src_len = gc_css_len
    pcol: int32 = _tag_color(bs, be)
    src_ptr = sp
    src_len = sl
    return pcol


# Render a matched rule's content immediately (::before path).
def _gc_render(bs: uint64, be: uint64, ne: uint64, te: uint64):
    if _gc_build(bs, be, ne, te) == 0:
        return
    pcol: int32  = _gc_body_color(bs, be)
    pbold: int32 = _gc_body_bold(bs, be)
    ppx: int32   = _gc_body_px(bs, be)
    _gc_emit_run(&gc_buf[0], gc_len, pcol, pbold, ppx)


# Stash a matched ::after rule's content (built now, emitted at close).
def _gc_stash_after(bs: uint64, be: uint64, ne: uint64, te: uint64):
    if gc_af_sp >= GC_AF_MAX:
        return
    if _gc_build(bs, be, ne, te) == 0:
        return
    if gc_af_tlen + cast[int32](gc_len) >= GC_AF_TCAP:
        return
    off: int32 = gc_af_tlen
    k: uint64 = 0
    while k < gc_len:
        gc_af_text[off + cast[int32](k)] = gc_buf[k]
        k = k + 1
    gc_af_tlen = off + cast[int32](gc_len)
    gc_af_eldepth[gc_af_sp] = el_sp
    gc_af_off[gc_af_sp]     = off
    gc_af_len[gc_af_sp]     = cast[int32](gc_len)
    gc_af_col[gc_af_sp]     = _gc_body_color(bs, be)
    gc_af_bold[gc_af_sp]    = _gc_body_bold(bs, be)
    gc_af_px[gc_af_sp]      = _gc_body_px(bs, be)
    gc_af_sp = gc_af_sp + 1


# Skip an @-rule (@import …; or @media { … } with nested braces).
def _gc_skip_atrule(i: uint64) -> uint64:
    while i < gc_css_len and gc_css[i] != 123 and gc_css[i] != 59:
        i = i + 1
    if i >= gc_css_len:
        return i
    if gc_css[i] == 59:
        return i + 1
    depth: int32 = 0
    while i < gc_css_len:
        c: uint8 = gc_css[i]
        if c == 123:
            depth = depth + 1
        elif c == 125:
            depth = depth - 1
            if depth == 0:
                return i + 1
        i = i + 1
    return i


# Locate the LAST rule matching this element+side; sets gc_fbs/gc_fbe. Returns 1/0.
def _gc_find_rule(np: uint64, nlen: uint64, ne: uint64, te: uint64, side: int32) -> int32:
    found: int32 = 0
    i: uint64 = 0
    while i < gc_css_len:
        while i < gc_css_len and _gc_is_ws(gc_css[i]) != 0:
            i = i + 1
        if i >= gc_css_len:
            break
        if gc_css[i] == 64:                              # '@' at-rule: skip block
            i = _gc_skip_atrule(i)
            continue
        if gc_css[i] == 125:                             # stray '}'
            i = i + 1
            continue
        ss: uint64 = i
        while i < gc_css_len and gc_css[i] != 123 and gc_css[i] != 125:
            i = i + 1
        if i >= gc_css_len or gc_css[i] != 123:
            break
        se: uint64 = i
        i = i + 1
        bs: uint64 = i
        while i < gc_css_len and gc_css[i] != 125:
            i = i + 1
        be: uint64 = i
        if i < gc_css_len:
            i = i + 1
        if _gc_sel_list_matches(ss, se, np, nlen, ne, te, side) != 0:
            found = 1
            gc_fbs = bs
            gc_fbe = be
    return found


# Does the sheet contain any :before / :after pseudo-element? (one-shot cache).
def _gc_scan_present() -> int32:
    i: uint64 = 0
    while i < gc_css_len:
        if gc_css[i] == 58:                              # ':'
            q: uint64 = i + 1
            if q < gc_css_len and gc_css[q] == 58:
                q = q + 1
            if _gc_kw(q, gc_css_len, cast[Ptr[uint8]]("before")) != 0:
                return 1
            if _gc_kw(q, gc_css_len, cast[Ptr[uint8]]("after")) != 0:
                return 1
        i = i + 1
    return 0


# Element OPEN hook: emit ::before now; resolve+stash ::after for the close.
# (np,nlen)=tag name span, (ne,te)=attribute span, el_sp already incremented.
def _gencontent_open(np: uint64, nlen: uint64, ne: uint64, te: uint64):
    if gc_css_len == 0:
        return
    if gc_present == 0:
        return
    if gc_present < 0:
        gc_present = _gc_scan_present()
        if gc_present == 0:
            return
    if _gc_find_rule(np, nlen, ne, te, 0) != 0:
        _gc_render(gc_fbs, gc_fbe, ne, te)
    if _gc_find_rule(np, nlen, ne, te, 1) != 0:
        _gc_stash_after(gc_fbs, gc_fbe, ne, te)


# Element CLOSE hook (before _el_pop): emit the stashed ::after content.
def _gencontent_close():
    if gc_af_sp <= 0:
        return
    top: int32 = gc_af_sp - 1
    if gc_af_eldepth[top] != el_sp:
        return
    gc_af_sp = top
    _gc_emit_run(&gc_af_text[gc_af_off[top]], cast[uint64](gc_af_len[top]), \
                 gc_af_col[top], gc_af_bold[top], gc_af_px[top])
    gc_af_tlen = gc_af_off[top]


from lib.web.html.entities import *
from lib.web.html.entities import _entity
from lib.web.css.values import *
from lib.web.css.values import _color_value, _hx_hexval, _hx_lower, _srcword_is, _tag_bgcolor, _tag_color

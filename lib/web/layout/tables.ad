# lib/web/layout/tables.ad — part of the modular web engine (extracted from htmlengine.ad).
# table two-pass column layout — natural-width measure + column computation.
#
# Behavior-preserving split (single-compilation-unit; byte-identical).

from lib.htmlengine import _close_style, _flow_right, _hx_lower, _style_break, _word_flush, g_cell_pending

# ====================================================================
# TABLE two-pass column layout.
# ====================================================================
def _alnum_at(p: uint64) -> int32:
    if p >= src_len:
        return 0
    c: uint8 = _hx_lower(src_ptr[p])
    if (c >= 97 and c <= 122) or (c >= 48 and c <= 57):
        return 1
    return 0


# Locate an attribute VALUE `name="..."` (or name='...' / name=bare) in the
# tag body [ts,te). On success sets g_attr_start/g_attr_end to the value span
# and returns 1; returns 0 if the attribute is absent.
g_attr_start: uint64 = 0
g_attr_end:   uint64 = 0


def _hx_find_attr(ts: uint64, te: uint64, name: Ptr[uint8]) -> int32:
    nl: uint64 = 0
    while name[nl] != 0:
        nl = nl + 1
    i: uint64 = ts
    while i + nl <= te:
        prev_alpha: int32 = 0
        if i > ts:
            pc: uint8 = _hx_lower(src_ptr[i - 1])
            if (pc >= 97 and pc <= 122) or (pc >= 48 and pc <= 57) or pc == 45:
                prev_alpha = 1
        if prev_alpha == 0 and _srcword_is(i, name) != 0 and \
           _alnum_at(i + nl) == 0:
            j: uint64 = i + nl
            while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
                j = j + 1
            if j < te and src_ptr[j] == 61:              # '='
                j = j + 1
                while j < te and (src_ptr[j] == 32 or src_ptr[j] == 9):
                    j = j + 1
                quote: uint8 = 0
                if j < te and (src_ptr[j] == 34 or src_ptr[j] == 39):
                    quote = src_ptr[j]
                    j = j + 1
                g_attr_start = j
                while j < te:
                    c: uint8 = src_ptr[j]
                    if quote != 0:
                        if c == quote:
                            break
                    else:
                        if c == 32 or c == 9:
                            break
                    j = j + 1
                g_attr_end = j
                return 1
        i = i + 1
    return 0


# Read an integer-valued attribute (e.g. colspan="2") from tag body [ts,te).
# Returns the parsed value, or `dflt` when absent / non-numeric / < 1.
def _attr_int(ts: uint64, te: uint64, name: Ptr[uint8], dflt: int32) -> int32:
    if _hx_find_attr(ts, te, name) == 0:
        return dflt
    v: int32 = 0
    p: uint64 = g_attr_start
    seen: int32 = 0
    while p < g_attr_end:
        d: uint8 = src_ptr[p]
        if d >= 48 and d <= 57:
            v = v * 10 + cast[int32](d - 48)
            seen = 1
        p = p + 1
    if seen == 0 or v < 1:
        return dflt
    return v


# Read a presentational `width="..."` attribute as a TABLE target width.
# Returns +px for a pixel value (width="600"), -pct for a percentage
# (width="85%" -> -85), or 0 when absent / non-numeric. The sign lets
# _compute_cols resolve a percentage against the table's available width
# (which it already knows) while a pixel value is used verbatim.
def _attr_width_val(ts: uint64, te: uint64) -> int32:
    if _hx_find_attr(ts, te, cast[Ptr[uint8]]("width")) == 0:
        return 0
    v: int32 = 0
    seen: int32 = 0
    pct: int32 = 0
    p: uint64 = g_attr_start
    while p < g_attr_end:
        d: uint8 = src_ptr[p]
        if d >= 48 and d <= 57:
            v = v * 10 + cast[int32](d - 48)
            seen = 1
        elif d == 37:                                # '%'
            pct = 1
        p = p + 1
    if seen == 0 or v < 1:
        return 0
    if pct != 0:
        return 0 - v
    return v


# A tag name at src[at] matches `lit` AND ends at a tag boundary (so "tr"
# does not match "track"). Returns 1 on a bounded match.
def _tagname_is(at: uint64, lit: Ptr[uint8]) -> int32:
    if _srcword_is(at, lit) == 0:
        return 0
    n: uint64 = 0
    while lit[n] != 0:
        n = n + 1
    if _alnum_at(at + n) != 0:
        return 0
    return 1


# Index of the '<' of the </table> that closes the table whose body begins at
# `body0` (nesting-aware). Returns src_len if unterminated.
def _table_region_end(body0: uint64) -> uint64:
    depth: int32 = 1
    i: uint64 = body0
    while i < src_len:
        if src_ptr[i] == 60:                         # '<'
            k: uint64 = i + 1
            close: int32 = 0
            if k < src_len and src_ptr[k] == 47:     # '/'
                close = 1
                k = k + 1
            if _tagname_is(k, cast[Ptr[uint8]]("table")) != 0:
                if close != 0:
                    depth = depth - 1
                    if depth == 0:
                        return i
                else:
                    depth = depth + 1
            while i < src_len and src_ptr[i] != 62:  # to '>'
                i = i + 1
            if i < src_len:
                i = i + 1
            continue
        i = i + 1
    return src_len


# Natural width (in character cells) of a table region, NESTING-AWARE and
# recursive: a cell that contains a sub-table contributes that sub-table's own
# natural width, so an outer cell's column grows wide enough to CONTAIN a nested
# table. Returns the widest row's summed cell widths — a safe containment upper
# bound; the per-column pass refines actual placement.
def _table_char_width(rgn_start: uint64, rgn_end: uint64) -> int32:
    maxrow: int32 = 0
    rowsum: int32 = 0
    cell_n: int32 = 0
    counting: int32 = 0
    pend_space: int32 = 0
    i: uint64 = rgn_start
    while i < rgn_end:
        ch: uint8 = src_ptr[i]
        if ch == 60:                                 # '<'
            k: uint64 = i + 1
            close: int32 = 0
            if k < rgn_end and src_ptr[k] == 47:
                close = 1
                k = k + 1
            tend: uint64 = k
            while tend < rgn_end and src_ptr[tend] != 62:
                tend = tend + 1
            if close == 0 and _tagname_is(k, cast[Ptr[uint8]]("table")) != 0:
                sub0: uint64 = tend
                if sub0 < rgn_end:
                    sub0 = sub0 + 1
                sube: uint64 = _table_region_end(sub0)
                w2: int32 = _table_char_width(sub0, sube)
                if w2 > cell_n:
                    cell_n = w2
                i = sube                             # resume at '<' of </table>
                continue
            is_cell: int32 = 0
            if _tagname_is(k, cast[Ptr[uint8]]("td")) != 0 or \
               _tagname_is(k, cast[Ptr[uint8]]("th")) != 0:
                is_cell = 1
            is_tr: int32 = _tagname_is(k, cast[Ptr[uint8]]("tr"))
            if is_cell != 0 or is_tr != 0:
                rowsum = rowsum + cell_n + CELL_PAD
                cell_n = 0
                counting = 0
                pend_space = 0
                if is_tr != 0 and close == 0:
                    if rowsum > maxrow:
                        maxrow = rowsum
                    rowsum = 0
                elif is_cell != 0 and close == 0:
                    counting = 1
            i = tend
            if i < rgn_end:
                i = i + 1
            continue
        if counting != 0:
            if ch == 32 or ch == 9 or ch == 10 or ch == 13:
                pend_space = 1
            else:
                if pend_space != 0 and cell_n > 0:
                    cell_n = cell_n + 1
                pend_space = 0
                cell_n = cell_n + 1
        i = i + 1
    rowsum = rowsum + cell_n + CELL_PAD
    if rowsum > maxrow:
        maxrow = rowsum
    return maxrow


# Proportional glyph-advance model for the auto-table column measure. The paint
# path (lib/htmlpaint via font_ttf_adv_px) flows REAL proportional advances, but
# this layout measure historically counted CHARACTERS * CELL_W, over/under-sizing
# any column whose text has wide (m,W,caps) or narrow (i,l) glyphs — a bold
# "Component" header overran its column while "Version"/"Status" were left too
# wide. These two constants carry each printable ASCII glyph's DejaVu Sans advance
# in px at the 16px reference size (regular + bold), encoded as (advance+48) so
# every byte is printable. _adv8() returns a glyph's advance; _measure_table sums
# it per cell and divides by CELL_W to recover a column width that tracks Chrome's
# proportional auto-layout (max content advance + padding) instead of a monospace
# char count. Non-ASCII falls back to the average lowercase advance.
def _adv8(ch: uint8, bold: int32) -> int32:
    if ch < 32 or ch > 126:
        return 10
    idx: int32 = cast[int32](ch) - 32
    if bold != 0:
        b: Ptr[uint8] = cast[Ptr[uint8]]("678=;@>5778=6766;;;;;;;;;;66===9@<<<=;;==66<:@=><><<;=<B<<<767=88;;9;;7;;55;5A;;;;8:8;:?::9;6;=")
        return cast[int32](b[idx]) - 48
    r: Ptr[uint8] = cast[Ptr[uint8]]("567=:?<4668=5655::::::::::55===8@;;;<:9<<55:9><=:=;::<;@;:;656=88::9::6::4494@::::786:9=998:5:=")
    return cast[int32](r[idx]) - 48


# Pass 1: record the widest cell (proportional advance width, whitespace-
# collapsed) per column across [rgn_start, rgn_end). Sets col_chars[] (in CELL_W
# units) and n_cols. A nested <table> is skipped (its cells belong to the inner
# table) but its natural width sizes the enclosing cell so the outer column
# contains it.
def _measure_table(rgn_start: uint64, rgn_end: uint64):
    c: int32 = 0
    while c < MAX_COLS:
        col_chars[c] = 0
        c = c + 1
    n_cols = 0
    col: int32 = -1
    nextcol: int32 = 0          # column index the next cell starts at
    cspan: int32 = 1            # colspan of the currently-counting cell
    counting: int32 = 0
    cell_n: int32 = 0           # glyph count (content-present gate for spaces)
    cell_px: int32 = 0          # summed proportional advance of the cell text (px)
    cell_th: int32 = 0          # the cell being counted is a <th> (bold glyphs)
    pend_space: int32 = 0
    i: uint64 = rgn_start
    while i < rgn_end:
        ch: uint8 = src_ptr[i]
        if ch == 60:                                 # '<'
            k: uint64 = i + 1
            close: int32 = 0
            if k < rgn_end and src_ptr[k] == 47:
                close = 1
                k = k + 1
            is_cell: int32 = 0
            is_th_tag: int32 = _tagname_is(k, cast[Ptr[uint8]]("th"))
            if _tagname_is(k, cast[Ptr[uint8]]("td")) != 0 or is_th_tag != 0:
                is_cell = 1
            is_tr: int32 = _tagname_is(k, cast[Ptr[uint8]]("tr"))
            # end of this tag's body ('>')
            tend: uint64 = k
            while tend < rgn_end and src_ptr[tend] != 62:
                tend = tend + 1
            if close == 0 and _tagname_is(k, cast[Ptr[uint8]]("table")) != 0:
                # nested table: skip its region, but grow the enclosing cell so
                # the outer column is wide enough to contain the inner grid.
                sub0: uint64 = tend
                if sub0 < rgn_end:
                    sub0 = sub0 + 1
                sube: uint64 = _table_region_end(sub0)
                if counting != 0:
                    w2: int32 = _table_char_width(sub0, sube)
                    if w2 * CELL_W > cell_px:
                        cell_px = w2 * CELL_W
                    if w2 > cell_n:
                        cell_n = w2
                i = sube                             # resume at '<' of </table>
                continue
            if is_cell != 0 or is_tr != 0:
                # finalize the cell that was open — a spanning cell (cspan>1)
                # does not size any single column, so only single-span cells
                # contribute to col_chars[]. The cell's proportional advance
                # (cell_px, bold-aware for a <th>) is converted to CELL_W units
                # (round to nearest) so the column tracks Chrome's content width;
                # a non-empty cell always claims at least one cell.
                eff: int32 = (cell_px + CELL_W - 1) / CELL_W
                if cell_n > 0 and eff < 1:
                    eff = 1
                if col >= 0 and col < MAX_COLS and cspan == 1 and \
                   eff > col_chars[col]:
                    col_chars[col] = eff
                counting = 0
                cell_n = 0
                cell_px = 0
                cell_th = 0
                pend_space = 0
                cspan = 1
                if is_tr != 0 and close == 0:
                    nextcol = 0                       # new row restarts columns
                    col = -1
                elif is_cell != 0 and close == 0:
                    col = nextcol
                    cell_th = is_th_tag
                    cspan = _attr_int(k, tend, cast[Ptr[uint8]]("colspan"), 1)
                    nextcol = col + cspan
                    counting = 1
                    if nextcol > n_cols:
                        n_cols = nextcol
            i = tend
            if i < rgn_end:
                i = i + 1
            continue
        if counting != 0:
            if ch == 32 or ch == 9 or ch == 10 or ch == 13:
                pend_space = 1
            else:
                if pend_space != 0 and cell_n > 0:
                    cell_px = cell_px + _adv8(32, cell_th)
                pend_space = 0
                cell_px = cell_px + _adv8(ch, cell_th)
                cell_n = cell_n + 1
        i = i + 1
    tail_eff: int32 = (cell_px + CELL_W - 1) / CELL_W
    if cell_n > 0 and tail_eff < 1:
        tail_eff = 1
    if col >= 0 and col < MAX_COLS and cspan == 1 and tail_eff > col_chars[col]:
        col_chars[col] = tail_eff


# Natural (unclamped) pixel width of the measured table — the sum of every
# column's char width (same growth rule _compute_cols uses). Drives the float
# box width for a floated <table> so the infobox is exactly as wide as its grid.
def _table_natural_width() -> int32:
    total: int32 = 0
    c: int32 = 0
    while c < n_cols and c < MAX_COLS:
        w: int32 = col_chars[c]
        if w < 1:
            w = 1
        if w > 60:
            w = 60
        total = total + (w + CELL_PAD) * CELL_W
        c = c + 1
    return total


# Explicit width target for the table currently being computed, set by the
# <table> open handler from a presentational width="..." attribute: +px for a
# pixel width, -pct for a percentage (resolved against the available width
# here), 0 when the table has no explicit width. Consumed and cleared by
# _compute_cols, so it never leaks into a following auto-width table.
tbl_target_w: int32 = 0


# Pass 2: turn per-column character widths into pixel column x-positions.
def _compute_cols():
    # Inside a float/box, clamp columns to the box's right edge so a floated
    # infobox's grid stays within its pinned box; a top-level table (no block
    # active, blk_right_cur==0) keeps its historical full-width growth.
    right: int32 = _flow_right()
    bounded: int32 = 0
    if blk_right_cur > 0:
        bounded = 1
    # A nested table clamps to its parent cell's right edge (_flow_right returns
    # cell_right while cell_active) so the inner grid stays inside the outer cell.
    if cell_active != 0:
        bounded = 1
    avail: int32 = right - indent_x
    # Natural (content) pixel width = sum of every clamped column's char width.
    nat: int32 = 0
    c: int32 = 0
    while c < n_cols and c < MAX_COLS:
        wn: int32 = col_chars[c]
        if wn < 1:
            wn = 1
        if wn > 60:
            wn = 60
        nat = nat + (wn + CELL_PAD) * CELL_W
        c = c + 1
    # An explicit table width (HTML width="85%" / width="600") STRETCHES the grid
    # to fill that target so cells wrap at the wider boundary — legacy table-layout
    # sites (Hacker News' `<center><table width="85%">`, many articles/forums) rely
    # on this to fill the viewport rather than shrinking to content. extra=0 =>
    # byte-identical to the auto path (no width attr => tbl_target_w==0).
    # A TOP-LEVEL table stretches to the viewport measure; a NESTED table
    # (cell_active != 0) stretches too, but `avail` is the PARENT CELL's content
    # width (right == cell_right via _flow_right), so a width:100% inner grid fills
    # its containing cell exactly — never exceeding it — the way Chrome lays out
    # Hacker News' orange header bar. Both clamp target to `avail`. (A FLOATED grid
    # is natural-width sized and never sets tbl_target_w, so it is untouched.)
    extra: int32 = 0
    if tbl_target_w != 0:
        target: int32 = tbl_target_w
        if target < 0:                               # percentage of available
            target = avail * (0 - tbl_target_w) / 100
        if target > avail:                           # never exceed the container
            target = avail
        if target > nat:
            extra = target - nat
    tbl_target_w = 0                                 # consume (one table only)
    x: int32 = indent_x
    # `<center>` / text-align:-webkit-center centres a block-level table in its
    # container (Chrome's UA <center> rule). When a centre-align scope is active
    # (g_align==2) and this is a TOP-LEVEL, unbounded table narrower than the
    # available width, offset its origin so the whole grid is centred — google.com's
    # homepage centres its logo+search-box+buttons table this way. A stretched table
    # (extra>0) centres its full target width. Nested/floated/in-cell tables keep
    # their clamped left origin.
    if g_align == 2 and cell_active == 0:
        span_w: int32 = nat + extra
        if span_w > 0 and span_w < avail:
            x = indent_x + (avail - span_w) / 2
    # Distribute the surplus across columns proportional to their content width so
    # the widest (content) column grows most — HTML auto-layout's free-space rule.
    # The final column absorbs the rounding remainder so the grid lands exactly on
    # the target right edge.
    used_extra: int32 = 0
    c = 0
    while c < n_cols and c < MAX_COLS:
        col_x[c] = x
        w: int32 = col_chars[c]
        if w < 1:
            w = 1
        if w > 60:                                   # cap a runaway column
            w = 60
        cw: int32 = (w + CELL_PAD) * CELL_W
        if extra > 0 and nat > 0:
            add: int32 = 0
            if c == n_cols - 1:
                add = extra - used_extra             # remainder to the last column
            else:
                add = extra * cw / nat
                used_extra = used_extra + add
            cw = cw + add
        if bounded != 0 and c > 0 and x + cw > right:
            cw = right - x
            if cw < 2 * CELL_W:
                cw = 2 * CELL_W
        x = x + cw
        c = c + 1
    if n_cols > MAX_COLS:
        n_cols = MAX_COLS
    col_x[n_cols] = x                                # right sentinel


# Close the open table cell: flush its word, drop its bold + colour scope.
def _cell_close():
    if cell_active == 0:
        return
    _word_flush()
    if cell_is_th != 0 and g_bold_n > 0:
        g_bold_n = g_bold_n - 1
    _close_style()
    # Fill the cell background (header tint / zebra stripe) across the WHOLE cell
    # box — [cell_bx_lx, cell_bx_rx) x [srow, cur_row+1] — so the fill reads as a
    # solid coloured cell rather than a strip behind the glyphs only. Painted as a
    # block fill (drawn under the text + grid rule). The cell's real vertical
    # padding is now baked into its row heights (htmlpage row_padt/row_padb), so a
    # cell's fill box [srow, cur_row+1] already tiles flush against the row below
    # with no seam — no extra bottom extension needed (the old CELL_ROW_LEAD stand-in
    # would now overfill into the next cell).
    if cell_bg >= 0 and n_bfills < BFILL_MAX and cast[uint64](cur_row) < MAX_ROWS:
        bfill_lx[n_bfills]     = cell_bx_lx + 2
        bfill_rx[n_bfills]     = cell_bx_rx + 6
        bfill_top[n_bfills]    = cell_bx_srow
        bfill_bot[n_bfills]    = cast[int32](cur_row) + 1
        bfill_rgb[n_bfills]    = cell_bg
        bfill_z[n_bfills]      = 0
        bfill_rad[n_bfills]    = 0
        bfill_filter[n_bfills] = 0
        bfill_padt[n_bfills]   = 0
        bfill_padb[n_bfills]   = 0
        bfill_bord[n_bfills]   = -1
        n_bfills = n_bfills + 1
    # Stroke this cell's own border box (the internal grid lines) when the
    # enclosing table is bordered. The cell spans [srow, cur_row+1] so a
    # single-line cell still has a real height; a wrapped/nested cell grows
    # with its content (cur_row advanced). Adjacent cells share edges, which
    # renders as the classic gridded table.
    if cell_border != 0 and n_bboxes < BBOX_MAX:
        # The stroke pass maps a box's left edge to lx+2 but its right edge to
        # rx+6 (the +6 reaches a general box's right box-art bar cell). For a
        # table cell rx is ALREADY the true column boundary, so an INTERNAL
        # cell's right rule lands at col_x[b]+5 while the next cell's left rule
        # lands at col_x[b]+2 — two parallel lines 3px apart, the "doubled /
        # gappy grid" a real browser never draws. Pull an internal cell's right
        # edge in by 3 so its right rule coincides with the neighbour's left
        # rule (one clean line per column boundary). The RIGHTMOST cell keeps
        # its true rx so its right rule still merges with the table frame.
        crx: int32 = cell_bx_rx
        if crx < col_x[n_cols]:
            crx = crx - 3
        bbox_lx[n_bboxes]  = cell_bx_lx
        bbox_rx[n_bboxes]  = crx
        bbox_top[n_bboxes] = cell_bx_srow
        bbox_bot[n_bboxes] = cast[int32](cur_row) + 1
        bbox_rgb[n_bboxes] = cell_bd_rgb
        bbox_rad[n_bboxes] = 0
        bbox_ps[n_bboxes]  = 0                    # table cells use the uniform stroke
        bbox_ss[n_bboxes]  = 0
        # Cell box: btop/bbot are CONTENT rows, so paint spans the full rows and
        # a cell's bottom rule coincides with the row-below cell's top rule —
        # one clean shared horizontal line per internal row boundary.
        bbox_kind[n_bboxes] = 1
        # Per-edge vertical padding = half the cell's declared padding sum, so the
        # row-tops pass lifts the cell top rule above and drops the bottom rule
        # below the content by the real CSS padding (Chrome's padded cell height).
        bbox_padv[n_bboxes] = cell_pady / 2
        n_bboxes = n_bboxes + 1
    cell_border = 0
    cell_pady = 0
    cell_active = 0
    cell_is_th = 0
    g_cell_pending = 0                         # reserved-row window ends with the cell
    _style_break()


# Push the parent table's column model + cell scope onto the nesting stack so a
# nested <table> can overwrite the shared col_x/n_cols/cur_col globals; the entry
# also carries slots for THIS table's border geometry (filled by the caller).
def _table_push():
    if tbl_sp >= TBL_MAX:
        return
    d: int32 = tbl_sp
    tbl_ncols_st[d]     = n_cols
    tbl_curcol_st[d]    = cur_col
    tbl_cellact_st[d]   = cell_active
    tbl_cellright_st[d] = cell_right
    tbl_cellisth_st[d]  = cell_is_th
    tbl_indentx_st[d]   = indent_x
    tbl_floated_st[d]   = table_floated
    tbl_cellbd_st[d]    = cell_border
    tbl_cellbxlx_st[d]  = cell_bx_lx
    tbl_cellbxrx_st[d]  = cell_bx_rx
    tbl_cellbxsr_st[d]  = cell_bx_srow
    c: int32 = 0
    while c <= MAX_COLS:
        tbl_colx_st[d * 33 + c] = col_x[c]
        c = c + 1
    tbl_srow_st[d]   = 0
    tbl_lx_st[d]     = 0
    tbl_border_st[d] = 0
    tbl_rgb_st[d]    = 0
    # The freshly-opened table starts with no pending cell border of its own.
    cell_border = 0
    tbl_sp = tbl_sp + 1


# Restore the parent table's column model + cell scope saved by _table_push.
def _table_pop():
    if tbl_sp <= 0:
        return
    tbl_sp = tbl_sp - 1
    d: int32 = tbl_sp
    n_cols        = tbl_ncols_st[d]
    cur_col       = tbl_curcol_st[d]
    cell_active   = tbl_cellact_st[d]
    cell_right    = tbl_cellright_st[d]
    cell_is_th    = tbl_cellisth_st[d]
    indent_x      = tbl_indentx_st[d]
    table_floated = tbl_floated_st[d]
    cell_border   = tbl_cellbd_st[d]
    cell_bx_lx    = tbl_cellbxlx_st[d]
    cell_bx_rx    = tbl_cellbxrx_st[d]
    cell_bx_srow  = tbl_cellbxsr_st[d]
    c: int32 = 0
    while c <= MAX_COLS:
        col_x[c] = tbl_colx_st[d * 33 + c]
        c = c + 1



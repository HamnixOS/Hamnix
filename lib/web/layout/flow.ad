# lib/web/layout/flow.ad — part of the modular web engine (extracted from htmlengine.ad).
# top-level layout driver — reset + parse src_ptr/src_len into the flat styled segment list.
#
# Behavior-preserving split (single-compilation-unit; byte-identical).

from lib.htmlengine import _close_seg, _collect_css, _content_right, _float_flush, _gc_collect_css, _handle_tag, _hx_name_eq, _hx_tag_end, _left_margin, _newline, _page_uses_layout, _pending_indjump, _word_flush, _word_push

# ====================================================================
# LAYOUT — parse src_ptr/src_len into segments.
# ====================================================================
def _reset_layout():
    n_segs = 0
    n_bboxes = 0
    # Clear per-box kind flags (0 = generic/frame; table cells set 1) so a slot
    # reused across layouts never inherits a stale cell mapping.
    bk: int32 = 0
    while bk < BBOX_MAX:
        bbox_kind[bk] = 0
        bk = bk + 1
    n_bfills = 0
    # Clear the per-fill padding-box extension (px) so a slot reused across layouts
    # never inherits a stale vertical-padding offset from a prior render (native BSS
    # persists). Only the padded-panel close path sets these non-zero.
    fb: int32 = 0
    while fb < BFILL_MAX:
        bfill_padt[fb] = 0
        bfill_padb[fb] = 0
        bfill_inlb[fb] = 0
        fb = fb + 1
    seg_text_len = 0
    n_eimg = 0
    eimg_name_used = 0
    n_links = 0
    link_href_len = 0
    cur_row = 0
    # READABLE-MEASURE SCOPING: decide BEFORE baking the initial content column
    # whether this page drives its own full-width layout (flex/grid/positioned)
    # — if so the readable gutter is disabled and the body spans the full window
    # like Firefox/Chrome; a plain-prose page keeps the ~73-col readable measure.
    g_layout_full = _page_uses_layout()
    pen_x = _left_margin()
    indent_x = _left_margin()
    row_dirty = 0
    need_space = 0
    seg_open = 0
    seg_curlen = 0
    _pending_indjump = 0
    g_color = 0
    g_page_bg = -1
    gblk_sp = 0
    g_bold = 0
    g_uline = 0
    g_link = -1
    g_link_rgb = -1
    g_bold_n = 0
    g_mono_n = 0
    g_heading = 0
    g_strike_n = 0
    g_yoff = 0
    sub_depth = 0
    sup_depth = 0
    dd_depth = 0
    p_open = 0
    dl_item = 0
    list_depth = 0
    lidx0: int32 = 0
    while lidx0 < MAX_LIST_DEPTH:
        li_styled[lidx0] = 0
        lidx0 = lidx0 + 1
    list_indent_drop = 0
    bq_depth = 0
    blk_indent_sp = 0
    blk_indent_sum = 0
    blk_right_sp = 0
    blk_right_cur = _content_right()
    box_sp = 0
    floatL_active = 0
    floatL_bottom = 0
    float_left_pad = 0
    floatR_active = 0
    floatR_bottom = 0
    float_redge = 0
    flex_sp = 0
    inlb_sp = 0
    g_inlb_floor = 0
    g_tindent_pending = 0
    pos_n = 0
    abs_flow_depth = 0
    posctx_sp = 0
    table_active = 0
    cell_active = 0
    cell_is_th = 0
    cur_col = 0
    n_cols = 0
    table_floated = 0
    tbl_sp = 0
    pre_mode = 0
    skip_active = 0
    skip_nlen = 0
    word_len = 0
    top_line = 0
    color_sp = 0
    g_rgb = -1
    bg_sp = 0
    g_bg = -1
    el_sp = 0
    el_slen = 0
    weight_sp = 0
    g_css_bold = 0
    fontpx_sp = 0
    g_font_px = 0
    lineh_sp = 0
    g_lineh = 0
    align_sp = 0
    g_align = 0
    deco_sp = 0
    g_css_uline = 0
    r: uint64 = 0
    while r < MAX_ROWS:
        row_rule[r] = 0
        row_align[r] = 0
        r = r + 1


# ---- CSS position bookkeeping ---------------------------------------
def _register_pos(seg0: int32, mode: int32, fxk: int32, ox: int32, ort: int32, \
                  orow: int32, pl: int32, pt: int32, pr: int32, \
                  pb: int32, pz: int32) -> int32:
    if pos_n >= POS_MAX:
        return -1
    ri: int32 = pos_n
    pos_seg0[ri] = seg0
    pos_seg1[ri] = seg0
    pos_mode[ri] = mode
    pos_fx[ri]   = fxk
    pos_ox[ri]   = ox
    pos_ort[ri]  = ort
    pos_orow[ri] = orow
    pos_l[ri]    = pl
    pos_t[ri]    = pt
    pos_r[ri]    = pr
    pos_b[ri]    = pb
    pos_z[ri]    = pz
    pos_bf0[ri]  = n_bfills            # backgrounds of this box start here
    pos_bf1[ri]  = n_bfills
    pos_bx0[ri]  = n_bboxes            # drawn border rectangles of this box
    pos_bx1[ri]  = n_bboxes
    pos_wauto[ri] = 0                  # explicit width unless the caller flags auto
    # An `absolute` box's containing block is the nearest positioned ancestor's
    # frame (the top of the posctx stack). `fixed` (fxk==1) and a box with no
    # positioned ancestor resolve against the page/viewport (-1). This lets the
    # right/bottom resolver read the ancestor's padding-box edges.
    pos_cbrun[ri] = -1
    if mode == 2 and fxk != 1 and posctx_sp > 0:
        pos_cbrun[ri] = posctx_run[posctx_sp - 1]
    # Containing-block padding-box edges captured from this box's own laid-out
    # geometry (below): -1 until its positioning context is pushed/popped.
    pos_cb_rx[ri]  = -1
    pos_cb_bot[ri] = -1
    # Remember this run so the _posctx_push that (may) immediately follow can tag
    # the frame it opens with its owning ancestor run.
    g_last_posrun = ri
    pos_n = pos_n + 1
    return ri


def _posctx_push(x: int32, rt: int32, row: int32):
    if posctx_sp < 64:
        posctx_x[posctx_sp]   = x
        posctx_rt[posctx_sp]  = rt
        posctx_row[posctx_sp] = row
        posctx_run[posctx_sp] = g_last_posrun
        posctx_sp = posctx_sp + 1
        # Record the ancestor's padding-box RIGHT edge from its LAID-OUT geometry:
        # `rt` is the box's inner right column (blk_right_cur), and a block paints
        # its background out to rt + CELL_W, so that is the padding-box right edge.
        # Captured here (not from a paint record) so `right:` anchoring works even
        # when the ancestor has a gradient/transparent/image background.
        if g_last_posrun >= 0:
            pos_cb_rx[g_last_posrun] = rt + CELL_W


def _posctx_pop():
    if posctx_sp > 0:
        # Record the ancestor's padding-box BOTTOM row from its LAID-OUT geometry.
        # The box's block-close (which advances cur_row to the box bottom and emits
        # any background out to that row) has already run by the time its context
        # is popped, so cur_row (+1 for a still-dirty last row) is the padding-box
        # bottom edge — the same value a solid background fill would record, but
        # available regardless of whether the ancestor paints one.
        run: int32 = posctx_run[posctx_sp - 1]
        if run >= 0:
            cbb: int32 = cast[int32](cur_row)
            if row_dirty != 0:
                cbb = cbb + 1
            pos_cb_bot[run] = cbb
        posctx_sp = posctx_sp - 1


# Post-layout pass: relocate each positioned element's segment run. `relative`
# offsets the box from its in-flow spot by left/top (or pulls it back by
# right/bottom); `absolute` places it against its containing-block origin. Runs
# are only registered for elements that declare `position`, so a page with none
# leaves this a no-op (byte-identical layout).
def _apply_positioned():
    i: int32 = 0
    while i < pos_n:
        s0: int32 = pos_seg0[i]
        s1: int32 = pos_seg1[i]
        # current pixel/row extent of the run's text (the box's in-flow origin).
        minx: int32 = 0x7fffffff
        maxx: int32 = -1
        minrow: int32 = 0x7fffffff
        k: int32 = s0
        while k < s1:
            # A drawn CSS border emits box-art glyph segments spanning the WHOLE
            # box width; they are decoration (painted as a real 1px rect from the
            # bbox registry, not as glyphs), NOT content. Excluding them here is
            # what lets shrink-to-fit measure the true content width of a bordered
            # auto-width abs box (else maxx == box width and it never shrinks).
            if seg_boxart[k] != 0:
                k = k + 1
                continue
            x0: int32 = seg_x[k]
            x1: int32 = x0 + seg_len[k] * CELL_W
            if x0 < minx:
                minx = x0
            if x1 > maxx:
                maxx = x1
            if seg_line[k] < minrow:
                minrow = seg_line[k]
            k = k + 1
        # An out-of-flow box with a background but no text: fall back to the
        # box's background rectangle for the in-flow origin so it still moves.
        if maxx < 0 and pos_bf1[i] > pos_bf0[i]:
            minx = bfill_lx[pos_bf0[i]]
            maxx = bfill_rx[pos_bf0[i]]
            minrow = bfill_top[pos_bf0[i]]
        dx: int32 = 0
        drow: int32 = 0
        if maxx >= 0:
            elemw: int32 = maxx - minx
            if pos_mode[i] == 1 and pos_fx[i] == 2:        # STICKY
                # Lays out in normal flow (minrow), but once the assumed scroll
                # offset carries its in-flow row above the top/bottom threshold
                # it PINS to that threshold within the viewport/scroll region.
                # Static resolution: threshold row = pos_scroll_y + top (rows);
                # the box takes max(in-flow, threshold) for `top` sticky, so at
                # scroll 0 (or before the threshold) it is byte-identical to its
                # flow position. `bottom` sticky and the container-bottom "unstick"
                # clamp (element released at the container's end) are the
                # documented live-scroll follow-up.
                srow: int32 = minrow
                if pos_t[i] >= 0:
                    pin_t: int32 = pos_scroll_y + pos_t[i] / LINE_H
                    if pin_t > srow:
                        srow = pin_t
                drow = srow - minrow
                # sticky keeps its inline (x) position (horizontal sticky within a
                # horizontally-scrolled container is the deferred case).
            elif pos_mode[i] == 1:                         # relative
                if pos_l[i] >= 0:
                    dx = pos_l[i]
                elif pos_r[i] >= 0:
                    dx = -pos_r[i]
                dpy: int32 = 0
                if pos_t[i] >= 0:
                    dpy = pos_t[i]
                elif pos_b[i] >= 0:
                    dpy = -pos_b[i]
                drow = dpy / LINE_H
            else:                                          # absolute / fixed
                # FIXED (pos_fx==1) resolves against the VIEWPORT: its containing
                # block was captured as the page viewport (not the nearest
                # positioned ancestor), and its top edge tracks the assumed scroll
                # row so the bar stays pinned to the viewport top as the page
                # scrolls. `absolute` keeps the ancestor origin at scroll 0.
                voff: int32 = 0
                if pos_fx[i] == 1:
                    voff = pos_scroll_y
                # Containing-block padding-box RIGHT/BOTTOM edges taken from the
                # positioned ancestor's LAID-OUT BOX GEOMETRY (pos_cb_rx/pos_cb_bot,
                # captured when the ancestor pushed/popped its positioning context),
                # NOT from any background/paint record. This makes `right:`/`bottom:`
                # anchoring work for ANY containing block — gradient, transparent,
                # image, or solid background all resolve to the same box edges.
                # `fixed`/no-ancestor (pos_cbrun == -1) falls back to the page
                # content-right / page bottom. left/top are unchanged: they keep
                # resolving against pos_ox / pos_orow byte-identically.
                cb_right: int32 = pos_ort[i]
                cb_bot:   int32 = cast[int32](total_rows)
                cbrun: int32 = pos_cbrun[i]
                if cbrun >= 0:
                    if pos_cb_rx[cbrun] >= 0:
                        cb_right = pos_cb_rx[cbrun]
                    if pos_cb_bot[cbrun] >= 0:
                        cb_bot = pos_cb_bot[cbrun]
                # SHRINK-TO-FIT (CSS 10.3.7): a `width:auto` abs/fixed box sizes to
                # its content, NOT the containing-block width. Without this an
                # auto-width `top;right` badge fills the whole CB and starts at the
                # far LEFT (overlapping the heading) even though its right edge
                # anchors correctly. Narrow the box's OWN background fill to
                # content-width (glyph run + symmetric left/right padding) so the
                # box_right below — and the right/bottom anchoring — see the small
                # box. Only ever shrinks (never grows past the CB), only for
                # auto-width boxes (pos_wauto), and not the `left+right` full-width
                # bar case (that stretch is handled after relocation).
                if pos_wauto[i] != 0 and pos_bf1[i] > pos_bf0[i] and \
                   maxx > minx and not (pos_l[i] >= 0 and pos_r[i] >= 0):
                    obf: int32 = pos_bf0[i]
                    padl: int32 = minx - bfill_lx[obf]
                    if padl < 0:
                        padl = 0
                    fitrx: int32 = maxx + padl        # symmetric right padding
                    if fitrx < bfill_rx[obf] and fitrx > bfill_lx[obf]:
                        bfill_rx[obf] = fitrx
                        # Narrow the DRAWN border rectangle(s) to the same content
                        # width so a bordered auto-width badge's box shrinks whole
                        # (border tracks the fill), not just its background.
                        sbx: int32 = pos_bx0[i]
                        while sbx < pos_bx1[i]:
                            if bbox_rx[sbx] > fitrx:
                                bbox_rx[sbx] = fitrx
                            sbx = sbx + 1
                # The box's OWN border-box extent (its background fill if present,
                # else its text run) so RIGHT/BOTTOM pin the whole box — not just
                # its glyph ink — inside the containing block.
                box_right: int32 = maxx
                box_bot:   int32 = minrow + 1
                if pos_bf1[i] > pos_bf0[i]:
                    box_right = bfill_rx[pos_bf0[i]]
                    box_bot   = bfill_bot[pos_bf0[i]]
                tx: int32 = minx
                if pos_l[i] >= 0:
                    tx = pos_ox[i] + pos_l[i]
                elif pos_r[i] >= 0:
                    # Pin the box's right edge `right`px inside the CB right edge:
                    # shift everything so box_right lands at cb_right - right.
                    tx = minx + (cb_right - pos_r[i] - box_right)
                trow: int32 = minrow
                if pos_t[i] >= 0:
                    trow = pos_orow[i] + voff + pos_t[i] / LINE_H
                elif pos_b[i] >= 0:
                    # Pin the box's bottom edge `bottom`px above the CB bottom.
                    trow = minrow + (cb_bot + voff - pos_b[i] / LINE_H - box_bot)
                else:
                    trow = minrow + voff
                dx = tx - minx
                drow = trow - minrow
        # Relocate the text segments.
        if dx != 0 or drow != 0:
            j: int32 = s0
            while j < s1:
                nx: int32 = seg_x[j] + dx
                if nx < 0:
                    nx = 0
                seg_x[j] = nx
                nr: int32 = seg_line[j] + drow
                if nr < 0:
                    nr = 0
                if cast[uint64](nr) >= MAX_ROWS:
                    nr = cast[int32](MAX_ROWS) - 1
                seg_line[j] = nr
                if cast[uint64](nr) + 1 > total_rows:
                    total_rows = cast[uint64](nr) + 1
                j = j + 1
        # Relocate the box's background fill(s) by the same delta and stamp the
        # stacking order so the paint pass can sort positioned boxes by z-index.
        bf: int32 = pos_bf0[i]
        while bf < pos_bf1[i]:
            if dx != 0:
                bfill_lx[bf] = bfill_lx[bf] + dx
                bfill_rx[bf] = bfill_rx[bf] + dx
                if bfill_lx[bf] < 0:
                    bfill_lx[bf] = 0
            if drow != 0:
                nt: int32 = bfill_top[bf] + drow
                nb: int32 = bfill_bot[bf] + drow
                if nt < 0:
                    nt = 0
                if nb < 0:
                    nb = 0
                if cast[uint64](nb) >= MAX_ROWS:
                    nb = cast[int32](MAX_ROWS) - 1
                bfill_top[bf] = nt
                bfill_bot[bf] = nb
                if cast[uint64](nb) > total_rows:
                    total_rows = cast[uint64](nb)
            bfill_z[bf] = pos_z[i]
            bf = bf + 1
        # Relocate the box's DRAWN border rectangle(s) by the SAME delta as its
        # fill/text, so a bordered `position:absolute` badge's border moves with
        # the box instead of staying at its static (top-left) laid-out spot.
        bx: int32 = pos_bx0[i]
        while bx < pos_bx1[i]:
            if dx != 0:
                bbox_lx[bx] = bbox_lx[bx] + dx
                bbox_rx[bx] = bbox_rx[bx] + dx
                if bbox_lx[bx] < 0:
                    bbox_lx[bx] = 0
            if drow != 0:
                nbt: int32 = bbox_top[bx] + drow
                nbb: int32 = bbox_bot[bx] + drow
                if nbt < 0:
                    nbt = 0
                if nbb < 0:
                    nbb = 0
                if cast[uint64](nbb) >= MAX_ROWS:
                    nbb = cast[int32](MAX_ROWS) - 1
                bbox_top[bx] = nbt
                bbox_bot[bx] = nbb
            bx = bx + 1
        # BOTH horizontal edges anchored (`left:0; right:0` bar): stretch the
        # box's OWN background fill (pos_bf0[i], the first fill of the run) to
        # span the containing block width instead of its natural content width.
        # This is the common full-width fixed/sticky-bar case; text stays
        # left-anchored (a full re-wrap to the wider width is out of scope).
        if pos_mode[i] == 2 and pos_l[i] >= 0 and pos_r[i] >= 0 and \
           pos_bf1[i] > pos_bf0[i]:
            slx: int32 = pos_ox[i] + pos_l[i]
            srx: int32 = pos_ort[i] - pos_r[i]
            if srx > slx:
                bfill_lx[pos_bf0[i]] = slx
                bfill_rx[pos_bf0[i]] = srx
        i = i + 1


# Post-layout pass: shift each row's segments for text-align center/right.
def _apply_alignment():
    right: int32 = _content_right()
    r: uint64 = 0
    while r < total_rows:
        a: uint8 = row_align[r]
        if a == 2 or a == 3:
            minx: int32 = 0x7fffffff
            maxr: int32 = -1
            si: uint64 = 0
            while si < n_segs:
                if cast[uint64](seg_line[si]) == r:
                    x0: int32 = seg_x[si]
                    x1: int32 = x0 + seg_len[si] * CELL_W
                    if x0 < minx:
                        minx = x0
                    if x1 > maxr:
                        maxr = x1
                si = si + 1
            if maxr >= 0:
                shift: int32 = 0
                if a == 2:                            # center in [left,right]
                    width: int32 = maxr - minx
                    lm: int32 = _left_margin()
                    newmin: int32 = lm + (right - lm - width) / 2
                    shift = newmin - minx
                else:                                 # right-align
                    shift = right - maxr
                if shift > 0:
                    si2: uint64 = 0
                    while si2 < n_segs:
                        if cast[uint64](seg_line[si2]) == r:
                            seg_x[si2] = seg_x[si2] + shift
                        si2 = si2 + 1
                    # Slide inline-block CHIP backgrounds (pills/badges/buttons) by
                    # the SAME centre/right shift as their label segments, so a
                    # centred inline-block button's box follows its text instead of
                    # being stranded at the pen's left. Keyed on the fill's TOP row
                    # (the chip's baseline row) == this aligned row. Block/positioned
                    # fills (bfill_inlb == 0) are never touched (byte-identical).
                    bfi: int32 = 0
                    while bfi < n_bfills:
                        if bfill_inlb[bfi] != 0 and \
                           cast[uint64](bfill_top[bfi]) == r:
                            bfill_lx[bfi] = bfill_lx[bfi] + shift
                            bfill_rx[bfi] = bfill_rx[bfi] + shift
                        bfi = bfi + 1
        r = r + 1


def _layout():
    _collect_css()
    _reset_layout()
    _gc_collect_css()          # gather ::before/::after stylesheet text (round 4)
    i: uint64 = 0
    while i < src_len:
        c: uint8 = src_ptr[i]
        if skip_active != 0:
            if c == 60:                              # '<'
                if i + 1 < src_len and src_ptr[i + 1] == 47:     # '</'
                    if _hx_name_eq(i + 2, skip_nlen, &skip_name[0]) != 0:
                        skip_active = 0
                # advance past '>'
                while i < src_len and src_ptr[i] != 62:
                    i = i + 1
                if i < src_len:
                    i = i + 1
                continue
            i = i + 1
            continue
        if c == 60:                                  # '<'
            ts: uint64 = i + 1
            # Quote-aware: a '>' inside a quoted attribute value (e.g.
            # <a title="a>b">) does NOT end the tag.
            j: uint64 = _hx_tag_end(ts)
            _word_flush()
            _handle_tag(ts, j)
            if j < src_len:
                i = j + 1
            else:
                i = j
            continue
        if c == 38:                                  # '&'
            consumed: uint64 = _entity(i)
            if consumed > 0:
                k: int32 = 0
                while k < g_ent_len:
                    _word_push(g_ent_buf[k])
                    k = k + 1
                i = i + consumed
                continue
            _word_push(38)
            i = i + 1
            continue
        # Whitespace is PRESERVED when the <pre>/<code> element is active
        # (pre_mode, monospace grid) OR CSS white-space set a preserving mode
        # (g_ws 2 = pre, 3 = pre-wrap; proportional flow). Otherwise runs of
        # whitespace collapse to a single inter-word space (normal / nowrap).
        ws_preserve: int32 = pre_mode
        if g_ws == 2 or g_ws == 3:
            ws_preserve = 1
        if ws_preserve == 0:
            if c == 32 or c == 9 or c == 10 or c == 13:
                _word_flush()
                need_space = 1
                i = i + 1
                continue
            _word_push(c)
            i = i + 1
            continue
        # preformatted: preserve whitespace, honor newlines.
        if c == 10:
            _word_flush()
            _newline()
            i = i + 1
            continue
        if c == 13:
            i = i + 1
            continue
        if c == 9:
            _word_push(32)
            _word_push(32)
            i = i + 1
            continue
        _word_push(c)
        i = i + 1
    _word_flush()
    _close_seg()
    _float_flush()                                       # drop below any trailing float
    total_rows = cur_row + 1
    _apply_alignment()
    _apply_positioned()



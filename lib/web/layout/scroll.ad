# lib/web/layout/scroll.ad — part of the modular web engine (extracted from htmlengine.ad).
# scroll offset helpers (max_top / scroll_to / scroll_by over the laid-out segment list).
#
# Behavior-preserving split (single-compilation-unit; byte-identical).

from lib.htmlengine import _vis_rows


# ====================================================================
# SCROLL helpers.
# ====================================================================
def _max_top() -> uint64:
    vr: uint64 = _vis_rows()
    if total_rows > vr:
        return total_rows - vr
    return 0


def _scroll_to(t: int64):
    mt: int64 = cast[int64](_max_top())
    if t < 0:
        t = 0
    if t > mt:
        t = mt
    top_line = cast[uint64](t)


def _scroll_by(delta: int64):
    _scroll_to(cast[int64](top_line) + delta)

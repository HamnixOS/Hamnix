# lib/htmlimg.ad — a tiny in-memory decoded-image STORE shared between the HTML
# engine (layout) and the pixel renderer (paint).
#
# The htmlengine layout is PURE (extern-free) and cannot read files, but it must
# know an <img>'s natural width/height to reserve its layout box. This module is
# the hand-off: the host driver (which HAS file access) slurps + decodes each
# PNG via lib/png.ad, then calls htmlimg_add(src_name, w, h, rgba) to copy the
# pixels into a slot keyed by the image's `src` string. During layout the engine
# calls htmlimg_find(src_name) to recover the natural size, and htmlpage/htmlpaint
# read the RGBA back through htmlimg_pixel() to blit it.
#
# Pixels are stored as 8-bit RGBA, row-major, in one shared arena so mixed image
# sizes pack tightly. PURE: no extern/syscall/float — compiles host + native.

MAX_IMG:       uint64 = 64
IMG_ARENA_CAP: uint64 = 4194304        # 4 MiB of RGBA pixel bytes
NAME_CAP:      uint64 = 8192

img_off:  Array[64, uint64]            # byte offset of this slot's pixels
img_w:    Array[64, int32]
img_h:    Array[64, int32]
img_noff: Array[64, uint64]            # src-name offset in the name buffer
img_nlen: Array[64, uint64]
n_img:    uint64 = 0

img_arena: Array[4194304, uint8]
arena_used: uint64 = 0
name_buf:  Array[8192, uint8]
name_used: uint64 = 0


def htmlimg_reset():
    n_img = 0
    arena_used = 0
    name_used = 0


def _name_eq(aoff: uint64, alen: uint64, b: Ptr[uint8], blen: uint64) -> int32:
    if alen != blen:
        return 0
    k: uint64 = 0
    while k < alen:
        if name_buf[aoff + k] != b[k]:
            return 0
        k = k + 1
    return 1


# Find a decoded image slot by its `src` string. Returns the slot, or -1.
def htmlimg_find(name: Ptr[uint8], namelen: uint64) -> int32:
    i: uint64 = 0
    while i < n_img:
        if _name_eq(img_noff[i], img_nlen[i], name, namelen) != 0:
            return cast[int32](i)
        i = i + 1
    return -1


# Register a decoded RGBA image under `name`. `rgba` is w*h*4 bytes (row-major,
# 8-bit R,G,B,A). Returns the slot index, or -1 if the store is full. A repeated
# name returns the existing slot without recopying.
def htmlimg_add(name: Ptr[uint8], namelen: uint64, w: int32, h: int32,
                rgba: Ptr[uint8]) -> int32:
    ex: int32 = htmlimg_find(name, namelen)
    if ex >= 0:
        return ex
    if n_img >= MAX_IMG or w <= 0 or h <= 0:
        return -1
    nbytes: uint64 = cast[uint64](w) * cast[uint64](h) * 4
    if arena_used + nbytes > IMG_ARENA_CAP:
        return -1
    if name_used + namelen > NAME_CAP:
        return -1
    slot: uint64 = n_img
    img_off[slot] = arena_used
    img_w[slot] = w
    img_h[slot] = h
    img_noff[slot] = name_used
    img_nlen[slot] = namelen
    k: uint64 = 0
    while k < nbytes:
        img_arena[arena_used + k] = rgba[k]
        k = k + 1
    arena_used = arena_used + nbytes
    j: uint64 = 0
    while j < namelen:
        name_buf[name_used + j] = name[j]
        j = j + 1
    name_used = name_used + namelen
    n_img = n_img + 1
    return cast[int32](slot)


def htmlimg_count() -> uint64:
    return n_img


def htmlimg_w(slot: int32) -> int32:
    if slot < 0 or cast[uint64](slot) >= n_img:
        return 0
    return img_w[slot]


def htmlimg_h(slot: int32) -> int32:
    if slot < 0 or cast[uint64](slot) >= n_img:
        return 0
    return img_h[slot]


# Packed 0xAARRGGBB for pixel (x,y) of slot; 0 if out of range.
def htmlimg_pixel(slot: int32, x: int32, y: int32) -> uint32:
    if slot < 0 or cast[uint64](slot) >= n_img:
        return 0
    w: int32 = img_w[slot]
    h: int32 = img_h[slot]
    if x < 0 or y < 0 or x >= w or y >= h:
        return 0
    o: uint64 = img_off[slot] + (cast[uint64](y) * cast[uint64](w) + \
                                 cast[uint64](x)) * 4
    r: uint32 = cast[uint32](img_arena[o])
    g: uint32 = cast[uint32](img_arena[o + 1])
    b: uint32 = cast[uint32](img_arena[o + 2])
    a: uint32 = cast[uint32](img_arena[o + 3])
    return (a << 24) | (r << 16) | (g << 8) | b

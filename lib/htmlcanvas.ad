# lib/htmlcanvas.ad — a scoped HTML <canvas> 2D drawing backend for hambrowse.
#
# WHAT THIS IS
# ============
# lib/htmlengine.ad runs a page's <script> against a minimal DOM. A real browser
# lets that script draw imperatively into a <canvas> via a 2D context. This
# module is the pixel side of that: each <canvas width= height=> gets a BLANK
# RGBA backing buffer (an lib/htmlimg slot, so the page renderer blits it exactly
# like an <img>), and the 2D drawing calls the script issues land in that buffer.
#
# The DRAWING REUSES lib/htmlpaint's rasteriser rather than duplicating it: we
# point htmlpaint's target-redirect at the canvas's RGBA slot, then call
# htmlpaint_fill_rect (opaque fills), htmlpaint_stroke_line (strokes + arc
# outlines), htmlpaint_fill_poly (filled paths / discs) and htmlpaint_text_ttf
# (anti-aliased fillText) straight into it. Only the two cases htmlpaint's
# opaque primitives cannot express — clearRect (transparent) and a globalAlpha<1
# fillRect — write RGBA into the slot directly.
#
# STYLE STATE (fillStyle, strokeStyle, lineWidth, font, globalAlpha) lives on the
# JS context object as plain properties; htmlengine reads them back at each draw
# and passes the resolved colour / width / px / alpha in here, so this module is
# pure geometry + pixels: no JS, no floats, no extern/syscall. It compiles for
# BOTH the x86_64-linux host (PNG gate) and the native Adder target.
#
# drawImage(img, dx, dy[, dw, dh]) blits an already-decoded source (a decoded
# <img>/Image or another <canvas>, both htmlimg-slot backed) scaled into the
# canvas with src-over compositing (see htmlcanvas_draw_image).
#
# NOW ALSO DELIVERED (the "advanced" round): a per-canvas 2x3 current
# transformation matrix (CTM) with save/restore/translate/scale/rotate/transform/
# setTransform/resetTransform — every path point (moveTo/lineTo/arc/rect) is mapped
# through it, and fillRect/strokeRect/clearRect map their corners so a rotated or
# scaled rect lands correctly; linear + radial GRADIENTS usable as fillStyle
# (per-pixel interpolation of colour stops projected onto the gradient, evaluated
# in USER space so they compose with the CTM); and getImageData/putImageData/
# createImageData raw RGBA pixel access to the backing buffer. Rotation/skew of a
# rect or gradient fill goes through a general inverse-mapped per-pixel rasteriser;
# the axis-aligned identity-CTM solid case keeps the fast htmlpaint path (byte-
# identical to the core round, zero regression).
#
# STILL SCOPED OUT (documented, not hidden): createPattern, shadows, clipping
# paths, bezier/quadratic curves, the 9-arg drawImage sub-rectangle form; and
# raster ROTATION of glyphs (fillText) / images (drawImage) — their ANCHOR is
# mapped through the full CTM and their SIZE through the CTM scale, but the glyph/
# image raster itself stays axis-aligned. A gradient used as strokeStyle or as the
# paint for a path fill()/fillText() falls back to the gradient's first colour stop
# (only fillRect does true per-pixel gradient interpolation).

from lib.htmlimg import htmlimg_buf_ptr, htmlimg_w, htmlimg_h
from lib.htmlpaint import htmlpaint_target_rgba, htmlpaint_target_internal, \
    htmlpaint_fill_rect, htmlpaint_stroke_line, htmlpaint_fill_poly, \
    htmlpaint_text_ttf, htmlpaint_measure_ttf
from lib.font_ttf import FACE_TT_SANS, FACE_TT_SANS_BOLD


CV_MAX:      uint64 = 8
CV_PATH_MAX: int32  = 512

cv_slot: Array[8, int32]          # backing lib/htmlimg slot for each canvas
cv_w:    Array[8, int32]
cv_h:    Array[8, int32]
cv_n:    int32 = 0

# One active path per canvas: flat point arrays [ci*CV_PATH_MAX + k].
cv_px:   Array[4096, int32]
cv_py:   Array[4096, int32]
cv_pn:   Array[8, int32]          # #points in the current path
cv_sub0: Array[8, int32]          # start index of the current subpath

# Integer sine table (scale 4096), 64 steps over a full turn; N/(2pi)=10.1859.
CIRC_N:  int32 = 64
sin_t:   Array[64, int32]
sin_ready: int32 = 0

# ---- current transformation matrix (CTM) --------------------------
# Per-canvas 2x3 affine [a b c d e f] mapping user (x,y) -> device:
#   dx = a*x + c*y + e ,  dy = b*x + d*y + f   (identity = 1 0 0 1 0 0).
_cv_ma: Array[8, float64]
_cv_mb: Array[8, float64]
_cv_mc: Array[8, float64]
_cv_md: Array[8, float64]
_cv_me: Array[8, float64]
_cv_mf: Array[8, float64]

# save()/restore() CTM stack (style state is stacked JS-side in dom/canvas.ad).
_CV_STK_MAX: int32 = 32
_cv_sa: Array[256, float64]         # 8 canvases * 32 deep, flat [ci*32 + depth]
_cv_sb: Array[256, float64]
_cv_sc: Array[256, float64]
_cv_sd: Array[256, float64]
_cv_se: Array[256, float64]
_cv_sf: Array[256, float64]
_cv_stk_n: Array[8, int32]

# ---- gradient table (fillStyle = createLinear/RadialGradient(...)) --
_CV_GRAD_MAX: int32 = 16
_CV_STOP_MAX: int32 = 8
_grad_kind:  Array[16, int32]        # 0 = linear, 1 = radial
_grad_x0:    Array[16, float64]
_grad_y0:    Array[16, float64]
_grad_r0:    Array[16, float64]
_grad_x1:    Array[16, float64]
_grad_y1:    Array[16, float64]
_grad_r1:    Array[16, float64]
_grad_nstop: Array[16, int32]
_grad_soff:  Array[128, float64]     # [gi*8 + k] stop offset 0..1
_grad_srgb:  Array[128, int32]       # [gi*8 + k] stop colour 0xRRGGBB
_grad_n:     int32 = 0


def htmlcanvas_reset():
    cv_n = 0
    _grad_n = 0


# Reset canvas `ci`'s CTM to the identity matrix and empty its save() stack.
def _ctm_identity(ci: int32):
    _cv_ma[ci] = cast[float64](1)
    _cv_mb[ci] = cast[float64](0)
    _cv_mc[ci] = cast[float64](0)
    _cv_md[ci] = cast[float64](1)
    _cv_me[ci] = cast[float64](0)
    _cv_mf[ci] = cast[float64](0)


# Register a <canvas> backed by htmlimg `slot` of w*h px. Returns a canvas
# index (>=0) or -1 if the table is full.
def htmlcanvas_new(slot: int32, w: int32, h: int32) -> int32:
    if cv_n >= cast[int32](CV_MAX):
        return -1
    ci: int32 = cv_n
    cv_slot[ci] = slot
    cv_w[ci] = w
    cv_h[ci] = h
    cv_pn[ci] = 0
    cv_sub0[ci] = 0
    _cv_stk_n[ci] = 0
    _ctm_identity(ci)
    cv_n = cv_n + 1
    return ci


def htmlcanvas_count() -> int32:
    return cv_n


def htmlcanvas_slot(ci: int32) -> int32:
    if ci < 0 or ci >= cv_n:
        return -1
    return cv_slot[ci]


def _ok(ci: int32) -> int32:
    if ci < 0 or ci >= cv_n:
        return 0
    return 1


# Redirect htmlpaint's pixel primitives into canvas `ci`'s RGBA slot.
def _target(ci: int32):
    htmlpaint_target_rgba(htmlimg_buf_ptr(cv_slot[ci]), cv_w[ci], cv_h[ci])


def _untarget():
    htmlpaint_target_internal()


# Directly write RGBA (source-copy, NOT src-over) at (x,y) of canvas `ci`. Used
# for clearRect (a=0) and a globalAlpha<255 fillRect, which htmlpaint's always-
# opaque fill_rect cannot express. The final page blit does the compositing.
def _put_rgba(ci: int32, x: int32, y: int32, r: uint8, g: uint8, b: uint8,
              a: uint8):
    if x < 0 or y < 0 or x >= cv_w[ci] or y >= cv_h[ci]:
        return
    buf: Ptr[uint8] = htmlimg_buf_ptr(cv_slot[ci])
    o: uint64 = (cast[uint64](y) * cast[uint64](cv_w[ci]) + cast[uint64](x)) * 4
    buf[o] = r
    buf[o + 1] = g
    buf[o + 2] = b
    buf[o + 3] = a


def _fill_rgba(ci: int32, x: int32, y: int32, w: int32, h: int32,
               r: uint8, g: uint8, b: uint8, a: uint8):
    yy: int32 = y
    ylim: int32 = y + h
    while yy < ylim:
        xx: int32 = x
        xlim: int32 = x + w
        while xx < xlim:
            _put_rgba(ci, xx, yy, r, g, b, a)
            xx = xx + 1
        yy = yy + 1


# ---- float math (self-contained: no libm, compiles for host + native) ----
_CV_PI:  float64 = 3.14159265358979323846
_CV_2PI: float64 = 6.28318530717958647692


# sin via range-reduced 9-term Taylor (Horner form); accurate to ~1e-3 over a
# full turn — ample for pixel placement. cos(x)=sin(x+pi/2).
def _fsin(xin: float64) -> float64:
    x: float64 = xin
    while x > _CV_PI:
        x = x - _CV_2PI
    while x < cast[float64](0) - _CV_PI:
        x = x + _CV_2PI
    x2: float64 = x * x
    t: float64 = cast[float64](1) - x2 / cast[float64](72)
    t = cast[float64](1) - x2 / cast[float64](42) * t
    t = cast[float64](1) - x2 / cast[float64](20) * t
    t = cast[float64](1) - x2 / cast[float64](6) * t
    return x * t


def _fcos(x: float64) -> float64:
    return _fsin(x + _CV_PI / cast[float64](2))


# sqrt via Newton iteration (non-negative input).
def _fsqrt(v: float64) -> float64:
    if v <= cast[float64](0):
        return cast[float64](0)
    g: float64 = v
    if g > cast[float64](1):
        g = v * cast[float64](0.5) + cast[float64](0.5)
    i: int32 = 0
    while i < 24:
        g = cast[float64](0.5) * (g + v / g)
        i = i + 1
    return g


# ---- CTM: composition (all post-multiply, per the Canvas spec) -----
def _ctm_is_identity(ci: int32) -> int32:
    if _cv_ma[ci] == cast[float64](1) and _cv_mb[ci] == cast[float64](0) and \
       _cv_mc[ci] == cast[float64](0) and _cv_md[ci] == cast[float64](1) and \
       _cv_me[ci] == cast[float64](0) and _cv_mf[ci] == cast[float64](0):
        return 1
    return 0


# Map user (x,y) through the CTM to device x / y (rounded to nearest int).
def _map_x(ci: int32, x: int32, y: int32) -> int32:
    v: float64 = _cv_ma[ci] * cast[float64](x) + _cv_mc[ci] * cast[float64](y) + \
                 _cv_me[ci]
    if v >= cast[float64](0):
        return cast[int32](v + cast[float64](0.5))
    return cast[int32](v - cast[float64](0.5))


def _map_y(ci: int32, x: int32, y: int32) -> int32:
    v: float64 = _cv_mb[ci] * cast[float64](x) + _cv_md[ci] * cast[float64](y) + \
                 _cv_mf[ci]
    if v >= cast[float64](0):
        return cast[int32](v + cast[float64](0.5))
    return cast[int32](v - cast[float64](0.5))


def htmlcanvas_save(ci: int32):
    if _ok(ci) == 0:
        return
    d: int32 = _cv_stk_n[ci]
    if d >= _CV_STK_MAX:
        return
    o: int32 = ci * _CV_STK_MAX + d
    _cv_sa[o] = _cv_ma[ci]
    _cv_sb[o] = _cv_mb[ci]
    _cv_sc[o] = _cv_mc[ci]
    _cv_sd[o] = _cv_md[ci]
    _cv_se[o] = _cv_me[ci]
    _cv_sf[o] = _cv_mf[ci]
    _cv_stk_n[ci] = d + 1


def htmlcanvas_restore(ci: int32):
    if _ok(ci) == 0:
        return
    d: int32 = _cv_stk_n[ci]
    if d <= 0:
        return
    d = d - 1
    o: int32 = ci * _CV_STK_MAX + d
    _cv_ma[ci] = _cv_sa[o]
    _cv_mb[ci] = _cv_sb[o]
    _cv_mc[ci] = _cv_sc[o]
    _cv_md[ci] = _cv_sd[o]
    _cv_me[ci] = _cv_se[o]
    _cv_mf[ci] = _cv_sf[o]
    _cv_stk_n[ci] = d


# M' = M * N, where N = [na nb nc nd ne nf]. Core of every transform below.
def _ctm_mul(ci: int32, na: float64, nb: float64, nc: float64, nd: float64,
             ne: float64, nf: float64):
    a: float64 = _cv_ma[ci]
    b: float64 = _cv_mb[ci]
    c: float64 = _cv_mc[ci]
    d: float64 = _cv_md[ci]
    e: float64 = _cv_me[ci]
    f: float64 = _cv_mf[ci]
    _cv_ma[ci] = a * na + c * nb
    _cv_mb[ci] = b * na + d * nb
    _cv_mc[ci] = a * nc + c * nd
    _cv_md[ci] = b * nc + d * nd
    _cv_me[ci] = a * ne + c * nf + e
    _cv_mf[ci] = b * ne + d * nf + f


def htmlcanvas_translate(ci: int32, tx: float64, ty: float64):
    if _ok(ci) == 0:
        return
    _ctm_mul(ci, cast[float64](1), cast[float64](0), cast[float64](0),
             cast[float64](1), tx, ty)


def htmlcanvas_scale(ci: int32, sx: float64, sy: float64):
    if _ok(ci) == 0:
        return
    _ctm_mul(ci, sx, cast[float64](0), cast[float64](0), sy,
             cast[float64](0), cast[float64](0))


def htmlcanvas_rotate(ci: int32, ang: float64):
    if _ok(ci) == 0:
        return
    cs: float64 = _fcos(ang)
    sn: float64 = _fsin(ang)
    _ctm_mul(ci, cs, sn, cast[float64](0) - sn, cs,
             cast[float64](0), cast[float64](0))


def htmlcanvas_transform(ci: int32, a: float64, b: float64, c: float64,
                         d: float64, e: float64, f: float64):
    if _ok(ci) == 0:
        return
    _ctm_mul(ci, a, b, c, d, e, f)


def htmlcanvas_set_transform(ci: int32, a: float64, b: float64, c: float64,
                             d: float64, e: float64, f: float64):
    if _ok(ci) == 0:
        return
    _cv_ma[ci] = a
    _cv_mb[ci] = b
    _cv_mc[ci] = c
    _cv_md[ci] = d
    _cv_me[ci] = e
    _cv_mf[ci] = f


def htmlcanvas_reset_transform(ci: int32):
    if _ok(ci) == 0:
        return
    _ctm_identity(ci)


# ---- gradients -----------------------------------------------------
# Register a gradient (kind 0=linear,1=radial). Returns an index (>=0) or -1.
def htmlcanvas_grad_new(kind: int32, x0: float64, y0: float64, r0: float64,
                        x1: float64, y1: float64, r1: float64) -> int32:
    if _grad_n >= _CV_GRAD_MAX:
        return -1
    gi: int32 = _grad_n
    _grad_kind[gi] = kind
    _grad_x0[gi] = x0
    _grad_y0[gi] = y0
    _grad_r0[gi] = r0
    _grad_x1[gi] = x1
    _grad_y1[gi] = y1
    _grad_r1[gi] = r1
    _grad_nstop[gi] = 0
    _grad_n = _grad_n + 1
    return gi


# addColorStop(offset, rgb): insert keeping stops sorted by ascending offset.
def htmlcanvas_grad_addstop(gi: int32, off: float64, rgb: int32):
    if gi < 0 or gi >= _grad_n:
        return
    n: int32 = _grad_nstop[gi]
    if n >= _CV_STOP_MAX:
        return
    base: int32 = gi * _CV_STOP_MAX
    p: int32 = n
    while p > 0 and _grad_soff[base + p - 1] > off:
        _grad_soff[base + p] = _grad_soff[base + p - 1]
        _grad_srgb[base + p] = _grad_srgb[base + p - 1]
        p = p - 1
    _grad_soff[base + p] = off
    _grad_srgb[base + p] = rgb
    _grad_nstop[gi] = n + 1


# The gradient's first colour stop (fallback paint for stroke/path-fill/text).
def htmlcanvas_grad_first_rgb(gi: int32) -> int32:
    if gi < 0 or gi >= _grad_n or _grad_nstop[gi] <= 0:
        return 0
    return _grad_srgb[gi * _CV_STOP_MAX]


def _lerp8(a: int32, b: int32, num: float64) -> int32:
    return a + cast[int32](cast[float64](b - a) * num)


# Colour of gradient `gi` at parameter t in 0..1 (0xRRGGBB).
def _grad_at_t(gi: int32, t: float64) -> int32:
    ns: int32 = _grad_nstop[gi]
    base: int32 = gi * _CV_STOP_MAX
    if ns <= 0:
        return 0
    if t <= _grad_soff[base]:
        return _grad_srgb[base]
    if t >= _grad_soff[base + ns - 1]:
        return _grad_srgb[base + ns - 1]
    i: int32 = 0
    while i < ns - 1:
        o0: float64 = _grad_soff[base + i]
        o1: float64 = _grad_soff[base + i + 1]
        if t >= o0 and t <= o1:
            span: float64 = o1 - o0
            frac: float64 = cast[float64](0)
            if span > cast[float64](0):
                frac = (t - o0) / span
            c0: int32 = _grad_srgb[base + i]
            c1: int32 = _grad_srgb[base + i + 1]
            r: int32 = _lerp8((c0 / 65536) & 255, (c1 / 65536) & 255, frac)
            g: int32 = _lerp8((c0 / 256) & 255, (c1 / 256) & 255, frac)
            b: int32 = _lerp8(c0 & 255, c1 & 255, frac)
            return (r << 16) | (g << 8) | b
        i = i + 1
    return _grad_srgb[base + ns - 1]


# Colour of gradient `gi` at USER-space point (ux,uy).
def _grad_color(gi: int32, ux: float64, uy: float64) -> int32:
    if _grad_kind[gi] == 0:
        dx: float64 = _grad_x1[gi] - _grad_x0[gi]
        dy: float64 = _grad_y1[gi] - _grad_y0[gi]
        len2: float64 = dx * dx + dy * dy
        t: float64 = cast[float64](0)
        if len2 > cast[float64](0):
            t = ((ux - _grad_x0[gi]) * dx + (uy - _grad_y0[gi]) * dy) / len2
        return _grad_at_t(gi, t)
    ddx: float64 = ux - _grad_x1[gi]
    ddy: float64 = uy - _grad_y1[gi]
    dist: float64 = _fsqrt(ddx * ddx + ddy * ddy)
    dr: float64 = _grad_r1[gi] - _grad_r0[gi]
    tr: float64 = cast[float64](0)
    if dr != cast[float64](0):
        tr = (dist - _grad_r0[gi]) / dr
    return _grad_at_t(gi, tr)


# ---- general (CTM-aware) rect rasteriser ---------------------------
# Composite one device pixel: source-copy when opaque, src-over when translucent.
def _blend_px(ci: int32, x: int32, y: int32, r: int32, g: int32, b: int32,
              a: int32):
    if a <= 0:
        return
    if a >= 255:
        _put_rgba(ci, x, y, cast[uint8](r), cast[uint8](g), cast[uint8](b), 255)
        return
    if x < 0 or y < 0 or x >= cv_w[ci] or y >= cv_h[ci]:
        return
    buf: Ptr[uint8] = htmlimg_buf_ptr(cv_slot[ci])
    o: uint64 = (cast[uint64](y) * cast[uint64](cv_w[ci]) + cast[uint64](x)) * 4
    dr: int32 = cast[int32](buf[o])
    dg: int32 = cast[int32](buf[o + 1])
    db: int32 = cast[int32](buf[o + 2])
    da: int32 = cast[int32](buf[o + 3])
    ia: int32 = 255 - a
    buf[o] = cast[uint8]((r * a + dr * ia) / 255)
    buf[o + 1] = cast[uint8]((g * a + dg * ia) / 255)
    buf[o + 2] = cast[uint8]((b * a + db * ia) / 255)
    buf[o + 3] = cast[uint8](a + da * ia / 255)


# Fill the user-space rect (x,y,w,h) mapped through the CTM. `mode`: 0 solid
# `rgb`, 1 gradient `gi`, 2 clear (write transparent). Iterates the device
# bounding box of the four transformed corners and inverse-maps each pixel centre
# back to user space to test membership + (for gradients) evaluate the paint.
def _paint_rect_general(ci: int32, x: int32, y: int32, w: int32, h: int32,
                        mode: int32, rgb: int32, gi: int32, alpha: int32):
    ux0: float64 = cast[float64](x)
    uy0: float64 = cast[float64](y)
    ux1: float64 = cast[float64](x + w)
    uy1: float64 = cast[float64](y + h)
    # four device corners
    dxa: float64 = _cv_ma[ci] * ux0 + _cv_mc[ci] * uy0 + _cv_me[ci]
    dya: float64 = _cv_mb[ci] * ux0 + _cv_md[ci] * uy0 + _cv_mf[ci]
    dxb: float64 = _cv_ma[ci] * ux1 + _cv_mc[ci] * uy0 + _cv_me[ci]
    dyb: float64 = _cv_mb[ci] * ux1 + _cv_md[ci] * uy0 + _cv_mf[ci]
    dxc: float64 = _cv_ma[ci] * ux1 + _cv_mc[ci] * uy1 + _cv_me[ci]
    dyc: float64 = _cv_mb[ci] * ux1 + _cv_md[ci] * uy1 + _cv_mf[ci]
    dxd: float64 = _cv_ma[ci] * ux0 + _cv_mc[ci] * uy1 + _cv_me[ci]
    dyd: float64 = _cv_mb[ci] * ux0 + _cv_md[ci] * uy1 + _cv_mf[ci]
    minx: float64 = dxa
    maxx: float64 = dxa
    miny: float64 = dya
    maxy: float64 = dya
    if dxb < minx:
        minx = dxb
    if dxb > maxx:
        maxx = dxb
    if dxc < minx:
        minx = dxc
    if dxc > maxx:
        maxx = dxc
    if dxd < minx:
        minx = dxd
    if dxd > maxx:
        maxx = dxd
    if dyb < miny:
        miny = dyb
    if dyb > maxy:
        maxy = dyb
    if dyc < miny:
        miny = dyc
    if dyc > maxy:
        maxy = dyc
    if dyd < miny:
        miny = dyd
    if dyd > maxy:
        maxy = dyd
    ix0: int32 = cast[int32](minx)
    ix1: int32 = cast[int32](maxx) + 1
    iy0: int32 = cast[int32](miny)
    iy1: int32 = cast[int32](maxy) + 1
    if ix0 < 0:
        ix0 = 0
    if iy0 < 0:
        iy0 = 0
    if ix1 > cv_w[ci]:
        ix1 = cv_w[ci]
    if iy1 > cv_h[ci]:
        iy1 = cv_h[ci]
    # inverse CTM
    det: float64 = _cv_ma[ci] * _cv_md[ci] - _cv_mb[ci] * _cv_mc[ci]
    if det == cast[float64](0):
        return
    ia: float64 = _cv_md[ci] / det
    ic: float64 = cast[float64](0) - _cv_mc[ci] / det
    ib: float64 = cast[float64](0) - _cv_mb[ci] / det
    idd: float64 = _cv_ma[ci] / det
    ie: float64 = (_cv_mc[ci] * _cv_mf[ci] - _cv_md[ci] * _cv_me[ci]) / det
    iff: float64 = (_cv_mb[ci] * _cv_me[ci] - _cv_ma[ci] * _cv_mf[ci]) / det
    r0: int32 = (rgb / 65536) & 255
    g0: int32 = (rgb / 256) & 255
    b0: int32 = rgb & 255
    py: int32 = iy0
    while py < iy1:
        dyf: float64 = cast[float64](py) + cast[float64](0.5)
        px: int32 = ix0
        while px < ix1:
            dxf: float64 = cast[float64](px) + cast[float64](0.5)
            uxp: float64 = ia * dxf + ic * dyf + ie
            uyp: float64 = ib * dxf + idd * dyf + iff
            if uxp >= ux0 and uxp < ux1 and uyp >= uy0 and uyp < uy1:
                if mode == 2:
                    _put_rgba(ci, px, py, 0, 0, 0, 0)
                elif mode == 1:
                    cc: int32 = _grad_color(gi, uxp, uyp)
                    _blend_px(ci, px, py, (cc / 65536) & 255, (cc / 256) & 255,
                              cc & 255, alpha)
                else:
                    _blend_px(ci, px, py, r0, g0, b0, alpha)
            px = px + 1
        py = py + 1


# ---- rectangles ----------------------------------------------------
# fillRect: opaque fills reuse htmlpaint_fill_rect; a translucent globalAlpha
# writes RGBA straight into the slot so the page blit blends it over the page.
def htmlcanvas_fill_rect(ci: int32, x: int32, y: int32, w: int32, h: int32,
                         rgb: int32, alpha: int32):
    if _ok(ci) == 0:
        return
    if _ctm_is_identity(ci) == 0:
        _paint_rect_general(ci, x, y, w, h, 0, rgb, -1, alpha)
        return
    r: uint8 = cast[uint8]((rgb / 65536) & 255)
    g: uint8 = cast[uint8]((rgb / 256) & 255)
    b: uint8 = cast[uint8](rgb & 255)
    if alpha >= 255:
        _target(ci)
        htmlpaint_fill_rect(x, y, w, h, r, g, b)
        _untarget()
    else:
        _fill_rgba(ci, x, y, w, h, r, g, b, cast[uint8](alpha & 255))


# fillRect with a gradient fillStyle: per-pixel interpolation, CTM-aware.
def htmlcanvas_fill_rect_grad(ci: int32, x: int32, y: int32, w: int32,
                              h: int32, gi: int32, alpha: int32):
    if _ok(ci) == 0:
        return
    _paint_rect_general(ci, x, y, w, h, 1, 0, gi, alpha)


def htmlcanvas_clear_rect(ci: int32, x: int32, y: int32, w: int32, h: int32):
    if _ok(ci) == 0:
        return
    if _ctm_is_identity(ci) == 0:
        _paint_rect_general(ci, x, y, w, h, 2, 0, -1, 0)
        return
    _fill_rgba(ci, x, y, w, h, 0, 0, 0, 0)


def htmlcanvas_stroke_rect(ci: int32, x: int32, y: int32, w: int32, h: int32,
                           rgb: int32, lw: int32):
    if _ok(ci) == 0:
        return
    r: uint8 = cast[uint8]((rgb / 65536) & 255)
    g: uint8 = cast[uint8]((rgb / 256) & 255)
    b: uint8 = cast[uint8](rgb & 255)
    # map the four corners through the CTM so a rotated/scaled strokeRect draws
    # the transformed quad (identity leaves the integer coords unchanged).
    ax: int32 = _map_x(ci, x, y)
    ay: int32 = _map_y(ci, x, y)
    bx: int32 = _map_x(ci, x + w, y)
    by: int32 = _map_y(ci, x + w, y)
    cx: int32 = _map_x(ci, x + w, y + h)
    cy: int32 = _map_y(ci, x + w, y + h)
    ex: int32 = _map_x(ci, x, y + h)
    ey: int32 = _map_y(ci, x, y + h)
    _target(ci)
    htmlpaint_stroke_line(ax, ay, bx, by, lw, r, g, b)
    htmlpaint_stroke_line(bx, by, cx, cy, lw, r, g, b)
    htmlpaint_stroke_line(cx, cy, ex, ey, lw, r, g, b)
    htmlpaint_stroke_line(ex, ey, ax, ay, lw, r, g, b)
    _untarget()


# ---- path building -------------------------------------------------
def htmlcanvas_begin(ci: int32):
    if _ok(ci) == 0:
        return
    cv_pn[ci] = 0
    cv_sub0[ci] = 0


def _path_add(ci: int32, x: int32, y: int32):
    n: int32 = cv_pn[ci]
    if n >= CV_PATH_MAX:
        return
    base: int32 = ci * CV_PATH_MAX
    cv_px[base + n] = x
    cv_py[base + n] = y
    cv_pn[ci] = n + 1


# moveTo/lineTo take USER coordinates and are mapped through the CTM before
# being stored, so a subsequent stroke()/fill() draws the transformed path.
def htmlcanvas_moveto(ci: int32, x: int32, y: int32):
    if _ok(ci) == 0:
        return
    cv_sub0[ci] = cv_pn[ci]
    _path_add(ci, _map_x(ci, x, y), _map_y(ci, x, y))


def htmlcanvas_lineto(ci: int32, x: int32, y: int32):
    if _ok(ci) == 0:
        return
    _path_add(ci, _map_x(ci, x, y), _map_y(ci, x, y))


def htmlcanvas_closepath(ci: int32):
    if _ok(ci) == 0:
        return
    s: int32 = cv_sub0[ci]
    if cv_pn[ci] > s:
        base: int32 = ci * CV_PATH_MAX
        _path_add(ci, cv_px[base + s], cv_py[base + s])


def _init_sin():
    if sin_ready != 0:
        return
    sin_t[0] = 0
    sin_t[1] = 401
    sin_t[2] = 799
    sin_t[3] = 1189
    sin_t[4] = 1567
    sin_t[5] = 1931
    sin_t[6] = 2276
    sin_t[7] = 2598
    sin_t[8] = 2896
    sin_t[9] = 3166
    sin_t[10] = 3406
    sin_t[11] = 3612
    sin_t[12] = 3784
    sin_t[13] = 3920
    sin_t[14] = 4017
    sin_t[15] = 4076
    sin_t[16] = 4096
    sin_t[17] = 4076
    sin_t[18] = 4017
    sin_t[19] = 3920
    sin_t[20] = 3784
    sin_t[21] = 3612
    sin_t[22] = 3406
    sin_t[23] = 3166
    sin_t[24] = 2896
    sin_t[25] = 2598
    sin_t[26] = 2276
    sin_t[27] = 1931
    sin_t[28] = 1567
    sin_t[29] = 1189
    sin_t[30] = 799
    sin_t[31] = 401
    sin_t[32] = 0
    sin_t[33] = -401
    sin_t[34] = -799
    sin_t[35] = -1189
    sin_t[36] = -1567
    sin_t[37] = -1931
    sin_t[38] = -2276
    sin_t[39] = -2598
    sin_t[40] = -2896
    sin_t[41] = -3166
    sin_t[42] = -3406
    sin_t[43] = -3612
    sin_t[44] = -3784
    sin_t[45] = -3920
    sin_t[46] = -4017
    sin_t[47] = -4076
    sin_t[48] = -4096
    sin_t[49] = -4076
    sin_t[50] = -4017
    sin_t[51] = -3920
    sin_t[52] = -3784
    sin_t[53] = -3612
    sin_t[54] = -3406
    sin_t[55] = -3166
    sin_t[56] = -2896
    sin_t[57] = -2598
    sin_t[58] = -2276
    sin_t[59] = -1931
    sin_t[60] = -1567
    sin_t[61] = -1189
    sin_t[62] = -799
    sin_t[63] = -401
    sin_ready = 1


def _sin(idx: int32) -> int32:
    i: int32 = idx & 63
    return sin_t[i]


def _cos(idx: int32) -> int32:
    i: int32 = (idx + 16) & 63
    return sin_t[i]


# arc(cx,cy,r, i0,i1): append a poly-approximated arc (i0..i1 are integer step
# indices, 0..64 over a full turn) to the current path, exactly like the real
# arc() so a following stroke()/fill() draws the outline / disc. The engine
# converts the JS radian angles to these indices.
def htmlcanvas_arc(ci: int32, cx: int32, cy: int32, rad: int32,
                   i0: int32, i1: int32):
    if _ok(ci) == 0:
        return
    _init_sin()
    a0: int32 = i0
    a1: int32 = i1
    if a1 < a0:
        a1 = a0
    steps: int32 = a1 - a0
    if steps > CIRC_N:
        steps = CIRC_N
    k: int32 = 0
    while k <= steps:
        idx: int32 = a0 + k
        px: int32 = cx + rad * _cos(idx) / 4096       # user-space arc point
        py: int32 = cy + rad * _sin(idx) / 4096
        mx: int32 = _map_x(ci, px, py)                # mapped through the CTM
        my: int32 = _map_y(ci, px, py)
        if cv_pn[ci] == 0:
            cv_sub0[ci] = 0
            _path_add(ci, mx, my)
        else:
            _path_add(ci, mx, my)
        k = k + 1


# ---- consuming the path --------------------------------------------
def htmlcanvas_stroke(ci: int32, rgb: int32, lw: int32):
    if _ok(ci) == 0:
        return
    n: int32 = cv_pn[ci]
    if n < 2:
        return
    r: uint8 = cast[uint8]((rgb / 65536) & 255)
    g: uint8 = cast[uint8]((rgb / 256) & 255)
    b: uint8 = cast[uint8](rgb & 255)
    base: int32 = ci * CV_PATH_MAX
    _target(ci)
    i: int32 = 0
    while i < n - 1:
        htmlpaint_stroke_line(cv_px[base + i], cv_py[base + i],
                              cv_px[base + i + 1], cv_py[base + i + 1],
                              lw, r, g, b)
        i = i + 1
    _untarget()


def htmlcanvas_fill(ci: int32, rgb: int32):
    if _ok(ci) == 0:
        return
    n: int32 = cv_pn[ci]
    if n < 3:
        return
    r: uint8 = cast[uint8]((rgb / 65536) & 255)
    g: uint8 = cast[uint8]((rgb / 256) & 255)
    b: uint8 = cast[uint8](rgb & 255)
    base: int32 = ci * CV_PATH_MAX
    _target(ci)
    htmlpaint_fill_poly(&cv_px[base], &cv_py[base], n, r, g, b)
    _untarget()


# ---- text ----------------------------------------------------------
# fillText(s,x,y): (x,y) is the text's left / alphabetic-baseline origin. Reuses
# htmlpaint's anti-aliased TrueType raster; `bold` selects the bold face slot.
def htmlcanvas_fill_text(ci: int32, x: int32, y: int32, rgb: int32,
                         px: int32, bold: int32, txt: Ptr[uint8], ln: int32):
    if _ok(ci) == 0:
        return
    r: uint8 = cast[uint8]((rgb / 65536) & 255)
    g: uint8 = cast[uint8]((rgb / 256) & 255)
    b: uint8 = cast[uint8](rgb & 255)
    face: int32 = FACE_TT_SANS
    if bold != 0:
        face = FACE_TT_SANS_BOLD
    # anchor mapped through the full CTM; glyph px scaled by the CTM's vertical
    # scale (the glyph raster itself stays axis-aligned — rotation of the text
    # run is documented out of scope).
    dx: int32 = _map_x(ci, x, y)
    dy: int32 = _map_y(ci, x, y)
    fpx: int32 = px
    if _ctm_is_identity(ci) == 0:
        sy: float64 = _fsqrt(_cv_mc[ci] * _cv_mc[ci] + _cv_md[ci] * _cv_md[ci])
        fpx = cast[int32](cast[float64](px) * sy + cast[float64](0.5))
        if fpx < 1:
            fpx = 1
    _target(ci)
    htmlpaint_text_ttf(dx, dy, face, fpx, txt, ln, r, g, b)
    _untarget()


def htmlcanvas_measure_text(px: int32, bold: int32, txt: Ptr[uint8],
                            ln: int32) -> int32:
    face: int32 = FACE_TT_SANS
    if bold != 0:
        face = FACE_TT_SANS_BOLD
    return htmlpaint_measure_ttf(face, px, txt, ln)


# ---- drawImage -----------------------------------------------------
# drawImage(img, dx, dy[, dw, dh]): nearest-neighbour blit of an already-decoded
# source (an lib/htmlimg slot `srcslot`, sw*sh px — this covers both a decoded
# <img>/Image and another <canvas>, whose backing buffer IS an htmlimg slot)
# into canvas `ci`'s RGBA slot, scaled to the dest rect. Compositing is src-over
# honouring the source pixel's own alpha combined with ctx.globalAlpha (`ga`,
# 0..255), so a transparent-background sprite blends over prior canvas content;
# the final page blit then composites the canvas over the page. The 9-arg
# source-sub-rectangle form and smoothing are documented as deferred.
def htmlcanvas_draw_image(ci: int32, srcslot: int32, sw: int32, sh: int32,
                          dx: int32, dy: int32, dw: int32, dh: int32,
                          ga: int32):
    if _ok(ci) == 0:
        return
    if srcslot < 0 or sw <= 0 or sh <= 0 or dw <= 0 or dh <= 0:
        return
    # CTM: map the dest anchor through the full matrix and scale the dest size by
    # the CTM's per-axis scale (the blit stays axis-aligned — image rotation is
    # documented out of scope).
    if _ctm_is_identity(ci) == 0:
        sxf: float64 = _fsqrt(_cv_ma[ci] * _cv_ma[ci] + _cv_mb[ci] * _cv_mb[ci])
        syf: float64 = _fsqrt(_cv_mc[ci] * _cv_mc[ci] + _cv_md[ci] * _cv_md[ci])
        ndw: int32 = cast[int32](cast[float64](dw) * sxf + cast[float64](0.5))
        ndh: int32 = cast[int32](cast[float64](dh) * syf + cast[float64](0.5))
        ndx: int32 = _map_x(ci, dx, dy)
        ndy: int32 = _map_y(ci, dx, dy)
        dx = ndx
        dy = ndy
        if ndw > 0:
            dw = ndw
        if ndh > 0:
            dh = ndh
    sbuf: Ptr[uint8] = htmlimg_buf_ptr(srcslot)
    dbuf: Ptr[uint8] = htmlimg_buf_ptr(cv_slot[ci])
    dW: int32 = cv_w[ci]
    dH: int32 = cv_h[ci]
    j: int32 = 0
    while j < dh:
        py: int32 = dy + j
        if py >= 0 and py < dH:
            syj: int32 = j * sh / dh
            if syj >= sh:
                syj = sh - 1
            i: int32 = 0
            while i < dw:
                px: int32 = dx + i
                if px >= 0 and px < dW:
                    sxi: int32 = i * sw / dw
                    if sxi >= sw:
                        sxi = sw - 1
                    so: uint64 = (cast[uint64](syj) * cast[uint64](sw) + \
                                  cast[uint64](sxi)) * 4
                    sr: int32 = cast[int32](sbuf[so])
                    sg: int32 = cast[int32](sbuf[so + 1])
                    sb: int32 = cast[int32](sbuf[so + 2])
                    sa: int32 = cast[int32](sbuf[so + 3])
                    a: int32 = sa * ga / 255
                    if a > 0:
                        dof: uint64 = (cast[uint64](py) * cast[uint64](dW) + \
                                       cast[uint64](px)) * 4
                        if a >= 255:
                            dbuf[dof] = cast[uint8](sr)
                            dbuf[dof + 1] = cast[uint8](sg)
                            dbuf[dof + 2] = cast[uint8](sb)
                            dbuf[dof + 3] = 255
                        else:
                            dr: int32 = cast[int32](dbuf[dof])
                            dg: int32 = cast[int32](dbuf[dof + 1])
                            db: int32 = cast[int32](dbuf[dof + 2])
                            da: int32 = cast[int32](dbuf[dof + 3])
                            ia: int32 = 255 - a
                            dbuf[dof] = cast[uint8]((sr * a + dr * ia) / 255)
                            dbuf[dof + 1] = cast[uint8]((sg * a + dg * ia) / 255)
                            dbuf[dof + 2] = cast[uint8]((sb * a + db * ia) / 255)
                            dbuf[dof + 3] = cast[uint8](a + da * ia / 255)
                i = i + 1
        j = j + 1


# ---- raw pixel access (getImageData / putImageData) ----------------
# One RGBA texel of canvas `ci` at device (x,y), packed 0xRRGGBBAA. Out of range
# reads transparent black. putImageData/getImageData work in DEVICE space (they
# ignore the CTM, per the Canvas spec).
def htmlcanvas_read_rgba(ci: int32, x: int32, y: int32) -> int32:
    if _ok(ci) == 0:
        return 0
    if x < 0 or y < 0 or x >= cv_w[ci] or y >= cv_h[ci]:
        return 0
    buf: Ptr[uint8] = htmlimg_buf_ptr(cv_slot[ci])
    o: uint64 = (cast[uint64](y) * cast[uint64](cv_w[ci]) + cast[uint64](x)) * 4
    r: int32 = cast[int32](buf[o])
    g: int32 = cast[int32](buf[o + 1])
    b: int32 = cast[int32](buf[o + 2])
    a: int32 = cast[int32](buf[o + 3])
    return (r << 24) | (g << 16) | (b << 8) | a


def htmlcanvas_write_rgba(ci: int32, x: int32, y: int32, r: int32, g: int32,
                          b: int32, a: int32):
    if _ok(ci) == 0:
        return
    _put_rgba(ci, x, y, cast[uint8](r & 255), cast[uint8](g & 255),
              cast[uint8](b & 255), cast[uint8](a & 255))


def htmlcanvas_width(ci: int32) -> int32:
    if _ok(ci) == 0:
        return 0
    return cv_w[ci]


def htmlcanvas_height(ci: int32) -> int32:
    if _ok(ci) == 0:
        return 0
    return cv_h[ci]

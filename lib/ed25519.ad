# lib/ed25519.ad
#
# Ed25519 signature VERIFICATION (RFC 8032) + streaming SHA-512.
#
# This is a faithful, self-contained port of the public-domain
# TweetNaCl reference implementation (Bernstein/van Gastel/Janssen/
# Lange/Schwabe/Schwabe, `crypto_sign_open`) into Adder. It exposes a
# single detached-signature verifier:
#
#     ed25519_verify(pk, sig, msg, msglen) -> 1 valid / 0 invalid
#
# WHY A PORT (not hand-rolled): rolling curve crypto from scratch is a
# footgun. TweetNaCl is small, widely audited, and validated here
# against RFC 8032 test vectors (tests/test_ed25519_verify.ad, driven
# host-side by scripts/test_hpm_signed_index.sh). The field/point layer
# uses TweetNaCl's 16-limb (16 x 16-bit) representation held in i64
# accumulators — the same one the reference uses — so every reduction
# constant matches the source byte-for-byte.
#
# The module is PURE COMPUTATION: no syscalls, no allocation. Every
# temporary is a top-level BSS array (single-threaded; verification is
# never re-entered), matching the hpm compiler-quirk discipline. That
# also lets the same object link into the freestanding x86_64-linux
# host test AND the Hamnix hpm binary unchanged.
#
# Consumers: user/hpm.ad (verifies the repo index signature).

# ======================================================================
# SHA-512 (streaming: init / update / final) — TweetNaCl crypto_hash.
# ======================================================================

sha512_h:     Array[8, uint64]
sha512_k:     Array[80, uint64]
sha512_w:     Array[16, uint64]
sha512_a:     Array[8, uint64]
sha512_b:     Array[8, uint64]
sha512_block: Array[128, uint8]
sha512_blen:  uint64 = 0
sha512_total: uint64 = 0
sha512_kset:  int32 = 0


def _rotr64(x: uint64, c: uint64) -> uint64:
    return (x >> c) | (x << (64 - c))


def _sha512_S0(x: uint64) -> uint64:
    return _rotr64(x, 28) ^ _rotr64(x, 34) ^ _rotr64(x, 39)


def _sha512_S1(x: uint64) -> uint64:
    return _rotr64(x, 14) ^ _rotr64(x, 18) ^ _rotr64(x, 41)


def _sha512_s0(x: uint64) -> uint64:
    return _rotr64(x, 1) ^ _rotr64(x, 8) ^ (x >> 7)


def _sha512_s1(x: uint64) -> uint64:
    return _rotr64(x, 19) ^ _rotr64(x, 61) ^ (x >> 6)


def _sha512_ch(x: uint64, y: uint64, z: uint64) -> uint64:
    return (x & y) ^ ((~x) & z)


def _sha512_maj(x: uint64, y: uint64, z: uint64) -> uint64:
    return (x & y) ^ (x & z) ^ (y & z)


def _dl64(p: Ptr[uint8], off: uint64) -> uint64:
    u: uint64 = 0
    i: uint64 = 0
    while i < 8:
        u = (u << 8) | cast[uint64](p[off + i])
        i = i + 1
    return u


def _st64(p: Ptr[uint8], off: uint64, u: uint64):
    v: uint64 = u
    i: uint64 = 0
    while i < 8:
        p[off + 7 - i] = cast[uint8](v & 0xFF)
        v = v >> 8
        i = i + 1



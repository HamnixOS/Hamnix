# lib/htmlpaint.ad — the GRAPHICAL (pixel) paint backend for hambrowse.
#
# THE CEILING THIS BREAKS
# =======================
# lib/htmlengine.ad parses HTML+CSS+JS and lays the document out as a list of
# styled SEGMENTS on a MONOSPACE 8px CHARACTER GRID. That grid is the ceiling
# on "looks like a real browser": every glyph is a fixed 8px cell, no font
# sizes, no proportional text. This module KEEPS all of that parse/cascade/JS
# work and replaces only the LAYOUT+PAINT tail: it re-flows the engine's
# segments onto a REAL RGB PIXEL CANVAS using PROPORTIONAL BDF fonts (per-glyph
# DWIDTH advance from lib/font_bdf.ad), a font HIERARCHY (headings render in a
# larger, bold face; <pre>/<code> in the monospace face), real pixel block
# stacking with per-row heights, background fills, underlines and rules — and
# emits a PPM a human/agent can LOOK at (converted to PNG by the host driver).
#
# PURITY: no `extern`, no syscalls, no I/O. It reads the laid-out segment table
# through lib/htmlengine.ad's he_seg_* accessors and fills a BSS framebuffer +
# a PPM header into a caller buffer. It links into BOTH the x86_64-linux host
# target (where user/hambrowse_host_gfx.ad dumps a PNG, no QEMU) and the native
# target. Font bytes are supplied by the caller (the host driver reads the .bdf
# files; the native driver embeds them) via htmlpaint_load_face().
#
# FONT-SIZE MAPPING (honest limitation)
# =====================================
# The three bundled BDF faces are FIXED-SIZE bitmaps (sans 6x10, mono 8x16,
# serif 6x12), so there is no true scalable font-size. We approximate a CSS
# heading hierarchy by INTEGER-SCALING the proportional sans bitmap (nearest-
# size, honest) and toggling bold. The seg_face byte set by the engine maps:
#     0 body   -> sans   x1
#     1 mono   -> mono   x1  (fixed 8px advance; keeps <pre>/tables aligned)
#     2 h1     -> sans   x3  bold
#     3 h2     -> sans   x2  bold
#     4 h3     -> sans   x2
#     5 h4     -> sans   x1  bold
#     6 h5     -> sans   x1  bold
#     7 h6     -> sans   x1
# Because the source bitmap is 10px, scaled headings are blocky (no hinting/
# antialiasing) and only 3 discrete sizes exist — a genuine limitation of a
# fixed-size bitmap font store, called out here rather than hidden.

from lib.font_bdf import font_bdf_parse, font_bdf_expand, FONT_BDF_BASE_CP, \
    FONT_BDF_N_GLYPHS
from lib.font_ttf import font_ttf_load, font_ttf_loaded, font_ttf_render, \
    font_ttf_adv_px, font_ttf_adv_fu, font_ttf_fu_to_px, \
    font_ttf_ascent_px, font_ttf_descent_px, \
    glyph_bw, glyph_bh, glyph_xoff, glyph_ytop, glyph_adv, glyph_cov
from lib.htmlimg import htmlimg_w, htmlimg_h, htmlimg_pixel


# ====================================================================
# Font store — up to 3 faces, flattened [face*95 + cp] tables.
# ====================================================================
HP_NFACE:  uint64 = 3
FACE_SANS: int32 = 0
FACE_MONO: int32 = 1
FACE_SERIF: int32 = 2

# per-face-per-glyph tables (3 * 95 = 285)
hp_gw:   Array[285, uint8]
hp_gh:   Array[285, uint8]
hp_gadv: Array[285, uint8]
hp_goff: Array[285, uint32]
# packed bitmap rows, 12288 bytes per face slot
HP_FACE_BITS: uint64 = 12288
hp_gbits: Array[36864, uint8]
# per-face metrics
hp_ascent:  Array[3, int32]
hp_descent: Array[3, int32]
hp_loaded:  Array[3, int32]

# scratch for parse ascent/descent read-back
_hp_asc: Array[1, int64]
_hp_desc: Array[1, int64]
# scratch for one expanded glyph (max mono 8x16 = 128; generous 1024)
_hp_glyph: Array[1024, uint8]


# Load one BDF face from a byte buffer into face slot `face`. Returns the glyph
# count (>=0) or a negative font_bdf error.
def htmlpaint_load_face(face: int32, buf: Ptr[uint8], buflen: uint64) -> int64:
    if face < 0 or cast[uint64](face) >= HP_NFACE:
        return -100
    base: uint64 = cast[uint64](face) * FONT_BDF_N_GLYPHS
    bitbase: uint64 = cast[uint64](face) * HP_FACE_BITS
    n: int64 = font_bdf_parse(buf, buflen,
                              &hp_gw[base], &hp_gh[base], &hp_goff[base],
                              &hp_gbits[bitbase], HP_FACE_BITS,
                              &hp_gadv[base], &_hp_asc[0], &_hp_desc[0])
    if n < 0:
        return n
    hp_ascent[face]  = cast[int32](_hp_asc[0])
    hp_descent[face] = cast[int32](_hp_desc[0])
    hp_loaded[face]  = 1
    return n


def _face_ok(face: int32) -> int32:
    if face < 0 or cast[uint64](face) >= HP_NFACE:
        return 0
    return hp_loaded[face]


# Advance (px) of codepoint cp in `face` at integer `scale`, +1*scale for bold.
def _glyph_adv(face: int32, cp: uint8, scale: int32, bold: int32) -> int32:
    if _face_ok(face) == 0:
        return 6 * scale
    if cast[int64](cp) < cast[int64](FONT_BDF_BASE_CP):
        return 3 * scale
    idx: uint64 = cast[uint64](face) * FONT_BDF_N_GLYPHS + \
                  (cast[uint64](cp) - FONT_BDF_BASE_CP)
    if cast[uint64](cp) - FONT_BDF_BASE_CP >= FONT_BDF_N_GLYPHS:
        return 3 * scale
    adv: int32 = cast[int32](hp_gadv[idx])
    if adv <= 0:
        adv = 4
    a: int32 = adv * scale
    if bold != 0:
        a = a + scale
    return a


# Face ascent/descent scaled.
def htmlpaint_face_ascent(face: int32, scale: int32) -> int32:
    if _face_ok(face) == 0:
        return 8 * scale
    return hp_ascent[face] * scale


def htmlpaint_face_height(face: int32, scale: int32) -> int32:
    if _face_ok(face) == 0:
        return 10 * scale
    return (hp_ascent[face] + hp_descent[face]) * scale


# ====================================================================
# Framebuffer (BSS). Row-major RGB, 3 bytes/pixel. Sized for the viewport plus
# a few screens of scroll — NOT an unbounded page.
# ====================================================================
# HP_MAX_H was 4000 (a 12 MB fb). On a low-RAM (~256 MB) DE image where the
# browser is the largest working set of any app, that fixed BSS was a big slice
# of the pre-window fault-in and helped push hambrowse into an OOM before its
# window even opened (issue: "the web browser doesn't open at all"). A 2000px
# ceiling still covers the tallest laid-out fixture (~1669px) with margin and
# ~3 viewports of scroll; taller pages clip at the ceiling (htmlpaint_begin
# clamps), which is acceptable — the window opens and the top of the page reads.
# Keep this the single source of truth: the hp_fb array MUST equal
# HP_MAX_W*HP_MAX_H*3 (guarded by scripts/test_htmlpaint_bounds_host.sh).
HP_MAX_W: uint64 = 1000
HP_MAX_H: uint64 = 2000
hp_fb: Array[6000000, uint8]         # 1000*2000*3
hp_w: int32 = 0
hp_h: int32 = 0

# Optional EXTERNAL render target (RGBA8888). When hp_tgt_addr != 0 the pixel
# primitives (_put_px / _blend_px — hence fill_rect + all text) draw into this
# caller-supplied buffer instead of the internal RGB framebuffer. The native
# browser uses it to paint anti-aliased CHROME text (title/URL/status) straight
# into the compositor's v2-blit backbuffer. Default 0 => internal hp_fb, so the
# host PPM path is bit-for-bit unchanged (it never calls the setter).
hp_tgt_addr:   uint64 = 0
hp_tgt_w:      int32 = 0
hp_tgt_h:      int32 = 0
hp_tgt_stride: uint64 = 0


# Redirect subsequent draws to an external RGBA8888 buffer (w*4 stride).
def htmlpaint_target_rgba(addr: Ptr[uint8], w: int32, h: int32):
    hp_tgt_addr = cast[uint64](addr)
    hp_tgt_w = w
    hp_tgt_h = h
    hp_tgt_stride = cast[uint64](w) * 4


# Restore draws to the internal RGB framebuffer (the default).
def htmlpaint_target_internal():
    hp_tgt_addr = 0


def htmlpaint_width() -> int32:
    return hp_w


def htmlpaint_height() -> int32:
    return hp_h


def htmlpaint_fb_ptr() -> Ptr[uint8]:
    return &hp_fb[0]


def htmlpaint_fb_bytes() -> uint64:
    return cast[uint64](hp_w) * cast[uint64](hp_h) * 3


# Packed 0x00RRGGBB at (x,y); 0 if out of range. For gate assertions.
def htmlpaint_pixel(x: int32, y: int32) -> uint32:
    if x < 0 or y < 0 or x >= hp_w or y >= hp_h:
        return 0
    o: uint64 = (cast[uint64](y) * cast[uint64](hp_w) + cast[uint64](x)) * 3
    r: uint32 = cast[uint32](hp_fb[o])
    g: uint32 = cast[uint32](hp_fb[o + 1])
    b: uint32 = cast[uint32](hp_fb[o + 2])
    return (r << 16) | (g << 8) | b


def _put_px(x: int32, y: int32, r: uint8, g: uint8, b: uint8):
    if hp_tgt_addr != 0:
        if x < 0 or y < 0 or x >= hp_tgt_w or y >= hp_tgt_h:
            return
        t: Ptr[uint8] = cast[Ptr[uint8]](hp_tgt_addr)
        to: uint64 = cast[uint64](y) * hp_tgt_stride + cast[uint64](x) * 4
        t[to] = r
        t[to + 1] = g
        t[to + 2] = b
        t[to + 3] = 255
        return
    if x < 0 or y < 0 or x >= hp_w or y >= hp_h:
        return
    o: uint64 = (cast[uint64](y) * cast[uint64](hp_w) + cast[uint64](x)) * 3
    hp_fb[o] = r
    hp_fb[o + 1] = g
    hp_fb[o + 2] = b


def htmlpaint_fill_rect(x: int32, y: int32, w: int32, h: int32,
                        r: uint8, g: uint8, b: uint8):
    yy: int32 = y
    ylim: int32 = y + h
    while yy < ylim:
        xx: int32 = x
        xlim: int32 = x + w
        while xx < xlim:
            _put_px(xx, yy, r, g, b)
            xx = xx + 1
        yy = yy + 1


# ---- CSS filter post-pass ----------------------------------------------------
# A per-pixel filter applied to an element's background-fill rectangle AFTER it
# is painted (htmlpage_render end-pass). Operates on the internal RGB
# framebuffer only (the host render-to-PNG path); a no-op when draws are
# redirected to an external RGBA target. The packed value is (type << 20) |
# amount — see lib/web/css/cascade.ad _filter_value. amount is a percent
# (grayscale(0.5)==grayscale(50%)==50) for the colour filters, or a pixel radius
# for blur. HONEST SCOPE: grayscale/brightness/invert/sepia/contrast/saturate are
# exact per-pixel transforms; opacity() is approximated by lightening toward
# white (no real backdrop compositing here); blur is a separable box blur;
# drop-shadow is recognised but painted as a no-op (offset/colour not modelled).
HPF_GRAYSCALE: int32 = 1
HPF_BRIGHTNESS: int32 = 2
HPF_INVERT: int32 = 3
HPF_SEPIA: int32 = 4
HPF_CONTRAST: int32 = 5
HPF_BLUR: int32 = 6
HPF_SATURATE: int32 = 7
HPF_OPACITY: int32 = 8
HPF_DROPSHADOW: int32 = 9
HPF_HUEROTATE: int32 = 10

HPF_BLUR_MAX: int32 = 4096
_hpf_tr: Array[4096, int32]
_hpf_tg: Array[4096, int32]
_hpf_tb: Array[4096, int32]


def _hp_clamp8(v: int32) -> int32:
    if v < 0:
        return 0
    if v > 255:
        return 255
    return v


# Rec.601 luma (0.299/0.587/0.114) in 8.8 fixed point.
def _hp_luma(r: int32, g: int32, b: int32) -> int32:
    return (r * 77 + g * 150 + b * 29) >> 8


# Separable box blur over the internal-fb rect [x0,x0+w) x [y0,y0+h), radius rad.
def _hp_box_blur(x0: int32, y0: int32, w: int32, h: int32, rad: int32):
    if rad <= 0 or w <= 0 or h <= 0:
        return
    if w > HPF_BLUR_MAX or h > HPF_BLUR_MAX:
        return
    win: int32 = 2 * rad + 1
    # ---- horizontal pass: each row, box-average its span in place ----
    yy: int32 = y0
    while yy < y0 + h:
        if yy >= 0 and yy < hp_h:
            base: uint64 = cast[uint64](yy) * cast[uint64](hp_w) * 3
            i: int32 = 0
            while i < w:
                px: int32 = x0 + i
                if px >= 0 and px < hp_w:
                    o: uint64 = base + cast[uint64](px) * 3
                    _hpf_tr[i] = cast[int32](hp_fb[o])
                    _hpf_tg[i] = cast[int32](hp_fb[o + 1])
                    _hpf_tb[i] = cast[int32](hp_fb[o + 2])
                else:
                    _hpf_tr[i] = 0
                    _hpf_tg[i] = 0
                    _hpf_tb[i] = 0
                i = i + 1
            i = 0
            while i < w:
                px: int32 = x0 + i
                if px >= 0 and px < hp_w:
                    sr: int32 = 0
                    sg: int32 = 0
                    sb: int32 = 0
                    cnt: int32 = 0
                    k: int32 = i - rad
                    while k <= i + rad:
                        if k >= 0 and k < w:
                            sr = sr + _hpf_tr[k]
                            sg = sg + _hpf_tg[k]
                            sb = sb + _hpf_tb[k]
                            cnt = cnt + 1
                        k = k + 1
                    if cnt < 1:
                        cnt = 1
                    o: uint64 = base + cast[uint64](px) * 3
                    hp_fb[o] = cast[uint8](sr / cnt)
                    hp_fb[o + 1] = cast[uint8](sg / cnt)
                    hp_fb[o + 2] = cast[uint8](sb / cnt)
                i = i + 1
        yy = yy + 1
    # ---- vertical pass: each column, box-average its span in place ----
    xx: int32 = x0
    while xx < x0 + w:
        if xx >= 0 and xx < hp_w:
            j: int32 = 0
            while j < h:
                py: int32 = y0 + j
                if py >= 0 and py < hp_h:
                    o: uint64 = (cast[uint64](py) * cast[uint64](hp_w) + cast[uint64](xx)) * 3
                    _hpf_tr[j] = cast[int32](hp_fb[o])
                    _hpf_tg[j] = cast[int32](hp_fb[o + 1])
                    _hpf_tb[j] = cast[int32](hp_fb[o + 2])
                else:
                    _hpf_tr[j] = 0
                    _hpf_tg[j] = 0
                    _hpf_tb[j] = 0
                j = j + 1
            j = 0
            while j < h:
                py: int32 = y0 + j
                if py >= 0 and py < hp_h:
                    sr: int32 = 0
                    sg: int32 = 0
                    sb: int32 = 0
                    cnt: int32 = 0
                    k: int32 = j - rad
                    while k <= j + rad:
                        if k >= 0 and k < h:
                            sr = sr + _hpf_tr[k]
                            sg = sg + _hpf_tg[k]
                            sb = sb + _hpf_tb[k]
                            cnt = cnt + 1
                        k = k + 1
                    if cnt < 1:
                        cnt = 1
                    o: uint64 = (cast[uint64](py) * cast[uint64](hp_w) + cast[uint64](xx)) * 3
                    hp_fb[o] = cast[uint8](sr / cnt)
                    hp_fb[o + 1] = cast[uint8](sg / cnt)
                    hp_fb[o + 2] = cast[uint8](sb / cnt)
                j = j + 1
        xx = xx + 1


# Apply the packed CSS filter to the fill rectangle [x0,x0+w) x [y0,y0+h).
def htmlpaint_filter_rect(x0: int32, y0: int32, w: int32, h: int32, fpk: int32):
    if fpk == 0:
        return
    if hp_tgt_addr != 0:
        return                                           # internal-fb PNG path only
    ftype: int32 = (fpk >> 20) & 0xFFF
    amt: int32 = fpk & 0xFFFFF
    if ftype == HPF_DROPSHADOW:
        return                                           # recognised, painted no-op
    if ftype == HPF_BLUR:
        _hp_box_blur(x0, y0, w, h, amt)
        return
    # hue-rotate: the CSS Filter Effects luma-preserving colour-rotation matrix,
    # coefficients scaled by 1000 (c/s from _hp_*1000). Computed ONCE per rect.
    hc: int32 = 0
    hs: int32 = 0
    ha00: int32 = 0
    ha01: int32 = 0
    ha02: int32 = 0
    ha10: int32 = 0
    ha11: int32 = 0
    ha12: int32 = 0
    ha20: int32 = 0
    ha21: int32 = 0
    ha22: int32 = 0
    if ftype == HPF_HUEROTATE:
        hc = _hp_cos1000(amt)
        hs = _hp_sin1000(amt)
        ha00 = 213 + (787 * hc - 213 * hs) / 1000
        ha01 = 715 + (0 - 715 * hc - 715 * hs) / 1000
        ha02 = 72 + (0 - 72 * hc + 928 * hs) / 1000
        ha10 = 213 + (0 - 213 * hc + 143 * hs) / 1000
        ha11 = 715 + (285 * hc + 140 * hs) / 1000
        ha12 = 72 + (0 - 72 * hc - 283 * hs) / 1000
        ha20 = 213 + (0 - 213 * hc - 787 * hs) / 1000
        ha21 = 715 + (0 - 715 * hc + 715 * hs) / 1000
        ha22 = 72 + (928 * hc + 72 * hs) / 1000
    yy: int32 = y0
    ylim: int32 = y0 + h
    while yy < ylim:
        if yy >= 0 and yy < hp_h:
            xx: int32 = x0
            xlim: int32 = x0 + w
            while xx < xlim:
                if xx >= 0 and xx < hp_w:
                    o: uint64 = (cast[uint64](yy) * cast[uint64](hp_w) + cast[uint64](xx)) * 3
                    r: int32 = cast[int32](hp_fb[o])
                    g: int32 = cast[int32](hp_fb[o + 1])
                    b: int32 = cast[int32](hp_fb[o + 2])
                    nr: int32 = r
                    ng: int32 = g
                    nb: int32 = b
                    if ftype == HPF_GRAYSCALE:
                        p: int32 = amt
                        if p > 100:
                            p = 100
                        lum: int32 = _hp_luma(r, g, b)
                        nr = r + (lum - r) * p / 100
                        ng = g + (lum - g) * p / 100
                        nb = b + (lum - b) * p / 100
                    elif ftype == HPF_INVERT:
                        p: int32 = amt
                        if p > 100:
                            p = 100
                        nr = r + (255 - r - r) * p / 100
                        ng = g + (255 - g - g) * p / 100
                        nb = b + (255 - b - b) * p / 100
                    elif ftype == HPF_BRIGHTNESS:
                        nr = r * amt / 100
                        ng = g * amt / 100
                        nb = b * amt / 100
                    elif ftype == HPF_CONTRAST:
                        nr = (r - 128) * amt / 100 + 128
                        ng = (g - 128) * amt / 100 + 128
                        nb = (b - 128) * amt / 100 + 128
                    elif ftype == HPF_SEPIA:
                        p: int32 = amt
                        if p > 100:
                            p = 100
                        sr: int32 = (r * 393 + g * 769 + b * 189) / 1000
                        sg: int32 = (r * 349 + g * 686 + b * 168) / 1000
                        sb: int32 = (r * 272 + g * 534 + b * 131) / 1000
                        nr = r + (sr - r) * p / 100
                        ng = g + (sg - g) * p / 100
                        nb = b + (sb - b) * p / 100
                    elif ftype == HPF_SATURATE:
                        lum: int32 = _hp_luma(r, g, b)
                        nr = lum + (r - lum) * amt / 100
                        ng = lum + (g - lum) * amt / 100
                        nb = lum + (b - lum) * amt / 100
                    elif ftype == HPF_OPACITY:
                        # approximate: lighten toward white by (1 - opacity).
                        p: int32 = amt
                        if p > 100:
                            p = 100
                        inv: int32 = 100 - p
                        nr = r + (255 - r) * inv / 100
                        ng = g + (255 - g) * inv / 100
                        nb = b + (255 - b) * inv / 100
                    elif ftype == HPF_HUEROTATE:
                        nr = (ha00 * r + ha01 * g + ha02 * b) / 1000
                        ng = (ha10 * r + ha11 * g + ha12 * b) / 1000
                        nb = (ha20 * r + ha21 * g + ha22 * b) / 1000
                    hp_fb[o] = cast[uint8](_hp_clamp8(nr))
                    hp_fb[o + 1] = cast[uint8](_hp_clamp8(ng))
                    hp_fb[o + 2] = cast[uint8](_hp_clamp8(nb))
                xx = xx + 1
        yy = yy + 1


# floor(sqrt(n)) via integer Newton iteration (matches the compositor twin).
def _hp_isqrt(n: int32) -> int32:
    if n <= 0:
        return 0
    x: int32 = n
    y: int32 = (x + 1) / 2
    while y < x:
        x = y
        y = (x + n / x) / 2
    return x


# Clamp a border-radius to a legal value for a w*h box (never past half either
# axis, never negative).
def _hp_clamp_rad(w: int32, h: int32, rad: int32) -> int32:
    rr: int32 = rad
    if rr < 0:
        rr = 0
    if rr > w / 2:
        rr = w / 2
    if rr > h / 2:
        rr = h / 2
    return rr


# Fill a rounded rectangle SOLID. Corner pixels outside the arc are left
# untouched (the parent background / page shows through), so no restore colour is
# needed. rad<=0 falls back to a plain rectangle (byte-identical to before).
def htmlpaint_fill_round_rect(x: int32, y: int32, w: int32, h: int32, rad: int32,
                              r: uint8, g: uint8, b: uint8):
    if w <= 0 or h <= 0:
        return
    rr: int32 = _hp_clamp_rad(w, h, rad)
    if rr <= 0:
        htmlpaint_fill_rect(x, y, w, h, r, g, b)
        return
    j: int32 = 0
    while j < h:
        inset: int32 = 0
        # dy = vertical distance INTO the corner (1..rr) for rows inside a corner
        # band; 0 for the straight middle. rem = rr^2 - dy^2 >= 0.
        dy: int32 = 0
        if j < rr:
            dy = rr - j
        elif j >= h - rr:
            dy = j - (h - rr) + 1
        if dy > 0:
            rem: int32 = rr * rr - dy * dy
            if rem < 0:
                rem = 0
            inset = rr - _hp_isqrt(rem)
        span: int32 = w - 2 * inset
        if span > 0:
            htmlpaint_fill_rect(x + inset, y + j, span, 1, r, g, b)
        j = j + 1


# Stroke a 1px rounded-rectangle OUTLINE in colour (r,g,b). Straight edges are
# drawn inset by the radius; the four corners are traced as arc pixels. rad<=0
# falls back to a square 1px frame (byte-identical to the old four fill_rects).
def htmlpaint_stroke_round_rect(x: int32, y: int32, w: int32, h: int32,
                                rad: int32, r: uint8, g: uint8, b: uint8):
    if w <= 0 or h <= 0:
        return
    rr: int32 = _hp_clamp_rad(w, h, rad)
    if rr <= 0:
        htmlpaint_fill_rect(x, y, w, 1, r, g, b)              # top
        htmlpaint_fill_rect(x, y + h - 1, w, 1, r, g, b)      # bottom
        htmlpaint_fill_rect(x, y, 1, h, r, g, b)              # left
        htmlpaint_fill_rect(x + w - 1, y, 1, h, r, g, b)      # right
        return
    # straight edges between the corner arcs.
    htmlpaint_fill_rect(x + rr, y, w - 2 * rr, 1, r, g, b)             # top
    htmlpaint_fill_rect(x + rr, y + h - 1, w - 2 * rr, 1, r, g, b)     # bottom
    htmlpaint_fill_rect(x, y + rr, 1, h - 2 * rr, r, g, b)            # left
    htmlpaint_fill_rect(x + w - 1, y + rr, 1, h - 2 * rr, r, g, b)     # right
    # corner arcs: one boundary pixel per row of each corner band.
    j: int32 = 0
    while j < rr:
        dy: int32 = rr - j
        rem: int32 = rr * rr - dy * dy
        if rem < 0:
            rem = 0
        inset: int32 = rr - _hp_isqrt(rem)
        _put_px(x + inset, y + j, r, g, b)                    # TL
        _put_px(x + w - 1 - inset, y + j, r, g, b)            # TR
        _put_px(x + inset, y + h - 1 - j, r, g, b)            # BL
        _put_px(x + w - 1 - inset, y + h - 1 - j, r, g, b)    # BR
        j = j + 1


# Stroke a line from (x0,y0) to (x1,y1) `lw` px wide in colour (r,g,b), via an
# integer Bresenham walk that stamps an lw*lw block at each step. Honours the
# active target-redirect (draws into the external RGBA buffer when set), so the
# <canvas> 2D backend reuses this exact rasteriser for strokeRect/stroke()/arc.
def htmlpaint_stroke_line(x0: int32, y0: int32, x1: int32, y1: int32,
                          lw: int32, r: uint8, g: uint8, b: uint8):
    w2: int32 = lw
    if w2 < 1:
        w2 = 1
    half: int32 = w2 / 2
    dx: int32 = x1 - x0
    if dx < 0:
        dx = 0 - dx
    dy: int32 = y1 - y0
    if dy < 0:
        dy = 0 - dy
    sx: int32 = 1
    if x1 < x0:
        sx = -1
    sy: int32 = 1
    if y1 < y0:
        sy = -1
    err: int32 = dx - dy
    x: int32 = x0
    y: int32 = y0
    guard: int32 = 0
    lim: int32 = (dx + dy) * 2 + 8
    while guard < lim:
        if w2 == 1:
            _put_px(x, y, r, g, b)
        else:
            htmlpaint_fill_rect(x - half, y - half, w2, w2, r, g, b)
        if x == x1 and y == y1:
            return
        e2: int32 = err * 2
        if e2 > 0 - dy:
            err = err - dy
            x = x + sx
        if e2 < dx:
            err = err + dx
            y = y + sy
        guard = guard + 1


# Scanline-fill the polygon xs[0..n)/ys[0..n) in colour (r,g,b) (even-odd rule).
# Honours the active target redirect. Reused by the <canvas> fill()/arc-fill
# path so a filled polygon/disc goes through the same rasteriser as everything
# else. n must be <= 512.
_fp_xints: Array[512, int32]


def htmlpaint_fill_poly(xs: Ptr[int32], ys: Ptr[int32], n: int32,
                        r: uint8, g: uint8, b: uint8):
    if n < 3:
        return
    ymin: int32 = ys[0]
    ymax: int32 = ys[0]
    k: int32 = 1
    while k < n:
        if ys[k] < ymin:
            ymin = ys[k]
        if ys[k] > ymax:
            ymax = ys[k]
        k = k + 1
    yy: int32 = ymin
    while yy <= ymax:
        # collect x crossings of scanline (yy + 0.5) with each edge.
        nx: int32 = 0
        i: int32 = 0
        while i < n:
            j: int32 = i + 1
            if j >= n:
                j = 0
            ya: int32 = ys[i]
            yb: int32 = ys[j]
            if (ya <= yy and yb > yy) or (yb <= yy and ya > yy):
                # x at this y by integer linear interpolation.
                xa: int32 = xs[i]
                xb: int32 = xs[j]
                xc: int32 = xa + (xb - xa) * (yy - ya) / (yb - ya)
                if nx < 512:
                    _fp_xints[nx] = xc
                    nx = nx + 1
            i = i + 1
        # insertion-sort the crossings.
        a: int32 = 1
        while a < nx:
            v: int32 = _fp_xints[a]
            bb: int32 = a - 1
            while bb >= 0 and _fp_xints[bb] > v:
                _fp_xints[bb + 1] = _fp_xints[bb]
                bb = bb - 1
            _fp_xints[bb + 1] = v
            a = a + 1
        # fill between crossing pairs.
        p: int32 = 0
        while p + 1 < nx:
            xl: int32 = _fp_xints[p]
            xr: int32 = _fp_xints[p + 1]
            if xr > xl:
                htmlpaint_fill_rect(xl, yy, xr - xl, 1, r, g, b)
            p = p + 2
        yy = yy + 1


# CSS 2D transform: paint the box [bx,by,bw,bh] through the affine (a,b,c,d in
# 4096-fixed point; epx/fpx whole-px translate) about the pivot (bx+oxpx,by+oypx)
# as a SOLID transformed quad. The four border-box corners are mapped
# p' = O + M*(p - O) + T and the resulting (possibly rotated/sheared) quad is
# scanline-filled via htmlpaint_fill_poly, so translate/scale are pixel-exact and
# rotation renders a real filled quad (not a bounding box). Honours the active
# target redirect through fill_poly. XF_FX must match cascade's XF_FX (4096).
HP_XF_FX: int32 = 4096


def htmlpaint_fill_box_xform(bx: int32, by: int32, bw: int32, bh: int32,
                             a: int32, b: int32, c: int32, d: int32,
                             epx: int32, fpx: int32, oxpx: int32, oypx: int32,
                             r: uint8, g: uint8, bl: uint8):
    if bw <= 0 or bh <= 0:
        return
    ox: int32 = bx + oxpx
    oy: int32 = by + oypx
    qx: Array[4, int32]
    qy: Array[4, int32]
    # corner order TL, TR, BR, BL (a simple convex ring for the scanline fill).
    cx0: int32 = bx
    cy0: int32 = by
    cx1: int32 = bx + bw
    cy1: int32 = by
    cx2: int32 = bx + bw
    cy2: int32 = by + bh
    cx3: int32 = bx
    cy3: int32 = by + bh
    lx: int32 = cx0 - ox
    ly: int32 = cy0 - oy
    qx[0] = (a * lx + c * ly) / HP_XF_FX + epx + ox
    qy[0] = (b * lx + d * ly) / HP_XF_FX + fpx + oy
    lx = cx1 - ox
    ly = cy1 - oy
    qx[1] = (a * lx + c * ly) / HP_XF_FX + epx + ox
    qy[1] = (b * lx + d * ly) / HP_XF_FX + fpx + oy
    lx = cx2 - ox
    ly = cy2 - oy
    qx[2] = (a * lx + c * ly) / HP_XF_FX + epx + ox
    qy[2] = (b * lx + d * ly) / HP_XF_FX + fpx + oy
    lx = cx3 - ox
    ly = cy3 - oy
    qx[3] = (a * lx + c * ly) / HP_XF_FX + epx + ox
    qy[3] = (b * lx + d * ly) / HP_XF_FX + fpx + oy
    htmlpaint_fill_poly(&qx[0], &qy[0], 4, r, g, bl)


# Set canvas size + clear to `r,g,b`. Clamped to the BSS ceiling.
def htmlpaint_begin(w: int32, h: int32, r: uint8, g: uint8, b: uint8):
    ww: int32 = w
    hh: int32 = h
    if ww < 1:
        ww = 1
    if hh < 1:
        hh = 1
    if cast[uint64](ww) > HP_MAX_W:
        ww = cast[int32](HP_MAX_W)
    if cast[uint64](hh) > HP_MAX_H:
        hh = cast[int32](HP_MAX_H)
    hp_w = ww
    hp_h = hh
    htmlpaint_fill_rect(0, 0, ww, hh, r, g, b)


# ====================================================================
# Glyph + text blit (proportional, integer-scaled, optional bold).
# ====================================================================
# Blit codepoint `cp` from `face` at scale `scale`, top-left (gx,gy). `bold`
# double-strikes +scale px in x. Returns the glyph advance in px.
def _blit_glyph(cp: uint8, face: int32, scale: int32, bold: int32,
                gx: int32, gy: int32, r: uint8, g: uint8, b: uint8) -> int32:
    if _face_ok(face) == 0 or cast[int64](cp) < cast[int64](FONT_BDF_BASE_CP):
        return _glyph_adv(face, cp, scale, bold)
    ci: uint64 = cast[uint64](cp) - FONT_BDF_BASE_CP
    if ci >= FONT_BDF_N_GLYPHS:
        return _glyph_adv(face, cp, scale, bold)
    idx: uint64 = cast[uint64](face) * FONT_BDF_N_GLYPHS + ci
    gw: uint8 = hp_gw[idx]
    gh: uint8 = hp_gh[idx]
    if gw == 0 or gh == 0:
        return _glyph_adv(face, cp, scale, bold)          # blank/absent
    bitbase: uint64 = cast[uint64](face) * HP_FACE_BITS
    font_bdf_expand(&hp_gbits[bitbase], hp_goff[idx], gw, gh, &_hp_glyph[0])
    row: int32 = 0
    hh: int32 = cast[int32](gh)
    ww: int32 = cast[int32](gw)
    while row < hh:
        col: int32 = 0
        while col < ww:
            if _hp_glyph[cast[uint64](row * ww + col)] != 0:
                # scale×scale block
                px: int32 = gx + col * scale
                py: int32 = gy + row * scale
                htmlpaint_fill_rect(px, py, scale, scale, r, g, b)
                if bold != 0:
                    htmlpaint_fill_rect(px + scale, py, scale, scale, r, g, b)
            col = col + 1
        row = row + 1
    return _glyph_adv(face, cp, scale, bold)


# Draw `len` bytes at (x, baseline_y): the glyph BOTTOMS align to baseline_y
# (BBX yoff 0 in the bundled fonts). Returns the ending pen x.
def htmlpaint_text(x: int32, baseline_y: int32, face: int32, scale: int32,
                   bold: int32, txt: Ptr[uint8], ln: int32,
                   r: uint8, g: uint8, b: uint8) -> int32:
    pen: int32 = x
    k: int32 = 0
    while k < ln:
        cp: uint8 = txt[k]
        gh: int32 = htmlpaint_glyph_h(face, cp, scale)
        gy: int32 = baseline_y - gh
        adv: int32 = _blit_glyph(cp, face, scale, bold, pen, gy, r, g, b)
        pen = pen + adv
        k = k + 1
    return pen


# Height (px, scaled) of the glyph box for cp — used to bottom-align to
# baseline. Falls back to the face box height.
def htmlpaint_glyph_h(face: int32, cp: uint8, scale: int32) -> int32:
    if _face_ok(face) == 0:
        return 10 * scale
    if cast[int64](cp) < cast[int64](FONT_BDF_BASE_CP):
        return htmlpaint_face_height(face, scale)
    ci: uint64 = cast[uint64](cp) - FONT_BDF_BASE_CP
    if ci >= FONT_BDF_N_GLYPHS:
        return htmlpaint_face_height(face, scale)
    idx: uint64 = cast[uint64](face) * FONT_BDF_N_GLYPHS + ci
    h: uint8 = hp_gh[idx]
    if h == 0:
        return htmlpaint_face_height(face, scale)
    return cast[int32](h) * scale


# Measure the pixel width of `len` bytes in a face/scale (proportional sum).
def htmlpaint_measure(face: int32, scale: int32, bold: int32,
                      txt: Ptr[uint8], ln: int32) -> int32:
    w: int32 = 0
    k: int32 = 0
    while k < ln:
        w = w + _glyph_adv(face, txt[k], scale, bold)
        k = k + 1
    return w


# ====================================================================
# SCALABLE, ANTI-ALIASED text via the TrueType rasteriser (lib/font_ttf.ad).
# This is the path that breaks the fixed-bitmap ceiling: continuous font-size
# and grayscale-AA glyph edges. htmlpaint just forwards face loading and blends
# the rasteriser's coverage bitmap over the RGB canvas.
# ====================================================================

# Load a .ttf into TrueType face slot `ttface` (FACE_TT_* from font_ttf).
def htmlpaint_load_ttf(ttface: int32, buf: Ptr[uint8], buflen: uint64) -> int32:
    return font_ttf_load(ttface, buf, buflen)


def htmlpaint_ttf_ok(ttface: int32) -> int32:
    return font_ttf_loaded(ttface)


# Alpha-blend colour (r,g,b) over the pixel at (x,y) with coverage `a` (0..255).
def _blend_px(x: int32, y: int32, r: uint8, g: uint8, b: uint8, a: uint32):
    if a == 0:
        return
    if hp_tgt_addr != 0:
        if x < 0 or y < 0 or x >= hp_tgt_w or y >= hp_tgt_h:
            return
        t: Ptr[uint8] = cast[Ptr[uint8]](hp_tgt_addr)
        to: uint64 = cast[uint64](y) * hp_tgt_stride + cast[uint64](x) * 4
        if a >= 255:
            t[to] = r
            t[to + 1] = g
            t[to + 2] = b
            t[to + 3] = 255
            return
        tia: uint32 = 255 - a
        tdr: uint32 = cast[uint32](t[to])
        tdg: uint32 = cast[uint32](t[to + 1])
        tdb: uint32 = cast[uint32](t[to + 2])
        t[to] = cast[uint8]((cast[uint32](r) * a + tdr * tia + 127) / 255)
        t[to + 1] = cast[uint8]((cast[uint32](g) * a + tdg * tia + 127) / 255)
        t[to + 2] = cast[uint8]((cast[uint32](b) * a + tdb * tia + 127) / 255)
        t[to + 3] = 255
        return
    if x < 0 or y < 0 or x >= hp_w or y >= hp_h:
        return
    o: uint64 = (cast[uint64](y) * cast[uint64](hp_w) + cast[uint64](x)) * 3
    if a >= 255:
        hp_fb[o] = r
        hp_fb[o + 1] = g
        hp_fb[o + 2] = b
        return
    ia: uint32 = 255 - a
    dr: uint32 = cast[uint32](hp_fb[o])
    dg: uint32 = cast[uint32](hp_fb[o + 1])
    db: uint32 = cast[uint32](hp_fb[o + 2])
    nr: uint32 = (cast[uint32](r) * a + dr * ia + 127) / 255
    ng: uint32 = (cast[uint32](g) * a + dg * ia + 127) / 255
    nb: uint32 = (cast[uint32](b) * a + db * ia + 127) / 255
    hp_fb[o] = cast[uint8](nr)
    hp_fb[o + 1] = cast[uint8](ng)
    hp_fb[o + 2] = cast[uint8](nb)


# Alpha-blend a horizontal run of `w` px starting at (x,y) in colour (r,g,b)
# at coverage a (0..255). The building block for translucent fills.
def _blend_hspan(x: int32, y: int32, w: int32, r: uint8, g: uint8, b: uint8,
                 a: uint32):
    xx: int32 = x
    xlim: int32 = x + w
    while xx < xlim:
        _blend_px(xx, y, r, g, b, a)
        xx = xx + 1


# Fill a rounded rectangle in colour (r,g,b) composited at alpha `a` (0..255)
# over whatever is behind it. a>=255 is a solid fill (identical geometry to
# htmlpaint_fill_round_rect); a<255 blends every covered pixel. Corner pixels
# outside the arc are left untouched. This is the path that lets opacity / rgba
# element fills show the background through them instead of rendering opaque.
def htmlpaint_fill_round_rect_a(x: int32, y: int32, w: int32, h: int32,
                                rad: int32, r: uint8, g: uint8, b: uint8,
                                a: uint32):
    if w <= 0 or h <= 0 or a == 0:
        return
    rr: int32 = _hp_clamp_rad(w, h, rad)
    j: int32 = 0
    while j < h:
        inset: int32 = 0
        if rr > 0:
            dy: int32 = 0
            if j < rr:
                dy = rr - j
            elif j >= h - rr:
                dy = j - (h - rr) + 1
            if dy > 0:
                rem: int32 = rr * rr - dy * dy
                if rem < 0:
                    rem = 0
                inset = rr - _hp_isqrt(rem)
        span: int32 = w - 2 * inset
        if span > 0:
            _blend_hspan(x + inset, y + j, span, r, g, b, a)
        j = j + 1


# Stroke a 1px rounded-rectangle outline in colour (r,g,b) at alpha `a`. Mirrors
# htmlpaint_stroke_round_rect but blends, so a translucent / dimmed border shows
# the background through it.
def htmlpaint_stroke_round_rect_a(x: int32, y: int32, w: int32, h: int32,
                                  rad: int32, r: uint8, g: uint8, b: uint8,
                                  a: uint32):
    if w <= 0 or h <= 0 or a == 0:
        return
    rr: int32 = _hp_clamp_rad(w, h, rad)
    if rr <= 0:
        _blend_hspan(x, y, w, r, g, b, a)                    # top
        _blend_hspan(x, y + h - 1, w, r, g, b, a)            # bottom
        jj: int32 = 0
        while jj < h:
            _blend_px(x, y + jj, r, g, b, a)                 # left
            _blend_px(x + w - 1, y + jj, r, g, b, a)         # right
            jj = jj + 1
        return
    _blend_hspan(x + rr, y, w - 2 * rr, r, g, b, a)          # top
    _blend_hspan(x + rr, y + h - 1, w - 2 * rr, r, g, b, a)  # bottom
    js: int32 = rr
    while js < h - rr:
        _blend_px(x, y + js, r, g, b, a)                     # left
        _blend_px(x + w - 1, y + js, r, g, b, a)             # right
        js = js + 1
    j: int32 = 0
    while j < rr:
        dy: int32 = rr - j
        rem: int32 = rr * rr - dy * dy
        if rem < 0:
            rem = 0
        inset: int32 = rr - _hp_isqrt(rem)
        _blend_px(x + inset, y + j, r, g, b, a)              # TL
        _blend_px(x + w - 1 - inset, y + j, r, g, b, a)      # TR
        _blend_px(x + inset, y + h - 1 - j, r, g, b, a)      # BL
        _blend_px(x + w - 1 - inset, y + h - 1 - j, r, g, b, a)   # BR
        j = j + 1


# Paint a CSS box-shadow behind an element's border-box. (x,y,w,h,rad) is the
# element's own border-box; the shadow is that box translated by (offx,offy),
# expanded by `spread` on every side, corners rounded to rad+spread, then
# feathered by `blur` px. The feather is approximated by stacking `blur`+1
# concentric alpha-blended rounded rects from the outer (spread+blur) edge
# inward: the overlap accumulates toward the centre (near the declared alpha)
# and thins at the rim, giving a cheap gaussian-ish falloff. Reuses the same
# rounded-rect + alpha-blend rasteriser as every other fill. Call BEFORE the
# element's own fill so the element paints on top.
def htmlpaint_shadow_round_rect(x: int32, y: int32, w: int32, h: int32,
                                rad: int32, offx: int32, offy: int32,
                                blur: int32, spread: int32,
                                r: uint8, g: uint8, b: uint8, a: uint32):
    bl: int32 = blur
    if bl < 0:
        bl = 0
    if bl > 24:
        bl = 24
    # Outer (faintest) shadow edge: border-box shifted by the offset, grown by
    # spread + the full blur radius on every side.
    grow: int32 = spread + bl
    ox: int32 = x + offx - grow
    oy: int32 = y + offy - grow
    ow: int32 = w + 2 * grow
    oh: int32 = h + 2 * grow
    orad: int32 = rad + grow
    # Per-band alpha: (blur+1) overlapping layers, each at a fraction of `a`, so
    # the fully-overlapped core (the spread box) reaches ~a and the outermost
    # ring only gets one thin band.
    bands: int32 = bl + 1
    band_a: uint32 = a / cast[uint32](bands)
    if band_a < 1:
        band_a = 1
    i: int32 = 0
    while i <= bl:
        htmlpaint_fill_round_rect_a(ox + i, oy + i, ow - 2 * i, oh - 2 * i,
                                    orad - i, r, g, b, band_a)
        i = i + 1


# ---- CSS gradient backgrounds --------------------------------------------
# sin(deg)*1000 via the Bhaskara I approximation (max error ~0.16%). Handles any
# integer degree; used to project a pixel onto a linear gradient's axis.
def _hp_sin1000(deg: int32) -> int32:
    d: int32 = deg % 360
    if d < 0:
        d = d + 360
    sign: int32 = 1
    if d >= 180:
        d = d - 180
        sign = -1
    num: int32 = 4 * d * (180 - d)
    den: int32 = 40500 - d * (180 - d)
    if den == 0:
        den = 1
    return sign * num * 1000 / den

def _hp_cos1000(deg: int32) -> int32:
    return _hp_sin1000(deg + 90)

def _hp_abs(v: int32) -> int32:
    if v < 0:
        return -v
    return v

# Angle (permille around the circle, 0..999) of a pixel offset (dx,dy) from the
# centre, measured CLOCKWISE from straight up — the CSS conic-gradient
# convention (0 = 12 o'clock, 250 = 3 o'clock, 500 = 6 o'clock). Uses the
# "diamond angle" (L1 metric): exact at the four cardinals, monotonic with the
# true angle in between (a slight distortion near the diagonals). Trig-free.
def _hp_conic_t(dx: int32, dy: int32) -> int32:
    adx: int32 = _hp_abs(dx)
    ady: int32 = _hp_abs(dy)
    tot: int32 = adx + ady
    if tot == 0:
        return 0
    if dy < 0 and dx >= 0:                               # up..right   0..250
        return 250 * adx / tot
    if dy >= 0 and dx >= 0:                              # right..down 250..500
        return 250 + 250 * ady / tot
    if dy >= 0 and dx < 0:                               # down..left  500..750
        return 500 + 250 * adx / tot
    return 750 + 250 * ady / tot                         # left..up    750..1000

# Wrap gradient parameter t into the stop pattern [lo, lo+per) so a repeating-*
# gradient tiles its stops across the whole axis. Pass-through when repeat==0 or
# the pattern has zero width.
def _hp_gwrap(t: int32, lo: int32, per: int32, repeat: int32) -> int32:
    if repeat == 0 or per <= 0:
        return t
    r: int32 = (t - lo) % per
    if r < 0:
        r = r + per
    return lo + r

# Colour (0xRRGGBB) at gradient parameter t (permille, 0..1000) across `nst`
# stops in cols[]/pos[] (pos already normalised to permille, ascending). The
# result is packed 0xRRGGBB; the caller unpacks channels.
def _hp_grad_at(t: int32, cols: Ptr[int32], pos: Ptr[int32], nst: int32) -> int32:
    if t <= pos[0]:
        return cols[0]
    if t >= pos[nst - 1]:
        return cols[nst - 1]
    k: int32 = 0
    while k < nst - 1:
        p0: int32 = pos[k]
        p1: int32 = pos[k + 1]
        if t >= p0 and t <= p1:
            span: int32 = p1 - p0
            if span <= 0:
                return cols[k + 1]
            f: int32 = (t - p0) * 1000 / span         # 0..1000 within the band
            c0: int32 = cols[k]
            c1: int32 = cols[k + 1]
            r0: int32 = (c0 / 65536) & 255
            g0: int32 = (c0 / 256) & 255
            b0: int32 = c0 & 255
            r1: int32 = (c1 / 65536) & 255
            g1: int32 = (c1 / 256) & 255
            b1: int32 = c1 & 255
            rr: int32 = r0 + (r1 - r0) * f / 1000
            gg: int32 = g0 + (g1 - g0) * f / 1000
            bb: int32 = b0 + (b1 - b0) * f / 1000
            return rr * 65536 + gg * 256 + bb
        k = k + 1
    return cols[nst - 1]

# Fill a (border-radius rounded) rectangle with a CSS gradient. gtype 0 = linear
# at `angle` degrees (0 to-top / 90 to-right / 180 to-bottom / 270 to-left);
# gtype 1 = radial center->farthest-corner. cols[]/poss[] carry `nst` stops
# (poss in permille, -1 = auto => spaced evenly). Corner pixels outside the arc
# are left untouched so the page shows through, matching htmlpaint_fill_round_rect.
def htmlpaint_fill_gradient(x: int32, y: int32, w: int32, h: int32, rad: int32,
                            gtype: int32, angle: int32,
                            cols: Ptr[int32], poss: Ptr[int32], nst: int32,
                            repeat: int32):
    if w <= 0 or h <= 0 or nst < 2:
        return
    n: int32 = nst
    if n > 16:
        n = 16
    # Normalise stop positions: fill autos evenly, then clamp to monotonic.
    pos2: Array[16, int32]
    i: int32 = 0
    while i < n:
        p: int32 = poss[i]
        if p < 0:
            p = i * 1000 / (n - 1)
        if p < 0:
            p = 0
        if p > 1000:
            p = 1000
        if i > 0 and p < pos2[i - 1]:
            p = pos2[i - 1]
        pos2[i] = p
        i = i + 1
    rr: int32 = _hp_clamp_rad(w, h, rad)
    cx: int32 = w / 2
    cy: int32 = h / 2
    # Linear axis direction (screen coords, y down): D = (sin, -cos) * 1000.
    sn: int32 = _hp_sin1000(angle)
    cs: int32 = _hp_cos1000(angle)
    dx: int32 = sn
    dy: int32 = -cs
    # Axis length so the 0%/100% stops meet the box corners.
    llen: int32 = _hp_abs(w * sn) + _hp_abs(h * cs)
    if llen <= 0:
        llen = 1
    # Radial: farthest-corner distance from the centre (px), scaled x1000.
    rmax: int32 = _hp_isqrt(cx * cx + cy * cy) * 1000
    if rmax <= 0:
        rmax = 1
    # Repeating-* tiling window (the stop pattern) and the conic `from` offset.
    glo: int32 = pos2[0]
    gper: int32 = pos2[n - 1] - pos2[0]
    fromp: int32 = angle * 1000 / 360                   # conic start (permille)
    j: int32 = 0
    while j < h:
        inset: int32 = 0
        if rr > 0:
            ddy: int32 = 0
            if j < rr:
                ddy = rr - j
            elif j >= h - rr:
                ddy = j - (h - rr) + 1
            if ddy > 0:
                rem: int32 = rr * rr - ddy * ddy
                if rem < 0:
                    rem = 0
                inset = rr - _hp_isqrt(rem)
        xa: int32 = inset
        xb: int32 = w - inset
        # Vertical gradient (no horizontal variation): one colour per row → fill
        # the whole span at once (fast + smooth).
        if gtype == 0 and dx == 0:
            proj: int32 = (j - cy) * dy
            t: int32 = proj * 1000 / llen + 500
            t = _hp_gwrap(t, glo, gper, repeat)
            c: int32 = _hp_grad_at(t, cols, &pos2[0], n)
            span: int32 = xb - xa
            if span > 0:
                htmlpaint_fill_rect(x + xa, y + j, span, 1,
                                    cast[uint8]((c / 65536) & 255),
                                    cast[uint8]((c / 256) & 255),
                                    cast[uint8](c & 255))
        else:
            xi: int32 = xa
            while xi < xb:
                t2: int32 = 0
                if gtype == 1:
                    ex: int32 = xi - cx
                    ey: int32 = j - cy
                    dist: int32 = _hp_isqrt(ex * ex + ey * ey) * 1000
                    t2 = dist * 1000 / rmax
                elif gtype == 2:
                    cex: int32 = xi - cx
                    cey: int32 = j - cy
                    t2 = _hp_conic_t(cex, cey) - fromp
                    t2 = t2 % 1000
                    if t2 < 0:
                        t2 = t2 + 1000
                else:
                    proj2: int32 = (xi - cx) * dx + (j - cy) * dy
                    t2 = proj2 * 1000 / llen + 500
                t2 = _hp_gwrap(t2, glo, gper, repeat)
                c2: int32 = _hp_grad_at(t2, cols, &pos2[0], n)
                _put_px(x + xi, y + j,
                        cast[uint8]((c2 / 65536) & 255),
                        cast[uint8]((c2 / 256) & 255),
                        cast[uint8](c2 & 255))
                xi = xi + 1
        j = j + 1


# Blit one rasterised glyph (already rendered into font_ttf's coverage bitmap)
# at pen origin (pen_x, baseline_y), blending colour by per-pixel coverage.
# FAUX-OBLIQUE shear: when non-zero, each glyph row is shifted horizontally by
# (distance ABOVE the baseline) / g_ttf_shear px, slanting the upright bitmap to
# the right (top pushed right, descenders pulled left) — a synthesised italic of
# the SAME face, not a true italic typeface. 4 ≈ a 0.25 (~14°) slant. 0 = off.
g_ttf_shear: int32 = 0


def htmlpaint_set_shear(divisor: int32):
    g_ttf_shear = divisor


def _blit_ttf_glyph(pen_x: int32, baseline_y: int32,
                    r: uint8, g: uint8, b: uint8):
    bw: int32 = glyph_bw()
    bh: int32 = glyph_bh()
    gx0: int32 = pen_x + glyph_xoff()
    gy0: int32 = baseline_y + glyph_ytop()
    row: int32 = 0
    while row < bh:
        # per-row horizontal shear offset for faux-oblique (0 for upright text).
        shx: int32 = 0
        if g_ttf_shear != 0:
            shx = (baseline_y - (gy0 + row)) / g_ttf_shear
        col: int32 = 0
        while col < bw:
            a: uint8 = glyph_cov(col, row)
            if a != 0:
                _blend_px(gx0 + col + shx, gy0 + row, r, g, b, cast[uint32](a))
            col = col + 1
        row = row + 1


# ADVANCE MODEL — matching DejaVu-on-Chrome at the two size regimes it renders.
# We measured Chrome's real per-run advances (DejaVu Sans, headless, hinting on)
# against the raw hmtx metrics on the framediff corpus:
#   * SMALL text (body, ~16px): Chrome HINTS each glyph's advance to an integer
#     pixel and accumulates those — e.g. the 96-char body line measured 781px,
#     matching the per-glyph-rounded sum (782), NOT the true fractional sum
#     (786). Summing per-glyph integer advances is therefore the faithful model,
#     and it also makes hb break prose lines at the SAME points as Chrome.
#   * LARGE text (headings, >=~20px): the per-glyph rounding bias makes hb's h1
#     render WIDER than Chrome (DejaVu-Bold "The quick brown fox" @32px: per-glyph
#     368px vs Chrome ~366 == the true fractional/fu sum). At display sizes Chrome
#     effectively positions on the fractional (subpixel) grid, so accumulating in
#     FONT UNITS and rounding the running PEN once tracks Chrome and fixes the
#     "headings too wide" gap.
# FU_ADV_MIN_PX is the crossover: at/above it, accumulate font units (fu);
# below it, sum per-glyph integer advances. MEASURE and PAINT use the SAME model
# at a given px, so layout wrap points and paint x-positions stay consistent.
FU_ADV_MIN_PX: int32 = 20


# Draw `ln` bytes at (x, baseline_y) in TrueType face `ttface` at `px` em size,
# anti-aliased, colour (r,g,b). Returns the ending pen x. `bold` is advisory —
# the caller should pass a bold face slot for real bold.
def htmlpaint_text_ttf(x: int32, baseline_y: int32, ttface: int32, px: int32,
                       txt: Ptr[uint8], ln: int32,
                       r: uint8, g: uint8, b: uint8) -> int32:
    upm: int64 = font_ttf_upm(ttface)
    fu_mode: int32 = 0
    if upm > 0 and px >= FU_ADV_MIN_PX:
        fu_mode = 1
    pen: int32 = x
    acc_fu: int64 = 0
    k: int32 = 0
    while k < ln:
        cp: int32 = cast[int32](txt[k])
        if fu_mode != 0:
            # font-unit accumulation: round the running pen once (subpixel grid).
            pen = x + font_ttf_fu_to_px(ttface, acc_fu, px)
        has: int32 = font_ttf_render(ttface, cp, px)
        if has != 0:
            _blit_ttf_glyph(pen, baseline_y, r, g, b)
        if fu_mode != 0:
            fu: int64 = font_ttf_adv_fu(ttface, cast[uint64](cast[uint32](txt[k])))
            if fu <= 0:
                fu = upm / 3        # unmapped/zero-advance: keep text flowing
            acc_fu = acc_fu + fu
        else:
            # small text: per-glyph integer advance (Chrome hints to this grid).
            adv: int32 = glyph_adv()
            if adv < 1:
                adv = 1
            pen = pen + adv
        k = k + 1
    if fu_mode != 0:
        return x + font_ttf_fu_to_px(ttface, acc_fu, px)
    return pen


# Measure the pixel width of `ln` bytes in a TrueType face/size. Uses the SAME
# size-gated advance model as htmlpaint_text_ttf (fu accumulation for display
# sizes, per-glyph integer sum for body) so LAYOUT wrap points and PAINT
# positions agree and both track Chrome's DejaVu metrics. See FU_ADV_MIN_PX.
def htmlpaint_measure_ttf(ttface: int32, px: int32,
                          txt: Ptr[uint8], ln: int32) -> int32:
    upm: int64 = font_ttf_upm(ttface)
    if upm > 0 and px >= FU_ADV_MIN_PX:
        acc_fu: int64 = 0
        j: int32 = 0
        while j < ln:
            fu: int64 = font_ttf_adv_fu(ttface, cast[uint64](cast[uint32](txt[j])))
            if fu <= 0:
                fu = upm / 3
            acc_fu = acc_fu + fu
            j = j + 1
        return font_ttf_fu_to_px(ttface, acc_fu, px)
    w: int32 = 0
    k: int32 = 0
    while k < ln:
        a: int32 = font_ttf_adv_px(ttface, cast[uint64](cast[uint32](txt[k])), px)
        if a < 1:
            a = 1
        w = w + a
        k = k + 1
    return w


# Face ascent / full line height (ascent+descent) at `px`, for row geometry.
def htmlpaint_ttf_ascent(ttface: int32, px: int32) -> int32:
    return font_ttf_ascent_px(ttface, px)


def htmlpaint_ttf_height(ttface: int32, px: int32) -> int32:
    return font_ttf_ascent_px(ttface, px) + font_ttf_descent_px(ttface, px)


# ====================================================================
# IMAGE blit — draw decoded RGBA (lib/htmlimg slot) into a dstw x dsth box at
# top-left (dx,dy), NEAREST-NEIGHBOUR scaled, alpha-blended over the canvas.
# ====================================================================
def htmlpaint_blit_image(dx: int32, dy: int32, dstw: int32, dsth: int32,
                         slot: int32):
    sw: int32 = htmlimg_w(slot)
    sh: int32 = htmlimg_h(slot)
    if sw <= 0 or sh <= 0 or dstw <= 0 or dsth <= 0:
        return
    j: int32 = 0
    while j < dsth:
        sy: int32 = j * sh / dsth
        if sy >= sh:
            sy = sh - 1
        i: int32 = 0
        while i < dstw:
            sx: int32 = i * sw / dstw
            if sx >= sw:
                sx = sw - 1
            argb: uint32 = htmlimg_pixel(slot, sx, sy)
            a: uint32 = (argb >> 24) & 255
            if a != 0:
                r: uint8 = cast[uint8]((argb >> 16) & 255)
                g: uint8 = cast[uint8]((argb >> 8) & 255)
                b: uint8 = cast[uint8](argb & 255)
                _blend_px(dx + i, dy + j, r, g, b, a)
            i = i + 1
        j = j + 1


# object-position axis offset: the image edge's distance from the box edge. For a
# percent value the pct% point of the image aligns to the pct% point of the box,
# i.e. offset = free * pct / 100 (free = box - drawn, may be negative for cover);
# for a px value the offset is the length itself.
def _objpos_off(val: int32, isp: int32, free: int32) -> int32:
    if isp != 0:
        return free * val / 100
    return val


# IMAGE blit with CSS object-fit + object-position. Draws the decoded RGBA
# (lib/htmlimg `slot`) into the dstw x dsth content box at (dx,dy). `fit`:
#   2 contain    — scale to fit preserving aspect (letterbox: box bg shows in the
#                  bars, since only the drawn image rectangle is painted);
#   3 cover      — scale to fill preserving aspect, cropping the overflow (the
#                  box clips because only box-local pixels are iterated);
#   4 none       — natural size, positioned + clipped to the box;
#   5 scale-down — min(none, contain): natural if it fits, else contain.
# fill (0/1) is handled by htmlpaint_blit_image (stretch). object-position
# (posx/posxp, posy/posyp; p==1 percent, else px) places the drawn rectangle.
def htmlpaint_blit_image_fit(dx: int32, dy: int32, dstw: int32, dsth: int32,
                             slot: int32, fit: int32, posx: int32, posxp: int32,
                             posy: int32, posyp: int32):
    sw: int32 = htmlimg_w(slot)
    sh: int32 = htmlimg_h(slot)
    if sw <= 0 or sh <= 0 or dstw <= 0 or dsth <= 0:
        return
    # ---- drawn size (pw x ph) per object-fit ----
    pw: int32 = dstw
    ph: int32 = dsth
    if fit == 4:                                       # none: natural size
        pw = sw
        ph = sh
    elif fit == 2:                                     # contain: min-scale
        if dstw * sh <= dsth * sw:                     # width-constrained
            pw = dstw
            ph = sh * dstw / sw
        else:                                          # height-constrained
            ph = dsth
            pw = sw * dsth / sh
    elif fit == 3:                                     # cover: max-scale
        if dstw * sh >= dsth * sw:                     # width-constrained
            pw = dstw
            ph = sh * dstw / sw
        else:                                          # height-constrained
            ph = dsth
            pw = sw * dsth / sh
    elif fit == 5:                                     # scale-down: min(none,contain)
        cpw: int32 = dstw
        cph: int32 = dsth
        if dstw * sh <= dsth * sw:
            cpw = dstw
            cph = sh * dstw / sw
        else:
            cph = dsth
            cpw = sw * dsth / sh
        if sw <= cpw and sh <= cph:                    # natural fits -> none
            pw = sw
            ph = sh
        else:
            pw = cpw
            ph = cph
    if pw < 1:
        pw = 1
    if ph < 1:
        ph = 1
    # ---- placement offset via object-position ----
    px: int32 = _objpos_off(posx, posxp, dstw - pw)
    py: int32 = _objpos_off(posy, posyp, dsth - ph)
    # ---- draw: iterate the box, sample the placed image, skip pixels outside
    # the drawn rectangle (letterbox bars for contain/none show the box bg). ----
    j: int32 = 0
    while j < dsth:
        fy: int32 = j - py
        if fy >= 0 and fy < ph:
            sy: int32 = fy * sh / ph
            if sy >= sh:
                sy = sh - 1
            i: int32 = 0
            while i < dstw:
                fx: int32 = i - px
                if fx >= 0 and fx < pw:
                    sx: int32 = fx * sw / pw
                    if sx >= sw:
                        sx = sw - 1
                    argb: uint32 = htmlimg_pixel(slot, sx, sy)
                    a: uint32 = (argb >> 24) & 255
                    if a != 0:
                        r: uint8 = cast[uint8]((argb >> 16) & 255)
                        g: uint8 = cast[uint8]((argb >> 8) & 255)
                        b: uint8 = cast[uint8](argb & 255)
                        _blend_px(dx + i, dy + j, r, g, b, a)
                i = i + 1
        j = j + 1


# Map a destination coordinate `i` (relative to the box) back to a source pixel
# index in [0,nat), given the tile origin `o`, tile size `tile` and natural size
# `nat`. `rep`!=0 tiles the axis (wrap into [0,tile)); rep==0 draws a single tile
# and returns -1 outside it so the box background shows through.
def _bg_map(i: int32, o: int32, tile: int32, nat: int32, rep: int32) -> int32:
    rel: int32 = i - o
    if rep != 0:
        rel = rel % tile
        if rel < 0:
            rel = rel + tile
    else:
        if rel < 0 or rel >= tile:
            return -1
    s: int32 = rel * nat / tile
    if s >= nat:
        s = nat - 1
    if s < 0:
        s = 0
    return s


# Paint a decoded RGBA image (htmlimg slot) as an element BACKGROUND inside the
# padding box (x,y,w,h), honouring CSS background-size, -position and -repeat,
# clipped to a border-radius `rad` rounded rectangle and alpha-blended over the
# canvas. Placement is computed as: tile size (from `szmode`/explicit szw/szh),
# then the first tile's origin (from posx/posy), then tiling/clipping per `rep`.
#   szmode: 0 fill/stretch (legacy default) / 1 cover / 2 contain / 3 explicit
#   sz*p  : 2 auto (aspect from the other axis) / 1 percent-of-box / 0 px
#   pos*p : 1 percent-of-free-space / 0 px      rep: 0 both / 1 none / 2 x / 3 y
# Corner pixels outside the arc are left untouched so the page shows through,
# matching htmlpaint_fill_round_rect.
def htmlpaint_blit_image_bg(x: int32, y: int32, w: int32, h: int32, rad: int32,
                            slot: int32, szmode: int32, szw: int32, szwp: int32,
                            szh: int32, szhp: int32, posx: int32, posxp: int32,
                            posy: int32, posyp: int32, rep: int32):
    sw: int32 = htmlimg_w(slot)
    sh: int32 = htmlimg_h(slot)
    if sw <= 0 or sh <= 0 or w <= 0 or h <= 0:
        return
    # ---- tile size ----------------------------------------------------------
    # szmode 0 = legacy FILL: stretch the image to the whole box (the behaviour
    # before background-size existed; the CSS initial value here is a keyword-
    # free background-image, which we keep rendering scale-to-fill). An explicit
    # `background-size: auto` selects mode 3 with auto components -> natural size.
    tw: int32 = w
    th: int32 = h
    if szmode == 1:                                      # cover: fill, crop
        if w * sh > h * sw:
            tw = w
            th = sh * w / sw
        else:
            th = h
            tw = sw * h / sh
    elif szmode == 2:                                    # contain: fit, letterbox
        if w * sh < h * sw:
            tw = w
            th = sh * w / sw
        else:
            th = h
            tw = sw * h / sh
    elif szmode == 3:                                    # explicit w/h
        wauto: int32 = 0
        hauto: int32 = 0
        if szwp == 2:
            wauto = 1
        elif szwp == 1:
            tw = w * szw / 100
        else:
            tw = szw
        if szhp == 2:
            hauto = 1
        elif szhp == 1:
            th = h * szh / 100
        else:
            th = szh
        if wauto != 0 and hauto != 0:
            tw = sw
            th = sh
        elif wauto != 0:
            tw = sw * th / sh
        elif hauto != 0:
            th = sh * tw / sw
    if tw < 1:
        tw = 1
    if th < 1:
        th = 1
    # ---- first-tile origin (px, relative to the box top-left) ---------------
    ox: int32 = posx
    if posxp == 1:
        ox = (w - tw) * posx / 100
    oy: int32 = posy
    if posyp == 1:
        oy = (h - th) * posy / 100
    rep_x: int32 = 0
    rep_y: int32 = 0
    if rep == 0 or rep == 2:
        rep_x = 1
    if rep == 0 or rep == 3:
        rep_y = 1
    rr: int32 = _hp_clamp_rad(w, h, rad)
    j: int32 = 0
    while j < h:
        inset: int32 = 0
        if rr > 0:
            ddy: int32 = 0
            if j < rr:
                ddy = rr - j
            elif j >= h - rr:
                ddy = j - (h - rr) + 1
            if ddy > 0:
                rem: int32 = rr * rr - ddy * ddy
                if rem < 0:
                    rem = 0
                inset = rr - _hp_isqrt(rem)
        sy: int32 = _bg_map(j, oy, th, sh, rep_y)
        if sy < 0:
            j = j + 1
            continue
        i: int32 = inset
        while i < w - inset:
            sx: int32 = _bg_map(i, ox, tw, sw, rep_x)
            if sx >= 0:
                argb: uint32 = htmlimg_pixel(slot, sx, sy)
                a: uint32 = (argb >> 24) & 255
                if a != 0:
                    r: uint8 = cast[uint8]((argb >> 16) & 255)
                    g: uint8 = cast[uint8]((argb >> 8) & 255)
                    b: uint8 = cast[uint8](argb & 255)
                    _blend_px(x + i, y + j, r, g, b, a)
            i = i + 1
        j = j + 1


# Copy a cw x ch region of the INTERNAL RGB framebuffer (source top-left
# sx,sy) into an EXTERNAL RGBA8888 buffer dst (dst_w x dst_h) at (dx,dy),
# forcing opaque alpha. This is how the native browser presents the rendered
# DOCUMENT canvas (a tall page) as a scrolled viewport inside the compositor
# v2-blit backbuffer. Independent of the target setting — always reads hp_fb.
# Pixels outside either buffer are clipped.
def htmlpaint_blit_internal_to_rgba(dst: Ptr[uint8], dst_w: int32, dst_h: int32,
                                    dx: int32, dy: int32, sx: int32, sy: int32,
                                    cw: int32, ch: int32):
    stride: uint64 = cast[uint64](dst_w) * 4
    j: int32 = 0
    while j < ch:
        syy: int32 = sy + j
        dyy: int32 = dy + j
        if dyy >= 0 and dyy < dst_h and syy >= 0 and syy < hp_h:
            i: int32 = 0
            while i < cw:
                sxx: int32 = sx + i
                dxx: int32 = dx + i
                if dxx >= 0 and dxx < dst_w and sxx >= 0 and sxx < hp_w:
                    so: uint64 = (cast[uint64](syy) * cast[uint64](hp_w) +
                                  cast[uint64](sxx)) * 3
                    doo: uint64 = cast[uint64](dyy) * stride + \
                                  cast[uint64](dxx) * 4
                    dst[doo] = hp_fb[so]
                    dst[doo + 1] = hp_fb[so + 1]
                    dst[doo + 2] = hp_fb[so + 2]
                    dst[doo + 3] = 255
                i = i + 1
        j = j + 1


# Draw a broken-image PLACEHOLDER: a light-grey box with a border and a red
# diagonal cross, for a missing/undecodable <img src>.
def htmlpaint_broken_image(dx: int32, dy: int32, w: int32, h: int32):
    if w <= 0 or h <= 0:
        return
    htmlpaint_fill_rect(dx, dy, w, h, 238, 238, 238)      # grey fill
    htmlpaint_fill_rect(dx, dy, w, 1, 160, 160, 160)      # top border
    htmlpaint_fill_rect(dx, dy + h - 1, w, 1, 160, 160, 160)
    htmlpaint_fill_rect(dx, dy, 1, h, 160, 160, 160)      # left border
    htmlpaint_fill_rect(dx + w - 1, dy, 1, h, 160, 160, 160)
    # red diagonal cross (two thin lines) as the classic broken-image glyph.
    n: int32 = w
    if h < n:
        n = h
    k: int32 = 0
    while k < n:
        xa: int32 = dx + k * (w - 1) / (n - 1 + cast[int32](n == 1))
        ya: int32 = dy + k * (h - 1) / (n - 1 + cast[int32](n == 1))
        _put_px(xa, ya, 200, 60, 60)
        _put_px(dx + (w - 1) - (xa - dx), ya, 200, 60, 60)
        k = k + 1


# ====================================================================
# PPM (P6) header — driver writes header then fb_ptr()/fb_bytes().
# ====================================================================
def htmlpaint_ppm_header(out: Ptr[uint8]) -> uint64:
    p: uint64 = 0
    out[p] = 80                                          # 'P'
    p = p + 1
    out[p] = 54                                          # '6'
    p = p + 1
    out[p] = 10
    p = p + 1
    p = p + _dec(hp_w, &out[p])
    out[p] = 32
    p = p + 1
    p = p + _dec(hp_h, &out[p])
    out[p] = 10
    p = p + 1
    out[p] = 50                                          # '2'
    p = p + 1
    out[p] = 53                                          # '5'
    p = p + 1
    out[p] = 53                                          # '5'
    p = p + 1
    out[p] = 10
    p = p + 1
    return p


def _dec(v: int32, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    x: uint32 = cast[uint32](v)
    digs: Array[16, uint8]
    n: uint64 = 0
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    w: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return w

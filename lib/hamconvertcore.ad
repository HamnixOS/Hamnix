# lib/hamconvertcore.ad — PURE, extern-free core for HamConvert, the Hamnix
# unit-converter desktop utility (/bin/hamconvert). A REPO-ONLY app (installed
# from the packages repo, not baked into the base image).
#
# Like the other dual-target apps (docs/hamui_dual_target.md) this file imports
# ONLY lib/hamscene (the pure display-list builder) and performs NO syscalls or
# I/O: everything — the conversion math, the eight category tables, the UI
# compositing and the keyboard/pointer handling — lives here so the EXACT
# shipping render path can be driven to a PNG on the dev host. The native driver
# (user/hamconvert.ad) opens the wsys window and feeds input events in; the host
# harness (user/hamconvert_host.ad) drives the same core with KNOWN conversions
# so the gate (scripts/test_hamconvert_host.sh) is deterministic.
#
# CONVERSION MODEL
# ================
# Every non-temperature category converts through a single canonical BASE unit:
#   value_base   = value * factor[from]          (unit -> base)
#   value_target = value_base / factor[to]       (base -> unit)
# where factor[u] is the exact size of unit u expressed in the base unit. The
# base units are: Length=metre, Mass=kilogram, Volume=litre, Area=square-metre,
# Time=second, Data=byte, Speed=metre/second. Temperature is AFFINE (offset +
# scale), so it is NOT a single ratio: it converts via explicit formulas through
# Celsius (unit -> Celsius -> unit).
#
# DATA UNITS: decimal SI — KB = 1000 bytes, MB = 1000 KB, GB = 1000 MB, … (NOT
# 1024). This is documented here and used consistently: 1 GB = 1_000_000_000
# bytes. (The binary KiB/MiB/GiB family is intentionally not offered.)

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_stroke, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_roundrect


# ---- category / unit table geometry ---------------------------------------
NCAT: int32 = 8
MAXU: int32 = 9                              # widest category (Volume) has 9

CAT_LENGTH: int32 = 0
CAT_MASS:   int32 = 1
CAT_TEMP:   int32 = 2
CAT_VOLUME: int32 = 3
CAT_AREA:   int32 = 4
CAT_TIME:   int32 = 5
CAT_DATA:   int32 = 6
CAT_SPEED:  int32 = 7

# factor[cat][u] — size of unit u in the category's base unit (temp unused).
_factor: Array[8, Array[9, float64]]
_ucount: Array[8, int32]
_ready:  int32 = 0


def _setf(cat: int32, u: int32, v: float64):
    _factor[cat][u] = v


def _init_tables():
    if _ready != 0:
        return
    # ---- Length (base = metre), 8 units ------------------------------------
    _ucount[0] = 8
    _setf(0, 0, 0.001)                       # mm
    _setf(0, 1, 0.01)                        # cm
    _setf(0, 2, 1.0)                         # m
    _setf(0, 3, 1000.0)                      # km
    _setf(0, 4, 0.0254)                      # inch
    _setf(0, 5, 0.3048)                      # foot
    _setf(0, 6, 0.9144)                      # yard
    _setf(0, 7, 1609.344)                    # mile
    # ---- Mass (base = kilogram), 7 units -----------------------------------
    _ucount[1] = 7
    _setf(1, 0, 0.000001)                    # mg
    _setf(1, 1, 0.001)                       # g
    _setf(1, 2, 1.0)                         # kg
    _setf(1, 3, 1000.0)                      # tonne (metric)
    _setf(1, 4, 0.028349523125)              # ounce (avoirdupois)
    _setf(1, 5, 0.45359237)                  # pound
    _setf(1, 6, 6.35029318)                  # stone
    # ---- Temperature (affine; factors unused), 3 units ---------------------
    _ucount[2] = 3
    # ---- Volume (base = litre), 9 units ------------------------------------
    _ucount[3] = 9
    _setf(3, 0, 0.001)                       # ml
    _setf(3, 1, 1.0)                         # l
    _setf(3, 2, 1000.0)                      # m3
    _setf(3, 3, 0.00492892159375)            # tsp   (US)
    _setf(3, 4, 0.01478676478125)            # tbsp  (US)
    _setf(3, 5, 0.2365882365)                # cup   (US legal 8 fl oz)
    _setf(3, 6, 0.473176473)                 # pint  (US liquid)
    _setf(3, 7, 0.946352946)                 # quart (US liquid)
    _setf(3, 8, 3.785411784)                 # gallon (US liquid)
    # ---- Area (base = square metre), 7 units -------------------------------
    _ucount[4] = 7
    _setf(4, 0, 0.000001)                    # mm2
    _setf(4, 1, 0.0001)                      # cm2
    _setf(4, 2, 1.0)                         # m2
    _setf(4, 3, 1000000.0)                   # km2
    _setf(4, 4, 10000.0)                     # hectare
    _setf(4, 5, 4046.8564224)                # acre
    _setf(4, 6, 0.09290304)                  # sq-ft
    # ---- Time (base = second), 6 units -------------------------------------
    _ucount[5] = 6
    _setf(5, 0, 0.001)                       # ms
    _setf(5, 1, 1.0)                         # s
    _setf(5, 2, 60.0)                        # min
    _setf(5, 3, 3600.0)                      # hour
    _setf(5, 4, 86400.0)                     # day
    _setf(5, 5, 604800.0)                    # week
    # ---- Data (base = byte, DECIMAL SI: KB=1000), 6 units ------------------
    _ucount[6] = 6
    _setf(6, 0, 0.125)                       # bit
    _setf(6, 1, 1.0)                         # byte
    _setf(6, 2, 1000.0)                      # KB
    _setf(6, 3, 1000000.0)                   # MB
    _setf(6, 4, 1000000000.0)                # GB
    _setf(6, 5, 1000000000000.0)             # TB
    # ---- Speed (base = metre/second), 4 units ------------------------------
    _ucount[7] = 4
    _setf(7, 0, 1.0)                         # m/s
    _setf(7, 1, 1000.0 / 3600.0)             # km/h
    _setf(7, 2, 0.44704)                     # mph
    _setf(7, 3, 1852.0 / 3600.0)             # knot
    _ready = 1


# ---- pure conversion -------------------------------------------------------
def _fabs(x: float64) -> float64:
    if x < 0.0:
        return 0.0 - x
    return x


# Temperature: unit -> Celsius. 0=Celsius, 1=Fahrenheit, 2=Kelvin.
def _temp_to_c(u: int32, v: float64) -> float64:
    if u == 1:
        return (v - 32.0) * 5.0 / 9.0
    if u == 2:
        return v - 273.15
    return v


# Temperature: Celsius -> unit.
def _temp_from_c(u: int32, c: float64) -> float64:
    if u == 1:
        return c * 9.0 / 5.0 + 32.0
    if u == 2:
        return c + 273.15
    return c


# The one true conversion entry point (PURE): value in `fromu` -> `tou`.
def hamconvert_convert(cat: int32, fromu: int32, tou: int32,
                       v: float64) -> float64:
    _init_tables()
    if cat == CAT_TEMP:
        return _temp_from_c(tou, _temp_to_c(fromu, v))
    base: float64 = v * _factor[cat][fromu]
    return base / _factor[cat][tou]


# ---- accessors -------------------------------------------------------------
def hamconvert_category_count() -> int32:
    return NCAT


def hamconvert_unit_count(cat: int32) -> int32:
    _init_tables()
    if cat < 0 or cat >= NCAT:
        return 0
    return _ucount[cat]


def hamconvert_category_name(c: int32) -> Ptr[uint8]:
    if c == 0:
        return cast[Ptr[uint8]]("Length")
    if c == 1:
        return cast[Ptr[uint8]]("Mass")
    if c == 2:
        return cast[Ptr[uint8]]("Temp")
    if c == 3:
        return cast[Ptr[uint8]]("Volume")
    if c == 4:
        return cast[Ptr[uint8]]("Area")
    if c == 5:
        return cast[Ptr[uint8]]("Time")
    if c == 6:
        return cast[Ptr[uint8]]("Data")
    return cast[Ptr[uint8]]("Speed")


def _unit_name_len(cat: int32, u: int32) -> Ptr[uint8]:
    if cat == 0:
        if u == 0:
            return cast[Ptr[uint8]]("mm")
        if u == 1:
            return cast[Ptr[uint8]]("cm")
        if u == 2:
            return cast[Ptr[uint8]]("m")
        if u == 3:
            return cast[Ptr[uint8]]("km")
        if u == 4:
            return cast[Ptr[uint8]]("inch")
        if u == 5:
            return cast[Ptr[uint8]]("foot")
        if u == 6:
            return cast[Ptr[uint8]]("yard")
        return cast[Ptr[uint8]]("mile")
    if cat == 1:
        if u == 0:
            return cast[Ptr[uint8]]("mg")
        if u == 1:
            return cast[Ptr[uint8]]("g")
        if u == 2:
            return cast[Ptr[uint8]]("kg")
        if u == 3:
            return cast[Ptr[uint8]]("tonne")
        if u == 4:
            return cast[Ptr[uint8]]("ounce")
        if u == 5:
            return cast[Ptr[uint8]]("pound")
        return cast[Ptr[uint8]]("stone")
    if cat == 2:
        if u == 0:
            return cast[Ptr[uint8]]("Celsius")
        if u == 1:
            return cast[Ptr[uint8]]("Fahrenheit")
        return cast[Ptr[uint8]]("Kelvin")
    return cast[Ptr[uint8]]("?")


def _unit_name_vol(cat: int32, u: int32) -> Ptr[uint8]:
    if cat == 3:
        if u == 0:
            return cast[Ptr[uint8]]("ml")
        if u == 1:
            return cast[Ptr[uint8]]("l")
        if u == 2:
            return cast[Ptr[uint8]]("m3")
        if u == 3:
            return cast[Ptr[uint8]]("tsp")
        if u == 4:
            return cast[Ptr[uint8]]("tbsp")
        if u == 5:
            return cast[Ptr[uint8]]("cup")
        if u == 6:
            return cast[Ptr[uint8]]("pint")
        if u == 7:
            return cast[Ptr[uint8]]("quart")
        return cast[Ptr[uint8]]("gallon")
    if cat == 4:
        if u == 0:
            return cast[Ptr[uint8]]("mm2")
        if u == 1:
            return cast[Ptr[uint8]]("cm2")
        if u == 2:
            return cast[Ptr[uint8]]("m2")
        if u == 3:
            return cast[Ptr[uint8]]("km2")
        if u == 4:
            return cast[Ptr[uint8]]("hectare")
        if u == 5:
            return cast[Ptr[uint8]]("acre")
        return cast[Ptr[uint8]]("sq-ft")
    return cast[Ptr[uint8]]("?")


def _unit_name_rest(cat: int32, u: int32) -> Ptr[uint8]:
    if cat == 5:
        if u == 0:
            return cast[Ptr[uint8]]("ms")
        if u == 1:
            return cast[Ptr[uint8]]("s")
        if u == 2:
            return cast[Ptr[uint8]]("min")
        if u == 3:
            return cast[Ptr[uint8]]("hour")
        if u == 4:
            return cast[Ptr[uint8]]("day")
        return cast[Ptr[uint8]]("week")
    if cat == 6:
        if u == 0:
            return cast[Ptr[uint8]]("bit")
        if u == 1:
            return cast[Ptr[uint8]]("byte")
        if u == 2:
            return cast[Ptr[uint8]]("KB")
        if u == 3:
            return cast[Ptr[uint8]]("MB")
        if u == 4:
            return cast[Ptr[uint8]]("GB")
        return cast[Ptr[uint8]]("TB")
    # speed
    if u == 0:
        return cast[Ptr[uint8]]("m/s")
    if u == 1:
        return cast[Ptr[uint8]]("km/h")
    if u == 2:
        return cast[Ptr[uint8]]("mph")
    return cast[Ptr[uint8]]("knot")


def hamconvert_unit_name(cat: int32, u: int32) -> Ptr[uint8]:
    if cat <= 2:
        return _unit_name_len(cat, u)
    if cat <= 4:
        return _unit_name_vol(cat, u)
    return _unit_name_rest(cat, u)


# ---- decimal formatting ----------------------------------------------------
# Format a float64 into `out` (NUL-terminated) with up to 6 fractional digits,
# trailing zeros + trailing '.' trimmed. Returns the string length. Handles the
# sign and pulls the integer part directly from the float to avoid overflow on
# large magnitudes (e.g. 1e12 bytes).
def hamconvert_fmt(value: float64, out: Ptr[uint8]) -> uint64:
    p: uint64 = 0
    x: float64 = value
    if x < 0.0:
        out[p] = 45                          # '-'
        p = p + 1
        x = 0.0 - x
    # round to 6 dp
    x = x + 0.0000005
    ip: uint64 = cast[uint64](x)
    frac: float64 = x - cast[float64](ip)
    # integer part
    if ip == 0:
        out[p] = 48
        p = p + 1
    else:
        digs: Array[24, uint8]
        n: uint64 = 0
        t: uint64 = ip
        while t > 0:
            digs[n] = cast[uint8](t % 10) + 48
            t = t / 10
            n = n + 1
        while n > 0:
            n = n - 1
            out[p] = digs[n]
            p = p + 1
    # fractional part -> a scratch of up to 6 digits, then trim
    fd: Array[8, uint8]
    fn: uint64 = 0
    k: int32 = 0
    while k < 6:
        frac = frac * 10.0
        d: int32 = cast[int32](frac)
        if d < 0:
            d = 0
        if d > 9:
            d = 9
        fd[fn] = cast[uint8](d) + 48
        fn = fn + 1
        frac = frac - cast[float64](d)
        k = k + 1
    # trim trailing zeros
    while fn > 0 and fd[fn - 1] == 48:
        fn = fn - 1
    if fn > 0:
        out[p] = 46                          # '.'
        p = p + 1
        j: uint64 = 0
        while j < fn:
            out[p] = fd[j]
            p = p + 1
            j = j + 1
    out[p] = 0
    return p


# Parse a decimal string (optional sign, integer + fractional; no exponent)
# into a float64. Junk after the number stops the scan.
def hamconvert_parse(s: Ptr[uint8], n: uint64) -> float64:
    i: uint64 = 0
    neg: int32 = 0
    if i < n and s[i] == 45:                 # '-'
        neg = 1
        i = i + 1
    elif i < n and s[i] == 43:               # '+'
        i = i + 1
    ip: float64 = 0.0
    while i < n and s[i] >= 48 and s[i] <= 57:
        ip = ip * 10.0 + cast[float64](cast[int32](s[i]) - 48)
        i = i + 1
    if i < n and s[i] == 46:                 # '.'
        i = i + 1
        scale: float64 = 0.1
        while i < n and s[i] >= 48 and s[i] <= 57:
            ip = ip + cast[float64](cast[int32](s[i]) - 48) * scale
            scale = scale * 0.1
            i = i + 1
    if neg != 0:
        return 0.0 - ip
    return ip


# ====================================================================
# INTERACTIVE STATE + UI
# ====================================================================
cur_cat:  int32 = 0
cur_from: int32 = 0
cur_to:   int32 = 1
focus:    int32 = 0                          # 0 = FROM list, 1 = TO list

IN_MAX: int32 = 18
in_buf: Array[24, uint8]
in_len: int32 = 0


def _in_reset_one():
    in_buf[0] = 49                           # '1'
    in_buf[1] = 0
    in_len = 1


def hamconvert_init():
    _init_tables()
    cur_cat = 0
    cur_from = 0
    cur_to = 1
    focus = 0
    _in_reset_one()


def hamconvert_category() -> int32:
    return cur_cat


def hamconvert_from() -> int32:
    return cur_from


def hamconvert_to() -> int32:
    return cur_to


def hamconvert_set_from(u: int32):
    n: int32 = hamconvert_unit_count(cur_cat)
    if u >= 0 and u < n:
        cur_from = u


def hamconvert_set_to(u: int32):
    n: int32 = hamconvert_unit_count(cur_cat)
    if u >= 0 and u < n:
        cur_to = u


def hamconvert_set_category(c: int32):
    if c < 0:
        c = 0
    if c >= NCAT:
        c = NCAT - 1
    cur_cat = c
    n: int32 = hamconvert_unit_count(c)
    cur_from = 0
    if n > 1:
        cur_to = 1
    else:
        cur_to = 0


# Replace the input string (host/testing edge). Clamps to IN_MAX bytes.
def hamconvert_set_input_str(s: Ptr[uint8]):
    i: int32 = 0
    while i < IN_MAX and s[i] != 0:
        in_buf[i] = s[i]
        i = i + 1
    in_buf[i] = 0
    in_len = i
    if in_len == 0:
        in_buf[0] = 48
        in_buf[1] = 0
        in_len = 1


def hamconvert_input_ptr() -> Ptr[uint8]:
    return &in_buf[0]


def hamconvert_input_value() -> float64:
    return hamconvert_parse(&in_buf[0], cast[uint64](in_len))


# The live result of the current input/category/from/to.
def hamconvert_result() -> float64:
    return hamconvert_convert(cur_cat, cur_from, cur_to,
                              hamconvert_input_value())


def hamconvert_result_str(out: Ptr[uint8]) -> uint64:
    return hamconvert_fmt(hamconvert_result(), out)


def hamconvert_swap():
    t: int32 = cur_from
    cur_from = cur_to
    cur_to = t


# ---- keyboard --------------------------------------------------------------
hc_esc: int32 = 0


def _in_append(c: uint8):
    if in_len >= IN_MAX:
        return
    # calculator-style: a lone "0" is replaced by the next typed digit (so
    # "0" then '2''5' -> "25", not "025"); a typed '.' keeps the leading 0.
    if in_len == 1 and in_buf[0] == 48 and c >= 49 and c <= 57:
        in_buf[0] = c
        return
    # only one decimal point; '-' only at position 0
    if c == 46:
        j: int32 = 0
        while j < in_len:
            if in_buf[j] == 46:
                return
            j = j + 1
    if c == 45 and in_len != 0:
        return
    in_buf[in_len] = c
    in_len = in_len + 1
    in_buf[in_len] = 0


def _in_backspace():
    if in_len > 0:
        in_len = in_len - 1
        in_buf[in_len] = 0


def _unit_up_down(delta: int32):
    n: int32 = hamconvert_unit_count(cur_cat)
    if n <= 0:
        return
    if focus == 0:
        v: int32 = cur_from + delta
        if v < 0:
            v = n - 1
        if v >= n:
            v = 0
        cur_from = v
    else:
        v2: int32 = cur_to + delta
        if v2 < 0:
            v2 = n - 1
        if v2 >= n:
            v2 = 0
        cur_to = v2


def _cat_step(delta: int32):
    c: int32 = cur_cat + delta
    if c < 0:
        c = NCAT - 1
    if c >= NCAT:
        c = 0
    hamconvert_set_category(c)


# CSI arrow final byte.
def _hc_arrow(fin: int32) -> int32:
    if fin == 65:                            # Up
        _unit_up_down(-1)
        return 1
    if fin == 66:                            # Down
        _unit_up_down(1)
        return 1
    if fin == 68:                            # Left  -> prev category
        _cat_step(-1)
        return 1
    if fin == 67:                            # Right -> next category
        _cat_step(1)
        return 1
    return 0


# Apply one key (ASCII / decoded). Returns 1 if state changed (redraw needed).
def hamconvert_key(code: int32) -> int32:
    if hc_esc == 1:
        if code == 91:                       # '['
            hc_esc = 2
        else:
            hc_esc = 0
        return 0
    if hc_esc == 2:
        hc_esc = 0
        return _hc_arrow(code)
    if code == 27:                           # ESC -> start CSI
        hc_esc = 1
        return 0

    # numeric entry
    if code >= 48 and code <= 57:            # 0-9
        _in_append(cast[uint8](code))
        return 1
    if code == 46:                           # '.'
        _in_append(46)
        return 1
    if code == 45:                           # '-'
        _in_append(45)
        return 1
    if code == 8 or code == 127:             # Backspace / Del
        _in_backspace()
        return 1
    if code == 99:                           # 'c' clear
        in_buf[0] = 48
        in_buf[1] = 0
        in_len = 1
        return 1

    # navigation / commands
    if code == 9:                            # Tab -> toggle focus
        if focus == 0:
            focus = 1
        else:
            focus = 0
        return 1
    if code == 115:                          # 's' swap from/to
        hamconvert_swap()
        return 1
    if code == 93:                           # ']' next category
        _cat_step(1)
        return 1
    if code == 91:                           # '[' prev category
        _cat_step(-1)
        return 1
    return 0


# Parse a "d <code>" key-press wire line and apply it. Returns 1 if changed.
def hamconvert_key_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 100:                 # 'd' press; ignore 'u' release
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    neg: int32 = 0
    if i < n and s[i] == 45:
        neg = 1
        i = i + 1
    code: int32 = 0
    got: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        code = code * 10 + cast[int32](s[i]) - 48
        i = i + 1
        got = 1
    if got == 0:
        return 0
    if neg != 0:
        code = 0 - code
    return hamconvert_key(code)


# ====================================================================
# LAYOUT + RENDER (scene display list)
# ====================================================================
WIN_W: int32 = 480
WIN_H: int32 = 560
BAR_H: int32 = 24

SIDE_X: int32 = 0
SIDE_W: int32 = 108
CAT_Y0: int32 = 30
CAT_H:  int32 = 40

MAIN_X: int32 = 116

# from/to unit list columns
FROM_X: int32 = 122
TO_X:   int32 = 316
LIST_W: int32 = 132
LIST_Y0: int32 = 158
ROW_H:  int32 = 26

# swap button (between the two lists)
SWAP_X: int32 = 262
SWAP_W: int32 = 48
SWAP_Y: int32 = 262

num_buf: Array[48, uint8]
res_buf: Array[48, uint8]


def _append(out: Ptr[uint8], p: uint64, s: Ptr[uint8]) -> uint64:
    j: uint64 = 0
    while s[j] != 0:
        out[p] = s[j]
        p = p + 1
        j = j + 1
    return p


def _slen(s: Ptr[uint8]) -> int32:
    n: int32 = 0
    while s[n] != 0:
        n = n + 1
    return n


# ---- category sidebar ------------------------------------------------------
def _build_sidebar():
    hamscene_fill(SIDE_X, BAR_H, SIDE_W, WIN_H - BAR_H,
                  cast[Ptr[uint8]]("#20223f"))
    c: int32 = 0
    while c < NCAT:
        y: int32 = CAT_Y0 + c * CAT_H
        active: int32 = 0
        if c == cur_cat:
            active = 1
        if active != 0:
            hamscene_fill(SIDE_X, y, SIDE_W, CAT_H,
                          cast[Ptr[uint8]]("#4453b8"))
            hamscene_fill(SIDE_X, y, 4, CAT_H, cast[Ptr[uint8]]("#ffd23f"))
            hamscene_glyphs_bold(SIDE_X + 14, y + 13,
                                 hamconvert_category_name(c),
                                 cast[Ptr[uint8]]("#ffffff"))
        else:
            hamscene_glyphs(SIDE_X + 14, y + 13,
                            hamconvert_category_name(c),
                            cast[Ptr[uint8]]("#b9bee0"))
        c = c + 1


# ---- the big result card ---------------------------------------------------
def _build_result_card():
    cx: int32 = MAIN_X
    cw: int32 = WIN_W - MAIN_X - 10
    hamscene_roundrect(cx, BAR_H + 8, cw, 88, 10,
                       cast[Ptr[uint8]]("#eef0fb"))
    hamscene_stroke(cx, BAR_H + 8, cw, 88, 1, cast[Ptr[uint8]]("#c3c8e0"))

    # top line: "<input> <fromunit>"
    p: uint64 = 0
    p = _append(&num_buf[0], p, &in_buf[0])
    num_buf[p] = 32
    p = p + 1
    p = _append(&num_buf[0], p, hamconvert_unit_name(cur_cat, cur_from))
    num_buf[p] = 0
    hamscene_glyphs(cx + 14, BAR_H + 22, &num_buf[0],
                    cast[Ptr[uint8]]("#6a72a0"))

    # equals
    hamscene_glyphs_bold(cx + 14, BAR_H + 44, cast[Ptr[uint8]]("="),
                         cast[Ptr[uint8]]("#8890b4"))

    # big result: "<result> <tounit>"
    rl: uint64 = hamconvert_fmt(hamconvert_result(), &res_buf[0])
    q: uint64 = 0
    q = _append(&num_buf[0], q, &res_buf[0])
    num_buf[q] = 32
    q = q + 1
    q = _append(&num_buf[0], q, hamconvert_unit_name(cur_cat, cur_to))
    num_buf[q] = 0
    hamscene_glyphs_bold(cx + 34, BAR_H + 62, &num_buf[0],
                         cast[Ptr[uint8]]("#20223f"))

    # hint under the card
    hamscene_glyphs(cx + 14, BAR_H + 82,
                    cast[Ptr[uint8]]("type a number  .  - +/-  Tab focus"),
                    cast[Ptr[uint8]]("#9aa0c4"))


# ---- from / to unit lists --------------------------------------------------
def _build_one_list(x: int32, sel: int32, focused: int32, title: Ptr[uint8]):
    # header
    hamscene_glyphs_bold(x, LIST_Y0 - 20, title, cast[Ptr[uint8]]("#4453b8"))
    n: int32 = hamconvert_unit_count(cur_cat)
    u: int32 = 0
    while u < n:
        y: int32 = LIST_Y0 + u * ROW_H
        rowbg: Ptr[uint8] = cast[Ptr[uint8]]("#ffffff")
        fg: Ptr[uint8] = cast[Ptr[uint8]]("#26305c")
        if u == sel:
            if focused != 0:
                rowbg = cast[Ptr[uint8]]("#4453b8")
            else:
                rowbg = cast[Ptr[uint8]]("#c9cef0")
        hamscene_fill(x, y, LIST_W, ROW_H - 2, rowbg)
        hamscene_stroke(x, y, LIST_W, ROW_H - 2, 1,
                        cast[Ptr[uint8]]("#d4d8ee"))
        if u == sel and focused != 0:
            fg = cast[Ptr[uint8]]("#ffffff")
            hamscene_glyphs_bold(x + 8, y + 5,
                                 hamconvert_unit_name(cur_cat, u), fg)
        else:
            hamscene_glyphs(x + 8, y + 5,
                            hamconvert_unit_name(cur_cat, u), fg)
        u = u + 1


def _build_lists():
    ff: int32 = 0
    tf: int32 = 0
    if focus == 0:
        ff = 1
    else:
        tf = 1
    _build_one_list(FROM_X, cur_from, ff, cast[Ptr[uint8]]("From"))
    _build_one_list(TO_X, cur_to, tf, cast[Ptr[uint8]]("To"))
    # swap button
    hamscene_roundrect(SWAP_X, SWAP_Y, SWAP_W, 30, 6,
                       cast[Ptr[uint8]]("#ffd23f"))
    hamscene_glyphs_bold(SWAP_X + 6, SWAP_Y + 9,
                         cast[Ptr[uint8]]("swap"),
                         cast[Ptr[uint8]]("#20223f"))


# ---- quick conversion table (1 <from> = X <unit> for each unit) ------------
TBL_Y0: int32 = 412
TBL_ROWH: int32 = 17


def _build_table():
    cx: int32 = MAIN_X
    hamscene_glyphs_bold(cx, TBL_Y0 - 16, cast[Ptr[uint8]]("Quick table"),
                         cast[Ptr[uint8]]("#4453b8"))
    n: int32 = hamconvert_unit_count(cur_cat)
    fname: Ptr[uint8] = hamconvert_unit_name(cur_cat, cur_from)
    u: int32 = 0
    row: int32 = 0
    while u < n:
        if u != cur_from:
            y: int32 = TBL_Y0 + row * TBL_ROWH
            val: float64 = hamconvert_convert(cur_cat, cur_from, u, 1.0)
            fmtb: Array[48, uint8]
            hamconvert_fmt(val, &fmtb[0])
            p: uint64 = 0
            p = _append(&num_buf[0], p, cast[Ptr[uint8]]("1 "))
            p = _append(&num_buf[0], p, fname)
            p = _append(&num_buf[0], p, cast[Ptr[uint8]](" = "))
            p = _append(&num_buf[0], p, &fmtb[0])
            num_buf[p] = 32
            p = p + 1
            p = _append(&num_buf[0], p, hamconvert_unit_name(cur_cat, u))
            num_buf[p] = 0
            hamscene_glyphs(cx, y, &num_buf[0], cast[Ptr[uint8]]("#3a4270"))
            row = row + 1
        u = u + 1


# ---- top-level scene -------------------------------------------------------
def hamconvert_build_scene():
    _init_tables()
    hamscene_begin()
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#f3f4fb"))
    # title bar
    hamscene_fill(0, 0, WIN_W, BAR_H, cast[Ptr[uint8]]("#2b2d5c"))
    hamscene_fill(0, BAR_H - 1, WIN_W, 1, cast[Ptr[uint8]]("#1f2044"))
    hamscene_glyphs_bold(10, 6, cast[Ptr[uint8]]("HamConvert"),
                         cast[Ptr[uint8]]("#ffffff"))
    hamscene_glyphs(WIN_W - 150, 6, cast[Ptr[uint8]]("unit converter"),
                    cast[Ptr[uint8]]("#c8cbe8"))
    _build_sidebar()
    _build_result_card()
    _build_table()
    _build_lists()


# ---- pointer hit-testing ---------------------------------------------------
def hamconvert_hit(x: int64, y: int64) -> int32:
    # category sidebar
    if x >= cast[int64](SIDE_X) and x < cast[int64](SIDE_X + SIDE_W):
        if y >= cast[int64](CAT_Y0):
            c: int32 = cast[int32]((y - cast[int64](CAT_Y0)) / cast[int64](CAT_H))
            if c >= 0 and c < NCAT:
                hamconvert_set_category(c)
                return 1
    # swap button
    if x >= cast[int64](SWAP_X) and x < cast[int64](SWAP_X + SWAP_W):
        if y >= cast[int64](SWAP_Y) and y < cast[int64](SWAP_Y + 30):
            hamconvert_swap()
            return 1
    n: int32 = hamconvert_unit_count(cur_cat)
    # FROM list
    if x >= cast[int64](FROM_X) and x < cast[int64](FROM_X + LIST_W):
        u: int32 = _row_hit(y)
        if u >= 0 and u < n:
            cur_from = u
            focus = 0
            return 1
    # TO list
    if x >= cast[int64](TO_X) and x < cast[int64](TO_X + LIST_W):
        u2: int32 = _row_hit(y)
        if u2 >= 0 and u2 < n:
            cur_to = u2
            focus = 1
            return 1
    return 0


def _row_hit(y: int64) -> int32:
    if y < cast[int64](LIST_Y0):
        return -1
    return cast[int32]((y - cast[int64](LIST_Y0)) / cast[int64](ROW_H))

# lib/shotoverlay.ad — PURE, extern-free scene builder for the screenshot
# "select area" / "application window" overlay.
#
# Shared by the native app (user/hamshotui.ad) and the host render-to-PNG
# harness (user/shotoverlay_host.ad) so BOTH the on-device compositor and the
# host rasterizer draw the IDENTICAL scrim + banner + selection rectangle from
# one source of truth (the ctxmenucore pattern).
#
# The overlay is a full-screen scrim the compositor presents in `blend` mode
# (source-over): a SEMI-TRANSPARENT dim (#00000066 == 40% black) alpha-blends
# over the LIVE desktop so the user still sees what they are framing — the
# whole point of this file's existence, since a plain opaque fill would blit a
# black rectangle over the desktop and hide it. A bright, un-dimmed selection
# rectangle is tracked live from pointer press -> drag -> release.
#
# ADDER QUIRKS HONOURED: Ptr[uint8] string locals (no module-scope string
# globals, no adjacent-literal concat), int32 primitive coords, while-loops.

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_glyphs, \
    hamscene_stroke


# Build the overlay display list into the shared hamscene buffer. The caller
# commits it (native: hamscene_commit; host: hamui_host_rasterize). Coordinates
# are window-local == screen coordinates (the overlay is full-screen).
#
#   scr_w, scr_h  screen dimensions
#   intent_app    0 = "Select Area" wording; 1 = "Application Window" wording
#   dragging      1 = draw the live selection rectangle at (rx,ry,rw,rh)
#   rx,ry,rw,rh   selection rectangle (already clamped to the screen)
def shot_overlay_build(scr_w: int32, scr_h: int32, intent_app: int32,
                       dragging: int32, rx: int32, ry: int32,
                       rw: int32, rh: int32):
    hamscene_begin()
    # Dim the live desktop (alpha-blended by the `blend`-mode present / the
    # host alpha-aware fill) so the user still sees what they are framing.
    dim: Ptr[uint8] = "#00000066"
    hamscene_fill(0, 0, scr_w, scr_h, dim)
    # Instruction banner across the top.
    banner: Ptr[uint8] = "Drag to select an area  -  Esc to cancel"
    if intent_app != 0:
        banner = "Drag a box over a window  -  Esc to cancel"
    bandcol: Ptr[uint8] = "#1b3a5b"
    hamscene_fill(0, 0, scr_w, 26, bandcol)
    bantext: Ptr[uint8] = "#e8f0ff"
    hamscene_glyphs(12, 9, banner, bantext)
    # Live selection rectangle: a lighter clear fill inside (reads as the
    # "un-dimmed" capture region) plus a crisp bright border.
    if dragging != 0 and rw > 0 and rh > 0:
        clearfill: Ptr[uint8] = "#ffffff22"
        hamscene_fill(rx, ry, rw, rh, clearfill)
        border: Ptr[uint8] = "#ffd166"
        hamscene_stroke(rx, ry, rw, rh, 2, border)

# lib/mjpegdemux.ad — a pure-Adder demux for the trivial "HMJV" Motion-JPEG
# container (see scripts/gen_test_video.py for the writer / byte layout).
#
# An HMJV file is a tiny fixed header followed by length-prefixed baseline-JPEG
# frames. This module walks that structure ONCE (mjv_parse), validates the
# magic/version/geometry, records each frame's byte offset+length, and exposes
# them for a player to slice out and hand to lib/jpeg.ad frame by frame. It does
# NOT decode pixels (that's lib/jpeg.ad) and does NO I/O — the caller slurps the
# file bytes and hands them here, exactly like lib/wavdecode.ad / lib/png.ad.
#
# PURE: no extern/syscall/FLOAT, integer-only — compiles for the Linux host AND
# the native x86_64-adder-user target from the same source (dual-target).
#
# WHY a bespoke container (not AVI/MP4): the USER wants moving pictures; the
# hard part is the CODEC (baseline JPEG, reused wholesale from lib/jpeg.ad).
# RIFF/AVI or ISO-BMFF demux adds real index/chunk parsing for ZERO codec
# benefit, so — mirroring the audio track's WAV-over-MP3 call — the carrier is
# deliberately trivial. AVI-MJPEG demux is the named follow-up.

# ---- capacities (BSS) ----------------------------------------------------
MJV_MAX_FRAMES: uint64 = 256           # bounded frame table

mjv_off:  Array[256, uint64]           # byte offset of frame i's JPEG in buf
mjv_len:  Array[256, uint64]           # byte length of frame i's JPEG

mjv_buf:    Ptr[uint8]                 # the whole file (caller-owned)
mjv_ok_f:   int32  = 0
mjv_w_f:    int32  = 0
mjv_h_f:    int32  = 0
mjv_fps_f:  int32  = 0
mjv_nf:     int32  = 0


def _mjv_u16(buf: Ptr[uint8], o: uint64) -> uint32:
    return cast[uint32](buf[o]) | (cast[uint32](buf[o + 1]) << 8)


def _mjv_u32(buf: Ptr[uint8], o: uint64) -> uint64:
    return cast[uint64](buf[o]) | (cast[uint64](buf[o + 1]) << 8) \
        | (cast[uint64](buf[o + 2]) << 16) | (cast[uint64](buf[o + 3]) << 24)


# Parse the container header + frame index. Returns 1 on success, 0 on any
# malformation (bad magic/version, truncated header, a frame length that runs
# past the buffer, or more frames than the table holds).
def mjv_parse(buf: Ptr[uint8], length: uint64) -> int32:
    mjv_ok_f = 0
    mjv_nf = 0
    mjv_buf = buf
    if length < 20:
        return 0
    # magic "HMJV"
    if buf[0] != 72 or buf[1] != 77 or buf[2] != 74 or buf[3] != 86:
        return 0
    ver: uint32 = _mjv_u16(buf, 4)
    if ver != 1:
        return 0
    w: uint32 = _mjv_u16(buf, 8)
    h: uint32 = _mjv_u16(buf, 10)
    fps: uint32 = _mjv_u16(buf, 12)
    fc: uint32 = _mjv_u16(buf, 14)
    if w == 0 or h == 0 or fc == 0:
        return 0
    if cast[uint64](fc) > MJV_MAX_FRAMES:
        return 0
    if fps == 0:
        fps = 1                         # guard the frame-pacing divide
    mjv_w_f = cast[int32](w)
    mjv_h_f = cast[int32](h)
    mjv_fps_f = cast[int32](fps)
    # Walk the length-prefixed frames.
    o: uint64 = 20
    i: uint64 = 0
    while i < cast[uint64](fc):
        if o + 4 > length:
            return 0                    # truncated length prefix
        flen: uint64 = _mjv_u32(buf, o)
        o = o + 4
        if flen < 2 or o + flen > length:
            return 0                    # frame runs past the buffer
        mjv_off[i] = o
        mjv_len[i] = flen
        o = o + flen
        i = i + 1
    mjv_nf = cast[int32](fc)
    mjv_ok_f = 1
    return 1


def mjv_ok() -> int32:
    return mjv_ok_f


def mjv_width() -> int32:
    return mjv_w_f


def mjv_height() -> int32:
    return mjv_h_f


def mjv_fps() -> int32:
    return mjv_fps_f


def mjv_frame_count() -> int32:
    return mjv_nf


def mjv_frame_off(i: int32) -> uint64:
    if i < 0 or i >= mjv_nf:
        return 0
    return mjv_off[cast[uint64](i)]


def mjv_frame_len(i: int32) -> uint64:
    if i < 0 or i >= mjv_nf:
        return 0
    return mjv_len[cast[uint64](i)]


# Pointer to frame i's first JPEG byte (into the caller's buffer), or the buffer
# base for an out-of-range index (never NULL if a buffer was parsed).
def mjv_frame_ptr(i: int32) -> Ptr[uint8]:
    if i < 0 or i >= mjv_nf:
        return mjv_buf
    return &mjv_buf[mjv_off[cast[uint64](i)]]

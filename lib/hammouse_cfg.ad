# lib/hammouse_cfg.ad
#
# LIVE sink for the Control Center Mouse capplet (lib/hamctlcore.ad, the
# `/tmp/hamnix-mouse.conf` producer). Holds the three pointer preferences —
# speed (1..10), primary button (Left/Right) and scroll direction
# (Standard/Natural) — and the PURE transform law that applies them to the
# raw /dev/mouse event stream.
#
# Kept extern-free (like lib/hamscene.ad::hamui_scroll_apply, BUG #123) so
# the sign/swap/scale law is unit-testable on the host target without a QEMU
# boot. Two consumers:
#   * the kernel /dev/mouse router — sys/src/9/port/devwsys.ad
#     wsys_route_mouse_rel/_abs — calls the map_* / scale helpers at event
#     time (cheap: reads cached globals, no file I/O in the hot path);
#   * the capplet PUSHES a new preference into those globals by writing a
#     `cfg <speed> <primary> <natural>` control line to /dev/mouse, which
#     sys/src/9/port/devmouse.ad::devmouse_write parses into mouse_cfg_set().
#
# DEFAULTS (speed 5, primary 0, natural 0) are EXACTLY the pre-existing
# behavior: map_buttons / map_dz return their argument unchanged and
# scale_delta is the identity, so an unconfigured system is byte-for-byte
# as before.

# 1..10, 5 = neutral (1.0x pointer speed).
mcfg_speed:   int32 = 5
# 0 = left primary (default), 1 = right primary -> swap L/R buttons.
mcfg_primary: int32 = 0
# 0 = standard wheel (default), 1 = natural -> invert the wheel sign.
mcfg_natural: int32 = 0


def mouse_cfg_set(speed: int32, primary: int32, natural: int32):
    # Clamp + normalize, mirroring the capplet's own bounds so a bad ctl
    # line can never wedge the pointer.
    if speed < 1:
        speed = 1
    if speed > 10:
        speed = 10
    mcfg_speed = speed
    if primary != 0:
        primary = 1
    mcfg_primary = primary
    if natural != 0:
        natural = 1
    mcfg_natural = natural


def mouse_cfg_reset():
    # Restore stock behavior (used by the boot self-test after it perturbs
    # the globals, so the real pointer path starts neutral).
    mcfg_speed = 5
    mcfg_primary = 0
    mcfg_natural = 0


def mouse_cfg_speed() -> int32:
    return mcfg_speed


def mouse_cfg_primary() -> int32:
    return mcfg_primary


def mouse_cfg_natural() -> int32:
    return mcfg_natural


def mouse_cfg_map_buttons(b: uint32) -> uint32:
    # PRIMARY BUTTON. The /dev/mouse bitmap is bit0=Left, bit1=Right,
    # bit2=Middle (see sys/src/9/port/devmouse.ad). "Primary = Right" swaps
    # the meaning of the left and right physical buttons: exchange bit0<->bit1
    # and leave the middle button (and any higher bits) untouched. Default
    # (primary==0) returns the bitmap unchanged.
    if mcfg_primary == 0:
        return b
    l: uint32 = b & 1
    r: uint32 = (b >> 1) & 1
    keep: uint32 = b & 0xFFFFFFFC                  # everything but bits 0,1
    return keep | r | (l << 1)


def mouse_cfg_map_dz(dz: int32) -> int32:
    # SCROLL DIRECTION. Standard leaves the wheel delta as the kernel
    # reports it; Natural inverts the sign ONCE, at the source. It composes
    # with the BUG #123 law (lib/hamscene.ad::hamui_scroll_apply subtracts
    # dz): feeding that helper a negated dz yields the opposite scroll
    # direction — a single net inversion, never a double one. Default
    # (natural==0) returns dz unchanged.
    if mcfg_natural == 0:
        return dz
    return 0 - dz


def mouse_cfg_scale_delta(d: int32) -> int32:
    # POINTER SPEED. Scale a per-motion delta by speed/5 so speed 5 is
    # exactly neutral (1.0x), 10 ~= 2.0x and 1 ~= 0.2x. Integer math with
    # the sign preserved; a non-zero delta never rounds to 0 (min magnitude
    # 1) so even the slowest setting still moves the cursor. Default speed 5
    # short-circuits to the identity.
    if mcfg_speed == 5:
        return d
    if d == 0:
        return 0
    scaled: int32 = (d * mcfg_speed) / 5
    if scaled == 0:
        if d > 0:
            return 1
        return 0 - 1
    return scaled

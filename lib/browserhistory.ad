# lib/browserhistory.ad — the browser's BACK / FORWARD navigation history.
#
# A pure, dual-target session-history model shared by the native browser
# (user/hambrowse.ad) and the host test harnesses. It is the single source of
# truth for the Back/Forward buttons: every user-initiated navigation (an
# address-bar Enter/Go or a link click) PUSHES the resulting URL; the Back and
# Forward buttons walk the cursor and hand back the URL to re-fetch.
#
# Semantics mirror a real browser's session history:
#   * push(url)  — records a new entry AFTER the cursor and moves the cursor to
#                  it, DISCARDING any forward entries (the classic "you went back
#                  then clicked a link, so the forward history is gone").
#                  A push equal to the current entry is a no-op (a reload of the
#                  same page does not grow the stack).
#   * back()     — moves the cursor one step toward the oldest entry and returns
#                  that entry's URL (NUL-terminated); 0 when already at the start.
#   * forward()  — moves the cursor one step toward the newest entry; 0 at the end.
# Neither back() nor forward() PUSHES — re-navigating through history must not
# rewrite the stack (that is what keeps Forward alive after a Back).
#
# PURE: no extern/syscall/I/O, so it links into both the native
# (x86_64-adder-user) browser and the x86_64-linux host gate.

HIST_CAP:  int32 = 64            # session-history depth (oldest dropped on overflow)
HIST_SLOT: uint64 = 1024         # max bytes per URL (matches cur_url/addr_buf)

hist_url:   Array[65536, uint8]  # HIST_CAP * HIST_SLOT flat URL storage
hist_len:   Array[64, uint64]    # byte length of each entry (excl. NUL)
hist_count: int32 = 0            # number of live entries
hist_cur:   int32 = -1           # cursor: index of the currently-shown entry


def _bh_slot(i: int32) -> Ptr[uint8]:
    return &hist_url[cast[uint64](i) * HIST_SLOT]


def _bh_copy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n:
        dst[i] = src[i]
        i = i + 1
    dst[n] = 0


def _bh_eq(a: Ptr[uint8], alen: uint64, b: Ptr[uint8], blen: uint64) -> int32:
    if alen != blen:
        return 0
    i: uint64 = 0
    while i < alen:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


def browserhist_reset():
    hist_count = 0
    hist_cur = -1


# Record a navigation to `url` (length `len`). Truncates any forward entries,
# appends after the cursor, and advances the cursor. A push identical to the
# current entry (e.g. a reload) is ignored so it does not inflate the stack.
def browserhist_push(url: Ptr[uint8], len: uint64):
    if len == 0:
        return
    ul: uint64 = len
    if ul >= HIST_SLOT:
        ul = HIST_SLOT - 1
    # No-op if this equals the current entry (reload / re-render of same URL).
    if hist_cur >= 0:
        cslot: Ptr[uint8] = _bh_slot(hist_cur)
        if _bh_eq(cslot, hist_len[hist_cur], url, ul) != 0:
            return
    # Drop any forward history: the new entry becomes the tip.
    ni: int32 = hist_cur + 1
    if ni >= HIST_CAP:
        # Full stack — shift everything down by one to make room at the tip,
        # dropping the oldest entry (cursor stays at the tip).
        j: int32 = 0
        while j < HIST_CAP - 1:
            src: Ptr[uint8] = _bh_slot(j + 1)
            dst: Ptr[uint8] = _bh_slot(j)
            _bh_copy(dst, src, hist_len[j + 1])
            hist_len[j] = hist_len[j + 1]
            j = j + 1
        ni = HIST_CAP - 1
    _bh_copy(_bh_slot(ni), url, ul)
    hist_len[ni] = ul
    hist_cur = ni
    hist_count = ni + 1


def browserhist_can_back() -> int32:
    if hist_cur > 0:
        return 1
    return 0


def browserhist_can_fwd() -> int32:
    if hist_cur >= 0 and hist_cur < hist_count - 1:
        return 1
    return 0


# Step back one entry and return its (NUL-terminated) URL; 0 if already at the
# oldest entry. Does NOT push (walking history must preserve the forward stack).
def browserhist_back() -> Ptr[uint8]:
    if browserhist_can_back() == 0:
        return cast[Ptr[uint8]](0)
    hist_cur = hist_cur - 1
    return _bh_slot(hist_cur)


# Step forward one entry and return its URL; 0 if already at the newest entry.
def browserhist_fwd() -> Ptr[uint8]:
    if browserhist_can_fwd() == 0:
        return cast[Ptr[uint8]](0)
    hist_cur = hist_cur + 1
    return _bh_slot(hist_cur)


def browserhist_cur_ptr() -> Ptr[uint8]:
    if hist_cur < 0:
        return cast[Ptr[uint8]](0)
    return _bh_slot(hist_cur)


def browserhist_count() -> int32:
    return hist_count


def browserhist_index() -> int32:
    return hist_cur

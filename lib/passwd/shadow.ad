# lib/passwd/shadow.ad
#
# /etc/shadow parser per docs/security.md.
#
# Format mirrors Linux's shadow(5):
#
#     name:$<algo>$<salt>$<hash>:<last-change-days>
#
# Examples:
#
#     hostowner:$6$abcdef12$<86-char-base64ish-hash>:19000
#     alice:$6$ghijkl34$<86-char-hash>:19012
#
# `$6$` means SHA-512-crypt (Linux default; the only algo v1 supports;
# bcrypt/argon2 deferred per docs/security.md). `<last-change-days>`
# is days since the Unix epoch (1970-01-01); 0 means "never changed"
# / "force change on next login" (POSIX standard convention).
#
# File mode 0600. Only the hostowner can read it; the /dev/auth cdev
# accesses it from kernel context with the file open for read by the
# kernel itself (userland never reads /etc/shadow directly).
#
# The parser is buffer-based, just like passwd.ad. The full hash
# triple `$6$<salt>$<hash>` is stored verbatim — callers (the /dev/auth
# kernel handler) hand it back to lib/crypt/sha512_crypt.ad which
# parses the salt out, runs the same algorithm against the user's
# typed password, and constant-time compares the resulting hash.


SHADOW_MAX_ENTRIES:   uint64 = 32
SHADOW_NAME_MAX:      uint64 = 64
# A SHA-512-crypt hash triple is `$6$<salt>$<hash>` where salt is up
# to 16 chars and the hash is 86 chars; total bounded at ~110. 128
# leaves comfortable headroom for any algo prefix change.
SHADOW_HASH_MAX:      uint64 = 128


shadow_in_use: Array[32, int32]
shadow_name:   Array[2048, uint8]    # 32 * 64
shadow_hash:   Array[4096, uint8]    # 32 * 128
shadow_lchg:   Array[32, uint64]     # last-change-days since epoch
shadow_count:  uint64 = 0


def _shadow_name_at(i: uint64) -> Ptr[uint8]:
    return &shadow_name[i * SHADOW_NAME_MAX]


def _shadow_hash_at(i: uint64) -> Ptr[uint8]:
    return &shadow_hash[i * SHADOW_HASH_MAX]


def shadow_reset():
    shadow_count = 0
    i: uint64 = 0
    while i < SHADOW_MAX_ENTRIES:
        shadow_in_use[i] = 0
        shadow_lchg[i] = 0
        i = i + 1
    j: uint64 = 0
    while j < SHADOW_MAX_ENTRIES * SHADOW_NAME_MAX:
        shadow_name[j] = 0
        j = j + 1
    k: uint64 = 0
    while k < SHADOW_MAX_ENTRIES * SHADOW_HASH_MAX:
        shadow_hash[k] = 0
        k = k + 1


def _shadow_strcpy_bounded(dst: Ptr[uint8], src: Ptr[uint8],
                           lo: uint64, hi: uint64, cap: uint64):
    i: uint64 = 0
    p: uint64 = lo
    while p < hi and i + 1 < cap:
        dst[i] = src[p]
        i = i + 1
        p = p + 1
    dst[i] = 0


def _shadow_parse_u64(buf: Ptr[uint8], lo: uint64, hi: uint64) -> uint64:
    n: uint64 = 0
    while lo < hi:
        c: uint8 = buf[lo]
        if c < 48 or c > 57:
            break
        n = n * 10 + cast[uint64](c - 48)
        lo = lo + 1
    return n


def _shadow_cstr_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while True:
        if a[i] != b[i]:
            return 0
        if a[i] == 0:
            return 1
        i = i + 1
    return 0


def shadow_parse(buf: Ptr[uint8], n: uint64) -> int32:
    # Parse /etc/shadow contents in buf[0..n). Returns the number of
    # entries successfully added. The buffer is read but NOT mutated.
    shadow_reset()
    p: uint64 = 0
    while p < n:
        e: uint64 = p
        while e < n and buf[e] != 10:
            e = e + 1
        scan: uint64 = p
        is_blank: int32 = 1
        while scan < e:
            c: uint8 = buf[scan]
            if c == 35:                    # '#'
                is_blank = 1
                break
            if c != 32 and c != 9 and c != 13:
                is_blank = 0
                break
            scan = scan + 1
        if is_blank != 0:
            p = e + 1
            continue
        # Find first colon (end of name), then find the LAST colon
        # on the line (separator before <last-change-days>). The hash
        # field itself contains '$' signs but NOT colons — those are
        # the only legal field separators in shadow(5).
        line_end: uint64 = e
        if line_end > p and buf[line_end - 1] == 13:
            line_end = line_end - 1
        first_col: int64 = -1
        last_col: int64 = -1
        scan = p
        while scan < line_end:
            if buf[scan] == 58:            # ':'
                if first_col < 0:
                    first_col = cast[int64](scan)
                last_col = cast[int64](scan)
            scan = scan + 1
        if first_col < 0 or last_col <= first_col:
            p = e + 1
            continue
        if shadow_count >= SHADOW_MAX_ENTRIES:
            p = e + 1
            continue
        slot: uint64 = shadow_count
        shadow_in_use[slot] = 1
        fc: uint64 = cast[uint64](first_col)
        lc: uint64 = cast[uint64](last_col)
        _shadow_strcpy_bounded(_shadow_name_at(slot), buf,
                               p, fc, SHADOW_NAME_MAX)
        _shadow_strcpy_bounded(_shadow_hash_at(slot), buf,
                               fc + 1, lc, SHADOW_HASH_MAX)
        shadow_lchg[slot] = _shadow_parse_u64(buf, lc + 1, line_end)
        shadow_count = shadow_count + 1
        p = e + 1
    return cast[int32](shadow_count)


def shadow_lookup_by_name(name: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while i < shadow_count:
        if shadow_in_use[i] != 0:
            if _shadow_cstr_eq(_shadow_name_at(i), name) != 0:
                return cast[int32](i)
        i = i + 1
    return -1


def shadow_entry_name(idx: int32) -> Ptr[uint8]:
    if idx < 0:
        return cast[Ptr[uint8]](0)
    return _shadow_name_at(cast[uint64](idx))


def shadow_entry_hash(idx: int32) -> Ptr[uint8]:
    if idx < 0:
        return cast[Ptr[uint8]](0)
    return _shadow_hash_at(cast[uint64](idx))


def shadow_entry_lchg(idx: int32) -> uint64:
    if idx < 0:
        return 0
    return shadow_lchg[cast[uint64](idx)]


def shadow_entry_count() -> uint64:
    return shadow_count

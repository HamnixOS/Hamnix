# lib/pngwrite.ad
#
# A minimal, extern-free PNG (8-bit truecolour RGB) ENCODER — the write
# companion to lib/png.ad's decoder. It performs NO I/O of its own: every
# helper builds PNG byte-spans into a CALLER-provided buffer and returns the
# byte count (or updates the running Adler-32), and the caller does the
# actual file writes. That keeps this module import-clean for BOTH the
# x86_64-adder-user target (user/hamshot.ad, Plan 9 syscalls) and the
# x86_64-linux host target (a host driver, raw Linux syscalls) — neither of
# which can resolve the other's externs.
#
# COMPRESSION: DEFLATE *stored* (uncompressed, BTYPE=00) blocks wrapped in a
# zlib stream — the simplest bit-exact-valid encoding, and one every PNG
# decoder (including lib/png.ad) accepts. One scanline maps to one stored
# block, so an encoder can stream a frame a row at a time without holding it.
#
# Per-row IDAT chunk layout the caller assembles with these helpers:
#   [4-byte BE length][ "IDAT" ][payload ...][4-byte BE CRC-32]
# where payload =
#   row 0        : zlib-header(2) + stored-block(hdr 5 + filter 1 + RGB 3*w)
#   rows 1..h-2  : stored-block(hdr 5 + filter 1 + RGB 3*w)
#   row h-1      : stored-block(final, ...) + Adler-32(4)
#
# ADDER QUIRKS HONOURED: no heap, fixed module-scope state, while-loops, no
# module-scope string literals (chunk tags are emitted as raw byte codes).

# ---- CRC-32 (IEEE 802.3, reflected, poly 0xEDB88320) ----------------
_pngw_crc_table: Array[256, uint32]
_pngw_crc_ready: int32 = 0


def _pngw_crc_init():
    if _pngw_crc_ready == 0:
        n: uint32 = 0
        while n < 256:
            c: uint32 = n
            k: int32 = 0
            while k < 8:
                if (c & 1) != 0:
                    c = cast[uint32](0xEDB88320) ^ (c >> 1)
                else:
                    c = c >> 1
                k = k + 1
            _pngw_crc_table[cast[uint64](n)] = c
            n = n + 1
        _pngw_crc_ready = 1


# Fold `len` bytes of buf[off..] into a running CRC. Seed with 0xFFFFFFFF and
# XOR the result with 0xFFFFFFFF once the whole chunk (type+data) is folded.
def pngw_crc_update(crc: uint32, buf: Ptr[uint8], off: uint64,
                    length: uint64) -> uint32:
    _pngw_crc_init()
    c: uint32 = crc
    i: uint64 = 0
    while i < length:
        idx: uint32 = (c ^ cast[uint32](buf[off + i])) & cast[uint32](0xFF)
        c = _pngw_crc_table[cast[uint64](idx)] ^ (c >> 8)
        i = i + 1
    return c


# ---- Adler-32 (zlib stream checksum) --------------------------------
_pngw_adler_s1: uint32 = 1
_pngw_adler_s2: uint32 = 0


def pngw_adler_reset():
    _pngw_adler_s1 = 1
    _pngw_adler_s2 = 0


def pngw_adler_update(buf: Ptr[uint8], off: uint64, length: uint64):
    s1: uint32 = _pngw_adler_s1
    s2: uint32 = _pngw_adler_s2
    i: uint64 = 0
    while i < length:
        s1 = (s1 + cast[uint32](buf[off + i])) % 65521
        s2 = (s2 + s1) % 65521
        i = i + 1
    _pngw_adler_s1 = s1
    _pngw_adler_s2 = s2


def pngw_adler_final() -> uint32:
    return (_pngw_adler_s2 << 16) | _pngw_adler_s1


# ---- byte emitters --------------------------------------------------
def pngw_put_u32_be(buf: Ptr[uint8], pos: uint64, v: uint32) -> uint64:
    buf[pos]     = cast[uint8]((v >> 24) & cast[uint32](0xFF))
    buf[pos + 1] = cast[uint8]((v >> 16) & cast[uint32](0xFF))
    buf[pos + 2] = cast[uint8]((v >> 8) & cast[uint32](0xFF))
    buf[pos + 3] = cast[uint8](v & cast[uint32](0xFF))
    return pos + 4


# The 8-byte PNG signature. Returns the new position (8).
def pngw_signature(buf: Ptr[uint8]) -> uint64:
    buf[0] = 137
    buf[1] = 80                                       # 'P'
    buf[2] = 78                                       # 'N'
    buf[3] = 71                                       # 'G'
    buf[4] = 13
    buf[5] = 10
    buf[6] = 26
    buf[7] = 10
    return 8


# Full IHDR chunk (8-bit RGB, no interlace) into buf at pos 0. Returns bytes.
def pngw_ihdr(buf: Ptr[uint8], w: uint32, h: uint32) -> uint64:
    p: uint64 = pngw_put_u32_be(buf, 0, 13)           # data length
    tstart: uint64 = p
    buf[p]     = 73                                    # 'I'
    buf[p + 1] = 72                                    # 'H'
    buf[p + 2] = 68                                    # 'D'
    buf[p + 3] = 82                                    # 'R'
    p = p + 4
    p = pngw_put_u32_be(buf, p, w)
    p = pngw_put_u32_be(buf, p, h)
    buf[p]     = 8                                     # bit depth
    buf[p + 1] = 2                                     # colour type: truecolour
    buf[p + 2] = 0                                     # compression: DEFLATE
    buf[p + 3] = 0                                     # filter method 0
    buf[p + 4] = 0                                     # no interlace
    p = p + 5
    crc: uint32 = pngw_crc_update(cast[uint32](0xFFFFFFFF), buf, tstart,
                                  p - tstart)
    crc = crc ^ cast[uint32](0xFFFFFFFF)
    p = pngw_put_u32_be(buf, p, crc)
    return p


# The empty IEND chunk into buf at pos 0. Returns bytes (12).
def pngw_iend(buf: Ptr[uint8]) -> uint64:
    p: uint64 = pngw_put_u32_be(buf, 0, 0)
    tstart: uint64 = p
    buf[p]     = 73                                    # 'I'
    buf[p + 1] = 69                                    # 'E'
    buf[p + 2] = 78                                    # 'N'
    buf[p + 3] = 68                                    # 'D'
    p = p + 4
    crc: uint32 = pngw_crc_update(cast[uint32](0xFFFFFFFF), buf, tstart, 4)
    crc = crc ^ cast[uint32](0xFFFFFFFF)
    p = pngw_put_u32_be(buf, p, crc)
    return p


# ---- IDAT framing (payload built in place by the caller) ------------
# Write the "IDAT" type tag at buf[4..8] (leaving buf[0..4] for the length,
# filled by pngw_idat_end). Returns the payload start offset (8).
def pngw_idat_begin(buf: Ptr[uint8]) -> uint64:
    buf[4] = 73                                        # 'I'
    buf[5] = 68                                        # 'D'
    buf[6] = 65                                        # 'A'
    buf[7] = 84                                        # 'T'
    return 8


# Finalise an IDAT chunk whose `clen`-byte payload sits at buf[8..8+clen]:
# back-fill the length and append the CRC-32 over type+payload. Returns the
# total chunk size (12 + clen).
def pngw_idat_end(buf: Ptr[uint8], clen: uint64) -> uint64:
    pngw_put_u32_be(buf, 0, cast[uint32](clen))
    crc: uint32 = pngw_crc_update(cast[uint32](0xFFFFFFFF), buf, 4, 4 + clen)
    crc = crc ^ cast[uint32](0xFFFFFFFF)
    pngw_put_u32_be(buf, 8 + clen, crc)
    return 12 + clen


# ---- zlib / DEFLATE stored-block helpers ----------------------------
# The 2-byte zlib header (CMF=0x78, FLG=0x01: 32K window, no dict, FCHECK ok:
# 0x7801 % 31 == 0). Returns pos+2.
def pngw_zlib_header(buf: Ptr[uint8], pos: uint64) -> uint64:
    buf[pos]     = 120                                 # 0x78
    buf[pos + 1] = 1                                    # 0x01
    return pos + 2


# A 5-byte DEFLATE stored-block header for `dlen` (<= 65535) literal bytes.
# `final` != 0 sets BFINAL on the last block of the stream. Returns pos+5.
def pngw_stored_block_hdr(buf: Ptr[uint8], pos: uint64, dlen: uint64,
                          final: int32) -> uint64:
    if final != 0:
        buf[pos] = 1                                   # BFINAL=1, BTYPE=00
    else:
        buf[pos] = 0                                   # BFINAL=0, BTYPE=00
    buf[pos + 1] = cast[uint8](dlen & 0xFF)            # LEN  (little-endian)
    buf[pos + 2] = cast[uint8]((dlen >> 8) & 0xFF)
    nlen: uint64 = (~dlen) & 0xFFFF                    # NLEN = one's complement
    buf[pos + 3] = cast[uint8](nlen & 0xFF)
    buf[pos + 4] = cast[uint8]((nlen >> 8) & 0xFF)
    return pos + 5

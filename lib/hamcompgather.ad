# lib/hamcompgather.ad — PURE completion-apply layer shared by the graphical
# terminal (user/hamtermscene.ad) and any other line editor that wants readline
# Tab semantics without re-deriving the policy.
#
# lib/hamcomplete.ad already provides the byte-level matching KERNEL
# (hc_prefix_match / hc_common_prefix_len / hc_complete). This module sits ONE
# layer up: given the current edit line + cursor it locates the token being
# completed, and given a pre-gathered LEAF candidate set (newline-separated
# names — the caller does the syscall gather: builtins, /bin listings, dir
# entries) it decides the ACTION a readline Tab takes:
#
#   0  HCG_NONE      no candidate matched — do nothing / beep
#   1  HCG_UNIQUE    exactly one match — the whole remainder was written into
#                    out_insert; the caller appends a separator (' ' or '/')
#   2  HCG_EXTEND    many matches, common prefix extends the leaf — the extra
#                    bytes were written into out_insert; caller arms tab_pending
#   3  HCG_LIST      many matches, no further common prefix, and this is the
#                    SECOND consecutive Tab — out_list holds the "name\n…" list
#   4  HCG_ARM       many matches, no further common prefix, FIRST Tab — nothing
#                    inserted; caller arms tab_pending so the next Tab lists
#
# Everything here is extern-free so user/termcomplete_host.ad can drive it on
# the x86_64-linux host with synthetic candidate sets — no QEMU, no namespace.

from lib.hamcomplete import hc_complete, hc_prefix_match, hc_common_prefix_len

HCG_NONE:   int32 = 0
HCG_UNIQUE: int32 = 1
HCG_EXTEND: int32 = 2
HCG_LIST:   int32 = 3
HCG_ARM:    int32 = 4

# Scratch the pure apply step renders into (module-scope, no malloc — same
# convention as the rest of the userland tree).
HCG_PFX_CAP:   uint64 = 256
HCG_MATCH_CAP: uint64 = 8192
_hcg_prefix:  Array[256, uint8]
_hcg_matches: Array[8192, uint8]
_hcg_plen:    Array[1, uint64]


def hcg_token_start(line: Ptr[uint8], line_len: uint64, cursor: uint64) -> uint64:
    # First byte of the whitespace-delimited token the cursor sits in: scan
    # back from `cursor` over non-space/non-tab bytes. (Mirrors hamsh's
    # _ed_token_start so the two editors agree on token boundaries.)
    i: uint64 = cursor
    if i > line_len:
        i = line_len
    while i > 0:
        c: uint8 = line[i - 1]
        if c == 32 or c == 9:
            break
        i = i - 1
    return i


def hcg_is_first_word(line: Ptr[uint8], token_start: uint64) -> int32:
    # 1 iff nothing but leading whitespace precedes `token_start` — i.e. the
    # token is the COMMAND word, which completes against the command set
    # rather than the filesystem.
    i: uint64 = 0
    while i < token_start:
        c: uint8 = line[i]
        if c != 32 and c != 9:
            return 0
        i = i + 1
    return 1


def hcg_leaf_off(tok: Ptr[uint8], tok_len: uint64) -> uint64:
    # Offset of the LEAF within a token: for a path token the leaf begins
    # just past the LAST '/', otherwise the whole token is the leaf. So
    # "/bin/l" -> leaf "l" at offset 5, "src/ma" -> "ma" at 4, "ls" -> "ls".
    off: uint64 = 0
    i: uint64 = 0
    while i < tok_len:
        if tok[i] == 47:                       # '/'
            off = i + 1
        i = i + 1
    return off


def _hcg_matches_len(count: uint64) -> uint64:
    # Byte length of the first `count` "name\n" records hc_complete wrote into
    # _hcg_matches (it returns the count, not the byte length).
    seen: uint64 = 0
    p: uint64 = 0
    while p < HCG_MATCH_CAP and seen < count:
        if _hcg_matches[p] == 10:
            seen = seen + 1
        p = p + 1
    return p


def hcg_apply(leaf: Ptr[uint8], leaf_len: uint64,
              cands: Ptr[uint8], cands_len: uint64,
              tab_pending: int32,
              out_insert: Ptr[uint8], out_insert_cap: uint64,
              out_insert_len: Ptr[uint64],
              out_list: Ptr[uint8], out_list_cap: uint64,
              out_list_len: Ptr[uint64]) -> int32:
    # The readline apply policy. `cands` is the newline-separated LEAF
    # candidate set the caller gathered; `leaf`/`leaf_len` is the prefix
    # actually on the line. Returns an HCG_* action; writes the bytes to
    # insert (remainder past the leaf) and, on a list, the candidate list.
    out_insert_len[0] = 0
    out_list_len[0] = 0
    count: uint64 = hc_complete(leaf, leaf_len, cands, cands_len,
                                &_hcg_prefix[0], HCG_PFX_CAP,
                                &_hcg_matches[0], HCG_MATCH_CAP,
                                &_hcg_plen[0])
    if count == 0:
        return HCG_NONE
    plen: uint64 = _hcg_plen[0]
    if count == 1:
        # Unique — the common prefix IS the whole match; write the remainder.
        i: uint64 = leaf_len
        w: uint64 = 0
        while i < plen and w < out_insert_cap:
            out_insert[w] = _hcg_prefix[i]
            w = w + 1
            i = i + 1
        out_insert_len[0] = w
        return HCG_UNIQUE
    # Multiple matches.
    if plen > leaf_len:
        i2: uint64 = leaf_len
        w2: uint64 = 0
        while i2 < plen and w2 < out_insert_cap:
            out_insert[w2] = _hcg_prefix[i2]
            w2 = w2 + 1
            i2 = i2 + 1
        out_insert_len[0] = w2
        return HCG_EXTEND
    # No further common prefix: a first Tab arms, a second lists.
    if tab_pending != 0:
        mlen: uint64 = _hcg_matches_len(count)
        w3: uint64 = 0
        while w3 < mlen and w3 < out_list_cap:
            out_list[w3] = _hcg_matches[w3]
            w3 = w3 + 1
        out_list_len[0] = w3
        return HCG_LIST
    return HCG_ARM

# lib/imgscale.ad — pure nearest-neighbour RGBA8888 image scaling + the
# fit/zoom dimension arithmetic, shared by user/hamview.ad (the on-device
# image viewer) and its host zoom gate (user/hamview_zoom_host.ad). No libc,
# no malloc — the caller owns both the source raster and the destination
# framebuffer; this module only does the sampling + the integer size math.
#
# Nearest-neighbour is deliberate: the compositor's own fb->window blit is
# nearest-neighbour too, so the on-screen result is consistent, and it needs
# no filtering state (memory/feedback_compiler_quirks: no large locals).


# Compute the "fit" display size for a source raster: scale (sw,sh) to fit
# INSIDE the box (max_w,max_h) preserving aspect ratio, DOWNSCALING ONLY —
# an image already smaller than the box is shown at its natural size (never
# enlarged past 1:1). Result written via out_w/out_h (both >= 1 when the
# source is non-empty). This is the 100%-zoom baseline the viewer starts at.
def imgscale_fit_dims(sw: uint64, sh: uint64, max_w: uint64, max_h: uint64,
                      out_w: Ptr[uint64], out_h: Ptr[uint64]):
    dw: uint64 = sw
    dh: uint64 = sh
    # Shrink to the width bound (recompute height from the SAME ratio first,
    # then clamp width — the classic downscale order).
    if dw > max_w and dw != 0:
        dh = (dh * max_w) / dw
        dw = max_w
    # Then shrink to the height bound.
    if dh > max_h and dh != 0:
        dw = (dw * max_h) / dh
        dh = max_h
    if dw == 0:
        dw = 1
    if dh == 0:
        dh = 1
    out_w[0] = dw
    out_h[0] = dh


# Apply a zoom PERCENT to a base (100%) display size. dw = base_w * zoom / 100
# (likewise height), each clamped to [1, cap] so a huge zoom can't blow the
# blit loop / buffer bounds (the caller centre-crops anything bigger than the
# window). Result via out_w/out_h.
def imgscale_zoom_dims(base_w: uint64, base_h: uint64, zoom_pct: int64,
                       cap: uint64, out_w: Ptr[uint64], out_h: Ptr[uint64]):
    z: uint64 = 0
    if zoom_pct > 0:
        z = cast[uint64](zoom_pct)
    dw: uint64 = (base_w * z) / 100
    dh: uint64 = (base_h * z) / 100
    if dw == 0:
        dw = 1
    if dh == 0:
        dh = 1
    if dw > cap:
        dw = cap
    if dh > cap:
        dh = cap
    out_w[0] = dw
    out_h[0] = dh


# Clamp a zoom percent into [min_pct, max_pct].
def imgscale_clamp_zoom(zoom_pct: int64, min_pct: int64, max_pct: int64) -> int64:
    if zoom_pct < min_pct:
        return min_pct
    if zoom_pct > max_pct:
        return max_pct
    return zoom_pct


# Opaque nearest-neighbour blit: sample the source raster (src, sw x sh,
# RGBA8888) into the destination framebuffer (dst, dstride bytes per row,
# RGBA8888) as a dw x dh rectangle whose top-left is (px,py), clipped to the
# destination box [0,clip_w) x [0,clip_h). Alpha is forced opaque (255) so a
# scaled photo can't punch a hole in the chrome behind it. Pure integer
# nearest-neighbour: dst pixel (x,y) samples src (x*sw/dw, y*sh/dh).
def imgscale_blit(src: Ptr[uint8], sw: uint64, sh: uint64,
                  dst: Ptr[uint8], dstride: uint64,
                  px: int64, py: int64, dw: uint64, dh: uint64,
                  clip_w: int64, clip_h: int64):
    if dw == 0 or dh == 0 or sw == 0 or sh == 0:
        return
    yy: uint64 = 0
    while yy < dh:
        dy: int64 = py + cast[int64](yy)
        if dy >= 0 and dy < clip_h:
            sy: uint64 = (yy * sh) / dh
            if sy >= sh:
                sy = sh - 1
            xx: uint64 = 0
            while xx < dw:
                dx: int64 = px + cast[int64](xx)
                if dx >= 0 and dx < clip_w:
                    sx: uint64 = (xx * sw) / dw
                    if sx >= sw:
                        sx = sw - 1
                    so: uint64 = (sy * sw + sx) * 4
                    dofs: uint64 = cast[uint64](dy) * dstride \
                                   + cast[uint64](dx) * 4
                    dst[dofs]     = src[so]
                    dst[dofs + 1] = src[so + 1]
                    dst[dofs + 2] = src[so + 2]
                    dst[dofs + 3] = 255
                xx = xx + 1
        yy = yy + 1

# lib/hammathcore.ad — the PURE, target-agnostic core of HamMath, the
# expression calculator scene app.
#
# WHY (dual-target seam, see docs/hamui_dual_target.md)
# =====================================================
# The arithmetic EXPRESSION EVALUATOR, the keypad STATE MACHINE, the resize-aware
# LAYOUT, the scene DISPLAY-LIST builder and the pure keyboard+pointer INPUT
# handlers — everything EXCEPT the Hamnix-only wsys window transport. Factored
# out exactly like lib/hamcalccore.ad / lib/hammarkcore.ad, so the SAME code
# drives both the native sink (hamscene_commit -> /dev/wsys) and the host sink
# (lib/hamui_host rasterizer -> PNG). Imports ONLY lib/hamscene.ad (the pure
# builder), has NO `extern`, and links into both the native and x86_64-linux
# targets.
#
# HOW HamMath DIFFERS FROM HamCalc
# ================================
# HamCalc is a classic immediate-execution calculator: one pending operator, no
# precedence, no parentheses (5 + 3 * 2 = evaluates left to right = 16). HamMath
# is a full EXPRESSION calculator: you build a whole expression string on the LCD
# ("2+3*4", "(2+3)*4", "-(3+2)") and `=` parses it with correct operator
# PRECEDENCE, PARENTHESES and unary minus (recursive-descent grammar below), so
# 2+3*4 = 14 and (2+3)*4 = 20. Repo-only office app in the dual-target quintet.
#
# NUMBER MODEL — FIXED POINT (int64, extern-free, no FPU)
# =======================================================
# A real value r is stored as the int64 `r * SCALE` with SCALE = 1_000_000 (6
# decimal places). All arithmetic is done with integer ops (see _fp_mul/_fp_div)
# so the evaluator behaves IDENTICALLY under the seed Python compiler and the
# self-hosted native compiler (no reliance on float codegen).

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_glyphs, \
    hamscene_stroke, hamscene_panel_button


# ---- tiny pure helpers (shared with the native driver) -------------------
def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# ====================================================================
# FIXED-POINT ARITHMETIC (all int64; SCALE = 10^6)
# ====================================================================
SCALE:  int64 = 1000000
SCALE10: int64 = 100000            # SCALE / 10


# Fixed-point multiply: (a/SCALE) * (b/SCALE) -> result/SCALE. Split into
# hi/lo parts so ordinary-range products don't overflow int64.
def _fp_mul(a: int64, b: int64) -> int64:
    sign: int64 = 1
    aa: int64 = a
    bb: int64 = b
    if aa < 0:
        sign = 0 - sign
        aa = 0 - aa
    if bb < 0:
        sign = 0 - sign
        bb = 0 - bb
    ah: int64 = aa / SCALE
    al: int64 = aa % SCALE
    bh: int64 = bb / SCALE
    bl: int64 = bb % SCALE
    r: int64 = SCALE * ah * bh + ah * bl + al * bh + (al * bl) / SCALE
    return sign * r


# Fixed-point divide: (a/SCALE) / (b/SCALE) -> result/SCALE. Long division of
# the remainder gives 6 fractional digits without overflow. Latches perr on
# divide-by-zero.
def _fp_div(a: int64, b: int64) -> int64:
    if b == 0:
        perr = 1
        return 0
    sign: int64 = 1
    aa: int64 = a
    bb: int64 = b
    if aa < 0:
        sign = 0 - sign
        aa = 0 - aa
    if bb < 0:
        sign = 0 - sign
        bb = 0 - bb
    ip: int64 = aa / bb
    rem: int64 = aa % bb
    res: int64 = ip * SCALE
    f: int64 = SCALE10
    k: int32 = 0
    while k < 6:
        rem = rem * 10
        d: int64 = rem / bb
        rem = rem % bb
        res = res + d * f
        f = f / 10
        k = k + 1
    return sign * res


# ====================================================================
# NUMBER FORMATTING
# ====================================================================
# Render the scaled value v into out (trailing zeros trimmed, leading "0." for
# pure fractions), NUL-terminated.
def _fmt_scaled(v: int64, out: Ptr[uint8]):
    neg: int32 = 0
    uv: uint64 = 0
    if v < 0:
        neg = 1
        uv = cast[uint64](0 - v)
    else:
        uv = cast[uint64](v)
    su: uint64 = cast[uint64](SCALE)
    ip: uint64 = uv / su
    fp: uint64 = uv % su
    p: uint64 = 0
    if neg != 0:
        out[p] = 45                     # '-'
        p = p + 1
    p = p + _u64_to_dec(ip, &out[p])
    if fp != 0:
        # six zero-padded fractional digits, trailing zeros trimmed.
        fd: Array[6, uint8]
        d: int32 = 5
        x: uint64 = fp
        while d >= 0:
            fd[d] = cast[uint8](x % 10) + 48
            x = x / 10
            d = d - 1
        last: int32 = 5
        while last > 0 and fd[last] == 48:
            last = last - 1
        out[p] = 46                     # '.'
        p = p + 1
        i: int32 = 0
        while i <= last:
            out[p] = fd[i]
            p = p + 1
            i = i + 1
    out[p] = 0


# ====================================================================
# EXPRESSION EVALUATOR — recursive descent (correct precedence + parens)
# ====================================================================
#   expr   := term   (('+' | '-') term)*
#   term   := factor (('*' | '/') factor)*
#   factor := ('+' | '-') factor | '(' expr ')' | number
#   number := DIGIT* ('.' DIGIT*)?
# All values are fixed-point int64. `perr` latches on any malformed input or
# divide-by-zero.
pbuf: Array[128, uint8]                 # the expression being parsed
pn:   uint64 = 0                        # its length
pp:   uint64 = 0                        # parse cursor
perr: int32 = 0


def _p_skip_ws():
    while pp < pn and pbuf[pp] == 32:
        pp = pp + 1


def _p_is_digit(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return 1
    return 0


# Parse a decimal number at pp into a scaled int64.
def _parse_number() -> int64:
    ipart: int64 = 0
    got: int32 = 0
    while pp < pn and _p_is_digit(pbuf[pp]) != 0:
        ipart = ipart * 10 + cast[int64](pbuf[pp]) - 48
        pp = pp + 1
        got = 1
    v: int64 = ipart * SCALE
    if pp < pn and pbuf[pp] == 46:      # '.'
        pp = pp + 1
        place: int64 = SCALE10          # 10^5 (first fractional digit weight)
        while pp < pn and _p_is_digit(pbuf[pp]) != 0:
            if place > 0:
                v = v + (cast[int64](pbuf[pp]) - 48) * place
                place = place / 10
            pp = pp + 1
            got = 1
    if got == 0:
        perr = 1
    return v


def _parse_factor() -> int64:
    _p_skip_ws()
    if pp >= pn:
        perr = 1
        return 0
    c: uint8 = pbuf[pp]
    if c == 45:                         # unary '-'
        pp = pp + 1
        return 0 - _parse_factor()
    if c == 43:                         # unary '+'
        pp = pp + 1
        return _parse_factor()
    if c == 40:                         # '('
        pp = pp + 1
        v: int64 = _parse_expr()
        _p_skip_ws()
        if pp < pn and pbuf[pp] == 41:  # ')'
            pp = pp + 1
        else:
            perr = 1
        return v
    if _p_is_digit(c) != 0 or c == 46:  # number or leading '.'
        return _parse_number()
    perr = 1
    return 0


def _parse_term() -> int64:
    v: int64 = _parse_factor()
    while True:
        _p_skip_ws()
        if pp >= pn:
            return v
        c: uint8 = pbuf[pp]
        if c == 42:                     # '*'
            pp = pp + 1
            v = _fp_mul(v, _parse_factor())
        elif c == 47:                   # '/'
            pp = pp + 1
            v = _fp_div(v, _parse_factor())
        else:
            return v
    return v


def _parse_expr() -> int64:
    v: int64 = _parse_term()
    while True:
        _p_skip_ws()
        if pp >= pn:
            return v
        c: uint8 = pbuf[pp]
        if c == 43:                     # '+'
            pp = pp + 1
            v = v + _parse_term()
        elif c == 45:                   # '-'
            pp = pp + 1
            v = v - _parse_term()
        else:
            return v
    return v


# PUBLIC: evaluate a NUL-terminated expression string. Sets the error flag on
# malformed input / divide-by-zero, stores + returns the scaled result.
result: int64 = 0
err:    int32 = 0


def hammath_eval_cstr(s: Ptr[uint8]) -> int64:
    n: uint64 = 0
    while s[n] != 0 and n < 127:
        pbuf[n] = s[n]
        n = n + 1
    pbuf[n] = 0
    pn = n
    pp = 0
    perr = 0
    if n == 0:
        perr = 1
    v: int64 = _parse_expr()
    _p_skip_ws()
    if pp < pn:                         # trailing junk (e.g. unbalanced ')')
        perr = 1
    err = perr
    if err != 0:
        v = 0
    result = v
    return v


def hammath_err() -> int32:
    return err


def hammath_result_scaled() -> int64:
    return result


# PUBLIC: format the last hammath_eval_cstr result as a NUL-terminated string
# ("ERR" if the error flag latched). Independent of the keypad display state.
def hammath_result_str() -> Ptr[uint8]:
    if err != 0:
        disp_buf[0] = 69                # 'E'
        disp_buf[1] = 82                # 'R'
        disp_buf[2] = 82                # 'R'
        disp_buf[3] = 0
        return &disp_buf[0]
    _fmt_scaled(result, &disp_buf[0])
    return &disp_buf[0]


# ====================================================================
# KEYPAD STATE MACHINE
# ====================================================================
# The LCD shows the whole expression string as you type ("2+3*4"); `=` parses it
# and collapses the LCD to the result. show_result is set after `=` so the next
# digit starts fresh and the next operator continues from the result.
expr_buf: Array[128, uint8]
expr_len: uint64 = 0
show_result: int32 = 0
disp_buf: Array[64, uint8]


def hammath_clear():
    expr_len = 0
    expr_buf[0] = 0
    show_result = 0
    err = 0
    result = 0


def _is_op_char(c: uint8) -> int32:
    if c == 43 or c == 45 or c == 42 or c == 47:
        return 1
    return 0


def _load_result_into_expr():
    _fmt_scaled(result, &expr_buf[0])
    expr_len = _slen(&expr_buf[0])


# Append one ASCII character to the running expression.
def hammath_append(c: uint8):
    if show_result != 0:
        if _is_op_char(c) != 0 and err == 0:
            _load_result_into_expr()    # continue from the result
        else:
            expr_len = 0                 # start a fresh expression
            expr_buf[0] = 0
        show_result = 0
        err = 0
    if expr_len < 126:
        expr_buf[expr_len] = c
        expr_len = expr_len + 1
        expr_buf[expr_len] = 0


def hammath_backspace():
    if show_result != 0:
        hammath_clear()
        return
    if expr_len > 0:
        expr_len = expr_len - 1
        expr_buf[expr_len] = 0


def hammath_equals():
    hammath_eval_cstr(&expr_buf[0])
    show_result = 1


# PUBLIC: refresh + return a pointer to the NUL-terminated LCD string.
def hammath_display() -> Ptr[uint8]:
    if err != 0:
        disp_buf[0] = 69                # 'E'
        disp_buf[1] = 82                # 'R'
        disp_buf[2] = 82                # 'R'
        disp_buf[3] = 0
        return &disp_buf[0]
    if show_result != 0:
        _fmt_scaled(result, &disp_buf[0])
        return &disp_buf[0]
    if expr_len == 0:
        disp_buf[0] = 48                # '0'
        disp_buf[1] = 0
        return &disp_buf[0]
    return &expr_buf[0]


# ====================================================================
# LAYOUT + RENDER
# ====================================================================
# Keypad is NCOLS x NROWS. Five rows fit the expression-calculator key set:
#   C  (  )  /
#   7  8  9  *
#   4  5  6  -
#   1  2  3  +
#   0  .  <  =
NCOLS: int32 = 4
NROWS: int32 = 5
NKEYS: int32 = 20

CALC_W: int32 = 200
CALC_H: int32 = 300
calc_w: int32 = 200
calc_h: int32 = 300

DISP_X: int32 = 8
DISP_Y: int32 = 8
DISP_W: int32 = 184
DISP_H: int32 = 40
GRID_X: int32 = 8
GRID_Y: int32 = 56
KEY_W: int32 = 44
KEY_H: int32 = 44
KEY_GAP: int32 = 4


def hammath_layout():
    pad: int32 = 8
    gap: int32 = 4
    disp_h: int32 = calc_h / 6
    if disp_h < 32:
        disp_h = 32
    if disp_h > 120:
        disp_h = 120
    DISP_X = pad
    DISP_Y = pad
    DISP_W = calc_w - pad * 2
    if DISP_W < 16:
        DISP_W = 16
    DISP_H = disp_h
    grid_top: int32 = DISP_Y + DISP_H + pad
    avail_w: int32 = calc_w - pad * 2
    avail_h: int32 = calc_h - grid_top - pad
    if avail_w < 16:
        avail_w = 16
    if avail_h < 16:
        avail_h = 16
    KEY_GAP = gap
    kw: int32 = (avail_w - gap * (NCOLS - 1)) / NCOLS
    kh: int32 = (avail_h - gap * (NROWS - 1)) / NROWS
    if kw < 8:
        kw = 8
    if kh < 8:
        kh = 8
    KEY_W = kw
    KEY_H = kh
    grid_w: int32 = kw * NCOLS + gap * (NCOLS - 1)
    grid_h: int32 = kh * NROWS + gap * (NROWS - 1)
    GRID_X = pad + (avail_w - grid_w) / 2
    GRID_Y = grid_top + (avail_h - grid_h) / 2


def _apply_resize(nw: int64, nh: int64) -> int32:
    if nw < 100:
        nw = 100
    if nh < 140:
        nh = 140
    if cast[int32](nw) == calc_w and cast[int32](nh) == calc_h:
        return 0
    calc_w = cast[int32](nw)
    calc_h = cast[int32](nh)
    hammath_layout()
    return 1


# Transient pressed-key highlight (so a click visibly "sinks" the button).
press_key: int32 = -1

# Key model: NKEYS keys. kind:
#   0=append ASCII char (key_val is the byte)  1=equals  2=clear  3=backspace
key_kind: Array[20, int32]
key_val:  Array[20, int32]


def _set_key(i: int32, kind: int32, val: int32):
    key_kind[i] = kind
    key_val[i] = val


# PUBLIC: initialise the keypad model (5x4 expression-calculator layout).
def hammath_init():
    _set_key(0, 2, 0)                   # C
    _set_key(1, 0, 40)                  # (
    _set_key(2, 0, 41)                  # )
    _set_key(3, 0, 47)                  # /
    _set_key(4, 0, 55)                  # 7
    _set_key(5, 0, 56)                  # 8
    _set_key(6, 0, 57)                  # 9
    _set_key(7, 0, 42)                  # *
    _set_key(8, 0, 52)                  # 4
    _set_key(9, 0, 53)                  # 5
    _set_key(10, 0, 54)                 # 6
    _set_key(11, 0, 45)                 # -
    _set_key(12, 0, 49)                 # 1
    _set_key(13, 0, 50)                 # 2
    _set_key(14, 0, 51)                 # 3
    _set_key(15, 0, 43)                 # +
    _set_key(16, 0, 48)                 # 0
    _set_key(17, 0, 46)                 # .
    _set_key(18, 3, 0)                  # <-  backspace
    _set_key(19, 1, 0)                  # =


lblbuf: Array[4, uint8]


def _key_label(i: int32) -> Ptr[uint8]:
    k: int32 = key_kind[i]
    if k == 1:
        lblbuf[0] = 61                  # '='
    elif k == 2:
        lblbuf[0] = 67                  # 'C'
    elif k == 3:
        lblbuf[0] = 60                  # '<'  (backspace)
    else:
        lblbuf[0] = cast[uint8](key_val[i])
    lblbuf[1] = 0
    return &lblbuf[0]


# Label colour by role: digits/dot dark, operators orange, parens blue,
# clear/backspace red, '=' orange.
def _key_color(i: int32) -> Ptr[uint8]:
    k: int32 = key_kind[i]
    if k == 1:
        return cast[Ptr[uint8]]("#7a2a00")            # '=' : orange
    if k == 2 or k == 3:
        return cast[Ptr[uint8]]("#7a0000")            # C / <- : red
    v: int32 = key_val[i]
    if v == 43 or v == 45 or v == 42 or v == 47:
        return cast[Ptr[uint8]]("#7a2a00")            # operators : orange
    if v == 40 or v == 41:
        return cast[Ptr[uint8]]("#00457a")            # parens : blue
    return cast[Ptr[uint8]]("#202020")                # digits / '.' : dark


def _key_x(i: int32) -> int32:
    col: int32 = i % NCOLS
    return GRID_X + col * (KEY_W + KEY_GAP)


def _key_y(i: int32) -> int32:
    row: int32 = i / NCOLS
    return GRID_Y + row * (KEY_H + KEY_GAP)


# PUBLIC: which key index is at window-local (lx,ly), or -1.
def hammath_key_at(lx: int64, ly: int64) -> int64:
    i: int32 = 0
    while i < NKEYS:
        kx: int64 = cast[int64](_key_x(i))
        ky: int64 = cast[int64](_key_y(i))
        if lx >= kx and lx < kx + cast[int64](KEY_W) and \
           ly >= ky and ly < ky + cast[int64](KEY_H):
            return cast[int64](i)
        i = i + 1
    return -1


# PUBLIC: build the whole display list into the shared hamscene buffer (no
# commit — native commits, host rasterizes).
def hammath_build_scene():
    hamscene_begin()
    # Body background (calculator case), sized to the current content area.
    hamscene_fill(0, 0, calc_w, calc_h, cast[Ptr[uint8]]("#2b2f36"))
    # Display bar: a sunken dark LCD with the value right-justified-ish.
    hamscene_fill(DISP_X, DISP_Y, DISP_W, DISP_H, cast[Ptr[uint8]]("#0d1410"))
    hamscene_stroke(DISP_X, DISP_Y, DISP_W, DISP_H, 1,
                    cast[Ptr[uint8]]("#5a6a5a"))
    ds: Ptr[uint8] = hammath_display()
    dl: uint64 = _slen(ds)
    tx: int32 = DISP_X + DISP_W - 8 - cast[int32](dl) * 8
    if tx < DISP_X + 6:
        tx = DISP_X + 6
    hamscene_glyphs(tx, DISP_Y + DISP_H / 2 - 8, ds,
                    cast[Ptr[uint8]]("#9ff09f"))
    # Button grid.
    i: int32 = 0
    while i < NKEYS:
        kx: int32 = _key_x(i)
        ky: int32 = _key_y(i)
        sunk: int32 = 0
        if i == press_key:
            sunk = 1
        hamscene_panel_button(kx, ky, KEY_W, KEY_H, sunk)
        lbl: Ptr[uint8] = _key_label(i)
        ll: int32 = cast[int32](_slen(lbl))
        gx: int32 = kx + (KEY_W - ll * 8) / 2
        gy: int32 = ky + (KEY_H - 16) / 2
        hamscene_glyphs(gx, gy, lbl, _key_color(i))
        i = i + 1


# Apply key index `k` to the state machine.
def _press(k: int64):
    kind: int32 = key_kind[k]
    val: int32 = key_val[k]
    if kind == 0:
        hammath_append(cast[uint8](val))
    elif kind == 1:
        hammath_equals()
    elif kind == 2:
        hammath_clear()
    elif kind == 3:
        hammath_backspace()


# PUBLIC: apply the key at index k AND latch the sink highlight.
def hammath_press_at(k: int64):
    _press(k)
    press_key = cast[int32](k)


# PUBLIC: clear the sink highlight (release edge). Returns 1 if a sink was
# actually cleared (so the caller only re-commits when something changed).
def hammath_release() -> int32:
    if press_key >= 0:
        press_key = -1
        return 1
    return 0


# Map an ASCII byte to a state-machine action; returns 1 if it changed state.
def _press_kbd(c: uint8) -> int32:
    if c >= 48 and c <= 57:                 # '0'..'9'
        hammath_append(c)
        return 1
    if c == 43 or c == 45 or c == 42 or c == 47:   # + - * /
        hammath_append(c)
        return 1
    if c == 40 or c == 41 or c == 46:              # ( ) .
        hammath_append(c)
        return 1
    if c == 61 or c == 10 or c == 13:       # '=' / Enter (NL/CR)
        hammath_equals()
        return 1
    if c == 99 or c == 67 or c == 27:       # 'c' / 'C' / Esc -> clear
        hammath_clear()
        return 1
    if c == 8 or c == 127:                  # Backspace / DEL
        hammath_backspace()
        return 1
    return 0


# PUBLIC: parse one "<type> <code>" key line; on a press ('d') apply the byte.
def hammath_key_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 100:                # 'd' = press; ignore 'u' release
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    neg: int32 = 0
    if i < n and s[i] == 45:
        neg = 1
        i = i + 1
    code: int32 = 0
    got: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        code = code * 10 + cast[int32](s[i]) - 48
        i = i + 1
        got = 1
    if got == 0:
        return 0
    if neg != 0:
        code = 0 - code
    if code < 0 or code > 255:
        return 0
    return _press_kbd(cast[uint8](code))


# PUBLIC: parse "r <w> <h>" resize line; apply. Returns 1 if applied.
def hammath_resize_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 114:                # 'r'
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    wv: int64 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        wv = wv * 10 + cast[int64](s[i]) - 48
        i = i + 1
    while i < n and s[i] == 32:
        i = i + 1
    hv: int64 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        hv = hv * 10 + cast[int64](s[i]) - 48
        i = i + 1
    if wv <= 0 or hv <= 0:
        return 0
    return _apply_resize(wv, hv)


# PUBLIC: parse "m <x> <y> <buttons> ..." -> 1 + fills bx/by/bbtn; else 0.
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                            # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc2: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc2 = acc2 * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc2 = 0 - acc2
        vals[v] = acc2
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1

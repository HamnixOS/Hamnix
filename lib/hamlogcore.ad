# lib/hamlogcore.ad — PURE, extern-free core for the Log Viewer scene app
# (/bin/hamlogscene). A MATE-style "System Log" window: it shows the kernel
# printk ring (the native driver reads /proc/kmsg — the same source as
# /bin/dmesg and /bin/hlog) as a scrollable list of the most-recent lines,
# with page Up / Down / Tail scroll controls and a wheel-scroll handler.
#
# All the line storage (a fixed ring of the last CAP_LINES lines), layout,
# rendering and hit-testing live here (imports only lib/hamscene) so the whole
# window renders on the host to a PNG and drives scripted input deterministic-
# ally (see user/hamlogscene_host.ad) AND ships native (user/hamlogscene.ad).

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_stroke, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_panel_button, \
    hamscene_roundrect, hamui_scroll_apply


# ---- line ring -----------------------------------------------------------
CAP_LINES: uint64 = 256
LINE_LEN:  uint64 = 96                  # bytes per stored line (incl. NUL)
log_buf: Array[24576, uint8]            # CAP_LINES * LINE_LEN
log_head:  uint64 = 0                   # ring index of the OLDEST line
log_count: uint64 = 0                   # number of stored lines (<= CAP_LINES)
log_scroll: uint64 = 0                  # logical index of the top visible line


def _log_slot_ptr(slot: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&log_buf[0]) + slot * LINE_LEN)


# Logical line i in [0, log_count) -> its byte pointer.
def _log_line_ptr(i: uint64) -> Ptr[uint8]:
    return _log_slot_ptr((log_head + i) % CAP_LINES)


def hamlog_count() -> uint64:
    return log_count


def hamlog_scroll() -> uint64:
    return log_scroll


def hamlog_line_ptr(i: uint64) -> Ptr[uint8]:
    return _log_line_ptr(i)


def hamlog_clear():
    log_head = 0
    log_count = 0
    log_scroll = 0


# Append one line (bytes s[0..n)), truncating to fit LINE_LEN-1. When the ring
# is full the oldest line is dropped (head advances).
def hamlog_add_line(s: Ptr[uint8], n: uint64):
    m: uint64 = n
    if m > LINE_LEN - 1:
        m = LINE_LEN - 1
    slot: uint64 = (log_head + log_count) % CAP_LINES
    dp: Ptr[uint8] = _log_slot_ptr(slot)
    k: uint64 = 0
    while k < m:
        c: uint8 = s[k]
        if c == 9:                                       # tab -> space
            c = 32
        if c < 32 or c > 126:                            # keep it printable
            c = 32
        dp[k] = c
        k = k + 1
    dp[k] = 0
    if log_count < CAP_LINES:
        log_count = log_count + 1
    else:
        log_head = (log_head + 1) % CAP_LINES


# Split a raw buffer (e.g. one read of /proc/kmsg) on '\n' and append each
# non-empty line. A trailing partial (no final newline) is also appended.
def hamlog_add_text(s: Ptr[uint8], n: uint64):
    ls: uint64 = 0
    i: uint64 = 0
    while i <= n:
        atend: int32 = 0
        if i == n:
            atend = 1
        if atend == 1 or s[i] == 10:
            if i > ls:
                hamlog_add_line(&s[ls], i - ls)
            ls = i + 1
        i = i + 1


# ---- layout --------------------------------------------------------------
WIN_W:  int32 = 568
WIN_H:  int32 = 360
BAR_H:  int32 = 26
TA_X:   int32 = 8
TA_Y:   int32 = 34
TA_W:   int32 = 524                     # leaves a 28px scroll gutter
TA_H:   int32 = 296
GLYPH_W: int32 = 8
LINE_H:  int32 = 16
MAXROWS: uint64 = 18                    # (TA_H-8)/16
MAXCOLS: uint64 = 64                    # (TA_W-8)/8

# scroll gutter click regions (right edge) — INVISIBLE now (the modern thin
# scrollbar replaces the drawn chunky buttons); clicking the top third pages
# up, the middle tails, the bottom third pages down.
BTN_X:  int32 = 536
BTN_W:  int32 = 24
BTN_H:  int32 = 24
UP_Y:   int32 = 34
DN_Y:   int32 = 306
TAIL_Y: int32 = 170

# Modern thin rounded scrollbar geometry (right gutter).
SB_W:         int32 = 6
SB_R:         int32 = 3
SB_X:         int32 = 550               # centered in the 28px gutter
SB_MIN_THUMB: int32 = 28


# Largest valid top index so the last page is fully shown.
def _log_maxscroll() -> uint64:
    if log_count <= MAXROWS:
        return 0
    return log_count - MAXROWS


def hamlog_clamp():
    m: uint64 = _log_maxscroll()
    if log_scroll > m:
        log_scroll = m


# Snap the viewport to the newest lines (tail follow).
def hamlog_tail():
    log_scroll = _log_maxscroll()


# ---- scene ---------------------------------------------------------------
_hdr_buf: Array[48, uint8]


def _log_u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _build_header():
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("Kernel Log  (")
    k: uint64 = 0
    while pre[k] != 0:
        _hdr_buf[p] = pre[k]
        p = p + 1
        k = k + 1
    p = p + _log_u64_to_dec(log_count, &_hdr_buf[p])
    suf: Ptr[uint8] = cast[Ptr[uint8]](" lines)")
    j: uint64 = 0
    while suf[j] != 0:
        _hdr_buf[p] = suf[j]
        p = p + 1
        j = j + 1
    _hdr_buf[p] = 0


def hamlog_build_scene():
    fg:  Ptr[uint8] = cast[Ptr[uint8]]("#c8d0d8")
    hamscene_begin()
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#eceef2"))
    hamscene_fill(0, 0, WIN_W, BAR_H, cast[Ptr[uint8]]("#3584e4"))
    # Modern headerbar elevation hairline along the titlebar's bottom edge.
    hamscene_fill(0, BAR_H - 1, WIN_W, 1, cast[Ptr[uint8]]("#1f66c8"))
    _build_header()
    hamscene_glyphs(10, 8, &_hdr_buf[0], cast[Ptr[uint8]]("#ffffff"))

    # console-style text area (dark)
    hamscene_fill(TA_X, TA_Y, TA_W, TA_H, cast[Ptr[uint8]]("#10161c"))
    hamscene_stroke(TA_X, TA_Y, TA_W, TA_H, 1, cast[Ptr[uint8]]("#808080"))

    row: uint64 = 0
    while row < MAXROWS and log_scroll + row < log_count:
        lp: Ptr[uint8] = _log_line_ptr(log_scroll + row)
        ly: int32 = TA_Y + 4 + cast[int32](row) * LINE_H
        hamscene_glyphs(TA_X + 4, ly, lp, fg)
        row = row + 1

    # Modern (KDE/Breeze-style) scrollbar: a thin rounded thumb in a subtle
    # track down the right gutter. No chunky arrow buttons — the wheel scrolls,
    # and clicking the gutter above/below the thumb still pages up/down / tails
    # (hit regions live in hamlog_click). The thumb size is proportional to the
    # visible page and its position tracks the scroll offset.
    hamscene_roundrect(SB_X, TA_Y, SB_W, TA_H, SB_R, cast[Ptr[uint8]]("#dfe2e8"))
    if log_count > MAXROWS:
        thumb_h: int32 = cast[int32](TA_H * cast[int32](MAXROWS) /
                                     cast[int32](log_count))
        if thumb_h < SB_MIN_THUMB:
            thumb_h = SB_MIN_THUMB
        if thumb_h > TA_H:
            thumb_h = TA_H
        span: int32 = TA_H - thumb_h
        m: uint64 = _log_maxscroll()
        toff: int32 = 0
        if m > 0:
            toff = cast[int32](cast[int32](span) * cast[int32](log_scroll) /
                               cast[int32](m))
        hamscene_roundrect(SB_X, TA_Y + toff, SB_W, thumb_h, SB_R,
                           cast[Ptr[uint8]]("#9aa0aa"))

    # footer: visible range
    hamscene_glyphs(TA_X, WIN_H - 20,
                    cast[Ptr[uint8]]("wheel scrolls  -  click the bar to page / tail"),
                    cast[Ptr[uint8]]("#606060"))


# ---- input ---------------------------------------------------------------
ACT_LOG_NONE: int32 = 0
ACT_LOG_UP:   int32 = 1
ACT_LOG_DOWN: int32 = 2
ACT_LOG_TAIL: int32 = 3


def _in(x: int64, y: int64, bx: int32, by: int32, bw: int32, bh: int32) -> int32:
    if x >= cast[int64](bx) and x < cast[int64](bx + bw) \
            and y >= cast[int64](by) and y < cast[int64](by + bh):
        return 1
    return 0


# Page-scroll amount = a full page minus one line of overlap.
def _log_page() -> uint64:
    if MAXROWS > 1:
        return MAXROWS - 1
    return 1


def hamlog_click(x: int64, y: int64) -> int32:
    if _in(x, y, BTN_X, UP_Y, BTN_W, BTN_H) != 0:
        pg: uint64 = _log_page()
        if log_scroll > pg:
            log_scroll = log_scroll - pg
        else:
            log_scroll = 0
        return ACT_LOG_UP
    if _in(x, y, BTN_X, DN_Y, BTN_W, BTN_H) != 0:
        log_scroll = log_scroll + _log_page()
        hamlog_clamp()
        return ACT_LOG_DOWN
    if _in(x, y, BTN_X, TAIL_Y, BTN_W, BTN_H) != 0:
        hamlog_tail()
        return ACT_LOG_TAIL
    return ACT_LOG_NONE


# Wheel: reuse the #123 sign law. dz>0 = wheel up/away -> scroll toward older
# (smaller offset); dz<0 -> toward newer. hamui_scroll_apply subtracts dz.
def hamlog_wheel(dz: int32) -> int32:
    cur: int32 = cast[int32](log_scroll)
    m: int32 = cast[int32](_log_maxscroll())
    log_scroll = cast[uint64](hamui_scroll_apply(cur, dz, 1, m))
    return 1


# Parse a wsys "m <x> <y> <buttons> <dz>\n" event line (4 signed ints). The
# scroll delta is the 4th field (0 when it's a plain move/click); parse_pointer
# in the other cores stops at 3, so the Log Viewer keeps its own 4-field parse
# to catch the wheel notch. Returns 1 on a well-formed line.
def hamlog_parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64],
                         by: Ptr[int64], bbtn: Ptr[int64],
                         bdz: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                             # 'm'
        return 0
    i: uint64 = 1
    vals: Array[4, int64]
    v: uint64 = 0
    while v < 4:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc = acc * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            # dz (the 4th field) may be absent on older event streams; treat a
            # missing trailing field as 0 rather than failing the whole line.
            if v == 3:
                acc = 0
            else:
                return 0
        if neg != 0:
            acc = 0 - acc
        vals[v] = acc
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    bdz[0] = vals[3]
    return 1

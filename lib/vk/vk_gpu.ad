# lib/vk/vk_gpu.ad
#
# GPU (virtio-gpu) backend for the native vk graphics spine — GPU track
# Phase D. This is the hardware-accelerated sibling of the software
# rasterizer (lib/vk/vk_raster.ad + lib/vk/vk_2d.ad): it routes the
# vk spine's CLEAR and PRESENT onto QEMU's native virtio-gpu device
# (drivers/video/virtio_gpu.ad), so the now-unified DE + hamSDL
# rendering (Phases A–C) can offload the frame's scanout to the device
# instead of streaming every pixel through the GOP MMIO framebuffer.
#
# ARCHITECTURE
# ============
#   * NATIVE-first: virtio-gpu is a standardized virtio-1.0 device, so
#     it is driven by a NATIVE Adder driver (like AHCI/NVMe/xHCI), NOT a
#     Linux .ko shim. ZERO Linux / namespace dependency, NO sockets.
#   * This file is a thin, dependency-light seam: it wraps the driver's
#     public entry points so lib/vk/vk_core.ad can select the backend
#     WITHOUT importing the driver directly. vk_core → vk_gpu → driver;
#     no cycle (the driver never imports vk).
#
# WHAT PHASE D OFFLOADS (this round)
# ==================================
#   * vk_gpu_clear(rgba)          — solid-fill the device scanout backing
#                                   (the CLEAR op; the #1 CPU cost the
#                                   Phase-C compositor flagged).
#   * vk_gpu_fill_rect(...)       — solid rectangle into the backing.
#   * vk_gpu_present()            — TRANSFER_TO_HOST + FLUSH the backing
#                                   to the scanout (the present offload).
#   * vk_gpu_present_image(...)   — convert a vk RGBA color image into the
#                                   backing and scan it out, so ANY
#                                   rendered frame can present via the GPU.
#
# HONEST SCOPE: the software 2D/3D ops (blit / line / roundrect / draw)
# still render into the vk color image on the CPU this round; only the
# CLEAR has a pure-device path and the PRESENT/scanout is offloaded.
# Next increments move more ops onto the device backing so the DE and
# games can flip to the GPU backend by default once it is faster.

from drivers.video.virtio_gpu import (
    virtio_gpu_available,
    virtio_gpu_scanout_width, virtio_gpu_scanout_height,
    virtio_gpu_backing_base,
    virtio_gpu_clear_solid, virtio_gpu_fill_rect_solid,
    virtio_gpu_present_frame, virtio_gpu_present_rgba,
)


def vk_gpu_backend_available() -> int32:
    # 1 if a virtio-gpu device probed + scanned out at boot, else 0.
    return virtio_gpu_available()


def vk_gpu_scanout_width() -> uint32:
    return virtio_gpu_scanout_width()


def vk_gpu_scanout_height() -> uint32:
    return virtio_gpu_scanout_height()


def vk_gpu_backing_base() -> uint64:
    # Direct-mapped VA of the BGRA scanout backing (for self-test readback).
    return virtio_gpu_backing_base()


def vk_gpu_clear(rgba: uint32) -> int32:
    # GPU CLEAR: solid-fill the whole scanout backing. rgba is 0xRRGGBBAA.
    return virtio_gpu_clear_solid(rgba)


def vk_gpu_fill_rect(x: int32, y: int32, w: int32, h: int32,
                     rgba: uint32) -> int32:
    # GPU solid rectangle fill into the scanout backing.
    return virtio_gpu_fill_rect_solid(x, y, w, h, rgba)


def vk_gpu_present() -> int32:
    # Scan out whatever is currently in the backing (clear / fills).
    return virtio_gpu_present_frame()


def vk_gpu_clear_present(rgba: uint32) -> int32:
    # Pure-device CLEAR + PRESENT fast path: solid-fill the backing and
    # flush it to the scanout, with NO vk color image / rasterizer
    # involved. This is the Phase-D proof-of-concept for the highest-value
    # op (clear) running entirely on the GPU device.
    if virtio_gpu_clear_solid(rgba) != 0:
        return -1
    return virtio_gpu_present_frame()


def vk_gpu_present_image(src_base: uint64, w: uint32, h: uint32) -> int32:
    # Present an arbitrary vk RGBA color image through the GPU scanout
    # (convert RGBA→BGRA into the backing, then TRANSFER_TO_HOST + FLUSH).
    return virtio_gpu_present_rgba(src_base, w, h)

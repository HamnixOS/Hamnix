# lib/vk/vk_gpu.ad
#
# GPU (virtio-gpu) backend for the native vk graphics spine — GPU track
# Phase D. This is the hardware-accelerated sibling of the software
# rasterizer (lib/vk/vk_raster.ad + lib/vk/vk_2d.ad): it routes the
# vk spine's CLEAR and PRESENT onto QEMU's native virtio-gpu device
# (drivers/video/virtio_gpu.ad), so the now-unified DE + hamSDL
# rendering (Phases A–C) can offload the frame's scanout to the device
# instead of streaming every pixel through the GOP MMIO framebuffer.
#
# ARCHITECTURE
# ============
#   * NATIVE-first: virtio-gpu is a standardized virtio-1.0 device, so
#     it is driven by a NATIVE Adder driver (like AHCI/NVMe/xHCI), NOT a
#     Linux .ko shim. ZERO Linux / namespace dependency, NO sockets.
#   * This file is a thin, dependency-light seam: it wraps the driver's
#     public entry points so lib/vk/vk_core.ad can select the backend
#     WITHOUT importing the driver directly. vk_core → vk_gpu → driver;
#     no cycle (the driver never imports vk).
#
# WHAT PHASE D OFFLOADS (this round)
# ==================================
#   * vk_gpu_clear(rgba)          — solid-fill the device scanout backing
#                                   (the CLEAR op; the #1 CPU cost the
#                                   Phase-C compositor flagged).
#   * vk_gpu_fill_rect(...)       — solid rectangle into the backing.
#   * vk_gpu_present()            — TRANSFER_TO_HOST + FLUSH the backing
#                                   to the scanout (the present offload).
#   * vk_gpu_present_image(...)   — convert a vk RGBA color image into the
#                                   backing and scan it out, so ANY
#                                   rendered frame can present via the GPU.
#
# HONEST SCOPE: the software 2D/3D ops (blit / line / roundrect / draw)
# still render into the vk color image on the CPU this round; only the
# CLEAR has a pure-device path and the PRESENT/scanout is offloaded.
# Base virtio-gpu 2D is a SCANOUT device — it presents a host resource but
# does NOT rasterize into it, so fills stay CPU-bound; real fill/compute
# acceleration needs venus/virgl 3D (a separate track, #182 venus).
#
# MEASURED (on-device, 1280x800, docs/de_perf_baseline.md "Phase D"): the
# pure device present (TRANSFER_TO_HOST + FLUSH, backing already BGRA) is
# ~61x faster than the SW per-pixel GOP-MMIO present. vk_gpu_present_image
# below does a CPU RGBA->BGRA convert copy first, and that copy costs ~as
# much as the SW present it replaces (net ~4% win).
#
# Phase D.3 (this round) closes that gap with a BGRA-NATIVE path: vk2d can
# render straight into a VK_FORMAT_B8G8R8A8_UNORM color image (BGRA store
# order — see lib/vk/vk_2d.ad vk2d_set_bgra + lib/vk/vk_core.ad format
# routing). When that BGRA frame IS the device backing, present is the pure
# 61x device DMA (vk_gpu_present). When it is a separate image,
# vk_gpu_present_bgra deposits it with a bulk 1:1 word copy (no per-pixel
# convert) then flushes. Either way the RGBA->BGRA convert is gone, so the
# DE can flip to the GPU backend as its default present path.

from drivers.video.virtio_gpu import (
    virtio_gpu_available,
    virtio_gpu_scanout_width, virtio_gpu_scanout_height,
    virtio_gpu_backing_base,
    virtio_gpu_clear_solid, virtio_gpu_fill_rect_solid,
    virtio_gpu_present_frame, virtio_gpu_present_rgba,
)


def vk_gpu_backend_available() -> int32:
    # 1 if a virtio-gpu device probed + scanned out at boot, else 0.
    return virtio_gpu_available()


def vk_gpu_scanout_width() -> uint32:
    return virtio_gpu_scanout_width()


def vk_gpu_scanout_height() -> uint32:
    return virtio_gpu_scanout_height()


def vk_gpu_backing_base() -> uint64:
    # Direct-mapped VA of the BGRA scanout backing (for self-test readback).
    return virtio_gpu_backing_base()


def vk_gpu_clear(rgba: uint32) -> int32:
    # GPU CLEAR: solid-fill the whole scanout backing. rgba is 0xRRGGBBAA.
    return virtio_gpu_clear_solid(rgba)


def vk_gpu_fill_rect(x: int32, y: int32, w: int32, h: int32,
                     rgba: uint32) -> int32:
    # GPU solid rectangle fill into the scanout backing.
    return virtio_gpu_fill_rect_solid(x, y, w, h, rgba)


def vk_gpu_present() -> int32:
    # Scan out whatever is currently in the backing (clear / fills).
    return virtio_gpu_present_frame()


def vk_gpu_clear_present(rgba: uint32) -> int32:
    # Pure-device CLEAR + PRESENT fast path: solid-fill the backing and
    # flush it to the scanout, with NO vk color image / rasterizer
    # involved. This is the Phase-D proof-of-concept for the highest-value
    # op (clear) running entirely on the GPU device.
    if virtio_gpu_clear_solid(rgba) != 0:
        return -1
    return virtio_gpu_present_frame()


def vk_gpu_present_image(src_base: uint64, w: uint32, h: uint32) -> int32:
    # Present an arbitrary vk RGBA color image through the GPU scanout
    # (convert RGBA→BGRA into the backing, then TRANSFER_TO_HOST + FLUSH).
    return virtio_gpu_present_rgba(src_base, w, h)


# ===================================================================
# DE PRESENT POLICY (Phase D.4 — flip the DE compositor to GPU present)
# ===================================================================
#
# The DE compositor (sys/src/9/port/devwsys.ad) composites into an RGBA
# screen-sized shadow and pushes finished damage rects to the display. On
# a plain OVMF/GOP boot (no virtio-gpu device) that push is the per-pixel
# GOP-MMIO STORE (fb_present_flush) — the software path, unchanged.
#
# When a virtio-gpu device IS present, virtio_gpu_init() has already done
# SET_SCANOUT to the driver's own resource, so the OVMF GOP linear
# framebuffer is NO LONGER the scanned-out surface: after ExitBootServices
# nothing refreshes it, so the SW GOP push shows NOTHING. Under virtio-gpu
# the device present (TRANSFER_TO_HOST_2D + RESOURCE_FLUSH of the backing)
# is the ONLY live scanout path. So the DE's backend choice is naturally
# HARDWARE-EXCLUSIVE:
#   * virtio-gpu present  -> the DE composites/flushes through the device
#   * no virtio-gpu device -> the DE stays on the SW GOP path (unchanged)
# and "never go dark on fallback" holds because each hardware config uses
# its ONLY working path — there is no config where both are live and one
# silently fails to a blank screen.
#
# vk_de_gpu_present_active() is the single authority the DE consults per
# flush. It is 1 iff a virtio-gpu device is present AND the DE-GPU default
# is enabled. vk_gpu_set_de_default(0) forces the SW path back on (the
# reversible flag/env the task requires; a boot arg or ctl can clear it) —
# useful for A/B on GOP-capable configs. The verified latch records that
# the on-device pixel-identity self-test passed this boot (informational;
# activation keys on device presence so a production boot with no self-test
# still presents through the device it must use).
vk_gpu_de_default:        int32 = 1     # 1 = DE presents via GPU when a device is present
vk_gpu_present_verified:  int32 = 0     # 1 = pixel-identity self-test passed this boot


def vk_gpu_set_de_default(on: int32):
    # Reversible switch: 0 forces the DE back to the SW GOP present path,
    # 1 (default) uses the virtio-gpu device present when one is present.
    if on == 0:
        vk_gpu_de_default = 0
    else:
        vk_gpu_de_default = 1


def vk_gpu_get_de_default() -> int32:
    return vk_gpu_de_default


def vk_gpu_mark_present_verified(v: int32):
    # Latched by the on-device DE-present self-test after it proves the
    # GPU-presented frame is pixel-identical to the SW reference.
    vk_gpu_present_verified = v


def vk_gpu_is_present_verified() -> int32:
    return vk_gpu_present_verified


def vk_de_gpu_present_active() -> int32:
    # THE DE's per-flush decision: present through the virtio-gpu device?
    # 1 iff a device is present AND the DE-GPU default has not been forced
    # off. No device -> 0 -> the DE keeps the SW GOP path (default-safe).
    if vk_gpu_de_default == 0:
        return 0
    return virtio_gpu_available()


def vk_de_present_shadow_rect(shadow_base: uint64, shadow_pitch_px: uint64,
                              rx: int32, ry: int32,
                              rw: int32, rh: int32) -> int32:
    # DE PRESENT (Phase D.4): scan the DE compositor's finished frame out
    # through the virtio-gpu device. The DE's shadow is a screen-sized
    # row-major RGBA8888 buffer; (rx,ry,rw,rh) is the just-composited damage
    # rect. We deposit ONLY that rect into the device's BGRA scanout backing
    # (the CPU R/B reorder, on cacheable RAM — never uncached GOP MMIO) at
    # the same screen coords, then TRANSFER_TO_HOST_2D + RESOURCE_FLUSH so
    # the device composites the whole backing onto the scanout in one DMA.
    #
    # Pixel-identical to the SW path: it lays down exactly the bytes
    # fb_present_flush would write to a BGRA scanout, only into the device
    # backing instead of dead GOP MMIO. Returns 0 on success; -1 if there is
    # no device / bad args, so the caller falls back to the SW GOP flush and
    # the screen is never left dark.
    if virtio_gpu_available() == 0 or shadow_base == 0:
        return -1
    dst: uint64 = virtio_gpu_backing_base()
    if dst == 0:
        return -1
    dw: uint32 = virtio_gpu_scanout_width()
    dh: uint32 = virtio_gpu_scanout_height()
    if rw <= 0 or rh <= 0:
        return -1
    x0: int32 = rx
    y0: int32 = ry
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    x1: int32 = rx + rw
    y1: int32 = ry + rh
    if x1 > cast[int32](dw):
        x1 = cast[int32](dw)
    if y1 > cast[int32](dh):
        y1 = cast[int32](dh)
    if x0 >= x1 or y0 >= y1:
        # Nothing inside the scanout to deposit, but the frame is valid;
        # still flush so any earlier backing writes reach the display.
        return virtio_gpu_present_frame()
    yy: int32 = y0
    while yy < y1:
        sp: uint64 = shadow_base \
            + (cast[uint64](yy) * shadow_pitch_px + cast[uint64](x0)) * 4
        dp: uint64 = dst \
            + (cast[uint64](yy) * cast[uint64](dw) + cast[uint64](x0)) * 4
        xx: int32 = x0
        while xx < x1:
            rr: uint8 = cast[Ptr[uint8]](sp + 0)[0]
            gg: uint8 = cast[Ptr[uint8]](sp + 1)[0]
            bb: uint8 = cast[Ptr[uint8]](sp + 2)[0]
            cast[Ptr[uint8]](dp + 0)[0] = bb
            cast[Ptr[uint8]](dp + 1)[0] = gg
            cast[Ptr[uint8]](dp + 2)[0] = rr
            cast[Ptr[uint8]](dp + 3)[0] = 255
            sp = sp + 4
            dp = dp + 4
            xx = xx + 1
        yy = yy + 1
    return virtio_gpu_present_frame()


def vk_gpu_present_bgra(src_base: uint64, w: uint32, h: uint32) -> int32:
    # BGRA-NATIVE present (Phase D.3): the source is ALREADY in the device's
    # BGRA scanout byte order (rendered by vk2d into a VK_FORMAT_B8G8R8A8
    # color image), so the backing is filled with a straight 1:1 word copy —
    # NO per-pixel RGBA→BGRA channel convert (the copy Phase D.2 measured
    # eating the entire 61x win) — then TRANSFER_TO_HOST + FLUSH.
    #
    # The strongest form of this path skips even the copy: render the vk2d
    # BGRA frame DIRECTLY into vk_gpu_backing_base() and call vk_gpu_present()
    # (pure device DMA). This helper covers the case where the BGRA frame
    # lives in a separate image and must be deposited first; the deposit is a
    # bulk cacheable word copy, not the byte-reordering convert.
    if virtio_gpu_available() == 0 or src_base == 0:
        return -1
    dst: uint64 = virtio_gpu_backing_base()
    if dst == 0:
        return -1
    dw: uint32 = virtio_gpu_scanout_width()
    dh: uint32 = virtio_gpu_scanout_height()
    cw: uint32 = w
    if cw > dw:
        cw = dw
    ch: uint32 = h
    if ch > dh:
        ch = dh
    y: uint32 = 0
    while y < ch:
        sp: uint64 = src_base + cast[uint64](y) * cast[uint64](w) * 4
        dp: uint64 = dst + cast[uint64](y) * cast[uint64](dw) * 4
        x: uint32 = 0
        while x < cw:
            cast[Ptr[uint32]](dp)[0] = cast[Ptr[uint32]](sp)[0]
            sp = sp + 4
            dp = dp + 4
            x = x + 1
        y = y + 1
    return virtio_gpu_present_frame()

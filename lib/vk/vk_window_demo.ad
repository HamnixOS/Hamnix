# lib/vk/vk_window_demo.ad
#
# GPU track #183 — native Vulkan output INTO a real desktop window.
#
# ===================================================================
# WHAT THIS IS
# ===================================================================
# A native, kernel-side demo that drives the SAME lib/vk software
# rasterizer the Phase-0 self-test uses, but PRESENTS each rendered
# frame into a real hamUI WINDOW's draw FILE SURFACE
# (/dev/wsys/<wid>/draw/vk/fb) via vk_present_to_window — instead of
# taking over the whole physical framebuffer. The userland desktop
# compositor (hamUId) then composites that window at its on-screen
# position, in z-order, like any other window.
#
# WHY KERNEL-SIDE
#   lib/vk is a KERNEL library (kmalloc / printk / fb_text backed). It
#   is NOT reachable from a userland --target=x86_64-adder-user binary,
#   which can only issue syscalls. So the Vulkan RENDER must run in the
#   kernel. The desktop COMPOSITE runs in userland (hamUId). The two are
#   bridged by the per-window draw surface (kernel-owned wsys storage)
#   and a thin syscall (SYS_VK_WINDOW_FRAME) the daemon calls once per
#   frame to ask the kernel to render frame N into the window's draw
#   surface. That is the faithful split: native rasterizer -> real
#   per-window draw surface -> real desktop compositor -> /dev/fb at the
#   window's position, with the animation driven LIVE by the desktop's
#   own frame loop.
#
# THE SCENE
#   A solid, depth-cleared, recognisable ROTATING TRIANGLE. Three
#   per-vertex-coloured corners (red / green / blue) orbit the image
#   centre; `frame` selects the rotation angle from a fixed Q8.8 integer
#   sin/cos table (24 steps = 15 deg each), so every frame is a DISTINCT,
#   bit-deterministic image — proving live animation, not a static blit.
#   The barycentric RGBA interpolation across the triangle is the same
#   rasterizer path the Phase-0 self-test pins with a golden checksum.
#
# ADDER NOTES (feedback_compiler_quirks.md)
#   * All sizable storage (the device-stack handles, the vertex buffer)
#     is kmalloc-backed VkDeviceMemory; the sin/cos table is a flat
#     module-scope Array (NOT a nested frame-local Array).
#   * Q8.8 fixed-point trig keeps each frame bit-deterministic,
#     independent of any FPU state.
#   * Global initialisers are literal constants only.

from kernel.printk.printk import printk0, printk1, printk2

from lib.vk.vk_core import (
    VK_SUCCESS,
    VK_FORMAT_R8G8B8A8_UNORM, VK_FORMAT_D32_UINT,
    VK_BUFFER_USAGE_VERTEX,
    VK_IMAGE_USAGE_COLOR, VK_IMAGE_USAGE_DEPTH,
    vkCreateInstance, vkEnumeratePhysicalDevices, vkCreateDevice,
    vkGetDeviceQueue, vkAllocateMemory, vk_memory_map,
    vkCreateBuffer, vkBindBufferMemory,
    vkCreateImage, vk_image_memory_size, vkBindImageMemory,
    vkCreateCommandPool, vkAllocateCommandBuffers,
    vkBeginCommandBuffer, vkEndCommandBuffer,
    vkCmdBeginRenderPass, vkCmdBindVertexBuffer, vkCmdSetViewport,
    vkCmdDraw, vkCmdEndRenderPass,
    vkQueueSubmit,
    vk_present_to_window, vk_window_present_pixel_count,
)
from lib.vk.vk_raster import VK_VERTEX_STRIDE


# The demo image is 192x192 — comfortably under the 256x256 per-layer
# draw-surface fb cap and a clean fit inside a typical window body.
VK_WIN_W: uint64 = 192
VK_WIN_H: uint64 = 192

# Clear color (opaque dark slate) and clear depth (far).
VK_WIN_CLEAR_RGBA:  uint32 = 0x101828FF
VK_WIN_CLEAR_DEPTH: uint32 = 0xFFFF

# Fixed Q8.8 (x256) cosine table, 24 steps over a full turn (15 deg/step).
# sin(theta) = cos(theta - 6 steps) -> reuse this table with a +18 offset
# (mod 24). Computed once on the reference: round(256*cos(i*15deg)).
VK_TRIG_STEPS: uint64 = 24
vk_cos_q8: Array[24, int64]
vk_trig_ready: int32 = 0


def _vk_win_trig_init():
    if vk_trig_ready != 0:
        return
    # cos(i * 15 deg) * 256, i = 0..23.
    vk_cos_q8[0]  = 256       # cos 0
    vk_cos_q8[1]  = 247       # cos 15
    vk_cos_q8[2]  = 222       # cos 30
    vk_cos_q8[3]  = 181       # cos 45
    vk_cos_q8[4]  = 128       # cos 60
    vk_cos_q8[5]  = 66        # cos 75
    vk_cos_q8[6]  = 0         # cos 90
    vk_cos_q8[7]  = 0 - 66    # cos 105
    vk_cos_q8[8]  = 0 - 128   # cos 120
    vk_cos_q8[9]  = 0 - 181   # cos 135
    vk_cos_q8[10] = 0 - 222   # cos 150
    vk_cos_q8[11] = 0 - 247   # cos 165
    vk_cos_q8[12] = 0 - 256   # cos 180
    vk_cos_q8[13] = 0 - 247   # cos 195
    vk_cos_q8[14] = 0 - 222   # cos 210
    vk_cos_q8[15] = 0 - 181   # cos 225
    vk_cos_q8[16] = 0 - 128   # cos 240
    vk_cos_q8[17] = 0 - 66    # cos 255
    vk_cos_q8[18] = 0         # cos 270
    vk_cos_q8[19] = 66        # cos 285
    vk_cos_q8[20] = 128       # cos 300
    vk_cos_q8[21] = 181       # cos 315
    vk_cos_q8[22] = 222       # cos 330
    vk_cos_q8[23] = 247       # cos 345
    vk_trig_ready = 1


def _vk_win_cos(step: int64) -> int64:
    s: int64 = step % cast[int64](VK_TRIG_STEPS)
    if s < 0:
        s = s + cast[int64](VK_TRIG_STEPS)
    return vk_cos_q8[cast[uint64](s)]


def _vk_win_sin(step: int64) -> int64:
    # sin(t) = cos(t - 90deg) = cos(step - 6).
    return _vk_win_cos(step - 6)


# ---- cached device stack (built once, reused every frame) -----------
vk_win_inited: int32 = 0
vk_win_dev:   uint64 = 0
vk_win_queue: uint64 = 0
vk_win_cimg:  uint64 = 0       # color image handle
vk_win_dimg:  uint64 = 0       # depth image handle
vk_win_cmem:  uint64 = 0
vk_win_cbase: uint64 = 0       # mapped color image host pointer
vk_win_vbuf:  uint64 = 0
vk_win_vbase: uint64 = 0       # mapped vertex buffer host pointer
vk_win_pool:  uint64 = 0
vk_win_cb:    uint64 = 0


def _vk_put_vertex(vbase: uint64, idx: uint64,
                   x_px: int64, y_px: int64, z: uint32,
                   r: uint8, g: uint8, b: uint8, a: uint8):
    o: uint64 = vbase + idx * VK_VERTEX_STRIDE
    cast[Ptr[int32]](o + 0)[0] = cast[int32](x_px << 16)
    cast[Ptr[int32]](o + 4)[0] = cast[int32](y_px << 16)
    cast[Ptr[uint32]](o + 8)[0] = z
    cast[Ptr[uint8]](o + 12)[0] = r
    cast[Ptr[uint8]](o + 13)[0] = g
    cast[Ptr[uint8]](o + 14)[0] = b
    cast[Ptr[uint8]](o + 15)[0] = a


def _vk_win_setup() -> int32:
    # Build the device stack + the persistent color/depth/vertex/command
    # resources once. Returns 1 on success, 0 on any failure.
    if vk_win_inited != 0:
        return 1
    _vk_win_trig_init()

    inst: uint64 = 0
    if vkCreateInstance(&inst) != VK_SUCCESS:
        return 0
    phys: uint64 = 0
    if vkEnumeratePhysicalDevices(inst, &phys) != VK_SUCCESS:
        return 0
    dev: uint64 = 0
    if vkCreateDevice(phys, &dev) != VK_SUCCESS:
        return 0
    queue: uint64 = 0
    if vkGetDeviceQueue(dev, &queue) != VK_SUCCESS:
        return 0

    cimg: uint64 = 0
    if vkCreateImage(dev, VK_WIN_W, VK_WIN_H,
                     VK_FORMAT_R8G8B8A8_UNORM, VK_IMAGE_USAGE_COLOR,
                     &cimg) != VK_SUCCESS:
        return 0
    dimg: uint64 = 0
    if vkCreateImage(dev, VK_WIN_W, VK_WIN_H,
                     VK_FORMAT_D32_UINT, VK_IMAGE_USAGE_DEPTH,
                     &dimg) != VK_SUCCESS:
        return 0
    cmem: uint64 = 0
    if vkAllocateMemory(dev, vk_image_memory_size(cimg),
                        &cmem) != VK_SUCCESS:
        return 0
    dmem: uint64 = 0
    if vkAllocateMemory(dev, vk_image_memory_size(dimg),
                        &dmem) != VK_SUCCESS:
        return 0
    if vkBindImageMemory(cimg, cmem, 0) != VK_SUCCESS:
        return 0
    if vkBindImageMemory(dimg, dmem, 0) != VK_SUCCESS:
        return 0

    vcount: uint64 = 3
    vbuf: uint64 = 0
    if vkCreateBuffer(dev, vcount * VK_VERTEX_STRIDE,
                      VK_BUFFER_USAGE_VERTEX, &vbuf) != VK_SUCCESS:
        return 0
    vmem: uint64 = 0
    if vkAllocateMemory(dev, vcount * VK_VERTEX_STRIDE,
                        &vmem) != VK_SUCCESS:
        return 0
    if vkBindBufferMemory(vbuf, vmem, 0) != VK_SUCCESS:
        return 0
    vbase: uint64 = vk_memory_map(vmem)
    if vbase == 0:
        return 0

    pool: uint64 = 0
    if vkCreateCommandPool(dev, &pool) != VK_SUCCESS:
        return 0
    cb: uint64 = 0
    if vkAllocateCommandBuffers(pool, &cb) != VK_SUCCESS:
        return 0

    vk_win_dev = dev
    vk_win_queue = queue
    vk_win_cimg = cimg
    vk_win_dimg = dimg
    vk_win_cmem = cmem
    vk_win_cbase = vk_memory_map(cmem)
    vk_win_vbuf = vbuf
    vk_win_vbase = vbase
    vk_win_pool = pool
    vk_win_cb = cb
    vk_win_inited = 1
    return 1


def _vk_win_rotated(step: int64, radius: int64, base_step: int64,
                    cx: int64, cy: int64, out_x: Ptr[int64],
                    out_y: Ptr[int64]):
    # Place a triangle corner at angle (step + base_step) around (cx,cy)
    # at `radius` pixels. Q8.8 trig -> >>8 back to pixels.
    a: int64 = step + base_step
    out_x[0] = cx + (radius * _vk_win_cos(a)) / 256
    out_y[0] = cy + (radius * _vk_win_sin(a)) / 256


def vk_window_render_frame(wid: int32, frame: int64) -> int32:
    # Render rotating-triangle frame `frame` into the offscreen color
    # image and present it into window `wid`'s "vk" draw-surface fb
    # layer. Returns VK_SUCCESS / VK_ERROR_*.
    if _vk_win_setup() == 0:
        return -1
    cx: int64 = cast[int64](VK_WIN_W) / 2
    cy: int64 = cast[int64](VK_WIN_H) / 2
    radius: int64 = 78
    # Three corners 120 deg apart (8 steps of 15deg), rotating with frame.
    x0: Array[1, int64]
    y0: Array[1, int64]
    x1: Array[1, int64]
    y1: Array[1, int64]
    x2: Array[1, int64]
    y2: Array[1, int64]
    _vk_win_rotated(frame, radius, 0,  cx, cy, &x0[0], &y0[0])
    _vk_win_rotated(frame, radius, 8,  cx, cy, &x1[0], &y1[0])
    _vk_win_rotated(frame, radius, 16, cx, cy, &x2[0], &y2[0])
    # z constant (mid range, all visible above the cleared far depth).
    _vk_put_vertex(vk_win_vbase, 0, x0[0], y0[0], 0x4000, 255, 40, 40, 255)
    _vk_put_vertex(vk_win_vbase, 1, x1[0], y1[0], 0x4000, 40, 255, 40, 255)
    _vk_put_vertex(vk_win_vbase, 2, x2[0], y2[0], 0x4000, 40, 40, 255, 255)

    if vkBeginCommandBuffer(vk_win_cb) != VK_SUCCESS:
        return -1
    vkCmdBeginRenderPass(vk_win_cb, vk_win_cimg, vk_win_dimg, 1,
                         VK_WIN_CLEAR_RGBA, VK_WIN_CLEAR_DEPTH)
    vkCmdSetViewport(vk_win_cb, 0, 0, VK_WIN_W, VK_WIN_H)
    vkCmdBindVertexBuffer(vk_win_cb, vk_win_vbuf, VK_VERTEX_STRIDE)
    vkCmdDraw(vk_win_cb, 3, 0)
    vkCmdEndRenderPass(vk_win_cb)
    if vkEndCommandBuffer(vk_win_cb) != VK_SUCCESS:
        return -1
    if vkQueueSubmit(vk_win_queue, vk_win_cb) != VK_SUCCESS:
        return -1

    name: Ptr[uint8] = "vk"
    rc: int32 = vk_present_to_window(wid, name, 2, vk_win_cimg)
    return rc


def vk_window_demo_dims_w() -> uint64:
    return VK_WIN_W


def vk_window_demo_dims_h() -> uint64:
    return VK_WIN_H

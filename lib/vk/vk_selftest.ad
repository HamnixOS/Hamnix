# lib/vk/vk_selftest.ad
#
# Phase-0 GPU spine self-test (GPU track #181). Drives the native
# Vulkan-shaped API end to end through the software rasterizer and
# asserts UNFORGEABLE pixel values that can only be correct if triangle
# setup, barycentric interpolation, the depth test, and the present
# path all really ran. Gated at boot by init/main.ad on the /etc/vk-test
# marker (planted by scripts/test_vk_software_raster.sh).
#
# SCENE (rendered into a 64x64 R8G8B8A8 color image + D32 depth image):
#   * clear color  = 0x101828FF  (dark slate, opaque)
#   * clear depth  = 0x0000FFFF  (65535 == far)
#   * TRIANGLE 1 (FAR, z=0x8000=32768 at all 3 verts) is a wide wedge
#     pointing RIGHT, occupying most of the left/centre: verts
#     A=(2,2) red, B=(50,32) green, C=(2,62) blue. Its gradient
#     interpolates red→green→blue across the wedge.
#   * TRIANGLE 2 (NEAR, z=0x2000=8192 at all 3 verts) is a wide wedge
#     pointing LEFT, occupying most of the right/centre: verts
#     A=(62,2) white, B=(14,32) yellow, C=(62,62) cyan.
#   The two wedges genuinely OVERLAP across the central band (roughly
#   x in [14,50]) — both cover the centre pixel (32,32). Because
#   triangle 2 is nearer (smaller z), the depth test makes it win
#   every shared pixel, proving the depth buffer actually arbitrates
#   occlusion rather than last-draw-wins.
#
# ASSERTED SIGNALS (printed as [vk] lines; the test script greps them):
#   1. corner pixel (0,0)        == clear color           (clear ran)
#   2. tri-1-only interior pixel  has non-clear color and is dominated
#      by the FAR triangle's gradient (a green/blue-ish fragment)
#   3. an OVERLAP pixel shows triangle 2's (nearer) palette, NOT
#      triangle 1's — i.e. the depth test chose the nearer surface
#   4. present advanced devfb_present_count() by the expected pixel
#      count (when an fb is up) — covered by the test script's count
#      assertion
#   5. a deterministic FNV-1a checksum of the whole color image equals
#      a known-good constant computed on the reference implementation
#
# The checksum is the strongest signal: any change to coverage,
# interpolation, or depth arbitration perturbs at least one byte and
# the hash diverges, so a [vk] PASS line is hard to fake.

from kernel.printk.printk import printk0, printk1, printk2
from mm.slab import kmalloc, kfree, kzalloc

from lib.vk.vk_core import (
    VK_SUCCESS,
    VK_FORMAT_R8G8B8A8_UNORM, VK_FORMAT_D32_UINT,
    VK_BUFFER_USAGE_VERTEX,
    VK_IMAGE_USAGE_COLOR, VK_IMAGE_USAGE_DEPTH,
    vkCreateInstance, vkEnumeratePhysicalDevices, vkCreateDevice,
    vkGetDeviceQueue, vkAllocateMemory, vk_memory_map,
    vkCreateBuffer, vkBindBufferMemory,
    vkCreateImage, vk_image_memory_size, vkBindImageMemory,
    vkCreateCommandPool, vkAllocateCommandBuffers,
    vkBeginCommandBuffer, vkEndCommandBuffer,
    vkCmdBeginRenderPass, vkCmdBindVertexBuffer, vkCmdSetViewport,
    vkCmdDraw, vkCmdEndRenderPass,
    vkQueueSubmit, vkCreateSwapchain, vkQueuePresent,
    vk_present_pixel_count,
    vkDestroyInstance, vkDestroyDevice,
    VK_BACKEND_SW, VK_BACKEND_GPU, vk_set_backend, vk_get_backend,
)
from lib.vk.vk_raster import (
    VK_VERTEX_STRIDE,
    vk_raster_color_checksum, vk_raster_pixel_rgba,
)
from lib.vk.vk_gpu import (
    vk_gpu_backend_available, vk_gpu_clear, vk_gpu_present,
    vk_gpu_backing_base,
    vk_gpu_scanout_width, vk_gpu_scanout_height, vk_gpu_present_image,
    vk_gpu_present_bgra,
    vk_de_gpu_present_active, vk_de_present_shadow_rect,
    vk_gpu_mark_present_verified, vk_gpu_get_de_default,
    vk_gpu_set_de_default,
)
from lib.vk.vk_2d import (
    vk2d_set_bgra, vk2d_get_bgra, vk2d_raster_fill_rect,
)

# Phase-D present benchmark deps: the monotonic TSC clock and the software
# GOP present path (per-pixel framebuffer STORE) we measure the GPU
# TRANSFER+FLUSH present against.
from arch.x86.kernel.time import tsc_monotonic_ns
from drivers.video.console.fb_text import (
    fb_get_initialized, fb_get_width, fb_get_height, fb_present_rgba_row,
)


VK_TEST_W: uint64 = 64
VK_TEST_H: uint64 = 64

# Known-good color-image FNV-1a checksum for the scene above. Captured
# from the reference render: the deterministic integer/fixed-point
# rasterizer produces the identical color image on every boot, so this
# is a stable golden. Any change to coverage, interpolation, or depth
# arbitration perturbs at least one byte and the hash diverges — an
# unforgeable proof that the rasterizer ran and produced THIS image.
VK_GOLDEN_CHECKSUM: uint32 = 0xC37B428E


def _vk_put_vertex(vbase: uint64, idx: uint64,
                   x_px: int64, y_px: int64, z: uint32,
                   r: uint8, g: uint8, b: uint8, a: uint8):
    # Write one VkVertex at slot idx. Screen coords are given in whole
    # pixels and stored as Q16.16 (x<<16) so they land on pixel origins.
    o: uint64 = vbase + idx * VK_VERTEX_STRIDE
    cast[Ptr[int32]](o + 0)[0] = cast[int32](x_px << 16)
    cast[Ptr[int32]](o + 4)[0] = cast[int32](y_px << 16)
    cast[Ptr[uint32]](o + 8)[0] = z
    cast[Ptr[uint8]](o + 12)[0] = r
    cast[Ptr[uint8]](o + 13)[0] = g
    cast[Ptr[uint8]](o + 14)[0] = b
    cast[Ptr[uint8]](o + 15)[0] = a


def vk_software_raster_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL. Prints [vk] PASS / [vk] FAIL lines.
    printk0("[vk] Phase-0 software rasterizer self-test starting\n")
    fail: int32 = 0

    # --- create the device stack -----------------------------------
    # Out-params are taken as &scalar (the canonical Hamnix idiom, e.g.
    # fat_lookup(name, &cluster, &size)).
    inst: uint64 = 0
    if vkCreateInstance(&inst) != VK_SUCCESS:
        printk0("[vk] FAIL: vkCreateInstance\n")
        return 0

    phys: uint64 = 0
    if vkEnumeratePhysicalDevices(inst, &phys) != VK_SUCCESS:
        printk0("[vk] FAIL: vkEnumeratePhysicalDevices\n")
        return 0

    dev: uint64 = 0
    if vkCreateDevice(phys, &dev) != VK_SUCCESS:
        printk0("[vk] FAIL: vkCreateDevice\n")
        return 0

    queue: uint64 = 0
    if vkGetDeviceQueue(dev, &queue) != VK_SUCCESS:
        printk0("[vk] FAIL: vkGetDeviceQueue\n")
        return 0

    # --- color + depth images --------------------------------------
    cimg: uint64 = 0
    if vkCreateImage(dev, VK_TEST_W, VK_TEST_H,
                     VK_FORMAT_R8G8B8A8_UNORM, VK_IMAGE_USAGE_COLOR,
                     &cimg) != VK_SUCCESS:
        printk0("[vk] FAIL: vkCreateImage(color)\n")
        return 0

    dimg: uint64 = 0
    if vkCreateImage(dev, VK_TEST_W, VK_TEST_H,
                     VK_FORMAT_D32_UINT, VK_IMAGE_USAGE_DEPTH,
                     &dimg) != VK_SUCCESS:
        printk0("[vk] FAIL: vkCreateImage(depth)\n")
        return 0

    cmem: uint64 = 0
    if vkAllocateMemory(dev, vk_image_memory_size(cimg),
                        &cmem) != VK_SUCCESS:
        printk0("[vk] FAIL: vkAllocateMemory(color)\n")
        return 0

    dmem: uint64 = 0
    if vkAllocateMemory(dev, vk_image_memory_size(dimg),
                        &dmem) != VK_SUCCESS:
        printk0("[vk] FAIL: vkAllocateMemory(depth)\n")
        return 0

    if vkBindImageMemory(cimg, cmem, 0) != VK_SUCCESS:
        printk0("[vk] FAIL: vkBindImageMemory(color)\n")
        return 0
    if vkBindImageMemory(dimg, dmem, 0) != VK_SUCCESS:
        printk0("[vk] FAIL: vkBindImageMemory(depth)\n")
        return 0

    # --- vertex buffer (6 verts = 2 triangles) ---------------------
    vcount: uint64 = 6
    vbuf: uint64 = 0
    if vkCreateBuffer(dev, vcount * VK_VERTEX_STRIDE,
                      VK_BUFFER_USAGE_VERTEX,
                      &vbuf) != VK_SUCCESS:
        printk0("[vk] FAIL: vkCreateBuffer\n")
        return 0

    vmem: uint64 = 0
    if vkAllocateMemory(dev, vcount * VK_VERTEX_STRIDE,
                        &vmem) != VK_SUCCESS:
        printk0("[vk] FAIL: vkAllocateMemory(vbuf)\n")
        return 0
    if vkBindBufferMemory(vbuf, vmem, 0) != VK_SUCCESS:
        printk0("[vk] FAIL: vkBindBufferMemory\n")
        return 0

    vbase: uint64 = vk_memory_map(vmem)
    if vbase == 0:
        printk0("[vk] FAIL: vk_memory_map(vbuf)\n")
        return 0

    # TRIANGLE 1 — FAR (z=32768). Wide wedge pointing RIGHT.
    #   A=(2,2) red    B=(50,32) green    C=(2,62) blue
    _vk_put_vertex(vbase, 0, 2, 2, 32768, 255, 0, 0, 255)
    _vk_put_vertex(vbase, 1, 50, 32, 32768, 0, 255, 0, 255)
    _vk_put_vertex(vbase, 2, 2, 62, 32768, 0, 0, 255, 255)
    # TRIANGLE 2 — NEAR (z=8192). Wide wedge pointing LEFT; overlaps
    # triangle 1 across the central band.
    #   A=(62,2) white    B=(14,32) yellow    C=(62,62) cyan
    _vk_put_vertex(vbase, 3, 62, 2, 8192, 255, 255, 255, 255)
    _vk_put_vertex(vbase, 4, 14, 32, 8192, 255, 255, 0, 255)
    _vk_put_vertex(vbase, 5, 62, 62, 8192, 0, 255, 255, 255)

    # --- record the command buffer ---------------------------------
    pool: uint64 = 0
    if vkCreateCommandPool(dev, &pool) != VK_SUCCESS:
        printk0("[vk] FAIL: vkCreateCommandPool\n")
        return 0

    cb: uint64 = 0
    if vkAllocateCommandBuffers(pool, &cb) != VK_SUCCESS:
        printk0("[vk] FAIL: vkAllocateCommandBuffers\n")
        return 0

    if vkBeginCommandBuffer(cb) != VK_SUCCESS:
        printk0("[vk] FAIL: vkBeginCommandBuffer\n")
        return 0
    # clear color 0x101828FF, clear depth 0xFFFF (far)
    vkCmdBeginRenderPass(cb, cimg, dimg, 1, 0x101828FF, 0xFFFF)
    vkCmdSetViewport(cb, 0, 0, VK_TEST_W, VK_TEST_H)
    vkCmdBindVertexBuffer(cb, vbuf, VK_VERTEX_STRIDE)
    vkCmdDraw(cb, 6, 0)
    vkCmdEndRenderPass(cb)
    if vkEndCommandBuffer(cb) != VK_SUCCESS:
        printk0("[vk] FAIL: vkEndCommandBuffer\n")
        return 0

    # --- submit (drives the rasterizer) ----------------------------
    if vkQueueSubmit(queue, cb) != VK_SUCCESS:
        printk0("[vk] FAIL: vkQueueSubmit\n")
        return 0

    # --- assertions on the rendered image --------------------------
    cbase: uint64 = vk_memory_map(cmem)
    if cbase == 0:
        printk0("[vk] FAIL: vk_memory_map(color)\n")
        return 0

    # (1) corner (0,0) must still be the clear color 0x101828FF.
    corner: uint32 = vk_raster_pixel_rgba(cbase, VK_TEST_W, 0, 0)
    printk1("[vk] corner(0,0)     = 0x%x (expect 0x101828FF)\n",
            cast[uint64](corner))
    if corner != 0x101828FF:
        printk0("[vk] FAIL: corner pixel not clear color\n")
        fail = 1
    else:
        printk0("[vk] PASS: corner pixel is clear color\n")

    # (2) A pixel deep inside the FAR triangle ONLY. Point (6,32):
    # it is inside tri 1 (wedge from x=2 reaching x=50 at y=32) but to
    # the LEFT of tri 2's leftmost extent (vertex B at x=14, y=32), so
    # tri 2 does not cover it. Must be non-clear and carry the FAR
    # triangle's gradient, NOT a near-triangle color. The decisive
    # discriminator: every tri-2 vertex has green==255, so a tri-2
    # fragment always has a high green channel; a tri-1 fragment near
    # the red(A)/blue(C) edge has LOW green. We assert non-clear, green
    # clearly sub-saturated (interpolated, not a flat near color), and
    # a real red+blue blend present (proving per-vertex interpolation).
    far_px: uint32 = vk_raster_pixel_rgba(cbase, VK_TEST_W, 6, 32)
    fr: uint32 = (far_px >> 24) & 0xFF
    fg: uint32 = (far_px >> 16) & 0xFF
    fb: uint32 = (far_px >> 8) & 0xFF
    printk2("[vk] far(6,32)      = 0x%x  r=%d\n",
            cast[uint64](far_px), cast[uint64](fr))
    printk2("[vk]                  g=%d b=%d\n",
            cast[uint64](fg), cast[uint64](fb))
    if far_px == 0x101828FF:
        printk0("[vk] FAIL: far-only pixel was not painted (still clear)\n")
        fail = 1
    elif fg < 200 and fr > 0 and fb > 0:
        # FAR wedge near its A(red)/C(blue) edge: red & blue both
        # present, green sub-saturated. A bled-through NEAR fragment
        # (g==255 family) would not satisfy fg<200.
        printk0("[vk] PASS: far-only pixel carries far triangle gradient\n")
    else:
        printk0("[vk] FAIL: far-only pixel gradient unexpected\n")
        fail = 1

    # (3) OVERLAP pixel. Point (32,32) lies in BOTH wedges (tri 1
    # reaches x=50 at y=32; tri 2 reaches x=14 at y=32; 14<32<50). The
    # NEAR triangle (tri 2) must win the depth test, so the color must
    # come from tri 2's palette (white/yellow/cyan — every vertex has
    # green==255), NOT tri 1's (red/green/blue, where at (32,32) green
    # would be only partial). Decisive discriminator: a tri-2 fragment
    # always has green==255; a tri-1 fragment here has green well below
    # 255. We require green saturated AND the pixel non-clear.
    ov: uint32 = vk_raster_pixel_rgba(cbase, VK_TEST_W, 32, 32)
    or_: uint32 = (ov >> 24) & 0xFF
    og: uint32 = (ov >> 16) & 0xFF
    ob: uint32 = (ov >> 8) & 0xFF
    printk2("[vk] overlap(32,32) = 0x%x  r=%d\n",
            cast[uint64](ov), cast[uint64](or_))
    printk2("[vk]                  g=%d b=%d\n",
            cast[uint64](og), cast[uint64](ob))
    if ov == 0x101828FF:
        printk0("[vk] FAIL: overlap pixel unpainted (still clear)\n")
        fail = 1
    elif og >= 250:
        # tri-2 palette: green channel saturated at every vertex, so
        # any interpolated tri-2 fragment keeps green==255. The far
        # triangle could not produce g==255 here.
        printk0("[vk] PASS: overlap shows NEAR triangle (depth test won)\n")
    else:
        printk0("[vk] FAIL: overlap shows wrong surface (depth test broke)\n")
        fail = 1

    # (4) deterministic checksum of the whole color image.
    sum: uint32 = vk_raster_color_checksum(cbase, VK_TEST_W, VK_TEST_H)
    printk2("[vk] checksum       = 0x%x (golden 0x%x)\n",
            cast[uint64](sum), cast[uint64](VK_GOLDEN_CHECKSUM))
    if VK_GOLDEN_CHECKSUM == 0:
        printk0("[vk] NOTE: golden checksum unpinned; pin VK_GOLDEN_CHECKSUM\n")
    elif sum == VK_GOLDEN_CHECKSUM:
        printk0("[vk] PASS: color image checksum matches golden\n")
    else:
        printk0("[vk] FAIL: color image checksum mismatch\n")
        fail = 1

    # --- present to /dev/fb (swapchain equivalent) -----------------
    # Snapshot the present-pixel counter before/after so we can assert
    # the present actually streamed exactly W*H pixels to the screen —
    # an unforgeable proof the swapchain copy ran end to end.
    pre_pp: uint64 = vk_present_pixel_count()
    sw: uint64 = 0
    if vkCreateSwapchain(dev, VK_TEST_W, VK_TEST_H,
                         &sw) == VK_SUCCESS:
        pr: int32 = vkQueuePresent(queue, sw, cimg)
        if pr == VK_SUCCESS:
            post_pp: uint64 = vk_present_pixel_count()
            advanced: uint64 = post_pp - pre_pp
            printk2("[vk] present pixels  = %d (expect %d)\n",
                    advanced, VK_TEST_W * VK_TEST_H)
            if advanced == VK_TEST_W * VK_TEST_H:
                printk0("[vk] PASS: present advanced pixel count by W*H\n")
            else:
                printk0("[vk] FAIL: present pixel count wrong\n")
                fail = 1
            printk0("[vk] PASS: presented color image to /dev/fb\n")
        else:
            # Not a hard failure: a serial-only boot may have no fb up.
            printk1("[vk] NOTE: present skipped/failed rc=%d (no fb?)\n",
                    cast[uint64](pr))

    if fail == 0:
        printk0("[vk] PASS: software rasterizer spine OK\n")
        return 1
    printk0("[vk] FAIL: software rasterizer spine had failures\n")
    return 0


# ===================================================================
# PHASE D — virtio-gpu BACKEND self-test
# ===================================================================
#
# Proves the GPU backend's CLEAR matches the software rasterizer's clear
# byte-for-byte (as a color), and that the CLEAR + PRESENT (scanout)
# path runs on the native virtio-gpu device. The comparison is the
# unforgeable proof requested for Phase D: the same clear color is
# produced two independent ways —
#   * SW: cleared into a vk R8G8B8A8 color image through the recorded
#     command-buffer / vkQueueSubmit path (backend = SW), read back with
#     vk_raster_pixel_rgba (returns 0xRRGGBBAA).
#   * GPU: vk_gpu_clear() writes the device BGRA scanout backing; we read
#     the backing bytes back and reconstruct 0xRRGGBBAA.
# If the two reconstructed colors are equal (and equal the requested
# color), the device clear is bit-correct against the SW reference.
# Then vk_gpu_present() runs TRANSFER_TO_HOST + FLUSH so the device
# actually scans the frame out.
#
# Returns 1 PASS, 0 FAIL, -1 SKIP (no virtio-gpu device present).

VGPU_TESTCOL: uint32 = 0x104E64FF          # teal, opaque (0xRRGGBBAA)


def _vgpu_backing_px0() -> uint32:
    # Read pixel (0,0) of the BGRA scanout backing and return it packed
    # as 0xRRGGBBAA to compare against the SW reference.
    base: uint64 = vk_gpu_backing_base()
    if base == 0:
        return 0
    b: uint32 = cast[uint32](cast[Ptr[uint8]](base + 0)[0])
    g: uint32 = cast[uint32](cast[Ptr[uint8]](base + 1)[0])
    r: uint32 = cast[uint32](cast[Ptr[uint8]](base + 2)[0])
    a: uint32 = cast[uint32](cast[Ptr[uint8]](base + 3)[0])
    return (r << 24) | (g << 16) | (b << 8) | a


def vk_gpu_backend_selftest() -> int32:
    printk0("[vgpu-vk] Phase-D GPU backend self-test starting\n")
    if vk_gpu_backend_available() == 0:
        printk0("[vgpu-vk] SKIP: no virtio-gpu device\n")
        return -1

    # --- backend seam: opt into GPU, then back to SW for the reference.
    if vk_set_backend(VK_BACKEND_GPU) != VK_SUCCESS:
        printk0("[vgpu-vk] FAIL: vk_set_backend(GPU) refused\n")
        return 0
    if vk_get_backend() != VK_BACKEND_GPU:
        printk0("[vgpu-vk] FAIL: backend not GPU after set\n")
        vk_set_backend(VK_BACKEND_SW)
        return 0

    fail: int32 = 0

    # --- SW reference clear (backend = SW) -------------------------
    vk_set_backend(VK_BACKEND_SW)
    inst: uint64 = 0
    if vkCreateInstance(&inst) != VK_SUCCESS:
        printk0("[vgpu-vk] FAIL: vkCreateInstance\n")
        return 0
    phys: uint64 = 0
    if vkEnumeratePhysicalDevices(inst, &phys) != VK_SUCCESS:
        printk0("[vgpu-vk] FAIL: vkEnumeratePhysicalDevices\n")
        return 0
    dev: uint64 = 0
    if vkCreateDevice(phys, &dev) != VK_SUCCESS:
        printk0("[vgpu-vk] FAIL: vkCreateDevice\n")
        return 0
    queue: uint64 = 0
    if vkGetDeviceQueue(dev, &queue) != VK_SUCCESS:
        printk0("[vgpu-vk] FAIL: vkGetDeviceQueue\n")
        return 0
    cimg: uint64 = 0
    if vkCreateImage(dev, 32, 32, VK_FORMAT_R8G8B8A8_UNORM,
                     VK_IMAGE_USAGE_COLOR, &cimg) != VK_SUCCESS:
        printk0("[vgpu-vk] FAIL: vkCreateImage\n")
        return 0
    cmem: uint64 = 0
    if vkAllocateMemory(dev, vk_image_memory_size(cimg),
                        &cmem) != VK_SUCCESS:
        printk0("[vgpu-vk] FAIL: vkAllocateMemory\n")
        return 0
    if vkBindImageMemory(cimg, cmem, 0) != VK_SUCCESS:
        printk0("[vgpu-vk] FAIL: vkBindImageMemory\n")
        return 0
    pool: uint64 = 0
    if vkCreateCommandPool(dev, &pool) != VK_SUCCESS:
        printk0("[vgpu-vk] FAIL: vkCreateCommandPool\n")
        return 0
    cb: uint64 = 0
    if vkAllocateCommandBuffers(pool, &cb) != VK_SUCCESS:
        printk0("[vgpu-vk] FAIL: vkAllocateCommandBuffers\n")
        return 0
    vkBeginCommandBuffer(cb)
    vkCmdBeginRenderPass(cb, cimg, 0, 1, VGPU_TESTCOL, 0)
    vkCmdEndRenderPass(cb)
    vkEndCommandBuffer(cb)
    if vkQueueSubmit(queue, cb) != VK_SUCCESS:
        printk0("[vgpu-vk] FAIL: vkQueueSubmit\n")
        return 0
    cbase: uint64 = vk_memory_map(cmem)
    sw_px: uint32 = vk_raster_pixel_rgba(cbase, 32, 0, 0)
    printk1("[vgpu-vk] SW  clear pixel(0,0) = 0x%x\n", cast[uint64](sw_px))

    # --- GPU clear (backend = GPU) on the device scanout backing ---
    vk_set_backend(VK_BACKEND_GPU)
    if vk_gpu_clear(VGPU_TESTCOL) != 0:
        printk0("[vgpu-vk] FAIL: vk_gpu_clear\n")
        vk_set_backend(VK_BACKEND_SW)
        return 0
    gpu_px: uint32 = _vgpu_backing_px0()
    printk1("[vgpu-vk] GPU clear pixel(0,0) = 0x%x\n", cast[uint64](gpu_px))

    # --- compare: GPU device clear must match the SW reference -----
    if sw_px != VGPU_TESTCOL:
        printk0("[vgpu-vk] FAIL: SW reference clear wrong color\n")
        fail = 1
    if gpu_px != VGPU_TESTCOL:
        printk0("[vgpu-vk] FAIL: GPU clear wrong color\n")
        fail = 1
    if sw_px == gpu_px:
        printk0("[vgpu-vk] PASS: GPU clear matches SW reference byte-for-byte\n")
    else:
        printk0("[vgpu-vk] FAIL: GPU clear != SW reference\n")
        fail = 1

    # --- present: scan the cleared backing out to the display ------
    if vk_gpu_present() == 0:
        printk0("[vgpu-vk] PASS: GPU present (TRANSFER_TO_HOST + FLUSH) ran\n")
    else:
        printk0("[vgpu-vk] FAIL: GPU present failed\n")
        fail = 1

    # --- restore the default SW backend so nothing else regresses --
    vk_set_backend(VK_BACKEND_SW)

    if fail == 0:
        printk0("[vgpu-vk] PASS: Phase-D GPU backend clear+present OK\n")
        return 1
    printk0("[vgpu-vk] FAIL: Phase-D GPU backend self-test had failures\n")
    return 0


# ===================================================================
# PHASE D — PRESENT-PATH BENCHMARK (SW GOP present vs GPU scanout)
# ===================================================================
#
# The honest Phase-D win on BASE virtio-gpu-2d is the PRESENT/scanout
# path, NOT the fills. Base virtio-gpu 2D is a SCANOUT device: the pixels
# are still drawn by the CPU into the resource backing; the device only
# composites the backing onto the display. So the fills stay CPU-bound
# (real fill/compute acceleration needs venus/virgl 3D — a separate,
# larger GPU track, #182 venus). What the device DOES accelerate is the
# present: replacing the software present's per-pixel GOP-MMIO framebuffer
# STOREs (fb_present_rgba_row, ~W*H uncached device-memory writes) with a
# single bulk DMA (TRANSFER_TO_HOST_2D) + composite (RESOURCE_FLUSH).
#
# This benchmark measures a full-scanout frame presented BOTH ways,
# best-of-N, and prints the nanosecond numbers so the flip-to-GPU-present
# decision rests on real on-device data. It also proves correctness: the
# GPU-presented backing must equal the software source frame pixel for
# pixel (RGBA source → BGRA backing).
#
# Prints [vgpu-bench] lines. Returns 1 PASS, 0 FAIL, -1 SKIP.

VGPU_BENCH_REPS: uint64 = 5


def _vgpu_bench_fill_frame(base: uint64, w: uint64, h: uint64):
    # Deterministic RGBA gradient so the frame is representative content
    # (not a single solid color the compiler/device could special-case).
    y: uint64 = 0
    while y < h:
        row: uint64 = base + y * w * 4
        x: uint64 = 0
        while x < w:
            o: uint64 = row + x * 4
            cast[Ptr[uint8]](o + 0)[0] = cast[uint8](x & 0xFF)          # R
            cast[Ptr[uint8]](o + 1)[0] = cast[uint8](y & 0xFF)          # G
            cast[Ptr[uint8]](o + 2)[0] = cast[uint8]((x + y) & 0xFF)    # B
            cast[Ptr[uint8]](o + 3)[0] = 255                            # A
            x = x + 1
        y = y + 1


def _vgpu_bench_fill_frame_bgra(base: uint64, pitch: uint64,
                                w: uint64, h: uint64):
    # The SAME visible gradient as _vgpu_bench_fill_frame, but laid down in
    # BGRA byte order (byte0=B, byte1=G, byte2=R) — i.e. rendered DIRECTLY in
    # the device scanout's format. This is what a BGRA-native compositor
    # deposits in place; presenting it needs NO RGBA->BGRA convert. `pitch`
    # is the destination row stride in pixels (the scanout width when the
    # target is the backing itself).
    y: uint64 = 0
    while y < h:
        row: uint64 = base + y * pitch * 4
        x: uint64 = 0
        while x < w:
            o: uint64 = row + x * 4
            cast[Ptr[uint8]](o + 0)[0] = cast[uint8]((x + y) & 0xFF)    # B
            cast[Ptr[uint8]](o + 1)[0] = cast[uint8](y & 0xFF)          # G
            cast[Ptr[uint8]](o + 2)[0] = cast[uint8](x & 0xFF)          # R
            cast[Ptr[uint8]](o + 3)[0] = 255                            # A
            x = x + 1
        y = y + 1


def _vgpu_bench_verify(src: uint64, w: uint64, h: uint64) -> uint64:
    # After a GPU present, the BGRA scanout backing must equal the RGBA
    # source converted (R↔B swapped). Return the mismatch count (0 == OK).
    dst: uint64 = vk_gpu_backing_base()
    if dst == 0:
        return w * h
    dw: uint64 = cast[uint64](vk_gpu_scanout_width())
    dh: uint64 = cast[uint64](vk_gpu_scanout_height())
    cw: uint64 = w
    if cw > dw:
        cw = dw
    ch: uint64 = h
    if ch > dh:
        ch = dh
    bad: uint64 = 0
    y: uint64 = 0
    while y < ch:
        sp: uint64 = src + y * w * 4
        dp: uint64 = dst + y * dw * 4
        x: uint64 = 0
        while x < cw:
            sr: uint8 = cast[Ptr[uint8]](sp + 0)[0]
            sg: uint8 = cast[Ptr[uint8]](sp + 1)[0]
            sb: uint8 = cast[Ptr[uint8]](sp + 2)[0]
            db: uint8 = cast[Ptr[uint8]](dp + 0)[0]
            dg: uint8 = cast[Ptr[uint8]](dp + 1)[0]
            dr: uint8 = cast[Ptr[uint8]](dp + 2)[0]
            if sr != dr or sg != dg or sb != db:
                bad = bad + 1
            sp = sp + 4
            dp = dp + 4
            x = x + 1
        y = y + 1
    return bad


def vk_gpu_present_benchmark() -> int32:
    printk0("[vgpu-bench] Phase-D present-path benchmark starting\n")
    if vk_gpu_backend_available() == 0:
        printk0("[vgpu-bench] SKIP: no virtio-gpu device\n")
        return -1
    w: uint64 = cast[uint64](vk_gpu_scanout_width())
    h: uint64 = cast[uint64](vk_gpu_scanout_height())
    if w == 0 or h == 0:
        printk0("[vgpu-bench] SKIP: scanout size 0\n")
        return -1
    printk2("[vgpu-bench] frame %dx%d\n", w, h)
    printk1("[vgpu-bench] best-of-%d reps\n", VGPU_BENCH_REPS)

    nbytes: uint64 = w * h * 4
    src: uint64 = kmalloc(nbytes)
    if src == 0:
        printk0("[vgpu-bench] SKIP: frame alloc failed\n")
        return -1
    _vgpu_bench_fill_frame(src, w, h)
    srcp: Ptr[uint8] = cast[Ptr[uint8]](src)

    # --- (a) software GOP present: per-pixel framebuffer STOREs --------
    # This is the exact path vkQueuePresent's SW branch and the DE use
    # today: fb_present_rgba_row repacks + stores each pixel to the GOP
    # linear framebuffer (device MMIO). No shadow is installed this early
    # in boot, so these are real scanout writes — the honest SW cost.
    sw_best: uint64 = 0xFFFFFFFFFFFFFFFF
    fb_ok: int32 = fb_get_initialized()
    if fb_ok != 0:
        pw: uint64 = w
        if pw > fb_get_width():
            pw = fb_get_width()
        ph: uint64 = h
        if ph > fb_get_height():
            ph = fb_get_height()
        rep: uint64 = 0
        while rep < VGPU_BENCH_REPS:
            t0: uint64 = tsc_monotonic_ns()
            yy: uint64 = 0
            while yy < ph:
                fb_present_rgba_row(yy, 0, yy, pw, srcp, w)
                yy = yy + 1
            t1: uint64 = tsc_monotonic_ns()
            dt: uint64 = t1 - t0
            if dt < sw_best:
                sw_best = dt
            rep = rep + 1
        printk1("[vgpu-bench] SW  GOP present  = %d ns (best of N)\n",
                sw_best)
    else:
        printk0("[vgpu-bench] NOTE: no GOP fb up — SW present not measured\n")

    # --- (b) GPU present: RGBA→BGRA convert + TRANSFER_TO_HOST + FLUSH -
    gpu_best: uint64 = 0xFFFFFFFFFFFFFFFF
    gpu_fail: int32 = 0
    rep2: uint64 = 0
    while rep2 < VGPU_BENCH_REPS:
        t0b: uint64 = tsc_monotonic_ns()
        grc: int32 = vk_gpu_present_image(src, cast[uint32](w),
                                          cast[uint32](h))
        t1b: uint64 = tsc_monotonic_ns()
        if grc != 0:
            gpu_fail = 1
        dtb: uint64 = t1b - t0b
        if dtb < gpu_best:
            gpu_best = dtb
        rep2 = rep2 + 1
    if gpu_fail != 0:
        printk0("[vgpu-bench] FAIL: GPU present returned error\n")
        kfree(src)
        return 0
    printk1("[vgpu-bench] GPU present      = %d ns (best of N)\n", gpu_best)

    # --- (c) pure device present: TRANSFER_TO_HOST + FLUSH only -------
    # vk_gpu_present_image (b) includes a CPU-side RGBA→BGRA convert copy
    # into the backing. The backing now already holds that converted frame,
    # so vk_gpu_present() times the DEVICE scanout offload ALONE (no CPU
    # copy) — the true ceiling of the base virtio-gpu-2d present win, and
    # exactly the cost a BGRA-native compositor would pay (render straight
    # into the backing, present = pure DMA + composite).
    dev_best: uint64 = 0xFFFFFFFFFFFFFFFF
    rep3: uint64 = 0
    while rep3 < VGPU_BENCH_REPS:
        t0c: uint64 = tsc_monotonic_ns()
        vk_gpu_present()
        t1c: uint64 = tsc_monotonic_ns()
        dtc: uint64 = t1c - t0c
        if dtc < dev_best:
            dev_best = dtc
        rep3 = rep3 + 1
    printk1("[vgpu-bench] GPU present (no convert) = %d ns (best of N)\n",
            dev_best)
    if fb_ok != 0 and dev_best > 0:
        ratio2_x100: uint64 = (sw_best * 100) / dev_best
        printk1("[vgpu-bench] SW / device-only present speedup = %d (x100)\n",
                ratio2_x100)

    # --- ratio (integer x100) so no FPU is needed ---------------------
    if fb_ok != 0 and gpu_best > 0:
        ratio_x100: uint64 = (sw_best * 100) / gpu_best
        printk1("[vgpu-bench] SW/GPU present speedup = %d (x100)\n",
                ratio_x100)
        if sw_best > gpu_best:
            printk0("[vgpu-bench] RESULT: GPU present is FASTER than SW GOP present\n")
        else:
            printk0("[vgpu-bench] RESULT: GPU present is NOT faster than SW GOP present\n")

    # --- correctness: GPU-presented backing == SW source frame --------
    bad: uint64 = _vgpu_bench_verify(src, w, h)
    if bad != 0:
        printk1("[vgpu-bench] FAIL: GPU backing mismatch (%d px)\n", bad)
        kfree(src)
        return 0
    printk0("[vgpu-bench] PASS: GPU-presented backing matches SW frame pixel-for-pixel\n")

    # ================================================================
    # (d) PHASE D.3 — BGRA-NATIVE, ZERO-CONVERT PRESENT
    # ================================================================
    # The convert path (b) pays a per-pixel RGBA->BGRA reorder into the
    # backing before the DMA; that copy is ~the whole cost (Phase D.2: net
    # ~1.04x). Here the frame is laid down DIRECTLY in the device's BGRA
    # scanout order — exactly what a BGRA-native vk2d compositor renders in
    # place — so the present is the pure device DMA (TRANSFER_TO_HOST +
    # FLUSH) with NO convert: the true 61x device-only path.

    # First, prove the vk2d BGRA STORE path itself is correct on-device:
    # fill an 8x8 scratch the RGBA way and the BGRA way with the same color
    # and assert the BGRA bytes are the RGBA bytes with R/B swapped (i.e.
    # identical visible color, flipped memory order).
    bgra_store_ok: int32 = 1
    scr_r: uint64 = kmalloc(8 * 8 * 4)
    scr_b: uint64 = kmalloc(8 * 8 * 4)
    if scr_r != 0 and scr_b != 0:
        vk2d_set_bgra(0)
        vk2d_raster_fill_rect(scr_r, 8, 8, 0, 0, 8, 8, 0x123456FF)
        vk2d_set_bgra(1)
        vk2d_raster_fill_rect(scr_b, 8, 8, 0, 0, 8, 8, 0x123456FF)
        vk2d_set_bgra(0)
        # RGBA bytes: 0x12,0x34,0x56,0xFF ; BGRA bytes: 0x56,0x34,0x12,0xFF
        rb0: uint8 = cast[Ptr[uint8]](scr_r + 0)[0]
        rb2: uint8 = cast[Ptr[uint8]](scr_r + 2)[0]
        bb0: uint8 = cast[Ptr[uint8]](scr_b + 0)[0]
        bb1: uint8 = cast[Ptr[uint8]](scr_b + 1)[0]
        bb2: uint8 = cast[Ptr[uint8]](scr_b + 2)[0]
        if bb0 != rb2 or bb2 != rb0 or bb1 != 0x34:
            bgra_store_ok = 0
    if scr_r != 0:
        kfree(scr_r)
    if scr_b != 0:
        kfree(scr_b)
    if bgra_store_ok == 1:
        printk0("[vgpu-bench] PASS: vk2d BGRA store lays B,G,R,A (R/B swap of RGBA)\n")
    else:
        printk0("[vgpu-bench] FAIL: vk2d BGRA store order wrong\n")
        kfree(src)
        return 0

    # Lay the gradient down in the backing in BGRA (in place, no convert),
    # then time the pure device present (vk_gpu_present) best-of-N. `w` is
    # the scanout width here, so it is also the backing row pitch.
    _vgpu_bench_fill_frame_bgra(vk_gpu_backing_base(), w, w, h)
    bgra_best: uint64 = 0xFFFFFFFFFFFFFFFF
    rep4: uint64 = 0
    while rep4 < VGPU_BENCH_REPS:
        # Re-lay the frame each rep so a warm backing can't hide the work a
        # real per-frame compositor would redo; the timed region is the
        # present ALONE (the render is outside t0d..t1d).
        _vgpu_bench_fill_frame_bgra(vk_gpu_backing_base(), w, w, h)
        t0d: uint64 = tsc_monotonic_ns()
        vk_gpu_present()
        t1d: uint64 = tsc_monotonic_ns()
        dtd: uint64 = t1d - t0d
        if dtd < bgra_best:
            bgra_best = dtd
        rep4 = rep4 + 1
    printk1("[vgpu-bench] BGRA-native present (no convert) = %d ns (best of N)\n",
            bgra_best)
    if fb_ok != 0 and bgra_best > 0:
        rbn_x100: uint64 = (sw_best * 100) / bgra_best
        printk1("[vgpu-bench] SW / BGRA-native present speedup = %d (x100)\n",
                rbn_x100)
    if gpu_best > 0 and bgra_best > 0:
        cvt_x100: uint64 = (gpu_best * 100) / bgra_best
        printk1("[vgpu-bench] convert / BGRA-native present speedup = %d (x100)\n",
                cvt_x100)

    # Correctness: the BGRA backing must show the SAME visible colors as the
    # RGBA reference frame (verify reads the backing as B,G,R and compares to
    # the RGBA source's R,G,B).
    bad2: uint64 = _vgpu_bench_verify(src, w, h)

    # Also time the separate-image BGRA present helper (bulk 1:1 word copy +
    # DMA, no convert) so the two zero-convert deposits are both on record.
    bgra_src: uint64 = kmalloc(nbytes)
    bhelp_best: uint64 = 0xFFFFFFFFFFFFFFFF
    bhelp_fail: int32 = 0
    if bgra_src != 0:
        _vgpu_bench_fill_frame_bgra(bgra_src, w, w, h)
        rep5: uint64 = 0
        while rep5 < VGPU_BENCH_REPS:
            t0e: uint64 = tsc_monotonic_ns()
            hrc: int32 = vk_gpu_present_bgra(bgra_src, cast[uint32](w),
                                             cast[uint32](h))
            t1e: uint64 = tsc_monotonic_ns()
            if hrc != 0:
                bhelp_fail = 1
            dte: uint64 = t1e - t0e
            if dte < bhelp_best:
                bhelp_best = dte
            rep5 = rep5 + 1
        if bhelp_fail == 0:
            printk1("[vgpu-bench] BGRA present helper (copy+DMA) = %d ns (best of N)\n",
                    bhelp_best)
        kfree(bgra_src)

    kfree(src)
    if bad2 == 0:
        printk0("[vgpu-bench] PASS: BGRA-native present matches RGBA reference\n")
        return 1
    printk1("[vgpu-bench] FAIL: BGRA-native backing mismatch (%d px)\n", bad2)
    return 0


# ===================================================================
# PHASE D.4 — DE PRESENT PATH self-test (flip the compositor to GPU)
# ===================================================================
#
# Exercises the EXACT code path the DE compositor now uses to reach the
# screen when a virtio-gpu device owns the scanout: an RGBA screen-shadow
# (what devwsys composites into) is presented through
# vk_de_present_shadow_rect() — the same function _wsys_flush_rect() calls.
# This proves, on real firmware + a real virtio-gpu device, that:
#   (1) the DE-present policy activates GPU present when the device is
#       present (vk_de_gpu_present_active() == 1) and honours the reversible
#       force-SW flag (vk_gpu_set_de_default(0) turns it back off);
#   (2) the GPU-presented device backing is PIXEL-IDENTICAL to the SW
#       reference frame (same visible colors — R/B swap into BGRA), i.e.
#       flipping the DE to GPU present does not change a single pixel; and
#   (3) the DE present time vs the SW GOP present time, so the flip rests on
#       on-device numbers.
# On PASS it latches vk_gpu_mark_present_verified(1). Prints [vgpu-de]
# markers. Returns 1 PASS, 0 FAIL, -1 SKIP (no device).

DE_PRESENT_REPS: uint64 = 5


def _de_fill_shadow(base: uint64, pitch: uint64, w: uint64, h: uint64):
    # A representative composited DE frame in RGBA8888: a gradient wallpaper
    # with an opaque panel band across the top — content the device could not
    # special-case, so a matching backing proves the real deposit ran.
    y: uint64 = 0
    while y < h:
        row: uint64 = base + y * pitch * 4
        x: uint64 = 0
        while x < w:
            o: uint64 = row + x * 4
            if y < 32:
                # top panel: opaque slate
                cast[Ptr[uint8]](o + 0)[0] = 0x20            # R
                cast[Ptr[uint8]](o + 1)[0] = 0x28            # G
                cast[Ptr[uint8]](o + 2)[0] = 0x38            # B
            else:
                cast[Ptr[uint8]](o + 0)[0] = cast[uint8](x & 0xFF)          # R
                cast[Ptr[uint8]](o + 1)[0] = cast[uint8](y & 0xFF)          # G
                cast[Ptr[uint8]](o + 2)[0] = cast[uint8]((x + y) & 0xFF)    # B
            cast[Ptr[uint8]](o + 3)[0] = 255                                # A
            x = x + 1
        y = y + 1


def vk_de_present_selftest() -> int32:
    printk0("[vgpu-de] Phase-D.4 DE present-path self-test starting\n")
    if vk_gpu_backend_available() == 0:
        printk0("[vgpu-de] SKIP: no virtio-gpu device\n")
        return -1

    # (1) policy: a device is present, so the DE must choose GPU present by
    # default, and the reversible flag must flip it back to SW.
    fail: int32 = 0
    if vk_de_gpu_present_active() != 1:
        printk0("[vgpu-de] FAIL: GPU present not active with device present\n")
        fail = 1
    else:
        printk0("[vgpu-de] PASS: GPU present is the DE default (device present)\n")
    vk_gpu_set_de_default(0)
    if vk_de_gpu_present_active() != 0:
        printk0("[vgpu-de] FAIL: force-SW flag did not disable GPU present\n")
        fail = 1
    else:
        printk0("[vgpu-de] PASS: force-SW flag flips the DE back to SW present\n")
    vk_gpu_set_de_default(1)

    w: uint64 = cast[uint64](vk_gpu_scanout_width())
    h: uint64 = cast[uint64](vk_gpu_scanout_height())
    if w == 0 or h == 0:
        printk0("[vgpu-de] SKIP: scanout size 0\n")
        return -1
    printk2("[vgpu-de] shadow %dx%d\n", w, h)

    nbytes: uint64 = w * h * 4
    shadow: uint64 = kmalloc(nbytes)
    if shadow == 0:
        printk0("[vgpu-de] SKIP: shadow alloc failed\n")
        return -1
    _de_fill_shadow(shadow, w, w, h)

    # (2) present the whole shadow through the DE GPU path and prove the
    # device backing is pixel-identical to the RGBA shadow (R/B swap). This
    # is the same deposit+flush _wsys_flush_rect() performs.
    grc: int32 = vk_de_present_shadow_rect(shadow, w, 0, 0,
                                           cast[int32](w), cast[int32](h))
    if grc != 0:
        printk1("[vgpu-de] FAIL: vk_de_present_shadow_rect rc=%d\n",
                cast[uint64](grc))
        kfree(shadow)
        return 0
    bad: uint64 = _vgpu_bench_verify(shadow, w, h)
    if bad == 0:
        printk0("[vgpu-de] PASS: DE GPU present matches SW reference pixel-for-pixel\n")
    else:
        printk1("[vgpu-de] FAIL: DE GPU present backing mismatch (%d px)\n", bad)
        fail = 1

    # (3) time the DE GPU present (deposit + DMA scanout) vs the SW GOP
    # present of the same frame, best-of-N. Under virtio-gpu the SW GOP path
    # is dead scanout, but timing it still records the CPU cost the device
    # present replaces.
    gpu_best: uint64 = 0xFFFFFFFFFFFFFFFF
    rep: uint64 = 0
    while rep < DE_PRESENT_REPS:
        t0: uint64 = tsc_monotonic_ns()
        vk_de_present_shadow_rect(shadow, w, 0, 0,
                                  cast[int32](w), cast[int32](h))
        t1: uint64 = tsc_monotonic_ns()
        dt: uint64 = t1 - t0
        if dt < gpu_best:
            gpu_best = dt
        rep = rep + 1
    printk1("[vgpu-de] DE GPU present = %d ns (best of N)\n", gpu_best)

    sw_best: uint64 = 0xFFFFFFFFFFFFFFFF
    srcp: Ptr[uint8] = cast[Ptr[uint8]](shadow)
    if fb_get_initialized() != 0:
        pw: uint64 = w
        if pw > fb_get_width():
            pw = fb_get_width()
        ph: uint64 = h
        if ph > fb_get_height():
            ph = fb_get_height()
        rep2: uint64 = 0
        while rep2 < DE_PRESENT_REPS:
            t0b: uint64 = tsc_monotonic_ns()
            yy: uint64 = 0
            while yy < ph:
                fb_present_rgba_row(yy, 0, yy, pw, srcp, w)
                yy = yy + 1
            t1b: uint64 = tsc_monotonic_ns()
            dtb: uint64 = t1b - t0b
            if dtb < sw_best:
                sw_best = dtb
            rep2 = rep2 + 1
        printk1("[vgpu-de] SW  GOP present = %d ns (best of N)\n", sw_best)
        if gpu_best > 0:
            ratio_x100: uint64 = (sw_best * 100) / gpu_best
            printk1("[vgpu-de] SW/DE-GPU present speedup = %d (x100)\n",
                    ratio_x100)

    kfree(shadow)
    if fail == 0:
        vk_gpu_mark_present_verified(1)
        printk0("[vgpu-de] PASS: DE present path verified — GPU present is the default\n")
        return 1
    printk0("[vgpu-de] FAIL: DE present-path self-test had failures\n")
    return 0

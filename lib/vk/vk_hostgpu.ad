# lib/vk/vk_hostgpu.ad — HOST-GPU reference compositor for the vk spine.
#
# GPU track: "Vulkan back into work on Linux". This is the Adder side of the
# host-GPU bridge that lets hambrowse / the DE / games be verified against the
# dev host's REAL Vulkan (NVIDIA / Mesa / lavapipe), complementing the in-VM
# virtio-gpu path.
#
# WHAT THIS FILE IS
#   A HOST harness (built x86_64-linux, NO QEMU) that composites a deterministic
#   scene through the SAME native vk 2D primitive layer the kernel spine uses
#   (lib/vk/vk_2d.ad — imported read-only) into an RGBA8888 vk-style color image
#   — the exact backing a vk render pass / present path use — and dumps it as a
#   binary PPM. That PPM is BOTH:
#     (a) the software REFERENCE framebuffer (what our rasterizer produces), and
#     (b) the INPUT handed across the file seam to scripts/vk_hostgpu_bridge.c,
#         which uploads it to a real VkDevice, round-trips it through a real GPU
#         transfer op, and reads it back. scripts/test_vk_hostgpu.sh asserts the
#         GPU readback is byte-identical to this reference — proving our
#         composited framebuffer marshals losslessly through real Linux Vulkan.
#
# WHY THE SEAM IS A FILE / C BRIDGE (not a direct extern call from here)
#   The Adder `x86_64-linux` host target links a STATIC, no-libc, no-PIE ELF
#   with raw `syscall` wrappers (compiler/adder.py). It has no dynamic loader
#   and no libc, so it CANNOT dlopen/link libvulkan.so.1. Real Vulkan therefore
#   lives behind the tiny C-ABI bridge; this harness composites and hands the
#   buffer over. The intended future C-ABI present seam the bridge exposes is:
#
#       // implemented in scripts/vk_hostgpu_bridge.c
#       int  vk_hostgpu_init(void);
#       int  vk_hostgpu_present_rgba(const uint8_t *rgba, uint32_t w, uint32_t h);
#       void vk_hostgpu_shutdown(void);
#
#   When a dynamic (libc-linked) host target lands, vk2d_present() can call that
#   seam directly instead of going through a PPM file. Until then the file seam
#   is the working, verified path. See docs/vk_hostgpu_bridge.md.
#
# USAGE (build/host/vk_hostgpu_ref):  vk_hostgpu_ref OUT.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.vk.vk_2d import (
    vk2d_raster_fill_rect, vk2d_raster_fill_rect_alpha,
    vk2d_raster_blit, vk2d_raster_draw_line,
    vk2d_raster_fill_roundrect,
)


IMG_W: uint64 = 96
IMG_H: uint64 = 64

# vk color image backing (row-major RGBA8888) — module-level BSS.
color_img: Array[24576, uint8]        # 96*64*4
# A 4x4 RGBA source sprite to blit (glyph/icon stand-in).
src_img: Array[64, uint8]             # 4*4*4


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_hexcol(v: uint32):
    _o_ch(35)                          # '#'
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- image helpers -------------------------------------------------------
def _cbase() -> uint64:
    return cast[uint64](&color_img[0])


def _sbase() -> uint64:
    return cast[uint64](&src_img[0])


def _pix(x: uint64, y: uint64) -> uint32:
    o: uint64 = _cbase() + (y * IMG_W + x) * 4
    r: uint32 = cast[uint32](cast[Ptr[uint8]](o)[0])
    g: uint32 = cast[uint32](cast[Ptr[uint8]](o + 1)[0])
    b: uint32 = cast[uint32](cast[Ptr[uint8]](o + 2)[0])
    return (r << 16) | (g << 8) | b


def _report_pix(label: Ptr[uint8], x: uint64, y: uint64):
    _o_str(label)
    _o_ch(32)
    _o_hexcol(_pix(x, y))
    _o_ch(10)


def _src_put(x: uint64, y: uint64, r: uint8, g: uint8, b: uint8, a: uint8):
    o: uint64 = _sbase() + (y * 4 + x) * 4
    cast[Ptr[uint8]](o)[0] = r
    cast[Ptr[uint8]](o + 1)[0] = g
    cast[Ptr[uint8]](o + 2)[0] = b
    cast[Ptr[uint8]](o + 3)[0] = a


# ---- PPM writer (P6, RGB) ------------------------------------------------
ppm_hdr: Array[32, uint8]


def _ppm_dec(hn: Ptr[uint64], v: uint64):
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    if x == 0:
        ppm_hdr[hn[0]] = 48
        hn[0] = hn[0] + 1
        return
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        ppm_hdr[hn[0]] = digs[n]
        hn[0] = hn[0] + 1


def _write_ppm(path: Ptr[char]):
    fd: int32 = sys_open(path, 577, 420)     # O_WRONLY|O_CREAT|O_TRUNC, 0644
    if fd < 0:
        return
    hn: uint64 = 0
    ppm_hdr[hn] = 80                          # 'P'
    hn = hn + 1
    ppm_hdr[hn] = 54                          # '6'
    hn = hn + 1
    ppm_hdr[hn] = 10
    hn = hn + 1
    _ppm_dec(&hn, IMG_W)
    ppm_hdr[hn] = 32
    hn = hn + 1
    _ppm_dec(&hn, IMG_H)
    ppm_hdr[hn] = 10
    hn = hn + 1
    ppm_hdr[hn] = 50                          # '2'
    ppm_hdr[hn + 1] = 53                      # '5'
    ppm_hdr[hn + 2] = 53                      # '5'
    ppm_hdr[hn + 3] = 10
    hn = hn + 4
    sys_write(fd, &ppm_hdr[0], hn)
    # body: RGB (drop alpha), row buffer wide enough for IMG_W px.
    row: Array[288, uint8]                    # 96 px * 3
    y: uint64 = 0
    while y < IMG_H:
        x: uint64 = 0
        while x < IMG_W:
            o: uint64 = _cbase() + (y * IMG_W + x) * 4
            row[x * 3] = cast[Ptr[uint8]](o)[0]
            row[x * 3 + 1] = cast[Ptr[uint8]](o + 1)[0]
            row[x * 3 + 2] = cast[Ptr[uint8]](o + 2)[0]
            x = x + 1
        sys_write(fd, &row[0], IMG_W * 3)
        y = y + 1
    sys_close(fd)


# ---- the scene -----------------------------------------------------------
# A deterministic "browser-ish" composite so the reference exercises the full
# vk2d op set the real page render leans on: opaque + alpha rects (chrome +
# translucent panel), a scaled blit (icon), a line (separator), a rounded rect
# (button). Every op writes into the vk color image that gets handed to the GPU.
def vk_hostgpu_compose(cb: uint64, w: uint64, h: uint64):
    # (0) page background — opaque slate #0d1220FF.
    vk2d_raster_fill_rect(cb, w, h, 0, 0, cast[int64](w), cast[int64](h), 0x0D1220FF)
    # (1) top chrome bar — opaque #2b3350FF, 96x10.
    vk2d_raster_fill_rect(cb, w, h, 0, 0, cast[int64](w), 10, 0x2B3350FF)
    # (2) content card — solid white #FFFFFFFF at (8,16,60,40).
    vk2d_raster_fill_rect(cb, w, h, 8, 16, 60, 40, 0xFFFFFFFF)
    # (3) translucent overlay panel — 50% cyan (#00CCFF80) over the card.
    vk2d_raster_fill_rect_alpha(cb, w, h, 20, 24, 24, 16, 0x00CCFF80)
    # (4) 4x4 icon sprite: green body, one blue corner pixel; 2x-scaled blit.
    sy: uint64 = 0
    while sy < 4:
        sx: uint64 = 0
        while sx < 4:
            _src_put(sx, sy, 0, 255, 0, 255)
            sx = sx + 1
        sy = sy + 1
    _src_put(3, 3, 0, 0, 255, 255)
    vk2d_raster_blit(cb, w, h, _sbase(), 4, 4, 74, 20, 8, 8, 0, 0, 0, 0)
    # (5) separator line — yellow #FFFF00, thickness 2 at y=58.
    vk2d_raster_draw_line(cb, w, h, 8, 58, 88, 58, 2, 0xFFFF00FF)
    # (6) rounded button — magenta #FF33CC, 20x12, radius 4 at (68,44).
    vk2d_raster_fill_roundrect(cb, w, h, 68, 44, 20, 12, 4, 15, 0xFF33CCFF)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        _o_str(cast[Ptr[uint8]]("usage: vk_hostgpu_ref OUT.ppm\n"))
        _o_flush()
        return 2

    cb: uint64 = _cbase()
    vk_hostgpu_compose(cb, IMG_W, IMG_H)
    _write_ppm(cast[Ptr[char]](argv[1]))

    # Sampled pixels for the gate to assert on BOTH the SW reference and the
    # real-GPU readback (they must match exactly).
    _report_pix(cast[Ptr[uint8]]("PIX_BG 2 2"), 2, 2)               # chrome bar
    _report_pix(cast[Ptr[uint8]]("PIX_PAGE 2 60"), 2, 60)          # page bg
    _report_pix(cast[Ptr[uint8]]("PIX_CARD 12 50"), 12, 50)        # white card
    _report_pix(cast[Ptr[uint8]]("PIX_PANEL 30 30"), 30, 30)       # alpha blend
    _report_pix(cast[Ptr[uint8]]("PIX_ICON 74 20"), 74, 20)        # blit green
    _report_pix(cast[Ptr[uint8]]("PIX_LINE 40 58"), 40, 58)        # separator
    _report_pix(cast[Ptr[uint8]]("PIX_BTN 78 50"), 78, 50)         # button
    _o_flush()
    return 0

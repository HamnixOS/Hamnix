# lib/zlib/deflate.ad
#
# Native DEFLATE (RFC 1951) *encoder* + gzip (RFC 1952) wrapper — the
# WRITE companion to lib/zlib/inflate.ad. It performs NO I/O of its own:
# a caller stack/module-allocates a `Deflater`, points it at an output
# byte buffer, then pushes input a block at a time; every helper packs
# DEFLATE bits into the caller buffer and the caller does the file
# writes. That keeps this module extern-free and import-clean for BOTH
# the x86_64-adder-user target (user/gzip.ad, user/tar.ad, Plan 9 I/O)
# and the x86_64-linux host target (a round-trip host harness) — neither
# of which can resolve the other's externs.
#
# COMPRESSION: real fixed-Huffman blocks (BTYPE=01, RFC 1951 §3.2.6)
# with LZ77 back-references. A greedy longest-match search over a 15-bit
# hash table + per-block chain (up to GZ_MAX_CHAIN probes) emits
# length/distance pairs (min match 3, max 258, distance up to the block
# size); everything else is a literal. This is genuine compression, not
# a stored wrapper — and every conformant inflater (GNU gunzip/zcat,
# zlib, python, our own lib/zlib/inflate.ad) reads it back byte-exact.
#
# STREAMING: the caller feeds the input one block of <= GZ_BLOCK_MAX
# (32 KiB) bytes at a time. LZ77 matches resolve only WITHIN the current
# block (a fresh hash table per block), so distances never exceed the
# 32 KiB window and arbitrarily large files stream through fixed
# buffers. Concatenated fixed-Huffman blocks are legal DEFLATE (RFC 1951
# §3.2.3); the last block carries BFINAL=1.
#
# USAGE:
#   d: Deflater
#   deflate_init(&d, out_buf, out_cap)
#   deflate_gzip_header(&d)                 # 10-byte gzip header
#   loop: deflate_block(&d, chunk, chunk_len, is_final)  # <=32768 bytes
#         # drain d.pos bytes to the fd, then deflate_reset_out(&d)
#   deflate_finish(&d)                      # flush bits + CRC32/ISIZE
#   # drain the final d.pos bytes
#
# ADDER QUIRKS HONOURED: no heap, fixed module-scope scratch (one
# compression in flight at a time), while-loops, byte-code emits only.

# ---- tunables --------------------------------------------------------
GZ_BLOCK_MAX: uint64 = 32768     # max input bytes per deflate_block call
GZ_MIN_MATCH: uint64 = 3
GZ_MAX_MATCH: uint64 = 258
GZ_MAX_CHAIN: int32  = 128       # longest-match search effort per position
GZ_HASH_SIZE: uint64 = 32768     # 2^15 hash buckets


# ---- Deflater state --------------------------------------------------
class Deflater:
    out:       Ptr[uint8]        # caller output buffer
    cap:       uint64            # its capacity
    pos:       uint64            # next write offset (drain + reset_out)
    overflow:  int32             # set if a write would exceed cap
    bitbuf:    uint32            # LSB-first bit accumulator
    bitcnt:    int32             # valid bits in bitbuf (< 8 between calls)
    crc:       uint32            # running CRC32 (pre-final-xor)
    isize:     uint64            # total uncompressed bytes fed


# ---- CRC32 (IEEE 0xEDB88320, gzip/PNG reflected) ---------------------
_dfl_crc_tbl:     Array[256, uint32]
_dfl_crc_ready:   int32 = 0


def _dfl_crc_init():
    if _dfl_crc_ready != 0:
        return
    i: uint32 = 0
    while i < 256:
        c: uint32 = i
        j: int32 = 0
        while j < 8:
            if (c & 1) != 0:
                c = (c >> 1) ^ cast[uint32](0xEDB88320)
            else:
                c = c >> 1
            j = j + 1
        _dfl_crc_tbl[cast[uint64](i)] = c
        i = i + 1
    _dfl_crc_ready = 1


def _dfl_crc_update(crc: uint32, buf: Ptr[uint8], length: uint64) -> uint32:
    c: uint32 = crc
    i: uint64 = 0
    while i < length:
        idx: uint32 = (c ^ cast[uint32](buf[i])) & cast[uint32](0xFF)
        c = (c >> 8) ^ _dfl_crc_tbl[cast[uint64](idx)]
        i = i + 1
    return c


# ---- length/distance code tables (RFC 1951 §3.2.5) -------------------
_dfl_len_base:   Array[29, uint32]
_dfl_len_extra:  Array[29, uint32]
_dfl_dist_base:  Array[30, uint32]
_dfl_dist_extra: Array[30, uint32]
_dfl_tbl_ready:  int32 = 0


def _dfl_tables_init():
    if _dfl_tbl_ready != 0:
        return
    # length symbols 257..285 (indices 0..28)
    _dfl_len_base[0] = 3
    _dfl_len_base[1] = 4
    _dfl_len_base[2] = 5
    _dfl_len_base[3] = 6
    _dfl_len_base[4] = 7
    _dfl_len_base[5] = 8
    _dfl_len_base[6] = 9
    _dfl_len_base[7] = 10
    _dfl_len_base[8] = 11
    _dfl_len_base[9] = 13
    _dfl_len_base[10] = 15
    _dfl_len_base[11] = 17
    _dfl_len_base[12] = 19
    _dfl_len_base[13] = 23
    _dfl_len_base[14] = 27
    _dfl_len_base[15] = 31
    _dfl_len_base[16] = 35
    _dfl_len_base[17] = 43
    _dfl_len_base[18] = 51
    _dfl_len_base[19] = 59
    _dfl_len_base[20] = 67
    _dfl_len_base[21] = 83
    _dfl_len_base[22] = 99
    _dfl_len_base[23] = 115
    _dfl_len_base[24] = 131
    _dfl_len_base[25] = 163
    _dfl_len_base[26] = 195
    _dfl_len_base[27] = 227
    _dfl_len_base[28] = 258
    k: uint64 = 0
    while k < 29:
        _dfl_len_extra[k] = 0
        k = k + 1
    _dfl_len_extra[8] = 1
    _dfl_len_extra[9] = 1
    _dfl_len_extra[10] = 1
    _dfl_len_extra[11] = 1
    _dfl_len_extra[12] = 2
    _dfl_len_extra[13] = 2
    _dfl_len_extra[14] = 2
    _dfl_len_extra[15] = 2
    _dfl_len_extra[16] = 3
    _dfl_len_extra[17] = 3
    _dfl_len_extra[18] = 3
    _dfl_len_extra[19] = 3
    _dfl_len_extra[20] = 4
    _dfl_len_extra[21] = 4
    _dfl_len_extra[22] = 4
    _dfl_len_extra[23] = 4
    _dfl_len_extra[24] = 5
    _dfl_len_extra[25] = 5
    _dfl_len_extra[26] = 5
    _dfl_len_extra[27] = 5
    _dfl_len_extra[28] = 0
    # distance symbols 0..29
    _dfl_dist_base[0] = 1
    _dfl_dist_base[1] = 2
    _dfl_dist_base[2] = 3
    _dfl_dist_base[3] = 4
    _dfl_dist_base[4] = 5
    _dfl_dist_base[5] = 7
    _dfl_dist_base[6] = 9
    _dfl_dist_base[7] = 13
    _dfl_dist_base[8] = 17
    _dfl_dist_base[9] = 25
    _dfl_dist_base[10] = 33
    _dfl_dist_base[11] = 49
    _dfl_dist_base[12] = 65
    _dfl_dist_base[13] = 97
    _dfl_dist_base[14] = 129
    _dfl_dist_base[15] = 193
    _dfl_dist_base[16] = 257
    _dfl_dist_base[17] = 385
    _dfl_dist_base[18] = 513
    _dfl_dist_base[19] = 769
    _dfl_dist_base[20] = 1025
    _dfl_dist_base[21] = 1537
    _dfl_dist_base[22] = 2049
    _dfl_dist_base[23] = 3073
    _dfl_dist_base[24] = 4097
    _dfl_dist_base[25] = 6145
    _dfl_dist_base[26] = 8193
    _dfl_dist_base[27] = 12289
    _dfl_dist_base[28] = 16385
    _dfl_dist_base[29] = 24577
    m: uint64 = 0
    while m < 30:
        _dfl_dist_extra[m] = 0
        m = m + 1
    _dfl_dist_extra[4] = 1
    _dfl_dist_extra[5] = 1
    _dfl_dist_extra[6] = 2
    _dfl_dist_extra[7] = 2
    _dfl_dist_extra[8] = 3
    _dfl_dist_extra[9] = 3
    _dfl_dist_extra[10] = 4
    _dfl_dist_extra[11] = 4
    _dfl_dist_extra[12] = 5
    _dfl_dist_extra[13] = 5
    _dfl_dist_extra[14] = 6
    _dfl_dist_extra[15] = 6
    _dfl_dist_extra[16] = 7
    _dfl_dist_extra[17] = 7
    _dfl_dist_extra[18] = 8
    _dfl_dist_extra[19] = 8
    _dfl_dist_extra[20] = 9
    _dfl_dist_extra[21] = 9
    _dfl_dist_extra[22] = 10
    _dfl_dist_extra[23] = 10
    _dfl_dist_extra[24] = 11
    _dfl_dist_extra[25] = 11
    _dfl_dist_extra[26] = 12
    _dfl_dist_extra[27] = 12
    _dfl_dist_extra[28] = 13
    _dfl_dist_extra[29] = 13
    _dfl_tbl_ready = 1


# ---- LZ77 match scratch (single compression in flight) ---------------
_dfl_head: Array[32768, int32]   # bucket -> last position + 1 (0 = empty)
_dfl_prev: Array[32768, int32]   # position -> earlier same-hash pos + 1


# ---- bit writer ------------------------------------------------------
def _put_byte(d: Ptr[Deflater], b: uint8):
    if d[0].pos < d[0].cap:
        d[0].out[d[0].pos] = b
        d[0].pos = d[0].pos + 1
    else:
        d[0].overflow = 1


# Pack the low `n` bits of `val` LSB-first (RFC 1951 §3.1.1). Used for
# extra bits and (via _send_code) for reversed Huffman codes. n may be 0.
def _send_bits(d: Ptr[Deflater], val: uint32, n: int32):
    if n <= 0:
        return
    mask: uint32 = (cast[uint32](1) << cast[uint32](n)) - cast[uint32](1)
    d[0].bitbuf = d[0].bitbuf | ((val & mask) << cast[uint32](d[0].bitcnt))
    d[0].bitcnt = d[0].bitcnt + n
    while d[0].bitcnt >= 8:
        _put_byte(d, cast[uint8](d[0].bitbuf & cast[uint32](0xFF)))
        d[0].bitbuf = d[0].bitbuf >> 8
        d[0].bitcnt = d[0].bitcnt - 8


# A Huffman code is transmitted with its MOST-significant bit first, but
# the stream packs LSB-first — so bit-reverse the `len`-bit code, then
# emit it LSB-first.
def _send_code(d: Ptr[Deflater], code: uint32, len: int32):
    r: uint32 = 0
    c: uint32 = code
    i: int32 = 0
    while i < len:
        r = (r << 1) | (c & cast[uint32](1))
        c = c >> 1
        i = i + 1
    _send_bits(d, r, len)


# Emit one literal/length Huffman symbol using the FIXED tree
# (RFC 1951 §3.2.6). sym is a literal (0..255), end-of-block (256) or a
# length symbol (257..285).
def _ll_send(d: Ptr[Deflater], sym: uint32):
    code: uint32 = 0
    ln: int32 = 0
    if sym < 144:
        code = cast[uint32](0x30) + sym         # 8-bit 0x30..0xBF
        ln = 8
    elif sym < 256:
        code = cast[uint32](0x190) + (sym - 144) # 9-bit 0x190..0x1FF
        ln = 9
    elif sym < 280:
        code = sym - 256                         # 7-bit 0x00..0x17
        ln = 7
    else:
        code = cast[uint32](0xC0) + (sym - 280)  # 8-bit 0xC0..0xC7
        ln = 8
    _send_code(d, code, ln)


# Emit a length/distance match: length symbol + extra, then the fixed
# 5-bit distance code + extra.
def _emit_match(d: Ptr[Deflater], length: uint64, dist: uint64):
    li: uint64 = 28
    while li > 0 and _dfl_len_base[li] > cast[uint32](length):
        li = li - 1
    _ll_send(d, cast[uint32](257) + cast[uint32](li))
    ne: int32 = cast[int32](_dfl_len_extra[li])
    if ne > 0:
        _send_bits(d, cast[uint32](length) - _dfl_len_base[li], ne)
    di: uint64 = 29
    while di > 0 and _dfl_dist_base[di] > cast[uint32](dist):
        di = di - 1
    _send_code(d, cast[uint32](di), 5)
    de: int32 = cast[int32](_dfl_dist_extra[di])
    if de > 0:
        _send_bits(d, cast[uint32](dist) - _dfl_dist_base[di], de)


# ---- LZ77 hashing ----------------------------------------------------
def _dfl_hash(inp: Ptr[uint8], i: uint64) -> uint64:
    a: uint32 = cast[uint32](inp[i])
    b: uint32 = cast[uint32](inp[i + 1])
    c: uint32 = cast[uint32](inp[i + 2])
    h: uint32 = (a << 10) ^ (b << 5) ^ c
    return cast[uint64](h & cast[uint32](0x7FFF))


def _dfl_insert(inp: Ptr[uint8], i: uint64):
    h: uint64 = _dfl_hash(inp, i)
    _dfl_prev[i] = _dfl_head[h]
    _dfl_head[h] = cast[int32](i + 1)


# ---- public API ------------------------------------------------------
def deflate_init(d: Ptr[Deflater], out: Ptr[uint8], cap: uint64):
    _dfl_crc_init()
    _dfl_tables_init()
    d[0].out = out
    d[0].cap = cap
    d[0].pos = 0
    d[0].overflow = 0
    d[0].bitbuf = 0
    d[0].bitcnt = 0
    d[0].crc = cast[uint32](0xFFFFFFFF)
    d[0].isize = 0


# The output buffer has been drained to the fd; keep the bit accumulator
# and running CRC/isize but rewind the byte cursor to reuse the buffer.
def deflate_reset_out(d: Ptr[Deflater]):
    d[0].pos = 0


def deflate_gzip_header(d: Ptr[Deflater]):
    _put_byte(d, cast[uint8](0x1F))
    _put_byte(d, cast[uint8](0x8B))
    _put_byte(d, cast[uint8](8))     # CM = DEFLATE
    _put_byte(d, cast[uint8](0))     # FLG
    _put_byte(d, cast[uint8](0))     # MTIME[0]
    _put_byte(d, cast[uint8](0))
    _put_byte(d, cast[uint8](0))
    _put_byte(d, cast[uint8](0))
    _put_byte(d, cast[uint8](0))     # XFL
    _put_byte(d, cast[uint8](0xFF))  # OS = unknown


# Compress one input block (<= GZ_BLOCK_MAX bytes) as a single fixed-
# Huffman DEFLATE block. `is_final` != 0 sets BFINAL on this block.
# Updates the running CRC32 and ISIZE. Matches resolve within this block
# only (distances stay <= its length <= 32 KiB).
def deflate_block(d: Ptr[Deflater], inp: Ptr[uint8], in_len: uint64,
                  is_final: int32):
    d[0].crc = _dfl_crc_update(d[0].crc, inp, in_len)
    d[0].isize = d[0].isize + in_len
    # Fresh hash table per block.
    z: uint64 = 0
    while z < GZ_HASH_SIZE:
        _dfl_head[z] = 0
        z = z + 1
    # Block header: BFINAL (1 bit) then BTYPE=01 (2 bits, value 1).
    bf: uint32 = 0
    if is_final != 0:
        bf = 1
    _send_bits(d, bf, 1)
    _send_bits(d, cast[uint32](1), 2)
    # LZ77 greedy longest-match.
    i: uint64 = 0
    while i < in_len:
        best_len: uint64 = 0
        best_dist: uint64 = 0
        if i + GZ_MIN_MATCH <= in_len:
            h: uint64 = _dfl_hash(inp, i)
            cand_i: int32 = _dfl_head[h]
            chain: int32 = 0
            maxl: uint64 = in_len - i
            if maxl > GZ_MAX_MATCH:
                maxl = GZ_MAX_MATCH
            while cand_i != 0 and chain < GZ_MAX_CHAIN:
                cand: uint64 = cast[uint64](cand_i - 1)
                l: uint64 = 0
                while l < maxl and inp[cand + l] == inp[i + l]:
                    l = l + 1
                if l > best_len:
                    best_len = l
                    best_dist = i - cand
                    if l >= GZ_MAX_MATCH:
                        chain = GZ_MAX_CHAIN
                cand_i = _dfl_prev[cand]
                chain = chain + 1
        if best_len >= GZ_MIN_MATCH:
            _emit_match(d, best_len, best_dist)
            endp: uint64 = i + best_len
            while i < endp:
                if i + GZ_MIN_MATCH <= in_len:
                    _dfl_insert(inp, i)
                i = i + 1
        else:
            _ll_send(d, cast[uint32](inp[i]))
            if i + GZ_MIN_MATCH <= in_len:
                _dfl_insert(inp, i)
            i = i + 1
    # End-of-block symbol (256).
    _ll_send(d, cast[uint32](256))


# Flush any residual bits to a byte boundary, then append the gzip
# trailer: CRC32 (little-endian) + ISIZE (original size mod 2^32, LE).
def deflate_finish(d: Ptr[Deflater]):
    if d[0].bitcnt > 0:
        _put_byte(d, cast[uint8](d[0].bitbuf & cast[uint32](0xFF)))
        d[0].bitbuf = 0
        d[0].bitcnt = 0
    fcrc: uint32 = d[0].crc ^ cast[uint32](0xFFFFFFFF)
    _put_byte(d, cast[uint8](fcrc & cast[uint32](0xFF)))
    _put_byte(d, cast[uint8]((fcrc >> 8) & cast[uint32](0xFF)))
    _put_byte(d, cast[uint8]((fcrc >> 16) & cast[uint32](0xFF)))
    _put_byte(d, cast[uint8]((fcrc >> 24) & cast[uint32](0xFF)))
    is32: uint32 = cast[uint32](d[0].isize & cast[uint64](0xFFFFFFFF))
    _put_byte(d, cast[uint8](is32 & cast[uint32](0xFF)))
    _put_byte(d, cast[uint8]((is32 >> 8) & cast[uint32](0xFF)))
    _put_byte(d, cast[uint8]((is32 >> 16) & cast[uint32](0xFF)))
    _put_byte(d, cast[uint8]((is32 >> 24) & cast[uint32](0xFF)))

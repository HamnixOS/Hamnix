# lib/hamui_host.ad — the HOST rasterizer sink for the hamUI scene builder.
#
# THE DUAL-TARGET SEAM (see docs/hamui_dual_target.md)
# ====================================================
# A hamUI scene app builds a display list with lib/hamscene.ad's hamscene_*
# calls into one text buffer. On the NATIVE target lib/hamui.ad's
# hamscene_commit() writes that buffer to /dev/wsys/<wid>/scene and the
# kernel scene compositor rasterizes + blits it. There is no compositor on
# the developer's host, so THIS module is the second sink: it PARSES the
# very same buffer (via lib/hamscene.ad's hamscene_bufptr()/hamscene_length()
# accessors) and RASTERIZES it into an RGB framebuffer using the SAME 8x16
# VGA font the compositor draws (lib/hamui_host_font.ad), so a host test can
# dump a PPM/PNG and a human/agent can LOOK at exactly what a native boot
# would show — in milliseconds, no QEMU.
#
# This module is PURE: no `extern`, no syscalls, no I/O. It only reads the
# scene buffer and fills a BSS framebuffer + builds a PPM header into a
# caller buffer. The per-app `*_host.ad` driver does the actual file writes
# (host Linux sys_write) and feeds SCRIPTED input to the app's pure input
# handlers. It links ONLY into the x86_64-linux host target; the native code
# path never references it.

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host_font import hamui_host_font_init, hamui_host_font_row
from lib.browserfonts import browserfonts_load
from lib.font_ttf import font_ttf_loaded, font_ttf_render, font_ttf_ascent_px, \
    glyph_bw, glyph_bh, glyph_xoff, glyph_ytop, glyph_blank, glyph_cov, \
    glyph_adv, FACE_TT_MONO, FACE_TT_SANS, FACE_TT_SANS_BOLD
from lib.vk.vk_2d import (
    vk2d_raster_fill_rect, vk2d_raster_fill_rect_alpha,
    vk2d_raster_blit, vk2d_raster_draw_line,
    vk2d_raster_fill_roundrect, vk2d_raster_cov_mask,
)


# ====================================================================
# PHASE C — the DE compositor's HOST rasterizer is now a vk CLIENT.
# ====================================================================
# This module used to own a private software rasterizer (direct _put_px /
# _put_px_blend writes into an RGB framebuffer). It now paints every primitive
# through the vk 2D primitive layer (lib/vk/vk_2d.ad — the exact ops the kernel
# vk command buffer replays at vkQueueSubmit) into a vk-style RGBA8888 COLOR
# IMAGE (VK_FORMAT_R8G8B8A8_UNORM backing), then FLATTENS that image (RGBA ->
# RGB) into a present buffer for the PPM writer. So the DE host rasterizer
# inherits the vk pipeline (and, later, GPU acceleration behind the same vk2d
# API) for free — while the public hamui_host_* / hamscene API and every DE app
# stay byte-for-byte unchanged.
#
# BYTE-EXACTNESS: vk_2d's blend math is byte-identical to the old
# _put_px_blend / _fill_rect_a / _fill_roundrect / _blit_glyph_prop (Phase A
# guaranteed this; the roundrect + glyph-coverage ops were ported verbatim from
# here). The colour image's RGB channels therefore evolve exactly as the old RGB
# framebuffer did — the write-only alpha byte is dropped at flatten — so the
# rendered DE frame (and the primitive count) match the old path pixel-for-pixel.
#
# The kernel compositor twin (sys/src/9/port/devwsys.ad) is the deeper Phase C.2
# follow-up (it needs a glyph atlas to feed the coverage-mask op device-side);
# this host routing is what the DE-speed bench + before/after comparison measure.
#
# ====================================================================
# The vk COLOR IMAGE (BSS, demand-zero on Linux). Row-major RGBA8888 — the exact
# backing a VkImage(VK_FORMAT_R8G8B8A8_UNORM) render pass + present path use.
# Sized to a generous window; the active WxH is set by hamui_host_begin(). A
# separate RGB present buffer holds the flattened frame for the PPM writer.
# ====================================================================
HOST_MAX_W: uint64 = 1024
HOST_MAX_H: uint64 = 768
hostfb: Array[3145728, uint8]        # 1024*768*4 RGBA vk colour image
hostrgb: Array[2359296, uint8]       # 1024*768*3 RGB present buffer
host_w: int32 = 0
host_h: int32 = 0

# Per-glyph coverage scratch (row-major cov_w*cov_h uint8), fed to the vk2d
# coverage-mask op. 128*128 comfortably holds a 14px cell glyph bitmap.
host_cov: Array[16384, uint8]


# Base pointer of the vk colour image (the vk2d ops' color_base argument).
def _host_cbase() -> uint64:
    return cast[uint64](&hostfb[0])


# Pack four channels into the vk2d ops' 0xRRGGBBAA colour word.
def _host_pack(r: uint8, g: uint8, b: uint8, a: uint8) -> uint32:
    return (cast[uint32](r) << 24) | (cast[uint32](g) << 16) | \
           (cast[uint32](b) << 8) | cast[uint32](a)


def hamui_host_width() -> int32:
    return host_w


def hamui_host_height() -> int32:
    return host_h


# Flatten the RGBA colour image into the RGB present buffer (dropping alpha; the
# colour target is an opaque compositing surface) and return it. Callers read
# hamui_host_fb_bytes() bytes for the PPM body.
def hamui_host_fb_ptr() -> Ptr[uint8]:
    n: uint64 = cast[uint64](host_w) * cast[uint64](host_h)
    src: uint64 = _host_cbase()
    i: uint64 = 0
    while i < n:
        so: uint64 = src + i * 4
        dofs: uint64 = i * 3
        hostrgb[dofs] = cast[Ptr[uint8]](so)[0]
        hostrgb[dofs + 1] = cast[Ptr[uint8]](so + 1)[0]
        hostrgb[dofs + 2] = cast[Ptr[uint8]](so + 2)[0]
        i = i + 1
    return &hostrgb[0]


def hamui_host_fb_bytes() -> uint64:
    return cast[uint64](host_w) * cast[uint64](host_h) * 3


# Packed 0x00RRGGBB at (x,y); 0 if out of range. For gate assertions. Reads the
# RGBA colour image directly (bytes 0,1,2 == the old RGB framebuffer values).
def hamui_host_pixel(x: int32, y: int32) -> uint32:
    if x < 0 or y < 0 or x >= host_w or y >= host_h:
        return 0
    o: uint64 = _host_cbase() + (cast[uint64](y) * cast[uint64](host_w)
                                 + cast[uint64](x)) * 4
    r: uint32 = cast[uint32](cast[Ptr[uint8]](o)[0])
    g: uint32 = cast[uint32](cast[Ptr[uint8]](o + 1)[0])
    b: uint32 = cast[uint32](cast[Ptr[uint8]](o + 2)[0])
    return (r << 16) | (g << 8) | b


# ====================================================================
# #128 HOST IMAGE REGISTRY — the host-side twin of the kernel's named
# image store. The kernel gets image bytes via the draw/ctl 'I' verb; on
# the host there is no compositor, so a host test/driver registers decoded
# RGBA bytes here BY NAME (e.g. from lib/png.ad's png_rgba_ptr()) before
# calling hamui_host_rasterize(). The `image NAME` scene verb then looks
# the name up and blits it — exactly mirroring the native path, so the PNG
# a human LOOKS at on the host is the render a native boot would show.
# ====================================================================
HOST_IMG_SLOTS:   uint64 = 8
HOST_IMG_NAME_CAP: uint64 = 32
host_img_name: Array[256, uint8]      # 8 * 32, NUL-terminated
host_img_w:    Array[8, int32]
host_img_h:    Array[8, int32]
host_img_ptr:  Array[8, uint64]       # RGBA8888 source (caller-owned)
host_img_used: Array[8, int32]


# Register (or replace) a named RGBA8888 image. rgba must stay valid until
# the next rasterize. Returns 1 on success, 0 if the table is full.
def hamui_host_register_image(name: Ptr[uint8], w: int32, h: int32,
                              rgba: Ptr[uint8]) -> int32:
    # find matching name or free slot
    slot: int32 = -1
    s: uint64 = 0
    while s < HOST_IMG_SLOTS:
        if host_img_used[s] != 0 and _host_img_name_eq(s, name) == 1:
            slot = cast[int32](s)
            s = HOST_IMG_SLOTS
        else:
            s = s + 1
    if slot < 0:
        s2: uint64 = 0
        while s2 < HOST_IMG_SLOTS:
            if host_img_used[s2] == 0:
                slot = cast[int32](s2)
                s2 = HOST_IMG_SLOTS
            else:
                s2 = s2 + 1
    if slot < 0:
        return 0
    u: uint64 = cast[uint64](slot)
    nb: uint64 = u * HOST_IMG_NAME_CAP
    k: uint64 = 0
    while name[k] != 0 and k < HOST_IMG_NAME_CAP - 1:
        host_img_name[nb + k] = name[k]
        k = k + 1
    host_img_name[nb + k] = 0
    host_img_w[u] = w
    host_img_h[u] = h
    host_img_ptr[u] = cast[uint64](rgba)
    host_img_used[u] = 1
    return 1


def _host_img_name_eq(slot: uint64, name: Ptr[uint8]) -> int32:
    nb: uint64 = slot * HOST_IMG_NAME_CAP
    k: uint64 = 0
    while name[k] != 0:
        if host_img_name[nb + k] == 0:
            return 0
        if host_img_name[nb + k] != name[k]:
            return 0
        k = k + 1
    if host_img_name[nb + k] != 0:
        return 0
    return 1


# Find the slot for the bareword name buf[ns..ne); -1 if none.
def _host_img_find(buf: Ptr[uint8], ns: uint64, ne: uint64) -> int32:
    if ns >= ne:
        return -1
    s: uint64 = 0
    while s < HOST_IMG_SLOTS:
        if host_img_used[s] != 0:
            nb: uint64 = s * HOST_IMG_NAME_CAP
            k: uint64 = ns
            j: uint64 = nb
            mt: int32 = 1
            while k < ne and mt == 1:
                if host_img_name[j] == 0 or host_img_name[j] != buf[k]:
                    mt = 0
                k = k + 1
                j = j + 1
            if mt == 1 and host_img_name[j] == 0:
                return cast[int32](s)
        s = s + 1
    return -1


# Blit registered image `slot` into rect (dx,dy,dw,dh), nearest-neighbor
# scaled + alpha-composited, THROUGH the vk2d blit op. dw/dh <= 0 -> natural
# size. vk2d_raster_blit's default source rect (sx=sy=sw=sh=0 -> whole image),
# nearest-neighbour scaling and source-over blend are byte-identical to the old
# private loop.
def _host_blit_image(slot: int32, dx: int32, dy: int32, dw: int32, dh: int32):
    u: uint64 = cast[uint64](slot)
    src: uint64 = host_img_ptr[u]
    if src == 0:
        return
    sw: int32 = host_img_w[u]
    sh: int32 = host_img_h[u]
    if sw <= 0 or sh <= 0:
        return
    vk2d_raster_blit(_host_cbase(), cast[uint64](host_w), cast[uint64](host_h),
                     src, cast[uint64](sw), cast[uint64](sh),
                     cast[int64](dx), cast[int64](dy),
                     cast[int64](dw), cast[int64](dh), 0, 0, 0, 0)


# Solid opaque rectangle fill via the vk2d fill op (alpha 0xFF).
def _fill_rect(x: int32, y: int32, w: int32, h: int32, r: uint8, g: uint8,
               b: uint8):
    vk2d_raster_fill_rect(_host_cbase(), cast[uint64](host_w),
                          cast[uint64](host_h), cast[int64](x), cast[int64](y),
                          cast[int64](w), cast[int64](h),
                          _host_pack(r, g, b, 255))


# Alpha-aware rectangle fill: SOURCE-OVER each pixel using `a` (0..255) so a
# translucent scene `fill`/`rect`/`stroke` (e.g. the screenshot overlay's
# #00000066 dim scrim) composites over whatever is already in the colour image
# instead of blitting opaque. a==255 reduces to the plain opaque store. Routed
# through vk2d_raster_fill_rect_alpha, whose source-over is byte-identical to
# the device compositor's _wsys_cache_fillrect -> _wsys_cache_putpixel.
def _fill_rect_a(x: int32, y: int32, w: int32, h: int32, r: uint8, g: uint8,
                 b: uint8, a: uint8):
    if a == 0:
        return
    vk2d_raster_fill_rect_alpha(_host_cbase(), cast[uint64](host_w),
                                cast[uint64](host_h), cast[int64](x),
                                cast[int64](y), cast[int64](w), cast[int64](h),
                                _host_pack(r, g, b, a))


# ---- rounded rectangle (shared AA corner formula, see devwsys.ad twin) ----
# Fill a rounded rectangle via the vk2d roundrect op. `corners` is a bitmask
# (1=TL 2=TR 4=BL 8=BR). The AA corner formula (_vk2d_rr_isqrt / _vk2d_rr_cov,
# in HALF-pixel units) was ported BYTE-FOR-BYTE from the old _rr_isqrt / _rr_cov
# here (whose twin is the kernel compositor _wsys_* rounder), so corners round to
# the exact same pixels; rr<=0 falls through to a plain source-over rectangle.
def _fill_roundrect(x: int32, y: int32, w: int32, h: int32, rad: int32,
                    corners: int32, r: uint8, g: uint8, b: uint8, a: uint8):
    vk2d_raster_fill_roundrect(_host_cbase(), cast[uint64](host_w),
                               cast[uint64](host_h), cast[int64](x),
                               cast[int64](y), cast[int64](w), cast[int64](h),
                               cast[int64](rad), corners, _host_pack(r, g, b, a))


# ---- colour parsing: "#RRGGBB" / "#RRGGBBAA" -> 3 bytes -------------------
_col_r: uint8 = 0
_col_g: uint8 = 0
_col_b: uint8 = 0
_col_a: uint8 = 255


def _hex1(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return cast[int32](c) - 48
    if c >= 97 and c <= 102:
        return cast[int32](c) - 97 + 10
    if c >= 65 and c <= 70:
        return cast[int32](c) - 65 + 10
    return 0


# Parse a colour token from buf at [off..); set _col_r/g/b. Returns the
# offset just past the token. Accepts "#rgb", "#rrggbb", "#rrggbbaa".
def _parse_color(buf: Ptr[uint8], off: uint64, end: uint64) -> uint64:
    i: uint64 = off
    if i < end and buf[i] == 35:                       # '#'
        i = i + 1
    start: uint64 = i
    while i < end and buf[i] != 32 and buf[i] != 10:
        i = i + 1
    ndig: uint64 = i - start
    _col_a = 255
    if ndig == 3:
        r4: int32 = _hex1(buf[start])
        g4: int32 = _hex1(buf[start + 1])
        b4: int32 = _hex1(buf[start + 2])
        _col_r = cast[uint8](r4 * 16 + r4)
        _col_g = cast[uint8](g4 * 16 + g4)
        _col_b = cast[uint8](b4 * 16 + b4)
    else:
        _col_r = cast[uint8](_hex1(buf[start]) * 16 + _hex1(buf[start + 1]))
        _col_g = cast[uint8](_hex1(buf[start + 2]) * 16 + _hex1(buf[start + 3]))
        _col_b = cast[uint8](_hex1(buf[start + 4]) * 16 + _hex1(buf[start + 5]))
        if ndig == 8:
            _col_a = cast[uint8](_hex1(buf[start + 6]) * 16
                                 + _hex1(buf[start + 7]))
    return i


# ---- integer parsing -----------------------------------------------------
_num: int32 = 0


def _skip_sp(buf: Ptr[uint8], off: uint64, end: uint64) -> uint64:
    i: uint64 = off
    while i < end and buf[i] == 32:
        i = i + 1
    return i


# Parse a signed decimal at [off..); set _num. Returns offset past it.
def _parse_int(buf: Ptr[uint8], off: uint64, end: uint64) -> uint64:
    i: uint64 = _skip_sp(buf, off, end)
    neg: int32 = 0
    if i < end and buf[i] == 45:                       # '-'
        neg = 1
        i = i + 1
    v: int32 = 0
    while i < end and buf[i] >= 48 and buf[i] <= 57:
        v = v * 10 + cast[int32](buf[i]) - 48
        i = i + 1
    if neg != 0:
        v = 0 - v
    _num = v
    return i


# ---- text blit -----------------------------------------------------------
# DE text is laid out on a FIXED 8px-per-character grid (all hamUI apps'
# layout math — e.g. title centring — assumes this monospace advance), and the
# text cell is 16px tall. Historically each cell was drawn with the crude 8x16
# VGA bitmap (hamui_host_font.ad); bold double-struck +1px, which ate the only
# inter-glyph gap in the 8px cell and turned bold headers (e.g. 2048's title)
# into a blob. We now render each cell through the SAME scalable, 4x4-super-
# sampled anti-aliased TrueType rasteriser the native browser uses (font_ttf.ad
# fed by the embedded DejaVu faces in browserfonts.ad), using the MONOSPACE
# face so the 8px grid is preserved exactly — only the pixels get crisper. The
# bitmap path remains as a fallback when the TTF face is unavailable.

# Mono em size chosen so the glyph ink sits comfortably inside the 8px cell
# (DejaVu Mono advance ~0.602em -> ~8.4px at 14px) while filling the 16px box.
TTF_PX: int32 = 14


# Rasterize the font's current glyph coverage (bw*bh) into host_cov and stamp it
# through the vk2d coverage-mask op at (x0,y0) in opaque ink. `ink` is packed
# 0xRRGGBB.FF: text ink is opaque (the coverage IS the alpha), so cov_mask's
# a_eff = cov * 0xFF / 255 == cov — byte-identical to the old per-pixel
# _put_px_blend(x, y, r, g, b, cov). Returns 1 if it stamped, 0 if the glyph is
# too large for the scratch (never for a 14px cell).
def _host_stamp_glyph(bw: int32, bh: int32, x0: int32, y0: int32,
                      ink: uint32) -> int32:
    if bw <= 0 or bh <= 0:
        return 0
    if cast[uint64](bw) * cast[uint64](bh) > 16384:
        return 0
    row: int32 = 0
    while row < bh:
        col: int32 = 0
        while col < bw:
            host_cov[cast[uint64](row * bw + col)] = glyph_cov(col, row)
            col = col + 1
        row = row + 1
    vk2d_raster_cov_mask(_host_cbase(), cast[uint64](host_w),
                         cast[uint64](host_h), cast[uint64](&host_cov[0]),
                         cast[int64](bw), cast[int64](bh),
                         cast[int64](x0), cast[int64](y0), ink)
    return 1


# Blit one glyph at top-left (gx,gy) in the current colour via the AA TrueType
# mono face, THROUGH the vk2d coverage-mask op. Returns 1 if the cell was
# handled (drawn or an empty space), 0 if the face is unavailable and the caller
# should fall back to the bitmap. `bold` double-strikes (+1px x) by stamping the
# same coverage a second time at x0+1, like the compositor's `b` flag.
def _blit_glyph_aa(ch: uint8, gx: int32, gy: int32, bold: int32) -> int32:
    if font_ttf_loaded(FACE_TT_MONO) == 0:
        return 0
    if font_ttf_render(FACE_TT_MONO, cast[int32](ch), TTF_PX) == 0:
        # No coverage: a blank glyph (space) is legitimately handled; a truly
        # missing glyph falls back to the bitmap so nothing silently vanishes.
        if glyph_blank() != 0:
            return 1
        return 0
    base: int32 = gy + font_ttf_ascent_px(FACE_TT_MONO, TTF_PX)
    bw: int32 = glyph_bw()
    bh: int32 = glyph_bh()
    x0: int32 = gx + glyph_xoff()
    y0: int32 = base + glyph_ytop()
    ink: uint32 = _host_pack(_col_r, _col_g, _col_b, 255)
    if _host_stamp_glyph(bw, bh, x0, y0, ink) == 1 and bold != 0:
        _host_stamp_glyph(bw, bh, x0 + 1, y0, ink)
    return 1


# Blit one 8x16 glyph at top-left (gx,gy) in the current colour; `bold`
# double-strikes (+1px x) like the compositor's `b` flag. The bitmap fallback's
# opaque bits are stamped through the vk2d fill op (1x1 opaque rects), so this
# path too is a vk client.
def _blit_glyph(ch: uint8, gx: int32, gy: int32, bold: int32):
    if _blit_glyph_aa(ch, gx, gy, bold) != 0:
        return
    cb: uint64 = _host_cbase()
    iw: uint64 = cast[uint64](host_w)
    ih: uint64 = cast[uint64](host_h)
    ink: uint32 = _host_pack(_col_r, _col_g, _col_b, 255)
    row: int32 = 0
    while row < 16:
        bits: uint8 = hamui_host_font_row(ch, cast[uint64](row))
        col: int32 = 0
        while col < 8:
            mask: uint8 = cast[uint8](128 >> col)
            if (bits & mask) != 0:
                vk2d_raster_fill_rect(cb, iw, ih, cast[int64](gx + col),
                                      cast[int64](gy + row), 1, 1, ink)
                if bold != 0:
                    vk2d_raster_fill_rect(cb, iw, ih, cast[int64](gx + col + 1),
                                          cast[int64](gy + row), 1, 1, ink)
            col = col + 1
        row = row + 1


# Blit one AA glyph of `face` with its pen origin at x=penx on baseline `base`,
# a faithful host port of the device _wsys_cache_draw_glyph_aa (devwsys.ad),
# routed through the vk2d coverage-mask op. Returns the glyph's REAL
# proportional advance in px (glyph_adv()) so the caller advances the pen
# exactly as the compositor does — no fixed cell.
def _blit_glyph_prop(face: int32, ch: uint8, penx: int32, base: int32) -> int32:
    got: int32 = font_ttf_render(face, cast[int32](ch), TTF_PX)
    adv: int32 = glyph_adv()
    if got == 1 and glyph_blank() == 0:
        bw: int32 = glyph_bw()
        bh: int32 = glyph_bh()
        x0: int32 = penx + glyph_xoff()
        y0: int32 = base + glyph_ytop()
        _host_stamp_glyph(bw, bh, x0, y0,
                          _host_pack(_col_r, _col_g, _col_b, 255))
    return adv


# Draw a quoted string starting at buf[off]=='"'. Device-faithful: when the
# embedded DejaVu Sans face is available we mirror the compositor's
# _wsys_cache_draw_str_aa exactly — same SANS(/bold) face at 14px, same
# per-glyph proportional advance, same baseline anchoring (text verb =
# baseline-anchored at y; glyphs verb = cell-anchored, baseline = y + 12).
# This makes a caret / selection band positioned by htb_text_width()/
# htb_caret_x sit flush on the drawn glyphs, matching the device. Only when the
# TTF face is unavailable do we fall back to the legacy 8px monospace cell.
def _draw_text(buf: Ptr[uint8], off: uint64, end: uint64, tx: int32,
               ty: int32, bold: int32, is_glyphs: int32) -> uint64:
    i: uint64 = off
    if i < end and buf[i] == 34:                       # opening quote
        i = i + 1
    if font_ttf_loaded(FACE_TT_SANS) == 1:
        face: int32 = FACE_TT_SANS
        if bold != 0 and font_ttf_loaded(FACE_TT_SANS_BOLD) == 1:
            face = FACE_TT_SANS_BOLD
        base: int32 = ty
        if is_glyphs != 0:
            base = ty + 12
        cx: int32 = tx
        while i < end and buf[i] != 34 and buf[i] != 10:
            cx = cx + _blit_glyph_prop(face, buf[i], cx, base)
            i = i + 1
        if i < end and buf[i] == 34:
            i = i + 1
        return i
    # Fallback: legacy 8px monospace bitmap cell (embedded face unavailable).
    cx2: int32 = tx
    while i < end and buf[i] != 34 and buf[i] != 10:
        _blit_glyph(buf[i], cx2, ty, bold)
        cx2 = cx2 + 8
        i = i + 1
    if i < end and buf[i] == 34:
        i = i + 1
    return i


# Opaque Bresenham line with a thick x thick square brush per plotted point,
# routed through the vk2d line op (byte-identical brush model to the old loop,
# which stamped _fill_rect(cx,cy,t,t) per point).
def _draw_line(x1: int32, y1: int32, x2: int32, y2: int32, thick: int32):
    vk2d_raster_draw_line(_host_cbase(), cast[uint64](host_w),
                          cast[uint64](host_h), cast[int64](x1), cast[int64](y1),
                          cast[int64](x2), cast[int64](y2), cast[int64](thick),
                          _host_pack(_col_r, _col_g, _col_b, 255))


# ====================================================================
# PUBLIC: begin a frame, rasterize the built scene, build a PPM header.
# ====================================================================

# Set the active framebuffer size and clear to opaque black. Clamped to the
# BSS ceiling. Call before hamui_host_rasterize().
def hamui_host_begin(w: int32, h: int32):
    hamui_host_font_init()
    browserfonts_load()             # register the embedded DejaVu TTF faces
    ww: int32 = w
    hh: int32 = h
    if ww < 1:
        ww = 1
    if hh < 1:
        hh = 1
    if cast[uint64](ww) > HOST_MAX_W:
        ww = cast[int32](HOST_MAX_W)
    if cast[uint64](hh) > HOST_MAX_H:
        hh = cast[int32](HOST_MAX_H)
    host_w = ww
    host_h = hh
    # Clear the vk colour image to OPAQUE BLACK (0,0,0,255) via the vk2d fill op
    # — the RGB channels match the old byte-wise zero of the RGB framebuffer.
    vk2d_raster_fill_rect(_host_cbase(), cast[uint64](ww), cast[uint64](hh),
                          0, 0, cast[int64](ww), cast[int64](hh), 0x000000FF)


# Parse the scene buffer produced by the last hamscene_* build pass and draw
# every primitive into the framebuffer. Returns the number of primitives
# drawn (comments/blank lines excluded).
def hamui_host_rasterize() -> int32:
    buf: Ptr[uint8] = hamscene_bufptr()
    end: uint64 = hamscene_length()
    drawn: int32 = 0
    i: uint64 = 0
    while i < end:
        # Determine the verb by first token.
        ls: uint64 = i
        # find end of line
        le: uint64 = i
        while le < end and buf[le] != 10:
            le = le + 1
        # skip comment / blank
        if ls < le and buf[ls] != 35:
            c0: uint8 = buf[ls]
            # fill / rect / text / glyphs / line / stroke — dispatch on c0
            # + length by re-reading the verb token.
            vstart: uint64 = ls
            vend: uint64 = ls
            while vend < le and buf[vend] != 32:
                vend = vend + 1
            vlen: uint64 = vend - vstart
            handled: int32 = _draw_verb(buf, vstart, vlen, vend, le)
            if handled != 0:
                drawn = drawn + 1
        i = le + 1
    return drawn


# Dispatch one primitive line. `vend` is the offset just past the verb; the
# args run [vend..le).
def _draw_verb(buf: Ptr[uint8], vstart: uint64, vlen: uint64, vend: uint64,
               le: uint64) -> int32:
    c0: uint8 = buf[vstart]
    # roundrect x y w h radius #col [corners] — 'r' + len 9 (before plain rect)
    if vlen == 9 and c0 == 114 and buf[vstart + 1] == 111:      # 'r' 'o'
        pr: uint64 = _parse_int(buf, vend, le)
        rx: int32 = _num
        pr = _parse_int(buf, pr, le)
        ry: int32 = _num
        pr = _parse_int(buf, pr, le)
        rw: int32 = _num
        pr = _parse_int(buf, pr, le)
        rh: int32 = _num
        pr = _parse_int(buf, pr, le)
        rrad: int32 = _num
        pr = _skip_sp(buf, pr, le)
        pr = _parse_color(buf, pr, le)
        # optional trailing corner mask (default all=15)
        cm: int32 = 15
        cs: uint64 = _skip_sp(buf, pr, le)
        if cs < le and buf[cs] >= 48 and buf[cs] <= 57:
            _parse_int(buf, cs, le)
            cm = _num
        _fill_roundrect(rx, ry, rw, rh, rrad, cm, _col_r, _col_g, _col_b,
                        _col_a)
        return 1
    # fill (102) / rect (114 'r' but 'rect') / stroke (115 's') / line (108)
    # / text (116 't') / glyphs (103 'g')
    if (c0 == 102) or (vlen == 4 and c0 == 114 and buf[vstart + 1] == 101):
        # fill x y w h #col   OR   rect x y w h #col
        p: uint64 = _parse_int(buf, vend, le)
        x: int32 = _num
        p = _parse_int(buf, p, le)
        y: int32 = _num
        p = _parse_int(buf, p, le)
        w: int32 = _num
        p = _parse_int(buf, p, le)
        h: int32 = _num
        p = _skip_sp(buf, p, le)
        _parse_color(buf, p, le)
        _fill_rect_a(x, y, w, h, _col_r, _col_g, _col_b, _col_a)
        return 1
    if c0 == 115:                                       # stroke x y w h thick #col
        p2: uint64 = _parse_int(buf, vend, le)
        sx: int32 = _num
        p2 = _parse_int(buf, p2, le)
        sy: int32 = _num
        p2 = _parse_int(buf, p2, le)
        sw: int32 = _num
        p2 = _parse_int(buf, p2, le)
        sh: int32 = _num
        p2 = _parse_int(buf, p2, le)
        st: int32 = _num
        p2 = _skip_sp(buf, p2, le)
        _parse_color(buf, p2, le)
        # four edges of thickness st
        _fill_rect_a(sx, sy, sw, st, _col_r, _col_g, _col_b, _col_a)            # top
        _fill_rect_a(sx, sy + sh - st, sw, st, _col_r, _col_g, _col_b, _col_a)  # bottom
        _fill_rect_a(sx, sy, st, sh, _col_r, _col_g, _col_b, _col_a)           # left
        _fill_rect_a(sx + sw - st, sy, st, sh, _col_r, _col_g, _col_b, _col_a) # right
        return 1
    if c0 == 108:                                       # line x1 y1 x2 y2 thick #col
        p3: uint64 = _parse_int(buf, vend, le)
        lx1: int32 = _num
        p3 = _parse_int(buf, p3, le)
        ly1: int32 = _num
        p3 = _parse_int(buf, p3, le)
        lx2: int32 = _num
        p3 = _parse_int(buf, p3, le)
        ly2: int32 = _num
        p3 = _parse_int(buf, p3, le)
        lt: int32 = _num
        p3 = _skip_sp(buf, p3, le)
        _parse_color(buf, p3, le)
        _draw_line(lx1, ly1, lx2, ly2, lt)
        return 1
    if c0 == 116 or c0 == 103:                          # text / glyphs x y "s" #col [b]
        p4: uint64 = _parse_int(buf, vend, le)
        tx: int32 = _num
        p4 = _parse_int(buf, p4, le)
        ty: int32 = _num
        p4 = _skip_sp(buf, p4, le)
        # Peek for a trailing " b" bold flag: colour token then optional 'b'.
        # We must set the colour BEFORE drawing, so scan the string first to
        # find its end, parse the colour, note bold, then draw.
        qs: uint64 = p4                                 # at opening quote
        # find closing quote
        qi: uint64 = qs
        if qi < le and buf[qi] == 34:
            qi = qi + 1
        while qi < le and buf[qi] != 34:
            qi = qi + 1
        # qi at closing quote; colour begins after it
        cp: uint64 = _skip_sp(buf, qi + 1, le)
        _parse_color(buf, cp, le)
        # bold flag: after colour, a lone 'b'
        bp: uint64 = cp
        while bp < le and buf[bp] != 32 and buf[bp] != 10:
            bp = bp + 1
        bp = _skip_sp(buf, bp, le)
        bold: int32 = 0
        if bp < le and buf[bp] == 98:
            bold = 1
        # c0==103 ('g') is the cell-anchored `glyphs` verb; 't' is baseline-
        # anchored `text`. Pass it through so the baseline matches the device.
        is_glyphs: int32 = 0
        if c0 == 103:
            is_glyphs = 1
        _draw_text(buf, qs, le, tx, ty, bold, is_glyphs)
        return 1
    # image x y w h NAME (#128) — 'i' 'm' distinguishes it from any other verb
    if vlen == 5 and c0 == 105 and buf[vstart + 1] == 109:
        p5: uint64 = _parse_int(buf, vend, le)
        ix: int32 = _num
        p5 = _parse_int(buf, p5, le)
        iy: int32 = _num
        p5 = _parse_int(buf, p5, le)
        iw: int32 = _num
        p5 = _parse_int(buf, p5, le)
        ih: int32 = _num
        # bareword NAME
        ns: uint64 = _skip_sp(buf, p5, le)
        ne: uint64 = ns
        while ne < le and buf[ne] != 32 and buf[ne] != 10:
            ne = ne + 1
        if ns >= ne:
            return 0
        slot: int32 = _host_img_find(buf, ns, ne)
        if slot < 0:
            return 1                                     # unknown name: no-op
        _host_blit_image(slot, ix, iy, iw, ih)
        return 1
    return 0


# Build a binary PPM (P6) header "P6\n<w> <h>\n255\n" into `out`; returns
# its length. The driver writes this header, then hamui_host_fb_ptr() for
# hamui_host_fb_bytes() bytes, to produce a complete .ppm.
def hamui_host_ppm_header(out: Ptr[uint8]) -> uint64:
    p: uint64 = 0
    out[p] = 80                                         # 'P'
    p = p + 1
    out[p] = 54                                         # '6'
    p = p + 1
    out[p] = 10
    p = p + 1
    p = p + _dec(host_w, &out[p])
    out[p] = 32
    p = p + 1
    p = p + _dec(host_h, &out[p])
    out[p] = 10
    p = p + 1
    out[p] = 50                                         # '2'
    p = p + 1
    out[p] = 53                                         # '5'
    p = p + 1
    out[p] = 53                                         # '5'
    p = p + 1
    out[p] = 10
    p = p + 1
    return p


def _dec(v: int32, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    x: uint32 = cast[uint32](v)
    digs: Array[16, uint8]
    n: uint64 = 0
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    w: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return w

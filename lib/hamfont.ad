# lib/hamfont.ad — 8x16 monospace bitmap font for the hamSDL/hamGame
# text renderer (the pygame.font.Font gap: hamGame could blit sprite
# Surfaces but had no way to rasterize a STRING into one).
#
# The glyph table is the SAME 8x16 VGA ROM font the GOP console draws
# (drivers/video/console/fb_font_8x16.S, derived verbatim from Linux's
# lib/fonts/font_8x16.c) and that lib/hamui_host_font.ad already embeds
# for the scene rasterizer — so a text Surface shows the exact glyphs a
# native boot would. It is EMBEDDED here as data (a copy of that ROM-font
# table), not extern-linked, so this module is pure data + logic and
# links into BOTH the x86_64-adder-user (device) and x86_64-linux (host)
# targets. This file only READS glyph bits; it never touches the console.
#
# Char N in 0..127 -> bytes N*16 .. N*16+15, each byte one 8-pixel
# scanline, MSB = leftmost pixel. Stored as a 4096-char ASCII-hex string
# (module-scope list/binary initialisers are unsupported by the x86
# codegen; a plain ASCII string with no embedded NUL/quote is robust)
# and decoded once into a BSS table by hamfont_init().

HAMFONT_GLYPH_W: int32 = 8
HAMFONT_GLYPH_H: int32 = 16

HAMFONT_HEX: Array[4097, uint8] = ""
HAMFONT_8X16: Array[2048, uint8]
_hamfont_ready: int32 = 0


def _hamfont_hexval(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return cast[int32](c) - 48
    if c >= 97 and c <= 102:
        return cast[int32](c) - 97 + 10
    if c >= 65 and c <= 70:
        return cast[int32](c) - 65 + 10
    return 0


def hamfont_init():
    # Decode the 4096-char hex string into the 2048-byte glyph table (once).
    if _hamfont_ready != 0:
        return
    i: uint64 = 0
    while i < 2048:
        hi: int32 = _hamfont_hexval(HAMFONT_HEX[i * 2])
        lo: int32 = _hamfont_hexval(HAMFONT_HEX[i * 2 + 1])
        HAMFONT_8X16[i] = cast[uint8](hi * 16 + lo)
        i = i + 1
    _hamfont_ready = 1


# Bitmap byte for glyph `ch` scanline `row` (0..15); blank if out of range.
# Non-printable ASCII (< 0x20) and >= 0x7F render as blank so a string of
# printables 0x20..0x7E rasterizes cleanly.
def hamfont_glyph_row(ch: uint8, row: uint64) -> uint8:
    if row >= 16:
        return 0
    if ch < 32 or ch >= 127:
        return 0
    return HAMFONT_8X16[cast[uint64](ch) * 16 + row]

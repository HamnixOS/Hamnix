# lib/hamscene.ad — the PURE, extern-free hamUI scene display-list builder.
#
# WHY THIS FILE EXISTS (the dual-target seam)
# ===========================================
# A hamUI scene app draws by BUILDING a text display list (fill/rect/glyphs/
# line/stroke/…) and then COMMITTING it. Historically both the builder and
# the commit lived in lib/hamui.ad. But `hamscene_commit` writes to
# /dev/wsys/<wid>/scene through Hamnix-only syscalls, so lib/hamui.ad can
# never be compiled for the developer's HOST Linux target — which meant a
# GUI app's render could only ever be seen via a full installer-image QEMU
# boot (~6 min).
#
# This file factors the display-list BUILDER out of lib/hamui.ad, exactly
# the way lib/htmlengine.ad was factored out of the browser: it is PURE
# (no `extern`, no I/O, no imports) and target-agnostic. It owns one module-
# scope text buffer (hamscene_buf) and appends grammar lines to it. The two
# SINKS behind this seam are:
#   * NATIVE  — lib/hamui.ad's hamscene_commit() writes hamscene_buf to
#               /dev/wsys/<wid>/scene via 9P (unchanged).
#   * HOST    — lib/hamui_host.ad rasterizes hamscene_buf to a PPM/PNG so a
#               human/agent can LOOK at the render on the host in ms.
# Both read the SAME buffer this builder fills, so the host test exercises
# the exact display list the native path ships.
#
# GRAMMAR (one line per primitive; `# scene v1 hamui` header):
#   fill   x y w h #RRGGBB[AA]              solid rectangle
#   rect   x y w h #RRGGBB[AA]              semantic filled box (alias fill)
#   text   x y "string" #RRGGBB[AA]         baseline-anchored DE font text
#   glyphs x y "string" #RRGGBB[AA] [b]     monospace 8x16 cell text (b=bold)
#   line   x1 y1 x2 y2 <thick> #RRGGBB[AA]  stroked segment
#   stroke x y w h <thick> #RRGGBB[AA]      unfilled rectangle outline
# Colours are passed as NUL-terminated "#RRGGBB"/"#RRGGBBAA" C-strings.
#
# This file has NO `extern` and imports NOTHING, so it links into BOTH the
# x86_64-adder-user (native) target and the x86_64-linux (host) target.


# ====================================================================
# Small, self-contained string helpers (extern-free). lib/hamui.ad keeps
# its own _h_* copies for its markup/path code; these _hs_* copies keep
# this module standalone so it never depends on hamui's native-only file.
# ====================================================================

def _hs_strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _hs_u32_to_dec(value: uint32, out: Ptr[uint8]) -> uint64:
    # Decimal, no newline. Returns digit count.
    if value == 0:
        out[0] = 48
        return 1
    digits: Array[16, uint8]
    n: uint64 = 0
    v: uint32 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return written


def _hs_i32_to_dec(value: int32, out: Ptr[uint8]) -> uint64:
    if value < 0:
        out[0] = 45                                  # '-'
        return 1 + _hs_u32_to_dec(cast[uint32](0 - value), &out[1])
    return _hs_u32_to_dec(cast[uint32](value), &out[0])


def _hs_putc(buf: Ptr[uint8], pos: uint64, c: uint8) -> uint64:
    buf[pos] = c
    return pos + 1


def _hs_puts(buf: Ptr[uint8], pos: uint64, s: Ptr[uint8]) -> uint64:
    p: uint64 = pos
    k: uint64 = 0
    while s[k] != 0:
        buf[p] = s[k]
        p = p + 1
        k = k + 1
    return p


# ====================================================================
# The display-list buffer. Sized to the kernel's per-window scene cap
# (WSYS_SCENE_SIZE = 16384 in devwsys.ad): a full display list — including
# the desktop's downsampled image-wallpaper backdrop grid plus icons — must
# fit in one scene write, so the client buffer matches the kernel ceiling.
# ====================================================================
HAMSCENE_CAP: uint64 = 16384
hamscene_buf: Array[16384, uint8]
hamscene_len: uint64 = 0


def _hs_room(extra: uint64) -> int32:
    # 1 if `extra` bytes still fit (leave 1 byte slack).
    if hamscene_len + extra + 1 <= HAMSCENE_CAP:
        return 1
    return 0


# ---- buffer accessors (so the native sink in lib/hamui.ad reads the buffer
# ---- without a cross-module variable reference) --------------------------
def hamscene_bufptr() -> Ptr[uint8]:
    return &hamscene_buf[0]


def hamscene_length() -> uint64:
    return hamscene_len


# ====================================================================
# Primitive builders — each appends one grammar line to hamscene_buf.
# ====================================================================

def hamscene_begin():
    # Start a fresh display list. A leading version comment keeps the file
    # self-describing (and the gate's `# scene v1` grep happy).
    hamscene_len = 0
    hamscene_len = _hs_puts(&hamscene_buf[0], hamscene_len, "# scene v1 hamui\n")


def hamscene_fill(x: int32, y: int32, w: int32, h: int32, color: Ptr[uint8]):
    # `fill x y w h #RRGGBB[AA]` — a solid rectangle.
    if _hs_room(96) == 0:
        return
    p: uint64 = hamscene_len
    p = _hs_puts(&hamscene_buf[0], p, "fill ")
    p = p + _hs_i32_to_dec(x, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(y, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(w, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(h, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = _hs_puts(&hamscene_buf[0], p, color)
    p = _hs_putc(&hamscene_buf[0], p, 10)
    hamscene_len = p


def hamscene_rect(x: int32, y: int32, w: int32, h: int32, color: Ptr[uint8]):
    # `rect x y w h #RRGGBB[AA]` — semantic filled box (alias of fill).
    if _hs_room(96) == 0:
        return
    p: uint64 = hamscene_len
    p = _hs_puts(&hamscene_buf[0], p, "rect ")
    p = p + _hs_i32_to_dec(x, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(y, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(w, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(h, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = _hs_puts(&hamscene_buf[0], p, color)
    p = _hs_putc(&hamscene_buf[0], p, 10)
    hamscene_len = p


def _hs_emit_str(p: uint64, s: Ptr[uint8]) -> uint64:
    # Append a quoted, sanitized string (quote/newline -> space).
    q: uint64 = p
    q = _hs_putc(&hamscene_buf[0], q, 34)                # opening quote
    k: uint64 = 0
    while s[k] != 0 and _hs_room(8) == 1:
        c: uint8 = s[k]
        if c == 34 or c == 10:
            c = 32
        q = _hs_putc(&hamscene_buf[0], q, c)
        k = k + 1
    q = _hs_putc(&hamscene_buf[0], q, 34)                # closing quote
    return q


def hamscene_text(x: int32, y: int32, s: Ptr[uint8], color: Ptr[uint8]):
    # `text x y "string" #RRGGBB[AA]` — baseline-anchored DE font text.
    if _hs_room(64 + _hs_strlen(s)) == 0:
        return
    p: uint64 = hamscene_len
    p = _hs_puts(&hamscene_buf[0], p, "text ")
    p = p + _hs_i32_to_dec(x, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(y, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = _hs_emit_str(p, s)
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = _hs_puts(&hamscene_buf[0], p, color)
    p = _hs_putc(&hamscene_buf[0], p, 10)
    hamscene_len = p


def hamscene_glyphs(x: int32, y: int32, s: Ptr[uint8], color: Ptr[uint8]):
    # `glyphs x y "string" #RRGGBB[AA]` — monospace cell text.
    if _hs_room(64 + _hs_strlen(s)) == 0:
        return
    p: uint64 = hamscene_len
    p = _hs_puts(&hamscene_buf[0], p, "glyphs ")
    p = p + _hs_i32_to_dec(x, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(y, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = _hs_emit_str(p, s)
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = _hs_puts(&hamscene_buf[0], p, color)
    p = _hs_putc(&hamscene_buf[0], p, 10)
    hamscene_len = p


def hamscene_glyphs_bold(x: int32, y: int32, s: Ptr[uint8], color: Ptr[uint8]):
    # `glyphs x y "string" #RRGGBB[AA] b` — monospace cell text with a trailing
    # `b` weight flag so the compositor DOUBLE-STRIKES each glyph (draws it
    # again shifted +1px in x, OR-ing the bits) for a heavier look. Older
    # readers that stop at the colour ignore it (forward-compatible).
    if _hs_room(66 + _hs_strlen(s)) == 0:
        return
    p: uint64 = hamscene_len
    p = _hs_puts(&hamscene_buf[0], p, "glyphs ")
    p = p + _hs_i32_to_dec(x, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(y, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = _hs_emit_str(p, s)
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = _hs_puts(&hamscene_buf[0], p, color)
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = _hs_putc(&hamscene_buf[0], p, 98)              # 'b' weight flag
    p = _hs_putc(&hamscene_buf[0], p, 10)
    hamscene_len = p


def hamscene_line(x1: int32, y1: int32, x2: int32, y2: int32,
                  thick: int32, color: Ptr[uint8]):
    # `line x1 y1 x2 y2 <thickness> #RRGGBB[AA]` — a stroked segment.
    if _hs_room(112) == 0:
        return
    p: uint64 = hamscene_len
    p = _hs_puts(&hamscene_buf[0], p, "line ")
    p = p + _hs_i32_to_dec(x1, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(y1, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(x2, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(y2, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(thick, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = _hs_puts(&hamscene_buf[0], p, color)
    p = _hs_putc(&hamscene_buf[0], p, 10)
    hamscene_len = p


def hamscene_stroke(x: int32, y: int32, w: int32, h: int32,
                    thick: int32, color: Ptr[uint8]):
    # `stroke x y w h <thickness> #RRGGBB[AA]` — an UNFILLED rectangle outline.
    if _hs_room(112) == 0:
        return
    p: uint64 = hamscene_len
    p = _hs_puts(&hamscene_buf[0], p, "stroke ")
    p = p + _hs_i32_to_dec(x, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(y, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(w, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(h, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = p + _hs_i32_to_dec(thick, &hamscene_buf[p])
    p = _hs_putc(&hamscene_buf[0], p, 32)
    p = _hs_puts(&hamscene_buf[0], p, color)
    p = _hs_putc(&hamscene_buf[0], p, 10)
    hamscene_len = p


# --------------------------------------------------------------------
# Scene APPLET helpers — small reusable chrome for a MATE-style panel.
# Composed from fill/stroke/glyphs so a panel applet is a one-call draw.
# --------------------------------------------------------------------

# A raised toolbar/launcher BUTTON: a filled face + a 1px outline, with an
# optional pressed/hover sink (sunk != 0 darkens the face). Returns nothing;
# the caller draws its own label/glyph on top.
def hamscene_panel_button(x: int32, y: int32, w: int32, h: int32, sunk: int32):
    face: Ptr[uint8] = cast[Ptr[uint8]]("#c8c4bc")
    if sunk != 0:
        face = cast[Ptr[uint8]]("#b4b0a8")
    hamscene_fill(x, y, w, h, face)
    hamscene_stroke(x, y, w, h, 1, cast[Ptr[uint8]]("#808080"))


# A horizontal BAR METER (e.g. CPU / memory load): a sunken trough with a
# coloured fill proportional to pct (0..100). Used by the sysmon applet.
# `fillcol` is the bar colour ("#RRGGBB"). The trough is dark; a 1px frame
# keeps it crisp against the light panel.
def hamscene_hbar(x: int32, y: int32, w: int32, h: int32, pct: int32,
                  fillcol: Ptr[uint8]):
    p: int32 = pct
    if p < 0:
        p = 0
    if p > 100:
        p = 100
    hamscene_fill(x, y, w, h, cast[Ptr[uint8]]("#404040"))
    fw: int32 = (w * p) / 100
    if fw > 0:
        hamscene_fill(x, y, fw, h, fillcol)
    hamscene_stroke(x, y, w, h, 1, cast[Ptr[uint8]]("#202020"))


# --------------------------------------------------------------------
# Scene ICON helpers — recognizable folder / document glyphs composed
# entirely from the fill/rect/line scene verbs (no bitmap/image tier).
# Drawn into the box (x,y,w,h); intended sizes ~32-48px.
# --------------------------------------------------------------------

# Classic tab-folder: a back tab rect, the folder body, and a slightly
# darker open-lip band + outline so it reads as a folder, not a plain box.
#   body  = #e8b94e (manila), tab = #d9a838, edge/outline = #9c7416.
def hamscene_icon_folder(x: int32, y: int32, w: int32, h: int32):
    body: Ptr[uint8] = cast[Ptr[uint8]]("#e8b94e")
    tabc: Ptr[uint8] = cast[Ptr[uint8]]("#d9a838")
    edge: Ptr[uint8] = cast[Ptr[uint8]]("#9c7416")
    lip: Ptr[uint8] = cast[Ptr[uint8]]("#f4d27a")
    # Geometry: leave a little vertical margin; the tab sits on top-left.
    tab_h: int32 = h / 5
    if tab_h < 4:
        tab_h = 4
    tab_w: int32 = (w * 2) / 5
    body_y: int32 = y + tab_h
    body_h: int32 = h - tab_h
    # Back tab (drawn first so the body overlaps its base).
    hamscene_fill(x, y, tab_w, tab_h + 2, tabc)
    # Folder body.
    hamscene_fill(x, body_y, w, body_h, body)
    # Open-lip highlight band near the top of the body.
    hamscene_fill(x, body_y, w, body_h / 5, lip)
    # Outline: body box + tab top, so the shape is crisp.
    hamscene_line(x, body_y, x + w - 1, body_y, 1, edge)            # top
    hamscene_line(x, body_y, x, y + h - 1, 1, edge)                 # left
    hamscene_line(x + w - 1, body_y, x + w - 1, y + h - 1, 1, edge) # right
    hamscene_line(x, y + h - 1, x + w - 1, y + h - 1, 1, edge)      # bottom
    hamscene_line(x, y, x + tab_w, y, 1, edge)                      # tab top
    hamscene_line(x, y, x, body_y, 1, edge)                         # tab left
    hamscene_line(x + tab_w, y, x + tab_w, body_y, 1, edge)         # tab right


# Document / page icon: a white page with a dog-eared top-right corner
# (drawn as a notch fill + two fold lines) and a few grey "text line"
# rects. `tint` recolors the page body for a coarse file class.
def hamscene_icon_file(x: int32, y: int32, w: int32, h: int32,
                       tint: Ptr[uint8]):
    edge: Ptr[uint8] = cast[Ptr[uint8]]("#8a8a8a")
    fold: Ptr[uint8] = cast[Ptr[uint8]]("#c8c8c8")
    textc: Ptr[uint8] = cast[Ptr[uint8]]("#a9b7c6")
    # Inset so a 32-48px cell leaves the page a touch narrower than a folder.
    px: int32 = x + w / 6
    pw: int32 = (w * 2) / 3
    py: int32 = y
    ph: int32 = h
    ear: int32 = pw / 3
    if ear < 4:
        ear = 4
    # Page body.
    hamscene_fill(px, py, pw, ph, tint)
    # Dog-ear: clear the top-right corner with the fold color.
    hamscene_fill(px + pw - ear, py, ear, ear, fold)
    hamscene_line(px + pw - ear, py, px + pw - 1, py + ear, 1, edge)  # fold diag
    hamscene_line(px + pw - ear, py, px + pw - ear, py + ear, 1, edge)
    hamscene_line(px + pw - ear, py + ear, px + pw - 1, py + ear, 1, edge)
    # Page outline.
    hamscene_line(px, py, px + pw - 1 - ear, py, 1, edge)            # top (to ear)
    hamscene_line(px, py, px, py + ph - 1, 1, edge)                  # left
    hamscene_line(px + pw - 1, py + ear, px + pw - 1, py + ph - 1, 1, edge)  # right
    hamscene_line(px, py + ph - 1, px + pw - 1, py + ph - 1, 1, edge)  # bottom
    # A few "text line" rects across the page.
    lx: int32 = px + 4
    lw: int32 = pw - 8
    ly: int32 = py + ear + 4
    n: int32 = 0
    while n < 3 and ly + 2 < py + ph - 3:
        ww: int32 = lw
        if n == 2:
            ww = (lw * 2) / 3
        hamscene_fill(lx, ly, ww, 2, textc)
        ly = ly + 6
        n = n + 1

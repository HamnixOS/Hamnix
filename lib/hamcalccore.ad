# lib/hamcalccore.ad — the PURE, target-agnostic core of the calculator
# scene app.
#
# WHY (dual-target seam, see docs/hamui_dual_target.md)
# =====================================================
# The arithmetic/keypad STATE MACHINE (acc/operand/pending/'='/'C'/div-by-zero
# ERR), the resize-aware LAYOUT, the scene DISPLAY-LIST builder, and the pure
# keyboard+pointer INPUT handlers — everything EXCEPT the Hamnix-only wsys
# window transport. Factored out of user/hamcalcscene.ad exactly like
# lib/ham2048core.ad / lib/htmlengine.ad, so the SAME code drives both the
# native sink (hamscene_commit -> /dev/wsys) and the host sink (lib/hamui_host
# rasterizer -> PNG). Imports ONLY lib/hamscene.ad (the pure builder), has NO
# `extern`, and links into both the native and x86_64-linux targets.
# Behaviour is identical to the pre-split app.

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_glyphs, hamscene_stroke, hamscene_panel_button


# ---- tiny pure helpers (shared with the native driver) -------------------
def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# ====================================================================
# CALCULATOR STATE
# ====================================================================
acc:      int64 = 0
operand:  int64 = 0
pending:  int32 = 0           # 0=none 1='+' 2='-' 3='*' 4='/'
entering: int32 = 0
err:      int32 = 0
show_res: int32 = 0
opdigits: int32 = 0
MAXDIGITS: int32 = 15

disp_buf: Array[32, uint8]


# int64 -> decimal into disp_buf, NUL-terminated. "ERR" while latched.
def _c_render(v: int64):
    if err != 0:
        disp_buf[0] = 69                # 'E'
        disp_buf[1] = 82                # 'R'
        disp_buf[2] = 82                # 'R'
        disp_buf[3] = 0
        return
    if v == 0:
        disp_buf[0] = 48                # '0'
        disp_buf[1] = 0
        return
    neg: int32 = 0
    uv: uint64 = 0
    if v < 0:
        neg = 1
        uv = cast[uint64](0 - v)
    else:
        uv = cast[uint64](v)
    tmp: Array[24, uint8]
    t: uint64 = 0
    while uv != 0:
        tmp[t] = cast[uint8](uv % 10) + 48
        uv = uv / 10
        t = t + 1
    p: uint64 = 0
    if neg != 0:
        disp_buf[p] = 45                # '-'
        p = p + 1
    while t > 0:
        t = t - 1
        disp_buf[p] = tmp[t]
        p = p + 1
    disp_buf[p] = 0


# Refresh disp_buf to the currently-shown value (result vs live operand).
def _c_refresh():
    if show_res != 0 or entering == 0:
        _c_render(acc)
    else:
        _c_render(operand)


def _c_clear():
    acc = 0
    operand = 0
    pending = 0
    entering = 0
    err = 0
    show_res = 1
    opdigits = 0


def _c_digit(d: int32):
    if err != 0:
        return
    if entering == 0:
        operand = 0
        opdigits = 0
        entering = 1
        show_res = 0
    if opdigits >= MAXDIGITS:
        return
    operand = operand * 10 + cast[int64](d)
    opdigits = opdigits + 1


def _c_apply():
    if pending == 0:
        acc = operand
        return
    if pending == 1:
        acc = acc + operand
    elif pending == 2:
        acc = acc - operand
    elif pending == 3:
        acc = acc * operand
    elif pending == 4:
        if operand == 0:
            err = 1
            return
        acc = acc / operand


def _c_operator(op: int32):
    if err != 0:
        return
    if entering != 0:
        _c_apply()
    pending = op
    entering = 0
    show_res = 1
    operand = 0
    opdigits = 0


def _c_equals():
    if err != 0:
        return
    if entering != 0:
        _c_apply()
    pending = 0
    entering = 0
    show_res = 1
    operand = 0
    opdigits = 0


# PUBLIC lifecycle + state getters (for native driver + host assertions).
def hamcalc_clear():
    _c_clear()


def hamcalc_acc() -> int64:
    return acc


def hamcalc_err() -> int32:
    return err


# Refresh + return a pointer to the NUL-terminated display string.
def hamcalc_display() -> Ptr[uint8]:
    _c_refresh()
    return &disp_buf[0]


# ====================================================================
# LAYOUT + RENDER
# ====================================================================
CALC_W: int32 = 188              # initial default width
CALC_H: int32 = 248              # initial default height
calc_w: int32 = 188              # current content width  (resize-derived)
calc_h: int32 = 248              # current content height (resize-derived)

DISP_X: int32 = 8
DISP_Y: int32 = 8
DISP_W: int32 = 172
DISP_H: int32 = 40
GRID_X: int32 = 8
GRID_Y: int32 = 56
KEY_W: int32 = 40
KEY_H: int32 = 40
KEY_GAP: int32 = 4


def hamcalc_layout():
    # Recompute the display-bar + keypad geometry to FILL the current content
    # area (calc_w x calc_h); everything centered so a maximized calculator
    # has no black quadrants.
    pad: int32 = 8
    gap: int32 = 4
    disp_h: int32 = calc_h / 6
    if disp_h < 32:
        disp_h = 32
    if disp_h > 120:
        disp_h = 120
    DISP_X = pad
    DISP_Y = pad
    DISP_W = calc_w - pad * 2
    if DISP_W < 16:
        DISP_W = 16
    DISP_H = disp_h
    grid_top: int32 = DISP_Y + DISP_H + pad
    avail_w: int32 = calc_w - pad * 2
    avail_h: int32 = calc_h - grid_top - pad
    if avail_w < 16:
        avail_w = 16
    if avail_h < 16:
        avail_h = 16
    KEY_GAP = gap
    kw: int32 = (avail_w - gap * 3) / 4
    kh: int32 = (avail_h - gap * 3) / 4
    if kw < 8:
        kw = 8
    if kh < 8:
        kh = 8
    KEY_W = kw
    KEY_H = kh
    grid_w: int32 = kw * 4 + gap * 3
    grid_h: int32 = kh * 4 + gap * 3
    GRID_X = pad + (avail_w - grid_w) / 2
    GRID_Y = grid_top + (avail_h - grid_h) / 2


def _calc_apply_resize(nw: int64, nh: int64) -> int32:
    if nw < 80:
        nw = 80
    if nh < 100:
        nh = 100
    if cast[int32](nw) == calc_w and cast[int32](nh) == calc_h:
        return 0
    calc_w = cast[int32](nw)
    calc_h = cast[int32](nh)
    hamcalc_layout()
    return 1


# Transient pressed-key highlight (so a click visibly "sinks" the button).
press_key: int32 = -1

# Key model: 16 keys in a 4x4 grid. kind: 0=digit 1=op 2=equals 3=clear.
key_label: Array[16, uint8]            # one ASCII glyph per key
key_kind:  Array[16, int32]
key_val:   Array[16, int32]            # digit value, or op code


def _set_key(i: int32, glyph: uint8, kind: int32, val: int32):
    key_label[i] = glyph
    key_kind[i] = kind
    key_val[i] = val


# PUBLIC: initialise the keypad model (row0: 7 8 9 /, ... row3: C 0 = +).
def hamcalc_init():
    _set_key(0, 55, 0, 7)              # '7'
    _set_key(1, 56, 0, 8)
    _set_key(2, 57, 0, 9)
    _set_key(3, 47, 1, 4)             # '/'
    _set_key(4, 52, 0, 4)
    _set_key(5, 53, 0, 5)
    _set_key(6, 54, 0, 6)
    _set_key(7, 42, 1, 3)             # '*'
    _set_key(8, 49, 0, 1)
    _set_key(9, 50, 0, 2)
    _set_key(10, 51, 0, 3)
    _set_key(11, 45, 1, 2)            # '-'
    _set_key(12, 67, 3, 0)            # 'C'
    _set_key(13, 48, 0, 0)            # '0'
    _set_key(14, 61, 2, 0)           # '='
    _set_key(15, 43, 1, 1)           # '+'


def _key_x(i: int32) -> int32:
    col: int32 = i % 4
    return GRID_X + col * (KEY_W + KEY_GAP)


def _key_y(i: int32) -> int32:
    row: int32 = i / 4
    return GRID_Y + row * (KEY_H + KEY_GAP)


# PUBLIC: which key index is at window-local (lx,ly), or -1.
def hamcalc_key_at(lx: int64, ly: int64) -> int64:
    i: int32 = 0
    while i < 16:
        kx: int64 = cast[int64](_key_x(i))
        ky: int64 = cast[int64](_key_y(i))
        if lx >= kx and lx < kx + cast[int64](KEY_W) and \
           ly >= ky and ly < ky + cast[int64](KEY_H):
            return cast[int64](i)
        i = i + 1
    return -1


# PUBLIC: build the whole display list into the shared hamscene buffer (no
# commit — native commits, host rasterizes).
def hamcalc_build_scene():
    hamscene_begin()
    # Body background (calculator case), sized to the current content area.
    hamscene_fill(0, 0, calc_w, calc_h, cast[Ptr[uint8]]("#2b2f36"))
    # Display bar: a sunken dark LCD with the value right-justified-ish.
    hamscene_fill(DISP_X, DISP_Y, DISP_W, DISP_H, cast[Ptr[uint8]]("#0d1410"))
    hamscene_stroke(DISP_X, DISP_Y, DISP_W, DISP_H, 1,
                    cast[Ptr[uint8]]("#5a6a5a"))
    _c_refresh()
    dl: uint64 = _slen(&disp_buf[0])
    tx: int32 = DISP_X + DISP_W - 8 - cast[int32](dl) * 8
    if tx < DISP_X + 6:
        tx = DISP_X + 6
    hamscene_glyphs(tx, DISP_Y + 14, &disp_buf[0],
                    cast[Ptr[uint8]]("#9ff09f"))
    # Button grid.
    i: int32 = 0
    while i < 16:
        kx: int32 = _key_x(i)
        ky: int32 = _key_y(i)
        sunk: int32 = 0
        if i == press_key:
            sunk = 1
        hamscene_panel_button(kx, ky, KEY_W, KEY_H, sunk)
        lbl: Array[2, uint8]
        lbl[0] = key_label[i]
        lbl[1] = 0
        gx: int32 = kx + (KEY_W - 8) / 2
        gy: int32 = ky + (KEY_H - 8) / 2
        col: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
        if key_kind[i] == 1 or key_kind[i] == 2:
            col = cast[Ptr[uint8]]("#7a2a00")          # ops/= in dark orange
        if key_kind[i] == 3:
            col = cast[Ptr[uint8]]("#7a0000")          # clear in red
        hamscene_glyphs(gx, gy, &lbl[0], col)
        i = i + 1


# Apply key index `k` to the state machine.
def _press(k: int64):
    kind: int32 = key_kind[k]
    val: int32 = key_val[k]
    if kind == 0:
        _c_digit(val)
    elif kind == 1:
        _c_operator(val)
    elif kind == 2:
        _c_equals()
    elif kind == 3:
        _c_clear()


# PUBLIC: apply the key at index k AND latch the sink highlight.
def hamcalc_press_at(k: int64):
    _press(k)
    press_key = cast[int32](k)


# PUBLIC: clear the sink highlight (release edge). Returns 1 if a sink was
# actually cleared (so the caller only re-commits when something changed).
def hamcalc_release() -> int32:
    if press_key >= 0:
        press_key = -1
        return 1
    return 0


# Map an ASCII byte to a state-machine action; returns 1 if it changed state.
def _press_kbd(c: uint8) -> int32:
    if c >= 48 and c <= 57:                 # '0'..'9'
        _c_digit(cast[int32](c) - 48)
        return 1
    if c == 43:                             # '+'
        _c_operator(1)
        return 1
    if c == 45:                             # '-'
        _c_operator(2)
        return 1
    if c == 42:                             # '*'
        _c_operator(3)
        return 1
    if c == 47:                             # '/'
        _c_operator(4)
        return 1
    if c == 61 or c == 10 or c == 13:       # '=' / Enter (NL/CR)
        _c_equals()
        return 1
    if c == 99 or c == 67 or c == 27:       # 'c' / 'C' / Esc -> clear
        _c_clear()
        return 1
    if c == 8 or c == 127:                  # Backspace / DEL -> drop last digit
        if err == 0 and entering != 0 and opdigits > 0:
            operand = operand / 10
            opdigits = opdigits - 1
            if opdigits == 0:
                entering = 0
                show_res = 1
            return 1
        return 0
    # '.' (46) and any other byte: integer calculator, ignore.
    return 0


# PUBLIC: parse one "<type> <code>" key line; on a press ('d') apply the byte.
def hamcalc_key_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 100:                # 'd' = press; ignore 'u' release
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    neg: int32 = 0
    if i < n and s[i] == 45:
        neg = 1
        i = i + 1
    code: int32 = 0
    got: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        code = code * 10 + cast[int32](s[i]) - 48
        i = i + 1
        got = 1
    if got == 0:
        return 0
    if neg != 0:
        code = 0 - code
    if code < 0 or code > 255:
        return 0
    return _press_kbd(cast[uint8](code))


# PUBLIC: parse "r <w> <h>" resize line; apply. Returns 1 if applied.
def hamcalc_resize_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 114:                # 'r'
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    wv: int64 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        wv = wv * 10 + cast[int64](s[i]) - 48
        i = i + 1
    while i < n and s[i] == 32:
        i = i + 1
    hv: int64 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        hv = hv * 10 + cast[int64](s[i]) - 48
        i = i + 1
    if wv <= 0 or hv <= 0:
        return 0
    return _calc_apply_resize(wv, hv)


# PUBLIC: parse "m <x> <y> <buttons> ..." -> 1 + fills bx/by/bbtn; else 0.
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                            # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc2: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc2 = acc2 * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc2 = 0 - acc2
        vals[v] = acc2
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1

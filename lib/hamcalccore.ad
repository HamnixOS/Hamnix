# lib/hamcalccore.ad — the PURE, target-agnostic core of the calculator
# scene app.
#
# WHY (dual-target seam, see docs/hamui_dual_target.md)
# =====================================================
# The arithmetic/keypad STATE MACHINE, the resize-aware LAYOUT, the scene
# DISPLAY-LIST builder, and the pure keyboard+pointer INPUT handlers —
# everything EXCEPT the Hamnix-only wsys window transport. Factored out of
# user/hamcalcscene.ad exactly like lib/ham2048core.ad / lib/htmlengine.ad, so
# the SAME code drives both the native sink (hamscene_commit -> /dev/wsys) and
# the host sink (lib/hamui_host rasterizer -> PNG). Imports ONLY
# lib/hamscene.ad (the pure builder), has NO `extern`, and links into both the
# native and x86_64-linux targets.
#
# NUMBER MODEL — FIXED POINT (int64, extern-free, no FPU)
# =======================================================
# A real value r is stored as the int64 `r * SCALE` with SCALE = 1_000_000 (6
# decimal places). All arithmetic — including sqrt / reciprocal / percent — is
# done with integer ops (see _fp_mul/_fp_div/_fp_sqrt), so the calculator
# behaves IDENTICALLY under the seed Python compiler and the self-hosted native
# compiler (no reliance on float codegen). This gives correct decimal-point
# entry, √, 1/x, x², ± and % without any `extern` float.

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_glyphs, hamscene_stroke, hamscene_panel_button


# ---- tiny pure helpers (shared with the native driver) -------------------
def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# ====================================================================
# FIXED-POINT ARITHMETIC (all int64; SCALE = 10^6)
# ====================================================================
SCALE:  int64 = 1000000
SCALE10: int64 = 100000            # SCALE / 10
FRACMAX: int32 = 6                 # max fractional digits entered/shown


# Integer square root of n (n >= 0) via Newton's method.
def _isqrt(n: int64) -> int64:
    if n <= 0:
        return 0
    if n < 4:
        return 1
    r: int64 = n
    y: int64 = (r + 1) / 2
    while y < r:
        r = y
        y = (r + n / r) / 2
    return r


# Fixed-point multiply: (a/SCALE) * (b/SCALE) -> result/SCALE. Split into
# hi/lo parts so ordinary-range products don't overflow int64.
def _fp_mul(a: int64, b: int64) -> int64:
    sign: int64 = 1
    aa: int64 = a
    bb: int64 = b
    if aa < 0:
        sign = 0 - sign
        aa = 0 - aa
    if bb < 0:
        sign = 0 - sign
        bb = 0 - bb
    ah: int64 = aa / SCALE
    al: int64 = aa % SCALE
    bh: int64 = bb / SCALE
    bl: int64 = bb % SCALE
    r: int64 = SCALE * ah * bh + ah * bl + al * bh + (al * bl) / SCALE
    return sign * r


# Fixed-point divide: (a/SCALE) / (b/SCALE) -> result/SCALE. Long division of
# the remainder gives FRACMAX fractional digits without overflow. Latches err
# on divide-by-zero.
def _fp_div(a: int64, b: int64) -> int64:
    if b == 0:
        err = 1
        return 0
    sign: int64 = 1
    aa: int64 = a
    bb: int64 = b
    if aa < 0:
        sign = 0 - sign
        aa = 0 - aa
    if bb < 0:
        sign = 0 - sign
        bb = 0 - bb
    ip: int64 = aa / bb
    rem: int64 = aa % bb
    res: int64 = ip * SCALE
    f: int64 = SCALE10
    k: int32 = 0
    while k < 6:
        rem = rem * 10
        d: int64 = rem / bb
        rem = rem % bb
        res = res + d * f
        f = f / 10
        k = k + 1
    return sign * res


# Fixed-point sqrt: sqrt(a/SCALE) -> result/SCALE = isqrt(a*SCALE). Latches
# err on a negative radicand or out-of-range magnitude.
def _fp_sqrt(a: int64) -> int64:
    if a < 0:
        err = 1
        return 0
    if a > 9000000000000:              # keep a*SCALE inside int64
        err = 1
        return 0
    return _isqrt(a * SCALE)


# ====================================================================
# CALCULATOR STATE
# ====================================================================
# acc  : scaled left-hand / running value (folded via `pending`)
# disp : scaled value CURRENTLY shown (the live entry, or a computed result)
# pending: 0=none 1='+' 2='-' 3='*' 4='/'
# entering: 1 while digits are being typed into the entry (drives the
#           as-typed display formatting + backspace); 0 for computed results.
acc:      int64 = 0
disp:     int64 = 0
pending:  int32 = 0
entering: int32 = 0
err:      int32 = 0

# Live-entry fields (only meaningful while entering != 0) — kept so the LCD can
# show exactly what was typed (trailing '.', trailing zeros) and backspace can
# edit a character at a time.
ent_int:     int64 = 0             # integer-part accumulator (unscaled)
ent_frac:    int64 = 0             # fractional digits as an integer
ent_fracdiv: int64 = 1            # 10^ent_fdigits
ent_fdigits: int32 = 0             # number of fractional digits entered
ent_dot:     int32 = 0             # decimal point pressed
ent_neg:     int32 = 0             # sign of the live entry

disp_buf: Array[40, uint8]

# #329: running-EXPRESSION accumulator. The LCD shows what you TYPE — `5`,
# then `5+`, then `5+5` — and only collapses to the result on `=`. expr_buf
# holds the COMMITTED prefix (operands + operator symbols already locked in
# via _c_operator); the live entry is appended by hamcalc_display() while the
# user is still typing the next operand. Cleared on C / CE / `=` (equals shows
# just the result) and on the unary ops (%, sqrt, 1/x, x2), whose result is a
# fresh standalone value.
expr_buf: Array[96, uint8]
expr_len: uint64 = 0
show_buf: Array[160, uint8]


def _expr_reset():
    expr_len = 0
    expr_buf[0] = 0


def _expr_append_cstr(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and expr_len < 94:
        expr_buf[expr_len] = s[i]
        expr_len = expr_len + 1
        i = i + 1
    expr_buf[expr_len] = 0


def _op_char(op: int32) -> uint8:
    if op == 1:
        return 43                       # '+'
    if op == 2:
        return 45                       # '-'
    if op == 3:
        return 42                       # '*'
    return 47                           # '/'


def _entry_reset():
    ent_int = 0
    ent_frac = 0
    ent_fracdiv = 1
    ent_fdigits = 0
    ent_dot = 0
    ent_neg = 0


# Recompute the scaled `disp` from the live-entry fields.
def _entry_recompute():
    fs: int64 = 0
    if ent_fdigits > 0:
        fs = ent_frac * (SCALE / ent_fracdiv)
    v: int64 = ent_int * SCALE + fs
    if ent_neg != 0:
        v = 0 - v
    disp = v


# Render the scaled value v into disp_buf (trailing zeros trimmed, leading
# "0." for pure fractions). "ERR" while latched.
def _render_scaled(v: int64):
    if err != 0:
        disp_buf[0] = 69                # 'E'
        disp_buf[1] = 82                # 'R'
        disp_buf[2] = 82                # 'R'
        disp_buf[3] = 0
        return
    neg: int32 = 0
    uv: uint64 = 0
    if v < 0:
        neg = 1
        uv = cast[uint64](0 - v)
    else:
        uv = cast[uint64](v)
    su: uint64 = cast[uint64](SCALE)
    ip: uint64 = uv / su
    fp: uint64 = uv % su
    p: uint64 = 0
    if neg != 0:
        disp_buf[p] = 45                # '-'
        p = p + 1
    p = p + _u64_to_dec(ip, &disp_buf[p])
    if fp != 0:
        # six zero-padded fractional digits, trailing zeros trimmed.
        fd: Array[6, uint8]
        d: int32 = 5
        x: uint64 = fp
        while d >= 0:
            fd[d] = cast[uint8](x % 10) + 48
            x = x / 10
            d = d - 1
        last: int32 = 5
        while last > 0 and fd[last] == 48:
            last = last - 1
        disp_buf[p] = 46                # '.'
        p = p + 1
        i: int32 = 0
        while i <= last:
            disp_buf[p] = fd[i]
            p = p + 1
            i = i + 1
    disp_buf[p] = 0


# Render exactly what the user typed (keeps a trailing '.' and typed zeros).
def _render_entry():
    p: uint64 = 0
    if ent_neg != 0 and (ent_int != 0 or ent_frac != 0):
        disp_buf[p] = 45                # '-'
        p = p + 1
    p = p + _u64_to_dec(cast[uint64](ent_int), &disp_buf[p])
    if ent_dot != 0:
        disp_buf[p] = 46                # '.'
        p = p + 1
        if ent_fdigits > 0:
            # zero-pad ent_frac to ent_fdigits.
            tmp: Array[6, uint8]
            t: int32 = ent_fdigits
            x: uint64 = cast[uint64](ent_frac)
            while t > 0:
                t = t - 1
                tmp[t] = cast[uint8](x % 10) + 48
                x = x / 10
            j: int32 = 0
            while j < ent_fdigits:
                disp_buf[p] = tmp[j]
                p = p + 1
                j = j + 1
    disp_buf[p] = 0


# Refresh disp_buf to the currently-shown value.
def _c_refresh():
    if err != 0:
        _render_scaled(0)
    elif entering != 0:
        _render_entry()
    else:
        _render_scaled(disp)


# ---- state transitions ---------------------------------------------------
def _expr_last_is_op() -> int32:
    if expr_len == 0:
        return 0
    c: uint8 = expr_buf[expr_len - 1]
    if c == 43 or c == 45 or c == 42 or c == 47:
        return 1
    return 0


def _c_clear():
    acc = 0
    disp = 0
    pending = 0
    entering = 0
    err = 0
    _entry_reset()
    _expr_reset()


def _c_digit(d: int32):
    if err != 0:
        return
    if entering == 0:
        _entry_reset()
        entering = 1
    if ent_dot == 0:
        if ent_int < 1000000000000:
            ent_int = ent_int * 10 + cast[int64](d)
    else:
        if ent_fdigits < FRACMAX:
            ent_frac = ent_frac * 10 + cast[int64](d)
            ent_fracdiv = ent_fracdiv * 10
            ent_fdigits = ent_fdigits + 1
    _entry_recompute()


def _c_dot():
    if err != 0:
        return
    if entering == 0:
        _entry_reset()
        entering = 1
    ent_dot = 1
    _entry_recompute()


def _c_backspace():
    if err != 0:
        return
    if entering == 0:
        return
    if ent_dot != 0 and ent_fdigits > 0:
        ent_fdigits = ent_fdigits - 1
        ent_frac = ent_frac / 10
        ent_fracdiv = ent_fracdiv / 10
    elif ent_dot != 0:
        ent_dot = 0
    elif ent_int != 0:
        ent_int = ent_int / 10
    else:
        ent_neg = 0
    _entry_recompute()


def _c_clear_entry():
    # CE: clear only the current entry to 0; keep acc + pending op. The
    # running-expression prefix is dropped so the LCD reads a clean "0".
    err = 0
    _entry_reset()
    _expr_reset()
    entering = 1
    disp = 0


def _apply(op: int32, a: int64, b: int64) -> int64:
    if op == 1:
        return a + b
    if op == 2:
        return a - b
    if op == 3:
        return _fp_mul(a, b)
    if op == 4:
        return _fp_div(a, b)
    return b


def _c_operator(op: int32):
    if err != 0:
        return
    # #329: fold the currently-shown operand into the running expression
    # BEFORE the math mutates disp / wipes the entry fields. While entering,
    # the operand is the live entry; otherwise it is the shown disp (a fresh
    # start or a just-computed result). Pressing a second operator without a
    # new entry (e.g. `5 + *`) just swaps the trailing operator symbol.
    if entering == 0 and _expr_last_is_op() != 0:
        expr_buf[expr_len - 1] = _op_char(op)
    else:
        _c_refresh()                            # disp_buf = operand as shown
        _expr_append_cstr(&disp_buf[0])
        b: Array[2, uint8]
        b[0] = _op_char(op)
        b[1] = 0
        _expr_append_cstr(&b[0])
    if entering != 0:
        if pending == 0:
            acc = disp
        else:
            acc = _apply(pending, acc, disp)
        entering = 0
    else:
        acc = disp
    pending = op
    disp = acc
    _entry_reset()


def _c_equals():
    if err != 0:
        return
    if entering != 0:
        if pending != 0:
            acc = _apply(pending, acc, disp)
        else:
            acc = disp
        entering = 0
    else:
        if pending != 0:
            acc = _apply(pending, acc, disp)
        else:
            acc = disp
    pending = 0
    disp = acc
    _entry_reset()
    _expr_reset()                       # `=` collapses the LCD to the result


def _c_sign():
    if err != 0:
        return
    if entering != 0:
        if ent_neg != 0:
            ent_neg = 0
        else:
            ent_neg = 1
        _entry_recompute()
    else:
        disp = 0 - disp


def _c_percent():
    # Windows-style percent: for + / - the entry becomes acc x entry%; for
    # x / div and the standalone case the entry is divided by 100 (so
    # `50 %` -> 0.5, `200 + 10 % =` -> 220).
    if err != 0:
        return
    if pending == 1 or pending == 2:
        disp = _fp_mul(acc, disp) / 100
    else:
        disp = disp / 100
    entering = 0
    _entry_reset()
    _expr_reset()                       # unary result is a fresh standalone value


def _c_sqrt():
    if err != 0:
        return
    disp = _fp_sqrt(disp)
    entering = 0
    _entry_reset()
    _expr_reset()


def _c_recip():
    if err != 0:
        return
    disp = _fp_div(SCALE, disp)
    entering = 0
    _entry_reset()
    _expr_reset()


def _c_square():
    if err != 0:
        return
    disp = _fp_mul(disp, disp)
    entering = 0
    _entry_reset()
    _expr_reset()


# PUBLIC lifecycle + state getters (for native driver + host assertions).
def hamcalc_clear():
    _c_clear()


def hamcalc_acc() -> int64:
    return acc


def hamcalc_disp() -> int64:
    return disp


def hamcalc_err() -> int32:
    return err


# Refresh + return a pointer to the NUL-terminated display string.
# #329: when a running expression is active (expr_len > 0) the LCD shows the
# committed prefix ("5+") plus the live entry being typed ("5" -> "5+5"). With
# no active expression it shows the plain value (a fresh operand, or a result
# after `=`). ERR always wins.
def hamcalc_display() -> Ptr[uint8]:
    _c_refresh()
    if err != 0 or expr_len == 0:
        return &disp_buf[0]
    p: uint64 = 0
    i: uint64 = 0
    while i < expr_len and p < 158:
        show_buf[p] = expr_buf[i]
        p = p + 1
        i = i + 1
    # Append the live entry only while the user is typing the next operand;
    # right after an operator (entering == 0) the LCD ends on the symbol ("5+").
    if entering != 0:
        j: uint64 = 0
        while disp_buf[j] != 0 and p < 158:
            show_buf[p] = disp_buf[j]
            p = p + 1
            j = j + 1
    show_buf[p] = 0
    return &show_buf[0]


# ====================================================================
# LAYOUT + RENDER
# ====================================================================
# Keypad is NCOLS x NROWS. Six rows fit the everyday-calculator key set:
#   CE  C   <-  /
#   sqrt %  1/x *
#   7   8   9   -
#   4   5   6   +
#   1   2   3   x2
#   0   .   +/- =
NCOLS: int32 = 4
NROWS: int32 = 6
NKEYS: int32 = 24

CALC_W: int32 = 188
CALC_H: int32 = 300
calc_w: int32 = 188
calc_h: int32 = 300

DISP_X: int32 = 8
DISP_Y: int32 = 8
DISP_W: int32 = 172
DISP_H: int32 = 40
GRID_X: int32 = 8
GRID_Y: int32 = 56
KEY_W: int32 = 40
KEY_H: int32 = 36
KEY_GAP: int32 = 4


def hamcalc_layout():
    # Recompute the display-bar + keypad geometry to FILL the current content
    # area (calc_w x calc_h); everything centered so a maximized calculator
    # has no black quadrants.
    pad: int32 = 8
    gap: int32 = 4
    disp_h: int32 = calc_h / 7
    if disp_h < 32:
        disp_h = 32
    if disp_h > 120:
        disp_h = 120
    DISP_X = pad
    DISP_Y = pad
    DISP_W = calc_w - pad * 2
    if DISP_W < 16:
        DISP_W = 16
    DISP_H = disp_h
    grid_top: int32 = DISP_Y + DISP_H + pad
    avail_w: int32 = calc_w - pad * 2
    avail_h: int32 = calc_h - grid_top - pad
    if avail_w < 16:
        avail_w = 16
    if avail_h < 16:
        avail_h = 16
    KEY_GAP = gap
    kw: int32 = (avail_w - gap * (NCOLS - 1)) / NCOLS
    kh: int32 = (avail_h - gap * (NROWS - 1)) / NROWS
    if kw < 8:
        kw = 8
    if kh < 8:
        kh = 8
    KEY_W = kw
    KEY_H = kh
    grid_w: int32 = kw * NCOLS + gap * (NCOLS - 1)
    grid_h: int32 = kh * NROWS + gap * (NROWS - 1)
    GRID_X = pad + (avail_w - grid_w) / 2
    GRID_Y = grid_top + (avail_h - grid_h) / 2


def _calc_apply_resize(nw: int64, nh: int64) -> int32:
    if nw < 80:
        nw = 80
    if nh < 120:
        nh = 120
    if cast[int32](nw) == calc_w and cast[int32](nh) == calc_h:
        return 0
    calc_w = cast[int32](nw)
    calc_h = cast[int32](nh)
    hamcalc_layout()
    return 1


# Transient pressed-key highlight (so a click visibly "sinks" the button).
press_key: int32 = -1

# Key model: NKEYS keys. kind:
#   0=digit 1=binary-op 2=equals 3=clear-all 5=clear-entry 6=backspace
#   7=dot 8=sign 9=percent 10=sqrt 11=reciprocal 12=square
key_kind:  Array[24, int32]
key_val:   Array[24, int32]            # digit value, or op code


def _set_key(i: int32, kind: int32, val: int32):
    key_kind[i] = kind
    key_val[i] = val


# PUBLIC: initialise the keypad model (6x4 everyday-calculator layout).
def hamcalc_init():
    _set_key(0, 5, 0)                 # CE
    _set_key(1, 3, 0)                 # C
    _set_key(2, 6, 0)                 # <-  backspace
    _set_key(3, 1, 4)                 # /
    _set_key(4, 10, 0)                # sqrt
    _set_key(5, 9, 0)                 # %
    _set_key(6, 11, 0)                # 1/x
    _set_key(7, 1, 3)                 # *
    _set_key(8, 0, 7)                 # 7
    _set_key(9, 0, 8)                 # 8
    _set_key(10, 0, 9)                # 9
    _set_key(11, 1, 2)                # -
    _set_key(12, 0, 4)                # 4
    _set_key(13, 0, 5)                # 5
    _set_key(14, 0, 6)                # 6
    _set_key(15, 1, 1)                # +
    _set_key(16, 0, 1)                # 1
    _set_key(17, 0, 2)                # 2
    _set_key(18, 0, 3)                # 3
    _set_key(19, 12, 0)               # x2  square
    _set_key(20, 0, 0)                # 0
    _set_key(21, 7, 0)                # .
    _set_key(22, 8, 0)                # +/- sign
    _set_key(23, 2, 0)                # =


# The ASCII label string for key `i` (multi-char labels are drawn on the
# fixed 8px monospace grid and centered).
def _key_label(i: int32) -> Ptr[uint8]:
    k: int32 = key_kind[i]
    if k == 0:
        if key_val[i] == 0:
            return cast[Ptr[uint8]]("0")
        if key_val[i] == 1:
            return cast[Ptr[uint8]]("1")
        if key_val[i] == 2:
            return cast[Ptr[uint8]]("2")
        if key_val[i] == 3:
            return cast[Ptr[uint8]]("3")
        if key_val[i] == 4:
            return cast[Ptr[uint8]]("4")
        if key_val[i] == 5:
            return cast[Ptr[uint8]]("5")
        if key_val[i] == 6:
            return cast[Ptr[uint8]]("6")
        if key_val[i] == 7:
            return cast[Ptr[uint8]]("7")
        if key_val[i] == 8:
            return cast[Ptr[uint8]]("8")
        return cast[Ptr[uint8]]("9")
    if k == 1:
        if key_val[i] == 1:
            return cast[Ptr[uint8]]("+")
        if key_val[i] == 2:
            return cast[Ptr[uint8]]("-")
        if key_val[i] == 3:
            return cast[Ptr[uint8]]("*")
        return cast[Ptr[uint8]]("/")
    if k == 2:
        return cast[Ptr[uint8]]("=")
    if k == 3:
        return cast[Ptr[uint8]]("C")
    if k == 5:
        return cast[Ptr[uint8]]("CE")
    if k == 6:
        return cast[Ptr[uint8]]("<-")
    if k == 7:
        return cast[Ptr[uint8]](".")
    if k == 8:
        return cast[Ptr[uint8]]("+/-")
    if k == 9:
        return cast[Ptr[uint8]]("%")
    if k == 10:
        return cast[Ptr[uint8]]("sqrt")
    if k == 11:
        return cast[Ptr[uint8]]("1/x")
    if k == 12:
        return cast[Ptr[uint8]]("x2")
    return cast[Ptr[uint8]](" ")


# Label colour by kind: digits/dot dark, ops/= orange, clear/CE red,
# function keys blue.
def _key_color(i: int32) -> Ptr[uint8]:
    k: int32 = key_kind[i]
    if k == 1 or k == 2:
        return cast[Ptr[uint8]]("#7a2a00")            # ops / = : orange
    if k == 3 or k == 5:
        return cast[Ptr[uint8]]("#7a0000")            # clear / CE : red
    if k == 0 or k == 7:
        return cast[Ptr[uint8]]("#202020")            # digits / '.' : dark
    return cast[Ptr[uint8]]("#00457a")                # function keys : blue


def _key_x(i: int32) -> int32:
    col: int32 = i % NCOLS
    return GRID_X + col * (KEY_W + KEY_GAP)


def _key_y(i: int32) -> int32:
    row: int32 = i / NCOLS
    return GRID_Y + row * (KEY_H + KEY_GAP)


# PUBLIC: which key index is at window-local (lx,ly), or -1.
def hamcalc_key_at(lx: int64, ly: int64) -> int64:
    i: int32 = 0
    while i < NKEYS:
        kx: int64 = cast[int64](_key_x(i))
        ky: int64 = cast[int64](_key_y(i))
        if lx >= kx and lx < kx + cast[int64](KEY_W) and \
           ly >= ky and ly < ky + cast[int64](KEY_H):
            return cast[int64](i)
        i = i + 1
    return -1


# PUBLIC: build the whole display list into the shared hamscene buffer (no
# commit — native commits, host rasterizes).
def hamcalc_build_scene():
    hamscene_begin()
    # Body background (calculator case), sized to the current content area.
    hamscene_fill(0, 0, calc_w, calc_h, cast[Ptr[uint8]]("#2b2f36"))
    # Display bar: a sunken dark LCD with the value right-justified-ish.
    hamscene_fill(DISP_X, DISP_Y, DISP_W, DISP_H, cast[Ptr[uint8]]("#0d1410"))
    hamscene_stroke(DISP_X, DISP_Y, DISP_W, DISP_H, 1,
                    cast[Ptr[uint8]]("#5a6a5a"))
    ds: Ptr[uint8] = hamcalc_display()
    dl: uint64 = _slen(ds)
    tx: int32 = DISP_X + DISP_W - 8 - cast[int32](dl) * 8
    if tx < DISP_X + 6:
        tx = DISP_X + 6
    hamscene_glyphs(tx, DISP_Y + 14, ds,
                    cast[Ptr[uint8]]("#9ff09f"))
    # Button grid.
    i: int32 = 0
    while i < NKEYS:
        kx: int32 = _key_x(i)
        ky: int32 = _key_y(i)
        sunk: int32 = 0
        if i == press_key:
            sunk = 1
        hamscene_panel_button(kx, ky, KEY_W, KEY_H, sunk)
        lbl: Ptr[uint8] = _key_label(i)
        ll: int32 = cast[int32](_slen(lbl))
        gx: int32 = kx + (KEY_W - ll * 8) / 2
        gy: int32 = ky + (KEY_H - 16) / 2
        hamscene_glyphs(gx, gy, lbl, _key_color(i))
        i = i + 1


# Apply key index `k` to the state machine.
def _press(k: int64):
    kind: int32 = key_kind[k]
    val: int32 = key_val[k]
    if kind == 0:
        _c_digit(val)
    elif kind == 1:
        _c_operator(val)
    elif kind == 2:
        _c_equals()
    elif kind == 3:
        _c_clear()
    elif kind == 5:
        _c_clear_entry()
    elif kind == 6:
        _c_backspace()
    elif kind == 7:
        _c_dot()
    elif kind == 8:
        _c_sign()
    elif kind == 9:
        _c_percent()
    elif kind == 10:
        _c_sqrt()
    elif kind == 11:
        _c_recip()
    elif kind == 12:
        _c_square()


# PUBLIC: apply the key at index k AND latch the sink highlight.
def hamcalc_press_at(k: int64):
    _press(k)
    press_key = cast[int32](k)


# PUBLIC: clear the sink highlight (release edge). Returns 1 if a sink was
# actually cleared (so the caller only re-commits when something changed).
def hamcalc_release() -> int32:
    if press_key >= 0:
        press_key = -1
        return 1
    return 0


# Map an ASCII byte to a state-machine action; returns 1 if it changed state.
def _press_kbd(c: uint8) -> int32:
    if c >= 48 and c <= 57:                 # '0'..'9'
        _c_digit(cast[int32](c) - 48)
        return 1
    if c == 43:                             # '+'
        _c_operator(1)
        return 1
    if c == 45:                             # '-'
        _c_operator(2)
        return 1
    if c == 42:                             # '*'
        _c_operator(3)
        return 1
    if c == 47:                             # '/'
        _c_operator(4)
        return 1
    if c == 61 or c == 10 or c == 13:       # '=' / Enter (NL/CR)
        _c_equals()
        return 1
    if c == 99 or c == 67 or c == 27:       # 'c' / 'C' / Esc -> clear
        _c_clear()
        return 1
    if c == 8 or c == 127:                  # Backspace / DEL
        _c_backspace()
        return 1
    if c == 46:                             # '.' decimal point
        _c_dot()
        return 1
    if c == 37:                             # '%' percent
        _c_percent()
        return 1
    if c == 110 or c == 78:                 # 'n' / 'N' -> sign toggle (no ASCII +/-)
        _c_sign()
        return 1
    if c == 115 or c == 83:                 # 's' / 'S' -> sqrt
        _c_sqrt()
        return 1
    if c == 114 or c == 82:                 # 'r' / 'R' -> reciprocal
        _c_recip()
        return 1
    if c == 113 or c == 81:                 # 'q' / 'Q' -> square
        _c_square()
        return 1
    if c == 101 or c == 69:                 # 'e' / 'E' -> clear entry
        _c_clear_entry()
        return 1
    return 0


# PUBLIC: parse one "<type> <code>" key line; on a press ('d') apply the byte.
def hamcalc_key_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 100:                # 'd' = press; ignore 'u' release
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    neg: int32 = 0
    if i < n and s[i] == 45:
        neg = 1
        i = i + 1
    code: int32 = 0
    got: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        code = code * 10 + cast[int32](s[i]) - 48
        i = i + 1
        got = 1
    if got == 0:
        return 0
    if neg != 0:
        code = 0 - code
    if code < 0 or code > 255:
        return 0
    return _press_kbd(cast[uint8](code))


# PUBLIC: parse "r <w> <h>" resize line; apply. Returns 1 if applied.
def hamcalc_resize_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 114:                # 'r'
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    wv: int64 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        wv = wv * 10 + cast[int64](s[i]) - 48
        i = i + 1
    while i < n and s[i] == 32:
        i = i + 1
    hv: int64 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        hv = hv * 10 + cast[int64](s[i]) - 48
        i = i + 1
    if wv <= 0 or hv <= 0:
        return 0
    return _calc_apply_resize(wv, hv)


# PUBLIC: parse "m <x> <y> <buttons> ..." -> 1 + fills bx/by/bbtn; else 0.
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                            # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc2: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc2 = acc2 * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc2 = 0 - acc2
        vals[v] = acc2
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1

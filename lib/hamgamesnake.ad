# lib/hamgamesnake.ad — "Snake", a hamGame arcade game (target-agnostic).
#
# The pygame-shaped twin of lib/hamgamedemo.ad ("Coin Dash"): ALL logic, drawing
# and text go through the PUBLIC lib/hamgame.ad API (Surface fill/rect + font
# render), so this SAME file drives BOTH the device app (user/hamgamesnake.ad)
# and the host render gate (user/hamgamesnake_host.ad). It is extern-free and
# holds NO transport of its own — it never touches a window, a clock or a file.
#
# NOTE ON THE OTHER SNAKE: lib/hamsnakecore.ad is a Snake built on the hamscene
# display-list layer (the 2048/hamscene family). THIS one is the hamGame/hamSDL
# Surface-backbuffer port — the pygame-shaped path — mirroring Coin Dash.
#
# The game: a classic grid Snake. A snake (a list of grid cells) slides one cell
# per step in the current heading; arrow / WASD keys turn it (never a 180). Food
# sits on a free cell; eating it grows the snake by one and scores a point, then
# food respawns via a DETERMINISTIC LCG (fixed seed -> reproducible for the host
# gate). Running into a wall or into itself ends the game.
#
# PERFORMANCE — WHY THIS PORT USED TO SLOW DOWN AS THE SNAKE GREW, AND THE FIX
# ===========================================================================
# The original port paid a cost that GREW with the snake's length every single
# step: it stored the body as a plain array and SHIFTED all N cells down one
# index per move (O(N)), scanned the whole body for self-collision and for a
# free food cell (O(N)), and then REDREW the whole surface plus all N body cells
# (O(W*H + N)). At length 190 that is ~190x the per-step work of length 3, so the
# framerate visibly sagged the more food you collected. The scene-based games
# (hamsnakescene / ham2048) never do this — they only touch what changed.
#
# This port is now O(1) per step, matching them:
#   * RING BUFFER body — the head index advances by one per step; the tail cell
#     simply falls out of the [head .. head-len+1] window. No shifting.
#   * OCCUPANCY GRID (g_occ, one flag per board cell) — self-collision and food
#     placement are O(1) lookups / an occupancy walk bounded by the FIXED board
#     size (never by the snake length).
#   * DAMAGE-RECT rendering — a normal step repaints only the (bounded) handful
#     of cells that actually changed (new head, ex-head-now-body, vacated tail,
#     and on an eat the new food + HUD), marking each via the framework damage
#     accumulator (game_mark_dirty). snk_render_dirty() repaints just those; the
#     full-surface snk_render() runs ONLY on the first frame / restart / a death
#     overlay. So the per-step repaint cost is CONSTANT as the snake grows.

from lib.hamgame import game_rgb, game_display_new, \
    game_surface_fill, game_surface_fill_rect, game_surface_draw_rect, \
    game_surface_draw_text, game_tone_new, game_play_sound_vol, \
    game_mark_dirty, game_damage_reset, \
    GAMEK_LEFT, GAMEK_RIGHT, GAMEK_UP, GAMEK_DOWN


# ---- board geometry ------------------------------------------------------
SNK_CELL: int32 = 16
SNK_COLS: int32 = 14
SNK_ROWS: int32 = 14
SNK_HUD: int32 = 24                                       # top HUD strip (px)
SNK_MAX: int32 = 196                                      # COLS*ROWS cells


# ---- world state ---------------------------------------------------------
snk_w: int32 = 0
snk_h: int32 = 0
snk_display: int32 = -1

# Body cells stored as a RING BUFFER: g_cx/g_cy[ (g_head - k + SNK_MAX) % SNK_MAX ]
# is body segment k (0 = head, g_len-1 = tail). A step advances g_head by one and
# writes the new head there; the old tail index just leaves the window. O(1).
g_cx: Array[196, int32]
g_cy: Array[196, int32]
g_head: int32 = 0                                         # ring index of the head
g_len: int32 = 0

# Occupancy grid: g_occ[row*SNK_COLS + col] == 1 iff a snake segment sits there.
# Maintained incrementally (set new head, clear vacated tail) so collision tests
# and food placement never scan the body.
g_occ: Array[196, int32]

g_dx: int32 = 1                                           # heading (cells/step)
g_dy: int32 = 0

g_food_col: int32 = 0
g_food_row: int32 = 0

g_score: int32 = 0
g_over: int32 = 0
g_step_accum: int32 = 0

g_rng: uint32 = 0                                         # deterministic LCG

SNK_STEP_MS: int32 = 140

# Frame pacing: the render/present of a whole SNK surface is expensive, so the
# driver only redraws when the board actually CHANGED. `snk_dirty` is raised on
# every state mutation (step, eat, death, restart) and drained via
# snk_take_dirty(); the device loop otherwise idles at its frame cap without
# re-uploading an identical surface every tick.
snk_dirty: int32 = 1
# Restart rotates the food PRNG seed so replays are not byte-identical.
snk_games: uint32 = 0

# ---- incremental-render bookkeeping --------------------------------------
# g_full_redraw forces the next render to repaint the WHOLE surface (first frame,
# a restart, or a death — which draws a centred overlay). Otherwise the render
# repaints only the cells recorded in g_dcell_* by the last snk_step. g_hud_dirty
# asks for a HUD-strip repaint (score changed). The dirty-cell list is small and
# FIXED (a step never changes more than a few cells), which is the whole point.
SNK_DCELL_MAX: int32 = 8
g_full_redraw: int32 = 1
g_hud_dirty:   int32 = 0
g_dcell_col: Array[8, int32]
g_dcell_row: Array[8, int32]
g_dcell_n:   int32 = 0

# ---- sound effects (reusable mixer clips via lib/hamgame.ad) --------------
# Each game event replays a distinct square-wave tone. The tone CLIPS are synth'd
# ONCE (lazily, into the fixed handles below) and replayed by handle — NOT
# re-registered per beep, which used to exhaust the 16-clip mixer table and
# silence the game after a handful of events. Deterministic (fixed freq/ms) so
# the host gate can assert on the produced PCM. EAT = a high blip, TURN = a short
# subtle click, OVER = a low, long tone.
SNK_EAT_FREQ:  int32 = 880
SNK_EAT_MS:    int32 = 40
SNK_TURN_FREQ: int32 = 520
SNK_TURN_MS:   int32 = 18
SNK_OVER_FREQ: int32 = 160
SNK_OVER_MS:   int32 = 220

SNK_SFX_EAT:  int32 = 0
SNK_SFX_TURN: int32 = 1
SNK_SFX_OVER: int32 = 2

g_last_tone: int32 = 0                                    # freq of the last beep
g_sfx_ready: int32 = 0                                    # tone clips registered?
g_clip_eat:  int32 = -1
g_clip_turn: int32 = -1
g_clip_over: int32 = -1

_g_score_buf: Array[24, uint8]


# Register the three event tone clips ONCE into the mixer (idempotent per mixer
# generation: cleared by snk_init so a fresh game_mixer_init re-registers them).
def _snk_ensure_sfx():
    if g_sfx_ready == 1:
        return
    g_clip_eat  = game_tone_new(cast[uint32](SNK_EAT_FREQ),
                                cast[uint32](SNK_EAT_MS), 110)
    g_clip_turn = game_tone_new(cast[uint32](SNK_TURN_FREQ),
                                cast[uint32](SNK_TURN_MS), 60)
    g_clip_over = game_tone_new(cast[uint32](SNK_OVER_FREQ),
                                cast[uint32](SNK_OVER_MS), 110)
    g_sfx_ready = 1


# Play a game-event tone by kind (EAT / TURN / OVER) on a mixer voice at full
# voice volume (the amplitude is baked into the clip), and record its frequency
# (so the host gate can cross-check WHICH event sounded alongside the PCM).
def _snk_beep(kind: int32):
    _snk_ensure_sfx()
    clip: int32 = g_clip_eat
    freq: int32 = SNK_EAT_FREQ
    if kind == SNK_SFX_TURN:
        clip = g_clip_turn
        freq = SNK_TURN_FREQ
    elif kind == SNK_SFX_OVER:
        clip = g_clip_over
        freq = SNK_OVER_FREQ
    g_last_tone = freq
    if clip >= 0:
        game_play_sound_vol(clip, 128)


# ---- deterministic PRNG (LCG; fixed seed -> reproducible food) ------------
def _snk_srand(seed: uint32):
    g_rng = seed


def _snk_rand() -> uint32:
    g_rng = g_rng * cast[uint32](1103515245) + cast[uint32](12345)
    return (g_rng >> 16) & cast[uint32](32767)


# ---- occupancy grid (O(1) collision + placement) -------------------------
def _snk_occ_idx(col: int32, row: int32) -> int32:
    return row * SNK_COLS + col


# Is (col,row) currently occupied by a snake segment? O(1) grid lookup.
def _snk_occupied(col: int32, row: int32) -> int32:
    if col < 0 or col >= SNK_COLS or row < 0 or row >= SNK_ROWS:
        return 0
    return g_occ[_snk_occ_idx(col, row)]


def _snk_occ_set(col: int32, row: int32, v: int32):
    if col < 0 or col >= SNK_COLS or row < 0 or row >= SNK_ROWS:
        return
    g_occ[_snk_occ_idx(col, row)] = v


# Ring index of body segment k (0 = head, g_len-1 = tail).
def _snk_seg_idx(k: int32) -> int32:
    return (g_head - k + SNK_MAX) % SNK_MAX


# Place food on a free cell using the LCG. O(board) (a FIXED bound, independent
# of the snake length): pick the k-th currently-free cell, k drawn from the LCG,
# so it lands on a guaranteed-empty square in one occupancy walk.
def _snk_spawn_food():
    free: int32 = SNK_MAX - g_len
    if free <= 0:
        return                                            # board full (win)
    k: int32 = cast[int32](_snk_rand() % cast[uint32](free))
    r: int32 = 0
    while r < SNK_ROWS:
        c: int32 = 0
        while c < SNK_COLS:
            if g_occ[_snk_occ_idx(c, r)] == 0:
                if k == 0:
                    g_food_col = c
                    g_food_row = r
                    return
                k = k - 1
            c = c + 1
        r = r + 1


# ---- incremental damage bookkeeping --------------------------------------
def _snk_dirty_clear():
    g_dcell_n = 0
    game_damage_reset()


# Record that grid cell (col,row) changed: remember it for the incremental
# repaint AND union its pixel rect into the framework damage accumulator.
def _snk_mark_cell(col: int32, row: int32):
    if g_dcell_n < SNK_DCELL_MAX:
        g_dcell_col[g_dcell_n] = col
        g_dcell_row[g_dcell_n] = row
        g_dcell_n = g_dcell_n + 1
    game_mark_dirty(col * SNK_CELL, SNK_HUD + row * SNK_CELL, SNK_CELL, SNK_CELL)


# Initialise a fresh game. `seed` seeds the food PRNG (fixed value = a
# reproducible game for the host gate). The snake starts length 3 heading right
# in the middle row; the FIRST food is placed at a fixed, known cell (same row,
# to the right) so a scripted "step right N times" deterministically eats it —
# every subsequent food comes from the PRNG.
# Reset ONLY the game state (snake, heading, food, score, over, occupancy) to a
# fresh round — WITHOUT touching the display Surface. Shared by snk_init (first
# game) and snk_restart (replay after a game-over), so a death never forces the
# app closed.
def _snk_reset_state(seed: uint32):
    g_score = 0
    g_over = 0
    g_step_accum = 0
    g_dx = 1
    g_dy = 0
    _snk_srand(seed)

    # clear the occupancy grid
    i: int32 = 0
    while i < SNK_MAX:
        g_occ[i] = 0
        i = i + 1

    hc: int32 = SNK_COLS / 3 + 2                          # head start col (5)
    hr: int32 = SNK_ROWS / 2                              # head start row (7)
    # lay the 3 starting cells into the ring: tail at index 0, head at index 2,
    # so _snk_seg_idx(0)=head .. _snk_seg_idx(2)=tail with g_head = 2.
    g_len = 3
    g_head = 2
    g_cx[2] = hc
    g_cy[2] = hr
    g_cx[1] = hc - 1
    g_cy[1] = hr
    g_cx[0] = hc - 2
    g_cy[0] = hr
    _snk_occ_set(hc, hr, 1)
    _snk_occ_set(hc - 1, hr, 1)
    _snk_occ_set(hc - 2, hr, 1)

    g_food_col = hc + 4                                   # fixed first food (9,7)
    g_food_row = hr

    snk_dirty = 1
    g_full_redraw = 1                                     # first frame = full draw
    g_hud_dirty = 0
    _snk_dirty_clear()


def snk_init(w: int32, h: int32, seed: uint32):
    snk_w = w
    snk_h = h
    snk_display = game_display_new(w, h)
    g_sfx_ready = 0                                       # (re)register tones lazily
    _snk_reset_state(seed)


# Start a brand-new round IN PLACE after a game-over (the display Surface stays
# allocated). Rotates the food seed so the replay differs. Public so the driver
# can wire it to a "press to retry" key.
def snk_restart():
    snk_games = snk_games + 1
    _snk_reset_state(cast[uint32](12345) + snk_games * cast[uint32](2654435761))


# Return whether the board changed since the last call, and clear the flag. The
# device driver renders + uploads the surface ONLY when this returns 1.
def snk_take_dirty() -> int32:
    d: int32 = snk_dirty
    snk_dirty = 0
    return d


# Turn the snake. Arrow keys or WASD; a direct 180 into itself is ignored.
def snk_key(key: int32):
    # After a game-over the app STAYS open: r / R / n / N (or Space) starts a
    # fresh round in place instead of the user having to relaunch. Steering keys
    # are ignored until then.
    if g_over == 1:
        if key == 114 or key == 82 or key == 110 or key == 78 or key == 32:
            snk_restart()
        return
    ndx: int32 = g_dx
    ndy: int32 = g_dy
    if key == GAMEK_UP or key == 119 or key == 87:        # up / w / W
        ndx = 0
        ndy = -1
    elif key == GAMEK_DOWN or key == 115 or key == 83:    # down / s / S
        ndx = 0
        ndy = 1
    elif key == GAMEK_LEFT or key == 97 or key == 65:     # left / a / A
        ndx = -1
        ndy = 0
    elif key == GAMEK_RIGHT or key == 100 or key == 68:   # right / d / D
        ndx = 1
        ndy = 0
    else:
        return
    # reject a reversal into the neck
    if ndx == 0 - g_dx and ndy == 0 - g_dy:
        return
    # a real heading change (not a repeat of the current direction) clicks. It
    # does NOT dirty the frame: nothing visual changes until the next step, so
    # there is no reason to re-upload an identical surface for a turn.
    changed: int32 = 0
    if ndx != g_dx or ndy != g_dy:
        changed = 1
    g_dx = ndx
    g_dy = ndy
    if changed == 1 and g_over == 0:
        _snk_beep(SNK_SFX_TURN)


# Advance the snake by ONE grid cell (the deterministic unit the host gate
# drives). Resolves wall / self collision (-> game over), eating (grow + score +
# respawn) and ordinary movement. O(1): a ring-buffer advance + occupancy pokes,
# and it repaints only the handful of cells that changed (via _snk_mark_cell).
def snk_step():
    if g_over == 1:
        return
    _snk_dirty_clear()                                    # fresh per-step damage

    hcx: int32 = g_cx[g_head]                             # current head
    hcy: int32 = g_cy[g_head]
    nhx: int32 = hcx + g_dx
    nhy: int32 = hcy + g_dy

    # wall collision -> game over (full-frame overlay next render)
    if nhx < 0 or nhx >= SNK_COLS or nhy < 0 or nhy >= SNK_ROWS:
        g_over = 1
        snk_dirty = 1
        g_full_redraw = 1
        _snk_beep(SNK_SFX_OVER)
        return

    grow: int32 = 0
    if nhx == g_food_col and nhy == g_food_row:
        grow = 1

    # tail cell (segment g_len-1); it vacates this step unless we grow
    ti: int32 = _snk_seg_idx(g_len - 1)
    tcol: int32 = g_cx[ti]
    trow: int32 = g_cy[ti]

    # self collision: the new head hits a body cell. Landing on the CURRENT tail
    # cell is legal when we are NOT growing (the tail moves out of the way).
    if _snk_occupied(nhx, nhy) == 1:
        if grow == 1 or nhx != tcol or nhy != trow:
            g_over = 1
            snk_dirty = 1
            g_full_redraw = 1
            _snk_beep(SNK_SFX_OVER)
            return

    # --- commit the move (all O(1)) ---
    if grow == 0:
        _snk_occ_set(tcol, trow, 0)                       # tail vacates
        _snk_mark_cell(tcol, trow)                        # repaint as background
    else:
        if g_len < SNK_MAX:
            g_len = g_len + 1

    _snk_mark_cell(hcx, hcy)                              # ex-head -> body colour

    g_head = (g_head + 1) % SNK_MAX                       # ring advance
    g_cx[g_head] = nhx
    g_cy[g_head] = nhy
    _snk_occ_set(nhx, nhy, 1)
    _snk_mark_cell(nhx, nhy)                              # new head
    snk_dirty = 1

    if grow == 1:
        g_score = g_score + 1
        _snk_spawn_food()
        _snk_mark_cell(g_food_col, g_food_row)            # new food cell
        g_hud_dirty = 1                                    # score text changed
        _snk_beep(SNK_SFX_EAT)


# Timer-driven update (device path): accumulate delta-time and step on a fixed
# cadence. The host gate calls snk_step() directly for determinism instead.
def snk_update(dt_ms: int32):
    if g_over == 1:
        return
    g_step_accum = g_step_accum + dt_ms
    while g_step_accum >= SNK_STEP_MS:
        g_step_accum = g_step_accum - SNK_STEP_MS
        snk_step()


# ---- HUD score text (pygame.font via game_surface_draw_text) --------------
def _snk_score_ptr() -> Ptr[uint8]:
    _g_score_buf[0] = 83                                  # 'S'
    _g_score_buf[1] = 99                                  # 'c'
    _g_score_buf[2] = 111                                 # 'o'
    _g_score_buf[3] = 114                                 # 'r'
    _g_score_buf[4] = 101                                 # 'e'
    _g_score_buf[5] = 32                                  # ' '
    n: int32 = 6
    v: int32 = g_score
    if v == 0:
        _g_score_buf[n] = 48
        n = n + 1
    else:
        digs: Array[10, uint8]
        d: int32 = 0
        while v > 0:
            digs[d] = cast[uint8](v % 10) + 48
            v = v / 10
            d = d + 1
        while d > 0:
            d = d - 1
            _g_score_buf[n] = digs[d]
            n = n + 1
    _g_score_buf[n] = 0
    return &_g_score_buf[0]


# ---- render onto the display backbuffer ----------------------------------
def _snk_cell_px_x(col: int32) -> int32:
    return col * SNK_CELL


def _snk_cell_px_y(row: int32) -> int32:
    return SNK_HUD + row * SNK_CELL


# ---- colours (single source of truth for full AND incremental render) -----
def _snk_col_board() -> uint32:
    return game_rgb(24, 28, 40)


def _snk_col_grid() -> uint32:
    return game_rgb(40, 46, 64)


def _snk_col_food() -> uint32:
    return game_rgb(230, 70, 70)


def _snk_col_body() -> uint32:
    return game_rgb(80, 200, 90)


def _snk_col_head() -> uint32:
    return game_rgb(140, 240, 120)


def _snk_col_hud() -> uint32:
    return game_rgb(28, 32, 48)


# Repaint the occupant of ONE grid cell (segment inset, tail-first ordering is
# irrelevant for a single cell). Head vs body chosen from the live head cell.
def _snk_paint_occupant(col: int32, row: int32):
    px: int32 = _snk_cell_px_x(col)
    py: int32 = _snk_cell_px_y(row)
    if col == g_food_col and row == g_food_row:
        game_surface_fill_rect(snk_display, px + 2, py + 2, SNK_CELL - 4,
                               SNK_CELL - 4, _snk_col_food())
        return
    if _snk_occupied(col, row) == 1:
        c: uint32 = _snk_col_body()
        if col == g_cx[g_head] and row == g_cy[g_head]:
            c = _snk_col_head()
        game_surface_fill_rect(snk_display, px + 1, py + 1, SNK_CELL - 2,
                               SNK_CELL - 2, c)


# Repaint a single board cell from scratch: background + the two grid lines that
# belong to it (left + top; the right/bottom belong to neighbours) + occupant.
# Byte-identical to what the full render would have produced for that cell.
def _snk_paint_cell(col: int32, row: int32):
    px: int32 = _snk_cell_px_x(col)
    py: int32 = _snk_cell_px_y(row)
    game_surface_fill_rect(snk_display, px, py, SNK_CELL, SNK_CELL,
                           _snk_col_board())
    gl: uint32 = _snk_col_grid()
    game_surface_fill_rect(snk_display, px, py, 1, SNK_CELL, gl)   # left line
    game_surface_fill_rect(snk_display, px, py, SNK_CELL, 1, gl)   # top line
    _snk_paint_occupant(col, row)


# Repaint the HUD strip (background, frame edge, score text). Bounded cost.
def _snk_paint_hud():
    game_surface_fill_rect(snk_display, 0, 0, snk_w, SNK_HUD, _snk_col_hud())
    game_surface_draw_rect(snk_display, 0, 0, snk_w, SNK_HUD,
                           game_rgb(70, 84, 120))
    game_surface_draw_text(snk_display, _snk_score_ptr(), 6, 4,
                           game_rgb(235, 235, 235))
    if g_over == 1:
        game_surface_draw_text(snk_display,
                               cast[Ptr[uint8]]("GAME OVER"),
                               snk_w / 2 - 36, 4, game_rgb(240, 120, 120))
    game_mark_dirty(0, 0, snk_w, SNK_HUD)


# Full-frame compose: dark backdrop, HUD strip + score, grid lines, food, then
# the snake body (tail..head so the head draws on top), and — when dead — the
# centred game-over overlay. Runs on the first frame / restart / a death. It
# leaves the whole surface as this frame's damage.
def snk_render():
    game_damage_reset()
    game_surface_fill(snk_display, game_rgb(14, 16, 24))
    game_surface_fill_rect(snk_display, 0, SNK_HUD, SNK_COLS * SNK_CELL,
                           SNK_ROWS * SNK_CELL, _snk_col_board())
    # grid lines
    gl: uint32 = _snk_col_grid()
    c: int32 = 0
    while c <= SNK_COLS:
        game_surface_fill_rect(snk_display, c * SNK_CELL, SNK_HUD, 1,
                               SNK_ROWS * SNK_CELL, gl)
        c = c + 1
    r: int32 = 0
    while r <= SNK_ROWS:
        game_surface_fill_rect(snk_display, 0, SNK_HUD + r * SNK_CELL,
                               SNK_COLS * SNK_CELL, 1, gl)
        r = r + 1

    # food (red)
    fx: int32 = _snk_cell_px_x(g_food_col)
    fy: int32 = _snk_cell_px_y(g_food_row)
    game_surface_fill_rect(snk_display, fx + 2, fy + 2, SNK_CELL - 4,
                           SNK_CELL - 4, _snk_col_food())

    # snake: body (green), head (bright green), drawn tail-first via the ring
    body: uint32 = _snk_col_body()
    head: uint32 = _snk_col_head()
    k: int32 = g_len - 1
    while k >= 0:
        idx: int32 = _snk_seg_idx(k)
        sx: int32 = _snk_cell_px_x(g_cx[idx])
        sy: int32 = _snk_cell_px_y(g_cy[idx])
        col: uint32 = body
        if k == 0:
            col = head
        game_surface_fill_rect(snk_display, sx + 1, sy + 1, SNK_CELL - 2,
                               SNK_CELL - 2, col)
        k = k - 1

    # HUD strip + score text
    game_surface_fill_rect(snk_display, 0, 0, snk_w, SNK_HUD, _snk_col_hud())
    game_surface_draw_rect(snk_display, 0, 0, snk_w, snk_h,
                           game_rgb(70, 84, 120))
    game_surface_draw_text(snk_display, _snk_score_ptr(), 6, 4,
                           game_rgb(235, 235, 235))
    # game-over overlay: a centred panel with the verdict + a retry prompt, so
    # the app stays open and the player can start a fresh round with a keypress.
    if g_over == 1:
        game_surface_draw_text(snk_display,
                               cast[Ptr[uint8]]("GAME OVER"),
                               snk_w / 2 - 36, 4, game_rgb(240, 120, 120))
        ow: int32 = 172
        oh: int32 = 58
        ox: int32 = snk_w / 2 - ow / 2
        oy: int32 = snk_h / 2 - oh / 2
        game_surface_fill_rect(snk_display, ox, oy, ow, oh, game_rgb(40, 26, 30))
        game_surface_draw_rect(snk_display, ox, oy, ow, oh, game_rgb(230, 80, 80))
        game_surface_draw_text(snk_display,
                               cast[Ptr[uint8]]("GAME OVER"),
                               ox + ow / 2 - 36, oy + 12, game_rgb(240, 120, 120))
        game_surface_draw_text(snk_display,
                               cast[Ptr[uint8]]("Press R to replay"),
                               ox + ow / 2 - 68, oy + 34, game_rgb(230, 230, 235))

    g_full_redraw = 0
    g_hud_dirty = 0
    g_dcell_n = 0
    game_mark_dirty(0, 0, snk_w, snk_h)


# DEVICE render path — the constant-cost one. Repaints ONLY what changed since
# the last frame: a full redraw when flagged (first frame / restart / death), or
# just the cells recorded by the last snk_step (+ the HUD if the score changed).
# The per-frame cost does NOT grow with the snake length.
def snk_render_dirty():
    if g_full_redraw == 1:
        snk_render()
        return
    i: int32 = 0
    while i < g_dcell_n:
        _snk_paint_cell(g_dcell_col[i], g_dcell_row[i])
        i = i + 1
    if g_hud_dirty == 1:
        _snk_paint_hud()
        g_hud_dirty = 0


# ---- accessors (drivers + the host gate read these) ----------------------
def snk_display_surf() -> int32:
    return snk_display


def snk_head_col() -> int32:
    return g_cx[g_head]


def snk_head_row() -> int32:
    return g_cy[g_head]


def snk_len() -> int32:
    return g_len


def snk_food_col() -> int32:
    return g_food_col


def snk_food_row() -> int32:
    return g_food_row


def snk_score() -> int32:
    return g_score


def snk_game_over() -> int32:
    return g_over


# Is board cell (col,row) occupied by the snake? O(1). Lets a driver / the host
# gate steer safely (and lets the gate confirm the occupancy grid is coherent).
def snk_occupied_at(col: int32, row: int32) -> int32:
    return _snk_occupied(col, row)


# Number of grid cells the LAST snk_step marked dirty (the incremental repaint
# set). This is BOUNDED by a small constant (new head, ex-head, vacated tail, and
# on an eat the new food) no matter how long the snake is — the host gate asserts
# it stays constant as the snake grows, proving O(1)-per-step rendering.
def snk_step_dirty_cells() -> int32:
    return g_dcell_n


# Frequency (Hz) of the most recent event tone — lets the host gate confirm
# WHICH sound effect fired (eat vs turn vs game-over) beside the raw PCM.
def snk_last_tone_freq() -> int32:
    return g_last_tone


# Pixel centre of a cell (host gate samples the rasterized framebuffer here).
def snk_cell_center_x(col: int32) -> int32:
    return _snk_cell_px_x(col) + SNK_CELL / 2


def snk_cell_center_y(row: int32) -> int32:
    return _snk_cell_px_y(row) + SNK_CELL / 2

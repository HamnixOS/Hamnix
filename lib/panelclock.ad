# lib/panelclock.ad — PURE, extern-free MATE-style clock formatting +
# rendering for the DE panel's clock applet.
#
# MATE's clock applet shows the weekday, month, day AND the time
# ("Sat Jul 12  14:30"), not just HH:MM. This module owns that formatting so
# it is (a) shared by the native panel driver (user/hampanelscene.ad) and
# (b) host-renderable to a PNG through lib/hamui_host.ad — it imports ONLY the
# pure scene builder (lib/hamscene.ad); NO extern, NO syscalls, NO I/O. That
# makes the clock iterable + regression-testable on the dev host in
# milliseconds (scripts/test_de_panel_clock_host.sh) with no QEMU boot.
#
# The calendar math is the classic civil-from-days algorithm (Howard
# Hinnant's), valid for any epoch >= 0. Input is a Unix epoch second count;
# everything below is unsigned integer arithmetic.

from lib.hamscene import hamscene_glyphs, hamscene_glyphs_bold


# Three-letter weekday names, index 0 = Sunday. 1970-01-01 was a Thursday, so
# weekday = (days_since_epoch + 4) % 7 gives 0=Sun .. 6=Sat.
def _wday_name(w: uint64) -> Ptr[uint8]:
    if w == 0:
        return cast[Ptr[uint8]]("Sun")
    if w == 1:
        return cast[Ptr[uint8]]("Mon")
    if w == 2:
        return cast[Ptr[uint8]]("Tue")
    if w == 3:
        return cast[Ptr[uint8]]("Wed")
    if w == 4:
        return cast[Ptr[uint8]]("Thu")
    if w == 5:
        return cast[Ptr[uint8]]("Fri")
    return cast[Ptr[uint8]]("Sat")


# Three-letter month names, index 1 = January.
def _mon_name(m: uint64) -> Ptr[uint8]:
    if m == 1:
        return cast[Ptr[uint8]]("Jan")
    if m == 2:
        return cast[Ptr[uint8]]("Feb")
    if m == 3:
        return cast[Ptr[uint8]]("Mar")
    if m == 4:
        return cast[Ptr[uint8]]("Apr")
    if m == 5:
        return cast[Ptr[uint8]]("May")
    if m == 6:
        return cast[Ptr[uint8]]("Jun")
    if m == 7:
        return cast[Ptr[uint8]]("Jul")
    if m == 8:
        return cast[Ptr[uint8]]("Aug")
    if m == 9:
        return cast[Ptr[uint8]]("Sep")
    if m == 10:
        return cast[Ptr[uint8]]("Oct")
    if m == 11:
        return cast[Ptr[uint8]]("Nov")
    return cast[Ptr[uint8]]("Dec")


def _cp3(dst: Ptr[uint8], di: uint64, src: Ptr[uint8]) -> uint64:
    # Copy a 3-char (NUL-terminated) name; returns new index.
    i: uint64 = 0
    while src[i] != 0:
        dst[di] = src[i]
        di = di + 1
        i = i + 1
    return di


# Broken-down civil date getters for a Unix epoch second count.
def panelclock_year(epoch: uint64) -> uint64:
    days: uint64 = epoch / 86400
    z: uint64 = days + 719468
    era: uint64 = z / 146097
    doe: uint64 = z - era * 146097
    yoe: uint64 = (doe - doe / 1460 + doe / 36524 - doe / 146096) / 365
    y: uint64 = yoe + era * 400
    doy: uint64 = doe - (365 * yoe + yoe / 4 - yoe / 100)
    mp: uint64 = (5 * doy + 2) / 153
    m: uint64 = mp + 3
    if mp >= 10:
        m = mp - 9
    if m <= 2:
        y = y + 1
    return y


def panelclock_month(epoch: uint64) -> uint64:
    days: uint64 = epoch / 86400
    z: uint64 = days + 719468
    era: uint64 = z / 146097
    doe: uint64 = z - era * 146097
    yoe: uint64 = (doe - doe / 1460 + doe / 36524 - doe / 146096) / 365
    doy: uint64 = doe - (365 * yoe + yoe / 4 - yoe / 100)
    mp: uint64 = (5 * doy + 2) / 153
    if mp < 10:
        return mp + 3
    return mp - 9


def panelclock_day(epoch: uint64) -> uint64:
    days: uint64 = epoch / 86400
    z: uint64 = days + 719468
    era: uint64 = z / 146097
    doe: uint64 = z - era * 146097
    yoe: uint64 = (doe - doe / 1460 + doe / 36524 - doe / 146096) / 365
    doy: uint64 = doe - (365 * yoe + yoe / 4 - yoe / 100)
    mp: uint64 = (5 * doy + 2) / 153
    return doy - (153 * mp + 2) / 5 + 1


def panelclock_weekday(epoch: uint64) -> uint64:
    days: uint64 = epoch / 86400
    return (days + 4) % 7


# Format just "HH:MM" (24-hour, zero-padded). Returns length written; out is
# NUL-terminated. Used for the compact (vertical/narrow) panel.
def panelclock_time(epoch: uint64, out: Ptr[uint8]) -> uint64:
    sod: uint64 = epoch % 86400
    hh: uint64 = sod / 3600
    mm: uint64 = (sod % 3600) / 60
    p: uint64 = 0
    out[p] = cast[uint8](hh / 10) + 48
    p = p + 1
    out[p] = cast[uint8](hh % 10) + 48
    p = p + 1
    out[p] = 58                                          # ':'
    p = p + 1
    out[p] = cast[uint8](mm / 10) + 48
    p = p + 1
    out[p] = cast[uint8](mm % 10) + 48
    p = p + 1
    out[p] = 0
    return p


# Format the full MATE-style "Wkd Mon DD  HH:MM" (e.g. "Sat Jul 12  14:30").
# Two spaces separate the date from the time (matches MATE's clock applet).
# Returns length written; out is NUL-terminated. out must hold >= 20 bytes.
def panelclock_format(epoch: uint64, out: Ptr[uint8]) -> uint64:
    wd: uint64 = panelclock_weekday(epoch)
    mo: uint64 = panelclock_month(epoch)
    dd: uint64 = panelclock_day(epoch)
    p: uint64 = 0
    p = _cp3(out, p, _wday_name(wd))
    out[p] = 32                                          # ' '
    p = p + 1
    p = _cp3(out, p, _mon_name(mo))
    out[p] = 32
    p = p + 1
    out[p] = cast[uint8](dd / 10) + 48                    # zero-padded 2-digit day
    p = p + 1
    out[p] = cast[uint8](dd % 10) + 48
    p = p + 1
    out[p] = 32                                          # two-space gap
    p = p + 1
    out[p] = 32
    p = p + 1
    tbuf: Array[8, uint8]
    tn: uint64 = panelclock_time(epoch, &tbuf[0])
    i: uint64 = 0
    while i < tn:
        out[p] = tbuf[i]
        p = p + 1
        i = i + 1
    out[p] = 0
    return p


# Pixel width of the full date+time string at the panel's 8px glyph advance.
def panelclock_width(epoch: uint64) -> int32:
    buf: Array[24, uint8]
    n: uint64 = panelclock_format(epoch, &buf[0])
    return cast[int32](n) * 8


# Render the full date+time into the scene buffer at (x, y). bold selects the
# panel's font weight; color is a "#rrggbb" string. Pure: emits scene glyphs.
def panelclock_render(x: int32, y: int32, epoch: uint64, bold: int32,
                      color: Ptr[uint8]):
    buf: Array[24, uint8]
    panelclock_format(epoch, &buf[0])
    if bold != 0:
        hamscene_glyphs_bold(x, y, &buf[0], color)
    else:
        hamscene_glyphs(x, y, &buf[0], color)


# Render just the compact HH:MM (for narrow vertical panels).
def panelclock_render_time(x: int32, y: int32, epoch: uint64, bold: int32,
                           color: Ptr[uint8]):
    buf: Array[8, uint8]
    panelclock_time(epoch, &buf[0])
    if bold != 0:
        hamscene_glyphs_bold(x, y, &buf[0], color)
    else:
        hamscene_glyphs(x, y, &buf[0], color)

# lib/hamui.ad
#
# hamui — a GTK/Qt-style retained-mode widget toolkit for Hamnix.
#
# WHY THIS EXISTS
# ===============
# The desktop (user/hamUId.ad, ~23k lines) hand-draws every widget from
# raw framebuffer primitives in one monolith. The project owner rejected
# that: "Writing in primitives ... is a terrible idea ... create a solid
# GTK/QT style library and then redo the entire desktop environment."
# This file is step 1: the client-side widget library. A later track
# rewrites the DE on top of it, so the API is designed for that consumer.
#
# CLIENT-SIDE means: this runs in an ORDINARY userland process and draws
# by writing the window-system (wsys) draw protocol that the compositor
# already parses. It is a CONSUMER of the compositor, NOT part of it. We
# never touch user/hamUId.ad — we speak its existing on-disk protocol.
#
# THE DRAW SUBSTRATE (verified against user/hamUId.ad + devwsys.ad)
# ================================================================
# A window `wid` owns LAYERS under /dev/wsys/<wid>/draw/ :
#   * control verbs go to     /dev/wsys/<wid>/draw/ctl
#       mklayer <name> markup [w h]   (markup defaults to full 640x480)
#       setz <name> <n>               (compositing order, z ascending)
#       clear <name>                  (empty a layer's body)
#       rmlayer <name>
#   * a markup layer's body is written to
#       /dev/wsys/<wid>/draw/<name>/markup
#     and the compositor parses "hamML v1" out of it:
#       <rect x y w h fill=#rrggbb/>          filled rectangle
#       <line x1 y1 x2 y2 stroke=#rrggbb width=n/>
#       <text x y fill=#rrggbb>CONTENT</text> 8x16 mono, top-left at (x,y),
#                                             advance 8 px per glyph
#       <group transform="translate(dx,dy)">...</group>
#     Colours: "#rrggbb" is the portable form (also "#rgb","rgba(...)").
#     The whole window is 640x480; markup uses ABSOLUTE window coords.
#
# We compose everything from <rect>/<line>/<text>; the compositor's
# convenience <button>/<input> tags hard-code their own colours, so the
# toolkit draws its own chrome for full theming control.
#
# EVENTS — per-window structured event files
# ===========================================
# The compositor OWNS pointer routing (focus window, click/drag/scroll)
# and gates the keyboard internally, and now EXPOSES that per window via
# two structured event files under /dev/wsys/<wid>/ :
#   * /dev/wsys/<wid>/pointer — one ASCII line per ROUTED pointer event
#                   "<type> <x> <y> <buttons> <dz>\n". type: m=motion
#                   d=button-down u=button-up s=scroll. x,y are ABSOLUTE
#                   WINDOW-LOCAL pixels (the compositor already mapped
#                   screen->window for this target window), so we set the
#                   cursor directly — no delta accumulation, no clamp.
#                   buttons = decimal bitmap (bit0=L bit1=R bit2=M),
#                   dz = signed scroll notch.
#   * /dev/wsys/<wid>/keys — one ASCII line per key event for the FOCUSED
#                   window only, "<type> <code>\n" (type d=press), where
#                   `code` is the byte/keycode fed to _h_dispatch_key
#                   exactly as a stdin byte used to be.
# So hamui_run() polls /dev/wsys/<wid>/{pointer,keys} (NON-BLOCKING, so one
# source never stalls the other), hit-tests the widget tree, and
# dispatches. The toolkit isolates ALL input in _h_poll_pointer /
# _h_poll_keys; nothing downstream (hit-test / click / scroll / key
# routing) changed.
#
# COMPILER QUIRKS HONOURED (see memory/feedback_compiler_quirks)
# ==============================================================
#   * big buffers live at MODULE scope (no large locals);
#   * string literals are passed as call-site Ptr[uint8] (NOT stored in
#     NUL-initialised globals);
#   * NO adjacent string-literal concatenation;
#   * augmented assignment (+=) is available.


extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield() -> int32
# Native multi-fd readiness wait (Plan 9 flavour). Sleeps the caller OFF the
# runqueue until any listed fd would read without blocking, or `timeout_ms`
# elapses (<0 = block forever). This is what lets an event-loop app idle
# without busy-polling — see hamui_wait().
extern def sys_waitfds(fds: Ptr[int32], nfds: uint64,
                       timeout_ms: int64) -> int64
# Anonymous demand-zero mapping for the v2 client backbuffer (see the
# HAMUI_V2 section). The kernel demand-pages anon mmap, so sizing the
# buffer to the ACTUAL window keeps a panel/icon/calc app's resident
# footprint at its real ~143 KB / ~194 KB rather than a fixed 4 MB.
extern def sys_mmap(addr: uint64, len: uint64, prot: int32, flags: int32,
                    fd: int32, off: uint64) -> int64
# Directory enumeration for the file-chooser dialog: returns the directory's
# entries as newline-separated names into `buf` (the same Plan-9 open-dir
# wrapper hamfiles uses); a non-negative return on a path also means "this
# path is a dir". p9_listdir lives in lib/p9.ad — it opens the dir, reads
# the DEV_DIR_FILE listing (still "NAME\n" packed), and closes.
from lib.p9 import p9_listdir, p9_chan_dir_mode
# The PURE scene display-list builder now lives in lib/hamscene.ad (an
# extern-free module that also links into the x86_64-linux HOST target so a
# GUI app's render can be rasterized to a PNG on the dev host — see
# lib/hamui_host.ad + docs/hamui_dual_target.md). hamui re-exports the
# builders (so apps keep importing them `from lib.hamui`) and keeps only the
# NATIVE sink hamscene_commit(), which writes the built buffer to
# /dev/wsys/<wid>/scene via 9P.
from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_text, hamscene_glyphs, hamscene_glyphs_bold, hamscene_line, \
    hamscene_stroke, hamscene_panel_button, hamscene_hbar, \
    hamscene_roundrect, hamscene_roundrect_c, \
    hamscene_icon_folder, hamscene_icon_file, hamscene_bufptr, \
    hamscene_icon_draw, hamscene_icon_code, \
    hamscene_headerbar, hamscene_vgrad_bar, \
    hamscene_length, hamui_scroll_apply


# ====================================================================
# Caps. A widget tree is fixed-size parallel arrays (Hamnix userland has
# no malloc); the limits lift by widening these. 128 widgets is generous
# for an app or a DE panel.
# ====================================================================

HAMUI_MAX_WIDGETS: uint64 = 256
HAMUI_WIN_W:       uint64 = 640
HAMUI_WIN_H:       uint64 = 480
HAMUI_LABEL_CAP:   uint64 = 64        # per-widget text cap (label/entry/list item)

# Widget kinds.
HAMUI_K_NONE:    int32 = 0
HAMUI_K_BOX_V:   int32 = 1            # vertical container
HAMUI_K_BOX_H:   int32 = 2            # horizontal container
HAMUI_K_FIXED:   int32 = 3            # absolute-position container
HAMUI_K_LABEL:   int32 = 4
HAMUI_K_BUTTON:  int32 = 5
HAMUI_K_ENTRY:   int32 = 6
HAMUI_K_CHECK:   int32 = 7
HAMUI_K_LIST:    int32 = 8
# --- expanded (MATE-class) widget set ---
HAMUI_K_MENUBAR:   int32 = 9         # horizontal strip of menu titles
HAMUI_K_MENU:      int32 = 10        # a popdown menu (child of a menubar)
HAMUI_K_MENUITEM:  int32 = 11        # an item inside a menu
HAMUI_K_TOOLBAR:   int32 = 12        # horizontal strip of tool buttons
HAMUI_K_STATUSBAR: int32 = 13        # bottom status text strip
HAMUI_K_SEP:       int32 = 14        # separator; w_state 0=horiz 1=vert
HAMUI_K_RADIO:     int32 = 15        # grouped radio (w_state checked, w_group)
HAMUI_K_PROGRESS:  int32 = 16        # progress bar; w_value 0..w_max
HAMUI_K_SLIDER:    int32 = 17        # scale; min=w_min max=w_max val=w_value
HAMUI_K_SPIN:      int32 = 18        # numeric spinbutton; val=w_value
HAMUI_K_COMBO:     int32 = 19        # dropdown of N rows (reuses list store)
HAMUI_K_NOTEBOOK:  int32 = 20        # tab container; w_state = active page idx
HAMUI_K_TABPAGE:   int32 = 21        # a page (child of notebook), title=w_text
HAMUI_K_IMAGE:     int32 = 22        # placeholder image (filled rect)
HAMUI_K_SCROLL:    int32 = 23        # scrolledwindow; clips one child + bar
HAMUI_K_TREEVIEW:  int32 = 24        # rows x columns grid; reuses list store
HAMUI_K_TEXTVIEW:  int32 = 25        # multi-line editable text
HAMUI_K_GRID:      int32 = 26        # grid container (cell coords + span)
HAMUI_K_DIALOG:    int32 = 27        # modal overlay container
HAMUI_K_CALENDAR:  int32 = 28        # GtkCalendar-style month view

# Pointer button bitmap (from /dev/wsys/<wid>/pointer "buttons" field).
HAMUI_BTN_L: int32 = 1

# Alignment constants for halign/valign.
HAMUI_ALIGN_START:  int32 = 0
HAMUI_ALIGN_CENTER: int32 = 1
HAMUI_ALIGN_END:    int32 = 2
HAMUI_ALIGN_FILL:   int32 = 3


# ====================================================================
# Widget tree — parallel arrays indexed by a widget id (0..count-1).
# id 0 is the implicit root content widget of a window.
# ====================================================================

w_kind:    Array[256, int32]
w_parent:  Array[256, int32]         # -1 for the root
w_visible: Array[256, int32]
# Geometry, filled by the layout pass (absolute window coords).
w_x:       Array[256, int32]
w_y:       Array[256, int32]
w_w:       Array[256, int32]
w_h:       Array[256, int32]
# FIXED-container child offset within the parent (set by hamui_fixed_place).
# Kept SEPARATE from w_x/w_y because the arrange pass OVERWRITES w_x/w_y with
# absolute window coords each layout; reusing w_x/w_y as the offset made the
# origin accumulate the parent's pad every relayout (BUG #122: the clock crept
# down+right ~6px per frame). w_fx/w_fy are the immutable source offset.
w_fx:      Array[256, int32]
w_fy:      Array[256, int32]
# Requested size for leaf widgets / fixed children (0 => auto/measure).
w_req_w:   Array[256, int32]
w_req_h:   Array[256, int32]
# Container layout: spacing between children + padding inside the box.
w_spacing: Array[256, int32]
w_pad:     Array[256, int32]
# Text payload (label/button/entry/checkbox label). Flat LABEL_CAP each.
w_text:    Array[16384, uint8]       # 256 * 64
# State scalars (meaning depends on kind):
#   CHECK/RADIO : 0/1 checked
#   ENTRY : caret index into the text
#   LIST/COMBO/TREEVIEW : selected row index (-1 = none)
#   NOTEBOOK : active page index
#   SEP : 0 horizontal, 1 vertical
#   MENU : 1 = open
w_state:   Array[256, int32]
# Per-widget signal flag: set when the widget is activated (button click,
# checkbox toggle, list-row select). The app drains these via
# hamui_take_event(). A pull-based signal model (instead of C-style
# function-pointer callbacks) keeps the toolkit free of fragile indirect
# calls and is trivial to consume — see the demo. 0 = no pending signal.
w_signal:  Array[256, int32]
# List rows: a separate flat store. Each list owns up to LIST_MAX_ROWS.
HAMUI_LIST_MAX_ROWS: uint64 = 16
w_list_first: Array[256, int32]      # first row slot in the row store, -1 none
w_list_count: Array[256, int32]

# --- expanded per-widget fields (parallel arrays) ---
# Numeric value model (slider/spin/progress): value + bounds + step.
w_value:   Array[256, int32]
w_min:     Array[256, int32]
w_max:     Array[256, int32]
w_step:    Array[256, int32]
# Radio grouping: widgets sharing a group id are mutually exclusive.
w_group:   Array[256, int32]         # -1 = ungrouped
# Layout flags: expand + alignment within the parent's allocation.
w_hexpand: Array[256, int32]
w_vexpand: Array[256, int32]
w_halign:  Array[256, int32]
w_valign:  Array[256, int32]
# Grid cell placement (for children of a GRID): col,row + spans.
w_gcol:    Array[256, int32]
w_grow:    Array[256, int32]
w_gcolspan: Array[256, int32]
w_growspan: Array[256, int32]
# Scrolledwindow / textview scroll offset (pixels / lines).
w_scroll:  Array[256, int32]
# Natural (minimum) measured sizes, captured by the measure pass so the
# arrange pass can distribute slack to expanders.
w_nat_w:   Array[256, int32]
w_nat_h:   Array[256, int32]

# List-row store. Holds rows for LIST / COMBO / TREEVIEW / MENU items via
# the same flat store; capacity widened for the bigger widget set.
HAMUI_ROW_CAP: uint64 = 64
HAMUI_ROW_SLOTS: uint64 = 128
list_row_text: Array[8192, uint8]    # 128 rows total * 64
list_row_used: int32 = 0

w_count: uint64 = 0

# Theme colours, "#rrggbb" literals fetched on demand (see colour getters).
# We keep them as small selectors so callers can retheme later; v1 uses a
# clean neutral palette.


# ====================================================================
# Window object. A window owns a wid + its draw layers. v1 supports one
# top-level window per process (the common app case); the DE rewrite will
# instantiate many, one per app, which the compositor already multiplexes.
# ====================================================================

win_wid:   int32 = -1
win_root:  int32 = -1                # root widget id
win_focus: int32 = -1                # focused widget id (-1 none)
# Absolute WINDOW-LOCAL cursor. The compositor now delivers absolute
# window-space x/y on /dev/wsys/<wid>/pointer, so we set this directly from
# each event rather than accumulating relative deltas.
cur_x:     int32 = 320
cur_y:     int32 = 240
prev_btn:  int32 = 0                 # button bitmap from the previous poll
# Per-window event-file fds (opened lazily, cached). -1 = not yet open / no
# compositor window for this wid.
pointer_fd: int32 = -1
keys_fd:    int32 = -1
# Damage/dirty tracking: the tree is dirty (needs relayout+repaint) until
# the first paint, and again whenever state mutates. hamui_step() only
# emits markup when this is set, so unchanged frames write nothing.
tree_dirty: int32 = 1

# TEXTVIEW backing store. Each textview owns one slot of TV_CAP bytes plus
# a caret. Multi-line plain text; '\n' separates lines. Editable.
HAMUI_TV_SLOTS: uint64 = 4
HAMUI_TV_CAP:   uint64 = 2048
tv_buf:    Array[8192, uint8]        # 4 slots * 2048
tv_slot:   Array[256, int32]         # widget id -> tv slot, -1 = none
tv_caret:  Array[256, int32]         # caret byte offset within the slot
tv_len:    Array[256, int32]         # current byte length
tv_used:   int32 = 0


# ====================================================================
# TOOLTIPS (GTK gtk_widget_set_tooltip_text equivalent)
# ====================================================================
# Each widget can carry tooltip text. The text is COPIED into a per-widget
# byte buffer (capped at HAMUI_LABEL_CAP, like widget text), so callers may
# pass transient buffers — e.g. hamsh's argv strings, which are reused on
# the next command — without dangling. _htt_text holds either 0 (no
# tooltip) or a pointer into that widget's slot of the copy buffer. A
# parallel dwell counter tracks how many
# consecutive event-loop steps the pointer has hovered the SAME widget; once
# it crosses the threshold the bubble shows near the pointer at the highest z
# (painted last, after the overlay pass). Moving to a different widget or a
# button press resets the dwell and hides the bubble. All globals are
# distinctively prefixed (_htt_) so they don't collide in the shared module
# namespace. The pool reuses the existing MAX_WIDGETS cap.
_htt_text:  Array[256, Ptr[uint8]]   # per-widget tooltip text, 0 = none
_htt_buf:   Array[16384, uint8]      # 256 widgets x HAMUI_LABEL_CAP copy slots
_htt_dwell: Array[256, int32]        # consecutive steps hovering this widget
_htt_hover: int32 = -1               # widget id currently under the pointer
_htt_show:  int32 = -1               # widget id whose tooltip is showing, -1 none
# Steps of continuous hover before the bubble appears (tuned for the run-loop
# poll cadence; a few steps ~ a short, GTK-like dwell).
_htt_THRESHOLD: int32 = 8


def _h_mark_dirty():
    tree_dirty = 1


# ====================================================================
# Small string / number helpers (self-contained — no libc).
# ====================================================================

def _h_strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _h_u32_to_dec(value: uint32, out: Ptr[uint8]) -> uint64:
    # Decimal, no newline. Returns digit count.
    if value == 0:
        out[0] = 48
        return 1
    digits: Array[16, uint8]
    n: uint64 = 0
    v: uint32 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return written


def _h_i32_to_dec(value: int32, out: Ptr[uint8]) -> uint64:
    if value < 0:
        out[0] = 45                                  # '-'
        return 1 + _h_u32_to_dec(cast[uint32](0 - value), &out[1])
    return _h_u32_to_dec(cast[uint32](value), &out[0])


def _h_putc(buf: Ptr[uint8], pos: uint64, c: uint8) -> uint64:
    buf[pos] = c
    return pos + 1


def _h_puts(buf: Ptr[uint8], pos: uint64, s: Ptr[uint8]) -> uint64:
    p: uint64 = pos
    k: uint64 = 0
    while s[k] != 0:
        buf[p] = s[k]
        p = p + 1
        k = k + 1
    return p


# ====================================================================
# Path builder: "/dev/wsys/<wid>/draw[/<layer>][/<leaf>]" into path_buf.
# ====================================================================

path_buf: Array[256, uint8]

def _h_build_path(wid: int32, layer: Ptr[uint8], leaf: Ptr[uint8]):
    i: uint64 = 0
    i = _h_puts(&path_buf[0], i, "/dev/wsys/")
    i = i + _h_u32_to_dec(cast[uint32](wid), &path_buf[i])
    i = _h_puts(&path_buf[0], i, "/draw")
    if layer != cast[Ptr[uint8]](0) and layer[0] != 0:
        i = _h_putc(&path_buf[0], i, 47)             # '/'
        i = _h_puts(&path_buf[0], i, layer)
        if leaf != cast[Ptr[uint8]](0) and leaf[0] != 0:
            i = _h_putc(&path_buf[0], i, 47)
            i = _h_puts(&path_buf[0], i, leaf)
    path_buf[i] = 0


# Build "/dev/wsys/<wid>/<leaf>" (the per-window event/control files that
# live directly under the wid dir, e.g. "pointer" / "keys") into path_buf.
def _h_build_wsys_path(wid: int32, leaf: Ptr[uint8]):
    i: uint64 = 0
    i = _h_puts(&path_buf[0], i, "/dev/wsys/")
    i = i + _h_u32_to_dec(cast[uint32](wid), &path_buf[i])
    i = _h_putc(&path_buf[0], i, 47)                 # '/'
    i = _h_puts(&path_buf[0], i, leaf)
    path_buf[i] = 0


# ====================================================================
# Widget construction API (the public, GTK/Qt-flavoured surface).
# Every constructor returns a widget id (int32). Attach a child to a
# container with hamui_add(parent, child).
# ====================================================================

def _h_alloc(kind: int32) -> int32:
    if w_count >= HAMUI_MAX_WIDGETS:
        return -1
    id: int32 = cast[int32](w_count)
    u: uint64 = w_count
    w_kind[u] = kind
    w_parent[u] = -1
    w_visible[u] = 1
    w_x[u] = 0
    w_y[u] = 0
    w_fx[u] = 0
    w_fy[u] = 0
    w_w[u] = 0
    w_h[u] = 0
    w_req_w[u] = 0
    w_req_h[u] = 0
    w_spacing[u] = 4
    w_pad[u] = 6
    w_state[u] = 0
    w_signal[u] = 0
    w_list_first[u] = -1
    w_list_count[u] = 0
    w_value[u] = 0
    w_min[u] = 0
    w_max[u] = 100
    w_step[u] = 1
    w_group[u] = -1
    w_hexpand[u] = 0
    w_vexpand[u] = 0
    w_halign[u] = HAMUI_ALIGN_START
    w_valign[u] = HAMUI_ALIGN_START
    w_gcol[u] = 0
    w_grow[u] = 0
    w_gcolspan[u] = 1
    w_growspan[u] = 1
    w_scroll[u] = 0
    w_nat_w[u] = 0
    w_nat_h[u] = 0
    tv_slot[u] = -1
    tv_caret[u] = 0
    tv_len[u] = 0
    _htt_text[u] = cast[Ptr[uint8]](0)
    _htt_dwell[u] = 0
    w_text[u * HAMUI_LABEL_CAP] = 0
    w_count = w_count + 1
    tree_dirty = 1
    return id


def _h_set_text(id: int32, s: Ptr[uint8]):
    base: uint64 = cast[uint64](id) * HAMUI_LABEL_CAP
    i: uint64 = 0
    while s[i] != 0 and i < HAMUI_LABEL_CAP - 1:
        w_text[base + i] = s[i]
        i = i + 1
    w_text[base + i] = 0


def _h_text_len(id: int32) -> uint64:
    base: uint64 = cast[uint64](id) * HAMUI_LABEL_CAP
    n: uint64 = 0
    while w_text[base + n] != 0:
        n = n + 1
    return n


def hamui_init():
    # Reset the toolkit. Call once before building a tree.
    w_count = 0
    list_row_used = 0
    tv_used = 0
    win_wid = -1
    win_root = -1
    win_focus = -1
    cur_x = 320
    cur_y = 240
    prev_btn = 0
    pointer_fd = -1
    keys_fd = -1
    _htt_hover = -1
    _htt_show = -1
    _hcal_seeded = 0
    tree_dirty = 1


# Attach tooltip text to any widget (mirrors gtk_widget_set_tooltip_text).
# `text` is COPIED into the widget's tooltip slot (cap HAMUI_LABEL_CAP), so
# transient caller buffers are safe. Pass a null pointer to clear. The
# bubble appears after a short hover dwell.
def hamui_set_tooltip(w: int32, text: Ptr[uint8]):
    if w < 0 or cast[uint64](w) >= w_count:
        return
    u: uint64 = cast[uint64](w)
    if text == cast[Ptr[uint8]](0):
        _htt_text[u] = cast[Ptr[uint8]](0)
        return
    base: uint64 = u * HAMUI_LABEL_CAP
    i: uint64 = 0
    while text[i] != 0 and i < HAMUI_LABEL_CAP - 1:
        _htt_buf[base + i] = text[i]
        i = i + 1
    _htt_buf[base + i] = 0
    _htt_text[u] = &_htt_buf[base]


def hamui_vbox() -> int32:
    return _h_alloc(HAMUI_K_BOX_V)


def hamui_hbox() -> int32:
    return _h_alloc(HAMUI_K_BOX_H)


def hamui_fixed() -> int32:
    return _h_alloc(HAMUI_K_FIXED)


def hamui_label(text: Ptr[uint8]) -> int32:
    id: int32 = _h_alloc(HAMUI_K_LABEL)
    if id >= 0:
        _h_set_text(id, text)
    return id


def hamui_button(text: Ptr[uint8]) -> int32:
    id: int32 = _h_alloc(HAMUI_K_BUTTON)
    if id >= 0:
        _h_set_text(id, text)
    return id


def hamui_entry() -> int32:
    id: int32 = _h_alloc(HAMUI_K_ENTRY)
    if id >= 0:
        w_state[cast[uint64](id)] = 0                # caret = 0
        w_req_w[cast[uint64](id)] = 160
    return id


def hamui_checkbox(text: Ptr[uint8]) -> int32:
    id: int32 = _h_alloc(HAMUI_K_CHECK)
    if id >= 0:
        _h_set_text(id, text)
    return id


def hamui_list() -> int32:
    id: int32 = _h_alloc(HAMUI_K_LIST)
    if id >= 0:
        w_state[cast[uint64](id)] = -1               # no selection
        w_req_w[cast[uint64](id)] = 180
    return id


# Internal: append a text row to any row-backed widget (LIST/COMBO/
# TREEVIEW/MENU). Rows are contiguous in the flat store so they can be
# indexed by (first + r).
def _h_row_add(id: int32, text: Ptr[uint8]):
    if id < 0:
        return
    lu: uint64 = cast[uint64](id)
    if cast[uint64](w_list_count[lu]) >= HAMUI_LIST_MAX_ROWS:
        return
    if cast[uint64](list_row_used) >= HAMUI_ROW_SLOTS:
        return
    slot: int32 = list_row_used
    if w_list_first[lu] < 0:
        w_list_first[lu] = slot
    base: uint64 = cast[uint64](slot) * HAMUI_ROW_CAP
    i: uint64 = 0
    while text[i] != 0 and i < HAMUI_ROW_CAP - 1:
        list_row_text[base + i] = text[i]
        i = i + 1
    list_row_text[base + i] = 0
    w_list_count[lu] = w_list_count[lu] + 1
    list_row_used = list_row_used + 1
    tree_dirty = 1


def hamui_list_add(list_id: int32, text: Ptr[uint8]):
    # Append a row to a listbox.
    if list_id < 0:
        return
    lu: uint64 = cast[uint64](list_id)
    if w_kind[lu] != HAMUI_K_LIST:
        return
    _h_row_add(list_id, text)


# Internal: drop EVERY row of a row-backed widget (LIST/COMBO/TREEVIEW)
# so it can be refilled in place — without leaking a treeview/list's worth
# of pooled row slots on each rebuild. This is the fix for the row-pool
# exhaustion the app suite hit (a treeview reused ~8 times spent the whole
# 128-slot pool because the old rows were never reclaimed).
#
# Reclaim is exact when this widget owns the TAIL of the pool: its rows
# end at list_row_used, so the high-water mark simply rolls back by
# w_list_count and those slots are immediately reusable. When the widget's
# rows sit in the middle of the pool (something allocated rows after it),
# we cannot compact safely without renumbering every other widget's
# w_list_first, so we conservatively keep the high-water mark but still
# clear this widget's count (the slots rejoin the pool the moment the
# widget(s) above it are themselves cleared in LIFO order, which is the
# common refill pattern). Either way the widget shows zero rows afterward
# and a subsequent _h_row_add re-grows it from a fresh first slot.
def _h_row_clear(id: int32):
    if id < 0:
        return
    lu: uint64 = cast[uint64](id)
    cnt: int32 = w_list_count[lu]
    first: int32 = w_list_first[lu]
    if cnt > 0 and first >= 0:
        # If this widget's rows are the tail of the pool, roll the
        # high-water mark back so the slots are reclaimed exactly.
        if first + cnt == list_row_used:
            list_row_used = first
    w_list_count[lu] = 0
    w_list_first[lu] = -1
    if cast[int32](w_state[lu]) >= cnt:
        w_state[lu] = -1                             # drop a now-invalid selection
    tree_dirty = 1


def hamui_list_clear(id: int32):
    # Remove all rows from a listbox so it can be repopulated in place.
    if id < 0:
        return
    if w_kind[cast[uint64](id)] != HAMUI_K_LIST:
        return
    _h_row_clear(id)


def hamui_treeview_clear(id: int32):
    # Remove all rows from a treeview so it can be repopulated in place.
    # Recycles the pooled row slots (see _h_row_clear), so a long-lived
    # treeview can be rebuilt indefinitely instead of allocating a fresh
    # treeview per refresh and burning the 128-slot row pool after ~8 views.
    if id < 0:
        return
    if w_kind[cast[uint64](id)] != HAMUI_K_TREEVIEW:
        return
    _h_row_clear(id)


def hamui_combo_clear(id: int32):
    # Remove all entries from a combo box (recycles its row slots).
    if id < 0:
        return
    if w_kind[cast[uint64](id)] != HAMUI_K_COMBO:
        return
    _h_row_clear(id)


# Pointer to the text of row `r` of a row-backed widget (-> &flat store).
def _h_row_ptr(id: int32, r: int32) -> Ptr[uint8]:
    lu: uint64 = cast[uint64](id)
    first: int32 = w_list_first[lu]
    base: uint64 = cast[uint64](first + r) * HAMUI_ROW_CAP
    return &list_row_text[base]


# ====================================================================
# Expanded constructors (menubar/menu/toolbar/statusbar/separator/radio/
# progress/slider/spin/combo/notebook/tabs/image/scroll/treeview/textview/
# grid/dialog). Each returns a widget id; setters take that id.
# ====================================================================

def hamui_menubar() -> int32:
    id: int32 = _h_alloc(HAMUI_K_MENUBAR)
    if id >= 0:
        w_spacing[cast[uint64](id)] = 0
        w_pad[cast[uint64](id)] = 0
    return id


def hamui_menu(title: Ptr[uint8]) -> int32:
    # A menu lives as a child of a menubar; its w_text is the bar title.
    id: int32 = _h_alloc(HAMUI_K_MENU)
    if id >= 0:
        _h_set_text(id, title)
        w_state[cast[uint64](id)] = 0                # closed
    return id


def hamui_menu_add(menu_id: int32, label: Ptr[uint8]) -> int32:
    # A menu item is a real child widget of the menu (so it can carry its
    # own signal). Returns the item id.
    if menu_id < 0:
        return -1
    item: int32 = _h_alloc(HAMUI_K_MENUITEM)
    if item >= 0:
        _h_set_text(item, label)
        w_parent[cast[uint64](item)] = menu_id
    return item


def hamui_toolbar() -> int32:
    id: int32 = _h_alloc(HAMUI_K_TOOLBAR)
    if id >= 0:
        w_spacing[cast[uint64](id)] = 2
        w_pad[cast[uint64](id)] = 2
    return id


def hamui_statusbar(text: Ptr[uint8]) -> int32:
    id: int32 = _h_alloc(HAMUI_K_STATUSBAR)
    if id >= 0:
        _h_set_text(id, text)
        w_hexpand[cast[uint64](id)] = 1
    return id


def hamui_status_set(id: int32, text: Ptr[uint8]):
    if id < 0:
        return
    _h_set_text(id, text)
    tree_dirty = 1


def hamui_separator(vertical: int32) -> int32:
    id: int32 = _h_alloc(HAMUI_K_SEP)
    if id >= 0:
        w_state[cast[uint64](id)] = vertical
    return id


def hamui_radio(text: Ptr[uint8], group: int32) -> int32:
    id: int32 = _h_alloc(HAMUI_K_RADIO)
    if id >= 0:
        _h_set_text(id, text)
        w_group[cast[uint64](id)] = group
    return id


def hamui_progress() -> int32:
    id: int32 = _h_alloc(HAMUI_K_PROGRESS)
    if id >= 0:
        w_req_w[cast[uint64](id)] = 200
        w_value[cast[uint64](id)] = 0
        w_max[cast[uint64](id)] = 100
    return id


def hamui_slider(minv: int32, maxv: int32, val: int32) -> int32:
    id: int32 = _h_alloc(HAMUI_K_SLIDER)
    if id >= 0:
        w_req_w[cast[uint64](id)] = 200
        w_min[cast[uint64](id)] = minv
        w_max[cast[uint64](id)] = maxv
        w_value[cast[uint64](id)] = val
    return id


def hamui_spin(minv: int32, maxv: int32, val: int32) -> int32:
    id: int32 = _h_alloc(HAMUI_K_SPIN)
    if id >= 0:
        w_req_w[cast[uint64](id)] = 90
        w_min[cast[uint64](id)] = minv
        w_max[cast[uint64](id)] = maxv
        w_value[cast[uint64](id)] = val
    return id


def hamui_combo() -> int32:
    id: int32 = _h_alloc(HAMUI_K_COMBO)
    if id >= 0:
        w_req_w[cast[uint64](id)] = 160
        w_state[cast[uint64](id)] = -1               # nothing selected
        w_value[cast[uint64](id)] = 0                # 0 = closed, 1 = open
    return id


def hamui_combo_add(combo_id: int32, text: Ptr[uint8]):
    if combo_id < 0:
        return
    if w_kind[cast[uint64](combo_id)] != HAMUI_K_COMBO:
        return
    if w_state[cast[uint64](combo_id)] < 0:
        w_state[cast[uint64](combo_id)] = 0          # default to first row
    _h_row_add(combo_id, text)


def hamui_notebook() -> int32:
    id: int32 = _h_alloc(HAMUI_K_NOTEBOOK)
    if id >= 0:
        w_state[cast[uint64](id)] = 0                # active page 0
        w_hexpand[cast[uint64](id)] = 1
        w_vexpand[cast[uint64](id)] = 1
    return id


def hamui_notebook_page(notebook_id: int32, title: Ptr[uint8]) -> int32:
    # Returns a page container id; add child widgets to it with hamui_add.
    if notebook_id < 0:
        return -1
    page: int32 = _h_alloc(HAMUI_K_TABPAGE)
    if page >= 0:
        _h_set_text(page, title)
        w_parent[cast[uint64](page)] = notebook_id
    return page


def hamui_notebook_active(id: int32) -> int32:
    if id < 0:
        return 0
    return w_state[cast[uint64](id)]


def hamui_image(w: int32, h: int32) -> int32:
    id: int32 = _h_alloc(HAMUI_K_IMAGE)
    if id >= 0:
        w_req_w[cast[uint64](id)] = w
        w_req_h[cast[uint64](id)] = h
    return id


def hamui_scrolled() -> int32:
    # A scrolledwindow viewports a single child; size it explicitly.
    id: int32 = _h_alloc(HAMUI_K_SCROLL)
    if id >= 0:
        w_req_w[cast[uint64](id)] = 220
        w_req_h[cast[uint64](id)] = 160
        w_pad[cast[uint64](id)] = 0
        w_scroll[cast[uint64](id)] = 0
    return id


def hamui_treeview(cols: int32) -> int32:
    id: int32 = _h_alloc(HAMUI_K_TREEVIEW)
    if id >= 0:
        w_req_w[cast[uint64](id)] = 280
        w_state[cast[uint64](id)] = -1               # no selection
        w_value[cast[uint64](id)] = cols             # column count
        if w_value[cast[uint64](id)] < 1:
            w_value[cast[uint64](id)] = 1
    return id


# Add a row to a treeview. Columns within the row are TAB-separated in
# `text` (the paint pass splits on '\t' across the column tracks).
def hamui_treeview_add(tree_id: int32, text: Ptr[uint8]):
    if tree_id < 0:
        return
    if w_kind[cast[uint64](tree_id)] != HAMUI_K_TREEVIEW:
        return
    _h_row_add(tree_id, text)


def hamui_textview() -> int32:
    id: int32 = _h_alloc(HAMUI_K_TEXTVIEW)
    if id >= 0:
        u: uint64 = cast[uint64](id)
        w_req_w[u] = 300
        w_req_h[u] = 160
        if cast[uint64](tv_used) < HAMUI_TV_SLOTS:
            tv_slot[u] = tv_used
            tv_caret[u] = 0
            tv_len[u] = 0
            tv_buf[cast[uint64](tv_used) * HAMUI_TV_CAP] = 0
            tv_used = tv_used + 1
    return id


# Replace a textview's contents with `s`.
def hamui_textview_set(id: int32, s: Ptr[uint8]):
    if id < 0:
        return
    u: uint64 = cast[uint64](id)
    if tv_slot[u] < 0:
        return
    base: uint64 = cast[uint64](tv_slot[u]) * HAMUI_TV_CAP
    i: uint64 = 0
    while s[i] != 0 and i < HAMUI_TV_CAP - 1:
        tv_buf[base + i] = s[i]
        i = i + 1
    tv_buf[base + i] = 0
    tv_len[u] = cast[int32](i)
    tv_caret[u] = cast[int32](i)
    tree_dirty = 1


def hamui_textview_text(id: int32) -> Ptr[uint8]:
    if id < 0:
        return cast[Ptr[uint8]](0)
    u: uint64 = cast[uint64](id)
    if tv_slot[u] < 0:
        return cast[Ptr[uint8]](0)
    return &tv_buf[cast[uint64](tv_slot[u]) * HAMUI_TV_CAP]


def hamui_grid() -> int32:
    id: int32 = _h_alloc(HAMUI_K_GRID)
    if id >= 0:
        w_spacing[cast[uint64](id)] = 6
        w_pad[cast[uint64](id)] = 6
    return id


# Attach a child into a GRID at cell (col,row) optionally spanning cells.
def hamui_grid_attach(grid_id: int32, child: int32, col: int32, row: int32, \
                      colspan: int32, rowspan: int32):
    if grid_id < 0 or child < 0:
        return
    cu: uint64 = cast[uint64](child)
    w_parent[cu] = grid_id
    w_gcol[cu] = col
    w_grow[cu] = row
    w_gcolspan[cu] = colspan
    if w_gcolspan[cu] < 1:
        w_gcolspan[cu] = 1
    w_growspan[cu] = rowspan
    if w_growspan[cu] < 1:
        w_growspan[cu] = 1
    tree_dirty = 1


def hamui_dialog(title: Ptr[uint8]) -> int32:
    # A modal overlay container (painted last, on top, with a backdrop).
    id: int32 = _h_alloc(HAMUI_K_DIALOG)
    if id >= 0:
        _h_set_text(id, title)
        w_req_w[cast[uint64](id)] = 320
        w_req_h[cast[uint64](id)] = 180
        w_visible[cast[uint64](id)] = 0              # hidden until shown
    return id


# ---- numeric value accessors (slider/spin/progress) ----

def hamui_value(id: int32) -> int32:
    if id < 0:
        return 0
    return w_value[cast[uint64](id)]


def hamui_set_value(id: int32, v: int32):
    if id < 0:
        return
    u: uint64 = cast[uint64](id)
    nv: int32 = v
    if nv < w_min[u]:
        nv = w_min[u]
    if nv > w_max[u]:
        nv = w_max[u]
    w_value[u] = nv
    tree_dirty = 1


def hamui_set_range(id: int32, minv: int32, maxv: int32):
    if id < 0:
        return
    u: uint64 = cast[uint64](id)
    w_min[u] = minv
    w_max[u] = maxv
    tree_dirty = 1


# ---- layout flags (expand + alignment), GTK-style ----

def hamui_set_expand(id: int32, hexpand: int32, vexpand: int32):
    if id < 0:
        return
    w_hexpand[cast[uint64](id)] = hexpand
    w_vexpand[cast[uint64](id)] = vexpand
    tree_dirty = 1


def hamui_set_align(id: int32, halign: int32, valign: int32):
    if id < 0:
        return
    w_halign[cast[uint64](id)] = halign
    w_valign[cast[uint64](id)] = valign
    tree_dirty = 1


def hamui_set_size(id: int32, w: int32, h: int32):
    if id < 0:
        return
    w_req_w[cast[uint64](id)] = w
    w_req_h[cast[uint64](id)] = h
    tree_dirty = 1


def hamui_set_spacing(id: int32, spacing: int32, pad: int32):
    if id < 0:
        return
    w_spacing[cast[uint64](id)] = spacing
    w_pad[cast[uint64](id)] = pad
    tree_dirty = 1


def hamui_set_text(id: int32, text: Ptr[uint8]):
    # Public label/button text setter (re-flows on next paint).
    if id < 0:
        return
    _h_set_text(id, text)
    tree_dirty = 1


def hamui_fixed_place(id: int32, x: int32, y: int32):
    # For children of a FIXED container: absolute offset within the parent.
    # Store into the dedicated w_fx/w_fy so the arrange pass (which clobbers
    # w_x/w_y with absolute coords) can re-read the ORIGINAL offset every
    # frame — otherwise the origin accumulates the parent pad (BUG #122).
    if id < 0:
        return
    w_fx[cast[uint64](id)] = x
    w_fy[cast[uint64](id)] = y
    w_x[cast[uint64](id)] = x
    w_y[cast[uint64](id)] = y
    tree_dirty = 1


def hamui_add(parent: int32, child: int32):
    if parent < 0 or child < 0:
        return
    w_parent[cast[uint64](child)] = parent
    tree_dirty = 1


def hamui_set_visible(id: int32, vis: int32):
    if id >= 0:
        w_visible[cast[uint64](id)] = vis
        tree_dirty = 1


def hamui_show(id: int32):
    if id >= 0:
        w_visible[cast[uint64](id)] = 1
        tree_dirty = 1


def hamui_hide(id: int32):
    if id >= 0:
        w_visible[cast[uint64](id)] = 0
        tree_dirty = 1


# Destroy a widget: detach it from its parent, recursively hide+free its
# subtree, and mark the tree dirty. Slots are not reclaimed for reuse (the
# arena is creation-ordered) but the widget becomes kind NONE + invisible
# so it never lays out or paints again. Children are detached too.
def hamui_destroy(id: int32):
    if id < 0:
        return
    u: uint64 = cast[uint64](id)
    # Detach + destroy any children first.
    c: uint64 = 0
    while c < w_count:
        if w_parent[c] == id:
            hamui_destroy(cast[int32](c))
        c = c + 1
    w_kind[u] = HAMUI_K_NONE
    w_visible[u] = 0
    w_parent[u] = -1
    w_signal[u] = 0
    if win_focus == id:
        win_focus = -1
    tree_dirty = 1


def hamui_checked(id: int32) -> int32:
    if id < 0:
        return 0
    return w_state[cast[uint64](id)]


def hamui_list_selected(id: int32) -> int32:
    if id < 0:
        return -1
    return w_state[cast[uint64](id)]


def hamui_combo_selected(id: int32) -> int32:
    if id < 0:
        return -1
    return w_state[cast[uint64](id)]


def hamui_tree_selected(id: int32) -> int32:
    if id < 0:
        return -1
    return w_state[cast[uint64](id)]


def hamui_entry_text(id: int32) -> Ptr[uint8]:
    if id < 0:
        return cast[Ptr[uint8]](0)
    return &w_text[cast[uint64](id) * HAMUI_LABEL_CAP]


# Programmatically set an entry's text (e.g. seed a path bar from argv).
# Places the caret at end. Mirrors hamui_entry_text on the write side.
def hamui_entry_set(id: int32, s: Ptr[uint8]):
    if id < 0:
        return
    _h_set_text(id, s)
    w_state[cast[uint64](id)] = cast[int32](_h_text_len(id))


def hamui_take_event() -> int32:
    # Pull-based signal drain (GTK-style "signal", but polled). Returns the
    # id of one widget that fired since the last drain and clears its flag,
    # or -1 when none are pending. Call in a loop to handle all pending
    # events:  while (id = hamui_take_event()) >= 0: ... handle id ...
    i: uint64 = 0
    while i < w_count:
        if w_signal[i] != 0:
            w_signal[i] = 0
            return cast[int32](i)
        i = i + 1
    return -1


def hamui_signalled(id: int32) -> int32:
    # Non-draining check: did this specific widget fire? Clears the flag.
    if id < 0:
        return 0
    u: uint64 = cast[uint64](id)
    if w_signal[u] != 0:
        w_signal[u] = 0
        return 1
    return 0


# ====================================================================
# LAYOUT PASS — measure then arrange. Sizes are computed bottom-up; the
# root fills the window. We do a single recursive-ish pass implemented
# iteratively over the (parent-before-child) creation order is NOT
# guaranteed, so we measure with explicit recursion via a helper.
# ====================================================================

# Intrinsic size of a leaf widget (its "natural" measure).
def _h_measure_leaf(id: int32, out_w: Ptr[int32], out_h: Ptr[int32]):
    u: uint64 = cast[uint64](id)
    k: int32 = w_kind[u]
    tl: int32 = cast[int32](_h_text_len(id))
    if k == HAMUI_K_LABEL:
        out_w[0] = tl * 8 + 2
        out_h[0] = 16
    elif k == HAMUI_K_BUTTON:
        out_w[0] = tl * 8 + 16
        out_h[0] = 24
    elif k == HAMUI_K_ENTRY:
        out_w[0] = 160
        out_h[0] = 22
    elif k == HAMUI_K_CHECK:
        out_w[0] = tl * 8 + 22                        # box + gap + label
        out_h[0] = 18
    elif k == HAMUI_K_LIST:
        out_w[0] = 180
        out_h[0] = cast[int32](w_list_count[u]) * 18 + 4
        if out_h[0] < 22:
            out_h[0] = 22
    elif k == HAMUI_K_RADIO:
        out_w[0] = tl * 8 + 22
        out_h[0] = 18
    elif k == HAMUI_K_SEP:
        if w_state[u] != 0:                           # vertical
            out_w[0] = 2
            out_h[0] = 16
        else:
            out_w[0] = 16
            out_h[0] = 2
    elif k == HAMUI_K_PROGRESS:
        out_w[0] = 200
        out_h[0] = 20
    elif k == HAMUI_K_SLIDER:
        out_w[0] = 200
        out_h[0] = 22
    elif k == HAMUI_K_SPIN:
        out_w[0] = 90
        out_h[0] = 24
    elif k == HAMUI_K_COMBO:
        out_w[0] = 160
        out_h[0] = 24
    elif k == HAMUI_K_IMAGE:
        out_w[0] = 32
        out_h[0] = 32
    elif k == HAMUI_K_STATUSBAR:
        out_w[0] = tl * 8 + 8
        out_h[0] = 20
    elif k == HAMUI_K_MENUITEM:
        out_w[0] = tl * 8 + 16
        out_h[0] = 20
    elif k == HAMUI_K_TREEVIEW:
        out_w[0] = 280
        out_h[0] = cast[int32](w_list_count[u]) * 18 + 22
        if out_h[0] < 40:
            out_h[0] = 40
    elif k == HAMUI_K_TEXTVIEW:
        out_w[0] = 300
        out_h[0] = 160
    elif k == HAMUI_K_CALENDAR:
        # 7 columns * 26px + 2px inset each side; 20px header band +
        # 16px weekday row + 6 rows * 18px + 2px bottom inset.
        out_w[0] = 186
        out_h[0] = 148
    else:
        out_w[0] = 0
        out_h[0] = 0
    # Honour an explicit requested size if larger / set.
    if w_req_w[u] > out_w[0]:
        out_w[0] = w_req_w[u]
    if w_req_h[u] > out_h[0]:
        out_h[0] = w_req_h[u]


def _h_is_container(k: int32) -> int32:
    if k == HAMUI_K_BOX_V or k == HAMUI_K_BOX_H or k == HAMUI_K_FIXED:
        return 1
    if k == HAMUI_K_MENUBAR or k == HAMUI_K_TOOLBAR or k == HAMUI_K_GRID:
        return 1
    if k == HAMUI_K_NOTEBOOK or k == HAMUI_K_SCROLL or k == HAMUI_K_DIALOG:
        return 1
    return 0


# Is `k` laid out like a horizontal strip of its children (menubar/toolbar
# behave like an hbox for measure/arrange)?
def _h_is_hstrip(k: int32) -> int32:
    if k == HAMUI_K_BOX_H or k == HAMUI_K_MENUBAR or k == HAMUI_K_TOOLBAR:
        return 1
    return 0


# A MENU inside a menubar contributes only its title text to the bar's
# flow; its MENUITEM children are a popdown (measured separately at paint).
def _h_menu_title_w(id: int32) -> int32:
    return cast[int32](_h_text_len(id)) * 8 + 16


# Measure widget `id` into w_w/w_h. Recurses into children first. Also
# records the natural (minimum) size into w_nat_w/w_nat_h so the arrange
# pass can hand slack to expanders.
def _h_measure(id: int32):
    u: uint64 = cast[uint64](id)
    k: int32 = w_kind[u]
    if _h_is_container(k) == 0:
        ow: Array[1, int32]
        oh: Array[1, int32]
        _h_measure_leaf(id, &ow[0], &oh[0])
        w_w[u] = ow[0]
        w_h[u] = oh[0]
        w_nat_w[u] = ow[0]
        w_nat_h[u] = oh[0]
        return
    pad: int32 = w_pad[u]
    sp: int32 = w_spacing[u]

    # NOTEBOOK: tab strip (24px) above a content area = max page footprint.
    if k == HAMUI_K_NOTEBOOK:
        maxpw: int32 = 0
        maxph: int32 = 0
        c0: uint64 = 0
        while c0 < w_count:
            if w_parent[c0] == id and w_kind[c0] == HAMUI_K_TABPAGE:
                _h_measure(cast[int32](c0))
                if w_w[c0] > maxpw:
                    maxpw = w_w[c0]
                if w_h[c0] > maxph:
                    maxph = w_h[c0]
            c0 = c0 + 1
        bw: int32 = maxpw + 8
        bh: int32 = maxph + 24 + 6
        if w_req_w[u] > bw:
            bw = w_req_w[u]
        if w_req_h[u] > bh:
            bh = w_req_h[u]
        w_w[u] = bw
        w_h[u] = bh
        w_nat_w[u] = bw
        w_nat_h[u] = bh
        return

    # SCROLL: a fixed viewport box; measure its single child but clamp our
    # own size to the requested viewport.
    if k == HAMUI_K_SCROLL:
        cc: uint64 = 0
        while cc < w_count:
            if w_parent[cc] == id and w_visible[cc] != 0:
                _h_measure(cast[int32](cc))
            cc = cc + 1
        sw: int32 = w_req_w[u]
        sh: int32 = w_req_h[u]
        if sw <= 0:
            sw = 200
        if sh <= 0:
            sh = 150
        w_w[u] = sw
        w_h[u] = sh
        w_nat_w[u] = sw
        w_nat_h[u] = sh
        return

    # GRID: track per-column widths and per-row heights, then sum.
    if k == HAMUI_K_GRID:
        colw: Array[16, int32]
        rowh: Array[16, int32]
        ncol: int32 = 0
        nrow: int32 = 0
        ic: uint64 = 0
        while ic < 16:
            colw[ic] = 0
            rowh[ic] = 0
            ic = ic + 1
        cg: uint64 = 0
        while cg < w_count:
            if w_parent[cg] == id and w_visible[cg] != 0:
                _h_measure(cast[int32](cg))
                col: int32 = w_gcol[cg]
                row: int32 = w_grow[cg]
                if col >= 0 and col < 16:
                    cwid: int32 = w_w[cg] / w_gcolspan[cg]
                    if cwid > colw[cast[uint64](col)]:
                        colw[cast[uint64](col)] = cwid
                    if col + 1 > ncol:
                        ncol = col + 1
                if row >= 0 and row < 16:
                    chgt: int32 = w_h[cg] / w_growspan[cg]
                    if chgt > rowh[cast[uint64](row)]:
                        rowh[cast[uint64](row)] = chgt
                    if row + 1 > nrow:
                        nrow = row + 1
            cg = cg + 1
        gw: int32 = 0
        i2: int32 = 0
        while i2 < ncol:
            gw = gw + colw[cast[uint64](i2)]
            i2 = i2 + 1
        if ncol > 1:
            gw = gw + (ncol - 1) * sp
        gh: int32 = 0
        i3: int32 = 0
        while i3 < nrow:
            gh = gh + rowh[cast[uint64](i3)]
            i3 = i3 + 1
        if nrow > 1:
            gh = gh + (nrow - 1) * sp
        w_w[u] = gw + pad * 2
        w_h[u] = gh + pad * 2
        if w_req_w[u] > w_w[u]:
            w_w[u] = w_req_w[u]
        if w_req_h[u] > w_h[u]:
            w_h[u] = w_req_h[u]
        w_nat_w[u] = w_w[u]
        w_nat_h[u] = w_h[u]
        return

    # DIALOG: fixed overlay size from request.
    if k == HAMUI_K_DIALOG:
        cd: uint64 = 0
        while cd < w_count:
            if w_parent[cd] == id and w_visible[cd] != 0:
                _h_measure(cast[int32](cd))
            cd = cd + 1
        w_w[u] = w_req_w[u]
        w_h[u] = w_req_h[u]
        w_nat_w[u] = w_w[u]
        w_nat_h[u] = w_h[u]
        return

    # BOX_V / BOX_H / MENUBAR / TOOLBAR / FIXED: stack/sum children.
    hstrip: int32 = _h_is_hstrip(k)
    acc_main: int32 = 0
    max_cross: int32 = 0
    nvis: int32 = 0
    c: uint64 = 0
    while c < w_count:
        if w_parent[c] == id and w_visible[c] != 0:
            cw: int32 = 0
            ch: int32 = 0
            if k == HAMUI_K_MENUBAR and w_kind[c] == HAMUI_K_MENU:
                # Menu's bar footprint is just its title.
                cw = _h_menu_title_w(cast[int32](c))
                ch = 22
                w_w[c] = cw
                w_h[c] = ch
                w_nat_w[c] = cw
                w_nat_h[c] = ch
            else:
                _h_measure(cast[int32](c))
                cw = w_w[c]
                ch = w_h[c]
            if k == HAMUI_K_BOX_V:
                acc_main = acc_main + ch
                if cw > max_cross:
                    max_cross = cw
            elif hstrip != 0:
                acc_main = acc_main + cw
                if ch > max_cross:
                    max_cross = ch
            else:
                # FIXED: bounding box of placed children (use the immutable
                # source offset w_fx/w_fy, NOT w_x/w_y which arrange clobbers).
                ext_w: int32 = w_fx[c] + cw
                ext_h: int32 = w_fy[c] + ch
                if ext_w > acc_main:
                    acc_main = ext_w
                if ext_h > max_cross:
                    max_cross = ext_h
            nvis = nvis + 1
        c = c + 1
    if k == HAMUI_K_BOX_V:
        gaps: int32 = 0
        if nvis > 1:
            gaps = (nvis - 1) * sp
        w_w[u] = max_cross + pad * 2
        w_h[u] = acc_main + gaps + pad * 2
    elif hstrip != 0:
        gaps2: int32 = 0
        if nvis > 1:
            gaps2 = (nvis - 1) * sp
        w_w[u] = acc_main + gaps2 + pad * 2
        w_h[u] = max_cross + pad * 2
    else:
        w_w[u] = acc_main + pad * 2
        w_h[u] = max_cross + pad * 2
    # Honour explicit container size if set larger.
    if w_req_w[u] > w_w[u]:
        w_w[u] = w_req_w[u]
    if w_req_h[u] > w_h[u]:
        w_h[u] = w_req_h[u]
    w_nat_w[u] = w_w[u]
    w_nat_h[u] = w_h[u]


# Align a child of size (cw) within a track of size (avail) starting at
# `base`, per the child's halign/valign flag. Returns the placement origin;
# FILL grows the child to fill the track (mutates the child's size).
def _h_align_main(child: int32, base: int32, avail: int32, align: int32, \
                  is_w: int32) -> int32:
    cu: uint64 = cast[uint64](child)
    sz: int32 = w_w[cu]
    if is_w == 0:
        sz = w_h[cu]
    if align == HAMUI_ALIGN_FILL:
        if is_w != 0:
            w_w[cu] = avail
        else:
            w_h[cu] = avail
        return base
    if align == HAMUI_ALIGN_CENTER:
        return base + (avail - sz) / 2
    if align == HAMUI_ALIGN_END:
        return base + (avail - sz)
    return base


# Arrange: place `id` at (x,y) using its already-measured size, then lay
# out children. Honours hexpand/vexpand (slack distribution along the main
# axis) and halign/valign (placement within the cross track).
def _h_arrange(id: int32, x: int32, y: int32):
    u: uint64 = cast[uint64](id)
    w_x[u] = x
    w_y[u] = y
    k: int32 = w_kind[u]
    if _h_is_container(k) == 0:
        return
    pad: int32 = w_pad[u]
    sp: int32 = w_spacing[u]

    # NOTEBOOK: tab strip on top; the active page fills the content area.
    if k == HAMUI_K_NOTEBOOK:
        active: int32 = w_state[u]
        idx: int32 = 0
        cn: uint64 = 0
        while cn < w_count:
            if w_parent[cn] == id and w_kind[cn] == HAMUI_K_TABPAGE:
                if idx == active:
                    w_visible[cn] = 1
                    w_w[cn] = w_w[u] - 8
                    w_h[cn] = w_h[u] - 24 - 6
                    _h_arrange(cast[int32](cn), x + 4, y + 24 + 2)
                else:
                    w_visible[cn] = 0
                idx = idx + 1
            cn = cn + 1
        return

    # SCROLL: clip a single child into the viewport, offset by w_scroll.
    if k == HAMUI_K_SCROLL:
        cs: uint64 = 0
        while cs < w_count:
            if w_parent[cs] == id and w_visible[cs] != 0:
                _h_arrange(cast[int32](cs), x + 2, y + 2 - w_scroll[u])
            cs = cs + 1
        return

    # GRID: place each child at its cell origin (cumulative col/row tracks).
    if k == HAMUI_K_GRID:
        colw: Array[16, int32]
        rowh: Array[16, int32]
        ig: uint64 = 0
        while ig < 16:
            colw[ig] = 0
            rowh[ig] = 0
            ig = ig + 1
        ncol: int32 = 0
        nrow: int32 = 0
        cm: uint64 = 0
        while cm < w_count:
            if w_parent[cm] == id and w_visible[cm] != 0:
                col: int32 = w_gcol[cm]
                row: int32 = w_grow[cm]
                if col >= 0 and col < 16:
                    cwid: int32 = w_w[cm] / w_gcolspan[cm]
                    if cwid > colw[cast[uint64](col)]:
                        colw[cast[uint64](col)] = cwid
                    if col + 1 > ncol:
                        ncol = col + 1
                if row >= 0 and row < 16:
                    chgt: int32 = w_h[cm] / w_growspan[cm]
                    if chgt > rowh[cast[uint64](row)]:
                        rowh[cast[uint64](row)] = chgt
                    if row + 1 > nrow:
                        nrow = row + 1
            cm = cm + 1
        cp: uint64 = 0
        while cp < w_count:
            if w_parent[cp] == id and w_visible[cp] != 0:
                col2: int32 = w_gcol[cp]
                row2: int32 = w_grow[cp]
                ox: int32 = x + pad
                jc: int32 = 0
                while jc < col2:
                    ox = ox + colw[cast[uint64](jc)] + sp
                    jc = jc + 1
                oy: int32 = y + pad
                jr: int32 = 0
                while jr < row2:
                    oy = oy + rowh[cast[uint64](jr)] + sp
                    jr = jr + 1
                _h_arrange(cast[int32](cp), ox, oy)
            cp = cp + 1
        return

    # DIALOG: center the overlay in the window; lay children as a vbox.
    if k == HAMUI_K_DIALOG:
        dx: int32 = (cast[int32](HAMUI_WIN_W) - w_w[u]) / 2
        dy: int32 = (cast[int32](HAMUI_WIN_H) - w_h[u]) / 2
        w_x[u] = dx
        w_y[u] = dy
        cyd: int32 = dy + 28
        cd2: uint64 = 0
        while cd2 < w_count:
            if w_parent[cd2] == id and w_visible[cd2] != 0:
                _h_arrange(cast[int32](cd2), dx + 12, cyd)
                cyd = cyd + w_h[cd2] + sp
            cd2 = cd2 + 1
        return

    # BOX_V / BOX_H / MENUBAR / TOOLBAR / FIXED.
    hstrip: int32 = _h_is_hstrip(k)
    # Count expanders + sum natural main-axis sizes for slack distribution.
    nvis: int32 = 0
    nexp: int32 = 0
    natsum: int32 = 0
    cc0: uint64 = 0
    while cc0 < w_count:
        if w_parent[cc0] == id and w_visible[cc0] != 0:
            nvis = nvis + 1
            if k == HAMUI_K_BOX_V:
                natsum = natsum + w_h[cc0]
                if w_vexpand[cc0] != 0:
                    nexp = nexp + 1
            elif hstrip != 0:
                natsum = natsum + w_w[cc0]
                if w_hexpand[cc0] != 0:
                    nexp = nexp + 1
        cc0 = cc0 + 1
    inner_main: int32 = 0
    inner_cross: int32 = 0
    if k == HAMUI_K_BOX_V:
        inner_main = w_h[u] - pad * 2
        inner_cross = w_w[u] - pad * 2
    elif hstrip != 0:
        inner_main = w_w[u] - pad * 2
        inner_cross = w_h[u] - pad * 2
    gaps: int32 = 0
    if nvis > 1:
        gaps = (nvis - 1) * sp
    slack: int32 = inner_main - natsum - gaps
    if slack < 0:
        slack = 0
    each_exp: int32 = 0
    if nexp > 0:
        each_exp = slack / nexp
    cx: int32 = x + pad
    cy: int32 = y + pad
    c: uint64 = 0
    while c < w_count:
        if w_parent[c] == id and w_visible[c] != 0:
            if k == HAMUI_K_BOX_V:
                add: int32 = 0
                if w_vexpand[c] != 0:
                    add = each_exp
                w_h[c] = w_h[c] + add
                px: int32 = _h_align_main(cast[int32](c), cx, inner_cross, \
                                          w_halign[c], 1)
                _h_arrange(cast[int32](c), px, cy)
                cy = cy + w_h[c] + sp
            elif hstrip != 0:
                add2: int32 = 0
                if w_hexpand[c] != 0:
                    add2 = each_exp
                w_w[c] = w_w[c] + add2
                py: int32 = _h_align_main(cast[int32](c), cy, inner_cross, \
                                          w_valign[c], 0)
                _h_arrange(cast[int32](c), cx, py)
                cx = cx + w_w[c] + sp
            else:
                # FIXED: child's stored w_fx/w_fy are offsets within parent.
                # (Reading w_x/w_y here re-added the parent origin each frame,
                # accumulating a down+right drift — BUG #122.)
                _h_arrange(cast[int32](c), x + pad + w_fx[c], y + pad + w_fy[c])
        c = c + 1


def hamui_layout():
    # Root fills the window content area.
    if win_root < 0:
        return
    ru: uint64 = cast[uint64](win_root)
    _h_measure(win_root)
    # Let the root expand to the window if it measured smaller.
    if w_w[ru] < cast[int32](HAMUI_WIN_W):
        w_w[ru] = cast[int32](HAMUI_WIN_W)
    if w_h[ru] < cast[int32](HAMUI_WIN_H):
        w_h[ru] = cast[int32](HAMUI_WIN_H)
    _h_arrange(win_root, 0, 0)


# ====================================================================
# PAINT PASS — emit hamML into a single markup buffer, then write it to
# the window's "ui" markup layer in one syscall.
# ====================================================================

markup_buf: Array[8192, uint8]
mk_pos: uint64 = 0


def _h_mk_reset():
    # QA-N8 fix: the widget-tree paint backend is now the SCENE display
    # list (docs/de_scene_file_arch.md), NOT the retired /draw/ markup
    # layer. The kernel scene compositor rasterizes ONLY the per-window
    # scene buffer (devwsys.ad `_wsys_rasterize_window`); the markup layer
    # is served for `cat` but never composited, so the old markup path
    # painted nothing in the scene DE. Begin a fresh scene here; the paint
    # primitives below append scene ops and hamui_paint() commits them to
    # /dev/wsys/<wid>/scene — the SAME path hamsettings/hameditscene use,
    # which is why those render for a regular user and hamui apps did not.
    mk_pos = 0
    hamscene_begin()


def _h_mk_str(s: Ptr[uint8]):
    if mk_pos < 8000:
        mk_pos = _h_puts(&markup_buf[0], mk_pos, s)


def _h_mk_int(v: int32):
    if mk_pos < 8000:
        mk_pos = mk_pos + _h_i32_to_dec(v, &markup_buf[mk_pos])


# Emit "<rect x.. y.. w.. h.. fill=#rrggbb/>"
def _h_rect(x: int32, y: int32, w: int32, h: int32, col: Ptr[uint8]):
    if w <= 0 or h <= 0:
        return
    # Scene backend: a solid filled rectangle.
    hamscene_fill(x, y, w, h, col)


# A stroked segment (scene `line`, thickness 1).
def _h_line(x1: int32, y1: int32, x2: int32, y2: int32, col: Ptr[uint8]):
    hamscene_line(x1, y1, x2, y2, 1, col)


# Emit a 1px border as four thin rects (keeps the parser trivial).
def _h_border(x: int32, y: int32, w: int32, h: int32, col: Ptr[uint8]):
    _h_rect(x, y, w, 1, col)
    _h_rect(x, y + h - 1, w, 1, col)
    _h_rect(x, y, 1, h, col)
    _h_rect(x + w - 1, y, 1, h, col)


# Scratch used to marshal a NUL-terminated run for the scene glyphs op.
_h_txt_tmp: Array[512, uint8]


# Paint a widget's text via the scene `glyphs` op (cell-anchored: y = top).
def _h_text_widget(id: int32, x: int32, y: int32, col: Ptr[uint8]):
    base: uint64 = cast[uint64](id) * HAMUI_LABEL_CAP
    i: uint64 = 0
    while w_text[base + i] != 0 and i < 511:
        _h_txt_tmp[i] = w_text[base + i]
        i = i + 1
    _h_txt_tmp[i] = 0
    hamscene_glyphs(x, y, &_h_txt_tmp[0], col)


# Paint a literal string (list rows / dynamic text) as scene glyphs.
def _h_text_lit(s: Ptr[uint8], x: int32, y: int32, col: Ptr[uint8]):
    hamscene_glyphs(x, y, s, col)


# Paint at most `n` bytes of s (stopping early at NUL or '\t' if stop_tab)
# as a scene glyphs run. Used for treeview column cells + textview lines.
def _h_text_run(s: Ptr[uint8], n: uint64, x: int32, y: int32, \
                col: Ptr[uint8], stop_tab: int32):
    i: uint64 = 0
    o: uint64 = 0
    while i < n and s[i] != 0 and o < 511:
        c: uint8 = s[i]
        if stop_tab != 0 and c == 9:
            break
        if c == 9:
            c = 32
        _h_txt_tmp[o] = c
        o = o + 1
        i = i + 1
    _h_txt_tmp[o] = 0
    hamscene_glyphs(x, y, &_h_txt_tmp[0], col)


# Format a signed integer into a temp buffer + emit it as a text run.
numtmp: Array[16, uint8]

def _h_text_num(v: int32, x: int32, y: int32, col: Ptr[uint8]):
    n: uint64 = _h_i32_to_dec(v, &numtmp[0])
    numtmp[n] = 0
    _h_text_lit(&numtmp[0], x, y, col)


# Content height of a scrolledwindow = its single visible child's natural
# height (used to size the scrollbar thumb + clamp the scroll offset).
def _h_scroll_content_h(id: int32) -> int32:
    c: uint64 = 0
    while c < w_count:
        if w_parent[c] == id and w_visible[c] != 0:
            return w_nat_h[c]
        c = c + 1
    return 0


# Paint a multi-line editable textview: bordered box, lines split on '\n',
# vertical scroll by whole lines (w_scroll holds a line offset), caret.
def _h_paint_textview(id: int32):
    u: uint64 = cast[uint64](id)
    if tv_slot[u] < 0:
        return
    x: int32 = w_x[u]
    y: int32 = w_y[u]
    w: int32 = w_w[u]
    h: int32 = w_h[u]
    _h_rect(x, y, w, h, "#161616")
    bc: Ptr[uint8] = "#555555"
    if win_focus == id:
        bc = "#3584e4"
    _h_border(x, y, w, h, bc)
    base: uint64 = cast[uint64](tv_slot[u]) * HAMUI_TV_CAP
    vis_lines: int32 = (h - 6) / 16
    scroll_line: int32 = w_scroll[u]
    caret: int32 = tv_caret[u]
    # Walk the buffer line by line, tracking caret (col,row).
    line: int32 = 0
    col: int32 = 0
    caret_row: int32 = 0
    caret_col: int32 = 0
    i: uint64 = 0
    line_start: uint64 = i
    tlen: int32 = tv_len[u]
    # First locate the caret's row/col.
    j: int32 = 0
    cr: int32 = 0
    cc: int32 = 0
    while j < caret:
        if tv_buf[base + cast[uint64](j)] == 10:
            cr = cr + 1
            cc = 0
        else:
            cc = cc + 1
        j = j + 1
    caret_row = cr
    caret_col = cc
    # Paint visible lines.
    while line < scroll_line + vis_lines and line_start <= cast[uint64](tlen):
        if line >= scroll_line:
            # Find line end.
            le: uint64 = line_start
            while le < cast[uint64](tlen) and tv_buf[base + le] != 10:
                le = le + 1
            ry: int32 = y + 3 + (line - scroll_line) * 16
            _h_text_run(&tv_buf[base + line_start], le - line_start, x + 4, ry, "#e8e8e8", 0)
        # advance to next line.
        nx: uint64 = line_start
        while nx < cast[uint64](tlen) and tv_buf[base + nx] != 10:
            nx = nx + 1
        if nx >= cast[uint64](tlen):
            line_start = cast[uint64](tlen) + 1
        else:
            line_start = nx + 1
        line = line + 1
    # Caret.
    if win_focus == id:
        if caret_row >= scroll_line and caret_row < scroll_line + vis_lines:
            cxp: int32 = x + 4 + caret_col * 8
            cyp: int32 = y + 3 + (caret_row - scroll_line) * 16
            _h_rect(cxp, cyp, 1, 14, "#e8e8e8")


def _h_paint_widget(id: int32):
    u: uint64 = cast[uint64](id)
    if w_visible[u] == 0:
        return
    k: int32 = w_kind[u]
    x: int32 = w_x[u]
    y: int32 = w_y[u]
    w: int32 = w_w[u]
    h: int32 = w_h[u]
    if k == HAMUI_K_LABEL:
        _h_text_widget(id, x + 1, y, "#e0e0e0")
    elif k == HAMUI_K_BUTTON:
        # Highlight the button if it owns focus (keyboard/visual cue).
        fill: Ptr[uint8] = "#3584e4"
        if win_focus == id:
            fill = "#5a9bf0"
        # Rounded (KDE-ish) button: accent border ring + inset accent face.
        hamscene_roundrect(x, y, w, h, 5, "#26344f")
        hamscene_roundrect(x + 1, y + 1, w - 2, h - 2, 4, fill)
        _h_text_widget(id, x + 8, y + 4, "#ffffff")
    elif k == HAMUI_K_ENTRY:
        _h_rect(x, y, w, h, "#202020")
        bc: Ptr[uint8] = "#555555"
        if win_focus == id:
            bc = "#3584e4"
        _h_border(x, y, w, h, bc)
        _h_text_widget(id, x + 4, y + 3, "#f0f0f0")
        # Caret at the caret index (now real, can be mid-string).
        if win_focus == id:
            caret_x: int32 = x + 4 + w_state[u] * 8
            _h_rect(caret_x, y + 3, 1, 16, "#f0f0f0")
    elif k == HAMUI_K_CHECK:
        _h_rect(x, y, 16, 16, "#202020")
        _h_border(x, y, 16, 16, "#888888")
        if w_state[u] != 0:
            # A filled check mark (inner box).
            _h_rect(x + 3, y + 3, 10, 10, "#5fc46d")
        _h_text_widget(id, x + 22, y, "#e0e0e0")
    elif k == HAMUI_K_LIST:
        _h_rect(x, y, w, h, "#181818")
        _h_border(x, y, w, h, "#555555")
        sel: int32 = w_state[u]
        first: int32 = w_list_first[u]
        r: int32 = 0
        while r < w_list_count[u]:
            ry: int32 = y + 2 + r * 18
            if r == sel:
                _h_rect(x + 1, ry, w - 2, 18, "#3584e4")
            rowbase: uint64 = cast[uint64](first + r) * HAMUI_ROW_CAP
            _h_text_lit(&list_row_text[rowbase], x + 4, ry + 1, "#f0f0f0")
            r = r + 1
    elif k == HAMUI_K_RADIO:
        # Circular-ish indicator drawn as a small bordered box + inner dot.
        _h_rect(x, y, 16, 16, "#202020")
        _h_border(x, y, 16, 16, "#888888")
        if w_state[u] != 0:
            _h_rect(x + 4, y + 4, 8, 8, "#5a9bf0")
        _h_text_widget(id, x + 22, y, "#e0e0e0")
    elif k == HAMUI_K_SEP:
        if w_state[u] != 0:
            _h_rect(x + w / 2, y, 1, h, "#555555")
        else:
            _h_rect(x, y + h / 2, w, 1, "#555555")
    elif k == HAMUI_K_PROGRESS:
        _h_rect(x, y, w, h, "#202020")
        _h_border(x, y, w, h, "#555555")
        span: int32 = w_max[u] - w_min[u]
        if span <= 0:
            span = 1
        filled: int32 = (w_value[u] - w_min[u]) * (w - 2) / span
        if filled > 0:
            _h_rect(x + 1, y + 1, filled, h - 2, "#5fc46d")
        _h_text_num((w_value[u] - w_min[u]) * 100 / span, x + w / 2 - 8, y + 2, "#ffffff")
    elif k == HAMUI_K_SLIDER:
        # Track + draggable thumb.
        ty: int32 = y + h / 2
        _h_rect(x + 4, ty - 1, w - 8, 3, "#555555")
        span2: int32 = w_max[u] - w_min[u]
        if span2 <= 0:
            span2 = 1
        tx: int32 = x + 4 + (w_value[u] - w_min[u]) * (w - 16) / span2
        thumb: Ptr[uint8] = "#3584e4"
        if win_focus == id:
            thumb = "#5a9bf0"
        _h_rect(tx, y + 2, 8, h - 4, thumb)
        _h_border(tx, y + 2, 8, h - 4, "#26344f")
    elif k == HAMUI_K_SPIN:
        _h_rect(x, y, w, h, "#202020")
        _h_border(x, y, w, h, "#555555")
        if win_focus == id:
            _h_border(x, y, w, h, "#3584e4")
        _h_text_num(w_value[u], x + 4, y + 4, "#f0f0f0")
        # up/down buttons on the right edge.
        bx: int32 = x + w - 18
        _h_rect(bx, y, 18, h / 2, "#3a3a3a")
        _h_rect(bx, y + h / 2, 18, h - h / 2, "#3a3a3a")
        _h_border(bx, y, 18, h, "#555555")
        _h_text_lit("+", bx + 5, y + 1, "#e0e0e0")
        _h_text_lit("-", bx + 5, y + h / 2, "#e0e0e0")
    elif k == HAMUI_K_COMBO:
        _h_rect(x, y, w, h, "#202020")
        bcc: Ptr[uint8] = "#555555"
        if win_focus == id:
            bcc = "#3584e4"
        _h_border(x, y, w, h, bcc)
        sel2: int32 = w_state[u]
        if sel2 >= 0 and sel2 < w_list_count[u]:
            _h_text_lit(_h_row_ptr(id, sel2), x + 4, y + 4, "#f0f0f0")
        # dropdown arrow box.
        ax: int32 = x + w - 18
        _h_rect(ax, y + 1, 17, h - 2, "#3a3a3a")
        _h_text_lit("v", ax + 5, y + 4, "#e0e0e0")
        # If open, draw the popdown list below (z order: drawn here, late).
        if w_value[u] != 0:
            r2: int32 = 0
            while r2 < w_list_count[u]:
                py2: int32 = y + h + r2 * 18
                _h_rect(x, py2, w, 18, "#181818")
                _h_border(x, py2, w, 18, "#555555")
                _h_text_lit(_h_row_ptr(id, r2), x + 4, py2 + 1, "#f0f0f0")
                r2 = r2 + 1
    elif k == HAMUI_K_IMAGE:
        # Placeholder: filled rect + diagonal cross (the "missing image"
        # convention) so it reads as an image slot, not empty space.
        _h_rect(x, y, w, h, "#303848")
        _h_border(x, y, w, h, "#5a9bf0")
        _h_line(x, y, x + w - 1, y + h - 1, "#5a9bf0")
        _h_line(x + w - 1, y, x, y + h - 1, "#5a9bf0")
    elif k == HAMUI_K_STATUSBAR:
        _h_rect(x, y, w, h, "#1e1e1e")
        _h_rect(x, y, w, 1, "#444444")
        _h_text_widget(id, x + 6, y + 2, "#c0c0c0")
    elif k == HAMUI_K_TOOLBAR:
        _h_rect(x, y, w, h, "#333333")
        _h_rect(x, y + h - 1, w, 1, "#222222")
    elif k == HAMUI_K_MENUBAR:
        _h_rect(x, y, w, h, "#333333")
        _h_rect(x, y + h - 1, w, 1, "#222222")
    elif k == HAMUI_K_MENU:
        # The bar title cell; highlight if open.
        if w_state[u] != 0:
            _h_rect(x, y, w, h, "#3584e4")
        _h_text_widget(id, x + 8, y + 3, "#e0e0e0")
        # If open, draw the popdown of MENUITEM children below the title.
        if w_state[u] != 0:
            mi: uint64 = 0
            row3: int32 = 0
            # Widest item determines popup width.
            maxw: int32 = 80
            while mi < w_count:
                if w_parent[mi] == id and w_kind[mi] == HAMUI_K_MENUITEM:
                    iw: int32 = cast[int32](_h_text_len(cast[int32](mi))) * 8 + 16
                    if iw > maxw:
                        maxw = iw
                mi = mi + 1
            mi = 0
            while mi < w_count:
                if w_parent[mi] == id and w_kind[mi] == HAMUI_K_MENUITEM:
                    iy: int32 = y + h + row3 * 20
                    _h_rect(x, iy, maxw, 20, "#252525")
                    _h_border(x, iy, maxw, 20, "#555555")
                    _h_text_widget(cast[int32](mi), x + 8, iy + 2, "#e0e0e0")
                    # Stash the item's hit rect for the click router.
                    w_x[mi] = x
                    w_y[mi] = iy
                    w_w[mi] = maxw
                    w_h[mi] = 20
                    row3 = row3 + 1
                mi = mi + 1
    elif k == HAMUI_K_NOTEBOOK:
        _h_rect(x, y + 24, w, h - 24, "#262626")
        _h_border(x, y + 24, w, h - 24, "#555555")
        # Tab strip.
        active2: int32 = w_state[u]
        tabx: int32 = x + 4
        idx2: int32 = 0
        tp: uint64 = 0
        while tp < w_count:
            if w_parent[tp] == id and w_kind[tp] == HAMUI_K_TABPAGE:
                tw: int32 = cast[int32](_h_text_len(cast[int32](tp))) * 8 + 16
                tcol: Ptr[uint8] = "#333333"
                if idx2 == active2:
                    tcol = "#262626"
                _h_rect(tabx, y, tw, 24, tcol)
                _h_border(tabx, y, tw, 24, "#555555")
                _h_text_widget(cast[int32](tp), tabx + 8, y + 4, "#e0e0e0")
                # Stash tab-strip hit rect on the page for the click router.
                w_x[tp] = tabx
                w_y[tp] = y
                w_w[tp] = tw
                w_h[tp] = 24
                tabx = tabx + tw + 2
                idx2 = idx2 + 1
            tp = tp + 1
    elif k == HAMUI_K_SCROLL:
        _h_rect(x, y, w, h, "#181818")
        _h_border(x, y, w, h, "#555555")
        # Modern thin rounded scrollbar: a subtle rounded track + a rounded
        # accent thumb on the right edge (no arrow buttons).
        ch2: int32 = _h_scroll_content_h(id)
        if ch2 > h:
            hamscene_roundrect(x + w - 8, y + 1, 6, h - 2, 3, "#222222")
            tlen: int32 = (h - 2) * (h - 2) / ch2
            if tlen < 24:
                tlen = 24
            maxoff: int32 = ch2 - h
            if maxoff < 1:
                maxoff = 1
            toff: int32 = w_scroll[u] * (h - 2 - tlen) / maxoff
            hamscene_roundrect(x + w - 8, y + 1 + toff, 6, tlen, 3, "#3584e4")
    elif k == HAMUI_K_TREEVIEW:
        _h_rect(x, y, w, h, "#181818")
        _h_border(x, y, w, h, "#555555")
        # Header row.
        _h_rect(x + 1, y + 1, w - 2, 18, "#2e2e2e")
        ncols: int32 = w_value[u]
        if ncols < 1:
            ncols = 1
        colw3: int32 = (w - 4) / ncols
        sel3: int32 = w_state[u]
        first3: int32 = w_list_first[u]
        rr: int32 = 0
        while rr < w_list_count[u]:
            ry3: int32 = y + 20 + rr * 18
            if rr == sel3:
                _h_rect(x + 1, ry3, w - 2, 18, "#3584e4")
            # Split the row's text on '\t' across the column tracks.
            rb: uint64 = cast[uint64](first3 + rr) * HAMUI_ROW_CAP
            colidx: int32 = 0
            p3: uint64 = 0
            colstart: uint64 = 0
            while colidx < ncols:
                # advance colstart to current segment start (already at p3)
                cxp: int32 = x + 4 + colidx * colw3
                _h_text_run(&list_row_text[rb + p3], 60, cxp, ry3 + 1, "#f0f0f0", 1)
                # skip to next '\t'
                while list_row_text[rb + p3] != 0 and list_row_text[rb + p3] != 9:
                    p3 = p3 + 1
                if list_row_text[rb + p3] == 9:
                    p3 = p3 + 1
                colidx = colidx + 1
            rr = rr + 1
    elif k == HAMUI_K_TEXTVIEW:
        _h_paint_textview(id)
    elif k == HAMUI_K_CALENDAR:
        _h_paint_calendar(id)
    elif k == HAMUI_K_DIALOG:
        # Backdrop dim + the dialog panel + title bar.
        _h_rect(0, 0, cast[int32](HAMUI_WIN_W), cast[int32](HAMUI_WIN_H), "#000000")
        _h_rect(x, y, w, h, "#2e2e2e")
        _h_border(x, y, w, h, "#5a9bf0")
        _h_rect(x, y, w, 24, "#3a3a3a")
        _h_text_widget(id, x + 8, y + 4, "#ffffff")
    # Other containers paint no chrome (transparent layout boxes).
    return


# An overlay widget paints LAST (on top): dialogs always, and an open
# menu/combo (so its popdown isn't occluded by later widgets).
def _h_is_overlay(id: int32) -> int32:
    u: uint64 = cast[uint64](id)
    k: int32 = w_kind[u]
    if k == HAMUI_K_DIALOG and w_visible[u] != 0:
        return 1
    if k == HAMUI_K_MENU and w_state[u] != 0:
        return 1
    if k == HAMUI_K_COMBO and w_value[u] != 0:
        return 1
    return 0


# --- TOOLTIP dwell + paint --------------------------------------------
# Advance the hover dwell once per event-loop step. Find the widget under
# the pointer (reusing the toolkit's hit-test plumbing); if it carries a
# tooltip and the pointer has dwelt on it long enough, mark it as showing.
# Moving to a different widget resets the dwell and hides any bubble.
# Returns 1 if the showing-state changed (so the caller can repaint).
def _h_tooltip_step() -> int32:
    hit: int32 = _h_hit_test(cur_x, cur_y)
    prev_show: int32 = _htt_show
    if hit != _htt_hover:
        # Moved to a different widget: reset dwell on the old, hide bubble.
        if _htt_hover >= 0:
            _htt_dwell[cast[uint64](_htt_hover)] = 0
        _htt_hover = hit
        _htt_show = -1
    if hit >= 0 and _htt_text[cast[uint64](hit)] != cast[Ptr[uint8]](0):
        d: int32 = _htt_dwell[cast[uint64](hit)] + 1
        _htt_dwell[cast[uint64](hit)] = d
        if d >= _htt_THRESHOLD:
            _htt_show = hit
    else:
        _htt_show = -1
    if _htt_show != prev_show:
        return 1
    return 0


# Force-hide any showing tooltip and reset the active dwell (called on a
# button press, so a click never leaves a stale bubble on screen).
def _h_tooltip_hide():
    if _htt_hover >= 0:
        _htt_dwell[cast[uint64](_htt_hover)] = 0
    _htt_show = -1


# Paint the active tooltip bubble: a small bordered, light-background box
# with dark text, positioned just below-right of the pointer and clamped to
# the window bounds. Emitted LAST so it sits at the highest z.
def _h_paint_tooltip():
    if _htt_show < 0:
        return
    s: Ptr[uint8] = _htt_text[cast[uint64](_htt_show)]
    if s == cast[Ptr[uint8]](0):
        return
    n: int32 = cast[int32](_h_strlen(s))
    if n <= 0:
        return
    # 8x16 mono glyphs; pad 5px each side, 16px tall text -> 22px box.
    bw: int32 = n * 8 + 10
    bh: int32 = 22
    bx: int32 = cur_x + 12
    by: int32 = cur_y + 18
    # Clamp to window bounds.
    if bx + bw > cast[int32](HAMUI_WIN_W):
        bx = cast[int32](HAMUI_WIN_W) - bw
    if bx < 0:
        bx = 0
    if by + bh > cast[int32](HAMUI_WIN_H):
        by = cur_y - bh - 4               # flip above the pointer
    if by < 0:
        by = 0
    # Subtle border + light background + dark text (existing palette style).
    _h_rect(bx, by, bw, bh, "#fdf6d3")
    _h_border(bx, by, bw, bh, "#8a8a5a")
    _h_text_lit(s, bx + 5, by + 3, "#202020")


def hamui_paint():
    # Clear, paint a window background, then every widget (creation order
    # == back-to-front; containers are transparent so order is fine). A
    # second pass paints overlays (open menus/combos, dialogs) on top.
    _h_mk_reset()
    _h_rect(0, 0, cast[int32](HAMUI_WIN_W), cast[int32](HAMUI_WIN_H), "#2b2b2b")
    i: uint64 = 0
    while i < w_count:
        if _h_is_overlay(cast[int32](i)) == 0:
            _h_paint_widget(cast[int32](i))
        i = i + 1
    # Overlay pass.
    i = 0
    while i < w_count:
        if _h_is_overlay(cast[int32](i)) != 0:
            _h_paint_widget(cast[int32](i))
        i = i + 1
    # Tooltip bubble paints LAST so it sits at the highest z above all else.
    _h_paint_tooltip()
    # Publish the display list atomically to /dev/wsys/<wid>/scene and poke
    # `commit` (hamscene_commit). This is the ONLY path the kernel scene
    # compositor rasterizes; the retired /draw/ markup layer painted nothing.
    if win_wid < 0:
        return
    if hamscene_commit(win_wid) < 0:
        _h_report_open_fail("scene commit", win_wid)


# ====================================================================
# WINDOW + LAYER setup.
# ====================================================================

def _h_ctl(verb: Ptr[uint8]):
    # The draw CTL sink is /dev/wsys/<wid>/draw/ctl. _h_build_path only
    # appends a trailing segment when it is the LAYER arg (a NULL layer +
    # non-NULL leaf collapses to the bare ".../draw" read-only listing,
    # which silently drops writes). So pass "ctl" as the LAYER token.
    _h_build_path(win_wid, "ctl", cast[Ptr[uint8]](0))
    fd: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if fd >= 0:
        sys_write(fd, verb, _h_strlen(verb))
        sys_close(fd)


def hamui_window_on(root: int32, wid: int32) -> int32:
    # Bind the toolkit to an EXISTING window `wid`. `root` is the content
    # widget. Returns the wid on success, -1 on a bad arg. Used by v2/blit
    # clients (they get a compositor-allocated wid via /dev/wsys/self or
    # argv). Scene-backend apps normally use hamui_window(), which
    # self-allocates an owned top-level. The legacy mklayer/setz pokes are
    # retained for back-compat but paint nothing in the scene DE.
    if root < 0 or wid < 1:
        return -1
    win_root = root
    win_wid = wid
    _h_ctl("mklayer ui markup\n")
    _h_ctl("setz ui 10\n")
    return win_wid


# App-visible window title (taskbar + SSD). Set BEFORE hamui_window().
_h_win_title: Array[64, uint8]
_h_win_title_set: int32 = 0


def hamui_set_title(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 63:
        _h_win_title[i] = s[i]
        i = i + 1
    _h_win_title[i] = 0
    _h_win_title_set = 1
    # LIVE UPDATE: if the top-level window already exists (title set AFTER
    # hamui_window()), push a fresh `title` ctl write now so the compositor's
    # per-window title field — and therefore the panel taskbar / SSD — reflect
    # the new name immediately, not only the one snapshotted at _h_win_setup().
    if win_wid >= 2:
        tbuf: Array[80, uint8]
        tp: uint64 = _h_puts(&tbuf[0], 0, "title ")
        k: uint64 = 0
        while _h_win_title[k] != 0 and tp < 76:
            tbuf[tp] = _h_win_title[k]
            tp = tp + 1
            k = k + 1
        tbuf[tp] = 10
        tbuf[tp + 1] = 0
        _h_win_ctl(win_wid, &tbuf[0])


def _h_report_open_fail(what: Ptr[uint8], wid: int32):
    # Visibility for a failed window-file open/commit (QA-N8 deliverable):
    # the old paths failed silently. Emit one diagnostic line to stderr.
    msg: Ptr[uint8] = "[hamui] window op failed: "
    sys_write(2, msg, _h_strlen(msg))
    sys_write(2, what, _h_strlen(what))
    tail: Ptr[uint8] = " wid="
    sys_write(2, tail, _h_strlen(tail))
    nb: Array[16, uint8]
    n: uint64 = _h_i32_to_dec(wid, &nb[0])
    nb[n] = 10
    sys_write(2, &nb[0], n + 1)


def _h_win_ctl(wid: int32, verb: Ptr[uint8]) -> int32:
    # Write one verb line to the per-window control file /dev/wsys/<wid>/ctl
    # (geometry / decorate / z / title). Ownership-gated by the kernel to the
    # window's OWNER (creator pid or ancestor) — so a regular-user app that
    # self-allocated its own window passes the gate. Returns 0 / -1.
    _h_build_wsys_path(wid, "ctl")
    fd: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        _h_report_open_fail("ctl open", wid)
        return -1
    sys_write(fd, verb, _h_strlen(verb))
    sys_close(fd)
    return 0


def _h_alloc_wid_from_ctl() -> int32:
    # Read the wid this task was spawned into (/dev/wsys/self); if none
    # (standalone / serial launch → "0" or foreground "1"), self-allocate an
    # OWNED top-level via `newwindow` on /dev/wsys/ctl and read it back. This
    # is the SAME self-serve path hamsettings uses, and it works for a
    # regular user because the resulting window is owned by the caller.
    sfd: int32 = sys_open("/dev/wsys/self")
    if sfd >= 0:
        sbuf: Array[16, uint8]
        sn: int64 = sys_read(sfd, &sbuf[0], 15)
        sys_close(sfd)
        if sn > 0:
            v: int32 = 0
            i: uint64 = 0
            while i < cast[uint64](sn) and sbuf[i] >= 48 and sbuf[i] <= 57:
                v = v * 10 + cast[int32](sbuf[i]) - 48
                i = i + 1
            if v >= 2:
                return v                       # compositor-allocated, owned
    # Self-allocate.
    wfd: int32 = sys_open_write("/dev/wsys/ctl")
    if wfd < 0:
        _h_report_open_fail("wsys/ctl open (newwindow)", -1)
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open("/dev/wsys/ctl")
    if rfd < 0:
        _h_report_open_fail("wsys/ctl read (newwindow)", -1)
        return -1
    rbuf: Array[16, uint8]
    rn: int64 = sys_read(rfd, &rbuf[0], 15)
    sys_close(rfd)
    nw: int32 = 0
    if rn > 0:
        j: uint64 = 0
        while j < cast[uint64](rn) and rbuf[j] >= 48 and rbuf[j] <= 57:
            nw = nw * 10 + cast[int32](rbuf[j]) - 48
            j = j + 1
    if nw >= 2:
        return nw
    return -1


def _h_win_setup(wid: int32):
    # Turn a freshly-allocated wid into a real, taskbar-listed top-level: set
    # geometry, mark it a decorated app window (so the SSD titlebar draws and
    # /dev/wsys/windows enumerates it for the panel taskbar), give it a z and
    # a title. Mirrors user/hameditscene.ad's proven scene-window setup.
    gbuf: Array[64, uint8]
    p: uint64 = _h_puts(&gbuf[0], 0, "geometry 120 90 ")
    p = p + _h_i32_to_dec(cast[int32](HAMUI_WIN_W), &gbuf[p])
    gbuf[p] = 32
    p = p + 1
    p = p + _h_i32_to_dec(cast[int32](HAMUI_WIN_H), &gbuf[p])
    gbuf[p] = 10
    gbuf[p + 1] = 0
    _h_win_ctl(wid, &gbuf[0])
    _h_win_ctl(wid, cast[Ptr[uint8]]("decorate 1\n"))
    _h_win_ctl(wid, cast[Ptr[uint8]]("z 6\n"))
    # Title line: "title <name>\n".
    tbuf: Array[80, uint8]
    tp: uint64 = _h_puts(&tbuf[0], 0, "title ")
    if _h_win_title_set != 0:
        k: uint64 = 0
        while _h_win_title[k] != 0 and tp < 76:
            tbuf[tp] = _h_win_title[k]
            tp = tp + 1
            k = k + 1
    else:
        tp = _h_puts(&tbuf[0], tp, "Hamnix")
    tbuf[tp] = 10
    tbuf[tp + 1] = 0
    _h_win_ctl(wid, &tbuf[0])


def hamui_window(root: int32) -> int32:
    # Create (or adopt) an OWNED top-level window and bind the toolkit to it.
    # QA-N8 fix: previously this hard-bound wid 1 (the foreground console
    # window), which a regular user launching from a shell does NOT own — so
    # every scene/ctl write was permission-denied and nothing rendered, and
    # wid 1 is never a taskbar window anyway. Now we discover our
    # compositor-allocated wid (or self-allocate one we own) exactly like the
    # working raw-scene apps, then set it up as a decorated top-level.
    if root < 0:
        return -1
    wid: int32 = _h_alloc_wid_from_ctl()
    if wid < 1:
        _h_report_open_fail("no window (alloc failed)", -1)
        return -1
    win_root = root
    win_wid = wid
    if wid >= 2:
        _h_win_setup(wid)
    return win_wid


def hamui_window_wid() -> int32:
    return win_wid


# Programmatically focus a widget (e.g. a command entry) so keystrokes
# routed via /dev/wsys/<wid>/keys land on it WITHOUT a prior mouse click.
# Normally focus follows a click (_h_route_click); a compositor-spawned app
# with no pointer interaction yet needs to seed an initial keyboard focus so
# its primary input field is live the moment the window is shown. Mirrors
# GTK's gtk_widget_grab_focus(). No-op for an out-of-range id.
def hamui_focus(id: int32):
    if id < 0 or cast[uint64](id) >= w_count:
        return
    win_focus = id


# ====================================================================
# EVENT PASS — hit-test pointer + dispatch keys.
# ====================================================================

# Topmost visible leaf/interactive widget containing (px,py). Returns -1.
def _h_hit_test(px: int32, py: int32) -> int32:
    # Walk in REVERSE creation order so later (front) widgets win.
    i: int64 = cast[int64](w_count) - 1
    while i >= 0:
        u: uint64 = cast[uint64](i)
        k: int32 = w_kind[u]
        hittable: int32 = 1
        if w_visible[u] == 0 or _h_is_container(k) != 0:
            hittable = 0
        # A menu item is only hittable while its menu is open (its hit rect
        # is stashed by the paint pass and is stale once closed).
        if k == HAMUI_K_MENUITEM:
            p: int32 = w_parent[u]
            if p < 0 or w_state[cast[uint64](p)] == 0:
                hittable = 0
        if hittable != 0:
            x: int32 = w_x[u]
            y: int32 = w_y[u]
            if px >= x and px < x + w_w[u] and py >= y and py < y + w_h[u]:
                return cast[int32](i)
        i = i - 1
    return -1


# Close every open menu / combo popdown (called before opening another or
# on a click that lands outside any popdown).
def _h_close_popups():
    i: uint64 = 0
    while i < w_count:
        if w_kind[i] == HAMUI_K_MENU:
            w_state[i] = 0
        elif w_kind[i] == HAMUI_K_COMBO:
            w_value[i] = 0
        i = i + 1


# Set the caret of an entry to the click x (snap to nearest glyph cell).
def _h_entry_caret_from_x(id: int32, px: int32):
    u: uint64 = cast[uint64](id)
    rel: int32 = px - (w_x[u] + 4)
    col: int32 = (rel + 4) / 8
    if col < 0:
        col = 0
    n: int32 = cast[int32](_h_text_len(id))
    if col > n:
        col = n
    w_state[u] = col


# Set the textview caret from a click (row,col -> byte offset).
def _h_tv_caret_from_click(id: int32, px: int32, py: int32):
    u: uint64 = cast[uint64](id)
    if tv_slot[u] < 0:
        return
    base: uint64 = cast[uint64](tv_slot[u]) * HAMUI_TV_CAP
    rrow: int32 = (py - (w_y[u] + 3)) / 16 + w_scroll[u]
    rcol: int32 = (px - (w_x[u] + 4) + 4) / 8
    if rrow < 0:
        rrow = 0
    if rcol < 0:
        rcol = 0
    # Walk to the start of row rrow, then advance rcol (clamped to EOL).
    off: int32 = 0
    line: int32 = 0
    tlen: int32 = tv_len[u]
    while line < rrow and off < tlen:
        if tv_buf[base + cast[uint64](off)] == 10:
            line = line + 1
        off = off + 1
    cc: int32 = 0
    while cc < rcol and off < tlen and tv_buf[base + cast[uint64](off)] != 10:
        off = off + 1
        cc = cc + 1
    w_tv_caret_set(id, off)


def w_tv_caret_set(id: int32, off: int32):
    u: uint64 = cast[uint64](id)
    o: int32 = off
    if o < 0:
        o = 0
    if o > tv_len[u]:
        o = tv_len[u]
    tv_caret[u] = o


def _h_dispatch_click(tid: int32):
    if tid < 0:
        return
    u: uint64 = cast[uint64](tid)
    k: int32 = w_kind[u]
    if k == HAMUI_K_BUTTON:
        win_focus = tid
        w_signal[u] = 1                              # fire the button signal
    elif k == HAMUI_K_ENTRY:
        win_focus = tid
        _h_entry_caret_from_x(tid, cur_x)
    elif k == HAMUI_K_TEXTVIEW:
        win_focus = tid
        _h_tv_caret_from_click(tid, cur_x, cur_y)
    elif k == HAMUI_K_CHECK:
        win_focus = tid
        if w_state[u] != 0:
            w_state[u] = 0
        else:
            w_state[u] = 1
        w_signal[u] = 1                              # toggled
    elif k == HAMUI_K_RADIO:
        win_focus = tid
        # Uncheck every other radio in the same group, check this one.
        g: int32 = w_group[u]
        i2: uint64 = 0
        while i2 < w_count:
            if w_kind[i2] == HAMUI_K_RADIO and w_group[i2] == g:
                w_state[i2] = 0
            i2 = i2 + 1
        w_state[u] = 1
        w_signal[u] = 1
    elif k == HAMUI_K_LIST:
        win_focus = tid
        # Which row was hit?
        row: int32 = (cur_y - (w_y[u] + 2)) / 18
        if row >= 0 and row < w_list_count[u]:
            w_state[u] = row
            w_signal[u] = 1                          # selection changed
    elif k == HAMUI_K_TREEVIEW:
        win_focus = tid
        trow: int32 = (cur_y - (w_y[u] + 20)) / 18
        if trow >= 0 and trow < w_list_count[u]:
            w_state[u] = trow
            w_signal[u] = 1
    elif k == HAMUI_K_SLIDER:
        win_focus = tid
        span: int32 = w_max[u] - w_min[u]
        rel: int32 = cur_x - (w_x[u] + 4)
        track: int32 = w_w[u] - 16
        if track < 1:
            track = 1
        nv: int32 = w_min[u] + rel * span / track
        if nv < w_min[u]:
            nv = w_min[u]
        if nv > w_max[u]:
            nv = w_max[u]
        w_value[u] = nv
        w_signal[u] = 1
    elif k == HAMUI_K_SPIN:
        win_focus = tid
        # Click upper half = +step, lower half = -step (button column).
        if cur_x >= w_x[u] + w_w[u] - 18:
            if cur_y < w_y[u] + w_h[u] / 2:
                hamui_set_value(tid, w_value[u] + w_step[u])
            else:
                hamui_set_value(tid, w_value[u] - w_step[u])
            w_signal[u] = 1
    elif k == HAMUI_K_CALENDAR:
        win_focus = tid
        _hcal_click(tid, cur_x, cur_y)
    elif k == HAMUI_K_MENUITEM:
        # A menu item fired: signal it + close the menus.
        win_focus = tid
        w_signal[u] = 1
        _h_close_popups()


# Route a raw click at (px,py) considering overlays first (open combo
# popdowns + menubar/menu titles + notebook tabs), then fall back to the
# normal leaf hit-test.
def _h_route_click(px: int32, py: int32):
    # 1. An open combo popdown row?
    i: uint64 = 0
    while i < w_count:
        if w_kind[i] == HAMUI_K_COMBO and w_value[i] != 0:
            cx: int32 = w_x[i]
            cy: int32 = w_y[i] + w_h[i]
            r: int32 = 0
            while r < w_list_count[i]:
                ry: int32 = cy + r * 18
                if px >= cx and px < cx + w_w[i] and py >= ry and py < ry + 18:
                    w_state[i] = r
                    w_value[i] = 0                   # close
                    w_signal[i] = 1
                    return
                r = r + 1
        i = i + 1
    # 2. A menubar menu title (toggle open) — the MENU widget is a child of
    #    a MENUBAR; its bar rect is (w_x,w_y,w_w,w_h) from layout.
    i = 0
    while i < w_count:
        if w_kind[i] == HAMUI_K_MENU:
            mx: int32 = w_x[i]
            my: int32 = w_y[i]
            if px >= mx and px < mx + w_w[i] and py >= my and py < my + 22:
                was: int32 = w_state[i]
                _h_close_popups()
                if was == 0:
                    w_state[i] = 1                   # open this one
                return
        i = i + 1
    # 3. Notebook tab strip (switch active page).
    i = 0
    while i < w_count:
        if w_kind[i] == HAMUI_K_TABPAGE:
            tx: int32 = w_x[i]
            ty: int32 = w_y[i]
            # Only the 24px tab cell stashed by paint counts as a tab click.
            if py >= ty and py < ty + 24 and px >= tx and px < tx + w_w[i]:
                nb: int32 = w_parent[i]
                # Compute this page's index within its notebook.
                idx: int32 = 0
                j: uint64 = 0
                while j < i:
                    if w_parent[j] == nb and w_kind[j] == HAMUI_K_TABPAGE:
                        idx = idx + 1
                    j = j + 1
                w_state[cast[uint64](nb)] = idx
                _h_close_popups()
                return
        i = i + 1
    # 4. A combo body (open it).
    i = 0
    while i < w_count:
        if w_kind[i] == HAMUI_K_COMBO and w_visible[i] != 0:
            cx2: int32 = w_x[i]
            cy2: int32 = w_y[i]
            if px >= cx2 and px < cx2 + w_w[i] and py >= cy2 and py < cy2 + w_h[i]:
                op: int32 = w_value[i]
                _h_close_popups()
                if op == 0:
                    w_value[i] = 1
                    win_focus = cast[int32](i)
                return
        i = i + 1
    # 5. Fall through to the normal leaf hit-test.
    _h_close_popups()
    _h_dispatch_click(_h_hit_test(px, py))


# ---- ENTRY editing (real: insert at caret, backspace/delete, nav) ----

# Insert char c into the focused entry at its caret, shifting the tail.
def _h_entry_insert(id: int32, c: uint8):
    u: uint64 = cast[uint64](id)
    base: uint64 = u * HAMUI_LABEL_CAP
    n: int32 = cast[int32](_h_text_len(id))
    if cast[uint64](n) >= HAMUI_LABEL_CAP - 1:
        return
    caret: int32 = w_state[u]
    if caret < 0:
        caret = 0
    if caret > n:
        caret = n
    # Shift [caret..n) right by one.
    j: int32 = n
    while j > caret:
        w_text[base + cast[uint64](j)] = w_text[base + cast[uint64](j - 1)]
        j = j - 1
    w_text[base + cast[uint64](caret)] = c
    w_text[base + cast[uint64](n + 1)] = 0
    w_state[u] = caret + 1


def _h_entry_backspace(id: int32):
    u: uint64 = cast[uint64](id)
    base: uint64 = u * HAMUI_LABEL_CAP
    n: int32 = cast[int32](_h_text_len(id))
    caret: int32 = w_state[u]
    if caret <= 0:
        return
    j: int32 = caret - 1
    while j < n - 1:
        w_text[base + cast[uint64](j)] = w_text[base + cast[uint64](j + 1)]
        j = j + 1
    w_text[base + cast[uint64](n - 1)] = 0
    w_state[u] = caret - 1


def _h_entry_delete(id: int32):
    u: uint64 = cast[uint64](id)
    base: uint64 = u * HAMUI_LABEL_CAP
    n: int32 = cast[int32](_h_text_len(id))
    caret: int32 = w_state[u]
    if caret >= n:
        return
    j: int32 = caret
    while j < n - 1:
        w_text[base + cast[uint64](j)] = w_text[base + cast[uint64](j + 1)]
        j = j + 1
    w_text[base + cast[uint64](n - 1)] = 0


# ---- TEXTVIEW editing ----

def _h_tv_insert(id: int32, c: uint8):
    u: uint64 = cast[uint64](id)
    if tv_slot[u] < 0:
        return
    base: uint64 = cast[uint64](tv_slot[u]) * HAMUI_TV_CAP
    n: int32 = tv_len[u]
    if cast[uint64](n) >= HAMUI_TV_CAP - 1:
        return
    caret: int32 = tv_caret[u]
    j: int32 = n
    while j > caret:
        tv_buf[base + cast[uint64](j)] = tv_buf[base + cast[uint64](j - 1)]
        j = j - 1
    tv_buf[base + cast[uint64](caret)] = c
    tv_len[u] = n + 1
    tv_buf[base + cast[uint64](n + 1)] = 0
    tv_caret[u] = caret + 1


def _h_tv_backspace(id: int32):
    u: uint64 = cast[uint64](id)
    if tv_slot[u] < 0:
        return
    base: uint64 = cast[uint64](tv_slot[u]) * HAMUI_TV_CAP
    n: int32 = tv_len[u]
    caret: int32 = tv_caret[u]
    if caret <= 0:
        return
    j: int32 = caret - 1
    while j < n - 1:
        tv_buf[base + cast[uint64](j)] = tv_buf[base + cast[uint64](j + 1)]
        j = j + 1
    tv_len[u] = n - 1
    tv_buf[base + cast[uint64](n - 1)] = 0
    tv_caret[u] = caret - 1


# Dispatch a typed character to the focused widget. Handles ESC-bracket
# arrow sequences via a tiny 3-state decoder so Left/Right/Home/End/Del
# navigate. Printable ASCII inserts at the caret.
key_esc: int32 = 0                    # 0=normal 1=after ESC 2=after ESC '['

# Set whenever Ctrl-S (0x13) is pressed while a TEXTVIEW holds focus. The
# toolkit swallows the control byte (so it is NOT inserted into the
# document) and raises this latch instead. An app polls/clears it via
# hamui_save_requested() to drive a Save action. Mirrors the GTK
# "accelerator" idea without a full accel table.
save_req: int32 = 0


# App-facing: did the user press Ctrl-S since the last call? Clears the
# latch. Returns 1 once per keypress, 0 otherwise.
def hamui_save_requested() -> int32:
    if save_req != 0:
        save_req = 0
        return 1
    return 0


# Set whenever Ctrl-D (0x04, EOT) is pressed while an ENTRY or TEXTVIEW
# holds focus. The toolkit swallows the control byte (never inserts it into
# the document) and raises this latch. A terminal-style app polls it via
# hamui_eof_requested() to deliver EOF to its shell — the GUI analogue of
# pressing Ctrl-D at a real tty prompt (closes stdin -> shell exits).
eof_req: int32 = 0


# App-facing: did the user press Ctrl-D since the last call? Clears the
# latch. Returns 1 once per keypress, 0 otherwise.
def hamui_eof_requested() -> int32:
    if eof_req != 0:
        eof_req = 0
        return 1
    return 0


def _h_dispatch_key(c: uint8):
    if win_focus < 0:
        key_esc = 0
        return
    u: uint64 = cast[uint64](win_focus)
    k: int32 = w_kind[u]
    is_entry: int32 = 0
    if k == HAMUI_K_ENTRY:
        is_entry = 1
    is_tv: int32 = 0
    if k == HAMUI_K_TEXTVIEW:
        is_tv = 1
    if is_entry == 0 and is_tv == 0:
        key_esc = 0
        return
    # --- ESC-sequence decoder for arrow / home / end / delete keys ---
    if key_esc == 1:
        if c == 91:                                   # '['
            key_esc = 2
        else:
            key_esc = 0
        return
    if key_esc == 2:
        key_esc = 0
        if is_entry != 0:
            n: int32 = cast[int32](_h_text_len(win_focus))
            if c == 68:                               # Left
                if w_state[u] > 0:
                    w_state[u] = w_state[u] - 1
            elif c == 67:                             # Right
                if w_state[u] < n:
                    w_state[u] = w_state[u] + 1
            elif c == 72:                             # Home
                w_state[u] = 0
            elif c == 70:                             # End
                w_state[u] = n
            elif c == 51:                             # Delete (ESC[3~)
                _h_entry_delete(win_focus)
        else:
            if c == 68:                               # Left
                if tv_caret[u] > 0:
                    tv_caret[u] = tv_caret[u] - 1
            elif c == 67:                             # Right
                if tv_caret[u] < tv_len[u]:
                    tv_caret[u] = tv_caret[u] + 1
            elif c == 72:
                tv_caret[u] = 0
            elif c == 70:
                tv_caret[u] = tv_len[u]
        return
    if c == 27:                                       # ESC
        key_esc = 1
        return
    if c == 19:                                       # Ctrl-S (DC3, 0x13)
        # Editor save accelerator. Swallow it (don't insert a control
        # byte into the document) and raise the save latch for the app.
        if is_tv != 0:
            save_req = 1
        return
    if c == 4:                                        # Ctrl-D (EOT, 0x04)
        # Terminal EOF accelerator. Swallow it and raise the EOF latch so a
        # terminal app (user/hamterm.ad) can close its shell's stdin — the
        # GUI equivalent of Ctrl-D at a tty. Never inserted as text.
        eof_req = 1
        return
    # --- normal characters ---
    if is_entry != 0:
        if c == 8 or c == 127:
            _h_entry_backspace(win_focus)
            return
        if c == 10 or c == 13:                        # Enter activates
            # A single-line entry has no newline to insert; Enter is the
            # "activate" gesture (GTK "activate" signal). Fire the entry's
            # own signal so an app can treat it like an OK/Run trigger
            # (e.g. a launcher entry, a path bar). Drained via
            # hamui_take_event()/hamui_signalled().
            w_signal[u] = 1
            return
        if c < 32 or c > 126:
            return
        _h_entry_insert(win_focus, c)
    else:
        if c == 8 or c == 127:
            _h_tv_backspace(win_focus)
            return
        if c == 10 or c == 13:                        # newline
            _h_tv_insert(win_focus, 10)
            return
        if c < 32 or c > 126:
            return
        _h_tv_insert(win_focus, c)


# Event-line scratch. The compositor delivers per-window event lines on
# /dev/wsys/<wid>/{pointer,keys}; one non-blocking read may return several
# whole '\n'-terminated lines, so the buffer holds a batch.
HAMUI_EV_BUF: uint64 = 256
pointer_buf: Array[256, uint8]
keys_buf:    Array[256, uint8]

# Read the leading event-type char (skipping spaces/tabs), advancing pos
# past it. Returns 0 if none remain.
def _h_parse_type(buf: Ptr[uint8], pos: Ptr[uint64], cap: uint64) -> uint8:
    i: uint64 = pos[0]
    while i < cap and (buf[i] == 32 or buf[i] == 9):
        i = i + 1
    if i >= cap:
        pos[0] = i
        return 0
    c: uint8 = buf[i]
    pos[0] = i + 1
    return c


def _h_parse_signed(buf: Ptr[uint8], pos: Ptr[uint64], cap: uint64) -> int32:
    i: uint64 = pos[0]
    while i < cap and (buf[i] == 32 or buf[i] == 9):
        i = i + 1
    neg: int32 = 0
    if i < cap and buf[i] == 45:                      # '-'
        neg = 1
        i = i + 1
    v: int32 = 0
    while i < cap and buf[i] >= 48 and buf[i] <= 57:
        v = v * 10 + cast[int32](buf[i]) - 48
        i = i + 1
    pos[0] = i
    if neg != 0:
        return 0 - v
    return v


# Scroll the topmost scrolledwindow / textview under (px,py) by `dz`
# notches. SCROLL scrolls by pixels (clamped to content); TEXTVIEW by
# whole lines.
#
# SIGN CONVENTION (BUG #123): the wheel delta `dz` follows the kernel
# /dev/mouse contract (see sys/src/9/port/devmouse.ad): dz > 0 = wheel
# UP / away, dz < 0 = wheel DOWN / toward the user. A LARGER `w_scroll`
# offset moves the viewed content DOWN through the document (the child is
# arranged at `y - w_scroll`, and the textview first-line index rises), so
# a wheel-DOWN notch (dz < 0) must INCREASE the offset. Hence we subtract
# dz (`offset -= dz`), NOT add it. The old `offset += dz` inverted every
# hamUI scrolledwindow/textview globally (scroll-down went to the top).
def _h_route_scroll(px: int32, py: int32, dz: int32):
    i: int64 = cast[int64](w_count) - 1
    while i >= 0:
        u: uint64 = cast[uint64](i)
        k: int32 = w_kind[u]
        if w_visible[u] != 0 and (k == HAMUI_K_SCROLL or k == HAMUI_K_TEXTVIEW):
            x: int32 = w_x[u]
            y: int32 = w_y[u]
            if px >= x and px < x + w_w[u] and py >= y and py < y + w_h[u]:
                if k == HAMUI_K_SCROLL:
                    ch: int32 = _h_scroll_content_h(cast[int32](i))
                    maxoff: int32 = ch - w_h[u]
                    if maxoff < 0:
                        maxoff = 0
                    w_scroll[u] = hamui_scroll_apply(w_scroll[u], dz, 16, maxoff)
                else:
                    w_scroll[u] = hamui_scroll_apply(w_scroll[u], dz, 1, 0 - 1)
                return
        i = i - 1


# Advance `pos` to just past the next '\n' (or to `cap` if the buffer ends
# without one — a partial tail line is then dropped, which is acceptable:
# the compositor enqueues whole lines and our buffer batches several).
def _h_skip_line(buf: Ptr[uint8], pos: Ptr[uint64], cap: uint64):
    i: uint64 = pos[0]
    while i < cap and buf[i] != 10:
        i = i + 1
    if i < cap:
        i = i + 1                                     # consume the '\n'
    pos[0] = i


# Poll the pointer once (non-blocking) from /dev/wsys/<wid>/pointer.
# Returns 1 if a fresh L-button press edge fired a click (or a scroll)
# this poll, else 0. x/y arrive as ABSOLUTE WINDOW-LOCAL coords already
# routed by the compositor, so we set the cursor directly (no delta accum,
# no clamp). Lines: "<type> <x> <y> <buttons> <dz>\n".
def _h_poll_pointer() -> int32:
    if pointer_fd < 0:
        _h_build_wsys_path(win_wid, "pointer")
        pointer_fd = sys_open(cast[Ptr[char]](&path_buf[0]))
    if pointer_fd < 0:
        return 0                                      # no window -> no-op
    clicked: int32 = 0
    n: int64 = sys_read_nb(pointer_fd, &pointer_buf[0], HAMUI_EV_BUF - 1)
    while n > 0:
        cap: uint64 = cast[uint64](n)
        pos: Array[1, uint64]
        pos[0] = 0
        while pos[0] < cap:
            t: uint8 = _h_parse_type(&pointer_buf[0], &pos[0], cap)
            if t == 0:
                break
            x:   int32 = _h_parse_signed(&pointer_buf[0], &pos[0], cap)
            y:   int32 = _h_parse_signed(&pointer_buf[0], &pos[0], cap)
            btn: int32 = _h_parse_signed(&pointer_buf[0], &pos[0], cap)
            dz:  int32 = _h_parse_signed(&pointer_buf[0], &pos[0], cap)
            _h_skip_line(&pointer_buf[0], &pos[0], cap)
            # Absolute window-local position — set directly.
            cur_x = x
            cur_y = y
            if t == 100:                              # 'd' button-down
                # Left-button press edge == a click (router already chose us).
                if (btn & HAMUI_BTN_L) != 0 and (prev_btn & HAMUI_BTN_L) == 0:
                    _h_tooltip_hide()
                    _h_route_click(cur_x, cur_y)
                    clicked = 1
                    tree_dirty = 1
                prev_btn = btn
            elif t == 117:                            # 'u' button-up
                prev_btn = btn
            elif t == 115:                            # 's' scroll
                if dz != 0:
                    _h_route_scroll(cur_x, cur_y, dz)
                    clicked = 1
                    tree_dirty = 1
            else:                                     # 'm' motion (or other)
                # A motion line still carries the live button bitmap; track
                # it so a press that arrives folded into motion still edges.
                if (btn & HAMUI_BTN_L) != 0 and (prev_btn & HAMUI_BTN_L) == 0:
                    _h_tooltip_hide()
                    _h_route_click(cur_x, cur_y)
                    clicked = 1
                    tree_dirty = 1
                prev_btn = btn
                # Some compositors fold scroll into a nonzero dz on any line.
                if dz != 0:
                    _h_route_scroll(cur_x, cur_y, dz)
                    clicked = 1
                    tree_dirty = 1
        n = sys_read_nb(pointer_fd, &pointer_buf[0], HAMUI_EV_BUF - 1)
    return clicked


# Poll the keyboard once (non-blocking) from /dev/wsys/<wid>/keys. The
# compositor gates the keyboard and only feeds the FOCUSED window's queue.
# Lines: "<type> <code>\n" with type 'd'=press; we feed `code` bytes to the
# existing key dispatch exactly as stdin bytes were fed before (so the
# backspace / arrow-ESC-sequence / caret editing behaviour is preserved).
def _h_poll_keys() -> int32:
    if keys_fd < 0:
        _h_build_wsys_path(win_wid, "keys")
        keys_fd = sys_open(cast[Ptr[char]](&path_buf[0]))
    if keys_fd < 0:
        return 0                                      # no window -> no-op
    consumed: int32 = 0
    n: int64 = sys_read_nb(keys_fd, &keys_buf[0], HAMUI_EV_BUF - 1)
    while n > 0:
        cap: uint64 = cast[uint64](n)
        pos: Array[1, uint64]
        pos[0] = 0
        while pos[0] < cap:
            t: uint8 = _h_parse_type(&keys_buf[0], &pos[0], cap)
            if t == 0:
                break
            code: int32 = _h_parse_signed(&keys_buf[0], &pos[0], cap)
            _h_skip_line(&keys_buf[0], &pos[0], cap)
            if t == 100:                              # 'd' press/typed
                _h_dispatch_key(cast[uint8](code))
                consumed = consumed + 1
                tree_dirty = 1
        n = sys_read_nb(keys_fd, &keys_buf[0], HAMUI_EV_BUF - 1)
    return consumed


# One render+dispatch step: poll input, and if anything changed, relayout
# and repaint. Returns 1 if it repainted. Useful for embedding in a host
# loop or for a single-shot render (call once after building the tree).
def hamui_step() -> int32:
    # Input may mutate widget state (which sets tree_dirty); an app-level
    # setter may also have set it. Only relayout+repaint when dirty, so
    # unchanged frames emit no markup write at all (damage tracking).
    _h_poll_pointer()
    _h_poll_keys()
    # Advance the hover dwell each step; a show/hide transition repaints.
    if _h_tooltip_step() != 0:
        tree_dirty = 1
    if tree_dirty != 0:
        hamui_layout()
        hamui_paint()
        tree_dirty = 0
        return 1
    return 0


# Render the current tree once (layout + paint) with no input polling.
# The headless `hamUId render <wid>` test path drives exactly this output.
def hamui_render():
    hamui_layout()
    hamui_paint()
    tree_dirty = 0


# Ensure the per-window input event fds (/keys, /pointer) are open. They are
# opened lazily on the first poll; hamui_wait() needs them open BEFORE it can
# park on them, so this forces the open. Safe to call repeatedly (no-op once
# open). No-op when there is no bound window (win_wid < 0).
def hamui_input_open():
    if win_wid < 0:
        return
    if keys_fd < 0:
        _h_build_wsys_path(win_wid, "keys")
        keys_fd = sys_open(cast[Ptr[char]](&path_buf[0]))
    if pointer_fd < 0:
        _h_build_wsys_path(win_wid, "pointer")
        pointer_fd = sys_open(cast[Ptr[char]](&path_buf[0]))


# EVENT-DRIVEN idle: sleep the caller OFF the runqueue until a keyboard or
# pointer event lands on THIS window (or one of the caller's `extra` fds is
# readable), or `timeout_ms` elapses. This REPLACES the old sys_yield()
# busy-poll idle: a poll-yield loop stays permanently STATE_READY, so under a
# multi-app desktop it round-robins through every other polling task before it
# runs again — each of which naps a full scheduler tick (~10 ms) in the
# cooperative-yield hlt. That compounding was the ~0.5 s keystroke-echo lag in
# the DE terminal. Parking in sys_waitfds instead means the app is woken the
# instant the compositor pushes a key (wsys_route_key_byte -> waitfds_notify),
# so echo is immediate and the idle desktop no longer busy-spins.
#
# `extra`/`n_extra` add app-owned fds (e.g. a terminal's shell-stdout pipe) to
# the wait set; pass (0,0) for none. `timeout_ms` bounds the idle sleep so
# time-based repaints (tooltip dwell, notification fade) still advance when no
# input arrives; pass a small value (tens of ms) for smooth idle animation or
# a larger one to sleep deeper. Returns sys_waitfds's result (>0 ready count,
# 0 timeout, <0 error); callers can ignore it and just re-run hamui_step().
HAMUI_WAIT_MAXFDS: uint64 = 16
def hamui_wait(extra: Ptr[int32], n_extra: uint64, timeout_ms: int64) -> int64:
    hamui_input_open()
    wfds: Array[16, int32]
    n: uint64 = 0
    if keys_fd >= 0 and n < HAMUI_WAIT_MAXFDS:
        wfds[n] = keys_fd
        n = n + 1
    if pointer_fd >= 0 and n < HAMUI_WAIT_MAXFDS:
        wfds[n] = pointer_fd
        n = n + 1
    k: uint64 = 0
    while k < n_extra and n < HAMUI_WAIT_MAXFDS:
        f: int32 = extra[k]
        if f >= 0:
            wfds[n] = f
            n = n + 1
        k = k + 1
    if n == 0:
        # No fds to park on (headless / pre-window): fall back to a plain
        # cooperative yield so we still let peers run.
        sys_yield()
        return 0
    return sys_waitfds(&wfds[0], n, timeout_ms)


# Idle cadence for the built-in run-loop: sleep up to this long between
# input events so tooltip dwell / animations still tick when nothing happens,
# while keystrokes still wake the loop instantly (event-driven, not this bound).
HAMUI_IDLE_MS: int64 = 50


# The app run-loop. Lays out + paints once, then waits for input forever,
# repainting on change. PARKS in sys_waitfds between events (via hamui_wait)
# so it never busy-burns a CPU and echoes input with no scheduler-rotation lag.
def hamui_run():
    hamui_render()
    while True:
        hamui_step()
        hamui_wait(cast[Ptr[int32]](0), 0, HAMUI_IDLE_MS)


# ====================================================================
# HIGH-LEVEL DIALOGS — MODAL ALERT + FILE CHOOSER
# ====================================================================
#
# These are the GtkMessageDialog / GtkFileChooser equivalents, built
# ENTIRELY on the existing primitives above: a DIALOG container (modal
# overlay, painted on top of a dimmed backdrop) holding a LABEL, a row of
# BUTTONs, plus — for the file chooser — a TREEVIEW row list and an ENTRY.
# Nothing here pokes the framebuffer directly; we only assemble widgets and
# read their pull-based signals, so the toolkit's ABI for existing apps is
# untouched.
#
# Both expose a GTK-style "run" call (cf. gtk_dialog_run): it shows the
# dialog, drives hamui_step()+sys_yield() until a button fires, hides the
# dialog, and returns a result code. The dialog handle (a widget id) can be
# reused across multiple runs, or destroyed with hamui_destroy() when done.
#
# Result codes returned by the *_run helpers:
HAMUI_DLG_NONE:   int32 = -1         # still running / dismissed without choice
HAMUI_DLG_OK:     int32 = 0          # primary action (OK / Open / Save)
HAMUI_DLG_CANCEL: int32 = 1          # cancel / secondary action


# ---- string-literal helpers (NO module-scope string globals allowed) ----
def _hdlg_s_ok() -> Ptr[uint8]:
    return "OK"


def _hdlg_s_cancel() -> Ptr[uint8]:
    return "Cancel"


def _hdlg_s_open() -> Ptr[uint8]:
    return "Open"


def _hdlg_s_dotdot_row() -> Ptr[uint8]:
    return "..\tdir"


def _hdlg_s_slash() -> Ptr[uint8]:
    return "/"


# ====================================================================
# MODAL ALERT / MESSAGE DIALOG
# ====================================================================
# Per-alert state (one alert handle is live at a time; reusable). The
# dialog id + its two button ids are remembered so *_run can watch them.
_hal_dlg:     int32 = -1
_hal_ok:      int32 = -1
_hal_cancel:  int32 = -1


# Build a modal message dialog. `title` is the title-bar text, `message`
# the body line. If `with_cancel` is nonzero the dialog gets an OK *and* a
# Cancel button (an OK/Cancel confirm); otherwise just OK. Returns the
# dialog widget id (a handle) or -1 if the widget pool is exhausted.
#
# The message is a single LABEL (one line, capped at HAMUI_LABEL_CAP); for
# multi-line bodies a caller can pre-wrap with '\n' the same way a textview
# does — kept simple here on purpose to match the message-dialog use case.
def hamui_alert_new(title: Ptr[uint8], message: Ptr[uint8], \
                    with_cancel: int32) -> int32:
    dlg: int32 = hamui_dialog(title)
    if dlg < 0:
        return -1
    msg: int32 = hamui_label(message)
    if msg >= 0:
        hamui_add(dlg, msg)
    # Button row: a horizontal box so OK / Cancel sit side by side, pushed
    # to the right (END align) like a real dialog action area.
    row: int32 = hamui_hbox()
    if row >= 0:
        hamui_set_align(row, HAMUI_ALIGN_END, HAMUI_ALIGN_START)
        hamui_add(dlg, row)
    cancel: int32 = -1
    if with_cancel != 0:
        cancel = hamui_button(_hdlg_s_cancel())
        if cancel >= 0:
            hamui_add(row, cancel)
    ok: int32 = hamui_button(_hdlg_s_ok())
    if ok >= 0:
        hamui_add(row, ok)
    _hal_dlg = dlg
    _hal_ok = ok
    _hal_cancel = cancel
    return dlg


# Make the alert visible (modal overlay). It paints on top of a dimmed
# backdrop automatically (DIALOG kind). Marks the tree dirty.
def hamui_alert_show(dlg: int32):
    hamui_show(dlg)


# Hide the alert without destroying it (so it can be shown again).
def hamui_alert_hide(dlg: int32):
    hamui_hide(dlg)


# Poll a shown alert ONCE (non-blocking): step the toolkit, then report
# which button fired this step. Returns HAMUI_DLG_OK, HAMUI_DLG_CANCEL, or
# HAMUI_DLG_NONE if nothing was pressed yet. Use this when the alert must
# cooperate with a larger app loop. On a non-NONE result the alert is
# hidden automatically (one decision per show).
def hamui_alert_poll() -> int32:
    hamui_step()
    if _hal_ok >= 0 and hamui_signalled(_hal_ok) != 0:
        hamui_hide(_hal_dlg)
        return HAMUI_DLG_OK
    if _hal_cancel >= 0 and hamui_signalled(_hal_cancel) != 0:
        hamui_hide(_hal_dlg)
        return HAMUI_DLG_CANCEL
    return HAMUI_DLG_NONE


# Blocking modal run (GTK gtk_dialog_run style): show the alert and spin the
# toolkit until a button is pressed, then hide it and return the result.
# Yields between polls so it never busy-burns a CPU. Returns HAMUI_DLG_OK or
# HAMUI_DLG_CANCEL.
def hamui_alert_run(dlg: int32) -> int32:
    hamui_show(dlg)
    while True:
        r: int32 = hamui_alert_poll()
        if r != HAMUI_DLG_NONE:
            return r
        sys_yield()


# One-shot convenience: build an OK-only message dialog, run it modally,
# destroy it, and return (always HAMUI_DLG_OK once dismissed). This is the
# `hamui_alert(title, message)` the brief asked for — the simplest path for
# "tell the user something" with no follow-up handle to manage.
def hamui_alert(title: Ptr[uint8], message: Ptr[uint8]) -> int32:
    dlg: int32 = hamui_alert_new(title, message, 0)
    if dlg < 0:
        return HAMUI_DLG_NONE
    r: int32 = hamui_alert_run(dlg)
    hamui_destroy(dlg)
    return r


# One-shot confirm convenience: build an OK/Cancel dialog, run it modally,
# destroy it, and return which button was pressed (HAMUI_DLG_OK /
# HAMUI_DLG_CANCEL).
def hamui_confirm(title: Ptr[uint8], message: Ptr[uint8]) -> int32:
    dlg: int32 = hamui_alert_new(title, message, 1)
    if dlg < 0:
        return HAMUI_DLG_NONE
    r: int32 = hamui_alert_run(dlg)
    hamui_destroy(dlg)
    return r


# ====================================================================
# FILE-CHOOSER DIALOG
# ====================================================================
# A modal dialog that browses a directory listing, lets the user descend
# into subdirectories (and ".." up), pick a file (or type a name), and
# confirm Open/Save. Returns the chosen ABSOLUTE path to the caller.
#
# Directory enumeration reuses the SAME mechanism hamfiles/hamfm use:
# p9_listdir(path, buf, count) writes the directory's entries as
# newline-separated names; a non-negative return on a candidate child path
# also tells us it is itself a directory (so we can mark dirs and allow
# descent). Fixed pools throughout — no malloc:
#   * the current path is a fixed _HFC_PATH_CAP buffer,
#   * the listing scratch is a fixed buffer,
#   * at most _HFC_MAX_ENT entries are shown (the treeview itself caps at
#     HAMUI_LIST_MAX_ROWS rows; we list "../" + up to that many real ones).
_HFC_PATH_CAP:  uint64 = 1024
_HFC_LIST_CAP:  uint64 = 4096
_HFC_NAME_CAP:  uint64 = 64
_HFC_MAX_ENT:   uint64 = 15          # real entries shown after the ".." row

# Browse state.
_hfc_path:      Array[1024, uint8]   # current directory (absolute, NUL-term)
_hfc_path_len:  uint64 = 0
_hfc_list:      Array[4096, uint8]   # raw p9_listdir scratch
_hfc_full:      Array[1024, uint8]   # scratch full child path (probe/result)
_hfc_result:    Array[1024, uint8]   # the chosen absolute path (return value)
_hfc_row:       Array[160, uint8]    # scratch "name\ttype" treeview row

# Entry table for the currently-listed directory.
_hfc_names:     Array[960, uint8]    # _HFC_MAX_ENT * _HFC_NAME_CAP
_hfc_name_len:  Array[15, uint64]
_hfc_is_dir:    Array[15, int32]
_hfc_nent:      uint64 = 0

# Widget handles for the live chooser (one at a time, reusable).
_hfc_dlg:       int32 = -1
_hfc_pathlbl:   int32 = -1           # label showing the current directory
_hfc_tree:      int32 = -1           # the directory listing
_hfc_entry:     int32 = -1           # filename entry
_hfc_open:      int32 = -1           # Open/Save button
_hfc_cancel:    int32 = -1           # Cancel button


def _hfc_name_ptr(i: uint64) -> Ptr[uint8]:
    return &_hfc_names[i * _HFC_NAME_CAP]


# Copy a NUL-terminated source into _hfc_path, clamping to capacity, and
# ensuring it is non-empty (defaults to "/").
def _hfc_set_path(src: Ptr[uint8]):
    i: uint64 = 0
    while src[i] != 0 and i < _HFC_PATH_CAP - 1:
        _hfc_path[i] = src[i]
        i = i + 1
    if i == 0:
        _hfc_path[0] = 47                            # '/'
        i = 1
    _hfc_path[i] = 0
    _hfc_path_len = i


# Build _hfc_full = _hfc_path + "/" + name(i), collapsing a double slash
# when the current path is exactly "/".
def _hfc_build_full(i: uint64):
    j: uint64 = 0
    while j < _hfc_path_len and j < _HFC_PATH_CAP - 1:
        _hfc_full[j] = _hfc_path[j]
        j = j + 1
    if j == 0 or _hfc_full[j - 1] != 47:
        _hfc_full[j] = 47                            # '/'
        j = j + 1
    nl: uint64 = _hfc_name_len[i]
    p: Ptr[uint8] = _hfc_name_ptr(i)
    k: uint64 = 0
    while k < nl and j < _HFC_PATH_CAP - 1:
        _hfc_full[j] = p[k]
        j = j + 1
        k = k + 1
    _hfc_full[j] = 0


# 1 if _hfc_full is a directory. A p9_listdir probe is NOT a reliable
# dir test — it succeeds on a regular file too (sys_open+sys_read returns
# the file's contents). Open the path and ask the kernel to flip the fd
# into Dir-record mode: namec_chan_set_p9_dir_mode accepts only
# DEV_DIR_FILE pool chans (real directories), -1 for regular files.
def _hfc_probe_is_dir() -> int32:
    fd: int32 = sys_open(cast[Ptr[char]](&_hfc_full[0]))
    if fd < 0:
        return 0
    d: int32 = p9_chan_dir_mode(fd, 1, cast[Ptr[char]](&_hfc_full[0]))
    sys_close(fd)
    if d == 0:
        return 1
    return 0


# Replace _hfc_path with its parent directory (root "/" stays root).
def _hfc_go_parent():
    if _hfc_path_len <= 1:
        _hfc_path[0] = 47
        _hfc_path[1] = 0
        _hfc_path_len = 1
        return
    n: uint64 = _hfc_path_len
    if _hfc_path[n - 1] == 47:
        n = n - 1
    while n > 1 and _hfc_path[n - 1] != 47:
        n = n - 1
    if n > 1:
        n = n - 1
    if n == 0:
        n = 1
    _hfc_path[n] = 0
    _hfc_path_len = n


# Re-read _hfc_path into the entry table (skips "." and ".."; the chooser
# offers its own ".." row). Bounded by _HFC_MAX_ENT — extra entries are
# silently dropped (no crash, no malloc).
def _hfc_load_dir():
    _hfc_nent = 0
    n: int64 = p9_listdir(cast[Ptr[char]](&_hfc_path[0]), &_hfc_list[0],
                           _HFC_LIST_CAP)
    if n < 0:
        return
    nu: uint64 = cast[uint64](n)
    i: uint64 = 0
    while i < nu:
        c: uint8 = _hfc_list[i]
        if c == 10 or c == 0:
            i = i + 1
            continue
        j: uint64 = i
        while j < nu:
            d: uint8 = _hfc_list[j]
            if d == 10 or d == 0:
                break
            j = j + 1
        nl: uint64 = j - i
        keep: int32 = 1
        if nl == 1 and _hfc_list[i] == 46:
            keep = 0
        if nl == 2 and _hfc_list[i] == 46 and _hfc_list[i + 1] == 46:
            keep = 0
        if keep != 0 and _hfc_nent < _HFC_MAX_ENT:
            store: uint64 = nl
            if store > _HFC_NAME_CAP - 1:
                store = _HFC_NAME_CAP - 1
            dst: Ptr[uint8] = _hfc_name_ptr(_hfc_nent)
            k: uint64 = 0
            while k < store:
                dst[k] = _hfc_list[i + k]
                k = k + 1
            dst[store] = 0
            _hfc_name_len[_hfc_nent] = store
            _hfc_build_full(_hfc_nent)
            _hfc_is_dir[_hfc_nent] = _hfc_probe_is_dir()
            _hfc_nent = _hfc_nent + 1
        i = j + 1


# Compose "name\ttype" into _hfc_row for one entry (type = "dir"/"file").
def _hfc_make_row(i: uint64):
    p: Ptr[uint8] = _hfc_name_ptr(i)
    j: uint64 = 0
    while p[j] != 0 and j < 160 - 8:
        _hfc_row[j] = p[j]
        j = j + 1
    _hfc_row[j] = 9                                  # '\t'
    j = j + 1
    if _hfc_is_dir[i] != 0:
        _hfc_row[j] = 100                            # 'd'
        _hfc_row[j + 1] = 105                        # 'i'
        _hfc_row[j + 2] = 114                        # 'r'
        j = j + 3
    else:
        _hfc_row[j] = 102                            # 'f'
        _hfc_row[j + 1] = 105                        # 'i'
        _hfc_row[j + 2] = 108                        # 'l'
        _hfc_row[j + 3] = 101                        # 'e'
        j = j + 4
    _hfc_row[j] = 0


# (Re)fill the chooser's treeview + path label from the entry table. Row 0
# is always ".." (parent). Reuses hamui_treeview_clear so repeated reloads
# recycle the shared row-pool slots instead of leaking them.
def _hfc_refresh():
    hamui_treeview_clear(_hfc_tree)
    hamui_treeview_add(_hfc_tree, _hdlg_s_dotdot_row())
    i: uint64 = 0
    while i < _hfc_nent:
        _hfc_make_row(i)
        hamui_treeview_add(_hfc_tree, &_hfc_row[0])
        i = i + 1
    hamui_set_text(_hfc_pathlbl, &_hfc_path[0])


# Build a modal file-chooser dialog rooted at `start_dir` (or "/" when
# start_dir is empty/NULL). Returns the dialog widget id (a handle) or -1 if
# the widget pool is exhausted. Reuse the handle with hamui_filechooser_run
# (re-show), or hamui_destroy() it when done.
def hamui_filechooser_new(title: Ptr[uint8], start_dir: Ptr[uint8]) -> int32:
    dlg: int32 = hamui_dialog(title)
    if dlg < 0:
        return -1
    # A roomier panel than the default 320x180 — room for the listing.
    hamui_set_size(dlg, 460, 360)

    # Current-directory label.
    pathlbl: int32 = hamui_label(_hdlg_s_slash())
    if pathlbl >= 0:
        hamui_add(dlg, pathlbl)

    # Directory listing: 2-column treeview (name | type).
    tree: int32 = hamui_treeview(2)
    if tree >= 0:
        hamui_set_size(tree, 420, 240)
        hamui_add(dlg, tree)

    # Filename entry (selected row mirrors here; user may also type).
    entry: int32 = hamui_entry()
    if entry >= 0:
        hamui_set_size(entry, 420, 24)
        hamui_add(dlg, entry)

    # Action row: Cancel + Open, pushed to the right.
    row: int32 = hamui_hbox()
    if row >= 0:
        hamui_set_align(row, HAMUI_ALIGN_END, HAMUI_ALIGN_START)
        hamui_add(dlg, row)
    cancel: int32 = hamui_button(_hdlg_s_cancel())
    if cancel >= 0:
        hamui_add(row, cancel)
    openb: int32 = hamui_button(_hdlg_s_open())
    if openb >= 0:
        hamui_add(row, openb)

    _hfc_dlg = dlg
    _hfc_pathlbl = pathlbl
    _hfc_tree = tree
    _hfc_entry = entry
    _hfc_open = openb
    _hfc_cancel = cancel

    # Seed the browse location + initial listing.
    if start_dir != cast[Ptr[uint8]](0) and start_dir[0] != 0:
        _hfc_set_path(start_dir)
    else:
        _hfc_set_path(_hdlg_s_slash())
    _hfc_load_dir()
    _hfc_refresh()
    return dlg


# Build _hfc_result = chosen absolute path. If the filename entry is
# non-empty it is treated as a path relative to the current directory (an
# absolute entry — leading '/' — overrides). Returns &_hfc_result[0].
def _hfc_compose_result() -> Ptr[uint8]:
    name: Ptr[uint8] = hamui_entry_text(_hfc_entry)
    abs_entry: int32 = 0
    if name != cast[Ptr[uint8]](0) and name[0] == 47:
        abs_entry = 1
    j: uint64 = 0
    if abs_entry != 0:
        k: uint64 = 0
        while name[k] != 0 and j < _HFC_PATH_CAP - 1:
            _hfc_result[j] = name[k]
            j = j + 1
            k = k + 1
        _hfc_result[j] = 0
        return &_hfc_result[0]
    # current dir + "/" + name
    while j < _hfc_path_len and j < _HFC_PATH_CAP - 1:
        _hfc_result[j] = _hfc_path[j]
        j = j + 1
    if name != cast[Ptr[uint8]](0) and name[0] != 0:
        if j == 0 or _hfc_result[j - 1] != 47:
            _hfc_result[j] = 47
            j = j + 1
        k2: uint64 = 0
        while name[k2] != 0 and j < _HFC_PATH_CAP - 1:
            _hfc_result[j] = name[k2]
            j = j + 1
            k2 = k2 + 1
    _hfc_result[j] = 0
    return &_hfc_result[0]


# Handle a treeview row selection: row 0 = "..", descend into a dir, or put
# a file's name into the entry. Reloads the listing on a directory change.
def _hfc_on_select(row: int32):
    if row == 0:
        _hfc_go_parent()
        _hfc_load_dir()
        _hfc_refresh()
        return
    ent: uint64 = cast[uint64](row - 1)
    if ent >= _hfc_nent:
        return
    if _hfc_is_dir[ent] != 0:
        # Descend: _hfc_full already holds path+"/"+name from the load pass;
        # recompute it (the table may have changed) and adopt it.
        _hfc_build_full(ent)
        _hfc_set_path(&_hfc_full[0])
        _hfc_load_dir()
        _hfc_refresh()
    else:
        # A file: copy its name into the entry for confirmation.
        hamui_set_text(_hfc_entry, _hfc_name_ptr(ent))


# Poll a shown file chooser ONCE (non-blocking): step the toolkit, react to
# a row click (navigate / pick) and to the Open/Cancel buttons. Returns
# HAMUI_DLG_OK once Open is pressed (the chosen path is then available via
# hamui_filechooser_path()), HAMUI_DLG_CANCEL on Cancel, or HAMUI_DLG_NONE
# while still browsing. Hides the dialog on a non-NONE result.
def hamui_filechooser_poll() -> int32:
    hamui_step()
    if _hfc_tree >= 0 and hamui_signalled(_hfc_tree) != 0:
        _hfc_on_select(hamui_tree_selected(_hfc_tree))
    if _hfc_cancel >= 0 and hamui_signalled(_hfc_cancel) != 0:
        hamui_hide(_hfc_dlg)
        return HAMUI_DLG_CANCEL
    if _hfc_open >= 0 and hamui_signalled(_hfc_open) != 0:
        _hfc_compose_result()
        hamui_hide(_hfc_dlg)
        return HAMUI_DLG_OK
    return HAMUI_DLG_NONE


# Blocking modal run (gtk_dialog_run style): show the chooser, spin the
# toolkit until Open or Cancel, hide it, and return HAMUI_DLG_OK /
# HAMUI_DLG_CANCEL. On OK the chosen path is read with
# hamui_filechooser_path().
def hamui_filechooser_run(dlg: int32) -> int32:
    hamui_show(dlg)
    while True:
        r: int32 = hamui_filechooser_poll()
        if r != HAMUI_DLG_NONE:
            return r
        sys_yield()


# The absolute path the user chose in the most recent successful run.
def hamui_filechooser_path() -> Ptr[uint8]:
    return &_hfc_result[0]


# One-shot convenience (mirrors hamui_alert / hamui_confirm): build a file
# chooser rooted at `start_dir` (null/empty -> "/"), run it modally, destroy
# it, and return the chosen absolute path — or a null pointer on Cancel (or
# if the widget pool is exhausted). The returned pointer is the shared
# _hfc_result buffer: copy it out before opening another chooser.
def hamui_filechooser(title: Ptr[uint8], start_dir: Ptr[uint8]) -> Ptr[uint8]:
    dlg: int32 = hamui_filechooser_new(title, start_dir)
    if dlg < 0:
        return cast[Ptr[uint8]](0)
    r: int32 = hamui_filechooser_run(dlg)
    hamui_destroy(dlg)
    if r != HAMUI_DLG_OK:
        return cast[Ptr[uint8]](0)
    return hamui_filechooser_path()


# ====================================================================
# CALENDAR WIDGET (GtkCalendar equivalent)
# ====================================================================
# A month view: header band "<MonthName> <Year>" with prev/next-month
# arrow click targets at the band's left/right edges, a Su..Sa weekday
# header row, and a 6x7 day grid. The CURRENT day (seeded from the system
# wall clock, see below) is outlined; clicking a day cell SELECTS it and
# fires the widget's pull-based signal (drain via hamui_take_event() /
# hamui_signalled(), exactly like a button click). Read the selection
# back with hamui_calendar_get(w, &y, &m, &d).
#
# CALENDAR MATH — real, self-contained Gregorian arithmetic (no libc, no
# lookup hacks): leap years via y%4==0 and (y%100!=0 or y%400==0), and
# day-of-week via Zeller's congruence (all-positive operands for y >= 1,
# so truncating integer division/modulo are exact). Verified against a
# host-side reference across 1800..2200.
#
# TODAY SEEDING — the same wall-clock source `date` uses: /proc/realtime,
# whose first line is "YYYY-MM-DDTHH:MM:SSZ <epoch>\n" (fs/procfs.ad
# render_realtime: RTC boot epoch + TSC delta). We parse the civil date
# straight out of the ISO-8601 prefix. If the RTC was unreadable at boot
# the kernel renders "unavailable 0" — we then fall back to 1970-01-01
# rather than fabricating a date (the widget still works; "today" just
# isn't highlighted in the displayed month).
#
# Geometry (all relative to the widget's laid-out x/y):
#   y+0  .. y+19   header band (arrows + centered "MonthName Year")
#   y+22 .. y+37   weekday header row
#   y+38 ..        6 rows of 18px day cells, 7 columns of 26px, inset 2px
_HCAL_CELL_W: int32 = 26
_HCAL_CELL_H: int32 = 18
_HCAL_GRID_Y: int32 = 38             # grid top, relative to widget y

# Per-widget calendar state (parallel arrays, like the rest of the tree).
# *_year/*_month = the DISPLAYED month; *_sel_* = the selected civil day.
_hcal_year:   Array[256, int64]
_hcal_month:  Array[256, int64]
_hcal_sel_y:  Array[256, int64]
_hcal_sel_m:  Array[256, int64]
_hcal_sel_d:  Array[256, int64]

# "Today", seeded once per process from /proc/realtime.
_hcal_seeded:  int32 = 0
_hcal_today_y: int64 = 1970
_hcal_today_m: int64 = 1
_hcal_today_d: int64 = 1
_hcal_rt_buf:  Array[64, uint8]      # /proc/realtime read scratch
_hcal_title:   Array[32, uint8]      # "MonthName Year" compose scratch


def _hcal_is_leap(y: int64) -> int64:
    if y % 4 == 0 and (y % 100 != 0 or y % 400 == 0):
        return 1
    return 0


def _hcal_days_in_month(y: int64, m: int64) -> int64:
    if m == 2:
        return 28 + _hcal_is_leap(y)
    if m == 4 or m == 6 or m == 9 or m == 11:
        return 30
    return 31


# Day of week for civil date y-m-d, 0=Sunday .. 6=Saturday. Zeller's
# congruence: Jan/Feb count as months 13/14 of the previous year; h is
# 0=Saturday, shifted to Sunday-based on return. Every operand stays
# positive for y >= 1, so truncating div/mod behave like floor.
def _hcal_dow_sun(y: int64, m: int64, d: int64) -> int64:
    yy: int64 = y
    mm: int64 = m
    if mm < 3:
        mm = mm + 12
        yy = yy - 1
    K: int64 = yy % 100
    J: int64 = yy / 100
    h: int64 = (d + (13 * (mm + 1)) / 5 + K + K / 4 + J / 4 + 5 * J) % 7
    return (h + 6) % 7


# Month name string literal (literals returned from a helper, never stored
# in module-scope globals — compiler quirk).
def _hcal_month_name(m: int64) -> Ptr[uint8]:
    if m == 1:
        return "January"
    if m == 2:
        return "February"
    if m == 3:
        return "March"
    if m == 4:
        return "April"
    if m == 5:
        return "May"
    if m == 6:
        return "June"
    if m == 7:
        return "July"
    if m == 8:
        return "August"
    if m == 9:
        return "September"
    if m == 10:
        return "October"
    if m == 11:
        return "November"
    return "December"


# Weekday column header, Sunday-first (matches user/cal.ad's grid).
def _hcal_dayname(c: int32) -> Ptr[uint8]:
    if c == 0:
        return "Su"
    if c == 1:
        return "Mo"
    if c == 2:
        return "Tu"
    if c == 3:
        return "We"
    if c == 4:
        return "Th"
    if c == 5:
        return "Fr"
    return "Sa"


def _hcal_digit(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return 1
    return 0


# Seed "today" from /proc/realtime (once per process). Line 1 is
# "YYYY-MM-DDTHH:MM:SSZ <epoch>\n" or "unavailable 0\n"; we validate the
# fixed ISO-8601 layout byte-by-byte before trusting it.
def _hcal_seed_today():
    if _hcal_seeded != 0:
        return
    _hcal_seeded = 1
    fd: int32 = sys_open("/proc/realtime")
    if fd < 0:
        return
    n: int64 = sys_read(fd, &_hcal_rt_buf[0], 63)
    sys_close(fd)
    if n < 10:
        return
    # Layout check: 4 digits '-' 2 digits '-' 2 digits.
    i: uint64 = 0
    while i < 4:
        if _hcal_digit(_hcal_rt_buf[i]) == 0:
            return
        i = i + 1
    if _hcal_rt_buf[4] != 45 or _hcal_rt_buf[7] != 45:        # '-'
        return
    if _hcal_digit(_hcal_rt_buf[5]) == 0 or _hcal_digit(_hcal_rt_buf[6]) == 0:
        return
    if _hcal_digit(_hcal_rt_buf[8]) == 0 or _hcal_digit(_hcal_rt_buf[9]) == 0:
        return
    y: int64 = 0
    i = 0
    while i < 4:
        y = y * 10 + cast[int64](_hcal_rt_buf[i]) - 48
        i = i + 1
    m: int64 = (cast[int64](_hcal_rt_buf[5]) - 48) * 10 \
             + cast[int64](_hcal_rt_buf[6]) - 48
    d: int64 = (cast[int64](_hcal_rt_buf[8]) - 48) * 10 \
             + cast[int64](_hcal_rt_buf[9]) - 48
    if m < 1 or m > 12:
        return
    if d < 1 or d > _hcal_days_in_month(y, m):
        return
    _hcal_today_y = y
    _hcal_today_m = m
    _hcal_today_d = d


# Constructor (toolkit convention: returns a widget id, attach with
# hamui_add). Opens on today's month with today selected.
def hamui_calendar() -> int32:
    id: int32 = _h_alloc(HAMUI_K_CALENDAR)
    if id < 0:
        return -1
    _hcal_seed_today()
    u: uint64 = cast[uint64](id)
    _hcal_year[u] = _hcal_today_y
    _hcal_month[u] = _hcal_today_m
    _hcal_sel_y[u] = _hcal_today_y
    _hcal_sel_m[u] = _hcal_today_m
    _hcal_sel_d[u] = _hcal_today_d
    return id


# Read back the SELECTED civil date (out-pointer style).
def hamui_calendar_get(id: int32, year: Ptr[int64], month: Ptr[int64], \
                       day: Ptr[int64]):
    if id < 0 or cast[uint64](id) >= w_count:
        return
    u: uint64 = cast[uint64](id)
    year[0] = _hcal_sel_y[u]
    month[0] = _hcal_sel_m[u]
    day[0] = _hcal_sel_d[u]


# Programmatically select a date (and navigate the view to its month).
# Out-of-range month/day are clamped into the Gregorian calendar.
def hamui_calendar_select(id: int32, y: int64, m: int64, d: int64):
    if id < 0 or cast[uint64](id) >= w_count:
        return
    u: uint64 = cast[uint64](id)
    mm: int64 = m
    if mm < 1:
        mm = 1
    if mm > 12:
        mm = 12
    dd: int64 = d
    if dd < 1:
        dd = 1
    nd: int64 = _hcal_days_in_month(y, mm)
    if dd > nd:
        dd = nd
    _hcal_year[u] = y
    _hcal_month[u] = mm
    _hcal_sel_y[u] = y
    _hcal_sel_m[u] = mm
    _hcal_sel_d[u] = dd
    tree_dirty = 1


# Click router for the calendar (called from _h_dispatch_click).
#   * header band: left edge = previous month, right edge = next month
#     (view navigation only — does NOT fire the signal);
#   * a valid day cell: select that civil day + fire the widget signal.
def _hcal_click(tid: int32, px: int32, py: int32):
    u: uint64 = cast[uint64](tid)
    relx: int32 = px - w_x[u]
    rely: int32 = py - w_y[u]
    if rely < 20:
        if relx < 26:
            # previous month
            if _hcal_month[u] <= 1:
                _hcal_month[u] = 12
                _hcal_year[u] = _hcal_year[u] - 1
            else:
                _hcal_month[u] = _hcal_month[u] - 1
            tree_dirty = 1
        elif relx > w_w[u] - 26:
            # next month
            if _hcal_month[u] >= 12:
                _hcal_month[u] = 1
                _hcal_year[u] = _hcal_year[u] + 1
            else:
                _hcal_month[u] = _hcal_month[u] + 1
            tree_dirty = 1
        return
    if rely < _HCAL_GRID_Y or relx < 2:
        return
    row: int32 = (rely - _HCAL_GRID_Y) / _HCAL_CELL_H
    col: int32 = (relx - 2) / _HCAL_CELL_W
    if row < 0 or row > 5 or col < 0 or col > 6:
        return
    first: int64 = _hcal_dow_sun(_hcal_year[u], _hcal_month[u], 1)
    nd2: int64 = _hcal_days_in_month(_hcal_year[u], _hcal_month[u])
    d: int64 = cast[int64](row * 7 + col) - first + 1
    if d < 1 or d > nd2:
        return
    _hcal_sel_y[u] = _hcal_year[u]
    _hcal_sel_m[u] = _hcal_month[u]
    _hcal_sel_d[u] = d
    w_signal[u] = 1                                  # selection changed
    tree_dirty = 1


# Paint the month view. NOTE: the hamML text sanitizer strips literal
# '<'/'>' glyphs (markup-corruption guard), so the prev/next arrows are
# drawn as chevron LINE pairs instead of text.
def _h_paint_calendar(id: int32):
    u: uint64 = cast[uint64](id)
    x: int32 = w_x[u]
    y: int32 = w_y[u]
    w: int32 = w_w[u]
    h: int32 = w_h[u]
    _h_rect(x, y, w, h, "#202020")
    _h_border(x, y, w, h, "#555555")
    # Header band + prev/next chevrons.
    _h_rect(x + 1, y + 1, w - 2, 19, "#2e2e2e")
    _h_line(x + 16, y + 5, x + 9, y + 10, "#e0e0e0")          # '<'
    _h_line(x + 9, y + 10, x + 16, y + 15, "#e0e0e0")
    _h_line(x + w - 17, y + 5, x + w - 10, y + 10, "#e0e0e0") # '>'
    _h_line(x + w - 10, y + 10, x + w - 17, y + 15, "#e0e0e0")
    # Centered "MonthName Year" title.
    fy: int64 = _hcal_year[u]
    fm: int64 = _hcal_month[u]
    tp: uint64 = 0
    tp = _h_puts(&_hcal_title[0], tp, _hcal_month_name(fm))
    tp = _h_putc(&_hcal_title[0], tp, 32)            # ' '
    tp = tp + _h_u32_to_dec(cast[uint32](fy), &_hcal_title[tp])
    _hcal_title[tp] = 0
    tx: int32 = x + (w - cast[int32](tp) * 8) / 2
    _h_text_lit(&_hcal_title[0], tx, y + 2, "#ffffff")
    # Weekday header row (Sunday-first).
    c: int32 = 0
    while c < 7:
        _h_text_lit(_hcal_dayname(c), x + 2 + c * _HCAL_CELL_W + 5, \
                    y + 22, "#9a9a9a")
        c = c + 1
    # Day grid.
    first: int64 = _hcal_dow_sun(fy, fm, 1)
    nd: int64 = _hcal_days_in_month(fy, fm)
    is_today_month: int32 = 0
    if fy == _hcal_today_y and fm == _hcal_today_m:
        is_today_month = 1
    is_sel_month: int32 = 0
    if fy == _hcal_sel_y[u] and fm == _hcal_sel_m[u]:
        is_sel_month = 1
    d: int64 = 1
    while d <= nd:
        idx: int64 = first + d - 1
        cx: int32 = x + 2 + cast[int32](idx % 7) * _HCAL_CELL_W
        cy: int32 = y + _HCAL_GRID_Y + cast[int32](idx / 7) * _HCAL_CELL_H
        selected: int32 = 0
        if is_sel_month != 0 and d == _hcal_sel_d[u]:
            selected = 1
        today: int32 = 0
        if is_today_month != 0 and d == _hcal_today_d:
            today = 1
        if selected != 0:
            _h_rect(cx, cy, _HCAL_CELL_W, _HCAL_CELL_H, "#3584e4")
        if today != 0:
            _h_border(cx, cy, _HCAL_CELL_W, _HCAL_CELL_H, "#5fc46d")
        fg: Ptr[uint8] = "#e0e0e0"
        if selected != 0:
            fg = "#ffffff"
        elif today != 0:
            fg = "#5fc46d"
        dx: int32 = cx + 5                           # 2 digits centered
        if d < 10:
            dx = cx + 9                              # 1 digit centered
        _h_text_num(cast[int32](d), dx, cy + 1, fg)
        d = d + 1


# ====================================================================
# #442 (c) RIO-FAITHFUL BLIT PROTOCOL — client-side rasterizer.
# ====================================================================
#
# This is the lib/hamui.ad half of the keystone: a small client-local
# backbuffer + rasterizer that hamui-clients commit to the kernel
# (devwsys.ad) via the binary 'B' / 'D' / 'C' verbs on
# /dev/wsys/<wid>/draw/ctl. With this, the toolkit's existing draw
# primitives no longer need to emit hamML markup the compositor parses
# per-frame; they can fill a client backbuffer directly and the
# compositor becomes a pure blitter for v2 windows.
#
# DESIGN
# ------
# 1. A v2-capable client calls hamui_set_protocol_v2() AFTER
#    hamui_window_on() to opt in (writes `version 2\n` to wctl).
# 2. The client rasterizes into a process-local backbuffer (RGBA8888)
#    via hamui_v2_clear / hamui_v2_fill_rect / hamui_v2_set_pixel.
# 3. hamui_v2_commit_rect(x,y,w,h) ships the dirty rect to the kernel
#    backbuffer as one 'B' followed by one 'D'.
#
# LIMITS
# ------
# Backbuffer dims match the kernel cap (HAMUI_V2_BB_W x HAMUI_V2_BB_H).
# The existing markup-emitting draw primitives (_h_paint_* etc) are
# UNCHANGED — v1 clients keep working bit-for-bit. v2 is opt-in.

# The maximum window the v2 backbuffer can ever be sized to. This is the
# CAP, not the per-app allocation: the actual buffer is mmap'd to the
# window's real width x height at protocol-negotiation time (see
# _h_v2_alloc). A panel (1280x28) resident-pages ~143 KB; a calculator
# (180x270) ~194 KB — instead of the old fixed 4 MB static BSS per app.
HAMUI_V2_BB_MAX_W: uint64 = 1280
HAMUI_V2_BB_MAX_H: uint64 = 800

HAMUI_V2_FMT_RGBA8888: uint8 = 1
HAMUI_V2_FMT_BGRA8888: uint8 = 2
HAMUI_V2_FMT_A8:       uint8 = 3

# mmap bits (native SYS_MMAP, Linux-numbered prot/flags), local copies so
# hamui doesn't depend on lib/thread.
HAMUI_PROT_READ:   int32 = 0x1
HAMUI_PROT_WRITE:  int32 = 0x2
HAMUI_MAP_PRIVATE: int32 = 0x02
HAMUI_MAP_ANON:    int32 = 0x20

# Client-local backbuffer, allocated dynamically (demand-zero anon mmap)
# to the actual window dims. h_v2_bb_addr / h_v2_msg_addr are the raw
# mapping addresses (0 until _h_v2_alloc succeeds); the codegen requires
# integer-initialised globals, so they are uint64 and cast to Ptr at use.
# h_v2_bb_w/h and the derived stride describe the CURRENT allocation; all
# draw primitives clip against these.
h_v2_bb_addr:  uint64 = 0
h_v2_msg_addr: uint64 = 0
h_v2_bb_w:      uint64 = 0
h_v2_bb_h:      uint64 = 0
h_v2_bb_stride: uint64 = 0      # w * 4
h_v2_bb_bytes:  uint64 = 0      # allocated bb byte size (page-rounded)
h_v2_msg_bytes: uint64 = 0      # allocated msg byte size (page-rounded)
h_v2_active: int32 = 0          # 1 = window is in v2 mode


def _h_v2_page_round(n: uint64) -> uint64:
    return (n + 4095) & cast[uint64](0xFFFFFFFFFFFFF000)


def _h_v2_bb() -> Ptr[uint8]:
    return cast[Ptr[uint8]](h_v2_bb_addr)


def _h_v2_msg() -> Ptr[uint8]:
    return cast[Ptr[uint8]](h_v2_msg_addr)


def _h_v2_alloc(w: uint64, h: uint64) -> int32:
    # Allocate (or grow to) a w x h RGBA8888 backbuffer plus its commit
    # scratch via demand-zero anon mmap. Idempotent: a second call with
    # dims that fit the current allocation is a no-op; a larger request
    # maps fresh, larger buffers (the old mapping is left to the kernel —
    # DE windows are fixed-size so this realloc path is the rare resize
    # case, not the steady state). Returns 0 on success, -1 on failure.
    if w == 0 or h == 0:
        return -1
    if w > HAMUI_V2_BB_MAX_W:
        w = HAMUI_V2_BB_MAX_W
    if h > HAMUI_V2_BB_MAX_H:
        h = HAMUI_V2_BB_MAX_H
    # Already have a big-enough buffer? Keep it, just re-describe dims so
    # clipping matches the window the client now draws into.
    if h_v2_bb_addr != 0 and w <= h_v2_bb_w and h <= h_v2_bb_h:
        h_v2_bb_w = w
        h_v2_bb_h = h
        h_v2_bb_stride = w * 4
        return 0
    bb_bytes:  uint64 = _h_v2_page_round(w * h * 4)
    # Commit scratch: 18-byte 'B'/'C' header + the full-frame RGBA payload.
    msg_bytes: uint64 = _h_v2_page_round(w * h * 4 + 32)
    bb64: int64 = sys_mmap(0, bb_bytes, HAMUI_PROT_READ | HAMUI_PROT_WRITE,
                           HAMUI_MAP_PRIVATE | HAMUI_MAP_ANON, -1, 0)
    if bb64 <= 0:
        return -1
    msg64: int64 = sys_mmap(0, msg_bytes, HAMUI_PROT_READ | HAMUI_PROT_WRITE,
                            HAMUI_MAP_PRIVATE | HAMUI_MAP_ANON, -1, 0)
    if msg64 <= 0:
        return -1
    h_v2_bb_addr  = cast[uint64](bb64)
    h_v2_msg_addr = cast[uint64](msg64)
    h_v2_bb_w = w
    h_v2_bb_h = h
    h_v2_bb_stride = w * 4
    h_v2_bb_bytes  = bb_bytes
    h_v2_msg_bytes = msg_bytes
    return 0


def hamui_set_protocol_v2_dims(w: int32, h: int32) -> int32:
    # Opt this hamui window into the rio blit protocol AND allocate a
    # backbuffer sized to the (w,h) window the client created. Writes
    # `version 2\n` to /dev/wsys/<wid>/wctl (hostowner-gated by the
    # kernel — a DE-spawned client running as hostowner satisfies that).
    # Returns 0 on success, -1 on failure (window not bound, alloc
    # failed, or write rejected). On failure h_v2_active stays 0 and the
    # legacy markup path is still authoritative for this client.
    if win_wid < 0:
        return -1
    if w <= 0 or h <= 0:
        return -1
    if _h_v2_alloc(cast[uint64](w), cast[uint64](h)) < 0:
        return -1
    _h_build_wsys_path(win_wid, "wctl")
    fd: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    msg: Ptr[uint8] = "version 2\n"
    n: int64 = sys_write(fd, msg, _h_strlen(msg))
    sys_close(fd)
    if n < 0:
        return -1
    h_v2_active = 1
    return 0


def hamui_set_protocol_v2() -> int32:
    # Back-compat entry: negotiate v2 with a full-size (max-window)
    # backbuffer. Demand-zero mmap means only the pages the client
    # actually touches become resident, but callers that know their
    # window dims should prefer hamui_set_protocol_v2_dims() so the
    # mapping itself is right-sized.
    return hamui_set_protocol_v2_dims(cast[int32](HAMUI_V2_BB_MAX_W),
                                      cast[int32](HAMUI_V2_BB_MAX_H))


def hamui_v2_is_active() -> int32:
    return h_v2_active


# Raw access to the client-local v2 backbuffer (RGBA8888) so a client can blit
# an externally-rasterised image (e.g. the browser's page canvas + AA text)
# straight into it before hamui_v2_commit_rect(). Address is 0 until a
# successful hamui_set_protocol_v2*(); w/h are the CURRENT allocation dims and
# the row stride is w*4.
def hamui_v2_bb_ptr() -> Ptr[uint8]:
    return cast[Ptr[uint8]](h_v2_bb_addr)


def hamui_v2_bb_w() -> int32:
    return cast[int32](h_v2_bb_w)


def hamui_v2_bb_h() -> int32:
    return cast[int32](h_v2_bb_h)


def _h_v2_bb_off(x: int32, y: int32) -> uint64:
    return cast[uint64](y) * h_v2_bb_stride + cast[uint64](x) * 4


def hamui_v2_clear(r: uint8, g: uint8, b: uint8):
    # Solid-fill the entire client backbuffer.
    if h_v2_bb_addr == 0:
        return
    bb: Ptr[uint8] = _h_v2_bb()
    y: uint64 = 0
    while y < h_v2_bb_h:
        x: uint64 = 0
        off: uint64 = y * h_v2_bb_stride
        while x < h_v2_bb_w:
            bb[off]     = r
            bb[off + 1] = g
            bb[off + 2] = b
            bb[off + 3] = 255
            off = off + 4
            x = x + 1
        y = y + 1


def hamui_v2_clear_transparent():
    # Solid-fill the entire client backbuffer with RGBA=(0,0,0,0).
    # The 0 alpha is a signal to the compositor's v2 blit path
    # (v2_blit_window_dirty_rect in user/hamUId.ad) to SKIP these
    # pixels — they don't overwrite the framebuffer, leaving whatever
    # the daemon_pixel cascade rendered under the window visible.
    # Use this in _paint_closed() of overlay clients (cycler/calpop/
    # run/lock/etc.) so a "hidden" overlay disappears instead of
    # painting a black box. Painted pixels (via fill_rect / set_pixel)
    # carry alpha=255 and remain visible as normal.
    if h_v2_bb_addr == 0:
        return
    bb: Ptr[uint8] = _h_v2_bb()
    y: uint64 = 0
    while y < h_v2_bb_h:
        x: uint64 = 0
        off: uint64 = y * h_v2_bb_stride
        while x < h_v2_bb_w:
            bb[off]     = 0
            bb[off + 1] = 0
            bb[off + 2] = 0
            bb[off + 3] = 0
            off = off + 4
            x = x + 1
        y = y + 1


def hamui_v2_fill_rect(x: int32, y: int32, w: int32, h: int32,
                       r: uint8, g: uint8, b: uint8):
    # Opaque-fill rect (x,y,w,h) in the client backbuffer. Clips to
    # the backbuffer; out-of-range coords are silently dropped.
    if w <= 0 or h <= 0:
        return
    if h_v2_bb_addr == 0:
        return
    bb: Ptr[uint8] = _h_v2_bb()
    x0: int32 = x
    y0: int32 = y
    x1: int32 = x + w
    y1: int32 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if cast[uint64](x1) > h_v2_bb_w:
        x1 = cast[int32](h_v2_bb_w)
    if cast[uint64](y1) > h_v2_bb_h:
        y1 = cast[int32](h_v2_bb_h)
    if x1 <= x0 or y1 <= y0:
        return
    yy: int32 = y0
    while yy < y1:
        xx: int32 = x0
        off: uint64 = _h_v2_bb_off(xx, yy)
        while xx < x1:
            bb[off]     = r
            bb[off + 1] = g
            bb[off + 2] = b
            bb[off + 3] = 255
            off = off + 4
            xx = xx + 1
        yy = yy + 1


def hamui_v2_set_pixel(x: int32, y: int32,
                       r: uint8, g: uint8, b: uint8):
    if x < 0 or y < 0:
        return
    if h_v2_bb_addr == 0:
        return
    if cast[uint64](x) >= h_v2_bb_w or cast[uint64](y) >= h_v2_bb_h:
        return
    bb: Ptr[uint8] = _h_v2_bb()
    off: uint64 = _h_v2_bb_off(x, y)
    bb[off]     = r
    bb[off + 1] = g
    bb[off + 2] = b
    bb[off + 3] = 255


def _h_v2_emit_i32_le(off: uint64, v: int32):
    msg: Ptr[uint8] = _h_v2_msg()
    u: uint32 = cast[uint32](v)
    msg[off]     = cast[uint8](u & 255)
    msg[off + 1] = cast[uint8]((u >> 8) & 255)
    msg[off + 2] = cast[uint8]((u >> 16) & 255)
    msg[off + 3] = cast[uint8]((u >> 24) & 255)


def hamui_v2_commit_rect(x: int32, y: int32, w: int32, h: int32) -> int32:
    # Ship (x,y,w,h) of the client backbuffer to the kernel as one 'B'
    # blit + one 'D' dirty-rect. Returns 0 on success, -1 on a write
    # failure / out-of-range rect.
    if win_wid < 0 or h_v2_active == 0:
        return -1
    if h_v2_bb_addr == 0 or h_v2_msg_addr == 0:
        return -1
    if w <= 0 or h <= 0:
        return 0
    bb:  Ptr[uint8] = _h_v2_bb()
    msg: Ptr[uint8] = _h_v2_msg()
    x0: int32 = x
    y0: int32 = y
    x1: int32 = x + w
    y1: int32 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if cast[uint64](x1) > h_v2_bb_w:
        x1 = cast[int32](h_v2_bb_w)
    if cast[uint64](y1) > h_v2_bb_h:
        y1 = cast[int32](h_v2_bb_h)
    if x1 <= x0 or y1 <= y0:
        return 0
    # --- compose 'B' header + RGBA payload into h_v2_msg ---
    msg[0] = 66                                          # 'B'
    _h_v2_emit_i32_le(1, x0)
    _h_v2_emit_i32_le(5, y0)
    _h_v2_emit_i32_le(9, x1)
    _h_v2_emit_i32_le(13, y1)
    msg[17] = HAMUI_V2_FMT_RGBA8888
    pos: uint64 = 18
    yy: int32 = y0
    while yy < y1:
        xx: int32 = x0
        sbo: uint64 = _h_v2_bb_off(xx, yy)
        while xx < x1:
            msg[pos]     = bb[sbo]
            msg[pos + 1] = bb[sbo + 1]
            msg[pos + 2] = bb[sbo + 2]
            msg[pos + 3] = bb[sbo + 3]
            sbo = sbo + 4
            pos = pos + 4
            xx = xx + 1
        yy = yy + 1
    # --- ship 'B' ---
    _h_build_path(win_wid, "ctl", cast[Ptr[uint8]](0))
    fd: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    nb: int64 = sys_write(fd, &msg[0], pos)
    if nb < 0:
        sys_close(fd)
        return -1
    # --- ship 'D' over the same rect on the same fd ---
    msg[0] = 68                                          # 'D'
    _h_v2_emit_i32_le(1, x0)
    _h_v2_emit_i32_le(5, y0)
    _h_v2_emit_i32_le(9, x1)
    _h_v2_emit_i32_le(13, y1)
    nd: int64 = sys_write(fd, &msg[0], 17)
    sys_close(fd)
    if nd < 0:
        return -1
    return 0


def hamui_v2_set_cursor(hx: int32, hy: int32, w: int32, h: int32,
                        pixels: Ptr[uint8]) -> int32:
    # Submit a 'C' cursor sprite update. `pixels` is RGBA8888, w*h*4
    # bytes. The kernel caps at WSYS_CUR_MAX_{W,H} (32x32); larger
    # sprites are silently truncated by the kernel.
    if win_wid < 0 or h_v2_active == 0:
        return -1
    if h_v2_msg_addr == 0:
        return -1
    if w <= 0 or h <= 0:
        return -1
    pix_bytes: uint64 = cast[uint64](w) * cast[uint64](h) * 4
    # Refuse a sprite that won't fit the commit scratch (the kernel would
    # still clip, but we'd just be wasting wire bytes / overrunning).
    if 18 + pix_bytes > h_v2_msg_bytes:
        return -1
    msg: Ptr[uint8] = _h_v2_msg()
    msg[0] = 67                                          # 'C'
    _h_v2_emit_i32_le(1, hx)
    _h_v2_emit_i32_le(5, hy)
    _h_v2_emit_i32_le(9, w)
    _h_v2_emit_i32_le(13, h)
    msg[17] = HAMUI_V2_FMT_RGBA8888
    i: uint64 = 0
    while i < pix_bytes:
        msg[18 + i] = pixels[i]
        i = i + 1
    _h_build_path(win_wid, "ctl", cast[Ptr[uint8]](0))
    fd: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    nb: int64 = sys_write(fd, &msg[0], 18 + pix_bytes)
    sys_close(fd)
    if nb < 0:
        return -1
    return 0


# ====================================================================
# SCENE-FILE EMIT PATH (docs/de_scene_file_arch.md §12, §16 step 7)
# ====================================================================
#
# A MINIMAL retained scene builder, decoupled from the legacy `/draw/`
# layered-pixel toolkit above. This is the first step of the toolkit's
# scene-file migration: an app builds a display list with hamscene_* calls
# and commits it, instead of hand-writing scene primitives + ctl pokes.
#
# Model (per the spec): build the whole display list each time the content
# changes, then commit. The builder owns one text buffer; hamscene_begin
# resets it, the primitive calls append one line each, and hamscene_commit
# writes the buffer to /dev/wsys/<wid>/scene and pokes `commit` on
# /dev/wsys/<wid>/ctl (the atomic data+commit pattern — the compositor
# reads the scene ONLY on the commit signal, never a half-written frame).
#
# Colors are passed as a NUL-terminated "#RRGGBB"/"#RRGGBBAA" C-string so
# the app stays in scene-grammar terms and never touches packed pixels.
# This is intentionally small: the full retained widget-tree -> scene
# lowering is a later wave; this unblocks apps (the file manager) driving
# their scene through the toolkit today.

def hamscene_commit(wid: int32) -> int32:
    # Atomically publish the built display list for `wid`: write the whole
    # scene to /dev/wsys/<wid>/scene, then poke `commit` on the window's
    # ctl. The compositor reads the scene ONLY on the commit signal, so it
    # never observes a torn frame. Returns 0 on success, -1 on any I/O
    # failure.
    _h_build_wsys_path(wid, "scene")
    sfd: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if sfd < 0:
        return -1
    nb: int64 = sys_write(sfd, hamscene_bufptr(), hamscene_length())
    sys_close(sfd)
    if nb < 0:
        return -1
    _h_build_wsys_path(wid, "ctl")
    cfd: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if cfd < 0:
        return -1
    sys_write(cfd, cast[Ptr[uint8]]("commit\n"), 7)
    sys_close(cfd)
    return 0

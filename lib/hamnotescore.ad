# lib/hamnotescore.ad — PURE, extern-free core for the Notes app
# (/bin/hamnotes). A multi-note pad with three things the user asked for:
#   1. a TITLE field to name the current note,
#   2. a large TEXT-EDIT area for the note body (multi-line, caret, editable),
#   3. a NOTE SELECTOR — a left sidebar listing every saved note by its title;
#      click a row to switch to it. Plus New / Save / Delete on the toolbar.
#
# Focus moves between the title field and the body (click either, or Tab). All
# state that survives a launch lives in files the driver owns under a notes
# directory (default /home/live/Notes/ so it survives a reboot):
#   <root>/note-<idx>.txt   one file per note, serialised "<title>\n<body>"
#   <root>/.state           "<count> <current>\n"
#
# This file owns the buffers, keyboard editing, the toolbar/sidebar hit-testing
# and the word-wrapped rendering; it builds the note/state file PATHS as pure
# strings and SERIALISES a note (title+body) but performs NO I/O itself (imports
# only lib/hamscene) so it renders on the host to a PNG and drives scripted
# keystrokes/clicks deterministically (see user/hamnotesscene_host.ad +
# docs/hamui_dual_target.md). The drivers (native user/hamnotesscene.ad + host
# harness) do the open/read/write and keep the sidebar titles current.

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_stroke, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_roundrect
# #303: proportional caret X (sum real glyph advances) — the DE font is
# proportional since #284, so tit_len*GLYPH_W drifted the caret rightward.
from lib.hamtextbox import htb_caret_x, htb_text_width


CAP: uint64 = 2048
text: Array[2048, uint8]
tlen: uint64 = 0
dirty: int32 = 0

# Per-note title being edited (single line, no newline).
TITLE_CAP: uint64 = 40
title: Array[40, uint8]
tit_len: uint64 = 0

# Which field the keyboard drives: 0 = body, 1 = title.
focus: int32 = 0

# Action requested by a keystroke or a click, drained by the driver.
#   0 none  1 save  2 new  3 prev  4 next  5 select(pending_select)  6 delete
pending_action: int32 = 0
pending_select: int32 = 0

# Multi-note state (owned here; persisted by the driver via .state).
cur_idx: int32 = 0
note_count: int32 = 1

# Sidebar titles: one fixed-width slot per note, kept fresh by the driver so the
# selector can list every saved note without loading its whole body.
MAX_NOTES: uint64 = 32
titles: Array[1280, uint8]              # MAX_NOTES * TITLE_CAP
tit_lens: Array[32, int32]

# Brief "saved!" acknowledgement countdown (decremented each render).
flash: int32 = 0

# Notes root directory. Empty => use the built-in default; the host harness
# overrides it (hamnotes_set_root) so its scratch dir stays out of the way.
NROOT_CAP: uint64 = 120
notes_root: Array[120, uint8]
notes_root_len: uint64 = 0


def _notes_slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def hamnotes_len() -> uint64:
    return tlen


def hamnotes_text_ptr() -> Ptr[uint8]:
    return &text[0]


def hamnotes_title_ptr() -> Ptr[uint8]:
    return &title[0]


def hamnotes_title_len() -> uint64:
    return tit_len


def hamnotes_dirty() -> int32:
    return dirty


def hamnotes_mark_saved():
    dirty = 0


def hamnotes_cur_idx() -> int32:
    return cur_idx


def hamnotes_count() -> int32:
    return note_count


def hamnotes_pending_select() -> int32:
    return pending_select


# Drain the pending action (0 = none). Driver calls this after a key changed.
def hamnotes_take_action() -> int32:
    a: int32 = pending_action
    pending_action = 0
    return a


def hamnotes_clear():
    tlen = 0
    tit_len = 0
    dirty = 0


# ---- sidebar title table (fresh copy the driver keeps in sync) -------------
def _title_slot(idx: int32) -> Ptr[uint8]:
    return &titles[cast[uint64](idx) * TITLE_CAP]


# Copy the FIRST LINE of a note buffer (title, terminated by '\n' or the end)
# into the sidebar slot for note <idx>. Used by the driver after reading files.
def hamnotes_load_title_at(idx: int32, s: Ptr[uint8], n: uint64):
    if idx < 0 or cast[uint64](idx) >= MAX_NOTES:
        return
    slot: Ptr[uint8] = _title_slot(idx)
    i: uint64 = 0
    while i < n and s[i] != 10 and i < TITLE_CAP:
        slot[i] = s[i]
        i = i + 1
    tit_lens[idx] = cast[int32](i)


def _clear_title_slot(idx: int32):
    if idx < 0 or cast[uint64](idx) >= MAX_NOTES:
        return
    tit_lens[idx] = 0


# Reflect the title currently being edited into the sidebar slot (so live edits
# show up in the list). Called each render.
def _sync_cur_title():
    if cast[uint64](cur_idx) >= MAX_NOTES:
        return
    slot: Ptr[uint8] = _title_slot(cur_idx)
    i: uint64 = 0
    while i < tit_len and i < TITLE_CAP:
        slot[i] = title[i]
        i = i + 1
    tit_lens[cur_idx] = cast[int32](tit_len)


# Start a brand-new blank note: the next free index becomes current.
def hamnotes_new_note():
    if cast[uint64](note_count) >= MAX_NOTES:
        return
    cur_idx = note_count
    note_count = note_count + 1
    tlen = 0
    tit_len = 0
    dirty = 0
    focus = 1                       # name the fresh note first
    _clear_title_slot(cur_idx)


# Page to the previous (dir<0) / next (dir>0) note; clamps at the ends.
def hamnotes_switch(dir: int32):
    if dir < 0:
        if cur_idx > 0:
            cur_idx = cur_idx - 1
    else:
        if cur_idx < note_count - 1:
            cur_idx = cur_idx + 1


# Jump straight to note <idx> (clamped); used by the sidebar selector.
def hamnotes_goto(idx: int32):
    if idx >= 0 and idx < note_count:
        cur_idx = idx


# Drop the current note from the in-memory count and clamp the cursor. The
# driver shifts the on-disk files and refreshes the sidebar titles around this.
def hamnotes_delete_current():
    if note_count > 1:
        note_count = note_count - 1
        if cur_idx >= note_count:
            cur_idx = note_count - 1


def hamnotes_flash_saved():
    flash = 8


def hamnotes_set_text(s: Ptr[uint8], n: uint64):
    if n > CAP:
        n = CAP
    i: uint64 = 0
    while i < n:
        text[i] = s[i]
        i = i + 1
    tlen = n
    dirty = 0


def hamnotes_set_cur_title(s: Ptr[uint8], n: uint64):
    if n > TITLE_CAP:
        n = TITLE_CAP
    i: uint64 = 0
    while i < n:
        title[i] = s[i]
        i = i + 1
    tit_len = n


def hamnotes_set_root(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < NROOT_CAP - 1:
        notes_root[i] = s[i]
        i = i + 1
    notes_root_len = i


# ---- serialise / deserialise a note = "<title>\n<body>" -------------------
# Write the whole current note (title line + body) into out. Returns byte count.
def hamnotes_serialize(out: Ptr[uint8]) -> uint64:
    p: uint64 = 0
    i: uint64 = 0
    while i < tit_len:
        out[p] = title[i]
        p = p + 1
        i = i + 1
    out[p] = 10
    p = p + 1
    j: uint64 = 0
    while j < tlen:
        out[p] = text[j]
        p = p + 1
        j = j + 1
    return p


# Parse "<title>\n<body>" back into the title + body buffers.
def hamnotes_deserialize(s: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n and s[i] != 10 and i < TITLE_CAP:
        title[i] = s[i]
        i = i + 1
    tit_len = i
    # advance to the byte after the first newline
    while i < n and s[i] != 10:
        i = i + 1
    if i < n:
        i = i + 1
    b: uint64 = 0
    while i < n and b < CAP:
        text[b] = s[i]
        b = b + 1
        i = i + 1
    tlen = b
    dirty = 0


# ---- path + state building (PURE; no syscalls) ---------------------------
def _default_root() -> Ptr[uint8]:
    return cast[Ptr[uint8]]("/home/live/Notes")


def _notes_udec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _append_cstr(out: Ptr[uint8], p: uint64, s: Ptr[uint8]) -> uint64:
    j: uint64 = 0
    while s[j] != 0:
        out[p] = s[j]
        p = p + 1
        j = j + 1
    return p


def _copy_root(out: Ptr[uint8]) -> uint64:
    if notes_root_len == 0:
        return _append_cstr(out, 0, _default_root())
    i: uint64 = 0
    while i < notes_root_len:
        out[i] = notes_root[i]
        i = i + 1
    return notes_root_len


# Build "<root>/note-<idx>.txt\0". Returns the length (excluding the NUL).
def hamnotes_notepath(out: Ptr[uint8], idx: int32) -> uint64:
    p: uint64 = _copy_root(out)
    p = _append_cstr(out, p, cast[Ptr[uint8]]("/note-"))
    p = p + _notes_udec(cast[uint64](idx), &out[p])
    p = _append_cstr(out, p, cast[Ptr[uint8]](".txt"))
    out[p] = 0
    return p


# Build "<root>/.state\0". Returns the length (excluding the NUL).
def hamnotes_statepath(out: Ptr[uint8]) -> uint64:
    p: uint64 = _copy_root(out)
    p = _append_cstr(out, p, cast[Ptr[uint8]]("/.state"))
    out[p] = 0
    return p


# Serialise "<count> <current>\n" into out. Returns the byte count.
def hamnotes_state_encode(out: Ptr[uint8]) -> uint64:
    p: uint64 = _notes_udec(cast[uint64](note_count), &out[0])
    out[p] = 32
    p = p + 1
    p = p + _notes_udec(cast[uint64](cur_idx), &out[p])
    out[p] = 10
    p = p + 1
    return p


# Parse "<count> <current>" back into note_count/cur_idx (clamped/coherent).
def hamnotes_state_decode(s: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n and s[i] == 32:
        i = i + 1
    c: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        c = c * 10 + cast[int32](s[i]) - 48
        i = i + 1
    while i < n and s[i] == 32:
        i = i + 1
    cur: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        cur = cur * 10 + cast[int32](s[i]) - 48
        i = i + 1
    if c < 1:
        c = 1
    if cur < 0:
        cur = 0
    if cur >= c:
        cur = c - 1
    note_count = c
    cur_idx = cur


# Arrow/escape decode state. The keyboard delivers arrow/Home/End keys as the
# byte run ESC(27) '['(91) <final>; both Notes fields are append-only (caret at
# end), so there is nothing to navigate — we SWALLOW the sequence rather than
# append the literal "[D"/"[C" the user saw as garbage (#303).
notes_esc: int32 = 0                                   # 0 none, 1 ESC, 2 ESC[


# Apply one key (ASCII code). Returns 1 if the buffer or action state changed.
def hamnotes_key(code: int32) -> int32:
    if notes_esc == 1:                                 # after ESC
        if code == 91:                                 # '['
            notes_esc = 2
        else:
            notes_esc = 0
        return 0
    if notes_esc == 2:                                 # inside CSI: eat to final
        if code < 48 or code > 57:                     # non-digit terminates
            notes_esc = 0
        return 0
    if code == 27:                                     # ESC -> begin sequence
        notes_esc = 1
        return 0
    if code == 14:                                     # Ctrl-N -> New note
        pending_action = 2
        return 1
    if code == 19:                                     # Ctrl-S -> Save
        pending_action = 1
        return 1
    if code == 9:                                      # Tab -> toggle focus
        if focus == 0:
            focus = 1
        else:
            focus = 0
        return 1
    if focus == 1:                                     # ---- editing the TITLE
        if code == 8 or code == 127:                   # backspace / DEL
            if tit_len > 0:
                tit_len = tit_len - 1
                dirty = 1
                return 1
            return 0
        if code == 13 or code == 10:                   # enter -> jump to body
            focus = 0
            return 1
        if code >= 32 and code <= 126:
            if tit_len < TITLE_CAP - 1:
                title[tit_len] = cast[uint8](code)
                tit_len = tit_len + 1
                dirty = 1
                return 1
        return 0
    # ---- editing the BODY
    if code == 8 or code == 127:                       # backspace / DEL
        if tlen > 0:
            tlen = tlen - 1
            dirty = 1
            return 1
        return 0
    if code == 13 or code == 10:                       # enter -> newline
        if tlen < CAP:
            text[tlen] = 10
            tlen = tlen + 1
            dirty = 1
            return 1
        return 0
    if code >= 32 and code <= 126:
        if tlen < CAP:
            text[tlen] = cast[uint8](code)
            tlen = tlen + 1
            dirty = 1
            return 1
    return 0


# Parse a "d <code>" key-press wire line and apply it. Returns 1 if changed.
def hamnotes_key_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 100:                           # 'd' press; ignore 'u'
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    neg: int32 = 0
    if i < n and s[i] == 45:
        neg = 1
        i = i + 1
    code: int32 = 0
    got: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        code = code * 10 + cast[int32](s[i]) - 48
        i = i + 1
        got = 1
    if got == 0:
        return 0
    if neg != 0:
        code = 0 - code
    return hamnotes_key(code)


# ---- layout --------------------------------------------------------------
WIN_W: int32 = 480
WIN_H: int32 = 300
BAR_H: int32 = 22          # amber sticky title bar
TB_Y: int32 = 22           # toolbar strip
TB_H: int32 = 26
BTN_Y: int32 = 25
BTN_H: int32 = 18
NEW_X: int32 = 6
NEW_W: int32 = 44
SAVE_X: int32 = 54
SAVE_W: int32 = 48
DEL_X: int32 = 106
DEL_W: int32 = 56
IND_X: int32 = 176         # "Note c/t" indicator

# sidebar note selector
SIDE_X: int32 = 0
SIDE_Y: int32 = 48
SIDE_W: int32 = 140
HDR_H: int32 = 18
ROW_Y0: int32 = 68
ROW_H: int32 = 24

# main pane: title field + body edit area
MAIN_X: int32 = 148
TIT_X: int32 = 152
# #303: the "Title" caption is drawn at TIT_Y-16; with the old TIT_Y=54 that
# put it at y=38, INSIDE the toolbar/button band (buttons y=25..43) so it
# rendered over the Delete button. Drop the title field to y=70 so its caption
# lands at y=54 — clear of the toolbar — and shift the body area down to match.
TIT_Y: int32 = 70
TIT_W: int32 = 320
TIT_H: int32 = 24
TA_X: int32 = 152
TA_Y: int32 = 100
TA_W: int32 = 320
TA_H: int32 = 190
GLYPH_W: int32 = 8
LINE_H: int32 = 16
MAXCOLS: uint64 = 38           # (TA_W-8)/8
MAXROWS: uint64 = 12


# Hit-test a pointer click. Toolbar buttons return their action (1 save, 2 new,
# 6 delete). A sidebar row returns 5 (select) with pending_select set. Clicking
# the title field / body area just moves focus (returns 0). Otherwise 0.
def hamnotes_hit(x: int64, y: int64) -> int32:
    # toolbar row
    if y >= cast[int64](TB_Y) and y < cast[int64](TB_Y + TB_H):
        if x >= cast[int64](NEW_X) and x < cast[int64](NEW_X + NEW_W):
            return 2
        if x >= cast[int64](SAVE_X) and x < cast[int64](SAVE_X + SAVE_W):
            return 1
        if x >= cast[int64](DEL_X) and x < cast[int64](DEL_X + DEL_W):
            return 6
        return 0
    # sidebar selector
    if x >= cast[int64](SIDE_X) and x < cast[int64](SIDE_X + SIDE_W) and \
            y >= cast[int64](ROW_Y0):
        r: int32 = cast[int32]((y - cast[int64](ROW_Y0)) / cast[int64](ROW_H))
        if r >= 0 and r < note_count:
            pending_select = r
            return 5
        return 0
    # title field -> focus title
    if x >= cast[int64](TIT_X) and x < cast[int64](TIT_X + TIT_W) and \
            y >= cast[int64](TIT_Y) and y < cast[int64](TIT_Y + TIT_H):
        focus = 1
        return 0
    # body area -> focus body
    if x >= cast[int64](TA_X) and x < cast[int64](TA_X + TA_W) and \
            y >= cast[int64](TA_Y) and y < cast[int64](TA_Y + TA_H):
        focus = 0
        return 0
    return 0


# ---- scene ---------------------------------------------------------------
line_buf: Array[64, uint8]
ind_buf: Array[24, uint8]


def _button(x: int32, w: int32, label: Ptr[uint8]):
    hamscene_roundrect(x, BTN_Y, w, BTN_H, 4, cast[Ptr[uint8]]("#e6e8ec"))
    hamscene_stroke(x, BTN_Y, w, BTN_H, 1, cast[Ptr[uint8]]("#a8b0ba"))
    hamscene_glyphs(x + 6, BTN_Y + 3, label, cast[Ptr[uint8]]("#202020"))


# One sidebar row: rounded highlight if selected, then the note's title (or a
# placeholder when it has none yet). Truncated to fit the rail.
def _side_row(r: int32):
    ry: int32 = ROW_Y0 + r * ROW_H
    sel: int32 = 0
    if r == cur_idx:
        sel = 1
    if sel != 0:
        hamscene_roundrect(4, ry, SIDE_W - 8, ROW_H - 4, 5,
                           cast[Ptr[uint8]]("#3584e4"))
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#23262b")
    if sel != 0:
        fg = cast[Ptr[uint8]]("#ffffff")
    tl: int32 = tit_lens[r]
    if tl > 0:
        slot: Ptr[uint8] = _title_slot(r)
        i: uint64 = 0
        mx: uint64 = 15
        while i < cast[uint64](tl) and i < mx:
            line_buf[i] = slot[i]
            i = i + 1
        line_buf[i] = 0
        hamscene_glyphs(12, ry + 4, &line_buf[0], fg)
    else:
        # untitled placeholder: "Note <r+1>"
        p: uint64 = _append_cstr(&line_buf[0], 0, cast[Ptr[uint8]]("Note "))
        p = p + _notes_udec(cast[uint64](r + 1), &line_buf[p])
        line_buf[p] = 0
        hamscene_glyphs(12, ry + 4, &line_buf[0], fg)


def hamnotes_build_scene():
    if flash > 0:
        flash = flash - 1
    _sync_cur_title()
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    hamscene_begin()
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#eceef2"))
    hamscene_fill(0, 0, WIN_W, BAR_H, cast[Ptr[uint8]]("#f2c744"))     # amber bar
    hamscene_fill(0, BAR_H - 1, WIN_W, 1, cast[Ptr[uint8]]("#d9a400"))
    hamscene_glyphs(10, 6, cast[Ptr[uint8]]("Notes"), fg)
    stat: Ptr[uint8] = cast[Ptr[uint8]]("ready")
    if flash > 0:
        stat = cast[Ptr[uint8]]("saved!")
    elif dirty != 0:
        stat = cast[Ptr[uint8]]("* editing")
    hamscene_glyphs(WIN_W - 92, 6, stat, cast[Ptr[uint8]]("#404020"))

    # toolbar strip + buttons (labels double as the keyboard hints)
    hamscene_fill(0, TB_Y, WIN_W, TB_H, cast[Ptr[uint8]]("#eceef2"))
    hamscene_stroke(0, TB_Y + TB_H - 1, WIN_W, 1, 1, cast[Ptr[uint8]]("#a0a0a0"))
    _button(NEW_X, NEW_W, cast[Ptr[uint8]]("New"))
    _button(SAVE_X, SAVE_W, cast[Ptr[uint8]]("Save"))
    _button(DEL_X, DEL_W, cast[Ptr[uint8]]("Delete"))

    # "Note c/t" indicator (1-based, human friendly)
    ip: uint64 = _append_cstr(&ind_buf[0], 0, cast[Ptr[uint8]]("Note "))
    ip = ip + _notes_udec(cast[uint64](cur_idx + 1), &ind_buf[ip])
    ind_buf[ip] = 47                                            # '/'
    ip = ip + 1
    ip = ip + _notes_udec(cast[uint64](note_count), &ind_buf[ip])
    ind_buf[ip] = 0
    hamscene_glyphs(IND_X, BTN_Y + 3, &ind_buf[0], cast[Ptr[uint8]]("#303030"))

    # ---- sidebar note selector ----------------------------------------
    hamscene_fill(SIDE_X, SIDE_Y, SIDE_W, WIN_H - SIDE_Y,
                  cast[Ptr[uint8]]("#f7f8fa"))
    hamscene_stroke(SIDE_X, SIDE_Y, SIDE_W, WIN_H - SIDE_Y, 1,
                    cast[Ptr[uint8]]("#cfd2d8"))
    hamscene_glyphs_bold(10, SIDE_Y + 3, cast[Ptr[uint8]]("NOTES"),
                         cast[Ptr[uint8]]("#6b7078"))
    hamscene_stroke(SIDE_X, SIDE_Y + HDR_H, SIDE_W, 1, 1,
                    cast[Ptr[uint8]]("#cfd2d8"))
    r: int32 = 0
    while r < note_count and cast[int32](ROW_Y0 + r * ROW_H) < WIN_H:
        _side_row(r)
        r = r + 1

    # ---- title field --------------------------------------------------
    hamscene_glyphs(MAIN_X, TIT_Y - 16, cast[Ptr[uint8]]("Title"),
                    cast[Ptr[uint8]]("#6b7078"))
    hamscene_roundrect(TIT_X, TIT_Y, TIT_W, TIT_H, 4,
                       cast[Ptr[uint8]]("#ffffff"))
    tbord: Ptr[uint8] = cast[Ptr[uint8]]("#cfd2d8")
    if focus == 1:
        tbord = cast[Ptr[uint8]]("#3584e4")
    hamscene_stroke(TIT_X, TIT_Y, TIT_W, TIT_H, 1, tbord)
    if tit_len > 0:
        ti: uint64 = 0
        while ti < tit_len and ti < 62:
            line_buf[ti] = title[ti]
            ti = ti + 1
        line_buf[ti] = 0
        hamscene_glyphs(TIT_X + 6, TIT_Y + 6, &line_buf[0],
                        cast[Ptr[uint8]]("#202020"))
    else:
        hamscene_glyphs(TIT_X + 6, TIT_Y + 6,
                        cast[Ptr[uint8]]("Untitled note"),
                        cast[Ptr[uint8]]("#a0a4ab"))
    if focus == 1:
        # caret after the title text — proportional advance sum, not len*8
        tcx: int32 = htb_caret_x(TIT_X + 6, &title[0], tit_len)
        hamscene_fill(tcx, TIT_Y + 5, 2, 14, cast[Ptr[uint8]]("#202020"))

    # ---- body text area (pale paper) ----------------------------------
    hamscene_fill(TA_X, TA_Y, TA_W, TA_H, cast[Ptr[uint8]]("#fffef0"))
    bbord: Ptr[uint8] = cast[Ptr[uint8]]("#808080")
    if focus == 0:
        bbord = cast[Ptr[uint8]]("#3584e4")
    hamscene_stroke(TA_X, TA_Y, TA_W, TA_H, 1, bbord)

    # word-wrap the buffer into display rows; break on explicit '\n' and at
    # MAXCOLS. Draw a caret block after the last glyph when the body has focus.
    row: uint64 = 0
    col: uint64 = 0
    lb: uint64 = 0
    caret_x: int32 = TA_X + 4
    caret_y: int32 = TA_Y + 4
    i: uint64 = 0
    while i < tlen and row < MAXROWS:
        ch: uint8 = text[i]
        if ch == 10:
            line_buf[lb] = 0
            hamscene_glyphs(TA_X + 4, TA_Y + 4 + cast[int32](row) * LINE_H,
                            &line_buf[0], fg)
            row = row + 1
            col = 0
            lb = 0
        else:
            line_buf[lb] = ch
            lb = lb + 1
            col = col + 1
            if col >= MAXCOLS:
                line_buf[lb] = 0
                hamscene_glyphs(TA_X + 4, TA_Y + 4 + cast[int32](row) * LINE_H,
                                &line_buf[0], fg)
                row = row + 1
                col = 0
                lb = 0
        i = i + 1
    # flush the trailing partial line
    if row < MAXROWS:
        line_buf[lb] = 0
        hamscene_glyphs(TA_X + 4, TA_Y + 4 + cast[int32](row) * LINE_H,
                        &line_buf[0], fg)
        # Proportional caret: advance-sum of the last line's glyphs so far.
        caret_x = TA_X + 4 + htb_text_width(&line_buf[0], col)
        caret_y = TA_Y + 4 + cast[int32](row) * LINE_H
    if focus == 0:
        hamscene_fill(caret_x, caret_y, 2, 14, cast[Ptr[uint8]]("#202020"))

    hamscene_glyphs(MAIN_X, WIN_H - 16,
                    cast[Ptr[uint8]]("Tab switch field  Ctrl-S save  Ctrl-N new"),
                    cast[Ptr[uint8]]("#606060"))

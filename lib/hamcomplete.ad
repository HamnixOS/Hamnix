# lib/hamcomplete.ad — PURE, extern-free completion engine for hamsh's
# interactive Tab completion (user/hamsh.ad :: _ed_complete).
#
# The engine is the readline matching kernel, factored out of the shell so
# it can be unit-tested on the host (user/hamcomplete_host.ad, gated by
# scripts/test_hamsh_complete_host.sh) with NO QEMU. It knows nothing about
# /bin, dirread, the line editor, or namespaces — those are wired on top in
# hamsh.ad. It deals only in bytes:
#
#   hc_prefix_match(name, nlen, pfx, plen)  -> 1 iff name starts with pfx
#   hc_common_prefix_len(a, alen, b, blen)  -> length of the shared prefix
#   hc_complete(partial, cands, ...)        -> (common_prefix, matches[])
#
# hc_complete is the pure driver the task specifies:
#   (partial, candidates[]) -> (common_prefix, matches[])
# where `candidates` is a NEWLINE-separated buffer of names and the result
# is the deduped subset that begins with `partial`, plus the longest common
# prefix of that subset. hamsh's gather helpers (_cmp_offer*) delegate their
# byte-level prefix test and LCP fold to the two primitives above so the
# on-device path and the host unit test share ONE implementation.

# Longest common prefix length of two byte spans. Never reads past either
# span's length; stops at the first differing byte.
def hc_common_prefix_len(a: Ptr[uint8], alen: uint64,
                         b: Ptr[uint8], blen: uint64) -> uint64:
    k: uint64 = 0
    while k < alen and k < blen and a[k] == b[k]:
        k = k + 1
    return k


# True iff the `nlen`-byte name begins with the `plen`-byte prefix. An
# empty prefix (plen == 0) matches everything; a prefix longer than the
# name never matches.
def hc_prefix_match(name: Ptr[uint8], nlen: uint64,
                    pfx: Ptr[uint8], plen: uint64) -> int32:
    if nlen < plen:
        return 0
    k: uint64 = 0
    while k < plen:
        if name[k] != pfx[k]:
            return 0
        k = k + 1
    return 1


# Scan the newline-separated buffer `matches[0..mlen)` for an exact name of
# length nlen. Returns 1 if already present (dedup).
def _hc_seen(matches: Ptr[uint8], mlen: uint64,
             name: Ptr[uint8], nlen: uint64) -> int32:
    p: uint64 = 0
    while p < mlen:
        s: uint64 = p
        while p < mlen and matches[p] != 10:
            p = p + 1
        llen: uint64 = p - s
        if p < mlen:
            p = p + 1
        if llen == nlen:
            same: int32 = 1
            k: uint64 = 0
            while k < nlen:
                if matches[s + k] != name[k]:
                    same = 0
                    break
                k = k + 1
            if same != 0:
                return 1
    return 0


# The pure completion driver.
#
#   partial           — the prefix being completed (`plen` bytes)
#   cands / cands_len — candidate names, NEWLINE-separated, in one buffer
#   out_prefix        — receives the longest common prefix of the matches
#   out_prefix_cap    — capacity of out_prefix (bytes)
#   out_matches       — receives the deduped matching names, NEWLINE-separated
#   out_matches_cap   — capacity of out_matches (bytes)
#   out_prefix_len    — receives the length of the common prefix written
#
# Returns the number of distinct matches. A candidate matches when it begins
# with `partial`; duplicates (same name offered twice) count once. With zero
# matches out_prefix_len is 0. With one match the common prefix IS that whole
# name. Empty fields in `cands` (a leading/trailing/doubled newline) are
# skipped.
def hc_complete(partial: Ptr[uint8], plen: uint64,
                cands: Ptr[uint8], cands_len: uint64,
                out_prefix: Ptr[uint8], out_prefix_cap: uint64,
                out_matches: Ptr[uint8], out_matches_cap: uint64,
                out_prefix_len: Ptr[uint64]) -> uint64:
    count: uint64 = 0
    mlen: uint64 = 0          # bytes written into out_matches so far
    pfx_len: uint64 = 0       # running longest common prefix length
    p: uint64 = 0
    while p < cands_len:
        s: uint64 = p
        while p < cands_len and cands[p] != 10:
            p = p + 1
        nlen: uint64 = p - s
        if p < cands_len:
            p = p + 1
        if nlen == 0:
            continue          # skip empty field
        if hc_prefix_match(&cands[s], nlen, partial, plen) == 0:
            continue
        if _hc_seen(&out_matches[0], mlen, &cands[s], nlen) != 0:
            continue
        # Fold into the running common prefix.
        if count == 0:
            i: uint64 = 0
            while i < nlen and i < out_prefix_cap:
                out_prefix[i] = cands[s + i]
                i = i + 1
            pfx_len = i
        else:
            pfx_len = hc_common_prefix_len(&out_prefix[0], pfx_len,
                                           &cands[s], nlen)
        count = count + 1
        # Append "name\n" to the matches buffer (skip if it would overflow).
        if mlen + nlen + 1 <= out_matches_cap:
            j: uint64 = 0
            while j < nlen:
                out_matches[mlen + j] = cands[s + j]
                j = j + 1
            out_matches[mlen + nlen] = 10
            mlen = mlen + nlen + 1
    if count == 0:
        pfx_len = 0
    out_prefix_len[0] = pfx_len
    return count

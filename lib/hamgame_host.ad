# lib/hamgame_host.ad — hamGame HOST backend (x86_64-linux only).
#
# The developer-host mirror of lib/hamgame_dev.ad and the twin of
# lib/hamsdl_host.ad: it REGISTERS the display Surface's RGBA bytes with the
# host image sink (lib/hamui_host.ad) under game_screen_name(), then RASTERIZES
# the scene lib/hamgame.ad built (the display-image blit + any HUD glyphs) into
# an RGB framebuffer and writes it as a binary PPM a human/agent can LOOK at.
# It also owns a scripted millisecond clock so a game iterates with NO QEMU —
# the hambrowse/hamUI/hamSDL dual-target seam. Input is scripted through the
# shared queue API (game_push_event / game_feed_* in lib/hamgame.ad).
#
# PUBLIC API (host half of the hamGame present seam):
#   game_host_present(surf) -> int32   register `surf` as the screen image +
#                                       rasterize the built frame; returns the
#                                       primitive count drawn
#   game_host_write_ppm(path) -> int32 write the framebuffer as a PPM
#   game_host_pixel(x, y) -> uint32    sampled 0x00RRGGBB pixel (gate asserts)
#   game_host_advance(ms)              advance the scripted clock
#   game_host_ticks() -> uint64        read the scripted millisecond clock
#   game_host_load_image(path) -> int32  read+decode an image FILE (PNG/BMP)
#                                       off the host FS into a new Surface
#                                       (pygame.image.load, the path form)

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

# Phase B (GPU track #181): hamGame's host present routes through the vk 2D
# primitive layer (lib/hamsdl_vk.ad -> lib/vk/vk_2d.ad) — the screen Surface is
# registered as a vk-blittable image and the frame is rasterized into a vk
# RGBA8888 color image through the exact vk2d ops the kernel command buffer
# replays, then presented as a PPM. Byte-identical to the old hamui_host path.
from lib.hamsdl_vk import hamsdl_vk_begin, hamsdl_vk_rasterize, \
    hamsdl_vk_ppm_header, hamsdl_vk_fb_rgb_ptr, hamsdl_vk_fb_rgb_bytes, \
    hamsdl_vk_pixel, hamsdl_vk_register_image
from lib.hamgame import game_screen_name, game_surface_w, game_surface_h, \
    game_surface_ptr, game_load_image


_game_host_ticks: uint64 = 0
_game_ppm_hdr: Array[64, uint8]

# File-slurp scratch for game_host_load_image — bounds a decodable asset on the
# host (sprites/spritesheets, not full-desktop captures). 4 MiB matches the BMP
# decoder's output ceiling with headroom for a compressed PNG of similar size.
GAME_IMG_FILE_CAP: uint64 = 4194304
_game_img_file: Array[4194304, uint8]


# pygame.image.load(path): read an image FILE off the host filesystem, sniff its
# format (PNG/BMP) and decode it into a NEW hamGame Surface, returning the handle
# (or -1 on open/read/decode failure or an over-cap file). This is the host half
# of the loader — file I/O lives in the backend (the extern-free core stays pure);
# lib/hamgame.ad::game_load_image does the format dispatch + surface fill. The
# device backend gets the equivalent from /dev when a game ships an asset.
def game_host_load_image(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 0, 0)                     # O_RDONLY
    if fd < 0:
        return -1
    total: uint64 = 0
    while total < GAME_IMG_FILE_CAP:
        got: int64 = sys_read(fd, &_game_img_file[total],
                              GAME_IMG_FILE_CAP - total)
        if got < 0:
            sys_close(fd)
            return -1
        if got == 0:
            break                                        # EOF
        total = total + cast[uint64](got)
    sys_close(fd)
    if total == 0:
        return -1
    return game_load_image(&_game_img_file[0], total)


# Register the display Surface under the fixed screen name, then rasterize the
# frame hamGame built (game_flip_scene emitted the image blit) into a fresh
# w*h vk color image through vk2d. Returns the number of primitives drawn.
def game_host_present(surf: int32) -> int32:
    w: int32 = game_surface_w(surf)
    h: int32 = game_surface_h(surf)
    hamsdl_vk_register_image(game_screen_name(), w, h, game_surface_ptr(surf))
    hamsdl_vk_begin(w, h)
    return hamsdl_vk_rasterize()


def game_host_write_ppm(path: Ptr[char]) -> int32:
    # O_WRONLY|O_CREAT|O_TRUNC = 577, mode 0644 = 420.
    fd: int32 = sys_open(path, 577, 420)
    if fd < 0:
        return -1
    hlen: uint64 = hamsdl_vk_ppm_header(&_game_ppm_hdr[0])
    sys_write(fd, &_game_ppm_hdr[0], hlen)
    sys_write(fd, hamsdl_vk_fb_rgb_ptr(), hamsdl_vk_fb_rgb_bytes())
    sys_close(fd)
    return 0


def game_host_pixel(x: int32, y: int32) -> uint32:
    return hamsdl_vk_pixel(x, y)


def game_host_advance(ms: uint64):
    _game_host_ticks = _game_host_ticks + ms


def game_host_ticks() -> uint64:
    return _game_host_ticks

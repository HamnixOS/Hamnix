# lib/hamgame_host.ad — hamGame HOST backend (x86_64-linux only).
#
# The developer-host mirror of lib/hamgame_dev.ad and the twin of
# lib/hamsdl_host.ad: it REGISTERS the display Surface's RGBA bytes with the
# host image sink (lib/hamui_host.ad) under game_screen_name(), then RASTERIZES
# the scene lib/hamgame.ad built (the display-image blit + any HUD glyphs) into
# an RGB framebuffer and writes it as a binary PPM a human/agent can LOOK at.
# It also owns a scripted millisecond clock so a game iterates with NO QEMU —
# the hambrowse/hamUI/hamSDL dual-target seam. Input is scripted through the
# shared queue API (game_push_event / game_feed_* in lib/hamgame.ad).
#
# PUBLIC API (host half of the hamGame present seam):
#   game_host_present(surf) -> int32   register `surf` as the screen image +
#                                       rasterize the built frame; returns the
#                                       primitive count drawn
#   game_host_write_ppm(path) -> int32 write the framebuffer as a PPM
#   game_host_pixel(x, y) -> uint32    sampled 0x00RRGGBB pixel (gate asserts)
#   game_host_advance(ms)              advance the scripted clock
#   game_host_ticks() -> uint64        read the scripted millisecond clock

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel, hamui_host_register_image
from lib.hamgame import game_screen_name, game_surface_w, game_surface_h, \
    game_surface_ptr


_game_host_ticks: uint64 = 0
_game_ppm_hdr: Array[64, uint8]


# Register the display Surface under the fixed screen name, then rasterize the
# frame hamGame built (game_flip_scene emitted the image blit) into a fresh
# w*h framebuffer. Returns the number of primitives drawn.
def game_host_present(surf: int32) -> int32:
    w: int32 = game_surface_w(surf)
    h: int32 = game_surface_h(surf)
    hamui_host_register_image(game_screen_name(), w, h, game_surface_ptr(surf))
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


def game_host_write_ppm(path: Ptr[char]) -> int32:
    # O_WRONLY|O_CREAT|O_TRUNC = 577, mode 0644 = 420.
    fd: int32 = sys_open(path, 577, 420)
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&_game_ppm_hdr[0])
    sys_write(fd, &_game_ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def game_host_pixel(x: int32, y: int32) -> uint32:
    return hamui_host_pixel(x, y)


def game_host_advance(ms: uint64):
    _game_host_ticks = _game_host_ticks + ms


def game_host_ticks() -> uint64:
    return _game_host_ticks

# lib/sha2/sha2.ad
#
# Userland SHA-512 / SHA-384 (FIPS 180-4). A re-namespaced port of the
# kernel's SHA-512 engine (drivers/net/tls.ad's `_tls_sha512_*` /
# `_tls_sha384_*`): those symbols are module-private to the kernel TLS
# driver, the driver cannot link into a CPL-3 user binary, and there is
# no exported userland SHA-512 anywhere else. This is the same pattern
# lib/ssh/sshcrypto.ad and lib/ecdsa/ecdsa.ad already used to carry a
# private copy of an algorithm into userland.
#
# The single consumer today is lib/rsa/rsa.ad's PKCS#1 v1.5 verifier
# (the SHA-512 / SHA-384 DigestInfo variants), reached from apt's
# OpenPGP InRelease verification: the real `deb.debian.org` archive
# signs `InRelease` with a SHA-512 digest.
#
# SHA-384 is SHA-512 with different IVs and the output truncated to 48
# bytes. The compression function is implemented once; `sha384_oneshot`
# re-uses the SHA-512 update path with the SHA-384 IV and emits the
# first 48 state bytes.
#
# 1024-bit (128-byte) message blocks. 8 x uint64 state. 80 rounds with
# K[80] (first 64 bits of the fractional parts of the cube roots of the
# first 80 primes — FIPS 180-4 §4.2.3).
#
# CONST-TIME: not a goal. The only inputs hashed here are public
# signed-data byte strings; there are no secrets.


# -- round constants ---------------------------------------------------

_sha512_k: Array[80, uint64]
_sha512_w: Array[80, uint64]
_sha512_state_scratch: Array[8, uint64]
_sha512_k_inited: int32 = 0


def _sha512_init_k():
    if _sha512_k_inited != 0:
        return
    _sha512_k_inited = 1
    _sha512_k[0]  = 0x428A2F98D728AE22
    _sha512_k[1]  = 0x7137449123EF65CD
    _sha512_k[2]  = 0xB5C0FBCFEC4D3B2F
    _sha512_k[3]  = 0xE9B5DBA58189DBBC
    _sha512_k[4]  = 0x3956C25BF348B538
    _sha512_k[5]  = 0x59F111F1B605D019
    _sha512_k[6]  = 0x923F82A4AF194F9B
    _sha512_k[7]  = 0xAB1C5ED5DA6D8118
    _sha512_k[8]  = 0xD807AA98A3030242
    _sha512_k[9]  = 0x12835B0145706FBE
    _sha512_k[10] = 0x243185BE4EE4B28C
    _sha512_k[11] = 0x550C7DC3D5FFB4E2
    _sha512_k[12] = 0x72BE5D74F27B896F
    _sha512_k[13] = 0x80DEB1FE3B1696B1
    _sha512_k[14] = 0x9BDC06A725C71235
    _sha512_k[15] = 0xC19BF174CF692694
    _sha512_k[16] = 0xE49B69C19EF14AD2
    _sha512_k[17] = 0xEFBE4786384F25E3
    _sha512_k[18] = 0x0FC19DC68B8CD5B5
    _sha512_k[19] = 0x240CA1CC77AC9C65
    _sha512_k[20] = 0x2DE92C6F592B0275
    _sha512_k[21] = 0x4A7484AA6EA6E483
    _sha512_k[22] = 0x5CB0A9DCBD41FBD4
    _sha512_k[23] = 0x76F988DA831153B5
    _sha512_k[24] = 0x983E5152EE66DFAB
    _sha512_k[25] = 0xA831C66D2DB43210
    _sha512_k[26] = 0xB00327C898FB213F
    _sha512_k[27] = 0xBF597FC7BEEF0EE4
    _sha512_k[28] = 0xC6E00BF33DA88FC2
    _sha512_k[29] = 0xD5A79147930AA725
    _sha512_k[30] = 0x06CA6351E003826F
    _sha512_k[31] = 0x142929670A0E6E70
    _sha512_k[32] = 0x27B70A8546D22FFC
    _sha512_k[33] = 0x2E1B21385C26C926
    _sha512_k[34] = 0x4D2C6DFC5AC42AED
    _sha512_k[35] = 0x53380D139D95B3DF
    _sha512_k[36] = 0x650A73548BAF63DE
    _sha512_k[37] = 0x766A0ABB3C77B2A8
    _sha512_k[38] = 0x81C2C92E47EDAEE6
    _sha512_k[39] = 0x92722C851482353B
    _sha512_k[40] = 0xA2BFE8A14CF10364
    _sha512_k[41] = 0xA81A664BBC423001
    _sha512_k[42] = 0xC24B8B70D0F89791
    _sha512_k[43] = 0xC76C51A30654BE30
    _sha512_k[44] = 0xD192E819D6EF5218
    _sha512_k[45] = 0xD69906245565A910
    _sha512_k[46] = 0xF40E35855771202A
    _sha512_k[47] = 0x106AA07032BBD1B8
    _sha512_k[48] = 0x19A4C116B8D2D0C8
    _sha512_k[49] = 0x1E376C085141AB53
    _sha512_k[50] = 0x2748774CDF8EEB99
    _sha512_k[51] = 0x34B0BCB5E19B48A8
    _sha512_k[52] = 0x391C0CB3C5C95A63
    _sha512_k[53] = 0x4ED8AA4AE3418ACB
    _sha512_k[54] = 0x5B9CCA4F7763E373
    _sha512_k[55] = 0x682E6FF3D6B2B8A3
    _sha512_k[56] = 0x748F82EE5DEFB2FC
    _sha512_k[57] = 0x78A5636F43172F60
    _sha512_k[58] = 0x84C87814A1F0AB72
    _sha512_k[59] = 0x8CC702081A6439EC
    _sha512_k[60] = 0x90BEFFFA23631E28

    _sha512_k[71] = 0x1B710B35131C471B
    _sha512_k[72] = 0x28DB77F523047D84
    _sha512_k[73] = 0x32CAAB7B40C72493
    _sha512_k[74] = 0x3C9EBE0A15C9BEBC
    _sha512_k[75] = 0x431D67C49C100D4C
    _sha512_k[76] = 0x4CC5D4BECB3E42B6
    _sha512_k[77] = 0x597F299CFC657E2A
    _sha512_k[78] = 0x5FCB6FAB3AD6FAEC
    _sha512_k[79] = 0x6C44198C4A475817


# -- running state -----------------------------------------------------
#
# Single-threaded, one hash at a time (the caller is a one-shot
# verifier). Module-scope per the small-stack discipline.

_sha512_state:      Array[8, uint64]
_sha512_buf:        Array[128, uint8]
_sha512_buflen:     uint64 = 0
_sha512_total_bits: uint64 = 0


def _sha512_rotr64(v: uint64, n: uint64) -> uint64:
    return (v >> n) | (v << (64 - n))


def _sha512_compress(block_ptr: Ptr[uint8]):
    # Expand 16 BE qwords -> 80 qwords, run 80 rounds, fold into state.
    i: uint64 = 0
    while i < 16:
        b0: uint64 = cast[uint64](block_ptr[i * 8 + 0])
        b1: uint64 = cast[uint64](block_ptr[i * 8 + 1])
        b2: uint64 = cast[uint64](block_ptr[i * 8 + 2])
        b3: uint64 = cast[uint64](block_ptr[i * 8 + 3])
        b4: uint64 = cast[uint64](block_ptr[i * 8 + 4])
        b5: uint64 = cast[uint64](block_ptr[i * 8 + 5])
        b6: uint64 = cast[uint64](block_ptr[i * 8 + 6])
        b7: uint64 = cast[uint64](block_ptr[i * 8 + 7])
        _sha512_w[i] = (b0 << 56) | (b1 << 48) | (b2 << 40) | (b3 << 32) \
            | (b4 << 24) | (b5 << 16) | (b6 << 8) | b7
        i = i + 1
    while i < 80:
        s0: uint64 = _sha512_rotr64(_sha512_w[i - 15], 1) \
            ^ _sha512_rotr64(_sha512_w[i - 15], 8) \
            ^ (_sha512_w[i - 15] >> 7)
        s1: uint64 = _sha512_rotr64(_sha512_w[i - 2], 19) \
            ^ _sha512_rotr64(_sha512_w[i - 2], 61) \
            ^ (_sha512_w[i - 2] >> 6)
        _sha512_w[i] = _sha512_w[i - 16] + s0 + _sha512_w[i - 7] + s1
        i = i + 1
    i = 0
    while i < 8:
        _sha512_state_scratch[i] = _sha512_state[i]
        i = i + 1
    a: uint64 = _sha512_state_scratch[0]
    b: uint64 = _sha512_state_scratch[1]
    c: uint64 = _sha512_state_scratch[2]
    d: uint64 = _sha512_state_scratch[3]
    e: uint64 = _sha512_state_scratch[4]
    f: uint64 = _sha512_state_scratch[5]
    g: uint64 = _sha512_state_scratch[6]
    h: uint64 = _sha512_state_scratch[7]
    i = 0
    while i < 80:
        S1: uint64 = _sha512_rotr64(e, 14) ^ _sha512_rotr64(e, 18) \
            ^ _sha512_rotr64(e, 41)
        ch: uint64 = (e & f) ^ ((~e) & g)
        t1: uint64 = h + S1 + ch + _sha512_k[i] + _sha512_w[i]
        S0: uint64 = _sha512_rotr64(a, 28) ^ _sha512_rotr64(a, 34) \
            ^ _sha512_rotr64(a, 39)
        maj: uint64 = (a & b) ^ (a & c) ^ (b & c)
        t2: uint64 = S0 + maj
        h = g
        g = f
        f = e
        e = d + t1
        d = c
        c = b
        b = a
        a = t1 + t2
        i = i + 1
    _sha512_state[0] = _sha512_state[0] + a
    _sha512_state[1] = _sha512_state[1] + b
    _sha512_state[2] = _sha512_state[2] + c
    _sha512_state[3] = _sha512_state[3] + d
    _sha512_state[4] = _sha512_state[4] + e
    _sha512_state[5] = _sha512_state[5] + f
    _sha512_state[6] = _sha512_state[6] + g
    _sha512_state[7] = _sha512_state[7] + h


def _sha512_reset():
    # SHA-512 IVs (FIPS 180-4 §5.3.5).
    _sha512_init_k()
    _sha512_state[0] = 0x6A09E667F3BCC908
    _sha512_state[1] = 0xBB67AE8584CAA73B
    _sha512_state[2] = 0x3C6EF372FE94F82B
    _sha512_state[3] = 0xA54FF53A5F1D36F1
    _sha512_state[4] = 0x510E527FADE682D1
    _sha512_state[5] = 0x9B05688C2B3E6C1F
    _sha512_state[6] = 0x1F83D9ABFB41BD6B
    _sha512_state[7] = 0x5BE0CD19137E2179
    _sha512_buflen = 0
    _sha512_total_bits = 0


def _sha384_reset():
    # SHA-384 IVs (FIPS 180-4 §5.3.4).
    _sha512_init_k()
    _sha512_state[0] = 0xCBBB9D5DC1059ED8
    _sha512_state[1] = 0x629A292A367CD507
    _sha512_state[2] = 0x9159015A3070DD17
    _sha512_state[3] = 0x152FECD8F70E5939
    _sha512_state[4] = 0x67332667FFC00B31
    _sha512_state[5] = 0x8EB44A8768581511
    _sha512_state[6] = 0xDB0C2E0D64F98FA7
    _sha512_state[7] = 0x47B5481DBEFA4FA4
    _sha512_buflen = 0
    _sha512_total_bits = 0


def _sha512_update(data: Ptr[uint8], n: uint64):
    # Stream n bytes into the SHA-512-engine state. 128-byte block.
    block_ptr: Ptr[uint8] = cast[Ptr[uint8]](&_sha512_buf[0])
    pos: uint64 = 0
    while pos < n:
        room: uint64 = 128 - _sha512_buflen
        take: uint64 = n - pos
        if take > room:
            take = room
        i: uint64 = 0
        while i < take:
            _sha512_buf[_sha512_buflen + i] = data[pos + i]
            i = i + 1
        _sha512_buflen = _sha512_buflen + take
        pos = pos + take
        if _sha512_buflen == 128:
            _sha512_compress(block_ptr)
            _sha512_buflen = 0
    _sha512_total_bits = _sha512_total_bits + n * 8


# Finish into `nwords` output state words emitted big-endian: 8 words
# (64 bytes) for SHA-512, 6 words (48 bytes) for SHA-384.

def _sha512_finish_words(out_hash: Ptr[uint8], nwords: uint64):
    # SHA-512/384 padding: 0x80 byte, zero pad, 128-bit big-endian
    # length. Our messages never exceed 2^64 bits so the high 64 bits
    # of the length field stay zero.
    block_ptr: Ptr[uint8] = cast[Ptr[uint8]](&_sha512_buf[0])
    saved_bits: uint64 = _sha512_total_bits
    _sha512_buf[_sha512_buflen] = 0x80
    _sha512_buflen = _sha512_buflen + 1
    if _sha512_buflen > 112:
        while _sha512_buflen < 128:
            _sha512_buf[_sha512_buflen] = 0
            _sha512_buflen = _sha512_buflen + 1
        _sha512_compress(block_ptr)
        _sha512_buflen = 0
    while _sha512_buflen < 112:
        _sha512_buf[_sha512_buflen] = 0
        _sha512_buflen = _sha512_buflen + 1
    # high 64 bits of the 128-bit length (zero for our inputs)
    i: uint64 = 0
    while i < 8:
        _sha512_buf[112 + i] = 0
        i = i + 1
    # low 64 bits, big-endian
    i = 0
    while i < 8:
        shift: uint64 = (7 - i) * 8
        _sha512_buf[120 + i] = cast[uint8]((saved_bits >> shift) & 0xFF)
        i = i + 1
    _sha512_compress(block_ptr)
    i = 0
    while i < nwords:
        w: uint64 = _sha512_state[i]
        out_hash[i * 8 + 0] = cast[uint8]((w >> 56) & 0xFF)
        out_hash[i * 8 + 1] = cast[uint8]((w >> 48) & 0xFF)
        out_hash[i * 8 + 2] = cast[uint8]((w >> 40) & 0xFF)
        out_hash[i * 8 + 3] = cast[uint8]((w >> 32) & 0xFF)
        out_hash[i * 8 + 4] = cast[uint8]((w >> 24) & 0xFF)
        out_hash[i * 8 + 5] = cast[uint8]((w >> 16) & 0xFF)
        out_hash[i * 8 + 6] = cast[uint8]((w >> 8) & 0xFF)
        out_hash[i * 8 + 7] = cast[uint8](w & 0xFF)
        i = i + 1


# -- public one-shot API -----------------------------------------------
#
# sha512_oneshot writes a 64-byte digest; sha384_oneshot writes 48.
# Both are self-contained: they reset, stream, and finish. The K-table
# is lazily initialised on first use (`_sha512_init_k` is idempotent),
# so no explicit init call is required by the caller.

def sha512_oneshot(data: Ptr[uint8], n: uint64, out_hash: Ptr[uint8]):
    _sha512_reset()
    _sha512_update(data, n)
    _sha512_finish_words(out_hash, 8)


def sha384_oneshot(data: Ptr[uint8], n: uint64, out_hash: Ptr[uint8]):
    _sha384_reset()
    _sha512_update(data, n)
    _sha512_finish_words(out_hash, 6)

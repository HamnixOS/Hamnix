# lib/hamsdl_audio_host.ad — hamSDL AUDIO host backend (x86_64-linux only).
#
# The developer-host mirror of lib/hamsdl_audio_dev.ad. It provides the SAME
# SDL_mixer/pygame-style verbs (sdl_audio_init / sdl_load_sound / sdl_play_sound
# / sdl_play_music / sdl_stop_music / sdl_audio_pump) so a hamSDL game's HOST
# harness compiles and runs with NO QEMU — exactly like lib/hamsdl_host.ad is the
# no-QEMU mirror of lib/hamsdl_dev.ad. The DAC is a no-op on the host (there is
# no /dev/audio), but the DECODE + REGISTRY path is REAL: sdl_load_sound reads
# the file (host sys_open) and decodes it through lib/hamsdl_audio's wav/mp3
# bridge, so a host gate structurally verifies that the audio API wires to the
# verified decoders and that "play" targets a genuinely-loaded sound.
#
# sdl_play_* record intent into the shared lib/hamsdl_audio state (last-played
# slot, music slot + loop) — the same truth the device backend drains — so the
# gate can assert what would have sounded. Real DAC output is proven separately
# by the on-device capture gate (scripts/test_hamaudio_playback.sh style).

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamsdl_audio import sdl_audio_register_wav, sdl_audio_register_mp3, \
    sdl_audio_find, sdl_audio_note_play, sdl_audio_set_music


FILE_CAP: uint64 = 262144
_sah_filebuf: Array[262144, uint8]
_sah_music_stopped: int32 = 0


# No audio device on the host — succeed structurally so the game loop runs.
def sdl_audio_init() -> int32:
    _sah_music_stopped = 0
    return 0


def _sah_read_file(path: Ptr[char]) -> int64:
    fd: int32 = sys_open(path, 0, 0)                    # O_RDONLY
    if fd < 0:
        return -1
    n: uint64 = 0
    while n < FILE_CAP:
        r: int64 = sys_read(fd, &_sah_filebuf[n], FILE_CAP - n)
        if r <= 0:
            break
        n = n + cast[uint64](r)
    sys_close(fd)
    return cast[int64](n)


def _sah_is_mp3(path: Ptr[char]) -> int32:
    p: Ptr[uint8] = cast[Ptr[uint8]](path)
    n: uint64 = 0
    while p[n] != 0:
        n = n + 1
    if n < 4:
        return 0
    e0: uint8 = p[n - 3]
    e1: uint8 = p[n - 2]
    e2: uint8 = p[n - 1]
    if (e0 == 109 or e0 == 77) and (e1 == 112 or e1 == 80) and e2 == 51:
        return 1
    return 0


# REAL decode + registry (structural verification of the audio API on the host).
def sdl_load_sound(name: Ptr[uint8], path: Ptr[char]) -> int32:
    got: int64 = _sah_read_file(path)
    if got <= 0:
        return -1
    if _sah_is_mp3(path) != 0:
        return sdl_audio_register_mp3(name, &_sah_filebuf[0], cast[uint64](got))
    return sdl_audio_register_wav(name, &_sah_filebuf[0], cast[uint64](got))


# Record the play intent; the host has no DAC so nothing sounds. Returns 0 if the
# sound exists (would have played), -1 if the name is unknown.
def sdl_play_sound(name: Ptr[uint8]) -> int32:
    slot: int32 = sdl_audio_find(name)
    if slot < 0:
        return -1
    sdl_audio_note_play(slot)
    return 0


def sdl_play_music(path: Ptr[char], loop: int32) -> int32:
    slot: int32 = sdl_load_sound(cast[Ptr[uint8]]("__music__"), path)
    if slot < 0:
        return -1
    sdl_audio_set_music(slot, loop)
    sdl_audio_note_play(slot)
    _sah_music_stopped = 0
    return 0


def sdl_stop_music():
    _sah_music_stopped = 1


def sdl_music_stopped() -> int32:                       # host-gate accessor
    return _sah_music_stopped


def sdl_audio_pump():
    return

# lib/hamaudiocore.ad — the PURE, target-agnostic core of the hamaudio player.
#
# WHY (dual-target seam, see docs/hamui_dual_target.md)
# =====================================================
# The player's UI STATE (loaded file name, duration, play position, play/pause
# flag, live level-meter reading), the resize-aware LAYOUT (transport buttons,
# progress bar, level meter), the scene DISPLAY-LIST builder, and the pure
# keyboard+pointer INPUT handlers — everything EXCEPT the Hamnix-only wsys
# window transport AND the actual PCM streaming to /dev/audio. Factored out of
# user/hamaudioscene.ad exactly like lib/hamcalccore.ad / lib/ham2048core.ad,
# so the SAME code drives both the native sink (hamscene_commit -> /dev/wsys)
# and the host sink (lib/hamui_host rasterizer -> PNG). Imports ONLY
# lib/hamscene.ad (the pure builder), has NO `extern`, and links into both the
# native x86_64-adder-user target and the x86_64-linux host target.
#
# COMMAND QUEUE
# =============
# Input handlers do not touch audio — they enqueue a single pending command
# (PLAYPAUSE / STOP / SEEK) that the native driver drains each event-loop tick
# and turns into ctl-file writes + stream-cursor moves. The driver is the sole
# source of truth for "is a stream actually running"; the core just reflects
# what the driver tells it via hamaudio_set_playing()/set_position_ms()/
# set_level(). This keeps ALL I/O on the native side of the seam.

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_stroke, hamscene_glyphs, hamscene_glyphs_bold, \
    hamscene_roundrect, hamscene_text

# ---- command codes (hamaudio_take_command) ------------------------------
HAMAUDIO_CMD_NONE:      int32 = 0
HAMAUDIO_CMD_PLAYPAUSE: int32 = 1
HAMAUDIO_CMD_STOP:      int32 = 2
HAMAUDIO_CMD_SEEK:      int32 = 3
HAMAUDIO_CMD_SELECT:    int32 = 4     # a playlist-row click; target in au_sel_index
HAMAUDIO_CMD_PREV:      int32 = 5     # previous track in the playlist
HAMAUDIO_CMD_NEXT:      int32 = 6     # next track in the playlist
HAMAUDIO_CMD_VOLUME:    int32 = 7     # volume slider moved; new % in au_volume
# Repeat/Shuffle are pure UI toggles (no driver I/O), so they are applied to
# the core state directly in the pointer handler and NEVER enqueued — the driver
# only reads hamaudio_repeat()/hamaudio_shuffle() when it reaches end-of-track.

# ---- module state --------------------------------------------------------
au_w:        int32  = 360
au_h:        int32  = 200
au_playing:  int32  = 0
au_pos_ms:   uint64 = 0
au_dur_ms:   uint64 = 0
au_level:    uint32 = 0            # peak |sample| of the last streamed chunk (0..32767)
au_rate:     uint32 = 0
au_channels: uint32 = 0

au_pending:  int32  = 0           # a HAMAUDIO_CMD_* awaiting the driver
au_seek_ms:  uint64 = 0

au_name:     Array[64, uint8]
au_press:    int32  = -1          # transport button currently sunk (-1 none)

# ---- VLC-style transport state (drawn only in the "extended" tall window) --
au_volume:   int32  = 80          # master volume 0..100 (%)
au_repeat:   int32  = 0           # 0=off, 1=repeat-all, 2=repeat-one
au_shuffle:  int32  = 0           # 0=off, 1=shuffle
au_extended: int32  = 0           # 1 when the window is tall enough for the
                                  # full transport (prev/next + vol + rpt/shuf)

# ---- playlist (optional; drawn only when tracks are added AND the window is
# tall enough to leave room below the meter) -------------------------------
# Up to 8 tracks, each a NUL-terminated name of <=63 bytes, packed 64 bytes
# apart in a flat buffer (Adder has no jagged 2-D arrays). The core holds the
# DISPLAY names + which row is the active/selected track; the native driver owns
# the real file paths and does the actual load on a SELECT command.
au_ntracks:   int32 = 0
au_seltrack:  int32 = 0           # active/highlighted row (driver-confirmed)
au_sel_index: int32 = 0           # SELECT command payload (the clicked row)
au_track_press: int32 = -1        # playlist row currently sunk (-1 none)
au_tracknames: Array[512, uint8]  # 8 slots * 64 bytes

# ---- layout (recomputed by hamaudio_layout) ------------------------------
BTN_W:  int32 = 84
BTN_H:  int32 = 40
btn_play_x: int32 = 0
btn_play_y: int32 = 0
btn_stop_x: int32 = 0
btn_stop_y: int32 = 0
# Extended transport: Prev / Play-Pause / Stop / Next as a 4-button row, plus a
# volume slider and Repeat/Shuffle toggle buttons on a control row above it.
# These are laid out (and drawn/hit-tested) ONLY when au_extended == 1.
TBTN_W: int32 = 64                 # narrower buttons for the 4-up transport row
btn_prev_x: int32 = 0
btn_prev_y: int32 = 0
btn_next_x: int32 = 0
btn_next_y: int32 = 0
vol_x:  int32 = 0
vol_y:  int32 = 0
vol_w:  int32 = 0
vol_h:  int32 = 10
rpt_x:  int32 = 0
rpt_y:  int32 = 0
shf_x:  int32 = 0
shf_y:  int32 = 0
tgl_w:  int32 = 56                 # repeat/shuffle toggle button width
tgl_h:  int32 = 26
bar_x:  int32 = 0
bar_y:  int32 = 0
bar_w:  int32 = 0
bar_h:  int32 = 14
mtr_x:  int32 = 0
mtr_y:  int32 = 0
mtr_w:  int32 = 0
mtr_h:  int32 = 12
# Playlist panel (0 visible rows in the compact 200 px window; grows when the
# host/native window is made taller).
pl_x:     int32 = 0
pl_y:     int32 = 0
pl_w:     int32 = 0
pl_row_h: int32 = 24
pl_rows:  int32 = 0               # rows that FIT between the meter and buttons


# ---- tiny pure string helpers (unique _au_ prefix, no link collisions) ---
def _au_strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _au_u64_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    written: uint64 = n
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return written


# Format a millisecond count as "M:SS" into `out` (NUL-terminated).
def _au_fmt_mmss(ms: uint64, out: Ptr[uint8]) -> uint64:
    secs: uint64 = ms / 1000
    mins: uint64 = secs / 60
    rem: uint64 = secs % 60
    p: uint64 = _au_u64_dec(mins, out)
    out[p] = 58                                     # ':'
    p = p + 1
    out[p] = cast[uint8](rem / 10) + 48
    p = p + 1
    out[p] = cast[uint8](rem % 10) + 48
    p = p + 1
    out[p] = 0
    return p


# ---- lifecycle -----------------------------------------------------------
def hamaudio_init():
    au_playing = 0
    au_pos_ms = 0
    au_dur_ms = 0
    au_level = 0
    au_rate = 0
    au_channels = 0
    au_pending = 0
    au_seek_ms = 0
    au_press = -1
    au_name[0] = 0
    au_ntracks = 0
    au_seltrack = 0
    au_sel_index = 0
    au_track_press = -1
    au_volume = 80
    au_repeat = 0
    au_shuffle = 0
    hamaudio_layout(au_w, au_h)


# ---- playlist API --------------------------------------------------------
# Reset the track list. The driver rebuilds it whenever the media set changes.
def hamaudio_playlist_clear():
    au_ntracks = 0
    au_seltrack = 0
    au_track_press = -1


# Append a display name; returns the new track's row index, or -1 if full.
def hamaudio_playlist_add(s: Ptr[uint8]) -> int32:
    if au_ntracks >= 8:
        return -1
    base: uint64 = cast[uint64](au_ntracks) * 64
    i: uint64 = 0
    while s[i] != 0 and i < 63:
        au_tracknames[base + i] = s[i]
        i = i + 1
    au_tracknames[base + i] = 0
    idx: int32 = au_ntracks
    au_ntracks = au_ntracks + 1
    return idx


def hamaudio_track_count() -> int32:
    return au_ntracks


# The active/highlighted row (the track the driver is actually playing).
def hamaudio_selected_track() -> int32:
    return au_seltrack


# Driver confirms which row is now active (after it loads the file).
def hamaudio_set_selected_track(i: int32):
    au_seltrack = i


# Payload of the last SELECT command: the row the user clicked.
def hamaudio_select_index() -> int32:
    return au_sel_index


# Pointer to track `i`'s display name (valid while the list is unchanged).
def hamaudio_track_name(i: int32) -> Ptr[uint8]:
    return &au_tracknames[cast[uint64](i) * 64]


# Playlist geometry accessors (valid after hamaudio_layout) — let a host gate
# aim clicks + pixel samples at exact rows without hard-coding the layout.
def hamaudio_pl_y() -> int32:
    return pl_y


def hamaudio_pl_row_h() -> int32:
    return pl_row_h


def hamaudio_pl_rows() -> int32:
    return pl_rows


def hamaudio_pl_x() -> int32:
    return pl_x


def hamaudio_pl_w() -> int32:
    return pl_w


# ---- VLC transport accessors (volume / repeat / shuffle / extended) ------
def hamaudio_volume() -> int32:
    return au_volume


def hamaudio_set_volume(pct: int32):
    if pct < 0:
        pct = 0
    if pct > 100:
        pct = 100
    au_volume = pct


def hamaudio_repeat() -> int32:
    return au_repeat


def hamaudio_shuffle() -> int32:
    return au_shuffle


def hamaudio_is_extended() -> int32:
    return au_extended


# Button-centre accessors so a host gate can synthesize exact clicks without
# hard-coding the layout (valid after hamaudio_layout).
def hamaudio_btn_prev_cx() -> int64:
    return cast[int64](btn_prev_x + TBTN_W / 2)


def hamaudio_btn_prev_cy() -> int64:
    return cast[int64](btn_prev_y + BTN_H / 2)


def hamaudio_btn_next_cx() -> int64:
    return cast[int64](btn_next_x + TBTN_W / 2)


def hamaudio_btn_next_cy() -> int64:
    return cast[int64](btn_next_y + BTN_H / 2)


def hamaudio_rpt_cx() -> int64:
    return cast[int64](rpt_x + tgl_w / 2)


def hamaudio_rpt_cy() -> int64:
    return cast[int64](rpt_y + tgl_h / 2)


def hamaudio_shf_cx() -> int64:
    return cast[int64](shf_x + tgl_w / 2)


def hamaudio_shf_cy() -> int64:
    return cast[int64](shf_y + tgl_h / 2)


def hamaudio_vol_x() -> int32:
    return vol_x


def hamaudio_vol_y() -> int32:
    return vol_y


def hamaudio_vol_w() -> int32:
    return vol_w


def hamaudio_set_name(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 63:
        au_name[i] = s[i]
        i = i + 1
    au_name[i] = 0


def hamaudio_set_format(rate: uint32, channels: uint32):
    au_rate = rate
    au_channels = channels


def hamaudio_set_duration_ms(ms: uint64):
    au_dur_ms = ms


def hamaudio_set_position_ms(ms: uint64):
    au_pos_ms = ms


def hamaudio_set_level(peak: uint32):
    au_level = peak


def hamaudio_set_playing(p: int32):
    au_playing = p


def hamaudio_is_playing() -> int32:
    return au_playing


def hamaudio_position_ms() -> uint64:
    return au_pos_ms


def hamaudio_duration_ms() -> uint64:
    return au_dur_ms


# ---- command queue -------------------------------------------------------
# The driver drains ONE pending command per tick. Returns HAMAUDIO_CMD_NONE
# when nothing is queued; a SEEK's target is read via hamaudio_seek_ms().
def hamaudio_take_command() -> int32:
    c: int32 = au_pending
    au_pending = HAMAUDIO_CMD_NONE
    return c


def hamaudio_seek_ms() -> uint64:
    return au_seek_ms


# ---- layout --------------------------------------------------------------
def hamaudio_layout(w: int32, h: int32):
    au_w = w
    au_h = h
    # Progress bar spans most of the width, below the filename + time.
    bar_x = 20
    bar_w = w - 40
    bar_y = 96
    bar_h = 14
    # Level meter just below the progress bar.
    mtr_x = 20
    mtr_w = w - 40
    mtr_y = 124
    mtr_h = 12
    # The full VLC-style transport (Prev/Play/Stop/Next + volume + repeat/
    # shuffle) only fits — and only appears — in a tall window (>= 300 px). The
    # compact 200 px single-clip window keeps the classic Play/Stop pair, so the
    # existing compact host gates render EXACTLY as before.
    au_extended = 0
    if h >= 300:
        au_extended = 1

    # Bottom transport-button row.
    by: int32 = h - BTN_H - 16
    if au_extended != 0:
        # Four buttons: Prev | Play/Pause | Stop | Next, centred as a group.
        gap: int32 = 10
        total: int32 = TBTN_W * 4 + gap * 3
        bx: int32 = (w - total) / 2
        btn_prev_x = bx
        btn_prev_y = by
        btn_play_x = bx + (TBTN_W + gap)
        btn_play_y = by
        btn_stop_x = bx + (TBTN_W + gap) * 2
        btn_stop_y = by
        btn_next_x = bx + (TBTN_W + gap) * 3
        btn_next_y = by
        # Control row above the buttons: volume slider (left) + Repeat/Shuffle
        # toggles (right).
        cby: int32 = by - 38
        vol_x = 20
        # Leave 44 px to the right of the slider for the "NNN%" readout so it
        # never collides with the Repeat/Shuffle toggles.
        vol_w = w - 40 - (tgl_w * 2 + 12) - 44
        vol_y = cby + (tgl_h - vol_h) / 2
        vol_h = 10
        rpt_x = w - 20 - (tgl_w * 2 + 12)
        rpt_y = cby
        shf_x = w - 20 - tgl_w
        shf_y = cby
        # Playlist fills the gap between the meter and the control row.
        pl_x = 20
        pl_w = w - 40
        pl_y = mtr_y + mtr_h + 24
        pl_row_h = 24
        avail: int32 = cby - 12 - pl_y
        if avail < 0:
            avail = 0
        pl_rows = avail / pl_row_h
    else:
        # Classic compact pair (unchanged geometry: 20 px up from the bottom).
        cby0: int32 = h - BTN_H - 20
        gap2: int32 = 16
        total2: int32 = BTN_W * 2 + gap2
        bx2: int32 = (w - total2) / 2
        btn_play_x = bx2
        btn_play_y = cby0
        btn_stop_x = bx2 + BTN_W + gap2
        btn_stop_y = cby0
        # No prev/next/volume/toggles in the compact window.
        btn_prev_x = 0
        btn_prev_y = 0
        btn_next_x = 0
        btn_next_y = 0
        vol_w = 0
        pl_x = 20
        pl_w = w - 40
        pl_y = mtr_y + mtr_h + 24
        pl_row_h = 24
        avail2: int32 = btn_play_y - 12 - pl_y
        if avail2 < 0:
            avail2 = 0
        pl_rows = avail2 / pl_row_h


# ---- input: keyboard -----------------------------------------------------
# Parse a /keys "d <code>\n" line. SPACE toggles play/pause, 's'/'S' stops.
# Returns 1 if a command was enqueued (a redraw is warranted), else 0.
def hamaudio_key_line(line: Ptr[uint8], n: uint64) -> int32:
    # Expect "d <decimal>".
    if n < 3:
        return 0
    if line[0] != 100:                              # 'd'
        return 0
    code: int32 = 0
    i: uint64 = 2
    while i < n and line[i] >= 48 and line[i] <= 57:
        code = code * 10 + cast[int32](line[i] - 48)
        i = i + 1
    if code == 32:                                  # space
        au_pending = HAMAUDIO_CMD_PLAYPAUSE
        return 1
    if code == 115 or code == 83:                   # s / S -> stop
        au_pending = HAMAUDIO_CMD_STOP
        return 1
    if code == 110 or code == 78:                   # n / N -> next track
        au_pending = HAMAUDIO_CMD_NEXT
        return 1
    if code == 112 or code == 80:                   # p / P -> previous track
        au_pending = HAMAUDIO_CMD_PREV
        return 1
    if code == 114 or code == 82:                   # r / R -> cycle repeat mode
        au_repeat = (au_repeat + 1) % 3
        return 1
    if code == 104:                                 # h -> toggle shuffle
        au_shuffle = 1 - au_shuffle
        return 1
    return 0


# ---- input: pointer ------------------------------------------------------
# Hit-test a click at (lx,ly). Returns 0=play/pause, 1=stop, 2=progress bar
# (seek), 3=prev, 4=next, 5=volume slider, 6=repeat toggle, 7=shuffle toggle,
# -1=miss. Codes 3..7 are only reachable in the extended (tall) window.
def hamaudio_hit(lx: int64, ly: int64) -> int32:
    x: int32 = cast[int32](lx)
    y: int32 = cast[int32](ly)
    # Play/Pause + Stop use BTN_W in the compact layout and TBTN_W in the
    # extended layout; pick the right width so the hit box matches what's drawn.
    bw: int32 = BTN_W
    if au_extended != 0:
        bw = TBTN_W
    if x >= btn_play_x and x < btn_play_x + bw \
            and y >= btn_play_y and y < btn_play_y + BTN_H:
        return 0
    if x >= btn_stop_x and x < btn_stop_x + bw \
            and y >= btn_stop_y and y < btn_stop_y + BTN_H:
        return 1
    if au_extended != 0:
        if x >= btn_prev_x and x < btn_prev_x + TBTN_W \
                and y >= btn_prev_y and y < btn_prev_y + BTN_H:
            return 3
        if x >= btn_next_x and x < btn_next_x + TBTN_W \
                and y >= btn_next_y and y < btn_next_y + BTN_H:
            return 4
        # Generous band around the thin volume slider.
        if vol_w > 0 and x >= vol_x and x < vol_x + vol_w \
                and y >= vol_y - 8 and y < vol_y + vol_h + 8:
            return 5
        if x >= rpt_x and x < rpt_x + tgl_w \
                and y >= rpt_y and y < rpt_y + tgl_h:
            return 6
        if x >= shf_x and x < shf_x + tgl_w \
                and y >= shf_y and y < shf_y + tgl_h:
            return 7
    # A generous seek band around the progress bar.
    if x >= bar_x and x < bar_x + bar_w \
            and y >= bar_y - 6 and y < bar_y + bar_h + 6:
        return 2
    return -1


# Which playlist row (0..ntracks-1) is under (lx,ly), or -1 if none / no list.
# Only rows that both EXIST and FIT (row < pl_rows) are hittable.
def _au_playlist_row_at(lx: int64, ly: int64) -> int32:
    if au_ntracks <= 0 or pl_rows <= 0:
        return -1
    x: int32 = cast[int32](lx)
    y: int32 = cast[int32](ly)
    if x < pl_x or x >= pl_x + pl_w:
        return -1
    if y < pl_y:
        return -1
    row: int32 = (y - pl_y) / pl_row_h
    if row >= au_ntracks or row >= pl_rows:
        return -1
    # Reject the inter-row gutter (rows are pl_row_h-4 tall).
    if (y - pl_y) - row * pl_row_h >= pl_row_h - 4:
        return -1
    return row


# Apply a press at (lx,ly): enqueue the matching command. For a progress-bar
# click, compute the seek target from the x fraction. Returns 1 if a command
# was enqueued.
def hamaudio_press_at(lx: int64, ly: int64) -> int32:
    prow: int32 = _au_playlist_row_at(lx, ly)
    if prow >= 0:
        au_sel_index = prow
        au_track_press = prow
        au_pending = HAMAUDIO_CMD_SELECT
        return 1
    hit: int32 = hamaudio_hit(lx, ly)
    if hit == 0:
        au_pending = HAMAUDIO_CMD_PLAYPAUSE
        au_press = 0
        return 1
    if hit == 1:
        au_pending = HAMAUDIO_CMD_STOP
        au_press = 1
        return 1
    if hit == 3:
        au_pending = HAMAUDIO_CMD_PREV
        au_press = 3
        return 1
    if hit == 4:
        au_pending = HAMAUDIO_CMD_NEXT
        au_press = 4
        return 1
    if hit == 5:
        # Volume slider: map the x fraction to 0..100 and tell the driver.
        if vol_w > 0:
            dx: int32 = cast[int32](lx) - vol_x
            if dx < 0:
                dx = 0
            if dx > vol_w:
                dx = vol_w
            au_volume = dx * 100 / vol_w
            au_pending = HAMAUDIO_CMD_VOLUME
            return 1
    if hit == 6:
        # Repeat toggle: cycle off -> all -> one. Pure UI state, no driver I/O.
        au_repeat = (au_repeat + 1) % 3
        return 1
    if hit == 7:
        # Shuffle toggle. Pure UI state, no driver I/O.
        au_shuffle = 1 - au_shuffle
        return 1
    if hit == 2:
        if au_dur_ms > 0 and bar_w > 0:
            dx2: int32 = cast[int32](lx) - bar_x
            if dx2 < 0:
                dx2 = 0
            if dx2 > bar_w:
                dx2 = bar_w
            au_seek_ms = au_dur_ms * cast[uint64](dx2) / cast[uint64](bar_w)
            au_pending = HAMAUDIO_CMD_SEEK
            return 1
    return 0


# Release: clear the sunk-button / sunk-row highlight. Returns 1 if state changed.
def hamaudio_release() -> int32:
    changed: int32 = 0
    if au_press != -1:
        au_press = -1
        changed = 1
    if au_track_press != -1:
        au_track_press = -1
        changed = 1
    return changed


# Centre of the Play button in window-local coords (valid after
# hamaudio_layout). Exposed so a host gate can synthesize a real Play click.
def hamaudio_btn_play_cx() -> int64:
    return cast[int64](btn_play_x + BTN_W / 2)


def hamaudio_btn_play_cy() -> int64:
    return cast[int64](btn_play_y + BTN_H / 2)


# Held pointer-button state for the edge detector below.
au_btn_down: int32 = 0


# Parse one /event pointer line "m <x> <y> <buttons> <dz>" and drive
# press/release edges through hamaudio_press_at / hamaudio_release. The kernel
# pointer router (sys/src/9/port/devwsys.ad) emits a leading 'm' then FOUR ints
# (x, y, buttons, dz); the FIRST THREE after the 'm' are x, y, buttons and the
# trailing dz MUST be ignored. Returns 1 if player state changed. Single source
# of truth shared by the native app (user/hamaudioscene.ad) and the host gate.
def hamaudio_handle_pointer_line(line: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or line[0] != 109:                         # require leading 'm'
        return 0
    xs: Array[8, int64]
    nints: int32 = 0
    i: uint64 = 0
    while i < n and nints < 8:
        while i < n and (line[i] < 48 or line[i] > 57) and line[i] != 45:
            i = i + 1
        if i >= n:
            break
        neg: int32 = 0
        if line[i] == 45:
            neg = 1
            i = i + 1
        val: int64 = 0
        got: int32 = 0
        while i < n and line[i] >= 48 and line[i] <= 57:
            val = val * 10 + cast[int64](line[i] - 48)
            i = i + 1
            got = 1
        if got == 1:
            if neg == 1:
                val = 0 - val
            xs[nints] = val
            nints = nints + 1
    if nints < 3:
        return 0
    bx: int64 = xs[0]
    by: int64 = xs[1]
    bbtn: int64 = xs[2]
    now_down: int32 = 0
    if (bbtn & 1) != 0:
        now_down = 1
    changed: int32 = 0
    if now_down != 0 and au_btn_down == 0:
        if hamaudio_press_at(bx, by) == 1:
            changed = 1
    elif now_down == 0 and au_btn_down != 0:
        if hamaudio_release() == 1:
            changed = 1
    au_btn_down = now_down
    return changed


# ---- scene builder -------------------------------------------------------
def _au_progress_fill_w() -> int32:
    if au_dur_ms == 0:
        return 0
    p: uint64 = au_pos_ms
    if p > au_dur_ms:
        p = au_dur_ms
    return cast[int32](cast[uint64](bar_w) * p / au_dur_ms)


def _au_meter_fill_w() -> int32:
    # Level 0..32767 mapped across the meter width.
    lv: uint32 = au_level
    if lv > 32767:
        lv = 32767
    return cast[int32](cast[uint64](mtr_w) * cast[uint64](lv) / 32767)


def hamaudio_build_scene():
    hamscene_begin()
    # Card background.
    hamscene_fill(0, 0, au_w, au_h, cast[Ptr[uint8]]("#1d2027"))
    # Header strip.
    hamscene_fill(0, 0, au_w, 30, cast[Ptr[uint8]]("#2b303b"))
    hamscene_glyphs_bold(12, 8, cast[Ptr[uint8]]("Audio Player"),
                         cast[Ptr[uint8]]("#e6e8ec"))

    # Now-playing filename (or a placeholder).
    if au_name[0] != 0:
        hamscene_glyphs(20, 44, &au_name[0], cast[Ptr[uint8]]("#8fd0ff"))
    else:
        hamscene_glyphs(20, 44, cast[Ptr[uint8]]("(no file)"),
                        cast[Ptr[uint8]]("#6b7280"))

    # Time readout "M:SS / M:SS".
    tbuf: Array[48, uint8]
    p: uint64 = _au_fmt_mmss(au_pos_ms, &tbuf[0])
    tbuf[p] = 32
    p = p + 1
    tbuf[p] = 47                                     # '/'
    p = p + 1
    tbuf[p] = 32
    p = p + 1
    p = p + _au_fmt_mmss(au_dur_ms, &tbuf[p])
    hamscene_glyphs(20, 68, &tbuf[0], cast[Ptr[uint8]]("#c8ccd4"))

    # Progress bar: track + filled portion + hairline frame.
    hamscene_fill(bar_x, bar_y, bar_w, bar_h, cast[Ptr[uint8]]("#0e1014"))
    fw: int32 = _au_progress_fill_w()
    if fw > 0:
        hamscene_fill(bar_x, bar_y, fw, bar_h, cast[Ptr[uint8]]("#3d7dff"))
    hamscene_stroke(bar_x, bar_y, bar_w, bar_h, 1,
                    cast[Ptr[uint8]]("#3a4150"))
    # Draggable play-head thumb: a light knob centred on the fill edge so the
    # seek position reads at a glance (purely additive over the bar).
    if au_dur_ms > 0:
        knob_w: int32 = 8
        knob_x: int32 = bar_x + fw - knob_w / 2
        if knob_x < bar_x:
            knob_x = bar_x
        if knob_x > bar_x + bar_w - knob_w:
            knob_x = bar_x + bar_w - knob_w
        hamscene_roundrect(knob_x, bar_y - 3, knob_w, bar_h + 6, 3,
                           cast[Ptr[uint8]]("#dfe6f2"))

    # Level meter: track + green fill.
    hamscene_glyphs(20, mtr_y - 16, cast[Ptr[uint8]]("Level"),
                    cast[Ptr[uint8]]("#6b7280"))
    hamscene_fill(mtr_x, mtr_y, mtr_w, mtr_h, cast[Ptr[uint8]]("#0e1014"))
    mw: int32 = _au_meter_fill_w()
    if mw > 0:
        hamscene_fill(mtr_x, mtr_y, mw, mtr_h, cast[Ptr[uint8]]("#33d17a"))
    hamscene_stroke(mtr_x, mtr_y, mtr_w, mtr_h, 1,
                    cast[Ptr[uint8]]("#3a4150"))

    # Transport buttons. Width is TBTN_W in the extended layout, BTN_W compact.
    bw: int32 = BTN_W
    if au_extended != 0:
        bw = TBTN_W

    # ---- extended control row (volume slider + repeat/shuffle) drawn FIRST ----
    if au_extended != 0:
        hamscene_glyphs(vol_x, vol_y - 16, cast[Ptr[uint8]]("Volume"),
                        cast[Ptr[uint8]]("#6b7280"))
        hamscene_fill(vol_x, vol_y, vol_w, vol_h, cast[Ptr[uint8]]("#0e1014"))
        vfw: int32 = vol_w * au_volume / 100
        if vfw > 0:
            hamscene_fill(vol_x, vol_y, vfw, vol_h, cast[Ptr[uint8]]("#33d17a"))
        hamscene_stroke(vol_x, vol_y, vol_w, vol_h, 1,
                        cast[Ptr[uint8]]("#3a4150"))
        # Volume % readout at the slider's right end.
        vbuf: Array[8, uint8]
        vp: uint64 = _au_u64_dec(cast[uint64](au_volume), &vbuf[0])
        vbuf[vp] = 37                                # '%'
        vbuf[vp + 1] = 0
        hamscene_glyphs(vol_x + vol_w + 8, vol_y - 3, &vbuf[0],
                        cast[Ptr[uint8]]("#c8ccd4"))

        # Repeat toggle: "Rpt", "Rpt1" (repeat-one), lit when active.
        rpt_face: Ptr[uint8] = cast[Ptr[uint8]]("#3a4150")
        rpt_lbl: Ptr[uint8] = cast[Ptr[uint8]]("Rpt")
        if au_repeat == 1:
            rpt_face = cast[Ptr[uint8]]("#25406a")
        elif au_repeat == 2:
            rpt_face = cast[Ptr[uint8]]("#25406a")
            rpt_lbl = cast[Ptr[uint8]]("Rpt1")
        hamscene_roundrect(rpt_x, rpt_y, tgl_w, tgl_h, 5, rpt_face)
        rpl: int32 = cast[int32](_au_strlen(rpt_lbl))
        hamscene_glyphs(rpt_x + (tgl_w - rpl * 8) / 2, rpt_y + (tgl_h - 16) / 2,
                        rpt_lbl, cast[Ptr[uint8]]("#e6e8ec"))

        # Shuffle toggle: "Shuf", lit when active.
        shf_face: Ptr[uint8] = cast[Ptr[uint8]]("#3a4150")
        if au_shuffle != 0:
            shf_face = cast[Ptr[uint8]]("#25406a")
        hamscene_roundrect(shf_x, shf_y, tgl_w, tgl_h, 5, shf_face)
        hamscene_glyphs(shf_x + (tgl_w - 4 * 8) / 2, shf_y + (tgl_h - 16) / 2,
                        cast[Ptr[uint8]]("Shuf"), cast[Ptr[uint8]]("#e6e8ec"))

        # Prev / Next buttons flank the Play/Stop pair.
        pv_face: Ptr[uint8] = cast[Ptr[uint8]]("#3a4150")
        if au_press == 3:
            pv_face = cast[Ptr[uint8]]("#2b303b")
        hamscene_roundrect(btn_prev_x, btn_prev_y, TBTN_W, BTN_H, 6, pv_face)
        hamscene_glyphs(btn_prev_x + (TBTN_W - 4 * 8) / 2,
                        btn_prev_y + (BTN_H - 16) / 2,
                        cast[Ptr[uint8]]("Prev"), cast[Ptr[uint8]]("#e6e8ec"))
        nx_face: Ptr[uint8] = cast[Ptr[uint8]]("#3a4150")
        if au_press == 4:
            nx_face = cast[Ptr[uint8]]("#2b303b")
        hamscene_roundrect(btn_next_x, btn_next_y, TBTN_W, BTN_H, 6, nx_face)
        hamscene_glyphs(btn_next_x + (TBTN_W - 4 * 8) / 2,
                        btn_next_y + (BTN_H - 16) / 2,
                        cast[Ptr[uint8]]("Next"), cast[Ptr[uint8]]("#e6e8ec"))

    pp_face: Ptr[uint8] = cast[Ptr[uint8]]("#3a4150")
    if au_press == 0:
        pp_face = cast[Ptr[uint8]]("#2b303b")
    hamscene_roundrect(btn_play_x, btn_play_y, bw, BTN_H, 6, pp_face)
    pp_label: Ptr[uint8] = cast[Ptr[uint8]]("Play")
    if au_playing != 0:
        pp_label = cast[Ptr[uint8]]("Pause")
    pl: int32 = cast[int32](_au_strlen(pp_label))
    hamscene_glyphs(btn_play_x + (bw - pl * 8) / 2,
                    btn_play_y + (BTN_H - 16) / 2, pp_label,
                    cast[Ptr[uint8]]("#e6e8ec"))

    st_face: Ptr[uint8] = cast[Ptr[uint8]]("#3a4150")
    if au_press == 1:
        st_face = cast[Ptr[uint8]]("#2b303b")
    hamscene_roundrect(btn_stop_x, btn_stop_y, bw, BTN_H, 6, st_face)
    hamscene_glyphs(btn_stop_x + (bw - 4 * 8) / 2,
                    btn_stop_y + (BTN_H - 16) / 2,
                    cast[Ptr[uint8]]("Stop"), cast[Ptr[uint8]]("#e6e8ec"))

    # ---- playlist panel (only when tracks exist AND rows fit) ----
    if au_ntracks > 0 and pl_rows > 0:
        hamscene_glyphs(20, pl_y - 16, cast[Ptr[uint8]]("Playlist"),
                        cast[Ptr[uint8]]("#6b7280"))
        row: int32 = 0
        while row < au_ntracks and row < pl_rows:
            ry: int32 = pl_y + row * pl_row_h
            face: Ptr[uint8] = cast[Ptr[uint8]]("#0e1014")
            if row == au_seltrack:
                face = cast[Ptr[uint8]]("#25406a")      # active track (blue)
            elif row == au_track_press:
                face = cast[Ptr[uint8]]("#2b303b")      # pressed feedback
            hamscene_fill(pl_x, ry, pl_w, pl_row_h - 4, face)
            hamscene_stroke(pl_x, ry, pl_w, pl_row_h - 4, 1,
                            cast[Ptr[uint8]]("#3a4150"))
            tcol: Ptr[uint8] = cast[Ptr[uint8]]("#c8ccd4")
            if row == au_seltrack:
                tcol = cast[Ptr[uint8]]("#8fd0ff")
                # A small "now playing" marker before the active track.
                hamscene_glyphs(pl_x + 6, ry + 3,
                                cast[Ptr[uint8]](">"), tcol)
            hamscene_glyphs(pl_x + 20, ry + 3,
                            hamaudio_track_name(row), tcol)
            row = row + 1

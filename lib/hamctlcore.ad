# lib/hamctlcore.ad — PURE, extern-free core for the Control Center hub
# (/bin/hamctl). A MATE-style control-centre: a left category sidebar
# (Appearance / Date & Time / About) selects a page drawn in the right pane.
# Three capplets that DO something real:
#
#   APPEARANCE  — a row of wallpaper colour swatches. Clicking one selects it;
#                 the driver writes a solid-colour PPM and sets it as the
#                 desktop wallpaper via /dev/wsys/ctl.  (config the DE reads)
#   DATE & TIME — shows the current date/time (the driver formats it from the
#                 #137-correct clock) and a UTC-offset stepper. Changing the
#                 offset makes the driver persist /tmp/hamnix-tz.conf and
#                 re-shift the displayed time.  (config the DE reads)
#   ABOUT       — real system facts (hostname, Hamnix/kernel version, uptime,
#                 memory, CPU count, process count) the driver reads from
#                 /dev/* and /proc and pushes in as text lines.
#
# All layout + rendering + hit-testing is here (target-agnostic, imports only
# lib/hamscene) so the whole hub renders on the host to a PNG (see
# user/hamctl_host.ad) AND ships native (user/hamctl.ad).

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_stroke, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_panel_button


# ---- tiny pure helpers (module-scoped) -----------------------------------
def _ctl_slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _ctl_u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# ---- categories ----------------------------------------------------------
# About stays LAST so the driver's I/O ordering (and existing gate click
# coordinates) grow forward as capplets are inserted before it.
CAT_APPEARANCE: int32 = 0
CAT_DATETIME:   int32 = 1
CAT_DISPLAY:    int32 = 2
CAT_MOUSE:      int32 = 3
CAT_KEYBOARD:   int32 = 4
CAT_SOUND:      int32 = 5
CAT_POWER:      int32 = 6
CAT_NETWORK:    int32 = 7
CAT_ABOUT:      int32 = 8
N_CAT:          uint64 = 9
sel_cat: int32 = 0


def _cat_name(c: int32) -> Ptr[uint8]:
    if c == CAT_APPEARANCE:
        return cast[Ptr[uint8]]("Appearance")
    if c == CAT_DATETIME:
        return cast[Ptr[uint8]]("Date & Time")
    if c == CAT_DISPLAY:
        return cast[Ptr[uint8]]("Display")
    if c == CAT_MOUSE:
        return cast[Ptr[uint8]]("Mouse")
    if c == CAT_KEYBOARD:
        return cast[Ptr[uint8]]("Keyboard")
    if c == CAT_SOUND:
        return cast[Ptr[uint8]]("Sound")
    if c == CAT_POWER:
        return cast[Ptr[uint8]]("Power")
    if c == CAT_NETWORK:
        return cast[Ptr[uint8]]("Network")
    return cast[Ptr[uint8]]("About")


# ---- wallpaper swatches --------------------------------------------------
N_SWATCH: uint64 = 6
sw_r: Array[6, int32]
sw_g: Array[6, int32]
sw_b: Array[6, int32]
sw_hex: Array[60, uint8]
sel_swatch: int32 = 0


def _sw_hex_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&sw_hex[0]) + i * 10)


def _set_swatch(i: uint64, r: int32, g: int32, b: int32, hx: Ptr[uint8]):
    sw_r[i] = r
    sw_g[i] = g
    sw_b[i] = b
    dp: Ptr[uint8] = _sw_hex_ptr(i)
    k: uint64 = 0
    while hx[k] != 0:
        dp[k] = hx[k]
        k = k + 1
    dp[k] = 0


# Public getters so the native driver can write the chosen colour's PPM.
def hamctl_swatch() -> int32:
    return sel_swatch


def hamctl_sw_r(i: uint64) -> int32:
    return sw_r[i]


def hamctl_sw_g(i: uint64) -> int32:
    return sw_g[i]


def hamctl_sw_b(i: uint64) -> int32:
    return sw_b[i]


# ---- image wallpapers ----------------------------------------------------
# Procedurally-generated wallpaper IMAGES (integer-only pixel laws) offered
# alongside the solid-colour swatches. The native driver renders the chosen
# image to a P6 PPM in /tmp and applies it via the /dev/wsys/ctl `wallpaper
# <path>` verb; the DE backdrop (user/hamdesktop.ad) loads that PPM and paints
# it as a nearest-neighbour mosaic of `fill` rects behind the panel + icons.
# The SAME pure pixel law drives (a) the capplet thumbnail previews here,
# (b) the native PPM writer, and (c) the host gate — so what you pick is what
# the desktop paints. Kept pure/extern-free so it renders on the host to a PNG.
N_IMAGE:  uint64 = 4
sel_kind:  int32 = 0                     # 0 = solid-colour swatch, 1 = image
sel_image: int32 = 0                     # selected image index (when kind==1)
IMG_REF_W: int32 = 64                    # reference field the pixel law samples
IMG_REF_H: int32 = 48


def _img_name(i: uint64) -> Ptr[uint8]:
    if i == 0:
        return cast[Ptr[uint8]]("Default")
    if i == 1:
        return cast[Ptr[uint8]]("Sunset")
    if i == 2:
        return cast[Ptr[uint8]]("Ocean")
    return cast[Ptr[uint8]]("Tiles")


def _img_clamp255(v: int32) -> int32:
    if v < 0:
        return 0
    if v > 255:
        return 255
    return v


# Procedural RGB for image `img` at pixel (px,py) in a w x h field. Integer
# only; writes out[0..2]. Deterministic and pure — the one law shared by the
# driver's PPM writer, the thumbnail preview and the host gate. Every image is
# NON-UNIFORM (a real gradient/pattern, not a flat fill).
def hamctl_image_rgb(img: int32, px: int32, py: int32, w: int32, h: int32,
                     out: Ptr[uint8]):
    dw: int32 = w - 1
    if dw < 1:
        dw = 1
    dh: int32 = h - 1
    if dh < 1:
        dh = 1
    nx: int32 = px * 255 / dw            # 0..255 across
    ny: int32 = py * 255 / dh            # 0..255 down
    r: int32 = 0
    g: int32 = 0
    b: int32 = 0
    if img == 0:                          # Default: the DE's out-of-box indigo-
                                          # slate VERTICAL gradient (top #223a63 ->
                                          # bottom #4d7ab0). Reproduces the exact
                                          # per-row law of hamdesktop.emit_gradient_bg
                                          # so picking it restores the default
                                          # backdrop via the same wallpaper sink.
        r = 34 + 43 * ny / 255
        g = 58 + 64 * ny / 255
        b = 99 + 77 * ny / 255
    elif img == 1:                        # Sunset: warm top -> violet bottom
        r = 250 - ny * 130 / 255
        g = 60 + ny * 60 / 255 + nx * 40 / 255
        b = 50 + ny * 160 / 255
    elif img == 2:                        # Ocean: teal, diagonal + ripple band
        d: int32 = (nx + ny) / 2
        rp: int32 = ((px + py) % 32) * 30 / 32 - 15
        r = 20 + d * 40 / 255
        g = 100 + d * 80 / 255 + rp
        b = 170 - d * 50 / 255 + rp
    else:                                 # Tiles: checker over a soft gradient
        tx: int32 = px * 8 / w
        ty: int32 = py * 8 / h
        chk: int32 = (tx + ty) % 2
        r = 40 + nx * 60 / 255
        g = 60 + ny * 80 / 255
        b = 120 + (255 - nx) * 60 / 255
        if chk == 1:
            r = r + 45
            g = g + 45
            b = b + 45
    out[0] = cast[uint8](_img_clamp255(r))
    out[1] = cast[uint8](_img_clamp255(g))
    out[2] = cast[uint8](_img_clamp255(b))


# "#RRGGBB" C-string for one RGB triple (>=8-byte out).
_img_hexd: Array[16, uint8]
_img_hexd_init: int32 = 0


def _img_hexd_setup():
    if _img_hexd_init != 0:
        return
    _img_hexd_init = 1
    j: uint64 = 0
    while j < 10:
        _img_hexd[j] = cast[uint8](48 + j)               # '0'..'9'
        j = j + 1
    while j < 16:
        _img_hexd[j] = cast[uint8](97 + (j - 10))        # 'a'..'f'
        j = j + 1


def _img_hexstr(r: uint8, g: uint8, b: uint8, out: Ptr[uint8]):
    _img_hexd_setup()
    out[0] = 35                                          # '#'
    out[1] = _img_hexd[(r >> 4) & 15]
    out[2] = _img_hexd[r & 15]
    out[3] = _img_hexd[(g >> 4) & 15]
    out[4] = _img_hexd[g & 15]
    out[5] = _img_hexd[(b >> 4) & 15]
    out[6] = _img_hexd[b & 15]
    out[7] = 0


# Emit image `img` as a gw x gh mosaic of `fill` rects covering the rect
# (ox,oy,w,h); each cell samples one pixel (nearest-neighbour). This is the
# SAME shape the DE backdrop (hamdesktop.emit_wallpaper) paints on-device, so
# the capplet thumbnail and the host-gate full-screen preview render the exact
# picture the desktop shows.
_img_cellhex: Array[8, uint8]
_img_rgb3: Array[3, uint8]


def hamctl_image_mosaic(img: int32, ox: int32, oy: int32, w: int32, h: int32,
                        gw: int32, gh: int32):
    gx: int32 = 0
    while gx < gw:
        x0: int32 = ox + gx * w / gw
        x1: int32 = ox + (gx + 1) * w / gw
        if gx == gw - 1:
            x1 = ox + w
        sx: int32 = gx * IMG_REF_W / gw
        gy: int32 = 0
        while gy < gh:
            y0: int32 = oy + gy * h / gh
            y1: int32 = oy + (gy + 1) * h / gh
            if gy == gh - 1:
                y1 = oy + h
            sy: int32 = gy * IMG_REF_H / gh
            hamctl_image_rgb(img, sx, sy, IMG_REF_W, IMG_REF_H, &_img_rgb3[0])
            _img_hexstr(_img_rgb3[0], _img_rgb3[1], _img_rgb3[2],
                        &_img_cellhex[0])
            hamscene_fill(x0, y0, x1 - x0, y1 - y0, &_img_cellhex[0])
            gy = gy + 1
        gx = gx + 1


# Public getters so the native driver knows what was picked.
def hamctl_wall_is_image() -> int32:
    return sel_kind


def hamctl_image_sel() -> int32:
    return sel_image


def hamctl_image_count() -> uint64:
    return N_IMAGE


# ---- date & time ---------------------------------------------------------
dt_buf: Array[64, uint8]                # "Fri Jul 12  14:30" (driver-supplied)
tz_off: int32 = 0                       # UTC offset in hours, -12..14


def hamctl_set_datetime(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 63:
        dt_buf[i] = s[i]
        i = i + 1
    dt_buf[i] = 0


def hamctl_tz() -> int32:
    return tz_off


def hamctl_set_tz(v: int32):
    if v < -12:
        v = -12
    if v > 14:
        v = 14
    tz_off = v


# ---- about lines ---------------------------------------------------------
ABOUT_MAX: uint64 = 10
ABOUT_STRIDE: uint64 = 72
about_lbl: Array[720, uint8]            # 10 * 72 label
about_val: Array[720, uint8]            # 10 * 72 value
about_n: uint64 = 0


def _about_lbl_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&about_lbl[0]) + i * ABOUT_STRIDE)


def _about_val_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&about_val[0]) + i * ABOUT_STRIDE)


def hamctl_about_clear():
    about_n = 0


def hamctl_about_add(label: Ptr[uint8], value: Ptr[uint8]):
    if about_n >= ABOUT_MAX:
        return
    lp: Ptr[uint8] = _about_lbl_ptr(about_n)
    vp: Ptr[uint8] = _about_val_ptr(about_n)
    k: uint64 = 0
    while label[k] != 0 and k < ABOUT_STRIDE - 1:
        lp[k] = label[k]
        k = k + 1
    lp[k] = 0
    j: uint64 = 0
    while value[j] != 0 and j < ABOUT_STRIDE - 1:
        vp[j] = value[j]
        j = j + 1
    vp[j] = 0
    about_n = about_n + 1


def hamctl_about_count() -> uint64:
    return about_n


# ---- display -------------------------------------------------------------
# The framebuffer geometry is a READ-OUT: the native driver reads /dev/fb
# ("W H PITCH BPP PIXFMT") and pushes it in here. `disp_scale` (1x/2x) is a
# UI-scale preference the capplet PERSISTS to /tmp/hamnix-display.conf.
#   SINK STATUS: the persisted scale is a FOLLOW-UP — the compositor does not
#   yet consume a HiDPI scale config, so bumping it re-labels the readout and
#   writes the file but does not yet re-scale the desktop. Read-out is real.
disp_w:     int32 = 0
disp_h:     int32 = 0
disp_pitch: int32 = 0
disp_bpp:   int32 = 0
disp_scale: int32 = 1


def hamctl_set_display(w: int32, h: int32, pitch: int32, bpp: int32):
    disp_w = w
    disp_h = h
    disp_pitch = pitch
    disp_bpp = bpp


def hamctl_disp_scale() -> int32:
    return disp_scale


def hamctl_set_disp_scale(v: int32):
    if v < 1:
        v = 1
    if v > 3:
        v = 3
    disp_scale = v


# ---- mouse ---------------------------------------------------------------
# Pointer speed (1..10), primary button (0=left, 1=right) and scroll
# direction (0=standard, 1=natural). The capplet PERSISTS these to
# /tmp/hamnix-mouse.conf (Plan 9 shape).
#   SINK STATUS: LIVE. user/hamctl.ad::_persist_mouse persists the file AND
#   pushes the prefs to the kernel /dev/mouse router as a `cfg <speed>
#   <primary> <natural>` control line (devmouse_write). The router
#   (sys/src/9/port/devwsys.ad wsys_route_mouse_rel/_abs) applies them per
#   event via the pure lib/hammouse_cfg.ad law: pointer-speed scales the
#   motion delta, primary=right swaps buttons L<->R, natural inverts the
#   wheel sign (composing once with the #123 hamui_scroll_apply law).
#   FOLLOW-UP: re-apply the persisted file at login (tmpfs is cleared on
#   reboot; a login hook should `cat /tmp/hamnix-mouse.conf` -> /dev/mouse).
ms_speed:   int32 = 5
ms_primary: int32 = 0
ms_natural: int32 = 0


def hamctl_ms_speed() -> int32:
    return ms_speed


def hamctl_ms_primary() -> int32:
    return ms_primary


def hamctl_ms_natural() -> int32:
    return ms_natural


# ---- keyboard ------------------------------------------------------------
# Repeat delay (ms, 200..1000 step 50), repeat rate (chars/sec, 2..40 step 2)
# and a layout READ-OUT (driver-supplied, e.g. "us"). Persisted to
# /tmp/hamnix-kbd.conf.
#   SINK STATUS: FOLLOW-UP (bigger track than it looks). Hamnix does NO
#   software key-repeat — drivers/input/atkbd.ad notes "repeats come from the
#   BIOS auto-repeat", i.e. the PS/2 controller's HARDWARE typematic. Honoring
#   delay/rate therefore needs one of: (a) send the PS/2 0xF3 "Set Typematic
#   Rate/Delay" command from atkbd init (delay 250..1000ms / rate 2..30cps,
#   PS/2-only — USB HID has no typematic and would need path (b)); or (b) a
#   software repeat loop in devcons/atkbd keyed off a timer. Both are a real
#   driver track; the delay/rate knobs are recorded pending it. The layout
#   string is a real driver-supplied read-out. Contrast the MOUSE sink above,
#   which is now LIVE end-to-end.
kb_delay: int32 = 500
kb_rate:  int32 = 20
kb_layout: Array[16, uint8]


def hamctl_set_kb_layout(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 15:
        kb_layout[i] = s[i]
        i = i + 1
    kb_layout[i] = 0


def hamctl_kb_delay() -> int32:
    return kb_delay


def hamctl_kb_rate() -> int32:
    return kb_rate


# ---- sound ---------------------------------------------------------------
# Hamnix has NO native audio device yet (#152 audio is a large ALSA-through-L
# -shim track that is not present). This capplet is therefore an HONEST
# read-out: the native driver probes for an audio device node and pushes in
# either a real device name or "No audio device". Volume (0..100 step 10) and
# Mute are USER PREFERENCES the capplet PERSISTS to /tmp/hamnix-sound.conf.
#   SINK STATUS: NONE. There is no mixer to consume volume/mute — the slider
#   does NOT move any real audio level. The pref file is a record for when a
#   #152 sound server lands. Labeled "sink WIP" in the UI; NOT a fake slider.
snd_present: int32 = 0
snd_name: Array[40, uint8]
snd_vol:  int32 = 70
snd_mute: int32 = 0


def _ctl_strcpy(dst: Ptr[uint8], src: Ptr[uint8], cap: uint64):
    i: uint64 = 0
    while src[i] != 0 and i < cap - 1:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0


def hamctl_set_sound(present: int32, name: Ptr[uint8]):
    snd_present = present
    _ctl_strcpy(&snd_name[0], name, 40)


def hamctl_snd_present() -> int32:
    return snd_present


def hamctl_snd_vol() -> int32:
    return snd_vol


def hamctl_snd_mute() -> int32:
    return snd_mute


# ---- power / session -----------------------------------------------------
# REAL actions (all already wired elsewhere and reused verbatim here — see
# user/hamsessui.ad): Lock Screen spawns /bin/hamlock (#138 locker); Log Out
# writes "runlevel 3" to /proc/svc/ctl (graphical->multi-user); Shut Down and
# Reboot write to /dev/reboot. The read-out shows a live uptime (from
# /proc/uptime, driver-supplied) and a power source. Hamnix has no ACPI
# battery device, so the source honestly reads "AC (no battery)".
pw_uptime: Array[24, uint8]
pw_source: Array[32, uint8]


def hamctl_set_power(uptime: Ptr[uint8], source: Ptr[uint8]):
    _ctl_strcpy(&pw_uptime[0], uptime, 24)
    _ctl_strcpy(&pw_source[0], source, 32)


# ---- network -------------------------------------------------------------
# REAL read-out AND a REAL sink. The native driver reads the kernel IPv4
# config via the SYS_NETCFG syscall (as `ifconfig` does) and pushes the
# address / netmask / gateway / DNS strings in here; `net_src` is the config
# source ("dhcp" / "static" / "none"). The DNS preset buttons are a GENUINE
# sink: clicking one makes the driver call SYS_NETCFG SET_DNS, latching a
# static DNS server in the live kernel resolver immediately (and persisting
# the choice to /tmp/hamnix-net.conf).
net_addr: Array[24, uint8]
net_mask: Array[24, uint8]
net_gw:   Array[24, uint8]
net_dns:  Array[24, uint8]
net_src:  Array[16, uint8]
net_dns_pref: int32 = 0                  # 0 none, 1 Google 8.8.8.8, 2 Cloudflare 1.1.1.1


def hamctl_set_net(addr: Ptr[uint8], mask: Ptr[uint8], gw: Ptr[uint8],
                   dns: Ptr[uint8], src: Ptr[uint8]):
    _ctl_strcpy(&net_addr[0], addr, 24)
    _ctl_strcpy(&net_mask[0], mask, 24)
    _ctl_strcpy(&net_gw[0], gw, 24)
    _ctl_strcpy(&net_dns[0], dns, 24)
    _ctl_strcpy(&net_src[0], src, 16)


def hamctl_net_dns_pref() -> int32:
    return net_dns_pref


# ---- init ----------------------------------------------------------------
def hamctl_init():
    _set_swatch(0, 32, 80, 96, cast[Ptr[uint8]]("#205060"))
    _set_swatch(1, 40, 44, 52, cast[Ptr[uint8]]("#282c34"))
    _set_swatch(2, 90, 60, 110, cast[Ptr[uint8]]("#5a3c6e"))
    _set_swatch(3, 60, 90, 60, cast[Ptr[uint8]]("#3c5a3c"))
    _set_swatch(4, 120, 80, 40, cast[Ptr[uint8]]("#785028"))
    _set_swatch(5, 30, 30, 30, cast[Ptr[uint8]]("#1e1e1e"))
    sel_cat = CAT_APPEARANCE
    sel_swatch = 0
    sel_kind = 0
    sel_image = 0
    tz_off = 0
    about_n = 0
    disp_w = 0
    disp_h = 0
    disp_pitch = 0
    disp_bpp = 0
    disp_scale = 1
    ms_speed = 5
    ms_primary = 0
    ms_natural = 0
    kb_delay = 500
    kb_rate = 20
    kb_layout[0] = 117                                  # 'u'
    kb_layout[1] = 115                                  # 's'
    kb_layout[2] = 0
    snd_present = 0
    snd_name[0] = 0
    snd_vol = 70
    snd_mute = 0
    pw_uptime[0] = 0
    pw_source[0] = 0
    net_addr[0] = 0
    net_mask[0] = 0
    net_gw[0] = 0
    net_dns[0] = 0
    net_src[0] = 0
    net_dns_pref = 0



# lib/hamctlcore.ad — PURE, extern-free core for the Control Center hub
# (/bin/hamctl). A MATE-style control-centre: a left category sidebar
# (Appearance / Date & Time / About) selects a page drawn in the right pane.
# Three capplets that DO something real:
#
#   APPEARANCE  — a row of wallpaper colour swatches. Clicking one selects it;
#                 the driver writes a solid-colour PPM and sets it as the
#                 desktop wallpaper via /dev/wsys/ctl.  (config the DE reads)
#   DATE & TIME — shows the current date/time (the driver formats it from the
#                 #137-correct clock) and a UTC-offset stepper. Changing the
#                 offset makes the driver persist /tmp/hamnix-tz.conf and
#                 re-shift the displayed time.  (config the DE reads)
#   ABOUT       — real system facts (hostname, Hamnix/kernel version, uptime,
#                 memory, CPU count, process count) the driver reads from
#                 /dev/* and /proc and pushes in as text lines.
#
# All layout + rendering + hit-testing is here (target-agnostic, imports only
# lib/hamscene) so the whole hub renders on the host to a PNG (see
# user/hamctl_host.ad) AND ships native (user/hamctl.ad).

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_stroke, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_panel_button


# ---- tiny pure helpers (module-scoped) -----------------------------------
def _ctl_slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _ctl_u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# ---- categories ----------------------------------------------------------
# About stays LAST so the driver's I/O ordering (and existing gate click
# coordinates) grow forward as capplets are inserted before it.
CAT_APPEARANCE: int32 = 0
CAT_DATETIME:   int32 = 1
CAT_DISPLAY:    int32 = 2
CAT_MOUSE:      int32 = 3
CAT_KEYBOARD:   int32 = 4
CAT_ABOUT:      int32 = 5
N_CAT:          uint64 = 6
sel_cat: int32 = 0


def _cat_name(c: int32) -> Ptr[uint8]:
    if c == CAT_APPEARANCE:
        return cast[Ptr[uint8]]("Appearance")
    if c == CAT_DATETIME:
        return cast[Ptr[uint8]]("Date & Time")
    if c == CAT_DISPLAY:
        return cast[Ptr[uint8]]("Display")
    if c == CAT_MOUSE:
        return cast[Ptr[uint8]]("Mouse")
    if c == CAT_KEYBOARD:
        return cast[Ptr[uint8]]("Keyboard")
    return cast[Ptr[uint8]]("About")


# ---- wallpaper swatches --------------------------------------------------
N_SWATCH: uint64 = 6
sw_r: Array[6, int32]
sw_g: Array[6, int32]
sw_b: Array[6, int32]
sw_hex: Array[60, uint8]
sel_swatch: int32 = 0


def _sw_hex_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&sw_hex[0]) + i * 10)


def _set_swatch(i: uint64, r: int32, g: int32, b: int32, hx: Ptr[uint8]):
    sw_r[i] = r
    sw_g[i] = g
    sw_b[i] = b
    dp: Ptr[uint8] = _sw_hex_ptr(i)
    k: uint64 = 0
    while hx[k] != 0:
        dp[k] = hx[k]
        k = k + 1
    dp[k] = 0


# Public getters so the native driver can write the chosen colour's PPM.
def hamctl_swatch() -> int32:
    return sel_swatch


def hamctl_sw_r(i: uint64) -> int32:
    return sw_r[i]


def hamctl_sw_g(i: uint64) -> int32:
    return sw_g[i]


def hamctl_sw_b(i: uint64) -> int32:
    return sw_b[i]


# ---- date & time ---------------------------------------------------------
dt_buf: Array[64, uint8]                # "Fri Jul 12  14:30" (driver-supplied)
tz_off: int32 = 0                       # UTC offset in hours, -12..14


def hamctl_set_datetime(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 63:
        dt_buf[i] = s[i]
        i = i + 1
    dt_buf[i] = 0


def hamctl_tz() -> int32:
    return tz_off


def hamctl_set_tz(v: int32):
    if v < -12:
        v = -12
    if v > 14:
        v = 14
    tz_off = v


# ---- about lines ---------------------------------------------------------
ABOUT_MAX: uint64 = 10
ABOUT_STRIDE: uint64 = 72
about_lbl: Array[720, uint8]            # 10 * 72 label
about_val: Array[720, uint8]            # 10 * 72 value
about_n: uint64 = 0


def _about_lbl_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&about_lbl[0]) + i * ABOUT_STRIDE)


def _about_val_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&about_val[0]) + i * ABOUT_STRIDE)


def hamctl_about_clear():
    about_n = 0


def hamctl_about_add(label: Ptr[uint8], value: Ptr[uint8]):
    if about_n >= ABOUT_MAX:
        return
    lp: Ptr[uint8] = _about_lbl_ptr(about_n)
    vp: Ptr[uint8] = _about_val_ptr(about_n)
    k: uint64 = 0
    while label[k] != 0 and k < ABOUT_STRIDE - 1:
        lp[k] = label[k]
        k = k + 1
    lp[k] = 0
    j: uint64 = 0
    while value[j] != 0 and j < ABOUT_STRIDE - 1:
        vp[j] = value[j]
        j = j + 1
    vp[j] = 0
    about_n = about_n + 1


def hamctl_about_count() -> uint64:
    return about_n


# ---- display -------------------------------------------------------------
# The framebuffer geometry is a READ-OUT: the native driver reads /dev/fb
# ("W H PITCH BPP PIXFMT") and pushes it in here. `disp_scale` (1x/2x) is a
# UI-scale preference the capplet PERSISTS to /tmp/hamnix-display.conf.
#   SINK STATUS: the persisted scale is a FOLLOW-UP — the compositor does not
#   yet consume a HiDPI scale config, so bumping it re-labels the readout and
#   writes the file but does not yet re-scale the desktop. Read-out is real.
disp_w:     int32 = 0
disp_h:     int32 = 0
disp_pitch: int32 = 0
disp_bpp:   int32 = 0
disp_scale: int32 = 1


def hamctl_set_display(w: int32, h: int32, pitch: int32, bpp: int32):
    disp_w = w
    disp_h = h
    disp_pitch = pitch
    disp_bpp = bpp


def hamctl_disp_scale() -> int32:
    return disp_scale


def hamctl_set_disp_scale(v: int32):
    if v < 1:
        v = 1
    if v > 3:
        v = 3
    disp_scale = v


# ---- mouse ---------------------------------------------------------------
# Pointer speed (1..10), primary button (0=left, 1=right) and scroll
# direction (0=standard, 1=natural). The capplet PERSISTS these to
# /tmp/hamnix-mouse.conf (Plan 9 shape).
#   SINK STATUS: FOLLOW-UP — devmouse.ad does not yet read this config, so
#   the settings are recorded but the live pointer path is unchanged. The
#   scroll-direction SIGN law itself is already fixed in lib/hamscene's
#   hamui_scroll_apply (#123); this capplet only records the user preference.
ms_speed:   int32 = 5
ms_primary: int32 = 0
ms_natural: int32 = 0


def hamctl_ms_speed() -> int32:
    return ms_speed


def hamctl_ms_primary() -> int32:
    return ms_primary


def hamctl_ms_natural() -> int32:
    return ms_natural


# ---- keyboard ------------------------------------------------------------
# Repeat delay (ms, 200..1000 step 50), repeat rate (chars/sec, 2..40 step 2)
# and a layout READ-OUT (driver-supplied, e.g. "us"). Persisted to
# /tmp/hamnix-kbd.conf.
#   SINK STATUS: FOLLOW-UP — the console/keyboard driver does not yet read a
#   repeat config; the layout string is a real read-out, the repeat knobs are
#   recorded for the future sink.
kb_delay: int32 = 500
kb_rate:  int32 = 20
kb_layout: Array[16, uint8]


def hamctl_set_kb_layout(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 15:
        kb_layout[i] = s[i]
        i = i + 1
    kb_layout[i] = 0


def hamctl_kb_delay() -> int32:
    return kb_delay


def hamctl_kb_rate() -> int32:
    return kb_rate


# ---- init ----------------------------------------------------------------
def hamctl_init():
    _set_swatch(0, 32, 80, 96, cast[Ptr[uint8]]("#205060"))
    _set_swatch(1, 40, 44, 52, cast[Ptr[uint8]]("#282c34"))
    _set_swatch(2, 90, 60, 110, cast[Ptr[uint8]]("#5a3c6e"))
    _set_swatch(3, 60, 90, 60, cast[Ptr[uint8]]("#3c5a3c"))
    _set_swatch(4, 120, 80, 40, cast[Ptr[uint8]]("#785028"))
    _set_swatch(5, 30, 30, 30, cast[Ptr[uint8]]("#1e1e1e"))
    sel_cat = CAT_APPEARANCE
    sel_swatch = 0
    tz_off = 0
    about_n = 0
    disp_w = 0
    disp_h = 0
    disp_pitch = 0
    disp_bpp = 0
    disp_scale = 1
    ms_speed = 5
    ms_primary = 0
    ms_natural = 0
    kb_delay = 500
    kb_rate = 20
    kb_layout[0] = 117                                  # 'u'
    kb_layout[1] = 115                                  # 's'
    kb_layout[2] = 0


# ---- layout --------------------------------------------------------------
WIN_W: int32 = 520
WIN_H: int32 = 360
BAR_H: int32 = 26
SIDE_W: int32 = 140
SIDE_BTN_X: int32 = 8
SIDE_BTN_Y0: int32 = 40
SIDE_BTN_W: int32 = 124
SIDE_BTN_H: int32 = 32
SIDE_BTN_GAP: int32 = 6
PANE_X: int32 = 152
PANE_Y: int32 = 40

# Appearance swatch row
SW_X: int32 = 168
SW_Y: int32 = 92
SW_SZ: int32 = 44
SW_GAP: int32 = 10

# Date/Time tz stepper
TZ_DEC_X: int32 = 168
TZ_INC_X: int32 = 300
TZ_BTN_Y: int32 = 150
TZ_BTN_W: int32 = 28
TZ_BTN_H: int32 = 24

# Shared stepper button metrics (Display scale, Keyboard delay/rate)
STEP_W: int32 = 28
STEP_H: int32 = 24

# Display: UI-scale stepper
DSC_DEC_X: int32 = 300
DSC_INC_X: int32 = 388
DSC_Y:     int32 = 208

# Mouse: speed stepper + primary/scroll toggle pairs
MS_SPD_DEC_X: int32 = 300
MS_SPD_INC_X: int32 = 388
MS_SPD_Y:     int32 = 70
MS_PRI_L_X:   int32 = 260
MS_PRI_R_X:   int32 = 330
MS_PRI_Y:     int32 = 130
MS_TGL_W:     int32 = 62
MS_TGL_H:     int32 = 24
MS_SCR_S_X:   int32 = 260
MS_SCR_N_X:   int32 = 340
MS_SCR_Y:     int32 = 190
MS_SCR_W:     int32 = 74

# Keyboard: delay + rate steppers
KB_DLY_DEC_X: int32 = 300
KB_DLY_INC_X: int32 = 388
KB_DLY_Y:     int32 = 78
KB_RAT_DEC_X: int32 = 300
KB_RAT_INC_X: int32 = 388
KB_RAT_Y:     int32 = 128


def _side_btn_y(i: uint64) -> int32:
    return SIDE_BTN_Y0 + cast[int32](i) * (SIDE_BTN_H + SIDE_BTN_GAP)


# A "- value +" spin control: two panel buttons flanking a bold value.
def _draw_stepper(dec_x: int32, inc_x: int32, y: int32, val: Ptr[uint8],
                  fg: Ptr[uint8]):
    hamscene_panel_button(dec_x, y, STEP_W, STEP_H, 0)
    hamscene_glyphs(dec_x + 9, y + 7, cast[Ptr[uint8]]("-"), fg)
    hamscene_glyphs_bold(dec_x + STEP_W + 12, y + 7, val, fg)
    hamscene_panel_button(inc_x, y, STEP_W, STEP_H, 0)
    hamscene_glyphs(inc_x + 9, y + 7, cast[Ptr[uint8]]("+"), fg)


# A selectable option button; `on` sinks it and draws a gold selection frame.
def _draw_toggle(x: int32, y: int32, w: int32, h: int32, label: Ptr[uint8],
                 on: int32, fg: Ptr[uint8]):
    hamscene_panel_button(x, y, w, h, on)
    if on != 0:
        hamscene_stroke(x, y, w, h, 2, cast[Ptr[uint8]]("#ffd040"))
    hamscene_glyphs(x + 8, y + (h - 16) / 2 + 3, label, fg)


def _swatch_x(i: uint64) -> int32:
    return SW_X + cast[int32](i) * (SW_SZ + SW_GAP)


# ---- scene ---------------------------------------------------------------
def _tz_label(out: Ptr[uint8]) -> uint64:
    p: uint64 = 0
    out[p] = 85                                        # 'U'
    out[p+1] = 84                                      # 'T'
    out[p+2] = 67                                      # 'C'
    p = 3
    v: int32 = tz_off
    if v >= 0:
        out[p] = 43                                    # '+'
    else:
        out[p] = 45                                    # '-'
        v = 0 - v
    p = p + 1
    p = p + _ctl_u64_to_dec(cast[uint64](v), &out[p])
    out[p] = 0
    return p


def hamctl_build_scene():
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    hamscene_begin()
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#d4d0c8"))
    hamscene_fill(0, 0, WIN_W, BAR_H, cast[Ptr[uint8]]("#3a6ea5"))
    hamscene_glyphs(10, 8, cast[Ptr[uint8]]("Control Center"),
                    cast[Ptr[uint8]]("#ffffff"))

    # --- sidebar ---
    hamscene_fill(0, BAR_H, SIDE_W, WIN_H - BAR_H, cast[Ptr[uint8]]("#c8c4bc"))
    hamscene_fill(SIDE_W, BAR_H, 1, WIN_H - BAR_H, cast[Ptr[uint8]]("#808080"))
    c: uint64 = 0
    while c < N_CAT:
        by: int32 = _side_btn_y(c)
        sunk: int32 = 0
        if sel_cat == cast[int32](c):
            sunk = 1
        hamscene_panel_button(SIDE_BTN_X, by, SIDE_BTN_W, SIDE_BTN_H, sunk)
        hamscene_glyphs(SIDE_BTN_X + 10, by + 11, _cat_name(cast[int32](c)), fg)
        c = c + 1

    # --- content pane ---
    if sel_cat == CAT_APPEARANCE:
        hamscene_glyphs_bold(PANE_X, PANE_Y, cast[Ptr[uint8]]("Desktop Wallpaper"), fg)
        hamscene_glyphs(PANE_X, PANE_Y + 24,
                        cast[Ptr[uint8]]("Pick a background colour:"), fg)
        i: uint64 = 0
        while i < N_SWATCH:
            sx: int32 = _swatch_x(i)
            hamscene_fill(sx, SW_Y, SW_SZ, SW_SZ, _sw_hex_ptr(i))
            bc: Ptr[uint8] = cast[Ptr[uint8]]("#606060")
            th: int32 = 1
            if sel_swatch == cast[int32](i):
                bc = cast[Ptr[uint8]]("#ffd040")
                th = 3
            hamscene_stroke(sx, SW_Y, SW_SZ, SW_SZ, th, bc)
            i = i + 1
        hamscene_glyphs(PANE_X, SW_Y + SW_SZ + 20,
                        cast[Ptr[uint8]]("Applied to the desktop immediately."),
                        cast[Ptr[uint8]]("#606060"))
    elif sel_cat == CAT_DATETIME:
        hamscene_glyphs_bold(PANE_X, PANE_Y, cast[Ptr[uint8]]("Date & Time"), fg)
        hamscene_glyphs(PANE_X, PANE_Y + 26, cast[Ptr[uint8]]("Current:"), fg)
        hamscene_glyphs_bold(PANE_X + 80, PANE_Y + 26, &dt_buf[0],
                             cast[Ptr[uint8]]("#204060"))
        hamscene_glyphs(PANE_X, 122, cast[Ptr[uint8]]("Time zone:"), fg)
        hamscene_panel_button(TZ_DEC_X, TZ_BTN_Y, TZ_BTN_W, TZ_BTN_H, 0)
        hamscene_glyphs(TZ_DEC_X + 9, TZ_BTN_Y + 7, cast[Ptr[uint8]]("-"), fg)
        tzl: Array[16, uint8]
        _tz_label(&tzl[0])
        hamscene_glyphs_bold(TZ_DEC_X + 46, TZ_BTN_Y + 7, &tzl[0], fg)
        hamscene_panel_button(TZ_INC_X, TZ_BTN_Y, TZ_BTN_W, TZ_BTN_H, 0)
        hamscene_glyphs(TZ_INC_X + 9, TZ_BTN_Y + 7, cast[Ptr[uint8]]("+"), fg)
        hamscene_glyphs(PANE_X, TZ_BTN_Y + 44,
                        cast[Ptr[uint8]]("Offset shifts the displayed clock."),
                        cast[Ptr[uint8]]("#606060"))
    elif sel_cat == CAT_DISPLAY:
        hamscene_glyphs_bold(PANE_X, PANE_Y, cast[Ptr[uint8]]("Display"), fg)
        res: Array[32, uint8]
        rp: uint64 = _ctl_u64_to_dec(cast[uint64](disp_w), &res[0])
        res[rp] = 120                                   # 'x'
        rp = rp + 1
        rp = rp + _ctl_u64_to_dec(cast[uint64](disp_h), &res[rp])
        res[rp] = 0
        hamscene_glyphs(PANE_X, PANE_Y + 30, cast[Ptr[uint8]]("Resolution:"), fg)
        hamscene_glyphs_bold(PANE_X + 130, PANE_Y + 30, &res[0],
                             cast[Ptr[uint8]]("#204060"))
        dep: Array[16, uint8]
        dpp: uint64 = _ctl_u64_to_dec(cast[uint64](disp_bpp), &dep[0])
        dep[dpp] = 45                                   # '-'
        dep[dpp+1] = 98                                 # 'b'
        dep[dpp+2] = 105                                # 'i'
        dep[dpp+3] = 116                                # 't'
        dep[dpp+4] = 0
        hamscene_glyphs(PANE_X, PANE_Y + 54, cast[Ptr[uint8]]("Colour depth:"), fg)
        hamscene_glyphs_bold(PANE_X + 130, PANE_Y + 54, &dep[0],
                             cast[Ptr[uint8]]("#204060"))
        pit: Array[24, uint8]
        pp: uint64 = _ctl_u64_to_dec(cast[uint64](disp_pitch), &pit[0])
        pit[pp] = 32
        pit[pp+1] = 66                                  # 'B'
        pit[pp+2] = 47                                  # '/'
        pit[pp+3] = 114                                 # 'r'
        pit[pp+4] = 111                                 # 'o'
        pit[pp+5] = 119                                 # 'w'
        pit[pp+6] = 0
        hamscene_glyphs(PANE_X, PANE_Y + 78, cast[Ptr[uint8]]("Stride:"), fg)
        hamscene_glyphs_bold(PANE_X + 130, PANE_Y + 78, &pit[0],
                             cast[Ptr[uint8]]("#204060"))
        hamscene_glyphs(PANE_X, DSC_Y + 6, cast[Ptr[uint8]]("UI scale:"), fg)
        scl: Array[8, uint8]
        sp: uint64 = _ctl_u64_to_dec(cast[uint64](disp_scale), &scl[0])
        scl[sp] = 120                                   # 'x'
        scl[sp+1] = 0
        _draw_stepper(DSC_DEC_X, DSC_INC_X, DSC_Y, &scl[0], fg)
        hamscene_glyphs(PANE_X, DSC_Y + 44,
                        cast[Ptr[uint8]]("Read-out is live; scale persists (sink WIP)."),
                        cast[Ptr[uint8]]("#606060"))
    elif sel_cat == CAT_MOUSE:
        hamscene_glyphs_bold(PANE_X, PANE_Y, cast[Ptr[uint8]]("Mouse"), fg)
        hamscene_glyphs(PANE_X, MS_SPD_Y + 6,
                        cast[Ptr[uint8]]("Pointer speed:"), fg)
        spd: Array[8, uint8]
        spl: uint64 = _ctl_u64_to_dec(cast[uint64](ms_speed), &spd[0])
        spd[spl] = 0
        _draw_stepper(MS_SPD_DEC_X, MS_SPD_INC_X, MS_SPD_Y, &spd[0], fg)
        hamscene_glyphs(PANE_X, MS_PRI_Y + 6,
                        cast[Ptr[uint8]]("Primary button:"), fg)
        lpri: int32 = 0
        rpri: int32 = 0
        if ms_primary == 0:
            lpri = 1
        else:
            rpri = 1
        _draw_toggle(MS_PRI_L_X, MS_PRI_Y, MS_TGL_W, MS_TGL_H,
                     cast[Ptr[uint8]]("Left"), lpri, fg)
        _draw_toggle(MS_PRI_R_X, MS_PRI_Y, MS_TGL_W, MS_TGL_H,
                     cast[Ptr[uint8]]("Right"), rpri, fg)
        hamscene_glyphs(PANE_X, MS_SCR_Y + 6,
                        cast[Ptr[uint8]]("Scroll:"), fg)
        sstd: int32 = 0
        snat: int32 = 0
        if ms_natural == 0:
            sstd = 1
        else:
            snat = 1
        _draw_toggle(MS_SCR_S_X, MS_SCR_Y, MS_SCR_W, MS_TGL_H,
                     cast[Ptr[uint8]]("Standard"), sstd, fg)
        _draw_toggle(MS_SCR_N_X, MS_SCR_Y, MS_SCR_W, MS_TGL_H,
                     cast[Ptr[uint8]]("Natural"), snat, fg)
    elif sel_cat == CAT_KEYBOARD:
        hamscene_glyphs_bold(PANE_X, PANE_Y, cast[Ptr[uint8]]("Keyboard"), fg)
        hamscene_glyphs(PANE_X, KB_DLY_Y + 6,
                        cast[Ptr[uint8]]("Repeat delay:"), fg)
        dly: Array[16, uint8]
        dl: uint64 = _ctl_u64_to_dec(cast[uint64](kb_delay), &dly[0])
        dly[dl] = 32
        dly[dl+1] = 109                                 # 'm'
        dly[dl+2] = 115                                 # 's'
        dly[dl+3] = 0
        _draw_stepper(KB_DLY_DEC_X, KB_DLY_INC_X, KB_DLY_Y, &dly[0], fg)
        hamscene_glyphs(PANE_X, KB_RAT_Y + 6,
                        cast[Ptr[uint8]]("Repeat rate:"), fg)
        rat: Array[16, uint8]
        rt: uint64 = _ctl_u64_to_dec(cast[uint64](kb_rate), &rat[0])
        rat[rt] = 47                                    # '/'
        rat[rt+1] = 115                                 # 's'
        rat[rt+2] = 0
        _draw_stepper(KB_RAT_DEC_X, KB_RAT_INC_X, KB_RAT_Y, &rat[0], fg)
        hamscene_glyphs(PANE_X, 178, cast[Ptr[uint8]]("Layout:"), fg)
        hamscene_glyphs_bold(PANE_X + 130, 178, &kb_layout[0],
                             cast[Ptr[uint8]]("#204060"))
        hamscene_glyphs(PANE_X, 214,
                        cast[Ptr[uint8]]("Layout is live; repeat persists (sink WIP)."),
                        cast[Ptr[uint8]]("#606060"))
    else:
        hamscene_glyphs_bold(PANE_X, PANE_Y, cast[Ptr[uint8]]("About This System"), fg)
        i2: uint64 = 0
        while i2 < about_n:
            ly: int32 = PANE_Y + 28 + cast[int32](i2) * 22
            hamscene_glyphs_bold(PANE_X, ly, _about_lbl_ptr(i2), fg)
            hamscene_glyphs(PANE_X + 130, ly, _about_val_ptr(i2),
                            cast[Ptr[uint8]]("#204060"))
            i2 = i2 + 1


# ---- input ---------------------------------------------------------------
def _in(x: int64, y: int64, bx: int32, by: int32, bw: int32, bh: int32) -> int32:
    if x >= cast[int64](bx) and x < cast[int64](bx + bw) \
            and y >= cast[int64](by) and y < cast[int64](by + bh):
        return 1
    return 0


# Action codes returned by hamctl_click:
ACT_NONE:    int32 = 0
ACT_CAT:     int32 = 1         # category changed — just re-render
ACT_WALL:    int32 = 2         # swatch chosen — driver applies wallpaper
ACT_TZ:      int32 = 3         # tz changed — driver persists + refreshes time
ACT_DISPLAY: int32 = 4         # UI scale changed — driver persists display.conf
ACT_MOUSE:   int32 = 5         # mouse pref changed — driver persists mouse.conf
ACT_KBD:     int32 = 6         # kbd repeat changed — driver persists kbd.conf


def hamctl_click(x: int64, y: int64) -> int32:
    # sidebar category buttons (always visible)
    c: uint64 = 0
    while c < N_CAT:
        by: int32 = _side_btn_y(c)
        if _in(x, y, SIDE_BTN_X, by, SIDE_BTN_W, SIDE_BTN_H) != 0:
            sel_cat = cast[int32](c)
            return ACT_CAT
        c = c + 1

    if sel_cat == CAT_APPEARANCE:
        if y >= cast[int64](SW_Y) and y < cast[int64](SW_Y + SW_SZ):
            i: uint64 = 0
            while i < N_SWATCH:
                sx: int64 = cast[int64](_swatch_x(i))
                if x >= sx and x < sx + cast[int64](SW_SZ):
                    sel_swatch = cast[int32](i)
                    return ACT_WALL
                i = i + 1
    elif sel_cat == CAT_DATETIME:
        if _in(x, y, TZ_DEC_X, TZ_BTN_Y, TZ_BTN_W, TZ_BTN_H) != 0:
            hamctl_set_tz(tz_off - 1)
            return ACT_TZ
        if _in(x, y, TZ_INC_X, TZ_BTN_Y, TZ_BTN_W, TZ_BTN_H) != 0:
            hamctl_set_tz(tz_off + 1)
            return ACT_TZ
    elif sel_cat == CAT_DISPLAY:
        if _in(x, y, DSC_DEC_X, DSC_Y, STEP_W, STEP_H) != 0:
            hamctl_set_disp_scale(disp_scale - 1)
            return ACT_DISPLAY
        if _in(x, y, DSC_INC_X, DSC_Y, STEP_W, STEP_H) != 0:
            hamctl_set_disp_scale(disp_scale + 1)
            return ACT_DISPLAY
    elif sel_cat == CAT_MOUSE:
        if _in(x, y, MS_SPD_DEC_X, MS_SPD_Y, STEP_W, STEP_H) != 0:
            if ms_speed > 1:
                ms_speed = ms_speed - 1
            return ACT_MOUSE
        if _in(x, y, MS_SPD_INC_X, MS_SPD_Y, STEP_W, STEP_H) != 0:
            if ms_speed < 10:
                ms_speed = ms_speed + 1
            return ACT_MOUSE
        if _in(x, y, MS_PRI_L_X, MS_PRI_Y, MS_TGL_W, MS_TGL_H) != 0:
            ms_primary = 0
            return ACT_MOUSE
        if _in(x, y, MS_PRI_R_X, MS_PRI_Y, MS_TGL_W, MS_TGL_H) != 0:
            ms_primary = 1
            return ACT_MOUSE
        if _in(x, y, MS_SCR_S_X, MS_SCR_Y, MS_SCR_W, MS_TGL_H) != 0:
            ms_natural = 0
            return ACT_MOUSE
        if _in(x, y, MS_SCR_N_X, MS_SCR_Y, MS_SCR_W, MS_TGL_H) != 0:
            ms_natural = 1
            return ACT_MOUSE
    elif sel_cat == CAT_KEYBOARD:
        if _in(x, y, KB_DLY_DEC_X, KB_DLY_Y, STEP_W, STEP_H) != 0:
            if kb_delay > 200:
                kb_delay = kb_delay - 50
            return ACT_KBD
        if _in(x, y, KB_DLY_INC_X, KB_DLY_Y, STEP_W, STEP_H) != 0:
            if kb_delay < 1000:
                kb_delay = kb_delay + 50
            return ACT_KBD
        if _in(x, y, KB_RAT_DEC_X, KB_RAT_Y, STEP_W, STEP_H) != 0:
            if kb_rate > 2:
                kb_rate = kb_rate - 2
            return ACT_KBD
        if _in(x, y, KB_RAT_INC_X, KB_RAT_Y, STEP_W, STEP_H) != 0:
            if kb_rate < 40:
                kb_rate = kb_rate + 2
            return ACT_KBD
    return ACT_NONE


def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                             # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc = acc * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc = 0 - acc
        vals[v] = acc
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1

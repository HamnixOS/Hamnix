# Network: two DNS-preset buttons
NET_DNS_G_X: int32 = 240
NET_DNS_C_X: int32 = 340
NET_DNS_Y:   int32 = 250
NET_DNS_W:   int32 = 92
NET_DNS_H:   int32 = 26


def _pw_btn_y(i: uint64) -> int32:
    return PW_BTN_Y0 + cast[int32](i) * (PW_BTN_H + PW_BTN_GAP)


def _side_btn_y(i: uint64) -> int32:
    return SIDE_BTN_Y0 + cast[int32](i) * (SIDE_BTN_H + SIDE_BTN_GAP)


# A "- value +" spin control: two panel buttons flanking a bold value.
def _draw_stepper(dec_x: int32, inc_x: int32, y: int32, val: Ptr[uint8],
                  fg: Ptr[uint8]):
    hamscene_panel_button(dec_x, y, STEP_W, STEP_H, 0)
    hamscene_glyphs(dec_x + 9, y + 7, cast[Ptr[uint8]]("-"), fg)
    hamscene_glyphs_bold(dec_x + STEP_W + 12, y + 7, val, fg)
    hamscene_panel_button(inc_x, y, STEP_W, STEP_H, 0)
    hamscene_glyphs(inc_x + 9, y + 7, cast[Ptr[uint8]]("+"), fg)


# A selectable option button; `on` sinks it and draws a gold selection frame.
def _draw_toggle(x: int32, y: int32, w: int32, h: int32, label: Ptr[uint8],
                 on: int32, fg: Ptr[uint8]):
    hamscene_panel_button(x, y, w, h, on)
    if on != 0:
        hamscene_stroke(x, y, w, h, 2, cast[Ptr[uint8]]("#ffd040"))
    hamscene_glyphs(x + 8, y + (h - 16) / 2 + 3, label, fg)


def _swatch_x(i: uint64) -> int32:
    return SW_X + cast[int32](i) * (SW_SZ + SW_GAP)


def _eq1(a: int32, b: int32) -> int32:
    if a == b:
        return 1
    return 0


# ---- scene ---------------------------------------------------------------
def _tz_label(out: Ptr[uint8]) -> uint64:
    p: uint64 = 0
    out[p] = 85                                        # 'U'
    out[p+1] = 84                                      # 'T'
    out[p+2] = 67                                      # 'C'
    p = 3
    v: int32 = tz_off
    if v >= 0:
        out[p] = 43                                    # '+'
    else:
        out[p] = 45                                    # '-'
        v = 0 - v
    p = p + 1
    p = p + _ctl_u64_to_dec(cast[uint64](v), &out[p])
    out[p] = 0
    return p


def hamctl_build_scene():
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    hamscene_begin()
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#eceef2"))
    hamscene_fill(0, 0, WIN_W, BAR_H, cast[Ptr[uint8]]("#3584e4"))
    # Modern headerbar elevation hairline along the titlebar's bottom edge.
    hamscene_fill(0, BAR_H - 1, WIN_W, 1, cast[Ptr[uint8]]("#1f66c8"))
    hamscene_glyphs(10, 8, cast[Ptr[uint8]]("Control Center"),
                    cast[Ptr[uint8]]("#ffffff"))

    # --- sidebar ---
    hamscene_fill(0, BAR_H, SIDE_W, WIN_H - BAR_H, cast[Ptr[uint8]]("#e6e8ec"))
    # Soft hairline divider (was a hard 90s #808080 chisel) matching the menu
    # popover frame token, so the sidebar reads as a flat modern nav rail.
    hamscene_fill(SIDE_W, BAR_H, 1, WIN_H - BAR_H, cast[Ptr[uint8]]("#cfd2d8"))
    c: uint64 = 0
    while c < N_CAT:
        by: int32 = _side_btn_y(c)
        if sel_cat == cast[int32](c):
            # Selected category: a flat MATE selection-blue row (matches the
            # #3584e4 highlight used by the context menu / applet chooser) with
            # white label text and a darker inset border, so the current page
            # reads unmistakably instead of as a barely-darker sunk button.
            hamscene_fill(SIDE_BTN_X, by, SIDE_BTN_W, SIDE_BTN_H,
                          cast[Ptr[uint8]]("#3584e4"))
            hamscene_fill(SIDE_BTN_X, by, SIDE_BTN_W, 1,
                          cast[Ptr[uint8]]("#3a5a8a"))
            hamscene_fill(SIDE_BTN_X, by + SIDE_BTN_H - 1, SIDE_BTN_W, 1,
                          cast[Ptr[uint8]]("#3a5a8a"))
            hamscene_fill(SIDE_BTN_X, by, 1, SIDE_BTN_H,
                          cast[Ptr[uint8]]("#3a5a8a"))
            hamscene_fill(SIDE_BTN_X + SIDE_BTN_W - 1, by, 1, SIDE_BTN_H,
                          cast[Ptr[uint8]]("#3a5a8a"))
            hamscene_glyphs(SIDE_BTN_X + 10, by + 11, _cat_name(cast[int32](c)),
                            cast[Ptr[uint8]]("#ffffff"))
        else:
            hamscene_panel_button(SIDE_BTN_X, by, SIDE_BTN_W, SIDE_BTN_H, 0)
            hamscene_glyphs(SIDE_BTN_X + 10, by + 11, _cat_name(cast[int32](c)), fg)
        c = c + 1

    # --- content pane ---
    if sel_cat == CAT_APPEARANCE:
        hamscene_glyphs_bold(PANE_X, PANE_Y, cast[Ptr[uint8]]("Desktop Wallpaper"), fg)
        hamscene_glyphs(PANE_X, PANE_Y + 24,
                        cast[Ptr[uint8]]("Pick a background colour:"), fg)
        i: uint64 = 0
        while i < N_SWATCH:
            sx: int32 = _swatch_x(i)
            hamscene_fill(sx, SW_Y, SW_SZ, SW_SZ, _sw_hex_ptr(i))
            bc: Ptr[uint8] = cast[Ptr[uint8]]("#606060")
            th: int32 = 1
            if sel_kind == 0 and sel_swatch == cast[int32](i):
                bc = cast[Ptr[uint8]]("#ffd040")
                th = 3
            hamscene_stroke(sx, SW_Y, SW_SZ, SW_SZ, th, bc)
            i = i + 1
        # image-wallpaper thumbnails: each is a live mosaic preview of the
        # procedural picture the desktop will paint.
        hamscene_glyphs(PANE_X, IMG_TH_Y - 18,
                        cast[Ptr[uint8]]("Or pick an image:"), fg)
        im: uint64 = 0
        while im < N_IMAGE:
            tx: int32 = IMG_TH_X + cast[int32](im) * (IMG_TH_W + IMG_TH_GAP)
            hamctl_image_mosaic(cast[int32](im), tx, IMG_TH_Y,
                                IMG_TH_W, IMG_TH_H, 8, 6)
            ibc: Ptr[uint8] = cast[Ptr[uint8]]("#606060")
            ith: int32 = 1
            if sel_kind == 1 and sel_image == cast[int32](im):
                ibc = cast[Ptr[uint8]]("#ffd040")
                ith = 3
            hamscene_stroke(tx, IMG_TH_Y, IMG_TH_W, IMG_TH_H, ith, ibc)
            hamscene_glyphs(tx + 4, IMG_TH_Y + IMG_TH_H + 3,
                            _img_name(cast[uint64](im)),
                            cast[Ptr[uint8]]("#404040"))
            im = im + 1
        hamscene_glyphs(PANE_X, IMG_TH_Y + IMG_TH_H + 22,
                        cast[Ptr[uint8]]("Applied to the desktop immediately."),
                        cast[Ptr[uint8]]("#606060"))
    elif sel_cat == CAT_DATETIME:
        hamscene_glyphs_bold(PANE_X, PANE_Y, cast[Ptr[uint8]]("Date & Time"), fg)
        hamscene_glyphs(PANE_X, PANE_Y + 26, cast[Ptr[uint8]]("Current:"), fg)
        hamscene_glyphs_bold(PANE_X + 80, PANE_Y + 26, &dt_buf[0],
                             cast[Ptr[uint8]]("#204060"))
        hamscene_glyphs(PANE_X, 122, cast[Ptr[uint8]]("Time zone:"), fg)
        hamscene_panel_button(TZ_DEC_X, TZ_BTN_Y, TZ_BTN_W, TZ_BTN_H, 0)
        hamscene_glyphs(TZ_DEC_X + 9, TZ_BTN_Y + 7, cast[Ptr[uint8]]("-"), fg)
        tzl: Array[16, uint8]
        _tz_label(&tzl[0])
        hamscene_glyphs_bold(TZ_DEC_X + 46, TZ_BTN_Y + 7, &tzl[0], fg)
        hamscene_panel_button(TZ_INC_X, TZ_BTN_Y, TZ_BTN_W, TZ_BTN_H, 0)
        hamscene_glyphs(TZ_INC_X + 9, TZ_BTN_Y + 7, cast[Ptr[uint8]]("+"), fg)
        hamscene_glyphs(PANE_X, TZ_BTN_Y + 44,
                        cast[Ptr[uint8]]("Offset shifts the displayed clock."),
                        cast[Ptr[uint8]]("#606060"))
    elif sel_cat == CAT_DISPLAY:
        hamscene_glyphs_bold(PANE_X, PANE_Y, cast[Ptr[uint8]]("Display"), fg)
        res: Array[32, uint8]
        rp: uint64 = _ctl_u64_to_dec(cast[uint64](disp_w), &res[0])
        res[rp] = 120                                   # 'x'
        rp = rp + 1
        rp = rp + _ctl_u64_to_dec(cast[uint64](disp_h), &res[rp])
        res[rp] = 0
        hamscene_glyphs(PANE_X, PANE_Y + 30, cast[Ptr[uint8]]("Resolution:"), fg)
        hamscene_glyphs_bold(PANE_X + 130, PANE_Y + 30, &res[0],
                             cast[Ptr[uint8]]("#204060"))
        dep: Array[16, uint8]
        dpp: uint64 = _ctl_u64_to_dec(cast[uint64](disp_bpp), &dep[0])
        dep[dpp] = 45                                   # '-'
        dep[dpp+1] = 98                                 # 'b'
        dep[dpp+2] = 105                                # 'i'
        dep[dpp+3] = 116                                # 't'
        dep[dpp+4] = 0
        hamscene_glyphs(PANE_X, PANE_Y + 54, cast[Ptr[uint8]]("Colour depth:"), fg)
        hamscene_glyphs_bold(PANE_X + 130, PANE_Y + 54, &dep[0],
                             cast[Ptr[uint8]]("#204060"))
        pit: Array[24, uint8]
        pp: uint64 = _ctl_u64_to_dec(cast[uint64](disp_pitch), &pit[0])
        pit[pp] = 32
        pit[pp+1] = 66                                  # 'B'
        pit[pp+2] = 47                                  # '/'
        pit[pp+3] = 114                                 # 'r'
        pit[pp+4] = 111                                 # 'o'
        pit[pp+5] = 119                                 # 'w'
        pit[pp+6] = 0
        hamscene_glyphs(PANE_X, PANE_Y + 78, cast[Ptr[uint8]]("Stride:"), fg)
        hamscene_glyphs_bold(PANE_X + 130, PANE_Y + 78, &pit[0],
                             cast[Ptr[uint8]]("#204060"))
        hamscene_glyphs(PANE_X, DSC_Y + 6, cast[Ptr[uint8]]("UI scale:"), fg)
        scl: Array[8, uint8]
        sp: uint64 = _ctl_u64_to_dec(cast[uint64](disp_scale), &scl[0])
        scl[sp] = 120                                   # 'x'
        scl[sp+1] = 0
        _draw_stepper(DSC_DEC_X, DSC_INC_X, DSC_Y, &scl[0], fg)
        hamscene_glyphs(PANE_X, DSC_Y + 44,
                        cast[Ptr[uint8]]("Read-out is live; scale persists (sink WIP)."),
                        cast[Ptr[uint8]]("#606060"))
    elif sel_cat == CAT_MOUSE:
        hamscene_glyphs_bold(PANE_X, PANE_Y, cast[Ptr[uint8]]("Mouse"), fg)
        hamscene_glyphs(PANE_X, MS_SPD_Y + 6,
                        cast[Ptr[uint8]]("Pointer speed:"), fg)
        spd: Array[8, uint8]
        spl: uint64 = _ctl_u64_to_dec(cast[uint64](ms_speed), &spd[0])
        spd[spl] = 0
        _draw_stepper(MS_SPD_DEC_X, MS_SPD_INC_X, MS_SPD_Y, &spd[0], fg)
        hamscene_glyphs(PANE_X, MS_PRI_Y + 6,
                        cast[Ptr[uint8]]("Primary button:"), fg)
        lpri: int32 = 0
        rpri: int32 = 0
        if ms_primary == 0:
            lpri = 1
        else:
            rpri = 1
        _draw_toggle(MS_PRI_L_X, MS_PRI_Y, MS_TGL_W, MS_TGL_H,
                     cast[Ptr[uint8]]("Left"), lpri, fg)
        _draw_toggle(MS_PRI_R_X, MS_PRI_Y, MS_TGL_W, MS_TGL_H,
                     cast[Ptr[uint8]]("Right"), rpri, fg)
        hamscene_glyphs(PANE_X, MS_SCR_Y + 6,
                        cast[Ptr[uint8]]("Scroll:"), fg)
        sstd: int32 = 0
        snat: int32 = 0
        if ms_natural == 0:
            sstd = 1
        else:
            snat = 1
        _draw_toggle(MS_SCR_S_X, MS_SCR_Y, MS_SCR_W, MS_TGL_H,
                     cast[Ptr[uint8]]("Standard"), sstd, fg)
        _draw_toggle(MS_SCR_N_X, MS_SCR_Y, MS_SCR_W, MS_TGL_H,
                     cast[Ptr[uint8]]("Natural"), snat, fg)
    elif sel_cat == CAT_KEYBOARD:
        hamscene_glyphs_bold(PANE_X, PANE_Y, cast[Ptr[uint8]]("Keyboard"), fg)
        hamscene_glyphs(PANE_X, KB_DLY_Y + 6,
                        cast[Ptr[uint8]]("Repeat delay:"), fg)
        dly: Array[16, uint8]
        dl: uint64 = _ctl_u64_to_dec(cast[uint64](kb_delay), &dly[0])
        dly[dl] = 32
        dly[dl+1] = 109                                 # 'm'
        dly[dl+2] = 115                                 # 's'
        dly[dl+3] = 0
        _draw_stepper(KB_DLY_DEC_X, KB_DLY_INC_X, KB_DLY_Y, &dly[0], fg)
        hamscene_glyphs(PANE_X, KB_RAT_Y + 6,
                        cast[Ptr[uint8]]("Repeat rate:"), fg)
        rat: Array[16, uint8]
        rt: uint64 = _ctl_u64_to_dec(cast[uint64](kb_rate), &rat[0])
        rat[rt] = 47                                    # '/'
        rat[rt+1] = 115                                 # 's'
        rat[rt+2] = 0
        _draw_stepper(KB_RAT_DEC_X, KB_RAT_INC_X, KB_RAT_Y, &rat[0], fg)
        hamscene_glyphs(PANE_X, 178, cast[Ptr[uint8]]("Layout:"), fg)
        hamscene_glyphs_bold(PANE_X + 130, 178, &kb_layout[0],
                             cast[Ptr[uint8]]("#204060"))
        hamscene_glyphs(PANE_X, 214,
                        cast[Ptr[uint8]]("Layout is live; repeat persists (sink WIP)."),
                        cast[Ptr[uint8]]("#606060"))
    elif sel_cat == CAT_SOUND:
        hamscene_glyphs_bold(PANE_X, PANE_Y, cast[Ptr[uint8]]("Sound"), fg)
        hamscene_glyphs(PANE_X, PANE_Y + 30,
                        cast[Ptr[uint8]]("Output device:"), fg)
        dcol: Ptr[uint8] = cast[Ptr[uint8]]("#204060")
        if snd_present == 0:
            dcol = cast[Ptr[uint8]]("#a03030")
        hamscene_glyphs_bold(PANE_X + 130, PANE_Y + 30, &snd_name[0], dcol)
        hamscene_glyphs(PANE_X, SND_VOL_Y + 6, cast[Ptr[uint8]]("Volume:"), fg)
        vol: Array[8, uint8]
        vp: uint64 = _ctl_u64_to_dec(cast[uint64](snd_vol), &vol[0])
        vol[vp] = 37                                    # '%'
        vol[vp+1] = 0
        _draw_stepper(SND_VOL_DEC_X, SND_VOL_INC_X, SND_VOL_Y, &vol[0], fg)
        hamscene_glyphs(PANE_X, SND_MUTE_Y + 6, cast[Ptr[uint8]]("Mute:"), fg)
        mlabel: Ptr[uint8] = cast[Ptr[uint8]]("Off")
        if snd_mute != 0:
            mlabel = cast[Ptr[uint8]]("On")
        _draw_toggle(SND_MUTE_X, SND_MUTE_Y, SND_MUTE_W, SND_MUTE_H,
                     mlabel, snd_mute, fg)
        hamscene_glyphs(PANE_X, SND_MUTE_Y + 44,
                        cast[Ptr[uint8]]("No mixer yet; volume/mute persist (sink WIP)."),
                        cast[Ptr[uint8]]("#606060"))
    elif sel_cat == CAT_POWER:
        hamscene_glyphs_bold(PANE_X, PANE_Y, cast[Ptr[uint8]]("Power & Session"), fg)
        hamscene_glyphs(PANE_X, PANE_Y + 30, cast[Ptr[uint8]]("Uptime:"), fg)
        hamscene_glyphs_bold(PANE_X + 130, PANE_Y + 30, &pw_uptime[0],
                             cast[Ptr[uint8]]("#204060"))
        hamscene_glyphs(PANE_X, PANE_Y + 54, cast[Ptr[uint8]]("Power source:"), fg)
        hamscene_glyphs_bold(PANE_X + 130, PANE_Y + 54, &pw_source[0],
                             cast[Ptr[uint8]]("#204060"))
        pwl0: Ptr[uint8] = cast[Ptr[uint8]]("Lock Screen")
        pwl1: Ptr[uint8] = cast[Ptr[uint8]]("Log Out")
        pwl2: Ptr[uint8] = cast[Ptr[uint8]]("Shut Down")
        pwl3: Ptr[uint8] = cast[Ptr[uint8]]("Reboot")
        pb: uint64 = 0
        while pb < 4:
            byy: int32 = _pw_btn_y(pb)
            hamscene_panel_button(PW_BTN_X, byy, PW_BTN_W, PW_BTN_H, 0)
            lbl: Ptr[uint8] = pwl0
            if pb == 1:
                lbl = pwl1
            elif pb == 2:
                lbl = pwl2
            elif pb == 3:
                lbl = pwl3
            hamscene_glyphs(PW_BTN_X + 12, byy + 8, lbl, fg)
            pb = pb + 1
    elif sel_cat == CAT_NETWORK:
        hamscene_glyphs_bold(PANE_X, PANE_Y, cast[Ptr[uint8]]("Network"), fg)
        hamscene_glyphs(PANE_X, PANE_Y + 30, cast[Ptr[uint8]]("Interface:"), fg)
        hamscene_glyphs_bold(PANE_X + 110, PANE_Y + 30,
                             cast[Ptr[uint8]]("eth0"), cast[Ptr[uint8]]("#204060"))
        hamscene_glyphs(PANE_X, PANE_Y + 52, cast[Ptr[uint8]]("Address:"), fg)
        hamscene_glyphs_bold(PANE_X + 110, PANE_Y + 52, &net_addr[0],
                             cast[Ptr[uint8]]("#204060"))
        hamscene_glyphs(PANE_X, PANE_Y + 74, cast[Ptr[uint8]]("Netmask:"), fg)
        hamscene_glyphs_bold(PANE_X + 110, PANE_Y + 74, &net_mask[0],
                             cast[Ptr[uint8]]("#204060"))
        hamscene_glyphs(PANE_X, PANE_Y + 96, cast[Ptr[uint8]]("Gateway:"), fg)
        hamscene_glyphs_bold(PANE_X + 110, PANE_Y + 96, &net_gw[0],
                             cast[Ptr[uint8]]("#204060"))
        hamscene_glyphs(PANE_X, PANE_Y + 118, cast[Ptr[uint8]]("DNS:"), fg)
        hamscene_glyphs_bold(PANE_X + 110, PANE_Y + 118, &net_dns[0],
                             cast[Ptr[uint8]]("#204060"))
        hamscene_glyphs(PANE_X, PANE_Y + 140, cast[Ptr[uint8]]("Source:"), fg)
        hamscene_glyphs_bold(PANE_X + 110, PANE_Y + 140, &net_src[0],
                             cast[Ptr[uint8]]("#204060"))
        hamscene_glyphs(PANE_X, NET_DNS_Y - 18,
                        cast[Ptr[uint8]]("Set DNS server:"), fg)
        _draw_toggle(NET_DNS_G_X, NET_DNS_Y, NET_DNS_W, NET_DNS_H,
                     cast[Ptr[uint8]]("8.8.8.8"), _eq1(net_dns_pref, 1), fg)
        _draw_toggle(NET_DNS_C_X, NET_DNS_Y, NET_DNS_W, NET_DNS_H,
                     cast[Ptr[uint8]]("1.1.1.1"), _eq1(net_dns_pref, 2), fg)
        hamscene_glyphs(PANE_X, NET_DNS_Y + 40,
                        cast[Ptr[uint8]]("DNS change is a live kernel sink (SET_DNS)."),
                        cast[Ptr[uint8]]("#606060"))
    else:
        hamscene_glyphs_bold(PANE_X, PANE_Y, cast[Ptr[uint8]]("About This System"), fg)
        i2: uint64 = 0
        while i2 < about_n:
            ly: int32 = PANE_Y + 28 + cast[int32](i2) * 22
            hamscene_glyphs_bold(PANE_X, ly, _about_lbl_ptr(i2), fg)
            hamscene_glyphs(PANE_X + 130, ly, _about_val_ptr(i2),
                            cast[Ptr[uint8]]("#204060"))
            i2 = i2 + 1


# ---- input ---------------------------------------------------------------
def _in(x: int64, y: int64, bx: int32, by: int32, bw: int32, bh: int32) -> int32:
    if x >= cast[int64](bx) and x < cast[int64](bx + bw) \
            and y >= cast[int64](by) and y < cast[int64](by + bh):
        return 1
    return 0


# Action codes returned by hamctl_click:
ACT_NONE:    int32 = 0
ACT_CAT:     int32 = 1         # category changed — just re-render
ACT_WALL:    int32 = 2         # swatch chosen — driver applies wallpaper
ACT_TZ:      int32 = 3         # tz changed — driver persists + refreshes time
ACT_DISPLAY: int32 = 4         # UI scale changed — driver persists display.conf
ACT_MOUSE:   int32 = 5         # mouse pref changed — driver persists mouse.conf
ACT_KBD:     int32 = 6         # kbd repeat changed — driver persists kbd.conf
ACT_WALLIMG: int32 = 7         # image wallpaper chosen — driver renders+applies
ACT_SOUND:    int32 = 8        # sound pref changed — driver persists sound.conf
ACT_LOCK:     int32 = 9        # Lock Screen — driver spawns /bin/hamlock
ACT_LOGOUT:   int32 = 10       # Log Out — driver writes runlevel 3 to /proc/svc/ctl
ACT_SHUTDOWN: int32 = 11       # Shut Down — driver writes poweroff to /dev/reboot
ACT_REBOOT:   int32 = 12       # Reboot — driver writes reboot to /dev/reboot
ACT_NET:      int32 = 13       # DNS preset chosen — driver calls SYS_NETCFG SET_DNS


def hamctl_click(x: int64, y: int64) -> int32:
    # sidebar category buttons (always visible)
    c: uint64 = 0
    while c < N_CAT:
        by: int32 = _side_btn_y(c)
        if _in(x, y, SIDE_BTN_X, by, SIDE_BTN_W, SIDE_BTN_H) != 0:
            sel_cat = cast[int32](c)
            return ACT_CAT
        c = c + 1

    if sel_cat == CAT_APPEARANCE:
        if y >= cast[int64](SW_Y) and y < cast[int64](SW_Y + SW_SZ):
            i: uint64 = 0
            while i < N_SWATCH:
                sx: int64 = cast[int64](_swatch_x(i))
                if x >= sx and x < sx + cast[int64](SW_SZ):
                    sel_swatch = cast[int32](i)
                    sel_kind = 0
                    return ACT_WALL
                i = i + 1
        im2: uint64 = 0
        while im2 < N_IMAGE:
            tx2: int32 = IMG_TH_X + cast[int32](im2) * (IMG_TH_W + IMG_TH_GAP)
            if _in(x, y, tx2, IMG_TH_Y, IMG_TH_W, IMG_TH_H) != 0:
                sel_kind = 1
                sel_image = cast[int32](im2)
                return ACT_WALLIMG
            im2 = im2 + 1
    elif sel_cat == CAT_DATETIME:
        if _in(x, y, TZ_DEC_X, TZ_BTN_Y, TZ_BTN_W, TZ_BTN_H) != 0:
            hamctl_set_tz(tz_off - 1)
            return ACT_TZ
        if _in(x, y, TZ_INC_X, TZ_BTN_Y, TZ_BTN_W, TZ_BTN_H) != 0:
            hamctl_set_tz(tz_off + 1)
            return ACT_TZ
    elif sel_cat == CAT_DISPLAY:
        if _in(x, y, DSC_DEC_X, DSC_Y, STEP_W, STEP_H) != 0:
            hamctl_set_disp_scale(disp_scale - 1)
            return ACT_DISPLAY
        if _in(x, y, DSC_INC_X, DSC_Y, STEP_W, STEP_H) != 0:
            hamctl_set_disp_scale(disp_scale + 1)
            return ACT_DISPLAY
    elif sel_cat == CAT_MOUSE:
        if _in(x, y, MS_SPD_DEC_X, MS_SPD_Y, STEP_W, STEP_H) != 0:
            if ms_speed > 1:
                ms_speed = ms_speed - 1
            return ACT_MOUSE
        if _in(x, y, MS_SPD_INC_X, MS_SPD_Y, STEP_W, STEP_H) != 0:
            if ms_speed < 10:
                ms_speed = ms_speed + 1
            return ACT_MOUSE
        if _in(x, y, MS_PRI_L_X, MS_PRI_Y, MS_TGL_W, MS_TGL_H) != 0:
            ms_primary = 0
            return ACT_MOUSE
        if _in(x, y, MS_PRI_R_X, MS_PRI_Y, MS_TGL_W, MS_TGL_H) != 0:
            ms_primary = 1
            return ACT_MOUSE
        if _in(x, y, MS_SCR_S_X, MS_SCR_Y, MS_SCR_W, MS_TGL_H) != 0:
            ms_natural = 0
            return ACT_MOUSE
        if _in(x, y, MS_SCR_N_X, MS_SCR_Y, MS_SCR_W, MS_TGL_H) != 0:
            ms_natural = 1
            return ACT_MOUSE
    elif sel_cat == CAT_KEYBOARD:
        if _in(x, y, KB_DLY_DEC_X, KB_DLY_Y, STEP_W, STEP_H) != 0:
            if kb_delay > 200:
                kb_delay = kb_delay - 50
            return ACT_KBD
        if _in(x, y, KB_DLY_INC_X, KB_DLY_Y, STEP_W, STEP_H) != 0:
            if kb_delay < 1000:
                kb_delay = kb_delay + 50
            return ACT_KBD
        if _in(x, y, KB_RAT_DEC_X, KB_RAT_Y, STEP_W, STEP_H) != 0:
            if kb_rate > 2:
                kb_rate = kb_rate - 2
            return ACT_KBD
        if _in(x, y, KB_RAT_INC_X, KB_RAT_Y, STEP_W, STEP_H) != 0:
            if kb_rate < 40:
                kb_rate = kb_rate + 2
            return ACT_KBD
    elif sel_cat == CAT_SOUND:
        if _in(x, y, SND_VOL_DEC_X, SND_VOL_Y, STEP_W, STEP_H) != 0:
            if snd_vol > 0:
                snd_vol = snd_vol - 10
            return ACT_SOUND
        if _in(x, y, SND_VOL_INC_X, SND_VOL_Y, STEP_W, STEP_H) != 0:
            if snd_vol < 100:
                snd_vol = snd_vol + 10
            return ACT_SOUND
        if _in(x, y, SND_MUTE_X, SND_MUTE_Y, SND_MUTE_W, SND_MUTE_H) != 0:
            if snd_mute == 0:
                snd_mute = 1
            else:
                snd_mute = 0
            return ACT_SOUND
    elif sel_cat == CAT_POWER:
        pb: uint64 = 0
        while pb < 4:
            byy: int32 = _pw_btn_y(pb)
            if _in(x, y, PW_BTN_X, byy, PW_BTN_W, PW_BTN_H) != 0:
                if pb == 0:
                    return ACT_LOCK
                if pb == 1:
                    return ACT_LOGOUT
                if pb == 2:
                    return ACT_SHUTDOWN
                return ACT_REBOOT
            pb = pb + 1
    elif sel_cat == CAT_NETWORK:
        if _in(x, y, NET_DNS_G_X, NET_DNS_Y, NET_DNS_W, NET_DNS_H) != 0:
            net_dns_pref = 1
            return ACT_NET
        if _in(x, y, NET_DNS_C_X, NET_DNS_Y, NET_DNS_W, NET_DNS_H) != 0:
            net_dns_pref = 2
            return ACT_NET
    return ACT_NONE


def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                             # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc = acc * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc = 0 - acc
        vals[v] = acc
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1

# lib/appmenucore.ad — the PURE, extern-free MATE-style Applications-menu
# MODEL + renderer, shared by the native menu client and the host render gate.
#
# WHY THIS FILE EXISTS
# ====================
# The Applications menu (/bin/hamappmenu, spawned by the compositor on the
# Apps trigger) used to be a CASCADING category column whose apps only
# appeared on hover, with no way to search and no memory of what you last
# launched. As the app catalogue grew it read as "one flat crowded list".
#
# This module is the single source of truth for a MATE-authentic menu:
#   * apps GROUPED BY CATEGORY, each category a bold HEADER above its apps
#     (Accessories / Graphics / Internet / Office / Games / System /
#     Settings / Other) — one vertical column, everything visible at once;
#   * a SEARCH box at the top that live-filters the visible apps by name;
#   * a RECENT section listing the most-recently-launched apps at the top.
#
# It is PURE (no `extern`, no I/O): it operates only on caller-supplied
# strings and its own module-scope arrays, and imports only lib/hamscene.ad.
# So it links into BOTH the x86_64-adder-user (native menu client) target
# AND the x86_64-linux (host render-to-PNG gate) target unchanged. The
# native client walks the ROW MODEL (amc_row_*) and paints it with hamui v2
# blits; the host driver renders the SAME model to a PNG through hamscene —
# so grouping / search / recent are proven identical on the host in ms.
#
# NOTE ON CATEGORIES: this module does its OWN freedesktop classification
# from the raw `Categories=` string into a richer MATE bucket set, kept
# LOCAL to the menu display. It deliberately does NOT reuse (or perturb)
# lib/desktopentry.ad's DE_CAT_* codes, which the panel (hampanelscene) uses
# for its own flat sort + Linux-namespace launch discriminator.

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_stroke, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_roundrect, \
    hamscene_icon_draw, hamscene_icon_code


# ---- MATE menu buckets (display order == numeric order) ------------------
AMC_ACCESSORIES: int32 = 0
AMC_GRAPHICS:    int32 = 1
AMC_INTERNET:    int32 = 2
AMC_OFFICE:      int32 = 3
AMC_GAMES:       int32 = 4
AMC_MULTIMEDIA:  int32 = 5                # "Sound & Video" (freedesktop AudioVideo)
AMC_SYSTEM:      int32 = 6
AMC_SETTINGS:    int32 = 7
AMC_OTHER:       int32 = 8
AMC_CAT_COUNT:   int32 = 9

# ---- geometry ------------------------------------------------------------
AMC_ROW_H:    int32 = 20
AMC_GLYPH_W:  int32 = 8                  # host + compositor 8x16 mono cell
AMC_BOX_W:    int32 = 208
AMC_PAD_L:    int32 = 10
AMC_ICON_SZ:  int32 = 16                 # real #285 per-app icon (matches panel)
AMC_ICON_PAD: int32 = 4
AMC_CHILD_W:  int32 = 200                # category hover fly-out width

# ---- capacities ----------------------------------------------------------
AMC_MAX_APPS:   uint64 = 48
AMC_NAME_CAP:   uint64 = 48
AMC_PROG_CAP:   uint64 = 96
AMC_MAX_ROWS:   uint64 = 80
AMC_FILTER_CAP: uint64 = 40
AMC_RECENT_CAP: uint64 = 8
AMC_RECENT_SHOW: int32 = 3               # rows shown in the Recent section

# ---- row kinds -----------------------------------------------------------
# SEARCH  — the top search field (always row 0).
# HEADER  — an inline bold category strip (used for the Recent section, and
#           for category sections ONLY while a search filter is active).
# APP     — a launchable app row (Recent apps; filtered-search results).
# CATBTN  — a category PARENT BUTTON row ("Accessories ▸", …). Hovering it
#           opens a CHILD FLY-OUT box listing that category's apps, mirroring
#           the panel's "Linux apps ▸" hover submenu. Category apps are NOT
#           listed inline; they live behind the fly-out. Emitted only when the
#           filter is empty (you can't hover categories mid-search).
AMC_ROW_SEARCH: int32 = 0
AMC_ROW_HEADER: int32 = 1
AMC_ROW_APP:    int32 = 2
AMC_ROW_CATBTN: int32 = 3

# A header row whose category field is this value is the "Recent" header.
AMC_HDR_RECENT: int32 = -2


# ---- app model -----------------------------------------------------------
_amc_count: uint64 = 0
_amc_name:     Array[48, Array[48, uint8]]
_amc_name_len: Array[48, uint64]
_amc_prog:     Array[48, Array[96, uint8]]
_amc_prog_len: Array[48, uint64]
_amc_cat:      Array[48, int32]
_amc_glyph:    Array[48, uint8]

# ---- recent (most-recently-launched prog paths, front == newest) ---------
_amc_recent_count: uint64 = 0
_amc_recent:     Array[8, Array[96, uint8]]
_amc_recent_len: Array[8, uint64]

# ---- live search filter (lowercased) -------------------------------------
_amc_filter:     Array[40, uint8]
_amc_filter_len: uint64 = 0

# ---- laid-out visible rows -----------------------------------------------
_amc_row_count: uint64 = 0
_amc_row_kind:  Array[80, int32]
_amc_row_cat:   Array[80, int32]         # HEADER: bucket code / AMC_HDR_RECENT
_amc_row_app:   Array[80, int32]         # APP: app index; else -1
_amc_row_y:     Array[80, int32]         # window-local top y of the row

# ---- category hover fly-out (the CHILD popup of a CATBTN parent) ----------
# Mirrors hampanelscene's "Linux apps" fly-out: at most ONE category is open
# at a time; its box is aligned to the parent CATBTN row and clamped inside
# the (grown) menu window. _amc_open_cat == -1 means no fly-out is showing.
_amc_open_cat:     int32 = -1
_amc_child_count:  uint64 = 0
_amc_child_app:    Array[48, int32]      # app indices shown in the fly-out
_amc_child_x:      int32 = 0             # fly-out box geometry (window-local)
_amc_child_y:      int32 = 0
_amc_child_w:      int32 = 0
_amc_child_h:      int32 = 0


# ---- tiny string helpers -------------------------------------------------
def _amc_slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _amc_lower(c: uint8) -> uint8:
    if c >= 65 and c <= 90:
        return c + 32
    return c


# ---- freedesktop classification (LOCAL to the menu) ----------------------
# Does the NUL-terminated `lit` occur as a substring anywhere in `cats`?
def _amc_cats_has(cats: Ptr[uint8], lit: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while cats[i] != 0:
        k: uint64 = 0
        j: uint64 = i
        while cats[j] != 0 and lit[k] != 0 and cats[j] == lit[k]:
            j = j + 1
            k = k + 1
        if lit[k] == 0:
            return 1
        i = i + 1
    return 0


# Classify a raw `Categories=` string to ONE MATE bucket (priority order).
def amc_classify(cats: Ptr[uint8]) -> int32:
    if _amc_cats_has(cats, cast[Ptr[uint8]]("Game")) != 0:
        return AMC_GAMES
    if _amc_cats_has(cats, cast[Ptr[uint8]]("Office")) != 0:
        return AMC_OFFICE
    if _amc_cats_has(cats, cast[Ptr[uint8]]("AudioVideo")) != 0:
        return AMC_MULTIMEDIA
    if _amc_cats_has(cats, cast[Ptr[uint8]]("Multimedia")) != 0:
        return AMC_MULTIMEDIA
    if _amc_cats_has(cats, cast[Ptr[uint8]]("Video")) != 0:
        return AMC_MULTIMEDIA
    if _amc_cats_has(cats, cast[Ptr[uint8]]("Audio")) != 0:
        return AMC_MULTIMEDIA
    if _amc_cats_has(cats, cast[Ptr[uint8]]("Graphics")) != 0:
        return AMC_GRAPHICS
    if _amc_cats_has(cats, cast[Ptr[uint8]]("Network")) != 0:
        return AMC_INTERNET
    if _amc_cats_has(cats, cast[Ptr[uint8]]("Settings")) != 0:
        return AMC_SETTINGS
    if _amc_cats_has(cats, cast[Ptr[uint8]]("System")) != 0:
        return AMC_SYSTEM
    if _amc_cats_has(cats, cast[Ptr[uint8]]("Utility")) != 0:
        return AMC_ACCESSORIES
    if _amc_cats_has(cats, cast[Ptr[uint8]]("Accessories")) != 0:
        return AMC_ACCESSORIES
    return AMC_OTHER


# Human header label for a bucket code.
def amc_cat_name(code: int32) -> Ptr[uint8]:
    if code == AMC_HDR_RECENT:
        r: Ptr[uint8] = "Recent"
        return r
    if code == AMC_ACCESSORIES:
        a: Ptr[uint8] = "Accessories"
        return a
    if code == AMC_GRAPHICS:
        g: Ptr[uint8] = "Graphics"
        return g
    if code == AMC_INTERNET:
        n: Ptr[uint8] = "Internet"
        return n
    if code == AMC_OFFICE:
        o: Ptr[uint8] = "Office"
        return o
    if code == AMC_GAMES:
        m: Ptr[uint8] = "Games"
        return m
    if code == AMC_MULTIMEDIA:
        v: Ptr[uint8] = "Sound & Video"
        return v
    if code == AMC_SYSTEM:
        s: Ptr[uint8] = "System"
        return s
    if code == AMC_SETTINGS:
        t: Ptr[uint8] = "Settings"
        return t
    e: Ptr[uint8] = "Other"
    return e


# Category icon-box colour (hex for the scene renderer).
def amc_cat_hex(code: int32) -> Ptr[uint8]:
    if code == AMC_HDR_RECENT:
        r: Ptr[uint8] = "#c9a84a"
        return r
    if code == AMC_ACCESSORIES:
        a: Ptr[uint8] = "#5a8a4a"
        return a
    if code == AMC_GRAPHICS:
        g: Ptr[uint8] = "#a05aa0"
        return g
    if code == AMC_INTERNET:
        n: Ptr[uint8] = "#3c64a0"
        return n
    if code == AMC_OFFICE:
        o: Ptr[uint8] = "#b0703c"
        return o
    if code == AMC_GAMES:
        m: Ptr[uint8] = "#966e3c"
        return m
    if code == AMC_MULTIMEDIA:
        v: Ptr[uint8] = "#c05a4a"
        return v
    if code == AMC_SYSTEM:
        s: Ptr[uint8] = "#787850"
        return s
    if code == AMC_SETTINGS:
        t: Ptr[uint8] = "#6e5096"
        return t
    e: Ptr[uint8] = "#5a5a6e"
    return e


# Category icon-box colour as three rgb bytes (for the native hamui-v2 client).
def amc_cat_rgb(code: int32, out: Ptr[uint8]):
    if code == AMC_HDR_RECENT:
        out[0] = 201
        out[1] = 168
        out[2] = 74
    elif code == AMC_ACCESSORIES:
        out[0] = 90
        out[1] = 138
        out[2] = 74
    elif code == AMC_GRAPHICS:
        out[0] = 160
        out[1] = 90
        out[2] = 160
    elif code == AMC_INTERNET:
        out[0] = 60
        out[1] = 100
        out[2] = 160
    elif code == AMC_OFFICE:
        out[0] = 176
        out[1] = 112
        out[2] = 60
    elif code == AMC_GAMES:
        out[0] = 150
        out[1] = 110
        out[2] = 60
    elif code == AMC_MULTIMEDIA:
        out[0] = 192
        out[1] = 90
        out[2] = 74
    elif code == AMC_SYSTEM:
        out[0] = 120
        out[1] = 120
        out[2] = 80
    elif code == AMC_SETTINGS:
        out[0] = 110
        out[1] = 80
        out[2] = 150
    else:
        out[0] = 90
        out[1] = 90
        out[2] = 110


# ====================================================================
# REAL per-app icons (#285) — resolve the SAME glyph the panel launcher,
# the desktop icons and the taskbar draw, so the menu rows carry real
# artwork instead of a flat colour chip. Keyword-matched off the app's
# prog PATH (already lower-case, e.g. /bin/hamterm), mapped to a
# freedesktop Icon= name that hamscene_icon_code understands — mirroring
# hampanelscene._task_icon so the menu / taskbar / desktop stay in lockstep.
# ====================================================================
# Substring test: 1 iff NUL-terminated `needle` occurs in `hay`.
def _amc_substr(hay: Ptr[uint8], needle: Ptr[uint8]) -> int32:
    if needle[0] == 0:
        return 0
    i: uint64 = 0
    while hay[i] != 0:
        j: uint64 = 0
        while needle[j] != 0 and hay[i + j] == needle[j]:
            j = j + 1
        if needle[j] == 0:
            return 1
        i = i + 1
    return 0


# Freedesktop Icon= name for app `a`, keyed off its prog path. "" -> the
# generic page fallback (HS_ICON_FILE). Order matters (specific first).
def _amc_app_icon_name(a: uint64) -> Ptr[uint8]:
    p: Ptr[uint8] = &_amc_prog[a][0]
    if _amc_substr(p, cast[Ptr[uint8]]("term")) != 0:
        r: Ptr[uint8] = "terminal"
        return r
    if _amc_substr(p, cast[Ptr[uint8]]("hamcal")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("calendar")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("clock")) != 0:
        r2: Ptr[uint8] = "office-calendar"
        return r2
    if _amc_substr(p, cast[Ptr[uint8]]("calc")) != 0:
        r3: Ptr[uint8] = "accessories-calculator"
        return r3
    if _amc_substr(p, cast[Ptr[uint8]]("hamfm")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("files")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("file-manager")) != 0:
        r4: Ptr[uint8] = "system-file-manager"
        return r4
    if _amc_substr(p, cast[Ptr[uint8]]("mon")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("sysmon")) != 0:
        r5: Ptr[uint8] = "utilities-system-monitor"
        return r5
    if _amc_substr(p, cast[Ptr[uint8]]("brows")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("web")) != 0:
        r6: Ptr[uint8] = "web-browser"
        return r6
    if _amc_substr(p, cast[Ptr[uint8]]("edit")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("note")) != 0:
        r7: Ptr[uint8] = "accessories-text-editor"
        return r7
    if _amc_substr(p, cast[Ptr[uint8]]("install")) != 0:
        r8: Ptr[uint8] = "system-installer"
        return r8
    if _amc_substr(p, cast[Ptr[uint8]]("2048")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("game")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("snake")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("chess")) != 0:
        r9: Ptr[uint8] = "ham2048"
        return r9
    if _amc_substr(p, cast[Ptr[uint8]]("view")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("image")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("shot")) != 0:
        r10: Ptr[uint8] = "applets-screenshooter"
        return r10
    if _amc_substr(p, cast[Ptr[uint8]]("ctl")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("control")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("setting")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("hpm")) != 0 \
            or _amc_substr(p, cast[Ptr[uint8]]("package")) != 0:
        r11: Ptr[uint8] = "preferences-system"
        return r11
    e: Ptr[uint8] = ""
    return e


# Icon glyph CODE for app `a` (ready for hamscene_icon_draw).
def amc_app_icon_code(a: uint64) -> int32:
    return hamscene_icon_code(_amc_app_icon_name(a))


# Representative Icon= name for a category PARENT button, so the CATBTN
# rows carry real artwork too. "" -> generic page.
def _amc_cat_icon_name(code: int32) -> Ptr[uint8]:
    if code == AMC_ACCESSORIES:
        a: Ptr[uint8] = "accessories-text-editor"
        return a
    if code == AMC_GRAPHICS:
        g: Ptr[uint8] = "applets-screenshooter"
        return g
    if code == AMC_INTERNET:
        n: Ptr[uint8] = "web-browser"
        return n
    if code == AMC_OFFICE:
        o: Ptr[uint8] = "office-calendar"
        return o
    if code == AMC_GAMES:
        m: Ptr[uint8] = "ham2048"
        return m
    if code == AMC_SYSTEM:
        s: Ptr[uint8] = "utilities-system-monitor"
        return s
    if code == AMC_SETTINGS:
        t: Ptr[uint8] = "preferences-system"
        return t
    e: Ptr[uint8] = ""
    return e


def amc_cat_icon_code(code: int32) -> int32:
    return hamscene_icon_code(_amc_cat_icon_name(code))


# ====================================================================
# MODEL population
# ====================================================================
def amc_reset():
    _amc_count = 0
    _amc_filter_len = 0
    _amc_filter[0] = 0
    _amc_open_cat = -1
    _amc_child_count = 0


# Append an app. `cats` is the raw freedesktop Categories= string (may be
# empty). The glyph is the one-letter icon drawn in the icon box.
def amc_add(name: Ptr[uint8], prog: Ptr[uint8], cats: Ptr[uint8],
            glyph: uint8):
    if _amc_count >= AMC_MAX_APPS:
        return
    i: uint64 = _amc_count
    nl: uint64 = _amc_slen(name)
    if nl >= AMC_NAME_CAP:
        nl = AMC_NAME_CAP - 1
    k: uint64 = 0
    while k < nl:
        _amc_name[i][k] = name[k]
        k = k + 1
    _amc_name[i][nl] = 0
    _amc_name_len[i] = nl
    pl: uint64 = _amc_slen(prog)
    if pl >= AMC_PROG_CAP:
        pl = AMC_PROG_CAP - 1
    k = 0
    while k < pl:
        _amc_prog[i][k] = prog[k]
        k = k + 1
    _amc_prog[i][pl] = 0
    _amc_prog_len[i] = pl
    _amc_cat[i] = amc_classify(cats)
    _amc_glyph[i] = glyph
    _amc_count = _amc_count + 1


def amc_app_count() -> uint64:
    return _amc_count


# ====================================================================
# RECENT tracking
# ====================================================================
def _amc_prog_eq(a: Ptr[uint8], alen: uint64, i: uint64) -> int32:
    if _amc_recent_len[i] != alen:
        return 0
    k: uint64 = 0
    while k < alen:
        if _amc_recent[i][k] != a[k]:
            return 0
        k = k + 1
    return 1


# Record a launch: move `prog` to the front of the recent list (dedup),
# capped at AMC_RECENT_CAP. In-memory; a caller may persist/reload the list
# via amc_recent_* accessors.
def amc_mark_launch(prog: Ptr[uint8]):
    pl: uint64 = _amc_slen(prog)
    if pl >= AMC_PROG_CAP:
        pl = AMC_PROG_CAP - 1
    # Find an existing slot for this prog.
    found: int64 = -1
    i: uint64 = 0
    while i < _amc_recent_count:
        if _amc_prog_eq(prog, pl, i) != 0:
            found = cast[int64](i)
        i = i + 1
    top: uint64 = _amc_recent_count
    if found >= 0:
        top = cast[uint64](found)          # shift everything above it down
    elif top >= AMC_RECENT_CAP:
        top = AMC_RECENT_CAP - 1           # drop the oldest
    else:
        _amc_recent_count = _amc_recent_count + 1
    # Shift [0..top) down by one to open slot 0.
    j: uint64 = top
    while j > 0:
        c: uint64 = 0
        while c < AMC_PROG_CAP:
            _amc_recent[j][c] = _amc_recent[j - 1][c]
            c = c + 1
        _amc_recent_len[j] = _amc_recent_len[j - 1]
        j = j - 1
    k: uint64 = 0
    while k < pl:
        _amc_recent[0][k] = prog[k]
        k = k + 1
    _amc_recent[0][pl] = 0
    _amc_recent_len[0] = pl


def amc_recent_count() -> uint64:
    return _amc_recent_count


# The app index whose prog matches recent slot `r`, or -1 if that recent
# prog is no longer in the catalogue.
def _amc_recent_app(r: uint64) -> int32:
    rl: uint64 = _amc_recent_len[r]
    a: uint64 = 0
    while a < _amc_count:
        if _amc_prog_len[a] == rl:
            k: uint64 = 0
            same: int32 = 1
            while k < rl:
                if _amc_prog[a][k] != _amc_recent[r][k]:
                    same = 0
                k = k + 1
            if same != 0:
                return cast[int32](a)
        a = a + 1
    return -1


# ====================================================================
# SEARCH filter
# ====================================================================
def amc_set_filter(s: Ptr[uint8]):
    n: uint64 = 0
    while s[n] != 0 and n + 1 < AMC_FILTER_CAP:
        _amc_filter[n] = _amc_lower(s[n])
        n = n + 1
    _amc_filter[n] = 0
    _amc_filter_len = n


def amc_filter_ptr() -> Ptr[uint8]:
    return &_amc_filter[0]


def amc_filter_len() -> uint64:
    return _amc_filter_len


# Append a character to the filter (for a keystroke).
def amc_filter_push(c: uint8):
    if _amc_filter_len + 1 < AMC_FILTER_CAP:
        _amc_filter[_amc_filter_len] = _amc_lower(c)
        _amc_filter_len = _amc_filter_len + 1
        _amc_filter[_amc_filter_len] = 0


# Delete the last filter character (backspace).
def amc_filter_backspace():
    if _amc_filter_len > 0:
        _amc_filter_len = _amc_filter_len - 1
        _amc_filter[_amc_filter_len] = 0


# Does app `a`'s name contain the current filter (case-insensitive)? An empty
# filter matches everything.
def _amc_app_matches(a: uint64) -> int32:
    if _amc_filter_len == 0:
        return 1
    nl: uint64 = _amc_name_len[a]
    if _amc_filter_len > nl:
        return 0
    i: uint64 = 0
    while i + _amc_filter_len <= nl:
        k: uint64 = 0
        while k < _amc_filter_len and \
                _amc_lower(_amc_name[a][i + k]) == _amc_filter[k]:
            k = k + 1
        if k == _amc_filter_len:
            return 1
        i = i + 1
    return 0


# ====================================================================
# CATEGORY HOVER FLY-OUT — the child popup of a CATBTN parent row.
# ====================================================================
# Row index of the CATBTN parent for category `cat` in the CURRENT layout, or
# -1 if that category has no parent button (e.g. it is empty, or the filter is
# active so categories render inline instead of as buttons).
def _amc_catbtn_row(cat: int32) -> int64:
    i: uint64 = 0
    while i < _amc_row_count:
        if _amc_row_kind[i] == AMC_ROW_CATBTN and _amc_row_cat[i] == cat:
            return cast[int64](i)
        i = i + 1
    return -1


# Open the hover fly-out for category `cat` (or -1 to close). Rebuilds the
# child app list (the matching apps in that bucket, in catalogue order). Only
# ONE category is ever open. Geometry is computed lazily by amc_child_layout.
def amc_set_open_cat(cat: int32):
    _amc_open_cat = cat
    _amc_child_count = 0
    if cat < 0:
        return
    a: uint64 = 0
    while a < _amc_count:
        if _amc_cat[a] == cat and _amc_app_matches(a) != 0:
            if _amc_child_count < AMC_MAX_APPS:
                _amc_child_app[_amc_child_count] = cast[int32](a)
                _amc_child_count = _amc_child_count + 1
        a = a + 1


def amc_open_cat() -> int32:
    return _amc_open_cat


def amc_child_count() -> uint64:
    return _amc_child_count


# App index shown in child fly-out row `i`.
def amc_child_app(i: uint64) -> int32:
    return _amc_child_app[i]


# ---- app-index accessors (the fly-out addresses apps by INDEX, not row) ----
def amc_app_name(a: uint64) -> Ptr[uint8]:
    return &_amc_name[a][0]


def amc_app_glyph(a: uint64) -> uint8:
    return _amc_glyph[a]


def amc_app_prog(a: uint64) -> Ptr[uint8]:
    return &_amc_prog[a][0]


def amc_app_prog_len(a: uint64) -> uint64:
    return _amc_prog_len[a]


def amc_app_cat(a: uint64) -> int32:
    return _amc_cat[a]


# Compute + cache the fly-out box geometry, aligned to the open category's
# parent CATBTN row and clamped inside the (grown) menu window [0..scr]. The
# menu content is anchored at (bx,by). Mirrors hampanelscene._compute_sub_box:
# the child opens to the RIGHT of the menu box (1px frame overlap) and flips to
# the LEFT if it would overflow scr_w. Call after amc_layout().
def amc_child_layout(bx: int32, by: int32, scr_w: int32, scr_h: int32):
    if _amc_open_cat < 0:
        _amc_child_w = 0
        _amc_child_h = 0
        return
    ch: int32 = cast[int32](_amc_child_count) * AMC_ROW_H
    if ch < AMC_ROW_H:
        ch = AMC_ROW_H
    pr: int64 = _amc_catbtn_row(_amc_open_cat)
    prtop: int32 = by
    if pr >= 0:
        prtop = by + _amc_row_y[cast[uint64](pr)]
    cy: int32 = prtop
    if cy + ch > scr_h:
        cy = scr_h - ch
    if cy < 0:
        cy = 0
    cx: int32 = bx + AMC_BOX_W - 1               # default: to the right
    if cx + AMC_CHILD_W > scr_w:
        cx = bx - AMC_CHILD_W + 1                # flip to the left
    if cx < 0:
        cx = 0
    _amc_child_x = cx
    _amc_child_y = cy
    _amc_child_w = AMC_CHILD_W
    _amc_child_h = ch


def amc_child_x() -> int32:
    return _amc_child_x


def amc_child_y() -> int32:
    return _amc_child_y


def amc_child_w() -> int32:
    return _amc_child_w


def amc_child_h() -> int32:
    return _amc_child_h


# Hit-test a point against the open fly-out. Returns the APP INDEX under
# (px,py) (ready to launch/mark), or -1 if the point is outside the fly-out.
def amc_child_hit(px: int32, py: int32) -> int64:
    if _amc_open_cat < 0 or _amc_child_count == 0:
        return -1
    if px < _amc_child_x or px >= _amc_child_x + _amc_child_w:
        return -1
    if py < _amc_child_y or py >= _amc_child_y + _amc_child_h:
        return -1
    li: int32 = (py - _amc_child_y) / AMC_ROW_H
    if li < 0 or cast[uint64](li) >= _amc_child_count:
        return -1
    return cast[int64](_amc_child_app[cast[uint64](li)])


# ====================================================================
# LAYOUT — build the visible single-column row list.
# ====================================================================
def _amc_push_row(kind: int32, cat: int32, app: int32, y: int32) -> int32:
    if _amc_row_count >= AMC_MAX_ROWS:
        return y
    i: uint64 = _amc_row_count
    _amc_row_kind[i] = kind
    _amc_row_cat[i] = cat
    _amc_row_app[i] = app
    _amc_row_y[i] = y
    _amc_row_count = _amc_row_count + 1
    return y + AMC_ROW_H


def amc_layout():
    _amc_row_count = 0
    y: int32 = 0
    # 1. Search box (always row 0).
    y = _amc_push_row(AMC_ROW_SEARCH, 0, -1, y)
    filtering: int32 = 0
    if _amc_filter_len > 0:
        filtering = 1
    # 2. Recent section — only when not filtering.
    if filtering == 0 and _amc_recent_count > 0:
        shown: int32 = 0
        r: uint64 = 0
        while r < _amc_recent_count and shown < AMC_RECENT_SHOW:
            ai: int32 = _amc_recent_app(r)
            if ai >= 0:
                if shown == 0:
                    y = _amc_push_row(AMC_ROW_HEADER, AMC_HDR_RECENT, -1, y)
                y = _amc_push_row(AMC_ROW_APP, AMC_HDR_RECENT, ai, y)
                shown = shown + 1
            r = r + 1
    # 3. Category sections in MATE order.
    #    * filter EMPTY  -> each non-empty category is a single CATBTN PARENT
    #      button; its apps live behind a hover fly-out (amc_child_*), NOT
    #      inline. Mirrors the panel's "Linux apps ▸" submenu.
    #    * filter ACTIVE -> you can't hover categories mid-search, so fall back
    #      to the flat, MATE-style grouped result (inline HEADER + APP rows).
    c: int32 = 0
    while c < AMC_CAT_COUNT:
        # Count matching apps in this bucket.
        matches: int32 = 0
        a: uint64 = 0
        while a < _amc_count:
            if _amc_cat[a] == c and _amc_app_matches(a) != 0:
                matches = matches + 1
            a = a + 1
        if matches > 0:
            if filtering != 0:
                y = _amc_push_row(AMC_ROW_HEADER, c, -1, y)
                a = 0
                while a < _amc_count:
                    if _amc_cat[a] == c and _amc_app_matches(a) != 0:
                        y = _amc_push_row(AMC_ROW_APP, c, cast[int32](a), y)
                    a = a + 1
            else:
                y = _amc_push_row(AMC_ROW_CATBTN, c, -1, y)
        c = c + 1
    # A fly-out that pointed at a now-absent category (e.g. the filter changed)
    # must not linger; drop it unless its category still has a parent button.
    if _amc_open_cat >= 0 and _amc_catbtn_row(_amc_open_cat) < 0:
        amc_set_open_cat(-1)


def amc_row_count() -> uint64:
    return _amc_row_count


def amc_row_kind(i: uint64) -> int32:
    return _amc_row_kind[i]


def amc_row_cat(i: uint64) -> int32:
    return _amc_row_cat[i]


def amc_row_app(i: uint64) -> int32:
    return _amc_row_app[i]


def amc_row_y(i: uint64) -> int32:
    return _amc_row_y[i]


# Total laid-out content height (for window sizing).
def amc_content_h() -> int32:
    return cast[int32](_amc_row_count) * AMC_ROW_H


def amc_box_w() -> int32:
    return AMC_BOX_W


# Label pointer for a row (search row -> current filter text).
def amc_row_label(i: uint64) -> Ptr[uint8]:
    kind: int32 = _amc_row_kind[i]
    if kind == AMC_ROW_SEARCH:
        return &_amc_filter[0]
    if kind == AMC_ROW_HEADER or kind == AMC_ROW_CATBTN:
        return amc_cat_name(_amc_row_cat[i])
    ai: int32 = _amc_row_app[i]
    return &_amc_name[cast[uint64](ai)][0]


def amc_row_glyph(i: uint64) -> uint8:
    if _amc_row_kind[i] != AMC_ROW_APP:
        return 32
    return _amc_glyph[cast[uint64](_amc_row_app[i])]


# The prog path launched by app row `i` (empty for non-app rows).
def amc_row_prog(i: uint64) -> Ptr[uint8]:
    if _amc_row_kind[i] != AMC_ROW_APP:
        e: Ptr[uint8] = ""
        return e
    return &_amc_prog[cast[uint64](_amc_row_app[i])][0]


def amc_row_prog_len(i: uint64) -> uint64:
    if _amc_row_kind[i] != AMC_ROW_APP:
        return 0
    return _amc_prog_len[cast[uint64](_amc_row_app[i])]


# ====================================================================
# HIT-TEST — row under (px,py) for a menu whose content origin is (bx,by).
# Returns the row index, or -1.
# ====================================================================
def amc_hit(bx: int32, by: int32, px: int32, py: int32) -> int64:
    if px < bx or px >= bx + AMC_BOX_W:
        return -1
    i: uint64 = 0
    while i < _amc_row_count:
        ry: int32 = by + _amc_row_y[i]
        if py >= ry and py < ry + AMC_ROW_H:
            return cast[int64](i)
        i = i + 1
    return -1


# ====================================================================
# HOST renderer — draw the MATE menu into the hamscene display list.
# Light Clearlooks palette so the PNG reads like MATE. Anchored at (bx,by).
# `hover` is the highlighted row index (-1 = none).
# ====================================================================
def amc_build_scene(bx: int32, by: int32, hover: int32,
                    scr_w: int32, scr_h: int32):
    # Back-compat entry (host render gate): an OPAQUE slate desktop backdrop so
    # the rendered PPM shows the menu in context. The on-device client uses
    # amc_build_scene_win with a TRANSPARENT backdrop (its window is grown wide
    # to hold the fly-out and keyed-composited, so everything outside the box
    # must stay alpha-0 to show the real desktop through it).
    amc_build_scene_win(bx, by, hover, scr_w, scr_h,
                        cast[Ptr[uint8]]("#5c6b80"))


# The SINGLE menu renderer shared by BOTH the host render gate and the native
# /bin/hamappmenu client, so the on-device menu and the QEMU-free host PNG can
# never diverge (the prior squares-vs-glyphs bug was exactly two render paths:
# a scene-glyph host render that went green while the shipped client painted
# solid block glyphs through a separate v2 blit path). `backdrop` is the whole-
# window fill emitted first: an opaque colour for the host PNG, or a fully
# transparent "#00000000" for the keyed on-device window.
def amc_build_scene_win(bx: int32, by: int32, hover: int32,
                        scr_w: int32, scr_h: int32, backdrop: Ptr[uint8]):
    body:    Ptr[uint8] = "#f7f8fa"      # clean near-white menu body
    frame:   Ptr[uint8] = "#cfd2d8"      # soft hairline border
    shadow:  Ptr[uint8] = "#00000030"    # soft drop shadow
    txt:     Ptr[uint8] = "#23262b"      # near-black label text
    seltxt:  Ptr[uint8] = "#ffffff"      # selected label text
    selbg:   Ptr[uint8] = "#3584e4"      # modern accent selection
    hdrbg:   Ptr[uint8] = "#eceef2"      # category header strip
    hdrtxt:  Ptr[uint8] = "#6b7078"      # muted header text
    searchbg: Ptr[uint8] = "#ffffff"     # search field
    searchtx: Ptr[uint8] = "#23262b"
    hint:    Ptr[uint8] = "#9298a1"      # placeholder / magnifier

    catbtn:  Ptr[uint8] = "#eef0f3"      # category parent-button strip
    chev:    Ptr[uint8] = "#8a9099"      # > affordance colour

    w: int32 = AMC_BOX_W
    h: int32 = amc_content_h()

    # Fresh fly-out geometry for the currently-open category (if any).
    amc_child_layout(bx, by, scr_w, scr_h)

    hamscene_begin()
    # Whole-window backdrop. The host PNG passes an opaque colour so the menu
    # reads in context. The on-device client passes an EMPTY string: we then
    # emit NO fill at all, leaving every pixel outside the box card UNPAINTED so
    # the keyed compositor shows the real desktop through it. (An explicit
    # alpha-0 fill does NOT read as transparent — it composites as opaque black,
    # the black-rectangle regression; only genuinely unpainted pixels are keyed
    # transparent, exactly as the scene panel's grown popup band relies on.)
    if backdrop[0] != 0:
        hamscene_fill(0, 0, scr_w, scr_h, backdrop)
    # Drop shadow, then the rounded body card (border ring + inset face).
    hamscene_roundrect(bx + 3, by + 3, w, h, 7, shadow)
    hamscene_roundrect(bx, by, w, h, 7, frame)
    hamscene_roundrect(bx + 1, by + 1, w - 2, h - 2, 6, body)

    i: uint64 = 0
    while i < _amc_row_count:
        ry: int32 = by + _amc_row_y[i]
        kind: int32 = _amc_row_kind[i]
        if kind == AMC_ROW_CATBTN:
            # A category PARENT BUTTON: colour chip + bold label + a ">"
            # chevron. Highlighted while hovered OR while its fly-out is open.
            hot: int32 = 0
            if cast[int32](i) == hover:
                hot = 1
            if _amc_row_cat[i] == _amc_open_cat:
                hot = 1
            clab: Ptr[uint8] = catbtn
            ctxt: Ptr[uint8] = txt
            if hot != 0:
                clab = selbg
                ctxt = seltxt
            hamscene_fill(bx + 1, ry, w - 2, AMC_ROW_H, clab)
            cix: int32 = bx + AMC_PAD_L
            ciy: int32 = ry + (AMC_ROW_H - AMC_ICON_SZ) / 2
            hamscene_icon_draw(cix, ciy, AMC_ICON_SZ, AMC_ICON_SZ,
                               amc_cat_icon_code(_amc_row_cat[i]))
            hamscene_glyphs_bold(cix + AMC_ICON_SZ + 6, ry + 3,
                                 amc_cat_name(_amc_row_cat[i]), ctxt)
            cchev: Ptr[uint8] = chev
            if hot != 0:
                cchev = seltxt
            hamscene_glyphs_bold(bx + w - 14, ry + 3,
                                 cast[Ptr[uint8]](">"), cchev)
        elif kind == AMC_ROW_SEARCH:
            # White search field with a magnifier tick + the live filter text
            # (or a "Search..." placeholder when empty).
            hamscene_fill(bx + 4, ry + 3, w - 8, AMC_ROW_H - 5, searchbg)
            hamscene_stroke(bx + 4, ry + 3, w - 8, AMC_ROW_H - 5, 1, frame)
            hamscene_fill(bx + 8, ry + 8, 5, 5, hint)   # magnifier lens
            hamscene_fill(bx + 12, ry + 12, 3, 3, hint) # handle
            if _amc_filter_len > 0:
                hamscene_glyphs(bx + 20, ry + 4, &_amc_filter[0], searchtx)
            else:
                hamscene_glyphs(bx + 20, ry + 4,
                                cast[Ptr[uint8]]("Search..."), hint)
        elif kind == AMC_ROW_HEADER:
            hamscene_fill(bx + 1, ry, w - 2, AMC_ROW_H, hdrbg)
            hamscene_glyphs_bold(bx + AMC_PAD_L, ry + 3,
                                 amc_cat_name(_amc_row_cat[i]), hdrtxt)
        else:
            col: Ptr[uint8] = txt
            if cast[int32](i) == hover:
                hamscene_fill(bx + 1, ry, w - 2, AMC_ROW_H, selbg)
                col = seltxt
            # Real per-app icon (#285) — same artwork as the panel/desktop.
            ix: int32 = bx + AMC_PAD_L
            iy: int32 = ry + (AMC_ROW_H - AMC_ICON_SZ) / 2
            hamscene_icon_draw(ix, iy, AMC_ICON_SZ, AMC_ICON_SZ,
                               amc_app_icon_code(
                                   cast[uint64](_amc_row_app[i])))
            # App name.
            hamscene_glyphs(ix + AMC_ICON_SZ + 6, ry + 3,
                            amc_row_label(i), col)
        i = i + 1

    # ---- CHILD FLY-OUT: the open category's apps, aligned to its parent ----
    if _amc_open_cat >= 0:
        cw: int32 = _amc_child_w
        chh: int32 = _amc_child_h
        cx: int32 = _amc_child_x
        cy: int32 = _amc_child_y
        hamscene_roundrect(cx + 3, cy + 3, cw, chh, 7, shadow)
        hamscene_roundrect(cx, cy, cw, chh, 7, frame)
        hamscene_roundrect(cx + 1, cy + 1, cw - 2, chh - 2, 6, body)
        ci: uint64 = 0
        while ci < _amc_child_count:
            ai2: uint64 = cast[uint64](_amc_child_app[ci])
            cry: int32 = cy + cast[int32](ci) * AMC_ROW_H
            ccol: Ptr[uint8] = txt
            # Highlight a fly-out row when the caller's `hover` maps into it
            # (hover is encoded as AMC row index; a value >= _amc_row_count and
            # < _amc_row_count + _amc_child_count selects a child row).
            if hover >= cast[int32](_amc_row_count) and \
                    hover - cast[int32](_amc_row_count) == cast[int32](ci):
                hamscene_fill(cx + 1, cry, cw - 2, AMC_ROW_H, selbg)
                ccol = seltxt
            cix2: int32 = cx + AMC_PAD_L
            ciy2: int32 = cry + (AMC_ROW_H - AMC_ICON_SZ) / 2
            hamscene_icon_draw(cix2, ciy2, AMC_ICON_SZ, AMC_ICON_SZ,
                               amc_app_icon_code(ai2))
            hamscene_glyphs(cix2 + AMC_ICON_SZ + 6, cry + 3,
                            &_amc_name[ai2][0], ccol)
            ci = ci + 1


# ====================================================================
# Detached-client dismiss-decision helpers (PURE, host-unit-testable)
# ====================================================================
# The Applications menu is a detached child process spawned on the panel Apps
# button's PRESS edge, with the mouse still physically held. It paints frame 1
# then drains pointer events. Two un-guarded triggers used to self-dismiss the
# just-painted menu on frame 1 (recurring #287/#313/#330 "one-frame flash"):
#
#   1. Spurious focus-out: the compositor's focus-settle during window map can
#      deliver an "f out" before/around the initial "f in" (cursor still over
#      the panel button). A focus-out must only dismiss AFTER the menu has been
#      focused at least once.
#   2. Phantom press-outside: the still-held opening click reads as a fresh
#      press edge on the first "m" event (prev button bitmap statically 0). A
#      press edge must not fire until the button bitmap has been PRIMED from a
#      first observed sample.
#
# Both decisions are pulled out here as pure functions so a host gate can drive
# them directly; the client keeps its own latch state and passes it in. Byte
# behaviour is identical to the inline logic that preceded this refactor.

# Should an "f out" focus line dismiss the menu?  fc is the char AFTER "f " (the
# first letter of "in"/"out": 'i'==105 / 'o'==111). seen_in!=0 once any "f in"
# has been processed.  Dismiss only on 'o' AND after the menu has been focused.
def amc_focus_out_dismiss(fc: uint8, seen_in: int32) -> int32:
    if fc == 111 and seen_in != 0:
        return 1
    return 0


# Is this "m" line a button-bit0 PRESS edge?  primed!=0 once the previous-button
# bitmap has been sampled from a first observed "m" event; until then the held
# opening click cannot register a synthetic press edge.  After priming a real
# NEW press (prev bit0 clear -> btn bit0 set) still edges.
def amc_press_edge(btn: int32, prev_btn: int32, primed: int32) -> int32:
    if primed == 0:
        return 0
    if (btn & 1) != 0 and (prev_btn & 1) == 0:
        return 1
    return 0

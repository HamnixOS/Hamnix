# lib/hamgamedemo.ad — "Coin Dash", the hamGame demo game (target-agnostic).
#
# The pygame-shaped twin of lib/sdlpong.ad: ALL logic, drawing, sprites and
# collision go through the PUBLIC lib/hamgame.ad API, so this same file drives
# BOTH the device app (user/hamgamedemo.ad) and the host render gate
# (user/hamgamedemo_host.ad). It is extern-free and holds NO transport of its
# own — it never touches a window, a clock or a file.
#
# The game: a round player avatar (a 2-frame spritesheet, animated on a
# delta-time timer) moves with the arrow keys inside the window and collects
# coins; every pickup scores a point and relocates the coin. It exercises the
# whole hamGame surface: Surface create/fill/rect/circle draw, a spritesheet
# blit_rect with a colourkey, Sprite move + AABB collision, the display
# backbuffer, and delta-time animation.

from lib.hamgame import game_rgb, game_display_new, game_surface_new, \
    game_surface_fill, game_surface_fill_rect, game_surface_draw_rect, \
    game_surface_draw_circle, game_surface_set_colorkey, \
    game_surface_draw_text, \
    game_sprite_new, game_sprite_set_sheet, game_sprite_set_pos, \
    game_sprite_draw, game_sprite_collide, \
    game_sprite_x, game_sprite_y, \
    GAMEK_LEFT, GAMEK_RIGHT, GAMEK_UP, GAMEK_DOWN


# ---- world state ---------------------------------------------------------
gd_w: int32 = 0
gd_h: int32 = 0
gd_display: int32 = -1
gd_player_surf: int32 = -1
gd_coin_surf: int32 = -1
gd_player: int32 = -1
gd_coin: int32 = -1
gd_score: int32 = 0
gd_frame: int32 = 0
gd_anim_ms: int32 = 0
gd_coin_seq: int32 = 0

GD_PLAYER_SZ: int32 = 16
GD_COIN_SZ: int32 = 12
GD_STEP: int32 = 8

# ---- the GAME rules (objective / scoring / win-lose) ---------------------
# Coin Dash is a beat-the-clock coin rush: grab GD_GOAL coins before the timer
# runs out. Reaching the goal WINS; the clock hitting zero first LOSES. Either
# way the round freezes with a verdict overlay and a "press to replay" prompt,
# so it is a real, restartable game rather than an endless sprite sandbox.
GD_TIME_LIMIT: int32 = 30000                              # 30 s round (ms)
GD_GOAL:       int32 = 10                                 # coins to win

gd_time_ms: int32 = 0                                     # elapsed this round
gd_over:    int32 = 0                                     # 0 play, 1 win, 2 lose
gd_sec_left: int32 = -1                                   # last whole-sec drawn
gd_rng:     uint32 = 0                                    # coin-placement LCG
gd_games:   uint32 = 0                                    # replay counter

# Frame pacing: uploading the whole display Surface every frame is what made the
# old demo feel sluggish. `gd_dirty` is raised on any visible change (a move, a
# pickup, an animation flip, a whole-second tick, a win/lose) and drained by
# gd_take_dirty(); the driver re-renders + uploads ONLY then.
gd_dirty: int32 = 1

# colourkey painted behind each sprite; skipped when blitting (transparency).
_gd_key: uint32 = 0                                        # set in gd_init


def _gd_srand(seed: uint32):
    gd_rng = seed


def _gd_rand() -> uint32:
    gd_rng = gd_rng * cast[uint32](1103515245) + cast[uint32](12345)
    return (gd_rng >> 16) & cast[uint32](32767)


# Return whether the frame changed since the last call, clearing the flag.
def gd_take_dirty() -> int32:
    d: int32 = gd_dirty
    gd_dirty = 0
    return d


def _gd_clampx(x: int32) -> int32:
    if x < 0:
        return 0
    if x > gd_w - GD_PLAYER_SZ:
        return gd_w - GD_PLAYER_SZ
    return x


def _gd_clampy(y: int32) -> int32:
    if y < 0:
        return 0
    if y > gd_h - GD_PLAYER_SZ:
        return gd_h - GD_PLAYER_SZ
    return y


# Paint one 16x16 player frame into the spritesheet at column `col`. A magenta
# key backdrop (made transparent by the colourkey) + a round body disc + eyes.
def _gd_paint_player_frame(col: int32, body: uint32):
    x0: int32 = col * GD_PLAYER_SZ
    game_surface_fill_rect(gd_player_surf, x0, 0, GD_PLAYER_SZ, GD_PLAYER_SZ,
                           _gd_key)
    game_surface_draw_circle(gd_player_surf, x0 + 8, 8, 7, body)
    eye: uint32 = game_rgb(20, 26, 38)
    game_surface_fill_rect(gd_player_surf, x0 + 5, 6, 2, 3, eye)
    game_surface_fill_rect(gd_player_surf, x0 + 10, 6, 2, 3, eye)


def gd_init(w: int32, h: int32):
    gd_w = w
    gd_h = h
    gd_score = 0
    gd_frame = 0
    gd_anim_ms = 0
    gd_coin_seq = 0
    gd_time_ms = 0
    gd_over = 0
    gd_sec_left = -1
    gd_dirty = 1
    _gd_srand(cast[uint32](2463534242))
    _gd_key = game_rgb(255, 0, 255)

    gd_display = game_display_new(w, h)

    # 2-frame spritesheet: two 16x16 avatars side by side (32x16).
    gd_player_surf = game_surface_new(GD_PLAYER_SZ * 2, GD_PLAYER_SZ)
    game_surface_set_colorkey(gd_player_surf, _gd_key)
    _gd_paint_player_frame(0, game_rgb(90, 200, 255))     # cyan
    _gd_paint_player_frame(1, game_rgb(150, 230, 255))    # brighter (blink)

    # coin: a gold disc on a keyed backdrop.
    gd_coin_surf = game_surface_new(GD_COIN_SZ, GD_COIN_SZ)
    game_surface_set_colorkey(gd_coin_surf, _gd_key)
    game_surface_fill(gd_coin_surf, _gd_key)
    game_surface_draw_circle(gd_coin_surf, 6, 6, 5, game_rgb(240, 210, 90))
    game_surface_draw_circle(gd_coin_surf, 6, 6, 2, game_rgb(255, 245, 200))

    gd_player = game_sprite_new(gd_player_surf, w / 2 - 8, h - 40)
    game_sprite_set_sheet(gd_player, 0, 0, GD_PLAYER_SZ, GD_PLAYER_SZ)
    gd_coin = game_sprite_new(gd_coin_surf, w / 2 - 6, 32)


# Start a fresh round IN PLACE after a win/lose (sprites + Surfaces stay), so the
# app never has to be relaunched. Public so the driver can wire it to a key.
def gd_restart():
    gd_games = gd_games + 1
    gd_score = 0
    gd_frame = 0
    gd_anim_ms = 0
    gd_coin_seq = 0
    gd_time_ms = 0
    gd_over = 0
    gd_sec_left = -1
    _gd_srand(cast[uint32](2463534242) + gd_games * cast[uint32](2654435761))
    game_sprite_set_pos(gd_player, gd_w / 2 - 8, gd_h - 40)
    game_sprite_set_pos(gd_coin, gd_w / 2 - 6, 32)
    gd_dirty = 1


def gd_key(key: int32):
    # After a round ends the app STAYS open: r / R / n / N / Space replays.
    if gd_over != 0:
        if key == 114 or key == 82 or key == 110 or key == 78 or key == 32:
            gd_restart()
        return
    px: int32 = game_sprite_x(gd_player)
    py: int32 = game_sprite_y(gd_player)
    if key == GAMEK_LEFT:
        px = px - GD_STEP
    elif key == GAMEK_RIGHT:
        px = px + GD_STEP
    elif key == GAMEK_UP:
        py = py - GD_STEP
    elif key == GAMEK_DOWN:
        py = py + GD_STEP
    else:
        return
    game_sprite_set_pos(gd_player, _gd_clampx(px), _gd_clampy(py))
    gd_dirty = 1


# Drop the coin on a fresh random cell inside the playfield (below the HUD strip,
# clear of the border). Seeded by a fixed LCG so a given round is reproducible.
def _gd_relocate_coin():
    gd_coin_seq = gd_coin_seq + 1
    span_x: int32 = gd_w - 28
    span_y: int32 = gd_h - 48
    if span_x < 1:
        span_x = 1
    if span_y < 1:
        span_y = 1
    rx: int32 = 8 + cast[int32](_gd_rand() % cast[uint32](span_x))
    ry: int32 = 28 + cast[int32](_gd_rand() % cast[uint32](span_y))
    game_sprite_set_pos(gd_coin, rx, ry)


# Advance the world by `dt_ms`: run the countdown, animate the avatar, resolve a
# pickup, and settle the win/lose verdict. Frozen once the round is over.
def gd_update(dt_ms: int32):
    if gd_over != 0:
        return

    # countdown: the clock running out loses the round.
    gd_time_ms = gd_time_ms + dt_ms
    if gd_time_ms >= GD_TIME_LIMIT:
        gd_time_ms = GD_TIME_LIMIT
        gd_over = 2                                       # time up -> lose
        gd_dirty = 1
        return

    # avatar blink animation (delta-time paced).
    gd_anim_ms = gd_anim_ms + dt_ms
    while gd_anim_ms >= 200:
        gd_anim_ms = gd_anim_ms - 200
        gd_frame = 1 - gd_frame
        gd_dirty = 1
    game_sprite_set_sheet(gd_player, gd_frame * GD_PLAYER_SZ, 0,
                          GD_PLAYER_SZ, GD_PLAYER_SZ)

    # pickup: score, relocate the coin, and check the win condition.
    if game_sprite_collide(gd_player, gd_coin) == 1:
        gd_score = gd_score + 1
        _gd_relocate_coin()
        gd_dirty = 1
        if gd_score >= GD_GOAL:
            gd_over = 1                                   # goal reached -> win

    # a whole-second change repaints the countdown bar without busy-redrawing.
    sl: int32 = (GD_TIME_LIMIT - gd_time_ms) / 1000
    if sl != gd_sec_left:
        gd_sec_left = sl
        gd_dirty = 1


# Compose the frame onto the display backbuffer (title + score text is the
# driver's job). Draws the play area, the countdown bar, and — once the round is
# decided — a centred win/lose verdict with a replay prompt.
def gd_render():
    game_surface_fill(gd_display, game_rgb(18, 22, 34))
    game_surface_fill_rect(gd_display, 0, 0, gd_w, 22, game_rgb(28, 34, 52))
    game_surface_draw_rect(gd_display, 0, 0, gd_w, gd_h, game_rgb(70, 84, 120))

    # countdown bar just under the HUD strip: shrinks as time runs out, and
    # turns amber then red in the final seconds so the stakes read at a glance.
    rem: int32 = GD_TIME_LIMIT - gd_time_ms
    if rem < 0:
        rem = 0
    bar_w: int32 = (gd_w - 4) * rem / GD_TIME_LIMIT
    bar_col: uint32 = game_rgb(90, 200, 120)
    if rem <= GD_TIME_LIMIT / 10:
        bar_col = game_rgb(230, 80, 80)
    elif rem <= GD_TIME_LIMIT / 3:
        bar_col = game_rgb(230, 190, 80)
    game_surface_fill_rect(gd_display, 2, 23, gd_w - 4, 4, game_rgb(40, 46, 64))
    if bar_w > 0:
        game_surface_fill_rect(gd_display, 2, 23, bar_w, 4, bar_col)

    game_sprite_draw(gd_coin, gd_display)
    game_sprite_draw(gd_player, gd_display)

    # verdict overlay (only when the round is decided; the driver's live frames
    # never hit this, so the deterministic host gate is unaffected).
    if gd_over != 0:
        ow: int32 = 200
        oh: int32 = 78
        ox: int32 = gd_w / 2 - ow / 2
        oy: int32 = gd_h / 2 - oh / 2
        game_surface_fill_rect(gd_display, ox, oy, ow, oh, game_rgb(22, 28, 44))
        game_surface_draw_rect(gd_display, ox, oy, ow, oh, game_rgb(120, 140, 180))
        if gd_over == 1:
            game_surface_draw_text(gd_display, cast[Ptr[uint8]]("YOU WIN!"),
                                   ox + ow / 2 - 32, oy + 14,
                                   game_rgb(120, 230, 140))
        else:
            game_surface_draw_text(gd_display, cast[Ptr[uint8]]("TIME UP"),
                                   ox + ow / 2 - 28, oy + 14,
                                   game_rgb(240, 120, 120))
        game_surface_draw_text(gd_display,
                               cast[Ptr[uint8]]("Press R to play again"),
                               ox + ow / 2 - 84, oy + 44,
                               game_rgb(225, 230, 238))


# ---- accessors (drivers + the host gate read these) ----------------------
def gd_display_surf() -> int32:
    return gd_display


def gd_player_x() -> int32:
    return game_sprite_x(gd_player)


def gd_player_y() -> int32:
    return game_sprite_y(gd_player)


def gd_coin_x() -> int32:
    return game_sprite_x(gd_coin)


def gd_coin_y() -> int32:
    return game_sprite_y(gd_coin)


def gd_get_score() -> int32:
    return gd_score


# Round outcome: 0 = still playing, 1 = won (goal reached), 2 = lost (time up).
def gd_over_state() -> int32:
    return gd_over


def gd_get_frame() -> int32:
    return gd_frame


# Test hook: drop the coin directly onto the player so the next gd_update scores.
def gd_place_coin_on_player():
    game_sprite_set_pos(gd_coin, game_sprite_x(gd_player), game_sprite_y(gd_player))

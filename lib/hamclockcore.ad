# lib/hamclockcore.ad — PURE, extern-free core for HamClock, the Hamnix
# clock / calendar / timer desktop utility (/bin/hamclock). A REPO-ONLY app
# (installed from the packages repo, not baked into the base image) that gives
# the desktop three genuinely-useful time views:
#
#   1. CLOCK  — a large 7-segment digital HH:MM:SS read-out plus an analog clock
#      face with hour / minute / second hands drawn at the correct angles, and
#      the full date underneath,
#   2. CALENDAR — a real month grid (weekday headers, day cells, today
#      highlighted) with correct first-of-month weekday + days-in-month for any
#      month (leap years handled); Left/Right page to the prev/next month,
#   3. TIMER  — a stopwatch counting elapsed MM:SS, Space start/stop, R reset.
#
# Like the other dual-target apps (docs/hamui_dual_target.md) this file imports
# ONLY lib/hamscene (the pure display-list builder) and performs NO syscalls or
# time reads: the wall-clock time is INJECTED at the edge. The native driver
# (user/hamclock.ad) reads /proc/realtime (a real UTC epoch, with a jiffies
# uptime fallback) and the monotonic jiffies counter, and feeds them in via
# hamclock_set_time(); the host harness (user/hamclock_host.ad) injects a KNOWN
# fixed epoch so the gate (scripts/test_hamclock_host.sh) is deterministic. That
# lets the exact shipping render path produce a PNG on the dev host and be
# asserted byte-for-byte.

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_stroke, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_line


# ---- views -----------------------------------------------------------------
VIEW_CLOCK:    int32 = 0
VIEW_CALENDAR: int32 = 1
VIEW_TIMER:    int32 = 2
view: int32 = 0

# ---- injected time state ---------------------------------------------------
# cur_epoch : UTC seconds since 1970 (wall clock). Meaningful when wall_ok!=0.
# cur_mono  : a MONOTONIC seconds counter (uptime), drives the stopwatch.
# The broken-down fields are derived from cur_epoch on each set_time.
cur_epoch: uint64 = 0
cur_mono:  uint64 = 0
wall_ok:   int32 = 0

c_year:  uint64 = 1970
c_month: uint64 = 1                       # 1..12
c_day:   uint64 = 1                       # 1..31
c_hour:  uint64 = 0
c_min:   uint64 = 0
c_sec:   uint64 = 0
c_wday:  uint64 = 4                       # 0=Sun .. 6=Sat (1970-01-01 = Thu)

# Displayed calendar month = current month shifted by cal_offset months.
cal_offset: int64 = 0

# Stopwatch: elapsed = t_accum + (cur_mono - t_start) while running.
t_running: int32 = 0
t_start:   uint64 = 0
t_accum:   uint64 = 0

# CSI arrow decode: 0 ground, 1 saw ESC, 2 saw ESC '['.
hc_esc: int32 = 0


# ---- pure date math --------------------------------------------------------
def _is_leap(y: uint64) -> int32:
    if y % 4 != 0:
        return 0
    if y % 100 != 0:
        return 1
    if y % 400 == 0:
        return 1
    return 0


# Days in month m (1..12) of year y — Feb is 28/29 by the leap rule.
def hamclock_days_in_month(y: uint64, m: uint64) -> uint64:
    if m == 2:
        if _is_leap(y) != 0:
            return 29
        return 28
    if m == 4 or m == 6 or m == 9 or m == 11:
        return 30
    return 31


# Days from 1970-01-01 to y-m-d (Howard Hinnant's days_from_civil, unsigned;
# valid for our >= 1970 range).
def _days_from_civil(y: uint64, m: uint64, d: uint64) -> uint64:
    yy: uint64 = y
    if m <= 2:
        yy = yy - 1
    era: uint64 = yy / 400
    yoe: uint64 = yy - era * 400
    mp: uint64 = 0
    if m > 2:
        mp = m - 3
    else:
        mp = m + 9
    doy: uint64 = (153 * mp + 2) / 5 + d - 1
    doe: uint64 = yoe * 365 + yoe / 4 - yoe / 100 + doy
    return era * 146097 + doe - 719468


# Weekday (0=Sun..6=Sat) of the 1st of month m in year y.
def hamclock_first_weekday(y: uint64, m: uint64) -> uint64:
    days: uint64 = _days_from_civil(y, m, 1)
    return (days + 4) % 7


# Broken-down UTC from a unix epoch (Hinnant's civil_from_days for the date +
# trivial h/m/s), storing into the c_* globals and c_wday.
def _decode_epoch(epoch: uint64):
    days: uint64 = epoch / 86400
    rem:  uint64 = epoch % 86400
    c_hour = rem / 3600
    c_min  = (rem % 3600) / 60
    c_sec  = rem % 60
    c_wday = (days + 4) % 7
    z: uint64 = days + 719468
    era: uint64 = z / 146097
    doe: uint64 = z - era * 146097
    yoe: uint64 = (doe - doe / 1460 + doe / 36524 - doe / 146096) / 365
    y: uint64 = yoe + era * 400
    doy: uint64 = doe - (365 * yoe + yoe / 4 - yoe / 100)
    mp: uint64 = (5 * doy + 2) / 153
    d: uint64 = doy - (153 * mp + 2) / 5 + 1
    m: uint64 = 0
    if mp < 10:
        m = mp + 3
    else:
        m = mp - 9
    if m <= 2:
        y = y + 1
    c_year = y
    c_month = m
    c_day = d


# ---- integer trig (Bhaskara I sine approx; pure, dual-target identical) -----
# Returns sin(deg) scaled by 10000, for any integer degree.
def _sin10k(deg: int32) -> int32:
    d: int32 = deg % 360
    if d < 0:
        d = d + 360
    sign: int32 = 1
    if d >= 180:
        sign = -1
        d = d - 180
    num: int32 = 4 * d * (180 - d)
    den: int32 = 40500 - d * (180 - d)
    v: int32 = num * 10000 / den
    return sign * v


def _cos10k(deg: int32) -> int32:
    return _sin10k(deg + 90)


# ---- public time entry point (the EDGE) ------------------------------------
# Inject the current wall epoch (UTC seconds), a monotonic seconds counter and
# whether the wall clock is valid. Returns 1 if the visible state changed (the
# second rolled over, or the stopwatch is running) so the driver repaints.
def hamclock_set_time(epoch: uint64, mono: uint64, ok: int32) -> int32:
    changed: int32 = 0
    if mono != cur_mono:
        if t_running != 0:
            changed = 1
    cur_mono = mono
    wall_ok = ok
    # Always decode the injected seconds so the digital + analog clock ticks
    # even in the uptime-fallback mode (ok==0 just flags the display note; the
    # driver passes uptime seconds as `epoch` in that case). With a real wall
    # clock this is the true UTC calendar time.
    if epoch != cur_epoch:
        changed = 1
    cur_epoch = epoch
    _decode_epoch(epoch)
    return changed


# ---- accessors (drivers + host gate) ---------------------------------------
def hamclock_view() -> int32:
    return view


def hamclock_hour() -> uint64:
    return c_hour


def hamclock_minute() -> uint64:
    return c_min


def hamclock_second() -> uint64:
    return c_sec


def hamclock_year() -> uint64:
    return c_year


def hamclock_month() -> uint64:
    return c_month


def hamclock_day() -> uint64:
    return c_day


def hamclock_weekday() -> uint64:
    return c_wday


# Integer angle (degrees clockwise from 12 o'clock) of a hand:
#   which 0 = hour, 1 = minute, 2 = second.
def hamclock_hand_angle(which: int32) -> int32:
    if which == 2:
        return cast[int32](c_sec) * 6
    if which == 1:
        return cast[int32](c_min) * 6
    # hour hand: 30 deg / hour + 0.5 deg / minute
    return cast[int32](c_hour % 12) * 30 + cast[int32](c_min) / 2


# Stopwatch elapsed seconds (live).
def hamclock_timer_elapsed() -> uint64:
    if t_running != 0:
        return t_accum + (cur_mono - t_start)
    return t_accum


def hamclock_timer_running() -> int32:
    return t_running


# Digital string "HH:MM:SS" (NUL-terminated). Returns length (8).
def hamclock_digital(out: Ptr[uint8]) -> uint64:
    _wr2(out, 0, c_hour)
    out[2] = 58                                        # ':'
    _wr2(out, 3, c_min)
    out[5] = 58
    _wr2(out, 6, c_sec)
    out[8] = 0
    return 8


def _wr2(out: Ptr[uint8], off: uint64, v: uint64):
    out[off] = cast[uint8](v / 10 % 10) + 48
    out[off + 1] = cast[uint8](v % 10) + 48


# ---- lifecycle -------------------------------------------------------------
def hamclock_init():
    view = VIEW_CLOCK
    cur_epoch = 0
    cur_mono = 0
    wall_ok = 0
    cal_offset = 0
    t_running = 0
    t_start = 0
    t_accum = 0
    hc_esc = 0
    c_year = 1970
    c_month = 1
    c_day = 1
    c_hour = 0
    c_min = 0
    c_sec = 0
    c_wday = 4


def hamclock_set_view(v: int32):
    view = v
    if v == VIEW_CALENDAR:
        cal_offset = 0


# ---- keyboard --------------------------------------------------------------
def _timer_toggle():
    if t_running != 0:
        t_accum = t_accum + (cur_mono - t_start)
        t_running = 0
    else:
        t_start = cur_mono
        t_running = 1


def _timer_reset():
    t_running = 0
    t_start = 0
    t_accum = 0


# CSI final byte in the calendar (Left/Right page months).
def _hc_nav(fin: int32) -> int32:
    if view == VIEW_CALENDAR:
        if fin == 68:                                  # Left -> prev month
            cal_offset = cal_offset - 1
            return 1
        if fin == 67:                                  # Right -> next month
            cal_offset = cal_offset + 1
            return 1
    return 0


# Apply one key (ASCII / decoded). Returns 1 if state changed (redraw needed).
def hamclock_key(code: int32) -> int32:
    if hc_esc == 1:
        if code == 91:                                 # '['
            hc_esc = 2
        else:
            hc_esc = 0
        return 0
    if hc_esc == 2:
        hc_esc = 0
        return _hc_nav(code)
    if code == 27:                                     # ESC -> start CSI
        hc_esc = 1
        return 0

    # view selection: 1/2/3 or c/a/t, Tab cycles
    if code == 49 or code == 99:                       # '1' / 'c' -> clock
        hamclock_set_view(VIEW_CLOCK)
        return 1
    if code == 50 or code == 97:                       # '2' / 'a' -> calendar
        hamclock_set_view(VIEW_CALENDAR)
        return 1
    if code == 51 or code == 116:                      # '3' / 't' -> timer
        hamclock_set_view(VIEW_TIMER)
        return 1
    if code == 9:                                      # Tab -> cycle
        nv: int32 = view + 1
        if nv > VIEW_TIMER:
            nv = VIEW_CLOCK
        hamclock_set_view(nv)
        return 1

    # timer controls (active in the TIMER view)
    if view == VIEW_TIMER:
        if code == 32:                                 # Space -> start/stop
            _timer_toggle()
            return 1
        if code == 114 or code == 82:                  # r / R -> reset
            _timer_reset()
            return 1

    # calendar: prev/next month with , / . and Home (offset 0) too
    if view == VIEW_CALENDAR:
        if code == 44:                                 # ',' prev month
            cal_offset = cal_offset - 1
            return 1
        if code == 46:                                 # '.' next month
            cal_offset = cal_offset + 1
            return 1
    return 0


# Parse a "d <code>" key-press wire line and apply it. Returns 1 if changed.
def hamclock_key_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 100:                           # 'd' press; ignore 'u'
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    neg: int32 = 0
    if i < n and s[i] == 45:
        neg = 1
        i = i + 1
    code: int32 = 0
    got: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        code = code * 10 + cast[int32](s[i]) - 48
        i = i + 1
        got = 1
    if got == 0:
        return 0
    if neg != 0:
        code = 0 - code
    return hamclock_key(code)


# ====================================================================
# LAYOUT + RENDER
# ====================================================================
WIN_W: int32 = 420
WIN_H: int32 = 470
BAR_H: int32 = 22
TB_Y:  int32 = 22
TB_H:  int32 = 28
CONTENT_Y: int32 = 50

# view-toggle toolbar buttons
BTN_CLK_X:  int32 = 8
BTN_CLK_W:  int32 = 84
BTN_CAL_X:  int32 = 96
BTN_CAL_W:  int32 = 100
BTN_TMR_X:  int32 = 200
BTN_TMR_W:  int32 = 84

num_buf: Array[32, uint8]
dig_buf: Array[12, uint8]


# ---- 7-segment digit -------------------------------------------------------
# Segment presence per digit, order a,b,c,d,e,f,g.
seg_mask: Array[70, uint8]
seg_ready: int32 = 0


def _init_segmasks():
    if seg_ready != 0:
        return
    _setseg(0, 1, 1, 1, 1, 1, 1, 0)
    _setseg(1, 0, 1, 1, 0, 0, 0, 0)
    _setseg(2, 1, 1, 0, 1, 1, 0, 1)
    _setseg(3, 1, 1, 1, 1, 0, 0, 1)
    _setseg(4, 0, 1, 1, 0, 0, 1, 1)
    _setseg(5, 1, 0, 1, 1, 0, 1, 1)
    _setseg(6, 1, 0, 1, 1, 1, 1, 1)
    _setseg(7, 1, 1, 1, 0, 0, 0, 0)
    _setseg(8, 1, 1, 1, 1, 1, 1, 1)
    _setseg(9, 1, 1, 1, 1, 0, 1, 1)
    seg_ready = 1


def _setseg(d: uint64, a: uint8, b: uint8, c: uint8, dd: uint8, e: uint8,
            f: uint8, g: uint8):
    base: uint64 = d * 7
    seg_mask[base + 0] = a
    seg_mask[base + 1] = b
    seg_mask[base + 2] = c
    seg_mask[base + 3] = dd
    seg_mask[base + 4] = e
    seg_mask[base + 5] = f
    seg_mask[base + 6] = g


# Draw one 7-segment digit in a w x h box at (x,y) with segment thickness t.
def _draw_digit(x: int32, y: int32, w: int32, h: int32, t: int32,
                digit: uint64, on: Ptr[uint8], off: Ptr[uint8]):
    _init_segmasks()
    base: uint64 = digit * 7
    midy: int32 = y + (h - t) / 2
    halfv: int32 = (h - t) / 2 - t
    # a top, g mid, d bottom (horizontal)
    _seg_h(x + t, y, w - 2 * t, t, seg_mask[base + 0], on, off)
    _seg_h(x + t, midy, w - 2 * t, t, seg_mask[base + 6], on, off)
    _seg_h(x + t, y + h - t, w - 2 * t, t, seg_mask[base + 3], on, off)
    # f top-left, b top-right, e bot-left, c bot-right (vertical)
    _seg_h(x, y + t, t, halfv, seg_mask[base + 5], on, off)
    _seg_h(x + w - t, y + t, t, halfv, seg_mask[base + 1], on, off)
    _seg_h(x, midy + t, t, halfv, seg_mask[base + 4], on, off)
    _seg_h(x + w - t, midy + t, t, halfv, seg_mask[base + 2], on, off)


def _seg_h(x: int32, y: int32, w: int32, h: int32, lit: uint8, on: Ptr[uint8],
           off: Ptr[uint8]):
    if w <= 0 or h <= 0:
        return
    if lit != 0:
        hamscene_fill(x, y, w, h, on)
    else:
        hamscene_fill(x, y, w, h, off)


def _draw_colon(x: int32, y: int32, h: int32, t: int32, col: Ptr[uint8]):
    q: int32 = h / 4
    hamscene_fill(x, y + q, t, t, col)
    hamscene_fill(x, y + 3 * q, t, t, col)


# ---- analog face -----------------------------------------------------------
def _draw_circle(cx: int32, cy: int32, r: int32, thick: int32,
                 col: Ptr[uint8]):
    prevx: int32 = cx + (r * _sin10k(0)) / 10000
    prevy: int32 = cy - (r * _cos10k(0)) / 10000
    a: int32 = 6
    while a <= 360:
        nx: int32 = cx + (r * _sin10k(a)) / 10000
        ny: int32 = cy - (r * _cos10k(a)) / 10000
        hamscene_line(prevx, prevy, nx, ny, thick, col)
        prevx = nx
        prevy = ny
        a = a + 6


def _draw_hand(cx: int32, cy: int32, angle: int32, length: int32,
               thick: int32, col: Ptr[uint8]):
    ex: int32 = cx + (length * _sin10k(angle)) / 10000
    ey: int32 = cy - (length * _cos10k(angle)) / 10000
    hamscene_line(cx, cy, ex, ey, thick, col)


def _draw_analog(cx: int32, cy: int32, r: int32):
    face: Ptr[uint8] = cast[Ptr[uint8]]("#ffffff")
    ring: Ptr[uint8] = cast[Ptr[uint8]]("#2b2d5c")
    # filled disc (approx via a square backdrop then ring) — a light face
    hamscene_fill(cx - r, cy - r, 2 * r, 2 * r, cast[Ptr[uint8]]("#eef0fb"))
    _draw_circle(cx, cy, r, 2, ring)
    # hour tick marks
    a: int32 = 0
    while a < 360:
        ox: int32 = cx + ((r - 10) * _sin10k(a)) / 10000
        oy: int32 = cy - ((r - 10) * _cos10k(a)) / 10000
        ix: int32 = cx + (r * _sin10k(a)) / 10000
        iy: int32 = cy - (r * _cos10k(a)) / 10000
        hamscene_line(ox, oy, ix, iy, 2, ring)
        a = a + 30
    # hands: hour (short, thick), minute (long), second (thin, red)
    _draw_hand(cx, cy, hamclock_hand_angle(0), r - 44, 4,
               cast[Ptr[uint8]]("#26305c"))
    _draw_hand(cx, cy, hamclock_hand_angle(1), r - 20, 3,
               cast[Ptr[uint8]]("#4453b8"))
    _draw_hand(cx, cy, hamclock_hand_angle(2), r - 12, 1,
               cast[Ptr[uint8]]("#d1495b"))
    # hub
    hamscene_fill(cx - 3, cy - 3, 6, 6, cast[Ptr[uint8]]("#26305c"))


# ---- shared chrome ---------------------------------------------------------
def _viewbtn(x: int32, w: int32, label: Ptr[uint8], active: int32):
    bg: Ptr[uint8] = cast[Ptr[uint8]]("#e7e9f2")
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#26305c")
    if active != 0:
        bg = cast[Ptr[uint8]]("#4453b8")
        fg = cast[Ptr[uint8]]("#ffffff")
    hamscene_fill(x, TB_Y + 4, w, TB_H - 8, bg)
    hamscene_stroke(x, TB_Y + 4, w, TB_H - 8, 1, cast[Ptr[uint8]]("#9aa2c4"))
    hamscene_glyphs_bold(x + 8, TB_Y + 8, label, fg)


WD_HDR: Array[22, uint8]                   # "Su Mo Tu We Th Fr Sa"
MON_NAME: Array[160, uint8]


def _mon3(m: uint64) -> Ptr[uint8]:
    if m == 1:
        return cast[Ptr[uint8]]("January")
    if m == 2:
        return cast[Ptr[uint8]]("February")
    if m == 3:
        return cast[Ptr[uint8]]("March")
    if m == 4:
        return cast[Ptr[uint8]]("April")
    if m == 5:
        return cast[Ptr[uint8]]("May")
    if m == 6:
        return cast[Ptr[uint8]]("June")
    if m == 7:
        return cast[Ptr[uint8]]("July")
    if m == 8:
        return cast[Ptr[uint8]]("August")
    if m == 9:
        return cast[Ptr[uint8]]("September")
    if m == 10:
        return cast[Ptr[uint8]]("October")
    if m == 11:
        return cast[Ptr[uint8]]("November")
    return cast[Ptr[uint8]]("December")


def _wday3(w: uint64) -> Ptr[uint8]:
    if w == 0:
        return cast[Ptr[uint8]]("Sunday")
    if w == 1:
        return cast[Ptr[uint8]]("Monday")
    if w == 2:
        return cast[Ptr[uint8]]("Tuesday")
    if w == 3:
        return cast[Ptr[uint8]]("Wednesday")
    if w == 4:
        return cast[Ptr[uint8]]("Thursday")
    if w == 5:
        return cast[Ptr[uint8]]("Friday")
    return cast[Ptr[uint8]]("Saturday")


def _udec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# ---- displayed calendar month (current + cal_offset) -----------------------
disp_year:  uint64 = 1970
disp_month: uint64 = 1


def _compute_disp():
    total: int64 = cast[int64](c_year) * 12 + cast[int64](c_month) - 1 + \
        cal_offset
    if total < 0:
        total = 0
    disp_year = cast[uint64](total / 12)
    disp_month = cast[uint64](total % 12) + 1


# Is the displayed month the CURRENT month (so "today" should be highlighted)?
def _disp_is_current() -> int32:
    if disp_year == c_year and disp_month == c_month:
        return 1
    return 0


# ---- CLOCK view ------------------------------------------------------------
def _build_clock():
    hamscene_fill(0, CONTENT_Y, WIN_W, WIN_H - CONTENT_Y,
                  cast[Ptr[uint8]]("#f3f4fb"))
    on: Ptr[uint8] = cast[Ptr[uint8]]("#26305c")
    off: Ptr[uint8] = cast[Ptr[uint8]]("#dfe2f2")
    # large 7-segment HH:MM:SS across the top of the content area
    dw: int32 = 34
    dh: int32 = 60
    t:  int32 = 8
    gap: int32 = 8
    colw: int32 = 14
    total: int32 = dw * 6 + gap * 5 + colw * 2 + 24
    x0: int32 = (WIN_W - total) / 2
    y0: int32 = CONTENT_Y + 18
    hamclock_digital(&dig_buf[0])
    x: int32 = x0
    _draw_digit(x, y0, dw, dh, t, c_hour / 10, on, off)
    x = x + dw + gap
    _draw_digit(x, y0, dw, dh, t, c_hour % 10, on, off)
    x = x + dw + 4
    _draw_colon(x, y0, dh, t, on)
    x = x + colw
    _draw_digit(x, y0, dw, dh, t, c_min / 10, on, off)
    x = x + dw + gap
    _draw_digit(x, y0, dw, dh, t, c_min % 10, on, off)
    x = x + dw + 4
    _draw_colon(x, y0, dh, t, on)
    x = x + colw
    _draw_digit(x, y0, dw, dh, t, c_sec / 10, on, off)
    x = x + dw + gap
    _draw_digit(x, y0, dw, dh, t, c_sec % 10, on, off)

    if wall_ok == 0:
        hamscene_glyphs((WIN_W - 22 * 8) / 2, y0 + dh + 8,
                        cast[Ptr[uint8]]("(uptime; clock not set)"),
                        cast[Ptr[uint8]]("#8890b4"))

    # analog face centred below
    cy: int32 = y0 + dh + 132
    _draw_analog(WIN_W / 2, cy, 108)

    # date line under the face: "Weekday, Month D, YYYY"
    p: uint64 = 0
    p = _append(&num_buf[0], p, _wday3(c_wday))
    num_buf[p] = 44
    p = p + 1
    num_buf[p] = 32
    p = p + 1
    p = _append(&num_buf[0], p, _mon3(c_month))
    num_buf[p] = 32
    p = p + 1
    p = p + _udec(c_day, &num_buf[p])
    num_buf[p] = 44
    p = p + 1
    num_buf[p] = 32
    p = p + 1
    p = p + _udec(c_year, &num_buf[p])
    num_buf[p] = 0
    dtx: int32 = (WIN_W - cast[int32](p) * 8) / 2
    if dtx < 8:
        dtx = 8
    hamscene_glyphs_bold(dtx, cy + 124, &num_buf[0],
                         cast[Ptr[uint8]]("#26305c"))


def _append(out: Ptr[uint8], p: uint64, s: Ptr[uint8]) -> uint64:
    j: uint64 = 0
    while s[j] != 0:
        out[p] = s[j]
        p = p + 1
        j = j + 1
    return p


# ---- CALENDAR view ---------------------------------------------------------
CAL_X:   int32 = 24
CAL_Y:   int32 = 104
CELL_W:  int32 = 52
CELL_H:  int32 = 44
HDR_H:   int32 = 24


def _build_calendar():
    _compute_disp()
    hamscene_fill(0, CONTENT_Y, WIN_W, WIN_H - CONTENT_Y,
                  cast[Ptr[uint8]]("#f3f4fb"))
    # month / year header, centred
    p: uint64 = 0
    p = _append(&num_buf[0], p, _mon3(disp_month))
    num_buf[p] = 32
    p = p + 1
    p = p + _udec(disp_year, &num_buf[p])
    num_buf[p] = 0
    hx: int32 = (WIN_W - cast[int32](p) * 8) / 2
    hamscene_glyphs_bold(hx, CONTENT_Y + 12, &num_buf[0],
                         cast[Ptr[uint8]]("#26305c"))
    # prev/next hint pinned to the window bottom (clear of the grid)
    hamscene_glyphs(CAL_X, WIN_H - 22,
                    cast[Ptr[uint8]]("< or ,  prev month     next month  . or >"),
                    cast[Ptr[uint8]]("#8890b4"))

    # weekday header row
    hdr: Ptr[uint8] = cast[Ptr[uint8]]("SuMoTuWeThFrSa")
    hamscene_fill(CAL_X, CAL_Y - HDR_H, CELL_W * 7, HDR_H,
                  cast[Ptr[uint8]]("#4453b8"))
    col: int32 = 0
    while col < 7:
        lbl: Array[3, uint8]
        lbl[0] = hdr[cast[uint64](col) * 2]
        lbl[1] = hdr[cast[uint64](col) * 2 + 1]
        lbl[2] = 0
        cx: int32 = CAL_X + col * CELL_W + (CELL_W - 16) / 2
        hamscene_glyphs_bold(cx, CAL_Y - HDR_H + 5, &lbl[0],
                             cast[Ptr[uint8]]("#ffffff"))
        col = col + 1

    fw: uint64 = hamclock_first_weekday(disp_year, disp_month)
    dim: uint64 = hamclock_days_in_month(disp_year, disp_month)
    is_cur: int32 = _disp_is_current()

    day: uint64 = 1
    while day <= dim:
        idx: uint64 = fw + day - 1
        row: int32 = cast[int32](idx / 7)
        col2: int32 = cast[int32](idx % 7)
        cx2: int32 = CAL_X + col2 * CELL_W
        cy2: int32 = CAL_Y + row * CELL_H
        # cell frame
        cellbg: Ptr[uint8] = cast[Ptr[uint8]]("#ffffff")
        fgc: Ptr[uint8] = cast[Ptr[uint8]]("#26305c")
        today: int32 = 0
        if is_cur != 0 and day == c_day:
            today = 1
        if today != 0:
            cellbg = cast[Ptr[uint8]]("#ffd23f")
        hamscene_fill(cx2 + 1, cy2 + 1, CELL_W - 2, CELL_H - 2, cellbg)
        hamscene_stroke(cx2, cy2, CELL_W, CELL_H, 1,
                        cast[Ptr[uint8]]("#c3c8e0"))
        db: Array[4, uint8]
        dn: uint64 = _udec(day, &db[0])
        db[dn] = 0
        tx: int32 = cx2 + CELL_W - 6 - cast[int32](dn) * 8
        wknd: int32 = 0
        if col2 == 0 or col2 == 6:
            wknd = 1
        if today != 0:
            hamscene_glyphs_bold(tx, cy2 + 6, &db[0],
                                 cast[Ptr[uint8]]("#26305c"))
        elif wknd != 0:
            hamscene_glyphs(tx, cy2 + 6, &db[0], cast[Ptr[uint8]]("#a04668"))
        else:
            hamscene_glyphs(tx, cy2 + 6, &db[0], fgc)
        day = day + 1


# ---- TIMER view ------------------------------------------------------------
def _build_timer():
    hamscene_fill(0, CONTENT_Y, WIN_W, WIN_H - CONTENT_Y,
                  cast[Ptr[uint8]]("#f3f4fb"))
    hamscene_glyphs_bold((WIN_W - 9 * 8) / 2, CONTENT_Y + 24,
                         cast[Ptr[uint8]]("STOPWATCH"),
                         cast[Ptr[uint8]]("#4453b8"))
    el: uint64 = hamclock_timer_elapsed()
    mm: uint64 = el / 60
    if mm > 99:
        mm = 99
    ss: uint64 = el % 60
    on: Ptr[uint8] = cast[Ptr[uint8]]("#26305c")
    off: Ptr[uint8] = cast[Ptr[uint8]]("#dfe2f2")
    dw: int32 = 46
    dh: int32 = 84
    t:  int32 = 10
    gap: int32 = 12
    colw: int32 = 18
    total: int32 = dw * 4 + gap * 3 + colw
    x0: int32 = (WIN_W - total) / 2
    y0: int32 = CONTENT_Y + 90
    x: int32 = x0
    _draw_digit(x, y0, dw, dh, t, mm / 10, on, off)
    x = x + dw + gap
    _draw_digit(x, y0, dw, dh, t, mm % 10, on, off)
    x = x + dw + 6
    _draw_colon(x, y0, dh, t, on)
    x = x + colw
    _draw_digit(x, y0, dw, dh, t, ss / 10, on, off)
    x = x + dw + gap
    _draw_digit(x, y0, dw, dh, t, ss % 10, on, off)

    # state pill
    state: Ptr[uint8] = cast[Ptr[uint8]]("STOPPED")
    pill: Ptr[uint8] = cast[Ptr[uint8]]("#8890b4")
    if t_running != 0:
        state = cast[Ptr[uint8]]("RUNNING")
        pill = cast[Ptr[uint8]]("#3aa657")
    sy: int32 = y0 + dh + 24
    hamscene_fill((WIN_W - 90) / 2, sy, 90, 22, pill)
    hamscene_glyphs_bold((WIN_W - 7 * 8) / 2, sy + 4, state,
                         cast[Ptr[uint8]]("#ffffff"))
    hamscene_glyphs((WIN_W - 30 * 8) / 2, sy + 44,
                    cast[Ptr[uint8]]("Space: start/stop     R: reset"),
                    cast[Ptr[uint8]]("#8890b4"))


# ---- top-level scene -------------------------------------------------------
def hamclock_build_scene():
    hamscene_begin()
    # window bg + title bar
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#e9ebf3"))
    hamscene_fill(0, 0, WIN_W, BAR_H, cast[Ptr[uint8]]("#2b2d5c"))
    hamscene_fill(0, BAR_H - 1, WIN_W, 1, cast[Ptr[uint8]]("#1f2044"))
    hamscene_glyphs_bold(10, 5, cast[Ptr[uint8]]("HamClock"),
                         cast[Ptr[uint8]]("#ffffff"))
    # live HH:MM:SS in the title bar corner
    hamclock_digital(&dig_buf[0])
    hamscene_glyphs(WIN_W - 80, 5, &dig_buf[0], cast[Ptr[uint8]]("#c8cbe8"))

    # toolbar
    hamscene_fill(0, TB_Y, WIN_W, TB_H, cast[Ptr[uint8]]("#eef0f6"))
    hamscene_stroke(0, TB_Y + TB_H - 1, WIN_W, 1, 1,
                    cast[Ptr[uint8]]("#b6bcd6"))
    a0: int32 = 0
    a1: int32 = 0
    a2: int32 = 0
    if view == VIEW_CLOCK:
        a0 = 1
    elif view == VIEW_CALENDAR:
        a1 = 1
    else:
        a2 = 1
    _viewbtn(BTN_CLK_X, BTN_CLK_W, cast[Ptr[uint8]]("Clock"), a0)
    _viewbtn(BTN_CAL_X, BTN_CAL_W, cast[Ptr[uint8]]("Calendar"), a1)
    _viewbtn(BTN_TMR_X, BTN_TMR_W, cast[Ptr[uint8]]("Timer"), a2)

    if view == VIEW_CLOCK:
        _build_clock()
    elif view == VIEW_CALENDAR:
        _build_calendar()
    else:
        _build_timer()


# ---- pointer hit-testing (toolbar buttons) ---------------------------------
def hamclock_hit(x: int64, y: int64) -> int32:
    if y >= cast[int64](TB_Y) and y < cast[int64](TB_Y + TB_H):
        if x >= cast[int64](BTN_CLK_X) and x < cast[int64](BTN_CLK_X + BTN_CLK_W):
            hamclock_set_view(VIEW_CLOCK)
            return 1
        if x >= cast[int64](BTN_CAL_X) and x < cast[int64](BTN_CAL_X + BTN_CAL_W):
            hamclock_set_view(VIEW_CALENDAR)
            return 1
        if x >= cast[int64](BTN_TMR_X) and x < cast[int64](BTN_TMR_X + BTN_TMR_W):
            hamclock_set_view(VIEW_TIMER)
            return 1
    return 0

# lib/hamsdl.ad — hamSDL: an SDL2-flavored game-creation core for Hamnix.
#
# hamSDL lets you write native games in Adder that run on the Hamnix desktop
# (drawing through the DE scene/compositor protocol, exactly like the built-in
# scene apps) AND iterate on the developer HOST with no QEMU (render-to-PNG via
# lib/hamui_host.ad, exactly like hambrowse/hamUI). This file is the CORE: it is
# EXTERN-FREE and target-agnostic, so it compiles for BOTH x86_64-adder-user
# (device) and x86_64-linux (host). The two thin transport backends live beside
# it:
#     lib/hamsdl_dev.ad   device: open a wsys window, read /event + /keys,
#                         commit the frame, jiffy-based ticks/delay.
#     lib/hamsdl_host.ad  host:   rasterize the frame to a PPM, scripted ticks.
#
# ============================ PUBLIC API (round 1) =========================
# This block IS the spec that the future hamsh / pygame-style bindings mirror.
#
# --- Colors (RGBA packed as 0xRRGGBBAA in a uint32) -----------------------
#   sdl_rgb(r, g, b)            -> uint32    opaque colour (alpha = 0xFF)
#   sdl_rgba(r, g, b, a)        -> uint32    colour with explicit alpha
#
# --- Frame / drawing (build the frame's display list, target-agnostic) ----
#   sdl_begin_frame()                        start a new frame (clears the list)
#   sdl_clear(w, h, color)                   fill the whole w*h window
#   sdl_fill_rect(x, y, w, h, color)         solid rectangle
#   sdl_draw_rect(x, y, w, h, color)         1px rectangle outline
#   sdl_fill_round_rect(x,y,w,h,r,color)     solid rounded rectangle
#   sdl_draw_line(x1, y1, x2, y2, color)     1px line segment
#   sdl_draw_line_t(x1,y1,x2,y2,t,color)     t-px line segment
#   sdl_blit(name, x, y, w, h)               blit a registered sprite/surface
#   sdl_draw_text(x, y, s, color)            cell text (top-left anchored)
#   sdl_draw_text_bold(x, y, s, color)       bold cell text
#   sdl_draw_int(x, y, v, color)             draw a signed integer as text
#   sdl_text_width(s)          -> int32      pixel width of cell text s
#   The frame is shown by the backend: sdl_dev_present() / sdl_host_present().
#
# --- Events (a unified queue both backends feed) --------------------------
#   Event kinds (module constants): SDL_QUIT, SDL_KEYDOWN, SDL_KEYUP,
#     SDL_MOUSEMOTION, SDL_MOUSEBUTTONDOWN, SDL_MOUSEBUTTONUP, SDL_WINDOWRESIZE
#   Key codes: printable keys are their ASCII byte; arrows are the synthetic
#     SDLK_LEFT / SDLK_RIGHT / SDLK_UP / SDLK_DOWN.
#   sdl_poll_event(&kind,&key,&x,&y,&button) -> int32   1 if dequeued, else 0
#         KEYDOWN/KEYUP  -> key = keycode
#         MOUSEMOTION    -> x,y = pointer, button = current button bitmask
#         MOUSEBUTTON*   -> x,y = pointer, button = which button (1 = left)
#         WINDOWRESIZE   -> x,y = new width,height
#   sdl_push_event(kind, key, x, y, button)             enqueue directly
#   sdl_push_quit()                                     enqueue SDL_QUIT
#   The backends translate DE wire lines to events for you, but these are also
#   public so a host test (or a game) can script input:
#   sdl_feed_key_line(s, n)          parse one "d <code>" / "u <code>" line
#   sdl_feed_event_line(s, n)        parse one "m x y btn" / "r w h" line
#   sdl_feed_keys_buffer(buf, n)     split a /keys read on '\n', feed each line
#   sdl_feed_event_buffer(buf, n)    split a /event read on '\n', feed each line
#
# --- Timing (pure; the backend supplies the clock + the sleep) ------------
#   sdl_set_fps(fps)                 set the target frame rate
#   sdl_frame_ms()      -> int32     ms budget for one frame at the target fps
#   sdl_frame_delay(elapsed_ms) -> int32   ms still to wait to hit the target
#
# No sockets, no raw Linux syscalls: native resource access is the DE scene /
# event files, reached only through the backends. Drawing is 100% via the
# lib/hamscene.ad display-list verbs (the same path every DE app uses).
# ===========================================================================

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_stroke, \
    hamscene_line, hamscene_roundrect, hamscene_glyphs, hamscene_glyphs_bold, \
    hamscene_image


# ---- Event-kind constants (public) ---------------------------------------
SDL_QUIT: int32 = 0
SDL_KEYDOWN: int32 = 1
SDL_KEYUP: int32 = 2
SDL_MOUSEMOTION: int32 = 3
SDL_MOUSEBUTTONDOWN: int32 = 4
SDL_MOUSEBUTTONUP: int32 = 5
SDL_WINDOWRESIZE: int32 = 6

# ---- Synthetic key codes for the arrow keys (public) ---------------------
# Printable keys arrive as their ASCII byte (0..255); the arrows are delivered
# by the compositor as ESC '[' A/B/C/D sequences and are surfaced here as these
# out-of-band codes so a game can test one keycode per key.
SDLK_UP: int32 = 256
SDLK_DOWN: int32 = 257
SDLK_LEFT: int32 = 258
SDLK_RIGHT: int32 = 259


# ---- Colour packing + "#rrggbb[aa]" emission -----------------------------
# Colours are a uint32 laid out 0xRRGGBBAA. Drawing calls convert to the
# NUL-terminated hex string the hamscene verbs expect, into a single shared
# scratch buffer — safe because each hamscene_* call copies the string out
# immediately before the next draw runs.
_sdl_col: Array[10, uint8]


def sdl_rgb(r: int32, g: int32, b: int32) -> uint32:
    return (cast[uint32](r & 255) << 24) | (cast[uint32](g & 255) << 16) | \
           (cast[uint32](b & 255) << 8) | 255


def sdl_rgba(r: int32, g: int32, b: int32, a: int32) -> uint32:
    return (cast[uint32](r & 255) << 24) | (cast[uint32](g & 255) << 16) | \
           (cast[uint32](b & 255) << 8) | cast[uint32](a & 255)


def _sdl_hexdig(v: uint32) -> uint8:
    d: uint32 = v & 15
    if d < 10:
        return cast[uint8](d) + 48                      # '0'..'9'
    return cast[uint8](d) - 10 + 97                     # 'a'..'f'


# Write "#rrggbb" (alpha 0xFF) or "#rrggbbaa" into _sdl_col; return &_sdl_col[0].
def _sdl_color(c: uint32) -> Ptr[uint8]:
    _sdl_col[0] = 35                                     # '#'
    _sdl_col[1] = _sdl_hexdig(c >> 28)
    _sdl_col[2] = _sdl_hexdig(c >> 24)
    _sdl_col[3] = _sdl_hexdig(c >> 20)
    _sdl_col[4] = _sdl_hexdig(c >> 16)
    _sdl_col[5] = _sdl_hexdig(c >> 12)
    _sdl_col[6] = _sdl_hexdig(c >> 8)
    a: uint32 = c & 255
    if a == 255:
        _sdl_col[7] = 0
        return &_sdl_col[0]
    _sdl_col[7] = _sdl_hexdig(c >> 4)
    _sdl_col[8] = _sdl_hexdig(c)
    _sdl_col[9] = 0
    return &_sdl_col[0]


# ---- Frame / drawing -----------------------------------------------------
def sdl_begin_frame():
    hamscene_begin()


def sdl_clear(w: int32, h: int32, color: uint32):
    hamscene_fill(0, 0, w, h, _sdl_color(color))


def sdl_fill_rect(x: int32, y: int32, w: int32, h: int32, color: uint32):
    hamscene_fill(x, y, w, h, _sdl_color(color))


def sdl_draw_rect(x: int32, y: int32, w: int32, h: int32, color: uint32):
    hamscene_stroke(x, y, w, h, 1, _sdl_color(color))


def sdl_fill_round_rect(x: int32, y: int32, w: int32, h: int32,
                        radius: int32, color: uint32):
    hamscene_roundrect(x, y, w, h, radius, _sdl_color(color))


def sdl_draw_line(x1: int32, y1: int32, x2: int32, y2: int32, color: uint32):
    hamscene_line(x1, y1, x2, y2, 1, _sdl_color(color))


def sdl_draw_line_t(x1: int32, y1: int32, x2: int32, y2: int32,
                    thick: int32, color: uint32):
    hamscene_line(x1, y1, x2, y2, thick, _sdl_color(color))


def sdl_blit(name: Ptr[uint8], x: int32, y: int32, w: int32, h: int32):
    hamscene_image(x, y, w, h, name)


def sdl_draw_text(x: int32, y: int32, s: Ptr[uint8], color: uint32):
    hamscene_glyphs(x, y, s, _sdl_color(color))


def sdl_draw_text_bold(x: int32, y: int32, s: Ptr[uint8], color: uint32):
    hamscene_glyphs_bold(x, y, s, _sdl_color(color))


# Cell text advances a fixed 8px per glyph (the DE `glyphs` grid); good enough
# for HUD layout. Proportional `text` measurement is a device concern (see
# lib/hamtextbox.ad) and out of scope for the round-1 core.
def sdl_text_width(s: Ptr[uint8]) -> int32:
    n: int32 = 0
    i: uint64 = 0
    while s[i] != 0:
        n = n + 1
        i = i + 1
    return n * 8


# Signed integer -> decimal string, drawn as text at (x, y).
_sdl_itoa_buf: Array[24, uint8]


def sdl_draw_int(x: int32, y: int32, v: int32, color: uint32):
    p: uint64 = 0
    neg: int32 = 0
    u: uint32 = 0
    if v < 0:
        neg = 1
        u = cast[uint32](0 - v)
    else:
        u = cast[uint32](v)
    if u == 0:
        _sdl_itoa_buf[0] = 48
        p = 1
    else:
        digs: Array[16, uint8]
        n: uint64 = 0
        while u > 0:
            digs[n] = cast[uint8](u % 10) + 48
            u = u / 10
            n = n + 1
        if neg == 1:
            _sdl_itoa_buf[p] = 45                        # '-'
            p = p + 1
        while n > 0:
            n = n - 1
            _sdl_itoa_buf[p] = digs[n]
            p = p + 1
    _sdl_itoa_buf[p] = 0
    hamscene_glyphs(x, y, &_sdl_itoa_buf[0], _sdl_color(color))


# ---- Event queue (a ring both backends + scripted tests feed) ------------
SDL_EVQ_CAP: uint64 = 128
_sdl_ev_kind: Array[128, int32]
_sdl_ev_key:  Array[128, int32]
_sdl_ev_x:    Array[128, int32]
_sdl_ev_y:    Array[128, int32]
_sdl_ev_btn:  Array[128, int32]
_sdl_ev_head: uint64 = 0
_sdl_ev_tail: uint64 = 0


def sdl_push_event(kind: int32, key: int32, x: int32, y: int32, button: int32):
    nxt: uint64 = (_sdl_ev_tail + 1) % SDL_EVQ_CAP
    if nxt == _sdl_ev_head:
        return                                           # queue full: drop
    _sdl_ev_kind[_sdl_ev_tail] = kind
    _sdl_ev_key[_sdl_ev_tail]  = key
    _sdl_ev_x[_sdl_ev_tail]    = x
    _sdl_ev_y[_sdl_ev_tail]    = y
    _sdl_ev_btn[_sdl_ev_tail]  = button
    _sdl_ev_tail = nxt


def sdl_push_quit():
    sdl_push_event(SDL_QUIT, 0, 0, 0, 0)


def sdl_poll_event(kind: Ptr[int32], key: Ptr[int32], x: Ptr[int32],
                   y: Ptr[int32], button: Ptr[int32]) -> int32:
    if _sdl_ev_head == _sdl_ev_tail:
        return 0
    kind[0]   = _sdl_ev_kind[_sdl_ev_head]
    key[0]    = _sdl_ev_key[_sdl_ev_head]
    x[0]      = _sdl_ev_x[_sdl_ev_head]
    y[0]      = _sdl_ev_y[_sdl_ev_head]
    button[0] = _sdl_ev_btn[_sdl_ev_head]
    _sdl_ev_head = (_sdl_ev_head + 1) % SDL_EVQ_CAP
    return 1


# ---- DE wire-line -> event translation -----------------------------------
# /keys lines are "d <code>" (press) / "u <code>" (release); code is an ASCII
# byte. Arrow keys arrive as an ESC '[' A/B/C/D sequence spread over successive
# press lines, tracked by _sdl_esc.
_sdl_esc: int32 = 0
# Previous left-button state, for pointer-button edge detection.
_sdl_btn0: int32 = 0


def _sdl_scan_dec(s: Ptr[uint8], n: uint64, i: uint64) -> int32:
    while i < n and s[i] == 32:
        i = i + 1
    v: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        v = v * 10 + cast[int32](s[i]) - 48
        i = i + 1
    return v


def sdl_feed_key_line(s: Ptr[uint8], n: uint64):
    if n < 1:
        return
    down: int32 = 0
    if s[0] == 100:                                      # 'd' press
        down = 1
    elif s[0] == 117:                                    # 'u' release
        down = 0
    else:
        return
    code: int32 = _sdl_scan_dec(s, n, 1)
    if code < 0 or code > 255:
        return
    kind: int32 = SDL_KEYUP
    if down == 1:
        kind = SDL_KEYDOWN
    # Arrow escape state machine.
    if _sdl_esc == 1:
        if code == 91:                                   # '['
            _sdl_esc = 2
            return
        _sdl_esc = 0                                     # not an arrow; fall thru
    elif _sdl_esc == 2:
        _sdl_esc = 0
        if code == 65:
            sdl_push_event(kind, SDLK_UP, 0, 0, 0)
        elif code == 66:
            sdl_push_event(kind, SDLK_DOWN, 0, 0, 0)
        elif code == 67:
            sdl_push_event(kind, SDLK_RIGHT, 0, 0, 0)
        elif code == 68:
            sdl_push_event(kind, SDLK_LEFT, 0, 0, 0)
        return
    if code == 27:                                       # ESC -> begin sequence
        _sdl_esc = 1
        return
    sdl_push_event(kind, code, 0, 0, 0)


def sdl_feed_event_line(s: Ptr[uint8], n: uint64):
    if n < 1:
        return
    if s[0] == 109:                                      # 'm' pointer
        # "m <x> <y> <btn>"
        i: uint64 = 1
        vals: Array[3, int32]
        v: uint64 = 0
        while v < 3:
            while i < n and s[i] == 32:
                i = i + 1
            neg: int32 = 0
            if i < n and s[i] == 45:
                neg = 1
                i = i + 1
            acc: int32 = 0
            got: int32 = 0
            while i < n and s[i] >= 48 and s[i] <= 57:
                acc = acc * 10 + cast[int32](s[i]) - 48
                i = i + 1
                got = 1
            if got == 0:
                return
            if neg == 1:
                acc = 0 - acc
            vals[v] = acc
            v = v + 1
        px: int32 = vals[0]
        py: int32 = vals[1]
        btn: int32 = vals[2]
        sdl_push_event(SDL_MOUSEMOTION, 0, px, py, btn)
        now0: int32 = btn & 1
        if now0 != 0 and _sdl_btn0 == 0:
            sdl_push_event(SDL_MOUSEBUTTONDOWN, 0, px, py, 1)
        elif now0 == 0 and _sdl_btn0 != 0:
            sdl_push_event(SDL_MOUSEBUTTONUP, 0, px, py, 1)
        _sdl_btn0 = now0
    elif s[0] == 114:                                    # 'r' resize
        i2: uint64 = 1
        wv: int32 = _sdl_scan_dec(s, n, 1)
        # advance past the width to read the height
        while i2 < n and s[i2] == 32:
            i2 = i2 + 1
        while i2 < n and s[i2] >= 48 and s[i2] <= 57:
            i2 = i2 + 1
        hv: int32 = _sdl_scan_dec(s, n, i2)
        sdl_push_event(SDL_WINDOWRESIZE, 0, wv, hv, 0)


# Split a raw /keys file read on '\n' and feed each non-empty line.
def sdl_feed_keys_buffer(buf: Ptr[uint8], n: uint64):
    ls: uint64 = 0
    i: uint64 = 0
    while i <= n:
        atend: int32 = 0
        if i == n:
            atend = 1
        if atend == 1 or buf[i] == 10:
            if i > ls:
                sdl_feed_key_line(&buf[ls], i - ls)
            ls = i + 1
        i = i + 1


# Split a raw /event file read on '\n' and feed each non-empty line.
def sdl_feed_event_buffer(buf: Ptr[uint8], n: uint64):
    ls: uint64 = 0
    i: uint64 = 0
    while i <= n:
        atend: int32 = 0
        if i == n:
            atend = 1
        if atend == 1 or buf[i] == 10:
            if i > ls:
                sdl_feed_event_line(&buf[ls], i - ls)
            ls = i + 1
        i = i + 1


# ---- Timing (pure; clock + sleep are supplied by the backend) ------------
_sdl_frame_ms: int32 = 33                                # ~30 fps default


def sdl_set_fps(fps: int32):
    if fps <= 0:
        _sdl_frame_ms = 0
        return
    _sdl_frame_ms = 1000 / fps


def sdl_frame_ms() -> int32:
    return _sdl_frame_ms


# Given how many ms the frame's work took, return how long to still wait to hit
# the target frame budget (0 if already over budget).
def sdl_frame_delay(elapsed_ms: int32) -> int32:
    rem: int32 = _sdl_frame_ms - elapsed_ms
    if rem < 0:
        return 0
    return rem

# lib/png.ad — a pure-Adder, integer-only PNG decoder.
#
# Decodes a PNG byte buffer into a flat 8-bit RGBA pixel array. It implements,
# from scratch and with NO extern/syscall/float, the three layers a PNG needs:
#   1. the container  — 8-byte signature + IHDR/PLTE/tRNS/IDAT/IEND chunk walk;
#   2. DEFLATE inflate — RFC-1951 stored + fixed-Huffman + dynamic-Huffman
#      blocks over the concatenated IDAT payload (a canonical-Huffman decoder
#      ported in the spirit of Mark Adler's puff.c, all in uint32 math);
#   3. PNG unfiltering — None/Sub/Up/Average/Paeth per scanline.
#
# Colour types: 8-bit truecolour RGB (2) and RGBA (6) are first-class; 8-bit
# grayscale (0) and 8-bit palette (3, with an optional tRNS alpha table) are
# also handled. Non-8-bit depths and interlacing are rejected (png_decode
# returns a negative error) — the caller then draws a broken-image placeholder.
#
# PURE: no I/O. The caller slurps the file bytes and hands them here; the
# decoded RGBA lives in this module's BSS and is read back via png_w/png_h and
# png_pixel(). Extern-free, so it compiles for the Linux host AND the native
# target from the same source.

# ---- capacities (BSS) ----------------------------------------------
PNG_MAX_DIM:   uint64 = 512         # max width or height accepted
PNG_RAW_CAP:   uint64 = 1310720     # inflate output: 512*(512*4+1) rounded up
PNG_OUT_CAP:   uint64 = 1048576     # RGBA output: 512*512*4

png_raw: Array[1310720, uint8]      # unfiltered-then-filtered scanline bytes
png_out: Array[1048576, uint8]      # final RGBA, row-major, 4 bytes/px

png_w:  int32 = 0
png_h:  int32 = 0
png_ok: int32 = 0

# ---- DEFLATE bit reader state --------------------------------------
inf_in:    Ptr[uint8]               # compressed input (concatenated IDAT)
inf_inlen: uint64 = 0
inf_pos:   uint64 = 0               # next input byte index
inf_bitbuf: uint32 = 0
inf_bitcnt: uint32 = 0
inf_out:   uint64 = 0               # next png_raw write index
inf_err:   int32 = 0

# ---- Huffman tables (canonical) ------------------------------------
# count[len] = number of codes of that bit length; symbol[] = symbols sorted by
# code. Separate tables for literal/length, distance, and the code-length code.
lit_count: Array[16, uint16]
lit_sym:   Array[288, uint16]
dst_count: Array[16, uint16]
dst_sym:   Array[32, uint16]
cl_count:  Array[16, uint16]
cl_sym:    Array[19, uint16]

# scratch code-length buffer for dynamic blocks (288 lit/len + 32 dist).
inf_lens: Array[320, uint16]

# ---- length/distance base + extra-bit tables -----------------------
len_base: Array[29, uint16]
len_ext:  Array[29, uint8]
dst_base: Array[30, uint16]
dst_ext:  Array[30, uint8]
cl_order: Array[19, uint8]
tbl_ready: int32 = 0


def _png_init_tables():
    if tbl_ready != 0:
        return
    # length symbol 257..285 base lengths + extra bits
    i: uint64 = 0
    len_base[0]=3
    len_base[1]=4
    len_base[2]=5
    len_base[3]=6
    len_base[4]=7
    len_base[5]=8
    len_base[6]=9
    len_base[7]=10
    len_base[8]=11
    len_base[9]=13
    len_base[10]=15
    len_base[11]=17
    len_base[12]=19
    len_base[13]=23
    len_base[14]=27
    len_base[15]=31
    len_base[16]=35
    len_base[17]=43
    len_base[18]=51
    len_base[19]=59
    len_base[20]=67
    len_base[21]=83
    len_base[22]=99
    len_base[23]=115
    len_base[24]=131
    len_base[25]=163
    len_base[26]=195
    len_base[27]=227
    len_base[28]=258
    i = 0
    while i < 29:
        len_ext[i] = 0
        i = i + 1
    len_ext[8]=1
    len_ext[9]=1
    len_ext[10]=1
    len_ext[11]=1
    len_ext[12]=2
    len_ext[13]=2
    len_ext[14]=2
    len_ext[15]=2
    len_ext[16]=3
    len_ext[17]=3
    len_ext[18]=3
    len_ext[19]=3
    len_ext[20]=4
    len_ext[21]=4
    len_ext[22]=4
    len_ext[23]=4
    len_ext[24]=5
    len_ext[25]=5
    len_ext[26]=5
    len_ext[27]=5
    len_ext[28]=0
    # distance symbol 0..29 base + extra
    dst_base[0]=1
    dst_base[1]=2
    dst_base[2]=3
    dst_base[3]=4
    dst_base[4]=5
    dst_base[5]=7
    dst_base[6]=9
    dst_base[7]=13
    dst_base[8]=17
    dst_base[9]=25
    dst_base[10]=33
    dst_base[11]=49
    dst_base[12]=65
    dst_base[13]=97
    dst_base[14]=129
    dst_base[15]=193
    dst_base[16]=257
    dst_base[17]=385
    dst_base[18]=513
    dst_base[19]=769
    dst_base[20]=1025
    dst_base[21]=1537
    dst_base[22]=2049
    dst_base[23]=3073
    dst_base[24]=4097
    dst_base[25]=6145
    dst_base[26]=8193
    dst_base[27]=12289
    dst_base[28]=16385
    dst_base[29]=24577
    dst_ext[0]=0
    dst_ext[1]=0
    dst_ext[2]=0
    dst_ext[3]=0
    dst_ext[4]=1
    dst_ext[5]=1
    dst_ext[6]=2
    dst_ext[7]=2
    dst_ext[8]=3
    dst_ext[9]=3
    dst_ext[10]=4
    dst_ext[11]=4
    dst_ext[12]=5
    dst_ext[13]=5
    dst_ext[14]=6
    dst_ext[15]=6
    dst_ext[16]=7
    dst_ext[17]=7
    dst_ext[18]=8
    dst_ext[19]=8
    dst_ext[20]=9
    dst_ext[21]=9
    dst_ext[22]=10
    dst_ext[23]=10
    dst_ext[24]=11
    dst_ext[25]=11
    dst_ext[26]=12
    dst_ext[27]=12
    dst_ext[28]=13
    dst_ext[29]=13
    # code-length code order
    cl_order[0]=16
    cl_order[1]=17
    cl_order[2]=18
    cl_order[3]=0
    cl_order[4]=8
    cl_order[5]=7
    cl_order[6]=9
    cl_order[7]=6
    cl_order[8]=10
    cl_order[9]=5
    cl_order[10]=11
    cl_order[11]=4
    cl_order[12]=12
    cl_order[13]=3
    cl_order[14]=13
    cl_order[15]=2
    cl_order[16]=14
    cl_order[17]=1
    cl_order[18]=15
    tbl_ready = 1


# Read `need` (0..16) bits LSB-first from the DEFLATE stream. Sets inf_err on
# input underflow and returns 0.
def _inf_bits(need: uint32) -> uint32:
    val: uint32 = inf_bitbuf
    while inf_bitcnt < need:
        if inf_pos >= inf_inlen:
            inf_err = 1
            return 0
        b: uint32 = cast[uint32](inf_in[inf_pos])
        inf_pos = inf_pos + 1
        val = val | (b << inf_bitcnt)
        inf_bitcnt = inf_bitcnt + 8
    inf_bitbuf = val >> need
    inf_bitcnt = inf_bitcnt - need
    mask: uint32 = (cast[uint32](1) << need) - 1
    return val & mask


# Build a canonical Huffman table (count[]/symbol[]) from `n` code lengths in
# `lens[loff..loff+n)`. Returns 0 on OK, negative on an over-subscribed set.
def _inf_construct(count: Ptr[uint16], sym: Ptr[uint16],
                   lens: Ptr[uint16], loff: uint64, n: uint64) -> int32:
    l: uint64 = 0
    while l <= 15:
        count[l] = 0
        l = l + 1
    s: uint64 = 0
    while s < n:
        count[lens[loff + s]] = count[lens[loff + s]] + 1
        s = s + 1
    # all-zero-length table is legal (e.g. an absent distance tree)
    if cast[uint64](count[0]) == n:
        return 0
    # check for an over- or incomplete set
    left: int32 = 1
    ln: uint64 = 1
    while ln <= 15:
        left = left * 2
        left = left - cast[int32](count[ln])
        if left < 0:
            return -1
        ln = ln + 1
    # offsets of each length within the sorted symbol table
    offs: Array[16, uint16]
    offs[1] = 0
    ln = 1
    while ln < 15:
        offs[ln + 1] = cast[uint16](cast[int32](offs[ln]) + cast[int32](count[ln]))
        ln = ln + 1
    s = 0
    while s < n:
        if lens[loff + s] != 0:
            o: uint64 = cast[uint64](offs[lens[loff + s]])
            sym[o] = cast[uint16](s)
            offs[lens[loff + s]] = cast[uint16](o + 1)
        s = s + 1
    return 0


# Decode one symbol via canonical table (count[]/symbol[]). Negative on error.
def _inf_decode(count: Ptr[uint16], sym: Ptr[uint16]) -> int32:
    code: int32 = 0
    first: int32 = 0
    index: int32 = 0
    len: uint32 = 1
    while len <= 15:
        code = code | cast[int32](_inf_bits(1))
        if inf_err != 0:
            return -1
        cnt: int32 = cast[int32](count[len])
        if code - first < cnt:
            return cast[int32](sym[cast[uint64](index + (code - first))])
        index = index + cnt
        first = first + cnt
        first = first * 2
        code = code * 2
        len = len + 1
    return -1


# Emit one literal byte to the inflate output. Sets inf_err on overflow.
def _inf_put(b: uint8):
    if inf_out >= PNG_RAW_CAP:
        inf_err = 1
        return
    png_raw[inf_out] = b
    inf_out = inf_out + 1


# Decode a compressed block body given its literal/length + distance tables.
def _inf_codes(lc: Ptr[uint16], ls: Ptr[uint16],
               dc: Ptr[uint16], ds: Ptr[uint16]) -> int32:
    while inf_err == 0:
        symbol: int32 = _inf_decode(lc, ls)
        if symbol < 0:
            return -1
        if symbol == 256:
            return 0
        if symbol < 256:
            _inf_put(cast[uint8](symbol))
        else:
            symbol = symbol - 257
            if symbol >= 29:
                return -1
            length: uint32 = cast[uint32](len_base[symbol]) + \
                             _inf_bits(cast[uint32](len_ext[symbol]))
            dsym: int32 = _inf_decode(dc, ds)
            if dsym < 0 or dsym >= 30:
                return -1
            dist: uint64 = cast[uint64](dst_base[dsym]) + \
                           cast[uint64](_inf_bits(cast[uint32](dst_ext[dsym])))
            if dist > inf_out:
                return -1
            k: uint32 = 0
            while k < length:
                if inf_out >= PNG_RAW_CAP:
                    inf_err = 1
                    return -1
                png_raw[inf_out] = png_raw[inf_out - dist]
                inf_out = inf_out + 1
                k = k + 1
    return -1


# Load the RFC-1951 fixed Huffman tables into lit_*/dst_*.
def _inf_fixed():
    s: uint64 = 0
    while s < 144:
        inf_lens[s] = 8
        s = s + 1
    while s < 256:
        inf_lens[s] = 9
        s = s + 1
    while s < 280:
        inf_lens[s] = 7
        s = s + 1
    while s < 288:
        inf_lens[s] = 8
        s = s + 1
    _inf_construct(&lit_count[0], &lit_sym[0], &inf_lens[0], 0, 288)
    s = 0
    while s < 30:
        inf_lens[s] = 5
        s = s + 1
    _inf_construct(&dst_count[0], &dst_sym[0], &inf_lens[0], 0, 30)


# Read a dynamic block's Huffman descriptions, then build lit_*/dst_*.
def _inf_dynamic() -> int32:
    nlen:  uint64 = cast[uint64](_inf_bits(5)) + 257
    ndist: uint64 = cast[uint64](_inf_bits(5)) + 1
    ncode: uint64 = cast[uint64](_inf_bits(4)) + 4
    if nlen > 286 or ndist > 30:
        return -1
    # code-length code lengths, in the funny order
    i: uint64 = 0
    while i < 19:
        inf_lens[i] = 0
        i = i + 1
    i = 0
    while i < ncode:
        inf_lens[cast[uint64](cl_order[i])] = cast[uint16](_inf_bits(3))
        i = i + 1
    if _inf_construct(&cl_count[0], &cl_sym[0], &inf_lens[0], 0, 19) != 0:
        return -1
    # decode the nlen+ndist code lengths, into inf_lens[0..nlen+ndist)
    total: uint64 = nlen + ndist
    idx: uint64 = 0
    while idx < total:
        sym: int32 = _inf_decode(&cl_count[0], &cl_sym[0])
        if sym < 0:
            return -1
        if sym < 16:
            inf_lens[idx] = cast[uint16](sym)
            idx = idx + 1
        else:
            rep: uint32 = 0
            val: uint16 = 0
            if sym == 16:
                if idx == 0:
                    return -1
                val = inf_lens[idx - 1]
                rep = 3 + _inf_bits(2)
            elif sym == 17:
                rep = 3 + _inf_bits(3)
            else:
                rep = 11 + _inf_bits(7)
            while rep > 0:
                if idx >= total:
                    return -1
                inf_lens[idx] = val
                idx = idx + 1
                rep = rep - 1
    if _inf_construct(&lit_count[0], &lit_sym[0], &inf_lens[0], 0, nlen) != 0:
        return -1
    # distance table (offset nlen); an incomplete single-symbol tree is OK
    _inf_construct(&dst_count[0], &dst_sym[0], &inf_lens[0], nlen, ndist)
    return 0


# Copy a stored (uncompressed) block: byte-align, read LEN, copy LEN bytes.
def _inf_stored() -> int32:
    inf_bitbuf = 0
    inf_bitcnt = 0
    if inf_pos + 4 > inf_inlen:
        return -1
    l0: uint32 = cast[uint32](inf_in[inf_pos])
    l1: uint32 = cast[uint32](inf_in[inf_pos + 1])
    length: uint64 = cast[uint64](l0 | (l1 << 8))
    inf_pos = inf_pos + 4                             # skip LEN + NLEN
    if inf_pos + length > inf_inlen:
        return -1
    k: uint64 = 0
    while k < length:
        _inf_put(inf_in[inf_pos])
        inf_pos = inf_pos + 1
        k = k + 1
    if inf_err != 0:
        return -1
    return 0


# Inflate the whole DEFLATE stream in inf_in[0..inf_inlen) into png_raw.
# Returns the number of output bytes, or negative on error.
def _inflate() -> int64:
    inf_pos = 0
    inf_bitbuf = 0
    inf_bitcnt = 0
    inf_out = 0
    inf_err = 0
    final: uint32 = 0
    while final == 0:
        final = _inf_bits(1)
        btype: uint32 = _inf_bits(2)
        if inf_err != 0:
            return -1
        if btype == 0:
            if _inf_stored() != 0:
                return -1
        elif btype == 1:
            _inf_fixed()
            if _inf_codes(&lit_count[0], &lit_sym[0],
                          &dst_count[0], &dst_sym[0]) != 0:
                return -1
        elif btype == 2:
            if _inf_dynamic() != 0:
                return -1
            if _inf_codes(&lit_count[0], &lit_sym[0],
                          &dst_count[0], &dst_sym[0]) != 0:
                return -1
        else:
            return -1
        if inf_err != 0:
            return -1
    return cast[int64](inf_out)


# ---- big-endian chunk length reader --------------------------------
def _be32(p: Ptr[uint8], o: uint64) -> uint64:
    return (cast[uint64](p[o]) << 24) | (cast[uint64](p[o + 1]) << 16) | \
           (cast[uint64](p[o + 2]) << 8) | cast[uint64](p[o + 3])


# Paeth predictor for the Paeth unfilter.
def _paeth(a: int32, b: int32, c: int32) -> int32:
    p: int32 = a + b - c
    pa: int32 = p - a
    if pa < 0:
        pa = 0 - pa
    pb: int32 = p - b
    if pb < 0:
        pb = 0 - pb
    pc: int32 = p - c
    if pc < 0:
        pc = 0 - pc
    if pa <= pb and pa <= pc:
        return a
    if pb <= pc:
        return b
    return c


# ---- PNG container state -------------------------------------------
png_palette: Array[1024, uint8]     # up to 256 entries * 4 (RGBA)
png_pal_n:  int32 = 0
idat_buf:   Array[262144, uint8]    # concatenated IDAT payload
idat_len:   uint64 = 0


# Decode PNG bytes at buf[0..len). On success sets png_w/png_h/png_ok=1 and
# fills png_out with RGBA; returns 0. Negative return = undecodable (caller
# draws a placeholder). Supports 8-bit colour types 0/2/3/6, no interlace.
def png_decode(buf: Ptr[uint8], len: uint64) -> int32:
    _png_init_tables()
    png_ok = 0
    png_w = 0
    png_h = 0
    png_pal_n = 0
    idat_len = 0
    if len < 8:
        return -1
    # signature 137 80 78 71 13 10 26 10
    if buf[0] != 137 or buf[1] != 80 or buf[2] != 78 or buf[3] != 71 or \
       buf[4] != 13 or buf[5] != 10 or buf[6] != 26 or buf[7] != 10:
        return -1
    o: uint64 = 8
    bit_depth: int32 = 0
    color_type: int32 = -1
    seen_ihdr: int32 = 0
    while o + 8 <= len:
        clen: uint64 = _be32(buf, o)
        t0: uint8 = buf[o + 4]
        t1: uint8 = buf[o + 5]
        t2: uint8 = buf[o + 6]
        t3: uint8 = buf[o + 7]
        dstart: uint64 = o + 8
        if dstart + clen + 4 > len:
            return -1
        # IHDR
        if t0 == 73 and t1 == 72 and t2 == 68 and t3 == 82:
            if clen < 13:
                return -1
            png_w = cast[int32](_be32(buf, dstart))
            png_h = cast[int32](_be32(buf, dstart + 4))
            bit_depth = cast[int32](buf[dstart + 8])
            color_type = cast[int32](buf[dstart + 9])
            interlace: int32 = cast[int32](buf[dstart + 12])
            if png_w <= 0 or png_h <= 0:
                return -1
            if cast[uint64](png_w) > PNG_MAX_DIM or \
               cast[uint64](png_h) > PNG_MAX_DIM:
                return -1
            if bit_depth != 8 or interlace != 0:
                return -1
            if color_type != 0 and color_type != 2 and color_type != 3 and \
               color_type != 6:
                return -1
            seen_ihdr = 1
        # PLTE
        elif t0 == 80 and t1 == 76 and t2 == 84 and t3 == 69:
            ne: uint64 = clen / 3
            if ne > 256:
                ne = 256
            k: uint64 = 0
            while k < ne:
                png_palette[k * 4] = buf[dstart + k * 3]
                png_palette[k * 4 + 1] = buf[dstart + k * 3 + 1]
                png_palette[k * 4 + 2] = buf[dstart + k * 3 + 2]
                png_palette[k * 4 + 3] = 255
                k = k + 1
            png_pal_n = cast[int32](ne)
        # tRNS (palette alpha)
        elif t0 == 116 and t1 == 82 and t2 == 78 and t3 == 83:
            if color_type == 3:
                k: uint64 = 0
                while k < clen and k < 256:
                    png_palette[k * 4 + 3] = buf[dstart + k]
                    k = k + 1
        # IDAT
        elif t0 == 73 and t1 == 68 and t2 == 65 and t3 == 84:
            k: uint64 = 0
            while k < clen:
                if idat_len >= 262144:
                    return -1
                idat_buf[idat_len] = buf[dstart + k]
                idat_len = idat_len + 1
                k = k + 1
        # IEND
        elif t0 == 73 and t1 == 69 and t2 == 78 and t3 == 68:
            break
        o = dstart + clen + 4
    if seen_ihdr == 0 or idat_len < 2:
        return -1

    # zlib wrapper: 2-byte header (CMF/FLG); no preset dict for PNG. Feed the
    # DEFLATE stream that follows to the inflater.
    inf_in = &idat_buf[2]
    inf_inlen = idat_len - 2
    nraw: int64 = _inflate()
    if nraw < 0:
        return -1

    # ---- unfilter into png_out (RGBA) ----
    chans: int32 = 1                                  # grayscale
    if color_type == 2:
        chans = 3
    elif color_type == 6:
        chans = 4
    elif color_type == 3:
        chans = 1
    bpp: int32 = chans                                # bytes-per-pixel (8-bit)
    stride: int32 = png_w * chans
    need: int64 = cast[int64](png_h) * cast[int64](stride + 1)
    if nraw < need:
        return -1

    # unfilter in place within png_raw (each byte references the row above / the
    # pixel `bpp` bytes to the left, both already reconstructed).
    row: int32 = 0
    while row < png_h:
        fbase: uint64 = cast[uint64](row) * cast[uint64](stride + 1)
        ftype: uint8 = png_raw[fbase]
        rbase: uint64 = fbase + 1
        # previous row's data begins one full row (filter byte + stride) back.
        prev: uint64 = rbase - cast[uint64](stride + 1)
        c: int32 = 0
        while c < stride:
            cur: uint64 = rbase + cast[uint64](c)
            x: int32 = cast[int32](png_raw[cur])
            a: int32 = 0                              # left
            if c >= bpp:
                a = cast[int32](png_raw[cur - cast[uint64](bpp)])
            b: int32 = 0                              # up
            if row > 0:
                b = cast[int32](png_raw[prev + cast[uint64](c)])
            cc: int32 = 0                             # up-left
            if row > 0 and c >= bpp:
                cc = cast[int32](png_raw[prev + cast[uint64](c) - cast[uint64](bpp)])
            recon: int32 = x
            if ftype == 1:
                recon = x + a
            elif ftype == 2:
                recon = x + b
            elif ftype == 3:
                recon = x + (a + b) / 2
            elif ftype == 4:
                recon = x + _paeth(a, b, cc)
            png_raw[cur] = cast[uint8](recon & 255)
            c = c + 1
        row = row + 1

    # ---- expand to RGBA in png_out ----
    npix: uint64 = cast[uint64](png_w) * cast[uint64](png_h)
    if npix * 4 > PNG_OUT_CAP:
        return -1
    py: int32 = 0
    while py < png_h:
        rbase: uint64 = cast[uint64](py) * cast[uint64](stride + 1) + 1
        px: int32 = 0
        while px < png_w:
            src: uint64 = rbase + cast[uint64](px * chans)
            dst: uint64 = (cast[uint64](py) * cast[uint64](png_w) + \
                           cast[uint64](px)) * 4
            if color_type == 2:
                png_out[dst] = png_raw[src]
                png_out[dst + 1] = png_raw[src + 1]
                png_out[dst + 2] = png_raw[src + 2]
                png_out[dst + 3] = 255
            elif color_type == 6:
                png_out[dst] = png_raw[src]
                png_out[dst + 1] = png_raw[src + 1]
                png_out[dst + 2] = png_raw[src + 2]
                png_out[dst + 3] = png_raw[src + 3]
            elif color_type == 0:
                g: uint8 = png_raw[src]
                png_out[dst] = g
                png_out[dst + 1] = g
                png_out[dst + 2] = g
                png_out[dst + 3] = 255
            else:                                     # palette (3)
                pidx: uint64 = cast[uint64](png_raw[src])
                png_out[dst] = png_palette[pidx * 4]
                png_out[dst + 1] = png_palette[pidx * 4 + 1]
                png_out[dst + 2] = png_palette[pidx * 4 + 2]
                png_out[dst + 3] = png_palette[pidx * 4 + 3]
            px = px + 1
        py = py + 1
    png_ok = 1
    return 0


def png_width() -> int32:
    return png_w


def png_height() -> int32:
    return png_h


# Packed 0xAARRGGBB for pixel (x,y) of the LAST successfully decoded image.
def png_pixel(x: int32, y: int32) -> uint32:
    if png_ok == 0 or x < 0 or y < 0 or x >= png_w or y >= png_h:
        return 0
    o: uint64 = (cast[uint64](y) * cast[uint64](png_w) + cast[uint64](x)) * 4
    r: uint32 = cast[uint32](png_out[o])
    g: uint32 = cast[uint32](png_out[o + 1])
    b: uint32 = cast[uint32](png_out[o + 2])
    a: uint32 = cast[uint32](png_out[o + 3])
    return (a << 24) | (r << 16) | (g << 8) | b


# Raw RGBA output pointer (row-major, 4 bytes/px) for a bulk copy into a store.
def png_rgba_ptr() -> Ptr[uint8]:
    return &png_out[0]

# lib/htermsel.ad — grid-text SELECTION model for the scene-file DE terminal
# (task #323: "copy an error message out of a terminal").
#
# The graphical terminal (user/hamtermscene.ad) renders the shell's output as a
# monospace GLYPH GRID (rows x cols of cells), NOT the single editable text box
# the #315 lib/hamtextbox substrate models — so this is a SEPARATE, purpose-built
# selection model over a 2-D cell grid. It owns:
#
#   * the click-drag selection STATE (an anchor cell + a caret cell),
#   * pixel -> cell mapping for the terminal's 8px monospace column model,
#   * the linear TEXT-FLOW span test used to highlight selected cells, and
#   * cell-span -> TEXT extraction (per-row trailing-space trim, rows joined by
#     '\n') — the string that gets copied.
#
# CLIPBOARD REUSE (task brief): a copy WRITES a Plan 9 file the compositor
# serves — /dev/snarf (CLIPBOARD, Ctrl+C/Ctrl+V) or /dev/snarf.primary (PRIMARY
# selection, highlight -> middle-click paste) — exactly the #315 protocol. We
# reuse that FILE PROTOCOL directly rather than importing lib.hamtextbox's
# htb_clip_put, because importing it drags the proportional TTF font engine
# (lib.font_ttf / lib.browserfonts / lib.hamscene) into the deliberately-minimal
# terminal binary. The three-syscall put/get here is the same REPLACE-on-write
# device contract, no new syscall (arch invariant: file-backed clipboard).
#
# The selection state, the pixel->cell map, the span test and the extractor are
# PURE (no terminal globals): the extractor takes the grid by pointer, so a
# headless host unit test (user/htermsel_host.ad) can feed synthetic
# anchor+caret cells over a synthetic grid and assert the extracted text —
# deterministic, font-independent, no compositor, no flaky mouse injection.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

# --- terminal cell geometry (must match user/hamtermscene.ad's grid model) ---
# The scene draws each row as `glyphs 6 <y> "..."`; glyph cells advance 8px from
# x=6, and rows are pitched 20px from y=6 (TERM_GLYPH_W / TERM_LINE_H there).
HTSEL_X0:     int64 = 6
HTSEL_CELL_W: int64 = 8
HTSEL_Y0:     int64 = 6
HTSEL_LINE_H: int64 = 20

# --- selection state ---------------------------------------------------------
# anchor = where the drag started (the fixed end); caret = the moving end.
# `active` is 0 for a bare click (anchor==caret, nothing highlighted) and 1 once
# the caret has moved off the anchor (a real drag span).
htsel_active_f: int32 = 0
htsel_armed:    int32 = 0                 # a press landed; a drag may follow
htsel_ar: int64 = 0                       # anchor row
htsel_ac: int64 = 0                       # anchor col
htsel_cr: int64 = 0                       # caret row
htsel_cc: int64 = 0                       # caret col


def htsel_reset():
    htsel_active_f = 0
    htsel_armed = 0
    htsel_ar = 0
    htsel_ac = 0
    htsel_cr = 0
    htsel_cc = 0


def htsel_begin(row: int64, col: int64):
    # A button PRESS: drop the anchor, collapse the selection. Not active until
    # the caret is dragged off the anchor.
    htsel_armed = 1
    htsel_active_f = 0
    htsel_ar = row
    htsel_ac = col
    htsel_cr = row
    htsel_cc = col


def htsel_extend(row: int64, col: int64):
    # A DRAG: move the caret. The span becomes active as soon as the caret
    # differs from the anchor.
    if htsel_armed == 0:
        return
    htsel_cr = row
    htsel_cc = col
    if row != htsel_ar or col != htsel_ac:
        htsel_active_f = 1


def htsel_active() -> int32:
    return htsel_active_f


# Accessors (for the host unit test + the terminal's grid hash).
def htsel_anchor_row() -> int64:
    return htsel_ar


def htsel_anchor_col() -> int64:
    return htsel_ac


def htsel_caret_row() -> int64:
    return htsel_cr


def htsel_caret_col() -> int64:
    return htsel_cc


# 1 when the anchor is the START of the span in reading order (row-major), 0
# when the caret is (i.e. the user dragged UP / leftward past the anchor).
def _htsel_anchor_first() -> int32:
    if htsel_ar < htsel_cr:
        return 1
    if htsel_ar > htsel_cr:
        return 0
    if htsel_ac <= htsel_cc:
        return 1
    return 0


# Ordered INCLUSIVE endpoints of the span in text-flow order: start cell
# (sr,sc) <= end cell (er,ec).
def _htsel_ordered(sr: Ptr[int64], sc: Ptr[int64], er: Ptr[int64],
                   ec: Ptr[int64]):
    if _htsel_anchor_first() != 0:
        sr[0] = htsel_ar
        sc[0] = htsel_ac
        er[0] = htsel_cr
        ec[0] = htsel_cc
    else:
        sr[0] = htsel_cr
        sc[0] = htsel_cc
        er[0] = htsel_ar
        ec[0] = htsel_ac


# Is cell (row,col) inside the selected span (linear text-flow order)? Used by
# the renderer to paint the highlight band. A row strictly between the start and
# end row is fully selected; the start/end rows are clipped at sc / ec.
def htsel_cell_selected(row: int64, col: int64) -> int32:
    if htsel_active_f == 0:
        return 0
    sr: int64 = 0
    sc: int64 = 0
    er: int64 = 0
    ec: int64 = 0
    _htsel_ordered(&sr, &sc, &er, &ec)
    if row < sr or row > er:
        return 0
    if row == sr and col < sc:
        return 0
    if row == er and col > ec:
        return 0
    return 1


# Extract the selected text. Walk the selected cells start..end in text-flow
# order; per row take columns [c0,c1] (start row clipped at sc, end row at ec,
# interior rows the full width), treat cells past the row's live length as
# spaces, TRIM trailing spaces per row, and JOIN rows with '\n'. Writes at most
# `cap` bytes into `out`; returns the byte length. 0 when no active selection.
def htsel_extract(rows: Ptr[uint8], row_len: Ptr[uint64], stride: uint64,
                  cols_n: uint64, out: Ptr[uint8], cap: uint64) -> uint64:
    if htsel_active_f == 0:
        return 0
    if cols_n == 0:
        return 0
    sr: int64 = 0
    sc: int64 = 0
    er: int64 = 0
    ec: int64 = 0
    _htsel_ordered(&sr, &sc, &er, &ec)
    op: uint64 = 0
    r: int64 = sr
    while r <= er:
        c0: int64 = 0
        if r == sr:
            c0 = sc
        c1: int64 = cast[int64](cols_n) - 1        # inclusive last column
        if r == er:
            c1 = ec
        if c1 > cast[int64](cols_n) - 1:
            c1 = cast[int64](cols_n) - 1
        if c0 < 0:
            c0 = 0
        base: uint64 = cast[uint64](r) * stride
        rl: uint64 = row_len[cast[uint64](r)]
        rowstart: uint64 = op
        c: int64 = c0
        while c <= c1:
            ch: uint8 = 32                          # cells past row_len are blank
            if cast[uint64](c) < rl:
                ch = rows[base + cast[uint64](c)]
            if op < cap:
                out[op] = ch
                op = op + 1
            c = c + 1
        # Trim trailing spaces on this row (terminal cells are space-padded).
        while op > rowstart and out[op - 1] == 32:
            op = op - 1
        if r < er:                                  # newline between rows only
            if op < cap:
                out[op] = 10
                op = op + 1
        r = r + 1
    return op


# Map a window-content-local pixel (lx,ly) to a grid cell (row,col), clamped to
# the active grid. The terminal's column model is 8px monospace cells from x=6;
# on-device `glyphs` render via the proportional TTF face, so the highlight
# tracks the terminal's OWN cell model (which is what term_col / the caret use)
# rather than exact glyph advances — round-1 monospace-grid selection.
def htsel_pix_to_cell(lx: int64, ly: int64, rows_n: int64, cols_n: int64,
                      out_row: Ptr[int64], out_col: Ptr[int64]):
    cx: int64 = lx - HTSEL_X0
    if cx < 0:
        cx = 0
    col: int64 = cx / HTSEL_CELL_W
    if cols_n > 0 and col > cols_n - 1:
        col = cols_n - 1
    cy: int64 = ly - HTSEL_Y0
    if cy < 0:
        cy = 0
    row: int64 = cy / HTSEL_LINE_H
    if rows_n > 0 and row > rows_n - 1:
        row = rows_n - 1
    out_row[0] = row
    out_col[0] = col


# --- clipboard / primary selection (file-backed, #315 protocol) --------------
def _htsel_clip_path(prim: int32) -> Ptr[char]:
    if prim != 0:
        return cast[Ptr[char]]("/dev/snarf.primary")
    return cast[Ptr[char]]("/dev/snarf")


# Copy `n` bytes into the selected buffer (REPLACE-on-write). prim: 0=CLIPBOARD
# (/dev/snarf), 1=PRIMARY (/dev/snarf.primary). Returns 1 on success, 0 on fail.
def htsel_clip_put(prim: int32, buf: Ptr[uint8], n: uint64) -> int32:
    fd: int32 = sys_open_write(_htsel_clip_path(prim))
    if fd < 0:
        return 0
    w: int64 = sys_write(fd, buf, n)
    sys_close(fd)
    if w < 0:
        return 0
    return 1


# Read up to `cap` bytes of the selected buffer into `out`; returns bytes read.
def htsel_clip_get(prim: int32, out: Ptr[uint8], cap: uint64) -> uint64:
    fd: int32 = sys_open(_htsel_clip_path(prim))
    if fd < 0:
        return 0
    total: uint64 = 0
    while total < cap:
        r: int64 = sys_read(fd, &out[total], cap - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    return total

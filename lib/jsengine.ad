# ====================================================================
# Regex instruction opcodes (backtracking bytecode VM).
# ====================================================================
RI_CHAR:    int32 = 0          # re_x = char byte
RI_ANY:     int32 = 1          # . (any char except newline)
RI_CLASS:   int32 = 2          # re_x = class index
RI_MATCH:   int32 = 3          # accept
RI_JMP:     int32 = 4          # re_x = target pc
RI_SPLIT:   int32 = 5          # try re_x first, then re_y
RI_SAVE:    int32 = 6          # re_x = capture slot; record sp
RI_BOL:     int32 = 7          # ^
RI_EOL:     int32 = 8          # $
RI_WORDB:   int32 = 9          # \b
RI_NWORDB:  int32 = 10         # \B
RI_BACKREF: int32 = 11         # re_x = group index

# Regex AST node ops (scratch AST between parse and codegen).
RN_CHAR:   int32 = 0           # rn_a = char
RN_ANY:    int32 = 1
RN_CLASS:  int32 = 2           # rn_a = class index
RN_BOL:    int32 = 3
RN_EOL:    int32 = 4
RN_WORDB:  int32 = 5
RN_NWORDB: int32 = 6
RN_BACKREF: int32 = 7          # rn_a = group index
RN_GROUP:  int32 = 8           # rn_d = child (alt), rn_a = capture index (-1 = non-capturing)
RN_STAR:   int32 = 9           # rn_d = child, rn_b = greedy
RN_PLUS:   int32 = 10          # rn_d = child, rn_b = greedy
RN_QUEST:  int32 = 11          # rn_d = child, rn_b = greedy
RN_REPEAT: int32 = 12          # rn_d = child, rn_b = min, rn_c = max(-1=inf), rn_a = greedy
RN_SEQ:    int32 = 13          # rn_a = head of item list (rn_next chained)
RN_ALT:    int32 = 14          # rn_a = head of branch list (rn_next chained)

# ====================================================================
# POOLS (all BSS; bump-allocated).
# ====================================================================
MAX_VAL:  int32 = 300000
v_tag: Array[300000, uint8]
v_num: Array[300000, float64]
v_ref: Array[300000, int32]
n_vals: int32 = 4                 # 0..3 reserved for the singletons

MAX_STR: int32 = 60000
SP_CAP:  int32 = 1048576
sp_buf: Array[1048576, uint8]
sp_top: int32 = 0
st_off: Array[60000, int32]
st_len: Array[60000, int32]
n_strs: int32 = 0

MAX_NODE: int32 = 30000
n_kind: Array[30000, uint8]
n_a:    Array[30000, int32]
n_b:    Array[30000, int32]
n_c:    Array[30000, int32]
n_d:    Array[30000, int32]
n_next: Array[30000, int32]
n_str:  Array[30000, int32]
n_op:   Array[30000, int32]
n_num:  Array[30000, float64]
n_nodes: int32 = 0

MAX_TOK: int32 = 30000
tk_kind: Array[30000, uint8]
tk_num:  Array[30000, float64]
tk_str:  Array[30000, int32]
tk_str2: Array[30000, int32]       # secondary string id (regex flags)
n_toks:  int32 = 0
tk_pos:  int32 = 0

# ---- REGEX pools (all BSS; compiled programs persist for the run) ----
MAX_REPROG: int32 = 40000
re_op: Array[40000, int32]
re_x:  Array[40000, int32]
re_y:  Array[40000, int32]
re_n:  int32 = 0                   # next free program slot

MAX_RENODE: int32 = 20000          # regex AST scratch (reset per compile)
rn_op:   Array[20000, int32]
rn_a:    Array[20000, int32]
rn_b:    Array[20000, int32]
rn_c:    Array[20000, int32]
rn_d:    Array[20000, int32]
rn_next: Array[20000, int32]
rn_n: int32 = 0

MAX_RECLS: int32 = 4096            # char classes; 32-byte (256-bit) bitmap each
cls_bits: Array[131072, uint8]     # 4096 * 32
cls_neg:  Array[4096, uint8]
n_cls: int32 = 0

RE_CAP_MAX: int32 = 128            # 64 groups * 2 slots
re_cap: Array[128, int32]

# replace() is two-phase: resolve every replacement string id FIRST (a user
# replacer function does its own string-building, which cannot run while our
# result builder holds the shared build cursor), then assemble in one pass.
MAX_REP: int32 = 16384
rep_start: Array[16384, int32]
rep_end:   Array[16384, int32]
rep_id:    Array[16384, int32]

# regex compile/match transient state
rc_off: int32 = 0                  # source byte offset (into sp_buf)
rc_len: int32 = 0                  # source length
rc_i:   int32 = 0                  # source cursor
re_gcount: int32 = 0               # capture groups seen during compile
re_ic:  int32 = 0                  # ignore-case (compile + match)
re_ml:  int32 = 0                  # multiline
rx_off: int32 = 0                  # subject byte offset (into sp_buf)
rx_len: int32 = 0                  # subject length
rx_matchend: int32 = 0             # end position set by a successful match

MAX_OBJ: int32 = 40000
obj_kind: Array[40000, uint8]
obj_head: Array[40000, int32]     # prop chain head (-1)
obj_fn_node:   Array[40000, int32]
obj_fn_env:    Array[40000, int32]
obj_fn_native: Array[40000, int32]
arr_len:  Array[40000, int32]
arr_cap:  Array[40000, int32]
arr_base: Array[40000, int32]     # offset into ax_val
obj_proto:    Array[40000, int32] # [[Prototype]] chain: another object id, or -1
obj_fn_this:  Array[40000, int32] # arrow: captured lexical `this` handle; -2 = not-arrow
obj_fn_home:  Array[40000, int32] # method/ctor: home prototype object id (for `super`); -1 none
obj_fn_super: Array[40000, int32] # class constructor: superclass function VALUE handle; -1 none
obj_class:    Array[40000, uint8] # bit0 = class constructor, bit1 = default (implicit) constructor
obj_re_prog:  Array[40000, int32] # regex object: start pc of compiled program, else -1
obj_re_ncap:  Array[40000, int32] # regex object: number of capture groups
obj_re_flags: Array[40000, int32] # regex object: bit0=g, bit1=i, bit2=m
n_objs: int32 = 0

MAX_PROP: int32 = 150000
p_next: Array[150000, int32]
p_key:  Array[150000, int32]      # string id
p_val:  Array[150000, int32]
n_props: int32 = 0

MAX_ENV: int32 = 80000
env_parent:  Array[80000, int32]
env_head:    Array[80000, int32]
env_is_func: Array[80000, uint8]
n_envs: int32 = 0

MAX_BIND: int32 = 250000
b_next:  Array[250000, int32]

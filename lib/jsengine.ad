# lib/jsengine.ad — a PURE, extern-free ES5 / basic-ES6 JavaScript engine.
#
# A tree-walking interpreter: lexer -> recursive-descent parser -> AST (flat
# node pools) -> evaluator over a scope chain. It is deliberately I/O-FREE and
# UI-FREE (NO `extern def`, NO syscalls, NO sockets) exactly like
# lib/htmlengine.ad, so the SAME engine links into BOTH Adder targets:
#
#   * x86_64-adder-user  — the native tool user/js.ad (runs inside Hamnix).
#   * x86_64-linux       — the host driver user/js_host.ad (runs on the dev
#                          host in milliseconds, NO QEMU — the fast loop).
#
# This is the scripting spine for the native browser (a `document` host object
# binds through js_set_host_dispatch) and a general OS scripting engine.
#
# MEMORY DISCIPLINE (memory/feedback_compiler_quirks.md): every pool is a
# top-level BSS Array, NEVER a stack local — the native user stack is a single
# 4 KiB page. Allocation is bump-only over generous fixed pools (no free): the
# brief permits a bump allocator with generous limits. Long/deep scripts on the
# NATIVE target are bounded by the 4 KiB stack (eval recurses per AST depth);
# the host target has a normal 8 MiB stack and runs the full suite.
#
# VALUE MODEL — a JS value is an int32 HANDLE into the value pool:
#   v_tag[h] in {UNDEF,NULL,BOOL,NUM,STR,OBJ}; v_num[h] holds a NUM (JS numbers
#   are float64); v_ref[h] holds a STR's string-record id or an OBJ's object id.
#   undefined/null/true/false are pre-allocated singletons (handles 0..3).
#
# PUBLIC API (the browser/host embedder calls these) is at the bottom.

from lib.web.js.consts import *
from lib.web.js.state import *
from lib.web.js.util import *

from lib.web.js.value import *
# ====================================================================
# LEXER — source in src_ptr/src_len; produces token arrays.
# ====================================================================
lex_p: Ptr[uint8] = 0
lex_n: int32 = 0
lex_i: int32 = 0


def push_tok(kind: int32):
    tk_kind[n_toks] = cast[uint8](kind)
    tk_num[n_toks] = 0.0
    tk_str[n_toks] = -1
    n_toks = n_toks + 1


def push_tok_num(x: float64):
    tk_kind[n_toks] = cast[uint8](TK_NUM)
    tk_num[n_toks] = x
    tk_str[n_toks] = -1
    n_toks = n_toks + 1


def push_tok_str(kind: int32, sid: int32):
    tk_kind[n_toks] = cast[uint8](kind)
    tk_num[n_toks] = 0.0
    tk_str[n_toks] = sid
    tk_str2[n_toks] = -1
    n_toks = n_toks + 1


def push_tok_regex(src_sid: int32, flags_sid: int32):
    tk_kind[n_toks] = cast[uint8](TK_REGEX)
    tk_num[n_toks] = 0.0
    tk_str[n_toks] = src_sid
    tk_str2[n_toks] = flags_sid
    n_toks = n_toks + 1


# A leading `/` starts a regex literal only in expression-start position — i.e.
# NOT right after a value-producing token (identifier, literal, `)`, `]`, `++`,
# `--`, this/super, etc.). Everything else (operators, `(`, `,`, `=`, `return`,
# `{`, `;`, start-of-input, ...) means an expression is expected -> regex.
def prev_is_value() -> int32:
    if n_toks == 0:
        return 0
    k: int32 = cast[int32](tk_kind[n_toks - 1])
    if k == TK_IDENT or k == TK_NUM or k == TK_STR or k == TK_REGEX:
        return 1
    if k == TK_RPAREN or k == TK_RBRACK:
        return 1
    if k == TK_THIS or k == TK_SUPER:
        return 1
    if k == TK_TRUE or k == TK_FALSE or k == TK_NULL or k == TK_UNDEFINED:
        return 1
    if k == TK_INC or k == TK_DEC:
        return 1
    return 0


# Lex a regex literal beginning at the opening `/` (lex_i points at it). Scans
# the pattern (tracking `\`-escapes and `[...]` classes so an inner `/` is not
# mistaken for the terminator), then the trailing flag letters.
def lex_regex():
    lex_i = lex_i + 1                     # skip opening /
    start: int32 = lex_i
    inclass: int32 = 0
    while lex_i < lex_n:
        c: uint8 = lex_p[lex_i]
        if c == 92:                       # backslash: escape next char
            lex_i = lex_i + 2
            continue
        if c == 91:                       # [
            inclass = 1
        elif c == 93:                     # ]
            inclass = 0
        elif c == 47 and inclass == 0:    # / terminator
            break
        elif c == 10:                     # unterminated at newline
            break
        lex_i = lex_i + 1
    src_sid: int32 = str_new(&lex_p[start], lex_i - start)
    if lex_i < lex_n and lex_p[lex_i] == 47:
        lex_i = lex_i + 1                 # skip closing /
    # flags
    fstart: int32 = lex_i
    while lex_i < lex_n and is_idpart(lex_p[lex_i]) != 0:
        lex_i = lex_i + 1
    flags_sid: int32 = str_new(&lex_p[fstart], lex_i - fstart)
    push_tok_regex(src_sid, flags_sid)


def kw_kind(sid: int32) -> int32:
    if str_eq_cstr(sid, cast[Ptr[uint8]]("var")) != 0:
        return TK_VAR
    if str_eq_cstr(sid, cast[Ptr[uint8]]("let")) != 0:
        return TK_LET
    if str_eq_cstr(sid, cast[Ptr[uint8]]("const")) != 0:
        return TK_CONST
    if str_eq_cstr(sid, cast[Ptr[uint8]]("function")) != 0:
        return TK_FUNCTION
    if str_eq_cstr(sid, cast[Ptr[uint8]]("return")) != 0:
        return TK_RETURN
    if str_eq_cstr(sid, cast[Ptr[uint8]]("if")) != 0:
        return TK_IF
    if str_eq_cstr(sid, cast[Ptr[uint8]]("else")) != 0:
        return TK_ELSE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("while")) != 0:
        return TK_WHILE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("for")) != 0:
        return TK_FOR
    if str_eq_cstr(sid, cast[Ptr[uint8]]("do")) != 0:
        return TK_DO
    if str_eq_cstr(sid, cast[Ptr[uint8]]("break")) != 0:
        return TK_BREAK
    if str_eq_cstr(sid, cast[Ptr[uint8]]("continue")) != 0:
        return TK_CONTINUE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("true")) != 0:
        return TK_TRUE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("false")) != 0:
        return TK_FALSE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("null")) != 0:
        return TK_NULL
    if str_eq_cstr(sid, cast[Ptr[uint8]]("undefined")) != 0:
        return TK_UNDEFINED
    if str_eq_cstr(sid, cast[Ptr[uint8]]("typeof")) != 0:
        return TK_TYPEOF
    if str_eq_cstr(sid, cast[Ptr[uint8]]("instanceof")) != 0:
        return TK_INSTANCEOF
    if str_eq_cstr(sid, cast[Ptr[uint8]]("in")) != 0:
        return TK_IN
    if str_eq_cstr(sid, cast[Ptr[uint8]]("new")) != 0:
        return TK_NEW
    if str_eq_cstr(sid, cast[Ptr[uint8]]("this")) != 0:
        return TK_THIS
    if str_eq_cstr(sid, cast[Ptr[uint8]]("class")) != 0:
        return TK_CLASS
    if str_eq_cstr(sid, cast[Ptr[uint8]]("extends")) != 0:
        return TK_EXTENDS
    if str_eq_cstr(sid, cast[Ptr[uint8]]("super")) != 0:
        return TK_SUPER
    if str_eq_cstr(sid, cast[Ptr[uint8]]("try")) != 0:
        return TK_TRY
    if str_eq_cstr(sid, cast[Ptr[uint8]]("catch")) != 0:
        return TK_CATCH
    if str_eq_cstr(sid, cast[Ptr[uint8]]("finally")) != 0:
        return TK_FINALLY
    if str_eq_cstr(sid, cast[Ptr[uint8]]("throw")) != 0:
        return TK_THROW
    if str_eq_cstr(sid, cast[Ptr[uint8]]("void")) != 0:
        return TK_VOID
    if str_eq_cstr(sid, cast[Ptr[uint8]]("delete")) != 0:
        return TK_DELETE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("switch")) != 0:
        return TK_SWITCH
    if str_eq_cstr(sid, cast[Ptr[uint8]]("case")) != 0:
        return TK_CASE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("default")) != 0:
        return TK_DEFAULT
    return TK_IDENT


def lch(off: int32) -> uint8:
    if lex_i + off >= lex_n:
        return 0
    return lex_p[lex_i + off]


def emit_utf8(cp: int32):
    # Encode a Unicode code point as UTF-8 into the current build target.
    if cp < 128:
        emit_c(cast[uint8](cp))
    elif cp < 2048:
        emit_c(cast[uint8](192 + (cp >> 6)))
        emit_c(cast[uint8](128 + (cp & 63)))
    elif cp < 65536:
        emit_c(cast[uint8](224 + (cp >> 12)))
        emit_c(cast[uint8](128 + ((cp >> 6) & 63)))
        emit_c(cast[uint8](128 + (cp & 63)))
    else:
        emit_c(cast[uint8](240 + (cp >> 18)))
        emit_c(cast[uint8](128 + ((cp >> 12) & 63)))
        emit_c(cast[uint8](128 + ((cp >> 6) & 63)))
        emit_c(cast[uint8](128 + (cp & 63)))


def lex_emit_hexesc(ndig: int32):
    # lex_i is AT the 'x' or 'u'. Read up to ndig hex digits following it,
    # emit the resulting code point as UTF-8, and leave lex_i at the LAST
    # consumed digit (the caller advances one past it). Malformed (zero
    # digits) emits nothing.
    cp: int32 = 0
    k: int32 = 0
    while k < ndig:
        hv: int32 = hexval(lch(1))
        if hv < 0:
            break
        cp = cp * 16 + hv
        lex_i = lex_i + 1
        k = k + 1
    if k > 0:
        emit_utf8(cp)


def lex_string(q: uint8):
    lex_i = lex_i + 1                 # skip opening quote
    bld_begin()
    save: int32 = emit_tgt
    emit_tgt = 0
    while lex_i < lex_n and lex_p[lex_i] != q:
        c: uint8 = lex_p[lex_i]
        if c == 92:                   # backslash
            lex_i = lex_i + 1
            e: uint8 = lch(0)
            if e == 110:                  # \n
                emit_c(10)
            elif e == 116:                # \t
                emit_c(9)
            elif e == 114:                # \r
                emit_c(13)
            elif e == 98:                 # \b -> backspace
                emit_c(8)
            elif e == 102:                # \f -> form feed
                emit_c(12)
            elif e == 118:                # \v -> vertical tab
                emit_c(11)
            elif e == 92:                 # \\
                emit_c(92)
            elif e == 39:                 # \'
                emit_c(39)
            elif e == 34:                 # \"
                emit_c(34)
            elif e == 48:                 # \0 -> NUL
                emit_c(0)
            elif e == 120:                # \xHH
                lex_emit_hexesc(2)
            elif e == 117:                # \uHHHH
                lex_emit_hexesc(4)
            elif e == 10:                 # line continuation \<LF> -> nothing
                pass
            elif e == 13:                 # line continuation \<CR>[<LF>]
                if lch(1) == 10:
                    lex_i = lex_i + 1
            else:                         # unknown escape -> literal char
                emit_c(e)
            lex_i = lex_i + 1
        else:
            emit_c(c)
            lex_i = lex_i + 1
    lex_i = lex_i + 1                 # skip closing quote
    emit_tgt = save
    sid: int32 = bld_end()
    push_tok_str(TK_STR, sid)


def lex_number():
    start: int32 = lex_i
    if lex_p[lex_i] == 48 and (lch(1) == 120 or lch(1) == 88):
        lex_i = lex_i + 2
        while lex_i < lex_n and is_hexdig(lex_p[lex_i]) != 0:
            lex_i = lex_i + 1
    else:
        while lex_i < lex_n and is_digit(lex_p[lex_i]) != 0:
            lex_i = lex_i + 1
        if lex_i < lex_n and lex_p[lex_i] == 46:
            lex_i = lex_i + 1
            while lex_i < lex_n and is_digit(lex_p[lex_i]) != 0:
                lex_i = lex_i + 1
        if lex_i < lex_n and (lex_p[lex_i] == 101 or lex_p[lex_i] == 69):
            lex_i = lex_i + 1
            if lex_i < lex_n and (lex_p[lex_i] == 43 or lex_p[lex_i] == 45):
                lex_i = lex_i + 1
            while lex_i < lex_n and is_digit(lex_p[lex_i]) != 0:
                lex_i = lex_i + 1
    x: float64 = parse_num_bytes(&lex_p[start], lex_i - start)
    push_tok_num(x)


def lex_ident():
    start: int32 = lex_i
    while lex_i < lex_n and is_idpart(lex_p[lex_i]) != 0:
        lex_i = lex_i + 1
    sid: int32 = str_new(&lex_p[start], lex_i - start)
    k: int32 = kw_kind(sid)
    # keywords carry their source text too, so they can be used as property
    # names after `.` (e.g. `.catch`, `.finally`, `.in`) — valid JS.
    push_tok_str(k, sid)


# ---- template literals ----
# A template `a${x}b` is lexed into an ordinary parenthesised concat expression:
#   ( "a" + ( x ) + "b" )
# The leading string chunk makes the whole `+` chain coerce to a string, so no
# new parser node is needed. Nested templates / interpolations use tmpl_bdepth.
def lex_tmpl_chunk() -> int32:
    # Cook a template chunk into the string pool; stop at ` or ${ or EOF,
    # leaving lex_i AT the terminator (not consumed).
    bld_begin()
    save: int32 = emit_tgt
    emit_tgt = 0
    while lex_i < lex_n:
        c: uint8 = lex_p[lex_i]
        if c == 96:                       # backtick -> end of template
            break
        if c == 36 and lch(1) == 123:     # ${ -> interpolation
            break
        if c == 92:                       # backslash escape
            lex_i = lex_i + 1
            e: uint8 = lch(0)
            if e == 110:                  # \n
                emit_c(10)
            elif e == 116:                # \t
                emit_c(9)
            elif e == 114:                # \r
                emit_c(13)
            elif e == 98:                 # \b -> backspace
                emit_c(8)
            elif e == 102:                # \f -> form feed
                emit_c(12)
            elif e == 118:                # \v -> vertical tab
                emit_c(11)
            elif e == 92:                 # \\
                emit_c(92)
            elif e == 96:                 # \`
                emit_c(96)
            elif e == 36:                 # \$
                emit_c(36)
            elif e == 39:                 # \'
                emit_c(39)
            elif e == 34:                 # \"
                emit_c(34)
            elif e == 48:                 # \0 -> NUL
                emit_c(0)
            elif e == 120:                # \xHH
                lex_emit_hexesc(2)
            elif e == 117:                # \uHHHH
                lex_emit_hexesc(4)
            elif e == 10:                 # line continuation \<LF> -> nothing
                pass
            elif e == 13:                 # line continuation \<CR>[<LF>]
                if lch(1) == 10:
                    lex_i = lex_i + 1
            else:                         # unknown escape -> literal char
                emit_c(e)
            lex_i = lex_i + 1
        else:
            emit_c(c)
            lex_i = lex_i + 1
    emit_tgt = save
    return bld_end()


def lex_tmpl_continue(is_open: int32):
    # Emit one chunk + its trailing delimiter. is_open=1 just past the opening
    # backtick (emit the wrapping '('); 0 when resuming just past a '}'.
    if is_open != 0:
        push_tok(TK_LPAREN)
    else:
        push_tok(TK_PLUS)
    sid: int32 = lex_tmpl_chunk()
    push_tok_str(TK_STR, sid)
    c: uint8 = lch(0)
    if c == 96:                           # end of template -> close the wrap
        lex_i = lex_i + 1
        push_tok(TK_RPAREN)
    elif c == 36 and lch(1) == 123:       # ${  -> begin an interpolation
        lex_i = lex_i + 2
        push_tok(TK_PLUS)
        push_tok(TK_LPAREN)
        tmpl_bdepth[tmpl_sp] = 0
        tmpl_sp = tmpl_sp + 1
    else:
        push_tok(TK_RPAREN)               # unterminated: close defensively


def tokenize(p: Ptr[uint8], n: int32):
    lex_p = p
    lex_n = n
    lex_i = 0
    n_toks = 0
    tmpl_sp = 0
    # Cap the token stream so a pathological / machine-generated script (real
    # sites ship megabytes of minified JS and eval() giant generated strings)
    # can never overrun the fixed token arrays and segfault the browser. Leave
    # headroom for the trailing TK_EOF + any multi-token lexeme in flight.
    while lex_i < lex_n and n_toks < MAX_TOK - 8:
        c: uint8 = lex_p[lex_i]
        if is_ws(c) != 0:
            lex_i = lex_i + 1
            continue
        # comments
        if c == 47 and lch(1) == 47:              # //
            while lex_i < lex_n and lex_p[lex_i] != 10:
                lex_i = lex_i + 1
            continue
        if c == 47 and lch(1) == 42:              # /* */
            lex_i = lex_i + 2
            while lex_i < lex_n and not (lex_p[lex_i] == 42 and lch(1) == 47):
                lex_i = lex_i + 1
            lex_i = lex_i + 2
            continue
        # regex literal: `/` in expression-start position
        if c == 47 and prev_is_value() == 0:
            lex_regex()
            continue
        if c == 34 or c == 39:                    # " '
            lex_string(c)
            continue
        if c == 96:                               # ` template literal
            lex_i = lex_i + 1
            lex_tmpl_continue(1)
            continue
        if is_digit(c) != 0:
            lex_number()
            continue
        if c == 46 and is_digit(lch(1)) != 0:     # .5
            lex_number()
            continue
        if is_idstart(c) != 0:
            lex_ident()
            continue
        # operators / punctuation (longest match first)
        c1: uint8 = lch(1)
        c2: uint8 = lch(2)
        c3: uint8 = lch(3)
        okind: int32 = -1
        olen: int32 = 1
        if c == 62 and c1 == 62 and c2 == 62 and c3 == 61:
            okind = TK_USHREQ           # >>>=
            olen = 4
        elif c == 63 and c1 == 63 and c2 == 61:
            okind = TK_QQEQ             # ??=
            olen = 3
        elif c == 124 and c1 == 124 and c2 == 61:
            okind = TK_OROREQ           # ||=
            olen = 3
        elif c == 38 and c1 == 38 and c2 == 61:
            okind = TK_ANDANDEQ         # &&=
            olen = 3
        elif c == 42 and c1 == 42 and c2 == 61:
            okind = TK_STARSTAREQ       # **=
            olen = 3
        elif c == 46 and c1 == 46 and c2 == 46:
            okind = TK_ELLIPSIS
            olen = 3
        elif c == 61 and c1 == 61 and c2 == 61:
            okind = TK_SEQ
            olen = 3
        elif c == 33 and c1 == 61 and c2 == 61:
            okind = TK_SNE
            olen = 3
        elif c == 60 and c1 == 60 and c2 == 61:
            okind = TK_SHLEQ            # <<=
            olen = 3
        elif c == 62 and c1 == 62 and c2 == 61:
            okind = TK_SHREQ            # >>=
            olen = 3
        elif c == 62 and c1 == 62 and c2 == 62:
            okind = TK_USHR
            olen = 3
        elif c == 61 and c1 == 61:
            okind = TK_EQ
            olen = 2
        elif c == 33 and c1 == 61:
            okind = TK_NE
            olen = 2
        elif c == 60 and c1 == 61:
            okind = TK_LE
            olen = 2
        elif c == 62 and c1 == 61:
            okind = TK_GE
            olen = 2
        elif c == 60 and c1 == 60:
            okind = TK_SHL
            olen = 2
        elif c == 62 and c1 == 62:
            okind = TK_SHR
            olen = 2
        elif c == 38 and c1 == 38:
            okind = TK_ANDAND
            olen = 2
        elif c == 124 and c1 == 124:
            okind = TK_OROR
            olen = 2
        elif c == 42 and c1 == 42:
            okind = TK_STARSTAR         # **
            olen = 2
        elif c == 63 and c1 == 63:
            okind = TK_QQ               # ??
            olen = 2
        elif c == 63 and c1 == 46 and is_digit(c2) == 0:
            okind = TK_QDOT             # ?.  (not ?.digit which is ternary)
            olen = 2
        elif c == 43 and c1 == 43:
            okind = TK_INC
            olen = 2
        elif c == 45 and c1 == 45:
            okind = TK_DEC
            olen = 2
        elif c == 43 and c1 == 61:
            okind = TK_PLUSEQ
            olen = 2
        elif c == 45 and c1 == 61:
            okind = TK_MINUSEQ
            olen = 2
        elif c == 42 and c1 == 61:
            okind = TK_STAREQ
            olen = 2
        elif c == 47 and c1 == 61:
            okind = TK_SLASHEQ
            olen = 2
        elif c == 37 and c1 == 61:
            okind = TK_PERCENTEQ
            olen = 2
        elif c == 124 and c1 == 61:
            okind = TK_OREQ            # |=
            olen = 2
        elif c == 38 and c1 == 61:
            okind = TK_ANDEQ           # &=
            olen = 2
        elif c == 94 and c1 == 61:
            okind = TK_XOREQ           # ^=
            olen = 2
        elif c == 61 and c1 == 62:
            okind = TK_ARROW
            olen = 2
        elif c == 40:
            okind = TK_LPAREN
        elif c == 41:
            okind = TK_RPAREN
        elif c == 123:
            okind = TK_LBRACE
        elif c == 125:
            okind = TK_RBRACE
        elif c == 91:
            okind = TK_LBRACK
        elif c == 93:
            okind = TK_RBRACK
        elif c == 59:
            okind = TK_SEMI
        elif c == 44:
            okind = TK_COMMA
        elif c == 46:
            okind = TK_DOT
        elif c == 58:
            okind = TK_COLON
        elif c == 63:
            okind = TK_QUESTION
        elif c == 61:
            okind = TK_ASSIGN
        elif c == 43:
            okind = TK_PLUS
        elif c == 45:
            okind = TK_MINUS
        elif c == 42:
            okind = TK_STAR
        elif c == 47:
            okind = TK_SLASH
        elif c == 37:
            okind = TK_PERCENT
        elif c == 60:
            okind = TK_LT
        elif c == 62:
            okind = TK_GT
        elif c == 33:
            okind = TK_NOT
        elif c == 38:
            okind = TK_BAND
        elif c == 124:
            okind = TK_BOR
        elif c == 94:
            okind = TK_BXOR
        elif c == 126:
            okind = TK_BNOT
        if okind < 0:
            lex_i = lex_i + 1
            continue
        # template interpolation: a '}' at brace-depth 0 closes `${ ... }`
        if okind == TK_RBRACE and tmpl_sp > 0 and tmpl_bdepth[tmpl_sp - 1] == 0:
            lex_i = lex_i + 1
            push_tok(TK_RPAREN)
            tmpl_sp = tmpl_sp - 1
            lex_tmpl_continue(0)
            continue
        if tmpl_sp > 0:
            if okind == TK_LBRACE:
                tmpl_bdepth[tmpl_sp - 1] = tmpl_bdepth[tmpl_sp - 1] + 1
            elif okind == TK_RBRACE:
                tmpl_bdepth[tmpl_sp - 1] = tmpl_bdepth[tmpl_sp - 1] - 1
        push_tok(okind)
        lex_i = lex_i + olen
    push_tok(TK_EOF)


# ====================================================================
# PARSER — recursive descent over the token array.
# ====================================================================
def pk() -> int32:
    return cast[int32](tk_kind[tk_pos])


def pk1() -> int32:
    if tk_pos + 1 < n_toks:
        return cast[int32](tk_kind[tk_pos + 1])
    return TK_EOF


def padv() -> int32:
    t: int32 = tk_pos
    tk_pos = tk_pos + 1
    return t


def pexpect(kind: int32):
    if pk() == kind:
        tk_pos = tk_pos + 1
    else:
        set_error(cast[Ptr[uint8]]("SyntaxError: unexpected token"))


def nd_new(kind: int32) -> int32:
    # Guard the fixed AST arena: a huge minified/generated program (or a deeply
    # nested eval) can exhaust it. Rather than write out of bounds (a segfault),
    # latch a parse error and keep returning the last slot so the caller unwinds
    # cleanly. js_eval/native_eval turn err_flag into a non-fatal per-script
    # failure, so one oversized script never crashes or blanks the page.
    if n_nodes >= 29996:
        set_error(cast[Ptr[uint8]]("SyntaxError: script too large (node limit)"))
        return 29996
    i: int32 = n_nodes
    n_kind[i] = cast[uint8](kind)
    n_a[i] = -1
    n_b[i] = -1
    n_c[i] = -1
    n_d[i] = -1
    n_next[i] = -1
    n_str[i] = -1
    n_op[i] = 0
    n_num[i] = 0.0
    n_nodes = n_nodes + 1
    return i


# forward-declared via mutual recursion (Adder resolves module-wide)
def parse_assign() -> int32:
    return parse_assign_impl()


def parse_expr() -> int32:
    # comma expression: evaluate left, keep right (rare) — support sequence
    e: int32 = parse_assign()
    while pk() == TK_COMMA:
        tk_pos = tk_pos + 1
        e = parse_assign()
    return e


def parse_primary() -> int32:
    k: int32 = pk()
    if k == TK_NUM:
        nd: int32 = nd_new(ND_NUM)
        n_num[nd] = tk_num[tk_pos]
        tk_pos = tk_pos + 1
        return nd
    if k == TK_STR:
        nd2: int32 = nd_new(ND_STR)
        n_str[nd2] = tk_str[tk_pos]
        tk_pos = tk_pos + 1
        return nd2
    if k == TK_REGEX:
        ndr: int32 = nd_new(ND_REGEX)
        n_str[ndr] = tk_str[tk_pos]        # source sid
        n_a[ndr] = tk_str2[tk_pos]         # flags sid
        tk_pos = tk_pos + 1
        return ndr
    if k == TK_TRUE:
        tk_pos = tk_pos + 1
        return nd_new(ND_TRUE)
    if k == TK_FALSE:
        tk_pos = tk_pos + 1
        return nd_new(ND_FALSE)
    if k == TK_NULL:
        tk_pos = tk_pos + 1
        return nd_new(ND_NULL)
    if k == TK_UNDEFINED:
        tk_pos = tk_pos + 1
        return nd_new(ND_UNDEF)
    if k == TK_THIS:
        tk_pos = tk_pos + 1
        return nd_new(ND_THIS)
    if k == TK_IDENT:
        nd3: int32 = nd_new(ND_IDENT)
        n_str[nd3] = tk_str[tk_pos]
        tk_pos = tk_pos + 1
        return nd3
    if k == TK_LPAREN:
        tk_pos = tk_pos + 1
        save_noin: int32 = no_in        # `in` is allowed again inside parens
        no_in = 0
        e: int32 = parse_expr()
        no_in = save_noin
        pexpect(TK_RPAREN)
        return e
    if k == TK_LBRACK:
        return parse_array_lit()
    if k == TK_LBRACE:
        return parse_object_lit()
    if k == TK_FUNCTION:
        return parse_function_expr()
    # `async function (){...}` expression (contextual keyword)
    if k == TK_IDENT and str_eq_cstr(tk_str[tk_pos], cast[Ptr[uint8]]("async")) != 0 and pk1() == TK_FUNCTION:
        tk_pos = tk_pos + 1            # consume 'async'
        pending_async = 1
        return parse_function_expr()
    if k == TK_CLASS:
        return parse_class()
    if k == TK_SUPER:
        tk_pos = tk_pos + 1
        return nd_new(ND_SUPER)
    set_error(cast[Ptr[uint8]]("SyntaxError: unexpected token in expression"))
    tk_pos = tk_pos + 1
    return nd_new(ND_UNDEF)


def parse_array_lit() -> int32:
    tk_pos = tk_pos + 1                # [
    nd: int32 = nd_new(ND_ARRAY)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RBRACK and pk() != TK_EOF:
        if pk() == TK_COMMA:
            tk_pos = tk_pos + 1
            continue
        el: int32 = -1
        if pk() == TK_ELLIPSIS:        # spread element [...xs]
            tk_pos = tk_pos + 1
            el = nd_new(ND_SPREAD)
            n_a[el] = parse_assign()
        else:
            el = parse_assign()
        if head < 0:
            head = el
            tail = el
        else:
            n_next[tail] = el
            tail = el
        if pk() == TK_COMMA:
            tk_pos = tk_pos + 1
    pexpect(TK_RBRACK)
    n_a[nd] = head
    return nd


def parse_object_lit() -> int32:
    tk_pos = tk_pos + 1                # {
    nd: int32 = nd_new(ND_OBJECT)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RBRACE and pk() != TK_EOF:
        if pk() == TK_ELLIPSIS:        # object spread {...o}
            tk_pos = tk_pos + 1
            sp: int32 = nd_new(ND_SPREAD)
            n_a[sp] = parse_assign()
            if head < 0:
                head = sp
                tail = sp
            else:
                n_next[tail] = sp
                tail = sp
            if pk() == TK_COMMA:
                tk_pos = tk_pos + 1
            continue
        keysid: int32 = -1
        if pk() == TK_STR:
            keysid = tk_str[tk_pos]
            tk_pos = tk_pos + 1
        elif pk() == TK_IDENT:
            keysid = tk_str[tk_pos]
            tk_pos = tk_pos + 1
        elif pk() == TK_NUM:
            keysid = num_to_strid(tk_num[tk_pos])
            tk_pos = tk_pos + 1
        else:
            # keyword-as-key
            keysid = str_from_cstr(cast[Ptr[uint8]]("key"))
            tk_pos = tk_pos + 1
        prop: int32 = nd_new(ND_PROP)
        n_str[prop] = keysid
        # shorthand {x}  ==  {x: x}
        if pk() == TK_COLON:
            tk_pos = tk_pos + 1
            n_a[prop] = parse_assign()
        else:
            sh: int32 = nd_new(ND_IDENT)
            n_str[sh] = keysid
            n_a[prop] = sh
        if head < 0:
            head = prop
            tail = prop
        else:
            n_next[tail] = prop
            tail = prop
        if pk() == TK_COMMA:
            tk_pos = tk_pos + 1
    pexpect(TK_RBRACE)
    n_a[nd] = head
    return nd


def parse_params() -> int32:
    # returns head of param list (ND_PARAM chain). Assumes cursor at '('
    pexpect(TK_LPAREN)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RPAREN and pk() != TK_EOF:
        pnode: int32 = nd_new(ND_PARAM)
        if pk() == TK_ELLIPSIS:            # rest parameter ...args
            tk_pos = tk_pos + 1
            n_op[pnode] = 1
        if pk() == TK_LBRACK or pk() == TK_LBRACE:
            n_b[pnode] = parse_pattern()   # destructuring parameter [a,b] / {x,y}
        elif pk() == TK_IDENT:
            n_str[pnode] = tk_str[tk_pos]
            tk_pos = tk_pos + 1
        else:
            tk_pos = tk_pos + 1
        if pk() == TK_ASSIGN:              # default value
            tk_pos = tk_pos + 1
            n_a[pnode] = parse_assign()
        if head < 0:
            head = pnode
            tail = pnode
        else:
            n_next[tail] = pnode
            tail = pnode
        if pk() == TK_COMMA:
            tk_pos = tk_pos + 1
    pexpect(TK_RPAREN)
    return head


def parse_function_expr() -> int32:
    isa: int32 = pending_async
    pending_async = 0
    tk_pos = tk_pos + 1                # 'function'
    nd: int32 = nd_new(ND_FUNC)
    n_op[nd] = isa                     # 1 => async function
    if pk() == TK_IDENT:
        n_str[nd] = tk_str[tk_pos]
        tk_pos = tk_pos + 1
    n_a[nd] = parse_params()
    save_async: int32 = in_async
    in_async = isa
    n_b[nd] = parse_block()
    in_async = save_async
    return nd


# ---- arrow functions ----
def scan_arrow_params() -> int32:
    # tk_pos at TK_LPAREN. Return 1 if the matching ')' is immediately '=>'.
    i: int32 = tk_pos
    depth: int32 = 0
    while i < n_toks:
        kk: int32 = cast[int32](tk_kind[i])
        if kk == TK_LPAREN:
            depth = depth + 1
        elif kk == TK_RPAREN:
            depth = depth - 1
            if depth == 0:
                if i + 1 < n_toks and cast[int32](tk_kind[i + 1]) == TK_ARROW:
                    return 1
                return 0
        elif kk == TK_EOF:
            return 0
        i = i + 1
    return 0


def parse_arrow_body(nd: int32):
    pexpect(TK_ARROW)
    if pk() == TK_LBRACE:
        n_b[nd] = parse_block()
        n_c[nd] = 0
    else:
        n_b[nd] = parse_assign()
        n_c[nd] = 1                        # concise expression body


def parse_arrow_single() -> int32:
    isa: int32 = pending_async
    pending_async = 0
    nd: int32 = nd_new(ND_ARROW)
    n_op[nd] = isa
    p: int32 = nd_new(ND_PARAM)
    n_str[p] = tk_str[tk_pos]
    tk_pos = tk_pos + 1                    # the single ident param
    n_a[nd] = p
    save_async: int32 = in_async
    in_async = isa
    parse_arrow_body(nd)
    in_async = save_async
    return nd


def parse_arrow_paren() -> int32:
    isa: int32 = pending_async
    pending_async = 0
    nd: int32 = nd_new(ND_ARROW)
    n_op[nd] = isa
    n_a[nd] = parse_params()
    save_async: int32 = in_async
    in_async = isa
    parse_arrow_body(nd)
    in_async = save_async
    return nd


# ---- classes ----
def parse_class() -> int32:
    tk_pos = tk_pos + 1                # 'class'
    nd: int32 = nd_new(ND_CLASS)
    if pk() == TK_IDENT:
        n_str[nd] = tk_str[tk_pos]
        tk_pos = tk_pos + 1
    if pk() == TK_EXTENDS:
        tk_pos = tk_pos + 1
        n_a[nd] = parse_call_member(parse_primary())   # superclass expression
    pexpect(TK_LBRACE)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RBRACE and pk() != TK_EOF and err_flag == 0:
        if pk() == TK_SEMI:
            tk_pos = tk_pos + 1
            continue
        m: int32 = nd_new(ND_METHOD)
        # 'static' modifier (lexed as an identifier)
        if pk() == TK_IDENT and str_eq_cstr(tk_str[tk_pos], cast[Ptr[uint8]]("static")) != 0 and pk1() != TK_LPAREN and pk1() != TK_ASSIGN:
            n_op[m] = 1
            tk_pos = tk_pos + 1
        # method name
        if pk() == TK_IDENT:
            n_str[m] = tk_str[tk_pos]
            tk_pos = tk_pos + 1
        else:
            tk_pos = tk_pos + 1        # keyword-as-name: skip (rare)
        f: int32 = nd_new(ND_FUNC)
        n_str[f] = n_str[m]
        n_a[f] = parse_params()
        n_b[f] = parse_block()
        n_a[m] = f
        if head < 0:
            head = m
            tail = m
        else:
            n_next[tail] = m
            tail = m
    pexpect(TK_RBRACE)
    n_b[nd] = head
    return nd


def parse_class_decl() -> int32:
    cls: int32 = parse_class()
    nd: int32 = nd_new(ND_CLASSDECL)
    n_str[nd] = n_str[cls]
    n_a[nd] = cls
    return nd


# member / call / new suffix parsing
def parse_call_member(base: int32) -> int32:
    e: int32 = base
    has_opt: int32 = 0                  # any `?.` link in this chain?
    while True:
        k: int32 = pk()
        if k == TK_DOT or (k == TK_QDOT and pk1() != TK_LPAREN and pk1() != TK_LBRACK):
            opt: int32 = 0
            if k == TK_QDOT:
                opt = 1
                has_opt = 1
            tk_pos = tk_pos + 1
            m: int32 = nd_new(ND_MEMBER)
            n_a[m] = e
            n_d[m] = opt
            # any identifier OR keyword after `.` is a property name; both now
            # carry their source text in tk_str.
            if tk_str[tk_pos] >= 0:
                n_str[m] = tk_str[tk_pos]
                tk_pos = tk_pos + 1
            else:
                n_str[m] = str_from_cstr(cast[Ptr[uint8]]("prop"))
                tk_pos = tk_pos + 1
            e = m
        elif k == TK_LBRACK or (k == TK_QDOT and pk1() == TK_LBRACK):
            iopt: int32 = 0
            if k == TK_QDOT:
                iopt = 1
                has_opt = 1
                tk_pos = tk_pos + 1        # consume `?.`
            tk_pos = tk_pos + 1            # consume `[`
            ix: int32 = nd_new(ND_INDEX)
            n_a[ix] = e
            n_d[ix] = iopt
            n_b[ix] = parse_expr()
            pexpect(TK_RBRACK)
            e = ix
        elif k == TK_LPAREN or (k == TK_QDOT and pk1() == TK_LPAREN):
            copt: int32 = 0
            if k == TK_QDOT:
                copt = 1
                has_opt = 1
                tk_pos = tk_pos + 1        # consume `?.` ; `(` handled by parse_args
            c: int32 = nd_new(ND_CALL)
            n_a[c] = e
            n_d[c] = copt
            n_b[c] = parse_args()
            e = c
        else:
            break
    if has_opt != 0:
        oc: int32 = nd_new(ND_OPTCHAIN)
        n_a[oc] = e
        return oc
    return e


def parse_args() -> int32:
    tk_pos = tk_pos + 1                # (
    save_noin: int32 = no_in           # `in` allowed inside a call's arguments
    no_in = 0
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RPAREN and pk() != TK_EOF:
        a: int32 = -1
        if pk() == TK_ELLIPSIS:        # spread argument f(...xs)
            tk_pos = tk_pos + 1
            a = nd_new(ND_SPREAD)
            n_a[a] = parse_assign()
        else:
            a = parse_assign()
        if head < 0:
            head = a
            tail = a
        else:
            n_next[tail] = a
            tail = a
        if pk() == TK_COMMA:
            tk_pos = tk_pos + 1
    no_in = save_noin
    pexpect(TK_RPAREN)
    return head


def parse_new() -> int32:
    if pk() == TK_NEW:
        tk_pos = tk_pos + 1
        callee: int32 = parse_member_only(parse_primary())
        nd: int32 = nd_new(ND_NEW)
        n_a[nd] = callee
        if pk() == TK_LPAREN:
            n_b[nd] = parse_args()
        else:
            n_b[nd] = -1
        return parse_call_member(nd)
    return parse_call_member(parse_primary())


def parse_member_only(base: int32) -> int32:
    # member access without calls (for `new X.Y()` callee)
    e: int32 = base
    while True:
        if pk() == TK_DOT:
            tk_pos = tk_pos + 1
            m: int32 = nd_new(ND_MEMBER)
            n_a[m] = e
            n_str[m] = tk_str[tk_pos]
            tk_pos = tk_pos + 1
            e = m
        else:
            break
    return e


def parse_unary() -> int32:
    k: int32 = pk()
    # `await expr` — high-precedence prefix operator, only inside an async body.
    if k == TK_IDENT and in_async != 0 and str_eq_cstr(tk_str[tk_pos], cast[Ptr[uint8]]("await")) != 0:
        tk_pos = tk_pos + 1
        aw: int32 = nd_new(ND_AWAIT)
        n_a[aw] = parse_unary()
        return aw
    if k == TK_MINUS:
        tk_pos = tk_pos + 1
        u: int32 = nd_new(ND_UNARY)
        n_op[u] = U_NEG
        n_a[u] = parse_unary()
        return u
    if k == TK_PLUS:
        tk_pos = tk_pos + 1
        u2: int32 = nd_new(ND_UNARY)
        n_op[u2] = U_POS
        n_a[u2] = parse_unary()
        return u2
    if k == TK_NOT:
        tk_pos = tk_pos + 1
        u3: int32 = nd_new(ND_UNARY)
        n_op[u3] = U_NOT
        n_a[u3] = parse_unary()
        return u3
    if k == TK_BNOT:
        tk_pos = tk_pos + 1
        u4: int32 = nd_new(ND_UNARY)
        n_op[u4] = U_BNOT
        n_a[u4] = parse_unary()
        return u4
    if k == TK_TYPEOF:
        tk_pos = tk_pos + 1
        u5: int32 = nd_new(ND_UNARY)
        n_op[u5] = U_TYPEOF
        n_a[u5] = parse_unary()
        return u5
    if k == TK_VOID:
        tk_pos = tk_pos + 1
        uv: int32 = nd_new(ND_UNARY)
        n_op[uv] = U_VOID
        n_a[uv] = parse_unary()
        return uv
    if k == TK_DELETE:
        tk_pos = tk_pos + 1
        ud: int32 = nd_new(ND_UNARY)
        n_op[ud] = U_DELETE
        n_a[ud] = parse_unary()
        return ud
    if k == TK_INC or k == TK_DEC:
        tk_pos = tk_pos + 1
        up: int32 = nd_new(ND_UPDATE)
        if k == TK_INC:
            n_op[up] = 1
        else:
            n_op[up] = -1
        n_b[up] = 1                    # prefix
        n_a[up] = parse_unary()
        return up
    return parse_postfix()


def parse_postfix() -> int32:
    e: int32 = parse_new()
    if pk() == TK_INC or pk() == TK_DEC:
        up: int32 = nd_new(ND_UPDATE)
        if pk() == TK_INC:
            n_op[up] = 1
        else:
            n_op[up] = -1
        n_b[up] = 0                    # postfix
        n_a[up] = e
        tk_pos = tk_pos + 1
        return up
    return e


# binary operator precedence
def tok_binop(k: int32) -> int32:
    if k == TK_STAR:
        return OP_MUL
    if k == TK_SLASH:
        return OP_DIV
    if k == TK_PERCENT:
        return OP_MOD
    if k == TK_PLUS:
        return OP_ADD
    if k == TK_MINUS:
        return OP_SUB
    if k == TK_SHL:
        return OP_SHL
    if k == TK_SHR:
        return OP_SHR
    if k == TK_USHR:
        return OP_USHR
    if k == TK_LT:
        return OP_LT
    if k == TK_GT:
        return OP_GT
    if k == TK_LE:
        return OP_LE
    if k == TK_GE:
        return OP_GE
    if k == TK_INSTANCEOF:
        return OP_INSTANCEOF
    if k == TK_IN:
        return OP_IN
    if k == TK_EQ:
        return OP_EQ
    if k == TK_NE:
        return OP_NE
    if k == TK_SEQ:
        return OP_SEQ
    if k == TK_SNE:
        return OP_SNE
    if k == TK_BAND:
        return OP_BAND
    if k == TK_BXOR:
        return OP_BXOR
    if k == TK_BOR:
        return OP_BOR
    return -1


def binop_prec(op: int32) -> int32:
    if op == OP_MUL or op == OP_DIV or op == OP_MOD:
        return 11
    if op == OP_ADD or op == OP_SUB:
        return 10
    if op == OP_SHL or op == OP_SHR or op == OP_USHR:
        return 9
    if op == OP_LT or op == OP_GT or op == OP_LE or op == OP_GE or op == OP_INSTANCEOF or op == OP_IN:
        return 8
    if op == OP_EQ or op == OP_NE or op == OP_SEQ or op == OP_SNE:
        return 7
    if op == OP_BAND:
        return 6
    if op == OP_BXOR:
        return 5
    if op == OP_BOR:
        return 4
    return -1


def parse_exp() -> int32:
    # ExponentiationExpression: UnaryExpression ** ExponentiationExpression
    # `**` binds tighter than the multiplicatives and is right-associative.
    left: int32 = parse_unary()
    if pk() == TK_STARSTAR:
        tk_pos = tk_pos + 1
        b: int32 = nd_new(ND_BINOP)
        n_op[b] = OP_POW
        n_a[b] = left
        n_b[b] = parse_exp()           # right-assoc
        return b
    return left


def parse_binary(minprec: int32) -> int32:
    left: int32 = parse_exp()
    while True:
        k: int32 = pk()
        op: int32 = tok_binop(k)
        if op < 0:
            break
        # inside a for-header init (the "NoIn" grammar), `in` is the for-in
        # keyword, not a relational operator: `for (d in obj)`.
        if op == OP_IN and no_in != 0:
            break
        prec: int32 = binop_prec(op)
        if prec < minprec:
            break
        tk_pos = tk_pos + 1
        right: int32 = parse_binary(prec + 1)
        b: int32 = nd_new(ND_BINOP)
        n_op[b] = op
        n_a[b] = left
        n_b[b] = right
        left = b
    return left


def parse_logical_and() -> int32:
    left: int32 = parse_binary(0)
    while pk() == TK_ANDAND:
        tk_pos = tk_pos + 1
        r: int32 = parse_binary(0)
        l: int32 = nd_new(ND_LOGICAL)
        n_op[l] = 0                    # &&
        n_a[l] = left
        n_b[l] = r
        left = l
    return left


def parse_logical_or() -> int32:
    left: int32 = parse_logical_and()
    while pk() == TK_OROR:
        tk_pos = tk_pos + 1
        r: int32 = parse_logical_and()
        l: int32 = nd_new(ND_LOGICAL)
        n_op[l] = 1                    # ||
        n_a[l] = left
        n_b[l] = r
        left = l
    return left


def parse_nullish() -> int32:
    left: int32 = parse_logical_or()
    while pk() == TK_QQ:
        tk_pos = tk_pos + 1
        r: int32 = parse_logical_or()
        l: int32 = nd_new(ND_LOGICAL)
        n_op[l] = 2                    # ??
        n_a[l] = left
        n_b[l] = r
        left = l
    return left


def parse_ternary() -> int32:
    c: int32 = parse_nullish()
    if pk() == TK_QUESTION:
        tk_pos = tk_pos + 1
        t: int32 = nd_new(ND_TERNARY)
        n_a[t] = c
        n_b[t] = parse_assign()
        pexpect(TK_COLON)
        n_c[t] = parse_assign()
        return t
    return c


# logical-assignment sentinel op codes (short-circuiting; handled in eval_assign)
ALOG_OR:      int32 = 30           # ||=
ALOG_AND:     int32 = 31           # &&=
ALOG_NULLISH: int32 = 32           # ??=


def is_assign_tok(k: int32) -> int32:
    if k == TK_ASSIGN or k == TK_PLUSEQ or k == TK_MINUSEQ or k == TK_STAREQ or k == TK_SLASHEQ or k == TK_PERCENTEQ:
        return 1
    if k == TK_OREQ or k == TK_ANDEQ or k == TK_XOREQ or k == TK_SHLEQ or k == TK_SHREQ or k == TK_USHREQ:
        return 1
    if k == TK_STARSTAREQ or k == TK_QQEQ or k == TK_OROREQ or k == TK_ANDANDEQ:
        return 1
    return 0


def assign_op(k: int32) -> int32:
    if k == TK_STARSTAREQ:
        return OP_POW
    if k == TK_QQEQ:
        return ALOG_NULLISH
    if k == TK_OROREQ:
        return ALOG_OR
    if k == TK_ANDANDEQ:
        return ALOG_AND
    if k == TK_PLUSEQ:
        return OP_ADD
    if k == TK_MINUSEQ:
        return OP_SUB
    if k == TK_STAREQ:
        return OP_MUL
    if k == TK_SLASHEQ:
        return OP_DIV
    if k == TK_PERCENTEQ:
        return OP_MOD
    if k == TK_OREQ:
        return OP_BOR
    if k == TK_ANDEQ:
        return OP_BAND
    if k == TK_XOREQ:
        return OP_BXOR
    if k == TK_SHLEQ:
        return OP_SHL
    if k == TK_SHREQ:
        return OP_SHR
    if k == TK_USHREQ:
        return OP_USHR
    return -1                          # plain '='


def parse_assign_impl() -> int32:
    # async arrow functions: `async x => ...` and `async (a, b) => ...`
    # (async is a contextual keyword — only treat it as one when an arrow follows)
    if pk() == TK_IDENT and str_eq_cstr(tk_str[tk_pos], cast[Ptr[uint8]]("async")) != 0:
        # async single-ident arrow:  async x => ...
        if pk1() == TK_IDENT and tk_pos + 2 < n_toks and cast[int32](tk_kind[tk_pos + 2]) == TK_ARROW:
            tk_pos = tk_pos + 1        # consume 'async'
            pending_async = 1
            return parse_arrow_single()
        # async paren arrow:  async (...) => ...
        if pk1() == TK_LPAREN:
            save_pos: int32 = tk_pos
            tk_pos = tk_pos + 1        # move onto '(' so scan_arrow_params works
            if scan_arrow_params() != 0:
                pending_async = 1
                return parse_arrow_paren()
            tk_pos = save_pos          # not an arrow: `async(...)` is a call
    # arrow functions: `x => ...` and `(a, b) => ...`
    if pk() == TK_IDENT and pk1() == TK_ARROW:
        return parse_arrow_single()
    if pk() == TK_LPAREN and scan_arrow_params() != 0:
        return parse_arrow_paren()
    left: int32 = parse_ternary()
    k: int32 = pk()
    if is_assign_tok(k) != 0:
        tk_pos = tk_pos + 1
        nd: int32 = nd_new(ND_ASSIGN)
        n_op[nd] = assign_op(k)
        n_a[nd] = left
        n_b[nd] = parse_assign()
        return nd
    return left


# ---- statements ----
def parse_block() -> int32:
    pexpect(TK_LBRACE)
    nd: int32 = nd_new(ND_BLOCK)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RBRACE and pk() != TK_EOF:
        s: int32 = parse_statement()
        if s < 0:
            continue
        if head < 0:
            head = s
            tail = s
        else:
            n_next[tail] = s
            tail = s
    pexpect(TK_RBRACE)
    n_a[nd] = head
    return nd


# ---- destructuring patterns ----
def parse_pattern() -> int32:
    if pk() == TK_LBRACK:
        return parse_array_pattern()
    if pk() == TK_LBRACE:
        return parse_object_pattern()
    return -1


def parse_array_pattern() -> int32:
    tk_pos = tk_pos + 1                # [
    nd: int32 = nd_new(ND_ARRPAT)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RBRACK and pk() != TK_EOF:
        e: int32 = nd_new(ND_PATELEM)
        if pk() == TK_COMMA:           # elision (hole)
            tk_pos = tk_pos + 1
        else:
            if pk() == TK_ELLIPSIS:
                tk_pos = tk_pos + 1
                n_op[e] = 1            # rest element
            if pk() == TK_LBRACK or pk() == TK_LBRACE:
                n_b[e] = parse_pattern()
            elif pk() == TK_IDENT:
                n_str[e] = tk_str[tk_pos]
                tk_pos = tk_pos + 1
            if pk() == TK_ASSIGN:
                tk_pos = tk_pos + 1
                n_a[e] = parse_assign()
            if pk() == TK_COMMA:
                tk_pos = tk_pos + 1
        if head < 0:
            head = e
            tail = e
        else:
            n_next[tail] = e
            tail = e
    pexpect(TK_RBRACK)
    n_a[nd] = head
    return nd


def parse_object_pattern() -> int32:
    tk_pos = tk_pos + 1                # {
    nd: int32 = nd_new(ND_OBJPAT)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RBRACE and pk() != TK_EOF:
        e: int32 = nd_new(ND_PATELEM)
        if pk() == TK_ELLIPSIS:        # object rest {a, ...others}
            tk_pos = tk_pos + 1
            n_op[e] = 1
            if pk() == TK_IDENT:
                n_c[e] = tk_str[tk_pos]
                tk_pos = tk_pos + 1
            if head < 0:
                head = e
                tail = e
            else:
                n_next[tail] = e
                tail = e
            if pk() == TK_COMMA:
                tk_pos = tk_pos + 1
            continue
        key: int32 = -1
        if pk() == TK_IDENT or pk() == TK_STR:
            key = tk_str[tk_pos]
            tk_pos = tk_pos + 1
        else:
            tk_pos = tk_pos + 1
        n_str[e] = key                 # source key
        n_c[e] = key                   # target name (default: same)
        if pk() == TK_COLON:
            tk_pos = tk_pos + 1
            if pk() == TK_LBRACK or pk() == TK_LBRACE:
                n_b[e] = parse_pattern()
                n_c[e] = -1
            elif pk() == TK_IDENT:
                n_c[e] = tk_str[tk_pos]
                tk_pos = tk_pos + 1
        if pk() == TK_ASSIGN:
            tk_pos = tk_pos + 1
            n_a[e] = parse_assign()
        if head < 0:
            head = e
            tail = e
        else:
            n_next[tail] = e
            tail = e
        if pk() == TK_COMMA:
            tk_pos = tk_pos + 1
    pexpect(TK_RBRACE)
    n_a[nd] = head
    return nd


def parse_var_decl() -> int32:
    k: int32 = pk()
    tk_pos = tk_pos + 1
    nd: int32 = nd_new(ND_VAR)
    if k == TK_CONST:
        n_op[nd] = 2
    elif k == TK_LET:
        n_op[nd] = 1
    else:
        n_op[nd] = 0
    head: int32 = -1
    tail: int32 = -1
    while True:
        d: int32 = nd_new(ND_DECLTOR)
        if pk() == TK_LBRACK or pk() == TK_LBRACE:
            n_b[d] = parse_pattern()   # destructuring target
        elif pk() == TK_IDENT:
            n_str[d] = tk_str[tk_pos]
            tk_pos = tk_pos + 1
        else:
            set_error(cast[Ptr[uint8]]("SyntaxError: expected identifier"))
            break
        if pk() == TK_ASSIGN:
            tk_pos = tk_pos + 1
            n_a[d] = parse_assign()
        if head < 0:
            head = d
            tail = d
        else:
            n_next[tail] = d
            tail = d
        if pk() == TK_COMMA:
            tk_pos = tk_pos + 1
            continue
        break
    n_a[nd] = head
    return nd


def semi_opt():
    if pk() == TK_SEMI:
        tk_pos = tk_pos + 1


def parse_statement() -> int32:
    k: int32 = pk()
    if k == TK_LBRACE:
        return parse_block()
    if k == TK_SEMI:
        tk_pos = tk_pos + 1
        return nd_new(ND_EMPTY)
    if k == TK_VAR or k == TK_LET or k == TK_CONST:
        d: int32 = parse_var_decl()
        semi_opt()
        return d
    if k == TK_FUNCTION:
        return parse_func_decl()
    # `async function f(){...}` declaration (async is a contextual keyword)
    if k == TK_IDENT and str_eq_cstr(tk_str[tk_pos], cast[Ptr[uint8]]("async")) != 0 and pk1() == TK_FUNCTION:
        tk_pos = tk_pos + 1            # consume 'async'
        pending_async = 1
        return parse_func_decl()
    if k == TK_IF:
        return parse_if()
    if k == TK_WHILE:
        return parse_while()
    if k == TK_DO:
        return parse_dowhile()
    if k == TK_FOR:
        return parse_for()
    if k == TK_RETURN:
        tk_pos = tk_pos + 1
        r: int32 = nd_new(ND_RETURN)
        if pk() != TK_SEMI and pk() != TK_RBRACE and pk() != TK_EOF:
            n_a[r] = parse_expr()
        semi_opt()
        return r
    if k == TK_TRY:
        return parse_try()
    if k == TK_THROW:
        tk_pos = tk_pos + 1
        th: int32 = nd_new(ND_THROW)
        n_a[th] = parse_expr()
        semi_opt()
        return th
    if k == TK_CLASS:
        return parse_class_decl()
    if k == TK_SWITCH:
        return parse_switch()
    if k == TK_BREAK:
        tk_pos = tk_pos + 1
        br: int32 = nd_new(ND_BREAK)
        if pk() == TK_IDENT:            # `break label;` (minified: no ASI newline)
            n_str[br] = tk_str[tk_pos]
            tk_pos = tk_pos + 1
        semi_opt()
        return br
    if k == TK_CONTINUE:
        tk_pos = tk_pos + 1
        ct: int32 = nd_new(ND_CONTINUE)
        if pk() == TK_IDENT:            # `continue label;`
            n_str[ct] = tk_str[tk_pos]
            tk_pos = tk_pos + 1
        semi_opt()
        return ct
    # labeled statement: `IDENT : stmt` (loop/block target for break/continue)
    if k == TK_IDENT and pk1() == TK_COLON:
        lbl: int32 = nd_new(ND_LABELED)
        n_str[lbl] = tk_str[tk_pos]
        tk_pos = tk_pos + 2             # consume IDENT and COLON
        n_a[lbl] = parse_statement()
        return lbl
    # expression statement
    es: int32 = nd_new(ND_EXPRSTMT)
    n_a[es] = parse_expr()
    semi_opt()
    return es


def parse_func_decl() -> int32:
    isa: int32 = pending_async
    pending_async = 0
    tk_pos = tk_pos + 1                # 'function'
    nd: int32 = nd_new(ND_FUNCDECL)
    if pk() == TK_IDENT:
        n_str[nd] = tk_str[tk_pos]
        tk_pos = tk_pos + 1
    fexpr: int32 = nd_new(ND_FUNC)
    n_op[fexpr] = isa                  # 1 => async function
    n_str[fexpr] = n_str[nd]
    n_a[fexpr] = parse_params()
    save_async: int32 = in_async
    in_async = isa
    n_b[fexpr] = parse_block()
    in_async = save_async
    n_a[nd] = fexpr
    return nd


def parse_if() -> int32:
    tk_pos = tk_pos + 1                # 'if'
    pexpect(TK_LPAREN)
    nd: int32 = nd_new(ND_IF)
    n_a[nd] = parse_expr()
    pexpect(TK_RPAREN)
    n_b[nd] = parse_statement()
    if pk() == TK_ELSE:
        tk_pos = tk_pos + 1
        n_c[nd] = parse_statement()
    return nd


def parse_switch() -> int32:
    tk_pos = tk_pos + 1                # 'switch'
    pexpect(TK_LPAREN)
    sw: int32 = nd_new(ND_SWITCH)
    n_a[sw] = parse_expr()
    pexpect(TK_RPAREN)
    pexpect(TK_LBRACE)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RBRACE and pk() != TK_EOF:
        cs: int32 = nd_new(ND_CASE)
        if pk() == TK_CASE:
            tk_pos = tk_pos + 1
            n_a[cs] = parse_expr()
            pexpect(TK_COLON)
        elif pk() == TK_DEFAULT:
            tk_pos = tk_pos + 1
            n_a[cs] = -1              # default marker
            pexpect(TK_COLON)
        else:
            set_error(cast[Ptr[uint8]]("SyntaxError: expected case/default in switch"))
            break
        # statements of this clause, up to the next case/default/}
        sh: int32 = -1
        stail: int32 = -1
        while pk() != TK_CASE and pk() != TK_DEFAULT and pk() != TK_RBRACE and pk() != TK_EOF:
            stmt: int32 = parse_statement()
            if sh < 0:
                sh = stmt
                stail = stmt
            else:
                n_next[stail] = stmt
                stail = stmt
        n_b[cs] = sh
        if head < 0:
            head = cs
            tail = cs
        else:
            n_next[tail] = cs
            tail = cs
    pexpect(TK_RBRACE)
    n_b[sw] = head
    return sw


def parse_while() -> int32:
    tk_pos = tk_pos + 1
    pexpect(TK_LPAREN)
    nd: int32 = nd_new(ND_WHILE)
    n_a[nd] = parse_expr()
    pexpect(TK_RPAREN)
    n_b[nd] = parse_statement()
    return nd


def parse_dowhile() -> int32:
    tk_pos = tk_pos + 1                # 'do'
    nd: int32 = nd_new(ND_DOWHILE)
    n_b[nd] = parse_statement()
    pexpect(TK_WHILE)
    pexpect(TK_LPAREN)
    n_a[nd] = parse_expr()
    pexpect(TK_RPAREN)
    semi_opt()
    return nd


def parse_try() -> int32:
    tk_pos = tk_pos + 1                # 'try'
    nd: int32 = nd_new(ND_TRY)
    n_a[nd] = parse_block()            # try block
    if pk() == TK_CATCH:
        tk_pos = tk_pos + 1
        if pk() == TK_LPAREN:
            tk_pos = tk_pos + 1
            if pk() == TK_IDENT:
                n_str[nd] = tk_str[tk_pos]   # catch binding name
                tk_pos = tk_pos + 1
            pexpect(TK_RPAREN)
        n_b[nd] = parse_block()        # catch block
    if pk() == TK_FINALLY:
        tk_pos = tk_pos + 1
        n_c[nd] = parse_block()        # finally block
    return nd


def parse_for() -> int32:
    tk_pos = tk_pos + 1                # 'for'
    pexpect(TK_LPAREN)
    # detect for-in: <decl-or-ident> 'in'
    init: int32 = -1
    is_decl: int32 = 0
    no_in = 1                          # `in` here is the for-in keyword, not a binop
    if pk() == TK_VAR or pk() == TK_LET or pk() == TK_CONST:
        is_decl = 1
        init = parse_var_decl()
    elif pk() != TK_SEMI:
        init = nd_new(ND_EXPRSTMT)
        n_a[init] = parse_expr()
    no_in = 0
    if pk() == TK_IN:
        # for-in
        tk_pos = tk_pos + 1
        nd: int32 = nd_new(ND_FORIN)
        n_op[nd] = is_decl
        n_a[nd] = init                 # var decl or expr stmt (target)
        n_b[nd] = parse_expr()         # object
        pexpect(TK_RPAREN)
        n_c[nd] = parse_statement()
        return nd
    if pk() == TK_IDENT and str_eq_cstr(tk_str[tk_pos], cast[Ptr[uint8]]("of")) != 0:
        # for-of : `for (target of iterable) body`
        tk_pos = tk_pos + 1            # consume contextual `of`
        ndo: int32 = nd_new(ND_FOROF)
        n_op[ndo] = is_decl
        n_a[ndo] = init                # var decl or expr stmt (target)
        n_b[ndo] = parse_assign()      # iterable (AssignmentExpression, not comma)
        pexpect(TK_RPAREN)
        n_c[ndo] = parse_statement()
        return ndo
    pexpect(TK_SEMI)
    nd2: int32 = nd_new(ND_FOR)
    n_a[nd2] = init
    if pk() != TK_SEMI:
        n_b[nd2] = parse_expr()
    pexpect(TK_SEMI)
    if pk() != TK_RPAREN:
        n_c[nd2] = parse_expr()
    pexpect(TK_RPAREN)
    n_op[nd2] = is_decl
    n_d[nd2] = parse_statement()
    return nd2


def parse_program() -> int32:
    tk_pos = 0
    nd: int32 = nd_new(ND_BLOCK)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_EOF and err_flag == 0:
        s: int32 = parse_statement()
        if head < 0:
            head = s
            tail = s
        else:
            n_next[tail] = s
            tail = s
    n_a[nd] = head
    return nd


# ====================================================================
# EVALUATOR.
# ====================================================================
# conversions
def to_bool(h: int32) -> int32:
    t: int32 = tag_of(h)
    if t == TAG_UNDEF or t == TAG_NULL:
        return 0
    if t == TAG_BOOL:
        if h == 2:
            return 1
        return 0
    if t == TAG_NUM:
        x: float64 = v_num[h]
        if x == 0.0 or is_nan(x) != 0:
            return 0
        return 1
    if t == TAG_STR:
        if str_len(strid_of(h)) == 0:
            return 0
        return 1
    return 1                            # objects are truthy


def to_number(h: int32) -> float64:
    t: int32 = tag_of(h)
    if t == TAG_NUM:
        return v_num[h]
    if t == TAG_BOOL:
        if h == 2:
            return 1.0
        return 0.0
    if t == TAG_NULL:
        return 0.0
    if t == TAG_UNDEF:
        return 0.0 / 0.0
    if t == TAG_STR:
        sid: int32 = strid_of(h)
        if str_len(sid) == 0:
            return 0.0
        return parse_num_bytes(str_ptr(sid), str_len(sid))
    return 0.0 / 0.0


def to_int32(h: int32) -> int32:
    x: float64 = to_number(h)
    if is_nan(x) != 0 or is_inf(x) != 0:
        return 0
    return cast[int32](cast[int64](f_trunc(x)))


def to_uint32(h: int32) -> uint32:
    return cast[uint32](to_int32(h))


# display: append a value's string form via emit_c (uses current emit_tgt)
def display_val(h: int32):
    t: int32 = tag_of(h)
    if t == TAG_UNDEF:
        emit_cstr(cast[Ptr[uint8]]("undefined"))
    elif t == TAG_NULL:
        emit_cstr(cast[Ptr[uint8]]("null"))
    elif t == TAG_BOOL:
        if h == 2:
            emit_cstr(cast[Ptr[uint8]]("true"))
        else:
            emit_cstr(cast[Ptr[uint8]]("false"))
    elif t == TAG_NUM:
        emit_num(v_num[h])
    elif t == TAG_STR:
        emit_strid(strid_of(h))
    else:
        display_obj(h)


def display_obj(h: int32):
    o: int32 = objid_of(h)
    if obj_is_date[o] != cast[uint8](0):      # Date -> ISO string
        emit_strid(date_iso_strid(obj_date_ms[o]))
        return
    if obj_re_prog[o] >= 0:                   # regex literal: /source/flags
        emit_c(47)
        emit_strid(strid_of(obj_get_cstr(o, cast[Ptr[uint8]]("source"))))
        emit_c(47)
        emit_strid(strid_of(obj_get_cstr(o, cast[Ptr[uint8]]("flags"))))
        return
    if cast[int32](obj_kind[o]) == OK_FUNC:
        emit_cstr(cast[Ptr[uint8]]("function"))
        return
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        # console.log prints arrays as: [ a, b, c ] — but our gate uses join;
        # for plain display use comma-separated bracketed form.
        emit_c(91)
        i: int32 = 0
        while i < arr_len[o]:
            if i > 0:
                emit_cstr(cast[Ptr[uint8]](", "))
            display_val_quoted(arr_get(o, i))
            i = i + 1
        emit_c(93)
        return
    # error-like object (has both name and message): print "Name: message".
    # Use allocation-free lookups: we may be mid string-build (emit_tgt==0).
    if obj_find_prop_cstr(o, cast[Ptr[uint8]]("name")) >= 0 and obj_find_prop_cstr(o, cast[Ptr[uint8]]("message")) >= 0:
        nmv: int32 = obj_get_cstr(o, cast[Ptr[uint8]]("name"))
        msv: int32 = obj_get_cstr(o, cast[Ptr[uint8]]("message"))
        if tag_of(nmv) == TAG_STR:
            emit_strid(strid_of(nmv))
        else:
            display_val(nmv)
        if tag_of(msv) == TAG_STR and str_len(strid_of(msv)) > 0:
            emit_cstr(cast[Ptr[uint8]](": "))
            emit_strid(strid_of(msv))
        return
    # plain object: { key: value, ... }
    emit_cstr(cast[Ptr[uint8]]("{ "))
    p: int32 = obj_head[o]
    first: int32 = 1
    # props are stored newest-first; reverse for stable output
    display_obj_props(o)
    emit_cstr(cast[Ptr[uint8]](" }"))


def display_obj_props(o: int32):
    # print in insertion order by walking a reversed view (simple: collect)
    # gather into a temp stack in ax? Use recursion to reverse.
    display_props_rec(obj_head[o], 1)


def display_props_rec(p: int32, first: int32):
    if p < 0:
        return
    display_props_rec(p_next[p], 0)
    if first == 0:
        # this is not the deepest; separators handled below
        pass
    emit_strid(p_key[p])
    emit_cstr(cast[Ptr[uint8]](": "))
    display_val_quoted(p_val[p])
    if p_next[p] >= 0:
        # not the last-in-print-order? Actually reversed: print comma if this
        # node has a predecessor in print order (i.e., it's not the first).
        pass


def display_val_quoted(h: int32):
    if tag_of(h) == TAG_STR:
        emit_c(39)
        emit_strid(strid_of(h))
        emit_c(39)
    else:
        display_val(h)


# to a fresh string value (for String(), concat, JSON)
def to_string_val(h: int32) -> int32:
    if tag_of(h) == TAG_STR:
        return h
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    display_val(h)
    id: int32 = bld_end()
    emit_tgt = save
    return v_string_id(id)


def strid_concat(a: int32, b: int32) -> int32:
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    emit_strid(a)
    emit_strid(b)
    id: int32 = bld_end()
    emit_tgt = save
    return id


# strict equality
def strict_eq(a: int32, b: int32) -> int32:
    ta: int32 = tag_of(a)
    tb: int32 = tag_of(b)
    if ta != tb:
        return 0
    if ta == TAG_UNDEF or ta == TAG_NULL:
        return 1
    if ta == TAG_BOOL:
        if a == b:
            return 1
        return 0
    if ta == TAG_NUM:
        if v_num[a] == v_num[b]:
            return 1
        return 0
    if ta == TAG_STR:
        return str_eq(strid_of(a), strid_of(b))
    # objects: reference identity
    if objid_of(a) == objid_of(b):
        return 1
    return 0


def loose_eq(a: int32, b: int32) -> int32:
    ta: int32 = tag_of(a)
    tb: int32 = tag_of(b)
    if ta == tb:
        return strict_eq(a, b)
    # null == undefined
    if (ta == TAG_NULL and tb == TAG_UNDEF) or (ta == TAG_UNDEF and tb == TAG_NULL):
        return 1
    if (ta == TAG_NULL or ta == TAG_UNDEF) or (tb == TAG_NULL or tb == TAG_UNDEF):
        return 0
    # number/string/bool coercions -> number compare
    if ta == TAG_OBJ or tb == TAG_OBJ:
        # compare via string for one object side (arrays/objs) — approx
        sa: int32 = to_string_val(a)
        sb: int32 = to_string_val(b)
        return str_eq(strid_of(sa), strid_of(sb))
    xa: float64 = to_number(a)
    xb: float64 = to_number(b)
    if xa == xb:
        return 1
    return 0


# member get on any value (properties + .length)
def prop_len_key() -> int32:
    return 0


LEN_STR: int32 = -1

def member_get(objv: int32, key_sid: int32) -> int32:
    t: int32 = tag_of(objv)
    if t == TAG_STR:
        if str_eq_cstr(key_sid, cast[Ptr[uint8]]("length")) != 0:
            return v_number(cast[float64](str_len(strid_of(objv))))
        return v_undef()
    if t == TAG_OBJ:
        o: int32 = objid_of(objv)
        if cast[int32](obj_map_kind[o]) != MAP_KIND_NONE and str_eq_cstr(key_sid, cast[Ptr[uint8]]("size")) != 0:
            return v_number(cast[float64](obj_ms_size[o]))
        if cast[int32](obj_kind[o]) == OK_ARRAY:
            if str_eq_cstr(key_sid, cast[Ptr[uint8]]("length")) != 0:
                return v_number(cast[float64](arr_len[o]))
            # numeric index as string?
            idx: int32 = str_as_index(key_sid)
            if idx >= 0:
                return arr_get(o, idx)
        # own property, then walk the [[Prototype]] chain
        cur: int32 = o
        while cur >= 0:
            pp: int32 = obj_find_prop(cur, key_sid)
            if pp >= 0:
                return p_val[pp]
            cur = obj_proto[cur]
        # the global object (window/self/globalThis) mirrors global scope:
        # `window.document`, `window.google` resolve to the matching global.
        if g_global_obj != 0 and o == objid_of(g_global_obj):
            gb: int32 = env_lookup_bind(g_env, key_sid)
            if gb >= 0:
                return b_val[gb]
        return v_undef()
    if t == TAG_UNDEF or t == TAG_NULL:
        throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("cannot read property of null or undefined"))
        return v_undef()
    return v_undef()


def str_as_index(sid: int32) -> int32:
    n: int32 = str_len(sid)
    if n == 0:
        return -1
    i: int32 = 0
    v: int32 = 0
    while i < n:
        c: uint8 = str_char(sid, i)
        if is_digit(c) == 0:
            return -1
        v = v * 10 + (cast[int32](c) - 48)
        i = i + 1
    return v


def member_set(objv: int32, key_sid: int32, val: int32):
    if tag_of(objv) != TAG_OBJ:
        return
    o: int32 = objid_of(objv)
    if obj_frozen[o] != 0:
        return                         # frozen: element/property writes are dropped
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        if str_eq_cstr(key_sid, cast[Ptr[uint8]]("length")) != 0:
            return
        idx: int32 = str_as_index(key_sid)
        if idx >= 0:
            arr_set(o, idx, val)
            return
    obj_set(o, key_sid, val)
    # assigning `window.X = v` also publishes X as a global (browser semantics),
    # so a later bare `X` sees it.
    if g_global_obj != 0 and o == objid_of(g_global_obj):
        gb: int32 = env_lookup_bind(g_env, key_sid)
        if gb >= 0:
            b_val[gb] = val
        else:
            env_define(g_env, key_sid, val, 0)
    # Fire the embedder's member-set hook (e.g. innerHTML fragment parsing).
    # Suppressed while already inside a hook so the hook's own property writes
    # (rebuilding childNodes, stamping created nodes) do not recurse.
    if member_set_hook_set != 0 and mset_in_hook == 0 and \
       (g_global_obj == 0 or o != objid_of(g_global_obj)):
        mset_in_hook = 1
        mset_this_v = objv
        mset_key_v = v_string_id(key_sid)
        mset_val_v = val
        mhf: Fn[int32, int32] = cast[Fn[int32, int32]](member_set_hook_addr)
        ignore_mh: int32 = mhf(0)
        mset_in_hook = 0


# binary numeric/string op
def eval_binop(op: int32, a: int32, b: int32) -> int32:
    if op == OP_ADD:
        # if either is a string -> string concat
        if tag_of(a) == TAG_STR or tag_of(b) == TAG_STR:
            sa: int32 = to_string_val(a)
            sb: int32 = to_string_val(b)
            return v_string_id(strid_concat(strid_of(sa), strid_of(sb)))
        if tag_of(a) == TAG_OBJ or tag_of(b) == TAG_OBJ:
            sa2: int32 = to_string_val(a)
            sb2: int32 = to_string_val(b)
            return v_string_id(strid_concat(strid_of(sa2), strid_of(sb2)))
        return v_number(to_number(a) + to_number(b))
    if op == OP_SUB:
        return v_number(to_number(a) - to_number(b))
    if op == OP_MUL:
        return v_number(to_number(a) * to_number(b))
    if op == OP_DIV:
        return v_number(to_number(a) / to_number(b))
    if op == OP_MOD:
        return v_number(f_fmod(to_number(a), to_number(b)))
    if op == OP_POW:
        return v_number(f_pow(to_number(a), to_number(b)))
    if op == OP_LT:
        return cmp_op(a, b, 0)
    if op == OP_GT:
        return cmp_op(a, b, 1)
    if op == OP_LE:
        return cmp_op(a, b, 2)
    if op == OP_GE:
        return cmp_op(a, b, 3)
    if op == OP_EQ:
        return v_boolv(loose_eq(a, b))
    if op == OP_NE:
        return v_boolv(1 - loose_eq(a, b))
    if op == OP_SEQ:
        return v_boolv(strict_eq(a, b))
    if op == OP_SNE:
        return v_boolv(1 - strict_eq(a, b))
    if op == OP_BAND:
        return v_number(cast[float64](to_int32(a) & to_int32(b)))
    if op == OP_BOR:
        return v_number(cast[float64](to_int32(a) | to_int32(b)))
    if op == OP_BXOR:
        return v_number(cast[float64](to_int32(a) ^ to_int32(b)))
    if op == OP_SHL:
        sh: int32 = to_int32(b) & 31
        return v_number(cast[float64](to_int32(a) << sh))
    if op == OP_SHR:
        sh2: int32 = to_int32(b) & 31
        return v_number(cast[float64](to_int32(a) >> sh2))
    if op == OP_USHR:
        sh3: uint32 = to_uint32(b) & 31
        uv: uint32 = to_uint32(a) >> sh3
        return v_number(cast[float64](uv))
    if op == OP_INSTANCEOF:
        return v_boolv(instance_of(a, b))
    if op == OP_IN:
        return v_boolv(op_in(a, b))
    return v_undef()


def instance_of(v: int32, ctor: int32) -> int32:
    if tag_of(v) != TAG_OBJ:
        return 0
    if is_callable(ctor) == 0:
        return 0
    protov: int32 = obj_get(objid_of(ctor), str_from_cstr(cast[Ptr[uint8]]("prototype")))
    if tag_of(protov) != TAG_OBJ:
        return 0
    target: int32 = objid_of(protov)
    cur: int32 = obj_proto[objid_of(v)]
    while cur >= 0:
        if cur == target:
            return 1
        cur = obj_proto[cur]
    return 0


def op_in(keyv: int32, objv: int32) -> int32:
    if tag_of(objv) != TAG_OBJ:
        return 0
    ks: int32 = strid_of(to_string_val(keyv))
    o: int32 = objid_of(objv)
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        idx: int32 = str_as_index(ks)
        if idx >= 0 and idx < arr_len[o]:
            return 1
    if obj_find_prop(o, ks) >= 0:
        return 1
    return 0


def cmp_op(a: int32, b: int32, kind: int32) -> int32:
    # string vs string -> lexicographic; else numeric
    if tag_of(a) == TAG_STR and tag_of(b) == TAG_STR:
        c: int32 = str_cmp(strid_of(a), strid_of(b))
        if kind == 0:
            return v_boolv(c < 0)
        if kind == 1:
            return v_boolv(c > 0)
        if kind == 2:
            return v_boolv(c <= 0)
        return v_boolv(c >= 0)
    xa: float64 = to_number(a)
    xb: float64 = to_number(b)
    if is_nan(xa) != 0 or is_nan(xb) != 0:
        return v_boolv(0)
    if kind == 0:
        return v_boolv(xa < xb)
    if kind == 1:
        return v_boolv(xa > xb)
    if kind == 2:
        return v_boolv(xa <= xb)
    return v_boolv(xa >= xb)


def str_cmp(a: int32, b: int32) -> int32:
    la: int32 = str_len(a)
    lb: int32 = str_len(b)
    n: int32 = la
    if lb < n:
        n = lb
    i: int32 = 0
    while i < n:
        ca: uint8 = str_char(a, i)
        cb: uint8 = str_char(b, i)
        if ca < cb:
            return -1
        if ca > cb:
            return 1
        i = i + 1
    if la < lb:
        return -1
    if la > lb:
        return 1
    return 0


# ---- expression evaluation ----
def eval_expr(node: int32, env: int32) -> int32:
    if node < 0:
        return v_undef()
    if err_flag != 0:
        return v_undef()
    if ctl == CTL_THROW:
        return v_undef()
    k: int32 = cast[int32](n_kind[node])
    if k == ND_NUM:
        return v_number(n_num[node])
    if k == ND_STR:
        return v_string_id(n_str[node])
    if k == ND_REGEX:
        return js_make_regex(n_str[node], n_a[node])
    if k == ND_TRUE:
        return v_true()
    if k == ND_FALSE:
        return v_false()
    if k == ND_NULL:
        return v_null()
    if k == ND_UNDEF:
        return v_undef()
    if k == ND_THIS:
        if this_top > 0:
            return this_stack[this_top - 1]
        return v_undef()
    if k == ND_IDENT:
        b: int32 = env_lookup_bind(env, n_str[node])
        if b < 0:
            # undefined global reference -> ReferenceError semantics soft:
            set_error(named_error_msg(cast[Ptr[uint8]]("ReferenceError: "), n_str[node], cast[Ptr[uint8]](" is not defined")))
            return v_undef()
        return b_val[b]
    if k == ND_ARRAY:
        return eval_array_lit(node, env)
    if k == ND_OBJECT:
        return eval_object_lit(node, env)
    if k == ND_AWAIT:
        av: int32 = eval_expr(n_a[node], env)
        if err_flag != 0 or ctl == CTL_THROW:
            return v_undef()
        return do_await(av)
    if k == ND_FUNC:
        return v_new_closure(node, env)
    if k == ND_ARROW:
        ah: int32 = v_new_closure(node, env)
        ao: int32 = objid_of(ah)
        if this_top > 0:
            obj_fn_this[ao] = this_stack[this_top - 1]
            obj_fn_home[ao] = home_stack[this_top - 1]
        else:
            obj_fn_this[ao] = v_undef()
            obj_fn_home[ao] = -1
        return ah
    if k == ND_BINOP:
        a: int32 = eval_expr(n_a[node], env)
        if err_flag != 0:
            return v_undef()
        bb: int32 = eval_expr(n_b[node], env)
        return eval_binop(n_op[node], a, bb)
    if k == ND_LOGICAL:
        la: int32 = eval_expr(n_a[node], env)
        if n_op[node] == 0:            # &&
            if to_bool(la) == 0:
                return la
            return eval_expr(n_b[node], env)
        elif n_op[node] == 2:          # ?? (nullish coalescing)
            if tag_of(la) == TAG_UNDEF or tag_of(la) == TAG_NULL:
                return eval_expr(n_b[node], env)
            return la
        else:                          # ||
            if to_bool(la) != 0:
                return la
            return eval_expr(n_b[node], env)
    if k == ND_OPTCHAIN:
        save_oc: int32 = oc_short
        oc_short = 0
        ocv: int32 = eval_expr(n_a[node], env)
        res_oc: int32 = ocv
        if oc_short != 0:
            res_oc = v_undef()
        oc_short = save_oc
        return res_oc
    if k == ND_UNARY:
        return eval_unary(node, env)
    if k == ND_UPDATE:
        return eval_update(node, env)
    if k == ND_TERNARY:
        cnd: int32 = eval_expr(n_a[node], env)
        if to_bool(cnd) != 0:
            return eval_expr(n_b[node], env)
        return eval_expr(n_c[node], env)
    if k == ND_ASSIGN:
        return eval_assign(node, env)
    if k == ND_CLASS:
        return eval_class(node, env)
    if k == ND_SUPER:
        # bare `super` as a value is not meaningful; return current this
        if this_top > 0:
            return this_stack[this_top - 1]
        return v_undef()
    if k == ND_MEMBER:
        if cast[int32](n_kind[n_a[node]]) == ND_SUPER:
            return super_get(n_str[node])
        objv: int32 = eval_expr(n_a[node], env)
        if oc_short != 0:
            return v_undef()           # earlier `?.` short-circuited: skip
        if n_d[node] == 1 and (tag_of(objv) == TAG_UNDEF or tag_of(objv) == TAG_NULL):
            oc_short = 1
            return v_undef()
        return member_get(objv, n_str[node])
    if k == ND_INDEX:
        objv2: int32 = eval_expr(n_a[node], env)
        if oc_short != 0:
            return v_undef()
        if n_d[node] == 1 and (tag_of(objv2) == TAG_UNDEF or tag_of(objv2) == TAG_NULL):
            oc_short = 1
            return v_undef()
        idxv: int32 = eval_expr(n_b[node], env)
        return index_get(objv2, idxv)
    if k == ND_CALL:
        return eval_call(node, env)
    if k == ND_NEW:
        return eval_new(node, env)
    return v_undef()


def index_get(objv: int32, idxv: int32) -> int32:
    if tag_of(objv) == TAG_STR:
        if tag_of(idxv) == TAG_NUM:
            i: int32 = cast[int32](v_num[idxv])
            sid: int32 = strid_of(objv)
            if i >= 0 and i < str_len(sid):
                return v_string_bytes(&sp_buf[st_off[sid] + i], 1)
            return v_undef()
    ks: int32 = strid_of(to_string_val(idxv))
    return member_get(objv, ks)


def eval_array_lit(node: int32, env: int32) -> int32:
    v: int32 = v_new_array()
    o: int32 = objid_of(v)
    el: int32 = n_a[node]
    while el >= 0:
        if cast[int32](n_kind[el]) == ND_SPREAD:
            srcv: int32 = eval_expr(n_a[el], env)
            if is_array(srcv) != 0:
                so: int32 = objid_of(srcv)
                i: int32 = 0
                while i < arr_len[so]:
                    arr_push(o, arr_get(so, i))
                    i = i + 1
            elif tag_of(srcv) == TAG_STR:
                sid: int32 = strid_of(srcv)
                j: int32 = 0
                while j < str_len(sid):
                    arr_push(o, v_string_bytes(&sp_buf[st_off[sid] + j], 1))
                    j = j + 1
        else:
            arr_push(o, eval_expr(el, env))
        el = n_next[el]
    return v


def eval_object_lit(node: int32, env: int32) -> int32:
    v: int32 = v_new_object()
    o: int32 = objid_of(v)
    pr: int32 = n_a[node]
    while pr >= 0:
        if cast[int32](n_kind[pr]) == ND_SPREAD:
            srcv2: int32 = eval_expr(n_a[pr], env)
            if tag_of(srcv2) == TAG_OBJ:
                copy_own_props(objid_of(srcv2), o)
        else:
            obj_set(o, n_str[pr], eval_expr(n_a[pr], env))
        pr = n_next[pr]
    return v


def eval_delete(tgt: int32, env: int32) -> int32:
    # `delete obj.key` / `delete obj[key]`. Returns true (delete rarely fails
    # in the code we run). Non-reference operands are a no-op that yields true.
    tk: int32 = cast[int32](n_kind[tgt])
    if tk == ND_MEMBER:
        objv: int32 = eval_expr(n_a[tgt], env)
        if tag_of(objv) == TAG_OBJ:
            obj_del_prop(objid_of(objv), n_str[tgt])
        return v_boolv(1)
    if tk == ND_INDEX:
        objv2: int32 = eval_expr(n_a[tgt], env)
        keyv: int32 = eval_expr(n_b[tgt], env)
        if tag_of(objv2) == TAG_OBJ:
            o: int32 = objid_of(objv2)
            if cast[int32](obj_kind[o]) == OK_ARRAY and tag_of(keyv) == TAG_NUM:
                idx: int32 = cast[int32](v_num[keyv])
                if idx >= 0 and idx < arr_len[o]:
                    arr_set(o, idx, v_undef())
                    return v_boolv(1)
            obj_del_prop(o, strid_of(to_string_val(keyv)))
        return v_boolv(1)
    return v_boolv(1)


def eval_unary(node: int32, env: int32) -> int32:
    op: int32 = n_op[node]
    if op == U_TYPEOF:
        # typeof of an undefined identifier is "undefined" (no ReferenceError)
        if cast[int32](n_kind[n_a[node]]) == ND_IDENT:
            b: int32 = env_lookup_bind(env, n_str[n_a[node]])
            if b < 0:
                return v_string_cstr(cast[Ptr[uint8]]("undefined"))
        v: int32 = eval_expr(n_a[node], env)
        return v_string_cstr(typeof_str(v))
    if op == U_VOID:
        # evaluate operand for side effects, result is always `undefined`
        eval_expr(n_a[node], env)
        return v_undef()
    if op == U_DELETE:
        return eval_delete(n_a[node], env)
    v2: int32 = eval_expr(n_a[node], env)
    if op == U_NEG:
        return v_number(0.0 - to_number(v2))
    if op == U_POS:
        return v_number(to_number(v2))
    if op == U_NOT:
        return v_boolv(1 - to_bool(v2))
    if op == U_BNOT:
        return v_number(cast[float64](~to_int32(v2)))
    return v_undef()


def typeof_str(v: int32) -> Ptr[uint8]:
    t: int32 = tag_of(v)
    if t == TAG_UNDEF:
        return cast[Ptr[uint8]]("undefined")
    if t == TAG_NULL:
        return cast[Ptr[uint8]]("object")
    if t == TAG_BOOL:
        return cast[Ptr[uint8]]("boolean")
    if t == TAG_NUM:
        return cast[Ptr[uint8]]("number")
    if t == TAG_STR:
        return cast[Ptr[uint8]]("string")
    if is_callable(v) != 0:
        return cast[Ptr[uint8]]("function")
    return cast[Ptr[uint8]]("object")


def eval_update(node: int32, env: int32) -> int32:
    delta: float64 = cast[float64](n_op[node])
    tgt: int32 = n_a[node]
    old: int32 = eval_expr(tgt, env)
    oldn: float64 = to_number(old)
    newn: float64 = oldn + delta
    nv: int32 = v_number(newn)
    assign_to(tgt, nv, env)
    if n_b[node] == 1:                 # prefix
        return nv
    return v_number(oldn)              # postfix returns old


def assign_to(tgt: int32, val: int32, env: int32):
    k: int32 = cast[int32](n_kind[tgt])
    if k == ND_IDENT:
        b: int32 = env_lookup_bind(env, n_str[tgt])
        if b < 0:
            env_define(g_env, n_str[tgt], val, 0)   # implicit global
        else:
            if b_const[b] != 0:
                throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("assignment to constant variable"))
                return
            b_val[b] = val
    elif k == ND_MEMBER:
        objv: int32 = eval_expr(n_a[tgt], env)
        member_set(objv, n_str[tgt], val)
    elif k == ND_INDEX:
        objv2: int32 = eval_expr(n_a[tgt], env)
        idxv: int32 = eval_expr(n_b[tgt], env)
        ks: int32 = strid_of(to_string_val(idxv))
        member_set(objv2, ks, val)


def eval_assign(node: int32, env: int32) -> int32:
    op: int32 = n_op[node]
    # short-circuiting logical assignments: the RHS is evaluated (and the store
    # performed) only when the operator would proceed.
    if op == ALOG_OR:
        curo: int32 = eval_expr(n_a[node], env)
        if to_bool(curo) != 0:
            return curo
        rvo: int32 = eval_expr(n_b[node], env)
        assign_to(n_a[node], rvo, env)
        return rvo
    if op == ALOG_AND:
        cura: int32 = eval_expr(n_a[node], env)
        if to_bool(cura) == 0:
            return cura
        rva: int32 = eval_expr(n_b[node], env)
        assign_to(n_a[node], rva, env)
        return rva
    if op == ALOG_NULLISH:
        curn: int32 = eval_expr(n_a[node], env)
        if tag_of(curn) != TAG_UNDEF and tag_of(curn) != TAG_NULL:
            return curn
        rvn: int32 = eval_expr(n_b[node], env)
        assign_to(n_a[node], rvn, env)
        return rvn
    rhs: int32 = eval_expr(n_b[node], env)
    if op >= 0:
        # compound assignment: target op= rhs
        cur: int32 = eval_expr(n_a[node], env)
        rhs = eval_binop(op, cur, rhs)
    assign_to(n_a[node], rhs, env)
    return rhs


# ---- calls ----
def spread_into_args(srcv: int32):
    # expand an iterable (array or string) onto call_args
    if is_array(srcv) != 0:
        o: int32 = objid_of(srcv)
        i: int32 = 0
        while i < arr_len[o]:
            call_args[call_top] = arr_get(o, i)
            call_top = call_top + 1
            i = i + 1
    elif tag_of(srcv) == TAG_STR:
        sid: int32 = strid_of(srcv)
        j: int32 = 0
        while j < str_len(sid):
            call_args[call_top] = v_string_bytes(&sp_buf[st_off[sid] + j], 1)
            call_top = call_top + 1
            j = j + 1


def eval_args_into(argnode: int32, env: int32) -> int32:
    # push arg values onto call_args; return count
    base: int32 = call_top
    a: int32 = argnode
    while a >= 0:
        if cast[int32](n_kind[a]) == ND_SPREAD:
            spread_into_args(eval_expr(n_a[a], env))
        else:
            call_args[call_top] = eval_expr(a, env)
            call_top = call_top + 1
        a = n_next[a]
    return call_top - base


# look up `key_sid` on the parent of the current method's home prototype
def super_get(key_sid: int32) -> int32:
    if this_top <= 0:
        return v_undef()
    home: int32 = home_stack[this_top - 1]
    if home < 0:
        return v_undef()
    cur: int32 = obj_proto[home]
    while cur >= 0:
        pp: int32 = obj_find_prop(cur, key_sid)
        if pp >= 0:
            return p_val[pp]
        cur = obj_proto[cur]
    return v_undef()


# Function.prototype.{call,apply,bind}. `fnv` is the callable receiver.
# Returns -2 if `name` is not one of these (so the caller falls through).
def try_function_method(fnv: int32, name: int32, argnode: int32, env: int32) -> int32:
    if str_eq_cstr(name, cast[Ptr[uint8]]("call")) != 0:
        base: int32 = call_top
        argc: int32 = eval_args_into(argnode, env)
        if ctl == CTL_THROW or err_flag != 0:
            call_top = base
            return v_undef()
        this_arg: int32 = v_undef()
        if argc >= 1:
            this_arg = call_args[base]
            r: int32 = invoke(fnv, this_arg, base + 1, argc - 1)
            call_top = base
            return r
        r0: int32 = invoke(fnv, this_arg, base, 0)
        call_top = base
        return r0
    if str_eq_cstr(name, cast[Ptr[uint8]]("apply")) != 0:
        base2: int32 = call_top
        argc2: int32 = eval_args_into(argnode, env)
        if ctl == CTL_THROW or err_flag != 0:
            call_top = base2
            return v_undef()
        this_arg2: int32 = v_undef()
        if argc2 >= 1:
            this_arg2 = call_args[base2]
        # second arg (an array-like) is spread into the call
        spreadbase: int32 = call_top
        nsp: int32 = 0
        if argc2 >= 2:
            arrv: int32 = call_args[base2 + 1]
            if is_array(arrv) != 0:
                ao: int32 = objid_of(arrv)
                i: int32 = 0
                while i < arr_len[ao]:
                    call_args[call_top] = arr_get(ao, i)
                    call_top = call_top + 1
                    nsp = nsp + 1
                    i = i + 1
        r2: int32 = invoke(fnv, this_arg2, spreadbase, nsp)
        call_top = base2
        return r2
    if str_eq_cstr(name, cast[Ptr[uint8]]("bind")) != 0:
        base3: int32 = call_top
        argc3: int32 = eval_args_into(argnode, env)
        if ctl == CTL_THROW or err_flag != 0:
            call_top = base3
            return v_undef()
        bthis: int32 = v_undef()
        if argc3 >= 1:
            bthis = call_args[base3]
        # capture pre-applied args (index 1..) into a JS array
        pre: int32 = -1
        if argc3 >= 2:
            pre = v_new_array()
            pao: int32 = objid_of(pre)
            j: int32 = 1
            while j < argc3:
                arr_push(pao, call_args[base3 + j])
                j = j + 1
        call_top = base3
        bf: int32 = v_new_native(-1)         # a callable object with no native id
        bo: int32 = objid_of(bf)
        obj_fn_btarget[bo] = fnv
        obj_fn_bthis[bo] = bthis
        obj_fn_bargs[bo] = pre
        return bf
    return -2


def eval_call(node: int32, env: int32) -> int32:
    callee: int32 = n_a[node]
    ck: int32 = cast[int32](n_kind[callee])
    thisv: int32 = v_undef()
    fnv: int32 = 0
    method_name: int32 = -1
    is_builtin_method: int32 = 0
    if ck == ND_SUPER:
        # super(...) : run the parent constructor on the current `this`
        cur_this: int32 = v_undef()
        curfn: int32 = -1
        if this_top > 0:
            cur_this = this_stack[this_top - 1]
            curfn = curfn_stack[this_top - 1]
        supv: int32 = v_undef()
        if curfn >= 0 and obj_fn_super[curfn] >= 0:
            supv = obj_fn_super[curfn]
        base0: int32 = call_top
        argc0: int32 = eval_args_into(n_b[node], env)
        if ctl == CTL_THROW:
            call_top = base0
            return v_undef()
        if is_callable(supv) != 0:
            run_constructor(supv, cur_this, base0, argc0)
        call_top = base0
        return v_undef()
    if ck == ND_MEMBER and cast[int32](n_kind[n_a[callee]]) == ND_SUPER:
        # super.method(...) : parent-prototype method, `this` = current this
        cur_this2: int32 = v_undef()
        if this_top > 0:
            cur_this2 = this_stack[this_top - 1]
        fnv2: int32 = super_get(n_str[callee])
        if is_callable(fnv2) == 0:
            throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("super method is not a function"))
            return v_undef()
        base1: int32 = call_top
        argc1: int32 = eval_args_into(n_b[node], env)
        if ctl == CTL_THROW:
            call_top = base1
            return v_undef()
        r1: int32 = invoke(fnv2, cur_this2, base1, argc1)
        call_top = base1
        return r1
    if ck == ND_MEMBER:
        thisv = eval_expr(n_a[callee], env)
        method_name = n_str[callee]
        if err_flag != 0 or ctl == CTL_THROW:
            return v_undef()
        if oc_short != 0:              # deeper `?.` short-circuited
            return v_undef()
        if n_d[callee] == 1 and (tag_of(thisv) == TAG_UNDEF or tag_of(thisv) == TAG_NULL):
            oc_short = 1
            return v_undef()
        # string/array builtin methods
        if tag_of(thisv) == TAG_STR:
            return call_string_method(thisv, method_name, n_b[node], env)
        if tag_of(thisv) == TAG_NUM:
            rn: int32 = try_number_method(thisv, method_name, n_b[node], env)
            if rn != -2:
                return rn
        if is_array(thisv) != 0:
            r: int32 = try_array_method(thisv, method_name, n_b[node], env)
            if r != -2:
                return r
        if is_regex(thisv) != 0:
            rr: int32 = try_regex_method(thisv, method_name, n_b[node], env)
            if rr != -2:
                return rr
        # Function.prototype.call/apply/bind on any callable receiver
        if is_callable(thisv) != 0:
            rfm: int32 = try_function_method(thisv, method_name, n_b[node], env)
            if rfm != -2:
                return rfm
        fnv = member_get(thisv, method_name)
    elif ck == ND_INDEX:
        thisv = eval_expr(n_a[callee], env)
        if oc_short != 0:
            return v_undef()
        if n_d[callee] == 1 and (tag_of(thisv) == TAG_UNDEF or tag_of(thisv) == TAG_NULL):
            oc_short = 1
            return v_undef()
        idxv: int32 = eval_expr(n_b[callee], env)
        ks: int32 = strid_of(to_string_val(idxv))
        fnv = member_get(thisv, ks)
    else:
        fnv = eval_expr(callee, env)
    if err_flag != 0 or ctl == CTL_THROW:
        return v_undef()
    if oc_short != 0:                  # optional chain upstream short-circuited
        return v_undef()
    if n_d[node] == 1 and (tag_of(fnv) == TAG_UNDEF or tag_of(fnv) == TAG_NULL):
        oc_short = 1                   # f?.() on a nullish callee
        return v_undef()
    if is_callable(fnv) == 0:
        callname: int32 = -1
        if ck == ND_MEMBER:
            callname = method_name
        elif cast[int32](n_kind[callee]) == ND_IDENT:
            callname = n_str[callee]
        if callname >= 0:
            throw_error(cast[Ptr[uint8]]("TypeError"), named_error_msg(cast[Ptr[uint8]](""), callname, cast[Ptr[uint8]](" is not a function")))
        else:
            throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("value is not a function"))
        return v_undef()
    base: int32 = call_top
    argc: int32 = eval_args_into(n_b[node], env)
    if ctl == CTL_THROW:
        call_top = base
        return v_undef()
    r2: int32 = invoke(fnv, thisv, base, argc)
    call_top = base
    return r2


def bind_params(fnode: int32, callenv: int32, argbase: int32, argc: int32):
    p: int32 = n_a[fnode]
    i: int32 = 0
    while p >= 0:
        if n_op[p] == 1:                   # rest parameter: gather the rest
            restv: int32 = v_new_array()
            ro: int32 = objid_of(restv)
            j: int32 = i
            while j < argc:
                arr_push(ro, call_args[argbase + j])
                j = j + 1
            env_define(callenv, n_str[p], restv, 0)
            return
        av: int32 = v_undef()
        if i < argc:
            av = call_args[argbase + i]
        if tag_of(av) == TAG_UNDEF and n_a[p] >= 0:
            av = eval_expr(n_a[p], callenv)   # default value
        if n_b[p] >= 0:                       # destructuring parameter
            bind_pattern(n_b[p], av, callenv, 0, callenv)
        else:
            env_define(callenv, n_str[p], av, 0)
        p = n_next[p]
        i = i + 1


def invoke(fnv: int32, thisv: int32, argbase: int32, argc: int32) -> int32:
    o: int32 = objid_of(fnv)
    # bound function (.bind): prepend the pre-applied args, force the bound
    # `this`, then invoke the target.
    if obj_fn_btarget[o] >= 0:
        tgt: int32 = obj_fn_btarget[o]
        bthis: int32 = obj_fn_bthis[o]
        pre: int32 = obj_fn_bargs[o]
        nbase: int32 = call_top
        np: int32 = 0
        if pre >= 0:
            po: int32 = objid_of(pre)
            pi: int32 = 0
            while pi < arr_len[po]:
                call_args[call_top] = arr_get(po, pi)
                call_top = call_top + 1
                pi = pi + 1
                np = np + 1
        ai: int32 = 0
        while ai < argc:
            call_args[call_top] = call_args[argbase + ai]
            call_top = call_top + 1
            ai = ai + 1
        rb: int32 = invoke(tgt, bthis, nbase, np + argc)
        call_top = nbase
        return rb
    nat: int32 = obj_fn_native[o]
    if nat >= 0:
        native_self = o                    # let a native recover its bound state
        return call_native(nat, thisv, argbase, argc)
    fnode: int32 = obj_fn_node[o]
    fenv: int32 = obj_fn_env[o]
    is_arrow: int32 = 0
    if cast[int32](n_kind[fnode]) == ND_ARROW:
        is_arrow = 1
    # arrows use their captured lexical `this` and home (for `super`)
    use_this: int32 = thisv
    use_home: int32 = obj_fn_home[o]
    if is_arrow != 0 and obj_fn_this[o] != -2:
        use_this = obj_fn_this[o]
    callenv: int32 = env_new(fenv, 1)
    # a named function expression binds its own name inside its body scope
    if n_str[fnode] >= 0:
        env_define(callenv, n_str[fnode], fnv, 0)
    bind_params(fnode, callenv, argbase, argc)
    this_stack[this_top] = use_this
    home_stack[this_top] = use_home
    curfn_stack[this_top] = o
    this_top = this_top + 1
    is_async_fn: int32 = cast[int32](n_op[fnode])   # 1 => async function/arrow
    if is_arrow != 0 and n_c[fnode] == 1:
        # concise expression body: value is the expression, no `return`
        rvx: int32 = eval_expr(n_b[fnode], callenv)
        this_top = this_top - 1
        if is_async_fn != 0:
            return async_wrap_return(rvx)  # ctl reflects a throw from the expr
        return rvx
    # hoist var/function declarations, then run body
    hoist_scan(n_b[fnode], callenv)
    exec_stmt(n_b[fnode], callenv)
    this_top = this_top - 1
    if is_async_fn != 0:
        # an async body's outcome becomes the returned promise (return/throw)
        arv: int32 = v_undef()
        if ctl == CTL_RETURN:
            arv = ctl_val
        return async_wrap_return(arv)
    if ctl == CTL_THROW:
        return v_undef()                   # propagate the exception
    rv: int32 = v_undef()
    if ctl == CTL_RETURN:
        rv = ctl_val
    ctl = CTL_NONE
    return rv


# Evaluate a class definition to its constructor function value.
def eval_class(node: int32, env: int32) -> int32:
    has_super: int32 = 0
    superv: int32 = 0
    if n_a[node] >= 0:
        has_super = 1
        superv = eval_expr(n_a[node], env)
    # the prototype object shared by all instances
    protov: int32 = v_new_object()
    proto_o: int32 = objid_of(protov)
    if has_super != 0 and tag_of(superv) == TAG_OBJ:
        sp: int32 = obj_get(objid_of(superv), str_from_cstr(cast[Ptr[uint8]]("prototype")))
        if tag_of(sp) == TAG_OBJ:
            obj_proto[proto_o] = objid_of(sp)
    # locate an explicit constructor
    ctor_func: int32 = -1
    m: int32 = n_b[node]
    while m >= 0:
        if n_op[m] == 0 and n_str[m] >= 0 and str_eq_cstr(n_str[m], cast[Ptr[uint8]]("constructor")) != 0:
            ctor_func = n_a[m]
        m = n_next[m]
    default_ctor: int32 = 0
    if ctor_func < 0:
        ctor_func = nd_new(ND_FUNC)
        blk: int32 = nd_new(ND_BLOCK)
        n_b[ctor_func] = blk
        default_ctor = 1
    classv: int32 = v_new_closure(ctor_func, env)
    co: int32 = objid_of(classv)
    if default_ctor != 0:
        obj_class[co] = cast[uint8](3)      # bit0 class, bit1 default
    else:
        obj_class[co] = cast[uint8](1)
    obj_fn_home[co] = proto_o               # `super.x` in the constructor
    if has_super != 0:
        obj_fn_super[co] = superv
        if tag_of(superv) == TAG_OBJ:
            obj_proto[co] = objid_of(superv)   # static inheritance
    obj_set(co, str_from_cstr(cast[Ptr[uint8]]("prototype")), protov)
    obj_set(proto_o, str_from_cstr(cast[Ptr[uint8]]("constructor")), classv)
    # install methods on the prototype (or the class, if static)
    m2: int32 = n_b[node]
    while m2 >= 0:
        if n_str[m2] >= 0 and str_eq_cstr(n_str[m2], cast[Ptr[uint8]]("constructor")) == 0:
            mfnv: int32 = v_new_closure(n_a[m2], env)
            mo: int32 = objid_of(mfnv)
            if n_op[m2] == 1:               # static
                obj_fn_home[mo] = co
                obj_set(co, n_str[m2], mfnv)
            else:
                obj_fn_home[mo] = proto_o
                obj_set(proto_o, n_str[m2], mfnv)
        m2 = n_next[m2]
    return classv


# Run a constructor on an already-allocated instance, applying the implicit
# super(...args) forwarding of a default derived constructor.
def run_constructor(fnv: int32, self_obj: int32, base: int32, argc: int32) -> int32:
    fo: int32 = objid_of(fnv)
    if obj_fn_native[fo] >= 0:
        return invoke(fnv, self_obj, base, argc)
    if (cast[int32](obj_class[fo]) & 2) != 0 and obj_fn_super[fo] >= 0:
        run_constructor(obj_fn_super[fo], self_obj, base, argc)
    return invoke(fnv, self_obj, base, argc)


def eval_new(node: int32, env: int32) -> int32:
    fnv: int32 = eval_expr(n_a[node], env)
    if err_flag != 0 or ctl == CTL_THROW:
        return v_undef()
    if is_callable(fnv) == 0:
        throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("value is not a constructor"))
        return v_undef()
    self_obj: int32 = v_new_object()
    so: int32 = objid_of(self_obj)
    # link the instance to Ctor.prototype
    protov: int32 = obj_get(objid_of(fnv), str_from_cstr(cast[Ptr[uint8]]("prototype")))
    if tag_of(protov) == TAG_OBJ:
        obj_proto[so] = objid_of(protov)
    base: int32 = call_top
    argc: int32 = 0
    if n_b[node] >= 0:
        argc = eval_args_into(n_b[node], env)
    if ctl == CTL_THROW:
        call_top = base
        return v_undef()
    r: int32 = run_constructor(fnv, self_obj, base, argc)
    call_top = base
    if ctl == CTL_THROW:
        return v_undef()
    if tag_of(r) == TAG_OBJ:
        return r
    return self_obj


# ---- statement execution ----
def exec_stmt(node: int32, env: int32):
    if node < 0:
        return
    if err_flag != 0:
        return
    k: int32 = cast[int32](n_kind[node])
    if k == ND_BLOCK:
        pending_label = -1             # a block does not carry a loop label inward
        benv: int32 = env_new(env, 0)
        hoist_funcs_only(n_a[node], benv)
        s: int32 = n_a[node]
        while s >= 0 and ctl == CTL_NONE:
            exec_stmt(s, benv)
            s = n_next[s]
        return
    if k == ND_VAR:
        exec_var(node, env)
        return
    if k == ND_FUNCDECL:
        # already hoisted; nothing to do at exec time
        return
    if k == ND_EXPRSTMT:
        eval_expr(n_a[node], env)
        return
    if k == ND_EMPTY:
        return
    if k == ND_IF:
        c: int32 = eval_expr(n_a[node], env)
        if to_bool(c) != 0:
            exec_stmt(n_b[node], env)
        elif n_c[node] >= 0:
            exec_stmt(n_c[node], env)
        return
    if k == ND_WHILE:
        wlbl: int32 = pending_label
        pending_label = -1
        while ctl == CTL_NONE and to_bool(eval_expr(n_a[node], env)) != 0:
            exec_stmt(n_b[node], env)
            if ctl == CTL_BREAK:
                if ctl_label < 0 or label_eq(ctl_label, wlbl) != 0:
                    ctl = CTL_NONE
                    ctl_label = -1
                break
            if ctl == CTL_CONTINUE:
                if ctl_label < 0 or label_eq(ctl_label, wlbl) != 0:
                    ctl = CTL_NONE
                    ctl_label = -1
                else:
                    break            # continue targets an outer loop
        return
    if k == ND_DOWHILE:
        dlbl: int32 = pending_label
        pending_label = -1
        while ctl == CTL_NONE:
            exec_stmt(n_b[node], env)
            if ctl == CTL_BREAK:
                if ctl_label < 0 or label_eq(ctl_label, dlbl) != 0:
                    ctl = CTL_NONE
                    ctl_label = -1
                break
            if ctl == CTL_CONTINUE:
                if ctl_label < 0 or label_eq(ctl_label, dlbl) != 0:
                    ctl = CTL_NONE
                    ctl_label = -1
                else:
                    break
            if to_bool(eval_expr(n_a[node], env)) == 0:
                break
        return
    if k == ND_FOR:
        exec_for(node, env)
        return
    if k == ND_FORIN:
        exec_forin(node, env)
        return
    if k == ND_FOROF:
        exec_forof(node, env)
        return
    if k == ND_RETURN:
        rv: int32 = v_undef()
        if n_a[node] >= 0:
            rv = eval_expr(n_a[node], env)
        ctl = CTL_RETURN
        ctl_val = rv
        return
    if k == ND_BREAK:
        ctl = CTL_BREAK
        ctl_label = n_str[node]        # -1 when unlabeled
        return
    if k == ND_CONTINUE:
        ctl = CTL_CONTINUE
        ctl_label = n_str[node]
        return
    if k == ND_LABELED:
        pending_label = n_str[node]    # hand the label to the loop it wraps
        exec_stmt(n_a[node], env)
        pending_label = -1
        # a break/continue targeting THIS label (e.g. `break L` out of a
        # labeled block) completes here.
        if (ctl == CTL_BREAK or ctl == CTL_CONTINUE) and label_eq(ctl_label, n_str[node]) != 0:
            ctl = CTL_NONE
            ctl_label = -1
        return
    if k == ND_SWITCH:
        exec_switch(node, env)
        return
    if k == ND_THROW:
        tv: int32 = eval_expr(n_a[node], env)
        if err_flag != 0:
            return
        throw_val = tv
        ctl = CTL_THROW
        return
    if k == ND_TRY:
        exec_try(node, env)
        return
    if k == ND_CLASSDECL:
        cv: int32 = eval_class(n_a[node], env)
        if n_str[node] >= 0:
            env_define(env, n_str[node], cv, 0)
        return
    # fallthrough: treat as expression
    eval_expr(node, env)


def exec_try(node: int32, env: int32):
    exec_stmt(n_a[node], env)          # try block
    if ctl == CTL_THROW and n_b[node] >= 0:
        caught: int32 = throw_val
        ctl = CTL_NONE
        catchenv: int32 = env_new(env, 0)
        if n_str[node] >= 0:
            env_define(catchenv, n_str[node], caught, 0)
        exec_stmt(n_b[node], catchenv)
    if n_c[node] >= 0:                  # finally
        save_ctl: int32 = ctl
        save_val: int32 = ctl_val
        save_throw: int32 = throw_val
        ctl = CTL_NONE
        exec_stmt(n_c[node], env)
        if ctl == CTL_NONE:
            # finally completed normally: restore the pending completion
            ctl = save_ctl
            ctl_val = save_val
            throw_val = save_throw


def exec_var(node: int32, env: int32):
    kind: int32 = n_op[node]           # 0 var, 1 let, 2 const
    tgt_env: int32 = env
    if kind == 0:
        tgt_env = env_func_scope(env)
    d: int32 = n_a[node]
    while d >= 0:
        val: int32 = v_undef()
        if n_a[d] >= 0:
            val = eval_expr(n_a[d], env)
        is_const: int32 = 0
        if kind == 2:
            is_const = 1
        if n_b[d] >= 0:                 # destructuring declarator
            bind_pattern(n_b[d], val, tgt_env, is_const, env)
        else:
            env_define(tgt_env, n_str[d], val, is_const)
        d = n_next[d]


# Bind a destructuring pattern's names from `val` into tgt_env.
def bind_pattern(pat: int32, val: int32, tgt_env: int32, is_const: int32, env: int32):
    if pat < 0:
        return
    pkind: int32 = cast[int32](n_kind[pat])
    if pkind == ND_ARRPAT:
        idx: int32 = 0
        e: int32 = n_a[pat]
        while e >= 0:
            if n_op[e] == 1:           # rest: collect remaining elements
                restv: int32 = v_new_array()
                ro: int32 = objid_of(restv)
                if is_array(val) != 0:
                    ov: int32 = objid_of(val)
                    j: int32 = idx
                    while j < arr_len[ov]:
                        arr_push(ro, arr_get(ov, j))
                        j = j + 1
                bind_pat_target(e, restv, tgt_env, is_const, env)
                return
            if n_str[e] >= 0 or n_b[e] >= 0:
                ev: int32 = index_get(val, v_number(cast[float64](idx)))
                if tag_of(ev) == TAG_UNDEF and n_a[e] >= 0:
                    ev = eval_expr(n_a[e], env)
                bind_pat_target(e, ev, tgt_env, is_const, env)
            idx = idx + 1
            e = n_next[e]
    elif pkind == ND_OBJPAT:
        e2: int32 = n_a[pat]
        while e2 >= 0:
            if n_op[e2] == 1:          # object rest: remaining own props
                resto: int32 = v_new_object()
                if tag_of(val) == TAG_OBJ:
                    obj_rest_rec(pat, obj_head[objid_of(val)], objid_of(resto))
                if n_c[e2] >= 0:
                    env_define(tgt_env, n_c[e2], resto, is_const)
            elif n_str[e2] >= 0:
                pv: int32 = member_get(val, n_str[e2])
                if tag_of(pv) == TAG_UNDEF and n_a[e2] >= 0:
                    pv = eval_expr(n_a[e2], env)
                bind_pat_target(e2, pv, tgt_env, is_const, env)
            e2 = n_next[e2]


def objpat_has_key(pat: int32, key_sid: int32) -> int32:
    e: int32 = n_a[pat]
    while e >= 0:
        if n_op[e] == 0 and n_str[e] >= 0 and str_eq(n_str[e], key_sid) != 0:
            return 1
        e = n_next[e]
    return 0


def obj_rest_rec(pat: int32, p: int32, resto: int32):
    if p < 0:
        return
    obj_rest_rec(pat, p_next[p], resto)
    if objpat_has_key(pat, p_key[p]) == 0:
        obj_set(resto, p_key[p], p_val[p])


def bind_pat_target(e: int32, v: int32, tgt_env: int32, is_const: int32, env: int32):
    if n_b[e] >= 0:                    # nested pattern
        bind_pattern(n_b[e], v, tgt_env, is_const, env)
    elif n_c[e] >= 0:                  # object element: bind to target name
        env_define(tgt_env, n_c[e], v, is_const)
    elif n_str[e] >= 0:                # array element: bind to name
        env_define(tgt_env, n_str[e], v, is_const)


def env_copy_locals(src: int32, dst: int32):
    b: int32 = env_head[src]
    while b >= 0:
        env_define(dst, b_name[b], b_val[b], 0)
        b = b_next[b]


def exec_switch(node: int32, env: int32):
    pending_label = -1
    disc: int32 = eval_expr(n_a[node], env)
    swenv: int32 = env_new(env, 0)
    # first pass: find the matching case (strict-equality, per spec)
    start: int32 = -1
    cs: int32 = n_b[node]
    while cs >= 0:
        if n_a[cs] >= 0:
            tv: int32 = eval_expr(n_a[cs], swenv)
            if strict_eq(disc, tv) != 0:
                start = cs
                cs = -1
        if cs >= 0:
            cs = n_next[cs]
    # no case matched -> jump to `default:` if present
    if start < 0:
        cs = n_b[node]
        while cs >= 0:
            if n_a[cs] < 0:
                start = cs
                cs = -1
            else:
                cs = n_next[cs]
    # execute from the entry clause, falling through subsequent clauses
    cur: int32 = start
    while cur >= 0 and ctl == CTL_NONE:
        st: int32 = n_b[cur]
        while st >= 0 and ctl == CTL_NONE:
            exec_stmt(st, swenv)
            st = n_next[st]
        cur = n_next[cur]
    # an unlabeled `break` terminates the switch (and is consumed here)
    if ctl == CTL_BREAK and ctl_label < 0:
        ctl = CTL_NONE


def exec_for(node: int32, env: int32):
    flbl: int32 = pending_label
    pending_label = -1
    loopenv: int32 = env_new(env, 0)
    init: int32 = n_a[node]
    is_let: int32 = 0
    if init >= 0:
        if cast[int32](n_kind[init]) == ND_VAR:
            exec_var(init, loopenv)
            if n_op[init] != 0:            # let / const -> per-iteration binding
                is_let = 1
        else:
            exec_stmt(init, loopenv)
    while ctl == CTL_NONE:
        curenv: int32 = loopenv
        if is_let != 0:
            curenv = env_new(env, 0)
            env_copy_locals(loopenv, curenv)
        if n_b[node] >= 0:
            if to_bool(eval_expr(n_b[node], curenv)) == 0:
                break
        exec_stmt(n_d[node], curenv)
        if ctl == CTL_BREAK:
            if ctl_label < 0 or label_eq(ctl_label, flbl) != 0:
                ctl = CTL_NONE
                ctl_label = -1
            break
        if ctl == CTL_CONTINUE:
            if ctl_label < 0 or label_eq(ctl_label, flbl) != 0:
                ctl = CTL_NONE
                ctl_label = -1
            else:
                break
        if n_c[node] >= 0:
            eval_expr(n_c[node], curenv)
        if is_let != 0:
            env_copy_locals(curenv, loopenv)


forin_lbl: int32 = -1


def exec_forin(node: int32, env: int32):
    forin_lbl = pending_label
    pending_label = -1
    objv: int32 = eval_expr(n_b[node], env)
    loopenv: int32 = env_new(env, 0)
    # determine target binding name
    name: int32 = -1
    target_decl: int32 = n_a[node]
    if cast[int32](n_kind[target_decl]) == ND_VAR:
        d: int32 = n_a[target_decl]
        name = n_str[d]
        env_define(loopenv, name, v_undef(), 0)
    else:
        # expr-stmt wrapping an ident
        inner: int32 = n_a[target_decl]
        if cast[int32](n_kind[inner]) == ND_IDENT:
            name = n_str[inner]
    if tag_of(objv) == TAG_OBJ:
        o: int32 = objid_of(objv)
        if cast[int32](obj_kind[o]) == OK_ARRAY:
            i: int32 = 0
            while i < arr_len[o] and ctl == CTL_NONE:
                keyv: int32 = v_string_id(num_to_strid(cast[float64](i)))
                forin_bind(name, keyv, loopenv, env)
                exec_stmt(n_c[node], loopenv)
                forin_after()
                i = i + 1
        else:
            # iterate props in insertion order (reverse the newest-first chain)
            forin_props(obj_head[o], name, node, loopenv, env)
    elif tag_of(objv) == TAG_STR:
        sid: int32 = strid_of(objv)
        i2: int32 = 0
        while i2 < str_len(sid) and ctl == CTL_NONE:
            keyv2: int32 = v_string_id(num_to_strid(cast[float64](i2)))
            forin_bind(name, keyv2, loopenv, env)
            exec_stmt(n_c[node], loopenv)
            forin_after()
            i2 = i2 + 1
    # consume a break targeting this for-in (a foreign-label break propagates)
    if ctl == CTL_BREAK and (ctl_label < 0 or label_eq(ctl_label, forin_lbl) != 0):
        ctl = CTL_NONE
        ctl_label = -1


def forin_props(p: int32, name: int32, node: int32, loopenv: int32, env: int32):
    if p < 0:
        return
    forin_props(p_next[p], name, node, loopenv, env)
    if ctl != CTL_NONE:
        return
    keyv: int32 = v_string_id(p_key[p])
    forin_bind(name, keyv, loopenv, env)
    exec_stmt(n_c[node], loopenv)
    forin_after()


def forin_bind(name: int32, keyv: int32, loopenv: int32, env: int32):
    if name >= 0:
        b: int32 = env_lookup_bind(loopenv, name)
        if b >= 0:
            b_val[b] = keyv
        else:
            env_define(loopenv, name, keyv, 0)


def forin_after():
    # A break (any label) leaves ctl set so the while/recursion guards stop the
    # loop; exec_forin consumes a break targeting THIS loop after iteration. A
    # matching (unlabeled or same-label) continue is consumed here so iteration
    # proceeds; a foreign-label continue propagates outward (guards stop us).
    if ctl == CTL_CONTINUE:
        if ctl_label < 0 or label_eq(ctl_label, forin_lbl) != 0:
            ctl = CTL_NONE
            ctl_label = -1


forof_lbl: int32 = -1


# bind one produced value to the for-of target (decl name, decl pattern, or lvalue expr)
def forof_bind(target_decl: int32, valv: int32, loopenv: int32, env: int32):
    tk: int32 = cast[int32](n_kind[target_decl])
    if tk == ND_VAR:
        d: int32 = n_a[target_decl]
        is_const: int32 = 0
        if n_op[target_decl] == 2:
            is_const = 1
        if n_b[d] >= 0:                # destructuring pattern target
            bind_pattern(n_b[d], valv, loopenv, is_const, env)
        else:
            b: int32 = env_lookup_bind(loopenv, n_str[d])
            if b >= 0:
                b_val[b] = valv
            else:
                env_define(loopenv, n_str[d], valv, is_const)
    else:
        # expr-stmt wrapping an lvalue (ident / member / index / pattern)
        inner: int32 = n_a[target_decl]
        assign_to(inner, valv, env)


# Returns 1 if the enclosing for-of loop must STOP (any break, or a continue
# targeting an outer label), 0 if it should proceed to the next element.
def forof_after() -> int32:
    if ctl == CTL_BREAK:
        if ctl_label < 0 or label_eq(ctl_label, forof_lbl) != 0:
            ctl = CTL_NONE
            ctl_label = -1
        return 1
    if ctl == CTL_CONTINUE:
        if ctl_label < 0 or label_eq(ctl_label, forof_lbl) != 0:
            ctl = CTL_NONE
            ctl_label = -1
            return 0
        return 1
    return 0


def exec_forof(node: int32, env: int32):
    forof_lbl = pending_label
    pending_label = -1
    iterv: int32 = eval_expr(n_b[node], env)
    if err_flag != 0 or ctl == CTL_THROW:
        return
    target_decl: int32 = n_a[node]
    if is_array(iterv) != 0:
        o: int32 = objid_of(iterv)
        i: int32 = 0
        while i < arr_len[o] and ctl == CTL_NONE:
            ienv: int32 = env_new(env, 0)
            forof_bind(target_decl, arr_get(o, i), ienv, env)
            exec_stmt(n_c[node], ienv)
            if forof_after() != 0:
                break
            i = i + 1
        return
    if tag_of(iterv) == TAG_STR:
        sid: int32 = strid_of(iterv)
        j: int32 = 0
        while j < str_len(sid) and ctl == CTL_NONE:
            ch: int32 = v_string_bytes(&sp_buf[st_off[sid] + j], 1)
            senv: int32 = env_new(env, 0)
            forof_bind(target_decl, ch, senv, env)
            exec_stmt(n_c[node], senv)
            if forof_after() != 0:
                break
            j = j + 1
        return
    if tag_of(iterv) == TAG_OBJ:
        oo: int32 = objid_of(iterv)
        mk: int32 = cast[int32](obj_map_kind[oo])
        if mk == MAP_KIND_MAP or mk == MAP_KIND_SET:
            e: int32 = obj_ms_head[oo]
            while e >= 0 and ctl == CTL_NONE:
                if mse_used[e] != 0:
                    itemv: int32 = v_undef()
                    if mk == MAP_KIND_SET:
                        itemv = mse_key[e]
                    else:
                        # Map yields fresh [key, value] pair arrays
                        pairv: int32 = v_new_array()
                        po: int32 = objid_of(pairv)
                        arr_push(po, mse_key[e])
                        arr_push(po, mse_val[e])
                        itemv = pairv
                    menv: int32 = env_new(env, 0)
                    forof_bind(target_decl, itemv, menv, env)
                    exec_stmt(n_c[node], menv)
                    if forof_after() != 0:
                        return
                e = mse_next[e]
            return
    throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("value is not iterable"))


# hoist var declarations (to function scope) and function declarations
def hoist_scan(block: int32, env: int32):
    if block < 0:
        return
    if cast[int32](n_kind[block]) != ND_BLOCK:
        return
    s: int32 = n_a[block]
    while s >= 0:
        hoist_stmt(s, env)
        s = n_next[s]


def hoist_stmt(s: int32, env: int32):
    k: int32 = cast[int32](n_kind[s])
    if k == ND_VAR:
        if n_op[s] == 0:               # var
            d: int32 = n_a[s]
            while d >= 0:
                if env_find_local(env, n_str[d]) < 0:
                    env_define(env, n_str[d], v_undef(), 0)
                d = n_next[d]
    elif k == ND_FUNCDECL:
        fv: int32 = v_new_closure(n_a[s], env)
        env_define(env, n_str[s], fv, 0)
    elif k == ND_IF:
        hoist_stmt_child(n_b[s], env)
        hoist_stmt_child(n_c[s], env)
    elif k == ND_WHILE or k == ND_DOWHILE:
        hoist_stmt_child(n_b[s], env)
    elif k == ND_FOR:
        hoist_stmt_child(n_a[s], env)
        hoist_stmt_child(n_d[s], env)
    elif k == ND_FORIN:
        hoist_stmt_child(n_c[s], env)
    elif k == ND_BLOCK:
        s2: int32 = n_a[s]
        while s2 >= 0:
            hoist_stmt(s2, env)
            s2 = n_next[s2]


def hoist_stmt_child(s: int32, env: int32):
    if s < 0:
        return
    hoist_stmt(s, env)


# function declarations only (for block-level hoisting)
def hoist_funcs_only(s: int32, env: int32):
    while s >= 0:
        if cast[int32](n_kind[s]) == ND_FUNCDECL:
            fv: int32 = v_new_closure(n_a[s], env)
            env_define(env, n_str[s], fv, 0)
        s = n_next[s]

from lib.web.js.builtins.strings import *
from lib.web.js.builtins.timers import *
from lib.web.js.builtins.date import *
from lib.web.js.builtins.promise import *
from lib.web.js.builtins.fetch import *
from lib.web.js.builtins.native import *
from lib.web.js.builtins.collections import *
# ====================================================================
# SETUP — build the global environment + builtin objects.
# ====================================================================
# ====================================================================
# REGULAR EXPRESSIONS
#   source -> recursive-descent parse -> regex AST -> backtracking bytecode
#   -> a recursive backtracking VM (correct over fast; supports backrefs).
# Supported: literals, `.`, classes [a-z]/[^..], anchors ^ $ (m), quantifiers
# * + ? {n} {n,} {n,m} (greedy + lazy `?`), groups ( ) capture + (?:..),
# alternation |, backrefs \1..\9, escapes \d \w \s \b and negations, flags g i m.
# lookahead (?=)(?!), lookbehind (?<=)(?<!), named groups (?<name>..) with .groups
# and \k<name> backrefs. Deferred (would balloon the diff): sticky `y`, `s` dotAll.
# ====================================================================

def re_fold(c: uint8) -> uint8:
    if c >= 65 and c <= 90:
        return c + 32
    return c


def re_is_word_byte(c: uint8) -> int32:
    if c >= 97 and c <= 122:
        return 1
    if c >= 65 and c <= 90:
        return 1
    if c >= 48 and c <= 57:
        return 1
    if c == 95:
        return 1
    return 0


def re_is_digit_byte(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return 1
    return 0


def re_is_space_byte(c: uint8) -> int32:
    if c == 32 or c == 9 or c == 10 or c == 13 or c == 12 or c == 11:
        return 1
    return 0


# ---- program emit / AST alloc ----
def re_emit(op: int32, x: int32, y: int32) -> int32:
    pc: int32 = re_n
    re_op[pc] = op
    re_x[pc] = x
    re_y[pc] = y
    re_n = re_n + 1
    return pc


def rn_new(op: int32) -> int32:
    i: int32 = rn_n
    rn_op[i] = op
    rn_a[i] = -1
    rn_b[i] = -1
    rn_c[i] = -1
    rn_d[i] = -1
    rn_next[i] = -1
    rn_n = rn_n + 1
    return i


# ---- char classes ----
def cls_new(negate: int32) -> int32:
    idx: int32 = n_cls
    i: int32 = 0
    while i < 32:
        cls_bits[idx * 32 + i] = 0
        i = i + 1
    cls_neg[idx] = cast[uint8](negate)
    n_cls = n_cls + 1
    return idx


def cls_add_raw(idx: int32, ch: int32):
    if ch < 0 or ch > 255:
        return
    cls_bits[idx * 32 + (ch >> 3)] = cls_bits[idx * 32 + (ch >> 3)] | cast[uint8](1 << (ch & 7))


def cls_add(idx: int32, ch: int32):
    cls_add_raw(idx, ch)
    if re_ic != 0:
        if ch >= 65 and ch <= 90:
            cls_add_raw(idx, ch + 32)
        elif ch >= 97 and ch <= 122:
            cls_add_raw(idx, ch - 32)


def cls_add_range(idx: int32, lo: int32, hi: int32):
    c: int32 = lo
    while c <= hi:
        cls_add(idx, c)
        c = c + 1


# which: 0=digit 1=word 2=space ; negate adds the complement set instead.
def cls_add_set(idx: int32, which: int32, negate: int32):
    c: int32 = 0
    while c < 256:
        inset: int32 = 0
        if which == 0:
            inset = re_is_digit_byte(cast[uint8](c))
        elif which == 1:
            inset = re_is_word_byte(cast[uint8](c))
        else:
            inset = re_is_space_byte(cast[uint8](c))
        if negate != 0:
            if inset == 0:
                cls_add_raw(idx, c)
        else:
            if inset != 0:
                cls_add_raw(idx, c)
        c = c + 1


def cls_test(idx: int32, ch: uint8) -> int32:
    c: int32 = cast[int32](ch)
    bit: int32 = cast[int32](cls_bits[idx * 32 + (c >> 3)] >> (c & 7)) & 1
    return bit


# ---- source cursor ----
def rc_at(i: int32) -> uint8:
    if i >= rc_len:
        return 0
    return sp_buf[rc_off + i]


def rc_peek() -> uint8:
    return rc_at(rc_i)


def rc_peek1() -> uint8:
    return rc_at(rc_i + 1)


# ---- regex parser (returns AST node id) ----
def re_parse_alt() -> int32:
    first: int32 = re_parse_seq()
    if rc_peek() != 124:                     # not '|'
        return first
    alt: int32 = rn_new(RN_ALT)
    rn_a[alt] = first
    tail: int32 = first
    while rc_peek() == 124:
        rc_i = rc_i + 1                       # consume '|'
        nb: int32 = re_parse_seq()
        rn_next[tail] = nb
        tail = nb
    return alt


def re_parse_seq() -> int32:
    seq: int32 = rn_new(RN_SEQ)
    head: int32 = -1
    tail: int32 = -1
    while rc_i < rc_len:
        c: uint8 = rc_peek()
        if c == 124 or c == 41:              # '|' or ')'
            break
        item: int32 = re_parse_repeat()
        if item < 0:
            break
        if head < 0:
            head = item
            tail = item
        else:
            rn_next[tail] = item
            tail = item
    rn_a[seq] = head
    return seq


def re_parse_repeat() -> int32:
    atom: int32 = re_parse_atom()
    if atom < 0:
        return atom
    c: uint8 = rc_peek()
    q: int32 = -1
    if c == 42:                              # *
        q = rn_new(RN_STAR)
        rc_i = rc_i + 1
    elif c == 43:                            # +
        q = rn_new(RN_PLUS)
        rc_i = rc_i + 1
    elif c == 63:                            # ?
        q = rn_new(RN_QUEST)
        rc_i = rc_i + 1
    elif c == 123:                           # { — maybe a bounded quantifier
        q = re_parse_brace(atom)
        if q < 0:
            return atom                      # `{` was a literal (handled as char by atom? no)
    else:
        return atom
    if q < 0:
        return atom
    rn_d[q] = atom
    # greedy unless followed by '?'
    greedy: int32 = 1
    if rc_peek() == 63:
        greedy = 0
        rc_i = rc_i + 1
    if rn_op[q] == RN_REPEAT:
        rn_a[q] = greedy
    else:
        rn_b[q] = greedy
    return q


# Try to parse {n} {n,} {n,m} starting at rc_i (a '{'). Returns an RN_REPEAT
# node (child unset) on success (consuming through '}'), or -1 without consuming.
def re_parse_brace(atom: int32) -> int32:
    j: int32 = rc_i + 1
    if is_digit(rc_at(j)) == 0:
        return -1
    lo: int32 = 0
    while is_digit(rc_at(j)) != 0:
        lo = lo * 10 + (cast[int32](rc_at(j)) - 48)
        j = j + 1
    hi: int32 = lo
    if rc_at(j) == 44:                       # ','
        j = j + 1
        if rc_at(j) == 125:                  # {n,}
            hi = -1
        else:
            if is_digit(rc_at(j)) == 0:
                return -1
            hi = 0
            while is_digit(rc_at(j)) != 0:
                hi = hi * 10 + (cast[int32](rc_at(j)) - 48)
                j = j + 1
    if rc_at(j) != 125:                      # need closing '}'
        return -1
    rc_i = j + 1                             # consume through '}'
    rep: int32 = rn_new(RN_REPEAT)
    rn_b[rep] = lo
    rn_c[rep] = hi
    return rep


def re_parse_atom() -> int32:
    c: uint8 = rc_peek()
    if c == 40:                              # (
        rc_i = rc_i + 1
        capidx: int32 = -1
        look: int32 = 0                      # 0 none, 1 lookahead, 2 lookbehind
        lookneg: int32 = 0
        if rc_peek() == 63:                  # (?  — group modifier
            n1: uint8 = rc_peek1()
            if n1 == 58:                     # (?:  non-capturing
                rc_i = rc_i + 2
            elif n1 == 61:                   # (?=  positive lookahead
                rc_i = rc_i + 2
                look = 1
            elif n1 == 33:                   # (?!  negative lookahead
                rc_i = rc_i + 2
                look = 1
                lookneg = 1
            elif n1 == 60:                   # (?<  lookbehind or named group
                n2: uint8 = rc_at(rc_i + 2)
                if n2 == 61:                 # (?<=  positive lookbehind
                    rc_i = rc_i + 3
                    look = 2
                elif n2 == 33:               # (?<!  negative lookbehind
                    rc_i = rc_i + 3
                    look = 2
                    lookneg = 1
                else:                        # (?<name>  named capture group
                    rc_i = rc_i + 2          # past '(?<'
                    nst: int32 = gname_buf_n
                    while rc_peek() != 62 and rc_peek() != 0:
                        if gname_buf_n < 8191:
                            gname_buf[gname_buf_n] = rc_peek()
                            gname_buf_n = gname_buf_n + 1
                        rc_i = rc_i + 1
                    if rc_peek() == 62:      # '>'
                        rc_i = rc_i + 1
                    re_gcount = re_gcount + 1
                    capidx = re_gcount
                    if gname_n < RE_GNAME_CAP:
                        gname_idx[gname_n] = capidx
                        gname_soff[gname_n] = nst
                        gname_slen[gname_n] = gname_buf_n - nst
                        gname_n = gname_n + 1
            else:                            # unknown (?X — treat as non-capturing
                rc_i = rc_i + 2
        else:
            re_gcount = re_gcount + 1
            capidx = re_gcount
        child: int32 = re_parse_alt()
        if rc_peek() == 41:                  # )
            rc_i = rc_i + 1
        if look != 0:
            lk: int32 = rn_new(RN_LOOK)
            if look == 2:
                rn_op[lk] = RN_LOOKB
            rn_a[lk] = lookneg
            rn_d[lk] = child
            return lk
        g: int32 = rn_new(RN_GROUP)
        rn_a[g] = capidx
        rn_d[g] = child
        return g
    if c == 91:                              # [
        return re_parse_class()
    if c == 46:                              # .
        rc_i = rc_i + 1
        return rn_new(RN_ANY)
    if c == 94:                              # ^
        rc_i = rc_i + 1
        return rn_new(RN_BOL)
    if c == 36:                              # $
        rc_i = rc_i + 1
        return rn_new(RN_EOL)
    if c == 92:                              # backslash
        return re_parse_escape()
    if c == 41 or c == 124 or c == 0:        # ) | end — empty atom
        return -1
    # ordinary literal char
    rc_i = rc_i + 1
    ch: int32 = rn_new(RN_CHAR)
    rn_a[ch] = cast[int32](c)
    return ch


# Resolve a `\k<name>` reference: compare the source name span [soff,soff+slen)
# against the named groups recorded for THIS compile. Returns the capture index,
# or -1 if the name is unknown.
def re_lookup_gname_src(soff: int32, slen: int32) -> int32:
    r: int32 = gname_compile_start
    while r < gname_n:
        if gname_slen[r] == slen:
            k: int32 = 0
            same: int32 = 1
            while k < slen:
                if gname_buf[gname_soff[r] + k] != rc_at(soff + k):
                    same = 0
                    break
                k = k + 1
            if same != 0:
                return gname_idx[r]
        r = r + 1
    return -1


def re_parse_escape() -> int32:
    rc_i = rc_i + 1                          # skip backslash
    e: uint8 = rc_peek()
    rc_i = rc_i + 1
    if e == 107 and rc_peek() == 60:         # \k<name>  named backreference
        rc_i = rc_i + 1                      # past '<'
        nsoff: int32 = rc_i
        while rc_peek() != 62 and rc_peek() != 0:
            rc_i = rc_i + 1
        nslen: int32 = rc_i - nsoff
        if rc_peek() == 62:                  # '>'
            rc_i = rc_i + 1
        ki: int32 = re_lookup_gname_src(nsoff, nslen)
        if ki < 0:                           # unknown name: match empty (lenient)
            eg: int32 = rn_new(RN_GROUP)
            rn_a[eg] = -1
            rn_d[eg] = -1
            return eg
        kbr: int32 = rn_new(RN_BACKREF)
        rn_a[kbr] = ki
        return kbr
    # predefined sets
    if e == 100:                             # \d
        cn: int32 = cls_new(0)
        cls_add_set(cn, 0, 0)
        return re_class_node(cn)
    if e == 68:                              # \D
        cn2: int32 = cls_new(0)
        cls_add_set(cn2, 0, 1)
        return re_class_node(cn2)
    if e == 119:                             # \w
        cn3: int32 = cls_new(0)
        cls_add_set(cn3, 1, 0)
        return re_class_node(cn3)
    if e == 87:                              # \W
        cn4: int32 = cls_new(0)
        cls_add_set(cn4, 1, 1)
        return re_class_node(cn4)
    if e == 115:                             # \s
        cn5: int32 = cls_new(0)
        cls_add_set(cn5, 2, 0)
        return re_class_node(cn5)
    if e == 83:                              # \S
        cn6: int32 = cls_new(0)
        cls_add_set(cn6, 2, 1)
        return re_class_node(cn6)
    if e == 98:                              # \b
        return rn_new(RN_WORDB)
    if e == 66:                              # \B
        return rn_new(RN_NWORDB)
    if e >= 49 and e <= 57:                  # \1..\9 backreference
        gi: int32 = cast[int32](e) - 48
        br: int32 = rn_new(RN_BACKREF)
        rn_a[br] = gi
        return br
    # single-char escapes
    lit: int32 = re_escape_char(e)
    ch2: int32 = rn_new(RN_CHAR)
    rn_a[ch2] = lit
    return ch2


def re_escape_char(e: uint8) -> int32:
    if e == 110:
        return 10                            # \n
    if e == 116:
        return 9                             # \t
    if e == 114:
        return 13                            # \r
    if e == 102:
        return 12                            # \f
    if e == 118:
        return 11                            # \v
    if e == 48:
        return 0                             # \0
    if e == 120:                             # \xHH
        h1: int32 = hexval(rc_peek())
        h2: int32 = hexval(rc_peek1())
        if h1 >= 0 and h2 >= 0:
            rc_i = rc_i + 2
            return h1 * 16 + h2
        return 120
    if e == 117:                             # \uHHHH -> low byte (byte engine)
        u1: int32 = hexval(rc_at(rc_i))
        u2: int32 = hexval(rc_at(rc_i + 1))
        u3: int32 = hexval(rc_at(rc_i + 2))
        u4: int32 = hexval(rc_at(rc_i + 3))
        if u1 >= 0 and u2 >= 0 and u3 >= 0 and u4 >= 0:
            rc_i = rc_i + 4
            return (u3 * 16 + u4)
        return 117
    return cast[int32](e)                    # \. \/ \\ \* ... literal


def hexval(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return cast[int32](c) - 48
    if c >= 97 and c <= 102:
        return cast[int32](c) - 87
    if c >= 65 and c <= 70:
        return cast[int32](c) - 55
    return -1


def re_class_node(clsidx: int32) -> int32:
    n: int32 = rn_new(RN_CLASS)
    rn_a[n] = clsidx
    return n


def re_parse_class() -> int32:
    rc_i = rc_i + 1                          # skip [
    neg: int32 = 0
    if rc_peek() == 94:                      # ^
        neg = 1
        rc_i = rc_i + 1
    idx: int32 = cls_new(neg)
    while rc_i < rc_len and rc_peek() != 93:  # until ]
        lo: int32 = re_class_item(idx)
        if lo < 0:
            continue                          # a set (\d etc) was folded in
        # range?
        if rc_peek() == 45 and rc_peek1() != 93 and rc_peek1() != 0:
            rc_i = rc_i + 1                    # consume '-'
            hi: int32 = re_class_item(idx)
            if hi < 0:
                cls_add(idx, 45)              # stray set after '-': treat '-' literal
            else:
                cls_add_range(idx, lo, hi)
        else:
            cls_add(idx, lo)
    if rc_peek() == 93:
        rc_i = rc_i + 1                       # skip ]
    return re_class_node(idx)


# Parse one class item; returns its char code, or -1 if it was a predefined
# set escape (\d \w \s + negations) already merged into the class bitmap.
def re_class_item(idx: int32) -> int32:
    c: uint8 = rc_peek()
    if c == 92:                              # escape
        rc_i = rc_i + 1
        e: uint8 = rc_peek()
        rc_i = rc_i + 1
        if e == 100:
            cls_add_set(idx, 0, 0)
            return -1
        if e == 68:
            cls_add_set(idx, 0, 1)
            return -1
        if e == 119:
            cls_add_set(idx, 1, 0)
            return -1
        if e == 87:
            cls_add_set(idx, 1, 1)
            return -1
        if e == 115:
            cls_add_set(idx, 2, 0)
            return -1
        if e == 83:
            cls_add_set(idx, 2, 1)
            return -1
        if e == 98:                          # \b inside class = backspace (8)
            return 8
        return re_escape_char(e)
    rc_i = rc_i + 1
    return cast[int32](c)


# ---- compile AST -> program ----
def re_compile(node: int32):
    if node < 0:
        return
    op: int32 = rn_op[node]
    if op == RN_SEQ:
        it: int32 = rn_a[node]
        while it >= 0:
            re_compile(it)
            it = rn_next[it]
        return
    if op == RN_CHAR:
        re_emit(RI_CHAR, rn_a[node], 0)
        return
    if op == RN_ANY:
        re_emit(RI_ANY, 0, 0)
        return
    if op == RN_CLASS:
        re_emit(RI_CLASS, rn_a[node], 0)
        return
    if op == RN_BOL:
        re_emit(RI_BOL, 0, 0)
        return
    if op == RN_EOL:
        re_emit(RI_EOL, 0, 0)
        return
    if op == RN_WORDB:
        re_emit(RI_WORDB, 0, 0)
        return
    if op == RN_NWORDB:
        re_emit(RI_NWORDB, 0, 0)
        return
    if op == RN_BACKREF:
        re_emit(RI_BACKREF, rn_a[node], 0)
        return
    if op == RN_GROUP:
        if rn_a[node] >= 0:
            re_emit(RI_SAVE, 2 * rn_a[node], 0)
            re_compile(rn_d[node])
            re_emit(RI_SAVE, 2 * rn_a[node] + 1, 0)
        else:
            re_compile(rn_d[node])
        return
    if op == RN_ALT:
        re_compile_alt(rn_a[node])
        return
    if op == RN_LOOK:
        la: int32 = re_emit(RI_LAHEAD, 0, rn_a[node])
        re_compile(rn_d[node])
        re_emit(RI_LADONE, 0, 0)
        re_x[la] = re_n
        return
    if op == RN_LOOKB:
        lb: int32 = re_emit(RI_LBEHIND, 0, rn_a[node])
        re_compile(rn_d[node])
        re_emit(RI_LBDONE, 0, 0)
        re_x[lb] = re_n
        return
    if op == RN_STAR:
        re_emit_star(rn_d[node], rn_b[node])
        return
    if op == RN_PLUS:
        re_emit_plus(rn_d[node], rn_b[node])
        return
    if op == RN_QUEST:
        re_emit_opt(rn_d[node], 1, rn_b[node])
        return
    if op == RN_REPEAT:
        lo: int32 = rn_b[node]
        hi: int32 = rn_c[node]
        greedy: int32 = rn_a[node]
        i: int32 = 0
        while i < lo:
            re_compile(rn_d[node])
            i = i + 1
        if hi < 0:
            re_emit_star(rn_d[node], greedy)
        else:
            re_emit_opt(rn_d[node], hi - lo, greedy)
        return


def re_compile_alt(branch: int32):
    nxt: int32 = rn_next[branch]
    if nxt < 0:
        re_compile(branch)
        return
    s: int32 = re_emit(RI_SPLIT, 0, 0)
    bstart: int32 = re_n
    re_compile(branch)
    j: int32 = re_emit(RI_JMP, 0, 0)
    reststart: int32 = re_n
    re_compile_alt(nxt)
    endp: int32 = re_n
    re_x[s] = bstart
    re_y[s] = reststart
    re_x[j] = endp


def re_emit_star(child: int32, greedy: int32):
    s: int32 = re_emit(RI_SPLIT, 0, 0)
    cstart: int32 = re_n
    re_compile(child)
    re_emit(RI_JMP, s, 0)
    endp: int32 = re_n
    if greedy != 0:
        re_x[s] = cstart
        re_y[s] = endp
    else:
        re_x[s] = endp
        re_y[s] = cstart


def re_emit_plus(child: int32, greedy: int32):
    cstart: int32 = re_n
    re_compile(child)
    s: int32 = re_emit(RI_SPLIT, 0, 0)
    endp: int32 = re_n
    if greedy != 0:
        re_x[s] = cstart
        re_y[s] = endp
    else:
        re_x[s] = endp
        re_y[s] = cstart


# emit `child{0,count}` (bounded optional) as right-nested SPLITs
def re_emit_opt(child: int32, count: int32, greedy: int32):
    if count <= 0:
        return
    s: int32 = re_emit(RI_SPLIT, 0, 0)
    cstart: int32 = re_n
    re_compile(child)
    re_emit_opt(child, count - 1, greedy)
    endp: int32 = re_n
    if greedy != 0:
        re_x[s] = cstart
        re_y[s] = endp
    else:
        re_x[s] = endp
        re_y[s] = cstart


# ---- matcher (backtracking VM) ----
def re_eqc(a: uint8, b: uint8) -> int32:
    if a == b:
        return 1
    if re_ic != 0:
        if re_fold(a) == re_fold(b):
            return 1
    return 0


def re_inclass(idx: int32, ch: uint8) -> int32:
    hit: int32 = cls_test(idx, ch)
    if cast[int32](cls_neg[idx]) != 0:
        if hit != 0:
            return 0
        return 1
    return hit


def re_subj(sp: int32) -> uint8:
    return sp_buf[rx_off + sp]


def re_is_bol(sp: int32) -> int32:
    if sp == 0:
        return 1
    if re_ml != 0 and re_subj(sp - 1) == 10:
        return 1
    return 0


def re_is_eol(sp: int32) -> int32:
    if sp == rx_len:
        return 1
    if re_ml != 0 and re_subj(sp) == 10:
        return 1
    return 0


def re_is_wordb(sp: int32) -> int32:
    left: int32 = 0
    right: int32 = 0
    if sp > 0 and re_is_word_byte(re_subj(sp - 1)) != 0:
        left = 1
    if sp < rx_len and re_is_word_byte(re_subj(sp)) != 0:
        right = 1
    if left != right:
        return 1
    return 0


def re_run(pc0: int32, sp0: int32) -> int32:
    pc: int32 = pc0
    sp: int32 = sp0
    while re_op[pc] >= 0:
        op: int32 = re_op[pc]
        if op == RI_CHAR:
            if sp < rx_len and re_eqc(re_subj(sp), cast[uint8](re_x[pc])) != 0:
                pc = pc + 1
                sp = sp + 1
                continue
            return 0
        elif op == RI_ANY:
            if sp < rx_len and re_subj(sp) != 10:
                pc = pc + 1
                sp = sp + 1
                continue
            return 0
        elif op == RI_CLASS:
            if sp < rx_len and re_inclass(re_x[pc], re_subj(sp)) != 0:
                pc = pc + 1
                sp = sp + 1
                continue
            return 0
        elif op == RI_MATCH:
            rx_matchend = sp
            return 1
        elif op == RI_JMP:
            pc = re_x[pc]
            continue
        elif op == RI_SPLIT:
            if re_run(re_x[pc], sp) != 0:
                return 1
            pc = re_y[pc]
            continue
        elif op == RI_SAVE:
            slot: int32 = re_x[pc]
            old: int32 = re_cap[slot]
            re_cap[slot] = sp
            if re_run(pc + 1, sp) != 0:
                return 1
            re_cap[slot] = old
            return 0
        elif op == RI_BOL:
            if re_is_bol(sp) != 0:
                pc = pc + 1
                continue
            return 0
        elif op == RI_EOL:
            if re_is_eol(sp) != 0:
                pc = pc + 1
                continue
            return 0
        elif op == RI_WORDB:
            if re_is_wordb(sp) != 0:
                pc = pc + 1
                continue
            return 0
        elif op == RI_NWORDB:
            if re_is_wordb(sp) == 0:
                pc = pc + 1
                continue
            return 0
        elif op == RI_LAHEAD:
            # Zero-width: does the child block match starting at sp? The child
            # ends in RI_LADONE (returns 1). Positive succeeds on a match,
            # negative on no match; either way sp does not advance.
            m: int32 = re_run(pc + 1, sp)
            if re_y[pc] == 0:
                if m != 0:
                    pc = re_x[pc]
                    continue
                return 0
            if m == 0:
                pc = re_x[pc]
                continue
            return 0
        elif op == RI_LADONE:
            return 1
        elif op == RI_LBEHIND:
            # Zero-width: is there a start j <= sp such that the child matches
            # exactly [j, sp)? RI_LBDONE accepts only when the child ends at sp.
            saved_t: int32 = lb_target
            lb_target = sp
            found: int32 = 0
            j: int32 = sp
            while j >= 0:
                if re_run(pc + 1, j) != 0:
                    found = 1
                    break
                j = j - 1
            lb_target = saved_t
            if re_y[pc] == 0:
                if found != 0:
                    pc = re_x[pc]
                    continue
                return 0
            if found == 0:
                pc = re_x[pc]
                continue
            return 0
        elif op == RI_LBDONE:
            if sp == lb_target:
                return 1
            return 0
        elif op == RI_BACKREF:
            g: int32 = re_x[pc]
            s0: int32 = re_cap[2 * g]
            e0: int32 = re_cap[2 * g + 1]
            if s0 < 0 or e0 < 0:
                pc = pc + 1
                continue
            blen: int32 = e0 - s0
            if sp + blen > rx_len:
                return 0
            k: int32 = 0
            ok: int32 = 1
            while k < blen:
                if re_eqc(re_subj(sp + k), re_subj(s0 + k)) == 0:
                    ok = 0
                    break
                k = k + 1
            if ok == 0:
                return 0
            sp = sp + blen
            pc = pc + 1
            continue
        return 0
    return 0


# Search for a match at or after `startpos`; returns match-start index (>=0) with
# re_cap[] populated and rx_matchend set, or -1 if none.
def regex_search(prog_start: int32, ncap: int32, sid: int32, startpos: int32, ic: int32, ml: int32) -> int32:
    re_ic = ic
    re_ml = ml
    rx_off = st_off[sid]
    rx_len = str_len(sid)
    pos: int32 = startpos
    while pos <= rx_len:
        i: int32 = 0
        while i < 2 * (ncap + 1):
            re_cap[i] = -1
            i = i + 1
        if re_run(prog_start, pos) != 0:
            return pos
        pos = pos + 1
    return -1


# ---- construction ----
def js_make_regex(src_sid: int32, flags_sid: int32) -> int32:
    gflag: int32 = 0
    iflag: int32 = 0
    mflag: int32 = 0
    fn: int32 = str_len(flags_sid)
    fi: int32 = 0
    while fi < fn:
        fc: uint8 = str_char(flags_sid, fi)
        if fc == 103:
            gflag = 1
        elif fc == 105:
            iflag = 1
        elif fc == 109:
            mflag = 1
        fi = fi + 1
    re_ic = iflag
    re_ml = mflag
    rn_n = 0
    re_gcount = 0
    gname_compile_start = gname_n
    rc_off = st_off[src_sid]
    rc_len = str_len(src_sid)
    rc_i = 0
    root: int32 = re_parse_alt()
    prog_start: int32 = re_n
    re_emit(RI_SAVE, 0, 0)
    re_compile(root)
    re_emit(RI_SAVE, 1, 0)
    re_emit(RI_MATCH, 0, 0)
    rv: int32 = v_new_object()
    o: int32 = objid_of(rv)
    obj_re_prog[o] = prog_start
    obj_re_ncap[o] = re_gcount
    obj_re_gnstart[o] = gname_compile_start
    obj_re_gncount[o] = gname_n - gname_compile_start
    bits: int32 = 0
    if gflag != 0:
        bits = bits | 1
    if iflag != 0:
        bits = bits | 2
    if mflag != 0:
        bits = bits | 4
    obj_re_flags[o] = bits
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("source")), v_string_id(src_sid))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("flags")), v_string_id(flags_sid))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("global")), v_boolv(gflag))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("ignoreCase")), v_boolv(iflag))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("multiline")), v_boolv(mflag))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("lastIndex")), v_number(0.0))
    return rv


def is_regex(v: int32) -> int32:
    if tag_of(v) != TAG_OBJ:
        return 0
    if obj_re_prog[objid_of(v)] >= 0:
        return 1
    return 0


# Coerce a value into a RegExp (pass regexes through; strings/others compile).
def to_regex(v: int32) -> int32:
    if is_regex(v) != 0:
        return v
    sid: int32 = strid_of(to_string_val(v))
    return js_make_regex(sid, str_from_cstr(cast[Ptr[uint8]]("")))


# Build the exec()-style result array for the current re_cap[] over subject sid.
def regex_result_array(sid: int32, ncap: int32, start: int32, gnstart: int32, gncount: int32) -> int32:
    res: int32 = v_new_array()
    ao: int32 = objid_of(res)
    g: int32 = 0
    while g <= ncap:
        s0: int32 = re_cap[2 * g]
        e0: int32 = re_cap[2 * g + 1]
        if s0 < 0 or e0 < 0:
            arr_push(ao, v_undef())
        else:
            arr_push(ao, v_string_bytes(&sp_buf[st_off[sid] + s0], e0 - s0))
        g = g + 1
    obj_set(ao, str_from_cstr(cast[Ptr[uint8]]("index")), v_number(cast[float64](start)))
    obj_set(ao, str_from_cstr(cast[Ptr[uint8]]("input")), v_string_id(sid))
    # .groups — an object of {name: capture} for `(?<name>...)` groups, else
    # undefined (per spec).
    if gncount > 0:
        grp: int32 = v_new_object()
        go: int32 = objid_of(grp)
        gi: int32 = 0
        while gi < gncount:
            row: int32 = gnstart + gi
            ci: int32 = gname_idx[row]
            ks: int32 = strid_of(v_string_bytes(&gname_buf[gname_soff[row]], gname_slen[row]))
            cs0: int32 = re_cap[2 * ci]
            ce0: int32 = re_cap[2 * ci + 1]
            if cs0 < 0 or ce0 < 0:
                obj_set(go, ks, v_undef())
            else:
                obj_set(go, ks, v_string_bytes(&sp_buf[st_off[sid] + cs0], ce0 - cs0))
            gi = gi + 1
        obj_set(ao, str_from_cstr(cast[Ptr[uint8]]("groups")), grp)
    else:
        obj_set(ao, str_from_cstr(cast[Ptr[uint8]]("groups")), v_undef())
    return res


# re.exec(str): returns a match array (with .index/.input + capture groups) or
# null; advances/reads .lastIndex when the `g` flag is set.
def regex_exec(rev: int32, strv: int32) -> int32:
    o: int32 = objid_of(rev)
    sid: int32 = strid_of(to_string_val(strv))
    gflag: int32 = obj_re_flags[o] & 1
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    li: int32 = 0
    if gflag != 0:
        li = cast[int32](to_number(obj_get_cstr(o, cast[Ptr[uint8]]("lastIndex"))))
    if li < 0:
        li = 0
    if li > str_len(sid):
        obj_set(o, str_from_cstr(cast[Ptr[uint8]]("lastIndex")), v_number(0.0))
        return v_null()
    start: int32 = regex_search(obj_re_prog[o], obj_re_ncap[o], sid, li, ic, ml)
    if start < 0:
        if gflag != 0:
            obj_set(o, str_from_cstr(cast[Ptr[uint8]]("lastIndex")), v_number(0.0))
        return v_null()
    if gflag != 0:
        obj_set(o, str_from_cstr(cast[Ptr[uint8]]("lastIndex")), v_number(cast[float64](rx_matchend)))
    return regex_result_array(sid, obj_re_ncap[o], start, obj_re_gnstart[o], obj_re_gncount[o])


def regex_test(rev: int32, strv: int32) -> int32:
    r: int32 = regex_exec(rev, strv)
    if tag_of(r) == TAG_NULL:
        return v_false()
    return v_true()


# re.test / re.exec dispatch (called from eval_call on a regex receiver).
# Returns -2 if `name` is not a regex method.
def try_regex_method(rev: int32, name: int32, argnode: int32, env: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    if ctl == CTL_THROW:
        call_top = base
        return v_undef()
    r: int32 = -2
    if str_eq_cstr(name, cast[Ptr[uint8]]("test")) != 0:
        r = regex_test(rev, arg_or(base, argc, 0))
    elif str_eq_cstr(name, cast[Ptr[uint8]]("exec")) != 0:
        r = regex_exec(rev, arg_or(base, argc, 0))
    elif str_eq_cstr(name, cast[Ptr[uint8]]("toString")) != 0:
        r = to_string_val(rev)
    call_top = base
    return r


# ---- String.prototype regex methods (subject sid + a regex value) ----
# str.search(re): index of first match or -1 (ignores g/lastIndex).
def str_regex_search(sid: int32, rev: int32) -> int32:
    o: int32 = objid_of(rev)
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    return v_number(cast[float64](regex_search(obj_re_prog[o], obj_re_ncap[o], sid, 0, ic, ml)))


# str.match(re): non-global -> exec-style array or null; global -> array of all
# matched substrings (or null).
def str_regex_match(sid: int32, rev: int32) -> int32:
    o: int32 = objid_of(rev)
    gflag: int32 = obj_re_flags[o] & 1
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    if gflag == 0:
        strv: int32 = v_string_id(sid)
        return regex_exec(rev, strv)
    res: int32 = v_new_array()
    ao: int32 = objid_of(res)
    pos: int32 = 0
    n: int32 = str_len(sid)
    any: int32 = 0
    while pos <= n:
        start: int32 = regex_search(obj_re_prog[o], obj_re_ncap[o], sid, pos, ic, ml)
        if start < 0:
            break
        any = 1
        mend: int32 = rx_matchend
        arr_push(ao, v_string_bytes(&sp_buf[st_off[sid] + start], mend - start))
        if mend > start:
            pos = mend
        else:
            pos = mend + 1                   # zero-width: advance to avoid a loop
    if any == 0:
        return v_null()
    return res


# str.matchAll(re): array of exec-style match arrays (each with groups+index).
def str_regex_matchall(sid: int32, rev: int32) -> int32:
    o: int32 = objid_of(rev)
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    ncap: int32 = obj_re_ncap[o]
    res: int32 = v_new_array()
    ao: int32 = objid_of(res)
    pos: int32 = 0
    n: int32 = str_len(sid)
    while pos <= n:
        start: int32 = regex_search(obj_re_prog[o], ncap, sid, pos, ic, ml)
        if start < 0:
            break
        mend: int32 = rx_matchend
        arr_push(ao, regex_result_array(sid, ncap, start, obj_re_gnstart[o], obj_re_gncount[o]))
        if mend > start:
            pos = mend
        else:
            pos = mend + 1
    return res


# str.split(re[, limit]): split on regex separators; captured groups from the
# separator are spliced into the result (per spec).
def str_regex_split(sid: int32, rev: int32) -> int32:
    o: int32 = objid_of(rev)
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    ncap: int32 = obj_re_ncap[o]
    res: int32 = v_new_array()
    ao: int32 = objid_of(res)
    n: int32 = str_len(sid)
    if n == 0:
        return res                           # "".split(re) -> [] (unless re matches "")
    last: int32 = 0
    pos: int32 = 0
    while pos < n:
        start: int32 = regex_search(obj_re_prog[o], ncap, sid, pos, ic, ml)
        if start < 0:
            break
        mend: int32 = rx_matchend
        if mend == start:
            # zero-width separator: skip to keep progress
            if start >= n:
                break
            pos = start + 1
            continue
        arr_push(ao, v_string_bytes(&sp_buf[st_off[sid] + last], start - last))
        g: int32 = 1
        while g <= ncap:
            s0: int32 = re_cap[2 * g]
            e0: int32 = re_cap[2 * g + 1]
            if s0 < 0 or e0 < 0:
                arr_push(ao, v_undef())
            else:
                arr_push(ao, v_string_bytes(&sp_buf[st_off[sid] + s0], e0 - s0))
            g = g + 1
        last = mend
        pos = mend
    arr_push(ao, v_string_bytes(&sp_buf[st_off[sid] + last], n - last))
    return res


# str.replace(re, repl): repl is a string ($1/$&/$$/$`/$') or a function.
# Two-phase: resolve each replacement to a string id first (so a replacer
# function can safely build strings), then assemble the result in one pass.
def str_regex_replace(sid: int32, rev: int32, replv: int32) -> int32:
    o: int32 = objid_of(rev)
    gflag: int32 = obj_re_flags[o] & 1
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    ncap: int32 = obj_re_ncap[o]
    is_fn: int32 = is_callable(replv)
    n: int32 = str_len(sid)
    count: int32 = 0
    pos: int32 = 0
    # phase 1: find matches + resolve replacement string ids
    while pos <= n and count < MAX_REP:
        start: int32 = regex_search(obj_re_prog[o], ncap, sid, pos, ic, ml)
        if start < 0:
            break
        mend: int32 = rx_matchend
        rid0: int32 = 0
        if is_fn != 0:
            rid0 = re_fn_repl_id(sid, replv, start, mend, ncap)
        else:
            rid0 = re_str_repl_id(sid, replv, start, mend, ncap)
        rep_start[count] = start
        rep_end[count] = mend
        rep_id[count] = rid0
        count = count + 1
        if mend > start:
            pos = mend
        else:
            pos = mend + 1
        if gflag == 0:
            break
    # phase 2: assemble
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    last: int32 = 0
    i: int32 = 0
    while i < count:
        j: int32 = last
        while j < rep_start[i]:
            emit_c(str_char(sid, j))
            j = j + 1
        emit_strid(rep_id[i])
        last = rep_end[i]
        i = i + 1
    j2: int32 = last
    while j2 < n:
        emit_c(str_char(sid, j2))
        j2 = j2 + 1
    rid: int32 = bld_end()
    emit_tgt = save
    return v_string_id(rid)


# Build a string-replacement into a fresh string id (handles $&, $$, $1..$99,
# $`, $'). Self-contained; no user code runs, so the shared builder is safe.
def re_str_repl_id(sid: int32, replv: int32, start: int32, mend: int32, ncap: int32) -> int32:
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    rsid: int32 = strid_of(to_string_val(replv))
    rn: int32 = str_len(rsid)
    i: int32 = 0
    while i < rn:
        c: uint8 = str_char(rsid, i)
        if c == 36 and i + 1 < rn:           # '$'
            d: uint8 = str_char(rsid, i + 1)
            if d == 36:                      # $$ -> literal $
                emit_c(36)
                i = i + 2
                continue
            if d == 38:                      # $& whole match
                k: int32 = start
                while k < mend:
                    emit_c(str_char(sid, k))
                    k = k + 1
                i = i + 2
                continue
            if d == 96:                      # $` prefix
                k2: int32 = 0
                while k2 < start:
                    emit_c(str_char(sid, k2))
                    k2 = k2 + 1
                i = i + 2
                continue
            if d == 39:                      # $' suffix
                k3: int32 = mend
                slen: int32 = str_len(sid)
                while k3 < slen:
                    emit_c(str_char(sid, k3))
                    k3 = k3 + 1
                i = i + 2
                continue
            if d >= 48 and d <= 57:          # $n or $nn
                gi: int32 = cast[int32](d) - 48
                adv: int32 = 2
                if i + 2 < rn:
                    d2: uint8 = str_char(rsid, i + 2)
                    if d2 >= 48 and d2 <= 57:
                        gi2: int32 = gi * 10 + (cast[int32](d2) - 48)
                        if gi2 <= ncap:
                            gi = gi2
                            adv = 3
                if gi >= 1 and gi <= ncap:
                    s0: int32 = re_cap[2 * gi]
                    e0: int32 = re_cap[2 * gi + 1]
                    if s0 >= 0 and e0 >= 0:
                        kk: int32 = s0
                        while kk < e0:
                            emit_c(str_char(sid, kk))
                            kk = kk + 1
                    i = i + adv
                    continue
            emit_c(36)                       # unrecognized -> literal '$'
            i = i + 1
        else:
            emit_c(c)
            i = i + 1
    rid: int32 = bld_end()
    emit_tgt = save
    return rid


# Call a replacer function fn(match, p1.., offset, str); return its result's
# string id. Args are snapshotted from re_cap before invoking.
def re_fn_repl_id(sid: int32, fnv: int32, start: int32, mend: int32, ncap: int32) -> int32:
    base: int32 = call_top
    call_args[call_top] = v_string_bytes(&sp_buf[st_off[sid] + start], mend - start)
    call_top = call_top + 1
    g: int32 = 1
    while g <= ncap:
        s0: int32 = re_cap[2 * g]
        e0: int32 = re_cap[2 * g + 1]
        if s0 < 0 or e0 < 0:
            call_args[call_top] = v_undef()
        else:
            call_args[call_top] = v_string_bytes(&sp_buf[st_off[sid] + s0], e0 - s0)
        call_top = call_top + 1
        g = g + 1
    call_args[call_top] = v_number(cast[float64](start))
    call_top = call_top + 1
    call_args[call_top] = v_string_id(sid)
    call_top = call_top + 1
    argc: int32 = call_top - base
    rv: int32 = invoke(fnv, v_undef(), base, argc)
    call_top = base
    return strid_of(to_string_val(rv))


def def_global_native(name: Ptr[uint8], native_id: int32):
    env_define(g_env, str_from_cstr(name), v_new_native(native_id), 0)


def obj_add_native(objv: int32, name: Ptr[uint8], native_id: int32):
    obj_set(objid_of(objv), str_from_cstr(name), v_new_native(native_id))


def obj_add_num(objv: int32, name: Ptr[uint8], x: float64):
    obj_set(objid_of(objv), str_from_cstr(name), v_number(x))


# Create an Error-family constructor with a .prototype. Returns the ctor value.
# `super_ctor` is the base Error ctor value (-1 for Error itself) so subclass
# prototypes chain to Error.prototype.
def install_error(name: Ptr[uint8], native_id: int32, super_ctor: int32) -> int32:
    fv: int32 = v_new_native(native_id)
    proto: int32 = v_new_object()
    obj_set(objid_of(proto), str_from_cstr(cast[Ptr[uint8]]("name")), v_string_cstr(name))
    if super_ctor >= 0:
        basep: int32 = obj_get(objid_of(super_ctor), str_from_cstr(cast[Ptr[uint8]]("prototype")))
        if tag_of(basep) == TAG_OBJ:
            obj_proto[objid_of(proto)] = objid_of(basep)
    obj_set(objid_of(fv), str_from_cstr(cast[Ptr[uint8]]("prototype")), proto)
    env_define(g_env, str_from_cstr(name), fv, 0)
    return fv


def install_builtins():
    # console
    g_console = v_new_object()
    obj_add_native(g_console, cast[Ptr[uint8]]("log"), NAT_CONSOLE_LOG)
    obj_add_native(g_console, cast[Ptr[uint8]]("error"), NAT_CONSOLE_LOG)
    obj_add_native(g_console, cast[Ptr[uint8]]("warn"), NAT_CONSOLE_LOG)
    obj_add_native(g_console, cast[Ptr[uint8]]("info"), NAT_CONSOLE_LOG)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("console")), g_console, 0)
    # Math
    g_math = v_new_object()
    obj_add_native(g_math, cast[Ptr[uint8]]("floor"), NAT_MATH_FLOOR)
    obj_add_native(g_math, cast[Ptr[uint8]]("ceil"), NAT_MATH_CEIL)
    obj_add_native(g_math, cast[Ptr[uint8]]("round"), NAT_MATH_ROUND)
    obj_add_native(g_math, cast[Ptr[uint8]]("abs"), NAT_MATH_ABS)
    obj_add_native(g_math, cast[Ptr[uint8]]("sqrt"), NAT_MATH_SQRT)
    obj_add_native(g_math, cast[Ptr[uint8]]("pow"), NAT_MATH_POW)
    obj_add_native(g_math, cast[Ptr[uint8]]("min"), NAT_MATH_MIN)
    obj_add_native(g_math, cast[Ptr[uint8]]("max"), NAT_MATH_MAX)
    obj_add_native(g_math, cast[Ptr[uint8]]("trunc"), NAT_MATH_TRUNC)
    obj_add_native(g_math, cast[Ptr[uint8]]("sign"), NAT_MATH_SIGN)
    obj_add_native(g_math, cast[Ptr[uint8]]("cbrt"), NAT_MATH_CBRT)
    obj_add_native(g_math, cast[Ptr[uint8]]("hypot"), NAT_MATH_HYPOT)
    obj_add_native(g_math, cast[Ptr[uint8]]("log"), NAT_MATH_LOG)
    obj_add_native(g_math, cast[Ptr[uint8]]("log2"), NAT_MATH_LOG2)
    obj_add_native(g_math, cast[Ptr[uint8]]("log10"), NAT_MATH_LOG10)
    obj_add_native(g_math, cast[Ptr[uint8]]("exp"), NAT_MATH_EXP)
    obj_add_native(g_math, cast[Ptr[uint8]]("sin"), NAT_MATH_SIN)
    obj_add_native(g_math, cast[Ptr[uint8]]("cos"), NAT_MATH_COS)
    obj_add_native(g_math, cast[Ptr[uint8]]("tan"), NAT_MATH_TAN)
    obj_add_native(g_math, cast[Ptr[uint8]]("random"), NAT_MATH_RANDOM)
    obj_add_num(g_math, cast[Ptr[uint8]]("PI"), 3.141592653589793)
    obj_add_num(g_math, cast[Ptr[uint8]]("E"), 2.718281828459045)
    obj_add_num(g_math, cast[Ptr[uint8]]("LN2"), 0.6931471805599453)
    obj_add_num(g_math, cast[Ptr[uint8]]("LN10"), 2.302585092994046)
    obj_add_num(g_math, cast[Ptr[uint8]]("LOG2E"), 1.4426950408889634)
    obj_add_num(g_math, cast[Ptr[uint8]]("LOG10E"), 0.4342944819032518)
    obj_add_num(g_math, cast[Ptr[uint8]]("SQRT2"), 1.4142135623730951)
    obj_add_num(g_math, cast[Ptr[uint8]]("SQRT1_2"), 0.7071067811865476)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Math")), g_math, 0)
    # JSON
    g_json = v_new_object()
    obj_add_native(g_json, cast[Ptr[uint8]]("stringify"), NAT_JSON_STRINGIFY)
    obj_add_native(g_json, cast[Ptr[uint8]]("parse"), NAT_JSON_PARSE)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("JSON")), g_json, 0)
    # Object
    g_object = v_new_object()
    obj_add_native(g_object, cast[Ptr[uint8]]("keys"), NAT_OBJECT_KEYS)
    obj_add_native(g_object, cast[Ptr[uint8]]("assign"), NAT_OBJECT_ASSIGN)
    obj_add_native(g_object, cast[Ptr[uint8]]("values"), NAT_OBJECT_VALUES)
    obj_add_native(g_object, cast[Ptr[uint8]]("entries"), NAT_OBJECT_ENTRIES)
    obj_add_native(g_object, cast[Ptr[uint8]]("fromEntries"), NAT_OBJECT_FROMENTRIES)
    obj_add_native(g_object, cast[Ptr[uint8]]("freeze"), NAT_OBJECT_FREEZE)
    obj_add_native(g_object, cast[Ptr[uint8]]("create"), NAT_OBJECT_CREATE)
    obj_add_native(g_object, cast[Ptr[uint8]]("getPrototypeOf"), NAT_OBJECT_GETPROTO)
    obj_add_native(g_object, cast[Ptr[uint8]]("setPrototypeOf"), NAT_OBJECT_SETPROTO)
    obj_add_native(g_object, cast[Ptr[uint8]]("getOwnPropertyNames"), NAT_OBJECT_GETOWNNAMES)
    obj_add_native(g_object, cast[Ptr[uint8]]("defineProperty"), NAT_OBJECT_DEFINEPROP)
    obj_add_native(g_object, cast[Ptr[uint8]]("defineProperties"), NAT_OBJECT_DEFINEPROPS)
    obj_add_native(g_object, cast[Ptr[uint8]]("getOwnPropertyDescriptor"), NAT_OBJECT_GETOWNDESC)
    obj_add_native(g_object, cast[Ptr[uint8]]("getOwnPropertyDescriptors"), NAT_OBJECT_GETOWNDESCS)
    obj_add_native(g_object, cast[Ptr[uint8]]("isFrozen"), NAT_OBJECT_ISFROZEN)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Object")), g_object, 0)
    # Array
    g_array = v_new_native(NAT_ARRAY_CTOR)
    obj_add_native(g_array, cast[Ptr[uint8]]("isArray"), NAT_ARRAY_ISARRAY)
    obj_add_native(g_array, cast[Ptr[uint8]]("of"), NAT_ARRAY_OF)
    obj_add_native(g_array, cast[Ptr[uint8]]("from"), NAT_ARRAY_FROM)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Array")), g_array, 0)
    # Number (static helpers + constants)
    g_number = v_new_native(NAT_NUMBER)
    obj_add_native(g_number, cast[Ptr[uint8]]("isInteger"), NAT_NUMBER_ISINTEGER)
    obj_add_native(g_number, cast[Ptr[uint8]]("isNaN"), NAT_NUMBER_ISNAN)
    obj_add_native(g_number, cast[Ptr[uint8]]("isFinite"), NAT_NUMBER_ISFINITE)
    obj_add_native(g_number, cast[Ptr[uint8]]("isSafeInteger"), NAT_NUMBER_ISSAFEINT)
    obj_add_native(g_number, cast[Ptr[uint8]]("parseFloat"), NAT_PARSEFLOAT)
    obj_add_native(g_number, cast[Ptr[uint8]]("parseInt"), NAT_PARSEINT)
    nobj: int32 = objid_of(g_number)
    obj_set(nobj, str_from_cstr(cast[Ptr[uint8]]("MAX_SAFE_INTEGER")), v_number(9007199254740991.0))
    obj_set(nobj, str_from_cstr(cast[Ptr[uint8]]("MIN_SAFE_INTEGER")), v_number(0.0 - 9007199254740991.0))
    obj_set(nobj, str_from_cstr(cast[Ptr[uint8]]("MAX_VALUE")), v_number(1.7976931348623157e308))
    obj_set(nobj, str_from_cstr(cast[Ptr[uint8]]("MIN_VALUE")), v_number(5.0e-324))
    obj_set(nobj, str_from_cstr(cast[Ptr[uint8]]("EPSILON")), v_number(2.220446049250313e-16))
    obj_set(nobj, str_from_cstr(cast[Ptr[uint8]]("POSITIVE_INFINITY")), v_number(1.0e309))
    obj_set(nobj, str_from_cstr(cast[Ptr[uint8]]("NEGATIVE_INFINITY")), v_number(0.0 - 1.0e309))
    obj_set(nobj, str_from_cstr(cast[Ptr[uint8]]("NaN")), v_number(0.0 / 0.0))
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Number")), g_number, 0)
    # Map (constructor + prototype collection methods)
    g_map: int32 = v_new_native(NAT_MAP)
    map_proto: int32 = v_new_object()
    obj_add_native(map_proto, cast[Ptr[uint8]]("get"), NAT_MAP_GET)
    obj_add_native(map_proto, cast[Ptr[uint8]]("set"), NAT_MAP_SET)
    obj_add_native(map_proto, cast[Ptr[uint8]]("has"), NAT_MAP_HAS)
    obj_add_native(map_proto, cast[Ptr[uint8]]("delete"), NAT_MAP_DELETE)
    obj_add_native(map_proto, cast[Ptr[uint8]]("clear"), NAT_MAP_CLEAR)
    obj_add_native(map_proto, cast[Ptr[uint8]]("forEach"), NAT_MAP_FOREACH)
    obj_add_native(map_proto, cast[Ptr[uint8]]("keys"), NAT_MAP_KEYS)
    obj_add_native(map_proto, cast[Ptr[uint8]]("values"), NAT_MAP_VALUES)
    obj_add_native(map_proto, cast[Ptr[uint8]]("entries"), NAT_MAP_ENTRIES)
    obj_set(objid_of(g_map), str_from_cstr(cast[Ptr[uint8]]("prototype")), map_proto)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Map")), g_map, 0)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("WeakMap")), g_map, 0)
    # Set
    g_set: int32 = v_new_native(NAT_SET)
    set_proto: int32 = v_new_object()
    obj_add_native(set_proto, cast[Ptr[uint8]]("add"), NAT_SET_ADD)
    obj_add_native(set_proto, cast[Ptr[uint8]]("has"), NAT_SET_HAS)
    obj_add_native(set_proto, cast[Ptr[uint8]]("delete"), NAT_SET_DELETE)
    obj_add_native(set_proto, cast[Ptr[uint8]]("clear"), NAT_SET_CLEAR)
    obj_add_native(set_proto, cast[Ptr[uint8]]("forEach"), NAT_SET_FOREACH)
    obj_add_native(set_proto, cast[Ptr[uint8]]("values"), NAT_SET_VALUES)
    obj_add_native(set_proto, cast[Ptr[uint8]]("keys"), NAT_SET_VALUES)
    obj_add_native(set_proto, cast[Ptr[uint8]]("entries"), NAT_SET_VALUES)
    obj_set(objid_of(g_set), str_from_cstr(cast[Ptr[uint8]]("prototype")), set_proto)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Set")), g_set, 0)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("WeakSet")), g_set, 0)
    # Promise (constructor + static resolve/reject/all/race/allSettled +
    # then/catch/finally on the prototype). Reactions run as MICROTASKS on the
    # #178 deferred-callback queue; g_promise_job is the shared reaction runner.
    g_promise_job = v_new_native(NAT_PROMISE_JOB)
    g_promise_proto = v_new_object()
    obj_add_native(g_promise_proto, cast[Ptr[uint8]]("then"), NAT_PROMISE_THEN)
    obj_add_native(g_promise_proto, cast[Ptr[uint8]]("catch"), NAT_PROMISE_CATCH)

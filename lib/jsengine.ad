b_val:   Array[250000, int32]
b_const: Array[250000, uint8]
n_binds: int32 = 0

MAX_AX: int32 = 250000
ax_val: Array[250000, int32]
ax_top: int32 = 0

OUT_CAP: int32 = 262144
out_buf: Array[262144, uint8]
out_top: int32 = 0

MAX_CALLARG: int32 = 8192
call_args: Array[8192, int32]
call_top: int32 = 0

MAX_THIS: int32 = 20000
this_stack: Array[20000, int32]
home_stack: Array[20000, int32]   # home prototype (for `super`) per active frame
curfn_stack: Array[20000, int32]  # object id of the function currently executing
this_top: int32 = 0

# thrown value (CTL_THROW). throw_val holds the exception handle.
throw_val: int32 = 0

# template-literal lexer state (nested interpolations)
MAX_TMPL: int32 = 64
tmpl_bdepth: Array[64, int32]     # object-brace depth inside the top interpolation
tmpl_sp: int32 = 0

SRC_CAP: int32 = 262144

# global roots / state
g_env:    int32 = 0               # global environment id
g_global_obj: int32 = 0           # the global object (host bindings)
g_math:   int32 = 0
g_json:   int32 = 0
g_object: int32 = 0
g_console: int32 = 0
g_array:  int32 = 0
g_number: int32 = 0

ctl:      int32 = 0               # CTL_*
ctl_val:  int32 = 0               # return value handle

err_flag: int32 = 0
err_str:  Array[256, uint8]

# Host dispatch is stored as a raw address (cast to Fn at call time). A Fn-typed
# GLOBAL initialized to a function name would emit a 64-bit relocation the
# native elf32-i386 wrapper cannot represent; a runtime uint64 avoids that.
host_dispatch_addr: uint64 = 0
host_dispatch_set: int32 = 0

# scratch buffer for js_str_ptr / js_to_display (NUL-terminated C string)
scratch: Array[65536, uint8]

# emit target: 0 = string-pool build (bld_*), 1 = out_buf
emit_tgt: int32 = 1


# ====================================================================
# Low-level char helpers.
# ====================================================================
def is_digit(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return 1
    return 0


def is_hexdig(c: uint8) -> int32:
    if is_digit(c) != 0:
        return 1
    if c >= 97 and c <= 102:
        return 1
    if c >= 65 and c <= 70:
        return 1
    return 0


def is_idstart(c: uint8) -> int32:
    if c >= 97 and c <= 122:
        return 1
    if c >= 65 and c <= 90:
        return 1
    if c == 95 or c == 36:            # _ or $
        return 1
    return 0


def is_idpart(c: uint8) -> int32:
    if is_idstart(c) != 0:
        return 1
    if is_digit(c) != 0:
        return 1
    return 0


def is_ws(c: uint8) -> int32:
    if c == 32 or c == 9 or c == 13 or c == 10:
        return 1
    return 0


# ====================================================================
# Float helpers (avoid libm).
# ====================================================================
def f_trunc(x: float64) -> float64:
    # truncate toward zero; exact for |x| < 9e18
    if x != x:
        return x
    if x < 0.0:
        i: int64 = cast[int64](0.0 - x)
        return 0.0 - cast[float64](i)
    i2: int64 = cast[int64](x)
    return cast[float64](i2)


def f_floor(x: float64) -> float64:
    t: float64 = f_trunc(x)
    if t > x:
        return t - 1.0
    return t


def f_ceil(x: float64) -> float64:
    t: float64 = f_trunc(x)
    if t < x:
        return t + 1.0
    return t


def f_abs(x: float64) -> float64:
    if x < 0.0:
        return 0.0 - x
    return x


def f_fmod(a: float64, b: float64) -> float64:
    if b == 0.0:
        return 0.0 / 0.0            # NaN
    q: float64 = f_trunc(a / b)
    return a - q * b


def f_sqrt(x: float64) -> float64:
    if x < 0.0:
        return 0.0 / 0.0
    if x == 0.0:
        return 0.0
    g: float64 = x
    if g < 1.0:
        g = 1.0
    i: int32 = 0
    while i < 60:
        g = 0.5 * (g + x / g)
        i = i + 1
    return g


def f_pow(base: float64, exp: float64) -> float64:
    # Integer exponent fast path (covers Math.pow / ** in the gate).
    e: float64 = f_trunc(exp)
    if e == exp:
        neg: int32 = 0
        n: int64 = cast[int64](e)
        if n < 0:
            neg = 1
            n = 0 - n
        r: float64 = 1.0
        b: float64 = base
        while n > 0:
            if n % 2 == 1:
                r = r * b
            b = b * b
            n = n / 2
        if neg != 0:
            return 1.0 / r
        return r
    # Fallback: sqrt-based for x^0.5 only; otherwise NaN (rare in scripts).
    if exp == 0.5:
        return f_sqrt(base)
    return 0.0 / 0.0


def is_nan(x: float64) -> int32:
    if x != x:
        return 1
    return 0


def is_inf(x: float64) -> int32:
    if x > 1.0e308:
        return 1
    if x < -1.0e308:
        return 1
    return 0


# --- transcendental helpers (range-reduced series; extern-free) ---
# (module-level float globals aren't supported by the x86 backend, so the
# constants live inside the helpers below as literals.)
def f_ln2() -> float64:
    return 0.6931471805599453


def f_twopi() -> float64:
    return 6.283185307179586


def f_sign(x: float64) -> float64:
    if x != x:
        return x
    if x > 0.0:
        return 1.0
    if x < 0.0:
        return -1.0
    return x                       # +0 / -0 pass through


def f_cbrt(x: float64) -> float64:
    if x == 0.0:
        return x
    neg: int32 = 0
    a: float64 = x
    if a < 0.0:
        neg = 1
        a = 0.0 - a
    g: float64 = a
    if g < 1.0:
        g = 1.0
    i: int32 = 0
    while i < 80:
        g = (2.0 * g + a / (g * g)) / 3.0
        i = i + 1
    if neg != 0:
        return 0.0 - g
    return g


def f_hypot(a: float64, b: float64) -> float64:
    return f_sqrt(a * a + b * b)


def f_ln(x: float64) -> float64:
    if x != x or x < 0.0:
        return 0.0 / 0.0
    if x == 0.0:
        return -1.0e309            # -Infinity
    if is_inf(x) != 0:
        return x
    k: int32 = 0
    m: float64 = x
    while m >= 2.0:
        m = m / 2.0
        k = k + 1
    while m < 1.0:
        m = m * 2.0
        k = k - 1
    # m in [1,2): ln(m) = 2*(t + t^3/3 + t^5/5 + ...), t=(m-1)/(m+1)
    t: float64 = (m - 1.0) / (m + 1.0)
    t2: float64 = t * t
    term: float64 = t
    sum: float64 = 0.0
    n: int32 = 1
    while n < 60:
        sum = sum + term / cast[float64](n)
        term = term * t2
        n = n + 2
    return 2.0 * sum + cast[float64](k) * f_ln2()


def f_exp(x: float64) -> float64:
    if x != x:
        return x
    if x > 709.0:
        return 1.0e309            # Infinity
    if x < -745.0:
        return 0.0
    # range-reduce: x = k*ln2 + r, r in [-ln2/2, ln2/2]
    k: int32 = cast[int32](f_floor(x / f_ln2() + 0.5))
    r: float64 = x - cast[float64](k) * f_ln2()
    term: float64 = 1.0
    sum: float64 = 1.0
    n: int32 = 1
    while n < 25:
        term = term * r / cast[float64](n)
        sum = sum + term
        n = n + 1
    return sum * f_pow(2.0, cast[float64](k))


def f_sin(x: float64) -> float64:
    if x != x or is_inf(x) != 0:
        return 0.0 / 0.0
    # reduce mod 2pi
    n: float64 = f_floor(x / f_twopi() + 0.5)
    r: float64 = x - n * f_twopi()
    term: float64 = r
    sum: float64 = r
    r2: float64 = r * r
    i: int32 = 1
    while i < 20:
        term = 0.0 - term * r2 / cast[float64]((2 * i) * (2 * i + 1))
        sum = sum + term
        i = i + 1
    return sum


def f_cos(x: float64) -> float64:
    if x != x or is_inf(x) != 0:
        return 0.0 / 0.0
    n: float64 = f_floor(x / f_twopi() + 0.5)
    r: float64 = x - n * f_twopi()
    term: float64 = 1.0
    sum: float64 = 1.0
    r2: float64 = r * r
    i: int32 = 1
    while i < 20:
        term = 0.0 - term * r2 / cast[float64]((2 * i - 1) * (2 * i))
        sum = sum + term
        i = i + 1
    return sum


# deterministic LCG-backed Math.random (no true entropy source in the engine).
rng_state: uint64 = 88172645463325252


def f_random() -> float64:
    rng_state = rng_state * 6364136223846793005 + 1442695040888963407
    # take the top 53 bits for a [0,1) double
    top: uint64 = rng_state >> 11
    return cast[float64](top) / 9007199254740992.0


# ====================================================================
# STRING pool.
# ====================================================================
def str_new(p: Ptr[uint8], n: int32) -> int32:
    off: int32 = sp_top
    i: int32 = 0
    while i < n:
        sp_buf[sp_top] = p[i]
        sp_top = sp_top + 1
        i = i + 1
    id: int32 = n_strs
    st_off[id] = off
    st_len[id] = n
    n_strs = n_strs + 1
    return id


def str_len(id: int32) -> int32:
    return st_len[id]


def str_ptr(id: int32) -> Ptr[uint8]:
    return &sp_buf[st_off[id]]


def str_char(id: int32, i: int32) -> uint8:
    return sp_buf[st_off[id] + i]


def str_eq(a: int32, b: int32) -> int32:
    if st_len[a] != st_len[b]:
        return 0
    n: int32 = st_len[a]
    i: int32 = 0
    oa: int32 = st_off[a]
    ob: int32 = st_off[b]
    while i < n:
        if sp_buf[oa + i] != sp_buf[ob + i]:
            return 0
        i = i + 1
    return 1


def str_eq_cstr(a: int32, s: Ptr[uint8]) -> int32:
    n: int32 = st_len[a]
    oa: int32 = st_off[a]
    i: int32 = 0
    while i < n:
        if s[i] == 0:
            return 0
        if sp_buf[oa + i] != s[i]:
            return 0
        i = i + 1
    if s[i] != 0:
        return 0
    return 1


def cstr_len(s: Ptr[uint8]) -> int32:
    n: int32 = 0
    while s[n] != 0:
        n = n + 1
    return n


def str_from_cstr(s: Ptr[uint8]) -> int32:
    return str_new(s, cstr_len(s))


# ---- build a string / write output through emit_c ----
_bld_start: int32 = 0

def bld_begin():
    _bld_start = sp_top


def bld_end() -> int32:
    id: int32 = n_strs
    st_off[id] = _bld_start
    st_len[id] = sp_top - _bld_start
    n_strs = n_strs + 1
    return id


def emit_c(c: uint8):
    if emit_tgt == 1:
        if out_top < OUT_CAP - 1:
            out_buf[out_top] = c
            out_top = out_top + 1
    else:
        if sp_top < SP_CAP - 1:
            sp_buf[sp_top] = c
            sp_top = sp_top + 1


def emit_cstr(s: Ptr[uint8]):
    i: int32 = 0
    while s[i] != 0:
        emit_c(s[i])
        i = i + 1


def emit_strid(id: int32):
    n: int32 = st_len[id]
    off: int32 = st_off[id]
    i: int32 = 0
    while i < n:
        emit_c(sp_buf[off + i])
        i = i + 1


def emit_u64(v: uint64):
    if v == 0:
        emit_c(48)
        return
    digs: Array[24, uint8]
    n: int32 = 0
    while v > 0:
        digs[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    while n > 0:
        n = n - 1
        emit_c(digs[n])


def emit_i64(v: int64):
    if v < 0:
        emit_c(45)
        emit_u64(cast[uint64](0 - v))
    else:
        emit_u64(cast[uint64](v))


def emit_num(x: float64):
    if is_nan(x) != 0:
        emit_cstr(cast[Ptr[uint8]]("NaN"))
        return
    if is_inf(x) != 0:
        if x < 0.0:
            emit_c(45)
        emit_cstr(cast[Ptr[uint8]]("Infinity"))
        return
    if x == 0.0:
        emit_c(48)
        return
    neg: int32 = 0
    if x < 0.0:
        neg = 1
        x = 0.0 - x
    ip: float64 = f_floor(x)
    frac: float64 = x - ip
    if neg != 0:
        emit_c(45)
    # integer part
    if ip < 9.0e18:
        emit_u64(cast[uint64](ip))
    else:
        emit_cstr(cast[Ptr[uint8]]("1e19"))     # absurdly large; rare
    if frac > 0.0:
        emit_c(46)                               # '.'
        # up to 12 significant fractional digits, trailing zeros trimmed
        fbuf: Array[16, uint8]
        fn: int32 = 0
        k: int32 = 0
        while k < 12:
            frac = frac * 10.0
            d: int32 = cast[int32](f_floor(frac))
            if d > 9:
                d = 9
            fbuf[fn] = cast[uint8](d) + 48
            fn = fn + 1
            frac = frac - cast[float64](d)
            k = k + 1
            if frac <= 0.0:
                break
        # trim trailing zeros
        while fn > 1 and fbuf[fn - 1] == 48:
            fn = fn - 1
        j: int32 = 0
        while j < fn:
            emit_c(fbuf[j])
            j = j + 1


# ---- number-string helper making a fresh string value ----
def num_to_strid(x: float64) -> int32:
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    emit_num(x)
    id: int32 = bld_end()
    emit_tgt = save
    return id


# parse a JS numeric literal / string to float64
def parse_num_bytes(p: Ptr[uint8], n: int32) -> float64:
    i: int32 = 0
    while i < n and is_ws(p[i]) != 0:
        i = i + 1
    sign: float64 = 1.0
    if i < n and p[i] == 43:
        i = i + 1
    elif i < n and p[i] == 45:
        sign = -1.0
        i = i + 1
    # hex
    if i + 1 < n and p[i] == 48 and (p[i + 1] == 120 or p[i + 1] == 88):
        i = i + 2
        hv: float64 = 0.0
        any: int32 = 0
        while i < n and is_hexdig(p[i]) != 0:
            c: uint8 = p[i]
            d: int32 = 0
            if c >= 48 and c <= 57:
                d = cast[int32](c) - 48
            elif c >= 97 and c <= 102:
                d = cast[int32](c) - 87
            else:
                d = cast[int32](c) - 55
            hv = hv * 16.0 + cast[float64](d)
            any = 1
            i = i + 1
        if any == 0:
            return 0.0 / 0.0
        return sign * hv
    val: float64 = 0.0
    any2: int32 = 0
    while i < n and is_digit(p[i]) != 0:
        val = val * 10.0 + cast[float64](cast[int32](p[i]) - 48)
        any2 = 1
        i = i + 1
    if i < n and p[i] == 46:
        i = i + 1
        scale: float64 = 0.1
        while i < n and is_digit(p[i]) != 0:
            val = val + cast[float64](cast[int32](p[i]) - 48) * scale
            scale = scale * 0.1
            any2 = 1
            i = i + 1
    if any2 == 0:
        return 0.0 / 0.0
    if i < n and (p[i] == 101 or p[i] == 69):    # e / E
        i = i + 1
        esign: int32 = 1
        if i < n and p[i] == 43:
            i = i + 1
        elif i < n and p[i] == 45:
            esign = -1
            i = i + 1
        ev: int32 = 0
        while i < n and is_digit(p[i]) != 0:
            ev = ev * 10 + (cast[int32](p[i]) - 48)
            i = i + 1
        k: int32 = 0
        while k < ev:
            if esign > 0:
                val = val * 10.0
            else:
                val = val * 0.1
            k = k + 1
    return sign * val


# ====================================================================
# VALUE constructors / accessors.
# ====================================================================
def mk_val(tag: int32) -> int32:
    h: int32 = n_vals
    v_tag[h] = cast[uint8](tag)
    v_ref[h] = 0
    v_num[h] = 0.0
    n_vals = n_vals + 1
    return h


def v_undef() -> int32:
    return 0


def v_null() -> int32:
    return 1


def v_true() -> int32:
    return 2


def v_false() -> int32:
    return 3


def v_boolv(b: int32) -> int32:
    if b != 0:
        return 2
    return 3


def v_number(x: float64) -> int32:
    h: int32 = mk_val(TAG_NUM)
    v_num[h] = x
    return h


def v_string_id(sid: int32) -> int32:
    h: int32 = mk_val(TAG_STR)
    v_ref[h] = sid
    return h


def v_string_bytes(p: Ptr[uint8], n: int32) -> int32:
    return v_string_id(str_new(p, n))


def v_string_cstr(s: Ptr[uint8]) -> int32:
    return v_string_id(str_from_cstr(s))


def tag_of(h: int32) -> int32:
    return cast[int32](v_tag[h])


def num_of(h: int32) -> float64:
    return v_num[h]


def strid_of(h: int32) -> int32:
    return v_ref[h]


def objid_of(h: int32) -> int32:
    return v_ref[h]


# ====================================================================
# OBJECTS.
# ====================================================================
def obj_new(kind: int32) -> int32:
    o: int32 = n_objs
    obj_kind[o] = cast[uint8](kind)
    obj_head[o] = -1
    obj_fn_node[o] = -1
    obj_fn_env[o] = -1
    obj_fn_native[o] = -1
    arr_len[o] = 0
    arr_cap[o] = 0
    arr_base[o] = -1
    obj_proto[o] = -1
    obj_fn_this[o] = -2
    obj_fn_home[o] = -1
    obj_fn_super[o] = -1
    obj_class[o] = 0
    obj_re_prog[o] = -1
    obj_re_ncap[o] = 0
    obj_re_flags[o] = 0
    n_objs = n_objs + 1
    return o


def v_new_object() -> int32:
    h: int32 = mk_val(TAG_OBJ)
    v_ref[h] = obj_new(OK_PLAIN)
    return h


def v_new_array() -> int32:
    h: int32 = mk_val(TAG_OBJ)
    v_ref[h] = obj_new(OK_ARRAY)
    return h


def v_new_native(native_id: int32) -> int32:
    h: int32 = mk_val(TAG_OBJ)
    o: int32 = obj_new(OK_FUNC)
    obj_fn_native[o] = native_id
    v_ref[h] = o
    return h


def v_new_closure(node: int32, env: int32) -> int32:
    h: int32 = mk_val(TAG_OBJ)
    o: int32 = obj_new(OK_FUNC)
    obj_fn_node[o] = node
    obj_fn_env[o] = env
    v_ref[h] = o
    return h


def is_callable(h: int32) -> int32:
    if tag_of(h) != TAG_OBJ:
        return 0
    if cast[int32](obj_kind[objid_of(h)]) == OK_FUNC:
        return 1
    return 0


def is_array(h: int32) -> int32:
    if tag_of(h) != TAG_OBJ:
        return 0
    if cast[int32](obj_kind[objid_of(h)]) == OK_ARRAY:
        return 1
    return 0


# ---- named property get/set (string-keyed) on an object id ----
def obj_find_prop(o: int32, key: int32) -> int32:
    p: int32 = obj_head[o]
    while p >= 0:
        if str_eq(p_key[p], key) != 0:
            return p
        p = p_next[p]
    return -1


# allocation-free lookup by C-string key (safe to call mid string-build)
def obj_find_prop_cstr(o: int32, s: Ptr[uint8]) -> int32:
    p: int32 = obj_head[o]
    while p >= 0:
        if str_eq_cstr(p_key[p], s) != 0:
            return p
        p = p_next[p]
    return -1


def obj_get_cstr(o: int32, s: Ptr[uint8]) -> int32:
    p: int32 = obj_find_prop_cstr(o, s)
    if p >= 0:
        return p_val[p]
    return v_undef()


def obj_set(o: int32, key: int32, val: int32):
    p: int32 = obj_find_prop(o, key)
    if p >= 0:
        p_val[p] = val
        return
    np: int32 = n_props
    p_key[np] = key
    p_val[np] = val
    p_next[np] = obj_head[o]
    obj_head[o] = np
    n_props = n_props + 1


def obj_get(o: int32, key: int32) -> int32:
    p: int32 = obj_find_prop(o, key)
    if p >= 0:
        return p_val[p]
    return v_undef()


# copy own (enumerable) props of src into dst, preserving insertion order
def copy_own_props(src: int32, dst: int32):
    copy_own_props_rec(obj_head[src], dst)


def copy_own_props_rec(p: int32, dst: int32):
    if p < 0:
        return
    copy_own_props_rec(p_next[p], dst)
    obj_set(dst, p_key[p], p_val[p])


# ---- array element storage ----
def arr_grow(o: int32, need: int32):
    if need <= arr_cap[o]:
        return
    ncap: int32 = arr_cap[o] * 2
    if ncap < 4:
        ncap = 4
    while ncap < need:
        ncap = ncap * 2
    nbase: int32 = ax_top
    ax_top = ax_top + ncap
    # copy old elements
    i: int32 = 0
    ob: int32 = arr_base[o]
    while i < arr_len[o]:
        ax_val[nbase + i] = ax_val[ob + i]
        i = i + 1
    # fill remainder with undefined
    while i < ncap:
        ax_val[nbase + i] = v_undef()
        i = i + 1
    arr_base[o] = nbase
    arr_cap[o] = ncap


def arr_set(o: int32, idx: int32, val: int32):
    if idx < 0:
        return
    if idx >= arr_cap[o]:
        arr_grow(o, idx + 1)
    if idx >= arr_len[o]:
        # fill holes with undefined
        i: int32 = arr_len[o]
        while i < idx:
            ax_val[arr_base[o] + i] = v_undef()
            i = i + 1
        arr_len[o] = idx + 1
    ax_val[arr_base[o] + idx] = val


def arr_get(o: int32, idx: int32) -> int32:
    if idx < 0 or idx >= arr_len[o]:
        return v_undef()
    return ax_val[arr_base[o] + idx]


def arr_push(o: int32, val: int32):
    arr_set(o, arr_len[o], val)


# ====================================================================
# ENVIRONMENTS.
# ====================================================================
def env_new(parent: int32, is_func: int32) -> int32:
    e: int32 = n_envs
    env_parent[e] = parent
    env_head[e] = -1
    if is_func != 0:
        env_is_func[e] = 1
    else:
        env_is_func[e] = 0
    n_envs = n_envs + 1
    return e


def env_find_local(e: int32, name: int32) -> int32:
    b: int32 = env_head[e]
    while b >= 0:
        if str_eq(b_name[b], name) != 0:
            return b
        b = b_next[b]
    return -1


def env_define(e: int32, name: int32, val: int32, is_const: int32):
    b: int32 = env_find_local(e, name)
    if b >= 0:
        b_val[b] = val
        return
    nb: int32 = n_binds
    b_name[nb] = name
    b_val[nb] = val
    if is_const != 0:
        b_const[nb] = 1
    else:
        b_const[nb] = 0
    b_next[nb] = env_head[e]
    env_head[e] = nb
    n_binds = n_binds + 1


def env_lookup_bind(e: int32, name: int32) -> int32:
    while e >= 0:
        b: int32 = env_find_local(e, name)
        if b >= 0:
            return b
        e = env_parent[e]
    return -1


def env_func_scope(e: int32) -> int32:
    while e >= 0:
        if env_is_func[e] != 0:
            return e
        if env_parent[e] < 0:
            return e
        e = env_parent[e]
    return e


# ====================================================================
# error handling
# ====================================================================
# A catchable runtime exception: builds an Error-like object and unwinds via
# CTL_THROW (as opposed to set_error, which is a fatal parse/engine error).
def throw_error(name: Ptr[uint8], msg: Ptr[uint8]):
    if ctl == CTL_THROW or err_flag != 0:
        return
    ev: int32 = v_new_object()
    o: int32 = objid_of(ev)
    obj_set(o, str_from_cstr(name_key()), v_string_cstr(name))
    obj_set(o, str_from_cstr(msg_key()), v_string_cstr(msg))
    throw_val = ev
    ctl = CTL_THROW


def name_key() -> Ptr[uint8]:
    return cast[Ptr[uint8]]("name")


def msg_key() -> Ptr[uint8]:
    return cast[Ptr[uint8]]("message")


def set_error(msg: Ptr[uint8]):
    if err_flag != 0:
        return
    err_flag = 1
    i: int32 = 0
    while msg[i] != 0 and i < 255:
        err_str[i] = msg[i]
        i = i + 1
    err_str[i] = 0
    ctl = CTL_RETURN
    ctl_val = v_undef()


# ====================================================================
# LEXER — source in src_ptr/src_len; produces token arrays.
# ====================================================================
lex_p: Ptr[uint8] = 0
lex_n: int32 = 0
lex_i: int32 = 0


def push_tok(kind: int32):
    tk_kind[n_toks] = cast[uint8](kind)
    tk_num[n_toks] = 0.0
    tk_str[n_toks] = -1
    n_toks = n_toks + 1


def push_tok_num(x: float64):
    tk_kind[n_toks] = cast[uint8](TK_NUM)
    tk_num[n_toks] = x
    tk_str[n_toks] = -1
    n_toks = n_toks + 1


def push_tok_str(kind: int32, sid: int32):
    tk_kind[n_toks] = cast[uint8](kind)
    tk_num[n_toks] = 0.0
    tk_str[n_toks] = sid
    tk_str2[n_toks] = -1
    n_toks = n_toks + 1


def push_tok_regex(src_sid: int32, flags_sid: int32):
    tk_kind[n_toks] = cast[uint8](TK_REGEX)
    tk_num[n_toks] = 0.0
    tk_str[n_toks] = src_sid
    tk_str2[n_toks] = flags_sid
    n_toks = n_toks + 1


# A leading `/` starts a regex literal only in expression-start position — i.e.
# NOT right after a value-producing token (identifier, literal, `)`, `]`, `++`,
# `--`, this/super, etc.). Everything else (operators, `(`, `,`, `=`, `return`,
# `{`, `;`, start-of-input, ...) means an expression is expected -> regex.
def prev_is_value() -> int32:
    if n_toks == 0:
        return 0
    k: int32 = cast[int32](tk_kind[n_toks - 1])
    if k == TK_IDENT or k == TK_NUM or k == TK_STR or k == TK_REGEX:
        return 1
    if k == TK_RPAREN or k == TK_RBRACK:
        return 1
    if k == TK_THIS or k == TK_SUPER:
        return 1
    if k == TK_TRUE or k == TK_FALSE or k == TK_NULL or k == TK_UNDEFINED:
        return 1
    if k == TK_INC or k == TK_DEC:
        return 1
    return 0


# Lex a regex literal beginning at the opening `/` (lex_i points at it). Scans
# the pattern (tracking `\`-escapes and `[...]` classes so an inner `/` is not
# mistaken for the terminator), then the trailing flag letters.
def lex_regex():
    lex_i = lex_i + 1                     # skip opening /
    start: int32 = lex_i
    inclass: int32 = 0
    while lex_i < lex_n:
        c: uint8 = lex_p[lex_i]
        if c == 92:                       # backslash: escape next char
            lex_i = lex_i + 2
            continue
        if c == 91:                       # [
            inclass = 1
        elif c == 93:                     # ]
            inclass = 0
        elif c == 47 and inclass == 0:    # / terminator
            break
        elif c == 10:                     # unterminated at newline
            break
        lex_i = lex_i + 1
    src_sid: int32 = str_new(&lex_p[start], lex_i - start)
    if lex_i < lex_n and lex_p[lex_i] == 47:
        lex_i = lex_i + 1                 # skip closing /
    # flags
    fstart: int32 = lex_i
    while lex_i < lex_n and is_idpart(lex_p[lex_i]) != 0:
        lex_i = lex_i + 1
    flags_sid: int32 = str_new(&lex_p[fstart], lex_i - fstart)
    push_tok_regex(src_sid, flags_sid)


def kw_kind(sid: int32) -> int32:
    if str_eq_cstr(sid, cast[Ptr[uint8]]("var")) != 0:
        return TK_VAR
    if str_eq_cstr(sid, cast[Ptr[uint8]]("let")) != 0:
        return TK_LET
    if str_eq_cstr(sid, cast[Ptr[uint8]]("const")) != 0:
        return TK_CONST
    if str_eq_cstr(sid, cast[Ptr[uint8]]("function")) != 0:
        return TK_FUNCTION
    if str_eq_cstr(sid, cast[Ptr[uint8]]("return")) != 0:
        return TK_RETURN
    if str_eq_cstr(sid, cast[Ptr[uint8]]("if")) != 0:
        return TK_IF
    if str_eq_cstr(sid, cast[Ptr[uint8]]("else")) != 0:
        return TK_ELSE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("while")) != 0:
        return TK_WHILE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("for")) != 0:
        return TK_FOR
    if str_eq_cstr(sid, cast[Ptr[uint8]]("do")) != 0:
        return TK_DO
    if str_eq_cstr(sid, cast[Ptr[uint8]]("break")) != 0:
        return TK_BREAK
    if str_eq_cstr(sid, cast[Ptr[uint8]]("continue")) != 0:
        return TK_CONTINUE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("true")) != 0:
        return TK_TRUE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("false")) != 0:
        return TK_FALSE
    if str_eq_cstr(sid, cast[Ptr[uint8]]("null")) != 0:
        return TK_NULL
    if str_eq_cstr(sid, cast[Ptr[uint8]]("undefined")) != 0:
        return TK_UNDEFINED
    if str_eq_cstr(sid, cast[Ptr[uint8]]("typeof")) != 0:
        return TK_TYPEOF
    if str_eq_cstr(sid, cast[Ptr[uint8]]("instanceof")) != 0:
        return TK_INSTANCEOF
    if str_eq_cstr(sid, cast[Ptr[uint8]]("in")) != 0:
        return TK_IN
    if str_eq_cstr(sid, cast[Ptr[uint8]]("new")) != 0:
        return TK_NEW
    if str_eq_cstr(sid, cast[Ptr[uint8]]("this")) != 0:
        return TK_THIS
    if str_eq_cstr(sid, cast[Ptr[uint8]]("class")) != 0:
        return TK_CLASS
    if str_eq_cstr(sid, cast[Ptr[uint8]]("extends")) != 0:
        return TK_EXTENDS
    if str_eq_cstr(sid, cast[Ptr[uint8]]("super")) != 0:
        return TK_SUPER
    if str_eq_cstr(sid, cast[Ptr[uint8]]("try")) != 0:
        return TK_TRY
    if str_eq_cstr(sid, cast[Ptr[uint8]]("catch")) != 0:
        return TK_CATCH
    if str_eq_cstr(sid, cast[Ptr[uint8]]("finally")) != 0:
        return TK_FINALLY
    if str_eq_cstr(sid, cast[Ptr[uint8]]("throw")) != 0:
        return TK_THROW
    return TK_IDENT


def lch(off: int32) -> uint8:
    if lex_i + off >= lex_n:
        return 0
    return lex_p[lex_i + off]


def emit_utf8(cp: int32):
    # Encode a Unicode code point as UTF-8 into the current build target.
    if cp < 128:
        emit_c(cast[uint8](cp))
    elif cp < 2048:
        emit_c(cast[uint8](192 + (cp >> 6)))
        emit_c(cast[uint8](128 + (cp & 63)))
    elif cp < 65536:
        emit_c(cast[uint8](224 + (cp >> 12)))
        emit_c(cast[uint8](128 + ((cp >> 6) & 63)))
        emit_c(cast[uint8](128 + (cp & 63)))
    else:
        emit_c(cast[uint8](240 + (cp >> 18)))
        emit_c(cast[uint8](128 + ((cp >> 12) & 63)))
        emit_c(cast[uint8](128 + ((cp >> 6) & 63)))
        emit_c(cast[uint8](128 + (cp & 63)))


def lex_emit_hexesc(ndig: int32):
    # lex_i is AT the 'x' or 'u'. Read up to ndig hex digits following it,
    # emit the resulting code point as UTF-8, and leave lex_i at the LAST
    # consumed digit (the caller advances one past it). Malformed (zero
    # digits) emits nothing.
    cp: int32 = 0
    k: int32 = 0
    while k < ndig:
        hv: int32 = hexval(lch(1))
        if hv < 0:
            break
        cp = cp * 16 + hv
        lex_i = lex_i + 1
        k = k + 1
    if k > 0:
        emit_utf8(cp)


def lex_string(q: uint8):
    lex_i = lex_i + 1                 # skip opening quote
    bld_begin()
    save: int32 = emit_tgt
    emit_tgt = 0
    while lex_i < lex_n and lex_p[lex_i] != q:
        c: uint8 = lex_p[lex_i]
        if c == 92:                   # backslash
            lex_i = lex_i + 1
            e: uint8 = lch(0)
            if e == 110:                  # \n
                emit_c(10)
            elif e == 116:                # \t
                emit_c(9)
            elif e == 114:                # \r
                emit_c(13)
            elif e == 98:                 # \b -> backspace
                emit_c(8)
            elif e == 102:                # \f -> form feed
                emit_c(12)
            elif e == 118:                # \v -> vertical tab
                emit_c(11)
            elif e == 92:                 # \\
                emit_c(92)
            elif e == 39:                 # \'
                emit_c(39)
            elif e == 34:                 # \"
                emit_c(34)
            elif e == 48:                 # \0 -> NUL
                emit_c(0)
            elif e == 120:                # \xHH
                lex_emit_hexesc(2)
            elif e == 117:                # \uHHHH
                lex_emit_hexesc(4)
            elif e == 10:                 # line continuation \<LF> -> nothing
                pass
            elif e == 13:                 # line continuation \<CR>[<LF>]
                if lch(1) == 10:
                    lex_i = lex_i + 1
            else:                         # unknown escape -> literal char
                emit_c(e)
            lex_i = lex_i + 1
        else:
            emit_c(c)
            lex_i = lex_i + 1
    lex_i = lex_i + 1                 # skip closing quote
    emit_tgt = save
    sid: int32 = bld_end()
    push_tok_str(TK_STR, sid)


def lex_number():
    start: int32 = lex_i
    if lex_p[lex_i] == 48 and (lch(1) == 120 or lch(1) == 88):
        lex_i = lex_i + 2
        while lex_i < lex_n and is_hexdig(lex_p[lex_i]) != 0:
            lex_i = lex_i + 1
    else:
        while lex_i < lex_n and is_digit(lex_p[lex_i]) != 0:
            lex_i = lex_i + 1
        if lex_i < lex_n and lex_p[lex_i] == 46:
            lex_i = lex_i + 1
            while lex_i < lex_n and is_digit(lex_p[lex_i]) != 0:
                lex_i = lex_i + 1
        if lex_i < lex_n and (lex_p[lex_i] == 101 or lex_p[lex_i] == 69):
            lex_i = lex_i + 1
            if lex_i < lex_n and (lex_p[lex_i] == 43 or lex_p[lex_i] == 45):
                lex_i = lex_i + 1
            while lex_i < lex_n and is_digit(lex_p[lex_i]) != 0:
                lex_i = lex_i + 1
    x: float64 = parse_num_bytes(&lex_p[start], lex_i - start)
    push_tok_num(x)


def lex_ident():
    start: int32 = lex_i
    while lex_i < lex_n and is_idpart(lex_p[lex_i]) != 0:
        lex_i = lex_i + 1
    sid: int32 = str_new(&lex_p[start], lex_i - start)
    k: int32 = kw_kind(sid)
    if k == TK_IDENT:
        push_tok_str(TK_IDENT, sid)
    else:
        push_tok(k)


# ---- template literals ----
# A template `a${x}b` is lexed into an ordinary parenthesised concat expression:
#   ( "a" + ( x ) + "b" )
# The leading string chunk makes the whole `+` chain coerce to a string, so no
# new parser node is needed. Nested templates / interpolations use tmpl_bdepth.
def lex_tmpl_chunk() -> int32:
    # Cook a template chunk into the string pool; stop at ` or ${ or EOF,
    # leaving lex_i AT the terminator (not consumed).
    bld_begin()
    save: int32 = emit_tgt
    emit_tgt = 0
    while lex_i < lex_n:
        c: uint8 = lex_p[lex_i]
        if c == 96:                       # backtick -> end of template
            break
        if c == 36 and lch(1) == 123:     # ${ -> interpolation
            break
        if c == 92:                       # backslash escape
            lex_i = lex_i + 1
            e: uint8 = lch(0)
            if e == 110:                  # \n
                emit_c(10)
            elif e == 116:                # \t
                emit_c(9)
            elif e == 114:                # \r
                emit_c(13)
            elif e == 98:                 # \b -> backspace
                emit_c(8)
            elif e == 102:                # \f -> form feed
                emit_c(12)
            elif e == 118:                # \v -> vertical tab
                emit_c(11)
            elif e == 92:                 # \\
                emit_c(92)
            elif e == 96:                 # \`
                emit_c(96)
            elif e == 36:                 # \$
                emit_c(36)
            elif e == 39:                 # \'
                emit_c(39)
            elif e == 34:                 # \"
                emit_c(34)
            elif e == 48:                 # \0 -> NUL
                emit_c(0)
            elif e == 120:                # \xHH
                lex_emit_hexesc(2)
            elif e == 117:                # \uHHHH
                lex_emit_hexesc(4)
            elif e == 10:                 # line continuation \<LF> -> nothing
                pass
            elif e == 13:                 # line continuation \<CR>[<LF>]
                if lch(1) == 10:
                    lex_i = lex_i + 1
            else:                         # unknown escape -> literal char
                emit_c(e)
            lex_i = lex_i + 1
        else:
            emit_c(c)
            lex_i = lex_i + 1
    emit_tgt = save
    return bld_end()


def lex_tmpl_continue(is_open: int32):
    # Emit one chunk + its trailing delimiter. is_open=1 just past the opening
    # backtick (emit the wrapping '('); 0 when resuming just past a '}'.
    if is_open != 0:
        push_tok(TK_LPAREN)
    else:
        push_tok(TK_PLUS)
    sid: int32 = lex_tmpl_chunk()
    push_tok_str(TK_STR, sid)
    c: uint8 = lch(0)
    if c == 96:                           # end of template -> close the wrap
        lex_i = lex_i + 1
        push_tok(TK_RPAREN)
    elif c == 36 and lch(1) == 123:       # ${  -> begin an interpolation
        lex_i = lex_i + 2
        push_tok(TK_PLUS)
        push_tok(TK_LPAREN)
        tmpl_bdepth[tmpl_sp] = 0
        tmpl_sp = tmpl_sp + 1
    else:
        push_tok(TK_RPAREN)               # unterminated: close defensively


def tokenize(p: Ptr[uint8], n: int32):
    lex_p = p
    lex_n = n
    lex_i = 0
    n_toks = 0
    tmpl_sp = 0
    while lex_i < lex_n:
        c: uint8 = lex_p[lex_i]
        if is_ws(c) != 0:
            lex_i = lex_i + 1
            continue
        # comments
        if c == 47 and lch(1) == 47:              # //
            while lex_i < lex_n and lex_p[lex_i] != 10:
                lex_i = lex_i + 1
            continue
        if c == 47 and lch(1) == 42:              # /* */
            lex_i = lex_i + 2
            while lex_i < lex_n and not (lex_p[lex_i] == 42 and lch(1) == 47):
                lex_i = lex_i + 1
            lex_i = lex_i + 2
            continue
        # regex literal: `/` in expression-start position
        if c == 47 and prev_is_value() == 0:
            lex_regex()
            continue
        if c == 34 or c == 39:                    # " '
            lex_string(c)
            continue
        if c == 96:                               # ` template literal
            lex_i = lex_i + 1
            lex_tmpl_continue(1)
            continue
        if is_digit(c) != 0:
            lex_number()
            continue
        if c == 46 and is_digit(lch(1)) != 0:     # .5
            lex_number()
            continue
        if is_idstart(c) != 0:
            lex_ident()
            continue
        # operators / punctuation (longest match first)
        c1: uint8 = lch(1)
        c2: uint8 = lch(2)
        okind: int32 = -1
        olen: int32 = 1
        if c == 46 and c1 == 46 and c2 == 46:
            okind = TK_ELLIPSIS
            olen = 3
        elif c == 61 and c1 == 61 and c2 == 61:
            okind = TK_SEQ
            olen = 3
        elif c == 33 and c1 == 61 and c2 == 61:
            okind = TK_SNE
            olen = 3
        elif c == 62 and c1 == 62 and c2 == 62:
            okind = TK_USHR
            olen = 3
        elif c == 61 and c1 == 61:
            okind = TK_EQ
            olen = 2
        elif c == 33 and c1 == 61:
            okind = TK_NE
            olen = 2
        elif c == 60 and c1 == 61:
            okind = TK_LE
            olen = 2
        elif c == 62 and c1 == 61:
            okind = TK_GE
            olen = 2
        elif c == 60 and c1 == 60:
            okind = TK_SHL
            olen = 2
        elif c == 62 and c1 == 62:
            okind = TK_SHR
            olen = 2
        elif c == 38 and c1 == 38:
            okind = TK_ANDAND
            olen = 2
        elif c == 124 and c1 == 124:
            okind = TK_OROR
            olen = 2
        elif c == 43 and c1 == 43:
            okind = TK_INC
            olen = 2
        elif c == 45 and c1 == 45:
            okind = TK_DEC
            olen = 2
        elif c == 43 and c1 == 61:
            okind = TK_PLUSEQ
            olen = 2
        elif c == 45 and c1 == 61:
            okind = TK_MINUSEQ
            olen = 2
        elif c == 42 and c1 == 61:
            okind = TK_STAREQ
            olen = 2
        elif c == 47 and c1 == 61:
            okind = TK_SLASHEQ
            olen = 2
        elif c == 37 and c1 == 61:
            okind = TK_PERCENTEQ
            olen = 2
        elif c == 61 and c1 == 62:
            okind = TK_ARROW
            olen = 2
        elif c == 40:
            okind = TK_LPAREN
        elif c == 41:
            okind = TK_RPAREN
        elif c == 123:
            okind = TK_LBRACE
        elif c == 125:
            okind = TK_RBRACE
        elif c == 91:
            okind = TK_LBRACK
        elif c == 93:
            okind = TK_RBRACK
        elif c == 59:
            okind = TK_SEMI
        elif c == 44:
            okind = TK_COMMA
        elif c == 46:
            okind = TK_DOT
        elif c == 58:
            okind = TK_COLON
        elif c == 63:
            okind = TK_QUESTION
        elif c == 61:
            okind = TK_ASSIGN
        elif c == 43:
            okind = TK_PLUS
        elif c == 45:
            okind = TK_MINUS
        elif c == 42:
            okind = TK_STAR
        elif c == 47:
            okind = TK_SLASH
        elif c == 37:
            okind = TK_PERCENT
        elif c == 60:
            okind = TK_LT
        elif c == 62:
            okind = TK_GT
        elif c == 33:
            okind = TK_NOT
        elif c == 38:
            okind = TK_BAND
        elif c == 124:
            okind = TK_BOR
        elif c == 94:
            okind = TK_BXOR
        elif c == 126:
            okind = TK_BNOT
        if okind < 0:
            lex_i = lex_i + 1
            continue
        # template interpolation: a '}' at brace-depth 0 closes `${ ... }`
        if okind == TK_RBRACE and tmpl_sp > 0 and tmpl_bdepth[tmpl_sp - 1] == 0:
            lex_i = lex_i + 1
            push_tok(TK_RPAREN)
            tmpl_sp = tmpl_sp - 1
            lex_tmpl_continue(0)
            continue
        if tmpl_sp > 0:
            if okind == TK_LBRACE:
                tmpl_bdepth[tmpl_sp - 1] = tmpl_bdepth[tmpl_sp - 1] + 1
            elif okind == TK_RBRACE:
                tmpl_bdepth[tmpl_sp - 1] = tmpl_bdepth[tmpl_sp - 1] - 1
        push_tok(okind)
        lex_i = lex_i + olen
    push_tok(TK_EOF)


# ====================================================================
# PARSER — recursive descent over the token array.
# ====================================================================
def pk() -> int32:
    return cast[int32](tk_kind[tk_pos])


def pk1() -> int32:
    if tk_pos + 1 < n_toks:
        return cast[int32](tk_kind[tk_pos + 1])
    return TK_EOF


def padv() -> int32:
    t: int32 = tk_pos
    tk_pos = tk_pos + 1
    return t


def pexpect(kind: int32):
    if pk() == kind:
        tk_pos = tk_pos + 1
    else:
        set_error(cast[Ptr[uint8]]("SyntaxError: unexpected token"))


def nd_new(kind: int32) -> int32:
    i: int32 = n_nodes
    n_kind[i] = cast[uint8](kind)
    n_a[i] = -1
    n_b[i] = -1
    n_c[i] = -1
    n_d[i] = -1
    n_next[i] = -1
    n_str[i] = -1
    n_op[i] = 0
    n_num[i] = 0.0
    n_nodes = n_nodes + 1
    return i


# forward-declared via mutual recursion (Adder resolves module-wide)
def parse_assign() -> int32:
    return parse_assign_impl()


def parse_expr() -> int32:
    # comma expression: evaluate left, keep right (rare) — support sequence
    e: int32 = parse_assign()
    while pk() == TK_COMMA:
        tk_pos = tk_pos + 1
        e = parse_assign()
    return e


def parse_primary() -> int32:
    k: int32 = pk()
    if k == TK_NUM:
        nd: int32 = nd_new(ND_NUM)
        n_num[nd] = tk_num[tk_pos]
        tk_pos = tk_pos + 1
        return nd
    if k == TK_STR:
        nd2: int32 = nd_new(ND_STR)
        n_str[nd2] = tk_str[tk_pos]
        tk_pos = tk_pos + 1
        return nd2
    if k == TK_REGEX:
        ndr: int32 = nd_new(ND_REGEX)
        n_str[ndr] = tk_str[tk_pos]        # source sid
        n_a[ndr] = tk_str2[tk_pos]         # flags sid
        tk_pos = tk_pos + 1
        return ndr
    if k == TK_TRUE:
        tk_pos = tk_pos + 1
        return nd_new(ND_TRUE)
    if k == TK_FALSE:
        tk_pos = tk_pos + 1
        return nd_new(ND_FALSE)
    if k == TK_NULL:
        tk_pos = tk_pos + 1
        return nd_new(ND_NULL)
    if k == TK_UNDEFINED:
        tk_pos = tk_pos + 1
        return nd_new(ND_UNDEF)
    if k == TK_THIS:
        tk_pos = tk_pos + 1
        return nd_new(ND_THIS)
    if k == TK_IDENT:
        nd3: int32 = nd_new(ND_IDENT)
        n_str[nd3] = tk_str[tk_pos]
        tk_pos = tk_pos + 1
        return nd3
    if k == TK_LPAREN:
        tk_pos = tk_pos + 1
        e: int32 = parse_expr()
        pexpect(TK_RPAREN)
        return e
    if k == TK_LBRACK:
        return parse_array_lit()
    if k == TK_LBRACE:
        return parse_object_lit()
    if k == TK_FUNCTION:
        return parse_function_expr()
    if k == TK_CLASS:
        return parse_class()
    if k == TK_SUPER:
        tk_pos = tk_pos + 1
        return nd_new(ND_SUPER)
    set_error(cast[Ptr[uint8]]("SyntaxError: unexpected token in expression"))
    tk_pos = tk_pos + 1
    return nd_new(ND_UNDEF)


def parse_array_lit() -> int32:
    tk_pos = tk_pos + 1                # [
    nd: int32 = nd_new(ND_ARRAY)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RBRACK and pk() != TK_EOF:
        if pk() == TK_COMMA:
            tk_pos = tk_pos + 1
            continue
        el: int32 = -1
        if pk() == TK_ELLIPSIS:        # spread element [...xs]
            tk_pos = tk_pos + 1
            el = nd_new(ND_SPREAD)
            n_a[el] = parse_assign()
        else:
            el = parse_assign()
        if head < 0:
            head = el
            tail = el
        else:
            n_next[tail] = el
            tail = el
        if pk() == TK_COMMA:
            tk_pos = tk_pos + 1
    pexpect(TK_RBRACK)
    n_a[nd] = head
    return nd


def parse_object_lit() -> int32:
    tk_pos = tk_pos + 1                # {
    nd: int32 = nd_new(ND_OBJECT)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RBRACE and pk() != TK_EOF:
        if pk() == TK_ELLIPSIS:        # object spread {...o}
            tk_pos = tk_pos + 1
            sp: int32 = nd_new(ND_SPREAD)
            n_a[sp] = parse_assign()
            if head < 0:
                head = sp
                tail = sp
            else:
                n_next[tail] = sp
                tail = sp
            if pk() == TK_COMMA:
                tk_pos = tk_pos + 1
            continue
        keysid: int32 = -1
        if pk() == TK_STR:
            keysid = tk_str[tk_pos]
            tk_pos = tk_pos + 1
        elif pk() == TK_IDENT:
            keysid = tk_str[tk_pos]
            tk_pos = tk_pos + 1
        elif pk() == TK_NUM:
            keysid = num_to_strid(tk_num[tk_pos])
            tk_pos = tk_pos + 1
        else:
            # keyword-as-key
            keysid = str_from_cstr(cast[Ptr[uint8]]("key"))
            tk_pos = tk_pos + 1
        prop: int32 = nd_new(ND_PROP)
        n_str[prop] = keysid
        # shorthand {x}  ==  {x: x}
        if pk() == TK_COLON:
            tk_pos = tk_pos + 1
            n_a[prop] = parse_assign()
        else:
            sh: int32 = nd_new(ND_IDENT)
            n_str[sh] = keysid
            n_a[prop] = sh
        if head < 0:
            head = prop
            tail = prop
        else:
            n_next[tail] = prop
            tail = prop
        if pk() == TK_COMMA:
            tk_pos = tk_pos + 1
    pexpect(TK_RBRACE)
    n_a[nd] = head
    return nd


def parse_params() -> int32:
    # returns head of param list (ND_PARAM chain). Assumes cursor at '('
    pexpect(TK_LPAREN)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RPAREN and pk() != TK_EOF:
        pnode: int32 = nd_new(ND_PARAM)
        if pk() == TK_ELLIPSIS:            # rest parameter ...args
            tk_pos = tk_pos + 1
            n_op[pnode] = 1
        if pk() == TK_IDENT:
            n_str[pnode] = tk_str[tk_pos]
            tk_pos = tk_pos + 1
        else:
            tk_pos = tk_pos + 1
        if pk() == TK_ASSIGN:              # default value
            tk_pos = tk_pos + 1
            n_a[pnode] = parse_assign()
        if head < 0:
            head = pnode
            tail = pnode
        else:
            n_next[tail] = pnode
            tail = pnode
        if pk() == TK_COMMA:
            tk_pos = tk_pos + 1
    pexpect(TK_RPAREN)
    return head


def parse_function_expr() -> int32:
    tk_pos = tk_pos + 1                # 'function'
    nd: int32 = nd_new(ND_FUNC)
    if pk() == TK_IDENT:
        n_str[nd] = tk_str[tk_pos]
        tk_pos = tk_pos + 1
    n_a[nd] = parse_params()
    n_b[nd] = parse_block()
    return nd


# ---- arrow functions ----
def scan_arrow_params() -> int32:
    # tk_pos at TK_LPAREN. Return 1 if the matching ')' is immediately '=>'.
    i: int32 = tk_pos
    depth: int32 = 0
    while i < n_toks:
        kk: int32 = cast[int32](tk_kind[i])
        if kk == TK_LPAREN:
            depth = depth + 1
        elif kk == TK_RPAREN:
            depth = depth - 1
            if depth == 0:
                if i + 1 < n_toks and cast[int32](tk_kind[i + 1]) == TK_ARROW:
                    return 1
                return 0
        elif kk == TK_EOF:
            return 0
        i = i + 1
    return 0


def parse_arrow_body(nd: int32):
    pexpect(TK_ARROW)
    if pk() == TK_LBRACE:
        n_b[nd] = parse_block()
        n_c[nd] = 0
    else:
        n_b[nd] = parse_assign()
        n_c[nd] = 1                        # concise expression body


def parse_arrow_single() -> int32:
    nd: int32 = nd_new(ND_ARROW)
    p: int32 = nd_new(ND_PARAM)
    n_str[p] = tk_str[tk_pos]
    tk_pos = tk_pos + 1                    # the single ident param
    n_a[nd] = p
    parse_arrow_body(nd)
    return nd


def parse_arrow_paren() -> int32:
    nd: int32 = nd_new(ND_ARROW)
    n_a[nd] = parse_params()
    parse_arrow_body(nd)
    return nd


# ---- classes ----
def parse_class() -> int32:
    tk_pos = tk_pos + 1                # 'class'
    nd: int32 = nd_new(ND_CLASS)
    if pk() == TK_IDENT:
        n_str[nd] = tk_str[tk_pos]
        tk_pos = tk_pos + 1
    if pk() == TK_EXTENDS:
        tk_pos = tk_pos + 1
        n_a[nd] = parse_call_member(parse_primary())   # superclass expression
    pexpect(TK_LBRACE)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RBRACE and pk() != TK_EOF and err_flag == 0:
        if pk() == TK_SEMI:
            tk_pos = tk_pos + 1
            continue
        m: int32 = nd_new(ND_METHOD)
        # 'static' modifier (lexed as an identifier)
        if pk() == TK_IDENT and str_eq_cstr(tk_str[tk_pos], cast[Ptr[uint8]]("static")) != 0 and pk1() != TK_LPAREN and pk1() != TK_ASSIGN:
            n_op[m] = 1
            tk_pos = tk_pos + 1
        # method name
        if pk() == TK_IDENT:
            n_str[m] = tk_str[tk_pos]
            tk_pos = tk_pos + 1
        else:
            tk_pos = tk_pos + 1        # keyword-as-name: skip (rare)
        f: int32 = nd_new(ND_FUNC)
        n_str[f] = n_str[m]
        n_a[f] = parse_params()
        n_b[f] = parse_block()
        n_a[m] = f
        if head < 0:
            head = m
            tail = m
        else:
            n_next[tail] = m
            tail = m
    pexpect(TK_RBRACE)
    n_b[nd] = head
    return nd


def parse_class_decl() -> int32:
    cls: int32 = parse_class()
    nd: int32 = nd_new(ND_CLASSDECL)
    n_str[nd] = n_str[cls]
    n_a[nd] = cls
    return nd


# member / call / new suffix parsing
def parse_call_member(base: int32) -> int32:
    e: int32 = base
    while True:
        k: int32 = pk()
        if k == TK_DOT:
            tk_pos = tk_pos + 1
            m: int32 = nd_new(ND_MEMBER)
            n_a[m] = e
            if pk() == TK_IDENT:
                n_str[m] = tk_str[tk_pos]
                tk_pos = tk_pos + 1
            else:
                # allow keyword-like property names
                n_str[m] = str_from_cstr(cast[Ptr[uint8]]("prop"))
                tk_pos = tk_pos + 1
            e = m
        elif k == TK_LBRACK:
            tk_pos = tk_pos + 1
            ix: int32 = nd_new(ND_INDEX)
            n_a[ix] = e
            n_b[ix] = parse_expr()
            pexpect(TK_RBRACK)
            e = ix
        elif k == TK_LPAREN:
            c: int32 = nd_new(ND_CALL)
            n_a[c] = e
            n_b[c] = parse_args()
            e = c
        else:
            break
    return e


def parse_args() -> int32:
    tk_pos = tk_pos + 1                # (
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RPAREN and pk() != TK_EOF:
        a: int32 = -1
        if pk() == TK_ELLIPSIS:        # spread argument f(...xs)
            tk_pos = tk_pos + 1
            a = nd_new(ND_SPREAD)
            n_a[a] = parse_assign()
        else:
            a = parse_assign()
        if head < 0:
            head = a
            tail = a
        else:
            n_next[tail] = a
            tail = a
        if pk() == TK_COMMA:
            tk_pos = tk_pos + 1
    pexpect(TK_RPAREN)
    return head


def parse_new() -> int32:
    if pk() == TK_NEW:
        tk_pos = tk_pos + 1
        callee: int32 = parse_member_only(parse_primary())
        nd: int32 = nd_new(ND_NEW)
        n_a[nd] = callee
        if pk() == TK_LPAREN:
            n_b[nd] = parse_args()
        else:
            n_b[nd] = -1
        return parse_call_member(nd)
    return parse_call_member(parse_primary())


def parse_member_only(base: int32) -> int32:
    # member access without calls (for `new X.Y()` callee)
    e: int32 = base
    while True:
        if pk() == TK_DOT:
            tk_pos = tk_pos + 1
            m: int32 = nd_new(ND_MEMBER)
            n_a[m] = e
            n_str[m] = tk_str[tk_pos]
            tk_pos = tk_pos + 1
            e = m
        else:
            break
    return e


def parse_unary() -> int32:
    k: int32 = pk()
    if k == TK_MINUS:
        tk_pos = tk_pos + 1
        u: int32 = nd_new(ND_UNARY)
        n_op[u] = U_NEG
        n_a[u] = parse_unary()
        return u
    if k == TK_PLUS:
        tk_pos = tk_pos + 1
        u2: int32 = nd_new(ND_UNARY)
        n_op[u2] = U_POS
        n_a[u2] = parse_unary()
        return u2
    if k == TK_NOT:
        tk_pos = tk_pos + 1
        u3: int32 = nd_new(ND_UNARY)
        n_op[u3] = U_NOT
        n_a[u3] = parse_unary()
        return u3
    if k == TK_BNOT:
        tk_pos = tk_pos + 1
        u4: int32 = nd_new(ND_UNARY)
        n_op[u4] = U_BNOT
        n_a[u4] = parse_unary()
        return u4
    if k == TK_TYPEOF:
        tk_pos = tk_pos + 1
        u5: int32 = nd_new(ND_UNARY)
        n_op[u5] = U_TYPEOF
        n_a[u5] = parse_unary()
        return u5
    if k == TK_INC or k == TK_DEC:
        tk_pos = tk_pos + 1
        up: int32 = nd_new(ND_UPDATE)
        if k == TK_INC:
            n_op[up] = 1
        else:
            n_op[up] = -1
        n_b[up] = 1                    # prefix
        n_a[up] = parse_unary()
        return up
    return parse_postfix()


def parse_postfix() -> int32:
    e: int32 = parse_new()
    if pk() == TK_INC or pk() == TK_DEC:
        up: int32 = nd_new(ND_UPDATE)
        if pk() == TK_INC:
            n_op[up] = 1
        else:
            n_op[up] = -1
        n_b[up] = 0                    # postfix
        n_a[up] = e
        tk_pos = tk_pos + 1
        return up
    return e


# binary operator precedence
def tok_binop(k: int32) -> int32:
    if k == TK_STAR:
        return OP_MUL
    if k == TK_SLASH:
        return OP_DIV
    if k == TK_PERCENT:
        return OP_MOD
    if k == TK_PLUS:
        return OP_ADD
    if k == TK_MINUS:
        return OP_SUB
    if k == TK_SHL:
        return OP_SHL
    if k == TK_SHR:
        return OP_SHR
    if k == TK_USHR:
        return OP_USHR
    if k == TK_LT:
        return OP_LT
    if k == TK_GT:
        return OP_GT
    if k == TK_LE:
        return OP_LE
    if k == TK_GE:
        return OP_GE
    if k == TK_INSTANCEOF:
        return OP_INSTANCEOF
    if k == TK_IN:
        return OP_IN
    if k == TK_EQ:
        return OP_EQ
    if k == TK_NE:
        return OP_NE
    if k == TK_SEQ:
        return OP_SEQ
    if k == TK_SNE:
        return OP_SNE
    if k == TK_BAND:
        return OP_BAND
    if k == TK_BXOR:
        return OP_BXOR
    if k == TK_BOR:
        return OP_BOR
    return -1


def binop_prec(op: int32) -> int32:
    if op == OP_MUL or op == OP_DIV or op == OP_MOD:
        return 11
    if op == OP_ADD or op == OP_SUB:
        return 10
    if op == OP_SHL or op == OP_SHR or op == OP_USHR:
        return 9
    if op == OP_LT or op == OP_GT or op == OP_LE or op == OP_GE or op == OP_INSTANCEOF or op == OP_IN:
        return 8
    if op == OP_EQ or op == OP_NE or op == OP_SEQ or op == OP_SNE:
        return 7
    if op == OP_BAND:
        return 6
    if op == OP_BXOR:
        return 5
    if op == OP_BOR:
        return 4
    return -1


def parse_binary(minprec: int32) -> int32:
    left: int32 = parse_unary()
    while True:
        k: int32 = pk()
        op: int32 = tok_binop(k)
        if op < 0:
            break
        prec: int32 = binop_prec(op)
        if prec < minprec:
            break
        tk_pos = tk_pos + 1
        right: int32 = parse_binary(prec + 1)
        b: int32 = nd_new(ND_BINOP)
        n_op[b] = op
        n_a[b] = left
        n_b[b] = right
        left = b
    return left


def parse_logical_and() -> int32:
    left: int32 = parse_binary(0)
    while pk() == TK_ANDAND:
        tk_pos = tk_pos + 1
        r: int32 = parse_binary(0)
        l: int32 = nd_new(ND_LOGICAL)
        n_op[l] = 0                    # &&
        n_a[l] = left
        n_b[l] = r
        left = l
    return left


def parse_logical_or() -> int32:
    left: int32 = parse_logical_and()
    while pk() == TK_OROR:
        tk_pos = tk_pos + 1
        r: int32 = parse_logical_and()
        l: int32 = nd_new(ND_LOGICAL)
        n_op[l] = 1                    # ||
        n_a[l] = left
        n_b[l] = r
        left = l
    return left


def parse_ternary() -> int32:
    c: int32 = parse_logical_or()
    if pk() == TK_QUESTION:
        tk_pos = tk_pos + 1
        t: int32 = nd_new(ND_TERNARY)
        n_a[t] = c
        n_b[t] = parse_assign()
        pexpect(TK_COLON)
        n_c[t] = parse_assign()
        return t
    return c


def is_assign_tok(k: int32) -> int32:
    if k == TK_ASSIGN or k == TK_PLUSEQ or k == TK_MINUSEQ or k == TK_STAREQ or k == TK_SLASHEQ or k == TK_PERCENTEQ:
        return 1
    return 0


def assign_op(k: int32) -> int32:
    if k == TK_PLUSEQ:
        return OP_ADD
    if k == TK_MINUSEQ:
        return OP_SUB
    if k == TK_STAREQ:
        return OP_MUL
    if k == TK_SLASHEQ:
        return OP_DIV
    if k == TK_PERCENTEQ:
        return OP_MOD
    return -1                          # plain '='


def parse_assign_impl() -> int32:
    # arrow functions: `x => ...` and `(a, b) => ...`
    if pk() == TK_IDENT and pk1() == TK_ARROW:
        return parse_arrow_single()
    if pk() == TK_LPAREN and scan_arrow_params() != 0:
        return parse_arrow_paren()
    left: int32 = parse_ternary()
    k: int32 = pk()
    if is_assign_tok(k) != 0:
        tk_pos = tk_pos + 1
        nd: int32 = nd_new(ND_ASSIGN)
        n_op[nd] = assign_op(k)
        n_a[nd] = left
        n_b[nd] = parse_assign()
        return nd
    return left


# ---- statements ----
def parse_block() -> int32:
    pexpect(TK_LBRACE)
    nd: int32 = nd_new(ND_BLOCK)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RBRACE and pk() != TK_EOF:
        s: int32 = parse_statement()
        if s < 0:
            continue
        if head < 0:
            head = s
            tail = s
        else:
            n_next[tail] = s
            tail = s
    pexpect(TK_RBRACE)
    n_a[nd] = head
    return nd


# ---- destructuring patterns ----
def parse_pattern() -> int32:
    if pk() == TK_LBRACK:
        return parse_array_pattern()
    if pk() == TK_LBRACE:
        return parse_object_pattern()
    return -1


def parse_array_pattern() -> int32:
    tk_pos = tk_pos + 1                # [
    nd: int32 = nd_new(ND_ARRPAT)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RBRACK and pk() != TK_EOF:
        e: int32 = nd_new(ND_PATELEM)
        if pk() == TK_COMMA:           # elision (hole)
            tk_pos = tk_pos + 1
        else:
            if pk() == TK_ELLIPSIS:
                tk_pos = tk_pos + 1
                n_op[e] = 1            # rest element
            if pk() == TK_LBRACK or pk() == TK_LBRACE:
                n_b[e] = parse_pattern()
            elif pk() == TK_IDENT:
                n_str[e] = tk_str[tk_pos]
                tk_pos = tk_pos + 1
            if pk() == TK_ASSIGN:
                tk_pos = tk_pos + 1
                n_a[e] = parse_assign()
            if pk() == TK_COMMA:
                tk_pos = tk_pos + 1
        if head < 0:
            head = e
            tail = e
        else:
            n_next[tail] = e
            tail = e
    pexpect(TK_RBRACK)
    n_a[nd] = head
    return nd


def parse_object_pattern() -> int32:
    tk_pos = tk_pos + 1                # {
    nd: int32 = nd_new(ND_OBJPAT)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_RBRACE and pk() != TK_EOF:
        e: int32 = nd_new(ND_PATELEM)
        if pk() == TK_ELLIPSIS:        # object rest {a, ...others}
            tk_pos = tk_pos + 1
            n_op[e] = 1
            if pk() == TK_IDENT:
                n_c[e] = tk_str[tk_pos]
                tk_pos = tk_pos + 1
            if head < 0:
                head = e
                tail = e
            else:
                n_next[tail] = e
                tail = e
            if pk() == TK_COMMA:
                tk_pos = tk_pos + 1
            continue
        key: int32 = -1
        if pk() == TK_IDENT or pk() == TK_STR:
            key = tk_str[tk_pos]
            tk_pos = tk_pos + 1
        else:
            tk_pos = tk_pos + 1
        n_str[e] = key                 # source key
        n_c[e] = key                   # target name (default: same)
        if pk() == TK_COLON:
            tk_pos = tk_pos + 1
            if pk() == TK_LBRACK or pk() == TK_LBRACE:
                n_b[e] = parse_pattern()
                n_c[e] = -1
            elif pk() == TK_IDENT:
                n_c[e] = tk_str[tk_pos]
                tk_pos = tk_pos + 1
        if pk() == TK_ASSIGN:
            tk_pos = tk_pos + 1
            n_a[e] = parse_assign()
        if head < 0:
            head = e
            tail = e
        else:
            n_next[tail] = e
            tail = e
        if pk() == TK_COMMA:
            tk_pos = tk_pos + 1
    pexpect(TK_RBRACE)
    n_a[nd] = head
    return nd


def parse_var_decl() -> int32:
    k: int32 = pk()
    tk_pos = tk_pos + 1
    nd: int32 = nd_new(ND_VAR)
    if k == TK_CONST:
        n_op[nd] = 2
    elif k == TK_LET:
        n_op[nd] = 1
    else:
        n_op[nd] = 0
    head: int32 = -1
    tail: int32 = -1
    while True:
        d: int32 = nd_new(ND_DECLTOR)
        if pk() == TK_LBRACK or pk() == TK_LBRACE:
            n_b[d] = parse_pattern()   # destructuring target
        elif pk() == TK_IDENT:
            n_str[d] = tk_str[tk_pos]
            tk_pos = tk_pos + 1
        else:
            set_error(cast[Ptr[uint8]]("SyntaxError: expected identifier"))
            break
        if pk() == TK_ASSIGN:
            tk_pos = tk_pos + 1
            n_a[d] = parse_assign()
        if head < 0:
            head = d
            tail = d
        else:
            n_next[tail] = d
            tail = d
        if pk() == TK_COMMA:
            tk_pos = tk_pos + 1
            continue
        break
    n_a[nd] = head
    return nd


def semi_opt():
    if pk() == TK_SEMI:
        tk_pos = tk_pos + 1


def parse_statement() -> int32:
    k: int32 = pk()
    if k == TK_LBRACE:
        return parse_block()
    if k == TK_SEMI:
        tk_pos = tk_pos + 1
        return nd_new(ND_EMPTY)
    if k == TK_VAR or k == TK_LET or k == TK_CONST:
        d: int32 = parse_var_decl()
        semi_opt()
        return d
    if k == TK_FUNCTION:
        return parse_func_decl()
    if k == TK_IF:
        return parse_if()
    if k == TK_WHILE:
        return parse_while()
    if k == TK_DO:
        return parse_dowhile()
    if k == TK_FOR:
        return parse_for()
    if k == TK_RETURN:
        tk_pos = tk_pos + 1
        r: int32 = nd_new(ND_RETURN)
        if pk() != TK_SEMI and pk() != TK_RBRACE and pk() != TK_EOF:
            n_a[r] = parse_expr()
        semi_opt()
        return r
    if k == TK_TRY:
        return parse_try()
    if k == TK_THROW:
        tk_pos = tk_pos + 1
        th: int32 = nd_new(ND_THROW)
        n_a[th] = parse_expr()
        semi_opt()
        return th
    if k == TK_CLASS:
        return parse_class_decl()
    if k == TK_BREAK:
        tk_pos = tk_pos + 1
        semi_opt()
        return nd_new(ND_BREAK)
    if k == TK_CONTINUE:
        tk_pos = tk_pos + 1
        semi_opt()
        return nd_new(ND_CONTINUE)
    # expression statement
    es: int32 = nd_new(ND_EXPRSTMT)
    n_a[es] = parse_expr()
    semi_opt()
    return es


def parse_func_decl() -> int32:
    tk_pos = tk_pos + 1                # 'function'
    nd: int32 = nd_new(ND_FUNCDECL)
    if pk() == TK_IDENT:
        n_str[nd] = tk_str[tk_pos]
        tk_pos = tk_pos + 1
    fexpr: int32 = nd_new(ND_FUNC)
    n_str[fexpr] = n_str[nd]
    n_a[fexpr] = parse_params()
    n_b[fexpr] = parse_block()
    n_a[nd] = fexpr
    return nd


def parse_if() -> int32:
    tk_pos = tk_pos + 1                # 'if'
    pexpect(TK_LPAREN)
    nd: int32 = nd_new(ND_IF)
    n_a[nd] = parse_expr()
    pexpect(TK_RPAREN)
    n_b[nd] = parse_statement()
    if pk() == TK_ELSE:
        tk_pos = tk_pos + 1
        n_c[nd] = parse_statement()
    return nd


def parse_while() -> int32:
    tk_pos = tk_pos + 1
    pexpect(TK_LPAREN)
    nd: int32 = nd_new(ND_WHILE)
    n_a[nd] = parse_expr()
    pexpect(TK_RPAREN)
    n_b[nd] = parse_statement()
    return nd


def parse_dowhile() -> int32:
    tk_pos = tk_pos + 1                # 'do'
    nd: int32 = nd_new(ND_DOWHILE)
    n_b[nd] = parse_statement()
    pexpect(TK_WHILE)
    pexpect(TK_LPAREN)
    n_a[nd] = parse_expr()
    pexpect(TK_RPAREN)
    semi_opt()
    return nd


def parse_try() -> int32:
    tk_pos = tk_pos + 1                # 'try'
    nd: int32 = nd_new(ND_TRY)
    n_a[nd] = parse_block()            # try block
    if pk() == TK_CATCH:
        tk_pos = tk_pos + 1
        if pk() == TK_LPAREN:
            tk_pos = tk_pos + 1
            if pk() == TK_IDENT:
                n_str[nd] = tk_str[tk_pos]   # catch binding name
                tk_pos = tk_pos + 1
            pexpect(TK_RPAREN)
        n_b[nd] = parse_block()        # catch block
    if pk() == TK_FINALLY:
        tk_pos = tk_pos + 1
        n_c[nd] = parse_block()        # finally block
    return nd


def parse_for() -> int32:
    tk_pos = tk_pos + 1                # 'for'
    pexpect(TK_LPAREN)
    # detect for-in: <decl-or-ident> 'in'
    init: int32 = -1
    is_decl: int32 = 0
    if pk() == TK_VAR or pk() == TK_LET or pk() == TK_CONST:
        is_decl = 1
        init = parse_var_decl()
    elif pk() != TK_SEMI:
        init = nd_new(ND_EXPRSTMT)
        n_a[init] = parse_expr()
    if pk() == TK_IN:
        # for-in
        tk_pos = tk_pos + 1
        nd: int32 = nd_new(ND_FORIN)
        n_op[nd] = is_decl
        n_a[nd] = init                 # var decl or expr stmt (target)
        n_b[nd] = parse_expr()         # object
        pexpect(TK_RPAREN)
        n_c[nd] = parse_statement()
        return nd
    pexpect(TK_SEMI)
    nd2: int32 = nd_new(ND_FOR)
    n_a[nd2] = init
    if pk() != TK_SEMI:
        n_b[nd2] = parse_expr()
    pexpect(TK_SEMI)
    if pk() != TK_RPAREN:
        n_c[nd2] = parse_expr()
    pexpect(TK_RPAREN)
    n_op[nd2] = is_decl
    n_d[nd2] = parse_statement()
    return nd2


def parse_program() -> int32:
    tk_pos = 0
    nd: int32 = nd_new(ND_BLOCK)
    head: int32 = -1
    tail: int32 = -1
    while pk() != TK_EOF and err_flag == 0:
        s: int32 = parse_statement()
        if head < 0:
            head = s
            tail = s
        else:
            n_next[tail] = s
            tail = s
    n_a[nd] = head
    return nd


# ====================================================================
# EVALUATOR.
# ====================================================================
# conversions
def to_bool(h: int32) -> int32:
    t: int32 = tag_of(h)
    if t == TAG_UNDEF or t == TAG_NULL:
        return 0
    if t == TAG_BOOL:
        if h == 2:
            return 1
        return 0
    if t == TAG_NUM:
        x: float64 = v_num[h]
        if x == 0.0 or is_nan(x) != 0:
            return 0
        return 1
    if t == TAG_STR:
        if str_len(strid_of(h)) == 0:
            return 0
        return 1
    return 1                            # objects are truthy


def to_number(h: int32) -> float64:
    t: int32 = tag_of(h)
    if t == TAG_NUM:
        return v_num[h]
    if t == TAG_BOOL:
        if h == 2:
            return 1.0
        return 0.0
    if t == TAG_NULL:
        return 0.0
    if t == TAG_UNDEF:
        return 0.0 / 0.0
    if t == TAG_STR:
        sid: int32 = strid_of(h)
        if str_len(sid) == 0:
            return 0.0
        return parse_num_bytes(str_ptr(sid), str_len(sid))
    return 0.0 / 0.0


def to_int32(h: int32) -> int32:
    x: float64 = to_number(h)
    if is_nan(x) != 0 or is_inf(x) != 0:
        return 0
    return cast[int32](cast[int64](f_trunc(x)))


def to_uint32(h: int32) -> uint32:
    return cast[uint32](to_int32(h))


# display: append a value's string form via emit_c (uses current emit_tgt)
def display_val(h: int32):
    t: int32 = tag_of(h)
    if t == TAG_UNDEF:
        emit_cstr(cast[Ptr[uint8]]("undefined"))
    elif t == TAG_NULL:
        emit_cstr(cast[Ptr[uint8]]("null"))
    elif t == TAG_BOOL:
        if h == 2:
            emit_cstr(cast[Ptr[uint8]]("true"))
        else:
            emit_cstr(cast[Ptr[uint8]]("false"))
    elif t == TAG_NUM:
        emit_num(v_num[h])
    elif t == TAG_STR:
        emit_strid(strid_of(h))
    else:
        display_obj(h)


def display_obj(h: int32):
    o: int32 = objid_of(h)
    if obj_re_prog[o] >= 0:                   # regex literal: /source/flags
        emit_c(47)
        emit_strid(strid_of(obj_get_cstr(o, cast[Ptr[uint8]]("source"))))
        emit_c(47)
        emit_strid(strid_of(obj_get_cstr(o, cast[Ptr[uint8]]("flags"))))
        return
    if cast[int32](obj_kind[o]) == OK_FUNC:
        emit_cstr(cast[Ptr[uint8]]("function"))
        return
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        # console.log prints arrays as: [ a, b, c ] — but our gate uses join;
        # for plain display use comma-separated bracketed form.
        emit_c(91)
        i: int32 = 0
        while i < arr_len[o]:
            if i > 0:
                emit_cstr(cast[Ptr[uint8]](", "))
            display_val_quoted(arr_get(o, i))
            i = i + 1
        emit_c(93)
        return
    # error-like object (has both name and message): print "Name: message".
    # Use allocation-free lookups: we may be mid string-build (emit_tgt==0).
    if obj_find_prop_cstr(o, cast[Ptr[uint8]]("name")) >= 0 and obj_find_prop_cstr(o, cast[Ptr[uint8]]("message")) >= 0:
        nmv: int32 = obj_get_cstr(o, cast[Ptr[uint8]]("name"))
        msv: int32 = obj_get_cstr(o, cast[Ptr[uint8]]("message"))
        if tag_of(nmv) == TAG_STR:
            emit_strid(strid_of(nmv))
        else:
            display_val(nmv)
        if tag_of(msv) == TAG_STR and str_len(strid_of(msv)) > 0:
            emit_cstr(cast[Ptr[uint8]](": "))
            emit_strid(strid_of(msv))
        return
    # plain object: { key: value, ... }
    emit_cstr(cast[Ptr[uint8]]("{ "))
    p: int32 = obj_head[o]
    first: int32 = 1
    # props are stored newest-first; reverse for stable output
    display_obj_props(o)
    emit_cstr(cast[Ptr[uint8]](" }"))


def display_obj_props(o: int32):
    # print in insertion order by walking a reversed view (simple: collect)
    # gather into a temp stack in ax? Use recursion to reverse.
    display_props_rec(obj_head[o], 1)


def display_props_rec(p: int32, first: int32):
    if p < 0:
        return
    display_props_rec(p_next[p], 0)
    if first == 0:
        # this is not the deepest; separators handled below
        pass
    emit_strid(p_key[p])
    emit_cstr(cast[Ptr[uint8]](": "))
    display_val_quoted(p_val[p])
    if p_next[p] >= 0:
        # not the last-in-print-order? Actually reversed: print comma if this
        # node has a predecessor in print order (i.e., it's not the first).
        pass


def display_val_quoted(h: int32):
    if tag_of(h) == TAG_STR:
        emit_c(39)
        emit_strid(strid_of(h))
        emit_c(39)
    else:
        display_val(h)


# to a fresh string value (for String(), concat, JSON)
def to_string_val(h: int32) -> int32:
    if tag_of(h) == TAG_STR:
        return h
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    display_val(h)
    id: int32 = bld_end()
    emit_tgt = save
    return v_string_id(id)


def strid_concat(a: int32, b: int32) -> int32:
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    emit_strid(a)
    emit_strid(b)
    id: int32 = bld_end()
    emit_tgt = save
    return id


# strict equality
def strict_eq(a: int32, b: int32) -> int32:
    ta: int32 = tag_of(a)
    tb: int32 = tag_of(b)
    if ta != tb:
        return 0
    if ta == TAG_UNDEF or ta == TAG_NULL:
        return 1
    if ta == TAG_BOOL:
        if a == b:
            return 1
        return 0
    if ta == TAG_NUM:
        if v_num[a] == v_num[b]:
            return 1
        return 0
    if ta == TAG_STR:
        return str_eq(strid_of(a), strid_of(b))
    # objects: reference identity
    if objid_of(a) == objid_of(b):
        return 1
    return 0


def loose_eq(a: int32, b: int32) -> int32:
    ta: int32 = tag_of(a)
    tb: int32 = tag_of(b)
    if ta == tb:
        return strict_eq(a, b)
    # null == undefined
    if (ta == TAG_NULL and tb == TAG_UNDEF) or (ta == TAG_UNDEF and tb == TAG_NULL):
        return 1
    if (ta == TAG_NULL or ta == TAG_UNDEF) or (tb == TAG_NULL or tb == TAG_UNDEF):
        return 0
    # number/string/bool coercions -> number compare
    if ta == TAG_OBJ or tb == TAG_OBJ:
        # compare via string for one object side (arrays/objs) — approx
        sa: int32 = to_string_val(a)
        sb: int32 = to_string_val(b)
        return str_eq(strid_of(sa), strid_of(sb))
    xa: float64 = to_number(a)
    xb: float64 = to_number(b)
    if xa == xb:
        return 1
    return 0


# member get on any value (properties + .length)
def prop_len_key() -> int32:
    return 0


LEN_STR: int32 = -1

def member_get(objv: int32, key_sid: int32) -> int32:
    t: int32 = tag_of(objv)
    if t == TAG_STR:
        if str_eq_cstr(key_sid, cast[Ptr[uint8]]("length")) != 0:
            return v_number(cast[float64](str_len(strid_of(objv))))
        return v_undef()
    if t == TAG_OBJ:
        o: int32 = objid_of(objv)
        if cast[int32](obj_kind[o]) == OK_ARRAY:
            if str_eq_cstr(key_sid, cast[Ptr[uint8]]("length")) != 0:
                return v_number(cast[float64](arr_len[o]))
            # numeric index as string?
            idx: int32 = str_as_index(key_sid)
            if idx >= 0:
                return arr_get(o, idx)
        # own property, then walk the [[Prototype]] chain
        cur: int32 = o
        while cur >= 0:
            pp: int32 = obj_find_prop(cur, key_sid)
            if pp >= 0:
                return p_val[pp]
            cur = obj_proto[cur]
        return v_undef()
    if t == TAG_UNDEF or t == TAG_NULL:
        throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("cannot read property of null or undefined"))
        return v_undef()
    return v_undef()


def str_as_index(sid: int32) -> int32:
    n: int32 = str_len(sid)
    if n == 0:
        return -1
    i: int32 = 0
    v: int32 = 0
    while i < n:
        c: uint8 = str_char(sid, i)
        if is_digit(c) == 0:
            return -1
        v = v * 10 + (cast[int32](c) - 48)
        i = i + 1
    return v


def member_set(objv: int32, key_sid: int32, val: int32):
    if tag_of(objv) != TAG_OBJ:
        return
    o: int32 = objid_of(objv)
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        if str_eq_cstr(key_sid, cast[Ptr[uint8]]("length")) != 0:
            return
        idx: int32 = str_as_index(key_sid)
        if idx >= 0:
            arr_set(o, idx, val)
            return
    obj_set(o, key_sid, val)


# binary numeric/string op
def eval_binop(op: int32, a: int32, b: int32) -> int32:
    if op == OP_ADD:
        # if either is a string -> string concat
        if tag_of(a) == TAG_STR or tag_of(b) == TAG_STR:
            sa: int32 = to_string_val(a)
            sb: int32 = to_string_val(b)
            return v_string_id(strid_concat(strid_of(sa), strid_of(sb)))
        if tag_of(a) == TAG_OBJ or tag_of(b) == TAG_OBJ:
            sa2: int32 = to_string_val(a)
            sb2: int32 = to_string_val(b)
            return v_string_id(strid_concat(strid_of(sa2), strid_of(sb2)))
        return v_number(to_number(a) + to_number(b))
    if op == OP_SUB:
        return v_number(to_number(a) - to_number(b))
    if op == OP_MUL:
        return v_number(to_number(a) * to_number(b))
    if op == OP_DIV:
        return v_number(to_number(a) / to_number(b))
    if op == OP_MOD:
        return v_number(f_fmod(to_number(a), to_number(b)))
    if op == OP_LT:
        return cmp_op(a, b, 0)
    if op == OP_GT:
        return cmp_op(a, b, 1)
    if op == OP_LE:
        return cmp_op(a, b, 2)
    if op == OP_GE:
        return cmp_op(a, b, 3)
    if op == OP_EQ:
        return v_boolv(loose_eq(a, b))
    if op == OP_NE:
        return v_boolv(1 - loose_eq(a, b))
    if op == OP_SEQ:
        return v_boolv(strict_eq(a, b))
    if op == OP_SNE:
        return v_boolv(1 - strict_eq(a, b))
    if op == OP_BAND:
        return v_number(cast[float64](to_int32(a) & to_int32(b)))
    if op == OP_BOR:
        return v_number(cast[float64](to_int32(a) | to_int32(b)))
    if op == OP_BXOR:
        return v_number(cast[float64](to_int32(a) ^ to_int32(b)))
    if op == OP_SHL:
        sh: int32 = to_int32(b) & 31
        return v_number(cast[float64](to_int32(a) << sh))
    if op == OP_SHR:
        sh2: int32 = to_int32(b) & 31
        return v_number(cast[float64](to_int32(a) >> sh2))
    if op == OP_USHR:
        sh3: uint32 = to_uint32(b) & 31
        uv: uint32 = to_uint32(a) >> sh3
        return v_number(cast[float64](uv))
    if op == OP_INSTANCEOF:
        return v_boolv(instance_of(a, b))
    if op == OP_IN:
        return v_boolv(op_in(a, b))
    return v_undef()


def instance_of(v: int32, ctor: int32) -> int32:
    if tag_of(v) != TAG_OBJ:
        return 0
    if is_callable(ctor) == 0:
        return 0
    protov: int32 = obj_get(objid_of(ctor), str_from_cstr(cast[Ptr[uint8]]("prototype")))
    if tag_of(protov) != TAG_OBJ:
        return 0
    target: int32 = objid_of(protov)
    cur: int32 = obj_proto[objid_of(v)]
    while cur >= 0:
        if cur == target:
            return 1
        cur = obj_proto[cur]
    return 0


def op_in(keyv: int32, objv: int32) -> int32:
    if tag_of(objv) != TAG_OBJ:
        return 0
    ks: int32 = strid_of(to_string_val(keyv))
    o: int32 = objid_of(objv)
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        idx: int32 = str_as_index(ks)
        if idx >= 0 and idx < arr_len[o]:
            return 1
    if obj_find_prop(o, ks) >= 0:
        return 1
    return 0


def cmp_op(a: int32, b: int32, kind: int32) -> int32:
    # string vs string -> lexicographic; else numeric
    if tag_of(a) == TAG_STR and tag_of(b) == TAG_STR:
        c: int32 = str_cmp(strid_of(a), strid_of(b))
        if kind == 0:
            return v_boolv(c < 0)
        if kind == 1:
            return v_boolv(c > 0)
        if kind == 2:
            return v_boolv(c <= 0)
        return v_boolv(c >= 0)
    xa: float64 = to_number(a)
    xb: float64 = to_number(b)
    if is_nan(xa) != 0 or is_nan(xb) != 0:
        return v_boolv(0)
    if kind == 0:
        return v_boolv(xa < xb)
    if kind == 1:
        return v_boolv(xa > xb)
    if kind == 2:
        return v_boolv(xa <= xb)
    return v_boolv(xa >= xb)


def str_cmp(a: int32, b: int32) -> int32:
    la: int32 = str_len(a)
    lb: int32 = str_len(b)
    n: int32 = la
    if lb < n:
        n = lb
    i: int32 = 0
    while i < n:
        ca: uint8 = str_char(a, i)
        cb: uint8 = str_char(b, i)
        if ca < cb:
            return -1
        if ca > cb:
            return 1
        i = i + 1
    if la < lb:
        return -1
    if la > lb:
        return 1
    return 0


# ---- expression evaluation ----
def eval_expr(node: int32, env: int32) -> int32:
    if node < 0:
        return v_undef()
    if err_flag != 0:
        return v_undef()
    if ctl == CTL_THROW:
        return v_undef()
    k: int32 = cast[int32](n_kind[node])
    if k == ND_NUM:
        return v_number(n_num[node])
    if k == ND_STR:
        return v_string_id(n_str[node])
    if k == ND_REGEX:
        return js_make_regex(n_str[node], n_a[node])
    if k == ND_TRUE:
        return v_true()
    if k == ND_FALSE:
        return v_false()
    if k == ND_NULL:
        return v_null()
    if k == ND_UNDEF:
        return v_undef()
    if k == ND_THIS:
        if this_top > 0:
            return this_stack[this_top - 1]
        return v_undef()
    if k == ND_IDENT:
        b: int32 = env_lookup_bind(env, n_str[node])
        if b < 0:
            # undefined global reference -> ReferenceError semantics soft:
            set_error(cast[Ptr[uint8]]("ReferenceError: name is not defined"))
            return v_undef()
        return b_val[b]
    if k == ND_ARRAY:
        return eval_array_lit(node, env)
    if k == ND_OBJECT:
        return eval_object_lit(node, env)
    if k == ND_FUNC:
        return v_new_closure(node, env)
    if k == ND_ARROW:
        ah: int32 = v_new_closure(node, env)
        ao: int32 = objid_of(ah)
        if this_top > 0:
            obj_fn_this[ao] = this_stack[this_top - 1]
            obj_fn_home[ao] = home_stack[this_top - 1]
        else:
            obj_fn_this[ao] = v_undef()
            obj_fn_home[ao] = -1
        return ah
    if k == ND_BINOP:
        a: int32 = eval_expr(n_a[node], env)
        if err_flag != 0:
            return v_undef()
        bb: int32 = eval_expr(n_b[node], env)
        return eval_binop(n_op[node], a, bb)
    if k == ND_LOGICAL:
        la: int32 = eval_expr(n_a[node], env)
        if n_op[node] == 0:            # &&
            if to_bool(la) == 0:
                return la
            return eval_expr(n_b[node], env)
        else:                          # ||
            if to_bool(la) != 0:
                return la
            return eval_expr(n_b[node], env)
    if k == ND_UNARY:
        return eval_unary(node, env)
    if k == ND_UPDATE:
        return eval_update(node, env)
    if k == ND_TERNARY:
        cnd: int32 = eval_expr(n_a[node], env)
        if to_bool(cnd) != 0:
            return eval_expr(n_b[node], env)
        return eval_expr(n_c[node], env)
    if k == ND_ASSIGN:
        return eval_assign(node, env)
    if k == ND_CLASS:
        return eval_class(node, env)
    if k == ND_SUPER:
        # bare `super` as a value is not meaningful; return current this
        if this_top > 0:
            return this_stack[this_top - 1]
        return v_undef()
    if k == ND_MEMBER:
        if cast[int32](n_kind[n_a[node]]) == ND_SUPER:
            return super_get(n_str[node])
        objv: int32 = eval_expr(n_a[node], env)
        return member_get(objv, n_str[node])
    if k == ND_INDEX:
        objv2: int32 = eval_expr(n_a[node], env)
        idxv: int32 = eval_expr(n_b[node], env)
        return index_get(objv2, idxv)
    if k == ND_CALL:
        return eval_call(node, env)
    if k == ND_NEW:
        return eval_new(node, env)
    return v_undef()


def index_get(objv: int32, idxv: int32) -> int32:
    if tag_of(objv) == TAG_STR:
        if tag_of(idxv) == TAG_NUM:
            i: int32 = cast[int32](v_num[idxv])
            sid: int32 = strid_of(objv)
            if i >= 0 and i < str_len(sid):
                return v_string_bytes(&sp_buf[st_off[sid] + i], 1)
            return v_undef()
    ks: int32 = strid_of(to_string_val(idxv))
    return member_get(objv, ks)


def eval_array_lit(node: int32, env: int32) -> int32:
    v: int32 = v_new_array()
    o: int32 = objid_of(v)
    el: int32 = n_a[node]
    while el >= 0:
        if cast[int32](n_kind[el]) == ND_SPREAD:
            srcv: int32 = eval_expr(n_a[el], env)
            if is_array(srcv) != 0:
                so: int32 = objid_of(srcv)
                i: int32 = 0
                while i < arr_len[so]:
                    arr_push(o, arr_get(so, i))
                    i = i + 1
            elif tag_of(srcv) == TAG_STR:
                sid: int32 = strid_of(srcv)
                j: int32 = 0
                while j < str_len(sid):
                    arr_push(o, v_string_bytes(&sp_buf[st_off[sid] + j], 1))
                    j = j + 1
        else:
            arr_push(o, eval_expr(el, env))
        el = n_next[el]
    return v


def eval_object_lit(node: int32, env: int32) -> int32:
    v: int32 = v_new_object()
    o: int32 = objid_of(v)
    pr: int32 = n_a[node]
    while pr >= 0:
        if cast[int32](n_kind[pr]) == ND_SPREAD:
            srcv2: int32 = eval_expr(n_a[pr], env)
            if tag_of(srcv2) == TAG_OBJ:
                copy_own_props(objid_of(srcv2), o)
        else:
            obj_set(o, n_str[pr], eval_expr(n_a[pr], env))
        pr = n_next[pr]
    return v


def eval_unary(node: int32, env: int32) -> int32:
    op: int32 = n_op[node]
    if op == U_TYPEOF:
        # typeof of an undefined identifier is "undefined" (no ReferenceError)
        if cast[int32](n_kind[n_a[node]]) == ND_IDENT:
            b: int32 = env_lookup_bind(env, n_str[n_a[node]])
            if b < 0:
                return v_string_cstr(cast[Ptr[uint8]]("undefined"))
        v: int32 = eval_expr(n_a[node], env)
        return v_string_cstr(typeof_str(v))
    v2: int32 = eval_expr(n_a[node], env)
    if op == U_NEG:
        return v_number(0.0 - to_number(v2))
    if op == U_POS:
        return v_number(to_number(v2))
    if op == U_NOT:
        return v_boolv(1 - to_bool(v2))
    if op == U_BNOT:
        return v_number(cast[float64](~to_int32(v2)))
    return v_undef()


def typeof_str(v: int32) -> Ptr[uint8]:
    t: int32 = tag_of(v)
    if t == TAG_UNDEF:
        return cast[Ptr[uint8]]("undefined")
    if t == TAG_NULL:
        return cast[Ptr[uint8]]("object")
    if t == TAG_BOOL:
        return cast[Ptr[uint8]]("boolean")
    if t == TAG_NUM:
        return cast[Ptr[uint8]]("number")
    if t == TAG_STR:
        return cast[Ptr[uint8]]("string")
    if is_callable(v) != 0:
        return cast[Ptr[uint8]]("function")
    return cast[Ptr[uint8]]("object")


def eval_update(node: int32, env: int32) -> int32:
    delta: float64 = cast[float64](n_op[node])
    tgt: int32 = n_a[node]
    old: int32 = eval_expr(tgt, env)
    oldn: float64 = to_number(old)
    newn: float64 = oldn + delta
    nv: int32 = v_number(newn)
    assign_to(tgt, nv, env)
    if n_b[node] == 1:                 # prefix
        return nv
    return v_number(oldn)              # postfix returns old


def assign_to(tgt: int32, val: int32, env: int32):
    k: int32 = cast[int32](n_kind[tgt])
    if k == ND_IDENT:
        b: int32 = env_lookup_bind(env, n_str[tgt])
        if b < 0:
            env_define(g_env, n_str[tgt], val, 0)   # implicit global
        else:
            if b_const[b] != 0:
                throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("assignment to constant variable"))
                return
            b_val[b] = val
    elif k == ND_MEMBER:
        objv: int32 = eval_expr(n_a[tgt], env)
        member_set(objv, n_str[tgt], val)
    elif k == ND_INDEX:
        objv2: int32 = eval_expr(n_a[tgt], env)
        idxv: int32 = eval_expr(n_b[tgt], env)
        ks: int32 = strid_of(to_string_val(idxv))
        member_set(objv2, ks, val)


def eval_assign(node: int32, env: int32) -> int32:
    op: int32 = n_op[node]
    rhs: int32 = eval_expr(n_b[node], env)
    if op >= 0:
        # compound assignment: target op= rhs
        cur: int32 = eval_expr(n_a[node], env)
        rhs = eval_binop(op, cur, rhs)
    assign_to(n_a[node], rhs, env)
    return rhs


# ---- calls ----
def spread_into_args(srcv: int32):
    # expand an iterable (array or string) onto call_args
    if is_array(srcv) != 0:
        o: int32 = objid_of(srcv)
        i: int32 = 0
        while i < arr_len[o]:
            call_args[call_top] = arr_get(o, i)
            call_top = call_top + 1
            i = i + 1
    elif tag_of(srcv) == TAG_STR:
        sid: int32 = strid_of(srcv)
        j: int32 = 0
        while j < str_len(sid):
            call_args[call_top] = v_string_bytes(&sp_buf[st_off[sid] + j], 1)
            call_top = call_top + 1
            j = j + 1


def eval_args_into(argnode: int32, env: int32) -> int32:
    # push arg values onto call_args; return count
    base: int32 = call_top
    a: int32 = argnode
    while a >= 0:
        if cast[int32](n_kind[a]) == ND_SPREAD:
            spread_into_args(eval_expr(n_a[a], env))
        else:
            call_args[call_top] = eval_expr(a, env)
            call_top = call_top + 1
        a = n_next[a]
    return call_top - base


# look up `key_sid` on the parent of the current method's home prototype
def super_get(key_sid: int32) -> int32:
    if this_top <= 0:
        return v_undef()
    home: int32 = home_stack[this_top - 1]
    if home < 0:
        return v_undef()
    cur: int32 = obj_proto[home]
    while cur >= 0:
        pp: int32 = obj_find_prop(cur, key_sid)
        if pp >= 0:
            return p_val[pp]
        cur = obj_proto[cur]
    return v_undef()


def eval_call(node: int32, env: int32) -> int32:
    callee: int32 = n_a[node]
    ck: int32 = cast[int32](n_kind[callee])
    thisv: int32 = v_undef()
    fnv: int32 = 0
    method_name: int32 = -1
    is_builtin_method: int32 = 0
    if ck == ND_SUPER:
        # super(...) : run the parent constructor on the current `this`
        cur_this: int32 = v_undef()
        curfn: int32 = -1
        if this_top > 0:
            cur_this = this_stack[this_top - 1]
            curfn = curfn_stack[this_top - 1]
        supv: int32 = v_undef()
        if curfn >= 0 and obj_fn_super[curfn] >= 0:
            supv = obj_fn_super[curfn]
        base0: int32 = call_top
        argc0: int32 = eval_args_into(n_b[node], env)
        if ctl == CTL_THROW:
            call_top = base0
            return v_undef()
        if is_callable(supv) != 0:
            run_constructor(supv, cur_this, base0, argc0)
        call_top = base0
        return v_undef()
    if ck == ND_MEMBER and cast[int32](n_kind[n_a[callee]]) == ND_SUPER:
        # super.method(...) : parent-prototype method, `this` = current this
        cur_this2: int32 = v_undef()
        if this_top > 0:
            cur_this2 = this_stack[this_top - 1]
        fnv2: int32 = super_get(n_str[callee])
        if is_callable(fnv2) == 0:
            throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("super method is not a function"))
            return v_undef()
        base1: int32 = call_top
        argc1: int32 = eval_args_into(n_b[node], env)
        if ctl == CTL_THROW:
            call_top = base1
            return v_undef()
        r1: int32 = invoke(fnv2, cur_this2, base1, argc1)
        call_top = base1
        return r1
    if ck == ND_MEMBER:
        thisv = eval_expr(n_a[callee], env)
        method_name = n_str[callee]
        if err_flag != 0 or ctl == CTL_THROW:
            return v_undef()
        # string/array builtin methods
        if tag_of(thisv) == TAG_STR:
            return call_string_method(thisv, method_name, n_b[node], env)
        if tag_of(thisv) == TAG_NUM:
            rn: int32 = try_number_method(thisv, method_name, n_b[node], env)
            if rn != -2:
                return rn
        if is_array(thisv) != 0:
            r: int32 = try_array_method(thisv, method_name, n_b[node], env)
            if r != -2:
                return r
        if is_regex(thisv) != 0:
            rr: int32 = try_regex_method(thisv, method_name, n_b[node], env)
            if rr != -2:
                return rr
        fnv = member_get(thisv, method_name)
    elif ck == ND_INDEX:
        thisv = eval_expr(n_a[callee], env)
        idxv: int32 = eval_expr(n_b[callee], env)
        ks: int32 = strid_of(to_string_val(idxv))
        fnv = member_get(thisv, ks)
    else:
        fnv = eval_expr(callee, env)
    if err_flag != 0 or ctl == CTL_THROW:
        return v_undef()
    if is_callable(fnv) == 0:
        throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("value is not a function"))
        return v_undef()
    base: int32 = call_top
    argc: int32 = eval_args_into(n_b[node], env)
    if ctl == CTL_THROW:
        call_top = base
        return v_undef()
    r2: int32 = invoke(fnv, thisv, base, argc)
    call_top = base
    return r2


def bind_params(fnode: int32, callenv: int32, argbase: int32, argc: int32):
    p: int32 = n_a[fnode]
    i: int32 = 0
    while p >= 0:
        if n_op[p] == 1:                   # rest parameter: gather the rest
            restv: int32 = v_new_array()
            ro: int32 = objid_of(restv)
            j: int32 = i
            while j < argc:
                arr_push(ro, call_args[argbase + j])
                j = j + 1
            env_define(callenv, n_str[p], restv, 0)
            return
        av: int32 = v_undef()
        if i < argc:
            av = call_args[argbase + i]
        if tag_of(av) == TAG_UNDEF and n_a[p] >= 0:
            av = eval_expr(n_a[p], callenv)   # default value
        env_define(callenv, n_str[p], av, 0)
        p = n_next[p]
        i = i + 1


def invoke(fnv: int32, thisv: int32, argbase: int32, argc: int32) -> int32:
    o: int32 = objid_of(fnv)
    nat: int32 = obj_fn_native[o]
    if nat >= 0:
        return call_native(nat, thisv, argbase, argc)
    fnode: int32 = obj_fn_node[o]
    fenv: int32 = obj_fn_env[o]
    is_arrow: int32 = 0
    if cast[int32](n_kind[fnode]) == ND_ARROW:
        is_arrow = 1
    # arrows use their captured lexical `this` and home (for `super`)
    use_this: int32 = thisv
    use_home: int32 = obj_fn_home[o]
    if is_arrow != 0 and obj_fn_this[o] != -2:
        use_this = obj_fn_this[o]
    callenv: int32 = env_new(fenv, 1)
    # a named function expression binds its own name inside its body scope
    if n_str[fnode] >= 0:
        env_define(callenv, n_str[fnode], fnv, 0)
    bind_params(fnode, callenv, argbase, argc)
    this_stack[this_top] = use_this
    home_stack[this_top] = use_home
    curfn_stack[this_top] = o
    this_top = this_top + 1
    if is_arrow != 0 and n_c[fnode] == 1:
        # concise expression body: value is the expression, no `return`
        rvx: int32 = eval_expr(n_b[fnode], callenv)
        this_top = this_top - 1
        return rvx
    # hoist var/function declarations, then run body
    hoist_scan(n_b[fnode], callenv)
    exec_stmt(n_b[fnode], callenv)
    this_top = this_top - 1
    if ctl == CTL_THROW:
        return v_undef()                   # propagate the exception
    rv: int32 = v_undef()
    if ctl == CTL_RETURN:
        rv = ctl_val
    ctl = CTL_NONE
    return rv


# Evaluate a class definition to its constructor function value.
def eval_class(node: int32, env: int32) -> int32:
    has_super: int32 = 0
    superv: int32 = 0
    if n_a[node] >= 0:
        has_super = 1
        superv = eval_expr(n_a[node], env)
    # the prototype object shared by all instances
    protov: int32 = v_new_object()
    proto_o: int32 = objid_of(protov)
    if has_super != 0 and tag_of(superv) == TAG_OBJ:
        sp: int32 = obj_get(objid_of(superv), str_from_cstr(cast[Ptr[uint8]]("prototype")))
        if tag_of(sp) == TAG_OBJ:
            obj_proto[proto_o] = objid_of(sp)
    # locate an explicit constructor
    ctor_func: int32 = -1
    m: int32 = n_b[node]
    while m >= 0:
        if n_op[m] == 0 and n_str[m] >= 0 and str_eq_cstr(n_str[m], cast[Ptr[uint8]]("constructor")) != 0:
            ctor_func = n_a[m]
        m = n_next[m]
    default_ctor: int32 = 0
    if ctor_func < 0:
        ctor_func = nd_new(ND_FUNC)
        blk: int32 = nd_new(ND_BLOCK)
        n_b[ctor_func] = blk
        default_ctor = 1
    classv: int32 = v_new_closure(ctor_func, env)
    co: int32 = objid_of(classv)
    if default_ctor != 0:
        obj_class[co] = cast[uint8](3)      # bit0 class, bit1 default
    else:
        obj_class[co] = cast[uint8](1)
    obj_fn_home[co] = proto_o               # `super.x` in the constructor
    if has_super != 0:
        obj_fn_super[co] = superv
        if tag_of(superv) == TAG_OBJ:
            obj_proto[co] = objid_of(superv)   # static inheritance
    obj_set(co, str_from_cstr(cast[Ptr[uint8]]("prototype")), protov)
    obj_set(proto_o, str_from_cstr(cast[Ptr[uint8]]("constructor")), classv)
    # install methods on the prototype (or the class, if static)
    m2: int32 = n_b[node]
    while m2 >= 0:
        if n_str[m2] >= 0 and str_eq_cstr(n_str[m2], cast[Ptr[uint8]]("constructor")) == 0:
            mfnv: int32 = v_new_closure(n_a[m2], env)
            mo: int32 = objid_of(mfnv)
            if n_op[m2] == 1:               # static
                obj_fn_home[mo] = co
                obj_set(co, n_str[m2], mfnv)
            else:
                obj_fn_home[mo] = proto_o
                obj_set(proto_o, n_str[m2], mfnv)
        m2 = n_next[m2]
    return classv


# Run a constructor on an already-allocated instance, applying the implicit
# super(...args) forwarding of a default derived constructor.
def run_constructor(fnv: int32, self_obj: int32, base: int32, argc: int32) -> int32:
    fo: int32 = objid_of(fnv)
    if obj_fn_native[fo] >= 0:
        return invoke(fnv, self_obj, base, argc)
    if (cast[int32](obj_class[fo]) & 2) != 0 and obj_fn_super[fo] >= 0:
        run_constructor(obj_fn_super[fo], self_obj, base, argc)
    return invoke(fnv, self_obj, base, argc)


def eval_new(node: int32, env: int32) -> int32:
    fnv: int32 = eval_expr(n_a[node], env)
    if err_flag != 0 or ctl == CTL_THROW:
        return v_undef()
    if is_callable(fnv) == 0:
        throw_error(cast[Ptr[uint8]]("TypeError"), cast[Ptr[uint8]]("value is not a constructor"))
        return v_undef()
    self_obj: int32 = v_new_object()
    so: int32 = objid_of(self_obj)
    # link the instance to Ctor.prototype
    protov: int32 = obj_get(objid_of(fnv), str_from_cstr(cast[Ptr[uint8]]("prototype")))
    if tag_of(protov) == TAG_OBJ:
        obj_proto[so] = objid_of(protov)
    base: int32 = call_top
    argc: int32 = 0
    if n_b[node] >= 0:
        argc = eval_args_into(n_b[node], env)
    if ctl == CTL_THROW:
        call_top = base
        return v_undef()
    r: int32 = run_constructor(fnv, self_obj, base, argc)
    call_top = base
    if ctl == CTL_THROW:
        return v_undef()
    if tag_of(r) == TAG_OBJ:
        return r
    return self_obj


# ---- statement execution ----
def exec_stmt(node: int32, env: int32):
    if node < 0:
        return
    if err_flag != 0:
        return
    k: int32 = cast[int32](n_kind[node])
    if k == ND_BLOCK:
        benv: int32 = env_new(env, 0)
        hoist_funcs_only(n_a[node], benv)
        s: int32 = n_a[node]
        while s >= 0 and ctl == CTL_NONE:
            exec_stmt(s, benv)
            s = n_next[s]
        return
    if k == ND_VAR:
        exec_var(node, env)
        return
    if k == ND_FUNCDECL:
        # already hoisted; nothing to do at exec time
        return
    if k == ND_EXPRSTMT:
        eval_expr(n_a[node], env)
        return
    if k == ND_EMPTY:
        return
    if k == ND_IF:
        c: int32 = eval_expr(n_a[node], env)
        if to_bool(c) != 0:
            exec_stmt(n_b[node], env)
        elif n_c[node] >= 0:
            exec_stmt(n_c[node], env)
        return
    if k == ND_WHILE:
        while ctl == CTL_NONE and to_bool(eval_expr(n_a[node], env)) != 0:
            exec_stmt(n_b[node], env)
            if ctl == CTL_BREAK:
                ctl = CTL_NONE
                break
            if ctl == CTL_CONTINUE:
                ctl = CTL_NONE
        return
    if k == ND_DOWHILE:
        while ctl == CTL_NONE:
            exec_stmt(n_b[node], env)
            if ctl == CTL_BREAK:
                ctl = CTL_NONE
                break
            if ctl == CTL_CONTINUE:
                ctl = CTL_NONE
            if to_bool(eval_expr(n_a[node], env)) == 0:
                break
        return
    if k == ND_FOR:
        exec_for(node, env)
        return
    if k == ND_FORIN:
        exec_forin(node, env)
        return
    if k == ND_RETURN:
        rv: int32 = v_undef()
        if n_a[node] >= 0:
            rv = eval_expr(n_a[node], env)
        ctl = CTL_RETURN
        ctl_val = rv
        return
    if k == ND_BREAK:
        ctl = CTL_BREAK
        return
    if k == ND_CONTINUE:
        ctl = CTL_CONTINUE
        return
    if k == ND_THROW:
        tv: int32 = eval_expr(n_a[node], env)
        if err_flag != 0:
            return
        throw_val = tv
        ctl = CTL_THROW
        return
    if k == ND_TRY:
        exec_try(node, env)
        return
    if k == ND_CLASSDECL:
        cv: int32 = eval_class(n_a[node], env)
        if n_str[node] >= 0:
            env_define(env, n_str[node], cv, 0)
        return
    # fallthrough: treat as expression
    eval_expr(node, env)


def exec_try(node: int32, env: int32):
    exec_stmt(n_a[node], env)          # try block
    if ctl == CTL_THROW and n_b[node] >= 0:
        caught: int32 = throw_val
        ctl = CTL_NONE
        catchenv: int32 = env_new(env, 0)
        if n_str[node] >= 0:
            env_define(catchenv, n_str[node], caught, 0)
        exec_stmt(n_b[node], catchenv)
    if n_c[node] >= 0:                  # finally
        save_ctl: int32 = ctl
        save_val: int32 = ctl_val
        save_throw: int32 = throw_val
        ctl = CTL_NONE
        exec_stmt(n_c[node], env)
        if ctl == CTL_NONE:
            # finally completed normally: restore the pending completion
            ctl = save_ctl
            ctl_val = save_val
            throw_val = save_throw


def exec_var(node: int32, env: int32):
    kind: int32 = n_op[node]           # 0 var, 1 let, 2 const
    tgt_env: int32 = env
    if kind == 0:
        tgt_env = env_func_scope(env)
    d: int32 = n_a[node]
    while d >= 0:
        val: int32 = v_undef()
        if n_a[d] >= 0:
            val = eval_expr(n_a[d], env)
        is_const: int32 = 0
        if kind == 2:
            is_const = 1
        if n_b[d] >= 0:                 # destructuring declarator
            bind_pattern(n_b[d], val, tgt_env, is_const, env)
        else:
            env_define(tgt_env, n_str[d], val, is_const)
        d = n_next[d]


# Bind a destructuring pattern's names from `val` into tgt_env.
def bind_pattern(pat: int32, val: int32, tgt_env: int32, is_const: int32, env: int32):
    if pat < 0:
        return
    pkind: int32 = cast[int32](n_kind[pat])
    if pkind == ND_ARRPAT:
        idx: int32 = 0
        e: int32 = n_a[pat]
        while e >= 0:
            if n_op[e] == 1:           # rest: collect remaining elements
                restv: int32 = v_new_array()
                ro: int32 = objid_of(restv)
                if is_array(val) != 0:
                    ov: int32 = objid_of(val)
                    j: int32 = idx
                    while j < arr_len[ov]:
                        arr_push(ro, arr_get(ov, j))
                        j = j + 1
                bind_pat_target(e, restv, tgt_env, is_const, env)
                return
            if n_str[e] >= 0 or n_b[e] >= 0:
                ev: int32 = index_get(val, v_number(cast[float64](idx)))
                if tag_of(ev) == TAG_UNDEF and n_a[e] >= 0:
                    ev = eval_expr(n_a[e], env)
                bind_pat_target(e, ev, tgt_env, is_const, env)
            idx = idx + 1
            e = n_next[e]
    elif pkind == ND_OBJPAT:
        e2: int32 = n_a[pat]
        while e2 >= 0:
            if n_op[e2] == 1:          # object rest: remaining own props
                resto: int32 = v_new_object()
                if tag_of(val) == TAG_OBJ:
                    obj_rest_rec(pat, obj_head[objid_of(val)], objid_of(resto))
                if n_c[e2] >= 0:
                    env_define(tgt_env, n_c[e2], resto, is_const)
            elif n_str[e2] >= 0:
                pv: int32 = member_get(val, n_str[e2])
                if tag_of(pv) == TAG_UNDEF and n_a[e2] >= 0:
                    pv = eval_expr(n_a[e2], env)
                bind_pat_target(e2, pv, tgt_env, is_const, env)
            e2 = n_next[e2]


def objpat_has_key(pat: int32, key_sid: int32) -> int32:
    e: int32 = n_a[pat]
    while e >= 0:
        if n_op[e] == 0 and n_str[e] >= 0 and str_eq(n_str[e], key_sid) != 0:
            return 1
        e = n_next[e]
    return 0


def obj_rest_rec(pat: int32, p: int32, resto: int32):
    if p < 0:
        return
    obj_rest_rec(pat, p_next[p], resto)
    if objpat_has_key(pat, p_key[p]) == 0:
        obj_set(resto, p_key[p], p_val[p])


def bind_pat_target(e: int32, v: int32, tgt_env: int32, is_const: int32, env: int32):
    if n_b[e] >= 0:                    # nested pattern
        bind_pattern(n_b[e], v, tgt_env, is_const, env)
    elif n_c[e] >= 0:                  # object element: bind to target name
        env_define(tgt_env, n_c[e], v, is_const)
    elif n_str[e] >= 0:                # array element: bind to name
        env_define(tgt_env, n_str[e], v, is_const)


def env_copy_locals(src: int32, dst: int32):
    b: int32 = env_head[src]
    while b >= 0:
        env_define(dst, b_name[b], b_val[b], 0)
        b = b_next[b]


def exec_for(node: int32, env: int32):
    loopenv: int32 = env_new(env, 0)
    init: int32 = n_a[node]
    is_let: int32 = 0
    if init >= 0:
        if cast[int32](n_kind[init]) == ND_VAR:
            exec_var(init, loopenv)
            if n_op[init] != 0:            # let / const -> per-iteration binding
                is_let = 1
        else:
            exec_stmt(init, loopenv)
    while ctl == CTL_NONE:
        curenv: int32 = loopenv
        if is_let != 0:
            curenv = env_new(env, 0)
            env_copy_locals(loopenv, curenv)
        if n_b[node] >= 0:
            if to_bool(eval_expr(n_b[node], curenv)) == 0:
                break
        exec_stmt(n_d[node], curenv)
        if ctl == CTL_BREAK:
            ctl = CTL_NONE
            break
        if ctl == CTL_CONTINUE:
            ctl = CTL_NONE
        if n_c[node] >= 0:
            eval_expr(n_c[node], curenv)
        if is_let != 0:
            env_copy_locals(curenv, loopenv)


def exec_forin(node: int32, env: int32):
    objv: int32 = eval_expr(n_b[node], env)
    loopenv: int32 = env_new(env, 0)
    # determine target binding name
    name: int32 = -1
    target_decl: int32 = n_a[node]
    if cast[int32](n_kind[target_decl]) == ND_VAR:
        d: int32 = n_a[target_decl]
        name = n_str[d]
        env_define(loopenv, name, v_undef(), 0)
    else:
        # expr-stmt wrapping an ident
        inner: int32 = n_a[target_decl]
        if cast[int32](n_kind[inner]) == ND_IDENT:
            name = n_str[inner]
    if tag_of(objv) == TAG_OBJ:
        o: int32 = objid_of(objv)
        if cast[int32](obj_kind[o]) == OK_ARRAY:
            i: int32 = 0
            while i < arr_len[o] and ctl == CTL_NONE:
                keyv: int32 = v_string_id(num_to_strid(cast[float64](i)))
                forin_bind(name, keyv, loopenv, env)
                exec_stmt(n_c[node], loopenv)
                forin_after()
                i = i + 1
        else:
            # iterate props in insertion order (reverse the newest-first chain)
            forin_props(obj_head[o], name, node, loopenv, env)
    elif tag_of(objv) == TAG_STR:
        sid: int32 = strid_of(objv)
        i2: int32 = 0
        while i2 < str_len(sid) and ctl == CTL_NONE:
            keyv2: int32 = v_string_id(num_to_strid(cast[float64](i2)))
            forin_bind(name, keyv2, loopenv, env)
            exec_stmt(n_c[node], loopenv)
            forin_after()
            i2 = i2 + 1


def forin_props(p: int32, name: int32, node: int32, loopenv: int32, env: int32):
    if p < 0:
        return
    forin_props(p_next[p], name, node, loopenv, env)
    if ctl != CTL_NONE:
        return
    keyv: int32 = v_string_id(p_key[p])
    forin_bind(name, keyv, loopenv, env)
    exec_stmt(n_c[node], loopenv)
    forin_after()


def forin_bind(name: int32, keyv: int32, loopenv: int32, env: int32):
    if name >= 0:
        b: int32 = env_lookup_bind(loopenv, name)
        if b >= 0:
            b_val[b] = keyv
        else:
            env_define(loopenv, name, keyv, 0)


def forin_after():
    if ctl == CTL_BREAK:
        ctl = CTL_NONE                 # note: only single-level
    elif ctl == CTL_CONTINUE:
        ctl = CTL_NONE


# hoist var declarations (to function scope) and function declarations
def hoist_scan(block: int32, env: int32):
    if block < 0:
        return
    if cast[int32](n_kind[block]) != ND_BLOCK:
        return
    s: int32 = n_a[block]
    while s >= 0:
        hoist_stmt(s, env)
        s = n_next[s]


def hoist_stmt(s: int32, env: int32):
    k: int32 = cast[int32](n_kind[s])
    if k == ND_VAR:
        if n_op[s] == 0:               # var
            d: int32 = n_a[s]
            while d >= 0:
                if env_find_local(env, n_str[d]) < 0:
                    env_define(env, n_str[d], v_undef(), 0)
                d = n_next[d]
    elif k == ND_FUNCDECL:
        fv: int32 = v_new_closure(n_a[s], env)
        env_define(env, n_str[s], fv, 0)
    elif k == ND_IF:
        hoist_stmt_child(n_b[s], env)
        hoist_stmt_child(n_c[s], env)
    elif k == ND_WHILE or k == ND_DOWHILE:
        hoist_stmt_child(n_b[s], env)
    elif k == ND_FOR:
        hoist_stmt_child(n_a[s], env)
        hoist_stmt_child(n_d[s], env)
    elif k == ND_FORIN:
        hoist_stmt_child(n_c[s], env)
    elif k == ND_BLOCK:
        s2: int32 = n_a[s]
        while s2 >= 0:
            hoist_stmt(s2, env)
            s2 = n_next[s2]


def hoist_stmt_child(s: int32, env: int32):
    if s < 0:
        return
    hoist_stmt(s, env)


# function declarations only (for block-level hoisting)
def hoist_funcs_only(s: int32, env: int32):
    while s >= 0:
        if cast[int32](n_kind[s]) == ND_FUNCDECL:
            fv: int32 = v_new_closure(n_a[s], env)
            env_define(env, n_str[s], fv, 0)
        s = n_next[s]


# ====================================================================
# BUILTIN string / array methods.
# ====================================================================
def call_string_method(sv: int32, name: int32, argnode: int32, env: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    r: int32 = string_method(sv, name, base, argc)
    call_top = base
    return r


def arg_or(base: int32, argc: int32, i: int32) -> int32:
    if i < argc:
        return call_args[base + i]
    return v_undef()


def string_method(sv: int32, name: int32, base: int32, argc: int32) -> int32:
    sid: int32 = strid_of(sv)
    slen: int32 = str_len(sid)
    if str_eq_cstr(name, cast[Ptr[uint8]]("charAt")) != 0:
        idx: int32 = 0
        if argc > 0:
            idx = cast[int32](to_number(call_args[base]))
        if idx >= 0 and idx < slen:
            return v_string_bytes(&sp_buf[st_off[sid] + idx], 1)
        return v_string_cstr(cast[Ptr[uint8]](""))
    if str_eq_cstr(name, cast[Ptr[uint8]]("charCodeAt")) != 0:
        idx2: int32 = 0
        if argc > 0:
            idx2 = cast[int32](to_number(call_args[base]))
        if idx2 >= 0 and idx2 < slen:
            return v_number(cast[float64](cast[int32](str_char(sid, idx2))))
        return v_number(0.0 / 0.0)
    if str_eq_cstr(name, cast[Ptr[uint8]]("indexOf")) != 0:
        return v_number(cast[float64](str_indexof(sid, strid_of(to_string_val(arg_or(base, argc, 0))))))
    if str_eq_cstr(name, cast[Ptr[uint8]]("toUpperCase")) != 0:
        return str_map_case(sid, 1)
    if str_eq_cstr(name, cast[Ptr[uint8]]("toLowerCase")) != 0:
        return str_map_case(sid, 0)
    if str_eq_cstr(name, cast[Ptr[uint8]]("slice")) != 0 or str_eq_cstr(name, cast[Ptr[uint8]]("substring")) != 0:
        st: int32 = 0
        en: int32 = slen
        if argc > 0:
            st = cast[int32](to_number(call_args[base]))
        if argc > 1:
            en = cast[int32](to_number(call_args[base + 1]))
        if st < 0:
            st = slen + st
            if st < 0:
                st = 0
        if en < 0:
            en = slen + en
        if en > slen:
            en = slen
        if st > en:
            st = en
        return v_string_bytes(&sp_buf[st_off[sid] + st], en - st)
    if str_eq_cstr(name, cast[Ptr[uint8]]("split")) != 0:
        sep0: int32 = arg_or(base, argc, 0)
        if is_regex(sep0) != 0:
            return str_regex_split(sid, sep0)
        return str_split(sid, sep0)
    if str_eq_cstr(name, cast[Ptr[uint8]]("match")) != 0:
        return str_regex_match(sid, to_regex(arg_or(base, argc, 0)))
    if str_eq_cstr(name, cast[Ptr[uint8]]("matchAll")) != 0:
        return str_regex_matchall(sid, to_regex(arg_or(base, argc, 0)))
    if str_eq_cstr(name, cast[Ptr[uint8]]("search")) != 0:
        return str_regex_search(sid, to_regex(arg_or(base, argc, 0)))
    if str_eq_cstr(name, cast[Ptr[uint8]]("replace")) != 0:
        pat: int32 = arg_or(base, argc, 0)
        rep: int32 = arg_or(base, argc, 1)
        if is_regex(pat) != 0:
            return str_regex_replace(sid, pat, rep)
        return str_replace_string(sid, pat, rep)
    if str_eq_cstr(name, cast[Ptr[uint8]]("replaceAll")) != 0:
        patA: int32 = arg_or(base, argc, 0)
        repA: int32 = arg_or(base, argc, 1)
        if is_regex(patA) != 0:
            return str_regex_replace(sid, patA, repA)
        return str_replace_all_string(sid, patA, repA)
    if str_eq_cstr(name, cast[Ptr[uint8]]("substr")) != 0:
        st2: int32 = 0
        ln: int32 = slen
        if argc > 0:
            st2 = cast[int32](to_number(call_args[base]))
        if argc > 1:
            ln = cast[int32](to_number(call_args[base + 1]))
        if st2 < 0:
            st2 = slen + st2
            if st2 < 0:
                st2 = 0
        if st2 + ln > slen:
            ln = slen - st2
        if ln < 0:
            ln = 0
        return v_string_bytes(&sp_buf[st_off[sid] + st2], ln)
    if str_eq_cstr(name, cast[Ptr[uint8]]("trim")) != 0:
        a: int32 = 0
        b2: int32 = slen
        while a < b2 and is_ws(str_char(sid, a)) != 0:
            a = a + 1
        while b2 > a and is_ws(str_char(sid, b2 - 1)) != 0:
            b2 = b2 - 1
        return v_string_bytes(&sp_buf[st_off[sid] + a], b2 - a)
    if str_eq_cstr(name, cast[Ptr[uint8]]("toString")) != 0:
        return sv
    if str_eq_cstr(name, cast[Ptr[uint8]]("lastIndexOf")) != 0:
        return v_number(cast[float64](str_lastindexof(sid, strid_of(to_string_val(arg_or(base, argc, 0))))))
    if str_eq_cstr(name, cast[Ptr[uint8]]("includes")) != 0:
        return v_boolv(bool_of(str_indexof(sid, strid_of(to_string_val(arg_or(base, argc, 0)))) >= 0))
    if str_eq_cstr(name, cast[Ptr[uint8]]("startsWith")) != 0:
        return v_boolv(str_startswith(sid, strid_of(to_string_val(arg_or(base, argc, 0)))))
    if str_eq_cstr(name, cast[Ptr[uint8]]("endsWith")) != 0:
        return v_boolv(str_endswith(sid, strid_of(to_string_val(arg_or(base, argc, 0)))))
    if str_eq_cstr(name, cast[Ptr[uint8]]("at")) != 0:
        ai: int32 = 0
        if argc > 0:
            ai = cast[int32](to_number(call_args[base]))
        if ai < 0:
            ai = slen + ai
        if ai >= 0 and ai < slen:
            return v_string_bytes(&sp_buf[st_off[sid] + ai], 1)
        return v_undef()
    if str_eq_cstr(name, cast[Ptr[uint8]]("codePointAt")) != 0:
        ci: int32 = 0
        if argc > 0:
            ci = cast[int32](to_number(call_args[base]))
        if ci >= 0 and ci < slen:
            return v_number(cast[float64](cast[int32](str_char(sid, ci))))
        return v_undef()
    if str_eq_cstr(name, cast[Ptr[uint8]]("concat")) != 0:
        save2: int32 = emit_tgt
        emit_tgt = 0
        bld_begin()
        emit_strid(sid)
        ce: int32 = 0
        while ce < argc:
            emit_strid(strid_of(to_string_val(call_args[base + ce])))
            ce = ce + 1
        cid: int32 = bld_end()
        emit_tgt = save2
        return v_string_id(cid)
    if str_eq_cstr(name, cast[Ptr[uint8]]("padStart")) != 0:
        return str_pad(sid, base, argc, 1)
    if str_eq_cstr(name, cast[Ptr[uint8]]("padEnd")) != 0:
        return str_pad(sid, base, argc, 0)
    if str_eq_cstr(name, cast[Ptr[uint8]]("trimStart")) != 0:
        a3: int32 = 0
        while a3 < slen and is_ws(str_char(sid, a3)) != 0:
            a3 = a3 + 1
        return v_string_bytes(&sp_buf[st_off[sid] + a3], slen - a3)
    if str_eq_cstr(name, cast[Ptr[uint8]]("trimEnd")) != 0:
        b3: int32 = slen
        while b3 > 0 and is_ws(str_char(sid, b3 - 1)) != 0:
            b3 = b3 - 1
        return v_string_bytes(&sp_buf[st_off[sid]], b3)
    if str_eq_cstr(name, cast[Ptr[uint8]]("repeat")) != 0:
        cnt: int32 = cast[int32](to_number(arg_or(base, argc, 0)))
        save: int32 = emit_tgt
        emit_tgt = 0
        bld_begin()
        j: int32 = 0
        while j < cnt:
            emit_strid(sid)
            j = j + 1
        rid: int32 = bld_end()
        emit_tgt = save
        return v_string_id(rid)
    set_error(cast[Ptr[uint8]]("TypeError: unknown string method"))
    return v_undef()


def str_map_case(sid: int32, upper: int32) -> int32:
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    n: int32 = str_len(sid)
    i: int32 = 0
    while i < n:
        c: uint8 = str_char(sid, i)
        if upper != 0:
            if c >= 97 and c <= 122:
                c = c - 32
        else:
            if c >= 65 and c <= 90:
                c = c + 32
        emit_c(c)
        i = i + 1
    id: int32 = bld_end()
    emit_tgt = save
    return v_string_id(id)


def str_indexof(hay: int32, needle: int32) -> int32:
    hn: int32 = str_len(hay)
    nn: int32 = str_len(needle)
    if nn == 0:
        return 0
    i: int32 = 0
    while i + nn <= hn:
        j: int32 = 0
        while j < nn and str_char(hay, i + j) == str_char(needle, j):
            j = j + 1
        if j == nn:
            return i
        i = i + 1
    return -1


def bool_of(c: int32) -> int32:
    if c != 0:
        return 1
    return 0


def str_lastindexof(hay: int32, needle: int32) -> int32:
    hn: int32 = str_len(hay)
    nn: int32 = str_len(needle)
    if nn == 0:
        return hn
    i: int32 = hn - nn
    while i >= 0:
        j: int32 = 0
        while j < nn and str_char(hay, i + j) == str_char(needle, j):
            j = j + 1
        if j == nn:
            return i
        i = i - 1
    return -1


def str_startswith(hay: int32, pre: int32) -> int32:
    hn: int32 = str_len(hay)
    pn: int32 = str_len(pre)
    if pn > hn:
        return 0
    i: int32 = 0
    while i < pn:
        if str_char(hay, i) != str_char(pre, i):
            return 0
        i = i + 1
    return 1


def str_endswith(hay: int32, suf: int32) -> int32:
    hn: int32 = str_len(hay)
    sn: int32 = str_len(suf)
    if sn > hn:
        return 0
    off: int32 = hn - sn
    i: int32 = 0
    while i < sn:
        if str_char(hay, off + i) != str_char(suf, i):
            return 0
        i = i + 1
    return 1


# padStart (at_start=1) / padEnd (at_start=0). arg0 = target length,
# arg1 = pad string (default " ").
def str_pad(sid: int32, base: int32, argc: int32, at_start: int32) -> int32:
    slen: int32 = str_len(sid)
    tgt: int32 = 0
    if argc > 0:
        tgt = cast[int32](to_number(call_args[base]))
    if tgt <= slen:
        return v_string_id(sid)
    pad: int32 = -1
    if argc > 1 and tag_of(call_args[base + 1]) != TAG_UNDEF:
        pad = strid_of(to_string_val(call_args[base + 1]))
    pn: int32 = 0
    if pad >= 0:
        pn = str_len(pad)
    need: int32 = tgt - slen
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    if at_start == 0:
        emit_strid(sid)
    k: int32 = 0
    while k < need:
        if pn == 0:
            emit_c(32)                 # default space
        else:
            emit_c(str_char(pad, k % pn))
        k = k + 1
    if at_start != 0:
        emit_strid(sid)
    rid: int32 = bld_end()
    emit_tgt = save
    return v_string_id(rid)


# plain (non-regex) String.replace / replaceAll. `all` replaces every
# occurrence; repl may be a function or a string ($& / $$ supported). Two-phase
# for the same reason as the regex path (a replacer function builds strings).
def str_replace_plain(sid: int32, patv: int32, replv: int32, all: int32) -> int32:
    pat: int32 = strid_of(to_string_val(patv))
    pn: int32 = str_len(pat)
    is_fn: int32 = is_callable(replv)
    n: int32 = str_len(sid)
    count: int32 = 0
    pos: int32 = 0
    while pos <= n and count < MAX_REP:
        found: int32 = -1
        if pn == 0:
            found = pos
        else:
            i: int32 = pos
            while i + pn <= n:
                j: int32 = 0
                while j < pn and str_char(sid, i + j) == str_char(pat, j):
                    j = j + 1
                if j == pn:
                    found = i
                    break
                i = i + 1
        if found < 0:
            break
        rid0: int32 = 0
        if is_fn != 0:
            rid0 = re_plain_fn_id(sid, replv, found, pn)
        else:
            rid0 = re_plain_str_id(sid, replv, found, pn)
        rep_start[count] = found
        rep_end[count] = found + pn
        rep_id[count] = rid0
        count = count + 1
        if pn == 0:
            pos = found + 1
        else:
            pos = found + pn
        if all == 0:
            break
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    last: int32 = 0
    a: int32 = 0
    while a < count:
        k: int32 = last
        while k < rep_start[a]:
            emit_c(str_char(sid, k))
            k = k + 1
        emit_strid(rep_id[a])
        last = rep_end[a]
        a = a + 1
    tail: int32 = last
    while tail < n:
        emit_c(str_char(sid, tail))
        tail = tail + 1
    rid: int32 = bld_end()
    emit_tgt = save
    return v_string_id(rid)


def re_plain_str_id(sid: int32, replv: int32, found: int32, pn: int32) -> int32:
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    rsid: int32 = strid_of(to_string_val(replv))
    ri: int32 = 0
    rl: int32 = str_len(rsid)
    while ri < rl:
        rc: uint8 = str_char(rsid, ri)
        if rc == 36 and ri + 1 < rl:
            dd: uint8 = str_char(rsid, ri + 1)
            if dd == 36:
                emit_c(36)
                ri = ri + 2
                continue
            if dd == 38:
                m: int32 = 0
                while m < pn:
                    emit_c(str_char(sid, found + m))
                    m = m + 1
                ri = ri + 2
                continue
        emit_c(rc)
        ri = ri + 1
    rid: int32 = bld_end()
    emit_tgt = save
    return rid


def re_plain_fn_id(sid: int32, fnv: int32, found: int32, pn: int32) -> int32:
    base: int32 = call_top
    call_args[call_top] = v_string_bytes(&sp_buf[st_off[sid] + found], pn)
    call_top = call_top + 1
    call_args[call_top] = v_number(cast[float64](found))
    call_top = call_top + 1
    call_args[call_top] = v_string_id(sid)
    call_top = call_top + 1
    rvf: int32 = invoke(fnv, v_undef(), base, 3)
    call_top = base
    return strid_of(to_string_val(rvf))


def str_replace_string(sid: int32, patv: int32, replv: int32) -> int32:
    return str_replace_plain(sid, patv, replv, 0)


def str_replace_all_string(sid: int32, patv: int32, replv: int32) -> int32:
    return str_replace_plain(sid, patv, replv, 1)


def str_split(sid: int32, sepv: int32) -> int32:
    v: int32 = v_new_array()
    o: int32 = objid_of(v)
    n: int32 = str_len(sid)
    if tag_of(sepv) == TAG_UNDEF:
        arr_push(o, v_string_id(sid))
        return v
    sep: int32 = strid_of(to_string_val(sepv))
    sl: int32 = str_len(sep)
    if sl == 0:
        # split into chars
        i: int32 = 0
        while i < n:
            arr_push(o, v_string_bytes(&sp_buf[st_off[sid] + i], 1))
            i = i + 1
        return v
    start: int32 = 0
    i2: int32 = 0
    while i2 + sl <= n:
        j: int32 = 0
        while j < sl and str_char(sid, i2 + j) == str_char(sep, j):
            j = j + 1
        if j == sl:
            arr_push(o, v_string_bytes(&sp_buf[st_off[sid] + start], i2 - start))
            i2 = i2 + sl
            start = i2
        else:
            i2 = i2 + 1
    arr_push(o, v_string_bytes(&sp_buf[st_off[sid] + start], n - start))
    return v


def emit_frac_padded(fp: uint64, d: int32):
    place: uint64 = 1
    i: int32 = 0
    while i < d - 1:
        place = place * 10
        i = i + 1
    while place > 0:
        emit_c(cast[uint8](48 + cast[int32]((fp / place) % 10)))
        place = place / 10


def num_tofixed(x: float64, d: int32) -> int32:
    if d < 0:
        d = 0
    if d > 20:
        d = 20
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    if is_nan(x) != 0:
        emit_cstr(cast[Ptr[uint8]]("NaN"))
        rid0: int32 = bld_end()
        emit_tgt = save
        return v_string_id(rid0)
    neg: int32 = 0
    if x < 0.0:
        neg = 1
        x = 0.0 - x
    p10: float64 = 1.0
    i: int32 = 0
    while i < d:
        p10 = p10 * 10.0
        i = i + 1
    scaled: float64 = f_floor(x * p10 + 0.5)
    s64: uint64 = cast[uint64](scaled)
    p64: uint64 = cast[uint64](p10)
    ip: uint64 = s64 / p64
    fp: uint64 = s64 % p64
    if neg != 0:
        emit_c(45)
    emit_u64(ip)
    if d > 0:
        emit_c(46)
        emit_frac_padded(fp, d)
    rid: int32 = bld_end()
    emit_tgt = save
    return v_string_id(rid)


def emit_radix(v: uint64, radix: int32):
    if v >= cast[uint64](radix):
        emit_radix(v / cast[uint64](radix), radix)
    dgt: int32 = cast[int32](v % cast[uint64](radix))
    if dgt < 10:
        emit_c(cast[uint8](48 + dgt))
    else:
        emit_c(cast[uint8](97 + dgt - 10))


def num_tostring_radix(x: float64, radix: int32) -> int32:
    if radix == 10 or radix < 2 or radix > 36 or f_trunc(x) != x or is_nan(x) != 0 or is_inf(x) != 0:
        return v_string_id(num_to_strid(x))
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    neg: int32 = 0
    if x < 0.0:
        neg = 1
        x = 0.0 - x
    if neg != 0:
        emit_c(45)
    emit_radix(cast[uint64](f_trunc(x)), radix)
    rid: int32 = bld_end()
    emit_tgt = save
    return v_string_id(rid)


# Number.prototype methods. Returns -2 if unrecognized (fall through to prop).
def try_number_method(nv: int32, name: int32, argnode: int32, env: int32) -> int32:
    x: float64 = v_num[nv]
    if str_eq_cstr(name, cast[Ptr[uint8]]("toFixed")) != 0:
        base: int32 = call_top
        argc: int32 = eval_args_into(argnode, env)
        d: int32 = 0
        if argc > 0:
            d = cast[int32](to_number(call_args[base]))
        call_top = base
        return num_tofixed(x, d)
    if str_eq_cstr(name, cast[Ptr[uint8]]("toString")) != 0:
        base2: int32 = call_top
        argc2: int32 = eval_args_into(argnode, env)
        radix: int32 = 10
        if argc2 > 0:
            radix = cast[int32](to_number(call_args[base2]))
        call_top = base2
        return num_tostring_radix(x, radix)
    if str_eq_cstr(name, cast[Ptr[uint8]]("valueOf")) != 0:
        eval_args_into(argnode, env)
        return nv
    return -2


def try_array_method(av: int32, name: int32, argnode: int32, env: int32) -> int32:
    # returns -2 if not a recognized array method (fall through to prop)
    o: int32 = objid_of(av)
    if str_eq_cstr(name, cast[Ptr[uint8]]("push")) != 0:
        base: int32 = call_top
        argc: int32 = eval_args_into(argnode, env)
        i: int32 = 0
        while i < argc:
            arr_push(o, call_args[base + i])
            i = i + 1
        call_top = base
        return v_number(cast[float64](arr_len[o]))
    if str_eq_cstr(name, cast[Ptr[uint8]]("pop")) != 0:
        eval_args_into(argnode, env)     # no args, but keep cursor clean
        call_top = call_top
        if arr_len[o] == 0:
            return v_undef()
        r: int32 = arr_get(o, arr_len[o] - 1)
        arr_len[o] = arr_len[o] - 1
        return r
    if str_eq_cstr(name, cast[Ptr[uint8]]("join")) != 0:
        base2: int32 = call_top
        argc2: int32 = eval_args_into(argnode, env)
        sepid: int32 = -1
        if argc2 > 0:
            sepid = strid_of(to_string_val(call_args[base2]))
        call_top = base2
        return array_join(o, sepid)
    if str_eq_cstr(name, cast[Ptr[uint8]]("indexOf")) != 0:
        base3: int32 = call_top
        argc3: int32 = eval_args_into(argnode, env)
        target: int32 = arg_or(base3, argc3, 0)
        idx: int32 = -1
        i2: int32 = 0
        while i2 < arr_len[o]:
            if strict_eq(arr_get(o, i2), target) != 0:
                idx = i2
                break
            i2 = i2 + 1
        call_top = base3
        return v_number(cast[float64](idx))
    if str_eq_cstr(name, cast[Ptr[uint8]]("map")) != 0:
        return array_map(o, argnode, env)
    if str_eq_cstr(name, cast[Ptr[uint8]]("forEach")) != 0:
        return array_foreach(o, argnode, env)
    if str_eq_cstr(name, cast[Ptr[uint8]]("filter")) != 0:
        return array_filter(o, argnode, env)
    if str_eq_cstr(name, cast[Ptr[uint8]]("reduce")) != 0:
        return array_reduce(o, argnode, env)
    if str_eq_cstr(name, cast[Ptr[uint8]]("slice")) != 0:
        return array_slice(o, argnode, env)
    if str_eq_cstr(name, cast[Ptr[uint8]]("shift")) != 0:
        eval_args_into(argnode, env)
        if arr_len[o] == 0:
            return v_undef()
        r2: int32 = arr_get(o, 0)
        i3: int32 = 1
        while i3 < arr_len[o]:
            arr_set(o, i3 - 1, arr_get(o, i3))
            i3 = i3 + 1
        arr_len[o] = arr_len[o] - 1
        return r2
    if str_eq_cstr(name, cast[Ptr[uint8]]("reverse")) != 0:
        eval_args_into(argnode, env)
        lo: int32 = 0
        hi: int32 = arr_len[o] - 1
        while lo < hi:
            t: int32 = arr_get(o, lo)
            arr_set(o, lo, arr_get(o, hi))
            arr_set(o, hi, t)
            lo = lo + 1
            hi = hi - 1
        return av
    if str_eq_cstr(name, cast[Ptr[uint8]]("lastIndexOf")) != 0:
        baseL: int32 = call_top
        argcL: int32 = eval_args_into(argnode, env)
        tgtL: int32 = arg_or(baseL, argcL, 0)
        idxL: int32 = -1
        iL: int32 = arr_len[o] - 1
        while iL >= 0:
            if strict_eq(arr_get(o, iL), tgtL) != 0:
                idxL = iL
                break
            iL = iL - 1
        call_top = baseL
        return v_number(cast[float64](idxL))
    if str_eq_cstr(name, cast[Ptr[uint8]]("includes")) != 0:
        baseI: int32 = call_top
        argcI: int32 = eval_args_into(argnode, env)
        tgtI: int32 = arg_or(baseI, argcI, 0)
        foundI: int32 = 0
        iI: int32 = 0
        while iI < arr_len[o]:
            if strict_eq(arr_get(o, iI), tgtI) != 0:
                foundI = 1
                break
            iI = iI + 1
        call_top = baseI
        return v_boolv(foundI)
    if str_eq_cstr(name, cast[Ptr[uint8]]("find")) != 0:
        return array_find(o, argnode, env, 0)
    if str_eq_cstr(name, cast[Ptr[uint8]]("findIndex")) != 0:
        return array_find(o, argnode, env, 1)
    if str_eq_cstr(name, cast[Ptr[uint8]]("some")) != 0:
        return array_some_every(o, argnode, env, 0)
    if str_eq_cstr(name, cast[Ptr[uint8]]("every")) != 0:
        return array_some_every(o, argnode, env, 1)
    if str_eq_cstr(name, cast[Ptr[uint8]]("concat")) != 0:
        return array_concat(av, argnode, env)
    if str_eq_cstr(name, cast[Ptr[uint8]]("reduceRight")) != 0:
        return array_reduce_right(o, argnode, env)
    if str_eq_cstr(name, cast[Ptr[uint8]]("sort")) != 0:
        return array_sort(av, argnode, env)
    if str_eq_cstr(name, cast[Ptr[uint8]]("flat")) != 0:
        return array_flat(o, argnode, env)
    if str_eq_cstr(name, cast[Ptr[uint8]]("fill")) != 0:
        return array_fill(av, argnode, env)
    if str_eq_cstr(name, cast[Ptr[uint8]]("splice")) != 0:
        return array_splice(av, argnode, env)
    if str_eq_cstr(name, cast[Ptr[uint8]]("unshift")) != 0:
        baseU: int32 = call_top
        argcU: int32 = eval_args_into(argnode, env)
        # shift existing elements right by argcU, then place new ones at front
        old: int32 = arr_len[o]
        k: int32 = old - 1
        while k >= 0:
            arr_set_ext(o, k + argcU, arr_get(o, k))
            k = k - 1
        j: int32 = 0
        while j < argcU:
            arr_set(o, j, call_args[baseU + j])
            j = j + 1
        arr_len[o] = old + argcU
        call_top = baseU
        return v_number(cast[float64](arr_len[o]))
    return -2


# arr_set that also grows arr_len to cover idx (used by unshift/splice growth).
def arr_set_ext(o: int32, idx: int32, val: int32):
    if idx >= arr_len[o]:
        arr_len[o] = idx + 1
    arr_set(o, idx, val)


def array_find(o: int32, argnode: int32, env: int32, want_index: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    fn: int32 = arg_or(base, argc, 0)
    res: int32 = v_undef()
    if want_index != 0:
        res = v_number(-1.0)
    i: int32 = 0
    while i < arr_len[o] and err_flag == 0:
        cb: int32 = call_top
        call_args[call_top] = arr_get(o, i)
        call_args[call_top + 1] = v_number(cast[float64](i))
        call_top = call_top + 2
        rv: int32 = invoke(fn, v_undef(), cb, 2)
        call_top = cb
        if to_bool(rv) != 0:
            if want_index != 0:
                res = v_number(cast[float64](i))
            else:
                res = arr_get(o, i)
            break
        i = i + 1
    call_top = base
    return res


def array_some_every(o: int32, argnode: int32, env: int32, is_every: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    fn: int32 = arg_or(base, argc, 0)
    result: int32 = is_every            # every starts true(1), some starts false(0)
    i: int32 = 0
    while i < arr_len[o] and err_flag == 0:
        cb: int32 = call_top
        call_args[call_top] = arr_get(o, i)
        call_args[call_top + 1] = v_number(cast[float64](i))
        call_top = call_top + 2
        rv: int32 = invoke(fn, v_undef(), cb, 2)
        call_top = cb
        tb: int32 = to_bool(rv)
        if is_every != 0 and tb == 0:
            result = 0
            break
        if is_every == 0 and tb != 0:
            result = 1
            break
        i = i + 1
    call_top = base
    return v_boolv(result)


def array_concat(av: int32, argnode: int32, env: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    res: int32 = v_new_array()
    ro: int32 = objid_of(res)
    src: int32 = objid_of(av)
    i: int32 = 0
    while i < arr_len[src]:
        arr_push(ro, arr_get(src, i))
        i = i + 1
    a: int32 = 0
    while a < argc:
        el: int32 = call_args[base + a]
        if is_array(el) != 0:
            eo: int32 = objid_of(el)
            j: int32 = 0
            while j < arr_len[eo]:
                arr_push(ro, arr_get(eo, j))
                j = j + 1
        else:
            arr_push(ro, el)
        a = a + 1
    call_top = base
    return res


def array_reduce_right(o: int32, argnode: int32, env: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    fn: int32 = arg_or(base, argc, 0)
    acc: int32 = v_undef()
    i: int32 = arr_len[o] - 1
    if argc > 1:
        acc = call_args[base + 1]
    else:
        if arr_len[o] > 0:
            acc = arr_get(o, i)
            i = i - 1
    while i >= 0 and err_flag == 0:
        cb: int32 = call_top
        call_args[call_top] = acc
        call_args[call_top + 1] = arr_get(o, i)
        call_args[call_top + 2] = v_number(cast[float64](i))
        call_top = call_top + 3
        acc = invoke(fn, v_undef(), cb, 3)
        call_top = cb
        i = i - 1
    call_top = base
    return acc


# String-key lexicographic compare of two values as their toString(). -1/0/1.
def cmp_str_vals(a: int32, b: int32) -> int32:
    sa: int32 = strid_of(to_string_val(a))
    sb: int32 = strid_of(to_string_val(b))
    la: int32 = str_len(sa)
    lb: int32 = str_len(sb)
    i: int32 = 0
    while i < la and i < lb:
        ca: uint8 = str_char(sa, i)
        cbc: uint8 = str_char(sb, i)
        if ca < cbc:
            return -1
        if ca > cbc:
            return 1
        i = i + 1
    if la < lb:
        return -1
    if la > lb:
        return 1
    return 0


# In-place stable insertion sort. Default = lexicographic on toString();
# with a comparator fn, use its sign. Returns the array value.
def array_sort(av: int32, argnode: int32, env: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    fn: int32 = arg_or(base, argc, 0)
    has_fn: int32 = is_callable(fn)
    o: int32 = objid_of(av)
    n: int32 = arr_len[o]
    i: int32 = 1
    while i < n and err_flag == 0:
        cur: int32 = arr_get(o, i)
        j: int32 = i - 1
        while j >= 0:
            c: int32 = 0
            if has_fn != 0:
                cb: int32 = call_top
                call_args[call_top] = arr_get(o, j)
                call_args[call_top + 1] = cur
                call_top = call_top + 2
                rv: int32 = invoke(fn, v_undef(), cb, 2)
                call_top = cb
                d: float64 = to_number(rv)
                if d > 0.0:
                    c = 1
                elif d < 0.0:
                    c = -1
                else:
                    c = 0
            else:
                c = cmp_str_vals(arr_get(o, j), cur)
            if c > 0:
                arr_set(o, j + 1, arr_get(o, j))
                j = j - 1
            else:
                break
        arr_set(o, j + 1, cur)
        i = i + 1
    call_top = base
    return av


def array_flat(o: int32, argnode: int32, env: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    depth: int32 = 1
    if argc > 0:
        depth = cast[int32](to_number(call_args[base]))
    call_top = base
    res: int32 = v_new_array()
    array_flat_into(o, objid_of(res), depth)
    return res


def array_flat_into(o: int32, ro: int32, depth: int32):
    i: int32 = 0
    while i < arr_len[o]:
        el: int32 = arr_get(o, i)
        if depth > 0 and is_array(el) != 0:
            array_flat_into(objid_of(el), ro, depth - 1)
        else:
            arr_push(ro, el)
        i = i + 1


def array_fill(av: int32, argnode: int32, env: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    o: int32 = objid_of(av)
    val: int32 = arg_or(base, argc, 0)
    n: int32 = arr_len[o]
    st: int32 = 0
    en: int32 = n
    if argc > 1:
        st = cast[int32](to_number(call_args[base + 1]))
    if argc > 2:
        en = cast[int32](to_number(call_args[base + 2]))
    call_top = base
    if st < 0:
        st = n + st
        if st < 0:
            st = 0
    if en < 0:
        en = n + en
    if en > n:
        en = n
    i: int32 = st
    while i < en:
        arr_set(o, i, val)
        i = i + 1
    return av


# Array.prototype.splice(start, deleteCount, ...items). Mutates av; returns an
# array of the removed elements.
def array_splice(av: int32, argnode: int32, env: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    o: int32 = objid_of(av)
    n: int32 = arr_len[o]
    st: int32 = 0
    if argc > 0:
        st = cast[int32](to_number(call_args[base]))
    if st < 0:
        st = n + st
        if st < 0:
            st = 0
    if st > n:
        st = n
    delc: int32 = n - st
    if argc > 1:
        delc = cast[int32](to_number(call_args[base + 1]))
        if delc < 0:
            delc = 0
        if delc > n - st:
            delc = n - st
    n_ins: int32 = argc - 2
    if n_ins < 0:
        n_ins = 0
    # removed slice
    removed: int32 = v_new_array()
    rro: int32 = objid_of(removed)
    r: int32 = 0
    while r < delc:
        arr_push(rro, arr_get(o, st + r))
        r = r + 1
    # build the new tail into a scratch by rebuilding the array in place.
    new_len: int32 = n - delc + n_ins
    diff: int32 = n_ins - delc
    if diff > 0:
        # shift right, from the end
        k: int32 = n - 1
        while k >= st + delc:
            arr_set_ext(o, k + diff, arr_get(o, k))
            k = k - 1
    elif diff < 0:
        # shift left
        k2: int32 = st + delc
        while k2 < n:
            arr_set(o, k2 + diff, arr_get(o, k2))
            k2 = k2 + 1
    # insert new items
    ins: int32 = 0
    while ins < n_ins:
        arr_set(o, st + ins, call_args[base + 2 + ins])
        ins = ins + 1
    arr_len[o] = new_len
    call_top = base
    return removed


def array_join(o: int32, sepid: int32) -> int32:
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    i: int32 = 0
    while i < arr_len[o]:
        if i > 0:
            if sepid >= 0:
                emit_strid(sepid)
            else:
                emit_c(44)             # default ','
        el: int32 = arr_get(o, i)
        if tag_of(el) != TAG_UNDEF and tag_of(el) != TAG_NULL:
            display_val(el)
        i = i + 1
    id: int32 = bld_end()
    emit_tgt = save
    return v_string_id(id)


def array_map(o: int32, argnode: int32, env: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    fn: int32 = arg_or(base, argc, 0)
    res: int32 = v_new_array()
    ro: int32 = objid_of(res)
    i: int32 = 0
    while i < arr_len[o] and err_flag == 0:
        cb: int32 = call_top
        call_args[call_top] = arr_get(o, i)
        call_args[call_top + 1] = v_number(cast[float64](i))
        call_top = call_top + 2
        rv: int32 = invoke(fn, v_undef(), cb, 2)
        call_top = cb
        arr_push(ro, rv)
        i = i + 1
    call_top = base
    return res


def array_filter(o: int32, argnode: int32, env: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    fn: int32 = arg_or(base, argc, 0)
    res: int32 = v_new_array()
    ro: int32 = objid_of(res)
    i: int32 = 0
    while i < arr_len[o] and err_flag == 0:
        cb: int32 = call_top
        call_args[call_top] = arr_get(o, i)
        call_args[call_top + 1] = v_number(cast[float64](i))
        call_top = call_top + 2
        rv: int32 = invoke(fn, v_undef(), cb, 2)
        call_top = cb
        if to_bool(rv) != 0:
            arr_push(ro, arr_get(o, i))
        i = i + 1
    call_top = base
    return res


def array_reduce(o: int32, argnode: int32, env: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    fn: int32 = arg_or(base, argc, 0)
    acc: int32 = v_undef()
    i: int32 = 0
    if argc > 1:
        acc = call_args[base + 1]
    else:
        if arr_len[o] > 0:
            acc = arr_get(o, 0)
            i = 1
    while i < arr_len[o] and err_flag == 0:
        cb: int32 = call_top
        call_args[call_top] = acc
        call_args[call_top + 1] = arr_get(o, i)
        call_args[call_top + 2] = v_number(cast[float64](i))
        call_top = call_top + 3
        acc = invoke(fn, v_undef(), cb, 3)
        call_top = cb
        i = i + 1
    call_top = base
    return acc


def array_foreach(o: int32, argnode: int32, env: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    fn: int32 = arg_or(base, argc, 0)
    i: int32 = 0
    while i < arr_len[o] and err_flag == 0:
        cb: int32 = call_top
        call_args[call_top] = arr_get(o, i)
        call_args[call_top + 1] = v_number(cast[float64](i))
        call_top = call_top + 2
        invoke(fn, v_undef(), cb, 2)
        call_top = cb
        i = i + 1
    call_top = base
    return v_undef()


def array_slice(o: int32, argnode: int32, env: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    st: int32 = 0
    en: int32 = arr_len[o]
    if argc > 0:
        st = cast[int32](to_number(call_args[base]))
    if argc > 1:
        en = cast[int32](to_number(call_args[base + 1]))
    call_top = base
    if st < 0:
        st = arr_len[o] + st
        if st < 0:
            st = 0
    if en < 0:
        en = arr_len[o] + en
    if en > arr_len[o]:
        en = arr_len[o]
    res: int32 = v_new_array()
    ro: int32 = objid_of(res)
    i: int32 = st
    while i < en:
        arr_push(ro, arr_get(o, i))
        i = i + 1
    return res


# ====================================================================
# NATIVE builtins (Math, JSON, console, parseInt, ...).
# ====================================================================
def call_native(id: int32, thisv: int32, base: int32, argc: int32) -> int32:
    if id >= HOST_NATIVE_BASE:
        if host_dispatch_set != 0:
            # expose args + receiver for the host dispatcher via globals
            hostcall_base = base
            hostcall_argc = argc
            hostcall_this = thisv
            hf: Fn[int32, int32] = cast[Fn[int32, int32]](host_dispatch_addr)
            return hf(id)
        return v_undef()
    if id == NAT_CONSOLE_LOG:
        emit_tgt = 1
        i: int32 = 0
        while i < argc:
            if i > 0:
                emit_c(32)
            display_val(call_args[base + i])
            i = i + 1
        emit_c(10)
        return v_undef()
    if id == NAT_PARSEINT:
        return native_parseint(base, argc)
    if id == NAT_PARSEFLOAT:
        s: int32 = to_string_val(arg_or(base, argc, 0))
        return v_number(parse_num_bytes(str_ptr(strid_of(s)), str_len(strid_of(s))))
    if id == NAT_ISNAN:
        return v_boolv(is_nan(to_number(arg_or(base, argc, 0))))
    if id == NAT_STRING:
        if argc == 0:
            return v_string_cstr(cast[Ptr[uint8]](""))
        return to_string_val(call_args[base])
    if id == NAT_NUMBER:
        if argc == 0:
            return v_number(0.0)
        return v_number(to_number(call_args[base]))
    if id == NAT_BOOLEAN:
        return v_boolv(to_bool(arg_or(base, argc, 0)))
    if id == NAT_MATH_FLOOR:
        return v_number(f_floor(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_CEIL:
        return v_number(f_ceil(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_ROUND:
        return v_number(f_floor(to_number(arg_or(base, argc, 0)) + 0.5))
    if id == NAT_MATH_ABS:
        return v_number(f_abs(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_SQRT:
        return v_number(f_sqrt(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_TRUNC:
        return v_number(f_trunc(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_POW:
        return v_number(f_pow(to_number(arg_or(base, argc, 0)), to_number(arg_or(base, argc, 1))))
    if id == NAT_MATH_MIN:
        return native_minmax(base, argc, 0)
    if id == NAT_MATH_MAX:
        return native_minmax(base, argc, 1)
    if id == NAT_MATH_SIGN:
        return v_number(f_sign(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_CBRT:
        return v_number(f_cbrt(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_HYPOT:
        return v_number(f_hypot(to_number(arg_or(base, argc, 0)), to_number(arg_or(base, argc, 1))))
    if id == NAT_MATH_LOG:
        return v_number(f_ln(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_LOG2:
        return v_number(f_ln(to_number(arg_or(base, argc, 0))) / 0.6931471805599453)
    if id == NAT_MATH_LOG10:
        return v_number(f_ln(to_number(arg_or(base, argc, 0))) / 2.302585092994046)
    if id == NAT_MATH_EXP:
        return v_number(f_exp(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_SIN:
        return v_number(f_sin(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_COS:
        return v_number(f_cos(to_number(arg_or(base, argc, 0))))
    if id == NAT_MATH_TAN:
        tx: float64 = to_number(arg_or(base, argc, 0))
        return v_number(f_sin(tx) / f_cos(tx))
    if id == NAT_MATH_RANDOM:
        return v_number(f_random())
    if id == NAT_ISFINITE:
        fx: float64 = to_number(arg_or(base, argc, 0))
        if is_nan(fx) != 0 or is_inf(fx) != 0:
            return v_boolv(0)
        return v_boolv(1)
    if id == NAT_NUMBER_ISNAN:
        v0: int32 = arg_or(base, argc, 0)
        if tag_of(v0) != TAG_NUM:
            return v_boolv(0)
        return v_boolv(is_nan(v_num[v0]))
    if id == NAT_NUMBER_ISFINITE:
        v1: int32 = arg_or(base, argc, 0)
        if tag_of(v1) != TAG_NUM:
            return v_boolv(0)
        if is_nan(v_num[v1]) != 0 or is_inf(v_num[v1]) != 0:
            return v_boolv(0)
        return v_boolv(1)
    if id == NAT_NUMBER_ISINTEGER:
        v2: int32 = arg_or(base, argc, 0)
        if tag_of(v2) != TAG_NUM:
            return v_boolv(0)
        nx: float64 = v_num[v2]
        if is_nan(nx) != 0 or is_inf(nx) != 0:
            return v_boolv(0)
        if f_trunc(nx) == nx:
            return v_boolv(1)
        return v_boolv(0)
    if id == NAT_OBJECT_ENTRIES:
        return object_entries(arg_or(base, argc, 0))
    if id == NAT_OBJECT_FROMENTRIES:
        return object_fromentries(arg_or(base, argc, 0))
    if id == NAT_OBJECT_FREEZE:
        return arg_or(base, argc, 0)
    if id == NAT_JSON_STRINGIFY:
        return json_stringify(arg_or(base, argc, 0), json_indent_of(arg_or(base, argc, 2)))
    if id == NAT_JSON_PARSE:
        return json_parse_val(arg_or(base, argc, 0))
    if id == NAT_OBJECT_KEYS:
        return object_keys(arg_or(base, argc, 0))
    if id == NAT_ARRAY_ISARRAY:
        return v_boolv(is_array(arg_or(base, argc, 0)))
    if id == NAT_ERROR or id == NAT_TYPEERROR or id == NAT_RANGEERROR or id == NAT_SYNTAXERROR or id == NAT_REFERENCEERROR:
        return make_error(id, thisv, base, argc)
    if id == NAT_OBJECT_ASSIGN:
        return object_assign(base, argc)
    if id == NAT_OBJECT_VALUES:
        return object_values(arg_or(base, argc, 0))
    if id == NAT_ARRAY_CTOR or id == NAT_ARRAY_OF:
        return array_ctor(id, base, argc)
    if id == NAT_REGEXP:
        pat: int32 = arg_or(base, argc, 0)
        src_sid: int32 = 0
        if is_regex(pat) != 0:
            src_sid = strid_of(obj_get_cstr(objid_of(pat), cast[Ptr[uint8]]("source")))
        elif tag_of(pat) == TAG_UNDEF:
            src_sid = str_from_cstr(cast[Ptr[uint8]](""))
        else:
            src_sid = strid_of(to_string_val(pat))
        flags_sid: int32 = str_from_cstr(cast[Ptr[uint8]](""))
        if argc > 1 and tag_of(call_args[base + 1]) != TAG_UNDEF:
            flags_sid = strid_of(to_string_val(call_args[base + 1]))
        elif is_regex(pat) != 0:
            flags_sid = strid_of(obj_get_cstr(objid_of(pat), cast[Ptr[uint8]]("flags")))
        return js_make_regex(src_sid, flags_sid)
    return v_undef()


def err_name_of(id: int32) -> Ptr[uint8]:
    if id == NAT_TYPEERROR:
        return cast[Ptr[uint8]]("TypeError")
    if id == NAT_RANGEERROR:
        return cast[Ptr[uint8]]("RangeError")
    if id == NAT_SYNTAXERROR:
        return cast[Ptr[uint8]]("SyntaxError")
    if id == NAT_REFERENCEERROR:
        return cast[Ptr[uint8]]("ReferenceError")
    return cast[Ptr[uint8]]("Error")


def make_error(id: int32, thisv: int32, base: int32, argc: int32) -> int32:
    ev: int32 = thisv
    if tag_of(ev) != TAG_OBJ:
        ev = v_new_object()             # allow `Error(...)` without `new`
    o: int32 = objid_of(ev)
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("name")), v_string_cstr(err_name_of(id)))
    msg: int32 = v_string_cstr(cast[Ptr[uint8]](""))
    if argc > 0:
        msg = to_string_val(call_args[base])
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("message")), msg)
    return ev


def object_assign(base: int32, argc: int32) -> int32:
    if argc == 0:
        return v_new_object()
    tgt: int32 = call_args[base]
    if tag_of(tgt) != TAG_OBJ:
        tgt = v_new_object()
    i: int32 = 1
    while i < argc:
        src: int32 = call_args[base + i]
        if tag_of(src) == TAG_OBJ:
            copy_own_props(objid_of(src), objid_of(tgt))
        i = i + 1
    return tgt


def object_values(v: int32) -> int32:
    ro: int32 = v_new_array()
    if tag_of(v) != TAG_OBJ:
        return ro
    o: int32 = objid_of(v)
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        i: int32 = 0
        while i < arr_len[o]:
            arr_push(objid_of(ro), arr_get(o, i))
            i = i + 1
        return ro
    object_values_rec(obj_head[o], objid_of(ro))
    return ro


def object_values_rec(p: int32, ro: int32):
    if p < 0:
        return
    object_values_rec(p_next[p], ro)
    arr_push(ro, p_val[p])


# Object.entries -> array of [key, value] pairs (insertion order).
def object_entries(v: int32) -> int32:
    res: int32 = v_new_array()
    ro: int32 = objid_of(res)
    if tag_of(v) != TAG_OBJ:
        return res
    o: int32 = objid_of(v)
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        i: int32 = 0
        while i < arr_len[o]:
            pair: int32 = v_new_array()
            arr_push(objid_of(pair), v_string_id(num_to_strid(cast[float64](i))))
            arr_push(objid_of(pair), arr_get(o, i))
            arr_push(ro, pair)
            i = i + 1
        return res
    object_entries_rec(obj_head[o], ro)
    return res


def object_entries_rec(p: int32, ro: int32):
    if p < 0:
        return
    object_entries_rec(p_next[p], ro)
    pair: int32 = v_new_array()
    arr_push(objid_of(pair), v_string_id(p_key[p]))
    arr_push(objid_of(pair), p_val[p])
    arr_push(ro, pair)


# Object.fromEntries([[k,v],...]) -> object.
def object_fromentries(v: int32) -> int32:
    res: int32 = v_new_object()
    if is_array(v) == 0:
        return res
    ro: int32 = objid_of(res)
    o: int32 = objid_of(v)
    i: int32 = 0
    while i < arr_len[o]:
        e: int32 = arr_get(o, i)
        if is_array(e) != 0:
            eo: int32 = objid_of(e)
            kv: int32 = v_undef()
            vv: int32 = v_undef()
            if arr_len[eo] > 0:
                kv = arr_get(eo, 0)
            if arr_len[eo] > 1:
                vv = arr_get(eo, 1)
            obj_set(ro, strid_of(to_string_val(kv)), vv)
        i = i + 1
    return res


def array_ctor(id: int32, base: int32, argc: int32) -> int32:
    av: int32 = v_new_array()
    o: int32 = objid_of(av)
    if id == NAT_ARRAY_CTOR and argc == 1 and tag_of(call_args[base]) == TAG_NUM:
        n: int32 = cast[int32](v_num[call_args[base]])
        i: int32 = 0
        while i < n:
            arr_push(o, v_undef())
            i = i + 1
        return av
    j: int32 = 0
    while j < argc:
        arr_push(o, call_args[base + j])
        j = j + 1
    return av


hostcall_base: int32 = 0
hostcall_argc: int32 = 0
hostcall_this: int32 = 0


def native_parseint(base: int32, argc: int32) -> int32:
    s: int32 = strid_of(to_string_val(arg_or(base, argc, 0)))
    p: Ptr[uint8] = str_ptr(s)
    n: int32 = str_len(s)
    i: int32 = 0
    while i < n and is_ws(p[i]) != 0:
        i = i + 1
    sign: float64 = 1.0
    if i < n and p[i] == 43:
        i = i + 1
    elif i < n and p[i] == 45:
        sign = -1.0
        i = i + 1
    radix: int32 = 10
    if argc > 1:
        radix = cast[int32](to_number(call_args[base + 1]))
        if radix == 0:
            radix = 10
    if radix == 16 and i + 1 < n and p[i] == 48 and (p[i + 1] == 120 or p[i + 1] == 88):
        i = i + 2
    elif i + 1 < n and p[i] == 48 and (p[i + 1] == 120 or p[i + 1] == 88):
        radix = 16
        i = i + 2
    val: float64 = 0.0
    any: int32 = 0
    while i < n:
        c: uint8 = p[i]
        d: int32 = -1
        if c >= 48 and c <= 57:
            d = cast[int32](c) - 48
        elif c >= 97 and c <= 122:
            d = cast[int32](c) - 87
        elif c >= 65 and c <= 90:
            d = cast[int32](c) - 55
        if d < 0 or d >= radix:
            break
        val = val * cast[float64](radix) + cast[float64](d)
        any = 1
        i = i + 1
    if any == 0:
        return v_number(0.0 / 0.0)
    return v_number(sign * val)


def native_minmax(base: int32, argc: int32, ismax: int32) -> int32:
    if argc == 0:
        if ismax != 0:
            return v_number(-1.0e309)   # -Infinity approx
        return v_number(1.0e309)
    r: float64 = to_number(call_args[base])
    i: int32 = 1
    while i < argc:
        x: float64 = to_number(call_args[base + i])
        if ismax != 0:
            if x > r:
                r = x
        else:
            if x < r:
                r = x
        i = i + 1
    return v_number(r)


def object_keys(v: int32) -> int32:
    res: int32 = v_new_array()
    ro: int32 = objid_of(res)
    if tag_of(v) != TAG_OBJ:
        return res
    o: int32 = objid_of(v)
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        i: int32 = 0
        while i < arr_len[o]:
            arr_push(ro, v_string_id(num_to_strid(cast[float64](i))))
            i = i + 1
        return res
    object_keys_rec(obj_head[o], ro)
    return res


def object_keys_rec(p: int32, ro: int32):
    if p < 0:
        return
    object_keys_rec(p_next[p], ro)
    arr_push(ro, v_string_id(p_key[p]))


# ---- JSON ----
# json_indent = spaces per level for the pretty-print (0 = compact single line).
# json_depth  = current nesting depth, used to size the indentation runs.
json_indent: int32 = 0
json_depth:  int32 = 0


# Resolve the 3rd stringify arg (the `space` reviver) into a spaces-per-level
# count. JS accepts a number (clamped 0..10) or a string (its length); we honor
# the numeric form (the common `JSON.stringify(v, null, 2)`) and treat a string
# by its length.
def json_indent_of(sp: int32) -> int32:
    t: int32 = tag_of(sp)
    n: int32 = 0
    if t == TAG_NUM:
        n = cast[int32](v_num[sp])
    elif t == TAG_STR:
        n = str_len(strid_of(sp))
    if n < 0:
        n = 0
    if n > 10:
        n = 10
    return n


def json_nl():
    emit_c(10)
    total: int32 = json_depth * json_indent
    k: int32 = 0
    while k < total:
        emit_c(32)
        k = k + 1


def json_stringify(v: int32, indent: int32) -> int32:
    save: int32 = emit_tgt
    save_ind: int32 = json_indent
    save_dep: int32 = json_depth
    emit_tgt = 0
    json_indent = indent
    json_depth = 0
    bld_begin()
    json_emit(v)
    id: int32 = bld_end()
    emit_tgt = save
    json_indent = save_ind
    json_depth = save_dep
    if st_len[id] == 0:
        return v_undef()
    return v_string_id(id)


def json_emit(v: int32):
    t: int32 = tag_of(v)
    if t == TAG_UNDEF:
        return                         # undefined -> omitted (caller-handled)
    if t == TAG_NULL:
        emit_cstr(cast[Ptr[uint8]]("null"))
        return
    if t == TAG_BOOL:
        if v == 2:
            emit_cstr(cast[Ptr[uint8]]("true"))
        else:
            emit_cstr(cast[Ptr[uint8]]("false"))
        return
    if t == TAG_NUM:
        if is_nan(v_num[v]) != 0 or is_inf(v_num[v]) != 0:
            emit_cstr(cast[Ptr[uint8]]("null"))
        else:
            emit_num(v_num[v])
        return
    if t == TAG_STR:
        json_emit_string(strid_of(v))
        return
    o: int32 = objid_of(v)
    if cast[int32](obj_kind[o]) == OK_ARRAY:
        emit_c(91)
        n_el: int32 = arr_len[o]
        if n_el > 0 and json_indent > 0:
            json_depth = json_depth + 1
        i: int32 = 0
        while i < n_el:
            if i > 0:
                emit_c(44)
            if json_indent > 0:
                json_nl()
            el: int32 = arr_get(o, i)
            if tag_of(el) == TAG_UNDEF or is_callable(el) != 0:
                emit_cstr(cast[Ptr[uint8]]("null"))
            else:
                json_emit(el)
            i = i + 1
        if n_el > 0 and json_indent > 0:
            json_depth = json_depth - 1
            json_nl()
        emit_c(93)
        return
    if cast[int32](obj_kind[o]) == OK_FUNC:
        return
    emit_c(123)
    save_any: int32 = json_emitted_any
    json_emitted_any = 0
    if json_indent > 0:
        json_depth = json_depth + 1
    json_emit_props(obj_head[o], 1)
    printed: int32 = json_emitted_any
    if json_indent > 0:
        json_depth = json_depth - 1
        if printed != 0:
            json_nl()
    json_emitted_any = save_any
    emit_c(125)


def json_emit_props(p: int32, is_last: int32):
    if p < 0:
        return
    json_emit_props(p_next[p], 0)
    v: int32 = p_val[p]
    if tag_of(v) == TAG_UNDEF or is_callable(v) != 0:
        return
    # emit comma if something was printed before this (deeper recursion did)
    if json_emitted_any != 0:
        emit_c(44)
    if json_indent > 0:
        json_nl()
    json_emitted_any = 1
    json_emit_string(p_key[p])
    emit_c(58)
    if json_indent > 0:
        emit_c(32)
    json_emit(v)


json_emitted_any: int32 = 0


def json_emit_string(sid: int32):
    emit_c(34)
    n: int32 = str_len(sid)
    i: int32 = 0
    while i < n:
        c: uint8 = str_char(sid, i)
        if c == 34:
            emit_c(92)
            emit_c(34)
        elif c == 92:
            emit_c(92)
            emit_c(92)
        elif c == 10:
            emit_c(92)
            emit_c(110)
        elif c == 9:
            emit_c(92)
            emit_c(116)
        elif c == 13:
            emit_c(92)
            emit_c(114)
        elif c == 8:
            emit_c(92)
            emit_c(98)
        elif c == 12:
            emit_c(92)
            emit_c(102)
        elif c < 32:
            # other control chars -> \u00XX
            emit_c(92)
            emit_c(117)
            emit_c(48)
            emit_c(48)
            emit_hex_nibble(cast[int32](c) / 16)
            emit_hex_nibble(cast[int32](c) & 15)
        else:
            emit_c(c)
        i = i + 1
    emit_c(34)


def emit_hex_nibble(d: int32):
    if d < 10:
        emit_c(cast[uint8](48 + d))
    else:
        emit_c(cast[uint8](87 + d))


# JSON.parse — parse a JS string value into a JS value.
jp_p: Ptr[uint8] = 0
jp_n: int32 = 0
jp_i: int32 = 0


def json_syntax_error():
    throw_error(cast[Ptr[uint8]]("SyntaxError"), cast[Ptr[uint8]]("Unexpected token in JSON"))


def json_parse_val(sv: int32) -> int32:
    s: int32 = strid_of(to_string_val(sv))
    jp_p = str_ptr(s)
    jp_n = str_len(s)
    jp_i = 0
    r: int32 = jp_value()
    if ctl == CTL_THROW:
        return v_undef()
    # reject trailing garbage after the top-level value
    jp_ws()
    if jp_i < jp_n:
        json_syntax_error()
        return v_undef()
    return r


# Match a bare literal (true/false/null) exactly; throw on any mismatch.
def jp_lit(word: Ptr[uint8], wlen: int32) -> int32:
    k: int32 = 0
    while k < wlen:
        if jp_i + k >= jp_n or jp_p[jp_i + k] != word[k]:
            json_syntax_error()
            return 0
        k = k + 1
    jp_i = jp_i + wlen
    return 1


def jp_ws():
    while jp_i < jp_n and is_ws(jp_p[jp_i]) != 0:
        jp_i = jp_i + 1


def jp_value() -> int32:
    jp_ws()
    if jp_i >= jp_n:
        json_syntax_error()
        return v_undef()
    c: uint8 = jp_p[jp_i]
    if c == 123:
        return jp_object()
    if c == 91:
        return jp_array()
    if c == 34:
        return v_string_id(jp_string())
    if c == 116:                       # true
        if jp_lit(cast[Ptr[uint8]]("true"), 4) != 0:
            return v_true()
        return v_undef()
    if c == 102:                       # false
        if jp_lit(cast[Ptr[uint8]]("false"), 5) != 0:
            return v_false()
        return v_undef()
    if c == 110:                       # null
        if jp_lit(cast[Ptr[uint8]]("null"), 4) != 0:
            return v_null()
        return v_undef()
    # number: optional '-', at least one digit, optional fraction/exponent
    if c != 45 and is_digit(c) == 0:
        json_syntax_error()
        return v_undef()
    start: int32 = jp_i
    if c == 45:
        jp_i = jp_i + 1
    ndig: int32 = 0
    while jp_i < jp_n and (is_digit(jp_p[jp_i]) != 0 or jp_p[jp_i] == 46 or jp_p[jp_i] == 101 or jp_p[jp_i] == 69 or jp_p[jp_i] == 43 or jp_p[jp_i] == 45):
        if is_digit(jp_p[jp_i]) != 0:
            ndig = ndig + 1
        jp_i = jp_i + 1
    if ndig == 0:
        json_syntax_error()
        return v_undef()
    return v_number(parse_num_bytes(&jp_p[start], jp_i - start))


def jp_string() -> int32:
    if jp_i >= jp_n or jp_p[jp_i] != 34:
        json_syntax_error()
        return str_from_cstr(cast[Ptr[uint8]](""))
    jp_i = jp_i + 1                    # opening quote
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    while jp_i < jp_n and jp_p[jp_i] != 34:
        c: uint8 = jp_p[jp_i]
        if c == 92:
            jp_i = jp_i + 1
            if jp_i >= jp_n:
                break
            e: uint8 = jp_p[jp_i]
            if e == 110:
                emit_c(10)
            elif e == 116:
                emit_c(9)
            elif e == 114:
                emit_c(13)
            elif e == 98:
                emit_c(8)
            elif e == 102:
                emit_c(12)
            elif e == 34:
                emit_c(34)
            elif e == 92:
                emit_c(92)
            elif e == 47:
                emit_c(47)
            elif e == 117:
                # \uXXXX -> emit low byte only (ASCII subset)
                emit_c(jp_hex4())
            else:
                emit_c(e)
            jp_i = jp_i + 1
        else:
            emit_c(c)
            jp_i = jp_i + 1
    id: int32 = bld_end()
    emit_tgt = save
    if jp_i >= jp_n:                   # ran off the end with no closing quote
        json_syntax_error()
        return id
    jp_i = jp_i + 1                    # closing quote
    return id


def jp_hex4() -> uint8:
    v: int32 = 0
    k: int32 = 0
    while k < 4:
        c: uint8 = jp_p[jp_i + 1 + k]
        d: int32 = 0
        if c >= 48 and c <= 57:
            d = cast[int32](c) - 48
        elif c >= 97 and c <= 102:
            d = cast[int32](c) - 87
        elif c >= 65 and c <= 70:
            d = cast[int32](c) - 55
        v = v * 16 + d
        k = k + 1
    jp_i = jp_i + 4
    return cast[uint8](v & 255)


def jp_array() -> int32:
    jp_i = jp_i + 1                    # [
    v: int32 = v_new_array()
    o: int32 = objid_of(v)
    jp_ws()
    if jp_i < jp_n and jp_p[jp_i] == 93:  # empty []
        jp_i = jp_i + 1
        return v
    while jp_i < jp_n and ctl != CTL_THROW:
        arr_push(o, jp_value())
        if ctl == CTL_THROW:
            return v
        jp_ws()
        if jp_i < jp_n and jp_p[jp_i] == 44:
            jp_i = jp_i + 1
            continue
        if jp_i < jp_n and jp_p[jp_i] == 93:
            jp_i = jp_i + 1
            return v
        json_syntax_error()             # neither ',' nor ']' -> malformed
        return v
    return v


def jp_object() -> int32:
    jp_i = jp_i + 1                    # {
    v: int32 = v_new_object()
    o: int32 = objid_of(v)
    jp_ws()
    if jp_i < jp_n and jp_p[jp_i] == 125:  # empty {}
        jp_i = jp_i + 1
        return v
    while jp_i < jp_n and ctl != CTL_THROW:
        jp_ws()
        key: int32 = jp_string()        # throws unless a "..." key
        if ctl == CTL_THROW:
            return v
        jp_ws()
        if jp_i < jp_n and jp_p[jp_i] == 58:
            jp_i = jp_i + 1
        else:
            json_syntax_error()         # missing ':'
            return v
        val: int32 = jp_value()
        if ctl == CTL_THROW:
            return v
        obj_set(o, key, val)
        jp_ws()
        if jp_i < jp_n and jp_p[jp_i] == 44:
            jp_i = jp_i + 1
            continue
        if jp_i < jp_n and jp_p[jp_i] == 125:
            jp_i = jp_i + 1
            return v
        json_syntax_error()             # neither ',' nor '}' -> malformed
        return v
    return v


# ====================================================================
# SETUP — build the global environment + builtin objects.
# ====================================================================
# ====================================================================
# REGULAR EXPRESSIONS
#   source -> recursive-descent parse -> regex AST -> backtracking bytecode
#   -> a recursive backtracking VM (correct over fast; supports backrefs).
# Supported: literals, `.`, classes [a-z]/[^..], anchors ^ $ (m), quantifiers
# * + ? {n} {n,} {n,m} (greedy + lazy `?`), groups ( ) capture + (?:..),
# alternation |, backrefs \1..\9, escapes \d \w \s \b and negations, flags g i m.
# Deferred (would balloon the diff): lookahead (?=)(?!), sticky `y`, `s` dotAll.
# ====================================================================

def re_fold(c: uint8) -> uint8:
    if c >= 65 and c <= 90:
        return c + 32
    return c


def re_is_word_byte(c: uint8) -> int32:
    if c >= 97 and c <= 122:
        return 1
    if c >= 65 and c <= 90:
        return 1
    if c >= 48 and c <= 57:
        return 1
    if c == 95:
        return 1
    return 0


def re_is_digit_byte(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return 1
    return 0


def re_is_space_byte(c: uint8) -> int32:
    if c == 32 or c == 9 or c == 10 or c == 13 or c == 12 or c == 11:
        return 1
    return 0


# ---- program emit / AST alloc ----
def re_emit(op: int32, x: int32, y: int32) -> int32:
    pc: int32 = re_n
    re_op[pc] = op
    re_x[pc] = x
    re_y[pc] = y
    re_n = re_n + 1
    return pc


def rn_new(op: int32) -> int32:
    i: int32 = rn_n
    rn_op[i] = op
    rn_a[i] = -1
    rn_b[i] = -1
    rn_c[i] = -1
    rn_d[i] = -1
    rn_next[i] = -1
    rn_n = rn_n + 1
    return i


# ---- char classes ----
def cls_new(negate: int32) -> int32:
    idx: int32 = n_cls
    i: int32 = 0
    while i < 32:
        cls_bits[idx * 32 + i] = 0
        i = i + 1
    cls_neg[idx] = cast[uint8](negate)
    n_cls = n_cls + 1
    return idx


def cls_add_raw(idx: int32, ch: int32):
    if ch < 0 or ch > 255:
        return
    cls_bits[idx * 32 + (ch >> 3)] = cls_bits[idx * 32 + (ch >> 3)] | cast[uint8](1 << (ch & 7))


def cls_add(idx: int32, ch: int32):
    cls_add_raw(idx, ch)
    if re_ic != 0:
        if ch >= 65 and ch <= 90:
            cls_add_raw(idx, ch + 32)
        elif ch >= 97 and ch <= 122:
            cls_add_raw(idx, ch - 32)


def cls_add_range(idx: int32, lo: int32, hi: int32):
    c: int32 = lo
    while c <= hi:
        cls_add(idx, c)
        c = c + 1


# which: 0=digit 1=word 2=space ; negate adds the complement set instead.
def cls_add_set(idx: int32, which: int32, negate: int32):
    c: int32 = 0
    while c < 256:
        inset: int32 = 0
        if which == 0:
            inset = re_is_digit_byte(cast[uint8](c))
        elif which == 1:
            inset = re_is_word_byte(cast[uint8](c))
        else:
            inset = re_is_space_byte(cast[uint8](c))
        if negate != 0:
            if inset == 0:
                cls_add_raw(idx, c)
        else:
            if inset != 0:
                cls_add_raw(idx, c)
        c = c + 1


def cls_test(idx: int32, ch: uint8) -> int32:
    c: int32 = cast[int32](ch)
    bit: int32 = cast[int32](cls_bits[idx * 32 + (c >> 3)] >> (c & 7)) & 1
    return bit


# ---- source cursor ----
def rc_at(i: int32) -> uint8:
    if i >= rc_len:
        return 0
    return sp_buf[rc_off + i]


def rc_peek() -> uint8:
    return rc_at(rc_i)


def rc_peek1() -> uint8:
    return rc_at(rc_i + 1)


# ---- regex parser (returns AST node id) ----
def re_parse_alt() -> int32:
    first: int32 = re_parse_seq()
    if rc_peek() != 124:                     # not '|'
        return first
    alt: int32 = rn_new(RN_ALT)
    rn_a[alt] = first
    tail: int32 = first
    while rc_peek() == 124:
        rc_i = rc_i + 1                       # consume '|'
        nb: int32 = re_parse_seq()
        rn_next[tail] = nb
        tail = nb
    return alt


def re_parse_seq() -> int32:
    seq: int32 = rn_new(RN_SEQ)
    head: int32 = -1
    tail: int32 = -1
    while rc_i < rc_len:
        c: uint8 = rc_peek()
        if c == 124 or c == 41:              # '|' or ')'
            break
        item: int32 = re_parse_repeat()
        if item < 0:
            break
        if head < 0:
            head = item
            tail = item
        else:
            rn_next[tail] = item
            tail = item
    rn_a[seq] = head
    return seq


def re_parse_repeat() -> int32:
    atom: int32 = re_parse_atom()
    if atom < 0:
        return atom
    c: uint8 = rc_peek()
    q: int32 = -1
    if c == 42:                              # *
        q = rn_new(RN_STAR)
        rc_i = rc_i + 1
    elif c == 43:                            # +
        q = rn_new(RN_PLUS)
        rc_i = rc_i + 1
    elif c == 63:                            # ?
        q = rn_new(RN_QUEST)
        rc_i = rc_i + 1
    elif c == 123:                           # { — maybe a bounded quantifier
        q = re_parse_brace(atom)
        if q < 0:
            return atom                      # `{` was a literal (handled as char by atom? no)
    else:
        return atom
    if q < 0:
        return atom
    rn_d[q] = atom
    # greedy unless followed by '?'
    greedy: int32 = 1
    if rc_peek() == 63:
        greedy = 0
        rc_i = rc_i + 1
    if rn_op[q] == RN_REPEAT:
        rn_a[q] = greedy
    else:
        rn_b[q] = greedy
    return q


# Try to parse {n} {n,} {n,m} starting at rc_i (a '{'). Returns an RN_REPEAT
# node (child unset) on success (consuming through '}'), or -1 without consuming.
def re_parse_brace(atom: int32) -> int32:
    j: int32 = rc_i + 1
    if is_digit(rc_at(j)) == 0:
        return -1
    lo: int32 = 0
    while is_digit(rc_at(j)) != 0:
        lo = lo * 10 + (cast[int32](rc_at(j)) - 48)
        j = j + 1
    hi: int32 = lo
    if rc_at(j) == 44:                       # ','
        j = j + 1
        if rc_at(j) == 125:                  # {n,}
            hi = -1
        else:
            if is_digit(rc_at(j)) == 0:
                return -1
            hi = 0
            while is_digit(rc_at(j)) != 0:
                hi = hi * 10 + (cast[int32](rc_at(j)) - 48)
                j = j + 1
    if rc_at(j) != 125:                      # need closing '}'
        return -1
    rc_i = j + 1                             # consume through '}'
    rep: int32 = rn_new(RN_REPEAT)
    rn_b[rep] = lo
    rn_c[rep] = hi
    return rep


def re_parse_atom() -> int32:
    c: uint8 = rc_peek()
    if c == 40:                              # (
        rc_i = rc_i + 1
        capidx: int32 = -1
        if rc_peek() == 63:                  # (?  — non-capturing / lookahead
            n1: uint8 = rc_peek1()
            if n1 == 58:                     # (?:
                rc_i = rc_i + 2
            else:                            # (?= (?! (?<  — deferred
                set_error(cast[Ptr[uint8]]("SyntaxError: unsupported regex group (lookahead/named not supported)"))
                return -1
        else:
            re_gcount = re_gcount + 1
            capidx = re_gcount
        child: int32 = re_parse_alt()
        if rc_peek() == 41:                  # )
            rc_i = rc_i + 1
        g: int32 = rn_new(RN_GROUP)
        rn_a[g] = capidx
        rn_d[g] = child
        return g
    if c == 91:                              # [
        return re_parse_class()
    if c == 46:                              # .
        rc_i = rc_i + 1
        return rn_new(RN_ANY)
    if c == 94:                              # ^
        rc_i = rc_i + 1
        return rn_new(RN_BOL)
    if c == 36:                              # $
        rc_i = rc_i + 1
        return rn_new(RN_EOL)
    if c == 92:                              # backslash
        return re_parse_escape()
    if c == 41 or c == 124 or c == 0:        # ) | end — empty atom
        return -1
    # ordinary literal char
    rc_i = rc_i + 1
    ch: int32 = rn_new(RN_CHAR)
    rn_a[ch] = cast[int32](c)
    return ch


def re_parse_escape() -> int32:
    rc_i = rc_i + 1                          # skip backslash
    e: uint8 = rc_peek()
    rc_i = rc_i + 1
    # predefined sets
    if e == 100:                             # \d
        cn: int32 = cls_new(0)
        cls_add_set(cn, 0, 0)
        return re_class_node(cn)
    if e == 68:                              # \D
        cn2: int32 = cls_new(0)
        cls_add_set(cn2, 0, 1)
        return re_class_node(cn2)
    if e == 119:                             # \w
        cn3: int32 = cls_new(0)
        cls_add_set(cn3, 1, 0)
        return re_class_node(cn3)
    if e == 87:                              # \W
        cn4: int32 = cls_new(0)
        cls_add_set(cn4, 1, 1)
        return re_class_node(cn4)
    if e == 115:                             # \s
        cn5: int32 = cls_new(0)
        cls_add_set(cn5, 2, 0)
        return re_class_node(cn5)
    if e == 83:                              # \S
        cn6: int32 = cls_new(0)
        cls_add_set(cn6, 2, 1)
        return re_class_node(cn6)
    if e == 98:                              # \b
        return rn_new(RN_WORDB)
    if e == 66:                              # \B
        return rn_new(RN_NWORDB)
    if e >= 49 and e <= 57:                  # \1..\9 backreference
        gi: int32 = cast[int32](e) - 48
        br: int32 = rn_new(RN_BACKREF)
        rn_a[br] = gi
        return br
    # single-char escapes
    lit: int32 = re_escape_char(e)
    ch2: int32 = rn_new(RN_CHAR)
    rn_a[ch2] = lit
    return ch2


def re_escape_char(e: uint8) -> int32:
    if e == 110:
        return 10                            # \n
    if e == 116:
        return 9                             # \t
    if e == 114:
        return 13                            # \r
    if e == 102:
        return 12                            # \f
    if e == 118:
        return 11                            # \v
    if e == 48:
        return 0                             # \0
    if e == 120:                             # \xHH
        h1: int32 = hexval(rc_peek())
        h2: int32 = hexval(rc_peek1())
        if h1 >= 0 and h2 >= 0:
            rc_i = rc_i + 2
            return h1 * 16 + h2
        return 120
    if e == 117:                             # \uHHHH -> low byte (byte engine)
        u1: int32 = hexval(rc_at(rc_i))
        u2: int32 = hexval(rc_at(rc_i + 1))
        u3: int32 = hexval(rc_at(rc_i + 2))
        u4: int32 = hexval(rc_at(rc_i + 3))
        if u1 >= 0 and u2 >= 0 and u3 >= 0 and u4 >= 0:
            rc_i = rc_i + 4
            return (u3 * 16 + u4)
        return 117
    return cast[int32](e)                    # \. \/ \\ \* ... literal


def hexval(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return cast[int32](c) - 48
    if c >= 97 and c <= 102:
        return cast[int32](c) - 87
    if c >= 65 and c <= 70:
        return cast[int32](c) - 55
    return -1


def re_class_node(clsidx: int32) -> int32:
    n: int32 = rn_new(RN_CLASS)
    rn_a[n] = clsidx
    return n


def re_parse_class() -> int32:
    rc_i = rc_i + 1                          # skip [
    neg: int32 = 0
    if rc_peek() == 94:                      # ^
        neg = 1
        rc_i = rc_i + 1
    idx: int32 = cls_new(neg)
    while rc_i < rc_len and rc_peek() != 93:  # until ]
        lo: int32 = re_class_item(idx)
        if lo < 0:
            continue                          # a set (\d etc) was folded in
        # range?
        if rc_peek() == 45 and rc_peek1() != 93 and rc_peek1() != 0:
            rc_i = rc_i + 1                    # consume '-'
            hi: int32 = re_class_item(idx)
            if hi < 0:
                cls_add(idx, 45)              # stray set after '-': treat '-' literal
            else:
                cls_add_range(idx, lo, hi)
        else:
            cls_add(idx, lo)
    if rc_peek() == 93:
        rc_i = rc_i + 1                       # skip ]
    return re_class_node(idx)


# Parse one class item; returns its char code, or -1 if it was a predefined
# set escape (\d \w \s + negations) already merged into the class bitmap.
def re_class_item(idx: int32) -> int32:
    c: uint8 = rc_peek()
    if c == 92:                              # escape
        rc_i = rc_i + 1
        e: uint8 = rc_peek()
        rc_i = rc_i + 1
        if e == 100:
            cls_add_set(idx, 0, 0)
            return -1
        if e == 68:
            cls_add_set(idx, 0, 1)
            return -1
        if e == 119:
            cls_add_set(idx, 1, 0)
            return -1
        if e == 87:
            cls_add_set(idx, 1, 1)
            return -1
        if e == 115:
            cls_add_set(idx, 2, 0)
            return -1
        if e == 83:
            cls_add_set(idx, 2, 1)
            return -1
        if e == 98:                          # \b inside class = backspace (8)
            return 8
        return re_escape_char(e)
    rc_i = rc_i + 1
    return cast[int32](c)


# ---- compile AST -> program ----
def re_compile(node: int32):
    if node < 0:
        return
    op: int32 = rn_op[node]
    if op == RN_SEQ:
        it: int32 = rn_a[node]
        while it >= 0:
            re_compile(it)
            it = rn_next[it]
        return
    if op == RN_CHAR:
        re_emit(RI_CHAR, rn_a[node], 0)
        return
    if op == RN_ANY:
        re_emit(RI_ANY, 0, 0)
        return
    if op == RN_CLASS:
        re_emit(RI_CLASS, rn_a[node], 0)
        return
    if op == RN_BOL:
        re_emit(RI_BOL, 0, 0)
        return
    if op == RN_EOL:
        re_emit(RI_EOL, 0, 0)
        return
    if op == RN_WORDB:
        re_emit(RI_WORDB, 0, 0)
        return
    if op == RN_NWORDB:
        re_emit(RI_NWORDB, 0, 0)
        return
    if op == RN_BACKREF:
        re_emit(RI_BACKREF, rn_a[node], 0)
        return
    if op == RN_GROUP:
        if rn_a[node] >= 0:
            re_emit(RI_SAVE, 2 * rn_a[node], 0)
            re_compile(rn_d[node])
            re_emit(RI_SAVE, 2 * rn_a[node] + 1, 0)
        else:
            re_compile(rn_d[node])
        return
    if op == RN_ALT:
        re_compile_alt(rn_a[node])
        return
    if op == RN_STAR:
        re_emit_star(rn_d[node], rn_b[node])
        return
    if op == RN_PLUS:
        re_emit_plus(rn_d[node], rn_b[node])
        return
    if op == RN_QUEST:
        re_emit_opt(rn_d[node], 1, rn_b[node])
        return
    if op == RN_REPEAT:
        lo: int32 = rn_b[node]
        hi: int32 = rn_c[node]
        greedy: int32 = rn_a[node]
        i: int32 = 0
        while i < lo:
            re_compile(rn_d[node])
            i = i + 1
        if hi < 0:
            re_emit_star(rn_d[node], greedy)
        else:
            re_emit_opt(rn_d[node], hi - lo, greedy)
        return


def re_compile_alt(branch: int32):
    nxt: int32 = rn_next[branch]
    if nxt < 0:
        re_compile(branch)
        return
    s: int32 = re_emit(RI_SPLIT, 0, 0)
    bstart: int32 = re_n
    re_compile(branch)
    j: int32 = re_emit(RI_JMP, 0, 0)
    reststart: int32 = re_n
    re_compile_alt(nxt)
    endp: int32 = re_n
    re_x[s] = bstart
    re_y[s] = reststart
    re_x[j] = endp


def re_emit_star(child: int32, greedy: int32):
    s: int32 = re_emit(RI_SPLIT, 0, 0)
    cstart: int32 = re_n
    re_compile(child)
    re_emit(RI_JMP, s, 0)
    endp: int32 = re_n
    if greedy != 0:
        re_x[s] = cstart
        re_y[s] = endp
    else:
        re_x[s] = endp
        re_y[s] = cstart


def re_emit_plus(child: int32, greedy: int32):
    cstart: int32 = re_n
    re_compile(child)
    s: int32 = re_emit(RI_SPLIT, 0, 0)
    endp: int32 = re_n
    if greedy != 0:
        re_x[s] = cstart
        re_y[s] = endp
    else:
        re_x[s] = endp
        re_y[s] = cstart


# emit `child{0,count}` (bounded optional) as right-nested SPLITs
def re_emit_opt(child: int32, count: int32, greedy: int32):
    if count <= 0:
        return
    s: int32 = re_emit(RI_SPLIT, 0, 0)
    cstart: int32 = re_n
    re_compile(child)
    re_emit_opt(child, count - 1, greedy)
    endp: int32 = re_n
    if greedy != 0:
        re_x[s] = cstart
        re_y[s] = endp
    else:
        re_x[s] = endp
        re_y[s] = cstart


# ---- matcher (backtracking VM) ----
def re_eqc(a: uint8, b: uint8) -> int32:
    if a == b:
        return 1
    if re_ic != 0:
        if re_fold(a) == re_fold(b):
            return 1
    return 0


def re_inclass(idx: int32, ch: uint8) -> int32:
    hit: int32 = cls_test(idx, ch)
    if cast[int32](cls_neg[idx]) != 0:
        if hit != 0:
            return 0
        return 1
    return hit


def re_subj(sp: int32) -> uint8:
    return sp_buf[rx_off + sp]


def re_is_bol(sp: int32) -> int32:
    if sp == 0:
        return 1
    if re_ml != 0 and re_subj(sp - 1) == 10:
        return 1
    return 0


def re_is_eol(sp: int32) -> int32:
    if sp == rx_len:
        return 1
    if re_ml != 0 and re_subj(sp) == 10:
        return 1
    return 0


def re_is_wordb(sp: int32) -> int32:
    left: int32 = 0
    right: int32 = 0
    if sp > 0 and re_is_word_byte(re_subj(sp - 1)) != 0:
        left = 1
    if sp < rx_len and re_is_word_byte(re_subj(sp)) != 0:
        right = 1
    if left != right:
        return 1
    return 0


def re_run(pc0: int32, sp0: int32) -> int32:
    pc: int32 = pc0
    sp: int32 = sp0
    while re_op[pc] >= 0:
        op: int32 = re_op[pc]
        if op == RI_CHAR:
            if sp < rx_len and re_eqc(re_subj(sp), cast[uint8](re_x[pc])) != 0:
                pc = pc + 1
                sp = sp + 1
                continue
            return 0
        elif op == RI_ANY:
            if sp < rx_len and re_subj(sp) != 10:
                pc = pc + 1
                sp = sp + 1
                continue
            return 0
        elif op == RI_CLASS:
            if sp < rx_len and re_inclass(re_x[pc], re_subj(sp)) != 0:
                pc = pc + 1
                sp = sp + 1
                continue
            return 0
        elif op == RI_MATCH:
            rx_matchend = sp
            return 1
        elif op == RI_JMP:
            pc = re_x[pc]
            continue
        elif op == RI_SPLIT:
            if re_run(re_x[pc], sp) != 0:
                return 1
            pc = re_y[pc]
            continue
        elif op == RI_SAVE:
            slot: int32 = re_x[pc]
            old: int32 = re_cap[slot]
            re_cap[slot] = sp
            if re_run(pc + 1, sp) != 0:
                return 1
            re_cap[slot] = old
            return 0
        elif op == RI_BOL:
            if re_is_bol(sp) != 0:
                pc = pc + 1
                continue
            return 0
        elif op == RI_EOL:
            if re_is_eol(sp) != 0:
                pc = pc + 1
                continue
            return 0
        elif op == RI_WORDB:
            if re_is_wordb(sp) != 0:
                pc = pc + 1
                continue
            return 0
        elif op == RI_NWORDB:
            if re_is_wordb(sp) == 0:
                pc = pc + 1
                continue
            return 0
        elif op == RI_BACKREF:
            g: int32 = re_x[pc]
            s0: int32 = re_cap[2 * g]
            e0: int32 = re_cap[2 * g + 1]
            if s0 < 0 or e0 < 0:
                pc = pc + 1
                continue
            blen: int32 = e0 - s0
            if sp + blen > rx_len:
                return 0
            k: int32 = 0
            ok: int32 = 1
            while k < blen:
                if re_eqc(re_subj(sp + k), re_subj(s0 + k)) == 0:
                    ok = 0
                    break
                k = k + 1
            if ok == 0:
                return 0
            sp = sp + blen
            pc = pc + 1
            continue
        return 0
    return 0


# Search for a match at or after `startpos`; returns match-start index (>=0) with
# re_cap[] populated and rx_matchend set, or -1 if none.
def regex_search(prog_start: int32, ncap: int32, sid: int32, startpos: int32, ic: int32, ml: int32) -> int32:
    re_ic = ic
    re_ml = ml
    rx_off = st_off[sid]
    rx_len = str_len(sid)
    pos: int32 = startpos
    while pos <= rx_len:
        i: int32 = 0
        while i < 2 * (ncap + 1):
            re_cap[i] = -1
            i = i + 1
        if re_run(prog_start, pos) != 0:
            return pos
        pos = pos + 1
    return -1


# ---- construction ----
def js_make_regex(src_sid: int32, flags_sid: int32) -> int32:
    gflag: int32 = 0
    iflag: int32 = 0
    mflag: int32 = 0
    fn: int32 = str_len(flags_sid)
    fi: int32 = 0
    while fi < fn:
        fc: uint8 = str_char(flags_sid, fi)
        if fc == 103:
            gflag = 1
        elif fc == 105:
            iflag = 1
        elif fc == 109:
            mflag = 1
        fi = fi + 1
    re_ic = iflag
    re_ml = mflag
    rn_n = 0
    re_gcount = 0
    rc_off = st_off[src_sid]
    rc_len = str_len(src_sid)
    rc_i = 0
    root: int32 = re_parse_alt()
    prog_start: int32 = re_n
    re_emit(RI_SAVE, 0, 0)
    re_compile(root)
    re_emit(RI_SAVE, 1, 0)
    re_emit(RI_MATCH, 0, 0)
    rv: int32 = v_new_object()
    o: int32 = objid_of(rv)
    obj_re_prog[o] = prog_start
    obj_re_ncap[o] = re_gcount
    bits: int32 = 0
    if gflag != 0:
        bits = bits | 1
    if iflag != 0:
        bits = bits | 2
    if mflag != 0:
        bits = bits | 4
    obj_re_flags[o] = bits
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("source")), v_string_id(src_sid))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("flags")), v_string_id(flags_sid))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("global")), v_boolv(gflag))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("ignoreCase")), v_boolv(iflag))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("multiline")), v_boolv(mflag))
    obj_set(o, str_from_cstr(cast[Ptr[uint8]]("lastIndex")), v_number(0.0))
    return rv


def is_regex(v: int32) -> int32:
    if tag_of(v) != TAG_OBJ:
        return 0
    if obj_re_prog[objid_of(v)] >= 0:
        return 1
    return 0


# Coerce a value into a RegExp (pass regexes through; strings/others compile).
def to_regex(v: int32) -> int32:
    if is_regex(v) != 0:
        return v
    sid: int32 = strid_of(to_string_val(v))
    return js_make_regex(sid, str_from_cstr(cast[Ptr[uint8]]("")))


# Build the exec()-style result array for the current re_cap[] over subject sid.
def regex_result_array(sid: int32, ncap: int32, start: int32) -> int32:
    res: int32 = v_new_array()
    ao: int32 = objid_of(res)
    g: int32 = 0
    while g <= ncap:
        s0: int32 = re_cap[2 * g]
        e0: int32 = re_cap[2 * g + 1]
        if s0 < 0 or e0 < 0:
            arr_push(ao, v_undef())
        else:
            arr_push(ao, v_string_bytes(&sp_buf[st_off[sid] + s0], e0 - s0))
        g = g + 1
    obj_set(ao, str_from_cstr(cast[Ptr[uint8]]("index")), v_number(cast[float64](start)))
    obj_set(ao, str_from_cstr(cast[Ptr[uint8]]("input")), v_string_id(sid))
    return res


# re.exec(str): returns a match array (with .index/.input + capture groups) or
# null; advances/reads .lastIndex when the `g` flag is set.
def regex_exec(rev: int32, strv: int32) -> int32:
    o: int32 = objid_of(rev)
    sid: int32 = strid_of(to_string_val(strv))
    gflag: int32 = obj_re_flags[o] & 1
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    li: int32 = 0
    if gflag != 0:
        li = cast[int32](to_number(obj_get_cstr(o, cast[Ptr[uint8]]("lastIndex"))))
    if li < 0:
        li = 0
    if li > str_len(sid):
        obj_set(o, str_from_cstr(cast[Ptr[uint8]]("lastIndex")), v_number(0.0))
        return v_null()
    start: int32 = regex_search(obj_re_prog[o], obj_re_ncap[o], sid, li, ic, ml)
    if start < 0:
        if gflag != 0:
            obj_set(o, str_from_cstr(cast[Ptr[uint8]]("lastIndex")), v_number(0.0))
        return v_null()
    if gflag != 0:
        obj_set(o, str_from_cstr(cast[Ptr[uint8]]("lastIndex")), v_number(cast[float64](rx_matchend)))
    return regex_result_array(sid, obj_re_ncap[o], start)


def regex_test(rev: int32, strv: int32) -> int32:
    r: int32 = regex_exec(rev, strv)
    if tag_of(r) == TAG_NULL:
        return v_false()
    return v_true()


# re.test / re.exec dispatch (called from eval_call on a regex receiver).
# Returns -2 if `name` is not a regex method.
def try_regex_method(rev: int32, name: int32, argnode: int32, env: int32) -> int32:
    base: int32 = call_top
    argc: int32 = eval_args_into(argnode, env)
    if ctl == CTL_THROW:
        call_top = base
        return v_undef()
    r: int32 = -2
    if str_eq_cstr(name, cast[Ptr[uint8]]("test")) != 0:
        r = regex_test(rev, arg_or(base, argc, 0))
    elif str_eq_cstr(name, cast[Ptr[uint8]]("exec")) != 0:
        r = regex_exec(rev, arg_or(base, argc, 0))
    elif str_eq_cstr(name, cast[Ptr[uint8]]("toString")) != 0:
        r = to_string_val(rev)
    call_top = base
    return r


# ---- String.prototype regex methods (subject sid + a regex value) ----
# str.search(re): index of first match or -1 (ignores g/lastIndex).
def str_regex_search(sid: int32, rev: int32) -> int32:
    o: int32 = objid_of(rev)
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    return v_number(cast[float64](regex_search(obj_re_prog[o], obj_re_ncap[o], sid, 0, ic, ml)))


# str.match(re): non-global -> exec-style array or null; global -> array of all
# matched substrings (or null).
def str_regex_match(sid: int32, rev: int32) -> int32:
    o: int32 = objid_of(rev)
    gflag: int32 = obj_re_flags[o] & 1
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    if gflag == 0:
        strv: int32 = v_string_id(sid)
        return regex_exec(rev, strv)
    res: int32 = v_new_array()
    ao: int32 = objid_of(res)
    pos: int32 = 0
    n: int32 = str_len(sid)
    any: int32 = 0
    while pos <= n:
        start: int32 = regex_search(obj_re_prog[o], obj_re_ncap[o], sid, pos, ic, ml)
        if start < 0:
            break
        any = 1
        mend: int32 = rx_matchend
        arr_push(ao, v_string_bytes(&sp_buf[st_off[sid] + start], mend - start))
        if mend > start:
            pos = mend
        else:
            pos = mend + 1                   # zero-width: advance to avoid a loop
    if any == 0:
        return v_null()
    return res


# str.matchAll(re): array of exec-style match arrays (each with groups+index).
def str_regex_matchall(sid: int32, rev: int32) -> int32:
    o: int32 = objid_of(rev)
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    ncap: int32 = obj_re_ncap[o]
    res: int32 = v_new_array()
    ao: int32 = objid_of(res)
    pos: int32 = 0
    n: int32 = str_len(sid)
    while pos <= n:
        start: int32 = regex_search(obj_re_prog[o], ncap, sid, pos, ic, ml)
        if start < 0:
            break
        mend: int32 = rx_matchend
        arr_push(ao, regex_result_array(sid, ncap, start))
        if mend > start:
            pos = mend
        else:
            pos = mend + 1
    return res


# str.split(re[, limit]): split on regex separators; captured groups from the
# separator are spliced into the result (per spec).
def str_regex_split(sid: int32, rev: int32) -> int32:
    o: int32 = objid_of(rev)
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    ncap: int32 = obj_re_ncap[o]
    res: int32 = v_new_array()
    ao: int32 = objid_of(res)
    n: int32 = str_len(sid)
    if n == 0:
        return res                           # "".split(re) -> [] (unless re matches "")
    last: int32 = 0
    pos: int32 = 0
    while pos < n:
        start: int32 = regex_search(obj_re_prog[o], ncap, sid, pos, ic, ml)
        if start < 0:
            break
        mend: int32 = rx_matchend
        if mend == start:
            # zero-width separator: skip to keep progress
            if start >= n:
                break
            pos = start + 1
            continue
        arr_push(ao, v_string_bytes(&sp_buf[st_off[sid] + last], start - last))
        g: int32 = 1
        while g <= ncap:
            s0: int32 = re_cap[2 * g]
            e0: int32 = re_cap[2 * g + 1]
            if s0 < 0 or e0 < 0:
                arr_push(ao, v_undef())
            else:
                arr_push(ao, v_string_bytes(&sp_buf[st_off[sid] + s0], e0 - s0))
            g = g + 1
        last = mend
        pos = mend
    arr_push(ao, v_string_bytes(&sp_buf[st_off[sid] + last], n - last))
    return res


# str.replace(re, repl): repl is a string ($1/$&/$$/$`/$') or a function.
# Two-phase: resolve each replacement to a string id first (so a replacer
# function can safely build strings), then assemble the result in one pass.
def str_regex_replace(sid: int32, rev: int32, replv: int32) -> int32:
    o: int32 = objid_of(rev)
    gflag: int32 = obj_re_flags[o] & 1
    ic: int32 = (obj_re_flags[o] >> 1) & 1
    ml: int32 = (obj_re_flags[o] >> 2) & 1
    ncap: int32 = obj_re_ncap[o]
    is_fn: int32 = is_callable(replv)
    n: int32 = str_len(sid)
    count: int32 = 0
    pos: int32 = 0
    # phase 1: find matches + resolve replacement string ids
    while pos <= n and count < MAX_REP:
        start: int32 = regex_search(obj_re_prog[o], ncap, sid, pos, ic, ml)
        if start < 0:
            break
        mend: int32 = rx_matchend
        rid0: int32 = 0
        if is_fn != 0:
            rid0 = re_fn_repl_id(sid, replv, start, mend, ncap)
        else:
            rid0 = re_str_repl_id(sid, replv, start, mend, ncap)
        rep_start[count] = start
        rep_end[count] = mend
        rep_id[count] = rid0
        count = count + 1
        if mend > start:
            pos = mend
        else:
            pos = mend + 1
        if gflag == 0:
            break
    # phase 2: assemble
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    last: int32 = 0
    i: int32 = 0
    while i < count:
        j: int32 = last
        while j < rep_start[i]:
            emit_c(str_char(sid, j))
            j = j + 1
        emit_strid(rep_id[i])
        last = rep_end[i]
        i = i + 1
    j2: int32 = last
    while j2 < n:
        emit_c(str_char(sid, j2))
        j2 = j2 + 1
    rid: int32 = bld_end()
    emit_tgt = save
    return v_string_id(rid)


# Build a string-replacement into a fresh string id (handles $&, $$, $1..$99,
# $`, $'). Self-contained; no user code runs, so the shared builder is safe.
def re_str_repl_id(sid: int32, replv: int32, start: int32, mend: int32, ncap: int32) -> int32:
    save: int32 = emit_tgt
    emit_tgt = 0
    bld_begin()
    rsid: int32 = strid_of(to_string_val(replv))
    rn: int32 = str_len(rsid)
    i: int32 = 0
    while i < rn:
        c: uint8 = str_char(rsid, i)
        if c == 36 and i + 1 < rn:           # '$'
            d: uint8 = str_char(rsid, i + 1)
            if d == 36:                      # $$ -> literal $
                emit_c(36)
                i = i + 2
                continue
            if d == 38:                      # $& whole match
                k: int32 = start
                while k < mend:
                    emit_c(str_char(sid, k))
                    k = k + 1
                i = i + 2
                continue
            if d == 96:                      # $` prefix
                k2: int32 = 0
                while k2 < start:
                    emit_c(str_char(sid, k2))
                    k2 = k2 + 1
                i = i + 2
                continue
            if d == 39:                      # $' suffix
                k3: int32 = mend
                slen: int32 = str_len(sid)
                while k3 < slen:
                    emit_c(str_char(sid, k3))
                    k3 = k3 + 1
                i = i + 2
                continue
            if d >= 48 and d <= 57:          # $n or $nn
                gi: int32 = cast[int32](d) - 48
                adv: int32 = 2
                if i + 2 < rn:
                    d2: uint8 = str_char(rsid, i + 2)
                    if d2 >= 48 and d2 <= 57:
                        gi2: int32 = gi * 10 + (cast[int32](d2) - 48)
                        if gi2 <= ncap:
                            gi = gi2
                            adv = 3
                if gi >= 1 and gi <= ncap:
                    s0: int32 = re_cap[2 * gi]
                    e0: int32 = re_cap[2 * gi + 1]
                    if s0 >= 0 and e0 >= 0:
                        kk: int32 = s0
                        while kk < e0:
                            emit_c(str_char(sid, kk))
                            kk = kk + 1
                    i = i + adv
                    continue
            emit_c(36)                       # unrecognized -> literal '$'
            i = i + 1
        else:
            emit_c(c)
            i = i + 1
    rid: int32 = bld_end()
    emit_tgt = save
    return rid


# Call a replacer function fn(match, p1.., offset, str); return its result's
# string id. Args are snapshotted from re_cap before invoking.
def re_fn_repl_id(sid: int32, fnv: int32, start: int32, mend: int32, ncap: int32) -> int32:
    base: int32 = call_top
    call_args[call_top] = v_string_bytes(&sp_buf[st_off[sid] + start], mend - start)
    call_top = call_top + 1
    g: int32 = 1
    while g <= ncap:
        s0: int32 = re_cap[2 * g]
        e0: int32 = re_cap[2 * g + 1]
        if s0 < 0 or e0 < 0:
            call_args[call_top] = v_undef()
        else:
            call_args[call_top] = v_string_bytes(&sp_buf[st_off[sid] + s0], e0 - s0)
        call_top = call_top + 1
        g = g + 1
    call_args[call_top] = v_number(cast[float64](start))
    call_top = call_top + 1
    call_args[call_top] = v_string_id(sid)
    call_top = call_top + 1
    argc: int32 = call_top - base
    rv: int32 = invoke(fnv, v_undef(), base, argc)
    call_top = base
    return strid_of(to_string_val(rv))


def def_global_native(name: Ptr[uint8], native_id: int32):
    env_define(g_env, str_from_cstr(name), v_new_native(native_id), 0)


def obj_add_native(objv: int32, name: Ptr[uint8], native_id: int32):
    obj_set(objid_of(objv), str_from_cstr(name), v_new_native(native_id))


def obj_add_num(objv: int32, name: Ptr[uint8], x: float64):
    obj_set(objid_of(objv), str_from_cstr(name), v_number(x))


# Create an Error-family constructor with a .prototype. Returns the ctor value.
# `super_ctor` is the base Error ctor value (-1 for Error itself) so subclass
# prototypes chain to Error.prototype.
def install_error(name: Ptr[uint8], native_id: int32, super_ctor: int32) -> int32:
    fv: int32 = v_new_native(native_id)
    proto: int32 = v_new_object()
    obj_set(objid_of(proto), str_from_cstr(cast[Ptr[uint8]]("name")), v_string_cstr(name))
    if super_ctor >= 0:
        basep: int32 = obj_get(objid_of(super_ctor), str_from_cstr(cast[Ptr[uint8]]("prototype")))
        if tag_of(basep) == TAG_OBJ:
            obj_proto[objid_of(proto)] = objid_of(basep)
    obj_set(objid_of(fv), str_from_cstr(cast[Ptr[uint8]]("prototype")), proto)
    env_define(g_env, str_from_cstr(name), fv, 0)
    return fv


def install_builtins():
    # console
    g_console = v_new_object()
    obj_add_native(g_console, cast[Ptr[uint8]]("log"), NAT_CONSOLE_LOG)
    obj_add_native(g_console, cast[Ptr[uint8]]("error"), NAT_CONSOLE_LOG)
    obj_add_native(g_console, cast[Ptr[uint8]]("warn"), NAT_CONSOLE_LOG)
    obj_add_native(g_console, cast[Ptr[uint8]]("info"), NAT_CONSOLE_LOG)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("console")), g_console, 0)
    # Math
    g_math = v_new_object()
    obj_add_native(g_math, cast[Ptr[uint8]]("floor"), NAT_MATH_FLOOR)
    obj_add_native(g_math, cast[Ptr[uint8]]("ceil"), NAT_MATH_CEIL)
    obj_add_native(g_math, cast[Ptr[uint8]]("round"), NAT_MATH_ROUND)
    obj_add_native(g_math, cast[Ptr[uint8]]("abs"), NAT_MATH_ABS)
    obj_add_native(g_math, cast[Ptr[uint8]]("sqrt"), NAT_MATH_SQRT)
    obj_add_native(g_math, cast[Ptr[uint8]]("pow"), NAT_MATH_POW)
    obj_add_native(g_math, cast[Ptr[uint8]]("min"), NAT_MATH_MIN)
    obj_add_native(g_math, cast[Ptr[uint8]]("max"), NAT_MATH_MAX)
    obj_add_native(g_math, cast[Ptr[uint8]]("trunc"), NAT_MATH_TRUNC)
    obj_add_native(g_math, cast[Ptr[uint8]]("sign"), NAT_MATH_SIGN)
    obj_add_native(g_math, cast[Ptr[uint8]]("cbrt"), NAT_MATH_CBRT)
    obj_add_native(g_math, cast[Ptr[uint8]]("hypot"), NAT_MATH_HYPOT)
    obj_add_native(g_math, cast[Ptr[uint8]]("log"), NAT_MATH_LOG)
    obj_add_native(g_math, cast[Ptr[uint8]]("log2"), NAT_MATH_LOG2)
    obj_add_native(g_math, cast[Ptr[uint8]]("log10"), NAT_MATH_LOG10)
    obj_add_native(g_math, cast[Ptr[uint8]]("exp"), NAT_MATH_EXP)
    obj_add_native(g_math, cast[Ptr[uint8]]("sin"), NAT_MATH_SIN)
    obj_add_native(g_math, cast[Ptr[uint8]]("cos"), NAT_MATH_COS)
    obj_add_native(g_math, cast[Ptr[uint8]]("tan"), NAT_MATH_TAN)
    obj_add_native(g_math, cast[Ptr[uint8]]("random"), NAT_MATH_RANDOM)
    obj_add_num(g_math, cast[Ptr[uint8]]("PI"), 3.141592653589793)
    obj_add_num(g_math, cast[Ptr[uint8]]("E"), 2.718281828459045)
    obj_add_num(g_math, cast[Ptr[uint8]]("LN2"), 0.6931471805599453)
    obj_add_num(g_math, cast[Ptr[uint8]]("LN10"), 2.302585092994046)
    obj_add_num(g_math, cast[Ptr[uint8]]("LOG2E"), 1.4426950408889634)
    obj_add_num(g_math, cast[Ptr[uint8]]("LOG10E"), 0.4342944819032518)
    obj_add_num(g_math, cast[Ptr[uint8]]("SQRT2"), 1.4142135623730951)
    obj_add_num(g_math, cast[Ptr[uint8]]("SQRT1_2"), 0.7071067811865476)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Math")), g_math, 0)
    # JSON
    g_json = v_new_object()
    obj_add_native(g_json, cast[Ptr[uint8]]("stringify"), NAT_JSON_STRINGIFY)
    obj_add_native(g_json, cast[Ptr[uint8]]("parse"), NAT_JSON_PARSE)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("JSON")), g_json, 0)
    # Object
    g_object = v_new_object()
    obj_add_native(g_object, cast[Ptr[uint8]]("keys"), NAT_OBJECT_KEYS)
    obj_add_native(g_object, cast[Ptr[uint8]]("assign"), NAT_OBJECT_ASSIGN)
    obj_add_native(g_object, cast[Ptr[uint8]]("values"), NAT_OBJECT_VALUES)
    obj_add_native(g_object, cast[Ptr[uint8]]("entries"), NAT_OBJECT_ENTRIES)
    obj_add_native(g_object, cast[Ptr[uint8]]("fromEntries"), NAT_OBJECT_FROMENTRIES)
    obj_add_native(g_object, cast[Ptr[uint8]]("freeze"), NAT_OBJECT_FREEZE)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Object")), g_object, 0)
    # Array
    g_array = v_new_native(NAT_ARRAY_CTOR)
    obj_add_native(g_array, cast[Ptr[uint8]]("isArray"), NAT_ARRAY_ISARRAY)
    obj_add_native(g_array, cast[Ptr[uint8]]("of"), NAT_ARRAY_OF)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Array")), g_array, 0)
    # Number (static helpers)
    g_number = v_new_native(NAT_NUMBER)
    obj_add_native(g_number, cast[Ptr[uint8]]("isInteger"), NAT_NUMBER_ISINTEGER)
    obj_add_native(g_number, cast[Ptr[uint8]]("isNaN"), NAT_NUMBER_ISNAN)
    obj_add_native(g_number, cast[Ptr[uint8]]("isFinite"), NAT_NUMBER_ISFINITE)
    obj_add_native(g_number, cast[Ptr[uint8]]("parseFloat"), NAT_PARSEFLOAT)
    obj_add_native(g_number, cast[Ptr[uint8]]("parseInt"), NAT_PARSEINT)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Number")), g_number, 0)
    # Error constructors (with prototypes so `e instanceof Error` works;
    # the subclasses chain their prototype to Error.prototype).
    errbase: int32 = install_error(cast[Ptr[uint8]]("Error"), NAT_ERROR, -1)
    install_error(cast[Ptr[uint8]]("TypeError"), NAT_TYPEERROR, errbase)
    install_error(cast[Ptr[uint8]]("RangeError"), NAT_RANGEERROR, errbase)
    install_error(cast[Ptr[uint8]]("SyntaxError"), NAT_SYNTAXERROR, errbase)
    install_error(cast[Ptr[uint8]]("ReferenceError"), NAT_REFERENCEERROR, errbase)
    # globals
    def_global_native(cast[Ptr[uint8]]("parseInt"), NAT_PARSEINT)
    def_global_native(cast[Ptr[uint8]]("parseFloat"), NAT_PARSEFLOAT)
    def_global_native(cast[Ptr[uint8]]("isNaN"), NAT_ISNAN)
    def_global_native(cast[Ptr[uint8]]("isFinite"), NAT_ISFINITE)
    def_global_native(cast[Ptr[uint8]]("String"), NAT_STRING)
    def_global_native(cast[Ptr[uint8]]("Boolean"), NAT_BOOLEAN)
    def_global_native(cast[Ptr[uint8]]("RegExp"), NAT_REGEXP)
    # NaN / Infinity / undefined globals
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("NaN")), v_number(0.0 / 0.0), 0)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("Infinity")), v_number(1.0e309), 0)
    env_define(g_env, str_from_cstr(cast[Ptr[uint8]]("undefined")), v_undef(), 0)


# ====================================================================
# PUBLIC API — the embedder (host driver, native tool, browser) calls these.
# ====================================================================
def js_init():
    # reset all pools
    n_vals = 4
    sp_top = 0
    n_strs = 0
    n_nodes = 0
    n_toks = 0
    n_objs = 0
    n_props = 0
    n_envs = 0
    n_binds = 0
    ax_top = 0
    out_top = 0
    call_top = 0
    this_top = 0
    err_flag = 0
    err_str[0] = 0
    ctl = CTL_NONE
    ctl_val = 0
    throw_val = 0
    tmpl_sp = 0
    re_n = 0
    rn_n = 0
    n_cls = 0
    json_emitted_any = 0
    emit_tgt = 1
    # singleton values
    v_tag[0] = cast[uint8](TAG_UNDEF)
    v_tag[1] = cast[uint8](TAG_NULL)
    v_tag[2] = cast[uint8](TAG_BOOL)
    v_tag[3] = cast[uint8](TAG_BOOL)
    v_ref[2] = 1
    v_ref[3] = 0
    # global env + object
    g_env = env_new(-1, 1)
    g_global_obj = v_new_object()
    install_builtins()


# Run a program. Returns a pointer to the NUL-terminated output buffer
# (accumulated console.log output). js_out_len() gives its length; js_error()
# is nonzero on a parse/runtime error and js_error_msg() the message.
def js_eval(src: Ptr[uint8], slen: uint64) -> Ptr[uint8]:
    tokenize(src, cast[int32](slen))
    prog: int32 = parse_program()
    if err_flag == 0:
        hoist_scan(prog, g_env)
        exec_stmt(prog, g_env)
    if err_flag == 0 and ctl == CTL_THROW:
        # uncaught exception -> print like a host runtime
        emit_tgt = 1
        emit_cstr(cast[Ptr[uint8]]("Uncaught "))
        display_val(throw_val)
        emit_c(10)
        ctl = CTL_NONE
    if err_flag != 0:
        # append the error message to the output for visibility
        emit_tgt = 1
        emit_cstr(&err_str[0])
        emit_c(10)
    out_buf[out_top] = 0
    return &out_buf[0]


def js_out_len() -> uint64:
    return cast[uint64](out_top)


def js_out_ptr() -> Ptr[uint8]:
    out_buf[out_top] = 0
    return &out_buf[0]


def js_error() -> int32:
    return err_flag


def js_error_msg() -> Ptr[uint8]:
    return &err_str[0]


# ---- value constructors for embedders ----
def js_undefined() -> int32:
    return v_undef()


def js_null() -> int32:
    return v_null()


def js_bool(b: int32) -> int32:
    return v_boolv(b)


def js_number(x: float64) -> int32:
    return v_number(x)


def js_new_string(p: Ptr[uint8], n: uint64) -> int32:
    return v_string_bytes(p, cast[int32](n))


def js_new_object_v() -> int32:
    return v_new_object()


def js_new_array_v() -> int32:
    return v_new_array()


def js_new_native_fn(native_id: int32) -> int32:
    return v_new_native(native_id)


# ---- object / global manipulation ----
def js_set_prop(objv: int32, name: Ptr[uint8], n: uint64, val: int32):
    member_set(objv, str_new(name, cast[int32](n)), val)


def js_get_prop(objv: int32, name: Ptr[uint8], n: uint64) -> int32:
    return member_get(objv, str_new(name, cast[int32](n)))


def js_array_push(arrv: int32, val: int32):
    if is_array(arrv) != 0:
        arr_push(objid_of(arrv), val)


def js_global_set(name: Ptr[uint8], n: uint64, val: int32):
    env_define(g_env, str_new(name, cast[int32](n)), val, 0)


# Read a global binding's current value by name (the mirror of js_global_set).
# Returns undefined if the name is not bound. Lets an embedder recover a value
# that a js_eval'd snippet stored in the global scope (e.g. a function compiled
# from inline-handler source).
def js_global_get(name: Ptr[uint8], n: uint64) -> int32:
    b: int32 = env_lookup_bind(g_env, str_new(name, cast[int32](n)))
    if b < 0:
        return v_undef()
    return b_val[b]


# ---- value inspection (for host dispatch) ----
def js_type_of(val: int32) -> int32:
    return tag_of(val)


def js_to_number(val: int32) -> float64:
    return to_number(val)


def js_to_bool(val: int32) -> int32:
    return to_bool(val)


def js_is_array(val: int32) -> int32:
    return is_array(val)


def js_array_len(val: int32) -> int32:
    if is_array(val) != 0:
        return arr_len[objid_of(val)]
    return 0


def js_array_get(val: int32, i: int32) -> int32:
    if is_array(val) != 0:
        return arr_get(objid_of(val), i)
    return v_undef()


# copy a value's string form into the shared scratch buffer (NUL-terminated)
def js_to_display(val: int32) -> Ptr[uint8]:
    save: int32 = emit_tgt
    save_out: int32 = out_top
    # render into out_buf temporarily then copy? Simpler: render into scratch
    # via a mini-emit — reuse display by targeting out_buf then copy out.
    emit_tgt = 1
    tmpstart: int32 = out_top
    display_val(val)
    ln: int32 = out_top - tmpstart
    i: int32 = 0
    while i < ln and i < 65535:
        scratch[i] = out_buf[tmpstart + i]
        i = i + 1
    scratch[i] = 0
    out_top = save_out                 # roll back the temporary render
    emit_tgt = save
    return &scratch[0]


def js_str_ptr(val: int32) -> Ptr[uint8]:
    return js_to_display(val)


# ---- host native dispatch seam ----
# The embedder registers fn(native_id) -> value-handle. Inside it, the embedder
# reads arguments via js_arg_count()/js_arg(i) and returns any value handle
# (build with js_number/js_new_string/js_new_object/...). Route calls to your
# host object's native methods (e.g. a future `document`) here. Host natives
# MUST use ids >= HOST_NATIVE_BASE (1000).
def js_set_host_dispatch(fn: Fn[int32, int32]):
    host_dispatch_addr = cast[uint64](fn)
    host_dispatch_set = 1


def js_arg_count() -> int32:
    return hostcall_argc


def js_arg(i: int32) -> int32:
    if i < hostcall_argc:
        return call_args[hostcall_base + i]
    return v_undef()


def js_host_base() -> int32:
    return HOST_NATIVE_BASE


# The receiver (`this`) of the native method currently being dispatched, so a
# host method like element.addEventListener / element.appendChild can identify
# which host object it was invoked on. Valid only inside the dispatch fn.
def js_this() -> int32:
    return hostcall_this


# Is `val` a callable JS function value? (For an embedder deciding whether a
# stored event handler can be invoked.)
def js_is_callable(val: int32) -> int32:
    return is_callable(val)


# Invoke a JS function VALUE from native/embedder code with `argc` argument
# value-handles (argv[0..argc), built via js_number/js_new_string/...), and
# `thisval` as the receiver. Returns the call's result value-handle. This is
# the seam that lets native code call a stored JS event handler AFTER the
# initial js_eval has returned — the JS context persists until the next
# js_init(), so handler function values stay live across a page's lifetime.
def js_call_fn(fnval: int32, thisval: int32, argv: Ptr[int32], argc: int32) -> int32:
    if is_callable(fnval) == 0:
        return v_undef()
    base: int32 = call_top
    i: int32 = 0
    while i < argc:
        call_args[call_top] = argv[i]
        call_top = call_top + 1
        i = i + 1
    r: int32 = invoke(fnval, thisval, base, argc)
    call_top = base
    return r

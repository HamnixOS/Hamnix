# lib/ctxmenucore.ad — the PURE, extern-free MATE context-menu MODEL + renderer.
#
# WHY THIS FILE EXISTS
# ====================
# The DE compositor (user/hamUId.ad) owns the right-click context menus, but
# its label/count tables were an ad-hoc grab-bag ("Flip Panel Position",
# "Autohide", "Add to Panel", "Panel Preferences") that did NOT match MATE, and
# the rendering was extracted into /bin/hamctxmenu which draws only PLACEHOLDER
# BARS (no text) — so the menus could never be VISUALLY verified.
#
# This module is the single source of truth for the MATE-authentic menus
# (Task #124):
#   * the PANEL menu (right-click empty panel)          — CTXM_KIND_PANEL
#   * the per-APPLET menu (right-click a specific applet) — CTXM_KIND_APPLET
#   * the Add-to-Panel CHOOSER (applet picker)           — CTXM_KIND_CHOOSER
# It is PURE (no `extern`, no I/O) and imports only lib/hamscene.ad, so it
# links into BOTH the x86_64-adder-user (native compositor) target AND the
# x86_64-linux (host render-to-PNG) target. hamUId consumes the count/label
# model; the host driver (user/ctxmenuscene_host.ad) draws the menus to a PNG
# a human can LOOK at — the same labels the compositor ships.


from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_stroke, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_line


# ---- geometry -----------------------------------------------------------
CTXM_KIND_DESKTOP: int32 = 0            # (owned by hamUId; here for symmetry)
CTXM_KIND_PANEL:   int32 = 4
CTXM_KIND_APPLET:  int32 = 5
CTXM_KIND_CHOOSER: int32 = 6

CTXM_ITEM_H: int32 = 20
CTXM_GLYPH_W: int32 = 8                 # host + compositor 8x16 mono cell
CTXM_PAD_L: int32 = 12                  # left text inset
CTXM_PAD_R: int32 = 16                  # right breathing room
CTXM_W_MIN: int32 = 150


# ---- applet identities (per-applet menu + Add-to-Panel insertion) -------
CTXM_APPLET_NONE:     int32 = 0
CTXM_APPLET_MENUBAR:  int32 = 1
CTXM_APPLET_CLOCK:    int32 = 2
CTXM_APPLET_SYSMON:   int32 = 3
CTXM_APPLET_WINLIST:  int32 = 4
CTXM_APPLET_PAGER:    int32 = 5
CTXM_APPLET_NOTIF:    int32 = 6
CTXM_APPLET_SHOWDESK: int32 = 7
CTXM_APPLET_LAUNCHER: int32 = 8


def ctxm_applet_name(a: int32) -> Ptr[uint8]:
    if a == CTXM_APPLET_MENUBAR:
        m: Ptr[uint8] = "Menu Bar"
        return m
    if a == CTXM_APPLET_CLOCK:
        c: Ptr[uint8] = "Clock"
        return c
    if a == CTXM_APPLET_SYSMON:
        s: Ptr[uint8] = "System Monitor"
        return s
    if a == CTXM_APPLET_WINLIST:
        w: Ptr[uint8] = "Window List"
        return w
    if a == CTXM_APPLET_PAGER:
        p: Ptr[uint8] = "Workspace Switcher"
        return p
    if a == CTXM_APPLET_NOTIF:
        n: Ptr[uint8] = "Notification Area"
        return n
    if a == CTXM_APPLET_SHOWDESK:
        d: Ptr[uint8] = "Show Desktop"
        return d
    if a == CTXM_APPLET_LAUNCHER:
        l: Ptr[uint8] = "Application Launcher"
        return l
    u: Ptr[uint8] = "Applet"
    return u


# ---- string helper (extern-free) ----------------------------------------
def _ctxm_slen(s: Ptr[uint8]) -> int32:
    n: int32 = 0
    while s[n] != 0:
        n = n + 1
    return n


# ====================================================================
# PANEL menu — right-click an empty part of the panel bar.
# MATE's exact panel context menu (mate-panel/panel-context-menu.c):
#   Add to Panel...  Properties  Reset All Panels  Delete This Panel
#   New Panel  |  Help  About Panels
# ====================================================================
def ctxm_panel_count() -> uint64:
    return 7


def ctxm_panel_label(i: uint64) -> Ptr[uint8]:
    if i == 0:
        a: Ptr[uint8] = "Add to Panel..."
        return a
    if i == 1:
        p: Ptr[uint8] = "Properties"
        return p
    if i == 2:
        r: Ptr[uint8] = "Reset All Panels"
        return r
    if i == 3:
        d: Ptr[uint8] = "Delete This Panel"
        return d
    if i == 4:
        n: Ptr[uint8] = "New Panel"
        return n
    if i == 5:
        h: Ptr[uint8] = "Help"
        return h
    ab: Ptr[uint8] = "About Panels"
    return ab


# ====================================================================
# APPLET menu — right-click a specific applet (clock, system monitor,
# window list, workspace switcher, ...). MATE's applet menu carries the
# applet-specific Preferences (DECENTRALIZED settings — the applet owns
# its own prefs, not a global panel Settings screen), then the standard
# Move / Remove From Panel / Lock To Panel block.
#   `locked` != 0 flips item 3 to the "Unlock" toggle (MATE toggles the
#   same row between Lock/Unlock like the checkbox in its real menu).
# ====================================================================
def ctxm_applet_count() -> uint64:
    return 4


def ctxm_applet_label(i: uint64, locked: int32) -> Ptr[uint8]:
    if i == 0:
        p: Ptr[uint8] = "Preferences"
        return p
    if i == 1:
        m: Ptr[uint8] = "Move"
        return m
    if i == 2:
        r: Ptr[uint8] = "Remove From Panel"
        return r
    if locked != 0:
        u: Ptr[uint8] = "Unlock From Panel"
        return u
    l: Ptr[uint8] = "Lock To Panel"
    return l


# ====================================================================
# Add-to-Panel CHOOSER — the applet picker opened by the panel menu's
# "Add to Panel...". MATE lists every available applet; the chosen one is
# inserted at the spot that was right-clicked.
# ====================================================================
def ctxm_chooser_count() -> uint64:
    return 8


def ctxm_chooser_label(i: uint64) -> Ptr[uint8]:
    if i == 0:
        a: Ptr[uint8] = "Application Launcher"
        return a
    if i == 1:
        m: Ptr[uint8] = "Menu Bar"
        return m
    if i == 2:
        c: Ptr[uint8] = "Clock"
        return c
    if i == 3:
        s: Ptr[uint8] = "System Monitor"
        return s
    if i == 4:
        w: Ptr[uint8] = "Workspace Switcher"
        return w
    if i == 5:
        wl: Ptr[uint8] = "Window List"
        return wl
    if i == 6:
        n: Ptr[uint8] = "Notification Area"
        return n
    d: Ptr[uint8] = "Show Desktop"
    return d


# Map a chooser row to the applet identity it inserts.
def ctxm_chooser_applet(i: uint64) -> int32:
    if i == 0:
        return CTXM_APPLET_LAUNCHER
    if i == 1:
        return CTXM_APPLET_MENUBAR
    if i == 2:
        return CTXM_APPLET_CLOCK
    if i == 3:
        return CTXM_APPLET_SYSMON
    if i == 4:
        return CTXM_APPLET_PAGER
    if i == 5:
        return CTXM_APPLET_WINLIST
    if i == 6:
        return CTXM_APPLET_NOTIF
    return CTXM_APPLET_SHOWDESK


# ====================================================================
# Kind dispatchers — hamUId calls these for CTX_KIND 4/5/6 so the model
# lives in one place. `locked` only affects the applet menu.
# ====================================================================
def ctxm_kind_count(kind: int32) -> uint64:
    if kind == CTXM_KIND_PANEL:
        return ctxm_panel_count()
    if kind == CTXM_KIND_APPLET:
        return ctxm_applet_count()
    if kind == CTXM_KIND_CHOOSER:
        return ctxm_chooser_count()
    return 0


def ctxm_kind_label(kind: int32, i: uint64, locked: int32) -> Ptr[uint8]:
    if kind == CTXM_KIND_PANEL:
        return ctxm_panel_label(i)
    if kind == CTXM_KIND_APPLET:
        return ctxm_applet_label(i, locked)
    if kind == CTXM_KIND_CHOOSER:
        return ctxm_chooser_label(i)
    e: Ptr[uint8] = ""
    return e


# Box width sized to the widest rendered label (no clipping, MATE-ish floor).
def ctxm_width(kind: int32, locked: int32) -> int32:
    n: uint64 = ctxm_kind_count(kind)
    maxw: int32 = 0
    i: uint64 = 0
    while i < n:
        w: int32 = _ctxm_slen(ctxm_kind_label(kind, i, locked)) * CTXM_GLYPH_W
        if w > maxw:
            maxw = w
        i = i + 1
    box: int32 = maxw + CTXM_PAD_L + CTXM_PAD_R
    if box < CTXM_W_MIN:
        box = CTXM_W_MIN
    return box


# Item under (px,py) for a menu box whose top-left is (bx,by), or -1.
def ctxm_item_at(kind: int32, locked: int32, bx: int32, by: int32,
                 px: int32, py: int32) -> int64:
    w: int32 = ctxm_width(kind, locked)
    n: int32 = cast[int32](ctxm_kind_count(kind))
    if px < bx or px >= bx + w:
        return -1
    if py < by or py >= by + n * CTXM_ITEM_H:
        return -1
    idx: int32 = (py - by) / CTXM_ITEM_H
    if idx < 0 or idx >= n:
        return -1
    return cast[int64](idx)


# ====================================================================
# HOST renderer — draw a full MATE-styled menu into the hamscene buffer.
# Light Clearlooks menu: cream body, grey frame, dark text, blue selection
# with white text. A caption above the box names the applet (applet menu) or
# the chooser ("Add to Panel") so the DECENTRALIZED per-applet identity is
# visible in the PNG. Anchored at (bx,by); `hover` is the highlighted row.
# ====================================================================
def ctxm_build_scene(kind: int32, bx: int32, by: int32, hover: int32,
                     locked: int32, applet: int32, scr_w: int32, scr_h: int32):
    body:   Ptr[uint8] = "#ede9e3"      # cream menu body
    frame:  Ptr[uint8] = "#8f8b85"      # grey 1px frame
    shadow: Ptr[uint8] = "#00000040"    # soft drop shadow
    txt:    Ptr[uint8] = "#2e2b28"      # near-black label text
    seltxt: Ptr[uint8] = "#ffffff"      # selected label text
    selbg:  Ptr[uint8] = "#4a6fa5"      # MATE selection blue
    capbg:  Ptr[uint8] = "#cdd6e5"      # caption strip
    captxt: Ptr[uint8] = "#33475f"      # caption text

    hamscene_begin()
    # Desktop-ish backdrop so the menu reads in context.
    hamscene_fill(0, 0, scr_w, scr_h, cast[Ptr[uint8]]("#5c6b80"))

    w: int32 = ctxm_width(kind, locked)
    n: int32 = cast[int32](ctxm_kind_count(kind))
    h: int32 = n * CTXM_ITEM_H

    # Caption strip above the box (applet name / chooser title).
    cap: Ptr[uint8] = cast[Ptr[uint8]]("")
    have_cap: int32 = 0
    if kind == CTXM_KIND_APPLET:
        cap = ctxm_applet_name(applet)
        have_cap = 1
    elif kind == CTXM_KIND_CHOOSER:
        ctitle: Ptr[uint8] = "Add to Panel"
        cap = ctitle
        have_cap = 1
    if have_cap != 0:
        hamscene_fill(bx, by - CTXM_ITEM_H, w, CTXM_ITEM_H, capbg)
        hamscene_stroke(bx, by - CTXM_ITEM_H, w, CTXM_ITEM_H, 1, frame)
        hamscene_glyphs_bold(bx + CTXM_PAD_L, by - CTXM_ITEM_H + 2, cap, captxt)

    # Drop shadow, then body + frame.
    hamscene_fill(bx + 3, by + 3, w, h, shadow)
    hamscene_fill(bx, by, w, h, body)
    hamscene_stroke(bx, by, w, h, 1, frame)

    # Rows.
    i: int32 = 0
    while i < n:
        ry: int32 = by + i * CTXM_ITEM_H
        lbl: Ptr[uint8] = ctxm_kind_label(kind, cast[uint64](i), locked)
        col: Ptr[uint8] = txt
        if i == hover:
            hamscene_fill(bx + 1, ry, w - 2, CTXM_ITEM_H, selbg)
            col = seltxt
        hamscene_glyphs(bx + CTXM_PAD_L, ry + 2, lbl, col)
        i = i + 1

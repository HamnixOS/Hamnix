# lib/ctxmenucore.ad — the PURE, extern-free MATE context-menu MODEL + renderer.
#
# WHY THIS FILE EXISTS
# ====================
# The DE compositor (user/hamUId.ad) owns the right-click context menus, but
# its label/count tables were an ad-hoc grab-bag ("Flip Panel Position",
# "Autohide", "Add to Panel", "Panel Preferences") that did NOT match MATE, and
# the rendering was extracted into /bin/hamctxmenu which draws only PLACEHOLDER
# BARS (no text) — so the menus could never be VISUALLY verified.
#
# This module is the single source of truth for the MATE-authentic menus
# (Task #124):
#   * the PANEL menu (right-click empty panel)          — CTXM_KIND_PANEL
#   * the per-APPLET menu (right-click a specific applet) — CTXM_KIND_APPLET
#   * the Add-to-Panel CHOOSER (applet picker)           — CTXM_KIND_CHOOSER
# It is PURE (no `extern`, no I/O) and imports only lib/hamscene.ad, so it
# links into BOTH the x86_64-adder-user (native compositor) target AND the
# x86_64-linux (host render-to-PNG) target. hamUId consumes the count/label
# model; the host driver (user/ctxmenuscene_host.ad) draws the menus to a PNG
# a human can LOOK at — the same labels the compositor ships.


from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_stroke, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_line


# ---- geometry -----------------------------------------------------------
CTXM_KIND_DESKTOP: int32 = 0            # (owned by hamUId; here for symmetry)
CTXM_KIND_PANEL:   int32 = 4
CTXM_KIND_APPLET:  int32 = 5
CTXM_KIND_CHOOSER: int32 = 6

CTXM_ITEM_H: int32 = 20
CTXM_GLYPH_W: int32 = 8                 # host + compositor 8x16 mono cell
CTXM_PAD_L: int32 = 12                  # left text inset
CTXM_PAD_R: int32 = 16                  # right breathing room
CTXM_W_MIN: int32 = 150


# ---- applet identities (per-applet menu + Add-to-Panel insertion) -------
CTXM_APPLET_NONE:     int32 = 0
CTXM_APPLET_MENUBAR:  int32 = 1
CTXM_APPLET_CLOCK:    int32 = 2
CTXM_APPLET_SYSMON:   int32 = 3
CTXM_APPLET_WINLIST:  int32 = 4
CTXM_APPLET_PAGER:    int32 = 5
CTXM_APPLET_NOTIF:    int32 = 6
CTXM_APPLET_SHOWDESK: int32 = 7
CTXM_APPLET_LAUNCHER: int32 = 8
# Two more identities the hampanelscene panel can actually add (its widget set
# carries a flexible Spacer and a Session/power button that MATE's stock
# chooser omits). Kept additive so the flat ctxm_chooser_* API (consumed by
# hamUId + the #124 host gate) is unchanged.
CTXM_APPLET_SPACER:   int32 = 9
CTXM_APPLET_SESSION:  int32 = 10


def ctxm_applet_name(a: int32) -> Ptr[uint8]:
    if a == CTXM_APPLET_MENUBAR:
        m: Ptr[uint8] = "Menu Bar"
        return m
    if a == CTXM_APPLET_CLOCK:
        c: Ptr[uint8] = "Clock"
        return c
    if a == CTXM_APPLET_SYSMON:
        s: Ptr[uint8] = "System Monitor"
        return s
    if a == CTXM_APPLET_WINLIST:
        w: Ptr[uint8] = "Window List"
        return w
    if a == CTXM_APPLET_PAGER:
        p: Ptr[uint8] = "Workspace Switcher"
        return p
    if a == CTXM_APPLET_NOTIF:
        n: Ptr[uint8] = "Notification Area"
        return n
    if a == CTXM_APPLET_SHOWDESK:
        d: Ptr[uint8] = "Show Desktop"
        return d
    if a == CTXM_APPLET_LAUNCHER:
        l: Ptr[uint8] = "Application Launcher"
        return l
    if a == CTXM_APPLET_SPACER:
        sp: Ptr[uint8] = "Spacer"
        return sp
    if a == CTXM_APPLET_SESSION:
        se: Ptr[uint8] = "Session"
        return se
    u: Ptr[uint8] = "Applet"
    return u


# ---- string helper (extern-free) ----------------------------------------
def _ctxm_slen(s: Ptr[uint8]) -> int32:
    n: int32 = 0
    while s[n] != 0:
        n = n + 1
    return n


# ====================================================================
# PANEL menu — right-click an empty part of the panel bar.
# MATE's exact panel context menu (mate-panel/panel-context-menu.c):
#   Add to Panel...  Properties  Reset All Panels  Delete This Panel
#   New Panel  |  Help  About Panels
# ====================================================================
def ctxm_panel_count() -> uint64:
    return 7


def ctxm_panel_label(i: uint64) -> Ptr[uint8]:
    if i == 0:
        a: Ptr[uint8] = "Add to Panel..."
        return a
    if i == 1:
        p: Ptr[uint8] = "Properties"
        return p
    if i == 2:
        r: Ptr[uint8] = "Reset All Panels"
        return r
    if i == 3:
        d: Ptr[uint8] = "Delete This Panel"
        return d
    if i == 4:
        n: Ptr[uint8] = "New Panel"
        return n
    if i == 5:
        h: Ptr[uint8] = "Help"
        return h
    ab: Ptr[uint8] = "About Panels"
    return ab


# ====================================================================
# APPLET menu — right-click a specific applet (clock, system monitor,
# window list, workspace switcher, ...). MATE's applet menu carries the
# applet-specific Preferences (DECENTRALIZED settings — the applet owns
# its own prefs, not a global panel Settings screen), then the standard
# Move / Remove From Panel / Lock To Panel block.
#   `locked` != 0 flips item 3 to the "Unlock" toggle (MATE toggles the
#   same row between Lock/Unlock like the checkbox in its real menu).
# ====================================================================
def ctxm_applet_count() -> uint64:
    return 4


def ctxm_applet_label(i: uint64, locked: int32) -> Ptr[uint8]:
    if i == 0:
        p: Ptr[uint8] = "Preferences"
        return p
    if i == 1:
        m: Ptr[uint8] = "Move"
        return m
    if i == 2:
        r: Ptr[uint8] = "Remove From Panel"
        return r
    if locked != 0:
        u: Ptr[uint8] = "Unlock From Panel"
        return u
    l: Ptr[uint8] = "Lock To Panel"
    return l


# ====================================================================
# Add-to-Panel CHOOSER — the applet picker opened by the panel menu's
# "Add to Panel...". MATE lists every available applet; the chosen one is
# inserted at the spot that was right-clicked.
# ====================================================================
def ctxm_chooser_count() -> uint64:
    return 8


def ctxm_chooser_label(i: uint64) -> Ptr[uint8]:
    if i == 0:
        a: Ptr[uint8] = "Application Launcher"
        return a
    if i == 1:
        m: Ptr[uint8] = "Menu Bar"
        return m
    if i == 2:
        c: Ptr[uint8] = "Clock"
        return c
    if i == 3:
        s: Ptr[uint8] = "System Monitor"
        return s
    if i == 4:
        w: Ptr[uint8] = "Workspace Switcher"
        return w
    if i == 5:
        wl: Ptr[uint8] = "Window List"
        return wl
    if i == 6:
        n: Ptr[uint8] = "Notification Area"
        return n
    d: Ptr[uint8] = "Show Desktop"
    return d


# Map a chooser row to the applet identity it inserts.
def ctxm_chooser_applet(i: uint64) -> int32:
    if i == 0:
        return CTXM_APPLET_LAUNCHER
    if i == 1:
        return CTXM_APPLET_MENUBAR
    if i == 2:
        return CTXM_APPLET_CLOCK
    if i == 3:
        return CTXM_APPLET_SYSMON
    if i == 4:
        return CTXM_APPLET_PAGER
    if i == 5:
        return CTXM_APPLET_WINLIST
    if i == 6:
        return CTXM_APPLET_NOTIF
    return CTXM_APPLET_SHOWDESK


# ====================================================================
# Kind dispatchers — hamUId calls these for CTX_KIND 4/5/6 so the model
# lives in one place. `locked` only affects the applet menu.
# ====================================================================
def ctxm_kind_count(kind: int32) -> uint64:
    if kind == CTXM_KIND_PANEL:
        return ctxm_panel_count()
    if kind == CTXM_KIND_APPLET:
        return ctxm_applet_count()
    if kind == CTXM_KIND_CHOOSER:
        return ctxm_chooser_count()
    return 0


def ctxm_kind_label(kind: int32, i: uint64, locked: int32) -> Ptr[uint8]:
    if kind == CTXM_KIND_PANEL:
        return ctxm_panel_label(i)
    if kind == CTXM_KIND_APPLET:
        return ctxm_applet_label(i, locked)
    if kind == CTXM_KIND_CHOOSER:
        return ctxm_chooser_label(i)
    e: Ptr[uint8] = ""
    return e


# Box width sized to the widest rendered label (no clipping, MATE-ish floor).
def ctxm_width(kind: int32, locked: int32) -> int32:
    n: uint64 = ctxm_kind_count(kind)
    maxw: int32 = 0
    i: uint64 = 0
    while i < n:
        w: int32 = _ctxm_slen(ctxm_kind_label(kind, i, locked)) * CTXM_GLYPH_W
        if w > maxw:
            maxw = w
        i = i + 1
    box: int32 = maxw + CTXM_PAD_L + CTXM_PAD_R
    if box < CTXM_W_MIN:
        box = CTXM_W_MIN
    return box


# Item under (px,py) for a menu box whose top-left is (bx,by), or -1.
def ctxm_item_at(kind: int32, locked: int32, bx: int32, by: int32,
                 px: int32, py: int32) -> int64:
    w: int32 = ctxm_width(kind, locked)
    n: int32 = cast[int32](ctxm_kind_count(kind))
    if px < bx or px >= bx + w:
        return -1
    if py < by or py >= by + n * CTXM_ITEM_H:
        return -1
    idx: int32 = (py - by) / CTXM_ITEM_H
    if idx < 0 or idx >= n:
        return -1
    return cast[int64](idx)


# ====================================================================
# HOST renderer — draw a full MATE-styled menu into the hamscene buffer.
# Light Clearlooks menu: cream body, grey frame, dark text, blue selection
# with white text. A caption above the box names the applet (applet menu) or
# the chooser ("Add to Panel") so the DECENTRALIZED per-applet identity is
# visible in the PNG. Anchored at (bx,by); `hover` is the highlighted row.
# ====================================================================
def ctxm_build_scene(kind: int32, bx: int32, by: int32, hover: int32,
                     locked: int32, applet: int32, scr_w: int32, scr_h: int32):
    body:   Ptr[uint8] = "#f7f8fa"      # clean near-white menu body
    frame:  Ptr[uint8] = "#cfd2d8"      # soft hairline border
    shadow: Ptr[uint8] = "#00000030"    # soft drop shadow
    txt:    Ptr[uint8] = "#23262b"      # near-black label text
    seltxt: Ptr[uint8] = "#ffffff"      # selected label text
    selbg:  Ptr[uint8] = "#3584e4"      # MATE selection blue
    capbg:  Ptr[uint8] = "#e3ecfb"      # accent-tinted caption strip
    captxt: Ptr[uint8] = "#1c5fb8"      # accent caption text

    hamscene_begin()
    # Desktop-ish backdrop so the menu reads in context.
    hamscene_fill(0, 0, scr_w, scr_h, cast[Ptr[uint8]]("#5c6b80"))

    w: int32 = ctxm_width(kind, locked)
    n: int32 = cast[int32](ctxm_kind_count(kind))
    h: int32 = n * CTXM_ITEM_H

    # Caption strip above the box (applet name / chooser title).
    cap: Ptr[uint8] = cast[Ptr[uint8]]("")
    have_cap: int32 = 0
    if kind == CTXM_KIND_APPLET:
        cap = ctxm_applet_name(applet)
        have_cap = 1
    elif kind == CTXM_KIND_CHOOSER:
        ctitle: Ptr[uint8] = "Add to Panel"
        cap = ctitle
        have_cap = 1
    if have_cap != 0:
        hamscene_fill(bx, by - CTXM_ITEM_H, w, CTXM_ITEM_H, capbg)
        hamscene_stroke(bx, by - CTXM_ITEM_H, w, CTXM_ITEM_H, 1, frame)
        hamscene_glyphs_bold(bx + CTXM_PAD_L, by - CTXM_ITEM_H + 2, cap, captxt)

    # Drop shadow, then body + frame.
    hamscene_fill(bx + 3, by + 3, w, h, shadow)
    hamscene_fill(bx, by, w, h, body)
    hamscene_stroke(bx, by, w, h, 1, frame)

    # Rows.
    i: int32 = 0
    while i < n:
        ry: int32 = by + i * CTXM_ITEM_H
        lbl: Ptr[uint8] = ctxm_kind_label(kind, cast[uint64](i), locked)
        col: Ptr[uint8] = txt
        if i == hover:
            hamscene_fill(bx + 1, ry, w - 2, CTXM_ITEM_H, selbg)
            col = seltxt
        hamscene_glyphs(bx + CTXM_PAD_L, ry + 2, lbl, col)
        i = i + 1


# ====================================================================
# SEARCHABLE "Add to Panel" CHOOSER (v2) — the MATE add-applet DIALOG.
# ====================================================================
# The flat ctxm_chooser_* list above is a bare label column (no search, no
# descriptions) and its identity set is MATE's stock one, which does NOT map
# cleanly onto the hampanelscene panel's real widgets. This richer model is
# what the panel's "Add to Panel..." opens: a dedicated dialog with a title,
# a SEARCH box, a category-GROUPED + SCROLL-friendly list where each applet
# shows a NAME + a short DESCRIPTION, mirroring MATE's applet chooser (and the
# search+list shape lib/appmenucore.ad established for the app menu, #206).
#
# It is PURE (extern-free) like the rest of this module, so it links into both
# the native panel (user/hampanelscene.ad) and the host render gate
# (user/ctxmenuscene_host.ad). The panel walks the row model + hit-test and
# draws with ctxm_choice_draw (no begin/backdrop, embedded in the panel
# window); the host driver wraps the same draw with ctxm_choice_build_scene.

# ---- geometry ------------------------------------------------------------
CTXM_CC_W:        int32 = 340
CTXM_CC_TITLE_H:  int32 = 26
CTXM_CC_SEARCH_H: int32 = 28
CTXM_CC_HEADER_H: int32 = 20
CTXM_CC_ENTRY_H:  int32 = 42
CTXM_CC_PAD_L:    int32 = 12
CTXM_CC_ICON:     int32 = 26

# ---- categories (display order == numeric order) -------------------------
CTXM_CC_CAT_LAUNCH:  int32 = 0
CTXM_CC_CAT_CLOCK:   int32 = 1
CTXM_CC_CAT_SYSTEM:  int32 = 2
CTXM_CC_CAT_WINDOWS: int32 = 3
CTXM_CC_CAT_UTIL:    int32 = 4
CTXM_CC_CAT_COUNT:   int32 = 5

# ---- row kinds -----------------------------------------------------------
CTXM_CC_ROW_SEARCH: int32 = 0
CTXM_CC_ROW_HEADER: int32 = 1
CTXM_CC_ROW_ENTRY:  int32 = 2

# ---- capacities ----------------------------------------------------------
CTXM_CC_MAX:        uint64 = 16
CTXM_CC_NAME_CAP:   uint64 = 40
CTXM_CC_DESC_CAP:   uint64 = 72
CTXM_CC_MAX_ROWS:   uint64 = 40
CTXM_CC_FILTER_CAP: uint64 = 40

# ---- applet registry -----------------------------------------------------
_cc_count:  uint64 = 0
_cc_name:   Array[16, Array[40, uint8]]
_cc_nlen:   Array[16, uint64]
_cc_desc:   Array[16, Array[72, uint8]]
_cc_dlen:   Array[16, uint64]
_cc_applet: Array[16, int32]
_cc_cat:    Array[16, int32]

# ---- live search filter (lowercased) -------------------------------------
_cc_filter:     Array[40, uint8]
_cc_filter_len: uint64 = 0

# ---- laid-out visible rows -----------------------------------------------
_cc_row_count: uint64 = 0
_cc_row_kind:  Array[40, int32]
_cc_row_cat:   Array[40, int32]
_cc_row_entry: Array[40, int32]        # ENTRY rows: registry index; else -1
_cc_row_y:     Array[40, int32]        # dialog-local top y of the row


def _cc_slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _cc_lower(c: uint8) -> uint8:
    if c >= 65 and c <= 90:
        return c + 32
    return c


def ctxm_choice_reset():
    _cc_count = 0
    _cc_filter_len = 0
    _cc_filter[0] = 0


def ctxm_choice_add(name: Ptr[uint8], desc: Ptr[uint8], applet: int32,
                    cat: int32):
    if _cc_count >= CTXM_CC_MAX:
        return
    i: uint64 = _cc_count
    nl: uint64 = _cc_slen(name)
    if nl >= CTXM_CC_NAME_CAP:
        nl = CTXM_CC_NAME_CAP - 1
    k: uint64 = 0
    while k < nl:
        _cc_name[i][k] = name[k]
        k = k + 1
    _cc_name[i][nl] = 0
    _cc_nlen[i] = nl
    dl: uint64 = _cc_slen(desc)
    if dl >= CTXM_CC_DESC_CAP:
        dl = CTXM_CC_DESC_CAP - 1
    k = 0
    while k < dl:
        _cc_desc[i][k] = desc[k]
        k = k + 1
    _cc_desc[i][dl] = 0
    _cc_dlen[i] = dl
    _cc_applet[i] = applet
    _cc_cat[i] = cat
    _cc_count = _cc_count + 1


# Populate the registry with the applets the hampanelscene panel can add.
def ctxm_choice_init():
    ctxm_choice_reset()
    ctxm_choice_add(cast[Ptr[uint8]]("Menu Bar"),
                    cast[Ptr[uint8]]("Applications menu button"),
                    CTXM_APPLET_MENUBAR, CTXM_CC_CAT_LAUNCH)
    ctxm_choice_add(cast[Ptr[uint8]]("Clock"),
                    cast[Ptr[uint8]]("Shows the current date and time"),
                    CTXM_APPLET_CLOCK, CTXM_CC_CAT_CLOCK)
    ctxm_choice_add(cast[Ptr[uint8]]("System Monitor"),
                    cast[Ptr[uint8]]("CPU and memory usage meters"),
                    CTXM_APPLET_SYSMON, CTXM_CC_CAT_SYSTEM)
    ctxm_choice_add(cast[Ptr[uint8]]("Notification Area"),
                    cast[Ptr[uint8]]("Message tray and alerts"),
                    CTXM_APPLET_NOTIF, CTXM_CC_CAT_SYSTEM)
    ctxm_choice_add(cast[Ptr[uint8]]("Session"),
                    cast[Ptr[uint8]]("Lock, log out, or shut down"),
                    CTXM_APPLET_SESSION, CTXM_CC_CAT_SYSTEM)
    ctxm_choice_add(cast[Ptr[uint8]]("Window List"),
                    cast[Ptr[uint8]]("Buttons for your open windows"),
                    CTXM_APPLET_WINLIST, CTXM_CC_CAT_WINDOWS)
    ctxm_choice_add(cast[Ptr[uint8]]("Workspace Switcher"),
                    cast[Ptr[uint8]]("Switch between virtual desktops"),
                    CTXM_APPLET_PAGER, CTXM_CC_CAT_WINDOWS)
    ctxm_choice_add(cast[Ptr[uint8]]("Spacer"),
                    cast[Ptr[uint8]]("Flexible empty space between applets"),
                    CTXM_APPLET_SPACER, CTXM_CC_CAT_UTIL)


def ctxm_choice_count() -> uint64:
    return _cc_count


def ctxm_choice_w() -> int32:
    return CTXM_CC_W


def ctxm_choice_cat_name(c: int32) -> Ptr[uint8]:
    if c == CTXM_CC_CAT_LAUNCH:
        a: Ptr[uint8] = "Menus & Launchers"
        return a
    if c == CTXM_CC_CAT_CLOCK:
        b: Ptr[uint8] = "Clock"
        return b
    if c == CTXM_CC_CAT_SYSTEM:
        d: Ptr[uint8] = "System & Hardware"
        return d
    if c == CTXM_CC_CAT_WINDOWS:
        e: Ptr[uint8] = "Windows & Workspaces"
        return e
    f: Ptr[uint8] = "Utilities"
    return f


def _cc_cat_hex(c: int32) -> Ptr[uint8]:
    if c == CTXM_CC_CAT_LAUNCH:
        a: Ptr[uint8] = "#3c64a0"
        return a
    if c == CTXM_CC_CAT_CLOCK:
        b: Ptr[uint8] = "#c9a84a"
        return b
    if c == CTXM_CC_CAT_SYSTEM:
        d: Ptr[uint8] = "#787850"
        return d
    if c == CTXM_CC_CAT_WINDOWS:
        e: Ptr[uint8] = "#5a8a4a"
        return e
    f: Ptr[uint8] = "#a05aa0"
    return f


# ---- search filter -------------------------------------------------------
def ctxm_choice_set_filter(s: Ptr[uint8]):
    n: uint64 = 0
    while s[n] != 0 and n + 1 < CTXM_CC_FILTER_CAP:
        _cc_filter[n] = _cc_lower(s[n])
        n = n + 1
    _cc_filter[n] = 0
    _cc_filter_len = n


def ctxm_choice_filter_ptr() -> Ptr[uint8]:
    return &_cc_filter[0]


def ctxm_choice_filter_len() -> uint64:
    return _cc_filter_len


def ctxm_choice_filter_push(c: uint8):
    if _cc_filter_len + 1 < CTXM_CC_FILTER_CAP:
        _cc_filter[_cc_filter_len] = _cc_lower(c)
        _cc_filter_len = _cc_filter_len + 1
        _cc_filter[_cc_filter_len] = 0


def ctxm_choice_filter_backspace():
    if _cc_filter_len > 0:
        _cc_filter_len = _cc_filter_len - 1
        _cc_filter[_cc_filter_len] = 0


# Case-insensitive substring: is _cc_filter inside buf[0..blen)?
def _cc_sub(buf: Ptr[uint8], blen: uint64) -> int32:
    if _cc_filter_len == 0:
        return 1
    if _cc_filter_len > blen:
        return 0
    i: uint64 = 0
    while i + _cc_filter_len <= blen:
        k: uint64 = 0
        while k < _cc_filter_len and \
                _cc_lower(buf[i + k]) == _cc_filter[k]:
            k = k + 1
        if k == _cc_filter_len:
            return 1
        i = i + 1
    return 0


# An entry matches when the filter is empty, or is a substring of its NAME or
# its DESCRIPTION (so "monitor" or "cpu" both surface the System Monitor).
def _cc_matches(i: uint64) -> int32:
    if _cc_filter_len == 0:
        return 1
    if _cc_sub(&_cc_name[i][0], _cc_nlen[i]) != 0:
        return 1
    if _cc_sub(&_cc_desc[i][0], _cc_dlen[i]) != 0:
        return 1
    return 0


# ---- layout --------------------------------------------------------------
def _cc_push_row(kind: int32, cat: int32, entry: int32, y: int32) -> int32:
    if _cc_row_count >= CTXM_CC_MAX_ROWS:
        return y
    i: uint64 = _cc_row_count
    _cc_row_kind[i] = kind
    _cc_row_cat[i] = cat
    _cc_row_entry[i] = entry
    _cc_row_y[i] = y
    _cc_row_count = _cc_row_count + 1
    h: int32 = CTXM_CC_ENTRY_H
    if kind == CTXM_CC_ROW_SEARCH:
        h = CTXM_CC_SEARCH_H
    elif kind == CTXM_CC_ROW_HEADER:
        h = CTXM_CC_HEADER_H
    return y + h


def ctxm_choice_layout():
    _cc_row_count = 0
    y: int32 = CTXM_CC_TITLE_H
    y = _cc_push_row(CTXM_CC_ROW_SEARCH, 0, -1, y)
    c: int32 = 0
    while c < CTXM_CC_CAT_COUNT:
        matches: int32 = 0
        a: uint64 = 0
        while a < _cc_count:
            if _cc_cat[a] == c and _cc_matches(a) != 0:
                matches = matches + 1
            a = a + 1
        if matches > 0:
            y = _cc_push_row(CTXM_CC_ROW_HEADER, c, -1, y)
            a = 0
            while a < _cc_count:
                if _cc_cat[a] == c and _cc_matches(a) != 0:
                    y = _cc_push_row(CTXM_CC_ROW_ENTRY, c, cast[int32](a), y)
                a = a + 1
        c = c + 1


def ctxm_choice_row_count() -> uint64:
    return _cc_row_count


def ctxm_choice_row_kind(i: uint64) -> int32:
    return _cc_row_kind[i]


def ctxm_choice_row_cat(i: uint64) -> int32:
    return _cc_row_cat[i]


def ctxm_choice_row_entry(i: uint64) -> int32:
    return _cc_row_entry[i]


def ctxm_choice_row_y(i: uint64) -> int32:
    return _cc_row_y[i]


# The CTXM_APPLET_* identity an ENTRY row inserts (or CTXM_APPLET_NONE).
def ctxm_choice_row_applet(i: uint64) -> int32:
    if _cc_row_kind[i] != CTXM_CC_ROW_ENTRY:
        return CTXM_APPLET_NONE
    e: int32 = _cc_row_entry[i]
    if e < 0:
        return CTXM_APPLET_NONE
    return _cc_applet[cast[uint64](e)]


def ctxm_choice_row_name(i: uint64) -> Ptr[uint8]:
    if _cc_row_kind[i] != CTXM_CC_ROW_ENTRY:
        e: Ptr[uint8] = ""
        return e
    return &_cc_name[cast[uint64](_cc_row_entry[i])][0]


# Total laid-out dialog height (title + rows + a little bottom pad).
def ctxm_choice_content_h() -> int32:
    if _cc_row_count == 0:
        return CTXM_CC_TITLE_H + CTXM_CC_SEARCH_H + 4
    last: uint64 = _cc_row_count - 1
    k: int32 = _cc_row_kind[last]
    h: int32 = CTXM_CC_ENTRY_H
    if k == CTXM_CC_ROW_SEARCH:
        h = CTXM_CC_SEARCH_H
    elif k == CTXM_CC_ROW_HEADER:
        h = CTXM_CC_HEADER_H
    return _cc_row_y[last] + h + 4


# Row under (px,py) for a dialog whose top-left is (bx,by), or -1.
def ctxm_choice_hit(bx: int32, by: int32, px: int32, py: int32) -> int64:
    if px < bx or px >= bx + CTXM_CC_W:
        return -1
    i: uint64 = 0
    while i < _cc_row_count:
        ry: int32 = by + _cc_row_y[i]
        k: int32 = _cc_row_kind[i]
        rh: int32 = CTXM_CC_ENTRY_H
        if k == CTXM_CC_ROW_SEARCH:
            rh = CTXM_CC_SEARCH_H
        elif k == CTXM_CC_ROW_HEADER:
            rh = CTXM_CC_HEADER_H
        if py >= ry and py < ry + rh:
            return cast[int64](i)
        i = i + 1
    return -1


# ---- renderer (no hamscene_begin; embeds in the caller's scene) ----------
# `hover` is the highlighted ENTRY row (-1 = none).
_cc_glyphbuf: Array[2, uint8]
def ctxm_choice_draw(bx: int32, by: int32, hover: int32):
    body:     Ptr[uint8] = "#f7f8fa"
    frame:    Ptr[uint8] = "#cfd2d8"
    shadow:   Ptr[uint8] = "#00000040"
    txt:      Ptr[uint8] = "#23262b"
    desctxt:  Ptr[uint8] = "#6b7078"
    seltxt:   Ptr[uint8] = "#ffffff"
    seldesc:  Ptr[uint8] = "#dfe6f2"
    selbg:    Ptr[uint8] = "#3584e4"
    capbg:    Ptr[uint8] = "#e3ecfb"
    captxt:   Ptr[uint8] = "#1c5fb8"
    hdrbg:    Ptr[uint8] = "#eceef2"
    hdrtxt:   Ptr[uint8] = "#6b7078"
    searchbg: Ptr[uint8] = "#ffffff"
    hint:     Ptr[uint8] = "#9298a1"

    w: int32 = CTXM_CC_W
    h: int32 = ctxm_choice_content_h()

    # Drop shadow, body, frame.
    hamscene_fill(bx + 3, by + 3, w, h, shadow)
    hamscene_fill(bx, by, w, h, body)
    hamscene_stroke(bx, by, w, h, 1, frame)
    # Title strip.
    hamscene_fill(bx, by, w, CTXM_CC_TITLE_H, capbg)
    hamscene_glyphs_bold(bx + CTXM_CC_PAD_L, by + 5,
                         cast[Ptr[uint8]]("Add to Panel"), captxt)

    i: uint64 = 0
    while i < _cc_row_count:
        ry: int32 = by + _cc_row_y[i]
        k: int32 = _cc_row_kind[i]
        if k == CTXM_CC_ROW_SEARCH:
            hamscene_fill(bx + 6, ry + 3, w - 12, CTXM_CC_SEARCH_H - 6, searchbg)
            hamscene_stroke(bx + 6, ry + 3, w - 12, CTXM_CC_SEARCH_H - 6, 1, frame)
            hamscene_fill(bx + 12, ry + 10, 5, 5, hint)     # magnifier lens
            hamscene_fill(bx + 16, ry + 14, 3, 3, hint)     # handle
            if _cc_filter_len > 0:
                hamscene_glyphs(bx + 26, ry + 6, &_cc_filter[0], txt)
            else:
                hamscene_glyphs(bx + 26, ry + 6,
                                cast[Ptr[uint8]]("Search applets..."), hint)
        elif k == CTXM_CC_ROW_HEADER:
            hamscene_fill(bx + 1, ry, w - 2, CTXM_CC_HEADER_H, hdrbg)
            hamscene_glyphs_bold(bx + CTXM_CC_PAD_L, ry + 2,
                                 ctxm_choice_cat_name(_cc_row_cat[i]), hdrtxt)
        else:
            nm: Ptr[uint8] = txt
            ds: Ptr[uint8] = desctxt
            if cast[int32](i) == hover:
                hamscene_fill(bx + 1, ry, w - 2, CTXM_CC_ENTRY_H, selbg)
                nm = seltxt
                ds = seldesc
            # Category-coloured icon chip.
            ix: int32 = bx + CTXM_CC_PAD_L
            iy: int32 = ry + (CTXM_CC_ENTRY_H - CTXM_CC_ICON) / 2
            hamscene_fill(ix, iy, CTXM_CC_ICON, CTXM_CC_ICON, _cc_cat_hex(_cc_row_cat[i]))
            hamscene_stroke(ix, iy, CTXM_CC_ICON, CTXM_CC_ICON, 1, frame)
            e: uint64 = cast[uint64](_cc_row_entry[i])
            tx: int32 = ix + CTXM_CC_ICON + 10
            hamscene_glyphs_bold(tx, ry + 5, &_cc_name[e][0], nm)
            hamscene_glyphs(tx, ry + 23, &_cc_desc[e][0], ds)
        i = i + 1


# ---- host wrapper: begin + desktop backdrop, then draw -------------------
def ctxm_choice_build_scene(bx: int32, by: int32, hover: int32,
                            scr_w: int32, scr_h: int32):
    hamscene_begin()
    hamscene_fill(0, 0, scr_w, scr_h, cast[Ptr[uint8]]("#5c6b80"))
    ctxm_choice_draw(bx, by, hover)

# lib/gamekey.ad — PURE decoder for the terminal GAME-input protocol.
#
# A terminal GAME (user/keydemo.ad and friends) opts into the graphical
# terminal's GAME input mode with the escape ESC[?9003h. While set, the
# terminal (user/hamtermscene.ad :: _forward_key_line) forwards each key event
# from the compositor's /dev/wsys/<wid>/keys stream VERBATIM to the program's
# stdin as an ASCII line:
#
#   d <code>\n   key DOWN (press)   — code is the raw ASCII/byte key code
#   u <code>\n   key UP   (release) — the record a cooked tty never delivers
#
# This is exactly what makes terminal GAMES possible on Hamnix but not on a
# normal Linux shell: a program can see a key being HELD (down with no up yet)
# and RELEASED. gk_next is the extern-free line decoder shared by the game and
# its host unit test (user/gamekey_host.ad) so the wire format has ONE parser.

GK_NONE: int32 = 0                            # no complete event line yet
GK_DOWN: int32 = 1
GK_UP:   int32 = 2


def gk_next(buf: Ptr[uint8], len: uint64, pos: Ptr[uint64],
            out_code: Ptr[int32]) -> int32:
    # Decode ONE "<d|u> <code>\n" line starting at *pos. Advances *pos past the
    # consumed line and returns GK_DOWN / GK_UP with *out_code set, or GK_NONE
    # (leaving *pos unchanged) when no COMPLETE line is buffered yet — so a
    # caller draining a pipe can carry a split trailing line into the next read.
    i: uint64 = pos[0]
    ls: uint64 = i
    if i >= len:
        return GK_NONE
    t: uint8 = buf[i]
    kind: int32 = GK_NONE
    if t == 100:                              # 'd'
        kind = GK_DOWN
    elif t == 117:                            # 'u'
        kind = GK_UP
    i = i + 1
    if i < len and buf[i] == 32:              # space
        i = i + 1
    code: int32 = 0
    have: int32 = 0
    neg: int32 = 0
    if i < len and buf[i] == 45:              # '-'
        neg = 1
        i = i + 1
    while i < len and buf[i] >= 48 and buf[i] <= 57:
        code = code * 10 + cast[int32](buf[i]) - 48
        i = i + 1
        have = 1
    while i < len and buf[i] != 10:           # to end of line
        i = i + 1
    if i >= len:
        # No terminating newline in this buffer — incomplete line, carry it.
        return GK_NONE
    i = i + 1                                 # consume '\n'
    pos[0] = i
    if neg != 0:
        code = 0 - code
    out_code[0] = code
    if kind == GK_NONE or have == 0:
        # A malformed / unknown-type line was consumed; report NONE but the
        # cursor advanced so the caller makes progress (does not spin).
        return GK_NONE
    return kind

# lib/hamchesscore.ad — the PURE, target-agnostic core of the Chess scene app.
#
# WHY (dual-target seam, see docs/hamui_dual_target.md)
# =====================================================
# This is the Chess RULES ENGINE (board, piece move generation for all six
# piece types, turn alternation, check / checkmate / stalemate detection,
# pawn promotion), its scene DISPLAY-LIST builder, and its pure pointer INPUT
# handler (click-to-select, click-to-move) — everything EXCEPT the Hamnix-only
# window transport. Factored out exactly the way lib/ham2048core.ad was, so the
# SAME code drives two sinks:
#   * user/hamchessscene.ad       — NATIVE: hchess_build_scene() +
#                                   hamscene_commit(wid) to /dev/wsys.
#   * user/hamchessscene_host.ad  — HOST: hchess_build_scene() then the
#                                   lib/hamui_host.ad rasterizer -> PPM/PNG,
#                                   driven by scripted clicks/moves.
# It imports ONLY lib/hamscene.ad (the pure builder), has NO `extern`, and so
# links into both the x86_64-adder-user (native) and x86_64-linux (host)
# targets.
#
# V1 SCOPE: hot-seat two humans. Full legal move generation for every piece,
# check/checkmate/stalemate detection, and auto-queen promotion. NOT YET:
# castling, en passant, or under-promotion (honest gaps — see the game core
# TODO at the foot of this file).

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_stroke, \
    hamscene_panel_button


# ---- tiny pure helpers ---------------------------------------------------
def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# ====================================================================
# GAME STATE
# ====================================================================
# board[rank*8 + file]. rank 0 = TOP row (black back rank), rank 7 = BOTTOM
# (white back rank), so white pieces sit at the bottom as drawn. Piece codes:
#   0 = empty. Sign encodes colour: POSITIVE = white, NEGATIVE = black.
#   |code|: 1 pawn, 2 knight, 3 bishop, 4 rook, 5 queen, 6 king.
board: Array[64, int32]

# side to move: 1 = white, -1 = black.
turn: int32 = 1

# selected source square (-1 = none) and its legal destinations.
sel: int32 = -1
legal_sq: Array[28, int32]
legal_n:  int32 = 0

# outcome: 0 = in progress, 1 = checkmate, 2 = stalemate.
outcome: int32 = 0
# winner when outcome==1: 1 = white, -1 = black, 0 = none.
winner: int32 = 0


PAWN:   int32 = 1
KNIGHT: int32 = 2
BISHOP: int32 = 3
ROOK:   int32 = 4
QUEEN:  int32 = 5
KING:   int32 = 6


def _abs32(v: int32) -> int32:
    if v < 0:
        return 0 - v
    return v


def _sign(v: int32) -> int32:
    if v > 0:
        return 1
    if v < 0:
        return -1
    return 0


def _rk(sq: int32) -> int32:
    return sq / 8


def _fl(sq: int32) -> int32:
    return sq % 8


def _on_board(r: int32, f: int32) -> int32:
    if r >= 0 and r < 8 and f >= 0 and f < 8:
        return 1
    return 0


# PUBLIC: set the standard opening position, white to move.
def hchess_reset():
    i: uint64 = 0
    while i < 64:
        board[i] = 0
        i = i + 1
    # back ranks (file order: R N B Q K B N R)
    back: Array[8, int32]
    back[0] = ROOK
    back[1] = KNIGHT
    back[2] = BISHOP
    back[3] = QUEEN
    back[4] = KING
    back[5] = BISHOP
    back[6] = KNIGHT
    back[7] = ROOK
    f: int32 = 0
    while f < 8:
        board[cast[uint64](f)] = 0 - back[cast[uint64](f)]          # rank0 black
        board[cast[uint64](8 + f)] = 0 - PAWN                       # rank1 black pawns
        board[cast[uint64](48 + f)] = PAWN                          # rank6 white pawns
        board[cast[uint64](56 + f)] = back[cast[uint64](f)]         # rank7 white
        f = f + 1
    turn = 1
    sel = -1
    legal_n = 0
    outcome = 0
    winner = 0


# ---- attack detection ----------------------------------------------------
# Sliding ray directions (dr,df).
_diag_dr: Array[4, int32]
_diag_df: Array[4, int32]
_orth_dr: Array[4, int32]
_orth_df: Array[4, int32]
_kn_dr:   Array[8, int32]
_kn_df:   Array[8, int32]
_dirs_ready: int32 = 0


def _init_dirs():
    if _dirs_ready != 0:
        return
    _diag_dr[0] = -1
    _diag_df[0] = -1
    _diag_dr[1] = -1
    _diag_df[1] = 1
    _diag_dr[2] = 1
    _diag_df[2] = -1
    _diag_dr[3] = 1
    _diag_df[3] = 1
    _orth_dr[0] = -1
    _orth_df[0] = 0
    _orth_dr[1] = 1
    _orth_df[1] = 0
    _orth_dr[2] = 0
    _orth_df[2] = -1
    _orth_dr[3] = 0
    _orth_df[3] = 1
    _kn_dr[0] = -2
    _kn_df[0] = -1
    _kn_dr[1] = -2
    _kn_df[1] = 1
    _kn_dr[2] = -1
    _kn_df[2] = -2
    _kn_dr[3] = -1
    _kn_df[3] = 2
    _kn_dr[4] = 1
    _kn_df[4] = -2
    _kn_dr[5] = 1
    _kn_df[5] = 2
    _kn_dr[6] = 2
    _kn_df[6] = -1
    _kn_dr[7] = 2
    _kn_df[7] = 1
    _dirs_ready = 1


# 1 iff square (r,f) is attacked by any piece of colour `by` (1 white, -1 black).
def _attacked(r: int32, f: int32, by: int32) -> int32:
    _init_dirs()
    # Pawn attacks: a `by` pawn sits one rank toward its own side and one file
    # to either side. A white pawn (by=1, moves toward rank 0) attacking (r,f)
    # sits at rank r+1; a black pawn at rank r-1.
    pr: int32 = r + by                  # white by=1 -> r+1; black by=-1 -> r-1
    fa: int32 = 0
    while fa < 2:
        pf: int32 = f - 1
        if fa == 1:
            pf = f + 1
        if _on_board(pr, pf) == 1:
            if board[cast[uint64](pr * 8 + pf)] == by * PAWN:
                return 1
        fa = fa + 1
    # Knight attacks.
    ki: int32 = 0
    while ki < 8:
        rr: int32 = r + _kn_dr[cast[uint64](ki)]
        ff: int32 = f + _kn_df[cast[uint64](ki)]
        if _on_board(rr, ff) == 1:
            if board[cast[uint64](rr * 8 + ff)] == by * KNIGHT:
                return 1
        ki = ki + 1
    # King attacks (adjacent).
    dr: int32 = -1
    while dr <= 1:
        df: int32 = -1
        while df <= 1:
            if dr != 0 or df != 0:
                rr2: int32 = r + dr
                ff2: int32 = f + df
                if _on_board(rr2, ff2) == 1:
                    if board[cast[uint64](rr2 * 8 + ff2)] == by * KING:
                        return 1
            df = df + 1
        dr = dr + 1
    # Diagonal rays: bishop or queen.
    d: int32 = 0
    while d < 4:
        rr3: int32 = r + _diag_dr[cast[uint64](d)]
        ff3: int32 = f + _diag_df[cast[uint64](d)]
        while _on_board(rr3, ff3) == 1:
            pc: int32 = board[cast[uint64](rr3 * 8 + ff3)]
            if pc != 0:
                if _sign(pc) == by:
                    ap: int32 = _abs32(pc)
                    if ap == BISHOP or ap == QUEEN:
                        return 1
                d = d                     # stop this ray
                rr3 = -100
                ff3 = -100
            else:
                rr3 = rr3 + _diag_dr[cast[uint64](d)]
                ff3 = ff3 + _diag_df[cast[uint64](d)]
        d = d + 1
    # Orthogonal rays: rook or queen.
    o: int32 = 0
    while o < 4:
        rr4: int32 = r + _orth_dr[cast[uint64](o)]
        ff4: int32 = f + _orth_df[cast[uint64](o)]
        while _on_board(rr4, ff4) == 1:
            pc2: int32 = board[cast[uint64](rr4 * 8 + ff4)]
            if pc2 != 0:
                if _sign(pc2) == by:
                    ap2: int32 = _abs32(pc2)
                    if ap2 == ROOK or ap2 == QUEEN:
                        return 1
                rr4 = -100
                ff4 = -100
            else:
                rr4 = rr4 + _orth_dr[cast[uint64](o)]
                ff4 = ff4 + _orth_df[cast[uint64](o)]
        o = o + 1
    return 0


def _king_sq(color: int32) -> int32:
    i: int32 = 0
    while i < 64:
        if board[cast[uint64](i)] == color * KING:
            return i
        i = i + 1
    return -1


# PUBLIC: is `color`'s king in check?
def hchess_in_check(color: int32) -> int32:
    ks: int32 = _king_sq(color)
    if ks < 0:
        return 0
    return _attacked(_rk(ks), _fl(ks), 0 - color)


# ---- pseudo-legal move generation ----------------------------------------
# Append dest square `d` for a mover of colour `me` if `d` is empty or holds an
# enemy piece. Returns the new count.
def _addmv(out: Ptr[int32], n: int32, d: int32, me: int32) -> int32:
    tgt: int32 = board[cast[uint64](d)]
    if tgt == 0 or _sign(tgt) != me:
        out[cast[uint64](n)] = d
        return n + 1
    return n


def _ray(out: Ptr[int32], n: int32, sq: int32, me: int32,
         dr: int32, df: int32) -> int32:
    r: int32 = _rk(sq) + dr
    f: int32 = _fl(sq) + df
    while _on_board(r, f) == 1:
        d: int32 = r * 8 + f
        tgt: int32 = board[cast[uint64](d)]
        if tgt == 0:
            out[cast[uint64](n)] = d
            n = n + 1
        else:
            if _sign(tgt) != me:
                out[cast[uint64](n)] = d
                n = n + 1
            r = 100
            f = 100
        r = r + dr
        f = f + df
    return n


# Fill `out` with pseudo-legal destinations from `sq` (ignoring self-check).
# Returns the count.
def _pseudo(sq: int32, out: Ptr[int32]) -> int32:
    _init_dirs()
    pc: int32 = board[cast[uint64](sq)]
    if pc == 0:
        return 0
    me: int32 = _sign(pc)
    ap: int32 = _abs32(pc)
    n: int32 = 0
    r: int32 = _rk(sq)
    f: int32 = _fl(sq)
    if ap == PAWN:
        fwd: int32 = 0 - me                 # white me=1 -> -1 (up); black -> +1
        r1: int32 = r + fwd
        if _on_board(r1, f) == 1 and board[cast[uint64](r1 * 8 + f)] == 0:
            out[cast[uint64](n)] = r1 * 8 + f
            n = n + 1
            # double from the start rank (white rank6, black rank1).
            start: int32 = 1
            if me == 1:
                start = 6
            r2: int32 = r + fwd * 2
            if r == start and board[cast[uint64](r2 * 8 + f)] == 0:
                out[cast[uint64](n)] = r2 * 8 + f
                n = n + 1
        cf: int32 = -1
        while cf <= 1:
            if cf != 0:
                ff: int32 = f + cf
                if _on_board(r1, ff) == 1:
                    tgt: int32 = board[cast[uint64](r1 * 8 + ff)]
                    if tgt != 0 and _sign(tgt) != me:
                        out[cast[uint64](n)] = r1 * 8 + ff
                        n = n + 1
            cf = cf + 2
        return n
    if ap == KNIGHT:
        ki: int32 = 0
        while ki < 8:
            rr: int32 = r + _kn_dr[cast[uint64](ki)]
            ff2: int32 = f + _kn_df[cast[uint64](ki)]
            if _on_board(rr, ff2) == 1:
                n = _addmv(out, n, rr * 8 + ff2, me)
            ki = ki + 1
        return n
    if ap == KING:
        dr: int32 = -1
        while dr <= 1:
            df: int32 = -1
            while df <= 1:
                if dr != 0 or df != 0:
                    rr2: int32 = r + dr
                    ff3: int32 = f + df
                    if _on_board(rr2, ff3) == 1:
                        n = _addmv(out, n, rr2 * 8 + ff3, me)
                df = df + 1
            dr = dr + 1
        return n
    # sliding pieces
    if ap == BISHOP or ap == QUEEN:
        d: int32 = 0
        while d < 4:
            n = _ray(out, n, sq, me, _diag_dr[cast[uint64](d)],
                     _diag_df[cast[uint64](d)])
            d = d + 1
    if ap == ROOK or ap == QUEEN:
        o: int32 = 0
        while o < 4:
            n = _ray(out, n, sq, me, _orth_dr[cast[uint64](o)],
                     _orth_df[cast[uint64](o)])
            o = o + 1
    return n


# Apply from->to on the real board, promoting a pawn reaching the last rank to
# a queen. Returns the captured piece (0 if none) plus, via out-params, the
# from-piece so the caller can UNDO.
def _do_move(fr: int32, to: int32, cap: Ptr[int32], moved: Ptr[int32]):
    pc: int32 = board[cast[uint64](fr)]
    cap[0] = board[cast[uint64](to)]
    moved[0] = pc
    np: int32 = pc
    if _abs32(pc) == PAWN:
        tr: int32 = _rk(to)
        if (pc > 0 and tr == 0) or (pc < 0 and tr == 7):
            np = _sign(pc) * QUEEN
    board[cast[uint64](to)] = np
    board[cast[uint64](fr)] = 0


def _undo_move(fr: int32, to: int32, cap: int32, moved: int32):
    board[cast[uint64](fr)] = moved
    board[cast[uint64](to)] = cap


# Fill `out` with fully LEGAL destinations from `sq` (self-check filtered).
def _legal_from(sq: int32, out: Ptr[int32]) -> int32:
    pc: int32 = board[cast[uint64](sq)]
    if pc == 0:
        return 0
    me: int32 = _sign(pc)
    pmv: Array[28, int32]
    pn: int32 = _pseudo(sq, &pmv[0])
    n: int32 = 0
    i: int32 = 0
    while i < pn:
        to: int32 = pmv[cast[uint64](i)]
        cap: int32 = 0
        moved: int32 = 0
        _do_move(sq, to, &cap, &moved)
        ok: int32 = 1
        if hchess_in_check(me) != 0:
            ok = 0
        _undo_move(sq, to, cap, moved)
        if ok == 1:
            out[cast[uint64](n)] = to
            n = n + 1
        i = i + 1
    return n


# Does `color` (side to move) have ANY legal move?
def _has_legal(color: int32) -> int32:
    sq: int32 = 0
    while sq < 64:
        pc: int32 = board[cast[uint64](sq)]
        if pc != 0 and _sign(pc) == color:
            tmp: Array[28, int32]
            if _legal_from(sq, &tmp[0]) > 0:
                return 1
        sq = sq + 1
    return 0


# Recompute check/checkmate/stalemate for the side to move.
def _update_outcome():
    outcome = 0
    winner = 0
    if _has_legal(turn) == 0:
        if hchess_in_check(turn) != 0:
            outcome = 1                      # checkmate
            winner = 0 - turn                # the side that just moved wins
        else:
            outcome = 2                      # stalemate


# PUBLIC: attempt a move fr->to for the side to move. Returns 1 if it was legal
# and applied (turn flips, outcome recomputed), else 0.
def hchess_try_move(fr: int32, to: int32) -> int32:
    if outcome != 0:
        return 0
    if fr < 0 or fr > 63 or to < 0 or to > 63:
        return 0
    pc: int32 = board[cast[uint64](fr)]
    if pc == 0 or _sign(pc) != turn:
        return 0
    lg: Array[28, int32]
    ln: int32 = _legal_from(fr, &lg[0])
    ok: int32 = 0
    i: int32 = 0
    while i < ln:
        if lg[cast[uint64](i)] == to:
            ok = 1
        i = i + 1
    if ok == 0:
        return 0
    cap: int32 = 0
    moved: int32 = 0
    _do_move(fr, to, &cap, &moved)
    turn = 0 - turn
    sel = -1
    legal_n = 0
    _update_outcome()
    return 1


# ---- PUBLIC state getters (host-test assertions) -------------------------
def hchess_piece_at(sq: int32) -> int32:
    if sq < 0 or sq > 63:
        return 0
    return board[cast[uint64](sq)]


def hchess_turn() -> int32:
    return turn


def hchess_selected() -> int32:
    return sel


def hchess_outcome() -> int32:
    return outcome


def hchess_winner() -> int32:
    return winner


# Number of legal moves from `sq` (0 if empty / not the side to move's piece).
def hchess_legal_count(sq: int32) -> int32:
    if sq < 0 or sq > 63:
        return 0
    tmp: Array[28, int32]
    return _legal_from(sq, &tmp[0])


# Total legal moves for the side to move (0 => mate or stalemate).
def hchess_legal_total() -> int32:
    tot: int32 = 0
    sq: int32 = 0
    while sq < 64:
        pc: int32 = board[cast[uint64](sq)]
        if pc != 0 and _sign(pc) == turn:
            tmp: Array[28, int32]
            tot = tot + _legal_from(sq, &tmp[0])
        sq = sq + 1
    return tot


# ====================================================================
# LAYOUT
# ====================================================================
GAME_W: int32 = 360
GAME_H: int32 = 470

SQ:      int32 = 40
BOARD_X: int32 = 20               # (360 - 8*40) / 2
BOARD_Y: int32 = 56
HDR_Y:   int32 = 14
STAT_Y:  int32 = 388
CTRL_Y:  int32 = 430
CTRL_H:  int32 = 30
PAD:     int32 = 12
BTN_W:   int32 = 80


def _sq_x(f: int32) -> int32:
    return BOARD_X + f * SQ


def _sq_y(r: int32) -> int32:
    return BOARD_Y + r * SQ


# PUBLIC: board square index at pixel (lx,ly), or -1 if outside the board.
def hchess_sq_at(lx: int64, ly: int64) -> int32:
    if lx < cast[int64](BOARD_X) or ly < cast[int64](BOARD_Y):
        return -1
    fx: int32 = cast[int32](lx) - BOARD_X
    fy: int32 = cast[int32](ly) - BOARD_Y
    if fx >= SQ * 8 or fy >= SQ * 8:
        return -1
    f: int32 = fx / SQ
    r: int32 = fy / SQ
    return r * 8 + f


# PUBLIC: which control button is at (lx,ly), or -1 (0 = New game).
def hchess_btn_at(lx: int64, ly: int64) -> int64:
    if ly < cast[int64](CTRL_Y) or ly >= cast[int64](CTRL_Y + CTRL_H):
        return -1
    bx: int64 = cast[int64](PAD)
    if lx >= bx and lx < bx + cast[int64](BTN_W):
        return 0
    return -1


# ====================================================================
# RENDER
# ====================================================================
sbuf: Array[80, uint8]


def _put(pos: uint64, s: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while s[i] != 0:
        sbuf[pos] = s[i]
        pos = pos + 1
        i = i + 1
    return pos


# The single upright glyph for a piece (uppercase for both colours; colour is
# carried by the glyph paint, light for white / dark for black).
gbuf: Array[2, uint8]


def _piece_letter(ap: int32) -> Ptr[uint8]:
    gbuf[1] = 0
    if ap == PAWN:
        gbuf[0] = 80                     # 'P'
    elif ap == KNIGHT:
        gbuf[0] = 78                     # 'N'
    elif ap == BISHOP:
        gbuf[0] = 66                     # 'B'
    elif ap == ROOK:
        gbuf[0] = 82                     # 'R'
    elif ap == QUEEN:
        gbuf[0] = 81                     # 'Q'
    else:
        gbuf[0] = 75                     # 'K'
    return &gbuf[0]


# PUBLIC: build the whole display list into the shared hamscene buffer.
def hchess_build_scene():
    hamscene_begin()
    hamscene_fill(0, 0, GAME_W, GAME_H, cast[Ptr[uint8]]("#20222b"))

    # Header: title + whose move / result.
    hamscene_glyphs_bold(PAD, HDR_Y, cast[Ptr[uint8]]("Chess"),
                         cast[Ptr[uint8]]("#eef0f6"))

    # Board squares (light/dark) + selection + legal-move hints + pieces.
    r: int32 = 0
    while r < 8:
        f: int32 = 0
        while f < 8:
            px: int32 = _sq_x(f)
            py: int32 = _sq_y(r)
            light: int32 = (r + f) % 2
            col: Ptr[uint8] = cast[Ptr[uint8]]("#8a6d4a")   # dark square
            if light == 0:
                col = cast[Ptr[uint8]]("#e9d3ab")           # light square
            hamscene_fill(px, py, SQ, SQ, col)
            f = f + 1
        r = r + 1

    # Selection highlight + legal destination dots (drawn under the pieces).
    if sel >= 0:
        sx: int32 = _sq_x(_fl(sel))
        sy: int32 = _sq_y(_rk(sel))
        hamscene_fill(sx, sy, SQ, SQ, cast[Ptr[uint8]]("#c8b45a"))
        i: int32 = 0
        while i < legal_n:
            d: int32 = legal_sq[cast[uint64](i)]
            dx: int32 = _sq_x(_fl(d)) + SQ / 2 - 5
            dy: int32 = _sq_y(_rk(d)) + SQ / 2 - 5
            hamscene_fill(dx, dy, 10, 10, cast[Ptr[uint8]]("#5aa0e0"))
            i = i + 1

    # Pieces.
    r2: int32 = 0
    while r2 < 8:
        f2: int32 = 0
        while f2 < 8:
            pc: int32 = board[cast[uint64](r2 * 8 + f2)]
            if pc != 0:
                ap: int32 = _abs32(pc)
                lt: Ptr[uint8] = _piece_letter(ap)
                gx: int32 = _sq_x(f2) + (SQ - 8) / 2
                gy: int32 = _sq_y(r2) + (SQ - 12) / 2
                pcol: Ptr[uint8] = cast[Ptr[uint8]]("#f7f7f7")   # white
                if pc < 0:
                    pcol = cast[Ptr[uint8]]("#161616")           # black
                hamscene_glyphs_bold(gx, gy, lt, pcol)
            f2 = f2 + 1
        r2 = r2 + 1

    # Board frame.
    hamscene_stroke(BOARD_X, BOARD_Y, SQ * 8, SQ * 8, 2,
                    cast[Ptr[uint8]]("#3a3d4a"))

    # Status line.
    sp: uint64 = 0
    if outcome == 1:
        sp = _put(sp, cast[Ptr[uint8]]("Checkmate - "))
        if winner == 1:
            sp = _put(sp, cast[Ptr[uint8]]("White wins"))
        else:
            sp = _put(sp, cast[Ptr[uint8]]("Black wins"))
    elif outcome == 2:
        sp = _put(sp, cast[Ptr[uint8]]("Stalemate - draw"))
    else:
        if turn == 1:
            sp = _put(sp, cast[Ptr[uint8]]("White to move"))
        else:
            sp = _put(sp, cast[Ptr[uint8]]("Black to move"))
        if hchess_in_check(turn) != 0:
            sp = _put(sp, cast[Ptr[uint8]]("  (check)"))
    sbuf[sp] = 0
    hamscene_glyphs(PAD, STAT_Y, &sbuf[0], cast[Ptr[uint8]]("#cfd3e0"))

    # New-game control button.
    hamscene_panel_button(PAD, CTRL_Y, BTN_W, CTRL_H, 0)
    lbl: Ptr[uint8] = cast[Ptr[uint8]]("New Game")
    lx: int32 = PAD + (BTN_W - cast[int32](_slen(lbl)) * 8) / 2
    ly: int32 = CTRL_Y + (CTRL_H - 12) / 2
    hamscene_glyphs(lx, ly, lbl, cast[Ptr[uint8]]("#202020"))


# ====================================================================
# INPUT (pure — clicks in, state mutations out)
# ====================================================================
# PUBLIC: handle a click at board pixel (lx,ly). Selects a piece of the side to
# move, or moves the selected piece to a legal destination. Returns 1 if the
# board state changed (a move was applied), else 0.
def hchess_click(lx: int64, ly: int64) -> int32:
    # New-game button first.
    if hchess_btn_at(lx, ly) == 0:
        hchess_reset()
        return 1
    sq: int32 = hchess_sq_at(lx, ly)
    if sq < 0:
        return 0
    if sel >= 0:
        # A click on a legal destination applies the move.
        i: int32 = 0
        while i < legal_n:
            if legal_sq[cast[uint64](i)] == sq:
                r: int32 = hchess_try_move(sel, sq)
                return r
            i = i + 1
        # Otherwise: reselect if it's the mover's own piece, else deselect.
        pc: int32 = board[cast[uint64](sq)]
        if pc != 0 and _sign(pc) == turn:
            sel = sq
            legal_n = _legal_from(sq, &legal_sq[0])
        else:
            sel = -1
            legal_n = 0
        return 0
    # No selection yet: select a piece of the side to move.
    pc2: int32 = board[cast[uint64](sq)]
    if pc2 != 0 and _sign(pc2) == turn:
        sel = sq
        legal_n = _legal_from(sq, &legal_sq[0])
    return 0


# PUBLIC: set the selection + its legal moves (used by the native pointer path
# and by tests to drive the highlight without a full click round-trip).
def hchess_select(sq: int32):
    if sq < 0 or sq > 63:
        sel = -1
        legal_n = 0
        return
    pc: int32 = board[cast[uint64](sq)]
    if pc != 0 and _sign(pc) == turn:
        sel = sq
        legal_n = _legal_from(sq, &legal_sq[0])
    else:
        sel = -1
        legal_n = 0


# PUBLIC: parse "m <x> <y> <buttons> ..." -> 1 + fills bx/by/bbtn; else 0.
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:            # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc2: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc2 = acc2 * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc2 = 0 - acc2
        vals[v] = acc2
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1


# PUBLIC: parse one "<type> <code>" key line; 'n'/'N' press starts a new game.
def hchess_key_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 100:            # 'd' = press
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    code: int32 = 0
    got: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        code = code * 10 + cast[int32](s[i]) - 48
        i = i + 1
        got = 1
    if got == 0:
        return 0
    if code == 110 or code == 78:       # n/N -> new game
        hchess_reset()
        return 1
    return 0

def mp3t_ht(i: int32) -> uint32:
    return cast[uint32](g_ht[i])


def mp3t_dtbl(i: int32) -> float64:
    return g_dtbl[i]


def mp3t_cs(i: int32) -> float64:
    return g_cs[i]


def mp3t_ca(i: int32) -> float64:
    return g_ca[i]


def mp3t_hoff(t: int32) -> int32:
    return g_hoff[t]


def mp3t_htl(t: int32) -> int32:
    return g_htl[t]


def mp3t_hlin(t: int32) -> int32:
    return g_hlin[t]


def mp3t_sfbl(sf: int32, i: int32) -> int32:
    return g_sfbl[sf][i]


def mp3t_sfbs(sf: int32, i: int32) -> int32:
    return g_sfbs[sf][i]


def mp3t_slen1(c: int32) -> int32:
    return g_slen1[c]


def mp3t_slen2(c: int32) -> int32:
    return g_slen2[c]


def mp3t_bitrate(i: int32) -> int32:
    return g_bitrate[i]


def mp3t_samprate(i: int32) -> int32:
    return g_samprate[i]


def mp3t_pretab(i: int32) -> int32:
    return g_pretab[i]

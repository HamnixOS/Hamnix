# lib/hamgamechess.ad — "Chess", a hamGame board game (target-agnostic).
#
# The pygame-shaped sibling of lib/hamgamesnake.ad ("Snake") and Coin Dash: ALL
# drawing goes through the PUBLIC lib/hamgame.ad Surface API (fill / fill_rect /
# draw_rect / draw_text) plus the embedded 8x16 font (lib/hamfont.ad) for the
# piece glyphs and the rank/file labels, so this SAME file drives BOTH the device
# app (user/hamgamechess.ad) and the host render gate (user/hamgamechess_host.ad).
# It is extern-free and holds NO transport of its own — it never touches a window,
# a clock or a file.
#
# THE GAME: a full 8x8 chess board in the standard start position, alternating
# light/dark squares, rank (8..1) and file (a..h) labels, and a HUD line naming
# the side to move. Pieces are drawn as LETTER GLYPHS — uppercase for White
# (K Q R B N P) and lowercase for Black (k q r b n p) — so every piece TYPE and
# COLOUR is visually distinguishable (and pixel-assertable) at a glance.
#
# THE ENGINE: chess_move(from_sq, to_sq) is a DETERMINISTIC entry (no clock, no
# random) the host gate drives headless. It generates and validates PSEUDO-LEGAL
# moves for all six piece types — pawn (single + two-square first push + diagonal
# capture), knight (L), bishop / rook / queen (sliding with blocking), king (one
# square) — enforces turn alternation and same-colour blocking, and performs
# ordinary moves + captures. An illegal move is rejected and leaves the board and
# the side-to-move unchanged.
#
# SCOPE (honest): moves are PSEUDO-LEGAL. Self-check filtering, check / checkmate
# / stalemate detection, castling, en-passant and pawn promotion are DEFERRED
# (out of scope for this drop) — a legal-move + capture + turn engine is the bar.
#
# SQUARE ENCODING: a square is row*8 + col, row 0 = the TOP of the screen (Black's
# back rank, rank 8), row 7 = the BOTTOM (White's back rank, rank 1); col 0 = file
# 'a' on the left. So e2 = row 6, col 4 = square 52; e4 = row 4, col 4 = 36.
#
# PIECE CODES: 0 = empty; White pieces are POSITIVE, Black NEGATIVE, with
# magnitude 1=Pawn 2=Knight 3=Bishop 4=Rook 5=Queen 6=King.

from lib.hamgame import game_rgb, game_display_new, \
    game_surface_fill, game_surface_fill_rect, game_surface_draw_rect, \
    game_surface_draw_text, game_surface_set_pixel
from lib.hamfont import hamfont_init, hamfont_glyph_row, \
    HAMFONT_GLYPH_W, HAMFONT_GLYPH_H


# ---- board geometry ------------------------------------------------------
CH_CELL: int32 = 24                                      # square size (px)
CH_N: int32 = 8                                          # 8x8 board
CH_HUD: int32 = 24                                       # top HUD strip (px)
CH_MARGIN: int32 = 16                                    # left rank-label margin
CH_BOTTOM: int32 = 16                                    # bottom file-label margin


# ---- world state ---------------------------------------------------------
ch_w: int32 = 0
ch_h: int32 = 0
ch_display: int32 = -1

ch_board: Array[64, int32]                               # row*8+col -> piece code
ch_turn: int32 = 0                                       # 0 = White, 1 = Black
ch_last_from: int32 = -1
ch_last_to: int32 = -1


# ---- small helpers -------------------------------------------------------
def _ch_abs(v: int32) -> int32:
    if v < 0:
        return 0 - v
    return v


def _ch_sign(v: int32) -> int32:
    if v > 0:
        return 1
    if v < 0:
        return 0 - 1
    return 0


# Colour of a piece code: 0 = White, 1 = Black, -1 = empty square.
def _ch_color(p: int32) -> int32:
    if p > 0:
        return 0
    if p < 0:
        return 1
    return 0 - 1


# ---- board setup ---------------------------------------------------------
# Fill the standard start position. Row 0 = Black back rank, row 7 = White back.
def _ch_setup():
    i: int32 = 0
    while i < 64:
        ch_board[i] = 0
        i = i + 1
    # back-rank order: R N B Q K B N R
    back: Array[8, int32]
    back[0] = 4
    back[1] = 2
    back[2] = 3
    back[3] = 5
    back[4] = 6
    back[5] = 3
    back[6] = 2
    back[7] = 4
    c: int32 = 0
    while c < 8:
        ch_board[0 * 8 + c] = 0 - back[c]                # Black back rank
        ch_board[1 * 8 + c] = 0 - 1                      # Black pawns
        ch_board[6 * 8 + c] = 1                          # White pawns
        ch_board[7 * 8 + c] = back[c]                    # White back rank
        c = c + 1


# Initialise a fresh game: allocate the display Surface and set the start
# position with White to move.
def ch_init(w: int32, h: int32):
    ch_w = w
    ch_h = h
    ch_display = game_display_new(w, h)
    ch_turn = 0
    ch_last_from = -1
    ch_last_to = -1
    _ch_setup()


# Re-allocate ONLY the display Surface (after a hamGame game_reset rewound the
# surface arena) WITHOUT disturbing the board or side-to-move. Lets the host gate
# render several frames with a fresh surface-slot budget each time.
def ch_reattach_display():
    ch_display = game_display_new(ch_w, ch_h)


# ---- move generation (pseudo-legal) --------------------------------------
# Is the straight/diagonal path between (fr,fc) and (tr,tc) — exclusive of both
# endpoints — free of pieces? Caller guarantees a rook/bishop/queen line.
def _ch_path_clear(fr: int32, fc: int32, tr: int32, tc: int32) -> int32:
    sr: int32 = _ch_sign(tr - fr)
    sc: int32 = _ch_sign(tc - fc)
    r: int32 = fr + sr
    c: int32 = fc + sc
    while r != tr or c != tc:
        if ch_board[r * 8 + c] != 0:
            return 0
        r = r + sr
        c = c + sc
    return 1


# Pseudo-legal test for the side to move: is `to` a valid destination for the
# piece on `from`? Enforces piece geometry, sliding blockers and same-colour
# blocking, but does NOT filter moves that leave one's own king in check.
def _ch_pseudo(frm: int32, to: int32) -> int32:
    if frm < 0 or frm >= 64 or to < 0 or to >= 64 or frm == to:
        return 0
    p: int32 = ch_board[frm]
    if p == 0:
        return 0
    if _ch_color(p) != ch_turn:
        return 0
    tp: int32 = ch_board[to]
    if tp != 0 and _ch_color(tp) == _ch_color(p):
        return 0                                         # cannot capture own piece
    kind: int32 = _ch_abs(p)
    fr: int32 = frm / 8
    fc: int32 = frm % 8
    tr: int32 = to / 8
    tc: int32 = to % 8
    dr: int32 = tr - fr
    dc: int32 = tc - fc
    adr: int32 = _ch_abs(dr)
    adc: int32 = _ch_abs(dc)

    if kind == 1:                                        # pawn
        fwd: int32 = 0 - 1                               # White marches up (row--)
        start: int32 = 6
        if _ch_color(p) == 1:                            # Black marches down
            fwd = 1
            start = 1
        # single push onto an empty square
        if dc == 0 and dr == fwd and tp == 0:
            return 1
        # two-square first push over two empty squares
        if dc == 0 and dr == fwd + fwd and fr == start and tp == 0 and \
                ch_board[(fr + fwd) * 8 + fc] == 0:
            return 1
        # diagonal capture of an enemy piece
        if adc == 1 and dr == fwd and tp != 0:
            return 1
        return 0

    if kind == 2:                                        # knight
        if (adr == 1 and adc == 2) or (adr == 2 and adc == 1):
            return 1
        return 0

    if kind == 3:                                        # bishop
        if adr == adc and adr != 0 and _ch_path_clear(fr, fc, tr, tc) == 1:
            return 1
        return 0

    if kind == 4:                                        # rook
        if (dr == 0 or dc == 0) and _ch_path_clear(fr, fc, tr, tc) == 1:
            return 1
        return 0

    if kind == 5:                                        # queen
        if (adr == adc or dr == 0 or dc == 0) and \
                _ch_path_clear(fr, fc, tr, tc) == 1:
            return 1
        return 0

    if kind == 6:                                        # king
        if adr <= 1 and adc <= 1:
            return 1
        return 0

    return 0


# Deterministic move entry the host gate drives. Applies `from`->`to` (moving the
# piece, capturing any enemy occupant) and flips the side to move IFF the move is
# pseudo-legal; returns 1 on success. An illegal move returns 0 and changes
# NOTHING (board + turn preserved).
def chess_move(frm: int32, to: int32) -> int32:
    if _ch_pseudo(frm, to) == 0:
        return 0
    ch_board[to] = ch_board[frm]
    ch_board[frm] = 0
    ch_last_from = frm
    ch_last_to = to
    ch_turn = 1 - ch_turn
    return 1


# ---- glyph blit (direct hamfont raster into the Surface) -----------------
# Draw one ASCII glyph at (x,y) straight into `surf` from the embedded 8x16 font,
# with NO intermediate text Surface — so drawing 32 pieces + 16 labels per frame
# never exhausts hamGame's 16-slot surface table (game_surface_draw_text allocates
# one Surface per call). Only lit glyph pixels are written; the square shows
# through the gaps.
def _ch_blit_glyph(surf: int32, ch: uint8, x: int32, y: int32, color: uint32):
    hamfont_init()
    gw: int32 = HAMFONT_GLYPH_W
    gh: int32 = HAMFONT_GLYPH_H
    row: uint64 = 0
    while row < cast[uint64](gh):
        bits: uint8 = hamfont_glyph_row(ch, row)
        col: int32 = 0
        while col < gw:
            mask: uint8 = cast[uint8](128 >> cast[uint32](col))
            if (bits & mask) != 0:
                game_surface_set_pixel(surf, x + col,
                                       y + cast[int32](row), color)
            col = col + 1
        row = row + 1


# Uppercase (White) / lowercase (Black) letter for a piece code.
def _ch_piece_glyph(p: int32) -> uint8:
    kind: int32 = _ch_abs(p)
    base: int32 = 32
    if kind == 1:
        base = 80                                        # 'P'
    elif kind == 2:
        base = 78                                        # 'N'
    elif kind == 3:
        base = 66                                        # 'B'
    elif kind == 4:
        base = 82                                        # 'R'
    elif kind == 5:
        base = 81                                        # 'Q'
    elif kind == 6:
        base = 75                                        # 'K'
    else:
        return 32
    if p < 0:
        base = base + 32                                 # lowercase for Black
    return cast[uint8](base)


# ---- board -> pixel mapping ----------------------------------------------
def ch_cell_px_x(col: int32) -> int32:
    return CH_MARGIN + col * CH_CELL


def ch_cell_px_y(row: int32) -> int32:
    return CH_HUD + row * CH_CELL


# ---- render onto the display backbuffer ----------------------------------
# Compose the frame: backdrop, HUD strip + side-to-move text, the 8x8 board of
# alternating squares, rank/file labels, then every piece as a letter glyph
# (White = bright letters, Black = near-black letters — distinct in both hue and
# case, and both readable on either square colour).
def ch_render():
    game_surface_fill(ch_display, game_rgb(30, 30, 38))

    light: uint32 = game_rgb(222, 210, 180)
    dark: uint32 = game_rgb(140, 110, 80)
    white_pc: uint32 = game_rgb(245, 245, 245)
    black_pc: uint32 = game_rgb(25, 25, 25)
    label_col: uint32 = game_rgb(200, 200, 210)

    # squares + pieces
    row: int32 = 0
    while row < CH_N:
        col: int32 = 0
        while col < CH_N:
            sx: int32 = ch_cell_px_x(col)
            sy: int32 = ch_cell_px_y(row)
            sq_col: uint32 = dark
            if (row + col) % 2 == 0:
                sq_col = light
            game_surface_fill_rect(ch_display, sx, sy, CH_CELL, CH_CELL, sq_col)
            p: int32 = ch_board[row * 8 + col]
            if p != 0:
                gc: uint32 = white_pc
                if p < 0:
                    gc = black_pc
                # centre the 8x16 glyph in the 24x24 square
                _ch_blit_glyph(ch_display, _ch_piece_glyph(p),
                               sx + (CH_CELL - HAMFONT_GLYPH_W) / 2,
                               sy + (CH_CELL - HAMFONT_GLYPH_H) / 2, gc)
            col = col + 1
        row = row + 1

    # board outline
    game_surface_draw_rect(ch_display, CH_MARGIN, CH_HUD, CH_N * CH_CELL,
                           CH_N * CH_CELL, game_rgb(70, 60, 50))

    # rank labels (8..1) down the left margin
    rr: int32 = 0
    while rr < CH_N:
        _ch_blit_glyph(ch_display, cast[uint8](56 - rr), 4,
                       ch_cell_px_y(rr) + (CH_CELL - HAMFONT_GLYPH_H) / 2,
                       label_col)
        rr = rr + 1

    # file labels (a..h) along the bottom margin
    fc: int32 = 0
    while fc < CH_N:
        _ch_blit_glyph(ch_display, cast[uint8](97 + fc),
                       ch_cell_px_x(fc) + (CH_CELL - HAMFONT_GLYPH_W) / 2,
                       CH_HUD + CH_N * CH_CELL, label_col)
        fc = fc + 1

    # HUD strip + side-to-move (via game_surface_draw_text, exercising the font
    # Surface path like the other hamGame titles)
    game_surface_fill_rect(ch_display, 0, 0, ch_w, CH_HUD, game_rgb(28, 32, 48))
    game_surface_draw_rect(ch_display, 0, 0, ch_w, ch_h, game_rgb(70, 84, 120))
    if ch_turn == 0:
        game_surface_draw_text(ch_display,
                               cast[Ptr[uint8]]("White to move"), 6, 4,
                               game_rgb(235, 235, 235))
    else:
        game_surface_draw_text(ch_display,
                               cast[Ptr[uint8]]("Black to move"), 6, 4,
                               game_rgb(235, 235, 235))


# ---- accessors (drivers + the host gate read these) ----------------------
def ch_display_surf() -> int32:
    return ch_display


def chess_piece_at(sq: int32) -> int32:
    if sq < 0 or sq >= 64:
        return 0
    return ch_board[sq]


def chess_turn() -> int32:
    return ch_turn


def chess_last_from() -> int32:
    return ch_last_from


def chess_last_to() -> int32:
    return ch_last_to


# Count pieces of a colour (0 = White, 1 = Black) still on the board.
def chess_piece_count(color: int32) -> int32:
    n: int32 = 0
    i: int32 = 0
    while i < 64:
        if ch_board[i] != 0 and _ch_color(ch_board[i]) == color:
            n = n + 1
        i = i + 1
    return n

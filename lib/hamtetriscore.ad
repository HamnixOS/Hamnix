# lib/hamtetriscore.ad — the PURE, target-agnostic core of the Tetris scene app.
#
# WHY (dual-target seam, see docs/hamui_dual_target.md)
# =====================================================
# This is the Tetris game STATE MACHINE (10x20 well / the 7 tetrominoes /
# spawn / rotate-with-wall-kick / gravity / lock / line-clear + scoring /
# level+speed / game-over-when-spawn-blocked / LCG piece bag), its scene
# DISPLAY-LIST builder, and its pure INPUT handlers — everything about the app
# EXCEPT the Hamnix-only window transport (newwindow, /dev/wsys/<wid>/{scene,
# keys,event}). Factored out exactly the way lib/hamsnakecore.ad was factored
# out of the Snake app, so the SAME code drives two sinks:
#   * user/hamtetrisscene.ad       — NATIVE: httetris_build_scene() +
#                                     hamscene_commit(wid) to /dev/wsys, with a
#                                     jiffy-paced gravity tick.
#   * user/hamtetrisscene_host.ad  — HOST: httetris_build_scene() then the
#                                     lib/hamui_host.ad rasterizer -> PPM/PNG,
#                                     driven by scripted input + explicit ticks.
# It imports ONLY lib/hamscene.ad (the pure builder), has NO `extern`, and so
# links into both the x86_64-adder-user (native) and x86_64-linux (host)
# targets. NOTE: module-scope MUTABLE state uses a `g_` prefix — these are
# PUBLIC (global across merged modules), so they must not collide with names in
# lib/hamui.ad (e.g. `cur_x`); the game logic is reached only via the
# httetris_* functions below.

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_stroke, \
    hamscene_panel_button


# ---- tiny pure helpers ---------------------------------------------------
def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# ====================================================================
# GAME STATE (module scope — no malloc, fixed arrays only)
# ====================================================================
WELL_W: int32 = 10
WELL_H: int32 = 20
NCELLS: int32 = 200                    # WELL_W * WELL_H

# The playfield. 0 == empty, else 1..7 == (piece index + 1), so a locked cell
# remembers the colour of the tetromino that filled it.
g_board: Array[200, int32]

# The falling piece: which tetromino (0..6), its rotation (0..3) and the
# top-left origin of its 4x4 bounding box in well coordinates.
g_piece: int32 = 0
g_rot:   int32 = 0
g_ox:    int32 = 3
g_oy:    int32 = 0
g_next:  int32 = 0

g_score: int32 = 0
g_lines: int32 = 0
g_level: int32 = 0
g_over:  int32 = 0

g_rng: uint64 = 0x9E3779B97F4A7C15


# The 7 tetrominoes, each as 4 rotation states, each state a 16-bit occupancy
# mask over a 4x4 box (bit r*4+c set == cell (col c,row r) filled). Order:
# 0=I 1=O 2=T 3=S 4=Z 5=J 6=L. Filled lazily (Adder has no array literals).
PIECE_MASK: Array[28, int32]
_pieces_ready: int32 = 0


def _init_pieces():
    if _pieces_ready != 0:
        return
    # I
    PIECE_MASK[0] = 240
    PIECE_MASK[1] = 17476
    PIECE_MASK[2] = 3840
    PIECE_MASK[3] = 8738
    # O
    PIECE_MASK[4] = 102
    PIECE_MASK[5] = 102
    PIECE_MASK[6] = 102
    PIECE_MASK[7] = 102
    # T
    PIECE_MASK[8] = 114
    PIECE_MASK[9] = 610
    PIECE_MASK[10] = 624
    PIECE_MASK[11] = 562
    # S
    PIECE_MASK[12] = 54
    PIECE_MASK[13] = 1122
    PIECE_MASK[14] = 864
    PIECE_MASK[15] = 561
    # Z
    PIECE_MASK[16] = 99
    PIECE_MASK[17] = 612
    PIECE_MASK[18] = 1584
    PIECE_MASK[19] = 306
    # J
    PIECE_MASK[20] = 113
    PIECE_MASK[21] = 550
    PIECE_MASK[22] = 1136
    PIECE_MASK[23] = 802
    # L
    PIECE_MASK[24] = 116
    PIECE_MASK[25] = 1570
    PIECE_MASK[26] = 368
    PIECE_MASK[27] = 547
    _pieces_ready = 1


def _mask(piece: int32, rot: int32) -> int32:
    _init_pieces()
    return PIECE_MASK[cast[uint64](piece * 4 + rot)]


def _t_rand() -> uint32:
    g_rng = g_rng * 6364136223846793005 + 1442695040888963407
    return cast[uint32](g_rng >> 33)


def _bidx(x: int32, y: int32) -> uint64:
    return cast[uint64](y * WELL_W + x)


# Colour string for a piece index (0..6).
def _piece_color(p: int32) -> Ptr[uint8]:
    if p == 0:
        c0: Ptr[uint8] = "#23d6d6"                     # I cyan
        return c0
    if p == 1:
        c1: Ptr[uint8] = "#e6c72a"                     # O yellow
        return c1
    if p == 2:
        c2: Ptr[uint8] = "#a24bd6"                     # T purple
        return c2
    if p == 3:
        c3: Ptr[uint8] = "#3ac35a"                     # S green
        return c3
    if p == 4:
        c4: Ptr[uint8] = "#ff5252"                     # Z red
        return c4
    if p == 5:
        c5: Ptr[uint8] = "#4b7bd6"                     # J blue
        return c5
    c6: Ptr[uint8] = "#e0862a"                         # L orange
    return c6


# 1 iff placing `piece` at rotation `rot` with box origin (ox,oy) would leave
# the well, overlap a locked cell, or hit the floor. Cells above the top
# (y < 0) are allowed so a piece can spawn/rotate partly off-screen.
def _collides(piece: int32, rot: int32, ox: int32, oy: int32) -> int32:
    m: uint32 = cast[uint32](_mask(piece, rot))
    bit: int32 = 0
    while bit < 16:
        if ((m >> cast[uint32](bit)) & 1) == 1:
            c: int32 = bit % 4
            r: int32 = bit / 4
            x: int32 = ox + c
            y: int32 = oy + r
            if x < 0 or x >= WELL_W or y >= WELL_H:
                return 1
            if y >= 0:
                if g_board[_bidx(x, y)] != 0:
                    return 1
        bit = bit + 1
    return 0


# Stamp the current piece into the board (locked). Cells inside the well are
# written; anything above the top is dropped (a fully-off-top lock ends the
# game via the next blocked spawn).
def _lock_piece():
    m: uint32 = cast[uint32](_mask(g_piece, g_rot))
    bit: int32 = 0
    while bit < 16:
        if ((m >> cast[uint32](bit)) & 1) == 1:
            c: int32 = bit % 4
            r: int32 = bit / 4
            x: int32 = g_ox + c
            y: int32 = g_oy + r
            if y >= 0 and y < WELL_H and x >= 0 and x < WELL_W:
                g_board[_bidx(x, y)] = g_piece + 1
        bit = bit + 1


# Remove every full row, shifting the rows above down. Returns the count.
def _clear_lines() -> int32:
    cleared: int32 = 0
    r: int32 = WELL_H - 1
    while r >= 0:
        full: int32 = 1
        c: int32 = 0
        while c < WELL_W:
            if g_board[_bidx(c, r)] == 0:
                full = 0
            c = c + 1
        if full != 0:
            rr: int32 = r
            while rr > 0:
                cc: int32 = 0
                while cc < WELL_W:
                    g_board[_bidx(cc, rr)] = g_board[_bidx(cc, rr - 1)]
                    cc = cc + 1
                rr = rr - 1
            cc2: int32 = 0
            while cc2 < WELL_W:
                g_board[_bidx(cc2, 0)] = 0
                cc2 = cc2 + 1
            cleared = cleared + 1
            # Re-check this same row index (rows shifted into it).
        else:
            r = r - 1
    return cleared


# Award points for `n` cleared rows (classic Nintendo table, scaled by level),
# bump the total line count, and recompute the level (one per 10 lines).
def _score_lines(n: int32):
    if n <= 0:
        return
    base: int32 = 0
    if n == 1:
        base = 40
    elif n == 2:
        base = 100
    elif n == 3:
        base = 300
    else:
        base = 1200
    g_score = g_score + base * (g_level + 1)
    g_lines = g_lines + n
    g_level = g_lines / 10


# Bring the queued piece into play at the top; if it cannot fit, game over.
def _spawn():
    g_piece = g_next
    g_next = cast[int32](_t_rand() % 7)
    g_rot = 0
    g_ox = 3
    g_oy = 0
    if _collides(g_piece, g_rot, g_ox, g_oy) != 0:
        g_over = 1


# Lock -> clear+score -> spawn the next piece. Shared by gravity/soft/hard drop.
def _lock_and_next():
    _lock_piece()
    n: int32 = _clear_lines()
    _score_lines(n)
    _spawn()


# PUBLIC: reset to a fresh game (empty well, score 0, first piece spawned).
def httetris_reset():
    i: int32 = 0
    while i < NCELLS:
        g_board[cast[uint64](i)] = 0
        i = i + 1
    g_score = 0
    g_lines = 0
    g_level = 0
    g_over = 0
    g_next = cast[int32](_t_rand() % 7)
    _spawn()


# PUBLIC: seed the LCG (host tests pass a fixed seed for determinism).
def httetris_seed(s: uint64):
    if s != 0:
        g_rng = g_rng ^ s


# PUBLIC: shift the falling piece by dx (usually +/-1). Returns 1 if it moved.
def httetris_move(dx: int32) -> int32:
    if g_over != 0:
        return 0
    if _collides(g_piece, g_rot, g_ox + dx, g_oy) == 0:
        g_ox = g_ox + dx
        return 1
    return 0


# PUBLIC: rotate clockwise, trying simple wall kicks (0, +/-1, +/-2 columns).
# Returns 1 if a kick placement was accepted.
def httetris_rotate() -> int32:
    if g_over != 0:
        return 0
    nr: int32 = (g_rot + 1) % 4
    kicks: Array[5, int32]
    kicks[0] = 0
    kicks[1] = 1
    kicks[2] = -1
    kicks[3] = 2
    kicks[4] = -2
    k: int32 = 0
    while k < 5:
        kx: int32 = kicks[cast[uint64](k)]
        if _collides(g_piece, nr, g_ox + kx, g_oy) == 0:
            g_rot = nr
            g_ox = g_ox + kx
            return 1
        k = k + 1
    return 0


# PUBLIC: one gravity step — drop a row, or lock + spawn if grounded. Returns
# 1 if the board changed (always, while the game is live).
def httetris_tick() -> int32:
    if g_over != 0:
        return 0
    if _collides(g_piece, g_rot, g_ox, g_oy + 1) == 0:
        g_oy = g_oy + 1
        return 1
    _lock_and_next()
    return 1


# PUBLIC: soft drop — identical to a gravity tick (drop one, else lock).
def httetris_softdrop() -> int32:
    return httetris_tick()


# PUBLIC: hard drop — fall to the floor and lock immediately. Returns rows
# fallen (>= 0).
def httetris_harddrop() -> int32:
    if g_over != 0:
        return 0
    n: int32 = 0
    while _collides(g_piece, g_rot, g_ox, g_oy + 1) == 0:
        g_oy = g_oy + 1
        n = n + 1
    _lock_and_next()
    return n


# PUBLIC state getters (for host-test assertions).
def httetris_score() -> int32:
    return g_score


def httetris_lines() -> int32:
    return g_lines


def httetris_level() -> int32:
    return g_level


def httetris_gameover() -> int32:
    return g_over


def httetris_cur_piece() -> int32:
    return g_piece


def httetris_cur_rot() -> int32:
    return g_rot


def httetris_cur_x() -> int32:
    return g_ox


def httetris_cur_y() -> int32:
    return g_oy


# Locked-cell value at (x,y): 0 empty, else piece index + 1.
def httetris_cell(x: int32, y: int32) -> int32:
    if x < 0 or x >= WELL_W or y < 0 or y >= WELL_H:
        return 0
    return g_board[_bidx(x, y)]


# ---- host-test helpers: deterministic setup ------------------------------
def httetris_test_setcell(x: int32, y: int32, v: int32):
    if x >= 0 and x < WELL_W and y >= 0 and y < WELL_H:
        g_board[_bidx(x, y)] = v


def httetris_test_setpiece(p: int32, rot: int32, x: int32, y: int32):
    g_piece = p
    g_rot = rot
    g_ox = x
    g_oy = y


# Force a spawn (queued piece into play). Returns the game-over flag so a gate
# can assert "spawn into a blocked top ends the game".
def httetris_test_spawn() -> int32:
    _spawn()
    return g_over


# Directly clear full rows (no scoring). Returns rows cleared.
def httetris_test_clear() -> int32:
    return _clear_lines()


# ====================================================================
# LAYOUT (fixed 360x470 window, matching the Snake/2048 footprint)
# ====================================================================
GAME_W: int32 = 360
GAME_H: int32 = 470

CELL:    int32 = 18
BOARD_X: int32 = 90               # (360 - 10*18) / 2
BOARD_Y: int32 = 56
HDR_Y:   int32 = 14
CTRL_H:  int32 = 30
CTRL_Y:  int32 = 430
PAD:     int32 = 12
GAP:     int32 = 10
BTN_W:   int32 = 62


def _cell_x(c: int32) -> int32:
    return BOARD_X + c * CELL


def _cell_y(r: int32) -> int32:
    return BOARD_Y + r * CELL


def _btn_x(i: int32) -> int32:
    return PAD + i * (BTN_W + GAP)


# PUBLIC: which control button is at (lx,ly), or -1 (0=New 1=Left 2=Rotate
# 3=Right 4=Drop).
def httetris_btn_at(lx: int64, ly: int64) -> int64:
    if ly < cast[int64](CTRL_Y) or ly >= cast[int64](CTRL_Y + CTRL_H):
        return -1
    i: int32 = 0
    while i < 5:
        bx: int64 = cast[int64](_btn_x(i))
        if lx >= bx and lx < bx + cast[int64](BTN_W):
            return cast[int64](i)
        i = i + 1
    return -1


# ====================================================================
# RENDER
# ====================================================================
sbuf: Array[64, uint8]


def _put(pos: uint64, s: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while s[i] != 0:
        sbuf[pos] = s[i]
        pos = pos + 1
        i = i + 1
    return pos


def _draw_controls():
    i: int32 = 0
    while i < 5:
        bx: int32 = _btn_x(i)
        hamscene_panel_button(bx, CTRL_Y, BTN_W, CTRL_H, 0)
        lbl: Ptr[uint8] = cast[Ptr[uint8]]("New")
        if i == 1:
            lbl = cast[Ptr[uint8]]("Left")
        elif i == 2:
            lbl = cast[Ptr[uint8]]("Rot")
        elif i == 3:
            lbl = cast[Ptr[uint8]]("Right")
        elif i == 4:
            lbl = cast[Ptr[uint8]]("Drop")
        lx: int32 = bx + (BTN_W - cast[int32](_slen(lbl)) * 8) / 2
        ly: int32 = CTRL_Y + (CTRL_H - 12) / 2
        hamscene_glyphs(lx, ly, lbl, cast[Ptr[uint8]]("#202020"))
        i = i + 1


# Draw one well cell (filled, inset by 1px) at grid (c,r) in colour `col`.
def _draw_block(c: int32, r: int32, col: Ptr[uint8]):
    px: int32 = _cell_x(c)
    py: int32 = _cell_y(r)
    hamscene_fill(px + 1, py + 1, CELL - 2, CELL - 2, col)


# PUBLIC: build the whole display list into the shared hamscene buffer. Does
# NOT commit. BOUNDED: one backdrop + one well panel + <=200 locked cells + 4
# current-piece cells + the header + 5 buttons, so per-frame work never grows
# with the number of pieces played.
def httetris_build_scene():
    hamscene_begin()
    hamscene_fill(0, 0, GAME_W, GAME_H, cast[Ptr[uint8]]("#1b1b2e"))

    # Header: title + live score / level readout.
    hamscene_glyphs_bold(PAD, HDR_Y, cast[Ptr[uint8]]("Tetris"),
                         cast[Ptr[uint8]]("#e8e8f0"))
    sp: uint64 = 0
    sp = _put(sp, cast[Ptr[uint8]]("Score "))
    sp = sp + _u64_to_dec(cast[uint64](g_score), &sbuf[sp])
    sp = _put(sp, cast[Ptr[uint8]]("  Lv "))
    sp = sp + _u64_to_dec(cast[uint64](g_level), &sbuf[sp])
    sbuf[sp] = 0
    hamscene_glyphs(PAD + 78, HDR_Y + 2, &sbuf[0], cast[Ptr[uint8]]("#9aa0c0"))

    # Well backing panel + frame.
    bw: int32 = WELL_W * CELL
    bh: int32 = WELL_H * CELL
    hamscene_fill(BOARD_X, BOARD_Y, bw, bh, cast[Ptr[uint8]]("#101024"))
    hamscene_stroke(BOARD_X, BOARD_Y, bw, bh, 1, cast[Ptr[uint8]]("#33345a"))

    # Locked cells.
    y: int32 = 0
    while y < WELL_H:
        x: int32 = 0
        while x < WELL_W:
            v: int32 = g_board[_bidx(x, y)]
            if v != 0:
                _draw_block(x, y, _piece_color(v - 1))
            x = x + 1
        y = y + 1

    # The falling piece on top.
    m: uint32 = cast[uint32](_mask(g_piece, g_rot))
    pcol: Ptr[uint8] = _piece_color(g_piece)
    if g_over != 0:
        pcol = cast[Ptr[uint8]]("#c0c0c0")             # dim on death
    bit: int32 = 0
    while bit < 16:
        if ((m >> cast[uint32](bit)) & 1) == 1:
            c2: int32 = g_ox + (bit % 4)
            r2: int32 = g_oy + (bit / 4)
            if r2 >= 0 and r2 < WELL_H and c2 >= 0 and c2 < WELL_W:
                _draw_block(c2, r2, pcol)
        bit = bit + 1

    _draw_controls()


# PUBLIC: draw the GAME OVER overlay on TOP of an already-built scene. No-op
# unless the game is over, so the ordinary per-frame render is unchanged.
def httetris_draw_overlay():
    if g_over == 0:
        return
    bw: int32 = WELL_W * CELL
    bh: int32 = WELL_H * CELL
    ov_w: int32 = bw + 20
    ov_h: int32 = 100
    ov_x: int32 = BOARD_X + (bw - ov_w) / 2
    ov_y: int32 = BOARD_Y + (bh - ov_h) / 2

    hamscene_fill(ov_x, ov_y, ov_w, ov_h, cast[Ptr[uint8]]("#2b2b4a"))
    hamscene_stroke(ov_x, ov_y, ov_w, ov_h, 3, cast[Ptr[uint8]]("#ff5252"))

    cx: int32 = ov_x + ov_w / 2
    title: Ptr[uint8] = cast[Ptr[uint8]]("GAME OVER")
    tx: int32 = cx - cast[int32](_slen(title)) * 4
    hamscene_glyphs_bold(tx, ov_y + 28, title, cast[Ptr[uint8]]("#ff6b6b"))
    l1: Ptr[uint8] = cast[Ptr[uint8]]("Press New to retry")
    x1: int32 = cx - cast[int32](_slen(l1)) * 4
    hamscene_glyphs(x1, ov_y + 62, l1, cast[Ptr[uint8]]("#e8e8f0"))


# PUBLIC: apply an on-screen control button press by index (0=New 1=Left
# 2=Rotate 3=Right 4=Drop). New resets instantly.
def httetris_ctrl_press(b: int64):
    if b == 0:
        httetris_reset()
    elif b == 1:
        httetris_move(-1)
    elif b == 2:
        httetris_rotate()
    elif b == 3:
        httetris_move(1)
    elif b == 4:
        httetris_harddrop()


# ====================================================================
# INPUT (pure — bytes/lines in, state mutations out)
# ====================================================================
esc_state: int32 = 0


def _key_byte(c: uint8) -> int32:
    if esc_state == 1:
        if c == 91:                     # '['
            esc_state = 2
            return 0
        esc_state = 0
    elif esc_state == 2:
        esc_state = 0
        if c == 65:                     # 'A' up -> rotate
            return httetris_rotate()
        if c == 66:                     # 'B' down -> soft drop
            return httetris_softdrop()
        if c == 67:                     # 'C' right
            return httetris_move(1)
        if c == 68:                     # 'D' left
            return httetris_move(-1)
        return 0
    if c == 27:                         # ESC -> begin arrow sequence
        esc_state = 1
        return 0
    if c == 119 or c == 87:             # w/W up -> rotate
        return httetris_rotate()
    if c == 115 or c == 83:             # s/S down -> soft drop
        return httetris_softdrop()
    if c == 97 or c == 65:              # a/A left
        return httetris_move(-1)
    if c == 100 or c == 68:             # d/D right
        return httetris_move(1)
    if c == 32:                         # space -> hard drop
        httetris_harddrop()
        return 1
    if c == 114 or c == 82 or c == 110 or c == 78:   # r/R/n/N restart
        httetris_reset()
        return 1
    return 0


# PUBLIC: parse one "<type> <code>" key line; on a press ('d'), apply the byte.
def httetris_key_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 100:            # 'd' = press; ignore 'u' release
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    code: int32 = 0
    got: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        code = code * 10 + cast[int32](s[i]) - 48
        i = i + 1
        got = 1
    if got == 0:
        return 0
    if code < 0 or code > 255:
        return 0
    return _key_byte(cast[uint8](code))


# PUBLIC: parse "m <x> <y> <buttons> ..." -> 1 + fills bx/by/bbtn; else 0.
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:            # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc2: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc2 = acc2 * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc2 = 0 - acc2
        vals[v] = acc2
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1

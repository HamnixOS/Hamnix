# lib/hamminescore.ad — the PURE, target-agnostic core of the Minesweeper scene
# app.
#
# WHY (dual-target seam, see docs/hamui_dual_target.md)
# =====================================================
# This is the Minesweeper game STATE MACHINE (9x9 field / 10 mines / LCG mine
# placement / neighbour-count computation / flood-fill reveal of 0-cells / flag
# toggle / first-click-safe / win when every non-mine is uncovered / loss when a
# mine is uncovered), its scene DISPLAY-LIST builder, and its pure INPUT
# handlers — everything about the app EXCEPT the Hamnix-only window transport
# (newwindow, /dev/wsys/<wid>/{scene,keys,event}). Factored out exactly the way
# lib/hamtetriscore.ad / lib/hamsnakecore.ad were, so the SAME code drives two
# sinks:
#   * user/hamminescene.ad       — NATIVE: hammine_build_scene() +
#                                   hamscene_commit(wid) to /dev/wsys.
#   * user/hamminescene_host.ad  — HOST: hammine_build_scene() then the
#                                   lib/hamui_host.ad rasterizer -> PPM/PNG,
#                                   driven by scripted input.
# It imports ONLY lib/hamscene.ad (the pure builder), has NO `extern`, and so
# links into both the x86_64-adder-user (native) and x86_64-linux (host)
# targets. NOTE: module-scope MUTABLE state uses a `g_` prefix — these are
# PUBLIC (global across merged modules), so they must not collide with names in
# lib/hamui.ad (e.g. `cur_x`); the game logic is reached only via the hammine_*
# functions below.

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_stroke, \
    hamscene_panel_button


# ---- tiny pure helpers ---------------------------------------------------
def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# ====================================================================
# GAME STATE (module scope — no malloc, fixed arrays only)
# ====================================================================
BOARD_W: int32 = 9
BOARD_H: int32 = 9
BOARD_N: int32 = 81                     # BOARD_W * BOARD_H
NMINES:  int32 = 10

# 1 iff the cell hides a mine.
g_mine:  Array[81, int32]
# Cell state: 0 == covered, 1 == revealed, 2 == flagged.
g_state: Array[81, int32]
# Number of neighbouring mines (0..8), valid for non-mine cells.
g_count: Array[81, int32]

g_over:     int32 = 0                   # 1 once the game has ended
g_won:      int32 = 0                   # 1 == win, 0 == loss (when g_over)
g_first:    int32 = 1                   # 1 until the very first reveal
g_flags:    int32 = 0                   # count of placed flags
g_revealed: int32 = 0                   # count of revealed cells (incl. mine)
g_flagmode: int32 = 0                   # 1 == pointer clicks flag instead of reveal

g_cx: int32 = 0                         # keyboard cursor
g_cy: int32 = 0

g_rng: uint64 = 0x9E3779B97F4A7C15


def _idx(x: int32, y: int32) -> uint64:
    return cast[uint64](y * BOARD_W + x)


def _m_rand() -> uint32:
    g_rng = g_rng * 6364136223846793005 + 1442695040888963407
    return cast[uint32](g_rng >> 33)


# Recompute every cell's neighbouring-mine count from g_mine.
def _recount():
    y: int32 = 0
    while y < BOARD_H:
        x: int32 = 0
        while x < BOARD_W:
            c: int32 = 0
            dy: int32 = -1
            while dy <= 1:
                dx: int32 = -1
                while dx <= 1:
                    nx: int32 = x + dx
                    ny: int32 = y + dy
                    if dx != 0 or dy != 0:
                        if nx >= 0 and nx < BOARD_W and ny >= 0 and ny < BOARD_H:
                            if g_mine[_idx(nx, ny)] != 0:
                                c = c + 1
                    dx = dx + 1
                dy = dy + 1
            g_count[_idx(x, y)] = c
            x = x + 1
        y = y + 1


# Scatter NMINES distinct mines with the LCG, never on the (avoid_x,avoid_y)
# cell (first-click-safe); avoid_x < 0 disables the exclusion.
def _place_mines(avoid_x: int32, avoid_y: int32):
    i: int32 = 0
    while i < BOARD_N:
        g_mine[cast[uint64](i)] = 0
        i = i + 1
    placed: int32 = 0
    while placed < NMINES:
        r: int32 = cast[int32](_m_rand() % cast[uint32](BOARD_N))
        x: int32 = r % BOARD_W
        y: int32 = r / BOARD_W
        ok: int32 = 0
        if g_mine[_idx(x, y)] == 0:
            ok = 1
            if x == avoid_x and y == avoid_y:
                ok = 0
        if ok != 0:
            g_mine[_idx(x, y)] = 1
            placed = placed + 1
    _recount()


# PUBLIC: reset to a fresh game (all covered, mines scattered, cursor home).
def hammine_reset():
    i: int32 = 0
    while i < BOARD_N:
        g_state[cast[uint64](i)] = 0
        i = i + 1
    g_over = 0
    g_won = 0
    g_first = 1
    g_flags = 0
    g_revealed = 0
    g_cx = 0
    g_cy = 0
    _place_mines(-1, -1)


# PUBLIC: seed the LCG (host tests pass a fixed seed for determinism).
def hammine_seed(s: uint64):
    if s != 0:
        g_rng = g_rng ^ s


# Uncover (x,y). Flood-fills across 0-count cells. A mine ends the game.
def _reveal_cell(x: int32, y: int32):
    if x < 0 or x >= BOARD_W or y < 0 or y >= BOARD_H:
        return
    i: uint64 = _idx(x, y)
    if g_state[i] != 0:                 # already revealed OR flagged
        return
    g_state[i] = 1
    g_revealed = g_revealed + 1
    if g_mine[i] != 0:
        g_over = 1
        g_won = 0
        return
    if g_count[i] == 0:
        dy: int32 = -1
        while dy <= 1:
            dx: int32 = -1
            while dx <= 1:
                if dx != 0 or dy != 0:
                    _reveal_cell(x + dx, y + dy)
                dx = dx + 1
            dy = dy + 1


# Win iff every non-mine cell is revealed.
def _check_win():
    if g_over != 0:
        return
    i: int32 = 0
    while i < BOARD_N:
        if g_mine[cast[uint64](i)] == 0 and g_state[cast[uint64](i)] != 1:
            return
        i = i + 1
    g_over = 1
    g_won = 1


# PUBLIC: uncover cell (x,y). Returns 1 if the board changed.
def hammine_reveal(x: int32, y: int32) -> int32:
    if g_over != 0:
        return 0
    if x < 0 or x >= BOARD_W or y < 0 or y >= BOARD_H:
        return 0
    i: uint64 = _idx(x, y)
    if g_state[i] == 1 or g_state[i] == 2:   # revealed or flagged: no-op
        return 0
    if g_first != 0:                    # first-click-safe: (re)place mines
        _place_mines(x, y)
        g_first = 0
    _reveal_cell(x, y)
    _check_win()
    return 1


# PUBLIC: toggle a flag on cell (x,y). Returns 1 if the board changed.
def hammine_flag(x: int32, y: int32) -> int32:
    if g_over != 0:
        return 0
    if x < 0 or x >= BOARD_W or y < 0 or y >= BOARD_H:
        return 0
    i: uint64 = _idx(x, y)
    if g_state[i] == 1:                 # can't flag an uncovered cell
        return 0
    if g_state[i] == 2:
        g_state[i] = 0
        g_flags = g_flags - 1
    else:
        g_state[i] = 2
        g_flags = g_flags + 1
    return 1


# PUBLIC: move the keyboard cursor by (dx,dy), clamped to the field.
def hammine_cursor_move(dx: int32, dy: int32) -> int32:
    nx: int32 = g_cx + dx
    ny: int32 = g_cy + dy
    if nx < 0:
        nx = 0
    if nx >= BOARD_W:
        nx = BOARD_W - 1
    if ny < 0:
        ny = 0
    if ny >= BOARD_H:
        ny = BOARD_H - 1
    if nx == g_cx and ny == g_cy:
        return 0
    g_cx = nx
    g_cy = ny
    return 1


# PUBLIC state getters (for host-test assertions + the native driver).
def hammine_gameover() -> int32:
    return g_over


def hammine_won() -> int32:
    return g_won


def hammine_mines_left() -> int32:
    return NMINES - g_flags


def hammine_flags() -> int32:
    return g_flags


def hammine_revealed() -> int32:
    return g_revealed


def hammine_flagmode() -> int32:
    return g_flagmode


def hammine_cursor_x() -> int32:
    return g_cx


def hammine_cursor_y() -> int32:
    return g_cy


def hammine_cell_state(x: int32, y: int32) -> int32:
    if x < 0 or x >= BOARD_W or y < 0 or y >= BOARD_H:
        return 0
    return g_state[_idx(x, y)]


def hammine_cell_count(x: int32, y: int32) -> int32:
    if x < 0 or x >= BOARD_W or y < 0 or y >= BOARD_H:
        return 0
    return g_count[_idx(x, y)]


def hammine_cell_mine(x: int32, y: int32) -> int32:
    if x < 0 or x >= BOARD_W or y < 0 or y >= BOARD_H:
        return 0
    return g_mine[_idx(x, y)]


# ---- host-test helpers: deterministic setup ------------------------------
# Fresh EMPTY board: every cell covered, NO mines (unlike hammine_reset, which
# scatters 10). Tests then place mines by hand for a byte-reproducible field.
# Marks the game no-longer-first so reveal won't re-scatter.
def hammine_test_clear():
    i: int32 = 0
    while i < BOARD_N:
        g_mine[cast[uint64](i)] = 0
        g_state[cast[uint64](i)] = 0
        g_count[cast[uint64](i)] = 0
        i = i + 1
    g_over = 0
    g_won = 0
    g_first = 0
    g_flags = 0
    g_revealed = 0
    g_cx = 0
    g_cy = 0


# Directly place/clear a mine. Marks the game as no-longer-first so the next
# reveal will NOT re-scatter mines (keeps the test board byte-reproducible).
def hammine_test_setmine(x: int32, y: int32, v: int32):
    if x >= 0 and x < BOARD_W and y >= 0 and y < BOARD_H:
        g_mine[_idx(x, y)] = v
        g_first = 0


def hammine_test_recount():
    _recount()


def hammine_test_setstate(x: int32, y: int32, s: int32):
    if x >= 0 and x < BOARD_W and y >= 0 and y < BOARD_H:
        g_state[_idx(x, y)] = s


# ====================================================================
# LAYOUT (fixed 360x470 window, matching the Snake/2048/Tetris footprint)
# ====================================================================
GAME_W: int32 = 360
GAME_H: int32 = 470

CELL:    int32 = 32
BOARD_X: int32 = 36               # (360 - 9*32) / 2
BOARD_Y: int32 = 64
HDR_Y:   int32 = 14
CTRL_H:  int32 = 30
CTRL_Y:  int32 = 430
PAD:     int32 = 12
GAP:     int32 = 10
BTN_W:   int32 = 100


def _cell_px(c: int32) -> int32:
    return BOARD_X + c * CELL


def _cell_py(r: int32) -> int32:
    return BOARD_Y + r * CELL


def _btn_x(i: int32) -> int32:
    return PAD + i * (BTN_W + GAP)


# PUBLIC: which control button is at (lx,ly), or -1 (0=New 1=Flag-mode).
def hammine_btn_at(lx: int64, ly: int64) -> int64:
    if ly < cast[int64](CTRL_Y) or ly >= cast[int64](CTRL_Y + CTRL_H):
        return -1
    i: int32 = 0
    while i < 2:
        bx: int64 = cast[int64](_btn_x(i))
        if lx >= bx and lx < bx + cast[int64](BTN_W):
            return cast[int64](i)
        i = i + 1
    return -1


# PUBLIC: field cell under (lx,ly) -> 1 + fills cx/cy; else 0.
def hammine_cell_at(lx: int64, ly: int64, cx: Ptr[int32], cy: Ptr[int32]) -> int32:
    if lx < cast[int64](BOARD_X) or ly < cast[int64](BOARD_Y):
        return 0
    gx: int32 = cast[int32](lx - cast[int64](BOARD_X)) / CELL
    gy: int32 = cast[int32](ly - cast[int64](BOARD_Y)) / CELL
    if gx < 0 or gx >= BOARD_W or gy < 0 or gy >= BOARD_H:
        return 0
    cx[0] = gx
    cy[0] = gy
    return 1


# ====================================================================
# RENDER
# ====================================================================
sbuf: Array[64, uint8]


# Classic Minesweeper number colour for a neighbour-count 1..8.
def _num_color(n: int32) -> Ptr[uint8]:
    if n == 1:
        c1: Ptr[uint8] = "#2a4bd6"                     # blue
        return c1
    if n == 2:
        c2: Ptr[uint8] = "#2f9e2f"                     # green
        return c2
    if n == 3:
        c3: Ptr[uint8] = "#d62a2a"                     # red
        return c3
    if n == 4:
        c4: Ptr[uint8] = "#6a1fb0"                     # purple
        return c4
    if n == 5:
        c5: Ptr[uint8] = "#8a5a1a"                     # maroon
        return c5
    if n == 6:
        c6: Ptr[uint8] = "#1aa0a0"                     # teal
        return c6
    if n == 7:
        c7: Ptr[uint8] = "#202020"                     # black
        return c7
    c8: Ptr[uint8] = "#707070"                         # grey
    return c8


def _draw_controls():
    i: int32 = 0
    while i < 2:
        bx: int32 = _btn_x(i)
        sunk: int32 = 0
        if i == 1 and g_flagmode != 0:
            sunk = 1
        hamscene_panel_button(bx, CTRL_Y, BTN_W, CTRL_H, sunk)
        lbl: Ptr[uint8] = cast[Ptr[uint8]]("New")
        if i == 1:
            if g_flagmode != 0:
                lbl = cast[Ptr[uint8]]("Flag: ON")
            else:
                lbl = cast[Ptr[uint8]]("Flag: off")
        lx: int32 = bx + (BTN_W - cast[int32](_slen(lbl)) * 8) / 2
        ly: int32 = CTRL_Y + (CTRL_H - 12) / 2
        hamscene_glyphs(lx, ly, lbl, cast[Ptr[uint8]]("#202020"))
        i = i + 1


# Draw one field cell.
def _draw_cell(x: int32, y: int32):
    px: int32 = _cell_px(x)
    py: int32 = _cell_py(y)
    i: uint64 = _idx(x, y)
    st: int32 = g_state[i]
    if st == 1:
        # Revealed: light face; a mine shows a dark marker, else a number.
        hamscene_fill(px + 1, py + 1, CELL - 2, CELL - 2,
                      cast[Ptr[uint8]]("#c8ccd8"))
        if g_mine[i] != 0:
            hamscene_fill(px + 9, py + 9, CELL - 18, CELL - 18,
                          cast[Ptr[uint8]]("#141414"))
        else:
            n: int32 = g_count[i]
            if n > 0:
                digs: Array[2, uint8]
                digs[0] = cast[uint8](n) + 48
                digs[1] = 0
                gx: int32 = px + (CELL - 8) / 2
                gy: int32 = py + (CELL - 12) / 2
                hamscene_glyphs_bold(gx, gy, &digs[0], _num_color(n))
    else:
        # Covered: raised face; a flagged cell gets a red marker.
        hamscene_fill(px + 1, py + 1, CELL - 2, CELL - 2,
                      cast[Ptr[uint8]]("#7f8fb0"))
        hamscene_stroke(px + 1, py + 1, CELL - 2, CELL - 2, 1,
                        cast[Ptr[uint8]]("#9fb0d0"))
        if st == 2:
            hamscene_fill(px + 10, py + 8, CELL - 20, CELL - 14,
                          cast[Ptr[uint8]]("#e02a2a"))


# PUBLIC: build the whole display list into the shared hamscene buffer. Does
# NOT commit. BOUNDED: one backdrop + header + 81 cells + cursor + 2 buttons.
def hammine_build_scene():
    hamscene_begin()
    hamscene_fill(0, 0, GAME_W, GAME_H, cast[Ptr[uint8]]("#1b1b2e"))

    # Header: title + mines-left + status.
    hamscene_glyphs_bold(PAD, HDR_Y, cast[Ptr[uint8]]("Mines"),
                         cast[Ptr[uint8]]("#e8e8f0"))
    sp: uint64 = 0
    p: uint64 = 0
    hdr: Ptr[uint8] = cast[Ptr[uint8]]("Left ")
    while hdr[p] != 0:
        sbuf[sp] = hdr[p]
        sp = sp + 1
        p = p + 1
    sp = sp + _u64_to_dec(cast[uint64](hammine_mines_left()), &sbuf[sp])
    sbuf[sp] = 0
    hamscene_glyphs(PAD + 64, HDR_Y + 2, &sbuf[0], cast[Ptr[uint8]]("#9aa0c0"))

    status: Ptr[uint8] = cast[Ptr[uint8]]("Playing")
    scol: Ptr[uint8] = cast[Ptr[uint8]]("#9aa0c0")
    if g_over != 0:
        if g_won != 0:
            status = cast[Ptr[uint8]]("You win!")
            scol = cast[Ptr[uint8]]("#3ac35a")
        else:
            status = cast[Ptr[uint8]]("Boom!")
            scol = cast[Ptr[uint8]]("#ff5252")
    hamscene_glyphs(PAD + 168, HDR_Y + 2, status, scol)

    # Field backing panel + frame.
    bw: int32 = BOARD_W * CELL
    bh: int32 = BOARD_H * CELL
    hamscene_fill(BOARD_X, BOARD_Y, bw, bh, cast[Ptr[uint8]]("#101024"))
    hamscene_stroke(BOARD_X, BOARD_Y, bw, bh, 1, cast[Ptr[uint8]]("#33345a"))

    y: int32 = 0
    while y < BOARD_H:
        x: int32 = 0
        while x < BOARD_W:
            _draw_cell(x, y)
            x = x + 1
        y = y + 1

    # Keyboard cursor highlight.
    cxp: int32 = _cell_px(g_cx)
    cyp: int32 = _cell_py(g_cy)
    hamscene_stroke(cxp, cyp, CELL, CELL, 2, cast[Ptr[uint8]]("#ffd23f"))

    _draw_controls()


# PUBLIC: draw the win/loss overlay on TOP of an already-built scene. No-op
# unless the game is over.
def hammine_draw_overlay():
    if g_over == 0:
        return
    bw: int32 = BOARD_W * CELL
    bh: int32 = BOARD_H * CELL
    ov_w: int32 = bw + 20
    ov_h: int32 = 100
    ov_x: int32 = BOARD_X + (bw - ov_w) / 2
    ov_y: int32 = BOARD_Y + (bh - ov_h) / 2

    hamscene_fill(ov_x, ov_y, ov_w, ov_h, cast[Ptr[uint8]]("#2b2b4a"))
    edge: Ptr[uint8] = cast[Ptr[uint8]]("#ff5252")
    title: Ptr[uint8] = cast[Ptr[uint8]]("BOOM!")
    tcol: Ptr[uint8] = cast[Ptr[uint8]]("#ff6b6b")
    if g_won != 0:
        edge = cast[Ptr[uint8]]("#3ac35a")
        title = cast[Ptr[uint8]]("YOU WIN!")
        tcol = cast[Ptr[uint8]]("#6bff9a")
    hamscene_stroke(ov_x, ov_y, ov_w, ov_h, 3, edge)

    cx: int32 = ov_x + ov_w / 2
    tx: int32 = cx - cast[int32](_slen(title)) * 4
    hamscene_glyphs_bold(tx, ov_y + 28, title, tcol)
    l1: Ptr[uint8] = cast[Ptr[uint8]]("Press New to retry")
    x1: int32 = cx - cast[int32](_slen(l1)) * 4
    hamscene_glyphs(x1, ov_y + 62, l1, cast[Ptr[uint8]]("#e8e8f0"))


# PUBLIC: apply an on-screen control button press (0=New 1=Flag-mode toggle).
def hammine_ctrl_press(b: int64):
    if b == 0:
        hammine_reset()
    elif b == 1:
        if g_flagmode != 0:
            g_flagmode = 0
        else:
            g_flagmode = 1


# PUBLIC: apply a pointer click on the FIELD at cell (x,y): reveal, or flag if
# flag-mode is on. `rightbtn` != 0 forces a flag regardless of mode.
def hammine_field_click(x: int32, y: int32, rightbtn: int32) -> int32:
    if rightbtn != 0 or g_flagmode != 0:
        return hammine_flag(x, y)
    return hammine_reveal(x, y)


# ====================================================================
# INPUT (pure — bytes/lines in, state mutations out)
# ====================================================================
esc_state: int32 = 0


def _key_byte(c: uint8) -> int32:
    if esc_state == 1:
        if c == 91:                     # '['
            esc_state = 2
            return 0
        esc_state = 0
    elif esc_state == 2:
        esc_state = 0
        if c == 65:                     # 'A' up
            return hammine_cursor_move(0, -1)
        if c == 66:                     # 'B' down
            return hammine_cursor_move(0, 1)
        if c == 67:                     # 'C' right
            return hammine_cursor_move(1, 0)
        if c == 68:                     # 'D' left
            return hammine_cursor_move(-1, 0)
        return 0
    if c == 27:                         # ESC -> begin arrow sequence
        esc_state = 1
        return 0
    if c == 119 or c == 87:             # w/W up
        return hammine_cursor_move(0, -1)
    if c == 115 or c == 83:             # s/S down
        return hammine_cursor_move(0, 1)
    if c == 97 or c == 65:              # a/A left
        return hammine_cursor_move(-1, 0)
    if c == 100 or c == 68:             # d/D right
        return hammine_cursor_move(1, 0)
    if c == 32 or c == 13 or c == 10:   # space/enter -> reveal at cursor
        return hammine_reveal(g_cx, g_cy)
    if c == 102 or c == 70:             # f/F -> flag at cursor
        return hammine_flag(g_cx, g_cy)
    if c == 114 or c == 82 or c == 110 or c == 78:   # r/R/n/N restart
        hammine_reset()
        return 1
    return 0


# PUBLIC: parse one "<type> <code>" key line; on a press ('d'), apply the byte.
def hammine_key_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 100:            # 'd' = press; ignore 'u' release
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    code: int32 = 0
    got: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        code = code * 10 + cast[int32](s[i]) - 48
        i = i + 1
        got = 1
    if got == 0:
        return 0
    if code < 0 or code > 255:
        return 0
    return _key_byte(cast[uint8](code))


# PUBLIC: parse "m <x> <y> <buttons> ..." -> 1 + fills bx/by/bbtn; else 0.
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:            # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc2: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc2 = acc2 * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc2 = 0 - acc2
        vals[v] = acc2
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1

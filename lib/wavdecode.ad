# lib/wavdecode.ad — PURE, extern-free RIFF/WAVE (.wav) PCM decoder.
#
# WHY THIS FILE EXISTS
# ====================
# The audio player (user/hamaudioscene.ad) and the raw `aplay` tool both need
# to turn a .wav file's bytes into (a) the stream format — sample rate, channel
# count, bit depth — and (b) the offset+length of the raw PCM payload, so the
# right rate/channels can be pushed to /dev/audioctl and the samples streamed
# to /dev/audio. This module is the ONE place that understands the container.
#
# It is deliberately PURE: no `extern`, no I/O, no imports. It operates on an
# in-memory byte buffer the caller already read. That makes it DUAL-TARGET —
# it links into BOTH the native x86_64-adder-user player AND the x86_64-linux
# host test harness, so scripts/test_hamaudio_host.sh can decode the shipped
# tests/fixtures/sounds/test.wav on the dev host (no QEMU) and check the
# extracted format + sample count + a PCM checksum against a Python `wave`
# reference — a real, deterministic correctness signal for the decoder.
#
# FORMAT SUPPORTED: canonical RIFF/WAVE, PCM (fmt audioFormat==1), 8- or
# 16-bit, mono or stereo. The chunk walker tolerates extra chunks (LIST,
# fact, ...) between `fmt ` and `data`, and an odd-length chunk's pad byte.
# Non-PCM (float/ADPCM/compressed) and MP3-in-RIFF are rejected — see the
# MP3-decode plan in docs/audio_media_track.md for the follow-up codec.
#
# This module owns module-scope state populated by wavdecode_parse(); the
# accessors read it back. One decode in flight at a time (the player decodes
# one file at a time), matching the other lib/*core.ad singletons.

# ---- module state (filled by wavdecode_parse) ---------------------------
wav_ok:        int32  = 0
wav_rate:      uint32 = 0
wav_channels:  uint32 = 0
wav_bits:      uint32 = 0
wav_fmt_tag:   uint32 = 0
wav_data_off:  uint64 = 0
wav_data_len:  uint64 = 0


# ---- little-endian buffer readers ---------------------------------------
def _wd_u16(buf: Ptr[uint8], off: uint64) -> uint32:
    return cast[uint32](buf[off]) | (cast[uint32](buf[off + 1]) << 8)


def _wd_u32(buf: Ptr[uint8], off: uint64) -> uint32:
    return cast[uint32](buf[off]) \
         | (cast[uint32](buf[off + 1]) << 8) \
         | (cast[uint32](buf[off + 2]) << 16) \
         | (cast[uint32](buf[off + 3]) << 24)


def _wd_tag(buf: Ptr[uint8], off: uint64, a: uint8, b: uint8, c: uint8,
            d: uint8) -> int32:
    if buf[off] == a and buf[off + 1] == b and buf[off + 2] == c \
            and buf[off + 3] == d:
        return 1
    return 0


# Parse a RIFF/WAVE buffer of `len` bytes. Returns 1 on success (a PCM fmt
# chunk and a data chunk were found), 0 otherwise. On success the accessors
# below return the stream format + the PCM payload span within `buf`.
def wavdecode_parse(buf: Ptr[uint8], len: uint64) -> int32:
    wav_ok = 0
    wav_rate = 0
    wav_channels = 0
    wav_bits = 0
    wav_fmt_tag = 0
    wav_data_off = 0
    wav_data_len = 0

    if len < 44:
        return 0
    # "RIFF" .... "WAVE"
    if _wd_tag(buf, 0, 82, 73, 70, 70) == 0:               # RIFF
        return 0
    if _wd_tag(buf, 8, 87, 65, 86, 69) == 0:               # WAVE
        return 0

    have_fmt: int32 = 0
    have_data: int32 = 0
    pos: uint64 = 12                                       # first chunk
    while pos + 8 <= len:
        csize: uint64 = cast[uint64](_wd_u32(buf, pos + 4))
        body: uint64 = pos + 8
        if _wd_tag(buf, pos, 102, 109, 116, 32) == 1:      # "fmt "
            if body + 16 <= len:
                wav_fmt_tag = _wd_u16(buf, body)
                wav_channels = _wd_u16(buf, body + 2)
                wav_rate = _wd_u32(buf, body + 4)
                wav_bits = _wd_u16(buf, body + 14)
                have_fmt = 1
        elif _wd_tag(buf, pos, 100, 97, 116, 97) == 1:     # "data"
            wav_data_off = body
            # Clamp a declared size that runs past the buffer (truncated file).
            if body + csize > len:
                wav_data_len = len - body
            else:
                wav_data_len = csize
            have_data = 1
        # Advance to the next chunk; chunks are word-aligned (pad odd sizes).
        adv: uint64 = csize
        if (adv & 1) != 0:
            adv = adv + 1
        pos = body + adv

    if have_fmt == 0 or have_data == 0:
        return 0
    # Only linear PCM (tag 1) with a sane layout is playable here.
    if wav_fmt_tag != 1:
        return 0
    if wav_channels == 0 or wav_channels > 2:
        return 0
    if wav_bits != 8 and wav_bits != 16:
        return 0
    if wav_rate == 0:
        return 0
    wav_ok = 1
    return 1


def wavdecode_ok() -> int32:
    return wav_ok


def wavdecode_rate() -> uint32:
    return wav_rate


def wavdecode_channels() -> uint32:
    return wav_channels


def wavdecode_bits() -> uint32:
    return wav_bits


def wavdecode_data_off() -> uint64:
    return wav_data_off


def wavdecode_data_len() -> uint64:
    return wav_data_len


# Bytes per sample-frame (all channels): channels * bits/8.
def wavdecode_frame_bytes() -> uint64:
    return cast[uint64](wav_channels) * (cast[uint64](wav_bits) / 8)


# Number of sample-frames in the PCM payload.
def wavdecode_nframes() -> uint64:
    fb: uint64 = wavdecode_frame_bytes()
    if fb == 0:
        return 0
    return wav_data_len / fb


# Clip duration in milliseconds (integer).
def wavdecode_duration_ms() -> uint64:
    if wav_rate == 0:
        return 0
    return wavdecode_nframes() * 1000 / cast[uint64](wav_rate)


# Peak |sample| (0..32767 for 16-bit, 0..128 for 8-bit) over a byte span of
# the PCM payload [off, off+n). Used to drive the player's live level meter
# from whatever chunk was just streamed. `off`/`n` are byte offsets into the
# WHOLE buffer (the caller passes wav_data_off + its stream cursor).
def wavdecode_peak(buf: Ptr[uint8], off: uint64, n: uint64) -> uint32:
    peak: uint32 = 0
    if wav_bits == 16:
        i: uint64 = 0
        while i + 1 < n:
            raw: uint32 = _wd_u16(buf, off + i)
            # sign-extend the 16-bit sample, take magnitude
            mag: uint32 = raw
            if raw >= 32768:
                mag = 65536 - raw
            if mag > peak:
                peak = mag
            i = i + 2
    else:
        # 8-bit PCM is unsigned, centred on 128.
        j: uint64 = 0
        while j < n:
            s: uint32 = cast[uint32](buf[off + j])
            mag2: uint32 = s
            if s >= 128:
                mag2 = s - 128
            else:
                mag2 = 128 - s
            if mag2 > peak:
                peak = mag2
            j = j + 1
    return peak

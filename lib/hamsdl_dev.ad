# lib/hamsdl_dev.ad — hamSDL DEVICE backend (x86_64-adder-user only).
#
# The Hamnix transport for lib/hamsdl.ad: it opens a real wsys window on the
# desktop, PUMPS its /event + /keys files into the shared hamSDL event queue,
# COMMITS the frame the game built, and drives ticks/delay off the boot clock.
# It links the native externs + lib/hamui.ad's hamscene_commit, so it is a
# DEVICE-only module (mirrors lib/hamui.ad; the host mirror is lib/hamsdl_host.ad).
#
# PUBLIC API (device half of the hamSDL spec):
#   sdl_dev_init(title, x, y, w, h) -> int32   create a titled game window;
#                                              returns its wid, or -1 on failure
#   sdl_dev_wid()                   -> int32   the current window id
#   sdl_dev_pump()                             drain /keys + /event -> events
#   sdl_dev_present()               -> int32   commit the built frame (0 ok)
#   sdl_dev_ticks()                 -> uint64  milliseconds since boot
#   sdl_dev_delay(ms)                          cooperative sleep for ms
#   sdl_dev_upload_rgba(name, w, h, rgba) -> int32   register a sprite/surface
#                                              (RGBA8888) under `name` for sdl_blit
#
# A game's device main() is just: init -> loop { pump; drain sdl_poll_event;
# update; begin_frame + draw; present; delay }. See user/sdlpong.ad.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

from lib.hamui import hamscene_commit
from lib.hamsdl import sdl_feed_keys_buffer, sdl_feed_event_buffer


_sdl_wid: int32 = -1
_sdl_kfd: int32 = -1
_sdl_evp:  Array[64, uint8]
_sdl_keysp: Array[64, uint8]
_sdl_ctlp:  Array[64, uint8]
_sdl_kbuf: Array[256, uint8]
_sdl_ebuf: Array[256, uint8]


def _sdl_slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _sdl_u64_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    tmp: Array[24, uint8]
    n: uint64 = 0
    while v > 0:
        tmp[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    i: uint64 = 0
    while i < n:
        out[i] = tmp[n - 1 - i]
        i = i + 1
    return n


def _sdl_writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _sdl_slen(s))


def _sdl_winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _sdl_u64_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


def _sdl_newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read_nb(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _sdl_ctlcmd(cmd: Ptr[uint8]):
    fd: int32 = sys_open_write(cast[Ptr[char]](&_sdl_ctlp[0]))
    if fd >= 0:
        _sdl_writeall(fd, cmd)
        sys_close(fd)


# Create a titled game window of the given size at (x, y). Returns the wid.
def sdl_dev_init(title: Ptr[uint8], x: int32, y: int32,
                 w: int32, h: int32) -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _sdl_newwindow()
    if wid < 0:
        return -1
    _sdl_wid = wid
    _sdl_winpath(&_sdl_ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _sdl_winpath(&_sdl_evp[0], wid, cast[Ptr[uint8]]("/event"))
    _sdl_winpath(&_sdl_keysp[0], wid, cast[Ptr[uint8]]("/keys"))

    # geometry <x> <y> <w> <h>
    gb: Array[80, uint8]
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("geometry ")
    while pre[p] != 0:
        gb[p] = pre[p]
        p = p + 1
    p = p + _sdl_u64_dec(cast[uint64](x), &gb[p])
    gb[p] = 32
    p = p + 1
    p = p + _sdl_u64_dec(cast[uint64](y), &gb[p])
    gb[p] = 32
    p = p + 1
    p = p + _sdl_u64_dec(cast[uint64](w), &gb[p])
    gb[p] = 32
    p = p + 1
    p = p + _sdl_u64_dec(cast[uint64](h), &gb[p])
    gb[p] = 10
    p = p + 1
    gb[p] = 0
    _sdl_ctlcmd(&gb[0])

    _sdl_ctlcmd(cast[Ptr[uint8]]("decorate 1\n"))
    _sdl_ctlcmd(cast[Ptr[uint8]]("z 6\n"))

    # title <text>
    tb: Array[96, uint8]
    tp: uint64 = 0
    tpre: Ptr[uint8] = cast[Ptr[uint8]]("title ")
    while tpre[tp] != 0:
        tb[tp] = tpre[tp]
        tp = tp + 1
    k: uint64 = 0
    while title[k] != 0 and tp < 90:
        tb[tp] = title[k]
        tp = tp + 1
        k = k + 1
    tb[tp] = 10
    tp = tp + 1
    tb[tp] = 0
    _sdl_ctlcmd(&tb[0])

    # Keep /keys open for the whole session (waitfds-wired wakeups).
    _sdl_kfd = sys_open(cast[Ptr[char]](&_sdl_keysp[0]))
    return wid


def sdl_dev_wid() -> int32:
    return _sdl_wid


# Drain /keys (kept open) then /event (reopened per poll) into the event queue.
def sdl_dev_pump():
    if _sdl_kfd >= 0:
        kr: int64 = sys_read_nb(_sdl_kfd, &_sdl_kbuf[0], 255)
        if kr > 0:
            sdl_feed_keys_buffer(&_sdl_kbuf[0], cast[uint64](kr))
    efd: int32 = sys_open(cast[Ptr[char]](&_sdl_evp[0]))
    if efd >= 0:
        er: int64 = sys_read_nb(efd, &_sdl_ebuf[0], 255)
        sys_close(efd)
        if er > 0:
            sdl_feed_event_buffer(&_sdl_ebuf[0], cast[uint64](er))


def sdl_dev_present() -> int32:
    if _sdl_wid < 0:
        return -1
    return hamscene_commit(_sdl_wid)


# Milliseconds since boot (jiffies are 100 Hz => 10 ms each).
def sdl_dev_ticks() -> uint64:
    return sys_get_jiffies() * 10


def sdl_dev_delay(ms: uint64):
    target: uint64 = ms / 10                             # ms -> jiffies
    if target == 0:
        target = 1
    s: uint64 = sys_get_jiffies()
    while sys_get_jiffies() - s < target:
        sys_yield()


# ---- sprite / surface upload ('I' verb on /dev/wsys/<wid>/draw/ctl) -------
# Registers `rgba` (w*h RGBA8888 bytes) under `name` so sdl_blit(name, ...) can
# draw it. Round-1 cap: the whole verb must fit _sdl_img_buf (up to 96x96).
_sdl_img_buf: Array[36880, uint8]


def _sdl_put_i32le(off: uint64, v: int32):
    u: uint32 = cast[uint32](v)
    _sdl_img_buf[off]     = cast[uint8](u & 255)
    _sdl_img_buf[off + 1] = cast[uint8]((u >> 8) & 255)
    _sdl_img_buf[off + 2] = cast[uint8]((u >> 16) & 255)
    _sdl_img_buf[off + 3] = cast[uint8]((u >> 24) & 255)


def sdl_dev_upload_rgba(name: Ptr[uint8], w: int32, h: int32,
                        rgba: Ptr[uint8]) -> int32:
    if _sdl_wid < 0:
        return -1
    nl: uint64 = _sdl_slen(name)
    if nl > 250:
        return -1
    pix: uint64 = cast[uint64](w) * cast[uint64](h) * 4
    hdr: uint64 = 2 + nl + 9
    if hdr + pix > 36880:
        return -1                                        # too big for round-1
    _sdl_img_buf[0] = 73                                 # 'I'
    _sdl_img_buf[1] = cast[uint8](nl)
    k: uint64 = 0
    while k < nl:
        _sdl_img_buf[2 + k] = name[k]
        k = k + 1
    _sdl_put_i32le(2 + nl, w)
    _sdl_put_i32le(2 + nl + 4, h)
    _sdl_img_buf[2 + nl + 8] = 1                         # WSYS_BLIT_FMT_RGBA8888
    j: uint64 = 0
    while j < pix:
        _sdl_img_buf[hdr + j] = rgba[j]
        j = j + 1
    dpath: Array[64, uint8]
    _sdl_winpath(&dpath[0], _sdl_wid, cast[Ptr[uint8]]("/draw/ctl"))
    fd: int32 = sys_open_write(cast[Ptr[char]](&dpath[0]))
    if fd < 0:
        return -1
    wr: int64 = sys_write(fd, &_sdl_img_buf[0], hdr + pix)
    sys_close(fd)
    if wr < 0:
        return -1
    return 0

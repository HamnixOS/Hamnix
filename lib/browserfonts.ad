# lib/browserfonts.ad — EMBEDDED DejaVu-subset TrueType faces for the
# NATIVE web browser (user/hambrowse.ad). AUTO-GENERATED from fonts/dejavu-
# *.ttf by scripts/gen_browserfonts.py — DO NOT EDIT BY HAND.
#
# The host driver reads the .ttf files directly; the native browser has no
# font files in its namespace, so the bytes are baked in here as ASCII-hex
# strings (module-scope binary initialisers are unsupported by the x86
# codegen) and decoded once into BSS buffers by browserfonts_load(), which
# then registers each face with the TrueType rasteriser via htmlpaint. PURE:
# no extern/syscall, so it also links into the x86_64-linux host target.

from lib.htmlpaint import htmlpaint_load_ttf
from lib.font_ttf import FACE_TT_SANS, FACE_TT_SANS_BOLD, FACE_TT_SERIF, \
    FACE_TT_MONO


# dejavu-sans.ttf: 7676 bytes
_BF_SANS_HEX: Array[15353, uint8] = ""
_BF_SANS_LEN: uint64 = 7676
_bf_sans_buf: Array[7676, uint8]

# dejavu-sans-bold.ttf: 7884 bytes
_BF_BOLD_HEX: Array[15769, uint8] = ""
_BF_BOLD_LEN: uint64 = 7884
_bf_bold_buf: Array[7884, uint8]

# dejavu-serif.ttf: 8732 bytes
_BF_SERIF_HEX: Array[17465, uint8] = ""
_BF_SERIF_LEN: uint64 = 8732
_bf_serif_buf: Array[8732, uint8]

# dejavu-mono.ttf: 7556 bytes
_BF_MONO_HEX: Array[15113, uint8] = ""
_BF_MONO_LEN: uint64 = 7556
_bf_mono_buf: Array[7556, uint8]


_bf_loaded: int32 = 0


def _bf_hexval(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return cast[int32](c) - 48
    if c >= 97 and c <= 102:
        return cast[int32](c) - 97 + 10
    if c >= 65 and c <= 70:
        return cast[int32](c) - 65 + 10
    return 0


def _bf_decode(hex: Ptr[uint8], dst: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n:
        hi: int32 = _bf_hexval(hex[i * 2])
        lo: int32 = _bf_hexval(hex[i * 2 + 1])
        dst[i] = cast[uint8](hi * 16 + lo)
        i = i + 1


# Decode + register all four embedded faces with the TrueType rasteriser.
# Idempotent. Returns 1 if the sans face loaded (enough to render), else 0.
def browserfonts_load() -> int32:
    if _bf_loaded != 0:
        return 1
    _bf_decode(&_BF_SANS_HEX[0], &_bf_sans_buf[0], _BF_SANS_LEN)
    htmlpaint_load_ttf(FACE_TT_SANS, &_bf_sans_buf[0], _BF_SANS_LEN)
    _bf_decode(&_BF_BOLD_HEX[0], &_bf_bold_buf[0], _BF_BOLD_LEN)
    htmlpaint_load_ttf(FACE_TT_SANS_BOLD, &_bf_bold_buf[0], _BF_BOLD_LEN)
    _bf_decode(&_BF_SERIF_HEX[0], &_bf_serif_buf[0], _BF_SERIF_LEN)
    htmlpaint_load_ttf(FACE_TT_SERIF, &_bf_serif_buf[0], _BF_SERIF_LEN)
    _bf_decode(&_BF_MONO_HEX[0], &_bf_mono_buf[0], _BF_MONO_LEN)
    htmlpaint_load_ttf(FACE_TT_MONO, &_bf_mono_buf[0], _BF_MONO_LEN)
    _bf_loaded = 1
    return 1

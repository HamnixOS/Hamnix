# lib/hamvideocore.ad — the PURE, target-agnostic core of the hamvideo player.
#
# WHY (dual-target seam, see docs/hamui_dual_target.md)
# =====================================================
# The player's UI STATE (loaded file name, native frame geometry, fps, total
# frame count, current frame index, play/pause flag), the resize-aware LAYOUT
# (video display rect, scrub bar, transport buttons), the scene DISPLAY-LIST
# builder, and the pure keyboard+pointer INPUT handlers — everything EXCEPT the
# Hamnix-only wsys window transport, the per-frame JPEG DECODE (lib/jpeg.ad),
# and the per-frame RGBA upload to the compositor. Factored out of
# user/hamvideoscene.ad exactly like lib/hamaudiocore.ad, so the SAME code
# drives both the native compositor (hamscene_commit -> /dev/wsys, frame pixels
# via the draw/ctl 'I' verb) and the host twin (lib/hamui_host rasterizer ->
# PNG, frame pixels via hamui_host_register_image). Imports ONLY lib/hamscene.ad
# (the pure builder), has NO `extern`, and links into BOTH the native
# x86_64-adder-user target and the x86_64-linux host target.
#
# The decoded video frame is referenced from the display list by the fixed
# image name "frame" (hamscene_image); the driver re-uploads that named image
# each tick before committing, so the compositor blits whatever frame is
# current. The core never touches pixels — it only lays the frame rect out and
# names it.
#
# COMMAND QUEUE (mirrors hamaudiocore)
# ====================================
# Input handlers enqueue a single pending command (PLAYPAUSE / STOP / SEEK) that
# the native driver drains each event-loop tick; a SEEK carries a target frame.
# The driver is the sole source of truth for playback progress and reflects it
# back via hamvideo_set_frame()/set_playing().

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_stroke, hamscene_glyphs, hamscene_glyphs_bold, \
    hamscene_roundrect, hamscene_text, hamscene_image

# ---- command codes (hamvideo_take_command) -------------------------------
HAMVIDEO_CMD_NONE:      int32 = 0
HAMVIDEO_CMD_PLAYPAUSE: int32 = 1
HAMVIDEO_CMD_STOP:      int32 = 2
HAMVIDEO_CMD_SEEK:      int32 = 3

# ---- module state --------------------------------------------------------
vi_w:        int32  = 288          # window width
vi_h:        int32  = 360          # window height
vi_playing:  int32  = 0
vi_frame:    int32  = 0            # current frame index (0-based)
vi_nframes:  int32  = 0
vi_fps:      int32  = 1
vi_natw:     int32  = 0            # native video width  (source pixels)
vi_nath:     int32  = 0            # native video height

vi_pending:  int32  = 0           # a HAMVIDEO_CMD_* awaiting the driver
vi_seek_frame: int32 = 0

vi_name:     Array[64, uint8]
vi_press:    int32  = -1          # transport button currently sunk (-1 none)

# ---- layout (recomputed by hamvideo_layout) ------------------------------
BTN_W:  int32 = 84
BTN_H:  int32 = 40
vid_x:  int32 = 0
vid_y:  int32 = 0
vid_w:  int32 = 0
vid_h:  int32 = 0
bar_x:  int32 = 0
bar_y:  int32 = 0
bar_w:  int32 = 0
bar_h:  int32 = 12
btn_play_x: int32 = 0
btn_play_y: int32 = 0
btn_stop_x: int32 = 0
btn_stop_y: int32 = 0


# ---- tiny pure string helpers (unique _vi_ prefix, no link collisions) ---
def _vi_strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _vi_u64_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    written: uint64 = n
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return written


# ---- lifecycle -----------------------------------------------------------
def hamvideo_init():
    vi_playing = 0
    vi_frame = 0
    vi_nframes = 0
    vi_fps = 1
    vi_natw = 0
    vi_nath = 0
    vi_pending = 0
    vi_seek_frame = 0
    vi_press = -1
    vi_name[0] = 0
    hamvideo_layout(vi_w, vi_h)


def hamvideo_set_name(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 63:
        vi_name[i] = s[i]
        i = i + 1
    vi_name[i] = 0


# Native video geometry + timing, from the demux header.
def hamvideo_set_meta(natw: int32, nath: int32, fps: int32, nframes: int32):
    vi_natw = natw
    vi_nath = nath
    if fps < 1:
        fps = 1
    vi_fps = fps
    vi_nframes = nframes
    hamvideo_layout(vi_w, vi_h)


def hamvideo_set_frame(idx: int32):
    if idx < 0:
        idx = 0
    if vi_nframes > 0 and idx >= vi_nframes:
        idx = vi_nframes - 1
    vi_frame = idx


def hamvideo_frame() -> int32:
    return vi_frame


def hamvideo_nframes() -> int32:
    return vi_nframes


def hamvideo_fps() -> int32:
    return vi_fps


def hamvideo_set_playing(p: int32):
    vi_playing = p


def hamvideo_is_playing() -> int32:
    return vi_playing


# ---- command queue -------------------------------------------------------
def hamvideo_take_command() -> int32:
    c: int32 = vi_pending
    vi_pending = HAMVIDEO_CMD_NONE
    return c


def hamvideo_seek_frame() -> int32:
    return vi_seek_frame


# ---- layout --------------------------------------------------------------
def hamvideo_layout(w: int32, h: int32):
    vi_w = w
    vi_h = h
    # Video display rect: full width (minus margins) below the header, height
    # chosen to preserve the source aspect ratio (fallback 4:3 before meta).
    vid_x = 8
    vid_y = 36
    vid_w = w - 16
    nw: int32 = vi_natw
    nh: int32 = vi_nath
    if nw <= 0 or nh <= 0:
        nw = 4
        nh = 3
    vid_h = vid_w * nh / nw
    # Scrub bar below the video.
    bar_x = 16
    bar_w = w - 32
    bar_y = vid_y + vid_h + 14
    bar_h = 12
    # Two transport buttons, centred as a pair below the scrub bar.
    gap: int32 = 16
    total: int32 = BTN_W * 2 + gap
    bx: int32 = (w - total) / 2
    by: int32 = bar_y + bar_h + 18
    btn_play_x = bx
    btn_play_y = by
    btn_stop_x = bx + BTN_W + gap
    btn_stop_y = by


# ---- input: keyboard -----------------------------------------------------
# Parse a /keys "d <code>\n" line. SPACE toggles play/pause, 's'/'S' stops.
# Returns 1 if a command was enqueued (a redraw is warranted), else 0.
def hamvideo_key_line(line: Ptr[uint8], n: uint64) -> int32:
    if n < 3:
        return 0
    if line[0] != 100:                              # 'd'
        return 0
    code: int32 = 0
    i: uint64 = 2
    while i < n and line[i] >= 48 and line[i] <= 57:
        code = code * 10 + cast[int32](line[i] - 48)
        i = i + 1
    if code == 32:                                  # space
        vi_pending = HAMVIDEO_CMD_PLAYPAUSE
        return 1
    if code == 115 or code == 83:                   # s / S
        vi_pending = HAMVIDEO_CMD_STOP
        return 1
    return 0


# ---- input: pointer ------------------------------------------------------
# Hit-test a click at (lx,ly). Returns 0=play/pause, 1=stop, 2=scrub bar, -1.
def hamvideo_hit(lx: int64, ly: int64) -> int32:
    x: int32 = cast[int32](lx)
    y: int32 = cast[int32](ly)
    if x >= btn_play_x and x < btn_play_x + BTN_W \
            and y >= btn_play_y and y < btn_play_y + BTN_H:
        return 0
    if x >= btn_stop_x and x < btn_stop_x + BTN_W \
            and y >= btn_stop_y and y < btn_stop_y + BTN_H:
        return 1
    if x >= bar_x and x < bar_x + bar_w \
            and y >= bar_y - 6 and y < bar_y + bar_h + 6:
        return 2
    return -1


# Apply a press: enqueue the matching command. A scrub-bar click computes the
# target frame from the x fraction. Returns 1 if a command was enqueued.
def hamvideo_press_at(lx: int64, ly: int64) -> int32:
    hit: int32 = hamvideo_hit(lx, ly)
    if hit == 0:
        vi_pending = HAMVIDEO_CMD_PLAYPAUSE
        vi_press = 0
        return 1
    if hit == 1:
        vi_pending = HAMVIDEO_CMD_STOP
        vi_press = 1
        return 1
    if hit == 2:
        if vi_nframes > 0 and bar_w > 0:
            dx: int32 = cast[int32](lx) - bar_x
            if dx < 0:
                dx = 0
            if dx > bar_w:
                dx = bar_w
            f: int32 = cast[int32](cast[int64](vi_nframes) * cast[int64](dx)
                                   / cast[int64](bar_w))
            if f >= vi_nframes:
                f = vi_nframes - 1
            vi_seek_frame = f
            vi_pending = HAMVIDEO_CMD_SEEK
            return 1
    return 0


# Release: clear the sunk-button highlight. Returns 1 if state changed.
def hamvideo_release() -> int32:
    if vi_press != -1:
        vi_press = -1
        return 1
    return 0


# Centre of the Play button in window-local coords (valid after
# hamvideo_layout). Exposed so a host gate can synthesize a real Play click.
def hamvideo_btn_play_cx() -> int64:
    return cast[int64](btn_play_x + BTN_W / 2)


def hamvideo_btn_play_cy() -> int64:
    return cast[int64](btn_play_y + BTN_H / 2)


# EOF rewind: return to a clean, replayable idle at frame 0 with playback
# stopped. Shared by the native driver loop so pressing Play from EOF restarts
# from the top instead of re-settling at the last frame (the old "stuck at the
# end" bug). The caller also resets its own base_frame to 0.
def hamvideo_eof_rewind():
    hamvideo_set_frame(0)
    hamvideo_set_playing(0)


# Held pointer-button state for the edge detector below.
vi_btn_down: int32 = 0


# Parse one /event pointer line "m <x> <y> <buttons> <dz>" and drive
# press/release edges through hamvideo_press_at / hamvideo_release. The kernel
# pointer router (sys/src/9/port/devwsys.ad) emits a leading 'm' then FOUR ints
# (x, y, buttons, dz); the FIRST THREE after the 'm' are x, y, buttons and the
# trailing dz MUST be ignored. Returns 1 if player state changed. Single source
# of truth shared by the native app (user/hamvideoscene.ad) and the host gate.
def hamvideo_handle_pointer_line(line: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or line[0] != 109:                         # require leading 'm'
        return 0
    xs: Array[8, int64]
    nints: int32 = 0
    i: uint64 = 0
    while i < n and nints < 8:
        while i < n and (line[i] < 48 or line[i] > 57) and line[i] != 45:
            i = i + 1
        if i >= n:
            break
        neg: int32 = 0
        if line[i] == 45:
            neg = 1
            i = i + 1
        val: int64 = 0
        got: int32 = 0
        while i < n and line[i] >= 48 and line[i] <= 57:
            val = val * 10 + cast[int64](line[i] - 48)
            i = i + 1
            got = 1
        if got == 1:
            if neg == 1:
                val = 0 - val
            xs[nints] = val
            nints = nints + 1
    if nints < 3:
        return 0
    bx: int64 = xs[0]
    by: int64 = xs[1]
    bbtn: int64 = xs[2]
    now_down: int32 = 0
    if (bbtn & 1) != 0:
        now_down = 1
    changed: int32 = 0
    if now_down != 0 and vi_btn_down == 0:
        if hamvideo_press_at(bx, by) == 1:
            changed = 1
    elif now_down == 0 and vi_btn_down != 0:
        if hamvideo_release() == 1:
            changed = 1
    vi_btn_down = now_down
    return changed


# ---- scene builder -------------------------------------------------------
def _vi_progress_fill_w() -> int32:
    if vi_nframes <= 0:
        return 0
    p: int32 = vi_frame + 1
    if p > vi_nframes:
        p = vi_nframes
    return cast[int32](cast[int64](bar_w) * cast[int64](p)
                       / cast[int64](vi_nframes))


def hamvideo_build_scene():
    hamscene_begin()
    # Card background.
    hamscene_fill(0, 0, vi_w, vi_h, cast[Ptr[uint8]]("#14161b"))
    # Header strip.
    hamscene_fill(0, 0, vi_w, 30, cast[Ptr[uint8]]("#2b303b"))
    hamscene_glyphs_bold(12, 8, cast[Ptr[uint8]]("Video Player"),
                         cast[Ptr[uint8]]("#e6e8ec"))

    # Video frame: a black letterbox behind the blitted image, then the named
    # "frame" image (uploaded out-of-band by the driver) scaled into the rect.
    hamscene_fill(vid_x, vid_y, vid_w, vid_h, cast[Ptr[uint8]]("#000000"))
    if vi_nframes > 0:
        hamscene_image(vid_x, vid_y, vid_w, vid_h, cast[Ptr[uint8]]("frame"))
    hamscene_stroke(vid_x, vid_y, vid_w, vid_h, 1,
                    cast[Ptr[uint8]]("#3a4150"))

    # Filename + "frame N/total" readout.
    if vi_name[0] != 0:
        hamscene_glyphs(bar_x, bar_y - 20, &vi_name[0],
                        cast[Ptr[uint8]]("#8fd0ff"))
    fbuf: Array[48, uint8]
    p: uint64 = 0
    lbl: Ptr[uint8] = cast[Ptr[uint8]]("frame ")
    j: uint64 = 0
    while lbl[j] != 0:
        fbuf[p] = lbl[j]
        p = p + 1
        j = j + 1
    p = p + _vi_u64_dec(cast[uint64](vi_frame + 1), &fbuf[p])
    fbuf[p] = 47                                     # '/'
    p = p + 1
    p = p + _vi_u64_dec(cast[uint64](vi_nframes), &fbuf[p])
    fbuf[p] = 0
    fw_lbl: int32 = cast[int32](p)
    hamscene_glyphs(bar_x + bar_w - fw_lbl * 8, bar_y - 20, &fbuf[0],
                    cast[Ptr[uint8]]("#c8ccd4"))

    # Scrub bar: track + filled portion + hairline frame.
    hamscene_fill(bar_x, bar_y, bar_w, bar_h, cast[Ptr[uint8]]("#0e1014"))
    fw: int32 = _vi_progress_fill_w()
    if fw > 0:
        hamscene_fill(bar_x, bar_y, fw, bar_h, cast[Ptr[uint8]]("#3d7dff"))
    hamscene_stroke(bar_x, bar_y, bar_w, bar_h, 1,
                    cast[Ptr[uint8]]("#3a4150"))

    # Transport buttons.
    pp_face: Ptr[uint8] = cast[Ptr[uint8]]("#3a4150")
    if vi_press == 0:
        pp_face = cast[Ptr[uint8]]("#2b303b")
    hamscene_roundrect(btn_play_x, btn_play_y, BTN_W, BTN_H, 6, pp_face)
    pp_label: Ptr[uint8] = cast[Ptr[uint8]]("Play")
    if vi_playing != 0:
        pp_label = cast[Ptr[uint8]]("Pause")
    pl: int32 = cast[int32](_vi_strlen(pp_label))
    hamscene_glyphs(btn_play_x + (BTN_W - pl * 8) / 2,
                    btn_play_y + (BTN_H - 16) / 2, pp_label,
                    cast[Ptr[uint8]]("#e6e8ec"))

    st_face: Ptr[uint8] = cast[Ptr[uint8]]("#3a4150")
    if vi_press == 1:
        st_face = cast[Ptr[uint8]]("#2b303b")
    hamscene_roundrect(btn_stop_x, btn_stop_y, BTN_W, BTN_H, 6, st_face)
    hamscene_glyphs(btn_stop_x + (BTN_W - 4 * 8) / 2,
                    btn_stop_y + (BTN_H - 16) / 2,
                    cast[Ptr[uint8]]("Stop"), cast[Ptr[uint8]]("#e6e8ec"))

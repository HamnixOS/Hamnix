# lib/ecdsa/ecdsa.ad
#
# ECDSA-P256 signature verification (V3) — third layer in Hamnix's
# TLS cert validation stack. Builds on:
#   - lib/asn1/asn1.ad (V0) to decode the DER `SEQUENCE { r, s }` sig
#   - lib/ec/p256.ad   (V3) for P-256 field, scalar, and group ops
#
# Algorithm — FIPS 186-4 §6.4.2:
#   Given message m, signature (r, s), public key Q:
#     e   = SHA-256(m), interpreted as a big-endian integer mod n
#     w   = s^{-1} mod n
#     u1  = e*w mod n
#     u2  = r*w mod n
#     R   = u1*G + u2*Q
#     accept iff R != O and (R.x mod n) == r
#
# Reject conditions:
#   - r or s not in [1, n-1]                                  (malformed)
#   - signature DER does not decode                            (malformed)
#   - public key not 65 bytes / first byte not 0x04            (malformed)
#   - R == O after the sum                                     (invalid)
#   - (R.x mod n) != r                                         (invalid)
#
# SHA-256 here is self-contained — drivers/net/tls.ad ships a SHA-256
# but its state and buffer are module-globals private to the TLS
# session machine (`tls_sha_state`, `tls_sha_buf`, etc.) and aren't
# exposed for general use. Rather than reach across into kernel TLS
# state from this cert-validation library (which must also link into
# userland), we copy the standard SHA-256 constants and the FIPS 180-4
# compression schedule here. ~150 lines of duplicate code today; the
# right unification step is a future lib/crypto/sha256.ad shared by
# both drivers/net/tls.ad and this file. Tracked as a follow-up.
#
# CONST-TIME DISCLOSURE: this module is not constant-time. p256.ad's
# scalar multiplication branches per scalar bit, fp_mul branches per
# bit of its multiplier, and we also early-out on the various reject
# conditions. ECDSA verify inputs are public (signature, pubkey, hash)
# so this is correct for V3. The same disclosure repeated in p256.ad.

from lib.asn1.asn1 import (
    Asn1Cursor,
    asn1_cursor_init,
    asn1_remaining,
    asn1_read_sequence,
    asn1_read_integer,
)
from lib.ec.p256 import (
    P256Point,
    P256_N,
    p256_copy,
    p256_set_zero,
    p256_is_zero,
    p256_be_to_limbs,
    p256_ge,
    p256_eq,
    p256_point_set_infinity,
    p256_point_copy,
    p256_scalar_mul,
    p256_scalar_mul_g,
    p256_add,
    sn_inv,
    sn_mul,
    sn_in_range,
)

# -- EcdsaPubkey -----------------------------------------------------------

class EcdsaPubkey:
    point: P256Point


# -- SHA-256 (self-contained; see header note) -----------------------------
#
# These constants and the compression loop are bit-identical to the
# ones in drivers/net/tls.ad — copied here to keep this module
# kernel-internals-free and re-link-clean from both userland and
# kernel space.

ecdsa_sha_k: Array[64, uint32]

ecdsa_sha_state: Array[8, uint32]
ecdsa_sha_buf:   Array[64, uint8]
ecdsa_sha_buflen: uint64 = 0
ecdsa_sha_total_bits: uint64 = 0

ecdsa_sha_w: Array[64, uint32]
ecdsa_sha_state_scratch: Array[8, uint32]


def _ecdsa_sha_init_k():
    ecdsa_sha_k[0]  = 0x428A2F98
    ecdsa_sha_k[1]  = 0x71374491
    ecdsa_sha_k[2]  = 0xB5C0FBCF
    ecdsa_sha_k[3]  = 0xE9B5DBA5
    ecdsa_sha_k[4]  = 0x3956C25B
    ecdsa_sha_k[5]  = 0x59F111F1
    ecdsa_sha_k[6]  = 0x923F82A4
    ecdsa_sha_k[7]  = 0xAB1C5ED5
    ecdsa_sha_k[8]  = 0xD807AA98
    ecdsa_sha_k[9]  = 0x12835B01
    ecdsa_sha_k[10] = 0x243185BE
    ecdsa_sha_k[11] = 0x550C7DC3
    ecdsa_sha_k[12] = 0x72BE5D74
    ecdsa_sha_k[13] = 0x80DEB1FE
    ecdsa_sha_k[14] = 0x9BDC06A7
    ecdsa_sha_k[15] = 0xC19BF174
    ecdsa_sha_k[16] = 0xE49B69C1
    ecdsa_sha_k[17] = 0xEFBE4786
    ecdsa_sha_k[18] = 0x0FC19DC6
    ecdsa_sha_k[19] = 0x240CA1CC
    ecdsa_sha_k[20] = 0x2DE92C6F
    ecdsa_sha_k[21] = 0x4A7484AA
    ecdsa_sha_k[22] = 0x5CB0A9DC
    ecdsa_sha_k[23] = 0x76F988DA
    ecdsa_sha_k[24] = 0x983E5152
    ecdsa_sha_k[25] = 0xA831C66D
    ecdsa_sha_k[26] = 0xB00327C8
    ecdsa_sha_k[27] = 0xBF597FC7
    ecdsa_sha_k[28] = 0xC6E00BF3
    ecdsa_sha_k[29] = 0xD5A79147
    ecdsa_sha_k[30] = 0x06CA6351
    ecdsa_sha_k[31] = 0x14292967
    ecdsa_sha_k[32] = 0x27B70A85
    ecdsa_sha_k[33] = 0x2E1B2138
    ecdsa_sha_k[34] = 0x4D2C6DFC
    ecdsa_sha_k[35] = 0x53380D13
    ecdsa_sha_k[36] = 0x650A7354
    ecdsa_sha_k[37] = 0x766A0ABB
    ecdsa_sha_k[38] = 0x81C2C92E
    ecdsa_sha_k[39] = 0x92722C85
    ecdsa_sha_k[40] = 0xA2BFE8A1
    ecdsa_sha_k[41] = 0xA81A664B
    ecdsa_sha_k[42] = 0xC24B8B70
    ecdsa_sha_k[43] = 0xC76C51A3
    ecdsa_sha_k[44] = 0xD192E819
    ecdsa_sha_k[45] = 0xD6990624
    ecdsa_sha_k[46] = 0xF40E3585
    ecdsa_sha_k[47] = 0x106AA070
    ecdsa_sha_k[48] = 0x19A4C116
    ecdsa_sha_k[49] = 0x1E376C08
    ecdsa_sha_k[50] = 0x2748774C
    ecdsa_sha_k[51] = 0x34B0BCB5
    ecdsa_sha_k[52] = 0x391C0CB3
    ecdsa_sha_k[53] = 0x4ED8AA4A
    ecdsa_sha_k[54] = 0x5B9CCA4F
    ecdsa_sha_k[55] = 0x682E6FF3
    ecdsa_sha_k[56] = 0x748F82EE
    ecdsa_sha_k[57] = 0x78A5636F
    ecdsa_sha_k[58] = 0x84C87814
    ecdsa_sha_k[59] = 0x8CC70208
    ecdsa_sha_k[60] = 0x90BEFFFA
    ecdsa_sha_k[61] = 0xA4506CEB
    ecdsa_sha_k[62] = 0xBEF9A3F7
    ecdsa_sha_k[63] = 0xC67178F2


def ecdsa_init():
    # Initialise the SHA-256 K table. Idempotent; safe to call more
    # than once. The test fixture and the kernel both call it once at
    # startup.
    _ecdsa_sha_init_k()


def _ecdsa_rotr32(v: uint32, n: uint64) -> uint32:
    x: uint64 = cast[uint64](v) & 0xFFFFFFFF
    lo: uint64 = x >> n
    hi: uint64 = (x << (32 - n)) & 0xFFFFFFFF
    return cast[uint32](lo | hi)


def _ecdsa_sha_compress(block_ptr: Ptr[uint8]):
    # Expand 16 BE words -> 64 words, run 64 rounds, fold into state.
    i: uint64 = 0
    while i < 16:
        b0: uint32 = cast[uint32](block_ptr[i * 4 + 0])
        b1: uint32 = cast[uint32](block_ptr[i * 4 + 1])
        b2: uint32 = cast[uint32](block_ptr[i * 4 + 2])
        b3: uint32 = cast[uint32](block_ptr[i * 4 + 3])
        ecdsa_sha_w[i] = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
        i = i + 1
    while i < 64:
        s0: uint32 = _ecdsa_rotr32(ecdsa_sha_w[i - 15], 7) \
            ^ _ecdsa_rotr32(ecdsa_sha_w[i - 15], 18) \
            ^ (ecdsa_sha_w[i - 15] >> 3)
        s1: uint32 = _ecdsa_rotr32(ecdsa_sha_w[i - 2], 17) \
            ^ _ecdsa_rotr32(ecdsa_sha_w[i - 2], 19) \
            ^ (ecdsa_sha_w[i - 2] >> 10)
        sum_v: uint64 = (cast[uint64](ecdsa_sha_w[i - 16]) & 0xFFFFFFFF) \
            + (cast[uint64](s0) & 0xFFFFFFFF) \
            + (cast[uint64](ecdsa_sha_w[i - 7]) & 0xFFFFFFFF) \
            + (cast[uint64](s1) & 0xFFFFFFFF)
        ecdsa_sha_w[i] = cast[uint32](sum_v & 0xFFFFFFFF)
        i = i + 1

    i = 0
    while i < 8:
        ecdsa_sha_state_scratch[i] = ecdsa_sha_state[i]
        i = i + 1
    a: uint32 = ecdsa_sha_state_scratch[0]
    b: uint32 = ecdsa_sha_state_scratch[1]
    c: uint32 = ecdsa_sha_state_scratch[2]
    d: uint32 = ecdsa_sha_state_scratch[3]
    e: uint32 = ecdsa_sha_state_scratch[4]
    f: uint32 = ecdsa_sha_state_scratch[5]
    g: uint32 = ecdsa_sha_state_scratch[6]
    h: uint32 = ecdsa_sha_state_scratch[7]
    i = 0
    while i < 64:
        S1: uint32 = _ecdsa_rotr32(e, 6) ^ _ecdsa_rotr32(e, 11) \
            ^ _ecdsa_rotr32(e, 25)
        ch: uint32 = (e & f) ^ ((~e) & g)
        t1_64: uint64 = (cast[uint64](h) & 0xFFFFFFFF) \
            + (cast[uint64](S1) & 0xFFFFFFFF) \
            + (cast[uint64](ch) & 0xFFFFFFFF) \
            + (cast[uint64](ecdsa_sha_k[i]) & 0xFFFFFFFF) \
            + (cast[uint64](ecdsa_sha_w[i]) & 0xFFFFFFFF)
        t1: uint32 = cast[uint32](t1_64 & 0xFFFFFFFF)
        S0: uint32 = _ecdsa_rotr32(a, 2) ^ _ecdsa_rotr32(a, 13) \
            ^ _ecdsa_rotr32(a, 22)
        maj: uint32 = (a & b) ^ (a & c) ^ (b & c)
        t2_64: uint64 = (cast[uint64](S0) & 0xFFFFFFFF) \
            + (cast[uint64](maj) & 0xFFFFFFFF)
        t2: uint32 = cast[uint32](t2_64 & 0xFFFFFFFF)
        h = g
        g = f
        f = e
        d64: uint64 = (cast[uint64](d) & 0xFFFFFFFF) \
            + (cast[uint64](t1) & 0xFFFFFFFF)
        e = cast[uint32](d64 & 0xFFFFFFFF)
        d = c
        c = b
        b = a
        a64: uint64 = (cast[uint64](t1) & 0xFFFFFFFF) \
            + (cast[uint64](t2) & 0xFFFFFFFF)
        a = cast[uint32](a64 & 0xFFFFFFFF)
        i = i + 1
    sum_v0: uint64 = (cast[uint64](ecdsa_sha_state[0]) + cast[uint64](a))
    sum_v1: uint64 = (cast[uint64](ecdsa_sha_state[1]) + cast[uint64](b))
    sum_v2: uint64 = (cast[uint64](ecdsa_sha_state[2]) + cast[uint64](c))
    sum_v3: uint64 = (cast[uint64](ecdsa_sha_state[3]) + cast[uint64](d))
    sum_v4: uint64 = (cast[uint64](ecdsa_sha_state[4]) + cast[uint64](e))
    sum_v5: uint64 = (cast[uint64](ecdsa_sha_state[5]) + cast[uint64](f))
    sum_v6: uint64 = (cast[uint64](ecdsa_sha_state[6]) + cast[uint64](g))
    sum_v7: uint64 = (cast[uint64](ecdsa_sha_state[7]) + cast[uint64](h))
    ecdsa_sha_state[0] = cast[uint32](sum_v0 & 0xFFFFFFFF)
    ecdsa_sha_state[1] = cast[uint32](sum_v1 & 0xFFFFFFFF)
    ecdsa_sha_state[2] = cast[uint32](sum_v2 & 0xFFFFFFFF)
    ecdsa_sha_state[3] = cast[uint32](sum_v3 & 0xFFFFFFFF)
    ecdsa_sha_state[4] = cast[uint32](sum_v4 & 0xFFFFFFFF)
    ecdsa_sha_state[5] = cast[uint32](sum_v5 & 0xFFFFFFFF)
    ecdsa_sha_state[6] = cast[uint32](sum_v6 & 0xFFFFFFFF)
    ecdsa_sha_state[7] = cast[uint32](sum_v7 & 0xFFFFFFFF)


def _ecdsa_sha_reset():
    ecdsa_sha_state[0] = 0x6A09E667
    ecdsa_sha_state[1] = 0xBB67AE85
    ecdsa_sha_state[2] = 0x3C6EF372
    ecdsa_sha_state[3] = 0xA54FF53A
    ecdsa_sha_state[4] = 0x510E527F
    ecdsa_sha_state[5] = 0x9B05688C
    ecdsa_sha_state[6] = 0x1F83D9AB
    ecdsa_sha_state[7] = 0x5BE0CD19
    ecdsa_sha_buflen = 0
    ecdsa_sha_total_bits = 0


def _ecdsa_sha_update(data: Ptr[uint8], n: uint64):
    block_ptr: Ptr[uint8] = cast[Ptr[uint8]](&ecdsa_sha_buf[0])
    pos: uint64 = 0
    while pos < n:
        room: uint64 = 64 - ecdsa_sha_buflen
        take: uint64 = n - pos
        if take > room:
            take = room
        i: uint64 = 0
        while i < take:
            ecdsa_sha_buf[ecdsa_sha_buflen + i] = data[pos + i]
            i = i + 1
        ecdsa_sha_buflen = ecdsa_sha_buflen + take
        pos = pos + take
        if ecdsa_sha_buflen == 64:
            _ecdsa_sha_compress(block_ptr)
            ecdsa_sha_buflen = 0
    ecdsa_sha_total_bits = ecdsa_sha_total_bits + n * 8


def _ecdsa_sha_finish_into(out_hash: Ptr[uint8]):
    block_ptr: Ptr[uint8] = cast[Ptr[uint8]](&ecdsa_sha_buf[0])
    saved_bits: uint64 = ecdsa_sha_total_bits
    ecdsa_sha_buf[ecdsa_sha_buflen] = 0x80
    ecdsa_sha_buflen = ecdsa_sha_buflen + 1
    if ecdsa_sha_buflen > 56:
        while ecdsa_sha_buflen < 64:
            ecdsa_sha_buf[ecdsa_sha_buflen] = 0
            ecdsa_sha_buflen = ecdsa_sha_buflen + 1
        _ecdsa_sha_compress(block_ptr)
        ecdsa_sha_buflen = 0
    while ecdsa_sha_buflen < 56:
        ecdsa_sha_buf[ecdsa_sha_buflen] = 0
        ecdsa_sha_buflen = ecdsa_sha_buflen + 1
    i: uint64 = 0
    while i < 8:
        shift: uint64 = (7 - i) * 8
        ecdsa_sha_buf[56 + i] = cast[uint8]((saved_bits >> shift) & 0xFF)
        i = i + 1
    _ecdsa_sha_compress(block_ptr)
    i = 0
    while i < 8:
        w: uint32 = ecdsa_sha_state[i]
        out_hash[i * 4 + 0] = cast[uint8]((w >> 24) & 0xFF)
        out_hash[i * 4 + 1] = cast[uint8]((w >> 16) & 0xFF)
        out_hash[i * 4 + 2] = cast[uint8]((w >> 8) & 0xFF)
        out_hash[i * 4 + 3] = cast[uint8](w & 0xFF)
        i = i + 1


def ecdsa_sha256(data: Ptr[uint8], n: uint64, out_hash: Ptr[uint8]):
    # One-shot SHA-256 over `n` bytes at `data`; emit 32 bytes at out_hash.
    _ecdsa_sha_reset()
    _ecdsa_sha_update(data, n)
    _ecdsa_sha_finish_into(out_hash)


# -- pubkey parse ----------------------------------------------------------
#
# An ECDSA P-256 SPKI subjectPublicKey value (per RFC 5480) is the
# SEC1 uncompressed encoding:
#   0x04 || X (32 BE bytes) || Y (32 BE bytes)
# Total 65 bytes. V1's x509_parse hands us exactly these bytes via
# X509Cert.pubkey_bytes / pubkey_bytes_len.

def ecdsa_parse_pubkey(spki_bytes: Ptr[uint8], spki_len: uint64,
                       out: Ptr[EcdsaPubkey]) -> int32:
    if spki_len != 65:
        return -1
    if spki_bytes[0] != 0x04:
        return -1
    rc: int32 = p256_be_to_limbs(&out[0].point.x[0],
                                 &spki_bytes[1], cast[uint64](32))
    if rc != 0:
        return -1
    rc = p256_be_to_limbs(&out[0].point.y[0],
                          &spki_bytes[33], cast[uint64](32))
    if rc != 0:
        return -1
    out[0].point.infinity = 0
    return 0


# -- signature parse helpers ----------------------------------------------
#
# An ECDSA signature on the wire (and inside the X.509 BIT STRING) is
# a DER `SEQUENCE { r INTEGER, s INTEGER }`. INTEGER bodies are signed
# big-endian and may carry a leading 0x00 sign-extension byte when the
# top bit of r/s would otherwise look negative. We strip that byte and
# also reject any value that's wider than 32 bytes (would overflow n).

def _ecdsa_strip_leading_zero(buf: Ptr[uint8], n: uint64,
                              out_ptr: Ptr[Ptr[uint8]],
                              out_len: Ptr[uint64]) -> int32:
    # If buf[0] == 0 and n > 1, treat as sign-extension prefix; strip it.
    if n == 0:
        return -1
    if n > 1:
        if buf[0] == 0:
            out_ptr[0] = &buf[1]
            out_len[0] = n - 1
            return 0
    out_ptr[0] = buf
    out_len[0] = n
    return 0


# -- ecdsa_p256_verify_rs -------------------------------------------------
#
# Verify an ECDSA-P256 signature given r and s DIRECTLY as 32-byte
# big-endian scalars — no DER wrapper. SSH (RFC 5656) carries the
# signature as `mpint r || mpint s` inside a string blob, not as the
# DER `SEQUENCE { r, s }` that ecdsa_p256_verify expects; this entry
# point lets the SSH publickey-auth path verify a client signature
# without first re-encoding it as DER.
#
# This is the cryptographic core of FIPS 186-4 §6.4.2 (steps 2..8);
# ecdsa_p256_verify decodes the DER wrapper and then calls straight
# into here.
#
# Returns: 1 valid, 0 invalid (well-formed but cryptographically
# wrong), -1 malformed (r or s out of [1, n-1]).

def ecdsa_p256_verify_rs(pubkey: Ptr[EcdsaPubkey],
                         message: Ptr[uint8], msg_len: uint64,
                         r_be: Ptr[uint8], s_be: Ptr[uint8]) -> int32:
    r: Array[4, uint64]
    if p256_be_to_limbs(&r[0], r_be, cast[uint64](32)) != 0:
        return -1
    s: Array[4, uint64]
    if p256_be_to_limbs(&s[0], s_be, cast[uint64](32)) != 0:
        return -1

    # 2. Range checks: r, s in [1, n-1].
    if sn_in_range(&r[0]) == 0:
        return -1
    if sn_in_range(&s[0]) == 0:
        return -1

    # 3. e = SHA-256(message), folded into [0, n) by one subtraction.
    hash_buf: Array[32, uint8]
    ecdsa_sha256(message, msg_len, &hash_buf[0])
    e: Array[4, uint64]
    if p256_be_to_limbs(&e[0], &hash_buf[0], cast[uint64](32)) != 0:
        return -1
    if p256_ge(&e[0], &P256_N[0]) != 0:
        e_minus_n: Array[4, uint64]
        i: uint64 = 0
        borrow: uint64 = 0
        while i < 4:
            ei: uint64 = e[i]
            ni: uint64 = P256_N[i]
            d: uint64 = ei - ni
            b1: uint64 = 0
            if ei < ni:
                b1 = 1
            d2: uint64 = d - borrow
            b2: uint64 = 0
            if d < borrow:
                b2 = 1
            e_minus_n[i] = d2
            borrow = b1 + b2
            i = i + 1
        p256_copy(&e[0], &e_minus_n[0])

    # 4. w = s^{-1} mod n.
    w: Array[4, uint64]
    sn_inv(&w[0], &s[0])

    # 5. u1 = e*w mod n, u2 = r*w mod n.
    u1: Array[4, uint64]
    sn_mul(&u1[0], &e[0], &w[0])
    u2: Array[4, uint64]
    sn_mul(&u2[0], &r[0], &w[0])

    # 6. R = u1*G + u2*Q.
    pt1: P256Point
    p256_scalar_mul_g(&pt1, &u1[0])
    pt2: P256Point
    p256_scalar_mul(&pt2, &u2[0], &pubkey[0].point)
    R: P256Point
    p256_add(&R, &pt1, &pt2)

    # 7. Reject if R is the point at infinity.
    if R.infinity != 0:
        return 0

    # 8. v = R.x mod n. Valid iff v == r.
    v: Array[4, uint64]
    p256_copy(&v[0], &R.x[0])
    if p256_ge(&v[0], &P256_N[0]) != 0:
        v_minus_n: Array[4, uint64]
        i2: uint64 = 0
        borrow2: uint64 = 0
        while i2 < 4:
            vi: uint64 = v[i2]
            ni2: uint64 = P256_N[i2]
            d: uint64 = vi - ni2
            b1: uint64 = 0
            if vi < ni2:
                b1 = 1
            d2: uint64 = d - borrow2
            b2: uint64 = 0
            if d < borrow2:
                b2 = 1
            v_minus_n[i2] = d2
            borrow2 = b1 + b2
            i2 = i2 + 1
        p256_copy(&v[0], &v_minus_n[0])

    if p256_eq(&v[0], &r[0]) != 0:
        return 1
    return 0


# -- ecdsa_p256_verify ----------------------------------------------------
#
# Returns: 1 valid, 0 invalid (well-formed but cryptographically wrong),
# -1 malformed (DER decode failure or out-of-range integers).

def ecdsa_p256_verify(pubkey: Ptr[EcdsaPubkey],
                      message: Ptr[uint8], msg_len: uint64,
                      signature: Ptr[uint8], sig_len: uint64) -> int32:
    # 1. Decode DER signature SEQUENCE { r INTEGER, s INTEGER }.
    sig_cur: Asn1Cursor
    asn1_cursor_init(&sig_cur, signature, sig_len)
    sig_seq: Asn1Cursor
    rc: int32 = asn1_read_sequence(&sig_cur, &sig_seq)
    if rc != 0:
        return -1

    r_raw: Array[40, uint8]
    r_raw_len: uint64 = 0
    n_r: int64 = asn1_read_integer(&sig_seq, &r_raw[0], &r_raw_len,
                                   cast[uint64](40))
    if n_r < cast[int64](0):
        return -1

    s_raw: Array[40, uint8]
    s_raw_len: uint64 = 0
    n_s: int64 = asn1_read_integer(&sig_seq, &s_raw[0], &s_raw_len,
                                   cast[uint64](40))
    if n_s < cast[int64](0):
        return -1

    # Strip the optional leading 0x00 sign-extension byte from each
    # INTEGER, then bail if either value is wider than 32 bytes (the
    # field width — anything longer cannot encode a valid scalar in n).
    r_bytes: Ptr[uint8] = &r_raw[0]
    r_len: uint64 = 0
    rc = _ecdsa_strip_leading_zero(&r_raw[0], r_raw_len, &r_bytes, &r_len)
    if rc != 0:
        return -1
    if r_len > 32:
        return -1

    s_bytes: Ptr[uint8] = &s_raw[0]
    s_len: uint64 = 0
    rc = _ecdsa_strip_leading_zero(&s_raw[0], s_raw_len, &s_bytes, &s_len)
    if rc != 0:
        return -1
    if s_len > 32:
        return -1

    # Left-pad the (already sign-extension-stripped) r and s into fixed
    # 32-byte big-endian buffers, then hand off to the shared verify
    # core. r_len / s_len are guaranteed <= 32 by the checks above.
    r_be: Array[32, uint8]
    s_be: Array[32, uint8]
    i: uint64 = 0
    while i < 32:
        r_be[i] = 0
        s_be[i] = 0
        i = i + 1
    i = 0
    while i < r_len:
        r_be[32 - r_len + i] = r_bytes[i]
        i = i + 1
    i = 0
    while i < s_len:
        s_be[32 - s_len + i] = s_bytes[i]
        i = i + 1
    return ecdsa_p256_verify_rs(pubkey, message, msg_len,
                                &r_be[0], &s_be[0])

# lib/dropplace.ad — PURE, extern-free helpers for drag-drop PLACEMENT of a
# launcher dragged out of the Applications menu (#327).
#
# WHY THIS FILE EXISTS
# ====================
# Dragging an app out of the Applications menu must drop it WHERE YOU RELEASE
# — as a panel launcher at the drop X, or as a desktop .desktop icon at the
# drop point — NOT snap it to a fixed spot next to the Apps button. The drag
# SOURCE (hamappmenu, a separate window) cannot see the release: the kernel
# compositor (devwsys) routes pointer motion/release ONLY to the window under
# the cursor (window-local coords, no cross-window button-grab). So the drop
# location can only be known by the RECEIVER — the panel or the desktop — from
# its OWN button-release event, in its OWN local coordinates. These helpers are
# the coordinate→placement math the receivers run on that release.
#
# It is PURE (no `extern`, no I/O, no imports): it operates only on
# caller-supplied buffers/arrays. So it links into BOTH the x86_64-adder-user
# (the live panel + desktop clients) target AND the x86_64-linux host gate
# (tests/dropplace_host.ad) unchanged — the drop-placement is proven
# DETERMINISTICALLY on the host in milliseconds, without a flaky live mouse
# drag over /dev/mouse.


# Panel: the flow-axis insertion index for a launcher DROPPED at coordinate
# `flow` (window-local X for a horizontal panel, Y for a vertical one). We
# insert BEFORE the first widget whose start (wx0[a]) is past `flow`; a drop
# past every widget appends at the end (returns n). This is what makes the
# launcher land at the DROP LOCATION: a drop near the left lands at a low
# index, a drop at the far right appends — never a fixed "index 1 next to the
# Apps button" spot. `wx0` holds the n laid-out widget start coordinates.
def dp_panel_insert_index(flow: int64, wx0: Ptr[int64], n: uint64) -> int64:
    a: uint64 = 0
    while a < n:
        if flow < wx0[a]:
            return cast[int64](a)
        a = a + 1
    return cast[int64](n)


# Panel: the flow-axis BOUNDARY coordinate at which to draw the LIVE DROP
# PREVIEW insertion indicator for a drag hovering at `flow`. This is the visual
# twin of dp_panel_insert_index: it resolves the same insertion index, then
# returns the coordinate midway between the two widgets the launcher would land
# between (or a sensible edge coordinate at the ends), so the preview caret sits
# exactly where the committed launcher will go. `wx0`/`wx1` are the n laid-out
# widget start/end coordinates. Empty bar -> a small left margin.
def dp_panel_insert_boundary(flow: int64, wx0: Ptr[int64], wx1: Ptr[int64],
                             n: uint64) -> int64:
    if n == 0:
        return 4
    at: int64 = dp_panel_insert_index(flow, wx0, n)
    if at <= 0:
        b: int64 = wx0[0] - 3
        if b < 1:
            b = 1
        return b
    if at >= cast[int64](n):
        return wx1[n - 1] + 2
    return (wx1[cast[uint64](at) - 1] + wx0[cast[uint64](at)]) / 2


# Desktop: build a minimal, well-formed freedesktop `.desktop` launcher body
# for an app dropped onto the desktop. `name` and `exec` are NUL-terminated.
# Writes `[Desktop Entry]\nName=<name>\nExec=<exec>\nType=Application\n` into
# `out` and returns the byte length. The desktop client writes this to
# ~/Desktop/<name>.desktop so the icon persists + re-scans like any launcher;
# the drop POINT is pinned separately (ic_x/ic_y + the position sidecar).
def _dp_put(out: Ptr[uint8], p: uint64, s: Ptr[uint8]) -> uint64:
    k: uint64 = 0
    while s[k] != 0:
        out[p] = s[k]
        p = p + 1
        k = k + 1
    return p


def dp_desktop_entry(out: Ptr[uint8], name: Ptr[uint8],
                     exec: Ptr[uint8]) -> uint64:
    p: uint64 = 0
    p = _dp_put(out, p, cast[Ptr[uint8]]("[Desktop Entry]\n"))
    p = _dp_put(out, p, cast[Ptr[uint8]]("Name="))
    p = _dp_put(out, p, name)
    out[p] = 10
    p = p + 1
    p = _dp_put(out, p, cast[Ptr[uint8]]("Exec="))
    p = _dp_put(out, p, exec)
    out[p] = 10
    p = p + 1
    p = _dp_put(out, p, cast[Ptr[uint8]]("Type=Application\n"))
    return p

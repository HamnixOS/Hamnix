# lib/hamcalcore.ad — PURE, extern-free core for the unified Calendar app.
#
# A month-grid calendar with:
#   * a title (Month YYYY) with prev/next arrows + a Today button,
#   * a weekday header row (Su Mo Tu We Th Fr Sa),
#   * a 6x7 grid of day cells with TODAY highlighted (blue) and the SELECTED
#     day outlined (orange); the leading/trailing blank cells are filled with
#     the ADJACENT month's spill-over days drawn dimmed (grey) — clicking one
#     flips to that month and selects it,
#   * a RELATIVE-TIME readout for the selected day ("today" / "N days ago" /
#     "in N days"), computed from a correct civil-days diff (days_from_civil,
#     Howard Hinnant — NO 365.25 approximation), and
#   * a STOPWATCH (Start / Stop / Reset) showing MM:SS.cc.
#
# All calendar math (days-in-month, leap years, day-of-week, the civil<->days
# conversions) is integer arithmetic here — no clock, no syscalls — so this
# module links into BOTH the native (x86_64-adder-user) and host (x86_64-linux)
# targets and renders deterministically for the host PNG gate.
#
# The DRIVER supplies "today" via hamcal_set_today() (derived from the real
# clock) and the current jiffies via hamcal_set_now() (for the stopwatch); the
# core owns all state and geometry. This is the SINGLE calendar app both the
# app-menu ("Calendar" -> /bin/hamcalscene) and the panel-clock click open.
#
# ARROW KEYS (decoded from CSI ESC '[' A/B/C/D):
#   Left  = selection - 1 day     Right = selection + 1 day
#   Up    = selection - 7 days    Down  = selection + 7 days
# Moving the selection past a month boundary flips the visible month.

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_stroke, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_roundrect, hamscene_headerbar


# ---- tiny pure helpers (module-scoped; each core keeps its own) ----------
def _cal_slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _cal_u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# ---- calendar math -------------------------------------------------------
def _is_leap(y: uint64) -> int32:
    if y % 400 == 0:
        return 1
    if y % 100 == 0:
        return 0
    if y % 4 == 0:
        return 1
    return 0


def _days_in_month(y: uint64, m: uint64) -> uint64:
    if m == 2:
        if _is_leap(y) != 0:
            return 29
        return 28
    if m == 4 or m == 6 or m == 9 or m == 11:
        return 30
    return 31


# Days since 1970-01-01 for the given civil date (Howard Hinnant's
# days_from_civil), valid for y >= 1970 (result >= 0). Signed so callers can
# subtract two dates and get a signed day difference.
def _days_from_civil(y: uint64, m: uint64, d: uint64) -> int64:
    yy: uint64 = y
    if m <= 2:
        yy = yy - 1
    era: uint64 = yy / 400
    yoe: uint64 = yy - era * 400
    mp: uint64 = m + 9
    if m > 2:
        mp = m - 3
    doy: uint64 = (153 * mp + 2) / 5 + d - 1
    doe: uint64 = yoe * 365 + yoe / 4 - yoe / 100 + doy
    return cast[int64](era * 146097 + doe) - 719468


# Weekday (0=Sun .. 6=Sat) of the given civil date, valid for y >= 1970.
# 1970-01-01 was a Thursday, so (days + 4) % 7 with 0=Sunday.
def _weekday(y: uint64, m: uint64, d: uint64) -> uint64:
    dd: int64 = _days_from_civil(y, m, d)
    r: int64 = (dd + 4) % 7
    if r < 0:
        r = r + 7
    return cast[uint64](r)


def _mon_full(m: uint64) -> Ptr[uint8]:
    if m == 1:
        return cast[Ptr[uint8]]("January")
    if m == 2:
        return cast[Ptr[uint8]]("February")
    if m == 3:
        return cast[Ptr[uint8]]("March")
    if m == 4:
        return cast[Ptr[uint8]]("April")
    if m == 5:
        return cast[Ptr[uint8]]("May")
    if m == 6:
        return cast[Ptr[uint8]]("June")
    if m == 7:
        return cast[Ptr[uint8]]("July")
    if m == 8:
        return cast[Ptr[uint8]]("August")
    if m == 9:
        return cast[Ptr[uint8]]("September")
    if m == 10:
        return cast[Ptr[uint8]]("October")
    if m == 11:
        return cast[Ptr[uint8]]("November")
    return cast[Ptr[uint8]]("December")


# ---- state ---------------------------------------------------------------
cal_y:  uint64 = 2026            # visible month's year
cal_m:  uint64 = 1              # visible month (1..12)
today_y: uint64 = 0
today_m: uint64 = 0
today_d: uint64 = 0
sel_y:  uint64 = 0              # selected day (0 = none)
sel_m:  uint64 = 0
sel_d:  uint64 = 0

# stopwatch (jiffies @ ~100Hz supplied by the driver via hamcal_set_now)
cur_now:    uint64 = 0
sw_running: int32  = 0
sw_start:   uint64 = 0
sw_accum:   uint64 = 0

# live uptime-since-boot (nanoseconds) supplied by the driver via
# hamcal_set_uptime(); rendered as an H:MM:SS clock line (the superset of the
# retired /bin/hamclock's "Uptime clock (H:MM:SS since boot)" readout).
cur_uptime_ns: uint64 = 0

# CSI arrow-key decode state: 0 ground, 1 saw ESC, 2 saw ESC '['
_key_st: int32 = 0


def hamcal_set_today(y: uint64, m: uint64, d: uint64):
    today_y = y
    today_m = m
    today_d = d
    cal_y = y
    cal_m = m
    # Default the selection to today so the readout shows "today" at startup.
    sel_y = y
    sel_m = m
    sel_d = d


def hamcal_set_now(j: uint64):
    cur_now = j


def hamcal_set_uptime(ns: uint64):
    cur_uptime_ns = ns


def hamcal_year() -> uint64:
    return cal_y


def hamcal_month() -> uint64:
    return cal_m


def hamcal_sel_year() -> uint64:
    return sel_y


def hamcal_sel_month() -> uint64:
    return sel_m


def hamcal_sel_day() -> uint64:
    return sel_d


def hamcal_prev_month():
    if cal_m <= 1:
        cal_m = 12
        cal_y = cal_y - 1
    else:
        cal_m = cal_m - 1


def hamcal_next_month():
    if cal_m >= 12:
        cal_m = 1
        cal_y = cal_y + 1
    else:
        cal_m = cal_m + 1


def hamcal_today():
    # Jump the view back to today AND select today.
    cal_y = today_y
    cal_m = today_m
    sel_y = today_y
    sel_m = today_m
    sel_d = today_d


# ---- stopwatch -----------------------------------------------------------
def hamcal_sw_elapsed() -> uint64:
    e: uint64 = sw_accum
    if sw_running != 0:
        if cur_now >= sw_start:
            e = e + (cur_now - sw_start)
    return e


def hamcal_sw_running() -> int32:
    return sw_running


def _sw_start():
    if sw_running == 0:
        sw_start = cur_now
        sw_running = 1


def _sw_stop():
    if sw_running != 0:
        if cur_now >= sw_start:
            sw_accum = sw_accum + (cur_now - sw_start)
        sw_running = 0


def _sw_reset():
    sw_running = 0
    sw_start = 0
    sw_accum = 0


# ---- selection movement (arrow keys) -------------------------------------
def _sel_step_fwd():
    dim: uint64 = _days_in_month(sel_y, sel_m)
    if sel_d >= dim:
        sel_d = 1
        if sel_m >= 12:
            sel_m = 1
            sel_y = sel_y + 1
        else:
            sel_m = sel_m + 1
    else:
        sel_d = sel_d + 1


def _sel_step_back():
    if sel_d <= 1:
        if sel_m <= 1:
            sel_m = 12
            sel_y = sel_y - 1
        else:
            sel_m = sel_m - 1
        sel_d = _days_in_month(sel_y, sel_m)
    else:
        sel_d = sel_d - 1


def _sel_add(delta: int32):
    if sel_d == 0:
        # nothing selected yet: anchor on today
        sel_y = today_y
        sel_m = today_m
        sel_d = today_d
    n: int32 = delta
    while n > 0:
        _sel_step_fwd()
        n = n - 1
    while n < 0:
        _sel_step_back()
        n = n + 1
    # follow the selection into its month
    cal_y = sel_y
    cal_m = sel_m


# ---- layout --------------------------------------------------------------
WIN_W: int32 = 236
WIN_H: int32 = 366
GRID_X: int32 = 6
GRID_Y: int32 = 76
CELL_W: int32 = 32
CELL_H: int32 = 26
PREV_X: int32 = 8
NEXT_X: int32 = 204
NAV_Y: int32 = 34
NAV_W: int32 = 24
NAV_H: int32 = 22
TODAY_X: int32 = 160
TODAY_Y: int32 = 236
TODAY_W: int32 = 68
TODAY_H: int32 = 20
READ_Y: int32 = 238            # "Selected YYYY-MM-DD"
REL_Y:  int32 = 256            # relative-time phrase
SEP_Y:  int32 = 278            # separator rule
SW_LBL_Y: int32 = 284         # "Stopwatch" label + value
SW_BTN_Y: int32 = 306         # Start / Stop / Reset row
SW_BTN_H: int32 = 26
SW_START_X: int32 = 8
SW_STOP_X:  int32 = 84
SW_RESET_X: int32 = 160
SW_BTN_W: int32 = 68
UPTIME_Y: int32 = 340          # live "Uptime  H:MM:SS since boot" clock line


def _wday_hdr(c: uint64) -> Ptr[uint8]:
    if c == 0:
        return cast[Ptr[uint8]]("Su")
    if c == 1:
        return cast[Ptr[uint8]]("Mo")
    if c == 2:
        return cast[Ptr[uint8]]("Tu")
    if c == 3:
        return cast[Ptr[uint8]]("We")
    if c == 4:
        return cast[Ptr[uint8]]("Th")
    if c == 5:
        return cast[Ptr[uint8]]("Fr")
    return cast[Ptr[uint8]]("Sa")


# The month/year immediately BEFORE the visible one (for leading spill days).
def _prev_ym(oy: Ptr[uint64], om: Ptr[uint64]):
    if cal_m <= 1:
        om[0] = 12
        oy[0] = cal_y - 1
    else:
        om[0] = cal_m - 1
        oy[0] = cal_y


# The month/year immediately AFTER the visible one (for trailing spill days).
def _next_ym(oy: Ptr[uint64], om: Ptr[uint64]):
    if cal_m >= 12:
        om[0] = 1
        oy[0] = cal_y + 1
    else:
        om[0] = cal_m + 1
        oy[0] = cal_y


# Draw a dimmed (grey) day number in the cell at (col,row) — used for the
# adjacent-month spill-over days that fill the grid's leading/trailing blanks.
def _draw_dim_day(col: uint64, row: uint64, d: uint64):
    cx: int32 = GRID_X + cast[int32](col) * CELL_W
    cyy: int32 = GRID_Y + cast[int32](row) * CELL_H
    dbuf: Array[4, uint8]
    dn: uint64 = _cal_u64_to_dec(d, &dbuf[0])
    dbuf[dn] = 0
    offx: int32 = 10
    if d >= 10:
        offx = 6
    hamscene_glyphs(cx + offx, cyy + 5, &dbuf[0], cast[Ptr[uint8]]("#a8acb0"))


# ---- text builders for the readouts --------------------------------------
def _put_str(buf: Ptr[uint8], pos: uint64, s: Ptr[uint8]) -> uint64:
    p: uint64 = pos
    k: uint64 = 0
    while s[k] != 0:
        buf[p] = s[k]
        p = p + 1
        k = k + 1
    return p


# "Selected YYYY-MM-DD" (or "No date selected") into buf; returns length.
def _build_seldate(buf: Ptr[uint8]) -> uint64:
    if sel_d == 0:
        p: uint64 = _put_str(buf, 0, cast[Ptr[uint8]]("No date selected"))
        buf[p] = 0
        return p
    p2: uint64 = _put_str(buf, 0, cast[Ptr[uint8]]("Selected "))
    p2 = p2 + _cal_u64_to_dec(sel_y, &buf[p2])
    buf[p2] = 45                                        # '-'
    p2 = p2 + 1
    if sel_m < 10:
        buf[p2] = 48
        p2 = p2 + 1
    p2 = p2 + _cal_u64_to_dec(sel_m, &buf[p2])
    buf[p2] = 45                                        # '-'
    p2 = p2 + 1
    if sel_d < 10:
        buf[p2] = 48
        p2 = p2 + 1
    p2 = p2 + _cal_u64_to_dec(sel_d, &buf[p2])
    buf[p2] = 0
    return p2


# Relative-time phrase for the selected day vs today into buf; returns length.
#   diff == 0 -> "today"
#   diff <  0 -> "N day(s) ago"
#   diff >  0 -> "in N day(s)"
def _build_relative(buf: Ptr[uint8]) -> uint64:
    if sel_d == 0 or today_d == 0:
        buf[0] = 0
        return 0
    diff: int64 = _days_from_civil(sel_y, sel_m, sel_d) \
        - _days_from_civil(today_y, today_m, today_d)
    if diff == 0:
        p: uint64 = _put_str(buf, 0, cast[Ptr[uint8]]("today"))
        buf[p] = 0
        return p
    n: uint64 = 0
    ahead: int32 = 0
    if diff > 0:
        ahead = 1
        n = cast[uint64](diff)
    else:
        n = cast[uint64](0 - diff)
    p2: uint64 = 0
    if ahead != 0:
        p2 = _put_str(buf, p2, cast[Ptr[uint8]]("in "))
    p2 = p2 + _cal_u64_to_dec(n, &buf[p2])
    if n == 1:
        p2 = _put_str(buf, p2, cast[Ptr[uint8]](" day"))
    else:
        p2 = _put_str(buf, p2, cast[Ptr[uint8]](" days"))
    if ahead == 0:
        p2 = _put_str(buf, p2, cast[Ptr[uint8]](" ago"))
    buf[p2] = 0
    return p2


# "MM:SS.cc" from the stopwatch elapsed jiffies into buf; returns length.
def _build_sw(buf: Ptr[uint8]) -> uint64:
    e: uint64 = hamcal_sw_elapsed()
    total_sec: uint64 = e / 100
    cc: uint64 = e % 100
    mins: uint64 = total_sec / 60
    secs: uint64 = total_sec % 60
    if mins > 99:
        mins = 99
    buf[0] = cast[uint8]((mins / 10) % 10) + 48
    buf[1] = cast[uint8](mins % 10) + 48
    buf[2] = 58                                          # ':'
    buf[3] = cast[uint8]((secs / 10) % 10) + 48
    buf[4] = cast[uint8](secs % 10) + 48
    buf[5] = 46                                          # '.'
    buf[6] = cast[uint8]((cc / 10) % 10) + 48
    buf[7] = cast[uint8](cc % 10) + 48
    buf[8] = 0
    return 8


# "H:MM:SS" from the live uptime (nanoseconds since boot) into buf; returns
# length. Hours are un-padded (grow past 9h without clipping); MM and SS are
# always two digits.
def _build_uptime(buf: Ptr[uint8]) -> uint64:
    total_sec: uint64 = cur_uptime_ns / 1000000000
    hrs:  uint64 = total_sec / 3600
    mins: uint64 = (total_sec / 60) % 60
    secs: uint64 = total_sec % 60
    p: uint64 = _cal_u64_to_dec(hrs, buf)
    buf[p] = 58                                          # ':'
    p = p + 1
    buf[p] = cast[uint8]((mins / 10) % 10) + 48
    buf[p + 1] = cast[uint8](mins % 10) + 48
    buf[p + 2] = 58                                      # ':'
    buf[p + 3] = cast[uint8]((secs / 10) % 10) + 48
    buf[p + 4] = cast[uint8](secs % 10) + 48
    p = p + 5
    buf[p] = 0
    return p


# ---- scene ---------------------------------------------------------------
def _btn(x: int32, y: int32, w: int32, h: int32, label: Ptr[uint8],
         fg: Ptr[uint8]):
    # Rounded flat button: hairline border ring + inset neutral face.
    hamscene_roundrect(x, y, w, h, 4, cast[Ptr[uint8]]("#808080"))
    hamscene_roundrect(x + 1, y + 1, w - 2, h - 2, 3,
                       cast[Ptr[uint8]]("#e6e8ec"))
    lw: int32 = cast[int32](_cal_slen(label)) * 8
    lx: int32 = x + (w - lw) / 2
    hamscene_glyphs(lx, y + 4, label, fg)


def hamcal_build_scene():
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    hamscene_begin()
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#eceef2"))
    # Cohesive cool-blue gradient headerbar (matches the compositor SSD
    # titlebar family + the sibling scene apps), with its own raised seam.
    hamscene_headerbar(0, 0, WIN_W, 26)
    hamscene_glyphs(10, 8, cast[Ptr[uint8]]("Calendar"),
                    cast[Ptr[uint8]]("#ffffff"))

    # --- title row: < Month YYYY > ---
    hamscene_stroke(PREV_X, NAV_Y, NAV_W, NAV_H, 1, cast[Ptr[uint8]]("#606060"))
    hamscene_glyphs(PREV_X + 8, NAV_Y + 4, cast[Ptr[uint8]]("<"), fg)
    hamscene_stroke(NEXT_X, NAV_Y, NAV_W, NAV_H, 1, cast[Ptr[uint8]]("#606060"))
    hamscene_glyphs(NEXT_X + 8, NAV_Y + 4, cast[Ptr[uint8]](">"), fg)

    title: Array[32, uint8]
    tp: uint64 = 0
    mn: Ptr[uint8] = _mon_full(cal_m)
    j: uint64 = 0
    while mn[j] != 0:
        title[tp] = mn[j]
        tp = tp + 1
        j = j + 1
    title[tp] = 32
    tp = tp + 1
    tp = tp + _cal_u64_to_dec(cal_y, &title[tp])
    title[tp] = 0
    # Roughly centre the title between the arrows (8px glyph advance).
    tw: int32 = cast[int32](tp) * 8
    txx: int32 = (WIN_W - tw) / 2
    hamscene_glyphs_bold(txx, NAV_Y + 4, &title[0], fg)

    # --- weekday header ---
    c: uint64 = 0
    while c < 7:
        hx: int32 = GRID_X + cast[int32](c) * CELL_W
        hc: Ptr[uint8] = fg
        if c == 0 or c == 6:
            hc = cast[Ptr[uint8]]("#a04040")           # weekend accent
        hamscene_glyphs_bold(hx + 8, 60, _wday_hdr(c), hc)
        c = c + 1

    # --- day grid ---
    first_wd: uint64 = _weekday(cal_y, cal_m, 1)
    dim: uint64 = _days_in_month(cal_y, cal_m)

    # Leading spill-over: previous month's trailing days fill row-0 cells before
    # the 1st, drawn dimmed so the current month still reads as primary.
    py: uint64 = 0
    pm: uint64 = 0
    _prev_ym(&py, &pm)
    pdim: uint64 = _days_in_month(py, pm)
    lc: uint64 = 0
    while lc < first_wd:
        _draw_dim_day(lc, 0, pdim - (first_wd - 1 - lc))
        lc = lc + 1

    # Trailing spill-over: next month's leading days fill the cells after the
    # last day out to the end of the 6x7 grid (42 cells).
    ny: uint64 = 0
    nm: uint64 = 0
    _next_ym(&ny, &nm)
    tidx: uint64 = first_wd + dim
    while tidx < 42:
        _draw_dim_day(tidx % 7, tidx / 7, tidx - (first_wd + dim) + 1)
        tidx = tidx + 1

    d: uint64 = 1
    while d <= dim:
        idx: uint64 = first_wd + (d - 1)
        row: uint64 = idx / 7
        col: uint64 = idx % 7
        cx: int32 = GRID_X + cast[int32](col) * CELL_W
        cyy: int32 = GRID_Y + cast[int32](row) * CELL_H
        is_today: int32 = 0
        if cal_y == today_y and cal_m == today_m and d == today_d:
            is_today = 1
        is_sel: int32 = 0
        if cal_y == sel_y and cal_m == sel_m and d == sel_d:
            is_sel = 1
        if is_today != 0:
            hamscene_fill(cx, cyy, CELL_W - 2, CELL_H - 2,
                          cast[Ptr[uint8]]("#3584e4"))
            hamscene_stroke(cx, cyy, CELL_W - 2, CELL_H - 2, 1,
                            cast[Ptr[uint8]]("#204060"))
        if is_sel != 0:
            # orange selection outline (visible even over the blue today cell)
            hamscene_stroke(cx, cyy, CELL_W - 2, CELL_H - 2, 2,
                            cast[Ptr[uint8]]("#e08020"))
        dc: Ptr[uint8] = fg
        if is_today != 0:
            dc = cast[Ptr[uint8]]("#ffffff")
        elif col == 0 or col == 6:
            dc = cast[Ptr[uint8]]("#a04040")
        dbuf: Array[4, uint8]
        dn: uint64 = _cal_u64_to_dec(d, &dbuf[0])
        dbuf[dn] = 0
        # right-ish align single/double digit within the cell
        offx: int32 = 10
        if d >= 10:
            offx = 6
        hamscene_glyphs(cx + offx, cyy + 5, &dbuf[0], dc)
        d = d + 1

    # --- Today button ---
    _btn(TODAY_X, TODAY_Y, TODAY_W, TODAY_H, cast[Ptr[uint8]]("Today"), fg)

    # --- selection readout + relative time ---
    sbuf: Array[40, uint8]
    _build_seldate(&sbuf[0])
    hamscene_glyphs(8, READ_Y, &sbuf[0], fg)
    rbuf: Array[40, uint8]
    if _build_relative(&rbuf[0]) > 0:
        hamscene_glyphs_bold(8, REL_Y, &rbuf[0], cast[Ptr[uint8]]("#204060"))

    # --- separator ---
    hamscene_fill(6, SEP_Y, WIN_W - 12, 1, cast[Ptr[uint8]]("#808080"))

    # --- stopwatch ---
    hamscene_glyphs_bold(8, SW_LBL_Y, cast[Ptr[uint8]]("Stopwatch"), fg)
    swbuf: Array[16, uint8]
    _build_sw(&swbuf[0])
    hamscene_glyphs(150, SW_LBL_Y, &swbuf[0], cast[Ptr[uint8]]("#204060"))
    _btn(SW_START_X, SW_BTN_Y, SW_BTN_W, SW_BTN_H,
         cast[Ptr[uint8]]("Start"), fg)
    _btn(SW_STOP_X, SW_BTN_Y, SW_BTN_W, SW_BTN_H,
         cast[Ptr[uint8]]("Stop"), fg)
    _btn(SW_RESET_X, SW_BTN_Y, SW_BTN_W, SW_BTN_H,
         cast[Ptr[uint8]]("Reset"), fg)

    # --- live uptime clock (H:MM:SS since boot) ---
    hamscene_glyphs_bold(8, UPTIME_Y, cast[Ptr[uint8]]("Uptime"), fg)
    upbuf: Array[16, uint8]
    _build_uptime(&upbuf[0])
    hamscene_glyphs(72, UPTIME_Y, &upbuf[0], cast[Ptr[uint8]]("#204060"))


# ---- input ---------------------------------------------------------------
def _in(x: int64, y: int64, bx: int32, by: int32, bw: int32, bh: int32) -> int32:
    if x >= cast[int64](bx) and x < cast[int64](bx + bw) \
            and y >= cast[int64](by) and y < cast[int64](by + bh):
        return 1
    return 0


# Hit-test a click against a day cell; select it. Returns 1 if a day changed.
def _click_day(x: int64, y: int64) -> int32:
    if x < cast[int64](GRID_X) or y < cast[int64](GRID_Y):
        return 0
    relx: int64 = x - cast[int64](GRID_X)
    rely: int64 = y - cast[int64](GRID_Y)
    col: int64 = relx / cast[int64](CELL_W)
    row: int64 = rely / cast[int64](CELL_H)
    if col < 0 or col > 6 or row < 0 or row > 5:
        return 0
    first_wd: uint64 = _weekday(cal_y, cal_m, 1)
    idx: int64 = row * 7 + col
    dim: uint64 = _days_in_month(cal_y, cal_m)
    if idx < cast[int64](first_wd):
        # a dimmed previous-month spill day: flip back a month and select it.
        spill: uint64 = cast[uint64](cast[int64](first_wd) - 1 - idx)
        hamcal_prev_month()
        sel_y = cal_y
        sel_m = cal_m
        sel_d = _days_in_month(cal_y, cal_m) - spill
        return 1
    dd: int64 = idx - cast[int64](first_wd) + 1
    if dd > cast[int64](dim):
        # a dimmed next-month spill day: flip forward a month and select it.
        nd: uint64 = cast[uint64](dd - cast[int64](dim))
        hamcal_next_month()
        sel_y = cal_y
        sel_m = cal_m
        sel_d = nd
        return 1
    sel_y = cal_y
    sel_m = cal_m
    sel_d = cast[uint64](dd)
    return 1


# Returns 1 if the click changed anything the caller should re-render.
def hamcal_click(x: int64, y: int64) -> int32:
    if _in(x, y, PREV_X, NAV_Y, NAV_W, NAV_H) != 0:
        hamcal_prev_month()
        return 1
    if _in(x, y, NEXT_X, NAV_Y, NAV_W, NAV_H) != 0:
        hamcal_next_month()
        return 1
    if _in(x, y, TODAY_X, TODAY_Y, TODAY_W, TODAY_H) != 0:
        hamcal_today()
        return 1
    if _in(x, y, SW_START_X, SW_BTN_Y, SW_BTN_W, SW_BTN_H) != 0:
        _sw_start()
        return 1
    if _in(x, y, SW_STOP_X, SW_BTN_Y, SW_BTN_W, SW_BTN_H) != 0:
        _sw_stop()
        return 1
    if _in(x, y, SW_RESET_X, SW_BTN_Y, SW_BTN_W, SW_BTN_H) != 0:
        _sw_reset()
        return 1
    return _click_day(x, y)


# Feed one already-decoded key CODE (a raw byte from the /keys leaf). Decodes
# CSI arrow sequences (ESC '[' A/B/C/D). Returns 1 if the selection moved.
def hamcal_key(code: int32) -> int32:
    if _key_st == 0:
        if code == 27:                                  # ESC
            _key_st = 1
        return 0
    if _key_st == 1:
        if code == 91:                                  # '['
            _key_st = 2
        else:
            _key_st = 0
        return 0
    # _key_st == 2: expect a final byte
    _key_st = 0
    if code == 65:                                      # 'A' Up  -> -7 days
        _sel_add(-7)
        return 1
    if code == 66:                                      # 'B' Down -> +7 days
        _sel_add(7)
        return 1
    if code == 67:                                      # 'C' Right -> +1 day
        _sel_add(1)
        return 1
    if code == 68:                                      # 'D' Left -> -1 day
        _sel_add(-1)
        return 1
    return 0


# Parse a "d <code>" / "u <code>" key line; apply only PRESS ('d'). Returns 1
# if the selection moved.
def hamcal_key_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 100:                            # 'd' = press
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    neg: int32 = 0
    if i < n and s[i] == 45:
        neg = 1
        i = i + 1
    code: int32 = 0
    got: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        code = code * 10 + cast[int32](s[i]) - 48
        i = i + 1
        got = 1
    if got == 0:
        return 0
    if neg != 0:
        code = 0 - code
    return hamcal_key(code)


# Shared pointer-line parser ("m <x> <y> <buttons>").
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                             # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc = acc * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc = 0 - acc
        vals[v] = acc
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1

# lib/hamcalcore.ad — PURE, extern-free core for the Calendar scene app.
#
# A month-grid calendar: a title (Month YYYY) with prev/next arrows, a
# weekday header row (Su Mo Tu We Th Fr Sa) and a 6x7 grid of day cells with
# TODAY highlighted. All calendar math (days-in-month, leap years, the
# day-of-week of the 1st via the civil-from-days algorithm) is done here with
# integer arithmetic — no clock, no syscalls — so this module links into BOTH
# the native (x86_64-adder-user) and host (x86_64-linux) targets and renders
# deterministically for the host PNG gate.
#
# The DRIVER supplies "today" (year/month/day, derived from the real clock)
# via hamcal_set_today(); the core defaults the visible month to today and
# lets prev/next navigate. Complements the panel clock's date read-out with a
# full month view (MATE's clock-applet calendar popdown as a standalone app).

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_stroke, \
    hamscene_glyphs, hamscene_glyphs_bold


# ---- tiny pure helpers (module-scoped; each core keeps its own) ----------
def _cal_slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _cal_u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# ---- calendar math -------------------------------------------------------
def _is_leap(y: uint64) -> int32:
    if y % 400 == 0:
        return 1
    if y % 100 == 0:
        return 0
    if y % 4 == 0:
        return 1
    return 0


def _days_in_month(y: uint64, m: uint64) -> uint64:
    if m == 2:
        if _is_leap(y) != 0:
            return 29
        return 28
    if m == 4 or m == 6 or m == 9 or m == 11:
        return 30
    return 31


# Weekday (0=Sun .. 6=Sat) of the given civil date, valid for y >= 1970.
# Uses the days-from-1970 count (Howard Hinnant) then (days + 4) % 7, matching
# lib/panelclock's epoch weekday convention (1970-01-01 was a Thursday).
def _weekday(y: uint64, m: uint64, d: uint64) -> uint64:
    yy: uint64 = y
    if m <= 2:
        yy = yy - 1
    era: uint64 = yy / 400
    yoe: uint64 = yy - era * 400
    mp: uint64 = m + 9
    if m > 2:
        mp = m - 3
    doy: uint64 = (153 * mp + 2) / 5 + d - 1
    doe: uint64 = yoe * 365 + yoe / 4 - yoe / 100 + doy
    days: uint64 = era * 146097 + doe - 719468
    return (days + 4) % 7


def _mon_full(m: uint64) -> Ptr[uint8]:
    if m == 1:
        return cast[Ptr[uint8]]("January")
    if m == 2:
        return cast[Ptr[uint8]]("February")
    if m == 3:
        return cast[Ptr[uint8]]("March")
    if m == 4:
        return cast[Ptr[uint8]]("April")
    if m == 5:
        return cast[Ptr[uint8]]("May")
    if m == 6:
        return cast[Ptr[uint8]]("June")
    if m == 7:
        return cast[Ptr[uint8]]("July")
    if m == 8:
        return cast[Ptr[uint8]]("August")
    if m == 9:
        return cast[Ptr[uint8]]("September")
    if m == 10:
        return cast[Ptr[uint8]]("October")
    if m == 11:
        return cast[Ptr[uint8]]("November")
    return cast[Ptr[uint8]]("December")


# ---- state ---------------------------------------------------------------
cal_y:  uint64 = 2026            # visible month's year
cal_m:  uint64 = 1              # visible month (1..12)
today_y: uint64 = 0
today_m: uint64 = 0
today_d: uint64 = 0


def hamcal_set_today(y: uint64, m: uint64, d: uint64):
    today_y = y
    today_m = m
    today_d = d
    cal_y = y
    cal_m = m


def hamcal_year() -> uint64:
    return cal_y


def hamcal_month() -> uint64:
    return cal_m


def hamcal_prev_month():
    if cal_m <= 1:
        cal_m = 12
        cal_y = cal_y - 1
    else:
        cal_m = cal_m - 1


def hamcal_next_month():
    if cal_m >= 12:
        cal_m = 1
        cal_y = cal_y + 1
    else:
        cal_m = cal_m + 1


def hamcal_today():
    # Jump the view back to the month containing today.
    cal_y = today_y
    cal_m = today_m


# ---- layout --------------------------------------------------------------
WIN_W: int32 = 236
WIN_H: int32 = 248
GRID_X: int32 = 6
GRID_Y: int32 = 76
CELL_W: int32 = 32
CELL_H: int32 = 26
PREV_X: int32 = 8
NEXT_X: int32 = 204
NAV_Y: int32 = 34
NAV_W: int32 = 24
NAV_H: int32 = 22
TODAY_X: int32 = 84
TODAY_Y: int32 = 222            # WIN_H(248) - 26
TODAY_W: int32 = 68
TODAY_H: int32 = 20


def _wday_hdr(c: uint64) -> Ptr[uint8]:
    if c == 0:
        return cast[Ptr[uint8]]("Su")
    if c == 1:
        return cast[Ptr[uint8]]("Mo")
    if c == 2:
        return cast[Ptr[uint8]]("Tu")
    if c == 3:
        return cast[Ptr[uint8]]("We")
    if c == 4:
        return cast[Ptr[uint8]]("Th")
    if c == 5:
        return cast[Ptr[uint8]]("Fr")
    return cast[Ptr[uint8]]("Sa")


# ---- scene ---------------------------------------------------------------
def hamcal_build_scene():
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    hamscene_begin()
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#d4d0c8"))
    hamscene_fill(0, 0, WIN_W, 26, cast[Ptr[uint8]]("#3a6ea5"))
    hamscene_glyphs(10, 8, cast[Ptr[uint8]]("Calendar"),
                    cast[Ptr[uint8]]("#ffffff"))

    # --- title row: < Month YYYY > ---
    hamscene_stroke(PREV_X, NAV_Y, NAV_W, NAV_H, 1, cast[Ptr[uint8]]("#606060"))
    hamscene_glyphs(PREV_X + 8, NAV_Y + 4, cast[Ptr[uint8]]("<"), fg)
    hamscene_stroke(NEXT_X, NAV_Y, NAV_W, NAV_H, 1, cast[Ptr[uint8]]("#606060"))
    hamscene_glyphs(NEXT_X + 8, NAV_Y + 4, cast[Ptr[uint8]](">"), fg)

    title: Array[32, uint8]
    tp: uint64 = 0
    mn: Ptr[uint8] = _mon_full(cal_m)
    j: uint64 = 0
    while mn[j] != 0:
        title[tp] = mn[j]
        tp = tp + 1
        j = j + 1
    title[tp] = 32
    tp = tp + 1
    tp = tp + _cal_u64_to_dec(cal_y, &title[tp])
    title[tp] = 0
    # Roughly centre the title between the arrows (8px glyph advance).
    tw: int32 = cast[int32](tp) * 8
    txx: int32 = (WIN_W - tw) / 2
    hamscene_glyphs_bold(txx, NAV_Y + 4, &title[0], fg)

    # --- weekday header ---
    c: uint64 = 0
    while c < 7:
        hx: int32 = GRID_X + cast[int32](c) * CELL_W
        hc: Ptr[uint8] = fg
        if c == 0 or c == 6:
            hc = cast[Ptr[uint8]]("#a04040")           # weekend accent
        hamscene_glyphs_bold(hx + 8, 60, _wday_hdr(c), hc)
        c = c + 1

    # --- day grid ---
    first_wd: uint64 = _weekday(cal_y, cal_m, 1)
    dim: uint64 = _days_in_month(cal_y, cal_m)
    d: uint64 = 1
    while d <= dim:
        idx: uint64 = first_wd + (d - 1)
        row: uint64 = idx / 7
        col: uint64 = idx % 7
        cx: int32 = GRID_X + cast[int32](col) * CELL_W
        cyy: int32 = GRID_Y + cast[int32](row) * CELL_H
        is_today: int32 = 0
        if cal_y == today_y and cal_m == today_m and d == today_d:
            is_today = 1
        if is_today != 0:
            hamscene_fill(cx, cyy, CELL_W - 2, CELL_H - 2,
                          cast[Ptr[uint8]]("#3a6ea5"))
            hamscene_stroke(cx, cyy, CELL_W - 2, CELL_H - 2, 1,
                            cast[Ptr[uint8]]("#204060"))
        dc: Ptr[uint8] = fg
        if is_today != 0:
            dc = cast[Ptr[uint8]]("#ffffff")
        elif col == 0 or col == 6:
            dc = cast[Ptr[uint8]]("#a04040")
        dbuf: Array[4, uint8]
        dn: uint64 = _cal_u64_to_dec(d, &dbuf[0])
        dbuf[dn] = 0
        # right-ish align single/double digit within the cell
        offx: int32 = 10
        if d >= 10:
            offx = 6
        hamscene_glyphs(cx + offx, cyy + 5, &dbuf[0], dc)
        d = d + 1

    # --- Today button ---
    hamscene_fill(TODAY_X, TODAY_Y, TODAY_W, TODAY_H, cast[Ptr[uint8]]("#c8c4bc"))
    hamscene_stroke(TODAY_X, TODAY_Y, TODAY_W, TODAY_H, 1,
                    cast[Ptr[uint8]]("#808080"))
    hamscene_glyphs(TODAY_X + 14, TODAY_Y + 3, cast[Ptr[uint8]]("Today"), fg)


# ---- input ---------------------------------------------------------------
def _in(x: int64, y: int64, bx: int32, by: int32, bw: int32, bh: int32) -> int32:
    if x >= cast[int64](bx) and x < cast[int64](bx + bw) \
            and y >= cast[int64](by) and y < cast[int64](by + bh):
        return 1
    return 0


# Returns 1 if the click changed the visible month (caller re-renders).
def hamcal_click(x: int64, y: int64) -> int32:
    if _in(x, y, PREV_X, NAV_Y, NAV_W, NAV_H) != 0:
        hamcal_prev_month()
        return 1
    if _in(x, y, NEXT_X, NAV_Y, NAV_W, NAV_H) != 0:
        hamcal_next_month()
        return 1
    if _in(x, y, TODAY_X, TODAY_Y, TODAY_W, TODAY_H) != 0:
        hamcal_today()
        return 1
    return 0


# Shared pointer-line parser ("m <x> <y> <buttons>").
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                             # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc = acc * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc = 0 - acc
        vals[v] = acc
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1

# lib/strview.ad — core String helpers (Adder language roadmap increment 7-tail).
#
# A `String` is a 16-byte {ptr@0, len@8} by-reference aggregate VIEW over
# caller-owned bytes (see docs/adder_language_roadmap.md). These helpers are
# ORDINARY Adder over raw (ptr, len) pairs pulled from `s.ptr` / `s.len`, so
# they compile through the byte-tested path and are seed<->native lockstep for
# FREE — no new codegen. They never allocate: comparison / search return
# scalars, substring is a {ptr, len} view, and concat writes into a
# CALLER-provided buffer (there is no general userland allocator to own one).
#
# All functions take raw pointers + lengths so they carry no aggregate ABI and
# stay usable from any target. Call them as, e.g., `str_eq(a.ptr, a.len,
# b.ptr, b.len)`.

# Byte-equality: 1 iff both views have the same length AND the same bytes.
def str_eq(ap: Ptr[uint8], an: uint64, bp: Ptr[uint8], bn: uint64) -> int32:
    if an != bn:
        return 0
    i: uint64 = 0
    while i < an:
        if ap[i] != bp[i]:
            return 0
        i = i + 1
    return 1

# Index of the first occurrence of needle in haystack, or -1 if absent.
# An empty needle matches at 0. A needle longer than the haystack never matches.
def str_find(hp: Ptr[uint8], hn: uint64, np: Ptr[uint8], nn: uint64) -> int64:
    if nn == 0:
        return 0
    if nn > hn:
        return -1
    last: uint64 = hn - nn
    i: uint64 = 0
    while i <= last:
        j: uint64 = 0
        while j < nn:
            if hp[i + j] != np[j]:
                j = nn + 1                 # sentinel: mismatch -> break outer
            else:
                j = j + 1
        if j == nn:
            return cast[int64](i)
        i = i + 1
    return -1

# 1 iff needle occurs somewhere in haystack.
def str_contains(hp: Ptr[uint8], hn: uint64, np: Ptr[uint8], nn: uint64) -> int32:
    if str_find(hp, hn, np, nn) >= 0:
        return 1
    return 0

# Pointer at byte offset `off` from `p` — the substring-view helper.
# `String(str_at(s.ptr, a), b - a)` builds a no-allocation sub-view of s[a:b].
def str_at(p: Ptr[uint8], off: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](p) + off)

# Concatenate a ++ b into the caller-owned `dst` buffer (capacity `cap`
# bytes). Returns the total byte length written, or -1 if it would overflow
# `cap`. The caller owns `dst` (a stack Array, an mmap'd/kmalloc'd region);
# String owns no allocator, so concatenation never mints storage of its own.
def str_concat_into(dst: Ptr[uint8], cap: uint64,
                    ap: Ptr[uint8], an: uint64,
                    bp: Ptr[uint8], bn: uint64) -> int64:
    total: uint64 = an + bn
    if total > cap:
        return -1
    i: uint64 = 0
    while i < an:
        dst[i] = ap[i]
        i = i + 1
    j: uint64 = 0
    while j < bn:
        dst[an + j] = bp[j]
        j = j + 1
    return cast[int64](total)

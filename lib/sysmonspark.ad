# lib/sysmonspark.ad — PURE, extern-free rolling-history sparkline for the
# MATE-style panel system-monitor applet. It draws a scrolling CPU (filled
# green columns) + memory (blue polyline) history graph into an arbitrary
# rectangle, from two ring buffers of 0..100 samples (newest at the highest
# live index). It imports only lib/hamscene.ad primitives, so the identical
# code renders through the compositor (user/hampanelscene.ad's applet) AND
# through lib/hamui_host.ad (the host render-to-PNG gate).

from lib.hamscene import hamscene_fill, hamscene_stroke, hamscene_line


# Draw the CPU+memory history sparkline into [gx,gy,gw,gh].
#   cpu / mem : ring buffers of `n` live samples (0..100), capacity `hist`.
def sysmon_spark(cpu: Ptr[uint8], mem: Ptr[uint8], n: uint64, hist: uint64,
                 gx: int32, gy: int32, gw: int32, gh: int32):
    hamscene_fill(gx, gy, gw, gh, cast[Ptr[uint8]]("#12151b"))
    hamscene_stroke(gx, gy, gw, gh, 1, cast[Ptr[uint8]]("#3a4250"))
    if n == 0 or gw < 3 or gh < 3:
        return
    ih: int32 = gh - 2
    iw: int32 = gw - 2
    colw: int32 = iw / cast[int32](hist)
    if colw < 1:
        colw = 1
    # CPU as filled columns (green) — the primary series.
    i: uint64 = 0
    while i < n:
        v: int32 = cast[int32](cpu[i])
        bh: int32 = (v * ih) / 100
        cx: int32 = gx + 1 + (iw - colw) * cast[int32](i) / cast[int32](hist)
        hamscene_fill(cx, gy + 1 + ih - bh, colw, bh,
                      cast[Ptr[uint8]]("#57bb6e"))
        i = i + 1
    # Memory as a polyline (blue) overlaid on top.
    if n >= 2:
        px: int32 = gx + 1
        py: int32 = gy + 1 + ih - (cast[int32](mem[0]) * ih) / 100
        i = 1
        while i < n:
            cx2: int32 = gx + 1 + (iw - 1) * cast[int32](i) / cast[int32](n - 1)
            cy2: int32 = gy + 1 + ih - (cast[int32](mem[i]) * ih) / 100
            hamscene_line(px, py, cx2, cy2, 1, cast[Ptr[uint8]]("#5b8def"))
            px = cx2
            py = cy2
            i = i + 1

# lib/filepick.ad
#
# Reusable modal FILE-PICKER service (Kate-style Open / Save-As browser),
# factored out of user/hameditscene.ad so EVERY scene app can pop the same
# real file-manager browse UI to choose a path — instead of each app
# carrying a bespoke mini-chooser.
#
# It draws as an OVERLAY over the caller's window canvas (the caller owns
# hamscene_begin/commit; filepick_emit() paints between them). It navigates
# directories (enter a dir, ".." to go up), lists subdirs + files one
# glyphs row each, lets the user pick a file (OPEN mode) or type a filename
# into a bottom field and save at <dir>/<name> (SAVE mode). The directory
# enumeration uses the shared Dir-record path (with a plain name-stream
# fallback) exactly like hamfmscene's load_dir.
#
# THE PICKER DOES NO FILE I/O ITSELF. It only RESOLVES a path: when the user
# commits, it stashes the chosen absolute path + the mode into a result slot
# and clears its active flag. The host polls filepick_take_result() each
# loop and performs its OWN open/save on that path. This keeps the picker
# app-agnostic (an editor opens/saves, another app might exec/copy/etc.).
#
# USAGE (host):
#   from lib.filepick import filepick_open, filepick_active, \
#       filepick_handle_code, filepick_emit, filepick_take_result, \
#       filepick_result_path, filepick_result_mode, \
#       FILEPICK_OPEN, FILEPICK_SAVE
#
#   # to pop it:   filepick_open(FILEPICK_SAVE, start_dir, save_seed)
#   # render:      if filepick_active(): filepick_emit(ed_w, ed_h)
#   # keys:        if filepick_active(): changed = filepick_handle_code(code)
#   # each loop:   if filepick_take_result():
#   #                  path = filepick_result_path()
#   #                  if filepick_result_mode() == FILEPICK_OPEN: ...open...
#   #                  else: ...save...

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.p9 import p9_listdir, p9_chan_dir_mode, p9_dir_decode_at, \
    DIR_CUR_QTYPE, DIR_CUR_NAME, DIR_CUR_NAME_LEN, P9_QTDIR
from lib.hamui import hamscene_fill, hamscene_rect, hamscene_glyphs, \
    hamscene_stroke


# Picker modes (also the result-mode the host reads back).
FILEPICK_OPEN: int32 = 1
FILEPICK_SAVE: int32 = 2


# ====================================================================
# STATE
# ====================================================================
FP_MAX:       uint64 = 256
FP_NAME_CAP:  uint64 = 48
FP_LIST_CAP:  uint64 = 32768
FP_PATH_CAP:  uint64 = 512

fp_mode:      int32 = 0          # 0 closed, 1 OPEN, 2 SAVE
fp_dir:       Array[512, uint8]  # current directory (NUL-term)
fp_dir_len:   uint64 = 0
fp_list:      Array[32768, uint8]
fp_names:     Array[12288, uint8]   # FP_MAX * FP_NAME_CAP
fp_name_len:  Array[256, uint64]
fp_is_dir:    Array[256, int32]
fp_n:         uint64 = 0          # entry count
fp_has_up:    int32 = 0           # row 0 is a synthetic ".."
fp_sel:       int64 = 0           # highlighted row
fp_top:       uint64 = 0          # first visible row (scroll)
fp_full:      Array[576, uint8]   # scratch full path
fp_save_name: Array[128, uint8]   # SAVE-mode typed filename
fp_save_len:  uint64 = 0

# Result slot: a committed pick the host has NOT yet consumed.
fp_result_ready: int32 = 0
fp_result_mode:  int32 = 0
fp_result_path:  Array[576, uint8]

# Arrow-key CSI decode state local to the picker (0 ground, 1 ESC, 2 ESC[).
fp_esc_st: int32 = 0

FP_TITLE_H:   int32 = 18
FP_ROW_H:     int32 = 14          # list row height


def fp_name_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&fp_names[0]) + i * FP_NAME_CAP)


def _fp_set_dir(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < FP_PATH_CAP - 1:
        fp_dir[i] = s[i]
        i = i + 1
    if i == 0:
        fp_dir[0] = 47                             # '/'
        i = 1
    fp_dir[i] = 0
    fp_dir_len = i


def _fp_store(src: Ptr[uint8], nl: uint64, dir_flag: int32):
    if fp_n >= FP_MAX:
        return
    store: uint64 = nl
    if store > FP_NAME_CAP - 1:
        store = FP_NAME_CAP - 1
    dst: Ptr[uint8] = fp_name_ptr(fp_n)
    k: uint64 = 0
    while k < store:
        dst[k] = src[k]
        k = k + 1
    dst[store] = 0
    fp_name_len[fp_n] = store
    fp_is_dir[fp_n] = dir_flag
    fp_n = fp_n + 1


def _fp_maybe_store(src: Ptr[uint8], nl: uint64, dir_flag: int32):
    if nl == 0:
        return
    if nl == 1 and src[0] == 46:                   # "."
        return
    if nl == 2 and src[0] == 46 and src[1] == 46:  # ".."
        return
    _fp_store(src, nl, dir_flag)


# Build <fp_dir>/<entry i> into fp_full (NUL-term).
def _fp_build_full(i: uint64):
    j: uint64 = 0
    while j < fp_dir_len and j < FP_PATH_CAP:
        fp_full[j] = fp_dir[j]
        j = j + 1
    if j == 0 or fp_full[j - 1] != 47:
        fp_full[j] = 47
        j = j + 1
    nl: uint64 = fp_name_len[i]
    p: Ptr[uint8] = fp_name_ptr(i)
    k: uint64 = 0
    while k < nl and j < 575:
        fp_full[j] = p[k]
        j = j + 1
        k = k + 1
    fp_full[j] = 0


# Open-probe directory test (flip the fd into Dir-record mode; only a real
# directory succeeds). Needed because the cpio rootfs stats every entry as a
# regular file.
def _fp_probe_is_dir(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path)
    if fd < 0:
        return 0
    rc: int32 = p9_chan_dir_mode(fd, 1, path)
    sys_close(fd)
    if rc == 0:
        return 1
    return 0


def _fp_classify():
    r: uint64 = 0
    if fp_has_up != 0:
        r = 1
    while r < fp_n:
        _fp_build_full(r)
        fp_is_dir[r] = _fp_probe_is_dir(cast[Ptr[char]](&fp_full[0]))
        r = r + 1


def _fp_load_namestream():
    n: int64 = p9_listdir(cast[Ptr[char]](&fp_dir[0]), &fp_list[0], FP_LIST_CAP)
    if n < 0:
        return
    nu: uint64 = cast[uint64](n)
    i: uint64 = 0
    while i < nu:
        c: uint8 = fp_list[i]
        if c == 10 or c == 0:
            i = i + 1
            continue
        j: uint64 = i
        while j < nu:
            d: uint8 = fp_list[j]
            if d == 10 or d == 0:
                break
            j = j + 1
        _fp_maybe_store(&fp_list[i], j - i, 0)
        i = j + 1
    _fp_classify()


# List fp_dir into the fp_* tables. Row 0 is a synthetic ".." unless we are
# at the filesystem root.
def _fp_load():
    fp_n = 0
    fp_has_up = 0
    fp_sel = 0
    fp_top = 0
    if fp_dir_len > 1:
        _fp_store(cast[Ptr[uint8]](".."), 2, 1)
        fp_has_up = 1
    fd: int32 = sys_open(cast[Ptr[char]](&fp_dir[0]))
    if fd < 0:
        return
    if p9_chan_dir_mode(fd, 1, cast[Ptr[char]](&fp_dir[0])) != 0:
        sys_close(fd)
        _fp_load_namestream()
        return
    total: uint64 = 0
    while total < FP_LIST_CAP:
        slice_ptr: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](&fp_list[0]) + total)
        n: int64 = sys_read(fd, slice_ptr, FP_LIST_CAP - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    off: uint64 = 0
    while off < total:
        rl: uint64 = p9_dir_decode_at(&fp_list[0], off, total)
        if rl == 0:
            break
        df: int32 = 0
        if (DIR_CUR_QTYPE & P9_QTDIR) != 0:
            df = 1
        _fp_maybe_store(&DIR_CUR_NAME[0], DIR_CUR_NAME_LEN, df)
        off = off + rl
    _fp_classify()


# Descend into entry i (a directory): fp_dir <- fp_full, re-list.
def _fp_enter(i: uint64):
    _fp_build_full(i)
    _fp_set_dir(&fp_full[0])
    _fp_load()


def _fp_go_parent():
    if fp_dir_len <= 1:
        return
    n: uint64 = fp_dir_len
    if fp_dir[n - 1] == 47:
        n = n - 1
    while n > 1 and fp_dir[n - 1] != 47:
        n = n - 1
    if n > 1:
        n = n - 1
    if n == 0:
        n = 1
    fp_dir[n] = 0
    fp_dir_len = n
    _fp_load()


# ====================================================================
# PUBLIC API
# ====================================================================
# Open the picker. mode = FILEPICK_OPEN or FILEPICK_SAVE. start_dir is the
# directory to browse from (NUL-term); if it can't be listed the picker
# climbs to /home then / so it always shows something. save_seed (may be
# NUL/empty) pre-fills the SAVE-mode filename field.
def filepick_open(mode: int32, start_dir: Ptr[uint8], save_seed: Ptr[uint8]):
    fp_mode = mode
    fp_result_ready = 0
    fp_esc_st = 0
    fp_save_len = 0
    fp_save_name[0] = 0
    if mode == FILEPICK_SAVE and save_seed != cast[Ptr[uint8]](0):
        s: uint64 = 0
        while save_seed[s] != 0 and fp_save_len < 126:
            fp_save_name[fp_save_len] = save_seed[s]
            fp_save_len = fp_save_len + 1
            s = s + 1
        fp_save_name[fp_save_len] = 0
    if start_dir != cast[Ptr[uint8]](0) and start_dir[0] != 0:
        _fp_set_dir(start_dir)
    else:
        _fp_set_dir(cast[Ptr[uint8]]("/home/live/Documents"))
    _fp_load()
    # If the chosen start dir has no entries (couldn't be opened/listed),
    # climb to /home, then /, so the picker always shows something.
    if fp_n == 0 and fp_has_up == 0:
        _fp_set_dir(cast[Ptr[uint8]]("/home"))
        _fp_load()
    if fp_n == 0 and fp_has_up == 0:
        _fp_set_dir(cast[Ptr[uint8]]("/"))
        _fp_load()


def filepick_active() -> int32:
    return fp_mode


# Commit a pick into the result slot and close the picker. The host reads
# it back via filepick_take_result + filepick_result_path/mode.
def _fp_emit_result(mode: int32, path: Ptr[uint8]):
    k: uint64 = 0
    while path[k] != 0 and k < 575:
        fp_result_path[k] = path[k]
        k = k + 1
    fp_result_path[k] = 0
    fp_result_mode = mode
    fp_result_ready = 1
    fp_mode = 0


# Commit a SAVE: compose <fp_dir>/<typed name> as the result path.
def _fp_commit_save():
    if fp_save_len == 0:
        return
    p: uint64 = 0
    while p < fp_dir_len and p < 574:
        fp_full[p] = fp_dir[p]
        p = p + 1
    if p == 0 or fp_full[p - 1] != 47:
        fp_full[p] = 47
        p = p + 1
    k: uint64 = 0
    while k < fp_save_len and p < 575:
        fp_full[p] = fp_save_name[k]
        p = p + 1
        k = k + 1
    fp_full[p] = 0
    _fp_emit_result(FILEPICK_SAVE, &fp_full[0])


# Activate the current selection. A directory (or "..") navigates; a file
# OPENs (mode 1) or, in SAVE mode, seeds the filename field from the pick.
def _fp_activate():
    if fp_n == 0:
        return
    u: uint64 = cast[uint64](fp_sel)
    if u >= fp_n:
        return
    if fp_has_up != 0 and u == 0:
        _fp_go_parent()
        return
    if fp_is_dir[u] != 0:
        _fp_enter(u)
        return
    # A regular file.
    if fp_mode == FILEPICK_OPEN:
        _fp_build_full(u)
        _fp_emit_result(FILEPICK_OPEN, &fp_full[0])
    else:
        # SAVE mode: copy the picked name into the filename field.
        fp_save_len = 0
        nl: uint64 = fp_name_len[u]
        src: Ptr[uint8] = fp_name_ptr(u)
        kk: uint64 = 0
        while kk < nl and fp_save_len < 126:
            fp_save_name[fp_save_len] = src[kk]
            fp_save_len = fp_save_len + 1
            kk = kk + 1
        fp_save_name[fp_save_len] = 0


# Host calls this each loop. Returns 1 (and clears the flag) if a pick was
# committed since the last call; the host then reads filepick_result_path/
# filepick_result_mode and acts on it.
def filepick_take_result() -> int32:
    if fp_result_ready == 0:
        return 0
    fp_result_ready = 0
    return 1


def filepick_result_path() -> Ptr[uint8]:
    return &fp_result_path[0]


def filepick_result_mode() -> int32:
    return fp_result_mode


# Visible picker rows for the current window height.
def _fp_vis_rows(ed_h: int32) -> uint64:
    avail: int32 = ed_h - FP_TITLE_H - 20
    rows: int32 = avail / FP_ROW_H
    if rows < 2:
        rows = 2
    return cast[uint64](rows)


def _fp_scroll_follow(ed_h: int32):
    vis: uint64 = _fp_vis_rows(ed_h)
    s: uint64 = cast[uint64](fp_sel)
    if s < fp_top:
        fp_top = s
    if s >= fp_top + vis:
        fp_top = s - vis + 1


# Render the picker overlay over the caller's whole window canvas. The
# caller owns hamscene_begin()/hamscene_commit(); this paints between them.
def filepick_emit(ed_w: int32, ed_h: int32):
    hamscene_fill(0, 0, ed_w, ed_h, cast[Ptr[uint8]]("#f3f3ee"))
    # Title bar: mode + current directory.
    hamscene_rect(0, 0, ed_w, FP_TITLE_H, cast[Ptr[uint8]]("#2d5a87"))
    tbuf: Array[96, uint8]
    tp: uint64 = 0
    lbl: Ptr[uint8] = cast[Ptr[uint8]]("Open: ")
    if fp_mode == FILEPICK_SAVE:
        lbl = cast[Ptr[uint8]]("Save in: ")
    a: uint64 = 0
    while lbl[a] != 0:
        tbuf[tp] = lbl[a]
        tp = tp + 1
        a = a + 1
    dn: uint64 = fp_dir_len
    if dn > 80:
        dn = 80
    b: uint64 = 0
    while b < dn:
        tbuf[tp] = fp_dir[b]
        tp = tp + 1
        b = b + 1
    tbuf[tp] = 0
    hamscene_glyphs(4, 4, &tbuf[0], cast[Ptr[uint8]]("#ffffff"))
    # Entry list.
    _fp_scroll_follow(ed_h)
    vis: uint64 = _fp_vis_rows(ed_h)
    r: uint64 = fp_top
    drawn: uint64 = 0
    rowbuf: Array[80, uint8]
    while r < fp_n and drawn < vis:
        yy: int32 = FP_TITLE_H + 2 + cast[int32](drawn) * FP_ROW_H
        if cast[int64](r) == fp_sel:
            hamscene_fill(0, yy, ed_w, FP_ROW_H, cast[Ptr[uint8]]("#cfe0f4"))
        # Compose "[D] name" / "    name".
        rp: uint64 = 0
        if fp_is_dir[r] != 0:
            rowbuf[rp] = 91                            # '['
            rowbuf[rp + 1] = 68                        # 'D'
            rowbuf[rp + 2] = 93                        # ']'
            rowbuf[rp + 3] = 32
            rp = 4
        else:
            rowbuf[rp] = 32
            rowbuf[rp + 1] = 32
            rowbuf[rp + 2] = 32
            rowbuf[rp + 3] = 32
            rp = 4
        nl: uint64 = fp_name_len[r]
        src: Ptr[uint8] = fp_name_ptr(r)
        k: uint64 = 0
        while k < nl and rp < 74:
            rowbuf[rp] = src[k]
            rp = rp + 1
            k = k + 1
        rowbuf[rp] = 0
        col: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
        if fp_is_dir[r] != 0:
            col = cast[Ptr[uint8]]("#1a4a8a")
        hamscene_glyphs(6, yy + 2, &rowbuf[0], col)
        r = r + 1
        drawn = drawn + 1
    # Bottom field: SAVE = the typed filename; OPEN = a key hint.
    fy: int32 = ed_h - 18
    hamscene_fill(0, fy - 2, ed_w, 18, cast[Ptr[uint8]]("#e8e8d8"))
    hamscene_stroke(2, fy - 1, ed_w - 4, 16, 1, cast[Ptr[uint8]]("#808060"))
    fbuf: Array[160, uint8]
    fp: uint64 = 0
    if fp_mode == FILEPICK_SAVE:
        nm: Ptr[uint8] = cast[Ptr[uint8]]("Name: ")
        a2: uint64 = 0
        while nm[a2] != 0:
            fbuf[fp] = nm[a2]
            fp = fp + 1
            a2 = a2 + 1
        k2: uint64 = 0
        while k2 < fp_save_len and fp < 150:
            fbuf[fp] = fp_save_name[k2]
            fp = fp + 1
            k2 = k2 + 1
        fbuf[fp] = 95                                 # '_' caret
        fp = fp + 1
    else:
        h2: Ptr[uint8] = cast[Ptr[uint8]](
            "Up/Dn=move Enter=open/cd Esc=cancel")
        a2: uint64 = 0
        while h2[a2] != 0 and fp < 150:
            fbuf[fp] = h2[a2]
            fp = fp + 1
            a2 = a2 + 1
    fbuf[fp] = 0
    hamscene_glyphs(6, fy + 2, &fbuf[0], cast[Ptr[uint8]]("#202020"))


# Handle a key while the picker is open. Returns 1 if the scene changed.
# Arrow keys arrive as ESC '[' A/B; a LONE Escape cancels.
def filepick_handle_code(code: int32) -> int32:
    if fp_esc_st == 1:
        if code == 91:                              # '['
            fp_esc_st = 2
            return 0
        # The ESC stood alone -> cancel the picker.
        fp_esc_st = 0
        fp_mode = 0
        return 1
    elif fp_esc_st == 2:
        fp_esc_st = 0
        if code == 65:                              # up
            if fp_sel > 0:
                fp_sel = fp_sel - 1
            return 1
        if code == 66:                              # down
            if cast[uint64](fp_sel) + 1 < fp_n:
                fp_sel = fp_sel + 1
            return 1
        return 0
    if code == 27:                                  # ESC -> begin CSI / cancel
        fp_esc_st = 1
        return 0
    if code == 3:                                   # Ctrl-C -> cancel
        fp_mode = 0
        return 1
    if code == 13 or code == 10:                    # Enter
        if fp_mode == FILEPICK_SAVE:
            u: uint64 = cast[uint64](fp_sel)
            on_dir: int32 = 0
            if fp_n > 0 and u < fp_n and fp_is_dir[u] != 0:
                on_dir = 1
            if on_dir != 0:
                _fp_activate()                      # navigate
            else:
                _fp_commit_save()
        else:
            _fp_activate()
        return 1
    if fp_mode == FILEPICK_SAVE:
        # SAVE mode: printable keys edit the filename field.
        if code == 8 or code == 127:                # Backspace
            if fp_save_len > 0:
                fp_save_len = fp_save_len - 1
                fp_save_name[fp_save_len] = 0
            return 1
        if code >= 32 and code < 127:
            if fp_save_len < 126:
                fp_save_name[fp_save_len] = cast[uint8](code)
                fp_save_len = fp_save_len + 1
                fp_save_name[fp_save_len] = 0
            return 1
    return 0

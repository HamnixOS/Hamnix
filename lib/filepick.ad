# lib/filepick.ad
#
# Reusable modal FILE-PICKER service (GtkFileChooser-style Open / Save-As),
# backed by the SAME real file-manager browse core as the file manager app.
#
# This is NO LONGER a bespoke chooser: it is a THIN wrapper over the shared
# browse core lib/hamfmcore.ad. The directory model, dir-walk, classify,
# navigation, icon-grid render, hit-test and scroll all live in the core and
# are shared with user/hamfmscene.ad. The picker adds only the chooser shell:
# the Open:/Save in: breadcrumb label, a SAVE-mode filename field, an OK/Cancel
# affordance (Enter=OK, Esc=Cancel), key navigation, and (when the host
# forwards them) pointer clicks for single-click-select / double-click-enter.
#
# It draws as an OVERLAY over the caller's window canvas: the caller owns
# hamscene_begin/commit; filepick_emit() paints the SHARED icon grid
# (fmc_paint) plus the picker's own Name/hint strip between them.
#
# THE PICKER DOES NO FILE I/O ITSELF. It only RESOLVES a path: when the user
# commits, it stashes the chosen absolute path + the mode into a result slot
# and clears its active flag. The host polls filepick_take_result() each loop
# and performs its OWN open/save on that path.
#
# USAGE (host):
#   from lib.filepick import filepick_open, filepick_active, \
#       filepick_handle_code, filepick_emit, filepick_take_result, \
#       filepick_result_path, filepick_result_mode, \
#       FILEPICK_OPEN, FILEPICK_SAVE
#
#   # to pop it:   filepick_open(FILEPICK_SAVE, start_dir, save_seed)
#   # render:      if filepick_active(): filepick_emit(ed_w, ed_h)
#   # keys:        if filepick_active(): changed = filepick_handle_code(code)
#   # each loop:   if filepick_take_result():
#   #                  path = filepick_result_path()
#   #                  if filepick_result_mode() == FILEPICK_OPEN: ...open...
#   #                  else: ...save...

from lib.hamui import hamscene_fill, hamscene_rect, hamscene_glyphs, \
    hamscene_stroke
from lib.hamfmcore import fmc_set_geometry, fmc_set_header, fmc_set_cur_path, \
    fmc_load_dir, fmc_paint, fmc_cell_at, fmc_go_into, fmc_go_parent, \
    fmc_num_entries, fmc_has_up_entry, fmc_entry_is_dir, fmc_full_path_ptr, \
    fmc_cur_path_ptr, fmc_select, fmc_selected, fmc_scroll_to, fmc_entry_name_len, \
    fmc_name_ptr, fmc_grid_cols


# Picker modes (also the result-mode the host reads back).
FILEPICK_OPEN: int32 = 1
FILEPICK_SAVE: int32 = 2


# ====================================================================
# STATE  (the directory model now lives in lib/hamfmcore; the picker keeps
#         only the chooser-shell state)
# ====================================================================
fp_mode:      int32 = 0          # 0 closed, 1 OPEN, 2 SAVE
fp_save_name: Array[128, uint8]  # SAVE-mode typed filename
fp_save_len:  uint64 = 0
fp_full:      Array[576, uint8]  # scratch full path for the commit

# Result slot: a committed pick the host has NOT yet consumed.
fp_result_ready: int32 = 0
fp_result_mode:  int32 = 0
fp_result_path:  Array[576, uint8]

# Arrow-key CSI decode state local to the picker (0 ground, 1 ESC, 2 ESC[).
fp_esc_st: int32 = 0

# Height of the picker's own bottom strip (Name field / hint + OK·Cancel).
FP_BOTTOM_H: int32 = 36


# ====================================================================
# PUBLIC API
# ====================================================================
# Open the picker. mode = FILEPICK_OPEN or FILEPICK_SAVE. start_dir is the
# directory to browse from (NUL-term); if it can't be listed the picker climbs
# to /home then / so it always shows something. save_seed (may be NUL/empty)
# pre-fills the SAVE-mode filename field.
def filepick_open(mode: int32, start_dir: Ptr[uint8], save_seed: Ptr[uint8]):
    fp_mode = mode
    fp_result_ready = 0
    fp_esc_st = 0
    fp_save_len = 0
    fp_save_name[0] = 0
    if mode == FILEPICK_SAVE and save_seed != cast[Ptr[uint8]](0):
        s: uint64 = 0
        while save_seed[s] != 0 and fp_save_len < 126:
            fp_save_name[fp_save_len] = save_seed[s]
            fp_save_len = fp_save_len + 1
            s = s + 1
        fp_save_name[fp_save_len] = 0
    # Header label per mode.
    if mode == FILEPICK_SAVE:
        fmc_set_header(cast[Ptr[uint8]]("Save in: "))
    else:
        fmc_set_header(cast[Ptr[uint8]]("Open: "))
    if start_dir != cast[Ptr[uint8]](0) and start_dir[0] != 0:
        fmc_set_cur_path(start_dir)
    else:
        fmc_set_cur_path(cast[Ptr[uint8]]("/home/live/Documents"))
    fmc_load_dir()
    # If the start dir had no entries (couldn't be opened/listed), climb to
    # /home, then /, so the picker always shows something.
    if fmc_num_entries() == 0 and fmc_has_up_entry() == 0:
        fmc_set_cur_path(cast[Ptr[uint8]]("/home"))
        fmc_load_dir()
    if fmc_num_entries() == 0 and fmc_has_up_entry() == 0:
        fmc_set_cur_path(cast[Ptr[uint8]]("/"))
        fmc_load_dir()
    # Select the first real entry (after the synthetic Up row).
    first: int64 = 0
    if fmc_has_up_entry() != 0 and fmc_num_entries() > 1:
        first = 1
    if fmc_num_entries() > 0:
        fmc_select(first)
    else:
        fmc_select(-1)


def filepick_active() -> int32:
    return fp_mode


# Commit a pick into the result slot and close the picker.
def _fp_emit_result(mode: int32, path: Ptr[uint8]):
    k: uint64 = 0
    while path[k] != 0 and k < 575:
        fp_result_path[k] = path[k]
        k = k + 1
    fp_result_path[k] = 0
    fp_result_mode = mode
    fp_result_ready = 1
    fp_mode = 0


# Commit a SAVE: compose <cur_path>/<typed name> as the result path.
def _fp_commit_save():
    if fp_save_len == 0:
        return
    dir: Ptr[uint8] = fmc_cur_path_ptr()
    p: uint64 = 0
    while dir[p] != 0 and p < 574:
        fp_full[p] = dir[p]
        p = p + 1
    if p == 0 or fp_full[p - 1] != 47:
        fp_full[p] = 47
        p = p + 1
    k: uint64 = 0
    while k < fp_save_len and p < 575:
        fp_full[p] = fp_save_name[k]
        p = p + 1
        k = k + 1
    fp_full[p] = 0
    _fp_emit_result(FILEPICK_SAVE, &fp_full[0])


# Seed the SAVE filename field from a picked file's basename.
def _fp_seed_name_from(u: uint64):
    fp_save_len = 0
    nl: uint64 = fmc_entry_name_len(u)
    src: Ptr[uint8] = fmc_name_ptr(u)
    kk: uint64 = 0
    while kk < nl and fp_save_len < 126:
        fp_save_name[fp_save_len] = src[kk]
        fp_save_len = fp_save_len + 1
        kk = kk + 1
    fp_save_name[fp_save_len] = 0


# Activate the current selection. A directory (or "..") navigates via the core;
# a file OPENs (mode 1) or, in SAVE mode, seeds the filename field.
def _fp_activate():
    n: uint64 = fmc_num_entries()
    if n == 0:
        return
    sel: int64 = fmc_selected()
    if sel < 0:
        return
    u: uint64 = cast[uint64](sel)
    if u >= n:
        return
    if fmc_has_up_entry() != 0 and u == 0:
        fmc_go_parent()
        _fp_reselect_first()
        return
    if fmc_entry_is_dir(u) != 0:
        fmc_go_into(u)
        _fp_reselect_first()
        return
    # A regular file.
    if fp_mode == FILEPICK_OPEN:
        _fp_emit_result(FILEPICK_OPEN, fmc_full_path_ptr(u))
    else:
        _fp_seed_name_from(u)


# After a directory change the core clears its selection; re-anchor it on the
# first real entry so key navigation has a starting point.
def _fp_reselect_first():
    first: int64 = 0
    if fmc_has_up_entry() != 0 and fmc_num_entries() > 1:
        first = 1
    if fmc_num_entries() > 0:
        fmc_select(first)
    else:
        fmc_select(-1)


# Host calls this each loop. Returns 1 (and clears the flag) if a pick was
# committed since the last call.
def filepick_take_result() -> int32:
    if fp_result_ready == 0:
        return 0
    fp_result_ready = 0
    return 1


def filepick_result_path() -> Ptr[uint8]:
    return &fp_result_path[0]


def filepick_result_mode() -> int32:
    return fp_result_mode


# Render the picker overlay over the caller's whole window canvas. The caller
# owns hamscene_begin()/hamscene_commit(); this paints between them: first the
# SHARED icon grid (fmc_paint, reserving FP_BOTTOM_H at the bottom), then the
# picker's own Name/hint + OK·Cancel strip.
def filepick_emit(ed_w: int32, ed_h: int32):
    # Match the core geometry to the host window and reserve the bottom strip.
    fmc_set_geometry(cast[int64](ed_w), cast[int64](ed_h), FP_BOTTOM_H)
    # Keep the selected cell in view (key navigation may have moved it).
    fmc_scroll_to(fmc_selected())
    # SHARED icon-grid browser (breadcrumb header + folder/file icons).
    fmc_paint()
    # --- picker chrome: bottom strip ---------------------------------
    fy: int32 = ed_h - FP_BOTTOM_H
    hamscene_fill(0, fy, ed_w, FP_BOTTOM_H, cast[Ptr[uint8]]("#e8e8d8"))
    hamscene_stroke(2, fy + 1, ed_w - 4, FP_BOTTOM_H - 3, 1,
                    cast[Ptr[uint8]]("#808060"))
    # Name field (SAVE) or key hint (OPEN).
    fbuf: Array[160, uint8]
    fp: uint64 = 0
    if fp_mode == FILEPICK_SAVE:
        nm: Ptr[uint8] = cast[Ptr[uint8]]("Name: ")
        a2: uint64 = 0
        while nm[a2] != 0:
            fbuf[fp] = nm[a2]
            fp = fp + 1
            a2 = a2 + 1
        k2: uint64 = 0
        while k2 < fp_save_len and fp < 150:
            fbuf[fp] = fp_save_name[k2]
            fp = fp + 1
            k2 = k2 + 1
        fbuf[fp] = 95                                 # '_' caret
        fp = fp + 1
    else:
        h2: Ptr[uint8] = cast[Ptr[uint8]](
            "Up/Dn/L/R=move Enter=open/cd Esc=cancel")
        a2: uint64 = 0
        while h2[a2] != 0 and fp < 150:
            fbuf[fp] = h2[a2]
            fp = fp + 1
            a2 = a2 + 1
    fbuf[fp] = 0
    hamscene_glyphs(6, fy + 4, &fbuf[0], cast[Ptr[uint8]]("#202020"))
    # OK / Cancel buttons along the bottom of the strip.
    okx: int32 = ed_w - 120
    cax: int32 = ed_w - 58
    by2: int32 = fy + 18
    hamscene_fill(okx, by2, 54, 14, cast[Ptr[uint8]]("#cfe0f4"))
    hamscene_stroke(okx, by2, 54, 14, 1, cast[Ptr[uint8]]("#5a9bf0"))
    hamscene_glyphs(okx + 18, by2 + 2, cast[Ptr[uint8]]("OK"),
                    cast[Ptr[uint8]]("#1a4a8a"))
    hamscene_fill(cax, by2, 54, 14, cast[Ptr[uint8]]("#f0d6d6"))
    hamscene_stroke(cax, by2, 54, 14, 1, cast[Ptr[uint8]]("#c45f5f"))
    hamscene_glyphs(cax + 6, by2 + 2, cast[Ptr[uint8]]("Cancel"),
                    cast[Ptr[uint8]]("#8a1a1a"))


# Move the selection by a cell delta (clamped to real entries).
def _fp_move_sel(delta: int64):
    n: uint64 = fmc_num_entries()
    if n == 0:
        return
    sel: int64 = fmc_selected()
    if sel < 0:
        sel = 0
    sel = sel + delta
    if sel < 0:
        sel = 0
    if sel >= cast[int64](n):
        sel = cast[int64](n) - 1
    fmc_select(sel)


# Handle a key while the picker is open. Returns 1 if the scene changed.
# Arrow keys arrive as ESC '[' A/B/C/D; a LONE Escape cancels.
def filepick_handle_code(code: int32) -> int32:
    if fp_esc_st == 1:
        if code == 91:                              # '['
            fp_esc_st = 2
            return 0
        fp_esc_st = 0
        fp_mode = 0                                 # lone ESC -> cancel
        return 1
    elif fp_esc_st == 2:
        fp_esc_st = 0
        if code == 65:                              # up
            _fp_move_sel(-fmc_cols_for_nav())
            return 1
        if code == 66:                              # down
            _fp_move_sel(fmc_cols_for_nav())
            return 1
        if code == 68:                              # left
            _fp_move_sel(-1)
            return 1
        if code == 67:                              # right
            _fp_move_sel(1)
            return 1
        return 0
    if code == 27:                                  # ESC -> begin CSI / cancel
        fp_esc_st = 1
        return 0
    if code == 3:                                   # Ctrl-C -> cancel
        fp_mode = 0
        return 1
    if code == 13 or code == 10:                    # Enter == OK
        if fp_mode == FILEPICK_SAVE:
            sel: int64 = fmc_selected()
            on_dir: int32 = 0
            n: uint64 = fmc_num_entries()
            if sel >= 0 and cast[uint64](sel) < n and \
               fmc_entry_is_dir(cast[uint64](sel)) != 0:
                on_dir = 1
            if on_dir != 0:
                _fp_activate()                      # navigate into dir
                return 1
            _fp_commit_save()
        else:
            _fp_activate()
        return 1
    if fp_mode == FILEPICK_SAVE:
        if code == 8 or code == 127:                # Backspace
            if fp_save_len > 0:
                fp_save_len = fp_save_len - 1
                fp_save_name[fp_save_len] = 0
            return 1
        if code >= 32 and code < 127:
            if fp_save_len < 126:
                fp_save_name[fp_save_len] = cast[uint8](code)
                fp_save_len = fp_save_len + 1
                fp_save_name[fp_save_len] = 0
            return 1
    return 0


# Up/Down move by a full grid ROW. The core owns the live column count; expose
# it for the navigation step (1 if unknown, never 0).
def fmc_cols_for_nav() -> int64:
    c: int64 = fmc_grid_cols()
    if c < 1:
        c = 1
    return c


# Optional pointer support: the host may forward a click in content-local
# coords. Single click selects; a click on the already-selected cell (or any
# dir) activates (enter dir / open file). Returns 1 if the scene changed.
def filepick_click(lx: int64, ly: int64) -> int32:
    idx: int64 = fmc_cell_at(lx, ly)
    if idx < 0:
        return 0
    prev: int64 = fmc_selected()
    fmc_select(idx)
    if prev == idx:
        _fp_activate()
    return 1

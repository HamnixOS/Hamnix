# lib/hamgame_dev.ad — hamGame DEVICE backend (x86_64-adder-user only).
#
# The Hamnix transport for lib/hamgame.ad, the pygame-shaped layer. It REUSES
# the hamSDL device backend (lib/hamsdl_dev.ad) for the window lifecycle, input
# pump, frame commit and the jiffy clock — no duplication — and ADDS only what
# the pygame present model needs that hamSDL lacks: uploading a WHOLE display
# Surface (up to GAME_MAX_DIM^2) as the named screen image. hamSDL's own sprite
# upload buffer caps at 96x96, too small for a full backbuffer, so hamGame keeps
# a larger one here. Like lib/hamsdl_dev.ad this is a DEVICE-only module (it
# links native externs); the host mirror is lib/hamgame_host.ad.
#
# PUBLIC API (device half of the hamGame seam):
#   game_dev_init(title,x,y,w,h) -> int32   create a titled game window (wid)
#   game_dev_wid() -> int32                 the current window id
#   game_dev_pump()                         drain /keys + /event -> events
#   game_dev_present(surf) -> int32         upload `surf` as the screen image +
#                                           commit the built frame (0 ok)
#   game_dev_ticks() -> uint64              milliseconds since boot
#   game_dev_delay(ms)                      cooperative sleep for ms
#   game_dev_play_pcm(buf,n) -> int32       thin audio hook: stream raw PCM to
#                                           the native HDA sink (/dev/audio)
#
# A game's device main() is: init -> loop { pump; drain game_poll_event;
# update; draw onto the display Surface; game_flip_scene + game_dev_present;
# delay }. See user/hamgamedemo.ad.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamsdl_dev import sdl_dev_init, sdl_dev_wid, sdl_dev_pump, \
    sdl_dev_present, sdl_dev_ticks, sdl_dev_delay
from lib.hamgame import game_screen_name, game_surface_w, game_surface_h, \
    game_surface_ptr


# Upload staging: the 'I' verb header + up to 256x256 RGBA8888 pixels.
GAME_DEV_MAX_DIM: int32 = 256
_game_img_buf: Array[262400, uint8]                       # 256*256*4 + 384 hdr


def game_dev_init(title: Ptr[uint8], x: int32, y: int32,
                  w: int32, h: int32) -> int32:
    return sdl_dev_init(title, x, y, w, h)


def game_dev_wid() -> int32:
    return sdl_dev_wid()


def game_dev_pump():
    sdl_dev_pump()


def game_dev_ticks() -> uint64:
    return sdl_dev_ticks()


def game_dev_delay(ms: uint64):
    sdl_dev_delay(ms)


def _game_slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _game_u64_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    tmp: Array[24, uint8]
    n: uint64 = 0
    while v > 0:
        tmp[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    i: uint64 = 0
    while i < n:
        out[i] = tmp[n - 1 - i]
        i = i + 1
    return n


# Build "/dev/wsys/<wid>/draw/ctl" into out.
def _game_drawpath(out: Ptr[uint8], wid: int32):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _game_u64_dec(cast[uint64](wid), &out[p])
    leaf: Ptr[uint8] = cast[Ptr[uint8]]("/draw/ctl")
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


def _game_put_i32le(off: uint64, v: int32):
    u: uint32 = cast[uint32](v)
    _game_img_buf[off]     = cast[uint8](u & 255)
    _game_img_buf[off + 1] = cast[uint8]((u >> 8) & 255)
    _game_img_buf[off + 2] = cast[uint8]((u >> 16) & 255)
    _game_img_buf[off + 3] = cast[uint8]((u >> 24) & 255)


# Upload the display Surface `surf` under game_screen_name() to the window's
# named-image store (the 'I' verb on /dev/wsys/<wid>/draw/ctl), then commit the
# scene hamGame built (game_flip_scene referenced that name). Returns 0 on ok.
def game_dev_present(surf: int32) -> int32:
    wid: int32 = sdl_dev_wid()
    if wid < 0:
        return -1
    w: int32 = game_surface_w(surf)
    h: int32 = game_surface_h(surf)
    if w <= 0 or h <= 0 or w > GAME_DEV_MAX_DIM or h > GAME_DEV_MAX_DIM:
        return -1
    name: Ptr[uint8] = game_screen_name()
    nl: uint64 = _game_slen(name)
    pix: uint64 = cast[uint64](w) * cast[uint64](h) * 4
    hdr: uint64 = 2 + nl + 9
    if hdr + pix > 262400:
        return -1
    _game_img_buf[0] = 73                                  # 'I'
    _game_img_buf[1] = cast[uint8](nl)
    k: uint64 = 0
    while k < nl:
        _game_img_buf[2 + k] = name[k]
        k = k + 1
    _game_put_i32le(2 + nl, w)
    _game_put_i32le(2 + nl + 4, h)
    _game_img_buf[2 + nl + 8] = 1                          # WSYS_BLIT_FMT_RGBA8888
    src: Ptr[uint8] = game_surface_ptr(surf)
    j: uint64 = 0
    while j < pix:
        _game_img_buf[hdr + j] = src[j]
        j = j + 1
    dpath: Array[64, uint8]
    _game_drawpath(&dpath[0], wid)
    fd: int32 = sys_open_write(cast[Ptr[char]](&dpath[0]))
    if fd < 0:
        return -1
    sys_write(fd, &_game_img_buf[0], hdr + pix)
    sys_close(fd)
    return sdl_dev_present()


# ---- Thin audio hook (pygame.mixer.Sound-shaped) -------------------------
# Stream raw PCM sample bytes straight to the native HDA sink. This round is a
# thin shim: the caller supplies already-decoded PCM (e.g. via lib/mp3decode.ad
# or a WAV body) and this pushes it to /dev/audio, the same file the aplay app
# writes. A richer mixer (channels, looping, format negotiation via
# /dev/audioctl) is deferred; see docs/hamgame.md.
def game_dev_play_pcm(buf: Ptr[uint8], n: uint64) -> int32:
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/audio"))
    if fd < 0:
        return -1
    wr: int64 = sys_write(fd, buf, n)
    sys_close(fd)
    if wr < 0:
        return -1
    return 0

# lib/hamtextbox.ad — shared editable text-box widget for hamUI scene apps.
#
# WHY THIS EXISTS (task #303, user-reported 2026-07-15):
# The DE `glyphs` scene primitive USED to be a monospace 8x16 cell font, so
# every app placed its text caret at `char_index * 8`. Task #284 re-routed the
# `text`/`glyphs` primitives through the PROPORTIONAL DejaVu Sans TTF engine
# (lib/font_ttf via the compositor's _wsys_cache_draw_str_aa). Glyph advances
# are now VARIABLE, but the per-app `index * 8` caret math stayed monospace, so
# the caret drifts further and further right of the real insertion point the
# more (narrower-than-8px) glyphs precede it — matching the user's editor,
# Notes-title, hamfm-new-file and installer-hostname reports.
#
# THE FIX: caret pixel-X must be the SUM of the SAME per-glyph advances the
# compositor uses to lay the string out. The compositor renders at
# WSYS_UI_PX(14) with FACE_TT_SANS and advances by font_ttf_render()'s g_adv,
# which is computed identically to font_ttf_adv_px() (both are
# (_hadv*px + upm/2)/upm). We reuse font_ttf_adv_px over the same embedded face
# (browserfonts_load bakes the identical DejaVu bytes), so our measured caret X
# is pixel-exact with the drawn text — no reinvented metrics.
#
# This module is the ONE place that owns editable-text cursor math + input-zone
# key handling. Apps either (a) call the pure measurement helpers to place a
# caret over their own buffer, or (b) allocate a managed single-line box and
# feed it raw key bytes (arrow/Home/End/Backspace/Delete decoded as NAVIGATION,
# never appended as escape garbage).

from lib.font_ttf import font_ttf_adv_px, font_ttf_loaded, FACE_TT_SANS
from lib.browserfonts import browserfonts_load
from lib.hamscene import hamscene_glyphs, hamscene_fill

# task #315: file-backed clipboard/selection. The two X11-style buffers are
# Plan 9 FILES the compositor serves (NO new syscall — arch invariant): the
# CLIPBOARD is /dev/snarf (Ctrl+C/Ctrl+V), the PRIMARY selection is
# /dev/snarf.primary (auto-filled on highlight, middle-click paste). A text
# box copies its selection by WRITING the file and pastes by READING it.
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

# MUST match devwsys.ad WSYS_UI_PX. The compositor lays out DE `text`/`glyphs`
# at this pixel size; our advance sum has to use the same px or the caret and
# the glyphs disagree.
HTB_UI_PX: int32 = 14

# Fallback cell width used only when the font engine is unavailable (boot must
# never depend on the TTF). Matches the old 8x16 cell advance.
HTB_FALLBACK_W: int32 = 8


# ---- font readiness -------------------------------------------------------
def htb_font_ready() -> int32:
    # Idempotent: browserfonts_load() self-guards and only decodes once.
    browserfonts_load()
    return font_ttf_loaded(FACE_TT_SANS)


# ---- pure measurement (the core fix) --------------------------------------
# Pixel width of the first `n` bytes of `buf` in the DE proportional face —
# i.e. exactly how far the compositor's pen advances drawing buf[0..n).
def htb_text_width(buf: Ptr[uint8], n: uint64) -> int32:
    if htb_font_ready() == 0:
        return cast[int32](n) * HTB_FALLBACK_W
    w: int32 = 0
    i: uint64 = 0
    while i < n:
        w = w + font_ttf_adv_px(FACE_TT_SANS, cast[uint64](buf[i]), HTB_UI_PX)
        i = i + 1
    return w


# Caret pixel X for a caret sitting BEFORE byte `cidx`, given the text's left
# edge is drawn at `x0`. This is the drop-in replacement for `x0 + cidx*8`.
def htb_caret_x(x0: int32, buf: Ptr[uint8], cidx: uint64) -> int32:
    return x0 + htb_text_width(buf, cidx)


# ---- click-to-position (task #315: the INVERSE of htb_caret_x) ------------
# Given a run of `n` bytes drawn with its left edge at `x0`, return the caret
# index (0..n) whose caret-X is nearest `click_x`. This is the exact inverse
# of htb_caret_x: walk the SAME proportional advances and pick the gap the
# click fell closest to (a click in the LEFT half of a glyph lands the caret
# BEFORE it, the RIGHT half AFTER it). Fixes "clicking the input doesn't move
# the caret to the click until you type" — an app maps a pointer x to a caret
# with this, then sets its caret there.
def htb_hit_test(x0: int32, buf: Ptr[uint8], n: uint64, click_x: int32) -> uint64:
    if click_x <= x0:
        return 0
    ready: int32 = htb_font_ready()
    x: int32 = x0
    i: uint64 = 0
    while i < n:
        adv: int32 = HTB_FALLBACK_W
        if ready != 0:
            adv = font_ttf_adv_px(FACE_TT_SANS, cast[uint64](buf[i]), HTB_UI_PX)
        # Midpoint of glyph i: left half -> caret before i, right half -> after.
        if click_x < x + adv / 2:
            return i
        x = x + adv
        i = i + 1
    return n


# ---- managed single-line boxes -------------------------------------------
# Instance state as handle-indexed parallel arrays (this codebase has no
# structs). A handle is 0..HTB_MAX-1; htb_new() hands them out in order.
HTB_MAX: int32 = 12                       # concurrent boxes across all apps
HTB_CAP: uint64 = 256                     # bytes per box (incl. NUL)

_htb_used:  Array[12, int32]              # slot allocated?
_htb_len:   Array[12, uint64]             # bytes in the buffer
_htb_cur:   Array[12, uint64]             # caret byte index (0..len)
_htb_esc:   Array[12, int32]             # CSI decode: 0 none, 1 ESC, 2 ESC[
_htb_par:   Array[12, int32]             # CSI numeric param (first digit)
# task #315: selection ANCHOR (the other end of a highlight) + an explicit
# ACTIVE flag. The selection is [min(anchor,caret), max(anchor,caret)); it is
# reported/drawn ONLY when _htb_selon is set. A box that never touches the
# selection API keeps _htb_selon == 0 forever, so htb_selection() reports an
# empty range and htb_render draws no highlight — byte-inert for non-selecting
# apps. Any ordinary key fed to htb_feed collapses the selection (selon->0),
# matching editor behaviour where typing/navigating clears the highlight.
_htb_anc:   Array[12, uint64]             # selection anchor byte index
_htb_selon: Array[12, int32]              # 1 iff a selection is live
_htb_buf:   Array[3072, uint8]            # HTB_MAX*HTB_CAP flattened storage


def _htb_base(h: int32) -> uint64:
    return cast[uint64](h) * HTB_CAP


def htb_new() -> int32:
    h: int32 = 0
    while h < HTB_MAX:
        if _htb_used[cast[uint64](h)] == 0:
            _htb_used[cast[uint64](h)] = 1
            _htb_len[cast[uint64](h)] = 0
            _htb_cur[cast[uint64](h)] = 0
            _htb_esc[cast[uint64](h)] = 0
            _htb_par[cast[uint64](h)] = 0
            _htb_anc[cast[uint64](h)] = 0
            _htb_selon[cast[uint64](h)] = 0
            _htb_buf[_htb_base(h)] = 0
            return h
        h = h + 1
    return -1                             # pool exhausted


def htb_reset(h: int32):
    _htb_len[cast[uint64](h)] = 0
    _htb_cur[cast[uint64](h)] = 0
    _htb_esc[cast[uint64](h)] = 0
    _htb_par[cast[uint64](h)] = 0
    _htb_anc[cast[uint64](h)] = 0
    _htb_selon[cast[uint64](h)] = 0
    _htb_buf[_htb_base(h)] = 0


# Load an initial NUL-terminated string, caret to end.
def htb_set(h: int32, s: Ptr[uint8], n: uint64):
    base: uint64 = _htb_base(h)
    m: uint64 = n
    if m > HTB_CAP - 1:
        m = HTB_CAP - 1
    i: uint64 = 0
    while i < m:
        _htb_buf[base + i] = s[i]
        i = i + 1
    _htb_buf[base + m] = 0
    _htb_len[cast[uint64](h)] = m
    _htb_cur[cast[uint64](h)] = m
    _htb_esc[cast[uint64](h)] = 0
    _htb_anc[cast[uint64](h)] = m
    _htb_selon[cast[uint64](h)] = 0


def htb_text(h: int32) -> Ptr[uint8]:
    return &_htb_buf[_htb_base(h)]


def htb_len(h: int32) -> uint64:
    return _htb_len[cast[uint64](h)]


def htb_caret(h: int32) -> uint64:
    return _htb_cur[cast[uint64](h)]


def htb_set_caret(h: int32, c: uint64):
    ln: uint64 = _htb_len[cast[uint64](h)]
    if c > ln:
        c = ln
    _htb_cur[cast[uint64](h)] = c


# Insert one printable byte at the caret (shifting the tail right).
def _htb_insert(h: int32, c: uint8) -> int32:
    hu: uint64 = cast[uint64](h)
    ln: uint64 = _htb_len[hu]
    if ln + 1 >= HTB_CAP:
        return 0
    base: uint64 = _htb_base(h)
    cur: uint64 = _htb_cur[hu]
    j: uint64 = ln
    while j > cur:
        _htb_buf[base + j] = _htb_buf[base + j - 1]
        j = j - 1
    _htb_buf[base + cur] = c
    _htb_len[hu] = ln + 1
    _htb_cur[hu] = cur + 1
    _htb_buf[base + ln + 1] = 0
    return 1


# Delete the byte BEFORE the caret (Backspace).
def _htb_backspace(h: int32) -> int32:
    hu: uint64 = cast[uint64](h)
    cur: uint64 = _htb_cur[hu]
    if cur == 0:
        return 0
    base: uint64 = _htb_base(h)
    ln: uint64 = _htb_len[hu]
    j: uint64 = cur - 1
    while j + 1 < ln:
        _htb_buf[base + j] = _htb_buf[base + j + 1]
        j = j + 1
    _htb_len[hu] = ln - 1
    _htb_cur[hu] = cur - 1
    _htb_buf[base + ln - 1] = 0
    return 1


# Delete the byte AT the caret (Delete / CSI 3~).
def _htb_delete(h: int32) -> int32:
    hu: uint64 = cast[uint64](h)
    cur: uint64 = _htb_cur[hu]
    ln: uint64 = _htb_len[hu]
    if cur >= ln:
        return 0
    base: uint64 = _htb_base(h)
    j: uint64 = cur
    while j + 1 < ln:
        _htb_buf[base + j] = _htb_buf[base + j + 1]
        j = j + 1
    _htb_len[hu] = ln - 1
    _htb_buf[base + ln - 1] = 0
    return 1


# Apply a decoded CSI final byte (after ESC '['). Returns 1 if state changed.
def _htb_csi_final(h: int32, code: int32) -> int32:
    hu: uint64 = cast[uint64](h)
    cur: uint64 = _htb_cur[hu]
    ln: uint64 = _htb_len[hu]
    if code == 67:                        # 'C' — Right
        if cur < ln:
            _htb_cur[hu] = cur + 1
            return 1
        return 0
    if code == 68:                        # 'D' — Left
        if cur > 0:
            _htb_cur[hu] = cur - 1
            return 1
        return 0
    if code == 72:                        # 'H' — Home
        if cur != 0:
            _htb_cur[hu] = 0
            return 1
        return 0
    if code == 70:                        # 'F' — End
        if cur != ln:
            _htb_cur[hu] = ln
            return 1
        return 0
    if code == 51:                        # from "3~" — Delete
        return _htb_delete(h)
    # 'A'/'B' (Up/Down) have no meaning in a single-line box: consume silently.
    return 0


# Feed one RAW input byte to box `h`. Decodes arrow/Home/End/Delete escape
# sequences (ESC '[' <final>, and ESC '[' <digit> '~') as caret NAVIGATION so
# they are never appended as literal "[C"/"C" garbage. Printable ASCII inserts
# at the caret; Backspace/DEL delete at the caret. Returns 1 if the box changed
# (caller should redraw). `filter` is an optional predicate: 0 accepts all
# printables, otherwise pass a class code (see htb_char_ok) to gate inserts.
def htb_feed_f(h: int32, code: int32, cls: int32) -> int32:
    hu: uint64 = cast[uint64](h)
    # task #315: any ordinary key collapses a live selection (type/navigate
    # over a highlight clears it). Copy (Ctrl+C) is intercepted by the app
    # BEFORE it reaches htb_feed, so this never eats a copy. No-op for
    # non-selecting boxes (selon already 0).
    _htb_selon[hu] = 0
    st: int32 = _htb_esc[hu]
    if st == 1:                           # after ESC
        if code == 91:                    # '['
            _htb_esc[hu] = 2
            return 0
        _htb_esc[hu] = 0                  # bare ESC / ESC<other>: abandon
        return 0
    if st == 2:                           # inside CSI
        if code >= 48 and code <= 57:     # digit param (e.g. "3~", "1~", "4~")
            _htb_par[hu] = code
            return 0
        _htb_esc[hu] = 0
        fin: int32 = code
        if code == 126:                   # '~' final: map by param
            p: int32 = _htb_par[hu]
            _htb_par[hu] = 0
            if p == 49:                    # '1' — Home
                fin = 72
            elif p == 52:                  # '4' — End
                fin = 70
            elif p == 51:                  # '3' — Delete
                fin = 51
            else:
                return 0
        _htb_par[hu] = 0
        return _htb_csi_final(h, fin)
    if code == 27:                        # ESC — begin a sequence
        _htb_esc[hu] = 1
        return 0
    if code == 8 or code == 127:          # Backspace / DEL
        return _htb_backspace(h)
    if code == 1:                         # Ctrl-A — Home
        if _htb_cur[hu] != 0:
            _htb_cur[hu] = 0
            return 1
        return 0
    if code == 5:                         # Ctrl-E — End
        if _htb_cur[hu] != _htb_len[hu]:
            _htb_cur[hu] = _htb_len[hu]
            return 1
        return 0
    if code < 32 or code >= 127:          # other control / non-ASCII: ignore
        return 0
    if cls != 0 and htb_char_ok(cast[uint8](code), cls) == 0:
        return 0
    return _htb_insert(h, cast[uint8](code))


def htb_feed(h: int32, code: int32) -> int32:
    return htb_feed_f(h, code, 0)


# Character-class filter for field inputs. Class codes:
#   1 = hostname/DNS label (letters, digits, '-')
#   2 = unix username (lowercase letters, digits, '-', '_')
#   3 = digits only
# Class 0 (or unknown) accepts any printable — callers pass 0 to skip filtering.
def htb_char_ok(c: uint8, cls: int32) -> int32:
    if cls == 3:
        if c >= 48 and c <= 57:
            return 1
        return 0
    is_alpha: int32 = 0
    if c >= 65 and c <= 90:
        is_alpha = 1
    if c >= 97 and c <= 122:
        is_alpha = 1
    is_digit: int32 = 0
    if c >= 48 and c <= 57:
        is_digit = 1
    if cls == 1:                          # hostname
        if is_alpha != 0 or is_digit != 0:
            return 1
        if c == 45:                       # '-'
            return 1
        return 0
    if cls == 2:                          # username
        if is_digit != 0:
            return 1
        if c >= 97 and c <= 122:          # lowercase only
            return 1
        if c == 45 or c == 95:            # '-' '_'
            return 1
        return 0
    return 1                              # class 0: accept all printables


# Proportional caret X for a managed box drawn with its text left edge at `x0`.
def htb_caret_px(h: int32, x0: int32) -> int32:
    return x0 + htb_text_width(&_htb_buf[_htb_base(h)], _htb_cur[cast[uint64](h)])


# One-call "here's a text box": draw the box's text glyphs at (x, y) and, when
# focused, a caret bar at the correct proportional X. `cbar_w`/`cbar_h`/`cbar_dy`
# size the caret (apps used 2x14 blocks and 1x12 bars); pass what matches the
# field chrome. Text/caret colours are NUL-terminated "#RRGGBB" strings.
def htb_render(h: int32, x: int32, y: int32, focus: int32,
               textcol: Ptr[uint8], caretcol: Ptr[uint8],
               cbar_w: int32, cbar_h: int32, cbar_dy: int32):
    base: uint64 = _htb_base(h)
    hu: uint64 = cast[uint64](h)
    # task #315: highlight the selected glyph run FIRST (under the text) so
    # the glyphs read on top of the selection band. Byte-inert when no
    # selection is live (_htb_selon == 0), so non-selecting fields are
    # unchanged. The band uses the SAME advance sums as the caret, so it
    # lines up glyph-exact with the text.
    if _htb_selon[hu] != 0:
        ss: uint64 = _htb_anc[hu]
        se: uint64 = _htb_cur[hu]
        if ss > se:
            ss = _htb_cur[hu]
            se = _htb_anc[hu]
        if se > ss:
            hx0: int32 = x + htb_text_width(&_htb_buf[base], ss)
            hx1: int32 = x + htb_text_width(&_htb_buf[base], se)
            # A soft blue selection band spanning the run; height matches the
            # caret bar's cell so it sits behind the glyph row.
            hamscene_fill(hx0, y + cbar_dy, hx1 - hx0, cbar_h,
                          cast[Ptr[uint8]]("#b4d0f8"))
    if _htb_len[hu] > 0:
        hamscene_glyphs(x, y, &_htb_buf[base], textcol)
    if focus != 0:
        cx: int32 = htb_caret_px(h, x)
        hamscene_fill(cx, y + cbar_dy, cbar_w, cbar_h, caretcol)


# ---- managed-box selection API (task #315) --------------------------------
# A pointer press inside a box: place BOTH the caret and the anchor at the
# hit-tested index (a collapsed selection). `x0` is the text's left edge in
# the same coords the box is rendered at; `click_x` is the pointer X.
def htb_sel_click(h: int32, x0: int32, click_x: int32):
    hu: uint64 = cast[uint64](h)
    idx: uint64 = htb_hit_test(x0, &_htb_buf[_htb_base(h)], _htb_len[hu], click_x)
    _htb_cur[hu] = idx
    _htb_anc[hu] = idx
    _htb_selon[hu] = 0                        # collapsed: nothing selected yet


# Pointer DRAG (motion with the button down): move the caret to the hit-tested
# index, KEEPING the anchor, extending the selection. Marks the selection live
# once the caret and anchor differ.
def htb_sel_drag(h: int32, x0: int32, click_x: int32):
    hu: uint64 = cast[uint64](h)
    idx: uint64 = htb_hit_test(x0, &_htb_buf[_htb_base(h)], _htb_len[hu], click_x)
    _htb_cur[hu] = idx
    if idx != _htb_anc[hu]:
        _htb_selon[hu] = 1
    else:
        _htb_selon[hu] = 0


# Is a (non-empty) selection live on this box?
def htb_sel_active(h: int32) -> int32:
    hu: uint64 = cast[uint64](h)
    if _htb_selon[hu] == 0:
        return 0
    if _htb_anc[hu] == _htb_cur[hu]:
        return 0
    return 1


# Selection bounds as [start,end) into the box buffer (start<=end). Returns 0
# when nothing is selected (start==end).
def htb_sel_start(h: int32) -> uint64:
    hu: uint64 = cast[uint64](h)
    if htb_sel_active(h) == 0:
        return _htb_cur[hu]
    if _htb_anc[hu] < _htb_cur[hu]:
        return _htb_anc[hu]
    return _htb_cur[hu]


def htb_sel_end(h: int32) -> uint64:
    hu: uint64 = cast[uint64](h)
    if htb_sel_active(h) == 0:
        return _htb_cur[hu]
    if _htb_anc[hu] > _htb_cur[hu]:
        return _htb_anc[hu]
    return _htb_cur[hu]


def htb_sel_clear(h: int32):
    hu: uint64 = cast[uint64](h)
    _htb_anc[hu] = _htb_cur[hu]
    _htb_selon[hu] = 0


# ---- file-backed clipboard / selection service (task #315) ----------------
# The two X11-style buffers are Plan 9 files served by the compositor. `prim`
# selects which: 0 = CLIPBOARD (/dev/snarf, Ctrl+C/Ctrl+V), 1 = PRIMARY
# (/dev/snarf.primary, highlight -> middle-click paste). No new syscall: a
# copy WRITES the file, a paste READS it.
def _htb_clip_path(prim: int32) -> Ptr[char]:
    if prim != 0:
        return cast[Ptr[char]]("/dev/snarf.primary")
    return cast[Ptr[char]]("/dev/snarf")


# Copy `n` bytes of `buf` into the selected clipboard file (REPLACE). Returns
# 1 on success, 0 if the file could not be opened/written.
def htb_clip_put(prim: int32, buf: Ptr[uint8], n: uint64) -> int32:
    fd: int32 = sys_open_write(_htb_clip_path(prim))
    if fd < 0:
        return 0
    # A single write REPLACES the whole buffer (the device is REPLACE-on-write).
    w: int64 = 0
    if n > 0:
        w = sys_write(fd, buf, n)
    else:
        w = sys_write(fd, buf, 0)             # 0-byte write clears the buffer
    sys_close(fd)
    if w < 0:
        return 0
    return 1


# Read up to `cap` bytes of the selected clipboard file into `out`. Returns
# the number of bytes read (0 if empty / unopenable). Reads in a loop so a
# chunk-capped device read still drains the whole buffer.
def htb_clip_get(prim: int32, out: Ptr[uint8], cap: uint64) -> uint64:
    fd: int32 = sys_open(_htb_clip_path(prim))
    if fd < 0:
        return 0
    total: uint64 = 0
    while total < cap:
        r: int64 = sys_read(fd, &out[total], cap - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    return total


# Convenience: copy a managed box's live selection into a clipboard file.
# Returns the number of bytes copied (0 if nothing selected).
def htb_sel_copy(h: int32, prim: int32) -> uint64:
    if htb_sel_active(h) == 0:
        return 0
    ss: uint64 = htb_sel_start(h)
    se: uint64 = htb_sel_end(h)
    n: uint64 = se - ss
    htb_clip_put(prim, &_htb_buf[_htb_base(h) + ss], n)
    return n


# ---- word / line boundaries + multi-click (task #328) ---------------------
# Linux/Windows convention: a SINGLE click places the caret, a DOUBLE click
# selects the WORD under it, a TRIPLE click selects the whole LINE. The two
# boundary helpers below are PURE (buffer + length + a reference byte index)
# so every text surface — the managed boxes here, the editor's flat doc, the
# Notes fields — computes identical word/line spans from one place.

# A "word character": ASCII alphanumerics plus '_' (matches the double-click
# word class in GTK/xterm). Everything else (space, punctuation, newline) is a
# boundary.
def htb_is_word_char(c: uint8) -> int32:
    if c >= 48 and c <= 57:                    # 0-9
        return 1
    if c >= 65 and c <= 90:                    # A-Z
        return 1
    if c >= 97 and c <= 122:                   # a-z
        return 1
    if c == 95:                                # '_'
        return 1
    return 0


# Whitespace class used to group a non-word double-click run (so a click in a
# gap of spaces selects the spaces, not an adjacent word).
def _htb_is_space(c: uint8) -> int32:
    if c == 32 or c == 9 or c == 10 or c == 13:
        return 1
    return 0


# WORD bounds around reference index `idx` (a caret 0..n or a click index).
# Writes [*startp,*endp) — the span the double-click should select. Rules
# (Linux double-click): the glyph at the reference (idx, or idx-1 at the very
# end) decides the class — a word char extends over the surrounding word chars;
# a whitespace/punctuation glyph extends over the surrounding run of the SAME
# class (whitespace run vs punctuation run). Empty buffers select nothing.
def htb_word_bounds(buf: Ptr[uint8], n: uint64, idx: uint64,
                    startp: Ptr[uint64], endp: Ptr[uint64]):
    if n == 0:
        startp[0] = 0
        endp[0] = 0
        return
    ref: uint64 = idx
    if ref >= n:
        ref = n - 1
    c0: uint8 = buf[ref]
    if htb_is_word_char(c0) != 0:
        s: uint64 = ref
        while s > 0 and htb_is_word_char(buf[s - 1]) != 0:
            s = s - 1
        e: uint64 = ref + 1
        while e < n and htb_is_word_char(buf[e]) != 0:
            e = e + 1
        startp[0] = s
        endp[0] = e
        return
    # Non-word glyph: group with its same-whitespace-class neighbours (a run of
    # spaces, or a run of punctuation), but never cross into a word.
    sp0: int32 = _htb_is_space(c0)
    s2: uint64 = ref
    while s2 > 0:
        pc: uint8 = buf[s2 - 1]
        if htb_is_word_char(pc) != 0:
            break
        if _htb_is_space(pc) != sp0:
            break
        s2 = s2 - 1
    e2: uint64 = ref + 1
    while e2 < n:
        nc: uint8 = buf[e2]
        if htb_is_word_char(nc) != 0:
            break
        if _htb_is_space(nc) != sp0:
            break
        e2 = e2 + 1
    startp[0] = s2
    endp[0] = e2


# LINE bounds around reference index `idx`: [*startp,*endp) spanning the line
# text (from just after the previous '\n' to just before the next '\n', or the
# buffer ends). The trailing newline is NOT included, so a triple-click copies
# the line's text. On a single-line field this is [0, n).
def htb_line_bounds(buf: Ptr[uint8], n: uint64, idx: uint64,
                    startp: Ptr[uint64], endp: Ptr[uint64]):
    ref: uint64 = idx
    if ref > n:
        ref = n
    s: uint64 = ref
    while s > 0 and buf[s - 1] != 10:
        s = s - 1
    e: uint64 = ref
    while e < n and buf[e] != 10:
        e = e + 1
    startp[0] = s
    endp[0] = e


# ---- multi-click counter (task #328) --------------------------------------
# A single mouse per process, so the click run is tracked in module globals.
# Each PRESS registers its position + tick; a press within HTB_MC_WINDOW ticks
# AND within HTB_MC_PX pixels of the previous one increments the run (capped at
# 3 = triple), otherwise the run restarts at 1. `now` is the app's monotonic
# tick (jiffies — HZ=100, so ~40 ticks == 400 ms, matching the compositor's
# WSYS_DBLCLICK_JIFFIES). Returns the resulting click count (1, 2, or 3).
HTB_MC_WINDOW: uint64 = 40                   # ticks (jiffies) between clicks
HTB_MC_PX: int64 = 4                          # max pixel drift within a run

_htb_mc_count: int32 = 0
_htb_mc_tick:  uint64 = 0
_htb_mc_x:     int64 = 0
_htb_mc_y:     int64 = 0


def _htb_abs64(v: int64) -> int64:
    if v < 0:
        return 0 - v
    return v


def htb_click_count(x: int64, y: int64, now: uint64) -> int32:
    within: int32 = 0
    if _htb_mc_count > 0 and now >= _htb_mc_tick \
            and (now - _htb_mc_tick) <= HTB_MC_WINDOW \
            and _htb_abs64(x - _htb_mc_x) <= HTB_MC_PX \
            and _htb_abs64(y - _htb_mc_y) <= HTB_MC_PX:
        within = 1
    if within != 0:
        _htb_mc_count = _htb_mc_count + 1
        if _htb_mc_count > 3:
            _htb_mc_count = 3                 # cap at triple
    else:
        _htb_mc_count = 1
    _htb_mc_tick = now
    _htb_mc_x = x
    _htb_mc_y = y
    return _htb_mc_count


# Test-only: reset the multi-click run (so a host unit test starts clean).
def htb_click_reset():
    _htb_mc_count = 0
    _htb_mc_tick = 0
    _htb_mc_x = 0
    _htb_mc_y = 0

# lib/ham2048core.ad — the PURE, target-agnostic core of the 2048 scene app.
#
# WHY (dual-target seam, see docs/hamui_dual_target.md)
# =====================================================
# This is the 2048 game STATE MACHINE (board/slide/merge/spawn/score/win/
# LCG), its resize-aware LAYOUT, its scene-DISPLAY-LIST builder, and its pure
# INPUT handlers — everything about the app EXCEPT the Hamnix-only window
# transport (newwindow, /dev/wsys/<wid>/{scene,keys,event}). Factored out of
# user/ham2048scene.ad exactly the way lib/htmlengine.ad was factored out of
# the browser, so the SAME code drives two sinks:
#   * user/ham2048scene.ad       — NATIVE: emit_scene() = h2048_build_scene()
#                                   + hamscene_commit(wid) to /dev/wsys.
#   * user/ham2048scene_host.ad  — HOST: h2048_build_scene() then the
#                                   lib/hamui_host.ad rasterizer -> PPM/PNG,
#                                   driven by scripted input.
# It imports ONLY lib/hamscene.ad (the pure builder), has NO `extern`, and so
# links into both the x86_64-adder-user (native) and x86_64-linux (host)
# targets. Behaviour is identical to the pre-split app.

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_stroke, \
    hamscene_panel_button


# ---- tiny pure helpers (shared with the native driver) -------------------
def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# ====================================================================
# GAME STATE (module scope — no malloc, fixed arrays only)
# ====================================================================
board:    Array[16, int32]            # row-major 4x4, 0 == empty
score:    int32 = 0
won:      int32 = 0
gameover: int32 = 0

rng_state: uint64 = 0x2545F4914F6CDD1D

# ---- animation state (see the ANIMATION section below) -------------------
# anim_phase: 0 = idle/settled, 1 = sliding tiles, 2 = merge/spawn pop.
anim_phase: int32 = 0
anim_frame: int32 = 0
# SLIDE/POP frame counts are deliberately SMALL: on the software rasterizer
# every animation frame is a full-board re-raster + /scene commit, so the
# per-move cost is dominated by the COMMIT COUNT (1 + SLIDE_FRAMES + POP_FRAMES).
# The old 6+3 = 10 commits/move made an active game feel like it "slowed way
# down" (~10 full re-rasters per keypress). 3+1 = 5 commits halves that while a
# 3-position ease-out slide (frame 0 at source, two intermediate positions) plus
# a single settle-pop frame still reads as a smooth slide.
SLIDE_FRAMES: int32 = 3                # slide over 3 frames (~ease-out)
POP_FRAMES:   int32 = 1               # then a single scale-settle pop frame

# Moving tiles for the SLIDE phase: each records a tile's source cell, its
# destination cell and the value it carries while sliding (pre-merge value).
anim_n:  int32 = 0
mv_fr:   Array[16, int32]              # from row / col
mv_fc:   Array[16, int32]
mv_tr:   Array[16, int32]             # to row / col
mv_tc:   Array[16, int32]
mv_val:  Array[16, int32]

# Cells that should POP (scale up then settle): merge results + the new spawn.
pop_n:   int32 = 0
pop_r:   Array[16, int32]
pop_c:   Array[16, int32]


def _g_rand() -> uint32:
    rng_state = rng_state * 6364136223846793005 + 1442695040888963407
    return cast[uint32](rng_state >> 33)


def _g_count_empty() -> int32:
    n: int32 = 0
    i: uint64 = 0
    while i < 16:
        if board[i] == 0:
            n = n + 1
        i = i + 1
    return n


# The board index the most recent _g_spawn() dropped a tile into (-1 = none).
# h2048_move_start() reads it to schedule the new tile's merge-pop.
last_spawn: int32 = -1


# Spawn a tile (2 @ 90%, else 4) into a random empty cell.
def _g_spawn():
    last_spawn = -1
    empties: int32 = _g_count_empty()
    if empties <= 0:
        return
    pick: int32 = cast[int32](_g_rand() % cast[uint32](empties))
    val: int32 = 2
    if _g_rand() % 10 == 0:
        val = 4
    i: uint64 = 0
    seen: int32 = 0
    while i < 16:
        if board[i] == 0:
            if seen == pick:
                board[i] = val
                last_spawn = cast[int32](i)
                return
            seen = seen + 1
        i = i + 1


# Slide+merge a single line of 4 cells given by absolute indices a,b,c,d
# in slide order (front-most first). Returns 1 if the line changed.
def _g_slide_line(a: uint64, b: uint64, c: uint64, d: uint64) -> int32:
    line: Array[4, int32]
    line[0] = board[a]
    line[1] = board[b]
    line[2] = board[c]
    line[3] = board[d]

    o0: int32 = line[0]
    o1: int32 = line[1]
    o2: int32 = line[2]
    o3: int32 = line[3]

    comp: Array[4, int32]
    comp[0] = 0
    comp[1] = 0
    comp[2] = 0
    comp[3] = 0
    w: int32 = 0
    r: int32 = 0
    while r < 4:
        if line[r] != 0:
            comp[w] = line[r]
            w = w + 1
        r = r + 1

    out: Array[4, int32]
    out[0] = 0
    out[1] = 0
    out[2] = 0
    out[3] = 0
    ow: int32 = 0
    j: int32 = 0
    while j < 4:
        if j < 3 and comp[j] != 0 and comp[j] == comp[j + 1]:
            merged: int32 = comp[j] * 2
            out[ow] = merged
            ow = ow + 1
            score = score + merged
            if merged == 2048:
                won = 1
            j = j + 2
        else:
            out[ow] = comp[j]
            ow = ow + 1
            j = j + 1

    board[a] = out[0]
    board[b] = out[1]
    board[c] = out[2]
    board[d] = out[3]

    if out[0] != o0 or out[1] != o1 or out[2] != o2 or out[3] != o3:
        return 1
    return 0


# Apply a move. dir: 0=up 1=down 2=left 3=right. Returns 1 if changed.
def _g_move(dir: int32) -> int32:
    changed: int32 = 0
    k: uint64 = 0
    while k < 4:
        ch: int32 = 0
        if dir == 2:                                  # left
            base: uint64 = k * 4
            ch = _g_slide_line(base, base + 1, base + 2, base + 3)
        elif dir == 3:                                # right
            base2: uint64 = k * 4
            ch = _g_slide_line(base2 + 3, base2 + 2, base2 + 1, base2)
        elif dir == 0:                                # up
            ch = _g_slide_line(k, k + 4, k + 8, k + 12)
        else:                                         # down
            ch = _g_slide_line(k + 12, k + 8, k + 4, k)
        if ch != 0:
            changed = 1
        k = k + 1
    return changed


def _g_any_move() -> int32:
    if _g_count_empty() > 0:
        return 1
    r: uint64 = 0
    while r < 4:
        c: uint64 = 0
        while c < 4:
            v: int32 = board[r * 4 + c]
            if c < 3 and v == board[r * 4 + c + 1]:
                return 1
            if r < 3 and v == board[(r + 1) * 4 + c]:
                return 1
            c = c + 1
        r = r + 1
    return 0


def _g_reset():
    i: uint64 = 0
    while i < 16:
        board[i] = 0
        i = i + 1
    score = 0
    won = 0
    gameover = 0
    anim_phase = 0
    anim_n = 0
    pop_n = 0
    anim_frame = 0
    _g_spawn()
    _g_spawn()


def _g_try_move(dir: int32):
    if gameover != 0:
        return
    if _g_move(dir) != 0:
        if _g_count_empty() > 0:
            _g_spawn()
        if _g_any_move() == 0:
            gameover = 1


# PUBLIC: reset the game to a fresh board (2 spawned tiles).
def h2048_reset():
    _g_reset()


# PUBLIC: seed the LCG (host tests pass a fixed seed for determinism).
def h2048_seed(s: uint64):
    if s != 0:
        rng_state = rng_state ^ s


# PUBLIC state getters (for host-test assertions).
def h2048_score() -> int32:
    return score


def h2048_gameover() -> int32:
    return gameover


def h2048_nonempty() -> int32:
    n: int32 = 0
    i: uint64 = 0
    while i < 16:
        if board[i] != 0:
            n = n + 1
        i = i + 1
    return n


# ====================================================================
# LAYOUT (resize-aware)
# ====================================================================
GAME_W: int32 = 360               # initial content width
GAME_H: int32 = 470               # initial content height
game_w: int32 = 360
game_h: int32 = 470

HDR_H:  int32 = 46                # header (title + score) height
CTRL_H: int32 = 40               # bottom on-screen-control row height
PAD:    int32 = 12
GAP:    int32 = 10

BOARD_X: int32 = 12
BOARD_Y: int32 = 58
TILE:    int32 = 76              # tile edge (square)
CTRL_Y:  int32 = 420
BTN_W:   int32 = 62
BTN_H:   int32 = 30


def h2048_layout():
    # Board fills the area between the header and the control row, square,
    # centred horizontally.
    area_top: int32 = HDR_H + PAD
    area_bot: int32 = game_h - CTRL_H - PAD
    avail_w: int32 = game_w - PAD * 2
    avail_h: int32 = area_bot - area_top
    if avail_w < 40:
        avail_w = 40
    if avail_h < 40:
        avail_h = 40
    side: int32 = avail_w
    if avail_h < side:
        side = avail_h
    t: int32 = (side - GAP * 5) / 4
    if t < 8:
        t = 8
    TILE = t
    board_side: int32 = t * 4 + GAP * 5
    BOARD_X = PAD + (avail_w - board_side) / 2
    BOARD_Y = area_top + (avail_h - board_side) / 2
    CTRL_Y = game_h - CTRL_H + (CTRL_H - BTN_H) / 2
    bw: int32 = (game_w - PAD * 2 - GAP * 4) / 5
    if bw < 24:
        bw = 24
    BTN_W = bw


def _apply_resize(nw: int64, nh: int64) -> int32:
    if nw < 220:
        nw = 220
    if nh < 260:
        nh = 260
    if cast[int32](nw) == game_w and cast[int32](nh) == game_h:
        return 0
    game_w = cast[int32](nw)
    game_h = cast[int32](nh)
    h2048_layout()
    return 1


def _tile_x(c: int32) -> int32:
    return BOARD_X + GAP + c * (TILE + GAP)


def _tile_y(r: int32) -> int32:
    return BOARD_Y + GAP + r * (TILE + GAP)


def _btn_x(i: int32) -> int32:
    return PAD + i * (BTN_W + GAP)


# PUBLIC: which control button is at (lx,ly), or -1 (0=New 1=Up 2=Left
# 3=Down 4=Right).
def h2048_btn_at(lx: int64, ly: int64) -> int64:
    if ly < cast[int64](CTRL_Y) or ly >= cast[int64](CTRL_Y + BTN_H):
        return -1
    i: int32 = 0
    while i < 5:
        bx: int64 = cast[int64](_btn_x(i))
        if lx >= bx and lx < bx + cast[int64](BTN_W):
            return cast[int64](i)
        i = i + 1
    return -1


# ====================================================================
# RENDER
# ====================================================================
def _tile_color(v: int32) -> Ptr[uint8]:
    if v == 0:
        return cast[Ptr[uint8]]("#cdc1b4")
    if v == 2:
        return cast[Ptr[uint8]]("#eee4da")
    if v == 4:
        return cast[Ptr[uint8]]("#ede0c8")
    if v == 8:
        return cast[Ptr[uint8]]("#f2b179")
    if v == 16:
        return cast[Ptr[uint8]]("#f59563")
    if v == 32:
        return cast[Ptr[uint8]]("#f67c5f")
    if v == 64:
        return cast[Ptr[uint8]]("#f65e3b")
    if v == 128:
        return cast[Ptr[uint8]]("#edcf72")
    if v == 256:
        return cast[Ptr[uint8]]("#edcc61")
    if v == 512:
        return cast[Ptr[uint8]]("#edc850")
    if v == 1024:
        return cast[Ptr[uint8]]("#edc53f")
    return cast[Ptr[uint8]]("#edc22e")            # 2048+


def _tile_text_color(v: int32) -> Ptr[uint8]:
    if v == 2 or v == 4:
        return cast[Ptr[uint8]]("#776e65")
    return cast[Ptr[uint8]]("#f9f6f2")


# Format a tile value's digits into `out` AND NUL-terminate it. The NUL is
# essential: every scene text sink (hamscene_glyphs*/_hs_strlen/_hs_emit_str)
# scans the string to a NUL, so a bare digit run leaves the sink reading
# whatever stack garbage follows — rendering junk after the number (the
# "32 L - Q" corruption). Because `out` is a fresh, uninitialized stack buffer
# in h2048_build_scene, that garbage depends on the call path that reached the
# render: the deep pointer/click path (parse_pointer -> h2048_btn_at ->
# h2048_ctrl_press -> _g_slide_line's Array[4] locals) leaves non-zero bytes
# where the keyboard path leaves zeros — which is exactly why the bug bit ONLY
# the on-screen-button input. Terminating here fixes both paths identically.
def _fmt(v: int32, out: Ptr[uint8]) -> uint64:
    n: uint64 = _u64_to_dec(cast[uint64](v), out)
    out[n] = 0
    return n


sbuf: Array[64, uint8]


def _put(pos: uint64, s: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while s[i] != 0:
        sbuf[pos] = s[i]
        pos = pos + 1
        i = i + 1
    return pos


# Draw the whole-window backdrop + header (title, live score, state line) +
# the board backing panel. Shared by the static and animated builders so the
# chrome is byte-identical across every frame.
def _draw_chrome():
    hamscene_begin()
    # Whole-window backdrop (2048 "faded" beige).
    hamscene_fill(0, 0, game_w, game_h, cast[Ptr[uint8]]("#faf8ef"))

    # Header: title + live score readout.
    hamscene_glyphs_bold(PAD, 14, cast[Ptr[uint8]]("2048"),
                         cast[Ptr[uint8]]("#776e65"))
    sp: uint64 = 0
    sp = _put(sp, cast[Ptr[uint8]]("Score "))
    sp = sp + _u64_to_dec(cast[uint64](score), &sbuf[sp])
    sbuf[sp] = 0
    hamscene_glyphs(PAD + 56, 16, &sbuf[0], cast[Ptr[uint8]]("#8f7a66"))
    # State line (right of score): win / game-over / hint.
    hp: uint64 = 0
    if gameover != 0:
        hp = _put(hp, cast[Ptr[uint8]]("GAME OVER - New"))
    elif won != 0:
        hp = _put(hp, cast[Ptr[uint8]]("YOU WIN! keep going"))
    else:
        hp = _put(hp, cast[Ptr[uint8]]("WASD / arrows"))
    sbuf[32] = 0
    hp2: uint64 = 0
    hb: Array[48, uint8]
    while hp2 < hp:
        hb[hp2] = sbuf[hp2]
        hp2 = hp2 + 1
    hb[hp] = 0
    hamscene_glyphs(PAD + 176, 16, &hb[0], cast[Ptr[uint8]]("#bbada0"))

    # Board backing panel.
    bside: int32 = TILE * 4 + GAP * 5
    hamscene_fill(BOARD_X, BOARD_Y, bside, bside, cast[Ptr[uint8]]("#bbada0"))


# Draw one tile: a coloured square of edge `size` at (px,py) and, if v!=0, its
# value centred inside it. `size` may exceed TILE (used by the merge/spawn pop).
def _draw_tile_at(px: int32, py: int32, size: int32, v: int32):
    hamscene_fill(px, py, size, size, _tile_color(v))
    if v != 0:
        nb: Array[8, uint8]
        nl: uint64 = _fmt(v, &nb[0])              # _fmt NUL-terminates nb
        gx: int32 = px + (size - cast[int32](nl) * 8) / 2
        gy: int32 = py + (size - 12) / 2
        hamscene_glyphs_bold(gx, gy, &nb[0], _tile_text_color(v))


# On-screen controls: New Up Left Down Right.
def _draw_controls():
    i: int32 = 0
    while i < 5:
        bx: int32 = _btn_x(i)
        hamscene_panel_button(bx, CTRL_Y, BTN_W, BTN_H, 0)
        lbl: Ptr[uint8] = cast[Ptr[uint8]]("New")
        if i == 1:
            lbl = cast[Ptr[uint8]]("Up")
        elif i == 2:
            lbl = cast[Ptr[uint8]]("Left")
        elif i == 3:
            lbl = cast[Ptr[uint8]]("Down")
        elif i == 4:
            lbl = cast[Ptr[uint8]]("Right")
        lx: int32 = bx + (BTN_W - cast[int32](_slen(lbl)) * 8) / 2
        ly: int32 = CTRL_Y + (BTN_H - 12) / 2
        hamscene_glyphs(lx, ly, lbl, cast[Ptr[uint8]]("#202020"))
        i = i + 1


# PUBLIC: build the whole (settled) display list into the shared hamscene
# buffer. Does NOT commit — the native driver calls hamscene_commit(wid), the
# host driver rasterizes. This is the STATIC frame (no animation in flight).
def h2048_build_scene():
    _draw_chrome()
    r: int32 = 0
    while r < 4:
        c: int32 = 0
        while c < 4:
            v: int32 = board[cast[uint64](r * 4 + c)]
            _draw_tile_at(_tile_x(c), _tile_y(r), TILE, v)
            c = c + 1
        r = r + 1
    _draw_controls()


# ====================================================================
# ANIMATION
# ====================================================================
# A move no longer teleports: h2048_move_start() records, for every tile, the
# cell it slides FROM and the cell it slides TO (computed on the PRE-move
# board, exactly mirroring _g_slide_line's compact+merge-once rule), applies
# the real move + spawn, then hands the driver a short frame sequence:
#   phase 1 (SLIDE): tiles ease from their old to their new pixel position;
#   phase 2 (POP):   merged tiles + the freshly spawned tile scale up a few px
#                    and settle back to TILE.
# The DRIVER (native /dev/wsys loop or the host harness) renders one frame per
# tick via h2048_build_scene_anim(), calls h2048_anim_advance(), and repeats
# while h2048_anim_active(). Input arriving mid-animation is naturally skipped
# (the driver is busy in the frame loop) and picked up on the next tick.


# Fill `out[0..3]` with the absolute board indices of line `k` in slide order
# (front-most first) for direction dir (0=up 1=down 2=left 3=right) — the same
# ordering _g_move feeds _g_slide_line.
def _line_indices(dir: int32, k: int32, out: Ptr[int32]):
    if dir == 2:                                       # left
        b: int32 = k * 4
        out[0] = b
        out[1] = b + 1
        out[2] = b + 2
        out[3] = b + 3
    elif dir == 3:                                     # right
        b2: int32 = k * 4
        out[0] = b2 + 3
        out[1] = b2 + 2
        out[2] = b2 + 1
        out[3] = b2
    elif dir == 0:                                     # up
        out[0] = k
        out[1] = k + 4
        out[2] = k + 8
        out[3] = k + 12
    else:                                             # down
        out[0] = k + 12
        out[1] = k + 8
        out[2] = k + 4
        out[3] = k


# Build the SLIDE trajectories for `dir` from the current (pre-move) board into
# mv_*/pop_* WITHOUT mutating the board. Returns 1 if any tile actually moves
# (i.e. the move changes the board). Mirrors the compact + merge-once rule.
def _track_all(dir: int32) -> int32:
    anim_n = 0
    pop_n = 0
    changed: int32 = 0
    k: int32 = 0
    while k < 4:
        idx: Array[4, int32]
        _line_indices(dir, k, &idx[0])
        write: int32 = 0
        last_val: int32 = 0
        last_merged: int32 = 0
        r: int32 = 0
        while r < 4:
            v: int32 = board[cast[uint64](idx[r])]
            if v != 0:
                dest: int32 = 0
                is_merge: int32 = 0
                if write > 0 and last_val == v and last_merged == 0:
                    dest = write - 1
                    last_merged = 1
                    is_merge = 1
                else:
                    dest = write
                    last_val = v
                    last_merged = 0
                    write = write + 1
                src_abs: int32 = idx[r]
                dst_abs: int32 = idx[dest]
                mv_fr[anim_n] = src_abs / 4
                mv_fc[anim_n] = src_abs % 4
                mv_tr[anim_n] = dst_abs / 4
                mv_tc[anim_n] = dst_abs % 4
                mv_val[anim_n] = v
                anim_n = anim_n + 1
                if dest != r:
                    changed = 1
                if is_merge == 1:
                    pop_r[pop_n] = dst_abs / 4
                    pop_c[pop_n] = dst_abs % 4
                    pop_n = pop_n + 1
            r = r + 1
        k = k + 1
    return changed


# PUBLIC: begin an animated move. dir: 0=up 1=down 2=left 3=right. If the move
# changes the board it records slide trajectories, APPLIES the move + spawns a
# tile (recording it for the pop), arms the SLIDE phase and returns 1. If the
# move is a no-op it leaves the board untouched, stays idle and returns 0.
def h2048_move_start(dir: int32) -> int32:
    if gameover != 0:
        return 0
    changed: int32 = _track_all(dir)
    if changed == 0:
        anim_phase = 0
        return 0
    # Apply the real move (mutates board/score/won), then spawn one tile and
    # schedule its pop. _g_move + _g_spawn read the SAME pre-move board the
    # tracker did, so mv_* trajectories land exactly on the final tiles.
    _g_move(dir)
    if _g_count_empty() > 0:
        _g_spawn()
    if _g_any_move() == 0:
        gameover = 1
    if last_spawn >= 0:
        pop_r[pop_n] = last_spawn / 4
        pop_c[pop_n] = last_spawn % 4
        pop_n = pop_n + 1
    anim_phase = 1
    anim_frame = 0
    return 1


# PUBLIC: 1 while an animation is in flight (slide or pop), else 0.
def h2048_anim_active() -> int32:
    if anim_phase != 0:
        return 1
    return 0


# PUBLIC state getters for the SLIDE phase (used by the host frame gate).
def h2048_anim_count() -> int32:
    return anim_n


def h2048_anim_phase() -> int32:
    return anim_phase


def h2048_anim_frame() -> int32:
    return anim_frame


# Ease-out interpolation of a 1-D coordinate from -> to at the CURRENT slide
# frame: t = anim_frame/SLIDE_FRAMES, eased = 1-(1-t)^2 (fast start, gentle
# stop). All integer. At frame 0 returns `from`; approaches `to` near the end.
def _slide_coord(fromv: int32, tov: int32) -> int32:
    n: int32 = SLIDE_FRAMES
    f: int32 = anim_frame
    rem: int32 = n - f
    enum: int32 = n * n - rem * rem
    eden: int32 = n * n
    return fromv + (tov - fromv) * enum / eden


# PUBLIC: current interpolated top-left pixel of moving tile i (SLIDE phase).
def h2048_anim_px(i: int32) -> int32:
    return _slide_coord(_tile_x(mv_fc[i]), _tile_x(mv_tc[i]))


def h2048_anim_py(i: int32) -> int32:
    return _slide_coord(_tile_y(mv_fr[i]), _tile_y(mv_tc[i]))


# SLIDE frame: empty board slots + every tile drawn at its interpolated pos.
def _build_slide():
    _draw_chrome()
    r: int32 = 0
    while r < 4:
        c: int32 = 0
        while c < 4:
            _draw_tile_at(_tile_x(c), _tile_y(r), TILE, 0)
            c = c + 1
        r = r + 1
    i: int32 = 0
    while i < anim_n:
        px: int32 = _slide_coord(_tile_x(mv_fc[i]), _tile_x(mv_tc[i]))
        py: int32 = _slide_coord(_tile_y(mv_fr[i]), _tile_y(mv_tr[i]))
        _draw_tile_at(px, py, TILE, mv_val[i])
        i = i + 1
    _draw_controls()


# How many extra px (per side total) a popping tile is enlarged at the current
# pop frame: largest on frame 0, settling to 0 as it finishes.
def _pop_grow() -> int32:
    m: int32 = POP_FRAMES
    f: int32 = anim_frame
    maxg: int32 = 10
    return maxg * (m - f) / m


def _is_pop(r: int32, c: int32) -> int32:
    i: int32 = 0
    while i < pop_n:
        if pop_r[i] == r and pop_c[i] == c:
            return 1
        i = i + 1
    return 0


# POP frame: the settled final board, but merged/spawned cells drawn enlarged.
def _build_pop():
    _draw_chrome()
    grow: int32 = _pop_grow()
    r: int32 = 0
    while r < 4:
        c: int32 = 0
        while c < 4:
            v: int32 = board[cast[uint64](r * 4 + c)]
            px: int32 = _tile_x(c)
            py: int32 = _tile_y(r)
            size: int32 = TILE
            if v != 0 and _is_pop(r, c) == 1:
                size = TILE + grow
                px = px - grow / 2
                py = py - grow / 2
            _draw_tile_at(px, py, size, v)
            c = c + 1
        r = r + 1
    _draw_controls()


# PUBLIC: build the display list for the CURRENT animation frame. Falls back to
# the static board when idle, so a driver can always call this.
def h2048_build_scene_anim():
    if anim_phase == 1:
        _build_slide()
    elif anim_phase == 2:
        _build_pop()
    else:
        h2048_build_scene()


# PUBLIC: advance the animation one frame. SLIDE runs SLIDE_FRAMES frames then
# hands off to POP (if any merge/spawn) which runs POP_FRAMES; then idle.
def h2048_anim_advance():
    if anim_phase == 1:
        anim_frame = anim_frame + 1
        if anim_frame >= SLIDE_FRAMES:
            if pop_n > 0:
                anim_phase = 2
                anim_frame = 0
            else:
                anim_phase = 0
    elif anim_phase == 2:
        anim_frame = anim_frame + 1
        if anim_frame >= POP_FRAMES:
            anim_phase = 0


# ---- host-test helpers: deterministic board setup (no spawn) --------------
def h2048_test_clear():
    i: uint64 = 0
    while i < 16:
        board[i] = 0
        i = i + 1
    score = 0
    won = 0
    gameover = 0
    anim_phase = 0
    anim_n = 0
    pop_n = 0
    anim_frame = 0


def h2048_test_set(i: int32, v: int32):
    board[cast[uint64](i)] = v


# PUBLIC: apply an on-screen control button press by index. Direction presses
# animate (h2048_move_start); New resets instantly.
def h2048_ctrl_press(b: int64):
    if b == 0:
        _g_reset()
    elif b == 1:
        h2048_move_start(0)
    elif b == 2:
        h2048_move_start(2)
    elif b == 3:
        h2048_move_start(1)
    elif b == 4:
        h2048_move_start(3)


# ====================================================================
# INPUT (pure — bytes/lines in, state mutations out)
# ====================================================================
esc_state: int32 = 0


def _key_byte(c: uint8) -> int32:
    if esc_state == 1:
        if c == 91:                     # '['
            esc_state = 2
            return 0
        esc_state = 0
    elif esc_state == 2:
        esc_state = 0
        if c == 65:                     # 'A' up
            h2048_move_start(0)
            return 1
        if c == 66:                     # 'B' down
            h2048_move_start(1)
            return 1
        if c == 67:                     # 'C' right
            h2048_move_start(3)
            return 1
        if c == 68:                     # 'D' left
            h2048_move_start(2)
            return 1
        return 0
    if c == 27:                         # ESC -> begin arrow sequence
        esc_state = 1
        return 0
    if c == 119 or c == 87:             # w/W up
        h2048_move_start(0)
        return 1
    if c == 115 or c == 83:             # s/S down
        h2048_move_start(1)
        return 1
    if c == 97 or c == 65:              # a/A left
        h2048_move_start(2)
        return 1
    if c == 100 or c == 68:             # d/D right
        h2048_move_start(3)
        return 1
    if c == 110 or c == 78:             # n/N new game
        _g_reset()
        return 1
    return 0


# PUBLIC: parse one "<type> <code>" key line; on a press ('d'), apply the byte.
def h2048_key_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 100:            # 'd' = press; ignore 'u' release
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    code: int32 = 0
    got: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        code = code * 10 + cast[int32](s[i]) - 48
        i = i + 1
        got = 1
    if got == 0:
        return 0
    if code < 0 or code > 255:
        return 0
    return _key_byte(cast[uint8](code))


# PUBLIC: parse "r <w> <h>" resize line; apply. Returns 1 if applied.
def h2048_resize_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 114:            # 'r'
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    wv: int64 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        wv = wv * 10 + cast[int64](s[i]) - 48
        i = i + 1
    while i < n and s[i] == 32:
        i = i + 1
    hv: int64 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        hv = hv * 10 + cast[int64](s[i]) - 48
        i = i + 1
    if wv <= 0 or hv <= 0:
        return 0
    return _apply_resize(wv, hv)


# PUBLIC: parse "m <x> <y> <buttons> ..." -> 1 + fills bx/by/bbtn; else 0.
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:            # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc2: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc2 = acc2 * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc2 = 0 - acc2
        vals[v] = acc2
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1

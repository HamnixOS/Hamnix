# lib/hampkgcore.ad — PURE, extern-free core for the Package Manager GUI
# (/bin/hampkgscene, "Software"). A Synaptic-flavoured graphical front-end over
# the native hpm package manager (user/hpm.ad). hpm stays the engine: this GUI
# never fetches/installs anything itself — the native driver (user/hampkgscene.ad)
# shells out to /bin/hpm and pipes its plain-text output back into the pure
# parsers here; the host harness (user/hampkgscene_host.ad) feeds the SAME
# parsers a fixture index so the whole UI renders + hit-tests on the dev host to
# a PNG with no QEMU (see docs/hamui_dual_target.md).
#
# What this file owns (imports only lib/hamscene + lib/hamtextbox — NO externs):
#   * the in-memory package model (name / version / short description /
#     installed-state), populated from `hpm search` + `hpm list` text lines,
#   * a live search filter driven by the shared text-box substrate,
#   * a scrollable, clickable package list + a detail pane parsed from
#     `hpm show <name>` (version / size / depends / description),
#   * the action buttons (Refresh / Install / Remove / Upgrade) as hit targets,
#   * a status line for progress/result feedback.
# The driver does all I/O (spawn hpm, drain pipes, write status) — this stays
# extern-free so it links into BOTH the native and host targets.

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_stroke, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_roundrect, \
    hamscene_icon_draw, hamui_scroll_apply
from lib.hamtextbox import htb_new, htb_set, htb_feed, htb_text, htb_len, \
    htb_render, htb_reset, htb_text_width


# ---- window geometry -------------------------------------------------------
WIN_W: int32 = 640
WIN_H: int32 = 430
HDR_H: int32 = 30

SB_X: int32 = 74                       # search box left edge
SB_Y: int32 = 38
SB_W: int32 = 358
SB_H: int32 = 22

BTN_Y: int32 = 70
BTN_H: int32 = 24
BTN_W: int32 = 84

LIST_X: int32 = 0
LIST_Y: int32 = 106
LIST_W: int32 = 362
ROW_H: int32 = 34

DET_X: int32 = 366
DET_W: int32 = 274
DET_Y: int32 = 106

STATUS_Y: int32 = 408                  # WIN_H - 22

# ---- category sidebar (Synaptic left rail) ---------------------------------
# Opt-in: the plain "Package Manager" front-end (hampkgscene) leaves it OFF so
# its geometry/tests are unchanged; the richer "Software" front-end
# (hamsoftware) turns it ON with hampkg_set_sidebar(1). When ON the window is
# SIDE_W wider and the list + detail panes shift right by SIDE_W; the header,
# search box, toolbar and status bar keep spanning the full (widened) width.
SIDE_W:   int32 = 132                   # sidebar column width (when enabled)
SIDE_ROWH: int32 = 30                   # a category row's height
sidebar_on: int32 = 0                   # 0 = hidden (default), 1 = shown
cat_filter: int32 = 0                   # 0 All, 1 Installed, 2 Available, 3 Upgradable
CAT_ALL:    int32 = 0
CAT_INST:   int32 = 1
CAT_AVAIL:  int32 = 2
CAT_UPGRAD: int32 = 3
CAT_N:      int32 = 4


# ---- package model (parallel fixed arrays) ---------------------------------
PKG_MAX: uint64 = 256
NAME_CAP: uint64 = 48
VER_CAP: uint64 = 24
DESC_CAP: uint64 = 128

pkg_name: Array[12288, uint8]          # PKG_MAX * NAME_CAP
pkg_name_len: Array[256, int32]
pkg_ver: Array[6144, uint8]            # PKG_MAX * VER_CAP
pkg_ver_len: Array[256, int32]
pkg_desc: Array[32768, uint8]          # PKG_MAX * DESC_CAP
pkg_desc_len: Array[256, int32]
pkg_installed: Array[256, int32]
pkg_upgradable: Array[256, int32]      # installed AND a newer version is available
pkg_count: int32 = 0

# search box handle (allocated in hampkg_init)
search_h: int32 = -1

# filtered view: filt[row] -> absolute package index
filt: Array[256, int32]
filt_count: int32 = 0

sel_pkg: int32 = -1                    # absolute index of the selected package
list_scroll: int32 = 0
detail_pending: int32 = 0              # driver should run `hpm show` for sel_pkg

# ---- detail pane (parsed from `hpm show <name>`) ---------------------------
det_valid: int32 = 0
det_name: Array[48, uint8]
det_name_len: int32 = 0
det_version: Array[24, uint8]
det_version_len: int32 = 0
det_size: Array[24, uint8]
det_size_len: int32 = 0
det_target: Array[48, uint8]
det_target_len: int32 = 0
det_depends: Array[192, uint8]
det_depends_len: int32 = 0
det_desc: Array[256, uint8]
det_desc_len: int32 = 0

# ---- status line -----------------------------------------------------------
status: Array[128, uint8]
status_len: int32 = 0


# ---- tiny string helpers ---------------------------------------------------
def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _lc(c: uint8) -> uint8:
    if c >= 65 and c <= 90:
        return c + 32
    return c


# Case-insensitive substring test.
def _contains_ci(hay: Ptr[uint8], hlen: uint64, needle: Ptr[uint8],
                 nlen: uint64) -> int32:
    if nlen == 0:
        return 1
    if nlen > hlen:
        return 0
    i: uint64 = 0
    while i + nlen <= hlen:
        m: uint64 = 0
        while m < nlen and _lc(hay[i + m]) == _lc(needle[m]):
            m = m + 1
        if m == nlen:
            return 1
        i = i + 1
    return 0


def _copy_clamped(dst: Ptr[uint8], cap: uint64, src: Ptr[uint8],
                  n: uint64) -> int32:
    # Leave one byte for a NUL the renderer writes at [len] before drawing.
    m: uint64 = n
    if m > cap - 1:
        m = cap - 1
    i: uint64 = 0
    while i < m:
        dst[i] = src[i]
        i = i + 1
    return cast[int32](m)


# ---- model accessors (also used by the host gate asserts) ------------------
def hampkg_count() -> int32:
    return pkg_count


def hampkg_filt_count() -> int32:
    return filt_count


def hampkg_sel_pkg() -> int32:
    return sel_pkg


def hampkg_detail_pending() -> int32:
    return detail_pending


def hampkg_clear_detail_pending():
    detail_pending = 0


def _name_slot(idx: int32) -> Ptr[uint8]:
    return &pkg_name[cast[uint64](idx) * NAME_CAP]


def _ver_slot(idx: int32) -> Ptr[uint8]:
    return &pkg_ver[cast[uint64](idx) * VER_CAP]


def _desc_slot(idx: int32) -> Ptr[uint8]:
    return &pkg_desc[cast[uint64](idx) * DESC_CAP]


def hampkg_selected_name() -> Ptr[uint8]:
    if sel_pkg < 0 or sel_pkg >= pkg_count:
        return cast[Ptr[uint8]]("")
    return _name_slot(sel_pkg)


def hampkg_selected_name_len() -> uint64:
    if sel_pkg < 0 or sel_pkg >= pkg_count:
        return 0
    return cast[uint64](pkg_name_len[sel_pkg])


def hampkg_selected_installed() -> int32:
    if sel_pkg < 0 or sel_pkg >= pkg_count:
        return 0
    return pkg_installed[sel_pkg]


# ---- category sidebar API --------------------------------------------------
# Turn the left category rail on (1) or off (0). OFF keeps the classic
# single-column geometry the "Package Manager" front-end + its gate expect.
def hampkg_set_sidebar(on: int32):
    if on != 0:
        sidebar_on = 1
    else:
        sidebar_on = 0


def hampkg_sidebar_on() -> int32:
    return sidebar_on


def hampkg_cat() -> int32:
    return cat_filter


# Select the active category (0 All, 1 Installed, 2 Available, 3 Upgradable).
def hampkg_set_cat(c: int32):
    if c >= 0 and c < CAT_N:
        cat_filter = c
        list_scroll = 0


# How many packages fall in a category (drives the sidebar row counters).
def hampkg_cat_count(c: int32) -> int32:
    n: int32 = 0
    i: int32 = 0
    while i < pkg_count:
        if _cat_keeps(c, i) != 0:
            n = n + 1
        i = i + 1
    return n


# Does category `c` admit package `i`?
def _cat_keeps(c: int32, i: int32) -> int32:
    if c == CAT_ALL:
        return 1
    if c == CAT_INST:
        return pkg_installed[i]
    if c == CAT_AVAIL:
        if pkg_installed[i] == 0:
            return 1
        return 0
    if c == CAT_UPGRAD:
        return pkg_upgradable[i]
    return 1


# ---- effective geometry (accounts for the optional sidebar) ----------------
def _ox() -> int32:
    if sidebar_on != 0:
        return SIDE_W
    return 0


def _winw() -> int32:
    return WIN_W + _ox()


# ---- lifecycle -------------------------------------------------------------
def hampkg_init():
    if search_h < 0:
        search_h = htb_new()
    pkg_count = 0
    filt_count = 0
    sel_pkg = -1
    list_scroll = 0
    detail_pending = 0
    det_valid = 0
    status_len = 0


def hampkg_reset_list():
    pkg_count = 0
    filt_count = 0
    sel_pkg = -1
    list_scroll = 0
    det_valid = 0


# Clear every installed/upgradable flag (call before re-feeding `hpm list`).
def hampkg_installed_reset():
    i: int32 = 0
    while i < pkg_count:
        pkg_installed[i] = 0
        pkg_upgradable[i] = 0
        i = i + 1


def hampkg_set_status(s: Ptr[uint8], n: uint64):
    status_len = _copy_clamped(&status[0], 128, s, n)


# ---- feed: one `hpm search` line -> a package ------------------------------
# Format printed by hpm: "<name>  <version>  -  <description>". We tokenise on
# whitespace runs: token0=name, token1=version, an optional lone "-" separator,
# then the rest is the description. Blank / non-package lines return 0.
def hampkg_add_search_line(s: Ptr[uint8], n: uint64) -> int32:
    if pkg_count >= cast[int32](PKG_MAX):
        return 0
    i: uint64 = 0
    # skip leading spaces
    while i < n and s[i] == 32:
        i = i + 1
    if i >= n:
        return 0
    # name
    ns: uint64 = i
    while i < n and s[i] != 32:
        i = i + 1
    nlen: uint64 = i - ns
    if nlen == 0:
        return 0
    while i < n and s[i] == 32:
        i = i + 1
    # version
    vs: uint64 = i
    while i < n and s[i] != 32:
        i = i + 1
    vlen: uint64 = i - vs
    while i < n and s[i] == 32:
        i = i + 1
    # optional lone "-" separator
    if i < n and s[i] == 45:
        j: uint64 = i + 1
        if j >= n or s[j] == 32:
            i = j
            while i < n and s[i] == 32:
                i = i + 1
    # description = remainder
    ds: uint64 = i
    dlen: uint64 = n - ds
    idx: int32 = pkg_count
    pkg_name_len[idx] = _copy_clamped(_name_slot(idx), NAME_CAP, &s[ns], nlen)
    pkg_ver_len[idx] = _copy_clamped(_ver_slot(idx), VER_CAP, &s[vs], vlen)
    pkg_desc_len[idx] = _copy_clamped(_desc_slot(idx), DESC_CAP, &s[ds], dlen)
    pkg_installed[idx] = 0
    pkg_upgradable[idx] = 0
    pkg_count = pkg_count + 1
    return 1


# ---- feed: a package with EXPLICIT fields (no whitespace tokenising) --------
# hampkg_add_search_line splits on whitespace, so a display name containing a
# space (e.g. "Coin Dash", "Control Center") would be truncated to its first
# word. This adds a package straight from caller-supplied name/version/desc
# spans, so the "Software" driver can enumerate the installed-app registry
# (/etc/hamde/apps/*.desktop) where friendly Names legitimately have spaces.
# `installed` seeds the installed flag (registry apps ARE installed). Returns 1
# on success, 0 if the model is full or the name is empty.
def hampkg_add_pkg(name: Ptr[uint8], nlen: uint64, ver: Ptr[uint8],
                   vlen: uint64, desc: Ptr[uint8], dlen: uint64,
                   installed: int32) -> int32:
    if pkg_count >= cast[int32](PKG_MAX):
        return 0
    if nlen == 0:
        return 0
    idx: int32 = pkg_count
    pkg_name_len[idx] = _copy_clamped(_name_slot(idx), NAME_CAP, name, nlen)
    pkg_ver_len[idx] = _copy_clamped(_ver_slot(idx), VER_CAP, ver, vlen)
    pkg_desc_len[idx] = _copy_clamped(_desc_slot(idx), DESC_CAP, desc, dlen)
    if installed != 0:
        pkg_installed[idx] = 1
    else:
        pkg_installed[idx] = 0
    pkg_upgradable[idx] = 0
    pkg_count = pkg_count + 1
    return 1


# ---- feed: one `hpm list` line -> mark that package installed ---------------
# hpm list prints "<name>  <version>  [pinned]  <target>"; we key on the first
# token and flip the installed flag of the matching package (if present).
def hampkg_mark_installed_line(s: Ptr[uint8], n: uint64) -> int32:
    i: uint64 = 0
    while i < n and s[i] == 32:
        i = i + 1
    ns: uint64 = i
    while i < n and s[i] != 32:
        i = i + 1
    nlen: uint64 = i - ns
    if nlen == 0:
        return 0
    # installed version = token1 (used to flag "upgradable" vs the available
    # version parsed from `hpm search`).
    while i < n and s[i] == 32:
        i = i + 1
    ivs: uint64 = i
    while i < n and s[i] != 32:
        i = i + 1
    ivlen: uint64 = i - ivs
    k: int32 = 0
    while k < pkg_count:
        if cast[uint64](pkg_name_len[k]) == nlen:
            slot: Ptr[uint8] = _name_slot(k)
            m: uint64 = 0
            while m < nlen and slot[m] == s[ns + m]:
                m = m + 1
            if m == nlen:
                pkg_installed[k] = 1
                # upgradable when both versions are known and differ
                avlen: uint64 = cast[uint64](pkg_ver_len[k])
                if ivlen > 0 and avlen > 0:
                    same: int32 = 0
                    if ivlen == avlen:
                        vslot: Ptr[uint8] = _ver_slot(k)
                        vm: uint64 = 0
                        while vm < avlen and vslot[vm] == s[ivs + vm]:
                            vm = vm + 1
                        if vm == avlen:
                            same = 1
                    if same == 0:
                        pkg_upgradable[k] = 1
                return 1
        k = k + 1
    return 0


# ---- detail pane parse (`hpm show <name>` "key: value" lines) --------------
def hampkg_detail_reset():
    det_valid = 0
    det_name_len = 0
    det_version_len = 0
    det_size_len = 0
    det_target_len = 0
    det_depends_len = 0
    det_desc_len = 0


def _key_is(s: Ptr[uint8], klen: uint64, key: Ptr[uint8]) -> int32:
    kl: uint64 = _slen(key)
    if kl != klen:
        return 0
    m: uint64 = 0
    while m < kl and s[m] == key[m]:
        m = m + 1
    if m == kl:
        return 1
    return 0


def hampkg_detail_line(s: Ptr[uint8], n: uint64) -> int32:
    # split at the first ':'
    c: uint64 = 0
    while c < n and s[c] != 58:
        c = c + 1
    if c >= n:
        return 0
    vs: uint64 = c + 1
    while vs < n and s[vs] == 32:
        vs = vs + 1
    vlen: uint64 = n - vs
    if _key_is(&s[0], c, cast[Ptr[uint8]]("name")) != 0:
        det_name_len = _copy_clamped(&det_name[0], 48, &s[vs], vlen)
        det_valid = 1
        return 1
    if _key_is(&s[0], c, cast[Ptr[uint8]]("version")) != 0:
        det_version_len = _copy_clamped(&det_version[0], 24, &s[vs], vlen)
        return 1
    if _key_is(&s[0], c, cast[Ptr[uint8]]("size")) != 0:
        det_size_len = _copy_clamped(&det_size[0], 24, &s[vs], vlen)
        return 1
    if _key_is(&s[0], c, cast[Ptr[uint8]]("target")) != 0:
        det_target_len = _copy_clamped(&det_target[0], 48, &s[vs], vlen)
        return 1
    if _key_is(&s[0], c, cast[Ptr[uint8]]("depends")) != 0:
        det_depends_len = _copy_clamped(&det_depends[0], 192, &s[vs], vlen)
        return 1
    if _key_is(&s[0], c, cast[Ptr[uint8]]("description")) != 0:
        det_desc_len = _copy_clamped(&det_desc[0], 256, &s[vs], vlen)
        return 1
    return 0


# ---- search filter ---------------------------------------------------------
def _visible_rows() -> int32:
    return (STATUS_Y - LIST_Y) / ROW_H


def _rebuild_filter():
    q: Ptr[uint8] = htb_text(search_h)
    ql: uint64 = htb_len(search_h)
    filt_count = 0
    i: int32 = 0
    while i < pkg_count and filt_count < cast[int32](PKG_MAX):
        keep: int32 = 0
        if ql == 0:
            keep = 1
        elif _contains_ci(_name_slot(i), cast[uint64](pkg_name_len[i]), q,
                          ql) != 0:
            keep = 1
        elif _contains_ci(_desc_slot(i), cast[uint64](pkg_desc_len[i]), q,
                          ql) != 0:
            keep = 1
        # intersect the text filter with the active category (sidebar)
        if keep != 0 and _cat_keeps(cat_filter, i) == 0:
            keep = 0
        if keep != 0:
            filt[filt_count] = i
            filt_count = filt_count + 1
        i = i + 1
    # clamp scroll to the new filtered length
    vis: int32 = _visible_rows()
    maxoff: int32 = filt_count - vis
    if maxoff < 0:
        maxoff = 0
    if list_scroll > maxoff:
        list_scroll = maxoff


# ---- keyboard: one "d <code>" wire line drives the search box --------------
def hampkg_key_line(s: Ptr[uint8], n: uint64) -> int32:
    if n < 1 or s[0] != 100:               # 'd' (down) only
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    code: int32 = 0
    got: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        code = code * 10 + cast[int32](s[i]) - 48
        i = i + 1
        got = 1
    if got == 0:
        return 0
    ch: int32 = htb_feed(search_h, code)
    if ch != 0:
        list_scroll = 0                    # new query -> back to the top
    return ch


# Host convenience: set the search query directly (bypasses per-key feed).
def hampkg_set_search(s: Ptr[uint8], n: uint64):
    htb_set(search_h, s, n)
    list_scroll = 0


# ---- pointer: wheel scroll + click hit-test --------------------------------
def hampkg_scroll(dz: int32) -> int32:
    _rebuild_filter()
    vis: int32 = _visible_rows()
    maxoff: int32 = filt_count - vis
    if maxoff < 0:
        maxoff = 0
    nv: int32 = hamui_scroll_apply(list_scroll, dz, 1, maxoff)
    if nv != list_scroll:
        list_scroll = nv
        return 1
    return 0


# Returns an action code: 0 none, 1 refresh, 2 install, 3 remove, 4 upgrade,
# 5 row-selected (driver should fetch detail). Row-select sets sel_pkg +
# detail_pending.
def hampkg_hit(x: int64, y: int64) -> int32:
    xi: int32 = cast[int32](x)
    yi: int32 = cast[int32](y)
    # toolbar buttons (Refresh / Install / Remove / Upgrade)
    if yi >= BTN_Y and yi < BTN_Y + BTN_H:
        b: int32 = 0
        while b < 4:
            bx: int32 = 8 + b * (BTN_W + 6)
            if xi >= bx and xi < bx + BTN_W:
                return b + 1
            b = b + 1
        return 0
    # category sidebar (only when shown) — its rows sit at x 0..SIDE_W below
    # the toolbar. A click selects a category and returns action code 6.
    if sidebar_on != 0 and xi >= 0 and xi < SIDE_W and yi >= LIST_Y \
            and yi < STATUS_Y:
        crow: int32 = (yi - LIST_Y) / SIDE_ROWH
        if crow >= 0 and crow < CAT_N:
            hampkg_set_cat(crow)
            return 6
    # package list rows (shifted right by the sidebar when shown)
    lx0: int32 = LIST_X + _ox()
    if xi >= lx0 and xi < lx0 + LIST_W and yi >= LIST_Y \
            and yi < STATUS_Y:
        _rebuild_filter()
        row: int32 = (yi - LIST_Y) / ROW_H
        vis_i: int32 = list_scroll + row
        if vis_i >= 0 and vis_i < filt_count:
            sel_pkg = filt[vis_i]
            detail_pending = 1
            hampkg_detail_reset()
            return 5
    return 0


# ---- status-bar count HUD (Synaptic-style live totals) ---------------------
# The classic Synaptic status bar shows the model at a glance: how many
# packages the CURRENT view lists, plus whole-index installed/upgradable
# totals. It is derived entirely from the in-memory model (never faked) and the
# "listed" figure tracks the live search + category filter, so it updates as
# you type or switch categories. Rendered right-aligned so the driver's
# progress echo keeps the left of the bar.
def _hud_put_int(out: Ptr[uint8], p: uint64, v: int32) -> uint64:
    if v <= 0:
        out[p] = 48
        return p + 1
    dd: Array[12, uint8]
    dn: uint64 = 0
    xv: int32 = v
    while xv > 0:
        dd[dn] = cast[uint8](xv % 10) + 48
        xv = xv / 10
        dn = dn + 1
    while dn > 0:
        dn = dn - 1
        out[p] = dd[dn]
        p = p + 1
    return p


def _hud_put_str(out: Ptr[uint8], p: uint64, s: Ptr[uint8]) -> uint64:
    k: uint64 = 0
    while s[k] != 0:
        out[p] = s[k]
        p = p + 1
        k = k + 1
    return p


# Build "<listed> listed  /  <N> installed  /  <M> upgradable" into `out`
# (NUL-terminated); returns the byte length. Assumes cap >= 64 (the string is
# short and bounded). Call after _rebuild_filter() so `filt_count` is current.
def hampkg_build_hud(out: Ptr[uint8], cap: uint64) -> uint64:
    if cap < 8:
        out[0] = 0
        return 0
    p: uint64 = 0
    p = _hud_put_int(out, p, filt_count)
    p = _hud_put_str(out, p, cast[Ptr[uint8]](" listed   /   "))
    p = _hud_put_int(out, p, hampkg_cat_count(CAT_INST))
    p = _hud_put_str(out, p, cast[Ptr[uint8]](" installed   /   "))
    p = _hud_put_int(out, p, hampkg_cat_count(CAT_UPGRAD))
    p = _hud_put_str(out, p, cast[Ptr[uint8]](" upgradable"))
    if p > cap - 1:
        p = cap - 1
    out[p] = 0
    return p


# ---- rendering -------------------------------------------------------------
def _draw_button(x: int32, label: Ptr[uint8], enabled: int32):
    face: Ptr[uint8] = cast[Ptr[uint8]]("#3a6ea5")
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#ffffff")
    if enabled == 0:
        face = cast[Ptr[uint8]]("#c4c8ce")
        fg = cast[Ptr[uint8]]("#8a8f96")
    hamscene_roundrect(x, BTN_Y, BTN_W, BTN_H, 6, face)
    lx: int32 = x + 10
    hamscene_glyphs(lx, BTN_Y + 5, label, fg)


def hampkg_build_scene():
    _rebuild_filter()
    ww: int32 = _winw()
    ox: int32 = _ox()
    hamscene_begin()
    hamscene_fill(0, 0, ww, WIN_H, cast[Ptr[uint8]]("#eceef2"))

    # header bar (spans the full, possibly-widened window)
    hamscene_fill(0, 0, ww, HDR_H, cast[Ptr[uint8]]("#2f5c8f"))
    hamscene_fill(0, HDR_H - 1, ww, 1, cast[Ptr[uint8]]("#22456c"))
    hamscene_icon_draw(6, 5, 20, 20, 8)                # HS_ICON_INSTALLER
    title: Ptr[uint8] = cast[Ptr[uint8]]("Package Manager")
    if sidebar_on != 0:
        title = cast[Ptr[uint8]]("Software")
    hamscene_glyphs_bold(32, 8, title, cast[Ptr[uint8]]("#ffffff"))

    # search field
    hamscene_glyphs(8, SB_Y + 4, cast[Ptr[uint8]]("Find"),
                    cast[Ptr[uint8]]("#303540"))
    hamscene_roundrect(SB_X, SB_Y, SB_W, SB_H, 5,
                       cast[Ptr[uint8]]("#ffffff"))
    hamscene_stroke(SB_X, SB_Y, SB_W, SB_H, 1, cast[Ptr[uint8]]("#a8b0ba"))
    if htb_len(search_h) == 0:
        hamscene_glyphs(SB_X + 6, SB_Y + 4,
                        cast[Ptr[uint8]]("search packages..."),
                        cast[Ptr[uint8]]("#9aa0aa"))
    else:
        htb_render(search_h, SB_X + 6, SB_Y + 4, 1,
                   cast[Ptr[uint8]]("#202124"), cast[Ptr[uint8]]("#2f5c8f"),
                   1, 14, 1)

    # action buttons — Install enabled only when a not-installed pkg is picked,
    # Remove enabled only for an installed pick.
    inst_en: int32 = 0
    rem_en: int32 = 0
    if sel_pkg >= 0:
        if hampkg_selected_installed() != 0:
            rem_en = 1
        else:
            inst_en = 1
    _draw_button(8 + 0 * (BTN_W + 6), cast[Ptr[uint8]]("Refresh"), 1)
    _draw_button(8 + 1 * (BTN_W + 6), cast[Ptr[uint8]]("Install"), inst_en)
    _draw_button(8 + 2 * (BTN_W + 6), cast[Ptr[uint8]]("Remove"), rem_en)
    _draw_button(8 + 3 * (BTN_W + 6), cast[Ptr[uint8]]("Upgrade"), 1)

    # ---- category sidebar (Synaptic left rail) — only when enabled --------
    if sidebar_on != 0:
        hamscene_fill(0, LIST_Y, SIDE_W, STATUS_Y - LIST_Y,
                      cast[Ptr[uint8]]("#e4e7ec"))
        hamscene_stroke(0, LIST_Y, SIDE_W, STATUS_Y - LIST_Y, 1,
                        cast[Ptr[uint8]]("#c4c8ce"))
        cat_label: Array[4, Ptr[uint8]]
        cat_label[0] = cast[Ptr[uint8]]("All")
        cat_label[1] = cast[Ptr[uint8]]("Installed")
        cat_label[2] = cast[Ptr[uint8]]("Available")
        cat_label[3] = cast[Ptr[uint8]]("Upgradable")
        ci: int32 = 0
        while ci < CAT_N:
            cy: int32 = LIST_Y + ci * SIDE_ROWH
            if ci == cat_filter:
                hamscene_roundrect(3, cy + 2, SIDE_W - 6, SIDE_ROWH - 4, 5,
                                   cast[Ptr[uint8]]("#2f5c8f"))
                hamscene_glyphs(12, cy + 8, cat_label[ci],
                                cast[Ptr[uint8]]("#ffffff"))
            else:
                hamscene_glyphs(12, cy + 8, cat_label[ci],
                                cast[Ptr[uint8]]("#303540"))
            # per-category counter, right-aligned-ish
            cnt: Array[8, uint8]
            cn: uint64 = 0
            cv: int32 = hampkg_cat_count(ci)
            if cv == 0:
                cnt[0] = 48
                cn = 1
            else:
                dd: Array[8, uint8]
                dn: uint64 = 0
                xv: int32 = cv
                while xv > 0:
                    dd[dn] = cast[uint8](xv % 10) + 48
                    xv = xv / 10
                    dn = dn + 1
                while dn > 0:
                    dn = dn - 1
                    cnt[cn] = dd[dn]
                    cn = cn + 1
            cnt[cn] = 0
            ccol: Ptr[uint8] = cast[Ptr[uint8]]("#586070")
            if ci == cat_filter:
                ccol = cast[Ptr[uint8]]("#dbe6f4")
            hamscene_glyphs(SIDE_W - 28, cy + 8, &cnt[0], ccol)
            ci = ci + 1

    # package list (shifted right by the sidebar when shown)
    lx: int32 = LIST_X + ox
    hamscene_fill(lx, LIST_Y, LIST_W, STATUS_Y - LIST_Y,
                  cast[Ptr[uint8]]("#f7f8fa"))
    hamscene_stroke(lx, LIST_Y, LIST_W, STATUS_Y - LIST_Y, 1,
                    cast[Ptr[uint8]]("#c4c8ce"))
    vis: int32 = _visible_rows()
    r: int32 = 0
    while r < vis:
        vi: int32 = list_scroll + r
        if vi >= filt_count:
            r = vis
        else:
            pk: int32 = filt[vi]
            ry: int32 = LIST_Y + r * ROW_H
            if pk == sel_pkg:
                hamscene_roundrect(lx + 2, ry + 1, LIST_W - 4, ROW_H - 2,
                                   5, cast[Ptr[uint8]]("#d4e3f5"))
            # name (bold)
            _name_slot(pk)[cast[uint64](pkg_name_len[pk])] = 0
            hamscene_glyphs_bold(lx + 8, ry + 4, _name_slot(pk),
                                 cast[Ptr[uint8]]("#1c2430"))
            # state badge on the right of the row
            if pkg_upgradable[pk] != 0:
                hamscene_roundrect(lx + LIST_W - 74, ry + 4, 66, 15, 7,
                                   cast[Ptr[uint8]]("#c8791e"))
                hamscene_glyphs(lx + LIST_W - 66, ry + 5,
                                cast[Ptr[uint8]]("upgrade"),
                                cast[Ptr[uint8]]("#ffffff"))
            elif pkg_installed[pk] != 0:
                hamscene_roundrect(lx + LIST_W - 74, ry + 4, 66, 15, 7,
                                   cast[Ptr[uint8]]("#2f8f4f"))
                hamscene_glyphs(lx + LIST_W - 68, ry + 5,
                                cast[Ptr[uint8]]("installed"),
                                cast[Ptr[uint8]]("#ffffff"))
            else:
                hamscene_roundrect(lx + LIST_W - 74, ry + 4, 66, 15, 7,
                                   cast[Ptr[uint8]]("#b8bec6"))
                hamscene_glyphs(lx + LIST_W - 66, ry + 5,
                                cast[Ptr[uint8]]("available"),
                                cast[Ptr[uint8]]("#2a2f38"))
            # short description
            _desc_slot(pk)[cast[uint64](pkg_desc_len[pk])] = 0
            hamscene_glyphs(lx + 8, ry + 18, _desc_slot(pk),
                            cast[Ptr[uint8]]("#586070"))
            r = r + 1

    # detail pane (shifted right by the sidebar when shown)
    dpx: int32 = DET_X + ox
    hamscene_fill(dpx, DET_Y, DET_W, STATUS_Y - DET_Y,
                  cast[Ptr[uint8]]("#ffffff"))
    hamscene_stroke(dpx, DET_Y, DET_W, STATUS_Y - DET_Y, 1,
                    cast[Ptr[uint8]]("#c4c8ce"))
    dx: int32 = dpx + 10
    dy: int32 = DET_Y + 8
    if sel_pkg < 0:
        hamscene_glyphs(dx, dy, cast[Ptr[uint8]]("Select a package"),
                        cast[Ptr[uint8]]("#8a8f96"))
    else:
        _name_slot(sel_pkg)[cast[uint64](pkg_name_len[sel_pkg])] = 0
        hamscene_glyphs_bold(dx, dy, _name_slot(sel_pkg),
                             cast[Ptr[uint8]]("#1c2430"))
        dy = dy + 20
        # installed state line
        if hampkg_selected_installed() != 0:
            hamscene_glyphs(dx, dy, cast[Ptr[uint8]]("State: installed"),
                            cast[Ptr[uint8]]("#2f8f4f"))
        else:
            hamscene_glyphs(dx, dy, cast[Ptr[uint8]]("State: available"),
                            cast[Ptr[uint8]]("#586070"))
        dy = dy + 18
        if det_valid != 0:
            if det_version_len > 0:
                det_version[cast[uint64](det_version_len)] = 0
                hamscene_glyphs(dx, dy, cast[Ptr[uint8]]("Version:"),
                                cast[Ptr[uint8]]("#586070"))
                hamscene_glyphs(dx + 66, dy, &det_version[0],
                                cast[Ptr[uint8]]("#202124"))
                dy = dy + 16
            if det_size_len > 0:
                det_size[cast[uint64](det_size_len)] = 0
                hamscene_glyphs(dx, dy, cast[Ptr[uint8]]("Size:"),
                                cast[Ptr[uint8]]("#586070"))
                hamscene_glyphs(dx + 66, dy, &det_size[0],
                                cast[Ptr[uint8]]("#202124"))
                dy = dy + 16
            if det_target_len > 0:
                det_target[cast[uint64](det_target_len)] = 0
                hamscene_glyphs(dx, dy, cast[Ptr[uint8]]("Target:"),
                                cast[Ptr[uint8]]("#586070"))
                hamscene_glyphs(dx + 66, dy, &det_target[0],
                                cast[Ptr[uint8]]("#202124"))
                dy = dy + 16
            if det_depends_len > 0:
                det_depends[cast[uint64](det_depends_len)] = 0
                hamscene_glyphs(dx, dy, cast[Ptr[uint8]]("Depends:"),
                                cast[Ptr[uint8]]("#586070"))
                dy = dy + 15
                hamscene_glyphs(dx + 8, dy, &det_depends[0],
                                cast[Ptr[uint8]]("#202124"))
                dy = dy + 18
            if det_desc_len > 0:
                det_desc[cast[uint64](det_desc_len)] = 0
                hamscene_glyphs(dx, dy, cast[Ptr[uint8]]("Description:"),
                                cast[Ptr[uint8]]("#586070"))
                dy = dy + 15
                hamscene_glyphs(dx + 8, dy, &det_desc[0],
                                cast[Ptr[uint8]]("#202124"))
        else:
            hamscene_glyphs(dx, dy, cast[Ptr[uint8]]("(loading details...)"),
                            cast[Ptr[uint8]]("#8a8f96"))

    # status bar
    hamscene_fill(0, STATUS_Y, ww, WIN_H - STATUS_Y,
                  cast[Ptr[uint8]]("#dfe2e8"))
    hamscene_stroke(0, STATUS_Y, ww, 1, 1, cast[Ptr[uint8]]("#b8bec6"))
    if status_len > 0:
        status[cast[uint64](status_len)] = 0
        hamscene_glyphs(8, STATUS_Y + 4, &status[0],
                        cast[Ptr[uint8]]("#303540"))
    else:
        hamscene_glyphs(8, STATUS_Y + 4,
                        cast[Ptr[uint8]]("Ready."),
                        cast[Ptr[uint8]]("#303540"))

    # right-aligned live-count HUD (listed / installed / upgradable)
    hud: Array[80, uint8]
    hlen: uint64 = hampkg_build_hud(&hud[0], 80)
    hwidth: int32 = htb_text_width(&hud[0], hlen)
    hx: int32 = ww - 10 - hwidth
    if hx < 180:
        hx = 180
    hamscene_glyphs(hx, STATUS_Y + 4, &hud[0], cast[Ptr[uint8]]("#4a5160"))

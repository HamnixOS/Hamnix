# arch/arm64/kmain.ad — Phase 3 bare-metal aarch64 interrupt-driven spine.
#
# This is the Adder-level kernel that boots on QEMU `virt`. The boot stub
# arch/arm64/boot.S sets up a stack and branches to kmain(); the EL1 exception
# vector table lives in arch/arm64/vectors.S and its IRQ entry calls back into
# the Adder handler arm64_irq_handler() below.
#
# What kmain() does, all driven from Adder:
#   1. Print a recognizable banner over the PL011 UART (MMIO @0x0900_0000).
#   2. Bring up a minimal identity-mapped MMU (1 GiB block descriptors:
#      device region @0x0000_0000, RAM @0x4000_0000) and enable it.
#   3. Install the EL1 vector table (VBAR_EL1) and initialise GICv2
#      (distributor @0x0800_0000, CPU interface @0x0801_0000).
#   4. Program the ARM generic *virtual* timer (PPI INTID 27) for a periodic
#      tick and unmask IRQs.
#   5. Spin in WFI. Each timer IRQ prints "[arm64] timer tick"; after 5 ticks
#      the handler prints "[arm64] timer IRQ OK".
#   6. (Phase 4) Drop to EL0: hand-emit a tiny AArch64 user routine into an
#      identity-mapped, EL0-accessible 2 MiB window, program SPSR_EL1 (EL0t),
#      ELR_EL1 (user entry) and SP_EL0 (user stack), then `eret` into it. The
#      EL0 routine issues write(1, msg, len) then exit(0) via `svc #0`. Each
#      svc traps to the "Lower EL using AArch64" Synchronous vector, which
#      saves the GPR frame and calls the Adder dispatcher arm64_sync_handler():
#      it reads ESR_EL1.EC to confirm SVC, services the syscall (write -> UART,
#      exit -> record code + halt), and writes the return value back into the
#      frame's x0 slot before eret-ing back to EL0. On exit() the test halts
#      after printing "[arm64] EL0 syscall OK".
#
# The privileged system-register pokes (MSR/MRS to VBAR_EL1, SCTLR_EL1,
# TTBR0_EL1, MAIR_EL1, TCR_EL1, CNTV_*, DAIF, SPSR_EL1, ELR_EL1, SP_EL0,
# ESR_EL1) plus DSB/ISB/TLBI/WFI/ERET are emitted by codegen_arm64.py as
# recognised intrinsics (_msr_*, _mrs_*, _dsb_ish, _isb, _tlbi_vmalle1is,
# _wfi, _eret). Everything else — GIC/timer MMIO, the page-table fill, the
# IRQ/syscall service logic, the EL0 blob builder — is ordinary Adder.

# ===========================================================================
# BOARD / PLATFORM ABSTRACTION LAYER
# ===========================================================================
# Historically every MMIO address in this file was a qemu-virt literal (PL011
# UART @0x0900_0000, GICv2 @0x0800_0000, RAM @0x4000_0000). To bring the port up
# on real silicon (Pinebook Pro = Rockchip RK3399) those addresses differ AND
# the console is an 8250/16550 UART rather than a PL011, so they cannot stay
# hardcoded. Instead we describe each supported board with a set of compile-time
# constant "descriptor" globals (BOARD_<name>_*), pick one with the compile-time
# selector BOARD_SEL, and at boot copy the chosen board's values into the MUTABLE
# runtime globals (PL011_BASE / GICD_BASE / GICC_BASE / RAM_BASE / UART_TYPE /
# arm64_cpu_count) that the rest of the kernel reads. Switching to a new board is
# therefore a descriptor edit (and a BOARD_SEL flip), not a code rewrite.
#
# The runtime globals keep their historical names so every existing call site —
# which loads e.g. `GICD_BASE` from .data at runtime — works unchanged; only
# their *value* is now board-selected at board_init() time.
# ---------------------------------------------------------------------------

# --- UART type tags (selects the putc primitive) ---------------------------
UART_TYPE_PL011: uint64 = 0          # ARM PrimeCell PL011 (qemu-virt)
UART_TYPE_8250: uint64 = 1           # 8250/16550-compatible (RK3399 UART2)

# --- Board selector identifiers --------------------------------------------
BOARD_QEMU_VIRT: uint64 = 0
BOARD_RK3399_PINEBOOK_PRO: uint64 = 1

# Compile-time board selection. Default = qemu-virt so the in-tree phase
# self-tests (which run under `qemu-system-aarch64 -M virt`) stay green. Flip
# this to BOARD_RK3399_PINEBOOK_PRO (value 1) to retarget the image at the
# Pinebook Pro; that is a one-line change, not a rewrite.
BOARD_SEL: uint64 = 0                # == BOARD_QEMU_VIRT

# --- Board descriptor: qemu-virt (the established defaults) -----------------
#   PL011 UART @0x0900_0000; GICv2 dist @0x0800_0000, cpu-if @0x0801_0000;
#   RAM @0x4000_0000; 2 cores (the phase self-tests boot with -smp 2).
BOARD_QV_UART_BASE: uint64 = 0x09000000
BOARD_QV_UART_TYPE: uint64 = 0       # UART_TYPE_PL011
BOARD_QV_GICD_BASE: uint64 = 0x08000000
BOARD_QV_GICC_BASE: uint64 = 0x08010000
BOARD_QV_RAM_BASE: uint64 = 0x40000000
BOARD_QV_CPU_COUNT: uint64 = 2

# --- Board descriptor: rk3399-pinebook-pro ---------------------------------
# Rockchip RK3399 (2x Cortex-A72 + 4x Cortex-A53 big.LITTLE = 6 cores).
#   Debug console = UART2, an 8250/16550-compatible block @0xFF1A_0000.
#   Interrupt controller = GIC-400 (GICv2): distributor @0xFEE0_0000,
#                          CPU interface @0xFEF0_2000 (RK3399 TRM).
#   DRAM base = 0x0000_0000.
# NOTE: structurally present + compiles; NOT validated on hardware here.
BOARD_RK_UART_BASE: uint64 = 0xFF1A0000
BOARD_RK_UART_TYPE: uint64 = 1       # UART_TYPE_8250
BOARD_RK_GICD_BASE: uint64 = 0xFEE00000
BOARD_RK_GICC_BASE: uint64 = 0xFEF02000
BOARD_RK_RAM_BASE: uint64 = 0x00000000
BOARD_RK_CPU_COUNT: uint64 = 6

# ---------------------------------------------------------------------------
# MUTABLE runtime board globals. Seeded with the qemu-virt defaults (so they are
# safe even before board_init() runs — e.g. an early fault printing over UART)
# and then overwritten by board_init() according to BOARD_SEL. The historical
# names are preserved so all existing call sites read the selected board's value.
# ---------------------------------------------------------------------------
PL011_BASE: uint64 = 0x09000000      # selected UART MMIO base (any UART type)
UART_TYPE: uint64 = 0                # selected UART type (PL011 vs 8250)
PL011_FR_TXFF: uint64 = 0x20         # PL011 FR.TXFF (bit5): TX FIFO full

# 8250/16550 register offsets (byte-addressed). Used by the 8250 putc path.
#   THR : base + 0x00 (write) — transmit holding register
#   LSR : base + 0x14 (read)  — line status; bit5 (0x20) = THRE (THR empty)
UART_8250_THR: uint64 = 0x00
UART_8250_LSR: uint64 = 0x14
UART_8250_LSR_THRE: uint64 = 0x20

# Selected CPU count hint (topology); informational for SMP bring-up.
arm64_cpu_count: uint64 = 2

GICD_BASE: uint64 = 0x08000000       # selected GIC distributor base
GICC_BASE: uint64 = 0x08010000       # selected GIC CPU-interface base

GICD_CTLR: uint64 = 0x000
GICD_ISENABLER: uint64 = 0x100      # set-enable, 1 bit / INTID, 32 / reg
GICD_IPRIORITYR: uint64 = 0x400     # 8 bits / INTID (byte addressed)

GICC_CTLR: uint64 = 0x000
GICC_PMR: uint64 = 0x004            # priority mask
GICC_BPR: uint64 = 0x008
GICC_IAR: uint64 = 0x00C            # interrupt acknowledge
GICC_EOIR: uint64 = 0x010           # end of interrupt

VTIMER_INTID: uint64 = 27           # virtual timer PPI
TICK_LIMIT: int64 = 5

# ---------------------------------------------------------------------------
# Phase 4: EL0 userspace. A tiny hand-emitted AArch64 routine is written into
# an identity-mapped RAM page and entered via `eret` with SPSR_EL1 selecting
# EL0t. It issues two syscalls mirroring the Linux aarch64 ABI (x8 = nr,
# x0..x5 = args, return in x0): write(1, msg, len) then exit(0).
# ---------------------------------------------------------------------------
USER_CODE_BASE: uint64 = 0x40200000   # EL0 instruction page (identity-mapped)
USER_MSG_BASE: uint64 = 0x40201000    # EL0 message buffer
USER_STACK_TOP: uint64 = 0x40280000   # EL0 stack top (grows down), 16B-aligned

# Linux-shape aarch64 syscall numbers used by the demo.
SYS_WRITE_NR: uint64 = 64
SYS_EXIT_NR: uint64 = 93

# Phase 8: a broader EL0 syscall surface. These mirror the Linux aarch64 ABI
# syscall numbers so the dispatch-by-x8 path proves a realistic multi-call
# interface (args in x0..x5, return in x0). One EL0 task exercises each in turn.
#   getpid (172): return the running task's PID.
#   gettid (178): return the running task's TID (== PID for our single thread).
#   sched_yield (124): voluntary yield; the kernel acknowledges and resumes.
#   brk (214): set the program break. brk(0) queries the current break; a
#              non-zero arg moves the break (within a fixed kernel-tracked heap
#              window) and returns the resulting break, sbrk-style.
#   clock_gettime-shape read (kernel-private 513): return CNTVCT_EL0 (the
#              monotonically-advancing virtual counter) so EL0 can observe time.
SYS_GETPID_NR: uint64 = 172
SYS_GETTID_NR: uint64 = 178
SYS_YIELD_NR: uint64 = 124
SYS_BRK_NR: uint64 = 214
SYS_CLOCK_NR: uint64 = 513

# Phase 6: a deliberately-EL1-only EL0 virtual address. RAM is split into 2 MiB
# L2 blocks; only the block at USER_L2_INDEX (0x4020_0000 .. 0x403F_FFFF) carries
# AP[1] (EL0 access). The block at 0x4040_0000 (L2 index 2) is mapped Normal
# EL1-only (no AP[1]), so an EL0 load from it raises a Data Abort (permission
# fault) — exactly the bad access the page-fault handler must catch. We pick a
# memorable sentinel so the reported FAR_EL1 is unmistakable in the log.
FAULT_VA: uint64 = 0x40400000

# Page-fault bookkeeping: set non-zero by the handler once it has caught and
# reported an EL0 abort, so the launcher can confirm the task was terminated
# (not resumed into the faulting instruction) before proceeding to Phase 5.
arm64_fault_handled: int64 = 0

# SPSR_EL1 value to ERET into EL0t with all interrupts masked: bits[3:0]=0
# (EL0t) and DAIF (bits[9:6]) set. 0x3C0 = D|A|I|F masked, mode EL0t.
SPSR_EL0T_DAIF: uint64 = 0x3C0

# Phase 7: per-task TTBR0_EL1 address-space isolation.
#
# Two EL0 tasks each get their OWN level-1 translation table root. Both map the
# SAME virtual address (ISO_SHARED_VA) but to DIFFERENT physical pages, so a
# load from that VA returns task-private data. The kernel switches TTBR0_EL1 (+
# TLB maintenance) between the two tasks; if isolation holds, task A reads its
# sentinel (0xAA) and task B reads its own (0xBB) — neither can see the other's.
#
# Each task's L1 + L2 tables live at distinct EL1-only physical pages (so EL0
# cannot tamper with its own translation tables). The two task-private physical
# data pages also live in EL1-only-for-the-OTHER space: each is only mapped (at
# ISO_SHARED_VA, EL0-accessible) by its own table, proving the isolation.
# The shared VA must be 2 MiB-aligned (it is granted EL0 access as a whole L2
# block). Index 3 (0x4060_0000) is clear of the EL0 code window (index 1) and
# the Phase-6 fault sentinel (index 2).
ISO_SHARED_VA: uint64 = 0x40600000     # the common VA both tasks dereference
ISO_SHARED_L2_INDEX: uint64 = 3        # (0x4060_0000 - 0x4000_0000) / 2 MiB

# Task A address space: L1 root and its RAM L2 table (each a 4 KiB-aligned page
# in EL1-only RAM). The private data BLOCK is a distinct 2 MiB-aligned physical
# region (so the L2 block descriptor for ISO_SHARED_VA can point at it).
ISO_A_L1: uint64 = 0x40110000
ISO_A_L2: uint64 = 0x40111000
ISO_A_DATA: uint64 = 0x40800000        # phys 2 MiB block A maps at ISO_SHARED_VA for A
# Task B address space: L1 root, its RAM L2 table, and its private data block.
ISO_B_L1: uint64 = 0x40114000
ISO_B_L2: uint64 = 0x40115000
ISO_B_DATA: uint64 = 0x40a00000        # phys 2 MiB block B maps at ISO_SHARED_VA for B

# The two sentinels written into the private data pages. Whichever value a task
# reads back at ISO_SHARED_VA identifies which physical page its TTBR0 reached.
ISO_SENTINEL_A: uint64 = 0xAA
ISO_SENTINEL_B: uint64 = 0xBB

# The EL0 code page for the isolation tasks is the existing EL0 RWX window
# (USER_CODE_BASE @0x40200000), identity-mapped EL0-RWX in BOTH task tables.
# The isolation "report" syscall number (kernel-private; outside the Linux ABI
# range used by write/exit) carries the value the task read at ISO_SHARED_VA.
SYS_ISO_REPORT_NR: uint64 = 512

# ESR_EL1.EC (bits[31:26]) value for "SVC instruction execution in AArch64".
ESR_EC_SVC64: uint64 = 0x15

# Phase 6: ESR_EL1.EC values for memory aborts taken from a LOWER EL (EL0):
#   0x20 = Instruction Abort from a lower EL
#   0x21 = Instruction Abort from the current EL
#   0x24 = Data Abort from a lower EL
#   0x25 = Data Abort from the current EL
# The EL0 page-fault path catches 0x20 (bad fetch) and 0x24 (bad load/store);
# FAR_EL1 then holds the faulting virtual address.
ESR_EC_IABORT_LOWER: uint64 = 0x20
ESR_EC_DABORT_LOWER: uint64 = 0x24
# Phase 15: Data Abort from the CURRENT EL (0x25) — the kernel itself faulted,
# e.g. while a copy_*_user accessor dereferenced a bad user pointer.
ESR_EC_DABORT_CUR: uint64 = 0x25

# Phase 14: ESR_EL1.ISS.DFSC (bits[5:0]) — the Data/Instruction Fault Status Code
# — tells WHY an abort fired. A TRANSLATION fault means the page is simply not
# mapped (demand-pageable); a PERMISSION fault means the page IS mapped but the
# access is disallowed (e.g. EL0 to an EL1-only page — a real SIGSEGV). DFSC is a
# {kind, level} pair: 0b0001LL = translation fault at level LL (0x04..0x07),
# 0b0011LL = permission fault at level LL (0x0C..0x0F). We classify by the top
# four bits (DFSC >> 2): 0b0001 == translation, 0b0011 == permission.
ESR_DFSC_MASK: uint64 = 0x3F             # bits[5:0]
ESR_DFSC_KIND_SHIFT: uint64 = 2          # drop the 2-bit level to get {kind}
ESR_DFSC_KIND_XLAT: uint64 = 0x1         # 0b0001xx -> translation fault
ESR_DFSC_KIND_PERM: uint64 = 0x3         # 0b0011xx -> permission fault

# Recorded EL0 exit code (written by the exit syscall) and a done flag.
arm64_el0_exit_code: int64 = -1
arm64_el0_exited: int64 = 0

# Phase 7: per-task TTBR0_EL1 address-space isolation bookkeeping. While the
# isolation demo runs, arm64_iso_active is non-zero; the svc dispatcher then
# routes the demo's "report" syscall (nr 512) into the Phase-7 driver instead
# of the Phase-4 write/exit logic. arm64_iso_reported_a/b latch the value each
# task read back from the SHARED virtual address through its OWN TTBR0, so the
# kernel can prove the two tasks saw different physical memory at the same VA.
arm64_iso_active: int64 = 0
arm64_iso_reported_a: uint64 = 0
arm64_iso_reported_b: uint64 = 0
# Which isolation task is currently live (0 = A, 1 = B).
arm64_iso_cur: int64 = 0

# Phase 8: broader EL0 syscall surface bookkeeping. While the multi-syscall demo
# task runs, arm64_sys_active is non-zero so the svc dispatcher routes calls into
# the Phase-8 handler (getpid/gettid/yield/brk/clock) instead of the Phase-4
# write/exit-only path. arm64_sys_pid is the PID the kernel reports to the task.
# arm64_sys_brk tracks the program break, seeded to the heap base; brk() bumps it
# within [SYS_HEAP_BASE, SYS_HEAP_END). arm64_sys_clock_first latches the first
# CNTVCT_EL0 the task read so the kernel can confirm a later read advanced (proving
# the clock is live + monotonic). arm64_sys_calls counts serviced syscalls.
arm64_sys_active: int64 = 0
arm64_sys_pid: uint64 = 0
arm64_sys_brk: uint64 = 0
arm64_sys_clock_first: uint64 = 0
arm64_sys_clock_seen: int64 = 0
arm64_sys_calls: int64 = 0

# Phase 8 program-break window. The "heap" is a fixed EL0-RWX region inside the
# existing 2 MiB EL0 window (USER_L2_INDEX): brk() may only move the break within
# [SYS_HEAP_BASE, SYS_HEAP_END). The demo task brk(0)s to query the initial break,
# then brk(SYS_HEAP_BASE + 0x1000) to grow it by 4 KiB and confirms the return.
SYS_HEAP_BASE: uint64 = 0x40230000
SYS_HEAP_END: uint64 = 0x40238000
SYS_HEAP_GROW: uint64 = 0x40231000     # the break the demo task requests (BASE + 4 KiB)

# The fixed PID/TID the kernel assigns the single Phase-8 EL0 task.
SYS_DEMO_PID: uint64 = 0x2A            # 42

# ---------------------------------------------------------------------------
# Phase 9: PAGE-TABLE-BACKED brk growth.
#
# Phase 8's brk() merely bumps a pointer inside the already-mapped 2 MiB EL0
# window, so a store to the "grown" address would have succeeded even WITHOUT the
# brk call. Phase 9 makes brk() do real memory management: the heap lives at a
# virtual address whose L2 slot is UNMAPPED at boot (so a store there raises a
# translation Data Abort). On brk-grow the kernel allocates a fresh physical 4 KiB
# page, installs a new L3 page descriptor (EL0 read/write) plus the L2->L3 table
# descriptor into the LIVE TTBR0_EL1 page tables, does the mandatory break-before-
# make TLB maintenance, and only THEN does the EL0 store/load to the newly-brk'd
# address succeed. The task writes a sentinel through the fresh mapping and reads
# it back; the kernel independently confirms the BACKING PHYSICAL page holds it,
# proving the new translation actually reached the page we mapped.
#
# Heap VA 0x40C0_0000: L1 idx 1 (the existing L2_PGTABLE), L2 idx 6 (UNMAPPED at
# boot), L3 idx 0. Index 6 is clear of the EL0 code window (idx 1), the Phase-6
# fault sentinel (idx 2) and the Phase-7 isolation block (idx 3).
P9_HEAP_BASE: uint64 = 0x40C00000      # EL0 heap virtual base (unmapped at boot)
P9_HEAP_L2_INDEX: uint64 = 6           # (0x40C0_0000 - 0x4000_0000) / 2 MiB
P9_HEAP_GROW: uint64 = 0x40C01000      # the break the demo task requests (BASE + 4 KiB)

# Fresh EL1-only physical pages backing the brk mapping. P9_L3 is the new L3
# table installed under L2 slot 6; P9_PAGE is the physical page the first grown
# 4 KiB virtual page maps to. Both sit in otherwise-unused EL1-only RAM, clear of
# the L1/L2 tables (0x4010_0000 / 0x4010_2000) and the Phase-7 iso tables.
P9_L3: uint64 = 0x40130000             # new L3 table for the heap's L2 slot
P9_PAGE: uint64 = 0x40132000           # physical page backing P9_HEAP_BASE

# L3 PAGE descriptor (NOT a block): bits[1:0] = 0b11. Reuse the block EL0 attrs
# (AF | SH_INNER | AttrIndx1 | AP_EL0 | VALID) and additionally set bit1 so the
# walker treats it as a level-3 page entry. 0x745 (block EL0) | 0x2 = 0x747.
P9_PAGE_FLAGS: uint64 = 0x747

# The sentinel the EL0 task stores through the freshly-mapped page and reads back.
P9_SENTINEL: uint64 = 0xC9C9C9C9

# Kernel-private "brk report" syscall: the EL0 task hands back the value it read
# from the brk-grown page so the kernel can verify the new mapping is live.
SYS_BRK_REPORT_NR: uint64 = 514

# Phase 9 bookkeeping. While the brk demo runs, arm64_brk_active routes svc into
# the Phase-9 dispatcher. arm64_brk_cur tracks the program break (seeded to the
# unmapped heap base). arm64_brk_mapped latches non-zero once the kernel has
# installed the fresh page mapping. arm64_brk_reported latches the value the EL0
# task read back through the new mapping.
arm64_brk_active: int64 = 0
arm64_brk_cur: uint64 = 0
arm64_brk_mapped: int64 = 0
arm64_brk_reported: uint64 = 0

# Phase 9 EL0 buffers/code reuse the existing identity-mapped EL0 RWX window
# (USER_CODE_BASE @ index 1). The task's write() message lives clear of the code.
P9_MSG_BASE: uint64 = 0x40224000

# ---------------------------------------------------------------------------
# Phase 10: SMP secondary-core bring-up via PSCI on qemu-virt.
#
# The aarch64 port boots single-core. qemu-virt with `-smp 2` starts the
# secondary CPU(s) POWERED OFF; they are released only by a PSCI CPU_ON call.
# The default `-M virt` machine (cortex-a72, no EL3 firmware) enters the OS at
# EL1 and routes PSCI through the HVC conduit, so _psci_cpu_on() issues `hvc #0`
# per the SMC Calling Convention.
#
# Bring-up sequence (all driven from the primary's Phase-9 hand-off):
#   1. The primary hand-emits a tiny secondary entry TRAMPOLINE into a RAM page.
#      The secondary is released with MMU OFF, SP undefined, at EL1; the
#      trampoline sets SP to a dedicated secondary stack, then branches to the
#      Adder body arm64_secondary_main(). (We bake arm64_secondary_main (as a value) into
#      the trampoline as an immediate — with the identity map VA == PA, an Adder
#      function's address is a valid physical entry point.)
#   2. The primary issues PSCI CPU_ON (func id 0xC4000003) targeting CPU1's
#      affinity, with the trampoline's physical address as the entry point.
#   3. arm64_secondary_main() runs MMU-off on CPU1: it sets an entered flag,
#      enables the GIC CPU interface for its own core, writes a sentinel to a
#      SHARED memory cell (with a dmb ish so the primary observes it), then
#      increments the online-CPU counter — proving real cross-core progress. It
#      never touches the UART (only the primary prints), so the two cores never
#      interleave bytes on the shared PL011.
#   4. The primary spins (dmb ish + reload) waiting for the online counter to
#      reach 2, then prints "[arm64] secondary core entered", "[arm64] CPU1
#      online" and "[arm64] SMP bring-up OK" on the secondary's behalf. The
#      shared cells are PLAIN memory accessed with
#      explicit barriers on both sides (no caching tricks: identity-mapped Normal
#      memory is coherent across the two cores once the MMU/caches are on for the
#      primary and the secondary publishes with dmb).
# ---------------------------------------------------------------------------

# PSCI CPU_ON 64-bit function id (SMC Calling Convention, PSCI v0.2+).
PSCI_FN_CPU_ON: uint64 = 0xC4000003
# PSCI return status: 0 == SUCCESS.
PSCI_SUCCESS: uint64 = 0
# Target affinity (MPIDR_EL1.Aff0) of the secondary core we bring up. On
# qemu-virt CPU index N has affinity N at Aff0.
SMP_CPU1_MPIDR: uint64 = 1

# Secondary entry trampoline: a hand-emitted blob in an EL1-only RAM page (clear
# of the EL0 windows, the page tables, and the Phase-7/9 scratch pages). The
# secondary's PSCI entry point is this page's physical address.
SMP_TRAMPOLINE: uint64 = 0x40140000
# Dedicated 16 KiB secondary boot stack (grows down from the top), EL1-only RAM.
SMP_CPU1_STACK_TOP: uint64 = 0x40150000

# Shared cross-core cells (plain identity-mapped Normal memory, published by the
# secondary with dmb ish and polled by the primary with dmb ish). Kept in their
# own 4 KiB page well clear of code/stacks/tables so cache-line traffic on them
# is isolated. SMP_ONLINE counts cores that have reported live; SMP_SENTINEL is
# the value the secondary writes so the primary can observe genuine cross-core
# progress at a known address.
SMP_ONLINE: uint64 = 0x40160000        # online-CPU counter (primary seeds to 1)
SMP_SENTINEL: uint64 = 0x40160008      # cross-core sentinel cell
SMP_ENTERED: uint64 = 0x40160010       # set to 1 by the secondary on entry
SMP_SENTINEL_VALUE: uint64 = 0x5A5A5A5A   # the value CPU1 publishes

# Phase 12: SECONDARY-CORE SCHEDULING under a real cache-coherent spinlock. After
# Phase 10 has proven CPU1 is alive, the secondary — instead of parking — spins
# on a "go" flag and then runs genuine scheduler work: SMP_ITERS locked
# increments of a SHARED counter, contending with CPU0 doing the same. The lock
# is acquired with ldaxr/stlxr (acquire) and released with stlr (release), so the
# read-modify-write of the shared counter cannot lose updates. The final count is
# deterministic (2*SMP_ITERS) and is ONLY correct if both cores actually ran AND
# the lock held — a missing core or a broken lock produces a wrong total. These
# cells live in their own 4 KiB page, clear of the Phase-10 cells above.
SMP_LOCK: uint64 = 0x40161000          # spinlock word (0 = free, 1 = held)
SMP_SHARED_COUNT: uint64 = 0x40161008  # the contended shared counter
SMP_GO: uint64 = 0x40161010            # primary sets 1 to release CPU1 into work
SMP_CPU0_DONE: uint64 = 0x40161018     # CPU0 sets 1 when its iterations finish
SMP_CPU1_DONE: uint64 = 0x40161020     # CPU1 sets 1 when its iterations finish
SMP_CPU1_TOUCHED: uint64 = 0x40161028  # CPU1 stamps its MPIDR Aff0 under the lock
# Per-core iteration count for the contended-increment demo. Each core performs
# this many locked increments, so a correct run leaves the shared counter at
# 2*SMP_ITERS. Chosen large enough that real contention occurs but the spin stays
# short under TCG.
SMP_ITERS: uint64 = 100000

# The secondary core does NOT touch the shared PL011 UART: with both cores alive
# and no UART lock, concurrent writes would interleave bytes mid-line. Instead
# the secondary signals liveness purely through the shared memory cells above
# (entered flag, sentinel, online counter), and the PRIMARY prints every marker
# once it has observed those publishes — so all UART output stays on one core
# and the boot log is clean and deterministic.

# ---------------------------------------------------------------------------
# Phase 14: DEMAND PAGING via a translation-fault handler.
#
# Phase 9 grew the heap, but only when EL0 explicitly asked for it (brk syscall);
# the mapping was installed BEFORE the EL0 store ran. Real demand paging is
# lazier: a region is left UNMAPPED, and the page is materialised ON FIRST TOUCH
# — the EL0 store itself faults, the kernel maps a fresh page from the abort
# handler, and then RESUMES the very instruction that faulted so it completes
# transparently. The EL0 task never issues a "grow" syscall; it just writes to an
# address that happens to be unbacked, and the kernel pages it in under the hood.
#
# Mechanics: a Data Abort taken from EL0 lands on the same synchronous vector as
# svc. ESR_EL1.EC distinguishes it (0x24, data abort from a lower EL), and
# ESR_EL1.ISS.DFSC (bits[5:0]) tells WHY: a TRANSLATION fault (DFSC 0b0001xx ==
# 0x04..0x07, i.e. the page simply is not mapped) is demand-pageable, whereas a
# PERMISSION fault (DFSC 0b0011xx == 0x0C..0x0F, e.g. EL0 touching an EL1-only
# page — exactly the Phase-6 fault) is a genuine SIGSEGV and the task is reaped.
# So the SAME handler now does both: it pages in translation faults inside the
# demand window and resumes EL0, and still terminates permission faults. The two
# never collide because Phase 6 uses an EL1-only (mapped-but-no-AP[1]) page and
# Phase 14 uses a wholly-unmapped VA.
#
# Demand VA 0x40E0_0000: L1 idx 1 (the existing L2_PGTABLE), L2 idx 7 (UNMAPPED
# at boot), L3 idx 0. Index 7 is clear of the EL0 window (1), the Phase-6 fault
# sentinel (2), the Phase-7 iso block (3) and the Phase-9 brk heap (6).
P14_DEMAND_BASE: uint64 = 0x40E00000     # EL0 demand-paged virtual base (unmapped)
P14_DEMAND_L2_INDEX: uint64 = 7          # (0x40E0_0000 - 0x4000_0000) / 2 MiB

# A SECOND demand-paged virtual page one 4 KiB page above the first, sharing the
# same L2 slot's L3 table. Touching it after the first page proves the handler
# maps each faulting page independently (two distinct first-touch faults) rather
# than blanket-mapping the whole 2 MiB block once.
P14_DEMAND_BASE2: uint64 = 0x40E01000

# Fresh EL1-only physical pages backing the demand mappings. P14_L3 is the new L3
# table installed under L2 slot 7; P14_PAGE0/P14_PAGE1 are the physical pages the
# two demand-faulted virtual pages map to. All sit in otherwise-unused EL1-only
# RAM, clear of the L1/L2 tables, the Phase-7 iso tables and the Phase-9 P9_L3/
# P9_PAGE scratch (0x4013_0000 / 0x4013_2000).
P14_L3: uint64 = 0x40134000              # new L3 table for the demand L2 slot
P14_PAGE0: uint64 = 0x40136000           # physical page backing P14_DEMAND_BASE
P14_PAGE1: uint64 = 0x40137000           # physical page backing P14_DEMAND_BASE2

# L3 PAGE descriptor flags (same as Phase 9): EL0 read/write Normal page,
# bits[1:0]=0b11 so the walker treats it as a level-3 page (not a block).
P14_PAGE_FLAGS: uint64 = 0x747

# The sentinels the EL0 task stores through each freshly demand-paged VA and reads
# back. Distinct per page so a read-back proves the right page was paged in.
P14_SENTINEL0: uint64 = 0xDEADBEEF11112222
P14_SENTINEL1: uint64 = 0xFEEDFACE33334444

# Kernel-private "demand report" syscall: the EL0 task hands back the two values
# it read from the demand-paged pages so the kernel can verify both faults paged
# in correctly. Outside the Linux ABI range; clear of the other private nrs.
SYS_DEMAND_REPORT_NR: uint64 = 540

# Phase 14 bookkeeping. arm64_demand_active routes EL0 aborts/svc into the demand
# path while the demo is live. arm64_demand_faults counts translation faults the
# handler serviced (must reach 2: one per page). arm64_demand_mapped0/1 latch when
# each page's mapping is installed. arm64_demand_reported0/1 latch the read-back
# values the EL0 task reported.
arm64_demand_active: int64 = 0
arm64_demand_faults: int64 = 0
arm64_demand_mapped0: int64 = 0
arm64_demand_mapped1: int64 = 0
arm64_demand_reported0: uint64 = 0
arm64_demand_reported1: uint64 = 0

# Phase 14 EL0 buffers reuse the existing identity-mapped EL0 RWX window
# (USER_CODE_BASE @ index 1). The task's write() message lives clear of the code.
P14_MSG_BASE: uint64 = 0x40225000

# ---------------------------------------------------------------------------
# Phase 15: SAFE USER-MEMORY ACCESS with EFAULT FAULT-TRAPPING (Linux-shape
# copy_from_user / copy_to_user).
#
# A real kernel must dereference user-supplied pointers WITHOUT trusting them: a
# bad pointer (unmapped, or EL1-only) must yield -EFAULT, never a kernel crash.
# Phases 6/14 already trap aborts taken FROM EL0; Phase 15 closes the other half —
# an abort taken FROM EL1 because the KERNEL ITSELF touched a bad user address.
#
# Mechanism (mirrors Linux's exception-table fixup): the safe accessors set a
# global "uaccess in progress" flag, clear a "faulted" flag, then perform the
# load/store through the _uaccess_get64 / _uaccess_put64 intrinsic (a single
# faultable instruction). If the access faults, the current-EL synchronous abort
# is taken; arm64_el1_sync_handler sees the active uaccess window, sets the
# faulted flag, and advances ELR_EL1 PAST the faulting instruction so the kernel
# resumes in the accessor (rather than panicking). The accessor then returns 0 on
# success or -EFAULT (-14) on a trapped fault — exactly the copy_*_user contract.
#
# The demo exercises three cases through the SAME accessor pair:
#   1. copy_from_user from a VALID EL0 address (USER window) -> 0, value
#   2. copy_from_user from TWO distinct wholly-unmapped addresses, each of which
#      raises a current-EL translation data abort -> both return -EFAULT
#   3. copy_to_user to a BAD (unmapped) address -> -EFAULT, then copy_to_user to a
#      VALID EL0 address -> 0, and a kernel read confirms the value landed.
# A PASS proves the kernel survived dereferencing bad user pointers (on both the
# read and the write side) and returned EFAULT instead of dying, AND that valid
# accesses still work.
# ---------------------------------------------------------------------------

# EFAULT, Linux's "bad address" errno, returned as a negative value (sys-style).
EFAULT: int64 = 14

# A valid EL0-accessible scratch cell inside the existing EL0 RWX 2 MiB window
# (USER_L2_INDEX, identity-mapped EL0 RW). Clear of the code page, message
# buffers and the Phase-8 heap window. Used for the "good pointer" cases.
P15_GOOD_VA: uint64 = 0x40240000

# A kernel-side (EL1-only RAM) scratch cell that copy_from_user writes its loaded
# value into — the "kernel destination" of the copy. Sits in otherwise-unused
# EL1-only RAM clear of the page tables and every prior phase's scratch.
P15_OUT_CELL: uint64 = 0x40139000

# Two wholly-UNMAPPED virtual addresses in L1 entries 2 and 3 (VA 0x8000_0000 and
# 0xC000_0000), which arm64_mmu_init leaves zeroed — only L1 entries 0 (device)
# and 1 (RAM) are mapped. Touching either from EL1 raises a current-EL TRANSLATION
# data abort, so the safe accessor must return -EFAULT for both. (FAULT_VA, RAM L2
# index 2, is mapped Normal EL1-only and does NOT fault from EL1 — the kernel may
# read it — so it is unsuitable as a bad-pointer case here.)
P15_UNMAPPED_VA: uint64 = 0x80000000
P15_UNMAPPED_VA2: uint64 = 0xC0000000

# Sentinels the demo writes/reads through the safe accessors. The first is the
# value copy_from_user must read back from the good page; the second is what
# copy_to_user must store (and a subsequent kernel read confirms).
P15_READ_SENTINEL: uint64 = 0x5151ABCD0000F00D
P15_WRITE_SENTINEL: uint64 = 0xCA11AB1E99990000

# Phase 15 uaccess bookkeeping. arm64_uaccess_active is non-zero ONLY across a
# single safe access, so a stray EL1 abort outside the accessor still panics (a
# real kernel bug must not be silently swallowed). arm64_uaccess_faulted latches
# when the EL1 sync handler traps an abort during an active uaccess window.
# arm64_uaccess_faults counts how many bad-pointer accesses were trapped (the
# demo expects exactly 2: the EL1-only page and the unmapped page).
arm64_uaccess_active: int64 = 0
arm64_uaccess_faulted: int64 = 0
arm64_uaccess_faults: int64 = 0

# Latched results of the demo's accesses for the finish-time verdict.
arm64_p15_read_ok: int64 = 0          # copy_from_user(good) returned 0
arm64_p15_read_val: uint64 = 0        # the value it read back
arm64_p15_write_ok: int64 = 0         # copy_to_user(good) returned 0
arm64_p15_write_seen: uint64 = 0      # value the kernel saw at the written cell
arm64_p15_efault0: int64 = 0          # copy_from_user(unmapped #1) -> -EFAULT
arm64_p15_efault1: int64 = 0          # copy_from_user(unmapped #2) -> -EFAULT
arm64_p15_efault2: int64 = 0          # copy_to_user(unmapped)      -> -EFAULT

# ---------------------------------------------------------------------------
# Phase 16: EL0 mmap / munmap with DEMAND-PAGED ANONYMOUS MAPPINGS.
#
# Phase 14 demand-paged a HARD-CODED window: the abort handler knew the two demand
# VAs by constant. Real Linux mmap is dynamic — userspace asks for an anonymous
# region of a given length, the kernel records a VMA (a [base,len) span) and hands
# back a base address WITHOUT mapping any page; the pages materialise lazily on
# first touch, and ONLY because the faulting VA falls inside a live VMA. munmap
# then tears the region down so a later touch of the SAME address faults fatally.
#
# Phase 16 builds exactly this on aarch64. A single EL0 task:
#   1. mmap(len)              -> kernel records a VMA, returns the anon base VA
#                               (no page mapped yet — purely lazy)
#   2. str sentinel,[base]    -> translation fault; the abort handler walks the VMA
#                               table, finds the VA covered, demand-maps a fresh
#                               page and RESUMES the store (it now completes)
#   3. ldr back               -> reads the sentinel through the new mapping
#   4. mmap_report(readback)  -> hands the value back; kernel verifies the demand
#                               map landed in the backing physical page
#   5. munmap(base,len)       -> kernel clears the L3 entry, drops the VMA, flushes
#   6. str sentinel2,[base]   -> translation fault AGAIN, but the VA is now in NO
#                               VMA, so the handler reaps the task (a real SIGSEGV)
# A PASS proves: the anon region was lazily backed only inside its VMA (one demand
# fault), the read-back reached the backing page, AND munmap genuinely removed the
# mapping (the post-munmap touch faulted and was NOT silently re-paged) — the full
# Linux mmap/munmap lifecycle on bare aarch64, driven from Adder.
#
# The mmap region lives in L2 slot 8 (VA 0x4100_0000), which arm64_mmu_init maps
# identity EL1-only; the Phase-16 launcher CLEARS that slot so the first EL0 touch
# genuinely translation-faults (mirroring how Phase 14 clears its slot 7).
# ---------------------------------------------------------------------------

# The anonymous mmap base the kernel hands back. L1 idx 1 (existing L2_PGTABLE),
# L2 idx 8 (cleared to UNMAPPED by the launcher), L3 idx 0.
P16_MMAP_BASE: uint64 = 0x41000000
P16_MMAP_L2_INDEX: uint64 = 8            # (0x4100_0000 - 0x4000_0000) / 2 MiB
P16_MMAP_LEN: uint64 = 0x1000            # one 4 KiB page (anonymous)

# Fresh EL1-only scratch: the new L3 table under L2 slot 8, and the physical page
# the anon VA demand-maps to. Both sit in otherwise-unused EL1-only RAM, clear of
# the L1/L2 tables and every prior phase's scratch (Phase 9 .. 0x4013_2000,
# Phase 14 .. 0x4013_7000, Phase 15 P15_OUT_CELL @0x4013_9000).
P16_L3: uint64 = 0x4013A000              # new L3 table for the mmap L2 slot
P16_PAGE: uint64 = 0x4013C000            # physical page backing P16_MMAP_BASE

# L3 PAGE descriptor flags (same as Phase 9/14): EL0 read/write Normal page,
# bits[1:0]=0b11 so the walker treats it as a level-3 page.
P16_PAGE_FLAGS: uint64 = 0x747

# Sentinels the EL0 task stores: the first through the freshly demand-paged anon
# page (read back + verified), the second after munmap (its store must fault).
P16_SENTINEL: uint64 = 0xB16B00B5C0DE0001
P16_SENTINEL2: uint64 = 0xDEAD0000FACE0002

# mmap region's EL0 message buffer (inside the existing EL0 RWX window, clear of
# the code page and every prior phase's buffers).
P16_MSG_BASE: uint64 = 0x40226000

# Linux aarch64 syscall numbers reused verbatim. mmap is 222, munmap is 215.
SYS_MMAP_NR: uint64 = 222
SYS_MUNMAP_NR: uint64 = 215
# Kernel-private "mmap report" syscall: the EL0 task hands back the value it read
# from the demand-paged anon page so the kernel can verify the mapping. Outside the
# Linux ABI range; clear of the other private nrs (512/514/540).
SYS_MMAP_REPORT_NR: uint64 = 541

# Phase 16 bookkeeping. arm64_mmap_active routes EL0 aborts/svc into the mmap path
# while the demo is live. The VMA table is a single dynamic span [vma_base, vma_base
# + vma_len); vma_live latches whether it is currently mapped (mmap sets it, munmap
# clears it). The abort handler honours a fault ONLY when vma_live and the VA is in
# range. The counters/latches feed the finish-time verdict.
arm64_mmap_active: int64 = 0
arm64_mmap_vma_base: uint64 = 0
arm64_mmap_vma_len: uint64 = 0
arm64_mmap_vma_live: int64 = 0
arm64_mmap_faults: int64 = 0          # demand faults serviced inside a live VMA
arm64_mmap_paged: int64 = 0           # anon page was demand-mapped at least once
arm64_mmap_readback: uint64 = 0       # value the EL0 task read back from the page
arm64_mmap_unmapped: int64 = 0        # munmap tore the VMA + mapping down
arm64_mmap_segv: int64 = 0            # post-munmap touch faulted with NO live VMA

# ---------------------------------------------------------------------------
# Phase 17: EL0 mprotect (nr 226) — CHANGING PAGE PERMISSIONS with a real
# permission-fault check (a write to a now-READ-ONLY page raises a genuine
# SIGSEGV, distinct from the Phase-14/16 demand TRANSLATION faults).
#
# Phase 16 proved an anon mapping materialises (translation fault) and tears
# down (munmap). Phase 17 closes the permissions half of the Linux mmap family:
# a mapped, writable anon page is downgraded to read-only IN PLACE, exactly like
# Linux mprotect(addr, len, PROT_READ). The kernel rewrites the page's L3
# descriptor's AP[2:1] from RW (0b01) to RO (0b11), break-before-makes the TLB,
# and the very next EL0 STORE to that page now raises a PERMISSION Data Abort
# (ESR_EL1.ISS.DFSC = 0b0011xx) — a real SIGSEGV — while a LOAD still succeeds.
#
# A single EL0 task:
#   1. mmap(len)               -> kernel records a VMA, returns the anon base VA
#   2. str sentinel,[base]     -> translation fault; handler demand-maps RW, resumes
#   3. ldr back ; report       -> kernel verifies the RW store/load reached the page
#   4. mprotect(base,len,RD)   -> kernel flips the L3 AP[2:1] RW->RO, flushes TLB
#   5. ldr after-protect       -> STILL succeeds (RO permits reads); report it
#   6. str sentinel2,[base]    -> PERMISSION fault (write to RO) -> real SIGSEGV
# A PASS proves: the page was demand-mapped RW (one translation fault), the read-
# back matched, mprotect flipped the live descriptor to RO, a post-mprotect READ
# still succeeded (RO is readable), AND the post-mprotect WRITE raised a genuine
# PERMISSION fault (NOT a translation fault — the page is still mapped, just not
# writable) — the full Linux mprotect lifecycle on bare aarch64, driven from Adder.
#
# The mprotect region lives in L2 slot 9 (VA 0x4120_0000), which arm64_mmu_init
# maps identity EL1-only; the Phase-17 launcher CLEARS that slot so the first EL0
# touch genuinely translation-faults (mirroring Phase 16's slot 8).
# ---------------------------------------------------------------------------

# The anonymous base the mprotect demo hands back. L1 idx 1 (existing L2_PGTABLE),
# L2 idx 9 (cleared to UNMAPPED by the launcher), L3 idx 0.
P17_MMAP_BASE: uint64 = 0x41200000
P17_MMAP_L2_INDEX: uint64 = 9            # (0x4120_0000 - 0x4000_0000) / 2 MiB
P17_MMAP_LEN: uint64 = 0x1000            # one 4 KiB page (anonymous)

# Fresh EL1-only scratch: the new L3 table under L2 slot 9, and the physical page
# the anon VA demand-maps to. Both sit in otherwise-unused EL1-only RAM, clear of
# every prior phase's scratch (Phase 16 .. P16_PAGE @0x4013_C000).
P17_L3: uint64 = 0x4013E000              # new L3 table for the mprotect L2 slot
# P17_PAGE skips the SMP region (0x4014_0000 .. 0x4016_1028) and lands in the
# free gap just above it, still inside the first identity-mapped 2 MiB RAM block.
P17_PAGE: uint64 = 0x40162000            # physical page backing P17_MMAP_BASE

# L3 PAGE descriptor flags. RW (writable by EL0): same as Phase 16 (0x747) —
# VALID|page(0b11)|AttrIndx1|AF|SH_INNER|AP[1] with AP[2] clear (AP[2:1]=0b01).
# RO sets AP[2] (bit7 = 0x80) so AP[2:1]=0b11 => read-only at EL0 AND EL1; an EL0
# store then raises a PERMISSION Data Abort.
P17_PAGE_FLAGS_RW: uint64 = 0x747
P17_PAGE_AP2_RO: uint64 = 0x80           # AP[2] (bit7): set => read-only
P17_PAGE_FLAGS_RO: uint64 = 0x7C7        # 0x747 | 0x80

# Sentinels: the first stored through the freshly demand-paged RW page (read back
# + verified); the second is the post-mprotect write whose store must PERMISSION-
# fault.
P17_SENTINEL: uint64 = 0xC0FFEE00AB17F001
P17_SENTINEL2: uint64 = 0xBADC0DE0FACE0017

# mprotect region's EL0 message buffer (inside the existing EL0 RWX window, clear
# of the code page and every prior phase's buffers).
P17_MSG_BASE: uint64 = 0x40228000

# Linux aarch64 mprotect syscall number, reused verbatim.
SYS_MPROTECT_NR: uint64 = 226
# Linux PROT_READ flag (mprotect arg2); the demo downgrades RW -> PROT_READ only.
PROT_READ: uint64 = 0x1
# Kernel-private "mprotect report" syscalls: the EL0 task hands back the RW read-
# back (before mprotect) and the post-mprotect read-back so the kernel can verify
# both. Outside the Linux ABI range; clear of the other private nrs (512/514/540/541).
SYS_MPROTECT_REPORT_NR: uint64 = 542     # RW read-back, pre-mprotect
SYS_MPROTECT_RDBACK_NR: uint64 = 543     # read still works post-mprotect (RO)

# Phase 17 bookkeeping. arm64_mprot_active routes EL0 aborts/svc into the mprotect
# path while the demo is live. The VMA span [base, base+len) is recorded by mmap;
# vma_prot_ro latches once mprotect has flipped it read-only. The abort handler
# demand-maps RW translation faults inside the span; a PERMISSION fault inside the
# span (only possible once RO) is the SIGSEGV the verdict needs.
arm64_mprot_active: int64 = 0
arm64_mprot_vma_base: uint64 = 0
arm64_mprot_vma_len: uint64 = 0
arm64_mprot_vma_live: int64 = 0
arm64_mprot_prot_ro: int64 = 0        # mprotect flipped the page read-only
arm64_mprot_faults: int64 = 0         # demand (translation) faults serviced
arm64_mprot_paged: int64 = 0          # anon page was demand-mapped RW at least once
arm64_mprot_readback: uint64 = 0      # RW read-back the EL0 task reported (pre-mprotect)
arm64_mprot_rd_after: uint64 = 0      # read-back AFTER mprotect (RO read must still work)
arm64_mprot_read_ok: int64 = 0        # the post-mprotect READ succeeded (no fault)
arm64_mprot_segv: int64 = 0           # post-mprotect WRITE took a PERMISSION fault

# ---------------------------------------------------------------------------
# Phase 18: MULTI-PAGE anonymous mmap + PARTIAL munmap that SPLITS a VMA.
#
# Every prior phase (9 brk, 14 demand, 16 mmap, 17 mprotect) backed exactly ONE
# 4 KiB page and tracked a single span. Real Linux mmap regions are MULTI-page,
# each page faulting in independently on first touch, and Linux munmap can carve
# a HOLE out of the MIDDLE of a live mapping — SPLITTING one VMA into two. Phase
# 18 builds exactly that on aarch64, using a real (small) VMA TABLE rather than a
# single latched span.
#
# A single EL0 task:
#   1. mmap(3*4KiB)            -> kernel records ONE VMA [base, base+0x3000),
#                                 returns base (no page mapped yet — fully lazy)
#   2. str s0,[base+0]         -> translation fault (page 0); demand-map page 0
#   3. str s1,[base+0x1000]    -> translation fault (page 1); demand-map page 1
#   4. str s2,[base+0x2000]    -> translation fault (page 2); demand-map page 2
#      (THREE independent demand faults — proves per-page lazy backing)
#   5. ldr each back ; report  -> kernel verifies all three reached their pages
#   6. munmap(base+0x1000,4KiB)-> PARTIAL unmap of the MIDDLE page: clears that
#                                 L3 entry AND SPLITS the VMA into two live spans
#                                 [base, base+0x1000) and [base+0x2000, base+0x3000)
#   7. ldr base+0 ; ldr base+0x2000 ; report -> the two SURVIVING pages still hold
#                                 their sentinels (the split kept them mapped)
#   8. str s3,[base+0x1000]    -> translation fault in the HOLE, covered by NO live
#                                 VMA -> fatal SIGSEGV (the reaper turns this into PASS)
#
# A PASS proves: a multi-page anon region was lazily backed one page per touch
# (EXACTLY three translation faults), all three read-backs reached their distinct
# backing pages, a partial munmap of the middle page SPLIT the VMA (leaving two
# live spans), the two surviving pages STAYED mapped across the split, AND the
# hole left by the split faults fatally (it is in no live VMA) — the full Linux
# multi-page-mmap + VMA-splitting munmap lifecycle on bare aarch64, from Adder.
#
# The region lives in L2 slot 10 (VA 0x4140_0000), which arm64_mmu_init maps
# identity EL1-only; the Phase-18 launcher CLEARS that slot so the first EL0 touch
# of each page genuinely translation-faults (mirroring Phase 17's slot 9).
# ---------------------------------------------------------------------------

# The anonymous base the multi-page demo hands back. L1 idx 1 (existing L2_PGTABLE),
# L2 idx 10 (cleared to UNMAPPED by the launcher), L3 idx 0.
P18_MMAP_BASE: uint64 = 0x41400000
P18_MMAP_L2_INDEX: uint64 = 10           # (0x4140_0000 - 0x4000_0000) / 2 MiB
P18_MMAP_LEN: uint64 = 0x3000            # THREE 4 KiB pages (anonymous)
P18_NPAGES: uint64 = 3

# Fresh EL1-only scratch: the new L3 table under L2 slot 10, plus THREE distinct
# physical pages the three anon VAs demand-map to. All sit in the free gap above
# the SMP region (ends 0x4016_1028) and below P17_PAGE (0x4016_2000)... actually
# P18 lands just past P17_PAGE, still inside the first identity-mapped 2 MiB block
# (RAM 0x4000_0000 .. 0x4020_0000), clear of every prior phase's scratch.
P18_L3: uint64 = 0x40163000              # new L3 table for the multi-page L2 slot
P18_PAGE0: uint64 = 0x40164000           # backs P18_MMAP_BASE + 0x0000
P18_PAGE1: uint64 = 0x40165000           # backs P18_MMAP_BASE + 0x1000 (the hole)
P18_PAGE2: uint64 = 0x40166000           # backs P18_MMAP_BASE + 0x2000

# RW page flags (same encoding as Phase 16/17 RW): EL0 read/write Normal page.
P18_PAGE_FLAGS: uint64 = 0x747

# Sentinels: one per page written through the demand-paged RW mapping (read back +
# verified), plus a fourth stored into the post-split HOLE whose store must FAULT.
P18_SENTINEL0: uint64 = 0x1818000000000A00
P18_SENTINEL1: uint64 = 0x1818000000000B01
P18_SENTINEL2: uint64 = 0x1818000000000C02
P18_SENTINEL3: uint64 = 0x1818DEAD0FACE003

# multi-page region's EL0 message buffer (inside the EL0 RWX window, clear of the
# code page and every prior phase's buffers).
P18_MSG_BASE: uint64 = 0x4022A000

# Kernel-private "multi-page report" syscalls (outside the Linux ABI range; clear
# of the other private nrs 512/513/514/540/541/542/543).
SYS_MP_REPORT_NR: uint64 = 544           # the three pre-munmap RW read-backs
SYS_MP_SURVIVE_NR: uint64 = 545          # the two post-split surviving read-backs

# Phase 18 bookkeeping. arm64_mp_active routes EL0 aborts/svc into the multi-page
# path while the demo is live. The VMA TABLE is a small fixed array of (base,len,
# live) triples; mmap fills slot 0 with the whole span; the partial munmap rewrites
# slot 0 to the LOW survivor and fills slot 1 with the HIGH survivor (the SPLIT).
# The abort handler honours a translation fault ONLY when the VA is inside SOME
# live VMA slot; a touch of the carved-out hole matches no slot -> fatal SIGSEGV.
P18_VMA_SLOTS: uint64 = 4
arm64_mp_active: int64 = 0
arm64_mp_vma_base: Array[4, uint64]   # per-slot span base
arm64_mp_vma_len: Array[4, uint64]    # per-slot span length (0 / live==0 => empty)
arm64_mp_vma_live: Array[4, int64]    # per-slot live flag
arm64_mp_faults: int64 = 0            # translation (demand) faults serviced
arm64_mp_paged: int64 = 0             # at least one anon page was demand-mapped
arm64_mp_split: int64 = 0             # partial munmap split the VMA into two
arm64_mp_rd0: uint64 = 0              # pre-munmap read-back of page 0
arm64_mp_rd1: uint64 = 0              # pre-munmap read-back of page 1
arm64_mp_rd2: uint64 = 0              # pre-munmap read-back of page 2
arm64_mp_surv0: uint64 = 0           # post-split read-back of surviving page 0
arm64_mp_surv2: uint64 = 0           # post-split read-back of surviving page 2
arm64_mp_segv: int64 = 0             # post-split touch of the HOLE faulted (no VMA)

# ---------------------------------------------------------------------------
# Phase 19: TWO preemptively-scheduled EL0 tasks, EACH with its OWN TTBR0_EL1
# address space AND its own ASID, with the timer-IRQ context switch swapping
# TTBR0+ASID as well as the saved register context.
#
# Phase 5 already round-robins two EL0 tasks under the EL1 timer IRQ, but both
# tasks share the SINGLE identity TTBR0 (one address space). Phase 7 proves two
# tasks CAN have private TTBR0 spaces, but only as a one-shot, non-preemptive
# hand-switch. Phase 19 fuses the two AND adds real ASID handling: two tasks run
# concurrently, each in a PRIVATE translation regime (private L1/L2 root mapping
# the SAME shared VA to a DIFFERENT physical page) tagged by a DISTINCT ASID, and
# every preemptive timer tick swaps BOTH the register context AND TTBR0_EL1 (with
# the ASID baked into bits[63:48]).
#
# Each task loops: it reads its private sentinel byte at P19_SHARED_VA (resolved
# through its own TTBR0+ASID) and reports it via a kernel-private syscall, then
# busy-loops. The kernel tallies, per task, how many reports carried the CORRECT
# sentinel. The ASID handling is the crux: on a swap the scheduler does NOT do a
# broad `tlbi vmalle1is` flush — it relies on the per-ASID tagging to keep each
# task's translations distinct in the TLB. If ASID tagging were broken, task B
# could resolve P19_SHARED_VA via task A's stale (ASID-untagged) TLB entry and
# read A's sentinel. A PASS requires that across MANY preemptive swaps EVERY read
# stayed private (no cross-task leak) — proving genuine ASID-tagged multitasking.
#
# After P19_GOAL correct swaps with zero leaks the scheduler prints PASS + halts.
# ---------------------------------------------------------------------------

# Shared VA both tasks dereference; 2 MiB-aligned (granted EL0 as one L2 block).
# L2 index 13 (0x41A0_0000), clear of every prior phase's EL0 VA window.
P19_SHARED_VA: uint64 = 0x41A00000
P19_SHARED_L2_INDEX: uint64 = 13        # (0x41A0_0000 - 0x4000_0000) / 2 MiB

# Per-task private translation roots (4 KiB EL1-only RAM pages) + their RAM L2
# tables. They sit in the free gap above the Phase-18 scratch (ends 0x4016_7000)
# and below the EL0 window (0x4020_0000).
P19_A_L1: uint64 = 0x40170000
P19_A_L2: uint64 = 0x40171000
P19_B_L1: uint64 = 0x40172000
P19_B_L2: uint64 = 0x40173000

# Per-task PRIVATE physical data block (2 MiB-aligned; backs P19_SHARED_VA for
# that task). Distinct blocks => the same VA resolves to private memory per task.
P19_A_DATA: uint64 = 0x41600000
P19_B_DATA: uint64 = 0x41800000

# The two sentinels seeded into the private blocks (byte 0). Whichever a task
# reads back at P19_SHARED_VA identifies which physical page its TTBR0 reached.
P19_SENTINEL_A: uint64 = 0xA9
P19_SENTINEL_B: uint64 = 0xB7

# Per-task ASID (in TTBR0_EL1 bits[63:48]; TCR.AS=0 => 8-bit ASID, so the value
# lives in bits[63:56]). Distinct, non-zero ASIDs keep each task's translations
# independently cached so a swap needs no broad TLB flush.
P19_ASID_A: uint64 = 1
P19_ASID_B: uint64 = 2
P19_ASID_SHIFT: uint64 = 48             # ASID field base bit in TTBR0_EL1

# Per-task code/stack live in the shared EL0 RWX window (USER_L2_INDEX), mapped
# identically in both private spaces so each task's instructions are fetchable
# under either TTBR0. Distinct code pages + stacks so the two tasks never alias.
P19_A_CODE: uint64 = 0x40208000
P19_B_CODE: uint64 = 0x4020C000
P19_A_STACK_TOP: uint64 = 0x40260000
P19_B_STACK_TOP: uint64 = 0x40268000

# Per-task context blocks (34 x 8-byte slots: x0..x30, SP_EL0, ELR_EL1, SPSR_EL1)
# in EL1-only RAM (outside the EL0 window). Distinct from the Phase-5 ctx pages.
P19_A_CTX: uint64 = 0x40106000
P19_B_CTX: uint64 = 0x40107000

# Kernel-private "dual-space report" syscall (outside the Linux ABI range and the
# other private nrs 512/513/514/540..545). Carries the byte read at P19_SHARED_VA.
SYS_P19_REPORT_NR: uint64 = 546

# Phase 19 bookkeeping. arm64_p19_active routes svc + timer IRQ into the Phase-19
# path while the demo is live. arm64_p19_cur is the live task index (0=A, 1=B).
# The per-task correct/leak tallies prove ASID-tagged isolation held across every
# preemptive swap; arm64_p19_swaps counts TTBR0+ASID context switches performed.
arm64_p19_active: int64 = 0
arm64_p19_cur: int64 = 0
arm64_p19_swaps: int64 = 0
arm64_p19_a_correct: int64 = 0       # task A reports that carried sentinel A
arm64_p19_b_correct: int64 = 0       # task B reports that carried sentinel B
arm64_p19_leaks: int64 = 0           # any report whose value was the OTHER task's
arm64_p19_reports: int64 = 0         # total reports serviced
P19_GOAL: int64 = 12                 # TTBR0+ASID swaps to perform before the verdict

# ---------------------------------------------------------------------------
# Phase 20: DYNAMIC TASK SPAWN + EXIT/REAPING.
#
# Every prior phase ran a FIXED set of statically-built EL0 tasks that either
# loop forever (Phases 5 / 19) or run a scripted syscall sequence then exit and
# HALT the boot (Phases 8 / 9 / ...). None of them prove the two pillars of a real
# process model: (a) a task can EXIT mid-run and the scheduler REAPS it (stops
# scheduling the dead slot) while the OTHER tasks keep running; (b) a task can be
# CREATED at runtime (a fresh EL0 task with its OWN private address space, ASID and
# entry built on the fly) and scheduled in alongside the survivors — a fork-like
# dynamic spawn, not just two/three static tasks wired up before the first ERET.
#
# Phase 20 builds directly on Phase 19's per-ASID dual-address-space machinery. It
# starts TWO preemptively-scheduled EL0 tasks in PRIVATE ASID-tagged spaces:
#   slot 0 ("A", ASID 1): loops reading its private sentinel at the shared VA and
#           reporting it; after P20_A_EXIT_AT reports it issues exit(7).
#   slot 1 ("B", ASID 2): loops reading + reporting its private sentinel forever.
# On A's exit() the dispatcher marks slot 0 REAPED; the timer-IRQ scheduler then
# NEVER picks slot 0 again — only runnable slots are scheduled, so B keeps running.
# After the reap, on the next tick the scheduler DYNAMICALLY SPAWNS slot 2 ("C",
# ASID 3): it builds C a brand-new private address space (clone identity + private
# shared-VA -> C's own physical block seeded with sentinel C), a fresh EL0 code
# routine, a fresh context block, recycles ASID 3's TLB, and adds it to the
# runnable set. From then on the scheduler round-robins over the RUNNABLE slots
# {B, C}. Each task only ever reads ITS OWN sentinel (resolved through its own
# TTBR0+ASID); a read of any other slot's sentinel is a cross-task LEAK.
#
# PASS requires: slot A actually ran AND exited AND was reaped; slot B ran across
# the whole demo (before AND after both the reap and the spawn); slot C was
# DYNAMICALLY spawned at runtime AND ran in its own private ASID space; and ZERO
# cross-task sentinel leaks occurred over every preemptive TTBR0+ASID swap. After
# P20_GOAL swaps past the spawn the scheduler prints the verdict + halts.
# ---------------------------------------------------------------------------

# Shared VA all three tasks dereference (each resolves it through its own
# TTBR0+ASID to a DIFFERENT private physical block). Reuse the Phase-19 L2 slot
# geometry: 2 MiB-aligned, granted EL0 as one L2 block, clear of prior windows.
P20_SHARED_VA: uint64 = 0x41A00000
P20_SHARED_L2_INDEX: uint64 = 13        # (0x41A0_0000 - 0x4000_0000) / 2 MiB

# Per-slot private translation roots (4 KiB EL1-only RAM pages) + their RAM L2
# tables, in the free gap above the Phase-19 page-table scratch (ends 0x4017_4000)
# and below the EL0 window (0x4020_0000).
P20_A_L1: uint64 = 0x40180000
P20_A_L2: uint64 = 0x40181000
P20_B_L1: uint64 = 0x40182000
P20_B_L2: uint64 = 0x40183000
P20_C_L1: uint64 = 0x40184000
P20_C_L2: uint64 = 0x40185000

# Per-slot PRIVATE physical data block (2 MiB-aligned; backs P20_SHARED_VA for that
# slot). Distinct blocks => the same VA resolves to private memory per slot.
P20_A_DATA: uint64 = 0x41C00000
P20_B_DATA: uint64 = 0x41E00000
P20_C_DATA: uint64 = 0x42000000

# Per-slot sentinels seeded into the private blocks (byte 0).
P20_SENTINEL_A: uint64 = 0xC3
P20_SENTINEL_B: uint64 = 0xD5
P20_SENTINEL_C: uint64 = 0xE7

# Per-slot ASID (TTBR0_EL1 bits[63:48], TCR.AS=0 => 8-bit ASID in bits[63:56]).
# Distinct non-zero ASIDs keep each slot's translations independently cached so a
# swap needs no broad TLB flush.
P20_ASID_A: uint64 = 4
P20_ASID_B: uint64 = 5
P20_ASID_C: uint64 = 6
P20_ASID_SHIFT: uint64 = 48

# Per-slot code + stacks live in the shared EL0 RWX window (USER_L2_INDEX), mapped
# identically in every private space so each slot's instructions are fetchable
# under any TTBR0. Distinct code pages + stacks so the slots never alias.
P20_A_CODE: uint64 = 0x40210000
P20_B_CODE: uint64 = 0x40214000
P20_C_CODE: uint64 = 0x40218000
P20_A_STACK_TOP: uint64 = 0x40270000
P20_B_STACK_TOP: uint64 = 0x40278000
P20_C_STACK_TOP: uint64 = 0x40280000

# Per-slot context blocks (34 x 8-byte slots) in EL1-only RAM (outside EL0 window).
P20_A_CTX: uint64 = 0x40108000
P20_B_CTX: uint64 = 0x40109000
P20_C_CTX: uint64 = 0x4010A000

# Kernel-private "tick report" syscall (carries the byte read at P20_SHARED_VA).
# Distinct from the Phase-19 report nr (546) and the other private nrs.
SYS_P20_TICK_NR: uint64 = 547

# Slot state machine. A runnable slot is scheduled; a REAPED slot (after exit())
# is never scheduled again; an EMPTY slot has not been spawned yet.
P20_SLOT_EMPTY: int64 = 0
P20_SLOT_RUNNABLE: int64 = 1
P20_SLOT_REAPED: int64 = 2

# Phase 20 bookkeeping. arm64_p20_active routes svc + timer IRQ into the Phase-20
# path while the demo is live. arm64_p20_cur is the live slot index (0=A,1=B,2=C).
arm64_p20_active: int64 = 0
arm64_p20_cur: int64 = 0
arm64_p20_state0: int64 = 0          # slot A state
arm64_p20_state1: int64 = 0          # slot B state
arm64_p20_state2: int64 = 0          # slot C state (EMPTY until dynamically spawned)
arm64_p20_a_reports: int64 = 0       # tick reports from slot A
arm64_p20_b_reports: int64 = 0       # tick reports from slot B
arm64_p20_c_reports: int64 = 0       # tick reports from slot C
arm64_p20_a_correct: int64 = 0       # slot A reports carrying its own sentinel
arm64_p20_b_correct: int64 = 0
arm64_p20_c_correct: int64 = 0
arm64_p20_leaks: int64 = 0           # any report whose value was ANOTHER slot's
arm64_p20_swaps: int64 = 0           # TTBR0+ASID swaps performed
arm64_p20_a_reaped: int64 = 0        # 1 once slot A's exit() was reaped
arm64_p20_a_exit_code: int64 = -1    # slot A's recorded exit code (proves exit ran)
arm64_p20_c_spawned: int64 = 0       # 1 once slot C was dynamically spawned
arm64_p20_b_after_spawn: int64 = 0   # slot B reports OBSERVED after the C spawn
arm64_p20_swaps_at_spawn: int64 = 0  # swap count when C was spawned (goal baseline)
P20_A_EXIT_AT: int64 = 3             # tick reports before slot A calls exit()
P20_GOAL: int64 = 10                 # swaps AFTER the spawn before the verdict

# ---------------------------------------------------------------------------
# Phase 21: A BLOCKING PRIMITIVE — sys_nanosleep that DESCHEDULES a task.
#
# Phases 19/20 prove preemptive multitasking, per-ASID address spaces, dynamic
# spawn, and exit/reaping — but every task that wasn't reaped was ALWAYS
# RUNNABLE; the scheduler only ever skipped DEAD slots. None proves the OTHER
# half of a real process model: a LIVE task can voluntarily DESCHEDULE itself
# (block) for a span of time, the scheduler keeps running the OTHER tasks while
# it sleeps, and when the task's deadline passes the scheduler WAKES it and it
# RESUMES exactly where it blocked (past the nanosleep, with the right return).
#
# Phase 21 runs TWO preemptively-scheduled EL0 tasks in PRIVATE ASID-tagged
# spaces (slot A ASID 7, slot B ASID 8 — reusing the Phase-19/20 geometry at
# fresh, non-overlapping addresses). Each task loops: read its private sentinel
# at the shared VA (through its own TTBR0+ASID), report it via a tick syscall,
# then call sys_nanosleep(N) — A sleeps LONG (P21_A_SLEEP ticks), B sleeps SHORT
# (P21_B_SLEEP ticks). nanosleep saves the caller's FULL resume context into its
# slot ctx (x0..x30 + SP_EL0 + the post-svc ELR), records a CNTVCT_EL0 deadline,
# marks the slot BLOCKED, and parks the live EL0 PC on a self-loop so the svc
# eret harmlessly spins until the next timer tick preempts it. The timer-IRQ
# scheduler (arm64_p21_sched_pick) WAKES any BLOCKED slot whose deadline passed
# (back to RUNNABLE) and round-robins ONLY the RUNNABLE slots.
#
# The svc path cannot itself switch tasks (arm64_lower_sync_entry erets to the
# LIVE ELR_EL1/SP_EL0, ignoring arm64_current_ctx), so the blocked task is
# parked on a self-loop and arm64_current_ctx is pointed at a THROWAWAY "park"
# ctx — so the next timer IRQ saves the spin state there, NOT over the slot's
# real saved resume context. On wake the scheduler restores the slot's real ctx.
#
# PASS requires: BOTH tasks ran; EACH task BLOCKED at least once AND was WOKEN
# and RESUMED past its nanosleep (proving the deschedule+deadline+resume cycle);
# at least one tick ran a RUNNABLE task while the OTHER was BLOCKED (proving the
# blocked task genuinely yielded the CPU to a peer); every read stayed private
# (zero cross-task sentinel leaks across the ASID swaps). After P21_GOAL swaps
# the scheduler prints the verdict + halts.
# ---------------------------------------------------------------------------

# Shared VA both tasks dereference (resolved per-slot through its own TTBR0+ASID
# to a DIFFERENT private block). 2 MiB-aligned, L2 index 13 (0x41A0_0000) — the
# same EL0 window slot Phases 19/20 use, but Phase 21's spaces are built fresh.
P21_SHARED_VA: uint64 = 0x41A00000
P21_SHARED_L2_INDEX: uint64 = 13        # (0x41A0_0000 - 0x4000_0000) / 2 MiB

# Per-slot private translation roots (4 KiB EL1-only RAM pages) + RAM L2 tables,
# in the free gap above the Phase-20 page-table scratch (ends 0x4018_6000) and
# below the EL0 window (0x4020_0000).
P21_A_L1: uint64 = 0x40186000
P21_A_L2: uint64 = 0x40187000
P21_B_L1: uint64 = 0x40188000
P21_B_L2: uint64 = 0x40189000

# Per-slot PRIVATE physical data block (2 MiB-aligned; backs P21_SHARED_VA for
# that slot). Above the Phase-20 blocks (which end at 0x4220_0000).
P21_A_DATA: uint64 = 0x42200000
P21_B_DATA: uint64 = 0x42400000

# Per-slot sentinels seeded into the private blocks (byte 0).
P21_SENTINEL_A: uint64 = 0x5A
P21_SENTINEL_B: uint64 = 0x6B

# Per-slot ASID (TTBR0_EL1 bits[63:48]; TCR.AS=0 => 8-bit ASID). Distinct from
# every prior phase's ASIDs (1,2 / 4,5,6) so a swap needs no broad TLB flush.
P21_ASID_A: uint64 = 7
P21_ASID_B: uint64 = 8
P21_ASID_SHIFT: uint64 = 48

# Per-slot code + stacks live in the shared EL0 RWX window (USER_L2_INDEX), in
# the free space above the Phase-20 code/stacks (code <=0x4021_8000, stacks
# <=0x4028_0000) and below the EL0 window top (0x4040_0000).
P21_A_CODE: uint64 = 0x40220000
P21_B_CODE: uint64 = 0x40224000
P21_A_STACK_TOP: uint64 = 0x40288000
P21_B_STACK_TOP: uint64 = 0x40290000

# Per-slot context blocks (34 x 8-byte slots) in EL1-only RAM (outside EL0
# window), above the Phase-20 ctx blocks (which end at 0x4010_B000).
P21_A_CTX: uint64 = 0x4010B000
P21_B_CTX: uint64 = 0x4010C000

# Throwaway "park" ctx: arm64_current_ctx is pointed here while a task is BLOCKED
# and spinning, so the next timer IRQ saves the spin state into THIS block rather
# than over the blocked slot's real (saved) resume context.
P21_PARK_CTX: uint64 = 0x4010D000

# Kernel-private nanosleep + tick-report syscall numbers (distinct from every
# prior private nr: 512/513/514, 540..545, 546, 547).
SYS_P21_TICK_NR: uint64 = 548        # carries the byte read at P21_SHARED_VA
SYS_P21_NANOSLEEP_NR: uint64 = 549   # a0 = number of scheduler ticks to sleep

# Per-slot sleep lengths (in scheduler ticks). A sleeps LONG, B sleeps SHORT, so
# while A is blocked the scheduler keeps running B (the deschedule-others pillar).
P21_A_SLEEP: int64 = 4
P21_B_SLEEP: int64 = 1

# Slot state machine. RUNNABLE => scheduled; BLOCKED => descheduled until its
# CNTVCT deadline passes (then the scheduler wakes it RUNNABLE).
P21_SLOT_RUNNABLE: int64 = 1
P21_SLOT_BLOCKED: int64 = 2

# Phase 21 bookkeeping. arm64_p21_active routes svc + timer IRQ into the Phase-21
# path while the demo is live. arm64_p21_cur is the live slot index (0=A, 1=B).
arm64_p21_active: int64 = 0
arm64_p21_cur: int64 = 0
arm64_p21_state0: int64 = 0          # slot A state
arm64_p21_state1: int64 = 0          # slot B state
arm64_p21_deadline0: uint64 = 0      # slot A CNTVCT wake deadline (when BLOCKED)
arm64_p21_deadline1: uint64 = 0      # slot B CNTVCT wake deadline
arm64_p21_a_reports: int64 = 0       # tick reports from slot A
arm64_p21_b_reports: int64 = 0       # tick reports from slot B
arm64_p21_a_correct: int64 = 0       # slot A reports carrying its own sentinel
arm64_p21_b_correct: int64 = 0
arm64_p21_a_blocks: int64 = 0        # times slot A descheduled via nanosleep
arm64_p21_b_blocks: int64 = 0        # times slot B descheduled via nanosleep
arm64_p21_a_wakes: int64 = 0         # times slot A was woken + resumed past sleep
arm64_p21_b_wakes: int64 = 0         # times slot B was woken + resumed past sleep
arm64_p21_ran_while_peer_blocked: int64 = 0  # ticks a task ran while peer BLOCKED
arm64_p21_leaks: int64 = 0           # any report whose value was the OTHER slot's
arm64_p21_swaps: int64 = 0           # TTBR0+ASID swaps performed
P21_GOAL: int64 = 16                 # swaps before the verdict

# ---------------------------------------------------------------------------
# Phase 22: EL0 FUTEX (FUTEX_WAIT / FUTEX_WAKE) — block on a memory word, woken
# by a peer task. Builds on Phase 21's BLOCKED-state + resume-context-save +
# park-ctx machinery; the ONLY difference is the WAKE condition. A nanosleep
# waiter wakes on a timer deadline; a futex waiter wakes when a PEER task calls
# FUTEX_WAKE on the matching uaddr key. Two preemptively-scheduled EL0 tasks in
# private ASID-tagged spaces share ONE physical futex word mapped at a well-known
# shared VA in BOTH spaces; the PHYSICAL address backing that word is the match
# key, so cross-ASID matching is unambiguous.
#
# Task A (WAITER) loops: report its private sentinel, then futex_wait(F,0). If
# *F==0 it BLOCKS on the futex key; on wake it resumes past the svc. Task B
# (WAKER) loops: report its private sentinel, nanosleep(short) to yield so A can
# block, then write *F=1, futex_wake(F,1) to wake A, then write *F=0 so A's next
# wait blocks again. The cycle repeats, proving block-on-word / wake-by-peer.
# ---------------------------------------------------------------------------

# Shared futex VA both tasks dereference. Resolved per-slot through its own
# TTBR0+ASID, but BOTH map it to the SAME physical block (so it is genuinely a
# shared word, unlike Phase 21's per-slot-private shared VA). 2 MiB-aligned, L2
# index 14 (0x41C0_0000), one slot above Phase 21's shared VA.
P22_FUTEX_VA: uint64 = 0x41C00000
P22_FUTEX_L2_INDEX: uint64 = 14          # (0x41C0_0000 - 0x4000_0000) / 2 MiB

# Private-sentinel shared VA (per-slot private block, like Phase 21) so each task
# has an observable private read for the tick-report / leak-detection pattern.
# 2 MiB-aligned, L2 index 15 (0x41E0_0000).
P22_SENT_VA: uint64 = 0x41E00000
P22_SENT_L2_INDEX: uint64 = 15           # (0x41E0_0000 - 0x4000_0000) / 2 MiB

# Per-slot private translation roots (4 KiB EL1-only RAM pages) + RAM L2 tables,
# in the free gap above Phase 21's page-table scratch (ends 0x4018_A000) and
# below the EL0 window (0x4020_0000).
P22_A_L1: uint64 = 0x4018A000
P22_A_L2: uint64 = 0x4018B000
P22_B_L1: uint64 = 0x4018C000
P22_B_L2: uint64 = 0x4018D000

# ONE shared physical futex word block (2 MiB-aligned), mapped at P22_FUTEX_VA in
# BOTH slots. Above Phase 21's private blocks (which end at 0x4260_0000).
P22_FUTEX_DATA: uint64 = 0x42600000

# Per-slot PRIVATE physical sentinel block (2 MiB-aligned), backs P22_SENT_VA for
# that slot. Above the shared futex block.
P22_A_SENT_DATA: uint64 = 0x42800000
P22_B_SENT_DATA: uint64 = 0x42A00000

# Per-slot sentinels seeded into the private sentinel blocks (byte 0).
P22_SENTINEL_A: uint64 = 0x7C
P22_SENTINEL_B: uint64 = 0x8D

# Per-slot ASID. Distinct from every prior phase's ASIDs (..7,8) so a swap needs
# no broad TLB flush.
P22_ASID_A: uint64 = 9
P22_ASID_B: uint64 = 10
P22_ASID_SHIFT: uint64 = 48

# Per-slot code + stacks live in the shared EL0 RWX window (USER_L2_INDEX), above
# Phase 21's code/stacks (code <=0x4022_8000, stacks <=0x4029_0000) and below the
# EL0 window top (0x4040_0000).
P22_A_CODE: uint64 = 0x40228000
P22_B_CODE: uint64 = 0x4022C000
P22_A_STACK_TOP: uint64 = 0x40298000
P22_B_STACK_TOP: uint64 = 0x402A0000

# Per-slot context blocks (34 x 8-byte slots) in EL1-only RAM, above Phase 21's
# park ctx (0x4010_D000).
P22_A_CTX: uint64 = 0x4010E000
P22_B_CTX: uint64 = 0x4010F000

# Throwaway "park" ctx (same trick as Phase 21): arm64_current_ctx points here
# while a task is BLOCKED + spinning so the next timer IRQ saves the spin state
# here, not over the blocked slot's real saved resume context.
P22_PARK_CTX: uint64 = 0x40110000

# Kernel-private syscall numbers (distinct from every prior private nr, incl.
# Phase 21's 548/549).
SYS_P22_TICK_NR: uint64 = 550        # a0 = byte read at P22_SENT_VA (private)
SYS_P22_FUTEX_NR: uint64 = 551       # a0 = uaddr, a1 = op, a2 = val
SYS_P22_NANOSLEEP_NR: uint64 = 552   # a0 = scheduler ticks to sleep (B pacing)
SYS_P22_POKE_NR: uint64 = 553        # a0 = uaddr, a1 = value: *uaddr = value

# Futex ops.
P22_FUTEX_WAIT: uint64 = 0
P22_FUTEX_WAKE: uint64 = 1

# B's pacing sleep (short) so A reliably blocks on the futex before B wakes it.
P22_B_SLEEP: int64 = 1

# Slot states. RUNNABLE => scheduled. BLOCKED => descheduled (on a futex key OR a
# timer deadline) until woken.
P22_SLOT_RUNNABLE: int64 = 1
P22_SLOT_BLOCKED: int64 = 2

# How a BLOCKED slot is woken: by a peer FUTEX_WAKE on a matching key, or by a
# timer deadline passing (nanosleep). Recorded per slot so the timer path only
# auto-wakes the timer-blocked ones and FUTEX_WAKE only wakes futex-blocked ones.
P22_WAIT_NONE: int64 = 0
P22_WAIT_FUTEX: int64 = 1
P22_WAIT_TIMER: int64 = 2

# Phase 22 bookkeeping. arm64_p22_active routes svc + timer IRQ into the Phase-22
# path while the demo is live. arm64_p22_cur is the live slot index (0=A, 1=B).
arm64_p22_active: int64 = 0
arm64_p22_cur: int64 = 0
arm64_p22_state0: int64 = 0          # slot A state
arm64_p22_state1: int64 = 0          # slot B state
arm64_p22_wait0: int64 = 0           # slot A wait-kind (futex / timer / none)
arm64_p22_wait1: int64 = 0           # slot B wait-kind
arm64_p22_key0: uint64 = 0           # slot A futex match key (physical uaddr)
arm64_p22_key1: uint64 = 0           # slot B futex match key
arm64_p22_deadline0: uint64 = 0      # slot A timer wake deadline (nanosleep)
arm64_p22_deadline1: uint64 = 0      # slot B timer wake deadline
arm64_p22_a_reports: int64 = 0       # tick reports from slot A
arm64_p22_b_reports: int64 = 0       # tick reports from slot B
arm64_p22_a_correct: int64 = 0       # slot A reports carrying its own sentinel
arm64_p22_b_correct: int64 = 0
arm64_p22_a_waits: int64 = 0         # times slot A BLOCKED on the futex
arm64_p22_a_wakes: int64 = 0         # times slot A was WOKEN by a peer FUTEX_WAKE
arm64_p22_wakes_issued: int64 = 0    # FUTEX_WAKE calls that woke >=1 waiter
arm64_p22_ran_while_peer_blocked: int64 = 0  # ticks a task ran while peer BLOCKED
arm64_p22_leaks: int64 = 0           # any report whose value was the OTHER slot's
arm64_p22_swaps: int64 = 0           # TTBR0+ASID swaps performed
P22_GOAL: int64 = 24                 # swaps before the verdict

# ---------------------------------------------------------------------------
# Phase 23: EL0 THREAD-LOCAL STORAGE via TPIDR_EL0 (the AArch64 TLS ABI thread
# pointer) + a SETTLS syscall, saved+restored PER-THREAD across every preemptive
# context switch. This is the register/scheduler wiring that makes pthread-style
# thread-local storage real on arm64: each EL0 thread installs its OWN thread
# pointer (TPIDR_EL0) once via SETTLS; thereafter the thread reads its TLS base
# with a bare `mrs x, tpidr_el0` (NO syscall) and dereferences it. Because the
# scheduler SAVES the outgoing thread's TPIDR_EL0 and RESTORES the incoming
# thread's on every tick, two threads running the SAME EL0 code each see their
# OWN thread-local value — proving genuine per-thread TLS isolation.
#
# Two preemptively-scheduled EL0 tasks in private ASID-tagged spaces: slot A
# (ASID 11) and slot B (ASID 12). Each maps a PRIVATE physical TLS block at a
# shared TLS VA. Each task: (1) on first run calls SETTLS(P23_TLS_VA) to install
# its thread pointer; (2) thereafter loops: `mrs x1,tpidr_el0; ldrb w0,[x1]` to
# read the thread-local sentinel through its OWN thread pointer with no syscall,
# then reports it. A PASS requires BOTH threads installed a TLS pointer, BOTH
# read their own thread-local sentinel through TPIDR_EL0 (no syscall), the
# scheduler preserved each thread's TPIDR_EL0 across MANY context switches, and
# ZERO cross-thread TLS leaks occurred (no thread ever saw the other's value).
# ---------------------------------------------------------------------------

# Shared TLS VA both threads use as their thread pointer. Resolved per-slot
# through its own TTBR0+ASID to that slot's PRIVATE physical TLS block, so the
# bare `mrs tpidr_el0 + ldrb` reads each thread's OWN thread-local sentinel.
# 2 MiB-aligned, L2 index 16 (0x4200_0000), above Phase 22's shared VAs.
P23_TLS_VA: uint64 = 0x42000000
P23_TLS_L2_INDEX: uint64 = 16            # (0x4200_0000 - 0x4000_0000) / 2 MiB

# Per-slot private translation roots (4 KiB EL1-only RAM pages) + RAM L2 tables,
# in the free gap above Phase 22's page-table scratch (ends 0x4018_E000) and
# below the EL0 window (0x4020_0000).
P23_A_L1: uint64 = 0x4018E000
P23_A_L2: uint64 = 0x4018F000
P23_B_L1: uint64 = 0x40190000
P23_B_L2: uint64 = 0x40191000

# Per-slot PRIVATE physical TLS block (2 MiB-aligned), backs P23_TLS_VA for that
# slot. Above Phase 22's sentinel blocks (which end at 0x42C0_0000).
P23_A_TLS_DATA: uint64 = 0x42C00000
P23_B_TLS_DATA: uint64 = 0x42E00000

# Per-slot thread-local sentinel seeded into each TLS block (byte 0). These are
# the values each thread must read back through its OWN TPIDR_EL0.
P23_SENTINEL_A: uint64 = 0xA1
P23_SENTINEL_B: uint64 = 0xB2

# Per-slot ASID. Distinct from every prior phase's ASIDs (..9,10).
P23_ASID_A: uint64 = 11
P23_ASID_B: uint64 = 12
P23_ASID_SHIFT: uint64 = 48

# Per-slot code + stacks in the shared EL0 RWX window, above Phase 22's code/
# stacks (code <=0x4022_C000, stacks <=0x402A_0000) and below the window top.
P23_A_CODE: uint64 = 0x40230000
P23_B_CODE: uint64 = 0x40234000
P23_A_STACK_TOP: uint64 = 0x402B0000
P23_B_STACK_TOP: uint64 = 0x402B8000

# Per-slot context blocks (34 x 8-byte slots) in EL1-only RAM, above Phase 22's
# park ctx (0x4011_0000).
P23_A_CTX: uint64 = 0x40111000
P23_B_CTX: uint64 = 0x40112000

# Kernel-private syscall numbers (distinct from every prior private nr).
SYS_P23_SETTLS_NR: uint64 = 560      # a0 = TLS base VA: write TPIDR_EL0 + record
SYS_P23_TICK_NR: uint64 = 561        # a0 = byte the thread read via TPIDR_EL0

# Phase 23 bookkeeping. arm64_p23_active routes svc + timer IRQ into the Phase-23
# path while the demo is live. arm64_p23_cur is the live slot index (0=A, 1=B).
arm64_p23_active: int64 = 0
arm64_p23_cur: int64 = 0
arm64_p23_tls0: uint64 = 0           # slot A saved TPIDR_EL0 (its thread pointer)
arm64_p23_tls1: uint64 = 0           # slot B saved TPIDR_EL0
arm64_p23_set0: int64 = 0            # slot A has installed its TLS pointer
arm64_p23_set1: int64 = 0            # slot B has installed its TLS pointer
arm64_p23_a_reads: int64 = 0         # slot A reads through its own TPIDR_EL0
arm64_p23_b_reads: int64 = 0
arm64_p23_a_correct: int64 = 0       # slot A reads carrying its own sentinel
arm64_p23_b_correct: int64 = 0
arm64_p23_a_settls: int64 = 0        # times slot A installed a thread pointer
arm64_p23_b_settls: int64 = 0
arm64_p23_leaks: int64 = 0           # any read whose value was the OTHER thread's
arm64_p23_swaps: int64 = 0           # TPIDR-preserving context switches performed
arm64_p23_both_ran_split: int64 = 0  # switches where outgoing+incoming TLS differ
P23_GOAL: int64 = 24                 # swaps before the verdict

# ---------------------------------------------------------------------------
# Phase 24: EL0 DEMAND PAGING across a fresh, wholly-unmapped VA window. Phase 14
# proved the mechanism on TWO hard-coded VAs; Phase 24 generalises it to a real
# multi-page window: a 2 MiB EL0 window is left ENTIRELY unmapped (its L2 slot is
# zero, no L3 table), so the FIRST touch of EACH page raises an independent
# translation Data Abort from EL0. The same EL1 synchronous handler decodes
# ESR_EL1 (EC == 0x24 Data Abort from a lower EL; DFSC == 0b0001xx translation
# fault), allocates a fresh physical page from a small per-phase page pool,
# installs its L3 PTE with EL0 RW permissions, invalidates ONLY that page's stale
# translation (tlbi vaae1is + dsb/isb), and returns WITHOUT advancing ELR so the
# faulting store/load RETRIES and completes transparently. The EL0 demo walks
# N_PAGES distinct pages across the window, writes a per-page sentinel to each,
# reads them all back, and hands the read-backs to the kernel, which verifies
# every value AND that exactly N_PAGES faults were serviced. A translation fault
# OUTSIDE the window keeps the existing fatal-fault behaviour (no masking of real
# bugs).
#
# Window VA 0x4220_0000: L1 idx 1 (the existing L2_PGTABLE), L2 idx 17 (UNMAPPED
# at boot, above Phase 23's TLS VA at L2 idx 16). L3 idx walks 0..N_PAGES-1.
# ---------------------------------------------------------------------------
P24_WINDOW_BASE: uint64 = 0x42200000     # EL0 demand-paged window base (unmapped)
P24_WINDOW_L2_INDEX: uint64 = 17         # (0x4220_0000 - 0x4000_0000) / 2 MiB
P24_PAGE_SIZE: uint64 = 0x1000           # 4 KiB pages
P24_N_PAGES: int64 = 4                   # distinct pages the demo touches/faults

# Fresh EL1-only physical pages: P24_L3 is the new L3 table installed under the
# window's L2 slot; P24_POOL_BASE is the base of a contiguous pool of N_PAGES
# physical pages the fault handler hands out one-per-fault. All sit in otherwise-
# unused EL1-only RAM above Phase 23's per-slot L1/L2 scratch (ends 0x4019_2000).
P24_L3: uint64 = 0x40192000              # new L3 table for the window's L2 slot
P24_POOL_BASE: uint64 = 0x40193000       # 4 contiguous backing pages (0x193..0x196)

# L3 PAGE descriptor flags: EL0 read/write Normal page (VALID | AF | SH_INNER |
# AttrIndx1 | AP[1]), bits[1:0]=0b11 so the walker treats it as a level-3 page.
P24_PAGE_FLAGS: uint64 = 0x747

# Per-page sentinel = base XOR (page index salt). Distinct per page so a read-back
# proves the RIGHT page paged in (not a stale alias of an earlier page).
P24_SENTINEL_BASE: uint64 = 0xC0FFEE0000000000

# Kernel-private syscalls (clear of every prior private nr). REPORT hands one
# read-back (index, value) pair back per page so the kernel verifies each.
SYS_P24_REPORT_NR: uint64 = 570          # a0 = page index, a1 = value read back
SYS_P24_WRITE_NR: uint64 = 571           # write(1, buf, len) -> UART
SYS_P24_EXIT_NR: uint64 = 572            # exit(code) -> verdict + halt

# EL0 message buffer (inside the identity-mapped EL0 RWX window, clear of code).
P24_MSG_BASE: uint64 = 0x40226000

# Phase 24 bookkeeping. arm64_p24_active routes EL0 aborts + svc into the Phase-24
# path while the demo is live. arm64_p24_faults counts translation faults the
# handler serviced (must reach N_PAGES). arm64_p24_next_page is the next pool page
# to hand out. arm64_p24_mapped_mask/_correct_mask are per-page latch bitmasks.
arm64_p24_active: int64 = 0
arm64_p24_faults: int64 = 0
arm64_p24_next_page: int64 = 0
arm64_p24_mapped_mask: uint64 = 0        # bit i set when page i's PTE installed
arm64_p24_correct_mask: uint64 = 0       # bit i set when page i read back correctly
arm64_p24_outside: int64 = 0             # translation faults OUTSIDE the window
arm64_p24_reports: int64 = 0             # report syscalls received

# ---------------------------------------------------------------------------
# Phase 25: COPY-ON-WRITE fork() for an EL0 task. The parent runs in its own
# ASID-tagged address space, mapping a single 4 KiB COW data page (VA
# P25_DATA_VA, via its own L3 table) RW-private and seeded with a sentinel. The
# parent writes a pre-fork value, then FORKs: the kernel builds a SECOND wholly
# independent address space (the child's own L1/L2/L3 + ASID) that aliases the
# SAME backing physical data page, but flips BOTH parent and child's L3 PTE for
# that page to EL0 READ-ONLY and records it copy-on-write. A WRITE by either
# side then takes a PERMISSION data abort; the COW handler allocates a FRESH
# physical page, copies the shared page into it, remaps the FAULTING task's L3
# PTE to the new page RW-PRIVATE (leaving the other side untouched), flushes that
# ASID's stale translation and resumes. Parent and child each write a DIFFERENT
# value to the SAME VA and read it back; the kernel proves each side sees its own
# value AND the two backing physical pages diverged — i.e. real COW isolation.
#
# Deterministic + abort-driven (IRQs masked, no scheduler), mirroring Phase 24:
# child runs to completion first (cooperatively handed control by FORK), then the
# kernel resumes the parent past the fork to run to its own exit + verdict.
#
# COW data VA 0x4240_0000: L1 idx 1, L2 idx 18 (UNMAPPED at boot, above Phase 24's
# window at L2 idx 17). The data page sits at L3 idx 0 of each space's data L3.
# ---------------------------------------------------------------------------
P25_DATA_VA: uint64 = 0x42400000         # shared (then COW-divergent) EL0 data VA
P25_DATA_L2_INDEX: uint64 = 18           # (0x4240_0000 - 0x4000_0000) / 2 MiB
P25_PAGE_SIZE: uint64 = 0x1000           # 4 KiB pages

# Per-space translation roots (4 KiB EL1-only RAM pages) + RAM L2 tables + the
# data VA's own L3 table, in free EL1-only RAM above Phase 24's pool (which ends
# at 0x4019_6000) and below the EL0 RWX window (0x4020_0000).
P25_PARENT_L1: uint64 = 0x401A0000
P25_PARENT_L2: uint64 = 0x401A1000
P25_PARENT_L3: uint64 = 0x401A2000       # L3 for the COW data VA in the parent
P25_CHILD_L1: uint64 = 0x401A3000
P25_CHILD_L2: uint64 = 0x401A4000
P25_CHILD_L3: uint64 = 0x401A5000        # L3 for the COW data VA in the child

# The ORIGINAL shared backing physical data page (2 MiB-clear of Phase 23's TLS
# blocks, which end at 0x4300_0000). Seeded with P25_SEED before the parent runs.
P25_SHARED_DATA_PA: uint64 = 0x43000000

# Fresh COW pages the permission-fault handler hands out one-per-divergent-write
# (two: one for whichever side writes first, one for the other). Above the
# per-space page-table scratch (ends 0x401A_6000).
P25_COW_POOL_BASE: uint64 = 0x401A6000   # 2 contiguous fresh COW pages

# Per-space EL0 code + stack inside the shared EL0 RWX window. Parent and child
# share IDENTICAL code at the SAME VA (fork shares the text); the child simply
# resumes at the post-FORK PC. Above Phase 23's code (<=0x4023_4000) and stacks.
P25_CODE_BASE: uint64 = 0x40240000
P25_PARENT_STACK_TOP: uint64 = 0x402C0000
P25_CHILD_STACK_TOP: uint64 = 0x402C8000

# Per-space context blocks (34 x 8-byte slots) in EL1-only RAM, above Phase 23's.
P25_PARENT_CTX: uint64 = 0x40113000
P25_CHILD_CTX: uint64 = 0x40114000

# Per-space ASIDs, distinct from every prior phase's (..9,10,11,12).
P25_PARENT_ASID: uint64 = 13
P25_CHILD_ASID: uint64 = 14

# L3 PAGE descriptor flags (bits[1:0]=0b11 page). RW = EL0 read/write Normal-WB
# (== Phase 24's 0x747); RO additionally sets AP[2] (bit7 0x80) -> EL0 read-only,
# so a store takes a PERMISSION fault. The COW share marks the page RO in both
# spaces; the handler restores RW (on a private copy) for the faulting side.
P25_PAGE_RW: uint64 = 0x747
P25_PAGE_RO: uint64 = 0x7C7

# Sentinel seeded into the shared page (byte 0) before the parent runs, plus the
# two DIFFERENT post-fork values parent and child each store at P25_DATA_VA.
P25_SEED: uint64 = 0x55
P25_PARENT_VAL: uint64 = 0xAA11
P25_CHILD_VAL: uint64 = 0xBB22

# Kernel-private syscall numbers (clear of every prior private nr).
SYS_P25_FORK_NR: uint64 = 580      # fork(): child returns x0=0, parent x0=1
SYS_P25_REPORT_NR: uint64 = 581    # a0 = which (0=child,1=parent), a1 = value read
SYS_P25_DONE_NR: uint64 = 582      # child finished -> kernel resumes the parent
SYS_P25_EXIT_NR: uint64 = 583      # parent exit(code) -> verdict + halt

# Phase 25 bookkeeping. arm64_p25_active routes EL0 aborts + svc into the Phase-25
# path while the demo is live. arm64_p25_cur is the live space (0=child,1=parent)
# so the permission-fault handler knows whose L3 to privatise.
arm64_p25_active: int64 = 0
arm64_p25_cur: int64 = 0               # 0 = child space live, 1 = parent space live
arm64_p25_next_cow: int64 = 0          # next fresh COW pool page to hand out
arm64_p25_cow_faults: int64 = 0        # COW permission faults serviced
arm64_p25_forked: int64 = 0            # fork() ran and built the child space
arm64_p25_child_reported: int64 = 0    # child reported its read-back
arm64_p25_parent_reported: int64 = 0   # parent reported its read-back
arm64_p25_child_val: uint64 = 0        # value the child read back at the data VA
arm64_p25_parent_val: uint64 = 0       # value the parent read back at the data VA
arm64_p25_child_pa: uint64 = 0         # child's PRIVATE backing physical page
arm64_p25_parent_pa: uint64 = 0        # parent's PRIVATE backing physical page
arm64_p25_resume_pc: uint64 = 0        # EL0 PC both sides resume at after FORK
arm64_p25_parent_sp: uint64 = 0        # parent's saved SP_EL0 at the FORK svc

# ---------------------------------------------------------------------------
# Phase 26: a real AArch64 ELF64 LOADER + execute. Every EL0 program before this
# phase was hand-emitted machine code dropped straight into an EL0 code page.
# Phase 26 instead PARSES a genuine ELF64 image: it validates e_ident (0x7F 'E'
# 'L' 'F', ELFCLASS64, little-endian), checks e_machine == EM_AARCH64, reads
# e_entry / e_phoff / e_phnum / e_phentsize from the header, then walks the
# program-header table. For each PT_LOAD it allocates page-aligned backing,
# copies p_filesz bytes from the image, zeroes the (p_memsz - p_filesz) BSS tail,
# and maps [p_vaddr, p_vaddr + p_memsz) into a FRESH EL0 address space (its own
# ASID + L1/L2/L3 tables) with protections derived from p_flags: PF_X -> EL0
# executable (read-only text), PF_W -> EL0 RW + non-exec (W^X data), else EL0
# read-only. It then sets up an EL0 stack, ELR_EL1 = e_entry, SPSR for EL0t, and
# ERETs into the loaded program — which runs write(1,msg,len) + exit(N) via svc.
#
# The test image is assembled at boot into a module-scope byte array (a real
# ELF header + two PT_LOADs: an RX text segment carrying the EL0 code + message,
# and an RW data segment with a BSS tail). The loader NEVER assumes the layout:
# every offset/size/flag it acts on is read out of the parsed ELF structures.
#
# Deterministic + abort-driven (IRQs masked, no scheduler), mirroring Phase 25:
# segment pages fault in on the demand-abort path, the program runs to exit().
# ---------------------------------------------------------------------------

# Module-scope image buffer holding the assembled ELF64 file. 4 KiB is ample for
# our header + two program headers + a page of code + message.
P26_IMG_MAX: uint64 = 4096
P26_PAGE_SIZE: uint64 = 0x1000           # 4 KiB pages
arm64_p26_image: Array[4096, uint8]      # the raw ELF64 file bytes
arm64_p26_image_len: uint64 = 0          # total bytes assembled into the image

# ELF64 structural constants (offsets into the file header / a program header).
ELF_EI_MAG0: uint64 = 0x7F
ELF_EI_MAG1: uint64 = 0x45               # 'E'
ELF_EI_MAG2: uint64 = 0x4C               # 'L'
ELF_EI_MAG3: uint64 = 0x46               # 'F'
ELFCLASS64: uint64 = 2
ELFDATA2LSB: uint64 = 1
ET_EXEC: uint64 = 2
EM_AARCH64: uint64 = 183                 # 0xB7
PT_LOAD: uint64 = 1
PF_X: uint64 = 1
PF_W: uint64 = 2
PF_R: uint64 = 4

EHDR_SIZE: uint64 = 64                   # sizeof(Elf64_Ehdr)
PHDR_SIZE: uint64 = 56                   # sizeof(Elf64_Phdr)

# Elf64_Ehdr field byte offsets.
EH_TYPE: uint64 = 16
EH_MACHINE: uint64 = 18
EH_ENTRY: uint64 = 24
EH_PHOFF: uint64 = 32
EH_PHENTSIZE: uint64 = 54
EH_PHNUM: uint64 = 56

# Elf64_Phdr field byte offsets.
PH_TYPE: uint64 = 0
PH_FLAGS: uint64 = 4
PH_OFFSET: uint64 = 8
PH_VADDR: uint64 = 16
PH_FILESZ: uint64 = 32
PH_MEMSZ: uint64 = 40

# Phase 26 EL0 program layout. The text segment loads at P26_TEXT_VA (its own
# 2 MiB L2 slot, distinct from every prior phase's), the data segment at
# P26_DATA_VA. Both are above Phase 25's COW data VA (0x4240_0000).
P26_TEXT_VA: uint64 = 0x42600000         # PT_LOAD #1 (RX): code + message
P26_DATA_VA: uint64 = 0x42800000         # PT_LOAD #2 (RW): data + BSS tail
P26_TEXT_L2_INDEX: uint64 = 19           # (0x4260_0000 - 0x4000_0000) / 2 MiB
P26_DATA_L2_INDEX: uint64 = 20           # (0x4280_0000 - 0x4000_0000) / 2 MiB

# Per-segment file offsets/sizes the ASSEMBLER stamps into the program headers
# (the LOADER re-reads them from the parsed headers — it does not use these).
P26_TEXT_FOFF: uint64 = 0x120            # text seg file offset (after ehdr+2 phdr)
P26_MSG_OFF: uint64 = 0x100              # message offset within the text segment
P26_DATA_FILESZ: uint64 = 8              # 8 init bytes in the data segment file
P26_DATA_MEMSZ: uint64 = 0x40           # data segment mem size (BSS tail beyond 8)

# EL0 VAs the program touches, derived from the segment VAs above.
P26_MSG_VA: uint64 = 0x42600100          # P26_TEXT_VA + P26_MSG_OFF
P26_BSS_VA: uint64 = 0x42800010          # a byte in the data segment's BSS tail

P26_EXIT_CODE: uint64 = 0x2A             # the program's exit status (== 42)

# Fresh EL0 address space for the loaded program: its own L1/L2/L3 roots + ASID +
# stack, in free EL1-only RAM above Phase 25's per-space scratch / COW pool.
P26_L1: uint64 = 0x401B0000
P26_L2: uint64 = 0x401B1000
P26_TEXT_L3: uint64 = 0x401B2000         # L3 for the text segment's 2 MiB slot
P26_DATA_L3: uint64 = 0x401B3000         # L3 for the data segment's 2 MiB slot
P26_ASID: uint64 = 15                    # distinct from prior phases' ASIDs

# Backing physical pages the loader maps the segments onto (each 2 MiB-clear of
# Phase 25's shared data page at 0x4300_0000).
P26_TEXT_PA: uint64 = 0x43200000         # text segment backing page
P26_DATA_PA: uint64 = 0x43400000         # data segment backing page

# EL0 stack for the loaded program (a mapped, RW, non-exec region; SP near top).
P26_STACK_VA: uint64 = 0x42A00000        # data-style RW stack region base
P26_STACK_L2_INDEX: uint64 = 21          # (0x42A0_0000 - 0x4000_0000) / 2 MiB
P26_STACK_L3: uint64 = 0x401B4000
P26_STACK_PA: uint64 = 0x43600000        # stack backing page
P26_STACK_TOP: uint64 = 0x42A01000       # 16B-aligned top of the mapped stack page

# L3 PAGE descriptor flags. RX = EL0 read+exec, read-only (UXN clear, AP[2] set
# read-only). RW = EL0 read/write, non-exec (UXN set, AP[1], no AP[2]). RO = EL0
# read-only, non-exec. (Same Normal-WB attrs as the other phases' 0x747 base.)
P26_PAGE_RX: uint64 = 0x7C7              # VALID|page|AF|SH|attr1|AP[1]|AP[2](RO)
P26_PAGE_RW: uint64 = 0x40000000000747   # ...|UXN(bit54) set -> EL0 non-exec RW
P26_PAGE_RO: uint64 = 0x400000000007C7   # UXN set, AP[2] set -> EL0 RO non-exec

# Kernel-private syscall numbers for the loaded program (clear of every prior nr).
SYS_P26_WRITE_NR: uint64 = 590     # write(1, buf, len): emit to UART
SYS_P26_BSS_NR: uint64 = 591       # report(a0 = byte read back from the BSS tail)
SYS_P26_EXIT_NR: uint64 = 592      # exit(code): verdict + halt

# Phase 26 bookkeeping. arm64_p26_active routes EL0 aborts + svc into the loader's
# path while the loaded program runs.
arm64_p26_active: int64 = 0
arm64_p26_entry: uint64 = 0            # e_entry parsed from the ELF header
arm64_p26_segs_loaded: int64 = 0       # PT_LOAD segments mapped by the loader
arm64_p26_text_faults: int64 = 0       # demand faults serviced for the text seg
arm64_p26_data_faults: int64 = 0       # demand faults serviced for the data seg
arm64_p26_msg_bytes: int64 = 0         # bytes the program wrote via write()
arm64_p26_bss_val: uint64 = 0xFF       # byte the program read back from BSS tail
arm64_p26_bss_reported: int64 = 0      # the program reported its BSS read-back
arm64_p26_exit_code: uint64 = 0xFFFF   # the program's exit() status
arm64_p26_exited: int64 = 0            # the program called exit()
arm64_p26_parse_ok: int64 = 0          # the ELF header validated cleanly

# ---------------------------------------------------------------------------
# Identity-mapped L1 page table. A single level-1 table of 512 8-byte block
# descriptors (4 KiB granule => each L1 entry spans 1 GiB). We place it at a
# fixed, 4 KiB-aligned physical address in RAM, well past the kernel image
# (loaded at 0x4008_0000) and its 64 KiB boot stack. RAM is identity-mapped
# Normal-WB by this very table, so the page used to hold the table is itself
# cacheable Normal memory — fine, the table is read by the page-table walker
# regardless.
# ---------------------------------------------------------------------------
L1_PGTABLE: uint64 = 0x40100000
# Phase 4: a second-level (L2) table covering the 1 GiB RAM block at
# 0x4000_0000 in 2 MiB blocks. We replace the coarse L1 RAM *block* with an L1
# *table* descriptor pointing here, so a single 2 MiB region can be granted EL0
# access without making the kernel's own (.text/stack/pgtable) memory
# EL0-writable. (EL0-writable memory is forced Privileged-eXecute-Never, which
# would fault the kernel's instruction fetches — hence the split.)
L2_PGTABLE: uint64 = 0x40102000

# Block descriptor attribute bits (stage-1 block, levels 1 and 2).
DESC_VALID: uint64 = 0x1            # bit0 valid
DESC_AF: uint64 = 0x400             # bit10 Access Flag (else translation fault)
DESC_SH_INNER: uint64 = 0x300       # bits[9:8]=3 Inner shareable
# AttrIndx: bits[4:2]. attr0 = Device-nGnRE, attr1 = Normal WB.
DEV_FLAGS: uint64 = 0x401           # VALID | AF | AttrIndx0 (device)
MEM_FLAGS: uint64 = 0x705           # VALID | AF | SH_INNER | AttrIndx1 (normal)
# Table descriptor (bits[1:0]=0b11) for an L1 entry that points at an L2 table.
DESC_TABLE: uint64 = 0x3
# Phase 4: the EL0 region's 2 MiB L2 block additionally carries AP[1]
# (bit6 = 0x40) so EL0 can read/write/execute it. UXN is left clear so EL0 may
# execute the hand-emitted user blob; this region holds NO kernel code, so the
# implied PXN-at-EL1 (from EL0 writability) does not affect the kernel.
AP_EL0: uint64 = 0x40               # AP[1]: EL0 access permitted
MEM_FLAGS_EL0: uint64 = 0x745       # MEM_FLAGS | AP_EL0

# RAM L2 geometry: 2 MiB per L2 entry. The user region (USER_CODE_BASE ..
# USER_STACK_TOP) all falls inside one 2 MiB block; index it off RAM base.
# RAM_BASE is a board global: seeded with the qemu-virt value (0x4000_0000) and
# overwritten by board_init() from the selected board descriptor (RK3399 = 0).
RAM_BASE: uint64 = 0x40000000
L2_BLOCK_SIZE: uint64 = 0x200000     # 2 MiB
USER_L2_INDEX: uint64 = 1            # (0x4020_0000 - 0x4000_0000) / 2 MiB

# Timer period (ticks of CNTFRQ): firing every freq/100 ~= 10 ms. Stashed by
# kmain after reading CNTFRQ_EL0 so the IRQ handler can re-arm the timer.
arm64_timer_period: uint64 = 0
# Number of timer ticks serviced so far.
arm64_tick_count: int64 = 0


# ---------------------------------------------------------------------------
# board_init(): copy the compile-time-selected board descriptor (BOARD_SEL) into
# the mutable runtime board globals that the rest of the kernel reads. Called as
# the very first thing in kmain(), BEFORE any UART output, so the console points
# at the right block (PL011 vs 8250) for the target board. Until it runs the
# globals carry their qemu-virt seed values, so an early pre-init fault can still
# print on qemu-virt.
# ---------------------------------------------------------------------------
def board_init() -> int64:
    if BOARD_SEL == BOARD_RK3399_PINEBOOK_PRO:
        PL011_BASE = BOARD_RK_UART_BASE
        UART_TYPE = BOARD_RK_UART_TYPE
        GICD_BASE = BOARD_RK_GICD_BASE
        GICC_BASE = BOARD_RK_GICC_BASE
        RAM_BASE = BOARD_RK_RAM_BASE
        arm64_cpu_count = BOARD_RK_CPU_COUNT
    else:
        # Default / BOARD_QEMU_VIRT.
        PL011_BASE = BOARD_QV_UART_BASE
        UART_TYPE = BOARD_QV_UART_TYPE
        GICD_BASE = BOARD_QV_GICD_BASE
        GICC_BASE = BOARD_QV_GICC_BASE
        RAM_BASE = BOARD_QV_RAM_BASE
        arm64_cpu_count = BOARD_QV_CPU_COUNT
    return 0


# PL011 (PrimeCell) transmit: spin while FR.TXFF set, then write DR.
def _uart_putc_pl011(c: uint8) -> int64:
    fr: Ptr[uint8] = cast[Ptr[uint8]](PL011_BASE + 0x18)
    while (cast[uint64](fr[0]) & PL011_FR_TXFF) != 0:
        pass
    dr: Ptr[uint8] = cast[Ptr[uint8]](PL011_BASE)
    dr[0] = c
    return 0


# 8250/16550 transmit (RK3399 UART2 console primitive): poll LSR until THRE
# (transmit holding register empty) is set, then write the byte to THR. This is
# the minimal working console primitive for the 8250-class boards; no FIFO/baud
# reprogramming is done here (firmware leaves the console initialised).
def _uart_putc_8250(c: uint8) -> int64:
    lsr: Ptr[uint8] = cast[Ptr[uint8]](PL011_BASE + UART_8250_LSR)
    while (cast[uint64](lsr[0]) & UART_8250_LSR_THRE) == 0:
        pass
    thr: Ptr[uint8] = cast[Ptr[uint8]](PL011_BASE + UART_8250_THR)
    thr[0] = c
    return 0


# Board-dispatched console putc. PL011_BASE holds the selected UART's MMIO base
# for either type; UART_TYPE selects the transmit protocol (board_init() sets
# both from the chosen board descriptor).
def _uart_putc(c: uint8) -> int64:
    if UART_TYPE == UART_TYPE_8250:
        _uart_putc_8250(c)
    else:
        _uart_putc_pl011(c)
    return 0


def _uart_puts(s: Ptr[char]) -> int64:
    # Write a NUL-terminated string to the UART, byte by byte.
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    i: int64 = 0
    while p[i] != 0:
        _uart_putc(p[i])
        i = i + 1
    return i


# Print a 64-bit value as "0x" + 16 hex digits, MSB first. Used by the Phase 6
# page-fault handler to report the faulting VA (FAR_EL1) and EL0 PC (ELR_EL1).
def _uart_puthex(value: uint64) -> int64:
    _uart_putc(cast[uint8](0x30))          # '0'
    _uart_putc(cast[uint8](0x78))          # 'x'
    shift: int64 = 60
    while shift >= 0:
        nib: uint64 = (value >> cast[uint64](shift)) & cast[uint64](0xF)
        if nib < cast[uint64](10):
            _uart_putc(cast[uint8](cast[uint64](0x30) + nib))      # '0'..'9'
        else:
            _uart_putc(cast[uint8](cast[uint64](0x37) + nib))      # 'A'..'F'
        shift = shift - 4
    return 0


# ---------------------------------------------------------------------------
# MMU: build the identity map and enable translation + caches.
# ---------------------------------------------------------------------------
def arm64_mmu_init() -> int64:
    tbl: Ptr[uint64] = cast[Ptr[uint64]](L1_PGTABLE)

    # Zero all 512 entries (anything not explicitly mapped faults).
    i: int64 = 0
    while i < 512:
        tbl[i] = 0
        i = i + 1

    # entry[0] : VA 0x0000_0000 .. 0x3FFF_FFFF -> Device-nGnRE (GIC + UART).
    tbl[0] = cast[uint64](0) | DEV_FLAGS

    # entry[1] : VA 0x4000_0000 .. 0x7FFF_FFFF -> RAM. Instead of a coarse 1 GiB
    # block (which would force the whole kernel image EL0-accessible to expose
    # the EL0 demo region), point to a second-level table of 2 MiB blocks so we
    # can grant EL0 access to exactly one 2 MiB window.
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    j: int64 = 0
    while j < 512:
        # Identity-map each 2 MiB block at RAM_BASE + j*2MiB, Normal-WB EL1-only.
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0   # EL0 RWX window for the demo
        else:
            l2[j] = blk_pa | MEM_FLAGS       # kernel: EL1-only
        j = j + 1
    # L1 entry 1 = table descriptor referencing the L2 table.
    tbl[1] = L2_PGTABLE | DESC_TABLE

    # MAIR_EL1 = 0xff04: attr0 = Device-nGnRE (0x04), attr1 = Normal WB (0xff).
    _msr_mair_el1(cast[uint64](0xff04))

    # TCR_EL1 = 0x1_0000_3519:
    #   T0SZ=25 (39-bit VA), IRGN0=1, ORGN0=1, SH0=3 (inner shareable),
    #   TG0=0 (4 KiB granule), IPS=1 (36-bit PA).
    _msr_tcr_el1(cast[uint64](0x100003519))

    # TTBR0_EL1 = &L1 table; TTBR1_EL1 unused.
    _msr_ttbr0_el1(L1_PGTABLE)
    _msr_ttbr1_el1(cast[uint64](0))

    # Make the table writes + sysreg writes visible, flush the TLB.
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # SCTLR_EL1: set M (MMU, bit0), C (data cache, bit2), I (instr cache,
    # bit12). Read-modify-write to preserve the reset state of the rest.
    sctlr: uint64 = cast[uint64](_mrs_sctlr_el1())
    sctlr = sctlr | cast[uint64](0x1)      # M
    sctlr = sctlr | cast[uint64](0x4)      # C
    sctlr = sctlr | cast[uint64](0x1000)   # I
    _msr_sctlr_el1(sctlr)
    _isb()
    return 0


# ---------------------------------------------------------------------------
# GICv2 bring-up: install VBAR_EL1 (the vector table from vectors.S), then
# enable the distributor + CPU interface and route our timer INTID.
# ---------------------------------------------------------------------------
def arm64_gic_init() -> int64:
    # Install the EL1 exception vector table. arm64_vectors is defined in
    # arch/arm64/vectors.S; we materialise its address as an extern.
    _install_vbar()
    _isb()

    # --- GIC Distributor ---
    gicd_ctlr: Ptr[uint32] = cast[Ptr[uint32]](GICD_BASE + GICD_CTLR)
    gicd_ctlr[0] = 0                                  # disable while configuring

    # Enable INTID 27 (timer PPI). It lives in ISENABLER[0] (INTIDs 0..31).
    isenabler: Ptr[uint32] = cast[Ptr[uint32]](GICD_BASE + GICD_ISENABLER)
    isenabler[0] = cast[uint32](1 << 27)

    # Priority 0 (highest) for INTID 27. IPRIORITYR is byte-addressed.
    iprio: Ptr[uint8] = cast[Ptr[uint8]](GICD_BASE + GICD_IPRIORITYR + VTIMER_INTID)
    iprio[0] = 0

    gicd_ctlr[0] = 1                                  # enable distributor

    # --- GIC CPU interface ---
    gicc_pmr: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_PMR)
    gicc_pmr[0] = 0xF0                                # allow all priorities
    gicc_bpr: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_BPR)
    gicc_bpr[0] = 0                                   # no preemption grouping
    gicc_ctlr: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_CTLR)
    gicc_ctlr[0] = 1                                  # enable signalling
    return 0


# ---------------------------------------------------------------------------
# Virtual timer: program a periodic tick and unmask IRQs.
# ---------------------------------------------------------------------------
def arm64_timer_init() -> int64:
    freq: uint64 = cast[uint64](_mrs_cntfrq_el0())    # timer rate (Hz)
    period: uint64 = freq / cast[uint64](100)         # ~10 ms
    arm64_timer_period = period

    _msr_cntv_tval_el0(period)                        # CVAL = now + period
    _msr_cntv_ctl_el0(cast[uint64](1))                # ENABLE=1, IMASK=0
    _isb()

    _msr_daifclr(2)                                   # clear DAIF.I -> IRQs on
    return 0


# ---------------------------------------------------------------------------
# IRQ service routine — called from the vectors.S IRQ stub (which has saved
# the GPR frame). Acks at GICC, prints a per-tick marker, re-arms the timer,
# EOIs, and after TICK_LIMIT ticks prints the completion banner and halts.
# ---------------------------------------------------------------------------
def arm64_irq_handler() -> int64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]                          # ack: raw IAR
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                            # spurious: just EOI
        return 0

    # Our timer. Quiesce the firing condition while we service it.
    _msr_cntv_ctl_el0(cast[uint64](0))

    tickmsg: Ptr[char] = "[arm64] timer tick\n"
    _uart_puts(tickmsg)

    arm64_tick_count = arm64_tick_count + 1

    # Re-arm the next compare and re-enable the timer.
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))

    # EOI the verbatim IAR value.
    gicc_eoir[0] = iar

    if arm64_tick_count >= TICK_LIMIT:
        donemsg: Ptr[char] = "[arm64] timer IRQ OK\n"
        _uart_puts(donemsg)
        # Mask IRQs so the EL0 demo runs without timer re-entry, then proceed
        # to Phase 4: drop to EL0 and service its syscalls. arm64_enter_el0()
        # does not return (the EL0 exit() halts the test).
        _msr_daifset(2)
        arm64_enter_el0()
        # Unreachable; arm64_enter_el0 erets to EL0 and never comes back here.
        while True:
            _wfi()
    return 0


# ---------------------------------------------------------------------------
# Synchronous / unhandled exception diagnostics (called from vectors.S).
# ---------------------------------------------------------------------------
def arm64_sync_panic() -> int64:
    msg: Ptr[char] = "[arm64] SYNC EXCEPTION\n"
    _uart_puts(msg)
    while True:
        _wfi()
    return 0


# Phase 15 — CURRENT-EL synchronous exception handler (the kernel fault-fixup
# path). Called from the vectors.S arm64_el1_sync_entry stub for any EL1h
# synchronous exception. If this is a DATA ABORT taken while a Phase-15 uaccess
# accessor is in progress (arm64_uaccess_active != 0), it is the EXPECTED result
# of dereferencing a bad user pointer: latch the fault, advance ELR_EL1 past the
# faulting load/store (so the eret resumes the accessor at the next instruction),
# and return — the kernel never crashes. Any OTHER current-EL synchronous
# exception is a genuine kernel bug: report the syndrome + faulting address and
# halt in WFI (the legacy panic behaviour), never returning to the stub.
def arm64_el1_sync_handler(frame_ptr: Ptr[uint64]) -> int64:
    esr: uint64 = cast[uint64](_mrs_esr_el1())
    ec: uint64 = (esr >> cast[uint64](26)) & cast[uint64](0x3F)

    if ec == ESR_EC_DABORT_CUR:
        if arm64_uaccess_active != 0:
            # Expected: a copy_*_user touch of a bad user pointer. Mark it and
            # skip the faulting instruction (ELR_EL1 += 4) so we resume cleanly.
            arm64_uaccess_faulted = 1
            arm64_uaccess_faults = arm64_uaccess_faults + 1
            elr: uint64 = cast[uint64](_mrs_elr_el1())
            _msr_elr_el1(elr + cast[uint64](4))
            _isb()
            return 0

    # Not a fixable uaccess fault — a real kernel-mode exception. Report and halt.
    msg: Ptr[char] = "[arm64] EL1 SYNC EXCEPTION (kernel fault)\n"
    _uart_puts(msg)
    far: uint64 = cast[uint64](_mrs_far_el1())
    fm: Ptr[char] = "[arm64] EL1 fault ESR/FAR -> "
    _uart_puts(fm)
    _uart_puthex(esr)
    sp: Ptr[char] = " "
    _uart_puts(sp)
    _uart_puthex(far)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    while True:
        _wfi()
    return 0


# Phase 15 — copy_from_user: safely read one uint64 from user virtual address
# `uptr` into *out, returning 0 on success or -EFAULT if the pointer is bad. The
# read goes through _uaccess_get64 (a single faultable EL1 load); a bad pointer
# faults to arm64_el1_sync_handler which sets arm64_uaccess_faulted and resumes
# us here. We arm the uaccess window only across the access, never wider.
def arm64_copy_from_user_u64(uptr: uint64, out: Ptr[uint64]) -> int64:
    arm64_uaccess_faulted = 0
    arm64_uaccess_active = 1
    v: uint64 = _uaccess_get64(uptr)
    arm64_uaccess_active = 0
    if arm64_uaccess_faulted != 0:
        return cast[int64](0) - EFAULT
    out[0] = v
    return 0


# Phase 15 — copy_to_user: safely write one uint64 `val` to user virtual address
# `uptr`, returning 0 on success or -EFAULT if the pointer is bad. Mirror of
# copy_from_user using _uaccess_put64 (a single faultable EL1 store).
def arm64_copy_to_user_u64(uptr: uint64, val: uint64) -> int64:
    arm64_uaccess_faulted = 0
    arm64_uaccess_active = 1
    _uaccess_put64(uptr, val)
    arm64_uaccess_active = 0
    if arm64_uaccess_faulted != 0:
        return cast[int64](0) - EFAULT
    return 0


def arm64_unhandled_panic() -> int64:
    msg: Ptr[char] = "[arm64] UNHANDLED EXCEPTION\n"
    _uart_puts(msg)
    while True:
        _wfi()
    return 0


# ---------------------------------------------------------------------------
# Phase 4 — EL0 userspace + svc syscall path.
# ---------------------------------------------------------------------------

# Store a 32-bit little-endian instruction word at a code address. Returns the
# next address so the builder can chain word-by-word.
def _emit_word(addr: uint64, word: uint64) -> uint64:
    p: Ptr[uint32] = cast[Ptr[uint32]](addr)
    p[0] = cast[uint32](word & cast[uint64](0xFFFFFFFF))
    return addr + cast[uint64](4)


# Build a 64-bit immediate into register xd using movz + up-to-three movk. The
# AArch64 encodings:
#   movz xd, #imm16, lsl #(16*hw)  = 0xD2800000 | (hw<<21) | (imm16<<5) | xd
#   movk xd, #imm16, lsl #(16*hw)  = 0xF2800000 | (hw<<21) | (imm16<<5) | xd
# We always emit the full 4-halfword sequence for simplicity/determinism.
def _emit_load_imm64(addr: uint64, xd: uint64, value: uint64) -> uint64:
    a: uint64 = addr
    h0: uint64 = value & cast[uint64](0xFFFF)
    h1: uint64 = (value >> cast[uint64](16)) & cast[uint64](0xFFFF)
    h2: uint64 = (value >> cast[uint64](32)) & cast[uint64](0xFFFF)
    h3: uint64 = (value >> cast[uint64](48)) & cast[uint64](0xFFFF)

    movz: uint64 = cast[uint64](0xD2800000) | (h0 << cast[uint64](5)) | xd
    a = _emit_word(a, movz)
    w1: uint64 = cast[uint64](0xF2800000) | (cast[uint64](1) << cast[uint64](21)) | (h1 << cast[uint64](5)) | xd
    a = _emit_word(a, w1)
    w2: uint64 = cast[uint64](0xF2800000) | (cast[uint64](2) << cast[uint64](21)) | (h2 << cast[uint64](5)) | xd
    a = _emit_word(a, w2)
    w3: uint64 = cast[uint64](0xF2800000) | (cast[uint64](3) << cast[uint64](21)) | (h3 << cast[uint64](5)) | xd
    a = _emit_word(a, w3)
    return a


# Copy a NUL-terminated string into the EL0 message buffer and return its
# byte length (excluding the terminator).
def _copy_user_msg(s: Ptr[char]) -> uint64:
    src: Ptr[uint8] = cast[Ptr[uint8]](s)
    dst: Ptr[uint8] = cast[Ptr[uint8]](USER_MSG_BASE)
    i: int64 = 0
    while src[i] != 0:
        dst[i] = src[i]
        i = i + 1
    return cast[uint64](i)


# Materialise the EL0 routine into USER_CODE_BASE:
#   x0 = 1 (stdout); x1 = msg ptr; x2 = len; x8 = 64 (write); svc #0
#   x0 = 0;          x8 = 93 (exit);                            svc #0
# Returns nothing meaningful; the page is then entered via eret.
def arm64_build_user_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))            # x0 = 1
    a = _emit_load_imm64(a, cast[uint64](1), USER_MSG_BASE)             # x1 = msg
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)                   # x2 = len
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)              # x8 = 64
    a = _emit_word(a, cast[uint64](0xD4000001))                        # svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))           # x0 = 0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)              # x8 = 93
    a = _emit_word(a, cast[uint64](0xD4000001))                        # svc #0

    # Ensure the freshly-written instructions are visible to the I-side: clean
    # the data writes and invalidate I-cache (we use a full barrier + ISB; the
    # demo page is small so a coarse maintenance is sufficient here).
    _dsb_ish()
    _isb()
    return 0


# ---------------------------------------------------------------------------
# EL0 synchronous-exception (svc) dispatcher. Called from the vectors.S
# lower-EL sync stub with `frame_ptr` -> the saved x0..x30 frame (slot n holds
# xn). We confirm the trap is an AArch64 SVC via ESR_EL1.EC, pull the syscall
# number (x8) and args (x0..x5) out of the frame, service it, and write the
# return value back into the x0 slot so the eret resumes EL0 with x0 set.
# ---------------------------------------------------------------------------
def arm64_sync_handler(frame_ptr: Ptr[uint64]) -> int64:
    esr: uint64 = cast[uint64](_mrs_esr_el1())
    ec: uint64 = (esr >> cast[uint64](26)) & cast[uint64](0x3F)

    if ec != ESR_EC_SVC64:
        # Not a syscall. Phase 6: an EL0 memory abort (bad load/store/fetch) is
        # a recoverable *user* fault — the kernel must report it and TERMINATE
        # the offending task, never hang. Catch data/instruction aborts taken
        # from the lower EL (EC 0x24 / 0x20), report the faulting VA (FAR_EL1)
        # and EL0 PC (ELR_EL1), then advance to Phase 5 instead of resuming the
        # dead task into its faulting instruction (which would re-fault forever).
        if ec == ESR_EC_DABORT_LOWER:
            # Phase 14: a data abort might be a DEMAND-PAGING translation fault
            # inside the demand window — page it in and resume EL0 — rather than a
            # genuine permission fault to reap. arm64_try_demand_page returns 1 if
            # it handled (mapped + resume) the fault, 0 to fall through to reaping.
            if arm64_demand_active != 0:
                if arm64_try_demand_page(esr) != 0:
                    return 0
            # Phase 24: a data abort might be a DEMAND-PAGING translation fault on
            # a still-unmapped page inside the Phase-24 window — allocate a fresh
            # page, install its EL0-RW L3 PTE, flush only that VA, and resume EL0
            # at the faulting instruction (retry). arm64_p24_try_fault returns 1 if
            # it handled the fault, 0 to fall through to the fatal-fault reaper.
            if arm64_p24_active != 0:
                if arm64_p24_try_fault(esr) != 0:
                    return 0
            # Phase 25: while the COW-fork demo is live, a data abort is a
            # PERMISSION fault on a store to the read-only COW page. Allocate a
            # fresh page, copy the shared page into it, remap the FAULTING space's
            # L3 PTE RW-PRIVATE, flush that ASID, and resume EL0 at the faulting
            # store (retry). arm64_p25_try_cow returns 1 if it serviced the fault.
            if arm64_p25_active != 0:
                if arm64_p25_try_cow(esr) != 0:
                    return 0
            # Phase 26: while the ELF-loaded program runs, a data abort is a
            # first-touch TRANSLATION fault on one of the loaded segment pages (the
            # loader pre-stamped the segment L3 PTEs, so this is the AF/translation
            # of the freshly-mapped page). arm64_p26_try_fault confirms the VA lies
            # in a loaded segment, accounts it, and resumes (return 1); anything
            # else falls through to the fatal-fault reaper.
            if arm64_p26_active != 0:
                if arm64_p26_try_fault(esr) != 0:
                    return 0
            # Phase 16: while the mmap demo is live, a data abort might be a
            # demand fault inside a LIVE anonymous VMA (page it in + resume) or a
            # post-munmap touch of a now-dead VMA (fall through to the reaper,
            # which the mmap reaper turns into the Phase-16 SEGV PASS).
            if arm64_mmap_active != 0:
                if arm64_mmap_try_fault(esr) != 0:
                    return 0
                return arm64_mmap_reap(esr)
            # Phase 17: while the mprotect demo is live, a data abort inside the
            # anon VMA is either a TRANSLATION fault (demand-map the RW page +
            # resume) or — once mprotect has flipped the page RO — a PERMISSION
            # fault on a store (a genuine SIGSEGV the reaper turns into the PASS).
            if arm64_mprot_active != 0:
                if arm64_mprot_try_fault(esr) != 0:
                    return 0
                return arm64_mprot_reap(esr)
            # Phase 18: while the multi-page mmap demo is live, a data abort inside
            # a LIVE anon VMA slot is a per-page TRANSLATION fault (demand-map that
            # page + resume); a touch of the carved-out HOLE matches no live slot
            # and falls through to the reaper (the PASS-yielding SIGSEGV).
            if arm64_mp_active != 0:
                if arm64_mp_try_fault(esr) != 0:
                    return 0
                return arm64_mp_reap(esr)
            return arm64_handle_el0_fault(esr, cast[uint64](0))
        if ec == ESR_EC_IABORT_LOWER:
            return arm64_handle_el0_fault(esr, cast[uint64](1))
        # Anything else from EL0 is genuinely unexpected — report and halt.
        msg: Ptr[char] = "[arm64] EL0 non-SVC sync exception\n"
        _uart_puts(msg)
        while True:
            _wfi()

    nr: uint64 = frame_ptr[8]          # x8 = syscall number
    a0: uint64 = frame_ptr[0]          # x0
    a1: uint64 = frame_ptr[1]          # x1
    a2: uint64 = frame_ptr[2]          # x2

    # Phase 7: while the isolation demo is live, the running EL0 task reports the
    # value it read at the SHARED virtual address through its own TTBR0 via the
    # kernel-private "iso report" syscall (x8 = 512, x0 = value). This never
    # returns to EL0; the driver records the value and either launches the next
    # task (after switching TTBR0) or finishes the demo and hands off to Phase 5.
    if arm64_iso_active != 0:
        if nr == SYS_ISO_REPORT_NR:
            arm64_iso_on_report(a0)
            # Unreachable: arm64_iso_on_report transitions away (next task or
            # Phase 5) and never returns. Safety halt if it ever falls through.
            while True:
                _wfi()
        # Any other syscall from an isolation task is unexpected.
        isobad: Ptr[char] = "[arm64] iso task issued unexpected syscall\n"
        _uart_puts(isobad)
        while True:
            _wfi()

    # Phase 11: while the EL0 signal-delivery demo is live, route every svc into
    # the Phase-11 dispatcher (raise/sigreturn/handler-ran/write/exit). raise()
    # builds a signal frame on the EL0 stack and redirects EL0 into a user signal
    # handler; sigreturn() restores the interrupted context; exit() prints PASS.
    if arm64_sig_active != 0:
        return arm64_sig_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 14: while the demand-paging demo is live, route every svc into the
    # Phase-14 dispatcher (demand report/write/exit). The page-in itself happens on
    # the ABORT path (arm64_try_demand_page), not here; these are the task's
    # explicit syscalls AFTER its faulting stores have transparently completed.
    if arm64_demand_active != 0:
        return arm64_demand_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 16: while the mmap demo is live, route every svc into the Phase-16
    # dispatcher (mmap/munmap/report/write/exit). mmap records a VMA + returns its
    # base; the page-in itself happens on the ABORT path (arm64_mmap_try_fault).
    # munmap tears the VMA + mapping down. report verifies the demand-paged value.
    if arm64_mmap_active != 0:
        return arm64_mmap_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 17: while the mprotect demo is live, route every svc into the Phase-17
    # dispatcher (mmap/mprotect/report/rdback/write/exit). mmap records a VMA +
    # returns its base; mprotect flips the live L3 descriptor RW->RO. The page-in
    # (translation fault) and the post-mprotect store PERMISSION fault both happen
    # on the ABORT path (arm64_mprot_try_fault / arm64_mprot_reap), not here.
    if arm64_mprot_active != 0:
        return arm64_mprot_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 18: while the multi-page mmap demo is live, route every svc into the
    # Phase-18 dispatcher (mmap/report/munmap/survive/write/exit). mmap records ONE
    # VMA spanning all pages + returns its base; the partial munmap SPLITS that VMA
    # into two live spans (carving out the middle page). The per-page page-ins
    # (translation faults) and the post-split hole-touch fault happen on the ABORT
    # path (arm64_mp_try_fault / arm64_mp_reap), not here.
    if arm64_mp_active != 0:
        return arm64_mp_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 24: while the demand-paging window demo is live, route every svc into
    # the Phase-24 dispatcher (report / write / exit). The page-ins themselves
    # happen on the ABORT path (arm64_p24_try_fault), not here; these are the
    # task's explicit syscalls AFTER its faulting stores transparently completed.
    if arm64_p24_active != 0:
        return arm64_p24_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 25: while the COW-fork demo is live, route every svc into the
    # Phase-25 dispatcher (fork / report / done / exit). fork() builds the child
    # address space and cooperatively runs it; the divergent-write COW page-ins
    # happen on the ABORT path (arm64_p25_try_cow), not here.
    if arm64_p25_active != 0:
        return arm64_p25_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 26: while the ELF-loaded EL0 program runs, route every svc into the
    # Phase-26 dispatcher (write / bss-report / exit). write() emits the program's
    # message to the UART; bss-report records the byte it read from the zeroed BSS
    # tail; exit() runs the loader verdict + halts. The segment page-ins happen on
    # the ABORT path (arm64_p26_try_fault), not here.
    if arm64_p26_active != 0:
        return arm64_p26_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 23: while the TLS demo is live, route every svc into the Phase-23
    # dispatcher (settls / tick-report). SETTLS installs the running thread's
    # TPIDR_EL0 (thread pointer) and records it so the scheduler preserves it
    # across context switches; tick-report tallies the thread-local sentinel the
    # thread read through its OWN TPIDR_EL0 (with no syscall).
    if arm64_p23_active != 0:
        return arm64_p23_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 22: while the futex demo is live, route every svc into the Phase-22
    # dispatcher (tick-report / futex / nanosleep / poke). FUTEX_WAIT DESCHEDULES
    # the running task on a memory-word key; FUTEX_WAKE flips matching BLOCKED-on-
    # futex peers back to RUNNABLE.
    if arm64_p22_active != 0:
        return arm64_p22_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 21: while the blocking-nanosleep demo is live, route every svc into the
    # Phase-21 dispatcher (tick-report / nanosleep). nanosleep DESCHEDULES the
    # running task — it records the task's wake deadline (a CNTVCT_EL0 target),
    # marks the slot BLOCKED, and forces a context switch to a RUNNABLE peer so the
    # blocked task's stack frame stays parked until the timer-IRQ scheduler wakes it.
    if arm64_p21_active != 0:
        return arm64_p21_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 19: while the dual-address-space scheduling demo is live, route every
    # svc into the Phase-19 dispatcher. Each task reads its OWN private sentinel at
    # the SHARED VA (resolved through its private TTBR0+ASID) and reports it; the
    # dispatcher tallies correct/incorrect reads per task. The TTBR0+ASID swap
    # itself happens on the timer-IRQ path (arm64_sched_pick), not here.
    if arm64_p19_active != 0:
        return arm64_p19_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 20: while the dynamic-spawn / exit-reaping demo is live, route every svc
    # into the Phase-20 dispatcher (tick-report / exit). A task's exit() marks its
    # slot REAPED so the scheduler drops it; tick-report tallies its private-sentinel
    # reads. The dynamic spawn of the third task happens on the timer-IRQ path
    # (arm64_p20_sched_pick), not here.
    if arm64_p20_active != 0:
        return arm64_p20_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 13: while the FP context-switch demo is live, route every svc into the
    # Phase-13 dispatcher (fpcheck/yield/exit). yield saves the outgoing task's
    # d8..d15, restores the incoming task's, and erets into it; fpcheck verifies a
    # task's FP signature survived the switch.
    if arm64_fp_active != 0:
        return arm64_fp_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 9: while the page-table-backed brk demo is live, route every svc into
    # the Phase-9 dispatcher (brk/report/write/exit). brk-grow installs a fresh
    # page mapping into the live TTBR0 tables; report verifies the EL0 task read
    # back the sentinel through that new mapping; exit prints the Phase-9 PASS
    # marker and halts.
    if arm64_brk_active != 0:
        return arm64_brk_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 8: while the broader-syscall-surface demo is live, route by x8 into
    # the Phase-8 handler (getpid/gettid/yield/brk/clock/write/exit). It services
    # the call, writes the return value into the x0 frame slot, and returns 0 so
    # the common eret path resumes EL0 — EXCEPT exit, which never returns (it
    # halts the boot after printing the Phase-8 PASS marker).
    if arm64_sys_active != 0:
        return arm64_sys_dispatch(frame_ptr, nr, a0, a1, a2)

    ret: uint64 = cast[uint64](0)

    if nr == SYS_WRITE_NR:
        # write(fd, buf, len): emit the buffer to the kernel UART regardless of
        # fd (the demo only ever uses fd 1). Return the byte count.
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        okmsg: Ptr[char] = "[arm64] EL0 write syscall serviced\n"
        _uart_puts(okmsg)
        ret = a2
    elif nr == SYS_EXIT_NR:
        # exit(code): record the code and signal the launcher to halt.
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        exmsg: Ptr[char] = "[arm64] EL0 exit syscall serviced\n"
        _uart_puts(exmsg)
        ret = cast[uint64](0)
    else:
        unkmsg: Ptr[char] = "[arm64] EL0 unknown syscall\n"
        _uart_puts(unkmsg)
        ret = cast[uint64](0)

    # Stash the return value into the x0 slot so eret resumes EL0 with x0 set.
    frame_ptr[0] = ret

    # If EL0 asked to exit, don't return into it. Emit the Phase-4 single-task
    # PASS marker, then advance to Phase 6: run a deliberately-faulting EL0 task
    # and prove the kernel catches the abort + terminates the task. The Phase-6
    # handler in turn hands off to Phase 5 (preemptive scheduling). Each stage's
    # launcher erets to EL0 and never returns, so this exit-syscall service point
    # is the hand-off from Phase 4 -> 6 -> 5.
    if arm64_el0_exited != 0:
        if arm64_el0_exit_code == 0:
            passmsg: Ptr[char] = "[arm64] EL0 syscall OK\n"
            _uart_puts(passmsg)
        else:
            failmsg: Ptr[char] = "[arm64] EL0 exited nonzero\n"
            _uart_puts(failmsg)
        # Mask IRQs while we transition, then launch Phase 6 (never returns):
        # the faulting task aborts, is reaped, and Phase 6 advances to Phase 5.
        _msr_daifset(2)
        arm64_run_faulting_task()
        # Unreachable; safe halt if the launcher ever falls through.
        while True:
            _wfi()
    return 0


# ---------------------------------------------------------------------------
# Drop to EL0 and run the user routine. Programs SPSR_EL1 (EL0t + DAIF),
# ELR_EL1 (user entry), SP_EL0 (user stack), then `eret`. Control resumes at
# USER_CODE_BASE in EL0; the svc traps re-enter EL1 via arm64_sync_handler,
# which halts the test on exit() (so this function does not return).
# ---------------------------------------------------------------------------
def arm64_enter_el0() -> int64:
    usermsg: Ptr[char] = "Hello from EL0 via svc write\n"
    msg_len: uint64 = _copy_user_msg(usermsg)
    arm64_build_user_routine(msg_len)

    enter: Ptr[char] = "[arm64] dropping to EL0\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # target PSTATE: EL0t, IRQ/FIQ masked
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; never returns here
    return 0


# ---------------------------------------------------------------------------
# Phase 6 — EL0 page-fault path.
#
# A buggy or hostile EL0 task that dereferences an unmapped / EL1-only address
# must NOT wedge the kernel. The CPU takes a Data (or Instruction) Abort to the
# "Lower EL using AArch64" Synchronous vector — the SAME vector as `svc` — so
# arm64_sync_handler sees ESR_EL1.EC == 0x24 (data) or 0x20 (instruction).
# Instead of resuming EL0 into the offending instruction (which would re-fault
# forever) we read FAR_EL1 (the faulting VA) + ELR_EL1 (the EL0 PC), report
# them, mark the fault handled, and TERMINATE the task by transferring to the
# next schedulable workload (Phase 5) rather than ERET-ing back. This is the
# aarch64 analogue of delivering SIGSEGV and reaping the process.
# ---------------------------------------------------------------------------

# Materialise a deliberately-faulting EL0 routine into USER_CODE_BASE:
#   x1 = FAULT_VA (an EL1-only RAM address); ldr x0, [x1]  -> Data Abort.
# The load never completes; control traps to EL1 and never returns to this code.
def arm64_build_faulting_routine() -> int64:
    a: uint64 = USER_CODE_BASE
    a = _emit_load_imm64(a, cast[uint64](1), FAULT_VA)     # x1 = bad VA
    # ldr x0, [x1]  = 0xF9400020 (LDR (immediate, unsigned offset 0), Xt=x0,
    # Xn=x1). This load from an EL0-inaccessible page raises a Data Abort.
    a = _emit_word(a, cast[uint64](0xF9400020))
    # Should never be reached; emit a trap-shaped svc exit as a safety net so a
    # miraculous non-fault still terminates cleanly rather than running off.
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))            # svc #0
    _dsb_ish()
    _isb()
    return 0


# The page-fault handler proper. `is_instr` is 0 for a data abort, 1 for an
# instruction abort. Reports the faulting VA + EL0 PC, latches the handled flag,
# then terminates the task by launching Phase 5 (never returns to EL0). This is
# the deliberate design: a faulting EL0 task is reaped, the kernel survives.
def arm64_handle_el0_fault(esr: uint64, is_instr: uint64) -> int64:
    far: uint64 = cast[uint64](_mrs_far_el1())
    elr: uint64 = cast[uint64](_mrs_elr_el1())

    if is_instr != 0:
        k0: Ptr[char] = "[arm64] EL0 instruction abort\n"
        _uart_puts(k0)
    else:
        k1: Ptr[char] = "[arm64] EL0 data abort\n"
        _uart_puts(k1)

    famsg: Ptr[char] = "[arm64] fault VA (FAR_EL1)="
    _uart_puts(famsg)
    _uart_puthex(far)
    nl0: Ptr[char] = "\n"
    _uart_puts(nl0)

    pcmsg: Ptr[char] = "[arm64] fault PC (ELR_EL1)="
    _uart_puts(pcmsg)
    _uart_puthex(elr)
    nl1: Ptr[char] = "\n"
    _uart_puts(nl1)

    esrmsg: Ptr[char] = "[arm64] fault ESR_EL1="
    _uart_puts(esrmsg)
    _uart_puthex(esr)
    nl2: Ptr[char] = "\n"
    _uart_puts(nl2)

    arm64_fault_handled = 1

    term: Ptr[char] = "[arm64] EL0 task terminated; kernel survived\n"
    _uart_puts(term)

    pass_mark: Ptr[char] = "[arm64] EL0 page-fault OK\n"
    _uart_puts(pass_mark)

    # The faulting task is dead. Rather than ERET back into its faulting
    # instruction, hand off to Phase 7 (per-task TTBR0 address-space isolation),
    # which in turn hands off to Phase 5. Mask IRQs while we transition; neither
    # arm64_run_isolation_demo() nor the Phase-5 launcher it tails into returns.
    _msr_daifset(2)
    arm64_run_isolation_demo()
    # Unreachable safety halt.
    while True:
        _wfi()
    return 0


# Build the deliberately-faulting EL0 task and ERET into it. The abort it raises
# traps to arm64_sync_handler -> arm64_handle_el0_fault, which reports + reaps
# it and never returns here. This is the Phase-6 entry point, invoked from the
# Phase-4 exit hand-off so all three EL0 milestones run in one boot.
def arm64_run_faulting_task() -> int64:
    arm64_build_faulting_routine()

    enter: Ptr[char] = "[arm64] launching faulting EL0 task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC (the bad load)
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; faults immediately, never returns
    return 0


# ---------------------------------------------------------------------------
# Phase 7 — per-task TTBR0_EL1 ADDRESS-SPACE ISOLATION.
#
# Each EL0 task gets its OWN level-1 translation table root (TTBR0_EL1). Both
# tasks map the SAME virtual address (ISO_SHARED_VA) but to DIFFERENT physical
# pages carrying distinct sentinels. The kernel switches TTBR0_EL1 between the
# two tasks and performs the required TLB maintenance (tlbi vmalle1is + dsb +
# isb) on each switch. Each task loads the byte at ISO_SHARED_VA and reports it
# via a kernel-private syscall (nr 512). If isolation holds, task A reports its
# sentinel (0xAA) and task B reports its own (0xBB) — proving that the same VA
# resolves to private physical memory per task, i.e. tasks cannot read each
# other's memory.
#
# Both per-task tables clone the kernel's device + RAM identity map (so the EL0
# code window at USER_CODE_BASE stays fetchable and the kernel stays mapped),
# and additionally map ISO_SHARED_VA's 2 MiB L2 block EL0-RWX to the task's
# private physical block. The tables live in EL1-only RAM, so EL0 cannot tamper
# with them.
# ---------------------------------------------------------------------------

# Build one task-private address space at (l1_base, l2_base): a full clone of
# the kernel identity map plus an EL0-RWX mapping of ISO_SHARED_VA -> data_pa.
# Also writes `sentinel` into the first byte of the data block so the task can
# read it back. data_pa must be 2 MiB-aligned (it backs a block descriptor).
def arm64_iso_build_space(l1_base: uint64, l2_base: uint64, data_pa: uint64, sentinel: uint64) -> int64:
    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    # Zero the L1 table (everything unmapped faults).
    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1

    # L1[0] : VA 0x0..0x3FFF_FFFF -> Device-nGnRE (GIC + UART), EL1-only.
    l1[0] = cast[uint64](0) | DEV_FLAGS

    # L2 covering the RAM 1 GiB block in 2 MiB pieces, identity-mapped. Most
    # blocks are Normal-WB EL1-only; the EL0 code window (USER_L2_INDEX) is
    # EL0-RWX so the task's instruction page + stack remain reachable.
    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0          # EL0 code/stack window
        elif cast[uint64](j) == ISO_SHARED_L2_INDEX:
            # The shared VA block: EL0-RWX, but mapped to the TASK-PRIVATE
            # physical block (NOT identity) — this is the isolation linchpin.
            l2[j] = data_pa | MEM_FLAGS_EL0
        else:
            l2[j] = blk_pa | MEM_FLAGS              # kernel: EL1-only
        j = j + 1

    # L1[1] = table descriptor -> this task's L2 table.
    l1[1] = l2_base | DESC_TABLE

    # Seed the private data block with the task's sentinel (byte 0). The kernel
    # writes it through the identity (physical==virtual) mapping the BOOT TTBR0
    # still has live; data_pa is plain RAM mapped Normal-WB by L1_PGTABLE.
    dp: Ptr[uint8] = cast[Ptr[uint8]](data_pa)
    dp[0] = cast[uint8](sentinel & cast[uint64](0xFF))
    return 0


# Materialise the isolation EL0 routine into USER_CODE_BASE:
#   x1 = ISO_SHARED_VA; ldrb w0, [x1]   (read the per-task sentinel byte)
#   x8 = 512 (iso report); svc #0       (hand x0 back to the kernel)
# The svc never returns to EL0 (the kernel transitions away), so no exit needed.
def arm64_build_iso_routine() -> int64:
    a: uint64 = USER_CODE_BASE
    a = _emit_load_imm64(a, cast[uint64](1), ISO_SHARED_VA)     # x1 = shared VA
    # ldrb w0, [x1] = 0x39400020 (LDRB immediate, unsigned offset 0, Wt=0, Xn=1).
    a = _emit_word(a, cast[uint64](0x39400020))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_ISO_REPORT_NR)  # x8 = 512
    a = _emit_word(a, cast[uint64](0xD4000001))                 # svc #0
    # Safety net: if the report syscall ever returned, exit(0).
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                 # svc #0
    _dsb_ish()
    _isb()
    return 0


# Switch the live address space to (l1_base) and ERET into the isolation EL0
# routine at EL0t with IRQs masked (deterministic, no preemption). Performs the
# mandatory TLB maintenance after writing TTBR0_EL1 so stale translations for
# ISO_SHARED_VA from the previous task cannot leak across the switch.
def arm64_iso_enter(l1_base: uint64) -> int64:
    # Point TTBR0_EL1 at this task's private L1 table, then flush all stage-1
    # EL1&0 translations (inner-shareable) so the new mapping for ISO_SHARED_VA
    # takes effect. dsb before+after ordering the table/sysreg writes vs. the
    # invalidate vs. the subsequent fetch; isb to resynchronise the context.
    _dsb_ish()
    _msr_ttbr0_el1(l1_base)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC (the shared-VA reader)
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0 under this task's TTBR0
    return 0


# Called from the svc dispatcher when an isolation task reports the value it
# read at ISO_SHARED_VA. Latch the value for the live task, then either switch
# to task B (after task A) or, once both have reported, verify isolation held
# and hand off to Phase 5. Never returns to EL0.
def arm64_iso_on_report(value: uint64) -> int64:
    if arm64_iso_cur == 0:
        arm64_iso_reported_a = value
        ra: Ptr[char] = "[arm64] iso task A read VA value="
        _uart_puts(ra)
        _uart_puthex(value)
        nla: Ptr[char] = "\n"
        _uart_puts(nla)

        # Switch to task B's address space (same VA, different physical page).
        arm64_iso_cur = 1
        sw: Ptr[char] = "[arm64] iso switching TTBR0 to task B\n"
        _uart_puts(sw)
        arm64_iso_enter(ISO_B_L1)      # never returns; task B will report next
        while True:
            _wfi()

    arm64_iso_reported_b = value
    rb: Ptr[char] = "[arm64] iso task B read VA value="
    _uart_puts(rb)
    _uart_puthex(value)
    nlb: Ptr[char] = "\n"
    _uart_puts(nlb)

    # Both tasks reported. Isolation holds iff each read its OWN sentinel at the
    # SAME virtual address — proving distinct per-task physical memory.
    ok_a: int64 = 0
    if arm64_iso_reported_a == ISO_SENTINEL_A:
        ok_a = 1
    ok_b: int64 = 0
    if arm64_iso_reported_b == ISO_SENTINEL_B:
        ok_b = 1
    distinct: int64 = 0
    if arm64_iso_reported_a != arm64_iso_reported_b:
        distinct = 1

    if (ok_a != 0) and (ok_b != 0) and (distinct != 0):
        pm: Ptr[char] = "[arm64] EL0 TTBR0 isolation OK\n"
        _uart_puts(pm)
    else:
        fm: Ptr[char] = "[arm64] EL0 TTBR0 isolation FAIL\n"
        _uart_puts(fm)

    # The demo is done. Leave isolation mode, restore the kernel's identity-only
    # TTBR0 (the Phase-5 tasks run in the original L1_PGTABLE address space),
    # flush the TLB, and hand off to Phase 5 so its scheduler stays reachable.
    arm64_iso_active = 0
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    _msr_daifset(2)
    arm64_start_tasks()                # Phase 5; never returns
    while True:
        _wfi()
    return 0


# Phase-7 entry point (invoked from the Phase-6 fault hand-off). Build both
# task-private address spaces, the shared EL0 reader routine, then ERET into
# task A. The chain runs entirely from the svc "report" path:
#   enter A -> A reads its VA -> svc 512 -> switch TTBR0 -> enter B ->
#   B reads its VA -> svc 512 -> verify + PASS -> Phase 5.
def arm64_run_isolation_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 7: per-task TTBR0 isolation\n"
    _uart_puts(intro)

    # Build the two private address spaces and seed their sentinels.
    arm64_iso_build_space(ISO_A_L1, ISO_A_L2, ISO_A_DATA, ISO_SENTINEL_A)
    arm64_iso_build_space(ISO_B_L1, ISO_B_L2, ISO_B_DATA, ISO_SENTINEL_B)

    # Build the EL0 reader routine into the shared code window (identity-mapped
    # the same way in both task tables, so it is fetchable under either TTBR0).
    arm64_build_iso_routine()

    # Clear any Phase-4 exit latch and arm isolation mode so the svc dispatcher
    # routes the report syscall here.
    arm64_el0_exited = 0
    arm64_iso_active = 1
    arm64_iso_cur = 0

    sa: Ptr[char] = "[arm64] iso entering task A (TTBR0=A)\n"
    _uart_puts(sa)
    arm64_iso_enter(ISO_A_L1)          # -> EL0 task A; never returns here
    while True:
        _wfi()
    return 0


# ---------------------------------------------------------------------------
# Phase 5 — timer-driven PREEMPTIVE round-robin scheduling of two EL0 tasks.
#
# Two independent EL0 tasks each run an endless loop: write(1, marker, len) then
# spin in a short busy-loop. Neither ever yields or exits. The EL1 generic-timer
# IRQ fires periodically while a task runs; the "Lower EL using AArch64" IRQ
# vector (arm64_lower_irq_entry in vectors.S) saves the running task's FULL
# context (x0..x30 + SP_EL0 + ELR_EL1 + SPSR_EL1) into its context block, calls
# the Adder scheduler arm64_sched_pick() — which services the timer and swaps
# the current-task pointer to the OTHER task — and restores+erets into that
# task. Each task therefore makes forward progress only because the kernel
# preempts and round-robins it: a real EL0<->EL0 context switch on bare aarch64,
# orchestrated from Adder.
#
# The .S IRQ stub finds the running task's context block via the global
# `arm64_current_ctx`, which the scheduler keeps pointing at the live task.
# ---------------------------------------------------------------------------

# Two task code pages, message buffers and stacks — all inside the single EL0
# RWX 2 MiB window (0x4020_0000 .. 0x403F_FFFF) granted by the L2 map.
TASK0_CODE: uint64 = 0x40200000
TASK1_CODE: uint64 = 0x40210000
TASK0_MSG: uint64 = 0x40220000
TASK1_MSG: uint64 = 0x40221000
TASK0_STACK_TOP: uint64 = 0x40240000
TASK1_STACK_TOP: uint64 = 0x40250000

# Context blocks (34 x 8-byte slots: x0..x30, SP_EL0, ELR_EL1, SPSR_EL1). These
# live in EL1-only RAM (outside the EL0 window) so a buggy/hostile EL0 task can
# neither read nor scribble the saved scheduler state.
TASK0_CTX: uint64 = 0x40104000
TASK1_CTX: uint64 = 0x40105000

CTX_X0: uint64 = 0          # slot index of x0
CTX_SP_EL0: uint64 = 31
CTX_ELR: uint64 = 32
CTX_SPSR: uint64 = 33

# SPSR to ERET into EL0t with IRQs ENABLED (so the timer can preempt the task):
# mode EL0t (bits[3:0]=0), DAIF with only D|A|F masked and I (bit7) CLEAR.
# 0x340 = D|A|F masked, IRQ unmasked, EL0t.
SPSR_EL0T_IRQ: uint64 = 0x340

# Published to the .S IRQ stub: address of the context block of the task that is
# currently running at EL0. The scheduler swaps this on every tick.
arm64_current_ctx: uint64 = 0

# Round-robin bookkeeping: which task index is live, and how many preemptive
# switches we have performed. After SWITCH_LIMIT switches (proving BOTH tasks
# ran and were preempted multiple times) the scheduler prints PASS and halts.
arm64_cur_task: int64 = 0
arm64_switch_count: int64 = 0
SWITCH_LIMIT: int64 = 8


# Materialise a self-looping EL0 task into `code_base`:
#   loop:
#     x0 = 1; x1 = msg; x2 = len; x8 = 64 (write); svc #0
#     x9 = busy; busy:  subs x9,x9,#1; b.ne busy
#     b loop
# The task never exits; only the preemptive timer IRQ moves control away. We
# hand-emit the busy-loop and backward branch directly (the imm-builder already
# exists for the syscall argument setup).
def arm64_build_task(code_base: uint64, msg_base: uint64, msg_len: uint64) -> int64:
    a: uint64 = code_base
    loop_top: uint64 = a

    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))      # x0 = 1 (fd)
    a = _emit_load_imm64(a, cast[uint64](1), msg_base)             # x1 = msg ptr
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)             # x2 = len
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)        # x8 = 64 (write)
    a = _emit_word(a, cast[uint64](0xD4000001))                  # svc #0

    # x9 = 0x40000 busy-loop counter (movz x9, #0x4, lsl #16). hw=1 => lsl #16.
    movz_x9: uint64 = cast[uint64](0xD2800000) | (cast[uint64](1) << cast[uint64](21)) | (cast[uint64](4) << cast[uint64](5)) | cast[uint64](9)
    a = _emit_word(a, movz_x9)
    busy_top: uint64 = a
    # subs x9, x9, #1   = 0xF1000529
    a = _emit_word(a, cast[uint64](0xF1000529))
    # b.ne busy_top : 0x54000001 | (imm19 << 5); imm19 = (busy_top - here) / 4.
    bne_here: uint64 = a
    off_busy: int64 = cast[int64](busy_top) - cast[int64](bne_here)
    imm19_busy: uint64 = cast[uint64](off_busy >> 2) & cast[uint64](0x7FFFF)
    a = _emit_word(a, cast[uint64](0x54000001) | (imm19_busy << cast[uint64](5)))

    # b loop_top : 0x14000000 | imm26; imm26 = (loop_top - here) / 4.
    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# Copy a NUL-terminated string into an arbitrary EL0 buffer; return byte length.
def _copy_msg_to(s: Ptr[char], dst_base: uint64) -> uint64:
    src: Ptr[uint8] = cast[Ptr[uint8]](s)
    dst: Ptr[uint8] = cast[Ptr[uint8]](dst_base)
    i: int64 = 0
    while src[i] != 0:
        dst[i] = src[i]
        i = i + 1
    return cast[uint64](i)


# Initialise a task's context block so the very first ERET starts it cleanly at
# its code entry, on its own stack, in EL0t with IRQs unmasked.
def arm64_init_ctx(ctx_base: uint64, code_base: uint64, stack_top: uint64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](ctx_base)
    i: int64 = 0
    while i < 34:
        ctx[i] = cast[uint64](0)
        i = i + 1
    ctx[CTX_SP_EL0] = stack_top
    ctx[CTX_ELR] = code_base
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ
    return 0


# Scheduler — invoked from the EL0 IRQ vector (arm64_lower_irq_entry) with the
# running task's context block already fully saved. We ack/re-arm the timer,
# pick the OTHER task, publish it as current, and return its context block base
# so the stub restores+erets into it. After SWITCH_LIMIT preemptions the test
# has proven both tasks ran and were repeatedly preempted; print PASS and halt.
def arm64_sched_pick(cur_ctx: uint64) -> uint64:
    # Phase 23: when the TLS scheduler is live, feed preemptions to its picker —
    # each tick it SAVES the outgoing thread's TPIDR_EL0 into its slot, round-
    # robins to the peer slot, swaps TTBR0+ASID, and RESTORES the incoming
    # thread's saved TPIDR_EL0 so each thread keeps its own thread pointer.
    if arm64_p23_active != 0:
        return arm64_p23_sched_pick(cur_ctx)

    # Phase 22: when the futex scheduler is live, feed preemptions to its picker —
    # each tick it auto-wakes any TIMER-blocked slot whose deadline passed (futex-
    # blocked slots are woken only by a peer FUTEX_WAKE, never the timer) and
    # round-robins only the RUNNABLE slots, swapping TTBR0+ASID.
    if arm64_p22_active != 0:
        return arm64_p22_sched_pick(cur_ctx)

    # Phase 21: when the blocking-nanosleep scheduler is live, feed preemptions to
    # its picker — on each tick it WAKES any BLOCKED slot whose CNTVCT_EL0 deadline
    # has passed (back to RUNNABLE) and round-robins only the RUNNABLE slots,
    # swapping TTBR0+ASID into the next runnable slot's private space.
    if arm64_p21_active != 0:
        return arm64_p21_sched_pick(cur_ctx)

    # Phase 19: when the dual-address-space scheduler is live, this same .S IRQ
    # stub feeds preemptions to the Phase-19 picker instead — it swaps TTBR0+ASID
    # (the private address space) in addition to the saved register context.
    if arm64_p19_active != 0:
        return arm64_p19_sched_pick(cur_ctx)

    # Phase 20: when the dynamic-spawn / exit-reaping scheduler is live, feed
    # preemptions to its picker — it skips REAPED (exited) tasks, swaps TTBR0+ASID
    # into the next RUNNABLE task's private space, and dynamically spawns a fresh
    # third task partway through.
    if arm64_p20_active != 0:
        return arm64_p20_sched_pick(cur_ctx)

    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this task
        return cur_ctx

    # Quiesce, re-arm, and EOI the timer.
    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_switch_count = arm64_switch_count + 1
    swmsg: Ptr[char] = "[arm64] preempt switch\n"
    _uart_puts(swmsg)

    if arm64_switch_count >= SWITCH_LIMIT:
        passmsg: Ptr[char] = "[arm64] EL0 preempt sched OK\n"
        _uart_puts(passmsg)
        # Mask IRQs (so the broader-syscall demo runs deterministically without
        # timer re-entry) and hand off to Phase 8: a single EL0 task exercising a
        # wider svc surface (getpid/gettid/yield/brk/clock/write/exit) dispatched
        # by x8. arm64_run_syscall_demo() does not return (its task's exit() halts
        # the boot), so Phase 5's PASS marker is the hand-off point to Phase 8.
        _msr_daifset(2)
        arm64_run_syscall_demo()
        # Unreachable safety halt.
        while True:
            _wfi()

    # Round-robin to the other task.
    next_ctx: uint64 = TASK1_CTX
    if arm64_cur_task == 0:
        arm64_cur_task = 1
        next_ctx = TASK1_CTX
    else:
        arm64_cur_task = 0
        next_ctx = TASK0_CTX

    arm64_current_ctx = next_ctx            # publish for the next preemption
    return next_ctx


# Build both tasks + context blocks, then ERET into task 0 with the timer live.
def arm64_start_tasks() -> int64:
    # Mask EL1 IRQs while we build the tasks so a stray current-EL timer IRQ
    # (left armed/unmasked by arm64_timer_init) cannot run the legacy handler
    # mid-setup. We re-enable just before ERETing into EL0.
    _msr_daifset(2)

    # Clear the Phase-4 single-task exit latch: the two Phase-5 tasks only ever
    # issue write() (nr 64) and must NOT re-enter the exit/hand-off path the svc
    # dispatcher keys off arm64_el0_exited.
    arm64_el0_exited = 0
    arm64_el0_exit_code = -1

    m0: Ptr[char] = "[task0] running on EL0\n"
    m1: Ptr[char] = "[task1] running on EL0\n"
    len0: uint64 = _copy_msg_to(m0, TASK0_MSG)
    len1: uint64 = _copy_msg_to(m1, TASK1_MSG)

    arm64_build_task(TASK0_CODE, TASK0_MSG, len0)
    arm64_build_task(TASK1_CODE, TASK1_MSG, len1)

    arm64_init_ctx(TASK0_CTX, TASK0_CODE, TASK0_STACK_TOP)
    arm64_init_ctx(TASK1_CTX, TASK1_CODE, TASK1_STACK_TOP)

    arm64_cur_task = 0
    arm64_current_ctx = TASK0_CTX

    enter: Ptr[char] = "[arm64] launching preemptive EL0 tasks\n"
    _uart_puts(enter)

    # Re-arm and enable the timer, unmask IRQs, then ERET into task 0 at EL0t
    # WITH IRQs unmasked (via its context SPSR) so the timer preempts it.
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](TASK0_CTX)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> task 0 at EL0; never returns here
    return 0


# ---------------------------------------------------------------------------
# Phase 8 — broader EL0 syscall surface dispatched by x8.
#
# A single EL0 task issues a sequence of syscalls mirroring the Linux aarch64
# ABI (number in x8, args x0..x5, return in x0):
#   getpid()                  -> the kernel-assigned PID (42)
#   gettid()                  -> the TID (== PID for our single thread)
#   sched_yield()             -> 0 (kernel acknowledges; resumes the same task)
#   clock read (CNTVCT) x2    -> the virtual counter; the kernel latches the
#                                first value and confirms the second ADVANCED
#                                (live, monotonic time visible to EL0)
#   brk(0)                    -> the current program break (queries it)
#   brk(BASE + 4 KiB)         -> moves the break and returns the new value (sbrk)
#   write(1, msg, len)        -> echoes a buffer to the UART, returns the length
#   exit(0)                   -> records the code and halts the boot
# The kernel services each call in arm64_sys_dispatch(), prints a per-call marker
# so the test can prove every syscall ran with a correct result, and on exit(0)
# prints the Phase-8 PASS marker.
# ---------------------------------------------------------------------------

# Phase 8 EL0 message buffer (inside the EL0 RWX window, clear of the code page
# at USER_CODE_BASE and the heap window at SYS_HEAP_BASE).
SYS_MSG_BASE: uint64 = 0x40222000


# Materialise the Phase-8 EL0 routine into USER_CODE_BASE. It issues the syscall
# sequence above. Every syscall but write needs no register args beyond x8 (or a
# single x0 for brk), so we reuse the imm-builder for x8/x0 and emit `svc #0`.
def arm64_build_syscall_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE

    # getpid(): x8 = 172; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_GETPID_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # gettid(): x8 = 178; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_GETTID_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # sched_yield(): x8 = 124; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_YIELD_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # clock read #1: x8 = 513; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_CLOCK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # clock read #2: x8 = 513; svc #0  (kernel confirms it advanced)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_CLOCK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # brk(0): x0 = 0; x8 = 214; svc #0  (query current break)
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_BRK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # brk(SYS_HEAP_GROW): x0 = new break; x8 = 214; svc #0  (grow the heap)
    a = _emit_load_imm64(a, cast[uint64](0), SYS_HEAP_GROW)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_BRK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 64; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), SYS_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # exit(0): x0 = 0; x8 = 93; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-8 syscall dispatcher. Called from arm64_sync_handler while the broader-
# surface demo is live, with `frame_ptr` -> the saved x0..x30 frame, `nr` the
# syscall number (x8) and a0..a2 the first three args. Services the call, writes
# the return value into the x0 frame slot, and returns 0 so the common eret path
# resumes EL0 — except exit(), which halts the boot after the PASS marker.
def arm64_sys_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    arm64_sys_calls = arm64_sys_calls + 1
    ret: uint64 = cast[uint64](0)

    if nr == SYS_GETPID_NR:
        ret = arm64_sys_pid
        m: Ptr[char] = "[arm64] EL0 getpid -> "
        _uart_puts(m)
        _uart_puthex(ret)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        frame_ptr[0] = ret
        return 0

    if nr == SYS_GETTID_NR:
        # Single-threaded task: TID == PID.
        ret = arm64_sys_pid
        m: Ptr[char] = "[arm64] EL0 gettid -> "
        _uart_puts(m)
        _uart_puthex(ret)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        frame_ptr[0] = ret
        return 0

    if nr == SYS_YIELD_NR:
        # Voluntary yield: the kernel acknowledges and resumes the same task
        # (there is only one Phase-8 task). Return 0 like Linux sched_yield.
        m: Ptr[char] = "[arm64] EL0 sched_yield serviced\n"
        _uart_puts(m)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_CLOCK_NR:
        # Read the always-incrementing virtual counter. Latch the first value;
        # on a later read, confirm it strictly advanced (live monotonic clock).
        now: uint64 = cast[uint64](_mrs_cntvct_el0())
        if arm64_sys_clock_seen == 0:
            arm64_sys_clock_first = now
            arm64_sys_clock_seen = 1
            m0: Ptr[char] = "[arm64] EL0 clock read #1 -> "
            _uart_puts(m0)
            _uart_puthex(now)
            nl0: Ptr[char] = "\n"
            _uart_puts(nl0)
        else:
            m1: Ptr[char] = "[arm64] EL0 clock read #2 -> "
            _uart_puts(m1)
            _uart_puthex(now)
            nl1: Ptr[char] = "\n"
            _uart_puts(nl1)
            if now > arm64_sys_clock_first:
                adv: Ptr[char] = "[arm64] EL0 clock advanced OK\n"
                _uart_puts(adv)
            else:
                bad: Ptr[char] = "[arm64] EL0 clock did NOT advance FAIL\n"
                _uart_puts(bad)
        frame_ptr[0] = now
        return 0

    if nr == SYS_BRK_NR:
        # brk(new): if a0 == 0, query the current break. Otherwise move it,
        # clamped to [SYS_HEAP_BASE, SYS_HEAP_END]; return the resulting break.
        if a0 == cast[uint64](0):
            m: Ptr[char] = "[arm64] EL0 brk query -> "
            _uart_puts(m)
            _uart_puthex(arm64_sys_brk)
            nl: Ptr[char] = "\n"
            _uart_puts(nl)
            frame_ptr[0] = arm64_sys_brk
            return 0
        if (a0 >= SYS_HEAP_BASE) and (a0 <= SYS_HEAP_END):
            arm64_sys_brk = a0
        # Out-of-range requests leave the break unchanged (Linux brk returns the
        # current break on failure rather than erroring).
        m2: Ptr[char] = "[arm64] EL0 brk set -> "
        _uart_puts(m2)
        _uart_puthex(arm64_sys_brk)
        nl2: Ptr[char] = "\n"
        _uart_puts(nl2)
        frame_ptr[0] = arm64_sys_brk
        return 0

    if nr == SYS_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        m: Ptr[char] = "[arm64] EL0 write syscall serviced\n"
        _uart_puts(m)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_EXIT_NR:
        # Record the exit code; if the whole sequence ran cleanly, print PASS.
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit syscall serviced\n"
        _uart_puts(em)
        if a0 == cast[uint64](0):
            pm: Ptr[char] = "[arm64] EL0 syscall surface OK\n"
            _uart_puts(pm)
            # Phase 8 complete and clean: leave Phase-8 mode and hand off to
            # Phase 9 (page-table-backed brk growth). The launcher erets into the
            # Phase-9 EL0 task and never returns (its exit() halts the boot), so
            # this is the Phase 8 -> 9 hand-off point.
            arm64_sys_active = 0
            _msr_daifset(2)
            arm64_run_brk_demo()
            # Unreachable safety halt if the Phase-9 launcher ever falls through.
            while True:
                _wfi()
        else:
            fm: Ptr[char] = "[arm64] EL0 syscall surface exited nonzero\n"
            _uart_puts(fm)
        # Nonzero exit: leave Phase-8 mode and halt deterministically.
        arm64_sys_active = 0
        _msr_daifset(2)
        while True:
            _wfi()

    # Unknown syscall under the Phase-8 surface.
    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 8)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-8 entry point (invoked from the Phase-5 sched PASS hand-off). Seed the
# PID + program break, build the EL0 routine and its message, arm Phase-8 mode,
# and ERET into the single multi-syscall EL0 task at EL0t with IRQs masked
# (deterministic; the demo never needs preemption). Never returns here.
def arm64_run_syscall_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 8: broader EL0 syscall surface\n"
    _uart_puts(intro)

    # Seed kernel-tracked per-task state for the demo.
    arm64_sys_pid = SYS_DEMO_PID
    arm64_sys_brk = SYS_HEAP_BASE
    arm64_sys_clock_first = cast[uint64](0)
    arm64_sys_clock_seen = 0
    arm64_sys_calls = 0

    # Restore the kernel's identity-only TTBR0 (Phase 7 may have left a per-task
    # root live) so the EL0 code/heap windows resolve through L1_PGTABLE, then
    # flush the TLB so no stale isolation translation lingers.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Build the EL0 routine + its write() message.
    sysmsg: Ptr[char] = "Hello from the EL0 syscall surface\n"
    msg_len: uint64 = _copy_msg_to(sysmsg, SYS_MSG_BASE)
    arm64_build_syscall_routine(msg_len)

    # Clear the Phase-4/5 exit latch and arm Phase-8 dispatch.
    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_sys_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 syscall-surface task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; svc traps re-enter EL1; no return
    return 0


# ---------------------------------------------------------------------------
# Phase 9 — PAGE-TABLE-BACKED brk growth over TTBR0_EL1.
#
# The EL0 task's heap lives at P9_HEAP_BASE, whose L2 slot (index 6) is UNMAPPED
# at boot. brk(0) queries the break; brk(P9_HEAP_GROW) asks the kernel to grow it
# by one page. On grow the kernel ACTUALLY MAPS a fresh physical page into the
# live TTBR0 tables (arm64_brk_map_page) before returning, so the subsequent EL0
# store to the grown VA succeeds. The task writes P9_SENTINEL through the new
# mapping, reads it back, and reports the value via a kernel-private syscall; the
# kernel verifies both the reported value AND the backing physical page hold the
# sentinel, then prints the Phase-9 PASS marker on exit(0).
# ---------------------------------------------------------------------------

# Map one fresh 4 KiB physical page (P9_PAGE) at the heap virtual base into the
# live TTBR0_EL1 tables, EL0 read/write. Installs an L3 page descriptor into a
# new L3 table (P9_L3) and the L2->L3 table descriptor into the existing RAM L2
# table (L2_PGTABLE) at the heap's L2 slot, with break-before-make + TLB
# maintenance so the new translation is visible to EL0. Returns the mapped VA.
def arm64_brk_map_page() -> uint64:
    # Zero the brand-new L3 table so every unmapped slot faults.
    l3: Ptr[uint64] = cast[Ptr[uint64]](P9_L3)
    i: int64 = 0
    while i < 512:
        l3[i] = cast[uint64](0)
        i = i + 1

    # Zero the backing physical page (a fresh page must start clean).
    pg: Ptr[uint64] = cast[Ptr[uint64]](P9_PAGE)
    j: int64 = 0
    while j < 512:
        pg[j] = cast[uint64](0)
        j = j + 1

    # L3 index of P9_HEAP_BASE = VA[20:12]. For 0x40C0_0000 this is 0.
    l3_index: uint64 = (P9_HEAP_BASE >> cast[uint64](12)) & cast[uint64](0x1FF)
    # Install the EL0-RW page descriptor (bits[1:0]=0b11 => level-3 page).
    l3[cast[int64](l3_index)] = P9_PAGE | P9_PAGE_FLAGS

    # Make the L3 writes visible before the table descriptor that exposes them.
    _dsb_ish()

    # Point the heap's L2 slot at the new L3 table (table descriptor 0b11).
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P9_HEAP_L2_INDEX)] = P9_L3 | DESC_TABLE

    # Publish the table edits and flush stale (faulting) translations for the VA.
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    arm64_brk_mapped = 1
    return P9_HEAP_BASE


# Materialise the Phase-9 EL0 routine into USER_CODE_BASE:
#   brk(0)            -> query the initial (unmapped) break
#   brk(P9_HEAP_GROW) -> ask the kernel to grow + map a fresh page
#   str sentinel -> [P9_HEAP_BASE]   (succeeds only because the page is now mapped)
#   ldr x9 <- [P9_HEAP_BASE]         (read it back)
#   brk_report(x9)    -> hand the read-back value to the kernel to verify
#   write(1, msg, len)
#   exit(0)
# We hand-emit the str/ldr (x10 = VA, x9 = value) around the reused imm-builder.
def arm64_build_brk_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE

    # brk(0): x0 = 0; x8 = 214; svc #0  (query current break)
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_BRK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # brk(P9_HEAP_GROW): x0 = new break; x8 = 214; svc #0  (grow + map a page)
    a = _emit_load_imm64(a, cast[uint64](0), P9_HEAP_GROW)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_BRK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x10 = P9_HEAP_BASE (the freshly-mapped VA); x9 = P9_SENTINEL.
    a = _emit_load_imm64(a, cast[uint64](10), P9_HEAP_BASE)
    a = _emit_load_imm64(a, cast[uint64](9), P9_SENTINEL)
    # str x9, [x10]   (STR Xt, [Xn]) = 0xF9000000 | (Rn<<5) | Rt
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # Re-zero x9 so the read-back can't trivially pass on a stale register, then
    # ldr x9, [x10]   (LDR Xt, [Xn]) = 0xF9400000 | (Rn<<5) | Rt
    a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # brk_report(x9): x0 = x9; x8 = 514; svc #0. Move x9 -> x0 (ORR x0, xzr, x9):
    # 0xAA0003E0 | (Rm<<16) => 0xAA0903E0 for Rm=9.
    a = _emit_word(a, cast[uint64](0xAA0003E0) | (cast[uint64](9) << cast[uint64](16)))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_BRK_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 64; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), P9_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # exit(0): x0 = 0; x8 = 93; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-9 syscall dispatcher. Routed from arm64_sync_handler while the brk demo
# is live. Services brk (query + page-table-backed grow), the kernel-private brk
# report, write and exit. Writes returns into the x0 frame slot; exit halts.
def arm64_brk_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_BRK_NR:
        if a0 == cast[uint64](0):
            m: Ptr[char] = "[arm64] EL0 brk(9) query -> "
            _uart_puts(m)
            _uart_puthex(arm64_brk_cur)
            nl: Ptr[char] = "\n"
            _uart_puts(nl)
            frame_ptr[0] = arm64_brk_cur
            return 0
        # Grow request: only accept the one-page grow to P9_HEAP_GROW, and map a
        # fresh physical page into the live tables BEFORE returning the new break.
        if a0 == P9_HEAP_GROW:
            arm64_brk_map_page()
            arm64_brk_cur = a0
            gm: Ptr[char] = "[arm64] EL0 brk(9) grow mapped page at "
            _uart_puts(gm)
            _uart_puthex(P9_HEAP_BASE)
            nlg: Ptr[char] = "\n"
            _uart_puts(nlg)
        frame_ptr[0] = arm64_brk_cur
        return 0

    if nr == SYS_BRK_REPORT_NR:
        # The EL0 task read back its sentinel through the freshly-mapped page.
        arm64_brk_reported = a0
        rm: Ptr[char] = "[arm64] EL0 brk page read-back -> "
        _uart_puts(rm)
        _uart_puthex(a0)
        nlr: Ptr[char] = "\n"
        _uart_puts(nlr)
        # Independently confirm the BACKING PHYSICAL page holds the sentinel, so
        # the new translation truly reached P9_PAGE (not some stale aliasing).
        backing: Ptr[uint64] = cast[Ptr[uint64]](P9_PAGE)
        phys_val: uint64 = backing[0]
        pm: Ptr[char] = "[arm64] brk backing phys page holds -> "
        _uart_puts(pm)
        _uart_puthex(phys_val)
        nlp: Ptr[char] = "\n"
        _uart_puts(nlp)
        if (a0 == P9_SENTINEL) and (phys_val == P9_SENTINEL) and (arm64_brk_mapped != 0):
            ok: Ptr[char] = "[arm64] EL0 brk-mapped page store/load OK\n"
            _uart_puts(ok)
        else:
            bad: Ptr[char] = "[arm64] EL0 brk-mapped page store/load FAIL\n"
            _uart_puts(bad)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(9) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_EXIT_NR:
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit(9) syscall serviced\n"
        _uart_puts(em)
        # The whole Phase-9 sequence completes cleanly iff exit(0) AND the page
        # was mapped AND the read-back matched the sentinel.
        ok: int64 = 0
        if a0 == cast[uint64](0):
            if arm64_brk_mapped != 0:
                if arm64_brk_reported == P9_SENTINEL:
                    ok = 1
        if ok != 0:
            pm: Ptr[char] = "[arm64] EL0 page-table brk OK\n"
            _uart_puts(pm)
        else:
            fm: Ptr[char] = "[arm64] EL0 page-table brk FAIL\n"
            _uart_puts(fm)
        arm64_brk_active = 0
        # Phase 9 done; hand off to Phase 10 SMP secondary-core bring-up. The
        # IRQs stay masked (deterministic, no timer re-entry); arm64_run_smp()
        # halts after printing the SMP PASS marker and never returns.
        _msr_daifset(2)
        arm64_run_smp()
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 9)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-9 entry point (invoked from the Phase-8 clean-exit hand-off). Seed the
# program break to the UNMAPPED heap base, restore the kernel's identity TTBR0,
# build the EL0 routine + message, arm Phase-9 dispatch and ERET into the brk
# task at EL0t with IRQs masked. Never returns (the task's exit() halts).
def arm64_run_brk_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 9: page-table-backed brk growth\n"
    _uart_puts(intro)

    # Seed Phase-9 state. The break starts at the UNMAPPED heap base.
    arm64_brk_cur = P9_HEAP_BASE
    arm64_brk_mapped = 0
    arm64_brk_reported = cast[uint64](0)

    # Restore the kernel's identity-only TTBR0 so the EL0 code/stack windows and
    # the page-table edits resolve through L1_PGTABLE / L2_PGTABLE, then flush.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Ensure the heap's L2 slot is UNMAPPED at the start (so a store there would
    # fault until brk-grow installs the page) — a clean, repeatable initial state.
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P9_HEAP_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Build the EL0 routine + its write() message.
    brkmsg: Ptr[char] = "Hello from the brk-mapped EL0 page\n"
    msg_len: uint64 = _copy_msg_to(brkmsg, P9_MSG_BASE)
    arm64_build_brk_routine(msg_len)

    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_brk_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 page-table brk task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; svc traps re-enter EL1; no return
    return 0


# ---------------------------------------------------------------------------
# Phase 10 — SMP secondary-core bring-up via PSCI.
# ---------------------------------------------------------------------------

# The Adder body the secondary core runs once the trampoline has given it a
# stack. It executes MMU-OFF at EL1 on CPU1: with the identity map, the kernel's
# code/globals/MMIO all resolve at their physical == virtual addresses, so plain
# Adder (GIC pokes, shared-cell stores) works directly. The secondary enables
# its OWN GIC CPU interface (the GICC registers are banked per core but share
# one MMIO address), records that it entered, publishes a sentinel to the shared
# cell with a dmb ish so the primary observes it, then increments the online
# counter. It deliberately does NOT touch the UART (no cross-core interleave);
# the primary prints all markers. After signalling liveness it parks forever.
def arm64_secondary_mmu_on() -> int64:
    # Phase 12: enable the secondary core's MMU using the page tables the primary
    # already built (L1_PGTABLE / L2_PGTABLE). We do NOT rewrite the tables — only
    # program this core's translation sysregs and flip on SCTLR_EL1.{M,C,I}. After
    # this the secondary sees RAM as Cacheable Inner-Shareable Normal memory,
    # matching the primary, so cross-core ldaxr/stlxr exclusives are coherent.
    _msr_mair_el1(cast[uint64](0xff04))
    _msr_tcr_el1(cast[uint64](0x100003519))
    _msr_ttbr0_el1(L1_PGTABLE)
    _msr_ttbr1_el1(cast[uint64](0))
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    sctlr: uint64 = cast[uint64](_mrs_sctlr_el1())
    sctlr = sctlr | cast[uint64](0x1)      # M (MMU)
    sctlr = sctlr | cast[uint64](0x4)      # C (data cache)
    sctlr = sctlr | cast[uint64](0x1000)   # I (instruction cache)
    _msr_sctlr_el1(sctlr)
    _isb()
    return 0


def arm64_secondary_main() -> int64:
    # Record entry into the Adder body (the primary reports this for us).
    entered: Ptr[uint64] = cast[Ptr[uint64]](SMP_ENTERED)
    entered[0] = cast[uint64](1)
    _dmb_ish()

    # Enable this core's GIC CPU interface so it could take IRQs (SGIs/PPIs).
    # GICC is banked per-core: writing these MMIO offsets configures CPU1's own
    # interface, independent of the primary's.
    gicc_pmr: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_PMR)
    gicc_pmr[0] = 0xF0                             # allow all priorities
    gicc_ctlr: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_CTLR)
    gicc_ctlr[0] = 1                               # enable signalling

    # Publish the cross-core sentinel FIRST, then a dmb ish to order it before
    # the online-counter store the primary waits on (so once the primary sees
    # the counter reach 2, the sentinel is guaranteed already visible).
    sentinel: Ptr[uint64] = cast[Ptr[uint64]](SMP_SENTINEL)
    sentinel[0] = SMP_SENTINEL_VALUE
    _dmb_ish()

    # Increment the online-CPU counter so the primary observes a real second
    # core reporting live. The secondary is the SOLE writer after the primary
    # seeds the cell to 1 (the primary only reads it), so an ordered read-add-
    # write under dmb ish is a correct increment here: read the seeded value,
    # add one, publish it. The dmb ish barriers (here and the sentinel store
    # above) give the primary a guaranteed coherent view once it sees the count.
    online: Ptr[uint64] = cast[Ptr[uint64]](SMP_ONLINE)
    _dmb_ish()
    cur: uint64 = online[0]
    online[0] = cur + cast[uint64](1)
    _dmb_ish()

    # Liveness signalled. Wake any core spinning in wfe.
    _sev()

    # Phase 12: enable THIS core's MMU using the primary's already-built page
    # tables BEFORE doing any ldaxr/stlxr work. The exclusive monitor used by the
    # spinlock requires the lock word to be Cacheable Inner-Shareable Normal
    # memory on every observer; with the MMU off the secondary would treat it as
    # non-cacheable and the global monitor would not be reliable across cores.
    # Turning the secondary's MMU on (same tables as the primary) makes both cores
    # see identical, inner-shareable cacheable attributes, so ldaxr/stlxr work.
    arm64_secondary_mmu_on()

    # Now the secondary runs REAL scheduler work.
    # Wait until the primary publishes the "go" flag (so both cores start the
    # contended loop together), then run SMP_ITERS locked increments against the
    # shared counter — concurrently with CPU0 doing the same. Re-read the go cell
    # through a dmb ish each spin so we observe the primary's publish.
    go: Ptr[uint64] = cast[Ptr[uint64]](SMP_GO)
    while True:
        _dmb_ish()
        if go[0] != cast[uint64](0):
            break
        _wfe()

    # Stamp our own MPIDR Aff0 (1 on CPU1) under the lock, proving this core ran
    # inside the critical section, then run the contended increments.
    arm64_smp_worker(cast[uint64](1))

    # Signal completion, wake the primary, then park forever.
    done: Ptr[uint64] = cast[Ptr[uint64]](SMP_CPU1_DONE)
    _dmb_ish()
    done[0] = cast[uint64](1)
    _dmb_ish()
    _sev()
    while True:
        _wfe()
    return 0


# Phase 12: the contended scheduler-work body run by BOTH cores. `core_id` is the
# running core's MPIDR Aff0 (0 on the primary, 1 on the secondary). Each call
# performs SMP_ITERS iterations of: acquire the shared spinlock (ldaxr/stlxr,
# acquire), read-modify-write the SHARED counter, stamp the touch cell with this
# core's id, release the lock (stlr, release). The acquire/release pair makes the
# read-add-write atomic across cores, so no increment is lost; the final counter
# (2*SMP_ITERS once both cores finish) is only correct if the lock truly held.
def arm64_smp_worker(core_id: uint64) -> int64:
    counter: Ptr[uint64] = cast[Ptr[uint64]](SMP_SHARED_COUNT)
    touched: Ptr[uint64] = cast[Ptr[uint64]](SMP_CPU1_TOUCHED)
    i: uint64 = 0
    while i < SMP_ITERS:
        _spin_lock(SMP_LOCK)
        # ---- critical section: only one core here at a time ----
        cur: uint64 = counter[0]
        counter[0] = cur + cast[uint64](1)
        # Stamp the touch cell so the primary can prove the secondary entered the
        # critical section at least once (CPU1's id is 1; CPU0 leaves it alone so
        # any nonzero value can only have come from the secondary).
        if core_id != cast[uint64](0):
            touched[0] = core_id
        _spin_unlock(SMP_LOCK)
        i = i + cast[uint64](1)
    return 0


# Hand-emit the secondary entry trampoline into SMP_TRAMPOLINE. The secondary is
# released by PSCI CPU_ON with MMU off, SP undefined, at EL1; this blob sets SP
# to the dedicated secondary stack top and branches to arm64_secondary_main().
# We bake the function's address in as an immediate: with the identity map a
# kernel function's virtual address equals its physical address, so the baked
# value is a valid MMU-off branch target. (We pass arm64_secondary_main (as a value) in so
# the primary supplies the runtime address.)
def arm64_build_smp_trampoline(secondary_entry: uint64) -> int64:
    a: uint64 = SMP_TRAMPOLINE

    # x9 = SMP_CPU1_STACK_TOP ; mov sp, x9   (ADD sp, x9, #0 = 0x91000000 | (Rn<<5) | 31)
    a = _emit_load_imm64(a, cast[uint64](9), SMP_CPU1_STACK_TOP)
    a = _emit_word(a, cast[uint64](0x91000000) | (cast[uint64](9) << cast[uint64](5)) | cast[uint64](31))

    # x9 = arm64_secondary_main (as a value) ; br x9   (BR Xn = 0xD61F0000 | (Rn<<5))
    a = _emit_load_imm64(a, cast[uint64](9), secondary_entry)
    a = _emit_word(a, cast[uint64](0xD61F0000) | (cast[uint64](9) << cast[uint64](5)))

    # Make the freshly-written instruction words visible to all cores' I-side.
    _dsb_ish()
    _isb()
    return 0


# Phase-10 entry point (invoked from the Phase-9 clean-exit hand-off). Build the
# secondary trampoline, seed the shared cells, issue PSCI CPU_ON to release CPU1,
# then spin (with barriers) until the secondary reports online and its sentinel
# appears — proving real cross-core progress. Prints explicit markers and halts.
def arm64_run_smp() -> int64:
    intro: Ptr[char] = "[arm64] Phase 10: SMP secondary-core bring-up via PSCI\n"
    _uart_puts(intro)

    # Seed the shared cells: this (primary) core counts as 1 online; clear the
    # sentinel + entered flag so their later appearance unambiguously comes from
    # the secondary.
    online: Ptr[uint64] = cast[Ptr[uint64]](SMP_ONLINE)
    sentinel: Ptr[uint64] = cast[Ptr[uint64]](SMP_SENTINEL)
    entered: Ptr[uint64] = cast[Ptr[uint64]](SMP_ENTERED)
    online[0] = cast[uint64](1)
    sentinel[0] = cast[uint64](0)
    entered[0] = cast[uint64](0)
    _dsb_ish()

    # Build the trampoline the secondary will enter at (PSCI entry = its phys
    # address). Pass the Adder body's address as the baked branch target.
    arm64_build_smp_trampoline(cast[uint64](arm64_secondary_main))

    # Release CPU1 via PSCI CPU_ON. ctx (x3) is passed to the secondary in x0;
    # the trampoline ignores it, so 0 is fine.
    status: uint64 = _psci_cpu_on(PSCI_FN_CPU_ON, SMP_CPU1_MPIDR, SMP_TRAMPOLINE, cast[uint64](0))
    if status != PSCI_SUCCESS:
        fm: Ptr[char] = "[arm64] PSCI CPU_ON FAILED status="
        _uart_puts(fm)
        _uart_puthex(status)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        bad: Ptr[char] = "[arm64] SMP bring-up FAIL\n"
        _uart_puts(bad)
        while True:
            _wfi()

    okmsg: Ptr[char] = "[arm64] PSCI CPU_ON issued\n"
    _uart_puts(okmsg)

    # Spin waiting for the secondary to report online. Re-read the shared cells
    # through a dmb ish each iteration so we observe CPU1's publishes. Bound the
    # wait with a large spin budget so a wedged secondary fails loudly instead of
    # hanging the whole test.
    spins: int64 = 0
    seen_online: int64 = 0
    while spins < 200000000:
        _dmb_ish()
        cur: uint64 = online[0]
        if cur >= cast[uint64](2):
            seen_online = 1
            break
        spins = spins + 1

    if seen_online == 0:
        to: Ptr[char] = "[arm64] secondary did not come online (timeout)\n"
        _uart_puts(to)
        bad2: Ptr[char] = "[arm64] SMP bring-up FAIL\n"
        _uart_puts(bad2)
        while True:
            _wfi()

    # The counter reached 2 -> CPU1 is live. Read the entered flag + cross-core
    # sentinel it published (both ordered before the counter store by the
    # secondary's dmb ish barriers). The primary prints these on the secondary's
    # behalf so no UART output ever interleaves across the two cores.
    _dmb_ish()
    obs: uint64 = sentinel[0]
    ent: uint64 = entered[0]

    if ent != cast[uint64](0):
        em: Ptr[char] = "[arm64] secondary core entered\n"
        _uart_puts(em)

    c1msg: Ptr[char] = "[arm64] CPU1 online\n"
    _uart_puts(c1msg)
    smsg: Ptr[char] = "[arm64] CPU1 sentinel -> "
    _uart_puts(smsg)
    _uart_puthex(obs)
    nl2: Ptr[char] = "\n"
    _uart_puts(nl2)

    if obs == SMP_SENTINEL_VALUE:
        pm: Ptr[char] = "[arm64] SMP bring-up OK\n"
        _uart_puts(pm)
    else:
        bad3: Ptr[char] = "[arm64] SMP bring-up FAIL\n"
        _uart_puts(bad3)

    # Phase 10 complete: CPU1 is live. Hand off to Phase 12 (secondary-core
    # scheduling under a real spinlock). The secondary is NOT parked yet — it is
    # spinning on the Phase-12 "go" flag — so the primary drives the contended
    # demo, then hands off to Phase 11. arm64_run_smp_sched() never returns.
    arm64_run_smp_sched()
    while True:
        _wfi()
    return 0


# ---------------------------------------------------------------------------
# Phase 12 — SECONDARY-CORE SCHEDULING under a cache-coherent spinlock.
#
# Phase 10 proved CPU1 is alive but then parked it. Phase 12 puts it to WORK: the
# primary releases both cores into a contended loop where each performs SMP_ITERS
# increments of a SHARED counter, every increment guarded by one spinlock taken
# with ldaxr/stlxr (acquire) and freed with stlr (release). If both cores ran and
# the lock held, the final counter is exactly 2*SMP_ITERS — a deterministic total
# that is WRONG if either core failed to run or the lock dropped an update. The
# primary also checks that CPU1 stamped its id inside a critical section, proving
# the second core genuinely entered the lock. Only the primary touches the UART.
# ---------------------------------------------------------------------------
def arm64_run_smp_sched() -> int64:
    intro: Ptr[char] = "[arm64] Phase 12: secondary-core scheduling under a spinlock\n"
    _uart_puts(intro)

    # Seed the Phase-12 shared cells. Lock free, counter zero, both done flags
    # clear, touch cell clear. The go flag stays 0 until both sides are armed.
    lock: Ptr[uint64] = cast[Ptr[uint64]](SMP_LOCK)
    counter: Ptr[uint64] = cast[Ptr[uint64]](SMP_SHARED_COUNT)
    go: Ptr[uint64] = cast[Ptr[uint64]](SMP_GO)
    cpu0_done: Ptr[uint64] = cast[Ptr[uint64]](SMP_CPU0_DONE)
    cpu1_done: Ptr[uint64] = cast[Ptr[uint64]](SMP_CPU1_DONE)
    touched: Ptr[uint64] = cast[Ptr[uint64]](SMP_CPU1_TOUCHED)
    lock[0] = cast[uint64](0)
    counter[0] = cast[uint64](0)
    cpu0_done[0] = cast[uint64](0)
    cpu1_done[0] = cast[uint64](0)
    touched[0] = cast[uint64](0)
    _dsb_ish()

    # Release both cores into the contended loop together. The secondary is
    # spinning on this cell (with dmb ish); publish it and sev to wake its wfe.
    go[0] = cast[uint64](1)
    _dsb_ish()
    _sev()

    # The primary runs its OWN share of the work (core_id 0) contending with CPU1.
    arm64_smp_worker(cast[uint64](0))
    _dmb_ish()
    cpu0_done[0] = cast[uint64](1)
    _dmb_ish()
    _sev()

    # Wait for the secondary to finish its share. Bound the wait so a wedged core
    # fails loudly instead of hanging.
    spins: int64 = 0
    seen_done: int64 = 0
    while spins < 200000000:
        _dmb_ish()
        if cpu1_done[0] != cast[uint64](0):
            seen_done = 1
            break
        spins = spins + 1

    nl: Ptr[char] = "\n"

    if seen_done == 0:
        to: Ptr[char] = "[arm64] secondary did not finish its work (timeout)\n"
        _uart_puts(to)
        bad: Ptr[char] = "[arm64] SMP scheduling FAIL\n"
        _uart_puts(bad)
        while True:
            _wfi()

    bothmsg: Ptr[char] = "[arm64] both cores finished\n"
    _uart_puts(bothmsg)

    # Read the final shared count and the CPU1 touch stamp through a dmb ish so we
    # observe every locked store from both cores.
    _dmb_ish()
    total: uint64 = counter[0]
    stamp: uint64 = touched[0]

    expected: uint64 = SMP_ITERS + SMP_ITERS

    cmsg: Ptr[char] = "[arm64] shared counter -> "
    _uart_puts(cmsg)
    _uart_puthex(total)
    _uart_puts(nl)
    emsg: Ptr[char] = "[arm64] expected         -> "
    _uart_puts(emsg)
    _uart_puthex(expected)
    _uart_puts(nl)
    smsg: Ptr[char] = "[arm64] CPU1 touched lock -> "
    _uart_puts(smsg)
    _uart_puthex(stamp)
    _uart_puts(nl)

    # PASS iff the total is exactly 2*SMP_ITERS (no lost updates -> the lock held
    # AND both cores ran) AND CPU1 stamped its id (the secondary entered the
    # critical section, so it really executed under the shared lock).
    if total == expected and stamp == cast[uint64](1):
        ranmsg: Ptr[char] = "[arm64] CPU1 ran in scheduler\n"
        _uart_puts(ranmsg)
        heldmsg: Ptr[char] = "[arm64] spinlock held under contention\n"
        _uart_puts(heldmsg)
        okmsg: Ptr[char] = "[arm64] SMP scheduling OK\n"
        _uart_puts(okmsg)
    else:
        failmsg: Ptr[char] = "[arm64] SMP scheduling FAIL\n"
        _uart_puts(failmsg)
        while True:
            _wfi()

    # Phase 12 complete. The secondary is now parked in WFE; the PRIMARY hands off
    # to Phase 11 (EL0 signal delivery). Mask IRQs (deterministic, no timer
    # re-entry); arm64_run_signal_demo() halts after the Phase-11 PASS marker.
    _msr_daifset(2)
    arm64_run_signal_demo()
    while True:
        _wfi()
    return 0


# ---------------------------------------------------------------------------
# Phase 11 — EL0 SIGNAL DELIVERY (push a signal frame, run a user handler,
# sigreturn back to the interrupted EL0 context).
#
# This mirrors the x86 signal-delivery path: a running EL0 task asks the kernel
# to deliver a signal to itself; the kernel saves the interrupted EL0 context
# (resume PC + stack pointer + the syscall's x0 result) into a SIGNAL FRAME it
# pushes onto the task's OWN EL0 stack, redirects EL0 to a user signal HANDLER,
# and ERETs into it. The handler runs entirely in EL0 (it records that it ran
# via a kernel-private syscall) and finally invokes a sigreturn TRAMPOLINE,
# which traps to the kernel; the kernel restores ELR_EL1 + SP_EL0 (and x0) from
# the saved frame and ERETs back to EXACTLY where the original raise() left off.
# The main routine then observes it resumed past the raise and exit(0)s, proving
# a complete deliver -> handle -> return round trip on bare-metal aarch64.
#
# Implementation notes:
#   * The signal frame is pushed BELOW the live SP_EL0 (read via MRS SP_EL0) so
#     it lands in the task's EL0-RWX stack window; SP_EL0 is then lowered past it
#     while the handler runs, and restored to its original value on sigreturn.
#   * raise()/sigreturn() are serviced from arm64_sync_handler's normal return
#     path: that path does NOT overwrite SPSR_EL1/ELR_EL1/SP_EL0 (it only reloads
#     the GPR frame then erets), so mutating ELR_EL1 + SP_EL0 inside the handler
#     and returning 0 makes the stub's ERET resume EL0 at the redirected target.
#   * SPSR_EL1 is left as the trapped EL0t PSTATE for both transitions, so the
#     handler and the resumed mainline both run at EL0t with IRQs masked.
# ---------------------------------------------------------------------------

# Kernel-private Phase-11 syscall numbers (outside the Linux ABI range used by
# write/exit). raise() asks the kernel to deliver the signal; sighandler_ran()
# lets the user handler tell the kernel it executed; sigreturn() asks the kernel
# to restore the interrupted context and resume the mainline.
SYS_RAISE_NR: uint64 = 520
SYS_SIGHANDLER_RAN_NR: uint64 = 521
SYS_SIGRETURN_NR: uint64 = 522

# The signal "number" the demo raises (mirrors a POSIX signal value; here it is
# only a token passed to the handler in x0 so we can prove it arrived intact).
SIG_DEMO_NR: uint64 = 0x11               # 17 — an arbitrary recognizable token

# Phase-11 EL0 layout, all inside the EL0-RWX window (USER_L2_INDEX @ 0x4020_0000):
#   main entry, handler entry, sigreturn trampoline, and the write() message.
SIG_MAIN_CODE: uint64 = 0x40200000       # main routine (== USER_CODE_BASE)
SIG_HANDLER_CODE: uint64 = 0x40208000    # signal handler routine
SIG_RET_TRAMP: uint64 = 0x4020C000       # sigreturn trampoline (handler returns here)
SIG_MSG_BASE: uint64 = 0x40223000        # handler's write() message buffer
SIG_STACK_TOP: uint64 = 0x40270000       # EL0 stack top for the signal demo task

# Phase-11 bookkeeping. arm64_sig_active routes svc into the Phase-11 dispatcher.
# The saved-frame cells latch the interrupted EL0 context across handler
# execution. arm64_sig_handler_ran / arm64_sig_delivered / arm64_sig_returned
# latch the three milestones so exit() can prove the full round trip occurred.
arm64_sig_active: int64 = 0
arm64_sig_saved_pc: uint64 = 0           # ELR_EL1 at raise (resume PC)
arm64_sig_saved_sp: uint64 = 0           # SP_EL0 at raise (resume stack)
arm64_sig_saved_x0: uint64 = 0           # x0 the mainline expects after raise
arm64_sig_delivered: int64 = 0           # set once the frame is pushed + redirected
arm64_sig_handler_ran: int64 = 0         # set when the EL0 handler reports in
arm64_sig_returned: int64 = 0            # set once sigreturn restored the context
arm64_sig_handler_arg: uint64 = 0        # the signal token the handler received

# The return value raise() hands back to the mainline once the handler has run
# and sigreturn has resumed it (a recognizable sentinel so the mainline can
# confirm the kernel restored its x0 across the signal round trip).
SIG_RAISE_RESULT: uint64 = 0x5161        # "Q a" — arbitrary recognizable value


# Materialise the Phase-11 EL0 MAIN routine into SIG_MAIN_CODE:
#   x8 = 520 (raise); svc #0          -> kernel delivers the signal here
#   (control diverts to the handler, runs it, sigreturns back to the next insn)
#   ... resumes here with x0 = SIG_RAISE_RESULT ...
#   write(1, msg, len)                -> echo a "resumed" marker
#   exit(0)
# Because raise() diverts to the handler and only returns AFTER sigreturn, the
# instructions after the raise svc are the resumption point the kernel restores.
def arm64_build_sig_main(msg_len: uint64) -> int64:
    a: uint64 = SIG_MAIN_CODE

    # raise(): x8 = 520; svc #0. The kernel saves THIS post-svc PC as the resume
    # point, delivers the signal, and only resumes here once sigreturn fires.
    a = _emit_load_imm64(a, cast[uint64](8), SYS_RAISE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 64; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), SIG_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0

    # exit(0): x0 = 0; x8 = 93; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0

    _dsb_ish()
    _isb()
    return 0


# Materialise the Phase-11 EL0 signal HANDLER into SIG_HANDLER_CODE. On entry the
# kernel has set x0 = the signal token (SIG_DEMO_NR). The handler:
#   sighandler_ran(x0): x8 = 521; svc #0   -> tell the kernel it executed (passing
#                                             the signal token back for checking)
#   b SIG_RET_TRAMP                         -> jump to the sigreturn trampoline
# The trampoline then issues the sigreturn svc, so the handler never falls off
# its end. (x0 already holds the signal token on entry, courtesy of the kernel.)
def arm64_build_sig_handler() -> int64:
    a: uint64 = SIG_HANDLER_CODE

    # sighandler_ran(token): the kernel placed the token in x0 already; move it to
    # x1 (so x0 can carry nothing in particular) — but simplest is to keep the
    # token in x0 as arg0. x8 = 521; svc #0.
    a = _emit_load_imm64(a, cast[uint64](8), SYS_SIGHANDLER_RAN_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0

    # b SIG_RET_TRAMP : 0x14000000 | imm26; imm26 = (target - here) / 4.
    b_here: uint64 = a
    off_tramp: int64 = cast[int64](SIG_RET_TRAMP) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_tramp >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# Materialise the Phase-11 sigreturn TRAMPOLINE into SIG_RET_TRAMP:
#   x8 = 522 (sigreturn); svc #0   -> kernel restores the interrupted context and
#                                     resumes the mainline (this svc never returns
#                                     to the trampoline; the kernel erets to the
#                                     saved mainline PC instead).
# A real Linux signal frame stores this trampoline address as the handler's
# return address; here the handler branches to it directly, which is equivalent.
def arm64_build_sig_trampoline() -> int64:
    a: uint64 = SIG_RET_TRAMP
    a = _emit_load_imm64(a, cast[uint64](8), SYS_SIGRETURN_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0
    _dsb_ish()
    _isb()
    return 0


# Deliver the signal to the running EL0 task. The trapped ELR_EL1 already points
# at the instruction AFTER the raise svc — that is the resume PC. Saves the
# interrupted context, pushes a signal frame below SP_EL0, redirects ELR_EL1 to
# the handler with the signal token in x0, and lowers SP_EL0 past the frame.
def arm64_sig_do_raise(frame_ptr: Ptr[uint64]) -> int64:
    resume_pc: uint64 = cast[uint64](_mrs_elr_el1())
    cur_sp: uint64 = cast[uint64](_mrs_sp_el0())

    rm: Ptr[char] = "[arm64] EL0 raise() -> delivering signal\n"
    _uart_puts(rm)

    # Save the interrupted context the mainline must see restored. The saved x0 is
    # a sentinel so the resumption can prove the kernel restored x0 round trip.
    arm64_sig_saved_pc = resume_pc
    arm64_sig_saved_sp = cur_sp
    arm64_sig_saved_x0 = SIG_RAISE_RESULT

    # Push a minimal signal frame onto the EL0 stack below the live SP_EL0 (two
    # 8-byte words, 16-byte aligned): the saved PC + SP, mirroring a real
    # sigframe. The kernel reads these back on sigreturn.
    new_sp: uint64 = cur_sp - cast[uint64](16)
    framep: Ptr[uint64] = cast[Ptr[uint64]](new_sp)
    framep[0] = resume_pc
    framep[1] = cur_sp

    pcmsg: Ptr[char] = "[arm64] signal frame pushed; resume PC="
    _uart_puts(pcmsg)
    _uart_puthex(resume_pc)
    nl0: Ptr[char] = "\n"
    _uart_puts(nl0)

    # Redirect EL0 into the user handler on the lowered stack, with the signal
    # token in x0 (the handler's arg0). The sync stub reloads the GPR frame then
    # erets, so writing the frame's x0 slot sets the handler's x0, and setting
    # ELR_EL1 + SP_EL0 here lands the eret on the handler.
    frame_ptr[0] = SIG_DEMO_NR
    _msr_elr_el1(SIG_HANDLER_CODE)
    _msr_sp_el0(new_sp)
    arm64_sig_delivered = 1

    dm: Ptr[char] = "[arm64] redirected EL0 to signal handler\n"
    _uart_puts(dm)
    return 0


# Restore the interrupted EL0 context from the saved signal frame and resume the
# mainline. Reads the frame back off the EL0 stack to prove the pushed layout
# round-tripped, then restores ELR_EL1 + SP_EL0 + x0.
def arm64_sig_do_return(frame_ptr: Ptr[uint64]) -> int64:
    sp_at_ret: uint64 = cast[uint64](_mrs_sp_el0())
    framep: Ptr[uint64] = cast[Ptr[uint64]](sp_at_ret)
    framed_pc: uint64 = framep[0]
    framed_sp: uint64 = framep[1]

    srm: Ptr[char] = "[arm64] EL0 sigreturn() -> restoring context\n"
    _uart_puts(srm)

    # The frame-stored PC/SP must match what raise() saved.
    ok_pc: int64 = 0
    if framed_pc == arm64_sig_saved_pc:
        ok_pc = 1
    ok_sp: int64 = 0
    if framed_sp == arm64_sig_saved_sp:
        ok_sp = 1
    if (ok_pc != 0) and (ok_sp != 0):
        fm: Ptr[char] = "[arm64] sigreturn frame matched saved context OK\n"
        _uart_puts(fm)
    else:
        bm: Ptr[char] = "[arm64] sigreturn frame MISMATCH FAIL\n"
        _uart_puts(bm)

    # Restore ELR_EL1 (resume PC) + SP_EL0 (original stack), and place the saved
    # x0 sentinel into the frame's x0 slot so the mainline resumes with raise()'s
    # return value. SPSR_EL1 is unchanged (still EL0t).
    _msr_elr_el1(arm64_sig_saved_pc)
    _msr_sp_el0(arm64_sig_saved_sp)
    frame_ptr[0] = arm64_sig_saved_x0
    arm64_sig_returned = 1

    dm: Ptr[char] = "[arm64] resuming interrupted EL0 mainline; PC="
    _uart_puts(dm)
    _uart_puthex(arm64_sig_saved_pc)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    return 0


# Phase-11 exit: record the code, print PASS iff the whole signal round trip ran
# cleanly (frame delivered + handler ran with the right token + sigreturn
# restored + resumed), then halt deterministically. Never returns.
def arm64_sig_do_exit(a0: uint64) -> int64:
    arm64_el0_exit_code = cast[int64](a0)
    arm64_el0_exited = 1
    em: Ptr[char] = "[arm64] EL0 exit(11) syscall serviced\n"
    _uart_puts(em)
    ok: int64 = 0
    if a0 == cast[uint64](0):
        if arm64_sig_delivered != 0:
            if arm64_sig_handler_ran != 0:
                if arm64_sig_returned != 0:
                    if arm64_sig_handler_arg == SIG_DEMO_NR:
                        ok = 1
    if ok != 0:
        pm: Ptr[char] = "[arm64] EL0 signal delivery OK\n"
        _uart_puts(pm)
    else:
        fm: Ptr[char] = "[arm64] EL0 signal delivery FAIL\n"
        _uart_puts(fm)
    arm64_sig_active = 0
    # Phase 11 done; hand off to Phase 13 (EL0 FP/SIMD context save/restore across
    # a context switch). Mask IRQs so the cooperative-yield FP demo runs
    # deterministically (no timer re-entry); arm64_run_fp_demo() halts after its
    # own PASS marker and never returns.
    _msr_daifset(2)
    arm64_run_fp_demo()
    # Unreachable safety halt.
    while True:
        _wfi()
    return 0


# Phase-11 signal dispatcher. Routed from arm64_sync_handler while the signal
# demo is live. Services raise (deliver), sighandler_ran (handler reporting in),
# sigreturn (restore + resume), write and exit. raise/sigreturn mutate ELR_EL1 +
# SP_EL0 and return 0 so the sync stub's ERET lands on the redirected target.
def arm64_sig_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_RAISE_NR:
        return arm64_sig_do_raise(frame_ptr)

    if nr == SYS_SIGHANDLER_RAN_NR:
        # The EL0 signal handler is executing and reporting in (a0 = signal token).
        arm64_sig_handler_ran = 1
        arm64_sig_handler_arg = a0
        hm: Ptr[char] = "[arm64] EL0 signal handler ran; token="
        _uart_puts(hm)
        _uart_puthex(a0)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_SIGRETURN_NR:
        return arm64_sig_do_return(frame_ptr)

    if nr == SYS_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(11) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_EXIT_NR:
        return arm64_sig_do_exit(a0)

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 11)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-11 entry point (invoked from the Phase-10 SMP hand-off). Restore the
# kernel's identity TTBR0, build the EL0 main routine + signal handler + sigreturn
# trampoline + handler message, arm Phase-11 dispatch, and ERET into the main
# routine at EL0t with IRQs masked. Never returns (the task's exit() halts).
def arm64_run_signal_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 11: EL0 signal delivery\n"
    _uart_puts(intro)

    # Restore the kernel's identity-only TTBR0 so the EL0 code/stack windows
    # resolve through L1_PGTABLE, then flush the TLB for a clean address space.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Build the three EL0 routines + the handler's write() message.
    sigmsg: Ptr[char] = "Resumed EL0 mainline after signal handler\n"
    msg_len: uint64 = _copy_msg_to(sigmsg, SIG_MSG_BASE)
    arm64_build_sig_main(msg_len)
    arm64_build_sig_handler()
    arm64_build_sig_trampoline()

    # Seed Phase-11 bookkeeping and arm the dispatcher.
    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_sig_delivered = 0
    arm64_sig_handler_ran = 0
    arm64_sig_returned = 0
    arm64_sig_handler_arg = 0
    arm64_sig_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 signal-delivery task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(SIG_MAIN_CODE)        # EL0 entry PC (the main routine)
    _msr_sp_el0(SIG_STACK_TOP)         # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; svc traps re-enter EL1; no return
    return 0


# ---------------------------------------------------------------------------
# Phase 13 — EL0 FP/SIMD CONTEXT SAVE/RESTORE ACROSS A CONTEXT SWITCH.
#
# Linux saves/restores the FP/SIMD register file (the V registers) on every
# context switch; without that, a task's floating-point state would be silently
# corrupted the moment another task ran. The aarch64 port's earlier scheduler
# (Phase 5) only saved the GPRs (x0..x30 + SP/ELR/SPSR), NOT the FP registers, so
# FP state did NOT survive a switch. Phase 13 closes that gap and PROVES it.
#
# Design (deterministic, cooperative — no timer needed):
#   * CPACR_EL1.FPEN is set so EL0 (and the kernel) may execute FP/SIMD ops; until
#     now FP was trapped.
#   * Two EL0 tasks each seed the callee-saved scalar FP register d8 with a
#     DISTINCTIVE 64-bit signature (FP_SIG0 / FP_SIG1) via a hand-emitted
#     `fmov d8, x9`. Each then loops: read d8 back (`fmov x_, d8`), hand the value
#     to the kernel via a private `fpcheck` syscall, then `yield`.
#   * The kernel runs a COOPERATIVE round-robin scheduler keyed off yield. On every
#     yield it SAVES the outgoing task's d8..d15 into that task's FP save area and
#     RESTORES the incoming task's d8..d15 from its save area — the FP half of a
#     real context switch. Between a task's two consecutive yields the OTHER task
#     runs and overwrites the LIVE d8 with its own signature, so WITHOUT the
#     save/restore a task would read back the wrong value. fpcheck FAILs loudly if
#     a task ever observes a value other than its own signature.
#   * After each task has been scheduled FP_YIELD_LIMIT times and every fpcheck
#     matched, the kernel prints the Phase-13 PASS marker and halts. A PASS proves
#     FP/SIMD state is per-task and genuinely survives an EL0<->EL0 context switch
#     on bare-metal aarch64.
# ---------------------------------------------------------------------------

# Kernel-private Phase-13 syscall: an EL0 task reports the current value it read
# back out of d8 so the kernel can verify its FP signature survived the switch.
SYS_FPCHECK_NR: uint64 = 530

# The two task FP signatures (arbitrary recognizable 64-bit values). Each task
# seeds d8 with its own and must always read exactly this back.
FP_SIG0: uint64 = 0x1234567811112222
FP_SIG1: uint64 = 0xCAFEF00D33334444

# Phase-13 EL0 layout — both tasks live inside the EL0-RWX 2 MiB window.
FP_TASK0_CODE: uint64 = 0x40200000
FP_TASK1_CODE: uint64 = 0x40210000
FP_TASK0_STACK_TOP: uint64 = 0x40240000
FP_TASK1_STACK_TOP: uint64 = 0x40250000

# Per-task context blocks (GPR frame, 34 slots) in EL1-only RAM, clear of the
# Phase-5 blocks (0x40104000 / 0x40105000) so the two demos never collide.
FP_TASK0_CTX: uint64 = 0x40106000
FP_TASK1_CTX: uint64 = 0x40107000

# Per-task FP save areas (d8..d15 = 8 doubles = 64 bytes each), EL1-only RAM. A
# task can neither read nor scribble the saved FP state of the other.
FP_TASK0_FPAREA: uint64 = 0x40108000
FP_TASK1_FPAREA: uint64 = 0x40108080

# How many times EACH task must be scheduled (and pass its fpcheck) before the
# demo declares success. Small but >1 so the save/restore is exercised both ways
# multiple times.
FP_YIELD_LIMIT: int64 = 6

# Phase-13 bookkeeping.
arm64_fp_active: int64 = 0           # routes svc into the Phase-13 dispatcher
arm64_fp_cur_task: int64 = 0         # which task is live (0 or 1)
arm64_fp_checks0: int64 = 0          # successful fpchecks by task 0
arm64_fp_checks1: int64 = 0          # successful fpchecks by task 1
arm64_fp_corrupt: int64 = 0          # set if ANY task ever read a wrong value
arm64_fp_current_ctx: uint64 = 0     # ctx block of the live task (for symmetry)


# Materialise a Phase-13 EL0 FP task into `code_base`. The task:
#   x9 = sig ; fmov d8, x9          -> seed its FP signature into d8
#   loop:
#     fmov x0, d8                   -> read d8 back into x0 (arg0)
#     x8 = 530 (fpcheck) ; svc #0   -> kernel verifies x0 == this task's sig
#     x8 = 124 (yield)   ; svc #0   -> cooperatively yield to the other task
#     b loop
# The task never exits; the kernel ends the demo once both tasks have passed
# FP_YIELD_LIMIT fpchecks. fmov encodings:
#   fmov d8, xN  : 0x9E670000 | (N<<5) | 8
#   fmov x0, d8  : 0x9E660000 | (8<<5) | 0
def arm64_build_fp_task(code_base: uint64, sig: uint64) -> int64:
    a: uint64 = code_base

    # x9 = sig ; fmov d8, x9
    a = _emit_load_imm64(a, cast[uint64](9), sig)
    fmov_d8_x9: uint64 = cast[uint64](0x9E670000) | (cast[uint64](9) << cast[uint64](5)) | cast[uint64](8)
    a = _emit_word(a, fmov_d8_x9)

    loop_top: uint64 = a

    # fmov x0, d8  (read the live d8 into x0 as fpcheck's arg0)
    fmov_x0_d8: uint64 = cast[uint64](0x9E660000) | (cast[uint64](8) << cast[uint64](5)) | cast[uint64](0)
    a = _emit_word(a, fmov_x0_d8)

    # fpcheck(x0): x8 = 530 ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_FPCHECK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0

    # yield(): x8 = 124 ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_YIELD_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0

    # b loop_top : 0x14000000 | imm26
    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# Enable EL0/EL1 FP/SIMD access by setting CPACR_EL1.FPEN (bits[21:20] = 0b11).
# Without this, the first fmov (kernel or EL0) traps as an EC=0x07 access fault.
def arm64_fp_enable() -> int64:
    cpacr: uint64 = cast[uint64](_mrs_cpacr_el1())
    cpacr = cpacr | cast[uint64](0x300000)     # FPEN = 0b11 (no trapping)
    _msr_cpacr_el1(cpacr)
    _isb()
    return 0


# Phase-13 cooperative scheduler: invoked from the dispatcher when the running
# task yields. The svc trap path (arm64_lower_sync_entry in vectors.S) reloads the
# GPR frame then erets WITHOUT touching SP_EL0/ELR_EL1/SPSR_EL1 — so, exactly like
# the Phase-11 signal path, we redirect the eret by mutating ELR_EL1 + SP_EL0 here.
#
# Save the OUTGOING task's resume context (the post-yield ELR_EL1 + live SP_EL0)
# into its ctx block AND save its FP registers d8..d15 into its FP save area; then
# pick the OTHER task, restore its FP registers, and program ELR_EL1/SP_EL0/SPSR
# from its ctx block so the stub's eret resumes it where it last yielded (or at its
# entry on the first schedule). This is the FP half of a real context switch
# layered on the GPR-frame reload the vector stub already does.
def arm64_fp_switch() -> uint64:
    out_ctx: uint64 = FP_TASK0_CTX
    out_area: uint64 = FP_TASK0_FPAREA
    in_ctx: uint64 = FP_TASK1_CTX
    in_area: uint64 = FP_TASK1_FPAREA
    if arm64_fp_cur_task == 0:
        out_ctx = FP_TASK0_CTX
        out_area = FP_TASK0_FPAREA
        in_ctx = FP_TASK1_CTX
        in_area = FP_TASK1_FPAREA
        arm64_fp_cur_task = 1
    else:
        out_ctx = FP_TASK1_CTX
        out_area = FP_TASK1_FPAREA
        in_ctx = FP_TASK0_CTX
        in_area = FP_TASK0_FPAREA
        arm64_fp_cur_task = 0

    # Save the outgoing task's resume PC (ELR_EL1, already pointing past its yield
    # svc) and live stack (SP_EL0) so it resumes mid-loop next time it is picked.
    outc: Ptr[uint64] = cast[Ptr[uint64]](out_ctx)
    outc[CTX_ELR] = cast[uint64](_mrs_elr_el1())
    outc[CTX_SP_EL0] = cast[uint64](_mrs_sp_el0())
    outc[CTX_SPSR] = SPSR_EL0T_DAIF

    # Save the outgoing task's FP state, then load the incoming task's FP state
    # into the live registers — the heart of the FP context switch.
    _fp_save_d8_d15(out_area)
    _fp_restore_d8_d15(in_area)

    # Program the eret target from the incoming task's ctx block.
    inc: Ptr[uint64] = cast[Ptr[uint64]](in_ctx)
    _msr_elr_el1(inc[CTX_ELR])
    _msr_sp_el0(inc[CTX_SP_EL0])
    _msr_spsr_el1(inc[CTX_SPSR])

    arm64_fp_current_ctx = in_ctx
    arm64_current_ctx = in_ctx
    return in_ctx


# Phase-13 syscall dispatcher. Services fpcheck (verify a task's FP signature),
# yield (save/restore FP + switch task), write and exit. fpcheck/yield return into
# EL0; the demo ends from inside the dispatcher (it never returns to EL0 then).
def arm64_fp_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_FPCHECK_NR:
        # a0 = the value the task read back out of d8. It must equal the live
        # task's signature; otherwise FP state was lost across a switch.
        expected: uint64 = FP_SIG0
        if arm64_fp_cur_task == 0:
            expected = FP_SIG0
        else:
            expected = FP_SIG1
        if a0 == expected:
            if arm64_fp_cur_task == 0:
                arm64_fp_checks0 = arm64_fp_checks0 + 1
            else:
                arm64_fp_checks1 = arm64_fp_checks1 + 1
            okm: Ptr[char] = "[arm64] fpcheck OK task="
            _uart_puts(okm)
            _uart_puthex(cast[uint64](arm64_fp_cur_task))
            sm: Ptr[char] = " d8="
            _uart_puts(sm)
            _uart_puthex(a0)
            nl: Ptr[char] = "\n"
            _uart_puts(nl)
        else:
            arm64_fp_corrupt = 1
            bm: Ptr[char] = "[arm64] fpcheck CORRUPT task="
            _uart_puts(bm)
            _uart_puthex(cast[uint64](arm64_fp_cur_task))
            gm: Ptr[char] = " got="
            _uart_puts(gm)
            _uart_puthex(a0)
            em: Ptr[char] = " want="
            _uart_puts(em)
            _uart_puthex(expected)
            nl2: Ptr[char] = "\n"
            _uart_puts(nl2)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_YIELD_NR:
        # Both tasks have run enough times AND every fpcheck matched -> success.
        if arm64_fp_checks0 >= FP_YIELD_LIMIT:
            if arm64_fp_checks1 >= FP_YIELD_LIMIT:
                arm64_fp_finish()
                # Unreachable: arm64_fp_finish halts. Safety loop if it falls through.
                while True:
                    _wfi()

        # Otherwise switch FP context to the other task. arm64_fp_switch saves the
        # outgoing FP + resume context and programs ELR_EL1/SP_EL0/SPSR for the
        # incoming task; we then return 0 so the sync stub reloads the GPR frame and
        # erets into the incoming task at its redirected resume point.
        arm64_fp_switch()
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_EXIT_NR:
        arm64_fp_finish()
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 13)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# ERET into the task whose context block is `ctx_base`: program SPSR/ELR/SP_EL0
# from the saved context and eret. Cooperative (no timer), so SPSR keeps IRQs
# masked (SPSR_EL0T_DAIF). Never returns; control resumes in EL0.
def arm64_fp_eret(ctx_base: uint64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](ctx_base)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()
    return 0


# Phase-13 finish: print PASS iff both tasks were scheduled FP_YIELD_LIMIT times
# with every fpcheck matching its signature (so FP state survived every switch)
# and no corruption was ever observed. Halt deterministically. Never returns.
def arm64_fp_finish() -> int64:
    arm64_fp_active = 0
    nl: Ptr[char] = "\n"
    c0m: Ptr[char] = "[arm64] task0 fpchecks passed -> "
    _uart_puts(c0m)
    _uart_puthex(cast[uint64](arm64_fp_checks0))
    _uart_puts(nl)
    c1m: Ptr[char] = "[arm64] task1 fpchecks passed -> "
    _uart_puts(c1m)
    _uart_puthex(cast[uint64](arm64_fp_checks1))
    _uart_puts(nl)

    ok: int64 = 0
    if arm64_fp_corrupt == 0:
        if arm64_fp_checks0 >= FP_YIELD_LIMIT:
            if arm64_fp_checks1 >= FP_YIELD_LIMIT:
                ok = 1
    if ok != 0:
        sm: Ptr[char] = "[arm64] FP state survived context switch\n"
        _uart_puts(sm)
        pm: Ptr[char] = "[arm64] EL0 FP context switch OK\n"
        _uart_puts(pm)
        # Phase 13 complete and clean. Hand off to Phase 14 (demand paging via a
        # translation-fault handler). IRQs stay masked (deterministic); the demand
        # task's exit() halts the boot after the Phase-14 PASS, so this is the
        # Phase 13 -> 14 hand-off point. arm64_run_demand_demo never returns.
        _msr_daifset(2)
        arm64_run_demand_demo()
        # Unreachable safety halt if the Phase-14 launcher ever falls through.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 FP context switch FAIL\n"
        _uart_puts(fm)
    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-13 entry point (invoked from the Phase-11 exit hand-off). Restore the
# kernel's identity TTBR0, enable FP/SIMD, build both EL0 FP tasks + their context
# blocks, seed each task's FP save area with its signature (so the FIRST restore
# of an incoming task loads the right value), arm Phase-13 dispatch, and ERET into
# task 0 at EL0t with IRQs masked. Never returns (the demo halts at its PASS).
def arm64_run_fp_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 13: EL0 FP/SIMD context save/restore\n"
    _uart_puts(intro)

    # Restore the kernel's identity-only TTBR0 (earlier phases may have left a
    # per-task TTBR0 installed), then flush the TLB for a clean address space.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Enable FP/SIMD so the tasks' fmov instructions (and the kernel's FP save/
    # restore) do not trap.
    arm64_fp_enable()
    fpm: Ptr[char] = "[arm64] CPACR_EL1.FPEN enabled\n"
    _uart_puts(fpm)

    # Build both EL0 FP tasks (each seeds d8 with its own signature) and their
    # context blocks (entry PC + stack, EL0t with IRQs masked for determinism).
    arm64_build_fp_task(FP_TASK0_CODE, FP_SIG0)
    arm64_build_fp_task(FP_TASK1_CODE, FP_SIG1)
    arm64_init_ctx(FP_TASK0_CTX, FP_TASK0_CODE, FP_TASK0_STACK_TOP)
    arm64_init_ctx(FP_TASK1_CTX, FP_TASK1_CODE, FP_TASK1_STACK_TOP)
    # arm64_init_ctx sets SPSR to SPSR_EL0T_IRQ (IRQs on). This demo is cooperative
    # with IRQs masked, so force EL0t with DAIF masked in both context blocks.
    ctx0: Ptr[uint64] = cast[Ptr[uint64]](FP_TASK0_CTX)
    ctx1: Ptr[uint64] = cast[Ptr[uint64]](FP_TASK1_CTX)
    ctx0[CTX_SPSR] = SPSR_EL0T_DAIF
    ctx1[CTX_SPSR] = SPSR_EL0T_DAIF

    # Seed each task's FP save area so that the very first time the scheduler
    # RESTORES a task, it loads that task's signature into d8 — though both tasks
    # also re-seed d8 themselves on entry, so this only matters for the inactive
    # task's first restore. Write d8's slot (offset 0) to the signature; the
    # remaining d9..d15 slots are left zero.
    area0: Ptr[uint64] = cast[Ptr[uint64]](FP_TASK0_FPAREA)
    area1: Ptr[uint64] = cast[Ptr[uint64]](FP_TASK1_FPAREA)
    i: int64 = 0
    while i < 8:
        area0[i] = cast[uint64](0)
        area1[i] = cast[uint64](0)
        i = i + 1
    area0[0] = FP_SIG0
    area1[0] = FP_SIG1

    # Seed bookkeeping and arm the dispatcher.
    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_fp_cur_task = 0
    arm64_fp_checks0 = 0
    arm64_fp_checks1 = 0
    arm64_fp_corrupt = 0
    arm64_fp_current_ctx = FP_TASK0_CTX
    arm64_current_ctx = FP_TASK0_CTX
    arm64_fp_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 FP tasks\n"
    _uart_puts(enter)

    arm64_fp_eret(FP_TASK0_CTX)        # -> task 0 at EL0; svc traps re-enter EL1
    return 0


# ---------------------------------------------------------------------------
# Phase 14 — DEMAND PAGING via a translation-fault handler.
#
# An EL0 task stores a sentinel to an UNMAPPED virtual page, then reads it back,
# then repeats for a SECOND unmapped page, then reports both values and exit()s.
# Each first store takes a Data Abort (translation fault) to the synchronous
# vector; the kernel's abort path recognises a translation fault in the demand
# window, maps a fresh physical page into the LIVE TTBR0 tables, and RESUMES the
# faulting store (ERET back into the same instruction) so it completes — true
# first-touch demand paging. The kernel then independently verifies each BACKING
# physical page holds the task's sentinel before printing the Phase-14 PASS.
# ---------------------------------------------------------------------------

# Install the L3 table under the demand window's L2 slot (idempotently): zero a
# fresh L3 table the first time, then point the heap's L2 slot at it with a table
# descriptor + break-before-make TLB maintenance. Subsequent demand faults reuse
# the same L3 table (only the per-page L3 entry is added by the caller).
def arm64_demand_install_l3() -> int64:
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    if l2[cast[int64](P14_DEMAND_L2_INDEX)] != cast[uint64](0):
        return 0                          # L3 already wired under this L2 slot

    # Zero the brand-new L3 table so every still-unmapped 4 KiB slot keeps faulting
    # (so the SECOND page is still a genuine first-touch translation fault).
    l3: Ptr[uint64] = cast[Ptr[uint64]](P14_L3)
    i: int64 = 0
    while i < 512:
        l3[i] = cast[uint64](0)
        i = i + 1
    _dsb_ish()

    # Point the demand window's L2 slot at the new L3 table (table descriptor).
    l2[cast[int64](P14_DEMAND_L2_INDEX)] = P14_L3 | DESC_TABLE
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Map one fresh physical page at demand VA `va` (which must lie in the demand
# window) into the live TTBR0_EL1 tables, EL0 read/write, then flush so EL0 sees
# the new translation. `page_pa` is the backing physical page. Returns the L3
# index that was installed.
def arm64_demand_map_page(va: uint64, page_pa: uint64) -> uint64:
    arm64_demand_install_l3()

    # Zero the backing physical page (a fresh page must start clean).
    pg: Ptr[uint64] = cast[Ptr[uint64]](page_pa)
    j: int64 = 0
    while j < 512:
        pg[j] = cast[uint64](0)
        j = j + 1
    _dsb_ish()

    # L3 index of `va` = VA[20:12].
    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P14_L3)
    l3[cast[int64](l3_index)] = page_pa | P14_PAGE_FLAGS

    # Publish the L3 edit and flush the stale (faulting) translation for this VA.
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return l3_index


# Phase-14 demand-paging fault entry. Called from arm64_sync_handler for a data
# abort from EL0 while the demo is live. Reads ESR_EL1.ISS.DFSC to decide whether
# this is a TRANSLATION fault (page in + resume) or anything else (fall through to
# the reaper). On a translation fault for a recognised demand VA it maps a fresh
# page and returns 1 so the caller resumes EL0 at the faulting instruction (which
# then completes). Returns 0 to defer to the permission-fault reaper.
def arm64_try_demand_page(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        # Not a translation fault (e.g. a permission fault) — not demand-pageable.
        return 0

    far: uint64 = cast[uint64](_mrs_far_el1())
    # Page-align the faulting VA down to 4 KiB to find which demand page to map.
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    if page_va == P14_DEMAND_BASE:
        arm64_demand_map_page(P14_DEMAND_BASE, P14_PAGE0)
        arm64_demand_mapped0 = 1
        arm64_demand_faults = arm64_demand_faults + 1
        m: Ptr[char] = "[arm64] demand fault: paged in VA "
        _uart_puts(m)
        _uart_puthex(P14_DEMAND_BASE)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        return 1

    if page_va == P14_DEMAND_BASE2:
        arm64_demand_map_page(P14_DEMAND_BASE2, P14_PAGE1)
        arm64_demand_mapped1 = 1
        arm64_demand_faults = arm64_demand_faults + 1
        m2: Ptr[char] = "[arm64] demand fault: paged in VA "
        _uart_puts(m2)
        _uart_puthex(P14_DEMAND_BASE2)
        nl2: Ptr[char] = "\n"
        _uart_puts(nl2)
        return 1

    # A translation fault OUTSIDE the demand window is still a real fault.
    return 0


# Materialise the Phase-14 EL0 routine into USER_CODE_BASE:
#   x10 = P14_DEMAND_BASE ; x9 = P14_SENTINEL0
#   str x9, [x10]                  -> FAULTS (page unmapped); kernel pages it in
#                                     and resumes here, so the store now completes
#   x9 = 0 ; ldr x9, [x10]         -> read the sentinel back through the new page
#   x11 = x9                       (stash read-back #0 in x11)
#   x10 = P14_DEMAND_BASE2 ; x9 = P14_SENTINEL1
#   str x9, [x10]                  -> SECOND demand fault on a distinct page
#   x9 = 0 ; ldr x9, [x10]         -> read sentinel #1 back
#   demand_report(x11, x9): x0=x11, x1=x9, x8=540 ; svc #0
#   write(1, msg, len)
#   exit(0)
# The two stores fault transparently; nothing in the task code references the
# kernel page-fault path. fmov-free, GPR-only.
def arm64_build_demand_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE

    # --- page 0: x10 = VA, x9 = sentinel0, str (faults), ldr back into x11 ---
    a = _emit_load_imm64(a, cast[uint64](10), P14_DEMAND_BASE)
    a = _emit_load_imm64(a, cast[uint64](9), P14_SENTINEL0)
    # str x9, [x10]   = 0xF9000000 | (Rn<<5) | Rt
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # x9 = 0 ; ldr x9, [x10]   = 0xF9400000 | (Rn<<5) | Rt
    a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # mov x11, x9  (ORR x11, xzr, x9) = 0xAA0003EB | (Rm<<16) ; Rm=9 -> 0xAA0903EB
    a = _emit_word(a, cast[uint64](0xAA0003EB) | (cast[uint64](9) << cast[uint64](16)))

    # --- page 1: x10 = VA2, x9 = sentinel1, str (faults), ldr back into x9 ---
    a = _emit_load_imm64(a, cast[uint64](10), P14_DEMAND_BASE2)
    a = _emit_load_imm64(a, cast[uint64](9), P14_SENTINEL1)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # demand_report(x11, x9): x0 = x11, x1 = x9, x8 = 540 ; svc #0
    # mov x0, x11  (ORR x0, xzr, x11) = 0xAA0003E0 | (11<<16) = 0xAA0B03E0
    a = _emit_word(a, cast[uint64](0xAA0003E0) | (cast[uint64](11) << cast[uint64](16)))
    # mov x1, x9   (ORR x1, xzr, x9)  = 0xAA0003E1 | (9<<16)  = 0xAA0903E1
    a = _emit_word(a, cast[uint64](0xAA0003E1) | (cast[uint64](9) << cast[uint64](16)))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_DEMAND_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 64; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), P14_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # exit(0): x0 = 0; x8 = 93; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-14 syscall dispatcher. Routed from arm64_sync_handler while the demand-
# paging demo is live. Services the kernel-private demand report (the two read-
# back values), write and exit. write/report return into EL0; exit verifies the
# whole sequence and halts.
def arm64_demand_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_DEMAND_REPORT_NR:
        arm64_demand_reported0 = a0
        arm64_demand_reported1 = a1
        r0: Ptr[char] = "[arm64] EL0 demand read-back #0 -> "
        _uart_puts(r0)
        _uart_puthex(a0)
        nl0: Ptr[char] = "\n"
        _uart_puts(nl0)
        r1: Ptr[char] = "[arm64] EL0 demand read-back #1 -> "
        _uart_puts(r1)
        _uart_puthex(a1)
        nl1: Ptr[char] = "\n"
        _uart_puts(nl1)
        # Independently confirm both BACKING physical pages hold the sentinels, so
        # the demand mappings truly reached P14_PAGE0/P14_PAGE1 (not stale alias).
        back0: Ptr[uint64] = cast[Ptr[uint64]](P14_PAGE0)
        back1: Ptr[uint64] = cast[Ptr[uint64]](P14_PAGE1)
        p0: uint64 = back0[0]
        p1: uint64 = back1[0]
        pm0: Ptr[char] = "[arm64] demand backing phys #0 -> "
        _uart_puts(pm0)
        _uart_puthex(p0)
        nlp0: Ptr[char] = "\n"
        _uart_puts(nlp0)
        pm1: Ptr[char] = "[arm64] demand backing phys #1 -> "
        _uart_puts(pm1)
        _uart_puthex(p1)
        nlp1: Ptr[char] = "\n"
        _uart_puts(nlp1)
        if (a0 == P14_SENTINEL0) and (a1 == P14_SENTINEL1):
            if (p0 == P14_SENTINEL0) and (p1 == P14_SENTINEL1):
                ok: Ptr[char] = "[arm64] demand-paged store/load OK\n"
                _uart_puts(ok)
            else:
                bad: Ptr[char] = "[arm64] demand backing phys mismatch FAIL\n"
                _uart_puts(bad)
        else:
            bad2: Ptr[char] = "[arm64] demand read-back mismatch FAIL\n"
            _uart_puts(bad2)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(14) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_EXIT_NR:
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit(14) syscall serviced\n"
        _uart_puts(em)
        arm64_demand_finish(a0)
        # Unreachable: arm64_demand_finish halts. Safety loop if it falls through.
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 14)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-14 finish: print PASS iff exit(0) AND both pages were demand-paged (one
# translation fault each), AND each read-back matched its sentinel. Report the
# fault count for evidence, then halt deterministically. Never returns.
def arm64_demand_finish(code: uint64) -> int64:
    arm64_demand_active = 0
    nl: Ptr[char] = "\n"
    fc: Ptr[char] = "[arm64] demand faults serviced -> "
    _uart_puts(fc)
    _uart_puthex(cast[uint64](arm64_demand_faults))
    _uart_puts(nl)

    ok: int64 = 0
    if code == cast[uint64](0):
        if arm64_demand_mapped0 != 0:
            if arm64_demand_mapped1 != 0:
                if arm64_demand_faults == 2:
                    if arm64_demand_reported0 == P14_SENTINEL0:
                        if arm64_demand_reported1 == P14_SENTINEL1:
                            ok = 1
    if ok != 0:
        sm: Ptr[char] = "[arm64] first-touch pages faulted in on demand\n"
        _uart_puts(sm)
        pm: Ptr[char] = "[arm64] EL0 demand paging OK\n"
        _uart_puts(pm)
        # Phase 14 complete and clean. Hand off to Phase 15 (safe user-memory
        # access with EFAULT fault-trapping). Mask IRQs (deterministic, no timer
        # re-entry) and run the demo; arm64_run_uaccess_demo halts after PASS.
        # This is the Phase 14 -> 15 hand-off point.
        _msr_daifset(2)
        arm64_run_uaccess_demo()
        # Unreachable: arm64_run_uaccess_demo halts. Safety loop if it falls through.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 demand paging FAIL\n"
        _uart_puts(fm)
    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-14 entry point (invoked from the Phase-13 finish hand-off). Restore the
# kernel's identity TTBR0, ensure the demand window's L2 slot is UNMAPPED (so the
# first EL0 store there genuinely translation-faults), build the EL0 routine +
# message, arm Phase-14 dispatch, and ERET into the demand task at EL0t with IRQs
# masked. Never returns (the task's exit() halts after the PASS marker).
def arm64_run_demand_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 14: demand paging via translation-fault handler\n"
    _uart_puts(intro)

    # Restore the kernel's identity-only TTBR0 (Phase 13 left it installed, but be
    # explicit), then flush the TLB for a clean address space.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Force the demand window's L2 slot UNMAPPED so the first EL0 store there
    # raises a translation Data Abort (a clean, repeatable initial state).
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P14_DEMAND_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Seed Phase-14 bookkeeping.
    arm64_demand_faults = 0
    arm64_demand_mapped0 = 0
    arm64_demand_mapped1 = 0
    arm64_demand_reported0 = cast[uint64](0)
    arm64_demand_reported1 = cast[uint64](0)

    demandmsg: Ptr[char] = "Hello from a demand-paged EL0 page\n"
    msg_len: uint64 = _copy_msg_to(demandmsg, P14_MSG_BASE)
    arm64_build_demand_routine(msg_len)

    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_demand_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 demand-paging task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; first store faults, kernel pages in
    return 0


# ---------------------------------------------------------------------------
# Phase 15 — SAFE USER-MEMORY ACCESS with EFAULT FAULT-TRAPPING.
#
# Entered from the Phase-14 finish hand-off. Runs entirely at EL1 (the kernel
# exercises its OWN copy_from_user / copy_to_user accessors): no EL0 task is
# launched. The kernel's identity-only TTBR0 is restored so the page tables are
# in a known state, the good EL0 scratch cell is seeded, then five accesses are
# performed through the safe accessors and the verdict printed:
#   read-good   : copy_from_user(P15_GOOD_VA)      must succeed + return the seed
#   read-bad #1 : copy_from_user(P15_UNMAPPED_VA)  must return -EFAULT (no crash)
#   read-bad #2 : copy_from_user(P15_UNMAPPED_VA2) must return -EFAULT (no crash)
#   write-bad   : copy_to_user(P15_UNMAPPED_VA)    must return -EFAULT (no crash)
#   write-good  : copy_to_user(P15_GOOD_VA)        must succeed; kernel re-reads it
# Never returns: arm64_uaccess_finish halts in WFI after the PASS/FAIL banner.
# ---------------------------------------------------------------------------
def arm64_uaccess_finish() -> int64:
    nl: Ptr[char] = "\n"
    fc: Ptr[char] = "[arm64] uaccess EFAULTs trapped -> "
    _uart_puts(fc)
    _uart_puthex(cast[uint64](arm64_uaccess_faults))
    _uart_puts(nl)

    ok: int64 = 0
    if arm64_p15_read_ok != 0:
        if arm64_p15_read_val == P15_READ_SENTINEL:
            if arm64_p15_efault0 != 0:
                if arm64_p15_efault1 != 0:
                    if arm64_p15_efault2 != 0:
                        if arm64_p15_write_ok != 0:
                            if arm64_p15_write_seen == P15_WRITE_SENTINEL:
                                if arm64_uaccess_faults == 3:
                                    ok = 1
    if ok != 0:
        sm: Ptr[char] = "[arm64] bad user pointers trapped, valid accesses OK\n"
        _uart_puts(sm)
        pm: Ptr[char] = "[arm64] EL1 safe user access OK\n"
        _uart_puts(pm)
        # Phase 15 complete and clean. Hand off to Phase 16 (EL0 mmap/munmap with
        # demand-paged anonymous mappings). Mask IRQs (deterministic, no timer
        # re-entry) and run the demo; arm64_run_mmap_demo halts after PASS. This is
        # the Phase 15 -> 16 hand-off point.
        _msr_daifset(2)
        arm64_run_mmap_demo()
        # Unreachable: arm64_run_mmap_demo halts. Safety loop if it falls through.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL1 safe user access FAIL\n"
        _uart_puts(fm)
    _msr_daifset(2)
    while True:
        _wfi()
    return 0


def arm64_run_uaccess_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 15: safe user access with EFAULT trapping\n"
    _uart_puts(intro)

    # Restore the kernel's identity-only TTBR0 (Phase 14 left a demand mapping in
    # the live tables) so the page tables are in a clean, known state, then flush.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Seed bookkeeping.
    arm64_uaccess_faults = 0
    arm64_p15_read_ok = 0
    arm64_p15_read_val = cast[uint64](0)
    arm64_p15_write_ok = 0
    arm64_p15_write_seen = cast[uint64](0)
    arm64_p15_efault0 = 0
    arm64_p15_efault1 = 0
    arm64_p15_efault2 = 0

    # Seed the GOOD EL0-accessible cell with the read sentinel (the kernel may
    # write it directly — the page is mapped EL0-RW, also EL1-accessible).
    good: Ptr[uint64] = cast[Ptr[uint64]](P15_GOOD_VA)
    good[0] = P15_READ_SENTINEL
    _dsb_ish()

    out: Ptr[uint64] = cast[Ptr[uint64]](P15_OUT_CELL)
    out[0] = cast[uint64](0)

    # --- read-good: copy_from_user from a valid EL0 address ---
    r0: int64 = arm64_copy_from_user_u64(P15_GOOD_VA, out)
    lr0: Ptr[char] = "[arm64] copy_from_user(good) -> rc "
    _uart_puts(lr0)
    _uart_puthex(cast[uint64](r0))
    vsep: Ptr[char] = " val "
    _uart_puts(vsep)
    _uart_puthex(out[0])
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    if r0 == 0:
        arm64_p15_read_ok = 1
        arm64_p15_read_val = out[0]

    # --- read-bad #1: copy_from_user from a wholly-unmapped VA -> -EFAULT ---
    out[0] = cast[uint64](0)
    r1: int64 = arm64_copy_from_user_u64(P15_UNMAPPED_VA, out)
    lr1: Ptr[char] = "[arm64] copy_from_user(unmapped#1) -> rc "
    _uart_puts(lr1)
    _uart_puthex(cast[uint64](r1))
    _uart_puts(nl)
    if r1 == (cast[int64](0) - EFAULT):
        arm64_p15_efault0 = 1
        e0: Ptr[char] = "[arm64] copy_from_user returned -EFAULT (no crash)\n"
        _uart_puts(e0)

    # --- read-bad #2: a second distinct unmapped VA -> -EFAULT ---
    out[0] = cast[uint64](0)
    r2: int64 = arm64_copy_from_user_u64(P15_UNMAPPED_VA2, out)
    lr2: Ptr[char] = "[arm64] copy_from_user(unmapped#2) -> rc "
    _uart_puts(lr2)
    _uart_puthex(cast[uint64](r2))
    _uart_puts(nl)
    if r2 == (cast[int64](0) - EFAULT):
        arm64_p15_efault1 = 1

    # --- write-bad: copy_to_user to an unmapped VA -> -EFAULT ---
    r3: int64 = arm64_copy_to_user_u64(P15_UNMAPPED_VA, P15_WRITE_SENTINEL)
    lr3: Ptr[char] = "[arm64] copy_to_user(unmapped) -> rc "
    _uart_puts(lr3)
    _uart_puthex(cast[uint64](r3))
    _uart_puts(nl)
    if r3 == (cast[int64](0) - EFAULT):
        arm64_p15_efault2 = 1
        e1: Ptr[char] = "[arm64] copy_to_user returned -EFAULT (no crash)\n"
        _uart_puts(e1)

    # --- write-good: copy_to_user to a valid EL0 address, then re-read it ---
    # Pre-clear the cell so the read-back unambiguously reflects the safe write.
    good[0] = cast[uint64](0)
    _dsb_ish()
    r4: int64 = arm64_copy_to_user_u64(P15_GOOD_VA, P15_WRITE_SENTINEL)
    _dsb_ish()
    seen: uint64 = good[0]
    lr4: Ptr[char] = "[arm64] copy_to_user(good) -> rc "
    _uart_puts(lr4)
    _uart_puthex(cast[uint64](r4))
    _uart_puts(vsep)
    _uart_puthex(seen)
    _uart_puts(nl)
    if r4 == 0:
        arm64_p15_write_ok = 1
        arm64_p15_write_seen = seen

    arm64_uaccess_finish()
    # Unreachable: arm64_uaccess_finish halts. Safety loop if it falls through.
    while True:
        _wfi()
    return 0


# ---------------------------------------------------------------------------
# Phase 16 — EL0 mmap / munmap with DEMAND-PAGED ANONYMOUS MAPPINGS.
# ---------------------------------------------------------------------------

# Install the L3 table under the mmap window's L2 slot (idempotently): zero a fresh
# L3 table the first time, then point the L2 slot at it with a table descriptor +
# break-before-make TLB maintenance. Mirrors arm64_demand_install_l3 for the mmap
# L2 slot. Subsequent map/unmap cycles reuse this L3 table; only the per-page L3
# entry is added/removed by the caller.
def arm64_mmap_install_l3() -> int64:
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    if l2[cast[int64](P16_MMAP_L2_INDEX)] != cast[uint64](0):
        return 0                          # L3 already wired under this L2 slot

    l3: Ptr[uint64] = cast[Ptr[uint64]](P16_L3)
    i: int64 = 0
    while i < 512:
        l3[i] = cast[uint64](0)
        i = i + 1
    _dsb_ish()

    l2[cast[int64](P16_MMAP_L2_INDEX)] = P16_L3 | DESC_TABLE
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Map one fresh physical page at anon VA `va` (which must lie in the mmap window)
# into the live TTBR0_EL1 tables, EL0 read/write, then flush so EL0 sees the new
# translation. `page_pa` is the backing physical page. Mirrors arm64_demand_map_page.
def arm64_mmap_map_page(va: uint64, page_pa: uint64) -> uint64:
    arm64_mmap_install_l3()

    # Zero the backing physical page (a fresh anon page must start clean).
    pg: Ptr[uint64] = cast[Ptr[uint64]](page_pa)
    j: int64 = 0
    while j < 512:
        pg[j] = cast[uint64](0)
        j = j + 1
    _dsb_ish()

    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P16_L3)
    l3[cast[int64](l3_index)] = page_pa | P16_PAGE_FLAGS

    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return l3_index


# Tear down one anon page mapping: clear its L3 entry (back to faulting) and flush.
def arm64_mmap_unmap_page(va: uint64) -> int64:
    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P16_L3)
    l3[cast[int64](l3_index)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Phase-16 anon-mapping fault entry. Called from arm64_sync_handler for a data
# abort from EL0 while the mmap demo is live. Honours the fault ONLY when it is a
# TRANSLATION fault for a VA inside the CURRENTLY-LIVE VMA: maps a fresh page and
# returns 1 so the caller resumes EL0 at the faulting store. Returns 0 otherwise —
# in particular for a touch after munmap (vma_live == 0), which the caller turns
# into a fatal SIGSEGV (proving munmap really removed the mapping).
def arm64_mmap_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0                          # not a translation fault

    if arm64_mmap_vma_live == 0:
        return 0                          # no live VMA -> not demand-pageable

    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    # Is the faulting VA inside the live VMA span [base, base + len)?
    if page_va < arm64_mmap_vma_base:
        return 0
    if page_va >= (arm64_mmap_vma_base + arm64_mmap_vma_len):
        return 0

    # Covered by the live VMA: demand-map a fresh page and resume.
    arm64_mmap_map_page(page_va, P16_PAGE)
    arm64_mmap_paged = 1
    arm64_mmap_faults = arm64_mmap_faults + 1
    m: Ptr[char] = "[arm64] mmap demand fault: paged in anon VA "
    _uart_puts(m)
    _uart_puthex(page_va)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    return 1


# Phase-16 fatal-fault path. Reached only when arm64_mmap_try_fault declined a data
# abort while the mmap demo is live — i.e. the EL0 task touched the anon VA AFTER
# munmap, when no VMA covers it. This is exactly a Linux SIGSEGV: report it, latch
# that the post-munmap touch faulted, and run the Phase-16 verdict. Never returns.
def arm64_mmap_reap(esr: uint64) -> int64:
    far: uint64 = cast[uint64](_mrs_far_el1())
    elr: uint64 = cast[uint64](_mrs_elr_el1())
    m: Ptr[char] = "[arm64] mmap post-munmap fault (no VMA) at VA "
    _uart_puts(m)
    _uart_puthex(far)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    pcm: Ptr[char] = "[arm64] mmap SIGSEGV PC (ELR_EL1)="
    _uart_puts(pcm)
    _uart_puthex(elr)
    _uart_puts(nl)
    arm64_mmap_segv = 1
    seg: Ptr[char] = "[arm64] munmap region unmapped; touch faulted (no re-page)\n"
    _uart_puts(seg)
    arm64_mmap_finish()
    # Unreachable: arm64_mmap_finish halts. Safety loop if it falls through.
    while True:
        _wfi()
    return 0


# Materialise the Phase-16 EL0 routine into USER_CODE_BASE. The kernel patches the
# anon base into x10 (it is returned by the mmap syscall at RUNTIME, but for this
# self-contained demo the base is the fixed P16_MMAP_BASE the kernel hands back, so
# we can build the touch sequence around it). The routine:
#   mmap(len): x0=len; x8=222; svc #0      -> x0 = anon base (== P16_MMAP_BASE)
#   x10 = anon base ; x9 = P16_SENTINEL
#   str x9,[x10]                            -> FAULTS; kernel demand-maps + resumes
#   x9 = 0 ; ldr x9,[x10]                   -> read the sentinel back
#   mmap_report(x9): x0=x9; x8=541; svc #0  -> kernel verifies the demand map
#   write(1,msg,len): x0=1; x1=msg; x2=len; x8=64; svc #0   (echo through the page)
#   munmap(base,len): x0=base; x1=len; x8=215; svc #0
#   x9 = P16_SENTINEL2 ; str x9,[x10]       -> FAULTS AGAIN (no VMA) -> SIGSEGV
# The last store never returns; the reaper takes over. We still emit a trailing
# exit(0) for completeness in case the store were ever (wrongly) re-paged.
def arm64_build_mmap_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE

    # mmap(len): x0 = len; x8 = 222; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P16_MMAP_LEN)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MMAP_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x10 = anon base (== P16_MMAP_BASE); x9 = P16_SENTINEL
    a = _emit_load_imm64(a, cast[uint64](10), P16_MMAP_BASE)
    a = _emit_load_imm64(a, cast[uint64](9), P16_SENTINEL)
    # str x9, [x10]   = 0xF9000000 | (Rn<<5) | Rt   (FAULTS first time)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # x9 = 0 ; ldr x9, [x10]   = 0xF9400000 | (Rn<<5) | Rt
    a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # mmap_report(x9): x0 = x9; x8 = 541; svc #0
    # mov x0, x9  (ORR x0, xzr, x9) = 0xAA0003E0 | (9<<16) = 0xAA0903E0
    a = _emit_word(a, cast[uint64](0xAA0003E0) | (cast[uint64](9) << cast[uint64](16)))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MMAP_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 64; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), P16_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # munmap(base, len): x0 = base; x1 = len; x8 = 215; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P16_MMAP_BASE)
    a = _emit_load_imm64(a, cast[uint64](1), P16_MMAP_LEN)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MUNMAP_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x9 = P16_SENTINEL2 ; str x9, [x10]   (FAULTS AGAIN; reaper takes over)
    a = _emit_load_imm64(a, cast[uint64](9), P16_SENTINEL2)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # exit(0): x0 = 0; x8 = 93; svc #0  (only reached if the touch were re-paged)
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-16 syscall dispatcher. Routed from arm64_sync_handler while the mmap demo
# is live. Services mmap (record VMA + return base), munmap (drop VMA + mapping),
# the kernel-private mmap report (verify the demand-paged value), and a defensive
# exit. The demand page-in happens on the ABORT path (arm64_mmap_try_fault).
def arm64_mmap_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_MMAP_NR:
        # Anonymous mmap: record a single VMA [P16_MMAP_BASE, +len) and return the
        # base. No page is mapped here — it materialises lazily on first touch.
        arm64_mmap_vma_base = P16_MMAP_BASE
        arm64_mmap_vma_len = a0
        arm64_mmap_vma_live = 1
        m: Ptr[char] = "[arm64] EL0 mmap(anon, len="
        _uart_puts(m)
        _uart_puthex(a0)
        sep: Ptr[char] = ") -> base "
        _uart_puts(sep)
        _uart_puthex(P16_MMAP_BASE)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        frame_ptr[0] = P16_MMAP_BASE
        return 0

    if nr == SYS_MMAP_REPORT_NR:
        arm64_mmap_readback = a0
        r: Ptr[char] = "[arm64] EL0 mmap read-back -> "
        _uart_puts(r)
        _uart_puthex(a0)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        # Independently confirm the BACKING physical page holds the sentinel, so the
        # demand map truly reached P16_PAGE (not a stale alias).
        back: Ptr[uint64] = cast[Ptr[uint64]](P16_PAGE)
        pv: uint64 = back[0]
        pm: Ptr[char] = "[arm64] mmap backing phys -> "
        _uart_puts(pm)
        _uart_puthex(pv)
        _uart_puts(nl)
        if a0 == P16_SENTINEL:
            if pv == P16_SENTINEL:
                ok: Ptr[char] = "[arm64] mmap demand-paged store/load OK\n"
                _uart_puts(ok)
            else:
                bad: Ptr[char] = "[arm64] mmap backing phys mismatch FAIL\n"
                _uart_puts(bad)
        else:
            bad2: Ptr[char] = "[arm64] mmap read-back mismatch FAIL\n"
            _uart_puts(bad2)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_MUNMAP_NR:
        # munmap(base, len): drop the VMA and tear the page mapping down so a later
        # touch of the same VA faults fatally. Returns 0 like Linux munmap.
        arm64_mmap_unmap_page(a0)
        arm64_mmap_vma_live = 0
        arm64_mmap_unmapped = 1
        m: Ptr[char] = "[arm64] EL0 munmap(base="
        _uart_puts(m)
        _uart_puthex(a0)
        sep: Ptr[char] = ", len="
        _uart_puts(sep)
        _uart_puthex(a1)
        sep2: Ptr[char] = ") -> 0\n"
        _uart_puts(sep2)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(16) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_EXIT_NR:
        # Reached only if the post-munmap touch were (wrongly) re-paged instead of
        # faulting. The verdict will FAIL because arm64_mmap_segv stays 0.
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit(16) syscall serviced (touch did NOT fault!)\n"
        _uart_puts(em)
        arm64_mmap_finish()
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 16)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-16 finish: print PASS iff the anon page was demand-paged exactly once
# inside its VMA, the read-back matched the sentinel, munmap tore the mapping down,
# AND the post-munmap touch faulted with no live VMA (so it was NOT re-paged).
# Report the fault count for evidence, then halt deterministically. Never returns.
def arm64_mmap_finish() -> int64:
    arm64_mmap_active = 0
    nl: Ptr[char] = "\n"
    fc: Ptr[char] = "[arm64] mmap demand faults serviced -> "
    _uart_puts(fc)
    _uart_puthex(cast[uint64](arm64_mmap_faults))
    _uart_puts(nl)

    ok: int64 = 0
    if arm64_mmap_paged != 0:
        if arm64_mmap_faults == 1:
            if arm64_mmap_readback == P16_SENTINEL:
                if arm64_mmap_unmapped != 0:
                    if arm64_mmap_segv != 0:
                        ok = 1
    if ok != 0:
        sm: Ptr[char] = "[arm64] anon mmap lazily backed; munmap removed it\n"
        _uart_puts(sm)
        pm: Ptr[char] = "[arm64] EL0 mmap/munmap OK\n"
        _uart_puts(pm)
        # Phase 16 complete and clean. Hand off to Phase 17 (EL0 mprotect — change
        # page permissions with a real permission-fault check). IRQs are already
        # masked here; arm64_run_mprotect_demo halts after its own PASS.
        arm64_run_mprotect_demo()
        # Unreachable: arm64_run_mprotect_demo halts. Safety loop if it falls through.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 mmap/munmap FAIL\n"
        _uart_puts(fm)
    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-16 entry point (invoked from the Phase-15 finish hand-off). Restore the
# kernel's identity TTBR0, force the mmap window's L2 slot UNMAPPED (so the first
# EL0 touch genuinely translation-faults), seed bookkeeping, build the EL0 routine,
# arm Phase-16 dispatch, and ERET into the mmap task at EL0t with IRQs masked.
# Never returns (the task faults fatally after munmap, handing off to the reaper).
def arm64_run_mmap_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 16: EL0 mmap/munmap with demand-paged anonymous mappings\n"
    _uart_puts(intro)

    # Restore the kernel's identity-only TTBR0, then flush for a clean state.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Force the mmap window's L2 slot UNMAPPED so the first EL0 touch there raises a
    # translation Data Abort (a clean, repeatable initial state).
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P16_MMAP_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Seed Phase-16 bookkeeping.
    arm64_mmap_vma_base = cast[uint64](0)
    arm64_mmap_vma_len = cast[uint64](0)
    arm64_mmap_vma_live = 0
    arm64_mmap_faults = 0
    arm64_mmap_paged = 0
    arm64_mmap_readback = cast[uint64](0)
    arm64_mmap_unmapped = 0
    arm64_mmap_segv = 0

    mapmsg: Ptr[char] = "Hello from an anonymous mmap region\n"
    msg_len: uint64 = _copy_msg_to(mapmsg, P16_MSG_BASE)
    arm64_build_mmap_routine(msg_len)

    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_mmap_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 mmap/munmap task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; mmap, touch (faults+paged), munmap,
    return 0                           #    touch (faults fatally) -> reaper PASS


# ===========================================================================
# Phase 17 — EL0 mprotect: change page permissions with a permission-fault check.
# ===========================================================================

# Install the L3 table under the mprotect window's L2 slot (idempotently): zero a
# fresh L3 table the first time, then point the L2 slot at it with a table
# descriptor + break-before-make TLB maintenance. Mirrors arm64_mmap_install_l3.
def arm64_mprot_install_l3() -> int64:
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    if l2[cast[int64](P17_MMAP_L2_INDEX)] != cast[uint64](0):
        return 0                          # L3 already wired under this L2 slot

    l3: Ptr[uint64] = cast[Ptr[uint64]](P17_L3)
    i: int64 = 0
    while i < 512:
        l3[i] = cast[uint64](0)
        i = i + 1
    _dsb_ish()

    l2[cast[int64](P17_MMAP_L2_INDEX)] = P17_L3 | DESC_TABLE
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Map one fresh, zeroed physical page at anon VA `va` into the live TTBR0_EL1
# tables with the given L3 `flags` (RW or RO), then flush so EL0 sees the new
# translation. Mirrors arm64_mmap_map_page but takes the descriptor flags.
def arm64_mprot_map_page(va: uint64, page_pa: uint64, flags: uint64) -> uint64:
    arm64_mprot_install_l3()

    # Zero the backing physical page (a fresh anon page must start clean).
    pg: Ptr[uint64] = cast[Ptr[uint64]](page_pa)
    j: int64 = 0
    while j < 512:
        pg[j] = cast[uint64](0)
        j = j + 1
    _dsb_ish()

    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P17_L3)
    l3[cast[int64](l3_index)] = page_pa | flags

    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return l3_index


# Re-point the L3 entry for anon VA `va` at the SAME physical page but with new
# `flags` (used by mprotect to flip AP[2:1] RW->RO). Break-before-make: clear the
# entry, flush, then install the new descriptor, flush again. Does NOT touch the
# page contents — the mapping persists, only its permissions change.
def arm64_mprot_reflag_page(va: uint64, page_pa: uint64, flags: uint64) -> int64:
    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P17_L3)
    l3[cast[int64](l3_index)] = cast[uint64](0)          # break
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    l3[cast[int64](l3_index)] = page_pa | flags          # make (new perms)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Phase-17 fault entry. Called from arm64_sync_handler for a data abort from EL0
# while the mprotect demo is live. Honours ONLY a TRANSLATION fault for a VA inside
# the live VMA: demand-maps a fresh RW page and returns 1 so EL0 resumes its store.
# Returns 0 for anything else — in particular a PERMISSION fault (post-mprotect
# store to the now-RO page), which the caller turns into a fatal SIGSEGV. This is
# the crux of Phase 17: translation faults page in; permission faults kill.
def arm64_mprot_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0                          # not a translation fault (e.g. permission)

    if arm64_mprot_vma_live == 0:
        return 0                          # no live VMA -> not demand-pageable

    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    # Is the faulting VA inside the live VMA span [base, base + len)?
    if page_va < arm64_mprot_vma_base:
        return 0
    if page_va >= (arm64_mprot_vma_base + arm64_mprot_vma_len):
        return 0

    # Covered by the live VMA: demand-map a fresh RW page and resume.
    arm64_mprot_map_page(page_va, P17_PAGE, P17_PAGE_FLAGS_RW)
    arm64_mprot_paged = 1
    arm64_mprot_faults = arm64_mprot_faults + 1
    m: Ptr[char] = "[arm64] mprotect demand fault: paged in RW anon VA "
    _uart_puts(m)
    _uart_puthex(page_va)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    return 1


# Phase-17 fatal-fault path. Reached when arm64_mprot_try_fault declines a data
# abort while the mprotect demo is live — i.e. a PERMISSION fault: the EL0 task
# STORED to the page after mprotect flipped it read-only. This is exactly a Linux
# SIGSEGV (SEGV_ACCERR). Confirm via ESR DFSC that it really is a permission fault,
# latch it, and run the Phase-17 verdict. Never returns.
def arm64_mprot_reap(esr: uint64) -> int64:
    far: uint64 = cast[uint64](_mrs_far_el1())
    elr: uint64 = cast[uint64](_mrs_elr_el1())
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT

    m: Ptr[char] = "[arm64] mprotect store-to-RO fault at VA "
    _uart_puts(m)
    _uart_puthex(far)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    pcm: Ptr[char] = "[arm64] mprotect SIGSEGV PC (ELR_EL1)="
    _uart_puts(pcm)
    _uart_puthex(elr)
    _uart_puts(nl)
    dm: Ptr[char] = "[arm64] mprotect fault DFSC kind (3=permission) -> "
    _uart_puts(dm)
    _uart_puthex(kind)
    _uart_puts(nl)

    if kind == ESR_DFSC_KIND_PERM:
        if arm64_mprot_prot_ro != 0:
            arm64_mprot_segv = 1
            seg: Ptr[char] = "[arm64] mprotect write to read-only page denied (permission fault)\n"
            _uart_puts(seg)
    arm64_mprot_finish()
    # Unreachable: arm64_mprot_finish halts. Safety loop if it falls through.
    while True:
        _wfi()
    return 0


# Materialise the Phase-17 EL0 routine into USER_CODE_BASE:
#   mmap(len): x0=len; x8=222; svc #0       -> x0 = anon base (== P17_MMAP_BASE)
#   x10 = anon base ; x9 = P17_SENTINEL
#   str x9,[x10]                            -> FAULTS (translation); kernel maps RW
#   x9 = 0 ; ldr x9,[x10]                   -> read the sentinel back (RW page)
#   report(x9): x0=x9; x8=542; svc #0       -> kernel verifies the RW store/load
#   mprotect(base,len,PROT_READ): x0=base; x1=len; x2=1; x8=226; svc #0
#   x9 = 0 ; ldr x9,[x10]                   -> READ still works on the RO page
#   rdback(x9): x0=x9; x8=543; svc #0       -> kernel verifies the post-RO read
#   write(1,msg,len): x0=1; x1=msg; x2=len; x8=64; svc #0   (echo through the page)
#   x9 = P17_SENTINEL2 ; str x9,[x10]       -> PERMISSION fault (RO) -> SIGSEGV
# The last store never returns; the reaper takes over. We still emit a trailing
# exit(0) in case the store were ever (wrongly) allowed.
def arm64_build_mprotect_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE

    # mmap(len): x0 = len; x8 = 222; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P17_MMAP_LEN)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MMAP_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x10 = anon base (== P17_MMAP_BASE); x9 = P17_SENTINEL
    a = _emit_load_imm64(a, cast[uint64](10), P17_MMAP_BASE)
    a = _emit_load_imm64(a, cast[uint64](9), P17_SENTINEL)
    # str x9, [x10]   (FAULTS first time -> demand-map RW)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # x9 = 0 ; ldr x9, [x10]   (read the RW sentinel back)
    a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # report(x9): x0 = x9; x8 = 542; svc #0   (mov x0, x9 = ORR x0,xzr,x9)
    a = _emit_word(a, cast[uint64](0xAA0003E0) | (cast[uint64](9) << cast[uint64](16)))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MPROTECT_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # mprotect(base, len, PROT_READ): x0=base; x1=len; x2=1; x8=226; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P17_MMAP_BASE)
    a = _emit_load_imm64(a, cast[uint64](1), P17_MMAP_LEN)
    a = _emit_load_imm64(a, cast[uint64](2), PROT_READ)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MPROTECT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x9 = 0 ; ldr x9, [x10]   (READ still works on the now-RO page)
    a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # rdback(x9): x0 = x9; x8 = 543; svc #0
    a = _emit_word(a, cast[uint64](0xAA0003E0) | (cast[uint64](9) << cast[uint64](16)))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MPROTECT_RDBACK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 64; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), P17_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x9 = P17_SENTINEL2 ; str x9, [x10]   (PERMISSION fault on RO -> reaper)
    a = _emit_load_imm64(a, cast[uint64](9), P17_SENTINEL2)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # exit(0): x0 = 0; x8 = 93; svc #0  (only reached if the RO store were allowed)
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-17 syscall dispatcher. Routed from arm64_sync_handler while the mprotect
# demo is live. Services mmap (record VMA + return base), the RW report (verify the
# demand-paged value), mprotect (flip the live L3 descriptor RW->RO), the post-RO
# read report (the read must still succeed), write, and a defensive exit. The
# page-in (translation fault) and the post-mprotect store fault both happen on the
# ABORT path.
def arm64_mprot_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_MMAP_NR:
        # Anonymous mmap: record a single VMA [P17_MMAP_BASE, +len) and return the
        # base. No page is mapped here — it materialises lazily RW on first touch.
        arm64_mprot_vma_base = P17_MMAP_BASE
        arm64_mprot_vma_len = a0
        arm64_mprot_vma_live = 1
        m: Ptr[char] = "[arm64] EL0 mmap(anon, len="
        _uart_puts(m)
        _uart_puthex(a0)
        sep: Ptr[char] = ") -> base "
        _uart_puts(sep)
        _uart_puthex(P17_MMAP_BASE)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        frame_ptr[0] = P17_MMAP_BASE
        return 0

    if nr == SYS_MPROTECT_REPORT_NR:
        arm64_mprot_readback = a0
        r: Ptr[char] = "[arm64] EL0 mprotect RW read-back -> "
        _uart_puts(r)
        _uart_puthex(a0)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        # Independently confirm the BACKING physical page holds the sentinel.
        back: Ptr[uint64] = cast[Ptr[uint64]](P17_PAGE)
        pv: uint64 = back[0]
        pm: Ptr[char] = "[arm64] mprotect backing phys -> "
        _uart_puts(pm)
        _uart_puthex(pv)
        _uart_puts(nl)
        if a0 == P17_SENTINEL:
            if pv == P17_SENTINEL:
                ok: Ptr[char] = "[arm64] mprotect RW store/load OK\n"
                _uart_puts(ok)
            else:
                bad: Ptr[char] = "[arm64] mprotect backing phys mismatch FAIL\n"
                _uart_puts(bad)
        else:
            bad2: Ptr[char] = "[arm64] mprotect RW read-back mismatch FAIL\n"
            _uart_puts(bad2)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_MPROTECT_NR:
        # mprotect(base, len, prot): downgrade the live mapping to read-only by
        # re-flagging its L3 descriptor AP[2:1] RW(0b01) -> RO(0b11). The mapping
        # persists (same backing page) so a READ still works; a WRITE now PERMISSION-
        # faults. We only implement the PROT_READ downgrade the demo exercises.
        m: Ptr[char] = "[arm64] EL0 mprotect(base="
        _uart_puts(m)
        _uart_puthex(a0)
        sep: Ptr[char] = ", len="
        _uart_puts(sep)
        _uart_puthex(a1)
        sep2: Ptr[char] = ", prot="
        _uart_puts(sep2)
        _uart_puthex(a2)
        nl: Ptr[char] = "\n"
        if a2 == PROT_READ:
            arm64_mprot_reflag_page(a0, P17_PAGE, P17_PAGE_FLAGS_RO)
            arm64_mprot_prot_ro = 1
            sep3: Ptr[char] = ") -> RO; AP[2:1]=0b11\n"
            _uart_puts(sep3)
            rm: Ptr[char] = "[arm64] mprotect set page read-only (PROT_READ)\n"
            _uart_puts(rm)
        else:
            sep3b: Ptr[char] = ") -> unchanged\n"
            _uart_puts(sep3b)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_MPROTECT_RDBACK_NR:
        # The post-mprotect READ reached here -> the RO page is still readable.
        arm64_mprot_rd_after = a0
        arm64_mprot_read_ok = 1
        r: Ptr[char] = "[arm64] EL0 read after mprotect(RO) -> "
        _uart_puts(r)
        _uart_puthex(a0)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        if a0 == P17_SENTINEL:
            ok: Ptr[char] = "[arm64] mprotect read-only page still readable OK\n"
            _uart_puts(ok)
        else:
            bad: Ptr[char] = "[arm64] mprotect post-RO read mismatch FAIL\n"
            _uart_puts(bad)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(17) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_EXIT_NR:
        # Reached only if the post-mprotect STORE were (wrongly) allowed instead of
        # faulting. The verdict will FAIL because arm64_mprot_segv stays 0.
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit(17) serviced (RO store did NOT fault!)\n"
        _uart_puts(em)
        arm64_mprot_finish()
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 17)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-17 finish: print PASS iff the anon page was demand-paged RW exactly once,
# the RW read-back matched, mprotect flipped it RO, the post-mprotect READ still
# succeeded (and matched), AND the post-mprotect WRITE took a genuine PERMISSION
# fault (NOT a translation fault). Report the fault count, then halt. Never returns.
def arm64_mprot_finish() -> int64:
    arm64_mprot_active = 0
    nl: Ptr[char] = "\n"
    fc: Ptr[char] = "[arm64] mprotect demand faults serviced -> "
    _uart_puts(fc)
    _uart_puthex(cast[uint64](arm64_mprot_faults))
    _uart_puts(nl)

    ok: int64 = 0
    if arm64_mprot_paged != 0:
        if arm64_mprot_faults == 1:
            if arm64_mprot_readback == P17_SENTINEL:
                if arm64_mprot_prot_ro != 0:
                    if arm64_mprot_read_ok != 0:
                        if arm64_mprot_rd_after == P17_SENTINEL:
                            if arm64_mprot_segv != 0:
                                ok = 1
    if ok != 0:
        sm: Ptr[char] = "[arm64] mprotect RW->RO enforced; read OK, write denied\n"
        _uart_puts(sm)
        pm: Ptr[char] = "[arm64] EL0 mprotect OK\n"
        _uart_puts(pm)
        # Phase 17 complete and clean. Hand off to Phase 18 (multi-page anon mmap +
        # partial munmap that SPLITS a VMA). IRQs are already masked here;
        # arm64_run_multipage_demo halts after its own PASS.
        arm64_run_multipage_demo()
        # Unreachable: arm64_run_multipage_demo halts. Safety loop if it falls through.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 mprotect FAIL\n"
        _uart_puts(fm)
    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-17 entry point (invoked from the Phase-16 finish hand-off). Restore the
# kernel's identity TTBR0, force the mprotect window's L2 slot UNMAPPED (so the
# first EL0 touch genuinely translation-faults), seed bookkeeping, build the EL0
# routine, arm Phase-17 dispatch, and ERET into the task at EL0t with IRQs masked.
# Never returns (the task faults fatally after mprotect, handing off to the reaper).
def arm64_run_mprotect_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 17: EL0 mprotect (change page permissions, permission-fault check)\n"
    _uart_puts(intro)

    # Restore the kernel's identity-only TTBR0, then flush for a clean state.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Force the mprotect window's L2 slot UNMAPPED so the first EL0 touch there
    # raises a translation Data Abort (a clean, repeatable initial state).
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P17_MMAP_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Seed Phase-17 bookkeeping.
    arm64_mprot_vma_base = cast[uint64](0)
    arm64_mprot_vma_len = cast[uint64](0)
    arm64_mprot_vma_live = 0
    arm64_mprot_prot_ro = 0
    arm64_mprot_faults = 0
    arm64_mprot_paged = 0
    arm64_mprot_readback = cast[uint64](0)
    arm64_mprot_rd_after = cast[uint64](0)
    arm64_mprot_read_ok = 0
    arm64_mprot_segv = 0

    protmsg: Ptr[char] = "Hello from an mprotect read-only region\n"
    msg_len: uint64 = _copy_msg_to(protmsg, P17_MSG_BASE)
    arm64_build_mprotect_routine(msg_len)

    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_mprot_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 mprotect task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; mmap, touch (RW), mprotect RO, read
    return 0                           #    (OK), write (PERMISSION fault) -> reaper


# ===========================================================================
# Phase 18 — Multi-page anon mmap + partial munmap that SPLITS a VMA.
# ===========================================================================

# Install the L3 table under the multi-page window's L2 slot (idempotently): zero a
# fresh L3 table the first time, then point the L2 slot at it with a table
# descriptor + break-before-make TLB maintenance. Mirrors arm64_mprot_install_l3.
def arm64_mp_install_l3() -> int64:
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    if l2[cast[int64](P18_MMAP_L2_INDEX)] != cast[uint64](0):
        return 0                          # L3 already wired under this L2 slot

    l3: Ptr[uint64] = cast[Ptr[uint64]](P18_L3)
    i: int64 = 0
    while i < 512:
        l3[i] = cast[uint64](0)
        i = i + 1
    _dsb_ish()

    l2[cast[int64](P18_MMAP_L2_INDEX)] = P18_L3 | DESC_TABLE
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Pick the backing physical page for anon VA `va` by its page offset within the
# region. Page 0 -> P18_PAGE0, page 1 -> P18_PAGE1, page 2 -> P18_PAGE2. Returns 0
# for an out-of-range offset (never happens for a VA the VMA check already cleared).
def arm64_mp_backing_page(va: uint64) -> uint64:
    off: uint64 = va - P18_MMAP_BASE
    idx: uint64 = off >> cast[uint64](12)
    if idx == cast[uint64](0):
        return P18_PAGE0
    if idx == cast[uint64](1):
        return P18_PAGE1
    if idx == cast[uint64](2):
        return P18_PAGE2
    return cast[uint64](0)


# Map one fresh, zeroed physical page at anon VA `va` into the live TTBR0_EL1
# tables RW, then flush so EL0 sees the new translation. Mirrors the prior phases'
# map-page helpers but picks the per-page backing store. Returns the L3 index used.
def arm64_mp_map_page(va: uint64) -> uint64:
    arm64_mp_install_l3()

    page_pa: uint64 = arm64_mp_backing_page(va)

    # Zero the backing physical page (a fresh anon page must start clean).
    pg: Ptr[uint64] = cast[Ptr[uint64]](page_pa)
    j: int64 = 0
    while j < 512:
        pg[j] = cast[uint64](0)
        j = j + 1
    _dsb_ish()

    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P18_L3)
    l3[cast[int64](l3_index)] = page_pa | P18_PAGE_FLAGS

    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return l3_index


# Clear the live L3 mapping for anon VA `va` (used by the partial munmap to carve
# out the middle page). Break-only: zero the descriptor and flush so a later EL0
# touch genuinely translation-faults. Does NOT touch the surrounding pages.
def arm64_mp_unmap_page(va: uint64) -> int64:
    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P18_L3)
    l3[cast[int64](l3_index)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Walk the VMA table: return 1 iff `va` (page-aligned) lies inside SOME live slot's
# [base, base+len) span, else 0. This is the heart of Phase 18 — a real (small)
# VMA table, not a single latched span, so the split can leave a covered HOLE.
def arm64_mp_va_covered(va: uint64) -> int64:
    s: int64 = 0
    while cast[uint64](s) < P18_VMA_SLOTS:
        if arm64_mp_vma_live[s] != 0:
            base: uint64 = arm64_mp_vma_base[s]
            ln: uint64 = arm64_mp_vma_len[s]
            if va >= base:
                if va < (base + ln):
                    return 1
        s = s + 1
    return 0


# Phase-18 fault entry. Called from arm64_sync_handler for a data abort from EL0
# while the multi-page demo is live. Honours ONLY a TRANSLATION fault for a VA
# covered by a live VMA slot: demand-maps that page's fresh RW backing store and
# returns 1 so EL0 resumes its store. Returns 0 otherwise — in particular for a VA
# in the carved-out hole (no live slot), which the caller turns into a SIGSEGV.
def arm64_mp_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0                          # not a translation fault

    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    if arm64_mp_va_covered(page_va) == 0:
        return 0                          # in no live VMA slot (e.g. the hole)

    arm64_mp_map_page(page_va)
    arm64_mp_paged = 1
    arm64_mp_faults = arm64_mp_faults + 1
    m: Ptr[char] = "[arm64] multipage demand fault: paged in anon VA "
    _uart_puts(m)
    _uart_puthex(page_va)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    return 1


# Phase-18 fatal-fault path. Reached when arm64_mp_try_fault declines a data abort
# while the multi-page demo is live — i.e. EL0 touched a VA covered by NO live VMA
# slot (the carved-out middle page after the partial munmap split). Exactly a Linux
# SIGSEGV. Latch it and run the Phase-18 verdict. Never returns.
def arm64_mp_reap(esr: uint64) -> int64:
    far: uint64 = cast[uint64](_mrs_far_el1())
    elr: uint64 = cast[uint64](_mrs_elr_el1())

    m: Ptr[char] = "[arm64] multipage hole fault at VA "
    _uart_puts(m)
    _uart_puthex(far)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    pcm: Ptr[char] = "[arm64] multipage SIGSEGV PC (ELR_EL1)="
    _uart_puts(pcm)
    _uart_puthex(elr)
    _uart_puts(nl)

    # The hole is only valid as a SIGSEGV once the split has happened.
    if arm64_mp_split != 0:
        arm64_mp_segv = 1
        seg: Ptr[char] = "[arm64] multipage touch of unmapped hole denied (no VMA)\n"
        _uart_puts(seg)
    arm64_mp_finish()
    # Unreachable: arm64_mp_finish halts. Safety loop if it falls through.
    while True:
        _wfi()
    return 0


# Materialise the Phase-18 EL0 routine into USER_CODE_BASE:
#   mmap(3*4KiB): x0=len; x8=222; svc #0       -> x0 = anon base (== P18_MMAP_BASE)
#   x10 = base
#   str s0,[x10+0x0000]   -> translation fault page 0; kernel demand-maps page 0
#   str s1,[x10+0x1000]   -> translation fault page 1; kernel demand-maps page 1
#   str s2,[x10+0x2000]   -> translation fault page 2; kernel demand-maps page 2
#   ldr each back; report(r0,r1,r2): x0,x1,x2; x8=544; svc #0
#   munmap(base+0x1000, 4KiB): x0; x1; x8=215; svc #0   -> SPLITS the VMA
#   ldr base+0; ldr base+0x2000; survive(r0,r2): x0,x1; x8=545; svc #0
#   write(1,msg,len): x8=64; svc #0
#   str s3,[x10+0x1000]   -> translation fault in the HOLE -> SIGSEGV (reaper)
# We reuse the scaled unsigned-offset STR/LDR encodings: the imm12 is the byte
# offset >> 3 (8-byte access scale). offsets 0,0x1000,0x2000 -> imm12 0,512,1024.
def arm64_build_multipage_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE

    # mmap(len): x0 = len; x8 = 222; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P18_MMAP_LEN)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MMAP_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x10 = base (== P18_MMAP_BASE)
    a = _emit_load_imm64(a, cast[uint64](10), P18_MMAP_BASE)

    # str s0,[x10+#0]    (imm12 = 0)   -- FAULTS page 0, demand-maps it
    a = _emit_load_imm64(a, cast[uint64](9), P18_SENTINEL0)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](0) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # str s1,[x10+#0x1000]  (imm12 = 0x1000>>3 = 512) -- FAULTS page 1
    a = _emit_load_imm64(a, cast[uint64](9), P18_SENTINEL1)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](512) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # str s2,[x10+#0x2000]  (imm12 = 0x2000>>3 = 1024) -- FAULTS page 2
    a = _emit_load_imm64(a, cast[uint64](9), P18_SENTINEL2)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](1024) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # ldr x0,[x10+#0]; ldr x1,[x10+#0x1000]; ldr x2,[x10+#0x2000]
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](0) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](512) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](1))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](1024) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](2))
    # report(x0,x1,x2): x8 = 544; svc #0  (x0..x2 already hold the read-backs)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MP_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # munmap(base+0x1000, 4KiB): x0 = base+0x1000; x1 = 0x1000; x8 = 215; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P18_MMAP_BASE + cast[uint64](0x1000))
    a = _emit_load_imm64(a, cast[uint64](1), cast[uint64](0x1000))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MUNMAP_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # ldr x0,[x10+#0]; ldr x1,[x10+#0x2000]   (the two SURVIVING pages)
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](0) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](1024) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](1))
    # survive(x0,x1): x8 = 545; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MP_SURVIVE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 64; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), P18_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # str s3,[x10+#0x1000]   (HOLE -> translation fault, NO live VMA -> reaper)
    a = _emit_load_imm64(a, cast[uint64](9), P18_SENTINEL3)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](512) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # exit(0): only reached if the hole store were (wrongly) allowed
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-18 syscall dispatcher. Routed from arm64_sync_handler while the multi-page
# demo is live. Services mmap (record ONE whole-span VMA + return base), the pre-
# munmap report (verify the three demand-paged read-backs landed in three distinct
# pages), munmap (the PARTIAL middle-page unmap that SPLITS the VMA), the survive
# report (the two surviving pages stayed mapped), write, and a defensive exit.
def arm64_mp_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_MMAP_NR:
        # Anonymous multi-page mmap: record ONE VMA [base, base+len) in slot 0; the
        # other slots stay empty until the split. No page mapped here — lazy.
        arm64_mp_vma_base[0] = P18_MMAP_BASE
        arm64_mp_vma_len[0] = a0
        arm64_mp_vma_live[0] = 1
        s: int64 = 1
        while cast[uint64](s) < P18_VMA_SLOTS:
            arm64_mp_vma_base[s] = cast[uint64](0)
            arm64_mp_vma_len[s] = cast[uint64](0)
            arm64_mp_vma_live[s] = 0
            s = s + 1
        m: Ptr[char] = "[arm64] EL0 mmap(anon multi, len="
        _uart_puts(m)
        _uart_puthex(a0)
        sep: Ptr[char] = ") -> base "
        _uart_puts(sep)
        _uart_puthex(P18_MMAP_BASE)
        _uart_puts(nl)
        frame_ptr[0] = P18_MMAP_BASE
        return 0

    if nr == SYS_MP_REPORT_NR:
        arm64_mp_rd0 = a0
        arm64_mp_rd1 = a1
        arm64_mp_rd2 = a2
        r: Ptr[char] = "[arm64] EL0 multipage read-back p0="
        _uart_puts(r)
        _uart_puthex(a0)
        r1: Ptr[char] = " p1="
        _uart_puts(r1)
        _uart_puthex(a1)
        r2: Ptr[char] = " p2="
        _uart_puts(r2)
        _uart_puthex(a2)
        _uart_puts(nl)
        # Independently confirm each backing physical page holds its sentinel — and
        # that the three pages are DISTINCT (page 1 differs from pages 0/2).
        b0: Ptr[uint64] = cast[Ptr[uint64]](P18_PAGE0)
        b1: Ptr[uint64] = cast[Ptr[uint64]](P18_PAGE1)
        b2: Ptr[uint64] = cast[Ptr[uint64]](P18_PAGE2)
        pm: Ptr[char] = "[arm64] multipage backing phys p0="
        _uart_puts(pm)
        _uart_puthex(b0[0])
        pm1: Ptr[char] = " p1="
        _uart_puts(pm1)
        _uart_puthex(b1[0])
        pm2: Ptr[char] = " p2="
        _uart_puts(pm2)
        _uart_puthex(b2[0])
        _uart_puts(nl)
        good: int64 = 0
        if a0 == P18_SENTINEL0:
            if a1 == P18_SENTINEL1:
                if a2 == P18_SENTINEL2:
                    if b0[0] == P18_SENTINEL0:
                        if b1[0] == P18_SENTINEL1:
                            if b2[0] == P18_SENTINEL2:
                                good = 1
        if good != 0:
            ok: Ptr[char] = "[arm64] multipage 3-page demand store/load OK\n"
            _uart_puts(ok)
        else:
            bad: Ptr[char] = "[arm64] multipage read-back mismatch FAIL\n"
            _uart_puts(bad)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_MUNMAP_NR:
        # PARTIAL munmap of the MIDDLE page: clear its L3 entry AND split the single
        # VMA (slot 0) into the LOW survivor [base, addr) plus the HIGH survivor
        # [addr+len, base+orig_len). The middle [addr, addr+len) becomes a hole.
        m: Ptr[char] = "[arm64] EL0 munmap(partial, addr="
        _uart_puts(m)
        _uart_puthex(a0)
        sep: Ptr[char] = ", len="
        _uart_puts(sep)
        _uart_puthex(a1)
        _uart_puts(nl)

        orig_base: uint64 = arm64_mp_vma_base[0]
        orig_len: uint64 = arm64_mp_vma_len[0]
        orig_end: uint64 = orig_base + orig_len
        hole_end: uint64 = a0 + a1

        # Drop the physical mapping for the carved-out middle page so a later touch
        # genuinely translation-faults.
        arm64_mp_unmap_page(a0)

        # Rewrite the VMA table: slot 0 becomes the LOW survivor, slot 1 the HIGH
        # survivor. If a survivor is empty (zero length) leave its slot dead.
        low_len: uint64 = a0 - orig_base
        if low_len != cast[uint64](0):
            arm64_mp_vma_base[0] = orig_base
            arm64_mp_vma_len[0] = low_len
            arm64_mp_vma_live[0] = 1
        else:
            arm64_mp_vma_live[0] = 0

        high_len: uint64 = orig_end - hole_end
        if high_len != cast[uint64](0):
            arm64_mp_vma_base[1] = hole_end
            arm64_mp_vma_len[1] = high_len
            arm64_mp_vma_live[1] = 1
        else:
            arm64_mp_vma_live[1] = 0

        arm64_mp_split = 1
        sp: Ptr[char] = "[arm64] munmap split VMA: low [base,hole) + high [hole_end,end)\n"
        _uart_puts(sp)
        lo: Ptr[char] = "[arm64] multipage VMA split survivors low_base="
        _uart_puts(lo)
        _uart_puthex(orig_base)
        lo2: Ptr[char] = " low_len="
        _uart_puts(lo2)
        _uart_puthex(low_len)
        hi: Ptr[char] = " high_base="
        _uart_puts(hi)
        _uart_puthex(hole_end)
        hi2: Ptr[char] = " high_len="
        _uart_puts(hi2)
        _uart_puthex(high_len)
        _uart_puts(nl)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_MP_SURVIVE_NR:
        arm64_mp_surv0 = a0
        arm64_mp_surv2 = a1
        r: Ptr[char] = "[arm64] EL0 post-split survivors p0="
        _uart_puts(r)
        _uart_puthex(a0)
        r2: Ptr[char] = " p2="
        _uart_puts(r2)
        _uart_puthex(a1)
        _uart_puts(nl)
        if a0 == P18_SENTINEL0:
            if a1 == P18_SENTINEL2:
                ok: Ptr[char] = "[arm64] multipage split survivors still mapped OK\n"
                _uart_puts(ok)
            else:
                bad: Ptr[char] = "[arm64] multipage survivor mismatch FAIL\n"
                _uart_puts(bad)
        else:
            bad2: Ptr[char] = "[arm64] multipage survivor mismatch FAIL\n"
            _uart_puts(bad2)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(18) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_EXIT_NR:
        # Reached only if the post-split HOLE store were (wrongly) allowed instead of
        # faulting. The verdict will FAIL because arm64_mp_segv stays 0.
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit(18) serviced (hole store did NOT fault!)\n"
        _uart_puts(em)
        arm64_mp_finish()
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 18)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-18 finish: print PASS iff all three anon pages were demand-paged (EXACTLY
# three translation faults), the three pre-munmap read-backs matched their distinct
# sentinels, the partial munmap SPLIT the VMA, the two surviving pages stayed mapped
# (read-backs matched), AND the post-split touch of the carved hole faulted with no
# live VMA. Report the fault count, then halt deterministically. Never returns.
def arm64_mp_finish() -> int64:
    arm64_mp_active = 0
    nl: Ptr[char] = "\n"
    fc: Ptr[char] = "[arm64] multipage demand faults serviced -> "
    _uart_puts(fc)
    _uart_puthex(cast[uint64](arm64_mp_faults))
    _uart_puts(nl)

    ok: int64 = 0
    if arm64_mp_paged != 0:
        if arm64_mp_faults == 3:
            if arm64_mp_rd0 == P18_SENTINEL0:
                if arm64_mp_rd1 == P18_SENTINEL1:
                    if arm64_mp_rd2 == P18_SENTINEL2:
                        if arm64_mp_split != 0:
                            if arm64_mp_surv0 == P18_SENTINEL0:
                                if arm64_mp_surv2 == P18_SENTINEL2:
                                    if arm64_mp_segv != 0:
                                        ok = 1
    if ok != 0:
        sm: Ptr[char] = "[arm64] multipage mmap split; survivors mapped, hole faults\n"
        _uart_puts(sm)
        pm: Ptr[char] = "[arm64] EL0 multipage mmap split OK\n"
        _uart_puts(pm)
        # Phase 18 complete and clean. Hand off to Phase 19 (two preemptively-
        # scheduled EL0 tasks, each in its OWN TTBR0_EL1 address space + ASID, with
        # the timer-IRQ context switch swapping TTBR0+ASID as well as registers).
        # IRQs are masked here; arm64_run_dualspace_demo re-enables the timer and
        # never returns (it halts after its own PASS).
        arm64_run_dualspace_demo()
        # Unreachable: arm64_run_dualspace_demo never returns. Safety loop.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 multipage mmap split FAIL\n"
        _uart_puts(fm)
    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-18 entry point (invoked from the Phase-17 finish hand-off). Restore the
# kernel's identity TTBR0, force the multi-page window's L2 slot UNMAPPED (so the
# first touch of each page genuinely translation-faults), seed bookkeeping, build
# the EL0 routine, arm Phase-18 dispatch, and ERET into the task at EL0t with IRQs
# masked. Never returns (the task faults fatally in the hole, handing to the reaper).
def arm64_run_multipage_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 18: multi-page mmap + partial munmap that splits a VMA\n"
    _uart_puts(intro)

    # Restore the kernel's identity-only TTBR0, then flush for a clean state.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Force the multi-page window's L2 slot UNMAPPED so the first touch of each page
    # raises a translation Data Abort (a clean, repeatable initial state).
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P18_MMAP_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Seed Phase-18 bookkeeping (empty VMA table + cleared latches/counters).
    s: int64 = 0
    while cast[uint64](s) < P18_VMA_SLOTS:
        arm64_mp_vma_base[s] = cast[uint64](0)
        arm64_mp_vma_len[s] = cast[uint64](0)
        arm64_mp_vma_live[s] = 0
        s = s + 1
    arm64_mp_faults = 0
    arm64_mp_paged = 0
    arm64_mp_split = 0
    arm64_mp_rd0 = cast[uint64](0)
    arm64_mp_rd1 = cast[uint64](0)
    arm64_mp_rd2 = cast[uint64](0)
    arm64_mp_surv0 = cast[uint64](0)
    arm64_mp_surv2 = cast[uint64](0)
    arm64_mp_segv = 0

    mpmsg: Ptr[char] = "Hello from a multi-page anonymous mmap region\n"
    msg_len: uint64 = _copy_msg_to(mpmsg, P18_MSG_BASE)
    arm64_build_multipage_routine(msg_len)

    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_mp_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 multi-page mmap task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; mmap, touch 3 pages (faults), report,
    return 0                           #    partial munmap (split), survive, hole-fault


# ===========================================================================
# Phase 19 — two preemptively-scheduled EL0 tasks, EACH with its OWN TTBR0_EL1
# address space + ASID; the timer-IRQ context switch swaps TTBR0+ASID too.
# ===========================================================================

# Build one task-private address space at (l1_base, l2_base): a full clone of the
# kernel identity map (so the EL0 code window stays fetchable and the kernel stays
# mapped EL1-only) plus an EL0-RWX mapping of P19_SHARED_VA -> this task's PRIVATE
# physical block. Seeds `sentinel` into byte 0 of that block (written through the
# boot identity map, which is still live). data_pa must be 2 MiB-aligned. Mirrors
# arm64_iso_build_space but for the Phase-19 shared VA / L2 slot.
def arm64_p19_build_space(l1_base: uint64, l2_base: uint64, data_pa: uint64, sentinel: uint64) -> int64:
    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    # Zero the L1 table (anything unmapped faults).
    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1

    # L1[0]: VA 0x0..0x3FFF_FFFF -> Device-nGnRE (GIC + UART), EL1-only.
    l1[0] = cast[uint64](0) | DEV_FLAGS

    # L2 covering the RAM 1 GiB block in 2 MiB pieces. Most blocks Normal-WB
    # EL1-only; the EL0 code/stack window (USER_L2_INDEX) is EL0-RWX (so each
    # task's instruction pages + stacks remain reachable under its own TTBR0);
    # the shared-VA block is EL0-RWX but mapped to this task's PRIVATE physical
    # block (the per-task isolation linchpin).
    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0
        elif cast[uint64](j) == P19_SHARED_L2_INDEX:
            l2[j] = data_pa | MEM_FLAGS_EL0
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    # L1[1] = table descriptor -> this task's L2 table.
    l1[1] = l2_base | DESC_TABLE

    # Seed the private data block's sentinel (byte 0) through the boot identity map.
    dp: Ptr[uint8] = cast[Ptr[uint8]](data_pa)
    dp[0] = cast[uint8](sentinel & cast[uint64](0xFF))
    _dsb_ish()
    return 0


# Materialise a Phase-19 EL0 task into `code_base`:
#   loop:
#     x1 = P19_SHARED_VA ; ldrb w0,[x1]    (read this task's private sentinel)
#     x8 = 546 (dual-space report) ; svc #0 (hand the byte to the kernel)
#     x9 = busy ; busy: subs x9,x9,#1 ; b.ne busy
#     b loop
# The report syscall RETURNS to EL0 (unlike Phase 7) so the task keeps looping and
# the timer keeps preempting it. Control only leaves via the preemptive timer IRQ.
def arm64_p19_build_task(code_base: uint64) -> int64:
    a: uint64 = code_base
    loop_top: uint64 = a

    # x1 = P19_SHARED_VA ; ldrb w0,[x1]   (LDRB imm, unsigned offset 0, Wt=0, Xn=1)
    a = _emit_load_imm64(a, cast[uint64](1), P19_SHARED_VA)
    a = _emit_word(a, cast[uint64](0x39400020))
    # x8 = 546 ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P19_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x9 = 0x40000 busy-loop counter (movz x9,#0x4,lsl #16).
    movz_x9: uint64 = cast[uint64](0xD2800000) | (cast[uint64](1) << cast[uint64](21)) | (cast[uint64](4) << cast[uint64](5)) | cast[uint64](9)
    a = _emit_word(a, movz_x9)
    busy_top: uint64 = a
    a = _emit_word(a, cast[uint64](0xF1000529))             # subs x9,x9,#1
    bne_here: uint64 = a
    off_busy: int64 = cast[int64](busy_top) - cast[int64](bne_here)
    imm19_busy: uint64 = cast[uint64](off_busy >> 2) & cast[uint64](0x7FFFF)
    a = _emit_word(a, cast[uint64](0x54000001) | (imm19_busy << cast[uint64](5)))   # b.ne busy

    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)     # b loop

    _dsb_ish()
    _isb()
    return 0


# Compute the TTBR0_EL1 value for task `idx`: the task's private L1 root with its
# ASID baked into bits[63:48]. Distinct ASIDs let both tasks' translations coexist
# in the TLB so a swap needs no broad flush.
def arm64_p19_ttbr0_for(idx: int64) -> uint64:
    if idx == 0:
        return P19_A_L1 | (P19_ASID_A << P19_ASID_SHIFT)
    return P19_B_L1 | (P19_ASID_B << P19_ASID_SHIFT)


# Switch the live address space to task `idx`: point TTBR0_EL1 at its private root
# WITH its ASID, then isb to resynchronise. CRUCIALLY there is NO `tlbi vmalle1is`
# here — the per-ASID tagging is what keeps the two tasks' translations of the
# SAME shared VA distinct. dsb orders the prior table writes before the TTBR0
# write; isb makes the new context effective for the subsequent EL0 fetches/loads.
def arm64_p19_switch_to(idx: int64) -> int64:
    ttbr0: uint64 = arm64_p19_ttbr0_for(idx)
    _dsb_ish()
    _msr_ttbr0_el1(ttbr0)
    _isb()
    return 0


# Phase-19 IRQ scheduler — invoked (via arm64_sched_pick) from the EL0 IRQ vector
# with the running task's register context already saved into its context block.
# Ack + re-arm the timer, round-robin to the OTHER task, swap TTBR0+ASID to that
# task's PRIVATE address space (no broad TLB flush — ASID-tagged), publish its
# context block as current, and return it so the .S stub restores+erets into it.
# After P19_GOAL swaps the demo's invariant (every read stayed private) is proven;
# run the verdict (never returns).
def arm64_p19_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this task
        return cur_ctx

    # Quiesce, re-arm, and EOI the timer.
    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_p19_swaps = arm64_p19_swaps + 1
    swmsg: Ptr[char] = "[arm64] dualspace TTBR0+ASID swap\n"
    _uart_puts(swmsg)

    if arm64_p19_swaps >= P19_GOAL:
        arm64_p19_finish()
        # Unreachable: arm64_p19_finish halts. Safety loop.
        while True:
            _wfi()

    # Round-robin to the other task and swap into its private address space.
    next_ctx: uint64 = P19_B_CTX
    if arm64_p19_cur == 0:
        arm64_p19_cur = 1
        next_ctx = P19_B_CTX
    else:
        arm64_p19_cur = 0
        next_ctx = P19_A_CTX

    arm64_p19_switch_to(arm64_p19_cur)      # TTBR0+ASID -> the incoming task
    arm64_current_ctx = next_ctx            # publish for the next preemption
    return next_ctx


# Phase-19 syscall dispatcher. Routed from arm64_sync_handler while the dual-space
# demo is live. Services the per-task "dual-space report": the byte the running
# task read at P19_SHARED_VA through its OWN TTBR0+ASID. Tally a CORRECT read (the
# task's own sentinel) or a LEAK (the OTHER task's sentinel — would mean an ASID-
# untagged stale TLB entry leaked across the swap). Returns 0 so EL0 resumes its
# loop (the timer, not this syscall, drives the context switches).
def arm64_p19_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P19_REPORT_NR:
        arm64_p19_reports = arm64_p19_reports + 1
        val: uint64 = a0 & cast[uint64](0xFF)
        if arm64_p19_cur == 0:
            # Task A: its own sentinel is A; B's sentinel is a cross-task leak.
            if val == P19_SENTINEL_A:
                arm64_p19_a_correct = arm64_p19_a_correct + 1
            elif val == P19_SENTINEL_B:
                arm64_p19_leaks = arm64_p19_leaks + 1
                lk: Ptr[char] = "[arm64] dualspace LEAK: task A read B's sentinel FAIL\n"
                _uart_puts(lk)
        else:
            if val == P19_SENTINEL_B:
                arm64_p19_b_correct = arm64_p19_b_correct + 1
            elif val == P19_SENTINEL_A:
                arm64_p19_leaks = arm64_p19_leaks + 1
                lk2: Ptr[char] = "[arm64] dualspace LEAK: task B read A's sentinel FAIL\n"
                _uart_puts(lk2)
        # Trace the FIRST report from each task (so the log shows BOTH A and B
        # reading their private sentinel through their own TTBR0+ASID), keeping the
        # rest of the busy-loop's reports out of the log.
        trace: int64 = 0
        if arm64_p19_cur == 0:
            if arm64_p19_a_correct == 1:
                trace = 1
        else:
            if arm64_p19_b_correct == 1:
                trace = 1
        if trace != 0:
            r: Ptr[char] = "[arm64] dualspace report: task "
            _uart_puts(r)
            _uart_puthex(cast[uint64](arm64_p19_cur))
            rv: Ptr[char] = " read VA value="
            _uart_puts(rv)
            _uart_puthex(val)
            _uart_puts(nl)
        frame_ptr[0] = cast[uint64](0)
        return 0

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 19)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-19 verdict. Reached from the scheduler once P19_GOAL TTBR0+ASID swaps have
# happened. PASS iff BOTH tasks actually ran (each reported its own sentinel at
# least once) AND zero cross-task leaks occurred — i.e. across every preemptive
# swap each task's private translation of the SHARED VA stayed private, proving
# ASID-tagged dual-address-space multitasking. Print the tallies, then halt.
def arm64_p19_finish() -> int64:
    arm64_p19_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] dualspace swaps="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p19_swaps))
    am: Ptr[char] = " a_correct="
    _uart_puts(am)
    _uart_puthex(cast[uint64](arm64_p19_a_correct))
    bm: Ptr[char] = " b_correct="
    _uart_puts(bm)
    _uart_puthex(cast[uint64](arm64_p19_b_correct))
    lm: Ptr[char] = " leaks="
    _uart_puts(lm)
    _uart_puthex(cast[uint64](arm64_p19_leaks))
    _uart_puts(nl)

    ok: int64 = 0
    if arm64_p19_a_correct > 0:
        if arm64_p19_b_correct > 0:
            if arm64_p19_leaks == 0:
                ok = 1
    if ok != 0:
        em: Ptr[char] = "[arm64] dualspace both tasks ran private; ASID isolation held\n"
        _uart_puts(em)
        pm: Ptr[char] = "[arm64] EL0 dual-address-space ASID sched OK\n"
        _uart_puts(pm)
        # Phase 19 complete and clean. Hand off to Phase 20 (dynamic task spawn +
        # exit/reaping). IRQs are masked here; arm64_run_spawn_demo re-enables the
        # timer and ERETs into the first task; it never returns.
        arm64_run_spawn_demo()
        # Unreachable: arm64_run_spawn_demo never returns. Safety halt.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 dual-address-space ASID sched FAIL\n"
        _uart_puts(fm)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-19 entry point (invoked from the Phase-18 finish hand-off). Build both
# task-private address spaces (+ seed sentinels), the two EL0 task routines, and
# their context blocks; flush any stale translations for BOTH ASIDs once; then
# ERET into task A under its private TTBR0+ASID with the timer LIVE so the IRQ
# scheduler round-robins the two tasks, swapping TTBR0+ASID on every tick. Never
# returns (the scheduler halts after its own PASS).
def arm64_run_dualspace_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 19: dual-address-space preemptive scheduling with per-task ASID\n"
    _uart_puts(intro)

    # Mask EL1 IRQs while we build everything so a stray timer IRQ cannot run the
    # scheduler mid-setup; re-enable just before the ERET into task A.
    _msr_daifset(2)

    # Build the two private address spaces (clone identity + private shared-VA map)
    # and seed their distinct sentinels.
    arm64_p19_build_space(P19_A_L1, P19_A_L2, P19_A_DATA, P19_SENTINEL_A)
    arm64_p19_build_space(P19_B_L1, P19_B_L2, P19_B_DATA, P19_SENTINEL_B)

    # Build the two EL0 task routines (read-private-sentinel + report + busy-loop).
    arm64_p19_build_task(P19_A_CODE)
    arm64_p19_build_task(P19_B_CODE)

    # Initialise each task's context block to start cleanly at its code entry, on
    # its own stack, in EL0t with IRQs UNMASKED (so the timer preempts it).
    arm64_init_ctx(P19_A_CTX, P19_A_CODE, P19_A_STACK_TOP)
    arm64_init_ctx(P19_B_CTX, P19_B_CODE, P19_B_STACK_TOP)

    # Clear any stale TLB entries for BOTH ASIDs before first use (recycling clean
    # ASIDs), then seed bookkeeping. The per-ASID invalidate is the maintenance a
    # real scheduler does when it (re)assigns an ASID; thereafter swaps need none.
    _dsb_ish()
    _tlbi_aside1is(P19_ASID_A << P19_ASID_SHIFT)
    _tlbi_aside1is(P19_ASID_B << P19_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p19_cur = 0
    arm64_p19_swaps = 0
    arm64_p19_a_correct = 0
    arm64_p19_b_correct = 0
    arm64_p19_leaks = 0
    arm64_p19_reports = 0
    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_current_ctx = P19_A_CTX
    arm64_p19_active = 1

    enter: Ptr[char] = "[arm64] launching dual-address-space EL0 tasks (ASID A=1, B=2)\n"
    _uart_puts(enter)

    # Switch into task A's private address space (TTBR0+ASID A), re-arm + enable the
    # timer, unmask EL1 IRQs, then ERET into task A at EL0t with IRQs unmasked.
    arm64_p19_switch_to(0)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](P19_A_CTX)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> task A at EL0 under TTBR0+ASID A
    return 0


# ===========================================================================
# Phase 20 — DYNAMIC TASK SPAWN + EXIT/REAPING on aarch64.
# ===========================================================================

# Per-slot accessors. Adder has no arrays-of-globals, so route the slot index to
# the slot's fixed constant. (Kept tiny and branchy on purpose — three slots.)
def arm64_p20_l1_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_A_L1
    if idx == 1:
        return P20_B_L1
    return P20_C_L1

def arm64_p20_l2_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_A_L2
    if idx == 1:
        return P20_B_L2
    return P20_C_L2

def arm64_p20_data_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_A_DATA
    if idx == 1:
        return P20_B_DATA
    return P20_C_DATA

def arm64_p20_sentinel_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_SENTINEL_A
    if idx == 1:
        return P20_SENTINEL_B
    return P20_SENTINEL_C

def arm64_p20_asid_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_ASID_A
    if idx == 1:
        return P20_ASID_B
    return P20_ASID_C

def arm64_p20_code_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_A_CODE
    if idx == 1:
        return P20_B_CODE
    return P20_C_CODE

def arm64_p20_stack_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_A_STACK_TOP
    if idx == 1:
        return P20_B_STACK_TOP
    return P20_C_STACK_TOP

def arm64_p20_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_A_CTX
    if idx == 1:
        return P20_B_CTX
    return P20_C_CTX

def arm64_p20_state_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p20_state0
    if idx == 1:
        return arm64_p20_state1
    return arm64_p20_state2

def arm64_p20_set_state(idx: int64, st: int64) -> int64:
    if idx == 0:
        arm64_p20_state0 = st
    elif idx == 1:
        arm64_p20_state1 = st
    else:
        arm64_p20_state2 = st
    return 0


# Build slot `idx`'s private address space at its (l1,l2): a full clone of the
# kernel identity map (EL0 code/stack window stays fetchable, kernel stays EL1-
# only) plus an EL0-RWX mapping of P20_SHARED_VA -> this slot's PRIVATE physical
# block, seeded (byte 0) with the slot's sentinel through the boot identity map.
def arm64_p20_build_space(idx: int64) -> int64:
    l1_base: uint64 = arm64_p20_l1_for(idx)
    l2_base: uint64 = arm64_p20_l2_for(idx)
    data_pa: uint64 = arm64_p20_data_for(idx)
    sentinel: uint64 = arm64_p20_sentinel_for(idx)

    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1

    # L1[0]: device window (GIC + UART), EL1-only.
    l1[0] = cast[uint64](0) | DEV_FLAGS

    # L2 for the RAM 1 GiB block: most EL1-only Normal-WB; the EL0 code/stack
    # window EL0-RWX; the shared-VA block EL0-RWX -> this slot's PRIVATE block.
    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0
        elif cast[uint64](j) == P20_SHARED_L2_INDEX:
            l2[j] = data_pa | MEM_FLAGS_EL0
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = l2_base | DESC_TABLE

    dp: Ptr[uint8] = cast[Ptr[uint8]](data_pa)
    dp[0] = cast[uint8](sentinel & cast[uint64](0xFF))
    _dsb_ish()
    return 0


# Materialise slot `idx`'s EL0 routine:
#   loop:
#     x1 = P20_SHARED_VA ; ldrb w0,[x1]           (read this slot's private byte)
#     x8 = 547 (tick) ; svc #0                    (hand the byte to the kernel)
#     busy-loop
#     b loop
# Every slot's emitted routine is the same self-looping read+report+busy body. A
# slot that should EXIT (slot A) is steered into an exit stub kernel-side once its
# report count reaches the threshold (see arm64_p20_dispatch / _redirect_to_exit),
# so the routine itself needs no exit logic baked in.
def arm64_p20_build_task(idx: int64) -> int64:
    code_base: uint64 = arm64_p20_code_for(idx)
    a: uint64 = code_base
    loop_top: uint64 = a

    # x1 = P20_SHARED_VA ; ldrb w0,[x1]  (LDRB imm, offset 0, Wt=0, Xn=1)
    a = _emit_load_imm64(a, cast[uint64](1), P20_SHARED_VA)
    a = _emit_word(a, cast[uint64](0x39400020))
    # x8 = 547 (tick) ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P20_TICK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x9 = 0x40000 busy-loop counter (movz x9,#0x4,lsl #16).
    movz_x9: uint64 = cast[uint64](0xD2800000) | (cast[uint64](1) << cast[uint64](21)) | (cast[uint64](4) << cast[uint64](5)) | cast[uint64](9)
    a = _emit_word(a, movz_x9)
    busy_top: uint64 = a
    a = _emit_word(a, cast[uint64](0xF1000529))             # subs x9,x9,#1
    bne_here: uint64 = a
    off_busy: int64 = cast[int64](busy_top) - cast[int64](bne_here)
    imm19_busy: uint64 = cast[uint64](off_busy >> 2) & cast[uint64](0x7FFFF)
    a = _emit_word(a, cast[uint64](0x54000001) | (imm19_busy << cast[uint64](5)))  # b.ne busy

    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)     # b loop

    _dsb_ish()
    _isb()
    return 0


# TTBR0_EL1 for slot `idx`: its private L1 root with its ASID in bits[63:48].
def arm64_p20_ttbr0_for(idx: int64) -> uint64:
    return arm64_p20_l1_for(idx) | (arm64_p20_asid_for(idx) << P20_ASID_SHIFT)


# Switch the live address space to slot `idx` (TTBR0+ASID). No broad TLB flush —
# per-ASID tagging keeps each slot's translation of the shared VA distinct.
def arm64_p20_switch_to(idx: int64) -> int64:
    _dsb_ish()
    _msr_ttbr0_el1(arm64_p20_ttbr0_for(idx))
    _isb()
    return 0


# Pick the next RUNNABLE slot after `from_idx`, round-robin over slots 0..2,
# skipping EMPTY and REAPED slots. Returns -1 if no slot is runnable.
def arm64_p20_next_runnable(from_idx: int64) -> int64:
    steps: int64 = 0
    idx: int64 = from_idx
    while steps < 3:
        idx = idx + 1
        if idx >= 3:
            idx = 0
        if arm64_p20_state_for(idx) == P20_SLOT_RUNNABLE:
            return idx
        steps = steps + 1
    return -1


# Dynamically spawn slot C at runtime: build its brand-new private address space
# (+ seed sentinel C), a fresh EL0 routine, a fresh context block, recycle ASID C's
# TLB, and mark the slot RUNNABLE. This is the fork-like creation — nothing about
# slot C existed before this call; it is wired up entirely after the demo started.
def arm64_p20_spawn_c() -> int64:
    sp: Ptr[char] = "[arm64] spawn: dynamically creating slot C (ASID 6) at runtime\n"
    _uart_puts(sp)

    arm64_p20_build_space(2)
    arm64_p20_build_task(2)
    arm64_init_ctx(arm64_p20_ctx_for(2), arm64_p20_code_for(2), arm64_p20_stack_for(2))

    # Recycle slot C's ASID in the TLB before first use, as a real scheduler does
    # when (re)assigning an ASID; thereafter swaps into C need no broad flush.
    _dsb_ish()
    _tlbi_aside1is(P20_ASID_C << P20_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p20_set_state(2, P20_SLOT_RUNNABLE)
    arm64_p20_c_spawned = 1
    arm64_p20_swaps_at_spawn = arm64_p20_swaps
    return 0


# Phase-20 IRQ scheduler — invoked (via arm64_sched_pick) from the EL0 IRQ vector
# with the running slot's register context already saved. Ack + re-arm the timer,
# then:
#   * if slot A has just been reaped and slot C has NOT yet been spawned, SPAWN C
#     dynamically (proving runtime task creation);
#   * round-robin to the next RUNNABLE slot, swapping TTBR0+ASID into its PRIVATE
#     space (no broad TLB flush — ASID-tagged), publish its ctx, and return it.
# After P20_GOAL swaps PAST the spawn the demo's invariants are checked; run the
# verdict (never returns).
def arm64_p20_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this slot
        return cur_ctx

    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_p20_swaps = arm64_p20_swaps + 1
    swmsg: Ptr[char] = "[arm64] spawn-demo TTBR0+ASID swap\n"
    _uart_puts(swmsg)

    # Once slot A has been reaped, dynamically spawn slot C (exactly once).
    if arm64_p20_a_reaped != 0:
        if arm64_p20_c_spawned == 0:
            arm64_p20_spawn_c()

    # Verdict once we have run enough swaps AFTER the spawn (so both the survivor B
    # and the freshly-spawned C have demonstrably run preemptively).
    if arm64_p20_c_spawned != 0:
        if (arm64_p20_swaps - arm64_p20_swaps_at_spawn) >= P20_GOAL:
            arm64_p20_finish()
            while True:
                _wfi()

    nxt: int64 = arm64_p20_next_runnable(arm64_p20_cur)
    if nxt < 0:
        # No runnable slot (should not happen while B is alive). Stay put.
        return cur_ctx

    arm64_p20_cur = nxt
    arm64_p20_switch_to(nxt)                 # TTBR0+ASID -> the incoming slot
    next_ctx: uint64 = arm64_p20_ctx_for(nxt)
    arm64_current_ctx = next_ctx
    return next_ctx


# Phase-20 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. Services:
#   SYS_P20_TICK_NR (547): the byte the running slot read at P20_SHARED_VA through
#       its OWN TTBR0+ASID. Tally a CORRECT read (own sentinel) or a LEAK (another
#       slot's sentinel). Slot A, after P20_A_EXIT_AT reports, is steered into an
#       exit stub (its eret ELR is rewritten so its NEXT EL0 instruction issues
#       exit(7)). Returns 0 so EL0 resumes (at the loop, or — for A past the
#       threshold — at the exit stub).
#   SYS_EXIT_NR (93): the running slot exits; mark its slot REAPED so the scheduler
#       never selects it again, then park its dead EL0 PC on a self-branch.
def arm64_p20_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P20_TICK_NR:
        val: uint64 = a0 & cast[uint64](0xFF)
        own: uint64 = arm64_p20_sentinel_for(arm64_p20_cur)

        # Tally correctness / leaks for the running slot.
        if arm64_p20_cur == 0:
            arm64_p20_a_reports = arm64_p20_a_reports + 1
            if val == own:
                arm64_p20_a_correct = arm64_p20_a_correct + 1
        elif arm64_p20_cur == 1:
            arm64_p20_b_reports = arm64_p20_b_reports + 1
            if val == own:
                arm64_p20_b_correct = arm64_p20_b_correct + 1
            if arm64_p20_c_spawned != 0:
                arm64_p20_b_after_spawn = arm64_p20_b_after_spawn + 1
        else:
            arm64_p20_c_reports = arm64_p20_c_reports + 1
            if val == own:
                arm64_p20_c_correct = arm64_p20_c_correct + 1

        # A read of a value that is neither this slot's own sentinel nor 0 is a
        # cross-task leak (a stale, ASID-untagged TLB entry resolving to another
        # slot's private block).
        if val != own:
            if val != cast[uint64](0):
                arm64_p20_leaks = arm64_p20_leaks + 1
                lk: Ptr[char] = "[arm64] spawn-demo LEAK: slot read another slot's sentinel FAIL\n"
                _uart_puts(lk)

        # Trace the FIRST correct report from each slot so the log shows A, B and
        # the dynamically-spawned C each reading their private sentinel.
        trace: int64 = 0
        if arm64_p20_cur == 0:
            if arm64_p20_a_correct == 1:
                trace = 1
        elif arm64_p20_cur == 1:
            if arm64_p20_b_correct == 1:
                trace = 1
        else:
            if arm64_p20_c_correct == 1:
                trace = 1
        if trace != 0:
            r: Ptr[char] = "[arm64] spawn-demo report: slot "
            _uart_puts(r)
            _uart_puthex(cast[uint64](arm64_p20_cur))
            rv: Ptr[char] = " read VA value="
            _uart_puts(rv)
            _uart_puthex(val)
            _uart_puts(nl)

        # Slot A exits after P20_A_EXIT_AT reports: redirect its EL0 PC to its exit
        # stub so its NEXT EL0 instruction issues exit(7), which we reap below.
        if arm64_p20_cur == 0:
            if arm64_p20_a_reports == P20_A_EXIT_AT:
                em: Ptr[char] = "[arm64] spawn-demo: slot A requesting exit(7)\n"
                _uart_puts(em)
                arm64_p20_redirect_to_exit(0, cast[uint64](7))

        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_EXIT_NR:
        # The running slot exits: reap it. The scheduler will never pick it again.
        code: int64 = cast[int64](a0)
        rm: Ptr[char] = "[arm64] spawn-demo: reaping slot "
        _uart_puts(rm)
        _uart_puthex(cast[uint64](arm64_p20_cur))
        cm: Ptr[char] = " exit code="
        _uart_puts(cm)
        _uart_puthex(cast[uint64](code))
        _uart_puts(nl)

        arm64_p20_set_state(arm64_p20_cur, P20_SLOT_REAPED)
        if arm64_p20_cur == 0:
            arm64_p20_a_reaped = 1
            arm64_p20_a_exit_code = code
        frame_ptr[0] = cast[uint64](0)
        # A reaped slot must NOT resume at EL0. Force a context switch now: pick the
        # next runnable slot and arm arm64_current_ctx so the IRQ stub will restore
        # the survivor — but the eret path here would resume the dead slot. Instead
        # we busy-yield: park the dead slot's PC on a wfe and let the timer preempt
        # to the survivor. Simpler + correct: spin the dead EL0 task on an infinite
        # self-branch (it will be preempted out next tick and never re-selected).
        arm64_p20_park_dead_el0()
        return 0

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 20)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Redirect slot `idx`'s EL0 execution to a freshly-emitted exit stub: x0=code,
# x8=93, svc #0. We patch the stub just past the slot's loop body and point the
# slot's SAVED ELR (in its ctx) — actually the LIVE ELR_EL1, since this slot is
# the running one — at the stub, so the NEXT EL0 instruction after this svc
# returns is the exit. Because we are servicing this slot's svc right now, the
# eret will resume at ELR_EL1; rewriting ELR_EL1 steers it to the stub.
def arm64_p20_redirect_to_exit(idx: int64, code: uint64) -> int64:
    # Emit the exit stub at a fixed offset inside the slot's code page (well past
    # its short loop body — 0x800 bytes in, same page, EL0-RWX).
    stub: uint64 = arm64_p20_code_for(idx) + cast[uint64](0x800)
    a: uint64 = stub
    a = _emit_load_imm64(a, cast[uint64](0), code)            # x0 = code
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)     # x8 = 93
    a = _emit_word(a, cast[uint64](0xD4000001))              # svc #0
    # Loop on itself afterwards (never reached — exit reaps first).
    a = _emit_word(a, cast[uint64](0x14000000))             # b . (offset 0)
    _dsb_ish()
    _isb()
    # Steer the running slot's eret target to the stub.
    _msr_elr_el1(stub)
    _isb()
    return 0


# Park the just-reaped slot's EL0 context on a harmless self-branch so that if it
# is ever (erroneously) eret-ed into, it merely spins until the timer preempts it
# to a runnable slot. We point the LIVE ELR_EL1 at a tiny "b ." stub in the dead
# slot's own EL0 page. The scheduler's runnable-only selection guarantees the dead
# slot is never picked again, so this is belt-and-suspenders.
def arm64_p20_park_dead_el0() -> int64:
    park: uint64 = arm64_p20_code_for(arm64_p20_cur) + cast[uint64](0xC00)
    _emit_word(park, cast[uint64](0x14000000))              # b . (self-loop)
    _dsb_ish()
    _isb()
    _msr_elr_el1(park)
    _isb()
    return 0


# Phase-20 verdict. PASS iff: slot A ran AND exited AND was reaped; slot B ran
# both BEFORE and AFTER the spawn (it survived the whole demo); slot C was
# DYNAMICALLY spawned at runtime AND ran in its own private ASID space; and ZERO
# cross-task sentinel leaks occurred. Print the tallies, then halt.
def arm64_p20_finish() -> int64:
    arm64_p20_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] spawn-demo swaps="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p20_swaps))
    am: Ptr[char] = " a_correct="
    _uart_puts(am)
    _uart_puthex(cast[uint64](arm64_p20_a_correct))
    bm: Ptr[char] = " b_correct="
    _uart_puts(bm)
    _uart_puthex(cast[uint64](arm64_p20_b_correct))
    cm: Ptr[char] = " c_correct="
    _uart_puts(cm)
    _uart_puthex(cast[uint64](arm64_p20_c_correct))
    rm: Ptr[char] = " a_reaped="
    _uart_puts(rm)
    _uart_puthex(cast[uint64](arm64_p20_a_reaped))
    spm: Ptr[char] = " c_spawned="
    _uart_puts(spm)
    _uart_puthex(cast[uint64](arm64_p20_c_spawned))
    bsm: Ptr[char] = " b_after_spawn="
    _uart_puts(bsm)
    _uart_puthex(cast[uint64](arm64_p20_b_after_spawn))
    lm: Ptr[char] = " leaks="
    _uart_puts(lm)
    _uart_puthex(cast[uint64](arm64_p20_leaks))
    _uart_puts(nl)

    ok: int64 = 1
    if arm64_p20_a_correct <= 0:
        ok = 0
    if arm64_p20_a_reaped == 0:
        ok = 0
    if arm64_p20_b_correct <= 0:
        ok = 0
    if arm64_p20_b_after_spawn <= 0:
        ok = 0
    if arm64_p20_c_spawned == 0:
        ok = 0
    if arm64_p20_c_correct <= 0:
        ok = 0
    if arm64_p20_leaks != 0:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] spawn-demo: slot A reaped, slot B survived, slot C dynamically spawned + ran\n"
        _uart_puts(rp)
        pm: Ptr[char] = "[arm64] EL0 dynamic spawn + exit/reaping OK\n"
        _uart_puts(pm)
        # Phase 20 complete and clean. Hand off to Phase 21 (a blocking primitive:
        # sys_nanosleep that DESCHEDULES a task and lets the scheduler run others
        # until a timer deadline wakes it). IRQs are masked here; the Phase-21 entry
        # re-enables the timer and ERETs into the first task; it never returns.
        arm64_run_sleep_demo()
        # Unreachable: arm64_run_sleep_demo never returns. Safety halt.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 dynamic spawn + exit/reaping FAIL\n"
        _uart_puts(fm)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-20 entry point (from the Phase-19 finish hand-off). Build slots A and B's
# private ASID-tagged address spaces + EL0 routines + context blocks; recycle both
# ASIDs once; mark A and B RUNNABLE and C EMPTY; then ERET into slot A under its
# private TTBR0+ASID with the timer LIVE. The IRQ scheduler round-robins the
# RUNNABLE slots, reaps A on its exit, dynamically spawns C, and round-robins
# {B,C}. Never returns (the scheduler halts after the verdict).
def arm64_run_spawn_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 20: dynamic task spawn + exit/reaping\n"
    _uart_puts(intro)

    # Mask EL1 IRQs while we build everything so a stray timer IRQ cannot run the
    # scheduler mid-setup; re-enable just before the ERET into slot A.
    _msr_daifset(2)

    arm64_p20_build_space(0)
    arm64_p20_build_space(1)
    arm64_p20_build_task(0)
    arm64_p20_build_task(1)
    arm64_init_ctx(arm64_p20_ctx_for(0), arm64_p20_code_for(0), arm64_p20_stack_for(0))
    arm64_init_ctx(arm64_p20_ctx_for(1), arm64_p20_code_for(1), arm64_p20_stack_for(1))

    # Recycle slots A and B's ASIDs before first use; C's ASID is recycled at spawn.
    _dsb_ish()
    _tlbi_aside1is(P20_ASID_A << P20_ASID_SHIFT)
    _tlbi_aside1is(P20_ASID_B << P20_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p20_cur = 0
    arm64_p20_set_state(0, P20_SLOT_RUNNABLE)
    arm64_p20_set_state(1, P20_SLOT_RUNNABLE)
    arm64_p20_set_state(2, P20_SLOT_EMPTY)
    arm64_p20_a_reports = 0
    arm64_p20_b_reports = 0
    arm64_p20_c_reports = 0
    arm64_p20_a_correct = 0
    arm64_p20_b_correct = 0
    arm64_p20_c_correct = 0
    arm64_p20_leaks = 0
    arm64_p20_swaps = 0
    arm64_p20_a_reaped = 0
    arm64_p20_c_spawned = 0
    arm64_p20_b_after_spawn = 0
    arm64_p20_swaps_at_spawn = 0
    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_current_ctx = arm64_p20_ctx_for(0)
    arm64_p20_active = 1

    enter: Ptr[char] = "[arm64] launching spawn-demo EL0 tasks (slot A ASID 4, slot B ASID 5)\n"
    _uart_puts(enter)

    arm64_p20_switch_to(0)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](P20_A_CTX)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> slot A at EL0 under TTBR0+ASID A
    return 0


# ===========================================================================
# Phase 21 — A BLOCKING PRIMITIVE: sys_nanosleep that DESCHEDULES a task on
# aarch64, and a scheduler that runs OTHER tasks while it sleeps then WAKES it.
# ===========================================================================

# Per-slot accessors (two slots; Adder has no arrays-of-globals).
def arm64_p21_l1_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_A_L1
    return P21_B_L1

def arm64_p21_l2_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_A_L2
    return P21_B_L2

def arm64_p21_data_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_A_DATA
    return P21_B_DATA

def arm64_p21_sentinel_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_SENTINEL_A
    return P21_SENTINEL_B

def arm64_p21_asid_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_ASID_A
    return P21_ASID_B

def arm64_p21_code_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_A_CODE
    return P21_B_CODE

def arm64_p21_stack_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_A_STACK_TOP
    return P21_B_STACK_TOP

def arm64_p21_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_A_CTX
    return P21_B_CTX

def arm64_p21_sleep_for(idx: int64) -> int64:
    if idx == 0:
        return P21_A_SLEEP
    return P21_B_SLEEP

def arm64_p21_state_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p21_state0
    return arm64_p21_state1

def arm64_p21_set_state(idx: int64, st: int64) -> int64:
    if idx == 0:
        arm64_p21_state0 = st
    else:
        arm64_p21_state1 = st
    return 0

def arm64_p21_deadline_for(idx: int64) -> uint64:
    if idx == 0:
        return arm64_p21_deadline0
    return arm64_p21_deadline1

def arm64_p21_set_deadline(idx: int64, dl: uint64) -> int64:
    if idx == 0:
        arm64_p21_deadline0 = dl
    else:
        arm64_p21_deadline1 = dl
    return 0


# Build slot `idx`'s private address space: a clone of the kernel identity map
# (EL0 code/stack window fetchable, kernel EL1-only) plus an EL0-RWX mapping of
# P21_SHARED_VA -> this slot's PRIVATE physical block, seeded with its sentinel.
def arm64_p21_build_space(idx: int64) -> int64:
    l1_base: uint64 = arm64_p21_l1_for(idx)
    l2_base: uint64 = arm64_p21_l2_for(idx)
    data_pa: uint64 = arm64_p21_data_for(idx)
    sentinel: uint64 = arm64_p21_sentinel_for(idx)

    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1

    l1[0] = cast[uint64](0) | DEV_FLAGS

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0
        elif cast[uint64](j) == P21_SHARED_L2_INDEX:
            l2[j] = data_pa | MEM_FLAGS_EL0
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = l2_base | DESC_TABLE

    dp: Ptr[uint8] = cast[Ptr[uint8]](data_pa)
    dp[0] = cast[uint8](sentinel & cast[uint64](0xFF))
    _dsb_ish()
    return 0


# Materialise slot `idx`'s EL0 routine:
#   loop:
#     x1 = P21_SHARED_VA ; ldrb w0,[x1]        (read this slot's private byte)
#     x8 = 548 (tick) ; svc #0                 (hand the byte to the kernel)
#     x0 = sleep_ticks ; x8 = 549 (nanosleep) ; svc #0   (DESCHEDULE for N ticks)
#     b loop
# nanosleep blocks the task kernel-side; on wake the kernel resumes it at the
# instruction AFTER its nanosleep svc (the `b loop`), so the routine itself needs
# no busy-loop — the sleep IS the pacing, and the kernel runs the peer meanwhile.
def arm64_p21_build_task(idx: int64) -> int64:
    code_base: uint64 = arm64_p21_code_for(idx)
    sleep_n: int64 = arm64_p21_sleep_for(idx)
    a: uint64 = code_base
    loop_top: uint64 = a

    # x1 = P21_SHARED_VA ; ldrb w0,[x1]
    a = _emit_load_imm64(a, cast[uint64](1), P21_SHARED_VA)
    a = _emit_word(a, cast[uint64](0x39400020))
    # x8 = 548 (tick) ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P21_TICK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))
    # x0 = sleep_ticks ; x8 = 549 (nanosleep) ; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](sleep_n))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P21_NANOSLEEP_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # b loop
    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# TTBR0_EL1 for slot `idx`: its private L1 root with its ASID in bits[63:48].
def arm64_p21_ttbr0_for(idx: int64) -> uint64:
    return arm64_p21_l1_for(idx) | (arm64_p21_asid_for(idx) << P21_ASID_SHIFT)


# Switch the live address space to slot `idx` (TTBR0+ASID). No broad TLB flush —
# per-ASID tagging keeps each slot's translation of the shared VA distinct.
def arm64_p21_switch_to(idx: int64) -> int64:
    _dsb_ish()
    _msr_ttbr0_el1(arm64_p21_ttbr0_for(idx))
    _isb()
    return 0


# Wake any BLOCKED slot whose CNTVCT_EL0 deadline has passed: mark it RUNNABLE and
# tally the wake (the resume itself happens when the scheduler next selects it and
# the IRQ stub restores its saved ctx). Returns the number of slots woken.
def arm64_p21_wake_expired() -> int64:
    now: uint64 = cast[uint64](_mrs_cntvct_el0())
    woke: int64 = 0
    idx: int64 = 0
    while idx < 2:
        if arm64_p21_state_for(idx) == P21_SLOT_BLOCKED:
            if now >= arm64_p21_deadline_for(idx):
                arm64_p21_set_state(idx, P21_SLOT_RUNNABLE)
                if idx == 0:
                    arm64_p21_a_wakes = arm64_p21_a_wakes + 1
                else:
                    arm64_p21_b_wakes = arm64_p21_b_wakes + 1
                wm: Ptr[char] = "[arm64] sleep-demo: waking slot "
                _uart_puts(wm)
                _uart_puthex(cast[uint64](idx))
                nl: Ptr[char] = " (deadline passed)\n"
                _uart_puts(nl)
                woke = woke + 1
        idx = idx + 1
    return woke


# Pick the next RUNNABLE slot after `from_idx`, round-robin over slots 0..1,
# skipping BLOCKED slots. Returns -1 if neither slot is runnable.
def arm64_p21_next_runnable(from_idx: int64) -> int64:
    steps: int64 = 0
    idx: int64 = from_idx
    while steps < 2:
        idx = idx + 1
        if idx >= 2:
            idx = 0
        if arm64_p21_state_for(idx) == P21_SLOT_RUNNABLE:
            return idx
        steps = steps + 1
    return -1


# Count whether the slot we are about to run will run WHILE the OTHER slot is
# BLOCKED — the crux invariant that a blocked task genuinely yielded the CPU.
def arm64_p21_note_peer_blocked(running: int64) -> int64:
    peer: int64 = 1
    if running == 1:
        peer = 0
    if arm64_p21_state_for(peer) == P21_SLOT_BLOCKED:
        arm64_p21_ran_while_peer_blocked = arm64_p21_ran_while_peer_blocked + 1
    return 0


# Phase-21 IRQ scheduler — invoked (via arm64_sched_pick) from the EL0 IRQ vector
# with the running slot's register context already saved. Ack + re-arm the timer,
# WAKE any BLOCKED slot whose deadline passed, then round-robin to the next
# RUNNABLE slot, swapping TTBR0+ASID into its PRIVATE space. After P21_GOAL swaps
# the demo's invariants are checked; run the verdict (never returns).
def arm64_p21_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this slot
        return cur_ctx

    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_p21_swaps = arm64_p21_swaps + 1
    swmsg: Ptr[char] = "[arm64] sleep-demo TTBR0+ASID swap\n"
    _uart_puts(swmsg)

    # Wake any sleeper whose deadline has passed (BLOCKED -> RUNNABLE).
    arm64_p21_wake_expired()

    # Verdict once enough swaps have run (both tasks have blocked + been woken).
    if arm64_p21_swaps >= P21_GOAL:
        arm64_p21_finish()
        while True:
            _wfi()

    nxt: int64 = arm64_p21_next_runnable(arm64_p21_cur)
    if nxt < 0:
        # Both slots BLOCKED: no runnable task this tick. Stay on the (parked)
        # current ctx — the next tick will wake a sleeper and pick it up. This
        # is the kernel idling while every task sleeps (legitimate, transient).
        return cur_ctx

    arm64_p21_note_peer_blocked(nxt)
    arm64_p21_cur = nxt
    arm64_p21_switch_to(nxt)                 # TTBR0+ASID -> the incoming slot
    next_ctx: uint64 = arm64_p21_ctx_for(nxt)
    arm64_current_ctx = next_ctx
    return next_ctx


# Save the running slot's FULL resume context (x0..x30 from the svc frame, plus
# the post-svc ELR_EL1, SP_EL0 and an EL0+IRQs-on SPSR) into its ctx block, so the
# scheduler can restore it verbatim on wake. x0 is forced to 0 (nanosleep's return
# value once it resumes). The slot is the running one, so ELR_EL1/SP_EL0 are live.
def arm64_p21_save_resume_ctx(frame_ptr: Ptr[uint64], idx: int64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p21_ctx_for(idx))
    i: int64 = 0
    while i < 31:
        ctx[i] = frame_ptr[i]                # x0..x30 from the saved svc frame
        i = i + 1
    ctx[CTX_X0] = cast[uint64](0)            # nanosleep returns 0 on wake
    ctx[CTX_SP_EL0] = cast[uint64](_mrs_sp_el0())
    ctx[CTX_ELR] = cast[uint64](_mrs_elr_el1())   # resume PC = insn after the svc
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ            # EL0t, IRQs enabled (re-preemptible)
    _dsb_ish()
    return 0


# Park the blocking slot's LIVE EL0 context on a harmless self-loop so the svc
# eret merely spins until the next timer tick preempts it. CRUCIAL: point
# arm64_current_ctx at the THROWAWAY park ctx so the preempting IRQ saves the spin
# state THERE, not over the slot's real (just-saved) resume context.
def arm64_p21_park_blocked_el0(idx: int64) -> int64:
    park: uint64 = arm64_p21_code_for(idx) + cast[uint64](0xE00)
    _emit_word(park, cast[uint64](0x14000000))   # b . (self-loop)
    _dsb_ish()
    _isb()
    _msr_elr_el1(park)
    _isb()
    arm64_current_ctx = P21_PARK_CTX             # IRQ spills spin state here
    return 0


# Phase-21 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. Services:
#   SYS_P21_TICK_NR (548): the byte the running slot read at P21_SHARED_VA through
#       its OWN TTBR0+ASID. Tally a CORRECT read (own sentinel) or a LEAK.
#   SYS_P21_NANOSLEEP_NR (549): a0 = scheduler ticks to sleep. DESCHEDULE the
#       running slot — save its full resume context, set a CNTVCT deadline, mark it
#       BLOCKED, and park its EL0 PC on a self-loop (the timer tick switches away).
def arm64_p21_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P21_TICK_NR:
        val: uint64 = a0 & cast[uint64](0xFF)
        own: uint64 = arm64_p21_sentinel_for(arm64_p21_cur)

        if arm64_p21_cur == 0:
            arm64_p21_a_reports = arm64_p21_a_reports + 1
            if val == own:
                arm64_p21_a_correct = arm64_p21_a_correct + 1
        else:
            arm64_p21_b_reports = arm64_p21_b_reports + 1
            if val == own:
                arm64_p21_b_correct = arm64_p21_b_correct + 1

        # A value that is neither this slot's own sentinel nor 0 is a cross-task
        # leak (a stale, ASID-untagged TLB entry resolving to the peer's block).
        if val != own:
            if val != cast[uint64](0):
                arm64_p21_leaks = arm64_p21_leaks + 1
                lk: Ptr[char] = "[arm64] sleep-demo LEAK: slot read another slot's sentinel FAIL\n"
                _uart_puts(lk)

        # Trace the FIRST correct report from each slot.
        trace: int64 = 0
        if arm64_p21_cur == 0:
            if arm64_p21_a_correct == 1:
                trace = 1
        else:
            if arm64_p21_b_correct == 1:
                trace = 1
        if trace != 0:
            r: Ptr[char] = "[arm64] sleep-demo report: slot "
            _uart_puts(r)
            _uart_puthex(cast[uint64](arm64_p21_cur))
            rv: Ptr[char] = " read VA value="
            _uart_puts(rv)
            _uart_puthex(val)
            _uart_puts(nl)

        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P21_NANOSLEEP_NR:
        ticks: int64 = cast[int64](a0)
        if ticks < 1:
            ticks = 1
        cur: int64 = arm64_p21_cur

        # Save the caller's full resume context so it can RESUME past the svc.
        arm64_p21_save_resume_ctx(frame_ptr, cur)

        # Record the wake deadline = now + ticks * one-timer-period (CNTVCT units).
        now: uint64 = cast[uint64](_mrs_cntvct_el0())
        span: uint64 = cast[uint64](ticks) * arm64_timer_period
        arm64_p21_set_deadline(cur, now + span)
        arm64_p21_set_state(cur, P21_SLOT_BLOCKED)

        if cur == 0:
            arm64_p21_a_blocks = arm64_p21_a_blocks + 1
        else:
            arm64_p21_b_blocks = arm64_p21_b_blocks + 1

        bm: Ptr[char] = "[arm64] sleep-demo: slot "
        _uart_puts(bm)
        _uart_puthex(cast[uint64](cur))
        bn: Ptr[char] = " nanosleep -> BLOCKED for "
        _uart_puts(bn)
        _uart_puthex(cast[uint64](ticks))
        bt: Ptr[char] = " ticks\n"
        _uart_puts(bt)

        # Park the blocked slot's EL0 PC on a self-loop; the next timer tick
        # preempts it and the scheduler runs a RUNNABLE peer (or idles if both
        # sleep). arm64_current_ctx now points at the throwaway park ctx so the
        # preempting IRQ does not clobber the saved resume context.
        arm64_p21_park_blocked_el0(cur)
        frame_ptr[0] = cast[uint64](0)
        return 0

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 21)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-21 verdict. PASS iff: BOTH slots ran (read their private sentinel); EACH
# slot BLOCKED at least once AND was WOKEN+resumed (block+wake cycle proven for
# both); at least one tick ran a task while its peer was BLOCKED (the deschedule-
# others pillar); and ZERO cross-task sentinel leaks. Print tallies, then halt.
def arm64_p21_finish() -> int64:
    arm64_p21_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] sleep-demo swaps="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p21_swaps))
    am: Ptr[char] = " a_correct="
    _uart_puts(am)
    _uart_puthex(cast[uint64](arm64_p21_a_correct))
    bm: Ptr[char] = " b_correct="
    _uart_puts(bm)
    _uart_puthex(cast[uint64](arm64_p21_b_correct))
    abm: Ptr[char] = " a_blocks="
    _uart_puts(abm)
    _uart_puthex(cast[uint64](arm64_p21_a_blocks))
    bbm: Ptr[char] = " b_blocks="
    _uart_puts(bbm)
    _uart_puthex(cast[uint64](arm64_p21_b_blocks))
    awm: Ptr[char] = " a_wakes="
    _uart_puts(awm)
    _uart_puthex(cast[uint64](arm64_p21_a_wakes))
    bwm: Ptr[char] = " b_wakes="
    _uart_puts(bwm)
    _uart_puthex(cast[uint64](arm64_p21_b_wakes))
    pm: Ptr[char] = " ran_while_peer_blocked="
    _uart_puts(pm)
    _uart_puthex(cast[uint64](arm64_p21_ran_while_peer_blocked))
    lm: Ptr[char] = " leaks="
    _uart_puts(lm)
    _uart_puthex(cast[uint64](arm64_p21_leaks))
    _uart_puts(nl)

    ok: int64 = 1
    if arm64_p21_a_correct <= 0:
        ok = 0
    if arm64_p21_b_correct <= 0:
        ok = 0
    if arm64_p21_a_blocks <= 0:
        ok = 0
    if arm64_p21_b_blocks <= 0:
        ok = 0
    if arm64_p21_a_wakes <= 0:
        ok = 0
    if arm64_p21_b_wakes <= 0:
        ok = 0
    if arm64_p21_ran_while_peer_blocked <= 0:
        ok = 0
    if arm64_p21_leaks != 0:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] sleep-demo: both tasks blocked + were woken; scheduler ran peers while one slept\n"
        _uart_puts(rp)
        op: Ptr[char] = "[arm64] EL0 nanosleep block/wake scheduling OK\n"
        _uart_puts(op)
        # Phase 21 complete and clean. Hand off to Phase 22 (a futex: block on a
        # memory word, woken by a peer task). IRQs are masked here; the Phase-22
        # entry re-enables the timer and ERETs into the first task; never returns.
        arm64_run_futex_demo()
        # Unreachable: arm64_run_futex_demo never returns. Safety halt.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 nanosleep block/wake scheduling FAIL\n"
        _uart_puts(fm)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-21 entry point (from the Phase-20 finish hand-off). Build both slots'
# private ASID-tagged address spaces + EL0 routines + context blocks; recycle both
# ASIDs once; mark both RUNNABLE; then ERET into slot A under its private
# TTBR0+ASID with the timer LIVE. The IRQ scheduler round-robins the RUNNABLE
# slots, blocks a task on its nanosleep, runs the peer while it sleeps, and wakes
# it when its deadline passes. Never returns (the scheduler halts after verdict).
def arm64_run_sleep_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 21: blocking nanosleep (deschedule + timer-deadline wake)\n"
    _uart_puts(intro)

    # Mask EL1 IRQs while we build everything so a stray timer IRQ cannot run the
    # scheduler mid-setup; re-enable just before the ERET into slot A.
    _msr_daifset(2)

    arm64_p21_build_space(0)
    arm64_p21_build_space(1)
    arm64_p21_build_task(0)
    arm64_p21_build_task(1)
    arm64_init_ctx(arm64_p21_ctx_for(0), arm64_p21_code_for(0), arm64_p21_stack_for(0))
    arm64_init_ctx(arm64_p21_ctx_for(1), arm64_p21_code_for(1), arm64_p21_stack_for(1))

    # Recycle both slots' ASIDs before first use; thereafter swaps need no flush.
    _dsb_ish()
    _tlbi_aside1is(P21_ASID_A << P21_ASID_SHIFT)
    _tlbi_aside1is(P21_ASID_B << P21_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p21_cur = 0
    arm64_p21_set_state(0, P21_SLOT_RUNNABLE)
    arm64_p21_set_state(1, P21_SLOT_RUNNABLE)
    arm64_p21_deadline0 = cast[uint64](0)
    arm64_p21_deadline1 = cast[uint64](0)
    arm64_p21_a_reports = 0
    arm64_p21_b_reports = 0
    arm64_p21_a_correct = 0
    arm64_p21_b_correct = 0
    arm64_p21_a_blocks = 0
    arm64_p21_b_blocks = 0
    arm64_p21_a_wakes = 0
    arm64_p21_b_wakes = 0
    arm64_p21_ran_while_peer_blocked = 0
    arm64_p21_leaks = 0
    arm64_p21_swaps = 0
    arm64_current_ctx = arm64_p21_ctx_for(0)
    arm64_p21_active = 1

    enter: Ptr[char] = "[arm64] launching sleep-demo EL0 tasks (slot A ASID 7, slot B ASID 8)\n"
    _uart_puts(enter)

    arm64_p21_switch_to(0)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](P21_A_CTX)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> slot A at EL0 under TTBR0+ASID A
    return 0


# ===========================================================================
# Phase 22 — EL0 FUTEX: block on a memory word (FUTEX_WAIT), woken by a peer
# task (FUTEX_WAKE), reusing Phase 21's BLOCKED-state + resume-save + park-ctx
# machinery. The ONLY difference from nanosleep is the wake condition: a futex
# waiter wakes when a peer calls FUTEX_WAKE on the matching uaddr key, NOT when a
# timer deadline expires.
# ===========================================================================

# Per-slot accessors (two slots; Adder has no arrays-of-globals).
def arm64_p22_l1_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_A_L1
    return P22_B_L1

def arm64_p22_l2_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_A_L2
    return P22_B_L2

def arm64_p22_sent_data_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_A_SENT_DATA
    return P22_B_SENT_DATA

def arm64_p22_sentinel_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_SENTINEL_A
    return P22_SENTINEL_B

def arm64_p22_asid_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_ASID_A
    return P22_ASID_B

def arm64_p22_code_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_A_CODE
    return P22_B_CODE

def arm64_p22_stack_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_A_STACK_TOP
    return P22_B_STACK_TOP

def arm64_p22_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_A_CTX
    return P22_B_CTX

def arm64_p22_state_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p22_state0
    return arm64_p22_state1

def arm64_p22_set_state(idx: int64, st: int64) -> int64:
    if idx == 0:
        arm64_p22_state0 = st
    else:
        arm64_p22_state1 = st
    return 0

def arm64_p22_wait_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p22_wait0
    return arm64_p22_wait1

def arm64_p22_set_wait(idx: int64, w: int64) -> int64:
    if idx == 0:
        arm64_p22_wait0 = w
    else:
        arm64_p22_wait1 = w
    return 0

def arm64_p22_key_for(idx: int64) -> uint64:
    if idx == 0:
        return arm64_p22_key0
    return arm64_p22_key1

def arm64_p22_set_key(idx: int64, k: uint64) -> int64:
    if idx == 0:
        arm64_p22_key0 = k
    else:
        arm64_p22_key1 = k
    return 0

def arm64_p22_deadline_for(idx: int64) -> uint64:
    if idx == 0:
        return arm64_p22_deadline0
    return arm64_p22_deadline1

def arm64_p22_set_deadline(idx: int64, dl: uint64) -> int64:
    if idx == 0:
        arm64_p22_deadline0 = dl
    else:
        arm64_p22_deadline1 = dl
    return 0


# Translate an EL0 futex VA to its STABLE physical match key. Both slots map
# P22_FUTEX_VA to the SAME physical block (P22_FUTEX_DATA), so any waiter's uaddr
# resolves to the same key regardless of which ASID space it ran in — that is
# what makes cross-ASID FUTEX_WAKE matching unambiguous. (Only the one shared VA
# is a valid futex address in this demo; anything else maps to its own VA as the
# key, which simply never matches a waiter and is harmless.)
def arm64_p22_key_of(uaddr: uint64) -> uint64:
    if uaddr == P22_FUTEX_VA:
        return P22_FUTEX_DATA
    return uaddr


# Build slot `idx`'s private address space: a clone of the kernel identity map
# (EL0 code/stack window fetchable, kernel EL1-only) PLUS two EL0-RWX mappings:
#   P22_FUTEX_VA -> the ONE SHARED physical futex block (same for both slots), and
#   P22_SENT_VA  -> this slot's PRIVATE physical sentinel block (seeded).
def arm64_p22_build_space(idx: int64) -> int64:
    l1_base: uint64 = arm64_p22_l1_for(idx)
    l2_base: uint64 = arm64_p22_l2_for(idx)
    sent_pa: uint64 = arm64_p22_sent_data_for(idx)
    sentinel: uint64 = arm64_p22_sentinel_for(idx)

    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1

    l1[0] = cast[uint64](0) | DEV_FLAGS

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0
        elif cast[uint64](j) == P22_FUTEX_L2_INDEX:
            l2[j] = P22_FUTEX_DATA | MEM_FLAGS_EL0     # SHARED futex word (both slots)
        elif cast[uint64](j) == P22_SENT_L2_INDEX:
            l2[j] = sent_pa | MEM_FLAGS_EL0            # PRIVATE per-slot sentinel
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = l2_base | DESC_TABLE

    sp: Ptr[uint8] = cast[Ptr[uint8]](sent_pa)
    sp[0] = cast[uint8](sentinel & cast[uint64](0xFF))
    _dsb_ish()
    return 0


# Seed the shared futex word to 0 (so the WAITER's initial FUTEX_WAIT(F,0) blocks).
def arm64_p22_seed_futex() -> int64:
    fp: Ptr[uint64] = cast[Ptr[uint64]](P22_FUTEX_DATA)
    fp[0] = cast[uint64](0)
    _dsb_ish()
    return 0


# Materialise slot `idx`'s EL0 routine.
#
# WAITER (slot 0 / A):
#   loop:
#     x1 = P22_SENT_VA ; ldrb w0,[x1]                    (read private sentinel)
#     x8 = 550 (tick)  ; svc #0                          (report it)
#     x0 = P22_FUTEX_VA ; x1 = 0 (WAIT) ; x2 = 0 (val) ; x8 = 551 ; svc #0  (FUTEX_WAIT)
#     b loop
#
# WAKER (slot 1 / B):
#   loop:
#     x1 = P22_SENT_VA ; ldrb w0,[x1]                    (read private sentinel)
#     x8 = 550 (tick)  ; svc #0                          (report it)
#     x0 = sleep ; x8 = 552 (nanosleep) ; svc #0         (yield so A blocks first)
#     x0 = P22_FUTEX_VA ; x1 = 1 ; x8 = 553 (poke) ; svc #0   (*F = 1)
#     x0 = P22_FUTEX_VA ; x1 = 1 (WAKE) ; x2 = 1 (cnt) ; x8 = 551 ; svc #0  (FUTEX_WAKE)
#     x0 = P22_FUTEX_VA ; x1 = 0 ; x8 = 553 (poke) ; svc #0   (*F = 0; A re-blocks)
#     b loop
#
# The kernel resolves *F and writes via syscalls (poke) so the futex word edits
# are observed by the kernel-side compare/wake under the running slot's ASID.
def arm64_p22_build_task(idx: int64) -> int64:
    code_base: uint64 = arm64_p22_code_for(idx)
    a: uint64 = code_base
    loop_top: uint64 = a

    # x1 = P22_SENT_VA ; ldrb w0,[x1]
    a = _emit_load_imm64(a, cast[uint64](1), P22_SENT_VA)
    a = _emit_word(a, cast[uint64](0x39400020))
    # x8 = 550 (tick) ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P22_TICK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    if idx == 0:
        # WAITER: FUTEX_WAIT(P22_FUTEX_VA, op=0, val=0)
        a = _emit_load_imm64(a, cast[uint64](0), P22_FUTEX_VA)
        a = _emit_load_imm64(a, cast[uint64](1), P22_FUTEX_WAIT)
        a = _emit_load_imm64(a, cast[uint64](2), cast[uint64](0))
        a = _emit_load_imm64(a, cast[uint64](8), SYS_P22_FUTEX_NR)
        a = _emit_word(a, cast[uint64](0xD4000001))
    else:
        # WAKER: nanosleep(short) so the waiter reliably blocks before we wake it.
        a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](P22_B_SLEEP))
        a = _emit_load_imm64(a, cast[uint64](8), SYS_P22_NANOSLEEP_NR)
        a = _emit_word(a, cast[uint64](0xD4000001))
        # poke(P22_FUTEX_VA, 1): *F = 1
        a = _emit_load_imm64(a, cast[uint64](0), P22_FUTEX_VA)
        a = _emit_load_imm64(a, cast[uint64](1), cast[uint64](1))
        a = _emit_load_imm64(a, cast[uint64](8), SYS_P22_POKE_NR)
        a = _emit_word(a, cast[uint64](0xD4000001))
        # FUTEX_WAKE(P22_FUTEX_VA, op=1, val=1): wake up to 1 waiter
        a = _emit_load_imm64(a, cast[uint64](0), P22_FUTEX_VA)
        a = _emit_load_imm64(a, cast[uint64](1), P22_FUTEX_WAKE)
        a = _emit_load_imm64(a, cast[uint64](2), cast[uint64](1))
        a = _emit_load_imm64(a, cast[uint64](8), SYS_P22_FUTEX_NR)
        a = _emit_word(a, cast[uint64](0xD4000001))
        # poke(P22_FUTEX_VA, 0): *F = 0 so the waiter's next FUTEX_WAIT blocks again
        a = _emit_load_imm64(a, cast[uint64](0), P22_FUTEX_VA)
        a = _emit_load_imm64(a, cast[uint64](1), cast[uint64](0))
        a = _emit_load_imm64(a, cast[uint64](8), SYS_P22_POKE_NR)
        a = _emit_word(a, cast[uint64](0xD4000001))

    # b loop
    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# TTBR0_EL1 for slot `idx`: its private L1 root with its ASID in bits[63:48].
def arm64_p22_ttbr0_for(idx: int64) -> uint64:
    return arm64_p22_l1_for(idx) | (arm64_p22_asid_for(idx) << P22_ASID_SHIFT)


# Switch the live address space to slot `idx` (TTBR0+ASID). No broad TLB flush —
# per-ASID tagging keeps each slot's translation of the shared VAs distinct.
def arm64_p22_switch_to(idx: int64) -> int64:
    _dsb_ish()
    _msr_ttbr0_el1(arm64_p22_ttbr0_for(idx))
    _isb()
    return 0


# Save the running slot's FULL resume context (x0..x30 from the svc frame, plus
# the post-svc ELR_EL1, SP_EL0 and an EL0+IRQs-on SPSR) into its ctx block, so the
# scheduler can restore it verbatim on wake. x0 is forced to 0 (FUTEX_WAIT /
# nanosleep return value once it resumes).
def arm64_p22_save_resume_ctx(frame_ptr: Ptr[uint64], idx: int64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p22_ctx_for(idx))
    i: int64 = 0
    while i < 31:
        ctx[i] = frame_ptr[i]                # x0..x30 from the saved svc frame
        i = i + 1
    ctx[CTX_X0] = cast[uint64](0)            # returns 0 on wake
    ctx[CTX_SP_EL0] = cast[uint64](_mrs_sp_el0())
    ctx[CTX_ELR] = cast[uint64](_mrs_elr_el1())   # resume PC = insn after the svc
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ            # EL0t, IRQs enabled (re-preemptible)
    _dsb_ish()
    return 0


# Park the blocking slot's LIVE EL0 context on a harmless self-loop so the svc
# eret merely spins until the next timer tick preempts it. CRUCIAL: point
# arm64_current_ctx at the THROWAWAY park ctx so the preempting IRQ saves the spin
# state THERE, not over the slot's real (just-saved) resume context.
def arm64_p22_park_blocked_el0(idx: int64) -> int64:
    park: uint64 = arm64_p22_code_for(idx) + cast[uint64](0xE00)
    _emit_word(park, cast[uint64](0x14000000))   # b . (self-loop)
    _dsb_ish()
    _isb()
    _msr_elr_el1(park)
    _isb()
    arm64_current_ctx = P22_PARK_CTX             # IRQ spills spin state here
    return 0


# FUTEX_WAKE(key, count): flip up to `count` slots that are BLOCKED on the futex
# matching `key` back to RUNNABLE. Returns the number woken.
def arm64_p22_futex_wake(key: uint64, count: int64) -> int64:
    woke: int64 = 0
    idx: int64 = 0
    while idx < 2:
        if woke >= count:
            return woke
        if arm64_p22_state_for(idx) == P22_SLOT_BLOCKED:
            if arm64_p22_wait_for(idx) == P22_WAIT_FUTEX:
                if arm64_p22_key_for(idx) == key:
                    arm64_p22_set_state(idx, P22_SLOT_RUNNABLE)
                    arm64_p22_set_wait(idx, P22_WAIT_NONE)
                    if idx == 0:
                        arm64_p22_a_wakes = arm64_p22_a_wakes + 1
                    wm: Ptr[char] = "[arm64] futex-demo: FUTEX_WAKE woke slot "
                    _uart_puts(wm)
                    _uart_puthex(cast[uint64](idx))
                    nl: Ptr[char] = " (peer signalled the word)\n"
                    _uart_puts(nl)
                    woke = woke + 1
        idx = idx + 1
    return woke


# Auto-wake any TIMER-blocked slot whose CNTVCT_EL0 deadline has passed (nanosleep
# pacing path — NOT the futex path; futex waiters are woken only by a peer).
def arm64_p22_wake_timer_expired() -> int64:
    now: uint64 = cast[uint64](_mrs_cntvct_el0())
    woke: int64 = 0
    idx: int64 = 0
    while idx < 2:
        if arm64_p22_state_for(idx) == P22_SLOT_BLOCKED:
            if arm64_p22_wait_for(idx) == P22_WAIT_TIMER:
                if now >= arm64_p22_deadline_for(idx):
                    arm64_p22_set_state(idx, P22_SLOT_RUNNABLE)
                    arm64_p22_set_wait(idx, P22_WAIT_NONE)
                    woke = woke + 1
        idx = idx + 1
    return woke


# Pick the next RUNNABLE slot after `from_idx`, round-robin over slots 0..1,
# skipping BLOCKED slots. Returns -1 if neither slot is runnable.
def arm64_p22_next_runnable(from_idx: int64) -> int64:
    steps: int64 = 0
    idx: int64 = from_idx
    while steps < 2:
        idx = idx + 1
        if idx >= 2:
            idx = 0
        if arm64_p22_state_for(idx) == P22_SLOT_RUNNABLE:
            return idx
        steps = steps + 1
    return -1


# Count whether the slot we are about to run will run WHILE the OTHER slot is
# BLOCKED — the crux invariant that a blocked task genuinely yielded the CPU.
def arm64_p22_note_peer_blocked(running: int64) -> int64:
    peer: int64 = 1
    if running == 1:
        peer = 0
    if arm64_p22_state_for(peer) == P22_SLOT_BLOCKED:
        arm64_p22_ran_while_peer_blocked = arm64_p22_ran_while_peer_blocked + 1
    return 0


# Phase-22 IRQ scheduler — invoked (via arm64_sched_pick) from the EL0 IRQ vector
# with the running slot's register context already saved. Ack + re-arm the timer,
# auto-wake any TIMER-blocked slot whose deadline passed (futex waiters are NOT
# auto-woken here), then round-robin to the next RUNNABLE slot, swapping
# TTBR0+ASID into its PRIVATE space. After P22_GOAL swaps run the verdict.
def arm64_p22_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this slot
        return cur_ctx

    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_p22_swaps = arm64_p22_swaps + 1
    swmsg: Ptr[char] = "[arm64] futex-demo TTBR0+ASID swap\n"
    _uart_puts(swmsg)

    # Auto-wake nanosleep (timer) sleepers whose deadline passed. Futex waiters are
    # woken only by a peer FUTEX_WAKE, never here.
    arm64_p22_wake_timer_expired()

    # Verdict once enough swaps have run.
    if arm64_p22_swaps >= P22_GOAL:
        arm64_p22_finish()
        while True:
            _wfi()

    nxt: int64 = arm64_p22_next_runnable(arm64_p22_cur)
    if nxt < 0:
        # Both slots BLOCKED this tick. If the waiter is futex-blocked and the
        # waker is timer-blocked, the waker will wake next tick and signal — so
        # just idle on the parked ctx; this is a legitimate transient.
        return cur_ctx

    arm64_p22_note_peer_blocked(nxt)
    arm64_p22_cur = nxt
    arm64_p22_switch_to(nxt)                 # TTBR0+ASID -> the incoming slot
    next_ctx: uint64 = arm64_p22_ctx_for(nxt)
    arm64_current_ctx = next_ctx
    return next_ctx


# Phase-22 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. Services:
#   SYS_P22_TICK_NR (550): the private sentinel byte the running slot read at
#       P22_SENT_VA. Tally a CORRECT read (own sentinel) or a LEAK.
#   SYS_P22_FUTEX_NR (551): a0=uaddr, a1=op, a2=val.
#       op=WAIT(0): if *uaddr == val, save resume ctx, record the futex KEY on the
#           slot, mark it BLOCKED-on-futex, and park its EL0 PC (the timer tick
#           switches away). If *uaddr != val, return immediately (EAGAIN).
#       op=WAKE(1): wake up to `val` slots BLOCKED on the matching key (RUNNABLE).
#   SYS_P22_NANOSLEEP_NR (552): a0=ticks. Timer-block the slot (waker pacing).
#   SYS_P22_POKE_NR (553): a0=uaddr, a1=value. *uaddr = value (kernel-side write,
#       so the futex word edit happens under the running slot's live ASID).
def arm64_p22_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P22_TICK_NR:
        val: uint64 = a0 & cast[uint64](0xFF)
        own: uint64 = arm64_p22_sentinel_for(arm64_p22_cur)

        if arm64_p22_cur == 0:
            arm64_p22_a_reports = arm64_p22_a_reports + 1
            if val == own:
                arm64_p22_a_correct = arm64_p22_a_correct + 1
        else:
            arm64_p22_b_reports = arm64_p22_b_reports + 1
            if val == own:
                arm64_p22_b_correct = arm64_p22_b_correct + 1

        # A value that is neither this slot's own sentinel nor 0 is a cross-task
        # leak (a stale, ASID-untagged TLB entry resolving to the peer's block).
        if val != own:
            if val != cast[uint64](0):
                arm64_p22_leaks = arm64_p22_leaks + 1
                lk: Ptr[char] = "[arm64] futex-demo LEAK: slot read another slot's sentinel FAIL\n"
                _uart_puts(lk)

        # Trace the FIRST correct report from each slot.
        trace: int64 = 0
        if arm64_p22_cur == 0:
            if arm64_p22_a_correct == 1:
                trace = 1
        else:
            if arm64_p22_b_correct == 1:
                trace = 1
        if trace != 0:
            r: Ptr[char] = "[arm64] futex-demo report: slot "
            _uart_puts(r)
            _uart_puthex(cast[uint64](arm64_p22_cur))
            rv: Ptr[char] = " read sentinel value="
            _uart_puts(rv)
            _uart_puthex(val)
            _uart_puts(nl)

        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P22_POKE_NR:
        # Kernel-side write of the futex word under the running slot's live ASID.
        wp: Ptr[uint64] = cast[Ptr[uint64]](a0)
        wp[0] = a1
        _dsb_ish()
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P22_NANOSLEEP_NR:
        ticks: int64 = cast[int64](a0)
        if ticks < 1:
            ticks = 1
        cur: int64 = arm64_p22_cur

        arm64_p22_save_resume_ctx(frame_ptr, cur)
        now: uint64 = cast[uint64](_mrs_cntvct_el0())
        span: uint64 = cast[uint64](ticks) * arm64_timer_period
        arm64_p22_set_deadline(cur, now + span)
        arm64_p22_set_key(cur, cast[uint64](0))
        arm64_p22_set_wait(cur, P22_WAIT_TIMER)
        arm64_p22_set_state(cur, P22_SLOT_BLOCKED)
        arm64_p22_park_blocked_el0(cur)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P22_FUTEX_NR:
        op: uint64 = a1
        cur2: int64 = arm64_p22_cur
        key: uint64 = arm64_p22_key_of(a0)

        if op == P22_FUTEX_WAKE:
            cnt: int64 = cast[int64](a2)
            if cnt < 1:
                cnt = 1
            n: int64 = arm64_p22_futex_wake(key, cnt)
            if n > 0:
                arm64_p22_wakes_issued = arm64_p22_wakes_issued + 1
            frame_ptr[0] = cast[uint64](n)
            return 0

        if op == P22_FUTEX_WAIT:
            # Compare *uaddr against the expected val. The word lives at a0 (the
            # EL0 VA) which is mapped into the running slot's live ASID, so the
            # kernel can read it directly.
            wp2: Ptr[uint64] = cast[Ptr[uint64]](a0)
            cur_val: uint64 = wp2[0]
            if cur_val != a2:
                # *uaddr changed already: do NOT block (EAGAIN). Return immediately.
                eg: Ptr[char] = "[arm64] futex-demo: FUTEX_WAIT slot "
                _uart_puts(eg)
                _uart_puthex(cast[uint64](cur2))
                eg2: Ptr[char] = " word already changed -> no block (EAGAIN)\n"
                _uart_puts(eg2)
                frame_ptr[0] = cast[uint64](0)
                return 0

            # *uaddr == val: BLOCK on the futex key.
            arm64_p22_save_resume_ctx(frame_ptr, cur2)
            arm64_p22_set_key(cur2, key)
            arm64_p22_set_deadline(cur2, cast[uint64](0))
            arm64_p22_set_wait(cur2, P22_WAIT_FUTEX)
            arm64_p22_set_state(cur2, P22_SLOT_BLOCKED)
            if cur2 == 0:
                arm64_p22_a_waits = arm64_p22_a_waits + 1

            bm: Ptr[char] = "[arm64] futex-demo: slot "
            _uart_puts(bm)
            _uart_puthex(cast[uint64](cur2))
            bn: Ptr[char] = " FUTEX_WAIT -> BLOCKED on key "
            _uart_puts(bn)
            _uart_puthex(key)
            _uart_puts(nl)

            arm64_p22_park_blocked_el0(cur2)
            frame_ptr[0] = cast[uint64](0)
            return 0

        # Unknown futex op.
        frame_ptr[0] = cast[uint64](0)
        return 0

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 22)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-22 verdict. PASS iff: BOTH slots ran (read their private sentinel); the
# WAITER BLOCKED on the futex at least once AND was WOKEN by a peer FUTEX_WAKE at
# least once (block-on-word / wake-by-peer cycle proven); at least one FUTEX_WAKE
# actually woke a waiter; at least one tick ran a task while its peer was BLOCKED
# (the deschedule-others pillar); and ZERO cross-task sentinel leaks. Print
# tallies, then halt.
def arm64_p22_finish() -> int64:
    arm64_p22_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] futex-demo swaps="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p22_swaps))
    am: Ptr[char] = " a_correct="
    _uart_puts(am)
    _uart_puthex(cast[uint64](arm64_p22_a_correct))
    bm: Ptr[char] = " b_correct="
    _uart_puts(bm)
    _uart_puthex(cast[uint64](arm64_p22_b_correct))
    awm: Ptr[char] = " a_waits="
    _uart_puts(awm)
    _uart_puthex(cast[uint64](arm64_p22_a_waits))
    akm: Ptr[char] = " a_wakes="
    _uart_puts(akm)
    _uart_puthex(cast[uint64](arm64_p22_a_wakes))
    wim: Ptr[char] = " wakes_issued="
    _uart_puts(wim)
    _uart_puthex(cast[uint64](arm64_p22_wakes_issued))
    pm: Ptr[char] = " ran_while_peer_blocked="
    _uart_puts(pm)
    _uart_puthex(cast[uint64](arm64_p22_ran_while_peer_blocked))
    lm: Ptr[char] = " leaks="
    _uart_puts(lm)
    _uart_puthex(cast[uint64](arm64_p22_leaks))
    _uart_puts(nl)

    ok: int64 = 1
    if arm64_p22_a_correct <= 0:
        ok = 0
    if arm64_p22_b_correct <= 0:
        ok = 0
    if arm64_p22_a_waits <= 0:
        ok = 0
    if arm64_p22_a_wakes <= 0:
        ok = 0
    if arm64_p22_wakes_issued <= 0:
        ok = 0
    if arm64_p22_ran_while_peer_blocked <= 0:
        ok = 0
    if arm64_p22_leaks != 0:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] futex-demo: waiter blocked on a word + was woken by a peer FUTEX_WAKE; scheduler ran the peer while it blocked\n"
        _uart_puts(rp)
        op: Ptr[char] = "[arm64] EL0 futex wait/wake scheduling OK\n"
        _uart_puts(op)
        # Phase 22 complete and clean. Hand off to Phase 23 (EL0 thread-local
        # storage via TPIDR_EL0 / SETTLS, saved+restored per-thread across every
        # preemptive context switch). IRQs are masked here; the Phase-23 entry
        # re-enables the timer and ERETs into the first task; never returns.
        arm64_run_tls_demo()
        # Unreachable: arm64_run_tls_demo never returns. Safety halt.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 futex wait/wake scheduling FAIL\n"
        _uart_puts(fm)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-22 entry point (from the Phase-21 finish hand-off). Build both slots'
# private ASID-tagged address spaces (each mapping the SHARED futex word + its
# OWN private sentinel) + EL0 routines + context blocks; seed the futex word to
# 0; recycle both ASIDs once; mark both RUNNABLE; then ERET into slot A (the
# WAITER) under its private TTBR0+ASID with the timer LIVE. The waiter blocks on
# the futex word; the waker writes it + FUTEX_WAKEs the waiter; the scheduler
# round-robins RUNNABLE slots. Never returns (the scheduler halts after verdict).
def arm64_run_futex_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 22: EL0 futex (FUTEX_WAIT on a word + peer FUTEX_WAKE)\n"
    _uart_puts(intro)

    # Mask EL1 IRQs while we build everything so a stray timer IRQ cannot run the
    # scheduler mid-setup; re-enable just before the ERET into slot A.
    _msr_daifset(2)

    arm64_p22_build_space(0)
    arm64_p22_build_space(1)
    arm64_p22_seed_futex()
    arm64_p22_build_task(0)
    arm64_p22_build_task(1)
    arm64_init_ctx(arm64_p22_ctx_for(0), arm64_p22_code_for(0), arm64_p22_stack_for(0))
    arm64_init_ctx(arm64_p22_ctx_for(1), arm64_p22_code_for(1), arm64_p22_stack_for(1))

    # Recycle both slots' ASIDs before first use; thereafter swaps need no flush.
    _dsb_ish()
    _tlbi_aside1is(P22_ASID_A << P22_ASID_SHIFT)
    _tlbi_aside1is(P22_ASID_B << P22_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p22_cur = 0
    arm64_p22_set_state(0, P22_SLOT_RUNNABLE)
    arm64_p22_set_state(1, P22_SLOT_RUNNABLE)
    arm64_p22_set_wait(0, P22_WAIT_NONE)
    arm64_p22_set_wait(1, P22_WAIT_NONE)
    arm64_p22_key0 = cast[uint64](0)
    arm64_p22_key1 = cast[uint64](0)
    arm64_p22_deadline0 = cast[uint64](0)
    arm64_p22_deadline1 = cast[uint64](0)
    arm64_p22_a_reports = 0
    arm64_p22_b_reports = 0
    arm64_p22_a_correct = 0
    arm64_p22_b_correct = 0
    arm64_p22_a_waits = 0
    arm64_p22_a_wakes = 0
    arm64_p22_wakes_issued = 0
    arm64_p22_ran_while_peer_blocked = 0
    arm64_p22_leaks = 0
    arm64_p22_swaps = 0
    arm64_current_ctx = arm64_p22_ctx_for(0)
    arm64_p22_active = 1

    enter: Ptr[char] = "[arm64] launching futex-demo EL0 tasks (waiter ASID 9, waker ASID 10)\n"
    _uart_puts(enter)

    arm64_p22_switch_to(0)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](P22_A_CTX)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> slot A (waiter) at EL0 under ASID 9
    return 0


# ===========================================================================
# Phase 23 — EL0 THREAD-LOCAL STORAGE via TPIDR_EL0: each EL0 thread installs
# its OWN thread pointer (TPIDR_EL0) once with a SETTLS syscall, then reads its
# thread-local data with a bare `mrs tpidr_el0` (no syscall). The scheduler
# SAVES the outgoing thread's TPIDR_EL0 and RESTORES the incoming thread's on
# every preemptive context switch, so two threads running the SAME EL0 code each
# keep their OWN thread pointer and see their OWN thread-local sentinel. This is
# the real register+scheduler wiring the AArch64 pthread TLS ABI relies on.
# ===========================================================================

# Per-slot accessors (two slots; Adder has no arrays-of-globals).
def arm64_p23_l1_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_A_L1
    return P23_B_L1

def arm64_p23_l2_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_A_L2
    return P23_B_L2

def arm64_p23_tls_data_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_A_TLS_DATA
    return P23_B_TLS_DATA

def arm64_p23_sentinel_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_SENTINEL_A
    return P23_SENTINEL_B

def arm64_p23_asid_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_ASID_A
    return P23_ASID_B

def arm64_p23_code_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_A_CODE
    return P23_B_CODE

def arm64_p23_stack_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_A_STACK_TOP
    return P23_B_STACK_TOP

def arm64_p23_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_A_CTX
    return P23_B_CTX

def arm64_p23_tls_for(idx: int64) -> uint64:
    if idx == 0:
        return arm64_p23_tls0
    return arm64_p23_tls1

def arm64_p23_set_tls(idx: int64, v: uint64) -> int64:
    if idx == 0:
        arm64_p23_tls0 = v
    else:
        arm64_p23_tls1 = v
    return 0

def arm64_p23_isset_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p23_set0
    return arm64_p23_set1

def arm64_p23_mark_set(idx: int64) -> int64:
    if idx == 0:
        arm64_p23_set0 = 1
    else:
        arm64_p23_set1 = 1
    return 0


# Build slot `idx`'s private address space: a clone of the kernel identity map
# (EL0 code/stack window fetchable, kernel EL1-only) PLUS one EL0-RWX mapping:
#   P23_TLS_VA -> this slot's PRIVATE physical TLS block (seeded with its own
#   thread-local sentinel). Both slots use the SAME TLS VA but it resolves
#   (through each slot's own TTBR0+ASID) to a DIFFERENT physical block.
def arm64_p23_build_space(idx: int64) -> int64:
    l1_base: uint64 = arm64_p23_l1_for(idx)
    l2_base: uint64 = arm64_p23_l2_for(idx)
    tls_pa: uint64 = arm64_p23_tls_data_for(idx)
    sentinel: uint64 = arm64_p23_sentinel_for(idx)

    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1

    l1[0] = cast[uint64](0) | DEV_FLAGS

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0
        elif cast[uint64](j) == P23_TLS_L2_INDEX:
            l2[j] = tls_pa | MEM_FLAGS_EL0             # PRIVATE per-thread TLS block
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = l2_base | DESC_TABLE

    tp: Ptr[uint8] = cast[Ptr[uint8]](tls_pa)
    tp[0] = cast[uint8](sentinel & cast[uint64](0xFF))
    _dsb_ish()
    return 0


# Materialise slot `idx`'s EL0 routine:
#   entry:
#     x0 = P23_TLS_VA ; x8 = 560 (settls) ; svc #0     (install TPIDR_EL0 once)
#   loop:
#     mrs x1, tpidr_el0 ; ldrb w0,[x1]                  (read TLS sentinel, NO syscall)
#     x8 = 561 (tick)   ; svc #0                        (report it)
#     b loop
# Both slots share identical code; only their PRIVATE TPIDR_EL0 (installed by
# settls, preserved by the scheduler) distinguishes what each thread reads.
def arm64_p23_build_task(idx: int64) -> int64:
    code_base: uint64 = arm64_p23_code_for(idx)
    a: uint64 = code_base

    # x0 = P23_TLS_VA ; x8 = 560 (settls) ; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P23_TLS_VA)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P23_SETTLS_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    loop_top: uint64 = a
    # mrs x1, tpidr_el0
    a = _emit_word(a, cast[uint64](0xD53BD041))
    # ldrb w0, [x1]
    a = _emit_word(a, cast[uint64](0x39400020))
    # x8 = 561 (tick) ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P23_TICK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # b loop
    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# TTBR0_EL1 for slot `idx`: its private L1 root with its ASID in bits[63:48].
def arm64_p23_ttbr0_for(idx: int64) -> uint64:
    return arm64_p23_l1_for(idx) | (arm64_p23_asid_for(idx) << P23_ASID_SHIFT)


# Switch the live address space to slot `idx` (TTBR0+ASID). Per-ASID tagging
# keeps each slot's translation of the shared TLS VA distinct (no broad flush).
def arm64_p23_switch_to(idx: int64) -> int64:
    _dsb_ish()
    _msr_ttbr0_el1(arm64_p23_ttbr0_for(idx))
    _isb()
    return 0


# Phase-23 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. Services:
#   SYS_P23_SETTLS_NR (560): a0 = TLS base VA. Write it into TPIDR_EL0 (the live
#       thread pointer) AND record it on the slot so the scheduler restores it on
#       every wake. Read it straight back to confirm the write landed.
#   SYS_P23_TICK_NR (561): a0 = the byte the thread read through its OWN
#       TPIDR_EL0. Tally a CORRECT read (own thread-local sentinel) or a LEAK
#       (the OTHER thread's sentinel — would mean TPIDR_EL0 was not preserved).
def arm64_p23_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"
    cur: int64 = arm64_p23_cur

    if nr == SYS_P23_SETTLS_NR:
        # Install the running thread's thread pointer into TPIDR_EL0.
        _msr_tpidr_el0(a0)
        _isb()
        # Read it straight back to confirm the system register took the value.
        got: uint64 = cast[uint64](_mrs_tpidr_el0())
        arm64_p23_set_tls(cur, got)
        arm64_p23_mark_set(cur)
        if cur == 0:
            arm64_p23_a_settls = arm64_p23_a_settls + 1
        else:
            arm64_p23_b_settls = arm64_p23_b_settls + 1

        sm: Ptr[char] = "[arm64] tls-demo: slot "
        _uart_puts(sm)
        _uart_puthex(cast[uint64](cur))
        s2: Ptr[char] = " SETTLS -> TPIDR_EL0="
        _uart_puts(s2)
        _uart_puthex(got)
        _uart_puts(nl)

        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P23_TICK_NR:
        val: uint64 = a0 & cast[uint64](0xFF)
        own: uint64 = arm64_p23_sentinel_for(cur)

        if cur == 0:
            arm64_p23_a_reads = arm64_p23_a_reads + 1
            if val == own:
                arm64_p23_a_correct = arm64_p23_a_correct + 1
        else:
            arm64_p23_b_reads = arm64_p23_b_reads + 1
            if val == own:
                arm64_p23_b_correct = arm64_p23_b_correct + 1

        # A value that is neither this thread's own sentinel nor 0 means the
        # thread read through the WRONG TPIDR_EL0 — a TLS leak across a switch.
        if val != own:
            if val != cast[uint64](0):
                arm64_p23_leaks = arm64_p23_leaks + 1
                lk: Ptr[char] = "[arm64] tls-demo LEAK: thread read another thread's TLS sentinel FAIL\n"
                _uart_puts(lk)

        # Trace the FIRST correct read from each thread.
        trace: int64 = 0
        if cur == 0:
            if arm64_p23_a_correct == 1:
                trace = 1
        else:
            if arm64_p23_b_correct == 1:
                trace = 1
        if trace != 0:
            r: Ptr[char] = "[arm64] tls-demo report: slot "
            _uart_puts(r)
            _uart_puthex(cast[uint64](cur))
            rv: Ptr[char] = " read TLS sentinel value="
            _uart_puts(rv)
            _uart_puthex(val)
            _uart_puts(nl)

        frame_ptr[0] = cast[uint64](0)
        return 0

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 23)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-23 IRQ scheduler — invoked (via arm64_sched_pick) from the EL0 IRQ
# vector with the running thread's register context already saved. Ack + re-arm
# the timer, SAVE the outgoing thread's live TPIDR_EL0 into its slot, round-
# robin to the peer slot, swap TTBR0+ASID, and RESTORE the incoming thread's
# saved TPIDR_EL0. After P23_GOAL swaps run the verdict. This save+restore of
# TPIDR_EL0 across the switch is exactly what keeps each thread's TLS private.
def arm64_p23_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this thread
        return cur_ctx

    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    # SAVE the OUTGOING thread's live thread pointer (it may have run settls or
    # could in principle mutate TPIDR_EL0); persist it on its slot.
    out_idx: int64 = arm64_p23_cur
    out_tls: uint64 = cast[uint64](_mrs_tpidr_el0())
    arm64_p23_set_tls(out_idx, out_tls)

    arm64_p23_swaps = arm64_p23_swaps + 1
    swmsg: Ptr[char] = "[arm64] tls-demo TPIDR_EL0-preserving swap\n"
    _uart_puts(swmsg)

    # Verdict once enough swaps have run.
    if arm64_p23_swaps >= P23_GOAL:
        arm64_p23_finish()
        while True:
            _wfi()

    # Round-robin to the peer slot (both threads are always RUNNABLE here).
    nxt: int64 = out_idx + 1
    if nxt >= 2:
        nxt = 0

    # Count switches that occur while BOTH threads are TLS-active AND each has
    # already read its OWN thread-local sentinel correctly — direct evidence the
    # scheduler is round-robining two threads whose TPIDR_EL0 it preserves so each
    # keeps reading its own (distinct) thread-local block across the switches.
    # (Both threads install the SAME thread-pointer VA — 0x42000000 — but it maps,
    # per ASID, to a DIFFERENT physical TLS block, which is why the sentinels they
    # read differ; the proof of preservation is correct-own-reads + zero leaks.)
    in_tls: uint64 = arm64_p23_tls_for(nxt)
    if arm64_p23_isset_for(out_idx) != 0:
        if arm64_p23_isset_for(nxt) != 0:
            if arm64_p23_a_correct > 0:
                if arm64_p23_b_correct > 0:
                    arm64_p23_both_ran_split = arm64_p23_both_ran_split + 1

    arm64_p23_cur = nxt
    arm64_p23_switch_to(nxt)                 # TTBR0+ASID -> the incoming thread

    # RESTORE the INCOMING thread's saved thread pointer into TPIDR_EL0 so it
    # resumes seeing its OWN thread-local block, regardless of what the outgoing
    # thread's TPIDR_EL0 was.
    _msr_tpidr_el0(in_tls)
    _isb()

    next_ctx: uint64 = arm64_p23_ctx_for(nxt)
    arm64_current_ctx = next_ctx
    return next_ctx


# Phase-23 verdict. PASS iff: BOTH threads installed a TLS pointer (settls);
# BOTH read their OWN thread-local sentinel through TPIDR_EL0 (no syscall); the
# scheduler preserved each thread's distinct TPIDR_EL0 across MANY switches (the
# split-TLS pillar); and ZERO cross-thread TLS leaks. Print tallies, then halt.
def arm64_p23_finish() -> int64:
    arm64_p23_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] tls-demo swaps="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p23_swaps))
    am: Ptr[char] = " a_correct="
    _uart_puts(am)
    _uart_puthex(cast[uint64](arm64_p23_a_correct))
    bm: Ptr[char] = " b_correct="
    _uart_puts(bm)
    _uart_puthex(cast[uint64](arm64_p23_b_correct))
    atm: Ptr[char] = " a_settls="
    _uart_puts(atm)
    _uart_puthex(cast[uint64](arm64_p23_a_settls))
    bsm: Ptr[char] = " b_settls="
    _uart_puts(bsm)
    _uart_puthex(cast[uint64](arm64_p23_b_settls))
    spm: Ptr[char] = " tls_split_switches="
    _uart_puts(spm)
    _uart_puthex(cast[uint64](arm64_p23_both_ran_split))
    lm: Ptr[char] = " leaks="
    _uart_puts(lm)
    _uart_puthex(cast[uint64](arm64_p23_leaks))
    _uart_puts(nl)

    ok: int64 = 1
    if arm64_p23_a_settls <= 0:
        ok = 0
    if arm64_p23_b_settls <= 0:
        ok = 0
    if arm64_p23_a_correct <= 0:
        ok = 0
    if arm64_p23_b_correct <= 0:
        ok = 0
    if arm64_p23_both_ran_split <= 0:
        ok = 0
    if arm64_p23_leaks != 0:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] tls-demo: both threads installed a TPIDR_EL0 + read their OWN thread-local sentinel; scheduler preserved each thread pointer across switches\n"
        _uart_puts(rp)
        op: Ptr[char] = "[arm64] EL0 thread-local storage (TPIDR_EL0) scheduling OK\n"
        _uart_puts(op)
        # Phase 23 complete and clean. Hand off to Phase 24 (EL0 demand paging
        # across a fresh unmapped VA window). Mask IRQs (deterministic, no timer
        # re-entry) and run the demo; arm64_run_demand_paging24_demo halts after
        # PASS. This is the Phase 23 -> 24 hand-off point.
        _msr_daifset(2)
        arm64_run_demand_paging24_demo()
        # Unreachable: arm64_run_demand_paging24_demo halts. Safety loop.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 thread-local storage scheduling FAIL\n"
        _uart_puts(fm)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-23 entry point (from the Phase-22 finish hand-off). Build both slots'
# private ASID-tagged address spaces (each mapping the SHARED TLS VA to its OWN
# private TLS block, seeded with its own sentinel) + EL0 routines + context
# blocks; recycle both ASIDs once; then ERET into slot A under its private
# TTBR0+ASID with the timer LIVE. Each thread installs its thread pointer via
# settls, then reads its thread-local sentinel through TPIDR_EL0 every tick; the
# scheduler save/restores TPIDR_EL0 per switch. Never returns (halts at verdict).
def arm64_run_tls_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 23: EL0 thread-local storage (TPIDR_EL0 / SETTLS, per-thread, scheduler-preserved)\n"
    _uart_puts(intro)

    # Mask EL1 IRQs while we build everything so a stray timer IRQ cannot run the
    # scheduler mid-setup; re-enable just before the ERET into slot A.
    _msr_daifset(2)

    arm64_p23_build_space(0)
    arm64_p23_build_space(1)
    arm64_p23_build_task(0)
    arm64_p23_build_task(1)
    arm64_init_ctx(arm64_p23_ctx_for(0), arm64_p23_code_for(0), arm64_p23_stack_for(0))
    arm64_init_ctx(arm64_p23_ctx_for(1), arm64_p23_code_for(1), arm64_p23_stack_for(1))

    # Recycle both slots' ASIDs before first use; thereafter swaps need no flush.
    _dsb_ish()
    _tlbi_aside1is(P23_ASID_A << P23_ASID_SHIFT)
    _tlbi_aside1is(P23_ASID_B << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p23_cur = 0
    arm64_p23_tls0 = cast[uint64](0)
    arm64_p23_tls1 = cast[uint64](0)
    arm64_p23_set0 = 0
    arm64_p23_set1 = 0
    arm64_p23_a_reads = 0
    arm64_p23_b_reads = 0
    arm64_p23_a_correct = 0
    arm64_p23_b_correct = 0
    arm64_p23_a_settls = 0
    arm64_p23_b_settls = 0
    arm64_p23_leaks = 0
    arm64_p23_swaps = 0
    arm64_p23_both_ran_split = 0
    arm64_current_ctx = arm64_p23_ctx_for(0)
    arm64_p23_active = 1

    enter: Ptr[char] = "[arm64] launching tls-demo EL0 threads (slot A ASID 11, slot B ASID 12)\n"
    _uart_puts(enter)

    # Slot A starts with a clean TPIDR_EL0 (it will install its own via settls).
    _msr_tpidr_el0(cast[uint64](0))
    arm64_p23_switch_to(0)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](P23_A_CTX)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> slot A at EL0 under ASID 11
    return 0


# ===========================================================================
# Phase 24 — EL0 DEMAND PAGING across a fresh, wholly-unmapped VA window.
# ===========================================================================

# Per-page sentinel the EL0 task stores then reads back. Distinct per page so a
# read-back proves the RIGHT page paged in.
def arm64_p24_sentinel_for(idx: int64) -> uint64:
    u: uint64 = cast[uint64](idx)
    return P24_SENTINEL_BASE | (u << cast[uint64](8)) | u


# VA of page `idx` inside the demand window.
def arm64_p24_va_for(idx: int64) -> uint64:
    return P24_WINDOW_BASE + (cast[uint64](idx) * P24_PAGE_SIZE)


# Install the window's L3 table under its (currently UNMAPPED) L2 slot, zeroed so
# every 4 KiB slot still translation-faults on first touch. Idempotent: if the L2
# slot already points at an L3 table it returns without re-wiring.
def arm64_p24_install_l3() -> int64:
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    if l2[cast[int64](P24_WINDOW_L2_INDEX)] != cast[uint64](0):
        return 0                          # L3 already wired under this L2 slot

    # Zero the brand-new L3 table so every still-unmapped 4 KiB slot keeps
    # faulting (each page is a genuine first-touch translation fault).
    l3: Ptr[uint64] = cast[Ptr[uint64]](P24_L3)
    i: int64 = 0
    while i < 512:
        l3[i] = cast[uint64](0)
        i = i + 1
    _dsb_ish()

    # Point the window's L2 slot at the new L3 table (table descriptor).
    l2[cast[int64](P24_WINDOW_L2_INDEX)] = P24_L3 | DESC_TABLE
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Allocate the next fresh physical page from the per-phase pool, install it as the
# L3 PTE backing VA `va` with EL0 RW permissions, then invalidate ONLY that VA's
# stale translation (tlbi vaae1is) so EL0 sees the new mapping. Returns the L3
# index installed.
def arm64_p24_map_page(va: uint64) -> uint64:
    arm64_p24_install_l3()

    # Hand out the next pool page (the handler only ever fires N_PAGES times).
    page_pa: uint64 = P24_POOL_BASE + (cast[uint64](arm64_p24_next_page) * P24_PAGE_SIZE)
    arm64_p24_next_page = arm64_p24_next_page + 1

    # Zero the backing physical page (a fresh page must start clean).
    pg: Ptr[uint64] = cast[Ptr[uint64]](page_pa)
    j: int64 = 0
    while j < 512:
        pg[j] = cast[uint64](0)
        j = j + 1
    _dsb_ish()

    # L3 index of `va` = VA[20:12].
    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P24_L3)
    l3[cast[int64](l3_index)] = page_pa | P24_PAGE_FLAGS

    # Publish the L3 edit, then flush ONLY this page's stale (faulting)
    # translation. The TLBI VAAE1IS operand is the VA's page number (VA >> 12).
    _dsb_ish()
    _tlbi_vaae1is(va >> cast[uint64](12))
    _dsb_ish()
    _isb()
    return l3_index


# Phase-24 demand-paging fault entry. Called from arm64_sync_handler for a data
# abort from EL0 while the demo is live. Decodes ESR_EL1.ISS.DFSC: a TRANSLATION
# fault (0b0001xx) on a page INSIDE the window is paged in (return 1 -> resume EL0
# at the faulting instruction, which retries). Anything else (permission fault, or
# a translation fault OUTSIDE the window) returns 0 so the fatal-fault reaper runs
# — real bugs are never masked.
def arm64_p24_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        # Not a translation fault (e.g. a permission fault) — not demand-pageable.
        return 0

    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    # Is the faulting page inside the demand window [BASE, BASE + N_PAGES*4KiB)?
    win_top: uint64 = P24_WINDOW_BASE + (cast[uint64](P24_N_PAGES) * P24_PAGE_SIZE)
    if page_va < P24_WINDOW_BASE:
        arm64_p24_outside = arm64_p24_outside + 1
        return 0
    if page_va >= win_top:
        arm64_p24_outside = arm64_p24_outside + 1
        return 0

    idx: int64 = cast[int64]((page_va - P24_WINDOW_BASE) >> cast[uint64](12))
    arm64_p24_map_page(page_va)
    arm64_p24_mapped_mask = arm64_p24_mapped_mask | (cast[uint64](1) << cast[uint64](idx))
    arm64_p24_faults = arm64_p24_faults + 1

    m: Ptr[char] = "[arm64] Phase 24 demand fault: paged in VA "
    _uart_puts(m)
    _uart_puthex(page_va)
    pi: Ptr[char] = " (page "
    _uart_puts(pi)
    _uart_puthex(cast[uint64](idx))
    cl: Ptr[char] = ")\n"
    _uart_puts(cl)
    return 1


# Materialise the Phase-24 EL0 routine into USER_CODE_BASE. For each of N_PAGES
# pages: load the page VA + its sentinel, str (FAULTS first touch; kernel pages it
# in then resumes here so the store completes), then ldr it back and hand (idx,
# value) to the kernel via SYS_P24_REPORT_NR. Finally write(1, msg, len), exit(0).
# Stores/loads fault transparently; nothing in the task references the page-fault
# path. GPR-only (no FP).
def arm64_build_p24_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE
    idx: int64 = 0
    while idx < P24_N_PAGES:
        va: uint64 = arm64_p24_va_for(idx)
        sent: uint64 = arm64_p24_sentinel_for(idx)

        # x10 = VA ; x9 = sentinel ; str x9,[x10] (faults -> demand-paged)
        a = _emit_load_imm64(a, cast[uint64](10), va)
        a = _emit_load_imm64(a, cast[uint64](9), sent)
        a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
        # x9 = 0 ; ldr x9,[x10]  (read the sentinel back through the new page)
        a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
        a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
        # report(idx, value): x0 = idx ; x1 = x9 ; x8 = 570 ; svc #0
        a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](idx))
        # mov x1, x9  (ORR x1, xzr, x9) = 0xAA0003E1 | (9<<16) = 0xAA0903E1
        a = _emit_word(a, cast[uint64](0xAA0003E1) | (cast[uint64](9) << cast[uint64](16)))
        a = _emit_load_imm64(a, cast[uint64](8), SYS_P24_REPORT_NR)
        a = _emit_word(a, cast[uint64](0xD4000001))
        idx = idx + 1

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 571; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), P24_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P24_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # exit(0): x0 = 0; x8 = 572; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P24_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-24 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. REPORT records + verifies one (page idx, read-back value) pair; write
# emits to the UART; exit runs the verdict + halts.
def arm64_p24_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P24_REPORT_NR:
        idx: int64 = cast[int64](a0)
        arm64_p24_reports = arm64_p24_reports + 1
        want: uint64 = arm64_p24_sentinel_for(idx)

        r0: Ptr[char] = "[arm64] Phase 24 read-back page "
        _uart_puts(r0)
        _uart_puthex(a0)
        ar: Ptr[char] = " -> "
        _uart_puts(ar)
        _uart_puthex(a1)
        _uart_puts(nl)

        if a1 == want:
            # Independently confirm the BACKING physical page holds the sentinel,
            # so the demand mapping truly reached the pool page (not a stale alias).
            back: Ptr[uint64] = cast[Ptr[uint64]](P24_POOL_BASE + (cast[uint64](idx) * P24_PAGE_SIZE))
            if back[0] == want:
                arm64_p24_correct_mask = arm64_p24_correct_mask | (cast[uint64](1) << cast[uint64](idx))
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P24_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(24) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_P24_EXIT_NR:
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit(24) syscall serviced\n"
        _uart_puts(em)
        arm64_p24_finish(a0)
        # Unreachable: arm64_p24_finish halts. Safety loop if it falls through.
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 24)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-24 verdict. PASS iff exit(0) AND exactly N_PAGES translation faults were
# serviced (one per page), AND every page was mapped, AND every read-back matched
# its sentinel, AND no translation fault fired OUTSIDE the window. Print the fault
# count + the required summary lines, then halt deterministically. Never returns.
def arm64_p24_finish(code: uint64) -> int64:
    arm64_p24_active = 0
    nl: Ptr[char] = "\n"

    fc: Ptr[char] = "[arm64] Phase 24 demand-paging: "
    _uart_puts(fc)
    _uart_puthex(cast[uint64](arm64_p24_faults))
    fs: Ptr[char] = " faults serviced\n"
    _uart_puts(fs)

    full: uint64 = (cast[uint64](1) << cast[uint64](P24_N_PAGES)) - cast[uint64](1)

    ok: int64 = 0
    if code == cast[uint64](0):
        if arm64_p24_faults == P24_N_PAGES:
            if arm64_p24_mapped_mask == full:
                if arm64_p24_correct_mask == full:
                    if arm64_p24_outside == 0:
                        if arm64_p24_reports == P24_N_PAGES:
                            ok = 1

    if ok != 0:
        sm: Ptr[char] = "[arm64] Phase 24 first-touch pages faulted in on demand across the window\n"
        _uart_puts(sm)
        pm: Ptr[char] = "[arm64] Phase 24 PASS\n"
        _uart_puts(pm)
        # Phase 24 complete and clean. Hand off to Phase 25 (COW fork for an EL0
        # task). IRQs stay masked (deterministic, abort-driven). The demo halts
        # after its PASS marker; this is the Phase 24 -> 25 hand-off point.
        _msr_daifset(2)
        arm64_run_cow_fork25_demo()
        # Unreachable: arm64_run_cow_fork25_demo halts. Safety loop.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] Phase 24 demand-paging FAIL\n"
        _uart_puts(fm)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-24 entry point (from the Phase-23 finish hand-off). Restore the kernel's
# identity TTBR0, force the window's L2 slot UNMAPPED (so the first touch of every
# page genuinely translation-faults), build the EL0 routine + message, arm
# Phase-24 dispatch, and ERET into the demand task at EL0t with IRQs masked
# (deterministic; the page-ins all happen on the synchronous abort path). Never
# returns (the task's exit() halts after the PASS marker).
def arm64_run_demand_paging24_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 24: EL0 demand paging across an unmapped VA window\n"
    _uart_puts(intro)

    # Mask EL1 IRQs: Phase 24 is a single-task, abort-driven demo; no scheduler.
    _msr_daifset(2)

    # Restore the kernel's identity-only TTBR0 (be explicit), then flush the TLB.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Force the window's L2 slot UNMAPPED so the first touch of every page raises a
    # translation Data Abort (a clean, repeatable initial state).
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P24_WINDOW_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Seed Phase-24 bookkeeping.
    arm64_p24_faults = 0
    arm64_p24_next_page = 0
    arm64_p24_mapped_mask = cast[uint64](0)
    arm64_p24_correct_mask = cast[uint64](0)
    arm64_p24_outside = 0
    arm64_p24_reports = 0

    p24msg: Ptr[char] = "Hello from a demand-paged EL0 window\n"
    msg_len: uint64 = _copy_msg_to(p24msg, P24_MSG_BASE)
    arm64_build_p24_routine(msg_len)

    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_p24_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 demand-paging window task (4 pages)\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; first store faults, kernel pages in
    # Unreachable: the task's exit() halts after the PASS marker.
    while True:
        _wfi()
    return 0


# ===========================================================================
# Phase 25 — COPY-ON-WRITE fork() for an EL0 task.
# ===========================================================================

# Per-space accessors (idx: 0 = child, 1 = parent).
def arm64_p25_l1_for(idx: int64) -> uint64:
    if idx == 0:
        return P25_CHILD_L1
    return P25_PARENT_L1


def arm64_p25_l2_for(idx: int64) -> uint64:
    if idx == 0:
        return P25_CHILD_L2
    return P25_PARENT_L2


def arm64_p25_l3_for(idx: int64) -> uint64:
    if idx == 0:
        return P25_CHILD_L3
    return P25_PARENT_L3


def arm64_p25_asid_for(idx: int64) -> uint64:
    if idx == 0:
        return P25_CHILD_ASID
    return P25_PARENT_ASID


def arm64_p25_stack_for(idx: int64) -> uint64:
    if idx == 0:
        return P25_CHILD_STACK_TOP
    return P25_PARENT_STACK_TOP


def arm64_p25_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P25_CHILD_CTX
    return P25_PARENT_CTX


# TTBR0_EL1 for space `idx`: its private L1 root + its ASID in bits[63:48].
def arm64_p25_ttbr0_for(idx: int64) -> uint64:
    return arm64_p25_l1_for(idx) | (arm64_p25_asid_for(idx) << P23_ASID_SHIFT)


# Switch the live translation to space `idx` (TTBR0+ASID). Per-ASID tagging keeps
# each space's COW mapping of P25_DATA_VA distinct.
def arm64_p25_switch_to(idx: int64) -> int64:
    _dsb_ish()
    _msr_ttbr0_el1(arm64_p25_ttbr0_for(idx))
    _isb()
    return 0


# Build space `idx`'s private translation tree: a fresh L1 (entry 0 device, entry
# 1 -> a fresh RAM L2 that block-maps the 1 GiB RAM Normal-WB, granting the EL0
# RWX window EL0 access), with the COW data VA's 2 MiB L2 slot pointing at a fresh
# L3 table whose single live entry (L3 idx 0) maps P25_DATA_VA to `data_pa` with
# `page_flags`. Used both for the parent (initial RW-private page) and the child
# (aliasing the SAME page RO at fork).
def arm64_p25_build_space(idx: int64, data_pa: uint64, page_flags: uint64) -> int64:
    l1_base: uint64 = arm64_p25_l1_for(idx)
    l2_base: uint64 = arm64_p25_l2_for(idx)
    l3_base: uint64 = arm64_p25_l3_for(idx)

    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)
    l3: Ptr[uint64] = cast[Ptr[uint64]](l3_base)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1
    l1[0] = cast[uint64](0) | DEV_FLAGS

    # Zero the data VA's L3 so every slot but idx 0 stays translation-faulting.
    k: int64 = 0
    while k < 512:
        l3[k] = cast[uint64](0)
        k = k + 1
    # Map the COW data page (P25_DATA_VA, L3 idx 0) to data_pa with page_flags.
    dl3: uint64 = (P25_DATA_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3[cast[int64](dl3)] = data_pa | page_flags

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0        # shared EL0 RWX code/stack window
        elif cast[uint64](j) == P25_DATA_L2_INDEX:
            l2[j] = l3_base | DESC_TABLE          # COW data VA -> private L3 table
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = l2_base | DESC_TABLE
    _dsb_ish()
    return 0


# Flip space `idx`'s COW data page L3 PTE to `page_flags` (used to mark the shared
# page RO in BOTH spaces at fork). Operates on that space's OWN L3 table.
def arm64_p25_set_data_flags(idx: int64, data_pa: uint64, page_flags: uint64) -> int64:
    l3: Ptr[uint64] = cast[Ptr[uint64]](arm64_p25_l3_for(idx))
    dl3: uint64 = (P25_DATA_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3[cast[int64](dl3)] = data_pa | page_flags
    _dsb_ish()
    return 0


# Materialise the shared EL0 fork routine at P25_CODE_BASE. Both spaces map this
# same text at the same VA. Flow:
#   entry:  x10=DATA_VA ; x9=SEED ; str x9,[x10]        (parent RW-private: no fault)
#           x8=FORK ; svc #0                            (-> x0: 0=child, 1=parent)
#           cbz x0, child                               (split on the fork return)
#   parent: x10=DATA_VA ; x9=PARENT_VAL ; str x9,[x10]  (PERMISSION fault -> COW)
#           ldr x9,[x10]                                (read back own private value)
#           x0=1 ; x1=x9 ; x8=REPORT ; svc #0
#           x0=0 ; x8=EXIT ; svc #0                     (verdict + halt)
#   child:  x10=DATA_VA ; x9=CHILD_VAL ; str x9,[x10]   (PERMISSION fault -> COW)
#           ldr x9,[x10]
#           x0=0 ; x1=x9 ; x8=REPORT ; svc #0
#           x8=DONE ; svc #0                            (kernel resumes the parent)
# Returns the EL0 VA of the instruction AFTER the FORK svc (the post-fork resume
# PC both sides re-enter at).
def arm64_build_p25_routine() -> uint64:
    a: uint64 = P25_CODE_BASE

    # pre-fork: x10=DATA_VA ; x9=SEED ; str x9,[x10]
    a = _emit_load_imm64(a, cast[uint64](10), P25_DATA_VA)
    a = _emit_load_imm64(a, cast[uint64](9), P25_SEED)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # fork(): x8 = 580 ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P25_FORK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # The post-FORK resume PC is the NEXT instruction (the cbz).
    resume_pc: uint64 = a

    # cbz x0, child  (forward branch; patched once `child` is known). Placeholder.
    cbz_addr: uint64 = a
    a = _emit_word(a, cast[uint64](0xB4000000))   # cbz x0, +0 (fixed up below)

    # ---- parent path ----
    a = _emit_load_imm64(a, cast[uint64](10), P25_DATA_VA)
    a = _emit_load_imm64(a, cast[uint64](9), P25_PARENT_VAL)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # ldr x9,[x10]
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # report(which=1, value): x0=1 ; mov x1,x9 ; x8=581 ; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_word(a, cast[uint64](0xAA0003E1) | (cast[uint64](9) << cast[uint64](16)))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P25_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))
    # exit(0): x0=0 ; x8=583 ; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P25_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # ---- child path ----
    child_addr: uint64 = a
    a = _emit_load_imm64(a, cast[uint64](10), P25_DATA_VA)
    a = _emit_load_imm64(a, cast[uint64](9), P25_CHILD_VAL)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # ldr x9,[x10]
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # report(which=0, value): x0=0 ; mov x1,x9 ; x8=581 ; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xAA0003E1) | (cast[uint64](9) << cast[uint64](16)))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P25_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))
    # done(): x8=582 ; svc #0  (kernel resumes the parent)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P25_DONE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # Patch the cbz: imm19 = (child_addr - cbz_addr) / 4, Rt = x0.
    off_child: int64 = cast[int64](child_addr) - cast[int64](cbz_addr)
    imm19: uint64 = cast[uint64](off_child >> 2) & cast[uint64](0x7FFFF)
    _emit_word(cbz_addr, cast[uint64](0xB4000000) | (imm19 << cast[uint64](5)))

    _dsb_ish()
    _isb()
    return resume_pc


# Phase-25 COW permission-fault entry. Called from arm64_sync_handler for a data
# abort from EL0 while the demo is live. A genuine COW write is a PERMISSION fault
# (DFSC 0b0011xx) that is a WRITE (ESR.ISS.WnR, bit 6) on the COW data page. We
# allocate a FRESH physical page, copy the shared page into it, remap the LIVE
# space's (arm64_p25_cur) L3 PTE for P25_DATA_VA to the fresh page RW-PRIVATE,
# flush that ASID, and return 1 so EL0 retries the store. Anything else returns 0
# so the fatal-fault reaper runs (real bugs stay fatal).
def arm64_p25_try_cow(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_PERM:
        return 0                              # not a permission fault — not COW
    wnr: uint64 = (esr >> cast[uint64](6)) & cast[uint64](1)
    if wnr == cast[uint64](0):
        return 0                              # a read perm-fault is a real bug

    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)
    if page_va != P25_DATA_VA:
        return 0                              # fault outside the COW page — fatal

    idx: int64 = arm64_p25_cur

    # Hand out the next fresh COW page from the pool.
    fresh_pa: uint64 = P25_COW_POOL_BASE + (cast[uint64](arm64_p25_next_cow) * P25_PAGE_SIZE)
    arm64_p25_next_cow = arm64_p25_next_cow + 1

    # Copy the (still-shared) backing page into the fresh private page.
    src: Ptr[uint64] = cast[Ptr[uint64]](P25_SHARED_DATA_PA)
    dst: Ptr[uint64] = cast[Ptr[uint64]](fresh_pa)
    n: int64 = 0
    while n < 512:
        dst[n] = src[n]
        n = n + 1
    _dsb_ish()

    # Remap ONLY the faulting space's L3 PTE to the fresh page, RW-PRIVATE.
    arm64_p25_set_data_flags(idx, fresh_pa, P25_PAGE_RW)

    # Record the private page for the verdict (per side).
    if idx == 0:
        arm64_p25_child_pa = fresh_pa
    else:
        arm64_p25_parent_pa = fresh_pa

    # Flush this ASID's stale (RO) translation so EL0 sees the new RW mapping.
    _dsb_ish()
    _tlbi_aside1is(arm64_p25_asid_for(idx) << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p25_cow_faults = arm64_p25_cow_faults + 1

    m: Ptr[char] = "[arm64] Phase 25 COW fault: "
    _uart_puts(m)
    if idx == 0:
        cm: Ptr[char] = "child"
        _uart_puts(cm)
    else:
        pm: Ptr[char] = "parent"
        _uart_puts(pm)
    vm: Ptr[char] = " privatised VA "
    _uart_puts(vm)
    _uart_puthex(P25_DATA_VA)
    am: Ptr[char] = " -> fresh PA "
    _uart_puts(am)
    _uart_puthex(fresh_pa)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    return 1


# fork(): build the CHILD address space aliasing the parent's shared COW page,
# flip BOTH spaces' data PTE to read-only, then ERET into the CHILD (x0=0) to run
# it to completion; the child's DONE syscall resumes the parent. `frame_ptr` is
# the parent's saved register frame at the FORK svc.
def arm64_p25_do_fork(frame_ptr: Ptr[uint64]) -> int64:
    arm64_p25_forked = 1

    # Stamp the resume PC + the parent's SP_EL0 (its EL0 stack at the FORK svc).
    arm64_p25_resume_pc = cast[uint64](_mrs_elr_el1())
    arm64_p25_parent_sp = cast[uint64](_mrs_sp_el0())

    # Build the child's wholly-private space aliasing the SAME backing page.
    arm64_p25_build_space(0, P25_SHARED_DATA_PA, P25_PAGE_RO)
    # Mark the parent's view of the page read-only too (copy-on-write share).
    arm64_p25_set_data_flags(1, P25_SHARED_DATA_PA, P25_PAGE_RO)

    # Recycle the child ASID, then flush both ASIDs' stale data-page translations.
    _dsb_ish()
    _tlbi_aside1is(P25_CHILD_ASID << P23_ASID_SHIFT)
    _tlbi_aside1is(P25_PARENT_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()

    fm: Ptr[char] = "[arm64] Phase 25 fork: built child space (ASID "
    _uart_puts(fm)
    _uart_puthex(P25_CHILD_ASID)
    a2: Ptr[char] = ") COW-sharing data page; parent ASID "
    _uart_puts(a2)
    _uart_puthex(P25_PARENT_ASID)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)

    # Cooperatively ENTER the child at the post-fork PC with x0=0 (child return).
    arm64_p25_cur = 0
    arm64_p25_switch_to(0)
    _msr_spsr_el1(SPSR_EL0T_DAIF)            # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(arm64_p25_resume_pc)
    _msr_sp_el0(P25_CHILD_STACK_TOP)
    # Child's x0 = 0; clear the rest of its caller-saved state to a clean slate by
    # only setting x0 (the routine reloads everything it needs).
    _isb()
    _eret_x0(cast[uint64](0))               # -> child at EL0 with x0 = 0
    # Unreachable: the child runs until its DONE syscall resumes the parent.
    while True:
        _wfi()
    return 0


# Resume the PARENT past the fork (x0=1) after the child's DONE syscall.
def arm64_p25_resume_parent() -> int64:
    rp: Ptr[char] = "[arm64] Phase 25: child done -> resuming parent past fork\n"
    _uart_puts(rp)
    arm64_p25_cur = 1
    arm64_p25_switch_to(1)
    _msr_spsr_el1(SPSR_EL0T_DAIF)
    _msr_elr_el1(arm64_p25_resume_pc)
    _msr_sp_el0(arm64_p25_parent_sp)
    _isb()
    _eret_x0(cast[uint64](1))               # -> parent at EL0 with x0 = 1
    while True:
        _wfi()
    return 0


# Phase-25 syscall dispatcher. fork() forks + runs the child; report() records a
# side's read-back; done() resumes the parent; exit() runs the verdict + halts.
def arm64_p25_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P25_FORK_NR:
        arm64_p25_do_fork(frame_ptr)
        # Unreachable: do_fork ERETs into the child and never returns.
        while True:
            _wfi()

    if nr == SYS_P25_REPORT_NR:
        which: int64 = cast[int64](a0)
        r0: Ptr[char] = "[arm64] Phase 25 read-back ("
        _uart_puts(r0)
        if which == 0:
            cm: Ptr[char] = "child"
            _uart_puts(cm)
            arm64_p25_child_val = a1
            arm64_p25_child_reported = 1
        else:
            pm: Ptr[char] = "parent"
            _uart_puts(pm)
            arm64_p25_parent_val = a1
            arm64_p25_parent_reported = 1
        ar: Ptr[char] = ") -> "
        _uart_puts(ar)
        _uart_puthex(a1)
        _uart_puts(nl)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P25_DONE_NR:
        arm64_p25_resume_parent()
        # Unreachable: resume_parent ERETs into the parent.
        while True:
            _wfi()

    if nr == SYS_P25_EXIT_NR:
        arm64_p25_finish(a0)
        # Unreachable: finish halts.
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 25)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-25 verdict. PASS iff: fork built the child; BOTH sides reported; the child
# read back its OWN value AND the parent read back its OWN value (each saw its own,
# not the other's or the seed); EXACTLY 2 COW permission faults were serviced (one
# per side); and the two PRIVATE backing physical pages DIVERGED (distinct PAs,
# each holding its own value) — i.e. genuine copy-on-write address-space isolation.
def arm64_p25_finish(code: uint64) -> int64:
    arm64_p25_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] Phase 25 COW summary: cow_faults="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p25_cow_faults))
    cm: Ptr[char] = " child_val="
    _uart_puts(cm)
    _uart_puthex(arm64_p25_child_val)
    pm: Ptr[char] = " parent_val="
    _uart_puts(pm)
    _uart_puthex(arm64_p25_parent_val)
    cpm: Ptr[char] = " child_pa="
    _uart_puts(cpm)
    _uart_puthex(arm64_p25_child_pa)
    ppm: Ptr[char] = " parent_pa="
    _uart_puts(ppm)
    _uart_puthex(arm64_p25_parent_pa)
    _uart_puts(nl)

    # Independently confirm each PRIVATE backing page holds its OWN side's value,
    # and that the OTHER side never overwrote the original shared page's content.
    child_back: Ptr[uint64] = cast[Ptr[uint64]](arm64_p25_child_pa)
    parent_back: Ptr[uint64] = cast[Ptr[uint64]](arm64_p25_parent_pa)

    ok: int64 = 1
    if code != cast[uint64](0):
        ok = 0
    if arm64_p25_forked == 0:
        ok = 0
    if arm64_p25_child_reported == 0:
        ok = 0
    if arm64_p25_parent_reported == 0:
        ok = 0
    if arm64_p25_cow_faults != 2:
        ok = 0
    # Each side read back its OWN value (divergence proven from EL0).
    if arm64_p25_child_val != P25_CHILD_VAL:
        ok = 0
    if arm64_p25_parent_val != P25_PARENT_VAL:
        ok = 0
    # The two private pages are DISTINCT physical pages.
    if arm64_p25_child_pa == arm64_p25_parent_pa:
        ok = 0
    if arm64_p25_child_pa == cast[uint64](0):
        ok = 0
    if arm64_p25_parent_pa == cast[uint64](0):
        ok = 0
    # And each private page independently holds its own side's value.
    if child_back[0] != P25_CHILD_VAL:
        ok = 0
    if parent_back[0] != P25_PARENT_VAL:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 25: fork gave child a private COW address space; a write by either side privatised its own page, leaving the other's untouched\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 25 PASS\n"
        _uart_puts(pp)
        # Phase 25 complete and clean. Hand off to Phase 26 (a real ELF64 loader +
        # execute). IRQs stay masked (deterministic, abort-driven). This is the
        # Phase 25 -> 26 hand-off point; the loaded program halts after its PASS.
        _msr_daifset(2)
        arm64_run_elf_loader26_demo()
        # Unreachable: arm64_run_elf_loader26_demo halts. Safety loop.
        while True:
            _wfi()
    else:
        fp: Ptr[char] = "[arm64] Phase 25 COW-fork FAIL\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-25 entry point (from the Phase-24 finish hand-off). Build the PARENT's
# private ASID-tagged space (mapping the COW data VA RW-private to the shared
# backing page seeded with P25_SEED), build the shared EL0 routine, arm Phase-25
# dispatch, and ERET into the parent at EL0t with IRQs masked. The parent writes,
# forks, and the COW page-ins all happen on the synchronous svc/abort paths.
# Never returns (the parent's exit() halts after the PASS marker).
def arm64_run_cow_fork25_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 25: copy-on-write fork() for an EL0 task\n"
    _uart_puts(intro)

    # Deterministic, abort-driven: no scheduler, EL1 IRQs masked.
    _msr_daifset(2)

    # Seed the shared backing physical data page (byte 0 = P25_SEED, rest 0).
    seedp: Ptr[uint64] = cast[Ptr[uint64]](P25_SHARED_DATA_PA)
    z: int64 = 0
    while z < 512:
        seedp[z] = cast[uint64](0)
        z = z + 1
    sb: Ptr[uint8] = cast[Ptr[uint8]](P25_SHARED_DATA_PA)
    sb[0] = cast[uint8](P25_SEED & cast[uint64](0xFF))
    _dsb_ish()

    # Build the parent space: COW data page mapped RW-PRIVATE initially (the parent
    # writes the pre-fork value with no fault; the fork flips it RO).
    arm64_p25_build_space(1, P25_SHARED_DATA_PA, P25_PAGE_RW)
    arm64_init_ctx(P25_PARENT_CTX, P25_CODE_BASE, P25_PARENT_STACK_TOP)
    arm64_init_ctx(P25_CHILD_CTX, P25_CODE_BASE, P25_CHILD_STACK_TOP)

    # Recycle both ASIDs before first use.
    _dsb_ish()
    _tlbi_aside1is(P25_PARENT_ASID << P23_ASID_SHIFT)
    _tlbi_aside1is(P25_CHILD_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_build_p25_routine()

    # Seed Phase-25 bookkeeping.
    arm64_p25_cur = 1
    arm64_p25_next_cow = 0
    arm64_p25_cow_faults = 0
    arm64_p25_forked = 0
    arm64_p25_child_reported = 0
    arm64_p25_parent_reported = 0
    arm64_p25_child_val = cast[uint64](0)
    arm64_p25_parent_val = cast[uint64](0)
    arm64_p25_child_pa = cast[uint64](0)
    arm64_p25_parent_pa = cast[uint64](0)
    arm64_p25_resume_pc = cast[uint64](0)
    arm64_p25_parent_sp = cast[uint64](0)
    arm64_p25_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 COW-fork parent task (ASID 13)\n"
    _uart_puts(enter)

    arm64_p25_switch_to(1)                  # parent's TTBR0+ASID
    _msr_spsr_el1(SPSR_EL0T_DAIF)           # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(P25_CODE_BASE)             # EL0 entry PC
    _msr_sp_el0(P25_PARENT_STACK_TOP)       # EL0 stack pointer
    _isb()
    _eret()                                 # -> parent at EL0; write, then fork
    # Unreachable: the parent's exit() halts after the PASS marker.
    while True:
        _wfi()
    return 0


# ===========================================================================
# Phase 26 — a real AArch64 ELF64 LOADER + execute.
# ===========================================================================

# --- little-endian writers into the module-scope ELF image buffer ----------
def _p26_img_u8(off: uint64, v: uint64) -> int64:
    arm64_p26_image[cast[int64](off)] = cast[uint8](v & cast[uint64](0xFF))
    return 0


def _p26_img_u16(off: uint64, v: uint64) -> int64:
    _p26_img_u8(off, v)
    _p26_img_u8(off + cast[uint64](1), v >> cast[uint64](8))
    return 0


def _p26_img_u32(off: uint64, v: uint64) -> int64:
    _p26_img_u8(off, v)
    _p26_img_u8(off + cast[uint64](1), v >> cast[uint64](8))
    _p26_img_u8(off + cast[uint64](2), v >> cast[uint64](16))
    _p26_img_u8(off + cast[uint64](3), v >> cast[uint64](24))
    return 0


def _p26_img_u64(off: uint64, v: uint64) -> int64:
    _p26_img_u32(off, v)
    _p26_img_u32(off + cast[uint64](4), v >> cast[uint64](32))
    return 0


# Store one 32-bit AArch64 instruction word at image byte offset `off`.
def _p26_img_word(off: uint64, word: uint64) -> uint64:
    _p26_img_u32(off, word)
    return off + cast[uint64](4)


# Assemble a movz + 3x movk sequence building `value` into xd, into the image at
# byte offset `off` (mirrors _emit_load_imm64 but targets the file buffer).
def _p26_img_load_imm64(off: uint64, xd: uint64, value: uint64) -> uint64:
    a: uint64 = off
    h0: uint64 = value & cast[uint64](0xFFFF)
    h1: uint64 = (value >> cast[uint64](16)) & cast[uint64](0xFFFF)
    h2: uint64 = (value >> cast[uint64](32)) & cast[uint64](0xFFFF)
    h3: uint64 = (value >> cast[uint64](48)) & cast[uint64](0xFFFF)
    a = _p26_img_word(a, cast[uint64](0xD2800000) | (h0 << cast[uint64](5)) | xd)
    a = _p26_img_word(a, cast[uint64](0xF2800000) | (cast[uint64](1) << cast[uint64](21)) | (h1 << cast[uint64](5)) | xd)
    a = _p26_img_word(a, cast[uint64](0xF2800000) | (cast[uint64](2) << cast[uint64](21)) | (h2 << cast[uint64](5)) | xd)
    a = _p26_img_word(a, cast[uint64](0xF2800000) | (cast[uint64](3) << cast[uint64](21)) | (h3 << cast[uint64](5)) | xd)
    return a


# Assemble the genuine ELF64 file image into arm64_p26_image:
#   * an Elf64_Ehdr (ET_EXEC, EM_AARCH64, ELFCLASS64/LSB) whose e_entry points at
#     the text segment's first instruction and e_phoff/e_phnum/e_phentsize
#     describe the two program headers that immediately follow,
#   * two Elf64_Phdr's: PT_LOAD #1 (PF_R|PF_X) for the text segment (code + an
#     embedded message), PT_LOAD #2 (PF_R|PF_W) for the data segment with a BSS
#     tail (p_memsz > p_filesz),
#   * the text-segment file content: the EL0 program code, padded to P26_MSG_OFF,
#     then the message bytes,
#   * the data-segment file content: P26_DATA_FILESZ initialised bytes.
# Returns the EL0 entry VA (== e_entry the loader will parse back out).
def arm64_p26_assemble_image() -> uint64:
    # Zero the whole image buffer first.
    i: int64 = 0
    while i < cast[int64](P26_IMG_MAX):
        arm64_p26_image[i] = cast[uint8](0)
        i = i + 1

    # ---- the message bytes (stored at text file offset TEXT_FOFF + MSG_OFF) ----
    msg_foff: uint64 = P26_TEXT_FOFF + P26_MSG_OFF
    m0: uint64 = cast[uint64](0x48)   # 'H'
    msgstr: Ptr[char] = "Hello from a real ELF64 loaded on aarch64\n"
    mp: Ptr[uint8] = cast[Ptr[uint8]](msgstr)
    msg_len: uint64 = cast[uint64](0)
    while mp[cast[int64](msg_len)] != 0:
        _p26_img_u8(msg_foff + msg_len, cast[uint64](mp[cast[int64](msg_len)]))
        msg_len = msg_len + cast[uint64](1)

    # ---- the EL0 program code (text segment file content) ----
    # write(1, MSG_VA, msg_len): x0=1; x1=MSG_VA; x2=len; x8=SYS_P26_WRITE_NR; svc
    a: uint64 = P26_TEXT_FOFF
    a = _p26_img_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _p26_img_load_imm64(a, cast[uint64](1), P26_MSG_VA)
    a = _p26_img_load_imm64(a, cast[uint64](2), msg_len)
    a = _p26_img_load_imm64(a, cast[uint64](8), SYS_P26_WRITE_NR)
    a = _p26_img_word(a, cast[uint64](0xD4000001))                 # svc #0
    # read a byte out of the data segment's zeroed BSS tail:
    #   x10 = BSS_VA ; ldrb w9,[x10] ; mov x0,x9 ; x8=SYS_P26_BSS_NR ; svc #0
    a = _p26_img_load_imm64(a, cast[uint64](10), P26_BSS_VA)
    a = _p26_img_word(a, cast[uint64](0x39400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))  # ldrb w9,[x10]
    a = _p26_img_word(a, cast[uint64](0xAA0003E0) | (cast[uint64](9) << cast[uint64](16)))                     # mov x0,x9
    a = _p26_img_load_imm64(a, cast[uint64](8), SYS_P26_BSS_NR)
    a = _p26_img_word(a, cast[uint64](0xD4000001))                 # svc #0
    # exit(P26_EXIT_CODE): x0=code ; x8=SYS_P26_EXIT_NR ; svc #0
    a = _p26_img_load_imm64(a, cast[uint64](0), P26_EXIT_CODE)
    a = _p26_img_load_imm64(a, cast[uint64](8), SYS_P26_EXIT_NR)
    a = _p26_img_word(a, cast[uint64](0xD4000001))                 # svc #0

    # ---- data segment file content: P26_DATA_FILESZ initialised bytes ----
    data_foff: uint64 = msg_foff + msg_len
    # Round up to keep the data file content clear of the message.
    if (data_foff & cast[uint64](7)) != cast[uint64](0):
        data_foff = (data_foff + cast[uint64](8)) & cast[uint64](0xFFFFFFFFFFFFFFF8)
    d: int64 = 0
    while d < cast[int64](P26_DATA_FILESZ):
        _p26_img_u8(data_foff + cast[uint64](d), cast[uint64](0xC0) + cast[uint64](d))
        d = d + 1

    img_end: uint64 = data_foff + P26_DATA_FILESZ
    arm64_p26_image_len = img_end

    # ---- Elf64_Ehdr ----
    _p26_img_u8(cast[uint64](0), ELF_EI_MAG0)
    _p26_img_u8(cast[uint64](1), ELF_EI_MAG1)
    _p26_img_u8(cast[uint64](2), ELF_EI_MAG2)
    _p26_img_u8(cast[uint64](3), ELF_EI_MAG3)
    _p26_img_u8(cast[uint64](4), ELFCLASS64)        # EI_CLASS
    _p26_img_u8(cast[uint64](5), ELFDATA2LSB)       # EI_DATA (little-endian)
    _p26_img_u8(cast[uint64](6), cast[uint64](1))   # EI_VERSION = EV_CURRENT
    _p26_img_u16(EH_TYPE, ET_EXEC)                  # e_type
    _p26_img_u16(EH_MACHINE, EM_AARCH64)            # e_machine
    _p26_img_u32(cast[uint64](20), cast[uint64](1)) # e_version
    _p26_img_u64(EH_ENTRY, P26_TEXT_VA)             # e_entry = first text insn VA
    _p26_img_u64(EH_PHOFF, EHDR_SIZE)               # e_phoff = 64 (phdrs follow)
    _p26_img_u16(cast[uint64](52), EHDR_SIZE)       # e_ehsize
    _p26_img_u16(EH_PHENTSIZE, PHDR_SIZE)           # e_phentsize = 56
    _p26_img_u16(EH_PHNUM, cast[uint64](2))         # e_phnum = 2

    # ---- Elf64_Phdr #1: text segment (PT_LOAD, R+X) ----
    p1: uint64 = EHDR_SIZE                          # 64
    _p26_img_u32(p1 + PH_TYPE, PT_LOAD)
    _p26_img_u32(p1 + PH_FLAGS, PF_R | PF_X)
    _p26_img_u64(p1 + PH_OFFSET, P26_TEXT_FOFF)
    _p26_img_u64(p1 + PH_VADDR, P26_TEXT_VA)
    _p26_img_u64(p1 + cast[uint64](24), P26_TEXT_VA)      # p_paddr (unused)
    # text file size spans through the message; mem size == file size (no BSS).
    text_filesz: uint64 = (msg_foff + msg_len) - P26_TEXT_FOFF
    _p26_img_u64(p1 + PH_FILESZ, text_filesz)
    _p26_img_u64(p1 + PH_MEMSZ, text_filesz)
    _p26_img_u64(p1 + cast[uint64](48), P26_PAGE_SIZE)    # p_align

    # ---- Elf64_Phdr #2: data segment (PT_LOAD, R+W, with a BSS tail) ----
    p2: uint64 = EHDR_SIZE + PHDR_SIZE              # 120
    _p26_img_u32(p2 + PH_TYPE, PT_LOAD)
    _p26_img_u32(p2 + PH_FLAGS, PF_R | PF_W)
    _p26_img_u64(p2 + PH_OFFSET, data_foff)
    _p26_img_u64(p2 + PH_VADDR, P26_DATA_VA)
    _p26_img_u64(p2 + cast[uint64](24), P26_DATA_VA)      # p_paddr (unused)
    _p26_img_u64(p2 + PH_FILESZ, P26_DATA_FILESZ)         # 8 init bytes
    _p26_img_u64(p2 + PH_MEMSZ, P26_DATA_MEMSZ)           # mem > file => BSS tail
    _p26_img_u64(p2 + cast[uint64](48), P26_PAGE_SIZE)    # p_align

    _dsb_ish()
    return P26_TEXT_VA


# Derive the L3 PAGE flags for a segment from its parsed ELF p_flags (W^X):
#   PF_X (and not PF_W) -> EL0 read-only + executable (text).
#   PF_W               -> EL0 read/write + non-exec (data; W^X).
#   else               -> EL0 read-only + non-exec.
def arm64_p26_flags_for(pflags: uint64) -> uint64:
    if (pflags & PF_W) != cast[uint64](0):
        return P26_PAGE_RW
    if (pflags & PF_X) != cast[uint64](0):
        return P26_PAGE_RX
    return P26_PAGE_RO


# Build the loaded program's fresh EL0 address space: a private L1 (entry 0 device,
# entry 1 -> a fresh RAM L2 block-mapping the 1 GiB RAM Normal-WB EL1-only) with
# the text / data / stack 2 MiB slots redirected to private (zeroed) L3 tables.
# The loader stamps the segment pages into those L3 tables; first touch then takes
# a translation fault the abort path accounts and resumes.
def arm64_p26_build_space() -> int64:
    l1: Ptr[uint64] = cast[Ptr[uint64]](P26_L1)
    l2: Ptr[uint64] = cast[Ptr[uint64]](P26_L2)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1
    l1[0] = cast[uint64](0) | DEV_FLAGS

    # Zero the three private L3 tables (every slot translation-faults until mapped).
    tl3: Ptr[uint64] = cast[Ptr[uint64]](P26_TEXT_L3)
    dl3: Ptr[uint64] = cast[Ptr[uint64]](P26_DATA_L3)
    sl3: Ptr[uint64] = cast[Ptr[uint64]](P26_STACK_L3)
    k: int64 = 0
    while k < 512:
        tl3[k] = cast[uint64](0)
        dl3[k] = cast[uint64](0)
        sl3[k] = cast[uint64](0)
        k = k + 1

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == P26_TEXT_L2_INDEX:
            l2[j] = P26_TEXT_L3 | DESC_TABLE
        elif cast[uint64](j) == P26_DATA_L2_INDEX:
            l2[j] = P26_DATA_L3 | DESC_TABLE
        elif cast[uint64](j) == P26_STACK_L2_INDEX:
            l2[j] = P26_STACK_L3 | DESC_TABLE
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = P26_L2 | DESC_TABLE
    _dsb_ish()

    # Map the EL0 stack page now (RW non-exec) so the program has a stack on entry.
    sidx: uint64 = (P26_STACK_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    sl3[cast[int64](sidx)] = P26_STACK_PA | P26_PAGE_RW
    sp: Ptr[uint64] = cast[Ptr[uint64]](P26_STACK_PA)
    z: int64 = 0
    while z < 512:
        sp[z] = cast[uint64](0)
        z = z + 1
    _dsb_ish()
    return 0


# Map [seg_va, seg_va + memsz) of a loaded segment onto `seg_pa` with `page_flags`
# in its 2 MiB slot's private L3 table. The backing page is pre-cleared, the
# p_filesz file bytes copied in from the image, and the BSS tail left zeroed. Only
# the segment's first 4 KiB page is wired (our test segments fit in one page).
def arm64_p26_map_segment(seg_va: uint64, seg_pa: uint64, foff: uint64, filesz: uint64, memsz: uint64, l3_base: uint64, page_flags: uint64) -> int64:
    # Clear the backing page (the BSS tail beyond filesz must read as zero).
    pg: Ptr[uint8] = cast[Ptr[uint8]](seg_pa)
    c: int64 = 0
    while c < cast[int64](P26_PAGE_SIZE):
        pg[c] = cast[uint8](0)
        c = c + 1

    # Copy p_filesz file bytes from the image into the backing page.
    n: uint64 = cast[uint64](0)
    while n < filesz:
        pg[cast[int64](n)] = arm64_p26_image[cast[int64](foff + n)]
        n = n + cast[uint64](1)
    _dsb_ish()

    # Stamp the segment's first-page L3 PTE with the W^X-derived permissions.
    l3: Ptr[uint64] = cast[Ptr[uint64]](l3_base)
    idx: uint64 = (seg_va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3[cast[int64](idx)] = seg_pa | page_flags
    _dsb_ish()
    _isb()
    return 0


# Parse + load the assembled ELF64 image into the fresh EL0 space. Validates the
# header, walks the program-header table, and maps every PT_LOAD. Returns e_entry
# on success, 0 on a validation failure.
def arm64_p26_load_elf() -> uint64:
    arm64_p26_parse_ok = 0
    arm64_p26_segs_loaded = 0

    # --- validate e_ident magic + class + data ---
    if cast[uint64](arm64_p26_image[0]) != ELF_EI_MAG0:
        return cast[uint64](0)
    if cast[uint64](arm64_p26_image[1]) != ELF_EI_MAG1:
        return cast[uint64](0)
    if cast[uint64](arm64_p26_image[2]) != ELF_EI_MAG2:
        return cast[uint64](0)
    if cast[uint64](arm64_p26_image[3]) != ELF_EI_MAG3:
        return cast[uint64](0)
    if cast[uint64](arm64_p26_image[4]) != ELFCLASS64:
        return cast[uint64](0)
    if cast[uint64](arm64_p26_image[5]) != ELFDATA2LSB:
        return cast[uint64](0)

    # --- read header fields ---
    e_type: uint64 = _p26_rd16(EH_TYPE)
    e_machine: uint64 = _p26_rd16(EH_MACHINE)
    e_entry: uint64 = _p26_rd64(EH_ENTRY)
    e_phoff: uint64 = _p26_rd64(EH_PHOFF)
    e_phentsize: uint64 = _p26_rd16(EH_PHENTSIZE)
    e_phnum: uint64 = _p26_rd16(EH_PHNUM)

    if e_type != ET_EXEC:
        return cast[uint64](0)
    if e_machine != EM_AARCH64:
        return cast[uint64](0)

    hm: Ptr[char] = "[arm64] Phase 26 ELF: class64 LSB, machine=AArch64, type=EXEC, entry="
    _uart_puts(hm)
    _uart_puthex(e_entry)
    pm: Ptr[char] = " phoff="
    _uart_puts(pm)
    _uart_puthex(e_phoff)
    nm: Ptr[char] = " phnum="
    _uart_puts(nm)
    _uart_puthex(e_phnum)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)

    arm64_p26_parse_ok = 1
    arm64_p26_entry = e_entry

    # --- walk the program-header table; map every PT_LOAD ---
    ph: uint64 = 0
    while ph < e_phnum:
        base: uint64 = e_phoff + (ph * e_phentsize)
        p_type: uint64 = _p26_rd32(base + PH_TYPE)
        if p_type == PT_LOAD:
            p_flags: uint64 = _p26_rd32(base + PH_FLAGS)
            p_offset: uint64 = _p26_rd64(base + PH_OFFSET)
            p_vaddr: uint64 = _p26_rd64(base + PH_VADDR)
            p_filesz: uint64 = _p26_rd64(base + PH_FILESZ)
            p_memsz: uint64 = _p26_rd64(base + PH_MEMSZ)
            page_flags: uint64 = arm64_p26_flags_for(p_flags)

            # Route the segment to its dedicated backing page + L3 by its VADDR.
            seg_pa: uint64 = cast[uint64](0)
            l3_base: uint64 = cast[uint64](0)
            if p_vaddr == P26_TEXT_VA:
                seg_pa = P26_TEXT_PA
                l3_base = P26_TEXT_L3
            elif p_vaddr == P26_DATA_VA:
                seg_pa = P26_DATA_PA
                l3_base = P26_DATA_L3
            else:
                # An unexpected PT_LOAD vaddr — fail loud rather than mis-map.
                return cast[uint64](0)

            arm64_p26_map_segment(p_vaddr, seg_pa, p_offset, p_filesz, p_memsz, l3_base, page_flags)
            arm64_p26_segs_loaded = arm64_p26_segs_loaded + 1

            sm: Ptr[char] = "[arm64] Phase 26 PT_LOAD: vaddr="
            _uart_puts(sm)
            _uart_puthex(p_vaddr)
            fm: Ptr[char] = " filesz="
            _uart_puts(fm)
            _uart_puthex(p_filesz)
            mm: Ptr[char] = " memsz="
            _uart_puts(mm)
            _uart_puthex(p_memsz)
            xm: Ptr[char] = " flags="
            _uart_puts(xm)
            _uart_puthex(p_flags)
            am: Ptr[char] = " -> pa="
            _uart_puts(am)
            _uart_puthex(seg_pa)
            _uart_puts(nl)
        ph = ph + cast[uint64](1)

    return e_entry


# Little-endian readers out of the image buffer (used by the parser).
def _p26_rd16(off: uint64) -> uint64:
    b0: uint64 = cast[uint64](arm64_p26_image[cast[int64](off)])
    b1: uint64 = cast[uint64](arm64_p26_image[cast[int64](off + cast[uint64](1))])
    return b0 | (b1 << cast[uint64](8))


def _p26_rd32(off: uint64) -> uint64:
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 4:
        r = r | (cast[uint64](arm64_p26_image[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


def _p26_rd64(off: uint64) -> uint64:
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 8:
        r = r | (cast[uint64](arm64_p26_image[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


# Phase-26 demand-fault entry. A first touch of a loaded segment page takes a
# TRANSLATION fault (the loader pre-stamped the PTE, so this is the AF/translation
# of the freshly-mapped page within the live ASID). We confirm the faulting VA is
# inside a loaded segment, account it, flush that VA, and resume (return 1). A
# fault outside the loaded segments returns 0 -> the fatal-fault reaper.
def arm64_p26_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0

    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    in_seg: int64 = 0
    if page_va == P26_TEXT_VA:
        arm64_p26_text_faults = arm64_p26_text_faults + 1
        in_seg = 1
    elif page_va == P26_DATA_VA:
        arm64_p26_data_faults = arm64_p26_data_faults + 1
        in_seg = 1
    if in_seg == 0:
        return 0

    _dsb_ish()
    _tlbi_vaae1is(page_va >> cast[uint64](12))
    _dsb_ish()
    _isb()

    m: Ptr[char] = "[arm64] Phase 26 segment fault: paged in VA "
    _uart_puts(m)
    _uart_puthex(page_va)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    return 1


# Phase-26 syscall dispatcher. Routed while the loaded program runs. write() emits
# its message to the UART; bss-report records the byte it read from the BSS tail;
# exit() runs the loader verdict + halts.
def arm64_p26_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P26_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[cast[int64](n)])
            n = n + cast[uint64](1)
        arm64_p26_msg_bytes = cast[int64](a2)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_P26_BSS_NR:
        arm64_p26_bss_val = a0
        arm64_p26_bss_reported = 1
        bm: Ptr[char] = "[arm64] Phase 26 program read BSS-tail byte -> "
        _uart_puts(bm)
        _uart_puthex(a0)
        _uart_puts(nl)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P26_EXIT_NR:
        arm64_p26_exit_code = a0
        arm64_p26_exited = 1
        arm64_p26_finish(a0)
        # Unreachable: finish halts.
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 26)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-26 verdict. PASS iff: the ELF header validated; BOTH PT_LOAD segments were
# mapped; the program wrote its full message (it ran from the loaded text mapping);
# it read back a ZERO byte from the BSS tail (BSS zeroing worked); and it exited
# with the expected status (proving e_entry executed the loaded code end-to-end).
def arm64_p26_finish(code: uint64) -> int64:
    arm64_p26_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] Phase 26 loader summary: parse_ok="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p26_parse_ok))
    g1: Ptr[char] = " segs="
    _uart_puts(g1)
    _uart_puthex(cast[uint64](arm64_p26_segs_loaded))
    g2: Ptr[char] = " text_faults="
    _uart_puts(g2)
    _uart_puthex(cast[uint64](arm64_p26_text_faults))
    g3: Ptr[char] = " msg_bytes="
    _uart_puts(g3)
    _uart_puthex(cast[uint64](arm64_p26_msg_bytes))
    g4: Ptr[char] = " bss_val="
    _uart_puts(g4)
    _uart_puthex(arm64_p26_bss_val)
    g5: Ptr[char] = " exit="
    _uart_puts(g5)
    _uart_puthex(arm64_p26_exit_code)
    _uart_puts(nl)

    ok: int64 = 1
    if arm64_p26_parse_ok == 0:
        ok = 0
    if arm64_p26_segs_loaded != 2:
        ok = 0
    if arm64_p26_msg_bytes <= 0:
        ok = 0
    if arm64_p26_bss_reported == 0:
        ok = 0
    if arm64_p26_bss_val != cast[uint64](0):
        ok = 0
    if arm64_p26_exited == 0:
        ok = 0
    if code != P26_EXIT_CODE:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 26: loaded a genuine AArch64 ELF64 (parsed header + 2 PT_LOADs, W^X-mapped, BSS-zeroed) and ran it at EL0 to exit\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 26 PASS\n"
        _uart_puts(pp)
    else:
        fp: Ptr[char] = "[arm64] Phase 26 ELF-loader FAIL\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-26 entry point (from the Phase-25 finish hand-off). Assemble the ELF64
# image, build a fresh EL0 address space, PARSE + LOAD the ELF (mapping its
# PT_LOAD segments with W^X protections), then ERET into e_entry at EL0t with IRQs
# masked. The segment page-ins happen on the synchronous abort path; the loaded
# program's write()/exit() syscalls drive the rest. Never returns.
def arm64_run_elf_loader26_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 26: AArch64 ELF64 loader + execute\n"
    _uart_puts(intro)

    # Deterministic, abort-driven: no scheduler, EL1 IRQs masked.
    _msr_daifset(2)

    # Seed Phase-26 bookkeeping.
    arm64_p26_segs_loaded = 0
    arm64_p26_text_faults = 0
    arm64_p26_data_faults = 0
    arm64_p26_msg_bytes = 0
    arm64_p26_bss_val = cast[uint64](0xFF)
    arm64_p26_bss_reported = 0
    arm64_p26_exit_code = cast[uint64](0xFFFF)
    arm64_p26_exited = 0
    arm64_p26_parse_ok = 0
    arm64_p26_entry = cast[uint64](0)

    # Assemble the genuine ELF64 file image, then build the program's EL0 space.
    arm64_p26_assemble_image()
    arm64_p26_build_space()

    am: Ptr[char] = "[arm64] Phase 26: assembled ELF64 image ("
    _uart_puts(am)
    _uart_puthex(arm64_p26_image_len)
    bm: Ptr[char] = " bytes); parsing + loading\n"
    _uart_puts(bm)

    # Recycle this ASID before first use.
    _dsb_ish()
    _tlbi_aside1is(P26_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()

    # Switch to the program's TTBR0+ASID so the loader's mapping edits are live.
    _msr_ttbr0_el1(P26_L1 | (P26_ASID << P23_ASID_SHIFT))
    _dsb_ish()
    _tlbi_aside1is(P26_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()

    entry: uint64 = arm64_p26_load_elf()
    if entry == cast[uint64](0):
        fp: Ptr[char] = "[arm64] Phase 26 ELF-loader FAIL\n"
        _uart_puts(fp)
        _msr_daifset(2)
        while True:
            _wfi()

    arm64_p26_active = 1

    enter: Ptr[char] = "[arm64] launching loaded ELF program at EL0 (ASID 15), entry "
    _uart_puts(enter)
    _uart_puthex(entry)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)

    _msr_spsr_el1(SPSR_EL0T_DAIF)           # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(entry)                     # EL0 entry PC = parsed e_entry
    _msr_sp_el0(P26_STACK_TOP)              # EL0 stack pointer
    _isb()
    _eret()                                 # -> EL0; segments fault in, program runs
    # Unreachable: the program's exit() halts after the PASS marker.
    while True:
        _wfi()
    return 0


def kmain() -> int64:
    # Select the board descriptor (BOARD_SEL) into the runtime board globals
    # before any console output, so UART/GIC/RAM addresses match the target.
    board_init()

    banner: Ptr[char] = "HAMNIX aarch64 boot OK\n"
    _uart_puts(banner)

    arm64_mmu_init()
    mmu_msg: Ptr[char] = "[arm64] MMU enabled\n"
    _uart_puts(mmu_msg)

    arm64_gic_init()
    arm64_timer_init()
    gic_msg: Ptr[char] = "[arm64] GICv2 + timer up\n"
    _uart_puts(gic_msg)

    # Wait for timer IRQs. After TICK_LIMIT ticks the IRQ handler runs the
    # Phase-4 single-task EL0 svc demo; on that task's exit() the syscall
    # dispatcher hands off to Phase 5 (preemptive two-task scheduling). Control
    # never returns here.
    while True:
        _wfi()
    return 0

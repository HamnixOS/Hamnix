# arch/arm64/kmain.ad — Phase 3 bare-metal aarch64 interrupt-driven spine.
#
# This is the Adder-level kernel that boots on QEMU `virt`. The boot stub
# arch/arm64/boot.S sets up a stack and branches to kmain(); the EL1 exception
# vector table lives in arch/arm64/vectors.S and its IRQ entry calls back into
# the Adder handler arm64_irq_handler() below.
#
# What kmain() does, all driven from Adder:
#   1. Print a recognizable banner over the PL011 UART (MMIO @0x0900_0000).
#   2. Bring up a minimal identity-mapped MMU (1 GiB block descriptors:
#      device region @0x0000_0000, RAM @0x4000_0000) and enable it.
#   3. Install the EL1 vector table (VBAR_EL1) and initialise GICv2
#      (distributor @0x0800_0000, CPU interface @0x0801_0000).
#   4. Program the ARM generic *virtual* timer (PPI INTID 27) for a periodic
#      tick and unmask IRQs.
#   5. Spin in WFI. Each timer IRQ prints "[arm64] timer tick"; after 5 ticks
#      the handler prints "[arm64] timer IRQ OK".
#   6. (Phase 4) Drop to EL0: hand-emit a tiny AArch64 user routine into an
#      identity-mapped, EL0-accessible 2 MiB window, program SPSR_EL1 (EL0t),
#      ELR_EL1 (user entry) and SP_EL0 (user stack), then `eret` into it. The
#      EL0 routine issues write(1, msg, len) then exit(0) via `svc #0`. Each
#      svc traps to the "Lower EL using AArch64" Synchronous vector, which
#      saves the GPR frame and calls the Adder dispatcher arm64_sync_handler():
#      it reads ESR_EL1.EC to confirm SVC, services the syscall (write -> UART,
#      exit -> record code + halt), and writes the return value back into the
#      frame's x0 slot before eret-ing back to EL0. On exit() the test halts
#      after printing "[arm64] EL0 syscall OK".
#
# The privileged system-register pokes (MSR/MRS to VBAR_EL1, SCTLR_EL1,
# TTBR0_EL1, MAIR_EL1, TCR_EL1, CNTV_*, DAIF, SPSR_EL1, ELR_EL1, SP_EL0,
# ESR_EL1) plus DSB/ISB/TLBI/WFI/ERET are emitted by codegen_arm64.py as
# recognised intrinsics (_msr_*, _mrs_*, _dsb_ish, _isb, _tlbi_vmalle1is,
# _wfi, _eret). Everything else — GIC/timer MMIO, the page-table fill, the
# IRQ/syscall service logic, the EL0 blob builder — is ordinary Adder.

# ---------------------------------------------------------------------------
# PL011 UART (QEMU virt, primary instance).
#   DR : base + 0x00 — write a byte to transmit it
#   FR : base + 0x18 — bit 5 (0x20) = TX FIFO full (TXFF)
# ---------------------------------------------------------------------------
PL011_BASE: uint64 = 0x09000000
PL011_FR_TXFF: uint64 = 0x20

# ---------------------------------------------------------------------------
# GICv2 (QEMU virt).
#   GICD (distributor)  base = 0x0800_0000
#   GICC (cpu interface) base = 0x0801_0000
# ---------------------------------------------------------------------------
GICD_BASE: uint64 = 0x08000000
GICC_BASE: uint64 = 0x08010000

GICD_CTLR: uint64 = 0x000
GICD_ISENABLER: uint64 = 0x100      # set-enable, 1 bit / INTID, 32 / reg
GICD_IPRIORITYR: uint64 = 0x400     # 8 bits / INTID (byte addressed)

GICC_CTLR: uint64 = 0x000
GICC_PMR: uint64 = 0x004            # priority mask
GICC_BPR: uint64 = 0x008
GICC_IAR: uint64 = 0x00C            # interrupt acknowledge
GICC_EOIR: uint64 = 0x010           # end of interrupt

VTIMER_INTID: uint64 = 27           # virtual timer PPI
TICK_LIMIT: int64 = 5

# ---------------------------------------------------------------------------
# Phase 4: EL0 userspace. A tiny hand-emitted AArch64 routine is written into
# an identity-mapped RAM page and entered via `eret` with SPSR_EL1 selecting
# EL0t. It issues two syscalls mirroring the Linux aarch64 ABI (x8 = nr,
# x0..x5 = args, return in x0): write(1, msg, len) then exit(0).
# ---------------------------------------------------------------------------
USER_CODE_BASE: uint64 = 0x40200000   # EL0 instruction page (identity-mapped)
USER_MSG_BASE: uint64 = 0x40201000    # EL0 message buffer
USER_STACK_TOP: uint64 = 0x40280000   # EL0 stack top (grows down), 16B-aligned

# Linux-shape aarch64 syscall numbers used by the demo.
SYS_WRITE_NR: uint64 = 64
SYS_EXIT_NR: uint64 = 93

# Phase 8: a broader EL0 syscall surface. These mirror the Linux aarch64 ABI
# syscall numbers so the dispatch-by-x8 path proves a realistic multi-call
# interface (args in x0..x5, return in x0). One EL0 task exercises each in turn.
#   getpid (172): return the running task's PID.
#   gettid (178): return the running task's TID (== PID for our single thread).
#   sched_yield (124): voluntary yield; the kernel acknowledges and resumes.
#   brk (214): set the program break. brk(0) queries the current break; a
#              non-zero arg moves the break (within a fixed kernel-tracked heap
#              window) and returns the resulting break, sbrk-style.
#   clock_gettime-shape read (kernel-private 513): return CNTVCT_EL0 (the
#              monotonically-advancing virtual counter) so EL0 can observe time.
SYS_GETPID_NR: uint64 = 172
SYS_GETTID_NR: uint64 = 178
SYS_YIELD_NR: uint64 = 124
SYS_BRK_NR: uint64 = 214
SYS_CLOCK_NR: uint64 = 513

# Phase 6: a deliberately-EL1-only EL0 virtual address. RAM is split into 2 MiB
# L2 blocks; only the block at USER_L2_INDEX (0x4020_0000 .. 0x403F_FFFF) carries
# AP[1] (EL0 access). The block at 0x4040_0000 (L2 index 2) is mapped Normal
# EL1-only (no AP[1]), so an EL0 load from it raises a Data Abort (permission
# fault) — exactly the bad access the page-fault handler must catch. We pick a
# memorable sentinel so the reported FAR_EL1 is unmistakable in the log.
FAULT_VA: uint64 = 0x40400000

# Page-fault bookkeeping: set non-zero by the handler once it has caught and
# reported an EL0 abort, so the launcher can confirm the task was terminated
# (not resumed into the faulting instruction) before proceeding to Phase 5.
arm64_fault_handled: int64 = 0

# SPSR_EL1 value to ERET into EL0t with all interrupts masked: bits[3:0]=0
# (EL0t) and DAIF (bits[9:6]) set. 0x3C0 = D|A|I|F masked, mode EL0t.
SPSR_EL0T_DAIF: uint64 = 0x3C0

# Phase 7: per-task TTBR0_EL1 address-space isolation.
#
# Two EL0 tasks each get their OWN level-1 translation table root. Both map the
# SAME virtual address (ISO_SHARED_VA) but to DIFFERENT physical pages, so a
# load from that VA returns task-private data. The kernel switches TTBR0_EL1 (+
# TLB maintenance) between the two tasks; if isolation holds, task A reads its
# sentinel (0xAA) and task B reads its own (0xBB) — neither can see the other's.
#
# Each task's L1 + L2 tables live at distinct EL1-only physical pages (so EL0
# cannot tamper with its own translation tables). The two task-private physical
# data pages also live in EL1-only-for-the-OTHER space: each is only mapped (at
# ISO_SHARED_VA, EL0-accessible) by its own table, proving the isolation.
# The shared VA must be 2 MiB-aligned (it is granted EL0 access as a whole L2
# block). Index 3 (0x4060_0000) is clear of the EL0 code window (index 1) and
# the Phase-6 fault sentinel (index 2).
ISO_SHARED_VA: uint64 = 0x40600000     # the common VA both tasks dereference
ISO_SHARED_L2_INDEX: uint64 = 3        # (0x4060_0000 - 0x4000_0000) / 2 MiB

# Task A address space: L1 root and its RAM L2 table (each a 4 KiB-aligned page
# in EL1-only RAM). The private data BLOCK is a distinct 2 MiB-aligned physical
# region (so the L2 block descriptor for ISO_SHARED_VA can point at it).
ISO_A_L1: uint64 = 0x40110000
ISO_A_L2: uint64 = 0x40111000
ISO_A_DATA: uint64 = 0x40800000        # phys 2 MiB block A maps at ISO_SHARED_VA for A
# Task B address space: L1 root, its RAM L2 table, and its private data block.
ISO_B_L1: uint64 = 0x40114000
ISO_B_L2: uint64 = 0x40115000
ISO_B_DATA: uint64 = 0x40a00000        # phys 2 MiB block B maps at ISO_SHARED_VA for B

# The two sentinels written into the private data pages. Whichever value a task
# reads back at ISO_SHARED_VA identifies which physical page its TTBR0 reached.
ISO_SENTINEL_A: uint64 = 0xAA
ISO_SENTINEL_B: uint64 = 0xBB

# The EL0 code page for the isolation tasks is the existing EL0 RWX window
# (USER_CODE_BASE @0x40200000), identity-mapped EL0-RWX in BOTH task tables.
# The isolation "report" syscall number (kernel-private; outside the Linux ABI
# range used by write/exit) carries the value the task read at ISO_SHARED_VA.
SYS_ISO_REPORT_NR: uint64 = 512

# ESR_EL1.EC (bits[31:26]) value for "SVC instruction execution in AArch64".
ESR_EC_SVC64: uint64 = 0x15

# Phase 6: ESR_EL1.EC values for memory aborts taken from a LOWER EL (EL0):
#   0x20 = Instruction Abort from a lower EL
#   0x21 = Instruction Abort from the current EL
#   0x24 = Data Abort from a lower EL
#   0x25 = Data Abort from the current EL
# The EL0 page-fault path catches 0x20 (bad fetch) and 0x24 (bad load/store);
# FAR_EL1 then holds the faulting virtual address.
ESR_EC_IABORT_LOWER: uint64 = 0x20
ESR_EC_DABORT_LOWER: uint64 = 0x24

# Recorded EL0 exit code (written by the exit syscall) and a done flag.
arm64_el0_exit_code: int64 = -1
arm64_el0_exited: int64 = 0

# Phase 7: per-task TTBR0_EL1 address-space isolation bookkeeping. While the
# isolation demo runs, arm64_iso_active is non-zero; the svc dispatcher then
# routes the demo's "report" syscall (nr 512) into the Phase-7 driver instead
# of the Phase-4 write/exit logic. arm64_iso_reported_a/b latch the value each
# task read back from the SHARED virtual address through its OWN TTBR0, so the
# kernel can prove the two tasks saw different physical memory at the same VA.
arm64_iso_active: int64 = 0
arm64_iso_reported_a: uint64 = 0
arm64_iso_reported_b: uint64 = 0
# Which isolation task is currently live (0 = A, 1 = B).
arm64_iso_cur: int64 = 0

# Phase 8: broader EL0 syscall surface bookkeeping. While the multi-syscall demo
# task runs, arm64_sys_active is non-zero so the svc dispatcher routes calls into
# the Phase-8 handler (getpid/gettid/yield/brk/clock) instead of the Phase-4
# write/exit-only path. arm64_sys_pid is the PID the kernel reports to the task.
# arm64_sys_brk tracks the program break, seeded to the heap base; brk() bumps it
# within [SYS_HEAP_BASE, SYS_HEAP_END). arm64_sys_clock_first latches the first
# CNTVCT_EL0 the task read so the kernel can confirm a later read advanced (proving
# the clock is live + monotonic). arm64_sys_calls counts serviced syscalls.
arm64_sys_active: int64 = 0
arm64_sys_pid: uint64 = 0
arm64_sys_brk: uint64 = 0
arm64_sys_clock_first: uint64 = 0
arm64_sys_clock_seen: int64 = 0
arm64_sys_calls: int64 = 0

# Phase 8 program-break window. The "heap" is a fixed EL0-RWX region inside the
# existing 2 MiB EL0 window (USER_L2_INDEX): brk() may only move the break within
# [SYS_HEAP_BASE, SYS_HEAP_END). The demo task brk(0)s to query the initial break,
# then brk(SYS_HEAP_BASE + 0x1000) to grow it by 4 KiB and confirms the return.
SYS_HEAP_BASE: uint64 = 0x40230000
SYS_HEAP_END: uint64 = 0x40238000
SYS_HEAP_GROW: uint64 = 0x40231000     # the break the demo task requests (BASE + 4 KiB)

# The fixed PID/TID the kernel assigns the single Phase-8 EL0 task.
SYS_DEMO_PID: uint64 = 0x2A            # 42

# ---------------------------------------------------------------------------
# Identity-mapped L1 page table. A single level-1 table of 512 8-byte block
# descriptors (4 KiB granule => each L1 entry spans 1 GiB). We place it at a
# fixed, 4 KiB-aligned physical address in RAM, well past the kernel image
# (loaded at 0x4008_0000) and its 64 KiB boot stack. RAM is identity-mapped
# Normal-WB by this very table, so the page used to hold the table is itself
# cacheable Normal memory — fine, the table is read by the page-table walker
# regardless.
# ---------------------------------------------------------------------------
L1_PGTABLE: uint64 = 0x40100000
# Phase 4: a second-level (L2) table covering the 1 GiB RAM block at
# 0x4000_0000 in 2 MiB blocks. We replace the coarse L1 RAM *block* with an L1
# *table* descriptor pointing here, so a single 2 MiB region can be granted EL0
# access without making the kernel's own (.text/stack/pgtable) memory
# EL0-writable. (EL0-writable memory is forced Privileged-eXecute-Never, which
# would fault the kernel's instruction fetches — hence the split.)
L2_PGTABLE: uint64 = 0x40102000

# Block descriptor attribute bits (stage-1 block, levels 1 and 2).
DESC_VALID: uint64 = 0x1            # bit0 valid
DESC_AF: uint64 = 0x400             # bit10 Access Flag (else translation fault)
DESC_SH_INNER: uint64 = 0x300       # bits[9:8]=3 Inner shareable
# AttrIndx: bits[4:2]. attr0 = Device-nGnRE, attr1 = Normal WB.
DEV_FLAGS: uint64 = 0x401           # VALID | AF | AttrIndx0 (device)
MEM_FLAGS: uint64 = 0x705           # VALID | AF | SH_INNER | AttrIndx1 (normal)
# Table descriptor (bits[1:0]=0b11) for an L1 entry that points at an L2 table.
DESC_TABLE: uint64 = 0x3
# Phase 4: the EL0 region's 2 MiB L2 block additionally carries AP[1]
# (bit6 = 0x40) so EL0 can read/write/execute it. UXN is left clear so EL0 may
# execute the hand-emitted user blob; this region holds NO kernel code, so the
# implied PXN-at-EL1 (from EL0 writability) does not affect the kernel.
AP_EL0: uint64 = 0x40               # AP[1]: EL0 access permitted
MEM_FLAGS_EL0: uint64 = 0x745       # MEM_FLAGS | AP_EL0

# RAM L2 geometry: 2 MiB per L2 entry. The user region (USER_CODE_BASE ..
# USER_STACK_TOP) all falls inside one 2 MiB block; index it off RAM base.
RAM_BASE: uint64 = 0x40000000
L2_BLOCK_SIZE: uint64 = 0x200000     # 2 MiB
USER_L2_INDEX: uint64 = 1            # (0x4020_0000 - 0x4000_0000) / 2 MiB

# Timer period (ticks of CNTFRQ): firing every freq/100 ~= 10 ms. Stashed by
# kmain after reading CNTFRQ_EL0 so the IRQ handler can re-arm the timer.
arm64_timer_period: uint64 = 0
# Number of timer ticks serviced so far.
arm64_tick_count: int64 = 0


def _uart_putc(c: uint8) -> int64:
    # Spin while the transmit FIFO is full so we never drop a byte.
    fr: Ptr[uint8] = cast[Ptr[uint8]](PL011_BASE + 0x18)
    while (cast[uint64](fr[0]) & PL011_FR_TXFF) != 0:
        pass
    dr: Ptr[uint8] = cast[Ptr[uint8]](PL011_BASE)
    dr[0] = c
    return 0


def _uart_puts(s: Ptr[char]) -> int64:
    # Write a NUL-terminated string to the UART, byte by byte.
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    i: int64 = 0
    while p[i] != 0:
        _uart_putc(p[i])
        i = i + 1
    return i


# Print a 64-bit value as "0x" + 16 hex digits, MSB first. Used by the Phase 6
# page-fault handler to report the faulting VA (FAR_EL1) and EL0 PC (ELR_EL1).
def _uart_puthex(value: uint64) -> int64:
    _uart_putc(cast[uint8](0x30))          # '0'
    _uart_putc(cast[uint8](0x78))          # 'x'
    shift: int64 = 60
    while shift >= 0:
        nib: uint64 = (value >> cast[uint64](shift)) & cast[uint64](0xF)
        if nib < cast[uint64](10):
            _uart_putc(cast[uint8](cast[uint64](0x30) + nib))      # '0'..'9'
        else:
            _uart_putc(cast[uint8](cast[uint64](0x37) + nib))      # 'A'..'F'
        shift = shift - 4
    return 0


# ---------------------------------------------------------------------------
# MMU: build the identity map and enable translation + caches.
# ---------------------------------------------------------------------------
def arm64_mmu_init() -> int64:
    tbl: Ptr[uint64] = cast[Ptr[uint64]](L1_PGTABLE)

    # Zero all 512 entries (anything not explicitly mapped faults).
    i: int64 = 0
    while i < 512:
        tbl[i] = 0
        i = i + 1

    # entry[0] : VA 0x0000_0000 .. 0x3FFF_FFFF -> Device-nGnRE (GIC + UART).
    tbl[0] = cast[uint64](0) | DEV_FLAGS

    # entry[1] : VA 0x4000_0000 .. 0x7FFF_FFFF -> RAM. Instead of a coarse 1 GiB
    # block (which would force the whole kernel image EL0-accessible to expose
    # the EL0 demo region), point to a second-level table of 2 MiB blocks so we
    # can grant EL0 access to exactly one 2 MiB window.
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    j: int64 = 0
    while j < 512:
        # Identity-map each 2 MiB block at RAM_BASE + j*2MiB, Normal-WB EL1-only.
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0   # EL0 RWX window for the demo
        else:
            l2[j] = blk_pa | MEM_FLAGS       # kernel: EL1-only
        j = j + 1
    # L1 entry 1 = table descriptor referencing the L2 table.
    tbl[1] = L2_PGTABLE | DESC_TABLE

    # MAIR_EL1 = 0xff04: attr0 = Device-nGnRE (0x04), attr1 = Normal WB (0xff).
    _msr_mair_el1(cast[uint64](0xff04))

    # TCR_EL1 = 0x1_0000_3519:
    #   T0SZ=25 (39-bit VA), IRGN0=1, ORGN0=1, SH0=3 (inner shareable),
    #   TG0=0 (4 KiB granule), IPS=1 (36-bit PA).
    _msr_tcr_el1(cast[uint64](0x100003519))

    # TTBR0_EL1 = &L1 table; TTBR1_EL1 unused.
    _msr_ttbr0_el1(L1_PGTABLE)
    _msr_ttbr1_el1(cast[uint64](0))

    # Make the table writes + sysreg writes visible, flush the TLB.
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # SCTLR_EL1: set M (MMU, bit0), C (data cache, bit2), I (instr cache,
    # bit12). Read-modify-write to preserve the reset state of the rest.
    sctlr: uint64 = cast[uint64](_mrs_sctlr_el1())
    sctlr = sctlr | cast[uint64](0x1)      # M
    sctlr = sctlr | cast[uint64](0x4)      # C
    sctlr = sctlr | cast[uint64](0x1000)   # I
    _msr_sctlr_el1(sctlr)
    _isb()
    return 0


# ---------------------------------------------------------------------------
# GICv2 bring-up: install VBAR_EL1 (the vector table from vectors.S), then
# enable the distributor + CPU interface and route our timer INTID.
# ---------------------------------------------------------------------------
def arm64_gic_init() -> int64:
    # Install the EL1 exception vector table. arm64_vectors is defined in
    # arch/arm64/vectors.S; we materialise its address as an extern.
    _install_vbar()
    _isb()

    # --- GIC Distributor ---
    gicd_ctlr: Ptr[uint32] = cast[Ptr[uint32]](GICD_BASE + GICD_CTLR)
    gicd_ctlr[0] = 0                                  # disable while configuring

    # Enable INTID 27 (timer PPI). It lives in ISENABLER[0] (INTIDs 0..31).
    isenabler: Ptr[uint32] = cast[Ptr[uint32]](GICD_BASE + GICD_ISENABLER)
    isenabler[0] = cast[uint32](1 << 27)

    # Priority 0 (highest) for INTID 27. IPRIORITYR is byte-addressed.
    iprio: Ptr[uint8] = cast[Ptr[uint8]](GICD_BASE + GICD_IPRIORITYR + VTIMER_INTID)
    iprio[0] = 0

    gicd_ctlr[0] = 1                                  # enable distributor

    # --- GIC CPU interface ---
    gicc_pmr: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_PMR)
    gicc_pmr[0] = 0xF0                                # allow all priorities
    gicc_bpr: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_BPR)
    gicc_bpr[0] = 0                                   # no preemption grouping
    gicc_ctlr: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_CTLR)
    gicc_ctlr[0] = 1                                  # enable signalling
    return 0


# ---------------------------------------------------------------------------
# Virtual timer: program a periodic tick and unmask IRQs.
# ---------------------------------------------------------------------------
def arm64_timer_init() -> int64:
    freq: uint64 = cast[uint64](_mrs_cntfrq_el0())    # timer rate (Hz)
    period: uint64 = freq / cast[uint64](100)         # ~10 ms
    arm64_timer_period = period

    _msr_cntv_tval_el0(period)                        # CVAL = now + period
    _msr_cntv_ctl_el0(cast[uint64](1))                # ENABLE=1, IMASK=0
    _isb()

    _msr_daifclr(2)                                   # clear DAIF.I -> IRQs on
    return 0


# ---------------------------------------------------------------------------
# IRQ service routine — called from the vectors.S IRQ stub (which has saved
# the GPR frame). Acks at GICC, prints a per-tick marker, re-arms the timer,
# EOIs, and after TICK_LIMIT ticks prints the completion banner and halts.
# ---------------------------------------------------------------------------
def arm64_irq_handler() -> int64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]                          # ack: raw IAR
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                            # spurious: just EOI
        return 0

    # Our timer. Quiesce the firing condition while we service it.
    _msr_cntv_ctl_el0(cast[uint64](0))

    tickmsg: Ptr[char] = "[arm64] timer tick\n"
    _uart_puts(tickmsg)

    arm64_tick_count = arm64_tick_count + 1

    # Re-arm the next compare and re-enable the timer.
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))

    # EOI the verbatim IAR value.
    gicc_eoir[0] = iar

    if arm64_tick_count >= TICK_LIMIT:
        donemsg: Ptr[char] = "[arm64] timer IRQ OK\n"
        _uart_puts(donemsg)
        # Mask IRQs so the EL0 demo runs without timer re-entry, then proceed
        # to Phase 4: drop to EL0 and service its syscalls. arm64_enter_el0()
        # does not return (the EL0 exit() halts the test).
        _msr_daifset(2)
        arm64_enter_el0()
        # Unreachable; arm64_enter_el0 erets to EL0 and never comes back here.
        while True:
            _wfi()
    return 0


# ---------------------------------------------------------------------------
# Synchronous / unhandled exception diagnostics (called from vectors.S).
# ---------------------------------------------------------------------------
def arm64_sync_panic() -> int64:
    msg: Ptr[char] = "[arm64] SYNC EXCEPTION\n"
    _uart_puts(msg)
    while True:
        _wfi()
    return 0


def arm64_unhandled_panic() -> int64:
    msg: Ptr[char] = "[arm64] UNHANDLED EXCEPTION\n"
    _uart_puts(msg)
    while True:
        _wfi()
    return 0


# ---------------------------------------------------------------------------
# Phase 4 — EL0 userspace + svc syscall path.
# ---------------------------------------------------------------------------

# Store a 32-bit little-endian instruction word at a code address. Returns the
# next address so the builder can chain word-by-word.
def _emit_word(addr: uint64, word: uint64) -> uint64:
    p: Ptr[uint32] = cast[Ptr[uint32]](addr)
    p[0] = cast[uint32](word & cast[uint64](0xFFFFFFFF))
    return addr + cast[uint64](4)


# Build a 64-bit immediate into register xd using movz + up-to-three movk. The
# AArch64 encodings:
#   movz xd, #imm16, lsl #(16*hw)  = 0xD2800000 | (hw<<21) | (imm16<<5) | xd
#   movk xd, #imm16, lsl #(16*hw)  = 0xF2800000 | (hw<<21) | (imm16<<5) | xd
# We always emit the full 4-halfword sequence for simplicity/determinism.
def _emit_load_imm64(addr: uint64, xd: uint64, value: uint64) -> uint64:
    a: uint64 = addr
    h0: uint64 = value & cast[uint64](0xFFFF)
    h1: uint64 = (value >> cast[uint64](16)) & cast[uint64](0xFFFF)
    h2: uint64 = (value >> cast[uint64](32)) & cast[uint64](0xFFFF)
    h3: uint64 = (value >> cast[uint64](48)) & cast[uint64](0xFFFF)

    movz: uint64 = cast[uint64](0xD2800000) | (h0 << cast[uint64](5)) | xd
    a = _emit_word(a, movz)
    w1: uint64 = cast[uint64](0xF2800000) | (cast[uint64](1) << cast[uint64](21)) | (h1 << cast[uint64](5)) | xd
    a = _emit_word(a, w1)
    w2: uint64 = cast[uint64](0xF2800000) | (cast[uint64](2) << cast[uint64](21)) | (h2 << cast[uint64](5)) | xd
    a = _emit_word(a, w2)
    w3: uint64 = cast[uint64](0xF2800000) | (cast[uint64](3) << cast[uint64](21)) | (h3 << cast[uint64](5)) | xd
    a = _emit_word(a, w3)
    return a


# Copy a NUL-terminated string into the EL0 message buffer and return its
# byte length (excluding the terminator).
def _copy_user_msg(s: Ptr[char]) -> uint64:
    src: Ptr[uint8] = cast[Ptr[uint8]](s)
    dst: Ptr[uint8] = cast[Ptr[uint8]](USER_MSG_BASE)
    i: int64 = 0
    while src[i] != 0:
        dst[i] = src[i]
        i = i + 1
    return cast[uint64](i)


# Materialise the EL0 routine into USER_CODE_BASE:
#   x0 = 1 (stdout); x1 = msg ptr; x2 = len; x8 = 64 (write); svc #0
#   x0 = 0;          x8 = 93 (exit);                            svc #0
# Returns nothing meaningful; the page is then entered via eret.
def arm64_build_user_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))            # x0 = 1
    a = _emit_load_imm64(a, cast[uint64](1), USER_MSG_BASE)             # x1 = msg
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)                   # x2 = len
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)              # x8 = 64
    a = _emit_word(a, cast[uint64](0xD4000001))                        # svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))           # x0 = 0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)              # x8 = 93
    a = _emit_word(a, cast[uint64](0xD4000001))                        # svc #0

    # Ensure the freshly-written instructions are visible to the I-side: clean
    # the data writes and invalidate I-cache (we use a full barrier + ISB; the
    # demo page is small so a coarse maintenance is sufficient here).
    _dsb_ish()
    _isb()
    return 0


# ---------------------------------------------------------------------------
# EL0 synchronous-exception (svc) dispatcher. Called from the vectors.S
# lower-EL sync stub with `frame_ptr` -> the saved x0..x30 frame (slot n holds
# xn). We confirm the trap is an AArch64 SVC via ESR_EL1.EC, pull the syscall
# number (x8) and args (x0..x5) out of the frame, service it, and write the
# return value back into the x0 slot so the eret resumes EL0 with x0 set.
# ---------------------------------------------------------------------------
def arm64_sync_handler(frame_ptr: Ptr[uint64]) -> int64:
    esr: uint64 = cast[uint64](_mrs_esr_el1())
    ec: uint64 = (esr >> cast[uint64](26)) & cast[uint64](0x3F)

    if ec != ESR_EC_SVC64:
        # Not a syscall. Phase 6: an EL0 memory abort (bad load/store/fetch) is
        # a recoverable *user* fault — the kernel must report it and TERMINATE
        # the offending task, never hang. Catch data/instruction aborts taken
        # from the lower EL (EC 0x24 / 0x20), report the faulting VA (FAR_EL1)
        # and EL0 PC (ELR_EL1), then advance to Phase 5 instead of resuming the
        # dead task into its faulting instruction (which would re-fault forever).
        if ec == ESR_EC_DABORT_LOWER:
            return arm64_handle_el0_fault(esr, cast[uint64](0))
        if ec == ESR_EC_IABORT_LOWER:
            return arm64_handle_el0_fault(esr, cast[uint64](1))
        # Anything else from EL0 is genuinely unexpected — report and halt.
        msg: Ptr[char] = "[arm64] EL0 non-SVC sync exception\n"
        _uart_puts(msg)
        while True:
            _wfi()

    nr: uint64 = frame_ptr[8]          # x8 = syscall number
    a0: uint64 = frame_ptr[0]          # x0
    a1: uint64 = frame_ptr[1]          # x1
    a2: uint64 = frame_ptr[2]          # x2

    # Phase 7: while the isolation demo is live, the running EL0 task reports the
    # value it read at the SHARED virtual address through its own TTBR0 via the
    # kernel-private "iso report" syscall (x8 = 512, x0 = value). This never
    # returns to EL0; the driver records the value and either launches the next
    # task (after switching TTBR0) or finishes the demo and hands off to Phase 5.
    if arm64_iso_active != 0:
        if nr == SYS_ISO_REPORT_NR:
            arm64_iso_on_report(a0)
            # Unreachable: arm64_iso_on_report transitions away (next task or
            # Phase 5) and never returns. Safety halt if it ever falls through.
            while True:
                _wfi()
        # Any other syscall from an isolation task is unexpected.
        isobad: Ptr[char] = "[arm64] iso task issued unexpected syscall\n"
        _uart_puts(isobad)
        while True:
            _wfi()

    # Phase 8: while the broader-syscall-surface demo is live, route by x8 into
    # the Phase-8 handler (getpid/gettid/yield/brk/clock/write/exit). It services
    # the call, writes the return value into the x0 frame slot, and returns 0 so
    # the common eret path resumes EL0 — EXCEPT exit, which never returns (it
    # halts the boot after printing the Phase-8 PASS marker).
    if arm64_sys_active != 0:
        return arm64_sys_dispatch(frame_ptr, nr, a0, a1, a2)

    ret: uint64 = cast[uint64](0)

    if nr == SYS_WRITE_NR:
        # write(fd, buf, len): emit the buffer to the kernel UART regardless of
        # fd (the demo only ever uses fd 1). Return the byte count.
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        okmsg: Ptr[char] = "[arm64] EL0 write syscall serviced\n"
        _uart_puts(okmsg)
        ret = a2
    elif nr == SYS_EXIT_NR:
        # exit(code): record the code and signal the launcher to halt.
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        exmsg: Ptr[char] = "[arm64] EL0 exit syscall serviced\n"
        _uart_puts(exmsg)
        ret = cast[uint64](0)
    else:
        unkmsg: Ptr[char] = "[arm64] EL0 unknown syscall\n"
        _uart_puts(unkmsg)
        ret = cast[uint64](0)

    # Stash the return value into the x0 slot so eret resumes EL0 with x0 set.
    frame_ptr[0] = ret

    # If EL0 asked to exit, don't return into it. Emit the Phase-4 single-task
    # PASS marker, then advance to Phase 6: run a deliberately-faulting EL0 task
    # and prove the kernel catches the abort + terminates the task. The Phase-6
    # handler in turn hands off to Phase 5 (preemptive scheduling). Each stage's
    # launcher erets to EL0 and never returns, so this exit-syscall service point
    # is the hand-off from Phase 4 -> 6 -> 5.
    if arm64_el0_exited != 0:
        if arm64_el0_exit_code == 0:
            passmsg: Ptr[char] = "[arm64] EL0 syscall OK\n"
            _uart_puts(passmsg)
        else:
            failmsg: Ptr[char] = "[arm64] EL0 exited nonzero\n"
            _uart_puts(failmsg)
        # Mask IRQs while we transition, then launch Phase 6 (never returns):
        # the faulting task aborts, is reaped, and Phase 6 advances to Phase 5.
        _msr_daifset(2)
        arm64_run_faulting_task()
        # Unreachable; safe halt if the launcher ever falls through.
        while True:
            _wfi()
    return 0


# ---------------------------------------------------------------------------
# Drop to EL0 and run the user routine. Programs SPSR_EL1 (EL0t + DAIF),
# ELR_EL1 (user entry), SP_EL0 (user stack), then `eret`. Control resumes at
# USER_CODE_BASE in EL0; the svc traps re-enter EL1 via arm64_sync_handler,
# which halts the test on exit() (so this function does not return).
# ---------------------------------------------------------------------------
def arm64_enter_el0() -> int64:
    usermsg: Ptr[char] = "Hello from EL0 via svc write\n"
    msg_len: uint64 = _copy_user_msg(usermsg)
    arm64_build_user_routine(msg_len)

    enter: Ptr[char] = "[arm64] dropping to EL0\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # target PSTATE: EL0t, IRQ/FIQ masked
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; never returns here
    return 0


# ---------------------------------------------------------------------------
# Phase 6 — EL0 page-fault path.
#
# A buggy or hostile EL0 task that dereferences an unmapped / EL1-only address
# must NOT wedge the kernel. The CPU takes a Data (or Instruction) Abort to the
# "Lower EL using AArch64" Synchronous vector — the SAME vector as `svc` — so
# arm64_sync_handler sees ESR_EL1.EC == 0x24 (data) or 0x20 (instruction).
# Instead of resuming EL0 into the offending instruction (which would re-fault
# forever) we read FAR_EL1 (the faulting VA) + ELR_EL1 (the EL0 PC), report
# them, mark the fault handled, and TERMINATE the task by transferring to the
# next schedulable workload (Phase 5) rather than ERET-ing back. This is the
# aarch64 analogue of delivering SIGSEGV and reaping the process.
# ---------------------------------------------------------------------------

# Materialise a deliberately-faulting EL0 routine into USER_CODE_BASE:
#   x1 = FAULT_VA (an EL1-only RAM address); ldr x0, [x1]  -> Data Abort.
# The load never completes; control traps to EL1 and never returns to this code.
def arm64_build_faulting_routine() -> int64:
    a: uint64 = USER_CODE_BASE
    a = _emit_load_imm64(a, cast[uint64](1), FAULT_VA)     # x1 = bad VA
    # ldr x0, [x1]  = 0xF9400020 (LDR (immediate, unsigned offset 0), Xt=x0,
    # Xn=x1). This load from an EL0-inaccessible page raises a Data Abort.
    a = _emit_word(a, cast[uint64](0xF9400020))
    # Should never be reached; emit a trap-shaped svc exit as a safety net so a
    # miraculous non-fault still terminates cleanly rather than running off.
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))            # svc #0
    _dsb_ish()
    _isb()
    return 0


# The page-fault handler proper. `is_instr` is 0 for a data abort, 1 for an
# instruction abort. Reports the faulting VA + EL0 PC, latches the handled flag,
# then terminates the task by launching Phase 5 (never returns to EL0). This is
# the deliberate design: a faulting EL0 task is reaped, the kernel survives.
def arm64_handle_el0_fault(esr: uint64, is_instr: uint64) -> int64:
    far: uint64 = cast[uint64](_mrs_far_el1())
    elr: uint64 = cast[uint64](_mrs_elr_el1())

    if is_instr != 0:
        k0: Ptr[char] = "[arm64] EL0 instruction abort\n"
        _uart_puts(k0)
    else:
        k1: Ptr[char] = "[arm64] EL0 data abort\n"
        _uart_puts(k1)

    famsg: Ptr[char] = "[arm64] fault VA (FAR_EL1)="
    _uart_puts(famsg)
    _uart_puthex(far)
    nl0: Ptr[char] = "\n"
    _uart_puts(nl0)

    pcmsg: Ptr[char] = "[arm64] fault PC (ELR_EL1)="
    _uart_puts(pcmsg)
    _uart_puthex(elr)
    nl1: Ptr[char] = "\n"
    _uart_puts(nl1)

    esrmsg: Ptr[char] = "[arm64] fault ESR_EL1="
    _uart_puts(esrmsg)
    _uart_puthex(esr)
    nl2: Ptr[char] = "\n"
    _uart_puts(nl2)

    arm64_fault_handled = 1

    term: Ptr[char] = "[arm64] EL0 task terminated; kernel survived\n"
    _uart_puts(term)

    pass_mark: Ptr[char] = "[arm64] EL0 page-fault OK\n"
    _uart_puts(pass_mark)

    # The faulting task is dead. Rather than ERET back into its faulting
    # instruction, hand off to Phase 7 (per-task TTBR0 address-space isolation),
    # which in turn hands off to Phase 5. Mask IRQs while we transition; neither
    # arm64_run_isolation_demo() nor the Phase-5 launcher it tails into returns.
    _msr_daifset(2)
    arm64_run_isolation_demo()
    # Unreachable safety halt.
    while True:
        _wfi()
    return 0


# Build the deliberately-faulting EL0 task and ERET into it. The abort it raises
# traps to arm64_sync_handler -> arm64_handle_el0_fault, which reports + reaps
# it and never returns here. This is the Phase-6 entry point, invoked from the
# Phase-4 exit hand-off so all three EL0 milestones run in one boot.
def arm64_run_faulting_task() -> int64:
    arm64_build_faulting_routine()

    enter: Ptr[char] = "[arm64] launching faulting EL0 task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC (the bad load)
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; faults immediately, never returns
    return 0


# ---------------------------------------------------------------------------
# Phase 7 — per-task TTBR0_EL1 ADDRESS-SPACE ISOLATION.
#
# Each EL0 task gets its OWN level-1 translation table root (TTBR0_EL1). Both
# tasks map the SAME virtual address (ISO_SHARED_VA) but to DIFFERENT physical
# pages carrying distinct sentinels. The kernel switches TTBR0_EL1 between the
# two tasks and performs the required TLB maintenance (tlbi vmalle1is + dsb +
# isb) on each switch. Each task loads the byte at ISO_SHARED_VA and reports it
# via a kernel-private syscall (nr 512). If isolation holds, task A reports its
# sentinel (0xAA) and task B reports its own (0xBB) — proving that the same VA
# resolves to private physical memory per task, i.e. tasks cannot read each
# other's memory.
#
# Both per-task tables clone the kernel's device + RAM identity map (so the EL0
# code window at USER_CODE_BASE stays fetchable and the kernel stays mapped),
# and additionally map ISO_SHARED_VA's 2 MiB L2 block EL0-RWX to the task's
# private physical block. The tables live in EL1-only RAM, so EL0 cannot tamper
# with them.
# ---------------------------------------------------------------------------

# Build one task-private address space at (l1_base, l2_base): a full clone of
# the kernel identity map plus an EL0-RWX mapping of ISO_SHARED_VA -> data_pa.
# Also writes `sentinel` into the first byte of the data block so the task can
# read it back. data_pa must be 2 MiB-aligned (it backs a block descriptor).
def arm64_iso_build_space(l1_base: uint64, l2_base: uint64, data_pa: uint64, sentinel: uint64) -> int64:
    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    # Zero the L1 table (everything unmapped faults).
    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1

    # L1[0] : VA 0x0..0x3FFF_FFFF -> Device-nGnRE (GIC + UART), EL1-only.
    l1[0] = cast[uint64](0) | DEV_FLAGS

    # L2 covering the RAM 1 GiB block in 2 MiB pieces, identity-mapped. Most
    # blocks are Normal-WB EL1-only; the EL0 code window (USER_L2_INDEX) is
    # EL0-RWX so the task's instruction page + stack remain reachable.
    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0          # EL0 code/stack window
        elif cast[uint64](j) == ISO_SHARED_L2_INDEX:
            # The shared VA block: EL0-RWX, but mapped to the TASK-PRIVATE
            # physical block (NOT identity) — this is the isolation linchpin.
            l2[j] = data_pa | MEM_FLAGS_EL0
        else:
            l2[j] = blk_pa | MEM_FLAGS              # kernel: EL1-only
        j = j + 1

    # L1[1] = table descriptor -> this task's L2 table.
    l1[1] = l2_base | DESC_TABLE

    # Seed the private data block with the task's sentinel (byte 0). The kernel
    # writes it through the identity (physical==virtual) mapping the BOOT TTBR0
    # still has live; data_pa is plain RAM mapped Normal-WB by L1_PGTABLE.
    dp: Ptr[uint8] = cast[Ptr[uint8]](data_pa)
    dp[0] = cast[uint8](sentinel & cast[uint64](0xFF))
    return 0


# Materialise the isolation EL0 routine into USER_CODE_BASE:
#   x1 = ISO_SHARED_VA; ldrb w0, [x1]   (read the per-task sentinel byte)
#   x8 = 512 (iso report); svc #0       (hand x0 back to the kernel)
# The svc never returns to EL0 (the kernel transitions away), so no exit needed.
def arm64_build_iso_routine() -> int64:
    a: uint64 = USER_CODE_BASE
    a = _emit_load_imm64(a, cast[uint64](1), ISO_SHARED_VA)     # x1 = shared VA
    # ldrb w0, [x1] = 0x39400020 (LDRB immediate, unsigned offset 0, Wt=0, Xn=1).
    a = _emit_word(a, cast[uint64](0x39400020))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_ISO_REPORT_NR)  # x8 = 512
    a = _emit_word(a, cast[uint64](0xD4000001))                 # svc #0
    # Safety net: if the report syscall ever returned, exit(0).
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                 # svc #0
    _dsb_ish()
    _isb()
    return 0


# Switch the live address space to (l1_base) and ERET into the isolation EL0
# routine at EL0t with IRQs masked (deterministic, no preemption). Performs the
# mandatory TLB maintenance after writing TTBR0_EL1 so stale translations for
# ISO_SHARED_VA from the previous task cannot leak across the switch.
def arm64_iso_enter(l1_base: uint64) -> int64:
    # Point TTBR0_EL1 at this task's private L1 table, then flush all stage-1
    # EL1&0 translations (inner-shareable) so the new mapping for ISO_SHARED_VA
    # takes effect. dsb before+after ordering the table/sysreg writes vs. the
    # invalidate vs. the subsequent fetch; isb to resynchronise the context.
    _dsb_ish()
    _msr_ttbr0_el1(l1_base)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC (the shared-VA reader)
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0 under this task's TTBR0
    return 0


# Called from the svc dispatcher when an isolation task reports the value it
# read at ISO_SHARED_VA. Latch the value for the live task, then either switch
# to task B (after task A) or, once both have reported, verify isolation held
# and hand off to Phase 5. Never returns to EL0.
def arm64_iso_on_report(value: uint64) -> int64:
    if arm64_iso_cur == 0:
        arm64_iso_reported_a = value
        ra: Ptr[char] = "[arm64] iso task A read VA value="
        _uart_puts(ra)
        _uart_puthex(value)
        nla: Ptr[char] = "\n"
        _uart_puts(nla)

        # Switch to task B's address space (same VA, different physical page).
        arm64_iso_cur = 1
        sw: Ptr[char] = "[arm64] iso switching TTBR0 to task B\n"
        _uart_puts(sw)
        arm64_iso_enter(ISO_B_L1)      # never returns; task B will report next
        while True:
            _wfi()

    arm64_iso_reported_b = value
    rb: Ptr[char] = "[arm64] iso task B read VA value="
    _uart_puts(rb)
    _uart_puthex(value)
    nlb: Ptr[char] = "\n"
    _uart_puts(nlb)

    # Both tasks reported. Isolation holds iff each read its OWN sentinel at the
    # SAME virtual address — proving distinct per-task physical memory.
    ok_a: int64 = 0
    if arm64_iso_reported_a == ISO_SENTINEL_A:
        ok_a = 1
    ok_b: int64 = 0
    if arm64_iso_reported_b == ISO_SENTINEL_B:
        ok_b = 1
    distinct: int64 = 0
    if arm64_iso_reported_a != arm64_iso_reported_b:
        distinct = 1

    if (ok_a != 0) and (ok_b != 0) and (distinct != 0):
        pm: Ptr[char] = "[arm64] EL0 TTBR0 isolation OK\n"
        _uart_puts(pm)
    else:
        fm: Ptr[char] = "[arm64] EL0 TTBR0 isolation FAIL\n"
        _uart_puts(fm)

    # The demo is done. Leave isolation mode, restore the kernel's identity-only
    # TTBR0 (the Phase-5 tasks run in the original L1_PGTABLE address space),
    # flush the TLB, and hand off to Phase 5 so its scheduler stays reachable.
    arm64_iso_active = 0
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    _msr_daifset(2)
    arm64_start_tasks()                # Phase 5; never returns
    while True:
        _wfi()
    return 0


# Phase-7 entry point (invoked from the Phase-6 fault hand-off). Build both
# task-private address spaces, the shared EL0 reader routine, then ERET into
# task A. The chain runs entirely from the svc "report" path:
#   enter A -> A reads its VA -> svc 512 -> switch TTBR0 -> enter B ->
#   B reads its VA -> svc 512 -> verify + PASS -> Phase 5.
def arm64_run_isolation_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 7: per-task TTBR0 isolation\n"
    _uart_puts(intro)

    # Build the two private address spaces and seed their sentinels.
    arm64_iso_build_space(ISO_A_L1, ISO_A_L2, ISO_A_DATA, ISO_SENTINEL_A)
    arm64_iso_build_space(ISO_B_L1, ISO_B_L2, ISO_B_DATA, ISO_SENTINEL_B)

    # Build the EL0 reader routine into the shared code window (identity-mapped
    # the same way in both task tables, so it is fetchable under either TTBR0).
    arm64_build_iso_routine()

    # Clear any Phase-4 exit latch and arm isolation mode so the svc dispatcher
    # routes the report syscall here.
    arm64_el0_exited = 0
    arm64_iso_active = 1
    arm64_iso_cur = 0

    sa: Ptr[char] = "[arm64] iso entering task A (TTBR0=A)\n"
    _uart_puts(sa)
    arm64_iso_enter(ISO_A_L1)          # -> EL0 task A; never returns here
    while True:
        _wfi()
    return 0


# ---------------------------------------------------------------------------
# Phase 5 — timer-driven PREEMPTIVE round-robin scheduling of two EL0 tasks.
#
# Two independent EL0 tasks each run an endless loop: write(1, marker, len) then
# spin in a short busy-loop. Neither ever yields or exits. The EL1 generic-timer
# IRQ fires periodically while a task runs; the "Lower EL using AArch64" IRQ
# vector (arm64_lower_irq_entry in vectors.S) saves the running task's FULL
# context (x0..x30 + SP_EL0 + ELR_EL1 + SPSR_EL1) into its context block, calls
# the Adder scheduler arm64_sched_pick() — which services the timer and swaps
# the current-task pointer to the OTHER task — and restores+erets into that
# task. Each task therefore makes forward progress only because the kernel
# preempts and round-robins it: a real EL0<->EL0 context switch on bare aarch64,
# orchestrated from Adder.
#
# The .S IRQ stub finds the running task's context block via the global
# `arm64_current_ctx`, which the scheduler keeps pointing at the live task.
# ---------------------------------------------------------------------------

# Two task code pages, message buffers and stacks — all inside the single EL0
# RWX 2 MiB window (0x4020_0000 .. 0x403F_FFFF) granted by the L2 map.
TASK0_CODE: uint64 = 0x40200000
TASK1_CODE: uint64 = 0x40210000
TASK0_MSG: uint64 = 0x40220000
TASK1_MSG: uint64 = 0x40221000
TASK0_STACK_TOP: uint64 = 0x40240000
TASK1_STACK_TOP: uint64 = 0x40250000

# Context blocks (34 x 8-byte slots: x0..x30, SP_EL0, ELR_EL1, SPSR_EL1). These
# live in EL1-only RAM (outside the EL0 window) so a buggy/hostile EL0 task can
# neither read nor scribble the saved scheduler state.
TASK0_CTX: uint64 = 0x40104000
TASK1_CTX: uint64 = 0x40105000

CTX_X0: uint64 = 0          # slot index of x0
CTX_SP_EL0: uint64 = 31
CTX_ELR: uint64 = 32
CTX_SPSR: uint64 = 33

# SPSR to ERET into EL0t with IRQs ENABLED (so the timer can preempt the task):
# mode EL0t (bits[3:0]=0), DAIF with only D|A|F masked and I (bit7) CLEAR.
# 0x340 = D|A|F masked, IRQ unmasked, EL0t.
SPSR_EL0T_IRQ: uint64 = 0x340

# Published to the .S IRQ stub: address of the context block of the task that is
# currently running at EL0. The scheduler swaps this on every tick.
arm64_current_ctx: uint64 = 0

# Round-robin bookkeeping: which task index is live, and how many preemptive
# switches we have performed. After SWITCH_LIMIT switches (proving BOTH tasks
# ran and were preempted multiple times) the scheduler prints PASS and halts.
arm64_cur_task: int64 = 0
arm64_switch_count: int64 = 0
SWITCH_LIMIT: int64 = 8


# Materialise a self-looping EL0 task into `code_base`:
#   loop:
#     x0 = 1; x1 = msg; x2 = len; x8 = 64 (write); svc #0
#     x9 = busy; busy:  subs x9,x9,#1; b.ne busy
#     b loop
# The task never exits; only the preemptive timer IRQ moves control away. We
# hand-emit the busy-loop and backward branch directly (the imm-builder already
# exists for the syscall argument setup).
def arm64_build_task(code_base: uint64, msg_base: uint64, msg_len: uint64) -> int64:
    a: uint64 = code_base
    loop_top: uint64 = a

    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))      # x0 = 1 (fd)
    a = _emit_load_imm64(a, cast[uint64](1), msg_base)             # x1 = msg ptr
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)             # x2 = len
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)        # x8 = 64 (write)
    a = _emit_word(a, cast[uint64](0xD4000001))                  # svc #0

    # x9 = 0x40000 busy-loop counter (movz x9, #0x4, lsl #16). hw=1 => lsl #16.
    movz_x9: uint64 = cast[uint64](0xD2800000) | (cast[uint64](1) << cast[uint64](21)) | (cast[uint64](4) << cast[uint64](5)) | cast[uint64](9)
    a = _emit_word(a, movz_x9)
    busy_top: uint64 = a
    # subs x9, x9, #1   = 0xF1000529
    a = _emit_word(a, cast[uint64](0xF1000529))
    # b.ne busy_top : 0x54000001 | (imm19 << 5); imm19 = (busy_top - here) / 4.
    bne_here: uint64 = a
    off_busy: int64 = cast[int64](busy_top) - cast[int64](bne_here)
    imm19_busy: uint64 = cast[uint64](off_busy >> 2) & cast[uint64](0x7FFFF)
    a = _emit_word(a, cast[uint64](0x54000001) | (imm19_busy << cast[uint64](5)))

    # b loop_top : 0x14000000 | imm26; imm26 = (loop_top - here) / 4.
    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# Copy a NUL-terminated string into an arbitrary EL0 buffer; return byte length.
def _copy_msg_to(s: Ptr[char], dst_base: uint64) -> uint64:
    src: Ptr[uint8] = cast[Ptr[uint8]](s)
    dst: Ptr[uint8] = cast[Ptr[uint8]](dst_base)
    i: int64 = 0
    while src[i] != 0:
        dst[i] = src[i]
        i = i + 1
    return cast[uint64](i)


# Initialise a task's context block so the very first ERET starts it cleanly at
# its code entry, on its own stack, in EL0t with IRQs unmasked.
def arm64_init_ctx(ctx_base: uint64, code_base: uint64, stack_top: uint64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](ctx_base)
    i: int64 = 0
    while i < 34:
        ctx[i] = cast[uint64](0)
        i = i + 1
    ctx[CTX_SP_EL0] = stack_top
    ctx[CTX_ELR] = code_base
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ
    return 0


# Scheduler — invoked from the EL0 IRQ vector (arm64_lower_irq_entry) with the
# running task's context block already fully saved. We ack/re-arm the timer,
# pick the OTHER task, publish it as current, and return its context block base
# so the stub restores+erets into it. After SWITCH_LIMIT preemptions the test
# has proven both tasks ran and were repeatedly preempted; print PASS and halt.
def arm64_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this task
        return cur_ctx

    # Quiesce, re-arm, and EOI the timer.
    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_switch_count = arm64_switch_count + 1
    swmsg: Ptr[char] = "[arm64] preempt switch\n"
    _uart_puts(swmsg)

    if arm64_switch_count >= SWITCH_LIMIT:
        passmsg: Ptr[char] = "[arm64] EL0 preempt sched OK\n"
        _uart_puts(passmsg)
        # Mask IRQs (so the broader-syscall demo runs deterministically without
        # timer re-entry) and hand off to Phase 8: a single EL0 task exercising a
        # wider svc surface (getpid/gettid/yield/brk/clock/write/exit) dispatched
        # by x8. arm64_run_syscall_demo() does not return (its task's exit() halts
        # the boot), so Phase 5's PASS marker is the hand-off point to Phase 8.
        _msr_daifset(2)
        arm64_run_syscall_demo()
        # Unreachable safety halt.
        while True:
            _wfi()

    # Round-robin to the other task.
    next_ctx: uint64 = TASK1_CTX
    if arm64_cur_task == 0:
        arm64_cur_task = 1
        next_ctx = TASK1_CTX
    else:
        arm64_cur_task = 0
        next_ctx = TASK0_CTX

    arm64_current_ctx = next_ctx            # publish for the next preemption
    return next_ctx


# Build both tasks + context blocks, then ERET into task 0 with the timer live.
def arm64_start_tasks() -> int64:
    # Mask EL1 IRQs while we build the tasks so a stray current-EL timer IRQ
    # (left armed/unmasked by arm64_timer_init) cannot run the legacy handler
    # mid-setup. We re-enable just before ERETing into EL0.
    _msr_daifset(2)

    # Clear the Phase-4 single-task exit latch: the two Phase-5 tasks only ever
    # issue write() (nr 64) and must NOT re-enter the exit/hand-off path the svc
    # dispatcher keys off arm64_el0_exited.
    arm64_el0_exited = 0
    arm64_el0_exit_code = -1

    m0: Ptr[char] = "[task0] running on EL0\n"
    m1: Ptr[char] = "[task1] running on EL0\n"
    len0: uint64 = _copy_msg_to(m0, TASK0_MSG)
    len1: uint64 = _copy_msg_to(m1, TASK1_MSG)

    arm64_build_task(TASK0_CODE, TASK0_MSG, len0)
    arm64_build_task(TASK1_CODE, TASK1_MSG, len1)

    arm64_init_ctx(TASK0_CTX, TASK0_CODE, TASK0_STACK_TOP)
    arm64_init_ctx(TASK1_CTX, TASK1_CODE, TASK1_STACK_TOP)

    arm64_cur_task = 0
    arm64_current_ctx = TASK0_CTX

    enter: Ptr[char] = "[arm64] launching preemptive EL0 tasks\n"
    _uart_puts(enter)

    # Re-arm and enable the timer, unmask IRQs, then ERET into task 0 at EL0t
    # WITH IRQs unmasked (via its context SPSR) so the timer preempts it.
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](TASK0_CTX)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> task 0 at EL0; never returns here
    return 0


# ---------------------------------------------------------------------------
# Phase 8 — broader EL0 syscall surface dispatched by x8.
#
# A single EL0 task issues a sequence of syscalls mirroring the Linux aarch64
# ABI (number in x8, args x0..x5, return in x0):
#   getpid()                  -> the kernel-assigned PID (42)
#   gettid()                  -> the TID (== PID for our single thread)
#   sched_yield()             -> 0 (kernel acknowledges; resumes the same task)
#   clock read (CNTVCT) x2    -> the virtual counter; the kernel latches the
#                                first value and confirms the second ADVANCED
#                                (live, monotonic time visible to EL0)
#   brk(0)                    -> the current program break (queries it)
#   brk(BASE + 4 KiB)         -> moves the break and returns the new value (sbrk)
#   write(1, msg, len)        -> echoes a buffer to the UART, returns the length
#   exit(0)                   -> records the code and halts the boot
# The kernel services each call in arm64_sys_dispatch(), prints a per-call marker
# so the test can prove every syscall ran with a correct result, and on exit(0)
# prints the Phase-8 PASS marker.
# ---------------------------------------------------------------------------

# Phase 8 EL0 message buffer (inside the EL0 RWX window, clear of the code page
# at USER_CODE_BASE and the heap window at SYS_HEAP_BASE).
SYS_MSG_BASE: uint64 = 0x40222000


# Materialise the Phase-8 EL0 routine into USER_CODE_BASE. It issues the syscall
# sequence above. Every syscall but write needs no register args beyond x8 (or a
# single x0 for brk), so we reuse the imm-builder for x8/x0 and emit `svc #0`.
def arm64_build_syscall_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE

    # getpid(): x8 = 172; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_GETPID_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # gettid(): x8 = 178; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_GETTID_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # sched_yield(): x8 = 124; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_YIELD_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # clock read #1: x8 = 513; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_CLOCK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # clock read #2: x8 = 513; svc #0  (kernel confirms it advanced)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_CLOCK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # brk(0): x0 = 0; x8 = 214; svc #0  (query current break)
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_BRK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # brk(SYS_HEAP_GROW): x0 = new break; x8 = 214; svc #0  (grow the heap)
    a = _emit_load_imm64(a, cast[uint64](0), SYS_HEAP_GROW)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_BRK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 64; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), SYS_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # exit(0): x0 = 0; x8 = 93; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-8 syscall dispatcher. Called from arm64_sync_handler while the broader-
# surface demo is live, with `frame_ptr` -> the saved x0..x30 frame, `nr` the
# syscall number (x8) and a0..a2 the first three args. Services the call, writes
# the return value into the x0 frame slot, and returns 0 so the common eret path
# resumes EL0 — except exit(), which halts the boot after the PASS marker.
def arm64_sys_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    arm64_sys_calls = arm64_sys_calls + 1
    ret: uint64 = cast[uint64](0)

    if nr == SYS_GETPID_NR:
        ret = arm64_sys_pid
        m: Ptr[char] = "[arm64] EL0 getpid -> "
        _uart_puts(m)
        _uart_puthex(ret)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        frame_ptr[0] = ret
        return 0

    if nr == SYS_GETTID_NR:
        # Single-threaded task: TID == PID.
        ret = arm64_sys_pid
        m: Ptr[char] = "[arm64] EL0 gettid -> "
        _uart_puts(m)
        _uart_puthex(ret)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        frame_ptr[0] = ret
        return 0

    if nr == SYS_YIELD_NR:
        # Voluntary yield: the kernel acknowledges and resumes the same task
        # (there is only one Phase-8 task). Return 0 like Linux sched_yield.
        m: Ptr[char] = "[arm64] EL0 sched_yield serviced\n"
        _uart_puts(m)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_CLOCK_NR:
        # Read the always-incrementing virtual counter. Latch the first value;
        # on a later read, confirm it strictly advanced (live monotonic clock).
        now: uint64 = cast[uint64](_mrs_cntvct_el0())
        if arm64_sys_clock_seen == 0:
            arm64_sys_clock_first = now
            arm64_sys_clock_seen = 1
            m0: Ptr[char] = "[arm64] EL0 clock read #1 -> "
            _uart_puts(m0)
            _uart_puthex(now)
            nl0: Ptr[char] = "\n"
            _uart_puts(nl0)
        else:
            m1: Ptr[char] = "[arm64] EL0 clock read #2 -> "
            _uart_puts(m1)
            _uart_puthex(now)
            nl1: Ptr[char] = "\n"
            _uart_puts(nl1)
            if now > arm64_sys_clock_first:
                adv: Ptr[char] = "[arm64] EL0 clock advanced OK\n"
                _uart_puts(adv)
            else:
                bad: Ptr[char] = "[arm64] EL0 clock did NOT advance FAIL\n"
                _uart_puts(bad)
        frame_ptr[0] = now
        return 0

    if nr == SYS_BRK_NR:
        # brk(new): if a0 == 0, query the current break. Otherwise move it,
        # clamped to [SYS_HEAP_BASE, SYS_HEAP_END]; return the resulting break.
        if a0 == cast[uint64](0):
            m: Ptr[char] = "[arm64] EL0 brk query -> "
            _uart_puts(m)
            _uart_puthex(arm64_sys_brk)
            nl: Ptr[char] = "\n"
            _uart_puts(nl)
            frame_ptr[0] = arm64_sys_brk
            return 0
        if (a0 >= SYS_HEAP_BASE) and (a0 <= SYS_HEAP_END):
            arm64_sys_brk = a0
        # Out-of-range requests leave the break unchanged (Linux brk returns the
        # current break on failure rather than erroring).
        m2: Ptr[char] = "[arm64] EL0 brk set -> "
        _uart_puts(m2)
        _uart_puthex(arm64_sys_brk)
        nl2: Ptr[char] = "\n"
        _uart_puts(nl2)
        frame_ptr[0] = arm64_sys_brk
        return 0

    if nr == SYS_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        m: Ptr[char] = "[arm64] EL0 write syscall serviced\n"
        _uart_puts(m)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_EXIT_NR:
        # Record the exit code; if the whole sequence ran cleanly, print PASS.
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit syscall serviced\n"
        _uart_puts(em)
        if a0 == cast[uint64](0):
            pm: Ptr[char] = "[arm64] EL0 syscall surface OK\n"
            _uart_puts(pm)
        else:
            fm: Ptr[char] = "[arm64] EL0 syscall surface exited nonzero\n"
            _uart_puts(fm)
        # The demo is complete. Leave Phase-8 mode and halt deterministically.
        arm64_sys_active = 0
        _msr_daifset(2)
        while True:
            _wfi()

    # Unknown syscall under the Phase-8 surface.
    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 8)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-8 entry point (invoked from the Phase-5 sched PASS hand-off). Seed the
# PID + program break, build the EL0 routine and its message, arm Phase-8 mode,
# and ERET into the single multi-syscall EL0 task at EL0t with IRQs masked
# (deterministic; the demo never needs preemption). Never returns here.
def arm64_run_syscall_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 8: broader EL0 syscall surface\n"
    _uart_puts(intro)

    # Seed kernel-tracked per-task state for the demo.
    arm64_sys_pid = SYS_DEMO_PID
    arm64_sys_brk = SYS_HEAP_BASE
    arm64_sys_clock_first = cast[uint64](0)
    arm64_sys_clock_seen = 0
    arm64_sys_calls = 0

    # Restore the kernel's identity-only TTBR0 (Phase 7 may have left a per-task
    # root live) so the EL0 code/heap windows resolve through L1_PGTABLE, then
    # flush the TLB so no stale isolation translation lingers.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Build the EL0 routine + its write() message.
    sysmsg: Ptr[char] = "Hello from the EL0 syscall surface\n"
    msg_len: uint64 = _copy_msg_to(sysmsg, SYS_MSG_BASE)
    arm64_build_syscall_routine(msg_len)

    # Clear the Phase-4/5 exit latch and arm Phase-8 dispatch.
    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_sys_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 syscall-surface task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; svc traps re-enter EL1; no return
    return 0


def kmain() -> int64:
    banner: Ptr[char] = "HAMNIX aarch64 boot OK\n"
    _uart_puts(banner)

    arm64_mmu_init()
    mmu_msg: Ptr[char] = "[arm64] MMU enabled\n"
    _uart_puts(mmu_msg)

    arm64_gic_init()
    arm64_timer_init()
    gic_msg: Ptr[char] = "[arm64] GICv2 + timer up\n"
    _uart_puts(gic_msg)

    # Wait for timer IRQs. After TICK_LIMIT ticks the IRQ handler runs the
    # Phase-4 single-task EL0 svc demo; on that task's exit() the syscall
    # dispatcher hands off to Phase 5 (preemptive two-task scheduling). Control
    # never returns here.
    while True:
        _wfi()
    return 0

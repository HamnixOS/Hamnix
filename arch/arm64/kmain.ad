# arch/arm64/kmain.ad — Phase 3 bare-metal aarch64 interrupt-driven spine.
#
# This is the Adder-level kernel that boots on QEMU `virt`. The boot stub
# arch/arm64/boot.S sets up a stack and branches to kmain(); the EL1 exception
# vector table lives in arch/arm64/vectors.S and its IRQ entry calls back into
# the Adder handler arm64_irq_handler() below.
#
# What kmain() does, all driven from Adder:
#   1. Print a recognizable banner over the PL011 UART (MMIO @0x0900_0000).
#   2. Bring up a minimal identity-mapped MMU (1 GiB block descriptors:
#      device region @0x0000_0000, RAM @0x4000_0000) and enable it.
#   3. Install the EL1 vector table (VBAR_EL1) and initialise GICv2
#      (distributor @0x0800_0000, CPU interface @0x0801_0000).
#   4. Program the ARM generic *virtual* timer (PPI INTID 27) for a periodic
#      tick and unmask IRQs.
#   5. Spin in WFI. Each timer IRQ prints "[arm64] timer tick"; after 5 ticks
#      the handler prints "[arm64] timer IRQ OK".
#   6. (Phase 4) Drop to EL0: hand-emit a tiny AArch64 user routine into an
#      identity-mapped, EL0-accessible 2 MiB window, program SPSR_EL1 (EL0t),
#      ELR_EL1 (user entry) and SP_EL0 (user stack), then `eret` into it. The
#      EL0 routine issues write(1, msg, len) then exit(0) via `svc #0`. Each
#      svc traps to the "Lower EL using AArch64" Synchronous vector, which
#      saves the GPR frame and calls the Adder dispatcher arm64_sync_handler():
#      it reads ESR_EL1.EC to confirm SVC, services the syscall (write -> UART,
#      exit -> record code + halt), and writes the return value back into the
#      frame's x0 slot before eret-ing back to EL0. On exit() the test halts
#      after printing "[arm64] EL0 syscall OK".
#
# The privileged system-register pokes (MSR/MRS to VBAR_EL1, SCTLR_EL1,
# TTBR0_EL1, MAIR_EL1, TCR_EL1, CNTV_*, DAIF, SPSR_EL1, ELR_EL1, SP_EL0,
# ESR_EL1) plus DSB/ISB/TLBI/WFI/ERET are emitted by codegen_arm64.py as
# recognised intrinsics (_msr_*, _mrs_*, _dsb_ish, _isb, _tlbi_vmalle1is,
# _wfi, _eret). Everything else — GIC/timer MMIO, the page-table fill, the
# IRQ/syscall service logic, the EL0 blob builder — is ordinary Adder.

# ===========================================================================
# BOARD / PLATFORM ABSTRACTION LAYER
# ===========================================================================
# Historically every MMIO address in this file was a qemu-virt literal (PL011
# UART @0x0900_0000, GICv2 @0x0800_0000, RAM @0x4000_0000). To bring the port up
# on real silicon (Pinebook Pro = Rockchip RK3399) those addresses differ AND
# the console is an 8250/16550 UART rather than a PL011, so they cannot stay
# hardcoded. Instead we describe each supported board with a set of compile-time
# constant "descriptor" globals (BOARD_<name>_*), pick one with the compile-time
# selector BOARD_SEL, and at boot copy the chosen board's values into the MUTABLE
# runtime globals (PL011_BASE / GICD_BASE / GICC_BASE / RAM_BASE / UART_TYPE /
# arm64_cpu_count) that the rest of the kernel reads. Switching to a new board is
# therefore a descriptor edit (and a BOARD_SEL flip), not a code rewrite.
#
# The runtime globals keep their historical names so every existing call site —
# which loads e.g. `GICD_BASE` from .data at runtime — works unchanged; only
# their *value* is now board-selected at board_init() time.
# ---------------------------------------------------------------------------

# --- UART type tags (selects the putc primitive) ---------------------------
UART_TYPE_PL011: uint64 = 0          # ARM PrimeCell PL011 (qemu-virt)
UART_TYPE_8250: uint64 = 1           # 8250/16550-compatible (RK3399 UART2)

# --- Board selector identifiers --------------------------------------------
BOARD_QEMU_VIRT: uint64 = 0
BOARD_RK3399_PINEBOOK_PRO: uint64 = 1

# Compile-time board selection. Default = qemu-virt so the in-tree phase
# self-tests (which run under `qemu-system-aarch64 -M virt`) stay green. Flip
# this to BOARD_RK3399_PINEBOOK_PRO (value 1) to retarget the image at the
# Pinebook Pro; that is a one-line change, not a rewrite.
BOARD_SEL: uint64 = 0                # == BOARD_QEMU_VIRT

# --- Board descriptor: qemu-virt (the established defaults) -----------------
#   PL011 UART @0x0900_0000; GICv2 dist @0x0800_0000, cpu-if @0x0801_0000;
#   RAM @0x4000_0000; 2 cores (the phase self-tests boot with -smp 2).
BOARD_QV_UART_BASE: uint64 = 0x09000000
BOARD_QV_UART_TYPE: uint64 = 0       # UART_TYPE_PL011
BOARD_QV_GICD_BASE: uint64 = 0x08000000
BOARD_QV_GICC_BASE: uint64 = 0x08010000
BOARD_QV_RAM_BASE: uint64 = 0x40000000
BOARD_QV_CPU_COUNT: uint64 = 2

# --- Board descriptor: rk3399-pinebook-pro ---------------------------------
# Rockchip RK3399 (2x Cortex-A72 + 4x Cortex-A53 big.LITTLE = 6 cores).
#   Debug console = UART2, an 8250/16550-compatible block @0xFF1A_0000.
#   Interrupt controller = GIC-400 (GICv2): distributor @0xFEE0_0000,
#                          CPU interface @0xFEF0_2000 (RK3399 TRM).
#   DRAM base = 0x0000_0000.
# NOTE: structurally present + compiles; NOT validated on hardware here.
BOARD_RK_UART_BASE: uint64 = 0xFF1A0000
BOARD_RK_UART_TYPE: uint64 = 1       # UART_TYPE_8250
BOARD_RK_GICD_BASE: uint64 = 0xFEE00000
BOARD_RK_GICC_BASE: uint64 = 0xFEF02000
BOARD_RK_RAM_BASE: uint64 = 0x00000000
BOARD_RK_CPU_COUNT: uint64 = 6

# ---------------------------------------------------------------------------
# MUTABLE runtime board globals. Seeded with the qemu-virt defaults (so they are
# safe even before board_init() runs — e.g. an early fault printing over UART)
# and then overwritten by board_init() according to BOARD_SEL. The historical
# names are preserved so all existing call sites read the selected board's value.
# ---------------------------------------------------------------------------
PL011_BASE: uint64 = 0x09000000      # selected UART MMIO base (any UART type)
UART_TYPE: uint64 = 0                # selected UART type (PL011 vs 8250)
PL011_FR_TXFF: uint64 = 0x20         # PL011 FR.TXFF (bit5): TX FIFO full

# 8250/16550 register offsets (byte-addressed). Used by the 8250 putc path.
#   THR : base + 0x00 (write) — transmit holding register
#   LSR : base + 0x14 (read)  — line status; bit5 (0x20) = THRE (THR empty)
UART_8250_THR: uint64 = 0x00
UART_8250_LSR: uint64 = 0x14
UART_8250_LSR_THRE: uint64 = 0x20

# Selected CPU count hint (topology); informational for SMP bring-up.
arm64_cpu_count: uint64 = 2

GICD_BASE: uint64 = 0x08000000       # selected GIC distributor base
GICC_BASE: uint64 = 0x08010000       # selected GIC CPU-interface base

GICD_CTLR: uint64 = 0x000
GICD_ISENABLER: uint64 = 0x100      # set-enable, 1 bit / INTID, 32 / reg
GICD_IPRIORITYR: uint64 = 0x400     # 8 bits / INTID (byte addressed)

GICC_CTLR: uint64 = 0x000
GICC_PMR: uint64 = 0x004            # priority mask
GICC_BPR: uint64 = 0x008
GICC_IAR: uint64 = 0x00C            # interrupt acknowledge
GICC_EOIR: uint64 = 0x010           # end of interrupt

VTIMER_INTID: uint64 = 27           # virtual timer PPI
TICK_LIMIT: int64 = 5

# ---------------------------------------------------------------------------
# Phase 4: EL0 userspace. A tiny hand-emitted AArch64 routine is written into
# an identity-mapped RAM page and entered via `eret` with SPSR_EL1 selecting
# EL0t. It issues two syscalls mirroring the Linux aarch64 ABI (x8 = nr,
# x0..x5 = args, return in x0): write(1, msg, len) then exit(0).
# ---------------------------------------------------------------------------
USER_CODE_BASE: uint64 = 0x40200000   # EL0 instruction page (identity-mapped)
USER_MSG_BASE: uint64 = 0x40201000    # EL0 message buffer
USER_STACK_TOP: uint64 = 0x40280000   # EL0 stack top (grows down), 16B-aligned

# Linux-shape aarch64 syscall numbers used by the demo.
SYS_WRITE_NR: uint64 = 64
SYS_EXIT_NR: uint64 = 93

# Phase 8: a broader EL0 syscall surface. These mirror the Linux aarch64 ABI
# syscall numbers so the dispatch-by-x8 path proves a realistic multi-call
# interface (args in x0..x5, return in x0). One EL0 task exercises each in turn.
#   getpid (172): return the running task's PID.
#   gettid (178): return the running task's TID (== PID for our single thread).
#   sched_yield (124): voluntary yield; the kernel acknowledges and resumes.
#   brk (214): set the program break. brk(0) queries the current break; a
#              non-zero arg moves the break (within a fixed kernel-tracked heap
#              window) and returns the resulting break, sbrk-style.
#   clock_gettime-shape read (kernel-private 513): return CNTVCT_EL0 (the
#              monotonically-advancing virtual counter) so EL0 can observe time.
SYS_GETPID_NR: uint64 = 172
SYS_GETTID_NR: uint64 = 178
SYS_YIELD_NR: uint64 = 124
SYS_BRK_NR: uint64 = 214
SYS_CLOCK_NR: uint64 = 513

# Phase 6: a deliberately-EL1-only EL0 virtual address. RAM is split into 2 MiB
# L2 blocks; only the block at USER_L2_INDEX (0x4020_0000 .. 0x403F_FFFF) carries
# AP[1] (EL0 access). The block at 0x4040_0000 (L2 index 2) is mapped Normal
# EL1-only (no AP[1]), so an EL0 load from it raises a Data Abort (permission
# fault) — exactly the bad access the page-fault handler must catch. We pick a
# memorable sentinel so the reported FAR_EL1 is unmistakable in the log.
FAULT_VA: uint64 = 0x40400000

# Page-fault bookkeeping: set non-zero by the handler once it has caught and
# reported an EL0 abort, so the launcher can confirm the task was terminated
# (not resumed into the faulting instruction) before proceeding to Phase 5.
arm64_fault_handled: int64 = 0

# SPSR_EL1 value to ERET into EL0t with all interrupts masked: bits[3:0]=0
# (EL0t) and DAIF (bits[9:6]) set. 0x3C0 = D|A|I|F masked, mode EL0t.
SPSR_EL0T_DAIF: uint64 = 0x3C0

# Phase 7: per-task TTBR0_EL1 address-space isolation.
#
# Two EL0 tasks each get their OWN level-1 translation table root. Both map the
# SAME virtual address (ISO_SHARED_VA) but to DIFFERENT physical pages, so a
# load from that VA returns task-private data. The kernel switches TTBR0_EL1 (+
# TLB maintenance) between the two tasks; if isolation holds, task A reads its
# sentinel (0xAA) and task B reads its own (0xBB) — neither can see the other's.
#
# Each task's L1 + L2 tables live at distinct EL1-only physical pages (so EL0
# cannot tamper with its own translation tables). The two task-private physical
# data pages also live in EL1-only-for-the-OTHER space: each is only mapped (at
# ISO_SHARED_VA, EL0-accessible) by its own table, proving the isolation.
# The shared VA must be 2 MiB-aligned (it is granted EL0 access as a whole L2
# block). Index 3 (0x4060_0000) is clear of the EL0 code window (index 1) and
# the Phase-6 fault sentinel (index 2).
ISO_SHARED_VA: uint64 = 0x40600000     # the common VA both tasks dereference
ISO_SHARED_L2_INDEX: uint64 = 3        # (0x4060_0000 - 0x4000_0000) / 2 MiB

# Task A address space: L1 root and its RAM L2 table (each a 4 KiB-aligned page
# in EL1-only RAM). The private data BLOCK is a distinct 2 MiB-aligned physical
# region (so the L2 block descriptor for ISO_SHARED_VA can point at it).
ISO_A_L1: uint64 = 0x40110000
ISO_A_L2: uint64 = 0x40111000
ISO_A_DATA: uint64 = 0x40800000        # phys 2 MiB block A maps at ISO_SHARED_VA for A
# Task B address space: L1 root, its RAM L2 table, and its private data block.
ISO_B_L1: uint64 = 0x40114000
ISO_B_L2: uint64 = 0x40115000
ISO_B_DATA: uint64 = 0x40a00000        # phys 2 MiB block B maps at ISO_SHARED_VA for B

# The two sentinels written into the private data pages. Whichever value a task
# reads back at ISO_SHARED_VA identifies which physical page its TTBR0 reached.
ISO_SENTINEL_A: uint64 = 0xAA
ISO_SENTINEL_B: uint64 = 0xBB

# The EL0 code page for the isolation tasks is the existing EL0 RWX window
# (USER_CODE_BASE @0x40200000), identity-mapped EL0-RWX in BOTH task tables.
# The isolation "report" syscall number (kernel-private; outside the Linux ABI
# range used by write/exit) carries the value the task read at ISO_SHARED_VA.
SYS_ISO_REPORT_NR: uint64 = 512

# ESR_EL1.EC (bits[31:26]) value for "SVC instruction execution in AArch64".
ESR_EC_SVC64: uint64 = 0x15

# Phase 6: ESR_EL1.EC values for memory aborts taken from a LOWER EL (EL0):
#   0x20 = Instruction Abort from a lower EL
#   0x21 = Instruction Abort from the current EL
#   0x24 = Data Abort from a lower EL
#   0x25 = Data Abort from the current EL
# The EL0 page-fault path catches 0x20 (bad fetch) and 0x24 (bad load/store);
# FAR_EL1 then holds the faulting virtual address.
ESR_EC_IABORT_LOWER: uint64 = 0x20
ESR_EC_DABORT_LOWER: uint64 = 0x24
# Phase 15: Data Abort from the CURRENT EL (0x25) — the kernel itself faulted,
# e.g. while a copy_*_user accessor dereferenced a bad user pointer.
ESR_EC_DABORT_CUR: uint64 = 0x25

# Phase 14: ESR_EL1.ISS.DFSC (bits[5:0]) — the Data/Instruction Fault Status Code
# — tells WHY an abort fired. A TRANSLATION fault means the page is simply not
# mapped (demand-pageable); a PERMISSION fault means the page IS mapped but the
# access is disallowed (e.g. EL0 to an EL1-only page — a real SIGSEGV). DFSC is a
# {kind, level} pair: 0b0001LL = translation fault at level LL (0x04..0x07),
# 0b0011LL = permission fault at level LL (0x0C..0x0F). We classify by the top
# four bits (DFSC >> 2): 0b0001 == translation, 0b0011 == permission.
ESR_DFSC_MASK: uint64 = 0x3F             # bits[5:0]
ESR_DFSC_KIND_SHIFT: uint64 = 2          # drop the 2-bit level to get {kind}
ESR_DFSC_KIND_XLAT: uint64 = 0x1         # 0b0001xx -> translation fault
ESR_DFSC_KIND_PERM: uint64 = 0x3         # 0b0011xx -> permission fault

# Recorded EL0 exit code (written by the exit syscall) and a done flag.
arm64_el0_exit_code: int64 = -1
arm64_el0_exited: int64 = 0

# Phase 7: per-task TTBR0_EL1 address-space isolation bookkeeping. While the
# isolation demo runs, arm64_iso_active is non-zero; the svc dispatcher then
# routes the demo's "report" syscall (nr 512) into the Phase-7 driver instead
# of the Phase-4 write/exit logic. arm64_iso_reported_a/b latch the value each
# task read back from the SHARED virtual address through its OWN TTBR0, so the
# kernel can prove the two tasks saw different physical memory at the same VA.
arm64_iso_active: int64 = 0
arm64_iso_reported_a: uint64 = 0
arm64_iso_reported_b: uint64 = 0
# Which isolation task is currently live (0 = A, 1 = B).
arm64_iso_cur: int64 = 0

# Phase 8: broader EL0 syscall surface bookkeeping. While the multi-syscall demo
# task runs, arm64_sys_active is non-zero so the svc dispatcher routes calls into
# the Phase-8 handler (getpid/gettid/yield/brk/clock) instead of the Phase-4
# write/exit-only path. arm64_sys_pid is the PID the kernel reports to the task.
# arm64_sys_brk tracks the program break, seeded to the heap base; brk() bumps it
# within [SYS_HEAP_BASE, SYS_HEAP_END). arm64_sys_clock_first latches the first
# CNTVCT_EL0 the task read so the kernel can confirm a later read advanced (proving
# the clock is live + monotonic). arm64_sys_calls counts serviced syscalls.
arm64_sys_active: int64 = 0
arm64_sys_pid: uint64 = 0
arm64_sys_brk: uint64 = 0
arm64_sys_clock_first: uint64 = 0
arm64_sys_clock_seen: int64 = 0
arm64_sys_calls: int64 = 0

# Phase 8 program-break window. The "heap" is a fixed EL0-RWX region inside the
# existing 2 MiB EL0 window (USER_L2_INDEX): brk() may only move the break within
# [SYS_HEAP_BASE, SYS_HEAP_END). The demo task brk(0)s to query the initial break,
# then brk(SYS_HEAP_BASE + 0x1000) to grow it by 4 KiB and confirms the return.
SYS_HEAP_BASE: uint64 = 0x40230000
SYS_HEAP_END: uint64 = 0x40238000
SYS_HEAP_GROW: uint64 = 0x40231000     # the break the demo task requests (BASE + 4 KiB)

# The fixed PID/TID the kernel assigns the single Phase-8 EL0 task.
SYS_DEMO_PID: uint64 = 0x2A            # 42

# ---------------------------------------------------------------------------
# Phase 9: PAGE-TABLE-BACKED brk growth.
#
# Phase 8's brk() merely bumps a pointer inside the already-mapped 2 MiB EL0
# window, so a store to the "grown" address would have succeeded even WITHOUT the
# brk call. Phase 9 makes brk() do real memory management: the heap lives at a
# virtual address whose L2 slot is UNMAPPED at boot (so a store there raises a
# translation Data Abort). On brk-grow the kernel allocates a fresh physical 4 KiB
# page, installs a new L3 page descriptor (EL0 read/write) plus the L2->L3 table
# descriptor into the LIVE TTBR0_EL1 page tables, does the mandatory break-before-
# make TLB maintenance, and only THEN does the EL0 store/load to the newly-brk'd
# address succeed. The task writes a sentinel through the fresh mapping and reads
# it back; the kernel independently confirms the BACKING PHYSICAL page holds it,
# proving the new translation actually reached the page we mapped.
#
# Heap VA 0x40C0_0000: L1 idx 1 (the existing L2_PGTABLE), L2 idx 6 (UNMAPPED at
# boot), L3 idx 0. Index 6 is clear of the EL0 code window (idx 1), the Phase-6
# fault sentinel (idx 2) and the Phase-7 isolation block (idx 3).
P9_HEAP_BASE: uint64 = 0x40C00000      # EL0 heap virtual base (unmapped at boot)
P9_HEAP_L2_INDEX: uint64 = 6           # (0x40C0_0000 - 0x4000_0000) / 2 MiB
P9_HEAP_GROW: uint64 = 0x40C01000      # the break the demo task requests (BASE + 4 KiB)

# Fresh EL1-only physical pages backing the brk mapping. P9_L3 is the new L3
# table installed under L2 slot 6; P9_PAGE is the physical page the first grown
# 4 KiB virtual page maps to. Both sit in otherwise-unused EL1-only RAM, clear of
# the L1/L2 tables (0x4010_0000 / 0x4010_2000) and the Phase-7 iso tables.
P9_L3: uint64 = 0x40130000             # new L3 table for the heap's L2 slot
P9_PAGE: uint64 = 0x40132000           # physical page backing P9_HEAP_BASE

# L3 PAGE descriptor (NOT a block): bits[1:0] = 0b11. Reuse the block EL0 attrs
# (AF | SH_INNER | AttrIndx1 | AP_EL0 | VALID) and additionally set bit1 so the
# walker treats it as a level-3 page entry. 0x745 (block EL0) | 0x2 = 0x747.
P9_PAGE_FLAGS: uint64 = 0x747

# The sentinel the EL0 task stores through the freshly-mapped page and reads back.
P9_SENTINEL: uint64 = 0xC9C9C9C9

# Kernel-private "brk report" syscall: the EL0 task hands back the value it read
# from the brk-grown page so the kernel can verify the new mapping is live.
SYS_BRK_REPORT_NR: uint64 = 514

# Phase 9 bookkeeping. While the brk demo runs, arm64_brk_active routes svc into
# the Phase-9 dispatcher. arm64_brk_cur tracks the program break (seeded to the
# unmapped heap base). arm64_brk_mapped latches non-zero once the kernel has
# installed the fresh page mapping. arm64_brk_reported latches the value the EL0
# task read back through the new mapping.
arm64_brk_active: int64 = 0
arm64_brk_cur: uint64 = 0
arm64_brk_mapped: int64 = 0
arm64_brk_reported: uint64 = 0

# Phase 9 EL0 buffers/code reuse the existing identity-mapped EL0 RWX window
# (USER_CODE_BASE @ index 1). The task's write() message lives clear of the code.
P9_MSG_BASE: uint64 = 0x40224000

# ---------------------------------------------------------------------------
# Phase 10: SMP secondary-core bring-up via PSCI on qemu-virt.
#
# The aarch64 port boots single-core. qemu-virt with `-smp 2` starts the
# secondary CPU(s) POWERED OFF; they are released only by a PSCI CPU_ON call.
# The default `-M virt` machine (cortex-a72, no EL3 firmware) enters the OS at
# EL1 and routes PSCI through the HVC conduit, so _psci_cpu_on() issues `hvc #0`
# per the SMC Calling Convention.
#
# Bring-up sequence (all driven from the primary's Phase-9 hand-off):
#   1. The primary hand-emits a tiny secondary entry TRAMPOLINE into a RAM page.
#      The secondary is released with MMU OFF, SP undefined, at EL1; the
#      trampoline sets SP to a dedicated secondary stack, then branches to the
#      Adder body arm64_secondary_main(). (We bake arm64_secondary_main (as a value) into
#      the trampoline as an immediate — with the identity map VA == PA, an Adder
#      function's address is a valid physical entry point.)
#   2. The primary issues PSCI CPU_ON (func id 0xC4000003) targeting CPU1's
#      affinity, with the trampoline's physical address as the entry point.
#   3. arm64_secondary_main() runs MMU-off on CPU1: it sets an entered flag,
#      enables the GIC CPU interface for its own core, writes a sentinel to a
#      SHARED memory cell (with a dmb ish so the primary observes it), then
#      increments the online-CPU counter — proving real cross-core progress. It
#      never touches the UART (only the primary prints), so the two cores never
#      interleave bytes on the shared PL011.
#   4. The primary spins (dmb ish + reload) waiting for the online counter to
#      reach 2, then prints "[arm64] secondary core entered", "[arm64] CPU1
#      online" and "[arm64] SMP bring-up OK" on the secondary's behalf. The
#      shared cells are PLAIN memory accessed with
#      explicit barriers on both sides (no caching tricks: identity-mapped Normal
#      memory is coherent across the two cores once the MMU/caches are on for the
#      primary and the secondary publishes with dmb).
# ---------------------------------------------------------------------------

# PSCI CPU_ON 64-bit function id (SMC Calling Convention, PSCI v0.2+).
PSCI_FN_CPU_ON: uint64 = 0xC4000003
# PSCI return status: 0 == SUCCESS.
PSCI_SUCCESS: uint64 = 0
# Target affinity (MPIDR_EL1.Aff0) of the secondary core we bring up. On
# qemu-virt CPU index N has affinity N at Aff0.
SMP_CPU1_MPIDR: uint64 = 1

# Secondary entry trampoline: a hand-emitted blob in an EL1-only RAM page (clear
# of the EL0 windows, the page tables, and the Phase-7/9 scratch pages). The
# secondary's PSCI entry point is this page's physical address.
SMP_TRAMPOLINE: uint64 = 0x40140000
# Dedicated 16 KiB secondary boot stack (grows down from the top), EL1-only RAM.
SMP_CPU1_STACK_TOP: uint64 = 0x40150000

# Shared cross-core cells (plain identity-mapped Normal memory, published by the
# secondary with dmb ish and polled by the primary with dmb ish). Kept in their
# own 4 KiB page well clear of code/stacks/tables so cache-line traffic on them
# is isolated. SMP_ONLINE counts cores that have reported live; SMP_SENTINEL is
# the value the secondary writes so the primary can observe genuine cross-core
# progress at a known address.
SMP_ONLINE: uint64 = 0x40160000        # online-CPU counter (primary seeds to 1)
SMP_SENTINEL: uint64 = 0x40160008      # cross-core sentinel cell
SMP_ENTERED: uint64 = 0x40160010       # set to 1 by the secondary on entry
SMP_SENTINEL_VALUE: uint64 = 0x5A5A5A5A   # the value CPU1 publishes

# Phase 12: SECONDARY-CORE SCHEDULING under a real cache-coherent spinlock. After
# Phase 10 has proven CPU1 is alive, the secondary — instead of parking — spins
# on a "go" flag and then runs genuine scheduler work: SMP_ITERS locked
# increments of a SHARED counter, contending with CPU0 doing the same. The lock
# is acquired with ldaxr/stlxr (acquire) and released with stlr (release), so the
# read-modify-write of the shared counter cannot lose updates. The final count is
# deterministic (2*SMP_ITERS) and is ONLY correct if both cores actually ran AND
# the lock held — a missing core or a broken lock produces a wrong total. These
# cells live in their own 4 KiB page, clear of the Phase-10 cells above.
SMP_LOCK: uint64 = 0x40161000          # spinlock word (0 = free, 1 = held)
SMP_SHARED_COUNT: uint64 = 0x40161008  # the contended shared counter
SMP_GO: uint64 = 0x40161010            # primary sets 1 to release CPU1 into work
SMP_CPU0_DONE: uint64 = 0x40161018     # CPU0 sets 1 when its iterations finish
SMP_CPU1_DONE: uint64 = 0x40161020     # CPU1 sets 1 when its iterations finish
SMP_CPU1_TOUCHED: uint64 = 0x40161028  # CPU1 stamps its MPIDR Aff0 under the lock
# Per-core iteration count for the contended-increment demo. Each core performs
# this many locked increments, so a correct run leaves the shared counter at
# 2*SMP_ITERS. Chosen large enough that real contention occurs but the spin stays
# short under TCG.
SMP_ITERS: uint64 = 100000

# The secondary core does NOT touch the shared PL011 UART: with both cores alive
# and no UART lock, concurrent writes would interleave bytes mid-line. Instead
# the secondary signals liveness purely through the shared memory cells above
# (entered flag, sentinel, online counter), and the PRIMARY prints every marker
# once it has observed those publishes — so all UART output stays on one core
# and the boot log is clean and deterministic.

# ---------------------------------------------------------------------------
# Phase 14: DEMAND PAGING via a translation-fault handler.
#
# Phase 9 grew the heap, but only when EL0 explicitly asked for it (brk syscall);
# the mapping was installed BEFORE the EL0 store ran. Real demand paging is
# lazier: a region is left UNMAPPED, and the page is materialised ON FIRST TOUCH
# — the EL0 store itself faults, the kernel maps a fresh page from the abort
# handler, and then RESUMES the very instruction that faulted so it completes
# transparently. The EL0 task never issues a "grow" syscall; it just writes to an
# address that happens to be unbacked, and the kernel pages it in under the hood.
#
# Mechanics: a Data Abort taken from EL0 lands on the same synchronous vector as
# svc. ESR_EL1.EC distinguishes it (0x24, data abort from a lower EL), and
# ESR_EL1.ISS.DFSC (bits[5:0]) tells WHY: a TRANSLATION fault (DFSC 0b0001xx ==
# 0x04..0x07, i.e. the page simply is not mapped) is demand-pageable, whereas a
# PERMISSION fault (DFSC 0b0011xx == 0x0C..0x0F, e.g. EL0 touching an EL1-only
# page — exactly the Phase-6 fault) is a genuine SIGSEGV and the task is reaped.
# So the SAME handler now does both: it pages in translation faults inside the
# demand window and resumes EL0, and still terminates permission faults. The two
# never collide because Phase 6 uses an EL1-only (mapped-but-no-AP[1]) page and
# Phase 14 uses a wholly-unmapped VA.
#
# Demand VA 0x40E0_0000: L1 idx 1 (the existing L2_PGTABLE), L2 idx 7 (UNMAPPED
# at boot), L3 idx 0. Index 7 is clear of the EL0 window (1), the Phase-6 fault
# sentinel (2), the Phase-7 iso block (3) and the Phase-9 brk heap (6).
P14_DEMAND_BASE: uint64 = 0x40E00000     # EL0 demand-paged virtual base (unmapped)
P14_DEMAND_L2_INDEX: uint64 = 7          # (0x40E0_0000 - 0x4000_0000) / 2 MiB

# A SECOND demand-paged virtual page one 4 KiB page above the first, sharing the
# same L2 slot's L3 table. Touching it after the first page proves the handler
# maps each faulting page independently (two distinct first-touch faults) rather
# than blanket-mapping the whole 2 MiB block once.
P14_DEMAND_BASE2: uint64 = 0x40E01000

# Fresh EL1-only physical pages backing the demand mappings. P14_L3 is the new L3
# table installed under L2 slot 7; P14_PAGE0/P14_PAGE1 are the physical pages the
# two demand-faulted virtual pages map to. All sit in otherwise-unused EL1-only
# RAM, clear of the L1/L2 tables, the Phase-7 iso tables and the Phase-9 P9_L3/
# P9_PAGE scratch (0x4013_0000 / 0x4013_2000).
P14_L3: uint64 = 0x40134000              # new L3 table for the demand L2 slot
P14_PAGE0: uint64 = 0x40136000           # physical page backing P14_DEMAND_BASE
P14_PAGE1: uint64 = 0x40137000           # physical page backing P14_DEMAND_BASE2

# L3 PAGE descriptor flags (same as Phase 9): EL0 read/write Normal page,
# bits[1:0]=0b11 so the walker treats it as a level-3 page (not a block).
P14_PAGE_FLAGS: uint64 = 0x747

# The sentinels the EL0 task stores through each freshly demand-paged VA and reads
# back. Distinct per page so a read-back proves the right page was paged in.
P14_SENTINEL0: uint64 = 0xDEADBEEF11112222
P14_SENTINEL1: uint64 = 0xFEEDFACE33334444

# Kernel-private "demand report" syscall: the EL0 task hands back the two values
# it read from the demand-paged pages so the kernel can verify both faults paged
# in correctly. Outside the Linux ABI range; clear of the other private nrs.
SYS_DEMAND_REPORT_NR: uint64 = 540

# Phase 14 bookkeeping. arm64_demand_active routes EL0 aborts/svc into the demand
# path while the demo is live. arm64_demand_faults counts translation faults the
# handler serviced (must reach 2: one per page). arm64_demand_mapped0/1 latch when
# each page's mapping is installed. arm64_demand_reported0/1 latch the read-back
# values the EL0 task reported.
arm64_demand_active: int64 = 0
arm64_demand_faults: int64 = 0
arm64_demand_mapped0: int64 = 0
arm64_demand_mapped1: int64 = 0
arm64_demand_reported0: uint64 = 0
arm64_demand_reported1: uint64 = 0

# Phase 14 EL0 buffers reuse the existing identity-mapped EL0 RWX window
# (USER_CODE_BASE @ index 1). The task's write() message lives clear of the code.
P14_MSG_BASE: uint64 = 0x40225000

# ---------------------------------------------------------------------------
# Phase 15: SAFE USER-MEMORY ACCESS with EFAULT FAULT-TRAPPING (Linux-shape
# copy_from_user / copy_to_user).
#
# A real kernel must dereference user-supplied pointers WITHOUT trusting them: a
# bad pointer (unmapped, or EL1-only) must yield -EFAULT, never a kernel crash.
# Phases 6/14 already trap aborts taken FROM EL0; Phase 15 closes the other half —
# an abort taken FROM EL1 because the KERNEL ITSELF touched a bad user address.
#
# Mechanism (mirrors Linux's exception-table fixup): the safe accessors set a
# global "uaccess in progress" flag, clear a "faulted" flag, then perform the
# load/store through the _uaccess_get64 / _uaccess_put64 intrinsic (a single
# faultable instruction). If the access faults, the current-EL synchronous abort
# is taken; arm64_el1_sync_handler sees the active uaccess window, sets the
# faulted flag, and advances ELR_EL1 PAST the faulting instruction so the kernel
# resumes in the accessor (rather than panicking). The accessor then returns 0 on
# success or -EFAULT (-14) on a trapped fault — exactly the copy_*_user contract.
#
# The demo exercises three cases through the SAME accessor pair:
#   1. copy_from_user from a VALID EL0 address (USER window) -> 0, value
#   2. copy_from_user from TWO distinct wholly-unmapped addresses, each of which
#      raises a current-EL translation data abort -> both return -EFAULT
#   3. copy_to_user to a BAD (unmapped) address -> -EFAULT, then copy_to_user to a
#      VALID EL0 address -> 0, and a kernel read confirms the value landed.
# A PASS proves the kernel survived dereferencing bad user pointers (on both the
# read and the write side) and returned EFAULT instead of dying, AND that valid
# accesses still work.
# ---------------------------------------------------------------------------

# EFAULT, Linux's "bad address" errno, returned as a negative value (sys-style).
EFAULT: int64 = 14

# A valid EL0-accessible scratch cell inside the existing EL0 RWX 2 MiB window
# (USER_L2_INDEX, identity-mapped EL0 RW). Clear of the code page, message
# buffers and the Phase-8 heap window. Used for the "good pointer" cases.
P15_GOOD_VA: uint64 = 0x40240000

# A kernel-side (EL1-only RAM) scratch cell that copy_from_user writes its loaded
# value into — the "kernel destination" of the copy. Sits in otherwise-unused
# EL1-only RAM clear of the page tables and every prior phase's scratch.
P15_OUT_CELL: uint64 = 0x40139000

# Two wholly-UNMAPPED virtual addresses in L1 entries 2 and 3 (VA 0x8000_0000 and
# 0xC000_0000), which arm64_mmu_init leaves zeroed — only L1 entries 0 (device)
# and 1 (RAM) are mapped. Touching either from EL1 raises a current-EL TRANSLATION
# data abort, so the safe accessor must return -EFAULT for both. (FAULT_VA, RAM L2
# index 2, is mapped Normal EL1-only and does NOT fault from EL1 — the kernel may
# read it — so it is unsuitable as a bad-pointer case here.)
P15_UNMAPPED_VA: uint64 = 0x80000000
P15_UNMAPPED_VA2: uint64 = 0xC0000000

# Sentinels the demo writes/reads through the safe accessors. The first is the
# value copy_from_user must read back from the good page; the second is what
# copy_to_user must store (and a subsequent kernel read confirms).
P15_READ_SENTINEL: uint64 = 0x5151ABCD0000F00D
P15_WRITE_SENTINEL: uint64 = 0xCA11AB1E99990000

# Phase 15 uaccess bookkeeping. arm64_uaccess_active is non-zero ONLY across a
# single safe access, so a stray EL1 abort outside the accessor still panics (a
# real kernel bug must not be silently swallowed). arm64_uaccess_faulted latches
# when the EL1 sync handler traps an abort during an active uaccess window.
# arm64_uaccess_faults counts how many bad-pointer accesses were trapped (the
# demo expects exactly 2: the EL1-only page and the unmapped page).
arm64_uaccess_active: int64 = 0
arm64_uaccess_faulted: int64 = 0
arm64_uaccess_faults: int64 = 0

# Latched results of the demo's accesses for the finish-time verdict.
arm64_p15_read_ok: int64 = 0          # copy_from_user(good) returned 0
arm64_p15_read_val: uint64 = 0        # the value it read back
arm64_p15_write_ok: int64 = 0         # copy_to_user(good) returned 0
arm64_p15_write_seen: uint64 = 0      # value the kernel saw at the written cell
arm64_p15_efault0: int64 = 0          # copy_from_user(unmapped #1) -> -EFAULT
arm64_p15_efault1: int64 = 0          # copy_from_user(unmapped #2) -> -EFAULT
arm64_p15_efault2: int64 = 0          # copy_to_user(unmapped)      -> -EFAULT

# ---------------------------------------------------------------------------
# Phase 16: EL0 mmap / munmap with DEMAND-PAGED ANONYMOUS MAPPINGS.
#
# Phase 14 demand-paged a HARD-CODED window: the abort handler knew the two demand
# VAs by constant. Real Linux mmap is dynamic — userspace asks for an anonymous
# region of a given length, the kernel records a VMA (a [base,len) span) and hands
# back a base address WITHOUT mapping any page; the pages materialise lazily on
# first touch, and ONLY because the faulting VA falls inside a live VMA. munmap
# then tears the region down so a later touch of the SAME address faults fatally.
#
# Phase 16 builds exactly this on aarch64. A single EL0 task:
#   1. mmap(len)              -> kernel records a VMA, returns the anon base VA
#                               (no page mapped yet — purely lazy)
#   2. str sentinel,[base]    -> translation fault; the abort handler walks the VMA
#                               table, finds the VA covered, demand-maps a fresh
#                               page and RESUMES the store (it now completes)
#   3. ldr back               -> reads the sentinel through the new mapping
#   4. mmap_report(readback)  -> hands the value back; kernel verifies the demand
#                               map landed in the backing physical page
#   5. munmap(base,len)       -> kernel clears the L3 entry, drops the VMA, flushes
#   6. str sentinel2,[base]   -> translation fault AGAIN, but the VA is now in NO
#                               VMA, so the handler reaps the task (a real SIGSEGV)
# A PASS proves: the anon region was lazily backed only inside its VMA (one demand
# fault), the read-back reached the backing page, AND munmap genuinely removed the
# mapping (the post-munmap touch faulted and was NOT silently re-paged) — the full
# Linux mmap/munmap lifecycle on bare aarch64, driven from Adder.
#
# The mmap region lives in L2 slot 8 (VA 0x4100_0000), which arm64_mmu_init maps
# identity EL1-only; the Phase-16 launcher CLEARS that slot so the first EL0 touch
# genuinely translation-faults (mirroring how Phase 14 clears its slot 7).
# ---------------------------------------------------------------------------

# The anonymous mmap base the kernel hands back. L1 idx 1 (existing L2_PGTABLE),
# L2 idx 8 (cleared to UNMAPPED by the launcher), L3 idx 0.
P16_MMAP_BASE: uint64 = 0x41000000
P16_MMAP_L2_INDEX: uint64 = 8            # (0x4100_0000 - 0x4000_0000) / 2 MiB
P16_MMAP_LEN: uint64 = 0x1000            # one 4 KiB page (anonymous)

# Fresh EL1-only scratch: the new L3 table under L2 slot 8, and the physical page
# the anon VA demand-maps to. Both sit in otherwise-unused EL1-only RAM, clear of
# the L1/L2 tables and every prior phase's scratch (Phase 9 .. 0x4013_2000,
# Phase 14 .. 0x4013_7000, Phase 15 P15_OUT_CELL @0x4013_9000).
P16_L3: uint64 = 0x4013A000              # new L3 table for the mmap L2 slot
P16_PAGE: uint64 = 0x4013C000            # physical page backing P16_MMAP_BASE

# L3 PAGE descriptor flags (same as Phase 9/14): EL0 read/write Normal page,
# bits[1:0]=0b11 so the walker treats it as a level-3 page.
P16_PAGE_FLAGS: uint64 = 0x747

# Sentinels the EL0 task stores: the first through the freshly demand-paged anon
# page (read back + verified), the second after munmap (its store must fault).
P16_SENTINEL: uint64 = 0xB16B00B5C0DE0001
P16_SENTINEL2: uint64 = 0xDEAD0000FACE0002

# mmap region's EL0 message buffer (inside the existing EL0 RWX window, clear of
# the code page and every prior phase's buffers).
P16_MSG_BASE: uint64 = 0x40226000

# Linux aarch64 syscall numbers reused verbatim. mmap is 222, munmap is 215.
SYS_MMAP_NR: uint64 = 222
SYS_MUNMAP_NR: uint64 = 215
# Kernel-private "mmap report" syscall: the EL0 task hands back the value it read
# from the demand-paged anon page so the kernel can verify the mapping. Outside the
# Linux ABI range; clear of the other private nrs (512/514/540).
SYS_MMAP_REPORT_NR: uint64 = 541

# Phase 16 bookkeeping. arm64_mmap_active routes EL0 aborts/svc into the mmap path
# while the demo is live. The VMA table is a single dynamic span [vma_base, vma_base
# + vma_len); vma_live latches whether it is currently mapped (mmap sets it, munmap
# clears it). The abort handler honours a fault ONLY when vma_live and the VA is in
# range. The counters/latches feed the finish-time verdict.
arm64_mmap_active: int64 = 0
arm64_mmap_vma_base: uint64 = 0
arm64_mmap_vma_len: uint64 = 0
arm64_mmap_vma_live: int64 = 0
arm64_mmap_faults: int64 = 0          # demand faults serviced inside a live VMA
arm64_mmap_paged: int64 = 0           # anon page was demand-mapped at least once
arm64_mmap_readback: uint64 = 0       # value the EL0 task read back from the page
arm64_mmap_unmapped: int64 = 0        # munmap tore the VMA + mapping down
arm64_mmap_segv: int64 = 0            # post-munmap touch faulted with NO live VMA

# ---------------------------------------------------------------------------
# Phase 17: EL0 mprotect (nr 226) — CHANGING PAGE PERMISSIONS with a real
# permission-fault check (a write to a now-READ-ONLY page raises a genuine
# SIGSEGV, distinct from the Phase-14/16 demand TRANSLATION faults).
#
# Phase 16 proved an anon mapping materialises (translation fault) and tears
# down (munmap). Phase 17 closes the permissions half of the Linux mmap family:
# a mapped, writable anon page is downgraded to read-only IN PLACE, exactly like
# Linux mprotect(addr, len, PROT_READ). The kernel rewrites the page's L3
# descriptor's AP[2:1] from RW (0b01) to RO (0b11), break-before-makes the TLB,
# and the very next EL0 STORE to that page now raises a PERMISSION Data Abort
# (ESR_EL1.ISS.DFSC = 0b0011xx) — a real SIGSEGV — while a LOAD still succeeds.
#
# A single EL0 task:
#   1. mmap(len)               -> kernel records a VMA, returns the anon base VA
#   2. str sentinel,[base]     -> translation fault; handler demand-maps RW, resumes
#   3. ldr back ; report       -> kernel verifies the RW store/load reached the page
#   4. mprotect(base,len,RD)   -> kernel flips the L3 AP[2:1] RW->RO, flushes TLB
#   5. ldr after-protect       -> STILL succeeds (RO permits reads); report it
#   6. str sentinel2,[base]    -> PERMISSION fault (write to RO) -> real SIGSEGV
# A PASS proves: the page was demand-mapped RW (one translation fault), the read-
# back matched, mprotect flipped the live descriptor to RO, a post-mprotect READ
# still succeeded (RO is readable), AND the post-mprotect WRITE raised a genuine
# PERMISSION fault (NOT a translation fault — the page is still mapped, just not
# writable) — the full Linux mprotect lifecycle on bare aarch64, driven from Adder.
#
# The mprotect region lives in L2 slot 9 (VA 0x4120_0000), which arm64_mmu_init
# maps identity EL1-only; the Phase-17 launcher CLEARS that slot so the first EL0
# touch genuinely translation-faults (mirroring Phase 16's slot 8).
# ---------------------------------------------------------------------------

# The anonymous base the mprotect demo hands back. L1 idx 1 (existing L2_PGTABLE),
# L2 idx 9 (cleared to UNMAPPED by the launcher), L3 idx 0.
P17_MMAP_BASE: uint64 = 0x41200000
P17_MMAP_L2_INDEX: uint64 = 9            # (0x4120_0000 - 0x4000_0000) / 2 MiB
P17_MMAP_LEN: uint64 = 0x1000            # one 4 KiB page (anonymous)

# Fresh EL1-only scratch: the new L3 table under L2 slot 9, and the physical page
# the anon VA demand-maps to. Both sit in otherwise-unused EL1-only RAM, clear of
# every prior phase's scratch (Phase 16 .. P16_PAGE @0x4013_C000).
P17_L3: uint64 = 0x4013E000              # new L3 table for the mprotect L2 slot
# P17_PAGE skips the SMP region (0x4014_0000 .. 0x4016_1028) and lands in the
# free gap just above it, still inside the first identity-mapped 2 MiB RAM block.
P17_PAGE: uint64 = 0x40162000            # physical page backing P17_MMAP_BASE

# L3 PAGE descriptor flags. RW (writable by EL0): same as Phase 16 (0x747) —
# VALID|page(0b11)|AttrIndx1|AF|SH_INNER|AP[1] with AP[2] clear (AP[2:1]=0b01).
# RO sets AP[2] (bit7 = 0x80) so AP[2:1]=0b11 => read-only at EL0 AND EL1; an EL0
# store then raises a PERMISSION Data Abort.
P17_PAGE_FLAGS_RW: uint64 = 0x747
P17_PAGE_AP2_RO: uint64 = 0x80           # AP[2] (bit7): set => read-only
P17_PAGE_FLAGS_RO: uint64 = 0x7C7        # 0x747 | 0x80

# Sentinels: the first stored through the freshly demand-paged RW page (read back
# + verified); the second is the post-mprotect write whose store must PERMISSION-
# fault.
P17_SENTINEL: uint64 = 0xC0FFEE00AB17F001
P17_SENTINEL2: uint64 = 0xBADC0DE0FACE0017

# mprotect region's EL0 message buffer (inside the existing EL0 RWX window, clear
# of the code page and every prior phase's buffers).
P17_MSG_BASE: uint64 = 0x40228000

# Linux aarch64 mprotect syscall number, reused verbatim.
SYS_MPROTECT_NR: uint64 = 226
# Linux PROT_READ flag (mprotect arg2); the demo downgrades RW -> PROT_READ only.
PROT_READ: uint64 = 0x1
# Kernel-private "mprotect report" syscalls: the EL0 task hands back the RW read-
# back (before mprotect) and the post-mprotect read-back so the kernel can verify
# both. Outside the Linux ABI range; clear of the other private nrs (512/514/540/541).
SYS_MPROTECT_REPORT_NR: uint64 = 542     # RW read-back, pre-mprotect
SYS_MPROTECT_RDBACK_NR: uint64 = 543     # read still works post-mprotect (RO)

# Phase 17 bookkeeping. arm64_mprot_active routes EL0 aborts/svc into the mprotect
# path while the demo is live. The VMA span [base, base+len) is recorded by mmap;
# vma_prot_ro latches once mprotect has flipped it read-only. The abort handler
# demand-maps RW translation faults inside the span; a PERMISSION fault inside the
# span (only possible once RO) is the SIGSEGV the verdict needs.
arm64_mprot_active: int64 = 0
arm64_mprot_vma_base: uint64 = 0
arm64_mprot_vma_len: uint64 = 0
arm64_mprot_vma_live: int64 = 0
arm64_mprot_prot_ro: int64 = 0        # mprotect flipped the page read-only
arm64_mprot_faults: int64 = 0         # demand (translation) faults serviced
arm64_mprot_paged: int64 = 0          # anon page was demand-mapped RW at least once
arm64_mprot_readback: uint64 = 0      # RW read-back the EL0 task reported (pre-mprotect)
arm64_mprot_rd_after: uint64 = 0      # read-back AFTER mprotect (RO read must still work)
arm64_mprot_read_ok: int64 = 0        # the post-mprotect READ succeeded (no fault)
arm64_mprot_segv: int64 = 0           # post-mprotect WRITE took a PERMISSION fault

# ---------------------------------------------------------------------------
# Phase 18: MULTI-PAGE anonymous mmap + PARTIAL munmap that SPLITS a VMA.
#
# Every prior phase (9 brk, 14 demand, 16 mmap, 17 mprotect) backed exactly ONE
# 4 KiB page and tracked a single span. Real Linux mmap regions are MULTI-page,
# each page faulting in independently on first touch, and Linux munmap can carve
# a HOLE out of the MIDDLE of a live mapping — SPLITTING one VMA into two. Phase
# 18 builds exactly that on aarch64, using a real (small) VMA TABLE rather than a
# single latched span.
#
# A single EL0 task:
#   1. mmap(3*4KiB)            -> kernel records ONE VMA [base, base+0x3000),
#                                 returns base (no page mapped yet — fully lazy)
#   2. str s0,[base+0]         -> translation fault (page 0); demand-map page 0
#   3. str s1,[base+0x1000]    -> translation fault (page 1); demand-map page 1
#   4. str s2,[base+0x2000]    -> translation fault (page 2); demand-map page 2
#      (THREE independent demand faults — proves per-page lazy backing)
#   5. ldr each back ; report  -> kernel verifies all three reached their pages
#   6. munmap(base+0x1000,4KiB)-> PARTIAL unmap of the MIDDLE page: clears that
#                                 L3 entry AND SPLITS the VMA into two live spans
#                                 [base, base+0x1000) and [base+0x2000, base+0x3000)
#   7. ldr base+0 ; ldr base+0x2000 ; report -> the two SURVIVING pages still hold
#                                 their sentinels (the split kept them mapped)
#   8. str s3,[base+0x1000]    -> translation fault in the HOLE, covered by NO live
#                                 VMA -> fatal SIGSEGV (the reaper turns this into PASS)
#
# A PASS proves: a multi-page anon region was lazily backed one page per touch
# (EXACTLY three translation faults), all three read-backs reached their distinct
# backing pages, a partial munmap of the middle page SPLIT the VMA (leaving two
# live spans), the two surviving pages STAYED mapped across the split, AND the
# hole left by the split faults fatally (it is in no live VMA) — the full Linux
# multi-page-mmap + VMA-splitting munmap lifecycle on bare aarch64, from Adder.
#
# The region lives in L2 slot 10 (VA 0x4140_0000), which arm64_mmu_init maps
# identity EL1-only; the Phase-18 launcher CLEARS that slot so the first EL0 touch
# of each page genuinely translation-faults (mirroring Phase 17's slot 9).
# ---------------------------------------------------------------------------

# The anonymous base the multi-page demo hands back. L1 idx 1 (existing L2_PGTABLE),
# L2 idx 10 (cleared to UNMAPPED by the launcher), L3 idx 0.
P18_MMAP_BASE: uint64 = 0x41400000
P18_MMAP_L2_INDEX: uint64 = 10           # (0x4140_0000 - 0x4000_0000) / 2 MiB
P18_MMAP_LEN: uint64 = 0x3000            # THREE 4 KiB pages (anonymous)
P18_NPAGES: uint64 = 3

# Fresh EL1-only scratch: the new L3 table under L2 slot 10, plus THREE distinct
# physical pages the three anon VAs demand-map to. All sit in the free gap above
# the SMP region (ends 0x4016_1028) and below P17_PAGE (0x4016_2000)... actually
# P18 lands just past P17_PAGE, still inside the first identity-mapped 2 MiB block
# (RAM 0x4000_0000 .. 0x4020_0000), clear of every prior phase's scratch.
P18_L3: uint64 = 0x40163000              # new L3 table for the multi-page L2 slot
P18_PAGE0: uint64 = 0x40164000           # backs P18_MMAP_BASE + 0x0000
P18_PAGE1: uint64 = 0x40165000           # backs P18_MMAP_BASE + 0x1000 (the hole)
P18_PAGE2: uint64 = 0x40166000           # backs P18_MMAP_BASE + 0x2000

# RW page flags (same encoding as Phase 16/17 RW): EL0 read/write Normal page.
P18_PAGE_FLAGS: uint64 = 0x747

# Sentinels: one per page written through the demand-paged RW mapping (read back +
# verified), plus a fourth stored into the post-split HOLE whose store must FAULT.
P18_SENTINEL0: uint64 = 0x1818000000000A00
P18_SENTINEL1: uint64 = 0x1818000000000B01
P18_SENTINEL2: uint64 = 0x1818000000000C02
P18_SENTINEL3: uint64 = 0x1818DEAD0FACE003

# multi-page region's EL0 message buffer (inside the EL0 RWX window, clear of the
# code page and every prior phase's buffers).
P18_MSG_BASE: uint64 = 0x4022A000

# Kernel-private "multi-page report" syscalls (outside the Linux ABI range; clear
# of the other private nrs 512/513/514/540/541/542/543).
SYS_MP_REPORT_NR: uint64 = 544           # the three pre-munmap RW read-backs
SYS_MP_SURVIVE_NR: uint64 = 545          # the two post-split surviving read-backs

# Phase 18 bookkeeping. arm64_mp_active routes EL0 aborts/svc into the multi-page
# path while the demo is live. The VMA TABLE is a small fixed array of (base,len,
# live) triples; mmap fills slot 0 with the whole span; the partial munmap rewrites
# slot 0 to the LOW survivor and fills slot 1 with the HIGH survivor (the SPLIT).
# The abort handler honours a translation fault ONLY when the VA is inside SOME
# live VMA slot; a touch of the carved-out hole matches no slot -> fatal SIGSEGV.
P18_VMA_SLOTS: uint64 = 4
arm64_mp_active: int64 = 0
arm64_mp_vma_base: Array[4, uint64]   # per-slot span base
arm64_mp_vma_len: Array[4, uint64]    # per-slot span length (0 / live==0 => empty)
arm64_mp_vma_live: Array[4, int64]    # per-slot live flag
arm64_mp_faults: int64 = 0            # translation (demand) faults serviced
arm64_mp_paged: int64 = 0             # at least one anon page was demand-mapped
arm64_mp_split: int64 = 0             # partial munmap split the VMA into two
arm64_mp_rd0: uint64 = 0              # pre-munmap read-back of page 0
arm64_mp_rd1: uint64 = 0              # pre-munmap read-back of page 1
arm64_mp_rd2: uint64 = 0              # pre-munmap read-back of page 2
arm64_mp_surv0: uint64 = 0           # post-split read-back of surviving page 0
arm64_mp_surv2: uint64 = 0           # post-split read-back of surviving page 2
arm64_mp_segv: int64 = 0             # post-split touch of the HOLE faulted (no VMA)

# ---------------------------------------------------------------------------
# Phase 19: TWO preemptively-scheduled EL0 tasks, EACH with its OWN TTBR0_EL1
# address space AND its own ASID, with the timer-IRQ context switch swapping
# TTBR0+ASID as well as the saved register context.
#
# Phase 5 already round-robins two EL0 tasks under the EL1 timer IRQ, but both
# tasks share the SINGLE identity TTBR0 (one address space). Phase 7 proves two
# tasks CAN have private TTBR0 spaces, but only as a one-shot, non-preemptive
# hand-switch. Phase 19 fuses the two AND adds real ASID handling: two tasks run
# concurrently, each in a PRIVATE translation regime (private L1/L2 root mapping
# the SAME shared VA to a DIFFERENT physical page) tagged by a DISTINCT ASID, and
# every preemptive timer tick swaps BOTH the register context AND TTBR0_EL1 (with
# the ASID baked into bits[63:48]).
#
# Each task loops: it reads its private sentinel byte at P19_SHARED_VA (resolved
# through its own TTBR0+ASID) and reports it via a kernel-private syscall, then
# busy-loops. The kernel tallies, per task, how many reports carried the CORRECT
# sentinel. The ASID handling is the crux: on a swap the scheduler does NOT do a
# broad `tlbi vmalle1is` flush — it relies on the per-ASID tagging to keep each
# task's translations distinct in the TLB. If ASID tagging were broken, task B
# could resolve P19_SHARED_VA via task A's stale (ASID-untagged) TLB entry and
# read A's sentinel. A PASS requires that across MANY preemptive swaps EVERY read
# stayed private (no cross-task leak) — proving genuine ASID-tagged multitasking.
#
# After P19_GOAL correct swaps with zero leaks the scheduler prints PASS + halts.
# ---------------------------------------------------------------------------

# Shared VA both tasks dereference; 2 MiB-aligned (granted EL0 as one L2 block).
# L2 index 13 (0x41A0_0000), clear of every prior phase's EL0 VA window.
P19_SHARED_VA: uint64 = 0x41A00000
P19_SHARED_L2_INDEX: uint64 = 13        # (0x41A0_0000 - 0x4000_0000) / 2 MiB

# Per-task private translation roots (4 KiB EL1-only RAM pages) + their RAM L2
# tables. They sit in the free gap above the Phase-18 scratch (ends 0x4016_7000)
# and below the EL0 window (0x4020_0000).
P19_A_L1: uint64 = 0x40170000
P19_A_L2: uint64 = 0x40171000
P19_B_L1: uint64 = 0x40172000
P19_B_L2: uint64 = 0x40173000

# Per-task PRIVATE physical data block (2 MiB-aligned; backs P19_SHARED_VA for
# that task). Distinct blocks => the same VA resolves to private memory per task.
P19_A_DATA: uint64 = 0x41600000
P19_B_DATA: uint64 = 0x41800000

# The two sentinels seeded into the private blocks (byte 0). Whichever a task
# reads back at P19_SHARED_VA identifies which physical page its TTBR0 reached.
P19_SENTINEL_A: uint64 = 0xA9
P19_SENTINEL_B: uint64 = 0xB7

# Per-task ASID (in TTBR0_EL1 bits[63:48]; TCR.AS=0 => 8-bit ASID, so the value
# lives in bits[63:56]). Distinct, non-zero ASIDs keep each task's translations
# independently cached so a swap needs no broad TLB flush.
P19_ASID_A: uint64 = 1
P19_ASID_B: uint64 = 2
P19_ASID_SHIFT: uint64 = 48             # ASID field base bit in TTBR0_EL1

# Per-task code/stack live in the shared EL0 RWX window (USER_L2_INDEX), mapped
# identically in both private spaces so each task's instructions are fetchable
# under either TTBR0. Distinct code pages + stacks so the two tasks never alias.
P19_A_CODE: uint64 = 0x40208000
P19_B_CODE: uint64 = 0x4020C000
P19_A_STACK_TOP: uint64 = 0x40260000
P19_B_STACK_TOP: uint64 = 0x40268000

# Per-task context blocks (34 x 8-byte slots: x0..x30, SP_EL0, ELR_EL1, SPSR_EL1)
# in EL1-only RAM (outside the EL0 window). Distinct from the Phase-5 ctx pages.
P19_A_CTX: uint64 = 0x40106000
P19_B_CTX: uint64 = 0x40107000

# Kernel-private "dual-space report" syscall (outside the Linux ABI range and the
# other private nrs 512/513/514/540..545). Carries the byte read at P19_SHARED_VA.
SYS_P19_REPORT_NR: uint64 = 546

# Phase 19 bookkeeping. arm64_p19_active routes svc + timer IRQ into the Phase-19
# path while the demo is live. arm64_p19_cur is the live task index (0=A, 1=B).
# The per-task correct/leak tallies prove ASID-tagged isolation held across every
# preemptive swap; arm64_p19_swaps counts TTBR0+ASID context switches performed.
arm64_p19_active: int64 = 0
arm64_p19_cur: int64 = 0
arm64_p19_swaps: int64 = 0
arm64_p19_a_correct: int64 = 0       # task A reports that carried sentinel A
arm64_p19_b_correct: int64 = 0       # task B reports that carried sentinel B
arm64_p19_leaks: int64 = 0           # any report whose value was the OTHER task's
arm64_p19_reports: int64 = 0         # total reports serviced
P19_GOAL: int64 = 12                 # TTBR0+ASID swaps to perform before the verdict

# ---------------------------------------------------------------------------
# Phase 20: DYNAMIC TASK SPAWN + EXIT/REAPING.
#
# Every prior phase ran a FIXED set of statically-built EL0 tasks that either
# loop forever (Phases 5 / 19) or run a scripted syscall sequence then exit and
# HALT the boot (Phases 8 / 9 / ...). None of them prove the two pillars of a real
# process model: (a) a task can EXIT mid-run and the scheduler REAPS it (stops
# scheduling the dead slot) while the OTHER tasks keep running; (b) a task can be
# CREATED at runtime (a fresh EL0 task with its OWN private address space, ASID and
# entry built on the fly) and scheduled in alongside the survivors — a fork-like
# dynamic spawn, not just two/three static tasks wired up before the first ERET.
#
# Phase 20 builds directly on Phase 19's per-ASID dual-address-space machinery. It
# starts TWO preemptively-scheduled EL0 tasks in PRIVATE ASID-tagged spaces:
#   slot 0 ("A", ASID 1): loops reading its private sentinel at the shared VA and
#           reporting it; after P20_A_EXIT_AT reports it issues exit(7).
#   slot 1 ("B", ASID 2): loops reading + reporting its private sentinel forever.
# On A's exit() the dispatcher marks slot 0 REAPED; the timer-IRQ scheduler then
# NEVER picks slot 0 again — only runnable slots are scheduled, so B keeps running.
# After the reap, on the next tick the scheduler DYNAMICALLY SPAWNS slot 2 ("C",
# ASID 3): it builds C a brand-new private address space (clone identity + private
# shared-VA -> C's own physical block seeded with sentinel C), a fresh EL0 code
# routine, a fresh context block, recycles ASID 3's TLB, and adds it to the
# runnable set. From then on the scheduler round-robins over the RUNNABLE slots
# {B, C}. Each task only ever reads ITS OWN sentinel (resolved through its own
# TTBR0+ASID); a read of any other slot's sentinel is a cross-task LEAK.
#
# PASS requires: slot A actually ran AND exited AND was reaped; slot B ran across
# the whole demo (before AND after both the reap and the spawn); slot C was
# DYNAMICALLY spawned at runtime AND ran in its own private ASID space; and ZERO
# cross-task sentinel leaks occurred over every preemptive TTBR0+ASID swap. After
# P20_GOAL swaps past the spawn the scheduler prints the verdict + halts.
# ---------------------------------------------------------------------------

# Shared VA all three tasks dereference (each resolves it through its own
# TTBR0+ASID to a DIFFERENT private physical block). Reuse the Phase-19 L2 slot
# geometry: 2 MiB-aligned, granted EL0 as one L2 block, clear of prior windows.
P20_SHARED_VA: uint64 = 0x41A00000
P20_SHARED_L2_INDEX: uint64 = 13        # (0x41A0_0000 - 0x4000_0000) / 2 MiB

# Per-slot private translation roots (4 KiB EL1-only RAM pages) + their RAM L2
# tables, in the free gap above the Phase-19 page-table scratch (ends 0x4017_4000)
# and below the EL0 window (0x4020_0000).
P20_A_L1: uint64 = 0x40180000
P20_A_L2: uint64 = 0x40181000
P20_B_L1: uint64 = 0x40182000
P20_B_L2: uint64 = 0x40183000
P20_C_L1: uint64 = 0x40184000
P20_C_L2: uint64 = 0x40185000

# Per-slot PRIVATE physical data block (2 MiB-aligned; backs P20_SHARED_VA for that
# slot). Distinct blocks => the same VA resolves to private memory per slot.
P20_A_DATA: uint64 = 0x41C00000
P20_B_DATA: uint64 = 0x41E00000
P20_C_DATA: uint64 = 0x42000000

# Per-slot sentinels seeded into the private blocks (byte 0).
P20_SENTINEL_A: uint64 = 0xC3
P20_SENTINEL_B: uint64 = 0xD5
P20_SENTINEL_C: uint64 = 0xE7

# Per-slot ASID (TTBR0_EL1 bits[63:48], TCR.AS=0 => 8-bit ASID in bits[63:56]).
# Distinct non-zero ASIDs keep each slot's translations independently cached so a
# swap needs no broad TLB flush.
P20_ASID_A: uint64 = 4
P20_ASID_B: uint64 = 5
P20_ASID_C: uint64 = 6
P20_ASID_SHIFT: uint64 = 48

# Per-slot code + stacks live in the shared EL0 RWX window (USER_L2_INDEX), mapped
# identically in every private space so each slot's instructions are fetchable
# under any TTBR0. Distinct code pages + stacks so the slots never alias.
P20_A_CODE: uint64 = 0x40210000
P20_B_CODE: uint64 = 0x40214000
P20_C_CODE: uint64 = 0x40218000
P20_A_STACK_TOP: uint64 = 0x40270000
P20_B_STACK_TOP: uint64 = 0x40278000
P20_C_STACK_TOP: uint64 = 0x40280000

# Per-slot context blocks (34 x 8-byte slots) in EL1-only RAM (outside EL0 window).
P20_A_CTX: uint64 = 0x40108000
P20_B_CTX: uint64 = 0x40109000
P20_C_CTX: uint64 = 0x4010A000

# Kernel-private "tick report" syscall (carries the byte read at P20_SHARED_VA).
# Distinct from the Phase-19 report nr (546) and the other private nrs.
SYS_P20_TICK_NR: uint64 = 547

# Slot state machine. A runnable slot is scheduled; a REAPED slot (after exit())
# is never scheduled again; an EMPTY slot has not been spawned yet.
P20_SLOT_EMPTY: int64 = 0
P20_SLOT_RUNNABLE: int64 = 1
P20_SLOT_REAPED: int64 = 2

# Phase 20 bookkeeping. arm64_p20_active routes svc + timer IRQ into the Phase-20
# path while the demo is live. arm64_p20_cur is the live slot index (0=A,1=B,2=C).
arm64_p20_active: int64 = 0
arm64_p20_cur: int64 = 0
arm64_p20_state0: int64 = 0          # slot A state
arm64_p20_state1: int64 = 0          # slot B state
arm64_p20_state2: int64 = 0          # slot C state (EMPTY until dynamically spawned)
arm64_p20_a_reports: int64 = 0       # tick reports from slot A
arm64_p20_b_reports: int64 = 0       # tick reports from slot B
arm64_p20_c_reports: int64 = 0       # tick reports from slot C
arm64_p20_a_correct: int64 = 0       # slot A reports carrying its own sentinel
arm64_p20_b_correct: int64 = 0
arm64_p20_c_correct: int64 = 0
arm64_p20_leaks: int64 = 0           # any report whose value was ANOTHER slot's
arm64_p20_swaps: int64 = 0           # TTBR0+ASID swaps performed
arm64_p20_a_reaped: int64 = 0        # 1 once slot A's exit() was reaped
arm64_p20_a_exit_code: int64 = -1    # slot A's recorded exit code (proves exit ran)
arm64_p20_c_spawned: int64 = 0       # 1 once slot C was dynamically spawned
arm64_p20_b_after_spawn: int64 = 0   # slot B reports OBSERVED after the C spawn
arm64_p20_swaps_at_spawn: int64 = 0  # swap count when C was spawned (goal baseline)
P20_A_EXIT_AT: int64 = 3             # tick reports before slot A calls exit()
P20_GOAL: int64 = 10                 # swaps AFTER the spawn before the verdict

# ---------------------------------------------------------------------------
# Phase 21: A BLOCKING PRIMITIVE — sys_nanosleep that DESCHEDULES a task.
#
# Phases 19/20 prove preemptive multitasking, per-ASID address spaces, dynamic
# spawn, and exit/reaping — but every task that wasn't reaped was ALWAYS
# RUNNABLE; the scheduler only ever skipped DEAD slots. None proves the OTHER
# half of a real process model: a LIVE task can voluntarily DESCHEDULE itself
# (block) for a span of time, the scheduler keeps running the OTHER tasks while
# it sleeps, and when the task's deadline passes the scheduler WAKES it and it
# RESUMES exactly where it blocked (past the nanosleep, with the right return).
#
# Phase 21 runs TWO preemptively-scheduled EL0 tasks in PRIVATE ASID-tagged
# spaces (slot A ASID 7, slot B ASID 8 — reusing the Phase-19/20 geometry at
# fresh, non-overlapping addresses). Each task loops: read its private sentinel
# at the shared VA (through its own TTBR0+ASID), report it via a tick syscall,
# then call sys_nanosleep(N) — A sleeps LONG (P21_A_SLEEP ticks), B sleeps SHORT
# (P21_B_SLEEP ticks). nanosleep saves the caller's FULL resume context into its
# slot ctx (x0..x30 + SP_EL0 + the post-svc ELR), records a CNTVCT_EL0 deadline,
# marks the slot BLOCKED, and parks the live EL0 PC on a self-loop so the svc
# eret harmlessly spins until the next timer tick preempts it. The timer-IRQ
# scheduler (arm64_p21_sched_pick) WAKES any BLOCKED slot whose deadline passed
# (back to RUNNABLE) and round-robins ONLY the RUNNABLE slots.
#
# The svc path cannot itself switch tasks (arm64_lower_sync_entry erets to the
# LIVE ELR_EL1/SP_EL0, ignoring arm64_current_ctx), so the blocked task is
# parked on a self-loop and arm64_current_ctx is pointed at a THROWAWAY "park"
# ctx — so the next timer IRQ saves the spin state there, NOT over the slot's
# real saved resume context. On wake the scheduler restores the slot's real ctx.
#
# PASS requires: BOTH tasks ran; EACH task BLOCKED at least once AND was WOKEN
# and RESUMED past its nanosleep (proving the deschedule+deadline+resume cycle);
# at least one tick ran a RUNNABLE task while the OTHER was BLOCKED (proving the
# blocked task genuinely yielded the CPU to a peer); every read stayed private
# (zero cross-task sentinel leaks across the ASID swaps). After P21_GOAL swaps
# the scheduler prints the verdict + halts.
# ---------------------------------------------------------------------------

# Shared VA both tasks dereference (resolved per-slot through its own TTBR0+ASID
# to a DIFFERENT private block). 2 MiB-aligned, L2 index 13 (0x41A0_0000) — the
# same EL0 window slot Phases 19/20 use, but Phase 21's spaces are built fresh.
P21_SHARED_VA: uint64 = 0x41A00000
P21_SHARED_L2_INDEX: uint64 = 13        # (0x41A0_0000 - 0x4000_0000) / 2 MiB

# Per-slot private translation roots (4 KiB EL1-only RAM pages) + RAM L2 tables,
# in the free gap above the Phase-20 page-table scratch (ends 0x4018_6000) and
# below the EL0 window (0x4020_0000).
P21_A_L1: uint64 = 0x40186000
P21_A_L2: uint64 = 0x40187000
P21_B_L1: uint64 = 0x40188000
P21_B_L2: uint64 = 0x40189000

# Per-slot PRIVATE physical data block (2 MiB-aligned; backs P21_SHARED_VA for
# that slot). Above the Phase-20 blocks (which end at 0x4220_0000).
P21_A_DATA: uint64 = 0x42200000
P21_B_DATA: uint64 = 0x42400000

# Per-slot sentinels seeded into the private blocks (byte 0).
P21_SENTINEL_A: uint64 = 0x5A
P21_SENTINEL_B: uint64 = 0x6B

# Per-slot ASID (TTBR0_EL1 bits[63:48]; TCR.AS=0 => 8-bit ASID). Distinct from
# every prior phase's ASIDs (1,2 / 4,5,6) so a swap needs no broad TLB flush.
P21_ASID_A: uint64 = 7
P21_ASID_B: uint64 = 8
P21_ASID_SHIFT: uint64 = 48

# Per-slot code + stacks live in the shared EL0 RWX window (USER_L2_INDEX), in
# the free space above the Phase-20 code/stacks (code <=0x4021_8000, stacks
# <=0x4028_0000) and below the EL0 window top (0x4040_0000).
P21_A_CODE: uint64 = 0x40220000
P21_B_CODE: uint64 = 0x40224000
P21_A_STACK_TOP: uint64 = 0x40288000
P21_B_STACK_TOP: uint64 = 0x40290000

# Per-slot context blocks (34 x 8-byte slots) in EL1-only RAM (outside EL0
# window), above the Phase-20 ctx blocks (which end at 0x4010_B000).
P21_A_CTX: uint64 = 0x4010B000
P21_B_CTX: uint64 = 0x4010C000

# Throwaway "park" ctx: arm64_current_ctx is pointed here while a task is BLOCKED
# and spinning, so the next timer IRQ saves the spin state into THIS block rather
# than over the blocked slot's real (saved) resume context.
P21_PARK_CTX: uint64 = 0x4010D000

# Kernel-private nanosleep + tick-report syscall numbers (distinct from every
# prior private nr: 512/513/514, 540..545, 546, 547).
SYS_P21_TICK_NR: uint64 = 548        # carries the byte read at P21_SHARED_VA
SYS_P21_NANOSLEEP_NR: uint64 = 549   # a0 = number of scheduler ticks to sleep

# Per-slot sleep lengths (in scheduler ticks). A sleeps LONG, B sleeps SHORT, so
# while A is blocked the scheduler keeps running B (the deschedule-others pillar).
P21_A_SLEEP: int64 = 4
P21_B_SLEEP: int64 = 1

# Slot state machine. RUNNABLE => scheduled; BLOCKED => descheduled until its
# CNTVCT deadline passes (then the scheduler wakes it RUNNABLE).
P21_SLOT_RUNNABLE: int64 = 1
P21_SLOT_BLOCKED: int64 = 2

# Phase 21 bookkeeping. arm64_p21_active routes svc + timer IRQ into the Phase-21
# path while the demo is live. arm64_p21_cur is the live slot index (0=A, 1=B).
arm64_p21_active: int64 = 0
arm64_p21_cur: int64 = 0
arm64_p21_state0: int64 = 0          # slot A state
arm64_p21_state1: int64 = 0          # slot B state
arm64_p21_deadline0: uint64 = 0      # slot A CNTVCT wake deadline (when BLOCKED)
arm64_p21_deadline1: uint64 = 0      # slot B CNTVCT wake deadline
arm64_p21_a_reports: int64 = 0       # tick reports from slot A
arm64_p21_b_reports: int64 = 0       # tick reports from slot B
arm64_p21_a_correct: int64 = 0       # slot A reports carrying its own sentinel
arm64_p21_b_correct: int64 = 0
arm64_p21_a_blocks: int64 = 0        # times slot A descheduled via nanosleep
arm64_p21_b_blocks: int64 = 0        # times slot B descheduled via nanosleep
arm64_p21_a_wakes: int64 = 0         # times slot A was woken + resumed past sleep
arm64_p21_b_wakes: int64 = 0         # times slot B was woken + resumed past sleep
arm64_p21_ran_while_peer_blocked: int64 = 0  # ticks a task ran while peer BLOCKED
arm64_p21_leaks: int64 = 0           # any report whose value was the OTHER slot's
arm64_p21_swaps: int64 = 0           # TTBR0+ASID swaps performed
P21_GOAL: int64 = 16                 # swaps before the verdict

# ---------------------------------------------------------------------------
# Phase 22: EL0 FUTEX (FUTEX_WAIT / FUTEX_WAKE) — block on a memory word, woken
# by a peer task. Builds on Phase 21's BLOCKED-state + resume-context-save +
# park-ctx machinery; the ONLY difference is the WAKE condition. A nanosleep
# waiter wakes on a timer deadline; a futex waiter wakes when a PEER task calls
# FUTEX_WAKE on the matching uaddr key. Two preemptively-scheduled EL0 tasks in
# private ASID-tagged spaces share ONE physical futex word mapped at a well-known
# shared VA in BOTH spaces; the PHYSICAL address backing that word is the match
# key, so cross-ASID matching is unambiguous.
#
# Task A (WAITER) loops: report its private sentinel, then futex_wait(F,0). If
# *F==0 it BLOCKS on the futex key; on wake it resumes past the svc. Task B
# (WAKER) loops: report its private sentinel, nanosleep(short) to yield so A can
# block, then write *F=1, futex_wake(F,1) to wake A, then write *F=0 so A's next
# wait blocks again. The cycle repeats, proving block-on-word / wake-by-peer.
# ---------------------------------------------------------------------------

# Shared futex VA both tasks dereference. Resolved per-slot through its own
# TTBR0+ASID, but BOTH map it to the SAME physical block (so it is genuinely a
# shared word, unlike Phase 21's per-slot-private shared VA). 2 MiB-aligned, L2
# index 14 (0x41C0_0000), one slot above Phase 21's shared VA.
P22_FUTEX_VA: uint64 = 0x41C00000
P22_FUTEX_L2_INDEX: uint64 = 14          # (0x41C0_0000 - 0x4000_0000) / 2 MiB

# Private-sentinel shared VA (per-slot private block, like Phase 21) so each task
# has an observable private read for the tick-report / leak-detection pattern.
# 2 MiB-aligned, L2 index 15 (0x41E0_0000).
P22_SENT_VA: uint64 = 0x41E00000
P22_SENT_L2_INDEX: uint64 = 15           # (0x41E0_0000 - 0x4000_0000) / 2 MiB

# Per-slot private translation roots (4 KiB EL1-only RAM pages) + RAM L2 tables,
# in the free gap above Phase 21's page-table scratch (ends 0x4018_A000) and
# below the EL0 window (0x4020_0000).
P22_A_L1: uint64 = 0x4018A000
P22_A_L2: uint64 = 0x4018B000
P22_B_L1: uint64 = 0x4018C000
P22_B_L2: uint64 = 0x4018D000

# ONE shared physical futex word block (2 MiB-aligned), mapped at P22_FUTEX_VA in
# BOTH slots. Above Phase 21's private blocks (which end at 0x4260_0000).
P22_FUTEX_DATA: uint64 = 0x42600000

# Per-slot PRIVATE physical sentinel block (2 MiB-aligned), backs P22_SENT_VA for
# that slot. Above the shared futex block.
P22_A_SENT_DATA: uint64 = 0x42800000
P22_B_SENT_DATA: uint64 = 0x42A00000

# Per-slot sentinels seeded into the private sentinel blocks (byte 0).
P22_SENTINEL_A: uint64 = 0x7C
P22_SENTINEL_B: uint64 = 0x8D

# Per-slot ASID. Distinct from every prior phase's ASIDs (..7,8) so a swap needs
# no broad TLB flush.
P22_ASID_A: uint64 = 9
P22_ASID_B: uint64 = 10
P22_ASID_SHIFT: uint64 = 48

# Per-slot code + stacks live in the shared EL0 RWX window (USER_L2_INDEX), above
# Phase 21's code/stacks (code <=0x4022_8000, stacks <=0x4029_0000) and below the
# EL0 window top (0x4040_0000).
P22_A_CODE: uint64 = 0x40228000
P22_B_CODE: uint64 = 0x4022C000
P22_A_STACK_TOP: uint64 = 0x40298000
P22_B_STACK_TOP: uint64 = 0x402A0000

# Per-slot context blocks (34 x 8-byte slots) in EL1-only RAM, above Phase 21's
# park ctx (0x4010_D000).
P22_A_CTX: uint64 = 0x4010E000
P22_B_CTX: uint64 = 0x4010F000

# Throwaway "park" ctx (same trick as Phase 21): arm64_current_ctx points here
# while a task is BLOCKED + spinning so the next timer IRQ saves the spin state
# here, not over the blocked slot's real saved resume context.
P22_PARK_CTX: uint64 = 0x40110000

# Kernel-private syscall numbers (distinct from every prior private nr, incl.
# Phase 21's 548/549).
SYS_P22_TICK_NR: uint64 = 550        # a0 = byte read at P22_SENT_VA (private)
SYS_P22_FUTEX_NR: uint64 = 551       # a0 = uaddr, a1 = op, a2 = val
SYS_P22_NANOSLEEP_NR: uint64 = 552   # a0 = scheduler ticks to sleep (B pacing)
SYS_P22_POKE_NR: uint64 = 553        # a0 = uaddr, a1 = value: *uaddr = value

# Futex ops.
P22_FUTEX_WAIT: uint64 = 0
P22_FUTEX_WAKE: uint64 = 1

# B's pacing sleep (short) so A reliably blocks on the futex before B wakes it.
P22_B_SLEEP: int64 = 1

# Slot states. RUNNABLE => scheduled. BLOCKED => descheduled (on a futex key OR a
# timer deadline) until woken.
P22_SLOT_RUNNABLE: int64 = 1
P22_SLOT_BLOCKED: int64 = 2

# How a BLOCKED slot is woken: by a peer FUTEX_WAKE on a matching key, or by a
# timer deadline passing (nanosleep). Recorded per slot so the timer path only
# auto-wakes the timer-blocked ones and FUTEX_WAKE only wakes futex-blocked ones.
P22_WAIT_NONE: int64 = 0
P22_WAIT_FUTEX: int64 = 1
P22_WAIT_TIMER: int64 = 2

# Phase 22 bookkeeping. arm64_p22_active routes svc + timer IRQ into the Phase-22
# path while the demo is live. arm64_p22_cur is the live slot index (0=A, 1=B).
arm64_p22_active: int64 = 0
arm64_p22_cur: int64 = 0
arm64_p22_state0: int64 = 0          # slot A state
arm64_p22_state1: int64 = 0          # slot B state
arm64_p22_wait0: int64 = 0           # slot A wait-kind (futex / timer / none)
arm64_p22_wait1: int64 = 0           # slot B wait-kind
arm64_p22_key0: uint64 = 0           # slot A futex match key (physical uaddr)
arm64_p22_key1: uint64 = 0           # slot B futex match key
arm64_p22_deadline0: uint64 = 0      # slot A timer wake deadline (nanosleep)
arm64_p22_deadline1: uint64 = 0      # slot B timer wake deadline
arm64_p22_a_reports: int64 = 0       # tick reports from slot A
arm64_p22_b_reports: int64 = 0       # tick reports from slot B
arm64_p22_a_correct: int64 = 0       # slot A reports carrying its own sentinel
arm64_p22_b_correct: int64 = 0
arm64_p22_a_waits: int64 = 0         # times slot A BLOCKED on the futex
arm64_p22_a_wakes: int64 = 0         # times slot A was WOKEN by a peer FUTEX_WAKE
arm64_p22_wakes_issued: int64 = 0    # FUTEX_WAKE calls that woke >=1 waiter
arm64_p22_ran_while_peer_blocked: int64 = 0  # ticks a task ran while peer BLOCKED
arm64_p22_leaks: int64 = 0           # any report whose value was the OTHER slot's
arm64_p22_swaps: int64 = 0           # TTBR0+ASID swaps performed
P22_GOAL: int64 = 24                 # swaps before the verdict

# ---------------------------------------------------------------------------
# Phase 23: EL0 THREAD-LOCAL STORAGE via TPIDR_EL0 (the AArch64 TLS ABI thread
# pointer) + a SETTLS syscall, saved+restored PER-THREAD across every preemptive
# context switch. This is the register/scheduler wiring that makes pthread-style
# thread-local storage real on arm64: each EL0 thread installs its OWN thread
# pointer (TPIDR_EL0) once via SETTLS; thereafter the thread reads its TLS base
# with a bare `mrs x, tpidr_el0` (NO syscall) and dereferences it. Because the
# scheduler SAVES the outgoing thread's TPIDR_EL0 and RESTORES the incoming
# thread's on every tick, two threads running the SAME EL0 code each see their
# OWN thread-local value — proving genuine per-thread TLS isolation.
#
# Two preemptively-scheduled EL0 tasks in private ASID-tagged spaces: slot A
# (ASID 11) and slot B (ASID 12). Each maps a PRIVATE physical TLS block at a
# shared TLS VA. Each task: (1) on first run calls SETTLS(P23_TLS_VA) to install
# its thread pointer; (2) thereafter loops: `mrs x1,tpidr_el0; ldrb w0,[x1]` to
# read the thread-local sentinel through its OWN thread pointer with no syscall,
# then reports it. A PASS requires BOTH threads installed a TLS pointer, BOTH
# read their own thread-local sentinel through TPIDR_EL0 (no syscall), the
# scheduler preserved each thread's TPIDR_EL0 across MANY context switches, and
# ZERO cross-thread TLS leaks occurred (no thread ever saw the other's value).
# ---------------------------------------------------------------------------

# Shared TLS VA both threads use as their thread pointer. Resolved per-slot
# through its own TTBR0+ASID to that slot's PRIVATE physical TLS block, so the
# bare `mrs tpidr_el0 + ldrb` reads each thread's OWN thread-local sentinel.
# 2 MiB-aligned, L2 index 16 (0x4200_0000), above Phase 22's shared VAs.
P23_TLS_VA: uint64 = 0x42000000
P23_TLS_L2_INDEX: uint64 = 16            # (0x4200_0000 - 0x4000_0000) / 2 MiB

# Per-slot private translation roots (4 KiB EL1-only RAM pages) + RAM L2 tables,
# in the free gap above Phase 22's page-table scratch (ends 0x4018_E000) and
# below the EL0 window (0x4020_0000).
P23_A_L1: uint64 = 0x4018E000
P23_A_L2: uint64 = 0x4018F000
P23_B_L1: uint64 = 0x40190000
P23_B_L2: uint64 = 0x40191000

# Per-slot PRIVATE physical TLS block (2 MiB-aligned), backs P23_TLS_VA for that
# slot. Above Phase 22's sentinel blocks (which end at 0x42C0_0000).
P23_A_TLS_DATA: uint64 = 0x42C00000
P23_B_TLS_DATA: uint64 = 0x42E00000

# Per-slot thread-local sentinel seeded into each TLS block (byte 0). These are
# the values each thread must read back through its OWN TPIDR_EL0.
P23_SENTINEL_A: uint64 = 0xA1
P23_SENTINEL_B: uint64 = 0xB2

# Per-slot ASID. Distinct from every prior phase's ASIDs (..9,10).
P23_ASID_A: uint64 = 11
P23_ASID_B: uint64 = 12
P23_ASID_SHIFT: uint64 = 48

# Per-slot code + stacks in the shared EL0 RWX window, above Phase 22's code/
# stacks (code <=0x4022_C000, stacks <=0x402A_0000) and below the window top.
P23_A_CODE: uint64 = 0x40230000
P23_B_CODE: uint64 = 0x40234000
P23_A_STACK_TOP: uint64 = 0x402B0000
P23_B_STACK_TOP: uint64 = 0x402B8000

# Per-slot context blocks (34 x 8-byte slots) in EL1-only RAM, above Phase 22's
# park ctx (0x4011_0000).
P23_A_CTX: uint64 = 0x40111000
P23_B_CTX: uint64 = 0x40112000

# Kernel-private syscall numbers (distinct from every prior private nr).
SYS_P23_SETTLS_NR: uint64 = 560      # a0 = TLS base VA: write TPIDR_EL0 + record
SYS_P23_TICK_NR: uint64 = 561        # a0 = byte the thread read via TPIDR_EL0

# Phase 23 bookkeeping. arm64_p23_active routes svc + timer IRQ into the Phase-23
# path while the demo is live. arm64_p23_cur is the live slot index (0=A, 1=B).
arm64_p23_active: int64 = 0
arm64_p23_cur: int64 = 0
arm64_p23_tls0: uint64 = 0           # slot A saved TPIDR_EL0 (its thread pointer)
arm64_p23_tls1: uint64 = 0           # slot B saved TPIDR_EL0
arm64_p23_set0: int64 = 0            # slot A has installed its TLS pointer
arm64_p23_set1: int64 = 0            # slot B has installed its TLS pointer
arm64_p23_a_reads: int64 = 0         # slot A reads through its own TPIDR_EL0
arm64_p23_b_reads: int64 = 0
arm64_p23_a_correct: int64 = 0       # slot A reads carrying its own sentinel
arm64_p23_b_correct: int64 = 0
arm64_p23_a_settls: int64 = 0        # times slot A installed a thread pointer
arm64_p23_b_settls: int64 = 0
arm64_p23_leaks: int64 = 0           # any read whose value was the OTHER thread's
arm64_p23_swaps: int64 = 0           # TPIDR-preserving context switches performed
arm64_p23_both_ran_split: int64 = 0  # switches where outgoing+incoming TLS differ
P23_GOAL: int64 = 24                 # swaps before the verdict

# ---------------------------------------------------------------------------
# Phase 24: EL0 DEMAND PAGING across a fresh, wholly-unmapped VA window. Phase 14
# proved the mechanism on TWO hard-coded VAs; Phase 24 generalises it to a real
# multi-page window: a 2 MiB EL0 window is left ENTIRELY unmapped (its L2 slot is
# zero, no L3 table), so the FIRST touch of EACH page raises an independent
# translation Data Abort from EL0. The same EL1 synchronous handler decodes
# ESR_EL1 (EC == 0x24 Data Abort from a lower EL; DFSC == 0b0001xx translation
# fault), allocates a fresh physical page from a small per-phase page pool,
# installs its L3 PTE with EL0 RW permissions, invalidates ONLY that page's stale
# translation (tlbi vaae1is + dsb/isb), and returns WITHOUT advancing ELR so the
# faulting store/load RETRIES and completes transparently. The EL0 demo walks
# N_PAGES distinct pages across the window, writes a per-page sentinel to each,
# reads them all back, and hands the read-backs to the kernel, which verifies
# every value AND that exactly N_PAGES faults were serviced. A translation fault
# OUTSIDE the window keeps the existing fatal-fault behaviour (no masking of real
# bugs).
#
# Window VA 0x4220_0000: L1 idx 1 (the existing L2_PGTABLE), L2 idx 17 (UNMAPPED
# at boot, above Phase 23's TLS VA at L2 idx 16). L3 idx walks 0..N_PAGES-1.
# ---------------------------------------------------------------------------
P24_WINDOW_BASE: uint64 = 0x42200000     # EL0 demand-paged window base (unmapped)
P24_WINDOW_L2_INDEX: uint64 = 17         # (0x4220_0000 - 0x4000_0000) / 2 MiB
P24_PAGE_SIZE: uint64 = 0x1000           # 4 KiB pages
P24_N_PAGES: int64 = 4                   # distinct pages the demo touches/faults

# Fresh EL1-only physical pages: P24_L3 is the new L3 table installed under the
# window's L2 slot; P24_POOL_BASE is the base of a contiguous pool of N_PAGES
# physical pages the fault handler hands out one-per-fault. All sit in otherwise-
# unused EL1-only RAM above Phase 23's per-slot L1/L2 scratch (ends 0x4019_2000).
P24_L3: uint64 = 0x40192000              # new L3 table for the window's L2 slot
P24_POOL_BASE: uint64 = 0x40193000       # 4 contiguous backing pages (0x193..0x196)

# L3 PAGE descriptor flags: EL0 read/write Normal page (VALID | AF | SH_INNER |
# AttrIndx1 | AP[1]), bits[1:0]=0b11 so the walker treats it as a level-3 page.
P24_PAGE_FLAGS: uint64 = 0x747

# Per-page sentinel = base XOR (page index salt). Distinct per page so a read-back
# proves the RIGHT page paged in (not a stale alias of an earlier page).
P24_SENTINEL_BASE: uint64 = 0xC0FFEE0000000000

# Kernel-private syscalls (clear of every prior private nr). REPORT hands one
# read-back (index, value) pair back per page so the kernel verifies each.
SYS_P24_REPORT_NR: uint64 = 570          # a0 = page index, a1 = value read back
SYS_P24_WRITE_NR: uint64 = 571           # write(1, buf, len) -> UART
SYS_P24_EXIT_NR: uint64 = 572            # exit(code) -> verdict + halt

# EL0 message buffer (inside the identity-mapped EL0 RWX window, clear of code).
P24_MSG_BASE: uint64 = 0x40226000

# Phase 24 bookkeeping. arm64_p24_active routes EL0 aborts + svc into the Phase-24
# path while the demo is live. arm64_p24_faults counts translation faults the
# handler serviced (must reach N_PAGES). arm64_p24_next_page is the next pool page
# to hand out. arm64_p24_mapped_mask/_correct_mask are per-page latch bitmasks.
arm64_p24_active: int64 = 0
arm64_p24_faults: int64 = 0
arm64_p24_next_page: int64 = 0
arm64_p24_mapped_mask: uint64 = 0        # bit i set when page i's PTE installed
arm64_p24_correct_mask: uint64 = 0       # bit i set when page i read back correctly
arm64_p24_outside: int64 = 0             # translation faults OUTSIDE the window
arm64_p24_reports: int64 = 0             # report syscalls received

# ---------------------------------------------------------------------------
# Phase 41: REAL EL0 demand-paged anonymous mmap (fault-backed) + munmap.
#
# An EL0 task reserves a virtual address WINDOW that is initially UNMAPPED (a
# lazily-populated anonymous region). On first touch of each page the resulting
# translation Data Abort from EL0 is handled by the kernel: it allocates a fresh
# ZEROED physical page from a small per-phase pool, installs the L3 PTE with EL0
# RW + non-executable (UXN) + inner-shareable Normal-WB attrs, flushes ONLY that
# VA's stale translation, and resumes EL0 at the faulting instruction so the
# store retries and completes. Two distinct pages are demand-paged so the path
# is clearly FAULT-DRIVEN, not pre-mapped. The task writes a known per-page
# sentinel, reads it back, and reports it; the kernel verifies it round-trips
# AND that the backing physical page truly holds it. The task then UNMAPs the
# region (the munmap syscall zeroes the L3 PTEs, drops the backing pages, and
# flushes the TLB), and touches the region AGAIN — which now translation-faults
# anew (the mapping is genuinely gone). The kernel catches that post-munmap
# fault CLEANLY (it does NOT re-page and does NOT crash), latches it, and runs
# the verdict.
#
# Window VA 0x4240_0000: L1 idx 1 (the existing L2_PGTABLE), L2 idx 18 (UNMAPPED
# at boot, above Phase 24's window at L2 idx 17). L3 idx walks 0..N_PAGES-1.
# ---------------------------------------------------------------------------
P41_WINDOW_BASE: uint64 = 0x42400000     # EL0 demand-paged anon window base (unmapped)
P41_WINDOW_L2_INDEX: uint64 = 18         # (0x4240_0000 - 0x4000_0000) / 2 MiB
P41_PAGE_SIZE: uint64 = 0x1000           # 4 KiB pages
P41_N_PAGES: int64 = 2                   # distinct pages the demo touches/faults

# Fresh EL1-only physical pages in the tail of the first identity-mapped 2 MiB
# RAM block (just past Phase 39's scratch which ends at 0x401F_9000). P41_L3 is
# the new L3 table installed under the window's L2 slot; P41_POOL_BASE is the
# base of a contiguous pool of N_PAGES physical pages the fault handler hands out
# one-per-fault.
P41_L3: uint64 = 0x401FA000              # new L3 table for the window's L2 slot
P41_POOL_BASE: uint64 = 0x401FB000       # 2 contiguous backing pages (0x1FB..0x1FC)

# L3 PAGE descriptor flags: EL0 read/write, NON-EXECUTABLE (UXN bit54 set),
# inner-shareable Normal-WB (VALID | page(0b11) | AF | SH_INNER | AttrIndx1 |
# AP[1]). Identical bit pattern to Phase 26's W^X data page flags.
P41_PAGE_FLAGS: uint64 = 0x40000000000747

# Per-page sentinel = base XOR (page index salt). Distinct per page so a read-back
# proves the RIGHT page paged in (not a stale alias of an earlier page).
P41_SENTINEL_BASE: uint64 = 0xA11C0DE000000000

# Kernel-private syscalls (clear of every prior phase's private nr). REPORT hands
# one read-back (index, value) pair back per page; MUNMAP tears the region down;
# WRITE echoes a message to the UART; EXIT runs the verdict + halts.
SYS_P41_REPORT_NR: uint64 = 590          # a0 = page index, a1 = value read back
SYS_P41_MUNMAP_NR: uint64 = 591          # a0 = base, a1 = len -> tear down region
SYS_P41_WRITE_NR: uint64 = 592           # write(1, buf, len) -> UART
SYS_P41_EXIT_NR: uint64 = 593            # exit(code) -> verdict + halt

# EL0 message buffer (inside the identity-mapped EL0 RWX window, clear of code).
P41_MSG_BASE: uint64 = 0x40227000

# Phase 41 bookkeeping. arm64_p41_active routes EL0 aborts + svc into the
# Phase-41 path while the demo is live. arm64_p41_faults counts demand-paging
# translation faults serviced (must reach N_PAGES). arm64_p41_next_page is the
# next pool page to hand out. arm64_p41_mapped_mask/_correct_mask are per-page
# latch bitmasks. arm64_p41_unmapped latches the munmap teardown; _refault_ok
# latches the post-munmap fault being caught cleanly (region truly gone).
arm64_p41_active: int64 = 0
arm64_p41_faults: int64 = 0
arm64_p41_next_page: int64 = 0
arm64_p41_l3_wired: int64 = 0            # L3 table installed under the L2 slot
arm64_p41_mapped_mask: uint64 = 0        # bit i set when page i's PTE installed
arm64_p41_correct_mask: uint64 = 0       # bit i set when page i read back correctly
arm64_p41_outside: int64 = 0             # translation faults OUTSIDE the window
arm64_p41_reports: int64 = 0             # report syscalls received
arm64_p41_unmapped: int64 = 0            # munmap tore the region down
arm64_p41_refault_ok: int64 = 0          # post-munmap touch faulted cleanly (gone)

# ---------------------------------------------------------------------------
# Phase 42: REAL EL0 FILE-backed mmap, demand-paged from the on-disk virtio-blk
# device. An EL0 task reserves a virtual address WINDOW that maps a FILE (a known
# on-disk extent with known contents) lazily: the window is initially UNMAPPED.
# On first touch of each page the resulting translation Data Abort is handled by
# the kernel: it allocates a fresh physical page, computes the page's FILE OFFSET,
# READS the corresponding disk sectors off the virtio-blk device into that page
# (a REAL disk read via the Phase-30 block primitive — NOT a memset), installs the
# L3 PTE with EL0 RO + non-executable (UXN) + inner-shareable Normal-WB attrs,
# flushes ONLY that VA's stale translation, and resumes EL0 so the load retries
# and observes the file's real bytes. Two distinct pages are demand-paged from two
# DIFFERENT file offsets (two different disk extents) so the path is clearly
# FAULT-DRIVEN and file-backed. The task reads the first 8 bytes of each page and
# reports them; the kernel verifies each equals the file's known on-disk signature
# (verified through BOTH the EL0 mapping AND the backing physical page). The task
# then UNMAPs the region (munmap zeroes the L3 PTEs, drops the backing pages,
# flushes the TLB), and touches it AGAIN — which now translation-faults anew (the
# mapping is genuinely gone). The kernel catches that post-munmap fault CLEANLY
# (no re-page, no crash), latches it, and runs the verdict.
#
# Window VA 0x4260_0000: L1 idx 1 (the existing L2_PGTABLE), L2 idx 19 (UNMAPPED
# at boot, above Phase 41's window at L2 idx 18). L3 idx walks 0..N_PAGES-1.
# ---------------------------------------------------------------------------
P42_WINDOW_BASE: uint64 = 0x42600000     # EL0 file-backed mmap window base (unmapped)
P42_WINDOW_L2_INDEX: uint64 = 19         # (0x4260_0000 - 0x4000_0000) / 2 MiB
P42_PAGE_SIZE: uint64 = 0x1000           # 4 KiB pages
P42_N_PAGES: int64 = 2                   # distinct file pages the demo touches/faults

# The file's on-disk extent: a contiguous run of 512-byte virtio-blk sectors,
# 8 sectors (= one 4 KiB page) per mapped page. Page i is backed from file offset
# i*4KiB, i.e. disk sectors [P42_FILE_LBA + i*8 .. +7]. These sectors live well
# past every FAT-filesystem cluster the prior phases use; the test seeds them
# with this phase's known signatures before booting.
P42_FILE_LBA: uint64 = 3072              # first disk sector of the mapped file
P42_SECTORS_PER_PAGE: uint64 = 8         # 8 * 512 = 4096 bytes per page

# Fresh EL1-only physical pages in a private 2 MiB-clear identity-mapped RAM block
# at 0x4700_0000 (above Phase 33's net region which ends at 0x4610_3000). P42_L3
# is the new L3 table installed under the window's L2 slot; P42_POOL_BASE is the
# base of a contiguous pool of N_PAGES physical pages the fault handler hands out
# one-per-fault and fills from disk; P42_SECTOR_BUF is unused scratch headroom.
P42_L3: uint64 = 0x47000000              # new L3 table for the window's L2 slot
P42_POOL_BASE: uint64 = 0x47001000       # N_PAGES contiguous disk-backed pages

# L3 PAGE descriptor flags: EL0 READ-ONLY, NON-EXECUTABLE (UXN bit54 set),
# inner-shareable Normal-WB. A file-backed read-only mapping: VALID | page(0b11) |
# AF | SH_INNER | AttrIndx1 | AP[2:1]=0b11 (EL0/EL1 read-only). Bit pattern:
#   AP=0b11 -> bits[7:6]=0b11 -> 0xC0 ; with the same base bits as Phase 41 but
#   AP[2] set: 0x747 | 0x80 = 0x7C7, plus UXN(bit54)=0x40000000000000.
P42_PAGE_FLAGS: uint64 = 0x400000000007C7

# Per-page on-disk file signature (the first 8 bytes the test writes at the start
# of each page's disk extent). Distinct per page so a read-back proves the RIGHT
# file offset paged in (not a stale alias of an earlier page). Stored LITTLE-ENDIAN
# on disk; an aligned ldr of the first 8 bytes yields exactly this uint64.
P42_FILE_SIG_BASE: uint64 = 0xF11EDA7A00000000

# Kernel-private syscalls (clear of every prior phase's private nr). REPORT hands
# one read-back (index, value) pair back per page; MUNMAP tears the region down;
# WRITE echoes a message to the UART; EXIT runs the verdict + halts.
SYS_P42_REPORT_NR: uint64 = 594          # a0 = page index, a1 = value read back
SYS_P42_MUNMAP_NR: uint64 = 595          # a0 = base, a1 = len -> tear down region
SYS_P42_WRITE_NR: uint64 = 596           # write(1, buf, len) -> UART
SYS_P42_EXIT_NR: uint64 = 597            # exit(code) -> verdict + halt

# EL0 message buffer (inside the identity-mapped EL0 RWX window, clear of code and
# clear of Phase 41's P41_MSG_BASE @0x40227000).
P42_MSG_BASE: uint64 = 0x40228000

# Phase 42 bookkeeping. arm64_p42_active routes EL0 aborts + svc into the
# Phase-42 path while the demo is live. arm64_p42_faults counts demand-paging
# translation faults serviced (must reach N_PAGES). arm64_p42_next_page is the
# next pool page to hand out. arm64_p42_mapped_mask/_correct_mask are per-page
# latch bitmasks. arm64_p42_unmapped latches the munmap teardown; _refault_ok
# latches the post-munmap fault being caught cleanly (region truly gone).
# arm64_p42_disk_base holds the located virtio-blk transport base; _read_ok
# latches that every demand fault's disk read completed OK.
arm64_p42_active: int64 = 0
arm64_p42_faults: int64 = 0
arm64_p42_next_page: int64 = 0
arm64_p42_l3_wired: int64 = 0            # L3 table installed under the L2 slot
arm64_p42_mapped_mask: uint64 = 0        # bit i set when page i's PTE installed
arm64_p42_correct_mask: uint64 = 0       # bit i set when page i read back correctly
arm64_p42_outside: int64 = 0             # translation faults OUTSIDE the window
arm64_p42_reports: int64 = 0             # report syscalls received
arm64_p42_unmapped: int64 = 0            # munmap tore the region down
arm64_p42_refault_ok: int64 = 0          # post-munmap touch faulted cleanly (gone)
arm64_p42_disk_base: uint64 = 0          # located virtio-blk transport base
arm64_p42_reads_ok: int64 = 0            # disk reads that completed OK (one per page)

# ---------------------------------------------------------------------------
# Phase 25: COPY-ON-WRITE fork() for an EL0 task. The parent runs in its own
# ASID-tagged address space, mapping a single 4 KiB COW data page (VA
# P25_DATA_VA, via its own L3 table) RW-private and seeded with a sentinel. The
# parent writes a pre-fork value, then FORKs: the kernel builds a SECOND wholly
# independent address space (the child's own L1/L2/L3 + ASID) that aliases the
# SAME backing physical data page, but flips BOTH parent and child's L3 PTE for
# that page to EL0 READ-ONLY and records it copy-on-write. A WRITE by either
# side then takes a PERMISSION data abort; the COW handler allocates a FRESH
# physical page, copies the shared page into it, remaps the FAULTING task's L3
# PTE to the new page RW-PRIVATE (leaving the other side untouched), flushes that
# ASID's stale translation and resumes. Parent and child each write a DIFFERENT
# value to the SAME VA and read it back; the kernel proves each side sees its own
# value AND the two backing physical pages diverged — i.e. real COW isolation.
#
# Deterministic + abort-driven (IRQs masked, no scheduler), mirroring Phase 24:
# child runs to completion first (cooperatively handed control by FORK), then the
# kernel resumes the parent past the fork to run to its own exit + verdict.
#
# COW data VA 0x4240_0000: L1 idx 1, L2 idx 18 (UNMAPPED at boot, above Phase 24's
# window at L2 idx 17). The data page sits at L3 idx 0 of each space's data L3.
# ---------------------------------------------------------------------------
P25_DATA_VA: uint64 = 0x42400000         # shared (then COW-divergent) EL0 data VA
P25_DATA_L2_INDEX: uint64 = 18           # (0x4240_0000 - 0x4000_0000) / 2 MiB
P25_PAGE_SIZE: uint64 = 0x1000           # 4 KiB pages

# Per-space translation roots (4 KiB EL1-only RAM pages) + RAM L2 tables + the
# data VA's own L3 table, in free EL1-only RAM above Phase 24's pool (which ends
# at 0x4019_6000) and below the EL0 RWX window (0x4020_0000).
P25_PARENT_L1: uint64 = 0x401A0000
P25_PARENT_L2: uint64 = 0x401A1000
P25_PARENT_L3: uint64 = 0x401A2000       # L3 for the COW data VA in the parent
P25_CHILD_L1: uint64 = 0x401A3000
P25_CHILD_L2: uint64 = 0x401A4000
P25_CHILD_L3: uint64 = 0x401A5000        # L3 for the COW data VA in the child

# The ORIGINAL shared backing physical data page (2 MiB-clear of Phase 23's TLS
# blocks, which end at 0x4300_0000). Seeded with P25_SEED before the parent runs.
P25_SHARED_DATA_PA: uint64 = 0x43000000

# Fresh COW pages the permission-fault handler hands out one-per-divergent-write
# (two: one for whichever side writes first, one for the other). Above the
# per-space page-table scratch (ends 0x401A_6000).
P25_COW_POOL_BASE: uint64 = 0x401A6000   # 2 contiguous fresh COW pages

# Per-space EL0 code + stack inside the shared EL0 RWX window. Parent and child
# share IDENTICAL code at the SAME VA (fork shares the text); the child simply
# resumes at the post-FORK PC. Above Phase 23's code (<=0x4023_4000) and stacks.
P25_CODE_BASE: uint64 = 0x40240000
P25_PARENT_STACK_TOP: uint64 = 0x402C0000
P25_CHILD_STACK_TOP: uint64 = 0x402C8000

# Per-space context blocks (34 x 8-byte slots) in EL1-only RAM, above Phase 23's.
P25_PARENT_CTX: uint64 = 0x40113000
P25_CHILD_CTX: uint64 = 0x40114000

# Per-space ASIDs, distinct from every prior phase's (..9,10,11,12).
P25_PARENT_ASID: uint64 = 13
P25_CHILD_ASID: uint64 = 14

# L3 PAGE descriptor flags (bits[1:0]=0b11 page). RW = EL0 read/write Normal-WB
# (== Phase 24's 0x747); RO additionally sets AP[2] (bit7 0x80) -> EL0 read-only,
# so a store takes a PERMISSION fault. The COW share marks the page RO in both
# spaces; the handler restores RW (on a private copy) for the faulting side.
P25_PAGE_RW: uint64 = 0x747
P25_PAGE_RO: uint64 = 0x7C7

# Sentinel seeded into the shared page (byte 0) before the parent runs, plus the
# two DIFFERENT post-fork values parent and child each store at P25_DATA_VA.
P25_SEED: uint64 = 0x55
P25_PARENT_VAL: uint64 = 0xAA11
P25_CHILD_VAL: uint64 = 0xBB22

# Kernel-private syscall numbers (clear of every prior private nr).
SYS_P25_FORK_NR: uint64 = 580      # fork(): child returns x0=0, parent x0=1
SYS_P25_REPORT_NR: uint64 = 581    # a0 = which (0=child,1=parent), a1 = value read
SYS_P25_DONE_NR: uint64 = 582      # child finished -> kernel resumes the parent
SYS_P25_EXIT_NR: uint64 = 583      # parent exit(code) -> verdict + halt

# Phase 25 bookkeeping. arm64_p25_active routes EL0 aborts + svc into the Phase-25
# path while the demo is live. arm64_p25_cur is the live space (0=child,1=parent)
# so the permission-fault handler knows whose L3 to privatise.
arm64_p25_active: int64 = 0
arm64_p25_cur: int64 = 0               # 0 = child space live, 1 = parent space live
arm64_p25_next_cow: int64 = 0          # next fresh COW pool page to hand out
arm64_p25_cow_faults: int64 = 0        # COW permission faults serviced
arm64_p25_forked: int64 = 0            # fork() ran and built the child space
arm64_p25_child_reported: int64 = 0    # child reported its read-back
arm64_p25_parent_reported: int64 = 0   # parent reported its read-back
arm64_p25_child_val: uint64 = 0        # value the child read back at the data VA
arm64_p25_parent_val: uint64 = 0       # value the parent read back at the data VA
arm64_p25_child_pa: uint64 = 0         # child's PRIVATE backing physical page
arm64_p25_parent_pa: uint64 = 0        # parent's PRIVATE backing physical page
arm64_p25_resume_pc: uint64 = 0        # EL0 PC both sides resume at after FORK
arm64_p25_parent_sp: uint64 = 0        # parent's saved SP_EL0 at the FORK svc

# ---------------------------------------------------------------------------
# Phase 26: a real AArch64 ELF64 LOADER + execute. Every EL0 program before this
# phase was hand-emitted machine code dropped straight into an EL0 code page.
# Phase 26 instead PARSES a genuine ELF64 image: it validates e_ident (0x7F 'E'
# 'L' 'F', ELFCLASS64, little-endian), checks e_machine == EM_AARCH64, reads
# e_entry / e_phoff / e_phnum / e_phentsize from the header, then walks the
# program-header table. For each PT_LOAD it allocates page-aligned backing,
# copies p_filesz bytes from the image, zeroes the (p_memsz - p_filesz) BSS tail,
# and maps [p_vaddr, p_vaddr + p_memsz) into a FRESH EL0 address space (its own
# ASID + L1/L2/L3 tables) with protections derived from p_flags: PF_X -> EL0
# executable (read-only text), PF_W -> EL0 RW + non-exec (W^X data), else EL0
# read-only. It then sets up an EL0 stack, ELR_EL1 = e_entry, SPSR for EL0t, and
# ERETs into the loaded program — which runs write(1,msg,len) + exit(N) via svc.
#
# The test image is assembled at boot into a module-scope byte array (a real
# ELF header + two PT_LOADs: an RX text segment carrying the EL0 code + message,
# and an RW data segment with a BSS tail). The loader NEVER assumes the layout:
# every offset/size/flag it acts on is read out of the parsed ELF structures.
#
# Deterministic + abort-driven (IRQs masked, no scheduler), mirroring Phase 25:
# segment pages fault in on the demand-abort path, the program runs to exit().
# ---------------------------------------------------------------------------

# Module-scope image buffer holding the assembled ELF64 file. 4 KiB is ample for
# our header + two program headers + a page of code + message.
P26_IMG_MAX: uint64 = 4096
P26_PAGE_SIZE: uint64 = 0x1000           # 4 KiB pages
arm64_p26_image: Array[4096, uint8]      # the raw ELF64 file bytes
arm64_p26_image_len: uint64 = 0          # total bytes assembled into the image

# ELF64 structural constants (offsets into the file header / a program header).
ELF_EI_MAG0: uint64 = 0x7F
ELF_EI_MAG1: uint64 = 0x45               # 'E'
ELF_EI_MAG2: uint64 = 0x4C               # 'L'
ELF_EI_MAG3: uint64 = 0x46               # 'F'
ELFCLASS64: uint64 = 2
ELFDATA2LSB: uint64 = 1
ET_EXEC: uint64 = 2
EM_AARCH64: uint64 = 183                 # 0xB7
PT_LOAD: uint64 = 1
PF_X: uint64 = 1
PF_W: uint64 = 2
PF_R: uint64 = 4

EHDR_SIZE: uint64 = 64                   # sizeof(Elf64_Ehdr)
PHDR_SIZE: uint64 = 56                   # sizeof(Elf64_Phdr)

# Elf64_Ehdr field byte offsets.
EH_TYPE: uint64 = 16
EH_MACHINE: uint64 = 18
EH_ENTRY: uint64 = 24
EH_PHOFF: uint64 = 32
EH_PHENTSIZE: uint64 = 54
EH_PHNUM: uint64 = 56

# Elf64_Phdr field byte offsets.
PH_TYPE: uint64 = 0
PH_FLAGS: uint64 = 4
PH_OFFSET: uint64 = 8
PH_VADDR: uint64 = 16
PH_FILESZ: uint64 = 32
PH_MEMSZ: uint64 = 40

# Phase 26 EL0 program layout. The text segment loads at P26_TEXT_VA (its own
# 2 MiB L2 slot, distinct from every prior phase's), the data segment at
# P26_DATA_VA. Both are above Phase 25's COW data VA (0x4240_0000).
P26_TEXT_VA: uint64 = 0x42600000         # PT_LOAD #1 (RX): code + message
P26_DATA_VA: uint64 = 0x42800000         # PT_LOAD #2 (RW): data + BSS tail
P26_TEXT_L2_INDEX: uint64 = 19           # (0x4260_0000 - 0x4000_0000) / 2 MiB
P26_DATA_L2_INDEX: uint64 = 20           # (0x4280_0000 - 0x4000_0000) / 2 MiB

# Per-segment file offsets/sizes the ASSEMBLER stamps into the program headers
# (the LOADER re-reads them from the parsed headers — it does not use these).
P26_TEXT_FOFF: uint64 = 0x120            # text seg file offset (after ehdr+2 phdr)
P26_MSG_OFF: uint64 = 0x100              # message offset within the text segment
P26_DATA_FILESZ: uint64 = 8              # 8 init bytes in the data segment file
P26_DATA_MEMSZ: uint64 = 0x40           # data segment mem size (BSS tail beyond 8)

# EL0 VAs the program touches, derived from the segment VAs above.
P26_MSG_VA: uint64 = 0x42600100          # P26_TEXT_VA + P26_MSG_OFF
P26_BSS_VA: uint64 = 0x42800010          # a byte in the data segment's BSS tail

P26_EXIT_CODE: uint64 = 0x2A             # the program's exit status (== 42)

# Fresh EL0 address space for the loaded program: its own L1/L2/L3 roots + ASID +
# stack, in free EL1-only RAM above Phase 25's per-space scratch / COW pool.
P26_L1: uint64 = 0x401B0000
P26_L2: uint64 = 0x401B1000
P26_TEXT_L3: uint64 = 0x401B2000         # L3 for the text segment's 2 MiB slot
P26_DATA_L3: uint64 = 0x401B3000         # L3 for the data segment's 2 MiB slot
P26_ASID: uint64 = 15                    # distinct from prior phases' ASIDs

# Backing physical pages the loader maps the segments onto (each 2 MiB-clear of
# Phase 25's shared data page at 0x4300_0000).
P26_TEXT_PA: uint64 = 0x43200000         # text segment backing page
P26_DATA_PA: uint64 = 0x43400000         # data segment backing page

# EL0 stack for the loaded program (a mapped, RW, non-exec region; SP near top).
P26_STACK_VA: uint64 = 0x42A00000        # data-style RW stack region base
P26_STACK_L2_INDEX: uint64 = 21          # (0x42A0_0000 - 0x4000_0000) / 2 MiB
P26_STACK_L3: uint64 = 0x401B4000
P26_STACK_PA: uint64 = 0x43600000        # stack backing page
P26_STACK_TOP: uint64 = 0x42A01000       # 16B-aligned top of the mapped stack page

# L3 PAGE descriptor flags. RX = EL0 read+exec, read-only (UXN clear, AP[2] set
# read-only). RW = EL0 read/write, non-exec (UXN set, AP[1], no AP[2]). RO = EL0
# read-only, non-exec. (Same Normal-WB attrs as the other phases' 0x747 base.)
P26_PAGE_RX: uint64 = 0x7C7              # VALID|page|AF|SH|attr1|AP[1]|AP[2](RO)
P26_PAGE_RW: uint64 = 0x40000000000747   # ...|UXN(bit54) set -> EL0 non-exec RW
P26_PAGE_RO: uint64 = 0x400000000007C7   # UXN set, AP[2] set -> EL0 RO non-exec

# Kernel-private syscall numbers for the loaded program (clear of every prior nr).
SYS_P26_WRITE_NR: uint64 = 590     # write(1, buf, len): emit to UART
SYS_P26_BSS_NR: uint64 = 591       # report(a0 = byte read back from the BSS tail)
SYS_P26_EXIT_NR: uint64 = 592      # exit(code): verdict + halt

# Phase 26 bookkeeping. arm64_p26_active routes EL0 aborts + svc into the loader's
# path while the loaded program runs.
arm64_p26_active: int64 = 0
arm64_p26_entry: uint64 = 0            # e_entry parsed from the ELF header
arm64_p26_segs_loaded: int64 = 0       # PT_LOAD segments mapped by the loader
arm64_p26_text_faults: int64 = 0       # demand faults serviced for the text seg
arm64_p26_data_faults: int64 = 0       # demand faults serviced for the data seg
arm64_p26_msg_bytes: int64 = 0         # bytes the program wrote via write()
arm64_p26_bss_val: uint64 = 0xFF       # byte the program read back from BSS tail
arm64_p26_bss_reported: int64 = 0      # the program reported its BSS read-back
arm64_p26_exit_code: uint64 = 0xFFFF   # the program's exit() status
arm64_p26_exited: int64 = 0            # the program called exit()
arm64_p26_parse_ok: int64 = 0          # the ELF header validated cleanly

# ---------------------------------------------------------------------------
# Identity-mapped L1 page table. A single level-1 table of 512 8-byte block
# descriptors (4 KiB granule => each L1 entry spans 1 GiB). We place it at a
# fixed, 4 KiB-aligned physical address in RAM, well past the kernel image
# (loaded at 0x4008_0000) and its 64 KiB boot stack. RAM is identity-mapped
# Normal-WB by this very table, so the page used to hold the table is itself
# cacheable Normal memory — fine, the table is read by the page-table walker
# regardless.
# ---------------------------------------------------------------------------
L1_PGTABLE: uint64 = 0x40100000
# Phase 4: a second-level (L2) table covering the 1 GiB RAM block at
# 0x4000_0000 in 2 MiB blocks. We replace the coarse L1 RAM *block* with an L1
# *table* descriptor pointing here, so a single 2 MiB region can be granted EL0
# access without making the kernel's own (.text/stack/pgtable) memory
# EL0-writable. (EL0-writable memory is forced Privileged-eXecute-Never, which
# would fault the kernel's instruction fetches — hence the split.)
L2_PGTABLE: uint64 = 0x40102000

# Block descriptor attribute bits (stage-1 block, levels 1 and 2).
DESC_VALID: uint64 = 0x1            # bit0 valid
DESC_AF: uint64 = 0x400             # bit10 Access Flag (else translation fault)
DESC_SH_INNER: uint64 = 0x300       # bits[9:8]=3 Inner shareable
# AttrIndx: bits[4:2]. attr0 = Device-nGnRE, attr1 = Normal WB.
DEV_FLAGS: uint64 = 0x401           # VALID | AF | AttrIndx0 (device)
MEM_FLAGS: uint64 = 0x705           # VALID | AF | SH_INNER | AttrIndx1 (normal)
# Table descriptor (bits[1:0]=0b11) for an L1 entry that points at an L2 table.
DESC_TABLE: uint64 = 0x3
# Phase 4: the EL0 region's 2 MiB L2 block additionally carries AP[1]
# (bit6 = 0x40) so EL0 can read/write/execute it. UXN is left clear so EL0 may
# execute the hand-emitted user blob; this region holds NO kernel code, so the
# implied PXN-at-EL1 (from EL0 writability) does not affect the kernel.
AP_EL0: uint64 = 0x40               # AP[1]: EL0 access permitted
MEM_FLAGS_EL0: uint64 = 0x745       # MEM_FLAGS | AP_EL0

# RAM L2 geometry: 2 MiB per L2 entry. The user region (USER_CODE_BASE ..
# USER_STACK_TOP) all falls inside one 2 MiB block; index it off RAM base.
# RAM_BASE is a board global: seeded with the qemu-virt value (0x4000_0000) and
# overwritten by board_init() from the selected board descriptor (RK3399 = 0).
RAM_BASE: uint64 = 0x40000000
L2_BLOCK_SIZE: uint64 = 0x200000     # 2 MiB
USER_L2_INDEX: uint64 = 1            # (0x4020_0000 - 0x4000_0000) / 2 MiB

# Timer period (ticks of CNTFRQ): firing every freq/100 ~= 10 ms. Stashed by
# kmain after reading CNTFRQ_EL0 so the IRQ handler can re-arm the timer.
arm64_timer_period: uint64 = 0
# Number of timer ticks serviced so far.
arm64_tick_count: int64 = 0


# ---------------------------------------------------------------------------
# board_init(): copy the compile-time-selected board descriptor (BOARD_SEL) into
# the mutable runtime board globals that the rest of the kernel reads. Called as
# the very first thing in kmain(), BEFORE any UART output, so the console points
# at the right block (PL011 vs 8250) for the target board. Until it runs the
# globals carry their qemu-virt seed values, so an early pre-init fault can still
# print on qemu-virt.
# ---------------------------------------------------------------------------
def board_init() -> int64:
    if BOARD_SEL == BOARD_RK3399_PINEBOOK_PRO:
        PL011_BASE = BOARD_RK_UART_BASE
        UART_TYPE = BOARD_RK_UART_TYPE
        GICD_BASE = BOARD_RK_GICD_BASE
        GICC_BASE = BOARD_RK_GICC_BASE
        RAM_BASE = BOARD_RK_RAM_BASE
        arm64_cpu_count = BOARD_RK_CPU_COUNT
    else:
        # Default / BOARD_QEMU_VIRT.
        PL011_BASE = BOARD_QV_UART_BASE
        UART_TYPE = BOARD_QV_UART_TYPE
        GICD_BASE = BOARD_QV_GICD_BASE
        GICC_BASE = BOARD_QV_GICC_BASE
        RAM_BASE = BOARD_QV_RAM_BASE
        arm64_cpu_count = BOARD_QV_CPU_COUNT
    return 0


# PL011 (PrimeCell) transmit: spin while FR.TXFF set, then write DR.
def _uart_putc_pl011(c: uint8) -> int64:
    fr: Ptr[uint8] = cast[Ptr[uint8]](PL011_BASE + 0x18)
    while (cast[uint64](fr[0]) & PL011_FR_TXFF) != 0:
        pass
    dr: Ptr[uint8] = cast[Ptr[uint8]](PL011_BASE)
    dr[0] = c
    return 0


# 8250/16550 transmit (RK3399 UART2 console primitive): poll LSR until THRE
# (transmit holding register empty) is set, then write the byte to THR. This is
# the minimal working console primitive for the 8250-class boards; no FIFO/baud
# reprogramming is done here (firmware leaves the console initialised).
def _uart_putc_8250(c: uint8) -> int64:
    lsr: Ptr[uint8] = cast[Ptr[uint8]](PL011_BASE + UART_8250_LSR)
    while (cast[uint64](lsr[0]) & UART_8250_LSR_THRE) == 0:
        pass
    thr: Ptr[uint8] = cast[Ptr[uint8]](PL011_BASE + UART_8250_THR)
    thr[0] = c
    return 0


# Board-dispatched console putc. PL011_BASE holds the selected UART's MMIO base
# for either type; UART_TYPE selects the transmit protocol (board_init() sets
# both from the chosen board descriptor).
def _uart_putc(c: uint8) -> int64:
    if UART_TYPE == UART_TYPE_8250:
        _uart_putc_8250(c)
    else:
        _uart_putc_pl011(c)
    return 0


def _uart_puts(s: Ptr[char]) -> int64:
    # Write a NUL-terminated string to the UART, byte by byte.
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    i: int64 = 0
    while p[i] != 0:
        _uart_putc(p[i])
        i = i + 1
    return i


# Print a 64-bit value as "0x" + 16 hex digits, MSB first. Used by the Phase 6
# page-fault handler to report the faulting VA (FAR_EL1) and EL0 PC (ELR_EL1).
def _uart_puthex(value: uint64) -> int64:
    _uart_putc(cast[uint8](0x30))          # '0'
    _uart_putc(cast[uint8](0x78))          # 'x'
    shift: int64 = 60
    while shift >= 0:
        nib: uint64 = (value >> cast[uint64](shift)) & cast[uint64](0xF)
        if nib < cast[uint64](10):
            _uart_putc(cast[uint8](cast[uint64](0x30) + nib))      # '0'..'9'
        else:
            _uart_putc(cast[uint8](cast[uint64](0x37) + nib))      # 'A'..'F'
        shift = shift - 4
    return 0


# ---------------------------------------------------------------------------
# MMU: build the identity map and enable translation + caches.
# ---------------------------------------------------------------------------
def arm64_mmu_init() -> int64:
    tbl: Ptr[uint64] = cast[Ptr[uint64]](L1_PGTABLE)

    # Zero all 512 entries (anything not explicitly mapped faults).
    i: int64 = 0
    while i < 512:
        tbl[i] = 0
        i = i + 1

    # entry[0] : VA 0x0000_0000 .. 0x3FFF_FFFF -> Device-nGnRE (GIC + UART).
    tbl[0] = cast[uint64](0) | DEV_FLAGS

    # entry[1] : VA 0x4000_0000 .. 0x7FFF_FFFF -> RAM. Instead of a coarse 1 GiB
    # block (which would force the whole kernel image EL0-accessible to expose
    # the EL0 demo region), point to a second-level table of 2 MiB blocks so we
    # can grant EL0 access to exactly one 2 MiB window.
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    j: int64 = 0
    while j < 512:
        # Identity-map each 2 MiB block at RAM_BASE + j*2MiB, Normal-WB EL1-only.
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0   # EL0 RWX window for the demo
        else:
            l2[j] = blk_pa | MEM_FLAGS       # kernel: EL1-only
        j = j + 1
    # L1 entry 1 = table descriptor referencing the L2 table.
    tbl[1] = L2_PGTABLE | DESC_TABLE

    # MAIR_EL1 = 0xff04: attr0 = Device-nGnRE (0x04), attr1 = Normal WB (0xff).
    _msr_mair_el1(cast[uint64](0xff04))

    # TCR_EL1 = 0x1_0000_3519:
    #   T0SZ=25 (39-bit VA), IRGN0=1, ORGN0=1, SH0=3 (inner shareable),
    #   TG0=0 (4 KiB granule), IPS=1 (36-bit PA).
    _msr_tcr_el1(cast[uint64](0x100003519))

    # TTBR0_EL1 = &L1 table; TTBR1_EL1 unused.
    _msr_ttbr0_el1(L1_PGTABLE)
    _msr_ttbr1_el1(cast[uint64](0))

    # Make the table writes + sysreg writes visible, flush the TLB.
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # SCTLR_EL1: set M (MMU, bit0), C (data cache, bit2), I (instr cache,
    # bit12). Read-modify-write to preserve the reset state of the rest.
    sctlr: uint64 = cast[uint64](_mrs_sctlr_el1())
    sctlr = sctlr | cast[uint64](0x1)      # M
    sctlr = sctlr | cast[uint64](0x4)      # C
    sctlr = sctlr | cast[uint64](0x1000)   # I
    _msr_sctlr_el1(sctlr)
    _isb()
    return 0


# ---------------------------------------------------------------------------
# GICv2 bring-up: install VBAR_EL1 (the vector table from vectors.S), then
# enable the distributor + CPU interface and route our timer INTID.
# ---------------------------------------------------------------------------
def arm64_gic_init() -> int64:
    # Install the EL1 exception vector table. arm64_vectors is defined in
    # arch/arm64/vectors.S; we materialise its address as an extern.
    _install_vbar()
    _isb()

    # --- GIC Distributor ---
    gicd_ctlr: Ptr[uint32] = cast[Ptr[uint32]](GICD_BASE + GICD_CTLR)
    gicd_ctlr[0] = 0                                  # disable while configuring

    # Enable INTID 27 (timer PPI). It lives in ISENABLER[0] (INTIDs 0..31).
    isenabler: Ptr[uint32] = cast[Ptr[uint32]](GICD_BASE + GICD_ISENABLER)
    isenabler[0] = cast[uint32](1 << 27)

    # Priority 0 (highest) for INTID 27. IPRIORITYR is byte-addressed.
    iprio: Ptr[uint8] = cast[Ptr[uint8]](GICD_BASE + GICD_IPRIORITYR + VTIMER_INTID)
    iprio[0] = 0

    gicd_ctlr[0] = 1                                  # enable distributor

    # --- GIC CPU interface ---
    gicc_pmr: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_PMR)
    gicc_pmr[0] = 0xF0                                # allow all priorities
    gicc_bpr: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_BPR)
    gicc_bpr[0] = 0                                   # no preemption grouping
    gicc_ctlr: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_CTLR)
    gicc_ctlr[0] = 1                                  # enable signalling
    return 0


# ---------------------------------------------------------------------------
# Virtual timer: program a periodic tick and unmask IRQs.
# ---------------------------------------------------------------------------
def arm64_timer_init() -> int64:
    freq: uint64 = cast[uint64](_mrs_cntfrq_el0())    # timer rate (Hz)
    period: uint64 = freq / cast[uint64](100)         # ~10 ms
    arm64_timer_period = period

    _msr_cntv_tval_el0(period)                        # CVAL = now + period
    _msr_cntv_ctl_el0(cast[uint64](1))                # ENABLE=1, IMASK=0
    _isb()

    _msr_daifclr(2)                                   # clear DAIF.I -> IRQs on
    return 0


# ---------------------------------------------------------------------------
# IRQ service routine — called from the vectors.S IRQ stub (which has saved
# the GPR frame). Acks at GICC, prints a per-tick marker, re-arms the timer,
# EOIs, and after TICK_LIMIT ticks prints the completion banner and halts.
# ---------------------------------------------------------------------------
def arm64_irq_handler() -> int64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]                          # ack: raw IAR
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                            # spurious: just EOI
        return 0

    # Our timer. Quiesce the firing condition while we service it.
    _msr_cntv_ctl_el0(cast[uint64](0))

    tickmsg: Ptr[char] = "[arm64] timer tick\n"
    _uart_puts(tickmsg)

    arm64_tick_count = arm64_tick_count + 1

    # Re-arm the next compare and re-enable the timer.
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))

    # EOI the verbatim IAR value.
    gicc_eoir[0] = iar

    if arm64_tick_count >= TICK_LIMIT:
        donemsg: Ptr[char] = "[arm64] timer IRQ OK\n"
        _uart_puts(donemsg)
        # Mask IRQs so the EL0 demo runs without timer re-entry, then proceed
        # to Phase 4: drop to EL0 and service its syscalls. arm64_enter_el0()
        # does not return (the EL0 exit() halts the test).
        _msr_daifset(2)
        arm64_enter_el0()
        # Unreachable; arm64_enter_el0 erets to EL0 and never comes back here.
        while True:
            _wfi()
    return 0


# ---------------------------------------------------------------------------
# Synchronous / unhandled exception diagnostics (called from vectors.S).
# ---------------------------------------------------------------------------
def arm64_sync_panic() -> int64:
    msg: Ptr[char] = "[arm64] SYNC EXCEPTION\n"
    _uart_puts(msg)
    while True:
        _wfi()
    return 0


# Phase 15 — CURRENT-EL synchronous exception handler (the kernel fault-fixup
# path). Called from the vectors.S arm64_el1_sync_entry stub for any EL1h
# synchronous exception. If this is a DATA ABORT taken while a Phase-15 uaccess
# accessor is in progress (arm64_uaccess_active != 0), it is the EXPECTED result
# of dereferencing a bad user pointer: latch the fault, advance ELR_EL1 past the
# faulting load/store (so the eret resumes the accessor at the next instruction),
# and return — the kernel never crashes. Any OTHER current-EL synchronous
# exception is a genuine kernel bug: report the syndrome + faulting address and
# halt in WFI (the legacy panic behaviour), never returning to the stub.
def arm64_el1_sync_handler(frame_ptr: Ptr[uint64]) -> int64:
    esr: uint64 = cast[uint64](_mrs_esr_el1())
    ec: uint64 = (esr >> cast[uint64](26)) & cast[uint64](0x3F)

    if ec == ESR_EC_DABORT_CUR:
        if arm64_uaccess_active != 0:
            # Expected: a copy_*_user touch of a bad user pointer. Mark it and
            # skip the faulting instruction (ELR_EL1 += 4) so we resume cleanly.
            arm64_uaccess_faulted = 1
            arm64_uaccess_faults = arm64_uaccess_faults + 1
            elr: uint64 = cast[uint64](_mrs_elr_el1())
            _msr_elr_el1(elr + cast[uint64](4))
            _isb()
            return 0

    # Not a fixable uaccess fault — a real kernel-mode exception. Report and halt.
    msg: Ptr[char] = "[arm64] EL1 SYNC EXCEPTION (kernel fault)\n"
    _uart_puts(msg)
    far: uint64 = cast[uint64](_mrs_far_el1())
    fm: Ptr[char] = "[arm64] EL1 fault ESR/FAR -> "
    _uart_puts(fm)
    _uart_puthex(esr)
    sp: Ptr[char] = " "
    _uart_puts(sp)
    _uart_puthex(far)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    while True:
        _wfi()
    return 0


# Phase 15 — copy_from_user: safely read one uint64 from user virtual address
# `uptr` into *out, returning 0 on success or -EFAULT if the pointer is bad. The
# read goes through _uaccess_get64 (a single faultable EL1 load); a bad pointer
# faults to arm64_el1_sync_handler which sets arm64_uaccess_faulted and resumes
# us here. We arm the uaccess window only across the access, never wider.
def arm64_copy_from_user_u64(uptr: uint64, out: Ptr[uint64]) -> int64:
    arm64_uaccess_faulted = 0
    arm64_uaccess_active = 1
    v: uint64 = _uaccess_get64(uptr)
    arm64_uaccess_active = 0
    if arm64_uaccess_faulted != 0:
        return cast[int64](0) - EFAULT
    out[0] = v
    return 0


# Phase 15 — copy_to_user: safely write one uint64 `val` to user virtual address
# `uptr`, returning 0 on success or -EFAULT if the pointer is bad. Mirror of
# copy_from_user using _uaccess_put64 (a single faultable EL1 store).
def arm64_copy_to_user_u64(uptr: uint64, val: uint64) -> int64:
    arm64_uaccess_faulted = 0
    arm64_uaccess_active = 1
    _uaccess_put64(uptr, val)
    arm64_uaccess_active = 0
    if arm64_uaccess_faulted != 0:
        return cast[int64](0) - EFAULT
    return 0


def arm64_unhandled_panic() -> int64:
    msg: Ptr[char] = "[arm64] UNHANDLED EXCEPTION\n"
    _uart_puts(msg)
    while True:
        _wfi()
    return 0


# ---------------------------------------------------------------------------
# Phase 4 — EL0 userspace + svc syscall path.
# ---------------------------------------------------------------------------

# Store a 32-bit little-endian instruction word at a code address. Returns the
# next address so the builder can chain word-by-word.
def _emit_word(addr: uint64, word: uint64) -> uint64:
    p: Ptr[uint32] = cast[Ptr[uint32]](addr)
    p[0] = cast[uint32](word & cast[uint64](0xFFFFFFFF))
    return addr + cast[uint64](4)


# Build a 64-bit immediate into register xd using movz + up-to-three movk. The
# AArch64 encodings:
#   movz xd, #imm16, lsl #(16*hw)  = 0xD2800000 | (hw<<21) | (imm16<<5) | xd
#   movk xd, #imm16, lsl #(16*hw)  = 0xF2800000 | (hw<<21) | (imm16<<5) | xd
# We always emit the full 4-halfword sequence for simplicity/determinism.
def _emit_load_imm64(addr: uint64, xd: uint64, value: uint64) -> uint64:
    a: uint64 = addr
    h0: uint64 = value & cast[uint64](0xFFFF)
    h1: uint64 = (value >> cast[uint64](16)) & cast[uint64](0xFFFF)
    h2: uint64 = (value >> cast[uint64](32)) & cast[uint64](0xFFFF)
    h3: uint64 = (value >> cast[uint64](48)) & cast[uint64](0xFFFF)

    movz: uint64 = cast[uint64](0xD2800000) | (h0 << cast[uint64](5)) | xd
    a = _emit_word(a, movz)
    w1: uint64 = cast[uint64](0xF2800000) | (cast[uint64](1) << cast[uint64](21)) | (h1 << cast[uint64](5)) | xd
    a = _emit_word(a, w1)
    w2: uint64 = cast[uint64](0xF2800000) | (cast[uint64](2) << cast[uint64](21)) | (h2 << cast[uint64](5)) | xd
    a = _emit_word(a, w2)
    w3: uint64 = cast[uint64](0xF2800000) | (cast[uint64](3) << cast[uint64](21)) | (h3 << cast[uint64](5)) | xd
    a = _emit_word(a, w3)
    return a


# Copy a NUL-terminated string into the EL0 message buffer and return its
# byte length (excluding the terminator).
def _copy_user_msg(s: Ptr[char]) -> uint64:
    src: Ptr[uint8] = cast[Ptr[uint8]](s)
    dst: Ptr[uint8] = cast[Ptr[uint8]](USER_MSG_BASE)
    i: int64 = 0
    while src[i] != 0:
        dst[i] = src[i]
        i = i + 1
    return cast[uint64](i)


# Materialise the EL0 routine into USER_CODE_BASE:
#   x0 = 1 (stdout); x1 = msg ptr; x2 = len; x8 = 64 (write); svc #0
#   x0 = 0;          x8 = 93 (exit);                            svc #0
# Returns nothing meaningful; the page is then entered via eret.
def arm64_build_user_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))            # x0 = 1
    a = _emit_load_imm64(a, cast[uint64](1), USER_MSG_BASE)             # x1 = msg
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)                   # x2 = len
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)              # x8 = 64
    a = _emit_word(a, cast[uint64](0xD4000001))                        # svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))           # x0 = 0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)              # x8 = 93
    a = _emit_word(a, cast[uint64](0xD4000001))                        # svc #0

    # Ensure the freshly-written instructions are visible to the I-side: clean
    # the data writes and invalidate I-cache (we use a full barrier + ISB; the
    # demo page is small so a coarse maintenance is sufficient here).
    _dsb_ish()
    _isb()
    return 0


# ---------------------------------------------------------------------------
# EL0 synchronous-exception (svc) dispatcher. Called from the vectors.S
# lower-EL sync stub with `frame_ptr` -> the saved x0..x30 frame (slot n holds
# xn). We confirm the trap is an AArch64 SVC via ESR_EL1.EC, pull the syscall
# number (x8) and args (x0..x5) out of the frame, service it, and write the
# return value back into the x0 slot so the eret resumes EL0 with x0 set.
# ---------------------------------------------------------------------------
def arm64_sync_handler(frame_ptr: Ptr[uint64]) -> int64:
    esr: uint64 = cast[uint64](_mrs_esr_el1())
    ec: uint64 = (esr >> cast[uint64](26)) & cast[uint64](0x3F)

    if ec != ESR_EC_SVC64:
        # Not a syscall. Phase 6: an EL0 memory abort (bad load/store/fetch) is
        # a recoverable *user* fault — the kernel must report it and TERMINATE
        # the offending task, never hang. Catch data/instruction aborts taken
        # from the lower EL (EC 0x24 / 0x20), report the faulting VA (FAR_EL1)
        # and EL0 PC (ELR_EL1), then advance to Phase 5 instead of resuming the
        # dead task into its faulting instruction (which would re-fault forever).
        if ec == ESR_EC_DABORT_LOWER:
            # Phase 14: a data abort might be a DEMAND-PAGING translation fault
            # inside the demand window — page it in and resume EL0 — rather than a
            # genuine permission fault to reap. arm64_try_demand_page returns 1 if
            # it handled (mapped + resume) the fault, 0 to fall through to reaping.
            if arm64_demand_active != 0:
                if arm64_try_demand_page(esr) != 0:
                    return 0
            # Phase 24: a data abort might be a DEMAND-PAGING translation fault on
            # a still-unmapped page inside the Phase-24 window — allocate a fresh
            # page, install its EL0-RW L3 PTE, flush only that VA, and resume EL0
            # at the faulting instruction (retry). arm64_p24_try_fault returns 1 if
            # it handled the fault, 0 to fall through to the fatal-fault reaper.
            if arm64_p24_active != 0:
                if arm64_p24_try_fault(esr) != 0:
                    return 0
            # Phase 41: while the demand-paged anon mmap demo is live, a data
            # abort is a translation fault inside the window: either a first-
            # touch demand-page (allocate a fresh page, install the EL0-RW non-
            # exec L3 PTE, resume EL0) or — after munmap — a post-teardown touch
            # the kernel catches cleanly and turns into the Phase-41 verdict.
            # arm64_p41_try_fault returns 1 if it serviced (resume) the fault.
            if arm64_p41_active != 0:
                if arm64_p41_try_fault(esr) != 0:
                    return 0
            # Phase 42: while the FILE-backed mmap demo is live, a data abort is a
            # translation fault inside the window: either a first-touch demand-page
            # (allocate a fresh page, READ the page's file bytes off the virtio-blk
            # device into it, install the EL0-RO non-exec L3 PTE, resume EL0) or —
            # after munmap — a post-teardown touch the kernel catches cleanly and
            # turns into the Phase-42 verdict. arm64_p42_try_fault returns 1 if it
            # serviced (resume) the fault, 0 to fall through to the fatal reaper.
            if arm64_p42_active != 0:
                if arm64_p42_try_fault(esr) != 0:
                    return 0
            # Phase 25: while the COW-fork demo is live, a data abort is a
            # PERMISSION fault on a store to the read-only COW page. Allocate a
            # fresh page, copy the shared page into it, remap the FAULTING space's
            # L3 PTE RW-PRIVATE, flush that ASID, and resume EL0 at the faulting
            # store (retry). arm64_p25_try_cow returns 1 if it serviced the fault.
            if arm64_p25_active != 0:
                if arm64_p25_try_cow(esr) != 0:
                    return 0
            # Phase 26: while the ELF-loaded program runs, a data abort is a
            # first-touch TRANSLATION fault on one of the loaded segment pages (the
            # loader pre-stamped the segment L3 PTEs, so this is the AF/translation
            # of the freshly-mapped page). arm64_p26_try_fault confirms the VA lies
            # in a loaded segment, accounts it, and resumes (return 1); anything
            # else falls through to the fatal-fault reaper.
            if arm64_p26_active != 0:
                if arm64_p26_try_fault(esr) != 0:
                    return 0
            # Phase 32: while the ON-DISK ELF program runs, a data abort is a
            # first-touch TRANSLATION fault on one of its loaded segment pages
            # (the loader pre-stamped the segment L3 PTEs). arm64_p32_try_fault
            # confirms the VA lies in a loaded segment, accounts it, and resumes
            # (return 1); anything else falls through to the fatal-fault reaper.
            if arm64_p32_active != 0:
                if arm64_p32_try_fault(esr) != 0:
                    return 0
            # Phase 36: while the on-disk multi-process userland scenario runs, a
            # data abort is a first-touch TRANSLATION fault on a loaded segment
            # page of WHICHEVER program (A or B) is currently live (the loader
            # pre-stamped the segment L3 PTEs in each program's private space).
            # arm64_p36_try_fault confirms the VA lies in a loaded segment of the
            # live program, accounts it, flushes, and resumes (return 1).
            if arm64_p36_active != 0:
                if arm64_p36_try_fault(esr) != 0:
                    return 0
            # Phase 37: while the blocking-pipe IPC demo runs, a data abort is a
            # first-touch TRANSLATION fault on a loaded segment page of WHICHEVER
            # process (producer or consumer) is currently live (the loader pre-
            # stamped each process's private segment L3 PTEs). arm64_p37_try_fault
            # confirms the VA lies in a loaded segment of the live process, accounts
            # it, flushes, and resumes (return 1).
            if arm64_p37_active != 0:
                if arm64_p37_try_fault(esr) != 0:
                    return 0
            # Phase 38: while the shared-memory IPC demo runs, a data abort is a
            # first-touch TRANSLATION fault on a loaded segment page (text/data/
            # stack) OR on the SHARED region page of WHICHEVER process is currently
            # live (the loader pre-stamped each process's private segment L3 PTEs;
            # SHM_ATTACH pre-stamps the shared page into the caller's private shm
            # L3, pointing at the SAME physical frame). arm64_p38_try_fault confirms
            # the VA lies in a loaded/attached page of the live process and resumes.
            if arm64_p38_active != 0:
                if arm64_p38_try_fault(esr) != 0:
                    return 0
            # Phase 39: while the futex thread-sync demo runs, a data abort is a
            # first-touch TRANSLATION fault on a page of the SINGLE shared address
            # space (either thread's text/stack, or the shared data/futex page). The
            # loader pre-stamped all the L3 PTEs in the ONE page-table tree; both
            # threads run under it. arm64_p39_try_fault confirms the VA lies in a
            # mapped page of the shared space, accounts it, flushes, and resumes.
            if arm64_p39_active != 0:
                if arm64_p39_try_fault(esr) != 0:
                    return 0
            # Phase 43: while the blocking-pipe IPC demo runs, a data abort is a
            # first-touch TRANSLATION fault on a page of the SINGLE shared address
            # space (either task's text/stack, or the shared data page). The loader
            # pre-stamped all the L3 PTEs in the ONE page-table tree; both tasks run
            # under it. arm64_p43_try_fault confirms the VA lies in a mapped page of
            # the shared space, accounts it, flushes, and resumes.
            if arm64_p43_active != 0:
                if arm64_p43_try_fault(esr) != 0:
                    return 0
            # Phase 44: while the EL0 signal-delivery demo is live, a data abort is a
            # first-touch TRANSLATION fault on a page of the single signal task's
            # address space (its text, stack, or sentinel data page — all pre-stamped
            # in the ONE page-table tree). arm64_p44_try_fault confirms the VA lies in a
            # mapped page, accounts it, flushes, and resumes (return 1).
            if arm64_p44_active != 0:
                if arm64_p44_try_fault(esr) != 0:
                    return 0
            # Phase 16: while the mmap demo is live, a data abort might be a
            # demand fault inside a LIVE anonymous VMA (page it in + resume) or a
            # post-munmap touch of a now-dead VMA (fall through to the reaper,
            # which the mmap reaper turns into the Phase-16 SEGV PASS).
            if arm64_mmap_active != 0:
                if arm64_mmap_try_fault(esr) != 0:
                    return 0
                return arm64_mmap_reap(esr)
            # Phase 17: while the mprotect demo is live, a data abort inside the
            # anon VMA is either a TRANSLATION fault (demand-map the RW page +
            # resume) or — once mprotect has flipped the page RO — a PERMISSION
            # fault on a store (a genuine SIGSEGV the reaper turns into the PASS).
            if arm64_mprot_active != 0:
                if arm64_mprot_try_fault(esr) != 0:
                    return 0
                return arm64_mprot_reap(esr)
            # Phase 18: while the multi-page mmap demo is live, a data abort inside
            # a LIVE anon VMA slot is a per-page TRANSLATION fault (demand-map that
            # page + resume); a touch of the carved-out HOLE matches no live slot
            # and falls through to the reaper (the PASS-yielding SIGSEGV).
            if arm64_mp_active != 0:
                if arm64_mp_try_fault(esr) != 0:
                    return 0
                return arm64_mp_reap(esr)
            return arm64_handle_el0_fault(esr, cast[uint64](0))
        if ec == ESR_EC_IABORT_LOWER:
            return arm64_handle_el0_fault(esr, cast[uint64](1))
        # Anything else from EL0 is genuinely unexpected — report and halt.
        msg: Ptr[char] = "[arm64] EL0 non-SVC sync exception\n"
        _uart_puts(msg)
        while True:
            _wfi()

    nr: uint64 = frame_ptr[8]          # x8 = syscall number
    a0: uint64 = frame_ptr[0]          # x0
    a1: uint64 = frame_ptr[1]          # x1
    a2: uint64 = frame_ptr[2]          # x2

    # Phase 7: while the isolation demo is live, the running EL0 task reports the
    # value it read at the SHARED virtual address through its own TTBR0 via the
    # kernel-private "iso report" syscall (x8 = 512, x0 = value). This never
    # returns to EL0; the driver records the value and either launches the next
    # task (after switching TTBR0) or finishes the demo and hands off to Phase 5.
    if arm64_iso_active != 0:
        if nr == SYS_ISO_REPORT_NR:
            arm64_iso_on_report(a0)
            # Unreachable: arm64_iso_on_report transitions away (next task or
            # Phase 5) and never returns. Safety halt if it ever falls through.
            while True:
                _wfi()
        # Any other syscall from an isolation task is unexpected.
        isobad: Ptr[char] = "[arm64] iso task issued unexpected syscall\n"
        _uart_puts(isobad)
        while True:
            _wfi()

    # Phase 11: while the EL0 signal-delivery demo is live, route every svc into
    # the Phase-11 dispatcher (raise/sigreturn/handler-ran/write/exit). raise()
    # builds a signal frame on the EL0 stack and redirects EL0 into a user signal
    # handler; sigreturn() restores the interrupted context; exit() prints PASS.
    if arm64_sig_active != 0:
        return arm64_sig_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 14: while the demand-paging demo is live, route every svc into the
    # Phase-14 dispatcher (demand report/write/exit). The page-in itself happens on
    # the ABORT path (arm64_try_demand_page), not here; these are the task's
    # explicit syscalls AFTER its faulting stores have transparently completed.
    if arm64_demand_active != 0:
        return arm64_demand_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 16: while the mmap demo is live, route every svc into the Phase-16
    # dispatcher (mmap/munmap/report/write/exit). mmap records a VMA + returns its
    # base; the page-in itself happens on the ABORT path (arm64_mmap_try_fault).
    # munmap tears the VMA + mapping down. report verifies the demand-paged value.
    if arm64_mmap_active != 0:
        return arm64_mmap_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 17: while the mprotect demo is live, route every svc into the Phase-17
    # dispatcher (mmap/mprotect/report/rdback/write/exit). mmap records a VMA +
    # returns its base; mprotect flips the live L3 descriptor RW->RO. The page-in
    # (translation fault) and the post-mprotect store PERMISSION fault both happen
    # on the ABORT path (arm64_mprot_try_fault / arm64_mprot_reap), not here.
    if arm64_mprot_active != 0:
        return arm64_mprot_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 18: while the multi-page mmap demo is live, route every svc into the
    # Phase-18 dispatcher (mmap/report/munmap/survive/write/exit). mmap records ONE
    # VMA spanning all pages + returns its base; the partial munmap SPLITS that VMA
    # into two live spans (carving out the middle page). The per-page page-ins
    # (translation faults) and the post-split hole-touch fault happen on the ABORT
    # path (arm64_mp_try_fault / arm64_mp_reap), not here.
    if arm64_mp_active != 0:
        return arm64_mp_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 24: while the demand-paging window demo is live, route every svc into
    # the Phase-24 dispatcher (report / write / exit). The page-ins themselves
    # happen on the ABORT path (arm64_p24_try_fault), not here; these are the
    # task's explicit syscalls AFTER its faulting stores transparently completed.
    if arm64_p24_active != 0:
        return arm64_p24_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 41: while the demand-paged anon mmap demo is live, route every svc
    # into the Phase-41 dispatcher (report / munmap / write / exit). The page-ins
    # themselves happen on the ABORT path (arm64_p41_try_fault), not here; these
    # are the task's explicit syscalls AFTER its faulting stores transparently
    # completed. munmap tears the region down so the subsequent re-touch faults.
    if arm64_p41_active != 0:
        return arm64_p41_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 42: while the FILE-backed mmap demo is live, route every svc into the
    # Phase-42 dispatcher (report / munmap / write / exit). The page-ins (and the
    # backing disk reads) themselves happen on the ABORT path (arm64_p42_try_fault),
    # not here; these are the task's explicit syscalls AFTER its faulting loads
    # transparently completed. munmap tears the region down so the re-touch faults.
    if arm64_p42_active != 0:
        return arm64_p42_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 25: while the COW-fork demo is live, route every svc into the
    # Phase-25 dispatcher (fork / report / done / exit). fork() builds the child
    # address space and cooperatively runs it; the divergent-write COW page-ins
    # happen on the ABORT path (arm64_p25_try_cow), not here.
    if arm64_p25_active != 0:
        return arm64_p25_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 28: while the THREE-task blocking-scheduler demo is live, route every
    # svc into the Phase-28 dispatcher (tick-report / sleep). sleep() DESCHEDULES
    # the running task — saves its full resume context, records a tick deadline,
    # marks it SLEEPING, and parks its EL0 PC on a self-loop so the next timer
    # tick switches to a RUNNABLE peer; the scheduler wakes it at its deadline.
    if arm64_p28_active != 0:
        return arm64_p28_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 29: while the task-exit + wait/reap demo is live, route every svc into
    # the Phase-29 dispatcher (sleep / exit). sleep() DESCHEDULES the caller like
    # Phase 28; exit(status) records the caller's exit status, transitions it to
    # the terminal EXITED (zombie) state and parks its EL0 PC — the scheduler then
    # REAPS it (EXITED -> DEAD) and never dispatches it again.
    if arm64_p29_active != 0:
        return arm64_p29_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 26: while the ELF-loaded EL0 program runs, route every svc into the
    # Phase-26 dispatcher (write / bss-report / exit). write() emits the program's
    # message to the UART; bss-report records the byte it read from the zeroed BSS
    # tail; exit() runs the loader verdict + halts. The segment page-ins happen on
    # the ABORT path (arm64_p26_try_fault), not here.
    if arm64_p26_active != 0:
        return arm64_p26_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 32: while the ON-DISK ELF program runs, route every svc into the
    # Phase-32 dispatcher (write / exit). write() emits the program's message to
    # the UART; exit() runs the loader verdict + halts. The segment page-ins
    # happen on the ABORT path (arm64_p32_try_fault), not here.
    if arm64_p32_active != 0:
        return arm64_p32_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 36: while the on-disk multi-process userland scenario runs, route
    # every svc into the Phase-36 dispatcher — a real EL0 ABI: open/read/write/
    # close against the live FAT16 disk, spawn (synchronously load + run a second
    # on-disk ELF in its own EL0 space), and exit (child resumes the parent past
    # its spawn svc with x0 = child exit status; parent runs the verdict). The
    # per-program segment page-ins happen on the ABORT path (arm64_p36_try_fault).
    if arm64_p36_active != 0:
        return arm64_p36_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 37: while the blocking-pipe IPC demo is live (two on-disk EL0 processes
    # running concurrently under the live timer scheduler), route every svc into
    # the Phase-37 dispatcher (pipe_write / pipe_read / report / exit). pipe_read on
    # an EMPTY pipe DESCHEDULES the caller (saves its resume ctx, marks it BLOCKED,
    # parks its EL0 PC); pipe_write fills the ring and WAKES a blocked reader.
    if arm64_p37_active != 0:
        return arm64_p37_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 38: while the shared-memory IPC demo is live (two on-disk EL0 processes
    # running concurrently under the live timer scheduler), route every svc into the
    # Phase-38 dispatcher (shm_get / shm_attach / signal / wait / report / exit).
    # shm_attach maps the SAME shared physical region into the caller's OWN EL0
    # space; wait on an unsignalled flag DESCHEDULES the caller (BLOCKED); signal
    # WAKES a blocked waiter. The shared region round-trips byte-for-byte.
    if arm64_p38_active != 0:
        return arm64_p38_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 39: while the futex thread-sync demo is live (TWO EL0 threads sharing
    # ONE address space: same page tables + ASID, distinct stacks + register
    # contexts), route every svc into the Phase-39 dispatcher (futex_wait /
    # futex_wake / report / exit). futex_wait(uaddr, expected) atomically checks
    # *uaddr == expected and, if so, DESCHEDULES the caller onto a kernel wait-queue
    # keyed on the user VA (BLOCKED, skipped by the picker); futex_wake(uaddr, n)
    # WAKES up to n waiters parked on that uaddr. Both threads share user memory
    # directly (same TTBR0), so the futex word + handoff value are the SAME bytes.
    if arm64_p39_active != 0:
        return arm64_p39_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 43: while the blocking-pipe IPC demo is live (TWO EL0 tasks sharing ONE
    # address space, run under the live timer scheduler), route every svc into the
    # Phase-43 dispatcher (pipe_read / pipe_write / report / exit). pipe_read on an
    # EMPTY pipe DESCHEDULES the caller (saves its resume ctx, marks it BLOCKED,
    # parks its EL0 PC); pipe_write fills the kernel ring and WAKES a blocked reader.
    # pipe_write into a FULL ring likewise BLOCKS the writer until a read drains it.
    if arm64_p43_active != 0:
        return arm64_p43_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 44: while the EL0 signal-delivery demo is live (ONE EL0 task running a
    # computation loop, signalled ASYNCHRONOUSLY by the timer), route every svc into
    # the Phase-44 dispatcher: the handler reports it ran + sets a user sentinel, then
    # sigreturn restores the FULL interrupted frame off the EL0 stack so the loop
    # resumes exactly where it was preempted; report/exit run the verdict.
    if arm64_p44_active != 0:
        return arm64_p44_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 23: while the TLS demo is live, route every svc into the Phase-23
    # dispatcher (settls / tick-report). SETTLS installs the running thread's
    # TPIDR_EL0 (thread pointer) and records it so the scheduler preserves it
    # across context switches; tick-report tallies the thread-local sentinel the
    # thread read through its OWN TPIDR_EL0 (with no syscall).
    if arm64_p23_active != 0:
        return arm64_p23_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 22: while the futex demo is live, route every svc into the Phase-22
    # dispatcher (tick-report / futex / nanosleep / poke). FUTEX_WAIT DESCHEDULES
    # the running task on a memory-word key; FUTEX_WAKE flips matching BLOCKED-on-
    # futex peers back to RUNNABLE.
    if arm64_p22_active != 0:
        return arm64_p22_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 21: while the blocking-nanosleep demo is live, route every svc into the
    # Phase-21 dispatcher (tick-report / nanosleep). nanosleep DESCHEDULES the
    # running task — it records the task's wake deadline (a CNTVCT_EL0 target),
    # marks the slot BLOCKED, and forces a context switch to a RUNNABLE peer so the
    # blocked task's stack frame stays parked until the timer-IRQ scheduler wakes it.
    if arm64_p21_active != 0:
        return arm64_p21_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 19: while the dual-address-space scheduling demo is live, route every
    # svc into the Phase-19 dispatcher. Each task reads its OWN private sentinel at
    # the SHARED VA (resolved through its private TTBR0+ASID) and reports it; the
    # dispatcher tallies correct/incorrect reads per task. The TTBR0+ASID swap
    # itself happens on the timer-IRQ path (arm64_sched_pick), not here.
    if arm64_p19_active != 0:
        return arm64_p19_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 20: while the dynamic-spawn / exit-reaping demo is live, route every svc
    # into the Phase-20 dispatcher (tick-report / exit). A task's exit() marks its
    # slot REAPED so the scheduler drops it; tick-report tallies its private-sentinel
    # reads. The dynamic spawn of the third task happens on the timer-IRQ path
    # (arm64_p20_sched_pick), not here.
    if arm64_p20_active != 0:
        return arm64_p20_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 13: while the FP context-switch demo is live, route every svc into the
    # Phase-13 dispatcher (fpcheck/yield/exit). yield saves the outgoing task's
    # d8..d15, restores the incoming task's, and erets into it; fpcheck verifies a
    # task's FP signature survived the switch.
    if arm64_fp_active != 0:
        return arm64_fp_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 9: while the page-table-backed brk demo is live, route every svc into
    # the Phase-9 dispatcher (brk/report/write/exit). brk-grow installs a fresh
    # page mapping into the live TTBR0 tables; report verifies the EL0 task read
    # back the sentinel through that new mapping; exit prints the Phase-9 PASS
    # marker and halts.
    if arm64_brk_active != 0:
        return arm64_brk_dispatch(frame_ptr, nr, a0, a1, a2)

    # Phase 8: while the broader-syscall-surface demo is live, route by x8 into
    # the Phase-8 handler (getpid/gettid/yield/brk/clock/write/exit). It services
    # the call, writes the return value into the x0 frame slot, and returns 0 so
    # the common eret path resumes EL0 — EXCEPT exit, which never returns (it
    # halts the boot after printing the Phase-8 PASS marker).
    if arm64_sys_active != 0:
        return arm64_sys_dispatch(frame_ptr, nr, a0, a1, a2)

    ret: uint64 = cast[uint64](0)

    if nr == SYS_WRITE_NR:
        # write(fd, buf, len): emit the buffer to the kernel UART regardless of
        # fd (the demo only ever uses fd 1). Return the byte count.
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        okmsg: Ptr[char] = "[arm64] EL0 write syscall serviced\n"
        _uart_puts(okmsg)
        ret = a2
    elif nr == SYS_EXIT_NR:
        # exit(code): record the code and signal the launcher to halt.
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        exmsg: Ptr[char] = "[arm64] EL0 exit syscall serviced\n"
        _uart_puts(exmsg)
        ret = cast[uint64](0)
    else:
        unkmsg: Ptr[char] = "[arm64] EL0 unknown syscall\n"
        _uart_puts(unkmsg)
        ret = cast[uint64](0)

    # Stash the return value into the x0 slot so eret resumes EL0 with x0 set.
    frame_ptr[0] = ret

    # If EL0 asked to exit, don't return into it. Emit the Phase-4 single-task
    # PASS marker, then advance to Phase 6: run a deliberately-faulting EL0 task
    # and prove the kernel catches the abort + terminates the task. The Phase-6
    # handler in turn hands off to Phase 5 (preemptive scheduling). Each stage's
    # launcher erets to EL0 and never returns, so this exit-syscall service point
    # is the hand-off from Phase 4 -> 6 -> 5.
    if arm64_el0_exited != 0:
        if arm64_el0_exit_code == 0:
            passmsg: Ptr[char] = "[arm64] EL0 syscall OK\n"
            _uart_puts(passmsg)
        else:
            failmsg: Ptr[char] = "[arm64] EL0 exited nonzero\n"
            _uart_puts(failmsg)
        # Mask IRQs while we transition, then launch Phase 6 (never returns):
        # the faulting task aborts, is reaped, and Phase 6 advances to Phase 5.
        _msr_daifset(2)
        arm64_run_faulting_task()
        # Unreachable; safe halt if the launcher ever falls through.
        while True:
            _wfi()
    return 0


# ---------------------------------------------------------------------------
# Drop to EL0 and run the user routine. Programs SPSR_EL1 (EL0t + DAIF),
# ELR_EL1 (user entry), SP_EL0 (user stack), then `eret`. Control resumes at
# USER_CODE_BASE in EL0; the svc traps re-enter EL1 via arm64_sync_handler,
# which halts the test on exit() (so this function does not return).
# ---------------------------------------------------------------------------
def arm64_enter_el0() -> int64:
    usermsg: Ptr[char] = "Hello from EL0 via svc write\n"
    msg_len: uint64 = _copy_user_msg(usermsg)
    arm64_build_user_routine(msg_len)

    enter: Ptr[char] = "[arm64] dropping to EL0\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # target PSTATE: EL0t, IRQ/FIQ masked
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; never returns here
    return 0


# ---------------------------------------------------------------------------
# Phase 6 — EL0 page-fault path.
#
# A buggy or hostile EL0 task that dereferences an unmapped / EL1-only address
# must NOT wedge the kernel. The CPU takes a Data (or Instruction) Abort to the
# "Lower EL using AArch64" Synchronous vector — the SAME vector as `svc` — so
# arm64_sync_handler sees ESR_EL1.EC == 0x24 (data) or 0x20 (instruction).
# Instead of resuming EL0 into the offending instruction (which would re-fault
# forever) we read FAR_EL1 (the faulting VA) + ELR_EL1 (the EL0 PC), report
# them, mark the fault handled, and TERMINATE the task by transferring to the
# next schedulable workload (Phase 5) rather than ERET-ing back. This is the
# aarch64 analogue of delivering SIGSEGV and reaping the process.
# ---------------------------------------------------------------------------

# Materialise a deliberately-faulting EL0 routine into USER_CODE_BASE:
#   x1 = FAULT_VA (an EL1-only RAM address); ldr x0, [x1]  -> Data Abort.
# The load never completes; control traps to EL1 and never returns to this code.
def arm64_build_faulting_routine() -> int64:
    a: uint64 = USER_CODE_BASE
    a = _emit_load_imm64(a, cast[uint64](1), FAULT_VA)     # x1 = bad VA
    # ldr x0, [x1]  = 0xF9400020 (LDR (immediate, unsigned offset 0), Xt=x0,
    # Xn=x1). This load from an EL0-inaccessible page raises a Data Abort.
    a = _emit_word(a, cast[uint64](0xF9400020))
    # Should never be reached; emit a trap-shaped svc exit as a safety net so a
    # miraculous non-fault still terminates cleanly rather than running off.
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))            # svc #0
    _dsb_ish()
    _isb()
    return 0


# The page-fault handler proper. `is_instr` is 0 for a data abort, 1 for an
# instruction abort. Reports the faulting VA + EL0 PC, latches the handled flag,
# then terminates the task by launching Phase 5 (never returns to EL0). This is
# the deliberate design: a faulting EL0 task is reaped, the kernel survives.
def arm64_handle_el0_fault(esr: uint64, is_instr: uint64) -> int64:
    far: uint64 = cast[uint64](_mrs_far_el1())
    elr: uint64 = cast[uint64](_mrs_elr_el1())

    if is_instr != 0:
        k0: Ptr[char] = "[arm64] EL0 instruction abort\n"
        _uart_puts(k0)
    else:
        k1: Ptr[char] = "[arm64] EL0 data abort\n"
        _uart_puts(k1)

    famsg: Ptr[char] = "[arm64] fault VA (FAR_EL1)="
    _uart_puts(famsg)
    _uart_puthex(far)
    nl0: Ptr[char] = "\n"
    _uart_puts(nl0)

    pcmsg: Ptr[char] = "[arm64] fault PC (ELR_EL1)="
    _uart_puts(pcmsg)
    _uart_puthex(elr)
    nl1: Ptr[char] = "\n"
    _uart_puts(nl1)

    esrmsg: Ptr[char] = "[arm64] fault ESR_EL1="
    _uart_puts(esrmsg)
    _uart_puthex(esr)
    nl2: Ptr[char] = "\n"
    _uart_puts(nl2)

    arm64_fault_handled = 1

    term: Ptr[char] = "[arm64] EL0 task terminated; kernel survived\n"
    _uart_puts(term)

    pass_mark: Ptr[char] = "[arm64] EL0 page-fault OK\n"
    _uart_puts(pass_mark)

    # The faulting task is dead. Rather than ERET back into its faulting
    # instruction, hand off to Phase 7 (per-task TTBR0 address-space isolation),
    # which in turn hands off to Phase 5. Mask IRQs while we transition; neither
    # arm64_run_isolation_demo() nor the Phase-5 launcher it tails into returns.
    _msr_daifset(2)
    arm64_run_isolation_demo()
    # Unreachable safety halt.
    while True:
        _wfi()
    return 0


# Build the deliberately-faulting EL0 task and ERET into it. The abort it raises
# traps to arm64_sync_handler -> arm64_handle_el0_fault, which reports + reaps
# it and never returns here. This is the Phase-6 entry point, invoked from the
# Phase-4 exit hand-off so all three EL0 milestones run in one boot.
def arm64_run_faulting_task() -> int64:
    arm64_build_faulting_routine()

    enter: Ptr[char] = "[arm64] launching faulting EL0 task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC (the bad load)
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; faults immediately, never returns
    return 0


# ---------------------------------------------------------------------------
# Phase 7 — per-task TTBR0_EL1 ADDRESS-SPACE ISOLATION.
#
# Each EL0 task gets its OWN level-1 translation table root (TTBR0_EL1). Both
# tasks map the SAME virtual address (ISO_SHARED_VA) but to DIFFERENT physical
# pages carrying distinct sentinels. The kernel switches TTBR0_EL1 between the
# two tasks and performs the required TLB maintenance (tlbi vmalle1is + dsb +
# isb) on each switch. Each task loads the byte at ISO_SHARED_VA and reports it
# via a kernel-private syscall (nr 512). If isolation holds, task A reports its
# sentinel (0xAA) and task B reports its own (0xBB) — proving that the same VA
# resolves to private physical memory per task, i.e. tasks cannot read each
# other's memory.
#
# Both per-task tables clone the kernel's device + RAM identity map (so the EL0
# code window at USER_CODE_BASE stays fetchable and the kernel stays mapped),
# and additionally map ISO_SHARED_VA's 2 MiB L2 block EL0-RWX to the task's
# private physical block. The tables live in EL1-only RAM, so EL0 cannot tamper
# with them.
# ---------------------------------------------------------------------------

# Build one task-private address space at (l1_base, l2_base): a full clone of
# the kernel identity map plus an EL0-RWX mapping of ISO_SHARED_VA -> data_pa.
# Also writes `sentinel` into the first byte of the data block so the task can
# read it back. data_pa must be 2 MiB-aligned (it backs a block descriptor).
def arm64_iso_build_space(l1_base: uint64, l2_base: uint64, data_pa: uint64, sentinel: uint64) -> int64:
    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    # Zero the L1 table (everything unmapped faults).
    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1

    # L1[0] : VA 0x0..0x3FFF_FFFF -> Device-nGnRE (GIC + UART), EL1-only.
    l1[0] = cast[uint64](0) | DEV_FLAGS

    # L2 covering the RAM 1 GiB block in 2 MiB pieces, identity-mapped. Most
    # blocks are Normal-WB EL1-only; the EL0 code window (USER_L2_INDEX) is
    # EL0-RWX so the task's instruction page + stack remain reachable.
    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0          # EL0 code/stack window
        elif cast[uint64](j) == ISO_SHARED_L2_INDEX:
            # The shared VA block: EL0-RWX, but mapped to the TASK-PRIVATE
            # physical block (NOT identity) — this is the isolation linchpin.
            l2[j] = data_pa | MEM_FLAGS_EL0
        else:
            l2[j] = blk_pa | MEM_FLAGS              # kernel: EL1-only
        j = j + 1

    # L1[1] = table descriptor -> this task's L2 table.
    l1[1] = l2_base | DESC_TABLE

    # Seed the private data block with the task's sentinel (byte 0). The kernel
    # writes it through the identity (physical==virtual) mapping the BOOT TTBR0
    # still has live; data_pa is plain RAM mapped Normal-WB by L1_PGTABLE.
    dp: Ptr[uint8] = cast[Ptr[uint8]](data_pa)
    dp[0] = cast[uint8](sentinel & cast[uint64](0xFF))
    return 0


# Materialise the isolation EL0 routine into USER_CODE_BASE:
#   x1 = ISO_SHARED_VA; ldrb w0, [x1]   (read the per-task sentinel byte)
#   x8 = 512 (iso report); svc #0       (hand x0 back to the kernel)
# The svc never returns to EL0 (the kernel transitions away), so no exit needed.
def arm64_build_iso_routine() -> int64:
    a: uint64 = USER_CODE_BASE
    a = _emit_load_imm64(a, cast[uint64](1), ISO_SHARED_VA)     # x1 = shared VA
    # ldrb w0, [x1] = 0x39400020 (LDRB immediate, unsigned offset 0, Wt=0, Xn=1).
    a = _emit_word(a, cast[uint64](0x39400020))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_ISO_REPORT_NR)  # x8 = 512
    a = _emit_word(a, cast[uint64](0xD4000001))                 # svc #0
    # Safety net: if the report syscall ever returned, exit(0).
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                 # svc #0
    _dsb_ish()
    _isb()
    return 0


# Switch the live address space to (l1_base) and ERET into the isolation EL0
# routine at EL0t with IRQs masked (deterministic, no preemption). Performs the
# mandatory TLB maintenance after writing TTBR0_EL1 so stale translations for
# ISO_SHARED_VA from the previous task cannot leak across the switch.
def arm64_iso_enter(l1_base: uint64) -> int64:
    # Point TTBR0_EL1 at this task's private L1 table, then flush all stage-1
    # EL1&0 translations (inner-shareable) so the new mapping for ISO_SHARED_VA
    # takes effect. dsb before+after ordering the table/sysreg writes vs. the
    # invalidate vs. the subsequent fetch; isb to resynchronise the context.
    _dsb_ish()
    _msr_ttbr0_el1(l1_base)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC (the shared-VA reader)
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0 under this task's TTBR0
    return 0


# Called from the svc dispatcher when an isolation task reports the value it
# read at ISO_SHARED_VA. Latch the value for the live task, then either switch
# to task B (after task A) or, once both have reported, verify isolation held
# and hand off to Phase 5. Never returns to EL0.
def arm64_iso_on_report(value: uint64) -> int64:
    if arm64_iso_cur == 0:
        arm64_iso_reported_a = value
        ra: Ptr[char] = "[arm64] iso task A read VA value="
        _uart_puts(ra)
        _uart_puthex(value)
        nla: Ptr[char] = "\n"
        _uart_puts(nla)

        # Switch to task B's address space (same VA, different physical page).
        arm64_iso_cur = 1
        sw: Ptr[char] = "[arm64] iso switching TTBR0 to task B\n"
        _uart_puts(sw)
        arm64_iso_enter(ISO_B_L1)      # never returns; task B will report next
        while True:
            _wfi()

    arm64_iso_reported_b = value
    rb: Ptr[char] = "[arm64] iso task B read VA value="
    _uart_puts(rb)
    _uart_puthex(value)
    nlb: Ptr[char] = "\n"
    _uart_puts(nlb)

    # Both tasks reported. Isolation holds iff each read its OWN sentinel at the
    # SAME virtual address — proving distinct per-task physical memory.
    ok_a: int64 = 0
    if arm64_iso_reported_a == ISO_SENTINEL_A:
        ok_a = 1
    ok_b: int64 = 0
    if arm64_iso_reported_b == ISO_SENTINEL_B:
        ok_b = 1
    distinct: int64 = 0
    if arm64_iso_reported_a != arm64_iso_reported_b:
        distinct = 1

    if (ok_a != 0) and (ok_b != 0) and (distinct != 0):
        pm: Ptr[char] = "[arm64] EL0 TTBR0 isolation OK\n"
        _uart_puts(pm)
    else:
        fm: Ptr[char] = "[arm64] EL0 TTBR0 isolation FAIL\n"
        _uart_puts(fm)

    # The demo is done. Leave isolation mode, restore the kernel's identity-only
    # TTBR0 (the Phase-5 tasks run in the original L1_PGTABLE address space),
    # flush the TLB, and hand off to Phase 5 so its scheduler stays reachable.
    arm64_iso_active = 0
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    _msr_daifset(2)
    arm64_start_tasks()                # Phase 5; never returns
    while True:
        _wfi()
    return 0


# Phase-7 entry point (invoked from the Phase-6 fault hand-off). Build both
# task-private address spaces, the shared EL0 reader routine, then ERET into
# task A. The chain runs entirely from the svc "report" path:
#   enter A -> A reads its VA -> svc 512 -> switch TTBR0 -> enter B ->
#   B reads its VA -> svc 512 -> verify + PASS -> Phase 5.
def arm64_run_isolation_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 7: per-task TTBR0 isolation\n"
    _uart_puts(intro)

    # Build the two private address spaces and seed their sentinels.
    arm64_iso_build_space(ISO_A_L1, ISO_A_L2, ISO_A_DATA, ISO_SENTINEL_A)
    arm64_iso_build_space(ISO_B_L1, ISO_B_L2, ISO_B_DATA, ISO_SENTINEL_B)

    # Build the EL0 reader routine into the shared code window (identity-mapped
    # the same way in both task tables, so it is fetchable under either TTBR0).
    arm64_build_iso_routine()

    # Clear any Phase-4 exit latch and arm isolation mode so the svc dispatcher
    # routes the report syscall here.
    arm64_el0_exited = 0
    arm64_iso_active = 1
    arm64_iso_cur = 0

    sa: Ptr[char] = "[arm64] iso entering task A (TTBR0=A)\n"
    _uart_puts(sa)
    arm64_iso_enter(ISO_A_L1)          # -> EL0 task A; never returns here
    while True:
        _wfi()
    return 0


# ---------------------------------------------------------------------------
# Phase 5 — timer-driven PREEMPTIVE round-robin scheduling of two EL0 tasks.
#
# Two independent EL0 tasks each run an endless loop: write(1, marker, len) then
# spin in a short busy-loop. Neither ever yields or exits. The EL1 generic-timer
# IRQ fires periodically while a task runs; the "Lower EL using AArch64" IRQ
# vector (arm64_lower_irq_entry in vectors.S) saves the running task's FULL
# context (x0..x30 + SP_EL0 + ELR_EL1 + SPSR_EL1) into its context block, calls
# the Adder scheduler arm64_sched_pick() — which services the timer and swaps
# the current-task pointer to the OTHER task — and restores+erets into that
# task. Each task therefore makes forward progress only because the kernel
# preempts and round-robins it: a real EL0<->EL0 context switch on bare aarch64,
# orchestrated from Adder.
#
# The .S IRQ stub finds the running task's context block via the global
# `arm64_current_ctx`, which the scheduler keeps pointing at the live task.
# ---------------------------------------------------------------------------

# Two task code pages, message buffers and stacks — all inside the single EL0
# RWX 2 MiB window (0x4020_0000 .. 0x403F_FFFF) granted by the L2 map.
TASK0_CODE: uint64 = 0x40200000
TASK1_CODE: uint64 = 0x40210000
TASK0_MSG: uint64 = 0x40220000
TASK1_MSG: uint64 = 0x40221000
TASK0_STACK_TOP: uint64 = 0x40240000
TASK1_STACK_TOP: uint64 = 0x40250000

# Context blocks (34 x 8-byte slots: x0..x30, SP_EL0, ELR_EL1, SPSR_EL1). These
# live in EL1-only RAM (outside the EL0 window) so a buggy/hostile EL0 task can
# neither read nor scribble the saved scheduler state.
TASK0_CTX: uint64 = 0x40104000
TASK1_CTX: uint64 = 0x40105000

CTX_X0: uint64 = 0          # slot index of x0
CTX_SP_EL0: uint64 = 31
CTX_ELR: uint64 = 32
CTX_SPSR: uint64 = 33

# SPSR to ERET into EL0t with IRQs ENABLED (so the timer can preempt the task):
# mode EL0t (bits[3:0]=0), DAIF with only D|A|F masked and I (bit7) CLEAR.
# 0x340 = D|A|F masked, IRQ unmasked, EL0t.
SPSR_EL0T_IRQ: uint64 = 0x340

# Published to the .S IRQ stub: address of the context block of the task that is
# currently running at EL0. The scheduler swaps this on every tick.
arm64_current_ctx: uint64 = 0

# Round-robin bookkeeping: which task index is live, and how many preemptive
# switches we have performed. After SWITCH_LIMIT switches (proving BOTH tasks
# ran and were preempted multiple times) the scheduler prints PASS and halts.
arm64_cur_task: int64 = 0
arm64_switch_count: int64 = 0
SWITCH_LIMIT: int64 = 8


# Materialise a self-looping EL0 task into `code_base`:
#   loop:
#     x0 = 1; x1 = msg; x2 = len; x8 = 64 (write); svc #0
#     x9 = busy; busy:  subs x9,x9,#1; b.ne busy
#     b loop
# The task never exits; only the preemptive timer IRQ moves control away. We
# hand-emit the busy-loop and backward branch directly (the imm-builder already
# exists for the syscall argument setup).
def arm64_build_task(code_base: uint64, msg_base: uint64, msg_len: uint64) -> int64:
    a: uint64 = code_base
    loop_top: uint64 = a

    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))      # x0 = 1 (fd)
    a = _emit_load_imm64(a, cast[uint64](1), msg_base)             # x1 = msg ptr
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)             # x2 = len
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)        # x8 = 64 (write)
    a = _emit_word(a, cast[uint64](0xD4000001))                  # svc #0

    # x9 = 0x40000 busy-loop counter (movz x9, #0x4, lsl #16). hw=1 => lsl #16.
    movz_x9: uint64 = cast[uint64](0xD2800000) | (cast[uint64](1) << cast[uint64](21)) | (cast[uint64](4) << cast[uint64](5)) | cast[uint64](9)
    a = _emit_word(a, movz_x9)
    busy_top: uint64 = a
    # subs x9, x9, #1   = 0xF1000529
    a = _emit_word(a, cast[uint64](0xF1000529))
    # b.ne busy_top : 0x54000001 | (imm19 << 5); imm19 = (busy_top - here) / 4.
    bne_here: uint64 = a
    off_busy: int64 = cast[int64](busy_top) - cast[int64](bne_here)
    imm19_busy: uint64 = cast[uint64](off_busy >> 2) & cast[uint64](0x7FFFF)
    a = _emit_word(a, cast[uint64](0x54000001) | (imm19_busy << cast[uint64](5)))

    # b loop_top : 0x14000000 | imm26; imm26 = (loop_top - here) / 4.
    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# Copy a NUL-terminated string into an arbitrary EL0 buffer; return byte length.
def _copy_msg_to(s: Ptr[char], dst_base: uint64) -> uint64:
    src: Ptr[uint8] = cast[Ptr[uint8]](s)
    dst: Ptr[uint8] = cast[Ptr[uint8]](dst_base)
    i: int64 = 0
    while src[i] != 0:
        dst[i] = src[i]
        i = i + 1
    return cast[uint64](i)


# Initialise a task's context block so the very first ERET starts it cleanly at
# its code entry, on its own stack, in EL0t with IRQs unmasked.
def arm64_init_ctx(ctx_base: uint64, code_base: uint64, stack_top: uint64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](ctx_base)
    i: int64 = 0
    while i < 34:
        ctx[i] = cast[uint64](0)
        i = i + 1
    ctx[CTX_SP_EL0] = stack_top
    ctx[CTX_ELR] = code_base
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ
    return 0


# Scheduler — invoked from the EL0 IRQ vector (arm64_lower_irq_entry) with the
# running task's context block already fully saved. We ack/re-arm the timer,
# pick the OTHER task, publish it as current, and return its context block base
# so the stub restores+erets into it. After SWITCH_LIMIT preemptions the test
# has proven both tasks ran and were repeatedly preempted; print PASS and halt.
def arm64_sched_pick(cur_ctx: uint64) -> uint64:
    # Phase 27: when the two-task preemptive round-robin demo is live, feed
    # preemptions to its picker — each timer tick it SAVES nothing extra (the .S
    # stub already saved the full GPR/SP/ELR/SPSR context), round-robins to the
    # peer slot, swaps TTBR0+ASID into that task's private space, re-arms the
    # timer, and ERETs back into the next EL0 task. The two tasks each busy-loop
    # incrementing a counter in their OWN data page; only the timer moves control.
    # Phase 28: when the THREE-task blocking scheduler is live, feed preemptions
    # to its picker — each timer tick it WAKES any SLEEPING task whose deadline
    # passed (back to RUNNABLE), then round-robins ONLY the RUNNABLE tasks (it
    # SKIPS the SLEEPING ones), swapping TTBR0+ASID into the next runnable task's
    # private space. The blocking sleep itself is initiated by an EL0 svc.
    # Phase 29: when the task-exit + wait/reap demo is live, feed preemptions to
    # its picker — each tick it WAKES any SLEEPING task whose deadline passed,
    # REAPS any task that called exit (collecting its status into the per-task
    # exit_status slot, EXITED -> DEAD, never dispatched again), then round-robins
    # the RUNNABLE tasks (skipping SLEEPING and EXITED/DEAD), swapping TTBR0+ASID.
    if arm64_p29_active != 0:
        return arm64_p29_sched_pick(cur_ctx)

    # Phase 37: when the blocking-pipe IPC scheduler is live, feed preemptions to
    # its picker — each tick it REAPS any process that called exit (EXITED -> DEAD),
    # then round-robins the two processes, SKIPPING any process that is BLOCKED on
    # an empty pipe (a blocked reader is woken only by a peer's pipe_write, never the
    # timer), swapping TTBR0+ASID into the next runnable process's private space.
    if arm64_p37_active != 0:
        return arm64_p37_sched_pick(cur_ctx)

    # Phase 38: when the shared-memory IPC scheduler is live, feed preemptions to
    # its picker — each tick it REAPS any process that called exit (EXITED -> DEAD),
    # then round-robins the two processes, SKIPPING any process BLOCKED waiting on
    # the shm-ready flag (woken only by a peer's signal, never the timer), swapping
    # TTBR0+ASID into the next runnable process's private space.
    if arm64_p38_active != 0:
        return arm64_p38_sched_pick(cur_ctx)

    # Phase 39: when the futex thread-sync scheduler is live, feed preemptions to
    # its picker — each tick it REAPS any thread that called exit (EXITED -> DEAD),
    # then round-robins the two threads, SKIPPING any thread BLOCKED on the futex
    # wait-queue (woken only by a peer's futex_wake, never the timer). Both threads
    # share ONE TTBR0+ASID, so no address-space swap is needed between them.
    if arm64_p39_active != 0:
        return arm64_p39_sched_pick(cur_ctx)

    # Phase 43: when the blocking-pipe IPC scheduler is live, feed preemptions to its
    # picker — each tick it REAPS any task that called exit (EXITED -> DEAD), then
    # round-robins the two tasks, SKIPPING any task BLOCKED on the pipe (an empty-pipe
    # reader or a full-pipe writer, woken only by a peer pipe op, never the timer).
    # Both tasks share ONE TTBR0+ASID, so no address-space swap is needed.
    if arm64_p43_active != 0:
        return arm64_p43_sched_pick(cur_ctx)

    # Phase 44: when the EL0 signal-delivery scheduler is live, feed preemptions to its
    # picker — each timer tick ASYNCHRONOUSLY interrupts the running EL0 task. On the
    # chosen tick the picker DELIVERS the signal: it builds a real signal frame on the
    # task's EL0 stack from the just-saved interrupted context (all GP regs + PC + SP +
    # PSTATE), redirects the resume PC to the user handler with the signal number in x0,
    # and lowers SP past the frame. Other ticks simply resume the task unchanged. The
    # single task runs under ONE TTBR0+ASID, so no address-space swap is needed.
    if arm64_p44_active != 0:
        return arm64_p44_sched_pick(cur_ctx)

    if arm64_p28_active != 0:
        return arm64_p28_sched_pick(cur_ctx)

    if arm64_p27_active != 0:
        return arm64_p27_sched_pick(cur_ctx)

    # Phase 23: when the TLS scheduler is live, feed preemptions to its picker —
    # each tick it SAVES the outgoing thread's TPIDR_EL0 into its slot, round-
    # robins to the peer slot, swaps TTBR0+ASID, and RESTORES the incoming
    # thread's saved TPIDR_EL0 so each thread keeps its own thread pointer.
    if arm64_p23_active != 0:
        return arm64_p23_sched_pick(cur_ctx)

    # Phase 22: when the futex scheduler is live, feed preemptions to its picker —
    # each tick it auto-wakes any TIMER-blocked slot whose deadline passed (futex-
    # blocked slots are woken only by a peer FUTEX_WAKE, never the timer) and
    # round-robins only the RUNNABLE slots, swapping TTBR0+ASID.
    if arm64_p22_active != 0:
        return arm64_p22_sched_pick(cur_ctx)

    # Phase 21: when the blocking-nanosleep scheduler is live, feed preemptions to
    # its picker — on each tick it WAKES any BLOCKED slot whose CNTVCT_EL0 deadline
    # has passed (back to RUNNABLE) and round-robins only the RUNNABLE slots,
    # swapping TTBR0+ASID into the next runnable slot's private space.
    if arm64_p21_active != 0:
        return arm64_p21_sched_pick(cur_ctx)

    # Phase 19: when the dual-address-space scheduler is live, this same .S IRQ
    # stub feeds preemptions to the Phase-19 picker instead — it swaps TTBR0+ASID
    # (the private address space) in addition to the saved register context.
    if arm64_p19_active != 0:
        return arm64_p19_sched_pick(cur_ctx)

    # Phase 20: when the dynamic-spawn / exit-reaping scheduler is live, feed
    # preemptions to its picker — it skips REAPED (exited) tasks, swaps TTBR0+ASID
    # into the next RUNNABLE task's private space, and dynamically spawns a fresh
    # third task partway through.
    if arm64_p20_active != 0:
        return arm64_p20_sched_pick(cur_ctx)

    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this task
        return cur_ctx

    # Quiesce, re-arm, and EOI the timer.
    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_switch_count = arm64_switch_count + 1
    swmsg: Ptr[char] = "[arm64] preempt switch\n"
    _uart_puts(swmsg)

    if arm64_switch_count >= SWITCH_LIMIT:
        passmsg: Ptr[char] = "[arm64] EL0 preempt sched OK\n"
        _uart_puts(passmsg)
        # Mask IRQs (so the broader-syscall demo runs deterministically without
        # timer re-entry) and hand off to Phase 8: a single EL0 task exercising a
        # wider svc surface (getpid/gettid/yield/brk/clock/write/exit) dispatched
        # by x8. arm64_run_syscall_demo() does not return (its task's exit() halts
        # the boot), so Phase 5's PASS marker is the hand-off point to Phase 8.
        _msr_daifset(2)
        arm64_run_syscall_demo()
        # Unreachable safety halt.
        while True:
            _wfi()

    # Round-robin to the other task.
    next_ctx: uint64 = TASK1_CTX
    if arm64_cur_task == 0:
        arm64_cur_task = 1
        next_ctx = TASK1_CTX
    else:
        arm64_cur_task = 0
        next_ctx = TASK0_CTX

    arm64_current_ctx = next_ctx            # publish for the next preemption
    return next_ctx


# Build both tasks + context blocks, then ERET into task 0 with the timer live.
def arm64_start_tasks() -> int64:
    # Mask EL1 IRQs while we build the tasks so a stray current-EL timer IRQ
    # (left armed/unmasked by arm64_timer_init) cannot run the legacy handler
    # mid-setup. We re-enable just before ERETing into EL0.
    _msr_daifset(2)

    # Clear the Phase-4 single-task exit latch: the two Phase-5 tasks only ever
    # issue write() (nr 64) and must NOT re-enter the exit/hand-off path the svc
    # dispatcher keys off arm64_el0_exited.
    arm64_el0_exited = 0
    arm64_el0_exit_code = -1

    m0: Ptr[char] = "[task0] running on EL0\n"
    m1: Ptr[char] = "[task1] running on EL0\n"
    len0: uint64 = _copy_msg_to(m0, TASK0_MSG)
    len1: uint64 = _copy_msg_to(m1, TASK1_MSG)

    arm64_build_task(TASK0_CODE, TASK0_MSG, len0)
    arm64_build_task(TASK1_CODE, TASK1_MSG, len1)

    arm64_init_ctx(TASK0_CTX, TASK0_CODE, TASK0_STACK_TOP)
    arm64_init_ctx(TASK1_CTX, TASK1_CODE, TASK1_STACK_TOP)

    arm64_cur_task = 0
    arm64_current_ctx = TASK0_CTX

    enter: Ptr[char] = "[arm64] launching preemptive EL0 tasks\n"
    _uart_puts(enter)

    # Re-arm and enable the timer, unmask IRQs, then ERET into task 0 at EL0t
    # WITH IRQs unmasked (via its context SPSR) so the timer preempts it.
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](TASK0_CTX)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> task 0 at EL0; never returns here
    return 0


# ---------------------------------------------------------------------------
# Phase 8 — broader EL0 syscall surface dispatched by x8.
#
# A single EL0 task issues a sequence of syscalls mirroring the Linux aarch64
# ABI (number in x8, args x0..x5, return in x0):
#   getpid()                  -> the kernel-assigned PID (42)
#   gettid()                  -> the TID (== PID for our single thread)
#   sched_yield()             -> 0 (kernel acknowledges; resumes the same task)
#   clock read (CNTVCT) x2    -> the virtual counter; the kernel latches the
#                                first value and confirms the second ADVANCED
#                                (live, monotonic time visible to EL0)
#   brk(0)                    -> the current program break (queries it)
#   brk(BASE + 4 KiB)         -> moves the break and returns the new value (sbrk)
#   write(1, msg, len)        -> echoes a buffer to the UART, returns the length
#   exit(0)                   -> records the code and halts the boot
# The kernel services each call in arm64_sys_dispatch(), prints a per-call marker
# so the test can prove every syscall ran with a correct result, and on exit(0)
# prints the Phase-8 PASS marker.
# ---------------------------------------------------------------------------

# Phase 8 EL0 message buffer (inside the EL0 RWX window, clear of the code page
# at USER_CODE_BASE and the heap window at SYS_HEAP_BASE).
SYS_MSG_BASE: uint64 = 0x40222000


# Materialise the Phase-8 EL0 routine into USER_CODE_BASE. It issues the syscall
# sequence above. Every syscall but write needs no register args beyond x8 (or a
# single x0 for brk), so we reuse the imm-builder for x8/x0 and emit `svc #0`.
def arm64_build_syscall_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE

    # getpid(): x8 = 172; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_GETPID_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # gettid(): x8 = 178; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_GETTID_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # sched_yield(): x8 = 124; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_YIELD_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # clock read #1: x8 = 513; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_CLOCK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # clock read #2: x8 = 513; svc #0  (kernel confirms it advanced)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_CLOCK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # brk(0): x0 = 0; x8 = 214; svc #0  (query current break)
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_BRK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # brk(SYS_HEAP_GROW): x0 = new break; x8 = 214; svc #0  (grow the heap)
    a = _emit_load_imm64(a, cast[uint64](0), SYS_HEAP_GROW)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_BRK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 64; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), SYS_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # exit(0): x0 = 0; x8 = 93; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-8 syscall dispatcher. Called from arm64_sync_handler while the broader-
# surface demo is live, with `frame_ptr` -> the saved x0..x30 frame, `nr` the
# syscall number (x8) and a0..a2 the first three args. Services the call, writes
# the return value into the x0 frame slot, and returns 0 so the common eret path
# resumes EL0 — except exit(), which halts the boot after the PASS marker.
def arm64_sys_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    arm64_sys_calls = arm64_sys_calls + 1
    ret: uint64 = cast[uint64](0)

    if nr == SYS_GETPID_NR:
        ret = arm64_sys_pid
        m: Ptr[char] = "[arm64] EL0 getpid -> "
        _uart_puts(m)
        _uart_puthex(ret)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        frame_ptr[0] = ret
        return 0

    if nr == SYS_GETTID_NR:
        # Single-threaded task: TID == PID.
        ret = arm64_sys_pid
        m: Ptr[char] = "[arm64] EL0 gettid -> "
        _uart_puts(m)
        _uart_puthex(ret)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        frame_ptr[0] = ret
        return 0

    if nr == SYS_YIELD_NR:
        # Voluntary yield: the kernel acknowledges and resumes the same task
        # (there is only one Phase-8 task). Return 0 like Linux sched_yield.
        m: Ptr[char] = "[arm64] EL0 sched_yield serviced\n"
        _uart_puts(m)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_CLOCK_NR:
        # Read the always-incrementing virtual counter. Latch the first value;
        # on a later read, confirm it strictly advanced (live monotonic clock).
        now: uint64 = cast[uint64](_mrs_cntvct_el0())
        if arm64_sys_clock_seen == 0:
            arm64_sys_clock_first = now
            arm64_sys_clock_seen = 1
            m0: Ptr[char] = "[arm64] EL0 clock read #1 -> "
            _uart_puts(m0)
            _uart_puthex(now)
            nl0: Ptr[char] = "\n"
            _uart_puts(nl0)
        else:
            m1: Ptr[char] = "[arm64] EL0 clock read #2 -> "
            _uart_puts(m1)
            _uart_puthex(now)
            nl1: Ptr[char] = "\n"
            _uart_puts(nl1)
            if now > arm64_sys_clock_first:
                adv: Ptr[char] = "[arm64] EL0 clock advanced OK\n"
                _uart_puts(adv)
            else:
                bad: Ptr[char] = "[arm64] EL0 clock did NOT advance FAIL\n"
                _uart_puts(bad)
        frame_ptr[0] = now
        return 0

    if nr == SYS_BRK_NR:
        # brk(new): if a0 == 0, query the current break. Otherwise move it,
        # clamped to [SYS_HEAP_BASE, SYS_HEAP_END]; return the resulting break.
        if a0 == cast[uint64](0):
            m: Ptr[char] = "[arm64] EL0 brk query -> "
            _uart_puts(m)
            _uart_puthex(arm64_sys_brk)
            nl: Ptr[char] = "\n"
            _uart_puts(nl)
            frame_ptr[0] = arm64_sys_brk
            return 0
        if (a0 >= SYS_HEAP_BASE) and (a0 <= SYS_HEAP_END):
            arm64_sys_brk = a0
        # Out-of-range requests leave the break unchanged (Linux brk returns the
        # current break on failure rather than erroring).
        m2: Ptr[char] = "[arm64] EL0 brk set -> "
        _uart_puts(m2)
        _uart_puthex(arm64_sys_brk)
        nl2: Ptr[char] = "\n"
        _uart_puts(nl2)
        frame_ptr[0] = arm64_sys_brk
        return 0

    if nr == SYS_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        m: Ptr[char] = "[arm64] EL0 write syscall serviced\n"
        _uart_puts(m)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_EXIT_NR:
        # Record the exit code; if the whole sequence ran cleanly, print PASS.
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit syscall serviced\n"
        _uart_puts(em)
        if a0 == cast[uint64](0):
            pm: Ptr[char] = "[arm64] EL0 syscall surface OK\n"
            _uart_puts(pm)
            # Phase 8 complete and clean: leave Phase-8 mode and hand off to
            # Phase 9 (page-table-backed brk growth). The launcher erets into the
            # Phase-9 EL0 task and never returns (its exit() halts the boot), so
            # this is the Phase 8 -> 9 hand-off point.
            arm64_sys_active = 0
            _msr_daifset(2)
            arm64_run_brk_demo()
            # Unreachable safety halt if the Phase-9 launcher ever falls through.
            while True:
                _wfi()
        else:
            fm: Ptr[char] = "[arm64] EL0 syscall surface exited nonzero\n"
            _uart_puts(fm)
        # Nonzero exit: leave Phase-8 mode and halt deterministically.
        arm64_sys_active = 0
        _msr_daifset(2)
        while True:
            _wfi()

    # Unknown syscall under the Phase-8 surface.
    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 8)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-8 entry point (invoked from the Phase-5 sched PASS hand-off). Seed the
# PID + program break, build the EL0 routine and its message, arm Phase-8 mode,
# and ERET into the single multi-syscall EL0 task at EL0t with IRQs masked
# (deterministic; the demo never needs preemption). Never returns here.
def arm64_run_syscall_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 8: broader EL0 syscall surface\n"
    _uart_puts(intro)

    # Seed kernel-tracked per-task state for the demo.
    arm64_sys_pid = SYS_DEMO_PID
    arm64_sys_brk = SYS_HEAP_BASE
    arm64_sys_clock_first = cast[uint64](0)
    arm64_sys_clock_seen = 0
    arm64_sys_calls = 0

    # Restore the kernel's identity-only TTBR0 (Phase 7 may have left a per-task
    # root live) so the EL0 code/heap windows resolve through L1_PGTABLE, then
    # flush the TLB so no stale isolation translation lingers.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Build the EL0 routine + its write() message.
    sysmsg: Ptr[char] = "Hello from the EL0 syscall surface\n"
    msg_len: uint64 = _copy_msg_to(sysmsg, SYS_MSG_BASE)
    arm64_build_syscall_routine(msg_len)

    # Clear the Phase-4/5 exit latch and arm Phase-8 dispatch.
    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_sys_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 syscall-surface task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; svc traps re-enter EL1; no return
    return 0


# ---------------------------------------------------------------------------
# Phase 9 — PAGE-TABLE-BACKED brk growth over TTBR0_EL1.
#
# The EL0 task's heap lives at P9_HEAP_BASE, whose L2 slot (index 6) is UNMAPPED
# at boot. brk(0) queries the break; brk(P9_HEAP_GROW) asks the kernel to grow it
# by one page. On grow the kernel ACTUALLY MAPS a fresh physical page into the
# live TTBR0 tables (arm64_brk_map_page) before returning, so the subsequent EL0
# store to the grown VA succeeds. The task writes P9_SENTINEL through the new
# mapping, reads it back, and reports the value via a kernel-private syscall; the
# kernel verifies both the reported value AND the backing physical page hold the
# sentinel, then prints the Phase-9 PASS marker on exit(0).
# ---------------------------------------------------------------------------

# Map one fresh 4 KiB physical page (P9_PAGE) at the heap virtual base into the
# live TTBR0_EL1 tables, EL0 read/write. Installs an L3 page descriptor into a
# new L3 table (P9_L3) and the L2->L3 table descriptor into the existing RAM L2
# table (L2_PGTABLE) at the heap's L2 slot, with break-before-make + TLB
# maintenance so the new translation is visible to EL0. Returns the mapped VA.
def arm64_brk_map_page() -> uint64:
    # Zero the brand-new L3 table so every unmapped slot faults.
    l3: Ptr[uint64] = cast[Ptr[uint64]](P9_L3)
    i: int64 = 0
    while i < 512:
        l3[i] = cast[uint64](0)
        i = i + 1

    # Zero the backing physical page (a fresh page must start clean).
    pg: Ptr[uint64] = cast[Ptr[uint64]](P9_PAGE)
    j: int64 = 0
    while j < 512:
        pg[j] = cast[uint64](0)
        j = j + 1

    # L3 index of P9_HEAP_BASE = VA[20:12]. For 0x40C0_0000 this is 0.
    l3_index: uint64 = (P9_HEAP_BASE >> cast[uint64](12)) & cast[uint64](0x1FF)
    # Install the EL0-RW page descriptor (bits[1:0]=0b11 => level-3 page).
    l3[cast[int64](l3_index)] = P9_PAGE | P9_PAGE_FLAGS

    # Make the L3 writes visible before the table descriptor that exposes them.
    _dsb_ish()

    # Point the heap's L2 slot at the new L3 table (table descriptor 0b11).
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P9_HEAP_L2_INDEX)] = P9_L3 | DESC_TABLE

    # Publish the table edits and flush stale (faulting) translations for the VA.
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    arm64_brk_mapped = 1
    return P9_HEAP_BASE


# Materialise the Phase-9 EL0 routine into USER_CODE_BASE:
#   brk(0)            -> query the initial (unmapped) break
#   brk(P9_HEAP_GROW) -> ask the kernel to grow + map a fresh page
#   str sentinel -> [P9_HEAP_BASE]   (succeeds only because the page is now mapped)
#   ldr x9 <- [P9_HEAP_BASE]         (read it back)
#   brk_report(x9)    -> hand the read-back value to the kernel to verify
#   write(1, msg, len)
#   exit(0)
# We hand-emit the str/ldr (x10 = VA, x9 = value) around the reused imm-builder.
def arm64_build_brk_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE

    # brk(0): x0 = 0; x8 = 214; svc #0  (query current break)
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_BRK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # brk(P9_HEAP_GROW): x0 = new break; x8 = 214; svc #0  (grow + map a page)
    a = _emit_load_imm64(a, cast[uint64](0), P9_HEAP_GROW)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_BRK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x10 = P9_HEAP_BASE (the freshly-mapped VA); x9 = P9_SENTINEL.
    a = _emit_load_imm64(a, cast[uint64](10), P9_HEAP_BASE)
    a = _emit_load_imm64(a, cast[uint64](9), P9_SENTINEL)
    # str x9, [x10]   (STR Xt, [Xn]) = 0xF9000000 | (Rn<<5) | Rt
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # Re-zero x9 so the read-back can't trivially pass on a stale register, then
    # ldr x9, [x10]   (LDR Xt, [Xn]) = 0xF9400000 | (Rn<<5) | Rt
    a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # brk_report(x9): x0 = x9; x8 = 514; svc #0. Move x9 -> x0 (ORR x0, xzr, x9):
    # 0xAA0003E0 | (Rm<<16) => 0xAA0903E0 for Rm=9.
    a = _emit_word(a, cast[uint64](0xAA0003E0) | (cast[uint64](9) << cast[uint64](16)))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_BRK_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 64; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), P9_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # exit(0): x0 = 0; x8 = 93; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-9 syscall dispatcher. Routed from arm64_sync_handler while the brk demo
# is live. Services brk (query + page-table-backed grow), the kernel-private brk
# report, write and exit. Writes returns into the x0 frame slot; exit halts.
def arm64_brk_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_BRK_NR:
        if a0 == cast[uint64](0):
            m: Ptr[char] = "[arm64] EL0 brk(9) query -> "
            _uart_puts(m)
            _uart_puthex(arm64_brk_cur)
            nl: Ptr[char] = "\n"
            _uart_puts(nl)
            frame_ptr[0] = arm64_brk_cur
            return 0
        # Grow request: only accept the one-page grow to P9_HEAP_GROW, and map a
        # fresh physical page into the live tables BEFORE returning the new break.
        if a0 == P9_HEAP_GROW:
            arm64_brk_map_page()
            arm64_brk_cur = a0
            gm: Ptr[char] = "[arm64] EL0 brk(9) grow mapped page at "
            _uart_puts(gm)
            _uart_puthex(P9_HEAP_BASE)
            nlg: Ptr[char] = "\n"
            _uart_puts(nlg)
        frame_ptr[0] = arm64_brk_cur
        return 0

    if nr == SYS_BRK_REPORT_NR:
        # The EL0 task read back its sentinel through the freshly-mapped page.
        arm64_brk_reported = a0
        rm: Ptr[char] = "[arm64] EL0 brk page read-back -> "
        _uart_puts(rm)
        _uart_puthex(a0)
        nlr: Ptr[char] = "\n"
        _uart_puts(nlr)
        # Independently confirm the BACKING PHYSICAL page holds the sentinel, so
        # the new translation truly reached P9_PAGE (not some stale aliasing).
        backing: Ptr[uint64] = cast[Ptr[uint64]](P9_PAGE)
        phys_val: uint64 = backing[0]
        pm: Ptr[char] = "[arm64] brk backing phys page holds -> "
        _uart_puts(pm)
        _uart_puthex(phys_val)
        nlp: Ptr[char] = "\n"
        _uart_puts(nlp)
        if (a0 == P9_SENTINEL) and (phys_val == P9_SENTINEL) and (arm64_brk_mapped != 0):
            ok: Ptr[char] = "[arm64] EL0 brk-mapped page store/load OK\n"
            _uart_puts(ok)
        else:
            bad: Ptr[char] = "[arm64] EL0 brk-mapped page store/load FAIL\n"
            _uart_puts(bad)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(9) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_EXIT_NR:
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit(9) syscall serviced\n"
        _uart_puts(em)
        # The whole Phase-9 sequence completes cleanly iff exit(0) AND the page
        # was mapped AND the read-back matched the sentinel.
        ok: int64 = 0
        if a0 == cast[uint64](0):
            if arm64_brk_mapped != 0:
                if arm64_brk_reported == P9_SENTINEL:
                    ok = 1
        if ok != 0:
            pm: Ptr[char] = "[arm64] EL0 page-table brk OK\n"
            _uart_puts(pm)
        else:
            fm: Ptr[char] = "[arm64] EL0 page-table brk FAIL\n"
            _uart_puts(fm)
        arm64_brk_active = 0
        # Phase 9 done; hand off to Phase 10 SMP secondary-core bring-up. The
        # IRQs stay masked (deterministic, no timer re-entry); arm64_run_smp()
        # halts after printing the SMP PASS marker and never returns.
        _msr_daifset(2)
        arm64_run_smp()
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 9)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-9 entry point (invoked from the Phase-8 clean-exit hand-off). Seed the
# program break to the UNMAPPED heap base, restore the kernel's identity TTBR0,
# build the EL0 routine + message, arm Phase-9 dispatch and ERET into the brk
# task at EL0t with IRQs masked. Never returns (the task's exit() halts).
def arm64_run_brk_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 9: page-table-backed brk growth\n"
    _uart_puts(intro)

    # Seed Phase-9 state. The break starts at the UNMAPPED heap base.
    arm64_brk_cur = P9_HEAP_BASE
    arm64_brk_mapped = 0
    arm64_brk_reported = cast[uint64](0)

    # Restore the kernel's identity-only TTBR0 so the EL0 code/stack windows and
    # the page-table edits resolve through L1_PGTABLE / L2_PGTABLE, then flush.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Ensure the heap's L2 slot is UNMAPPED at the start (so a store there would
    # fault until brk-grow installs the page) — a clean, repeatable initial state.
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P9_HEAP_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Build the EL0 routine + its write() message.
    brkmsg: Ptr[char] = "Hello from the brk-mapped EL0 page\n"
    msg_len: uint64 = _copy_msg_to(brkmsg, P9_MSG_BASE)
    arm64_build_brk_routine(msg_len)

    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_brk_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 page-table brk task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; svc traps re-enter EL1; no return
    return 0


# ---------------------------------------------------------------------------
# Phase 10 — SMP secondary-core bring-up via PSCI.
# ---------------------------------------------------------------------------

# The Adder body the secondary core runs once the trampoline has given it a
# stack. It executes MMU-OFF at EL1 on CPU1: with the identity map, the kernel's
# code/globals/MMIO all resolve at their physical == virtual addresses, so plain
# Adder (GIC pokes, shared-cell stores) works directly. The secondary enables
# its OWN GIC CPU interface (the GICC registers are banked per core but share
# one MMIO address), records that it entered, publishes a sentinel to the shared
# cell with a dmb ish so the primary observes it, then increments the online
# counter. It deliberately does NOT touch the UART (no cross-core interleave);
# the primary prints all markers. After signalling liveness it parks forever.
def arm64_secondary_mmu_on() -> int64:
    # Phase 12: enable the secondary core's MMU using the page tables the primary
    # already built (L1_PGTABLE / L2_PGTABLE). We do NOT rewrite the tables — only
    # program this core's translation sysregs and flip on SCTLR_EL1.{M,C,I}. After
    # this the secondary sees RAM as Cacheable Inner-Shareable Normal memory,
    # matching the primary, so cross-core ldaxr/stlxr exclusives are coherent.
    _msr_mair_el1(cast[uint64](0xff04))
    _msr_tcr_el1(cast[uint64](0x100003519))
    _msr_ttbr0_el1(L1_PGTABLE)
    _msr_ttbr1_el1(cast[uint64](0))
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    sctlr: uint64 = cast[uint64](_mrs_sctlr_el1())
    sctlr = sctlr | cast[uint64](0x1)      # M (MMU)
    sctlr = sctlr | cast[uint64](0x4)      # C (data cache)
    sctlr = sctlr | cast[uint64](0x1000)   # I (instruction cache)
    _msr_sctlr_el1(sctlr)
    _isb()
    return 0


def arm64_secondary_main() -> int64:
    # Record entry into the Adder body (the primary reports this for us).
    entered: Ptr[uint64] = cast[Ptr[uint64]](SMP_ENTERED)
    entered[0] = cast[uint64](1)
    _dmb_ish()

    # Enable this core's GIC CPU interface so it could take IRQs (SGIs/PPIs).
    # GICC is banked per-core: writing these MMIO offsets configures CPU1's own
    # interface, independent of the primary's.
    gicc_pmr: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_PMR)
    gicc_pmr[0] = 0xF0                             # allow all priorities
    gicc_ctlr: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_CTLR)
    gicc_ctlr[0] = 1                               # enable signalling

    # Publish the cross-core sentinel FIRST, then a dmb ish to order it before
    # the online-counter store the primary waits on (so once the primary sees
    # the counter reach 2, the sentinel is guaranteed already visible).
    sentinel: Ptr[uint64] = cast[Ptr[uint64]](SMP_SENTINEL)
    sentinel[0] = SMP_SENTINEL_VALUE
    _dmb_ish()

    # Increment the online-CPU counter so the primary observes a real second
    # core reporting live. The secondary is the SOLE writer after the primary
    # seeds the cell to 1 (the primary only reads it), so an ordered read-add-
    # write under dmb ish is a correct increment here: read the seeded value,
    # add one, publish it. The dmb ish barriers (here and the sentinel store
    # above) give the primary a guaranteed coherent view once it sees the count.
    online: Ptr[uint64] = cast[Ptr[uint64]](SMP_ONLINE)
    _dmb_ish()
    cur: uint64 = online[0]
    online[0] = cur + cast[uint64](1)
    _dmb_ish()

    # Liveness signalled. Wake any core spinning in wfe.
    _sev()

    # Phase 12: enable THIS core's MMU using the primary's already-built page
    # tables BEFORE doing any ldaxr/stlxr work. The exclusive monitor used by the
    # spinlock requires the lock word to be Cacheable Inner-Shareable Normal
    # memory on every observer; with the MMU off the secondary would treat it as
    # non-cacheable and the global monitor would not be reliable across cores.
    # Turning the secondary's MMU on (same tables as the primary) makes both cores
    # see identical, inner-shareable cacheable attributes, so ldaxr/stlxr work.
    arm64_secondary_mmu_on()

    # Now the secondary runs REAL scheduler work.
    # Wait until the primary publishes the "go" flag (so both cores start the
    # contended loop together), then run SMP_ITERS locked increments against the
    # shared counter — concurrently with CPU0 doing the same. Re-read the go cell
    # through a dmb ish each spin so we observe the primary's publish.
    go: Ptr[uint64] = cast[Ptr[uint64]](SMP_GO)
    while True:
        _dmb_ish()
        if go[0] != cast[uint64](0):
            break
        _wfe()

    # Stamp our own MPIDR Aff0 (1 on CPU1) under the lock, proving this core ran
    # inside the critical section, then run the contended increments.
    arm64_smp_worker(cast[uint64](1))

    # Signal completion, wake the primary, then park forever.
    done: Ptr[uint64] = cast[Ptr[uint64]](SMP_CPU1_DONE)
    _dmb_ish()
    done[0] = cast[uint64](1)
    _dmb_ish()
    _sev()
    while True:
        _wfe()
    return 0


# Phase 12: the contended scheduler-work body run by BOTH cores. `core_id` is the
# running core's MPIDR Aff0 (0 on the primary, 1 on the secondary). Each call
# performs SMP_ITERS iterations of: acquire the shared spinlock (ldaxr/stlxr,
# acquire), read-modify-write the SHARED counter, stamp the touch cell with this
# core's id, release the lock (stlr, release). The acquire/release pair makes the
# read-add-write atomic across cores, so no increment is lost; the final counter
# (2*SMP_ITERS once both cores finish) is only correct if the lock truly held.
def arm64_smp_worker(core_id: uint64) -> int64:
    counter: Ptr[uint64] = cast[Ptr[uint64]](SMP_SHARED_COUNT)
    touched: Ptr[uint64] = cast[Ptr[uint64]](SMP_CPU1_TOUCHED)
    i: uint64 = 0
    while i < SMP_ITERS:
        _spin_lock(SMP_LOCK)
        # ---- critical section: only one core here at a time ----
        cur: uint64 = counter[0]
        counter[0] = cur + cast[uint64](1)
        # Stamp the touch cell so the primary can prove the secondary entered the
        # critical section at least once (CPU1's id is 1; CPU0 leaves it alone so
        # any nonzero value can only have come from the secondary).
        if core_id != cast[uint64](0):
            touched[0] = core_id
        _spin_unlock(SMP_LOCK)
        i = i + cast[uint64](1)
    return 0


# Hand-emit the secondary entry trampoline into SMP_TRAMPOLINE. The secondary is
# released by PSCI CPU_ON with MMU off, SP undefined, at EL1; this blob sets SP
# to the dedicated secondary stack top and branches to arm64_secondary_main().
# We bake the function's address in as an immediate: with the identity map a
# kernel function's virtual address equals its physical address, so the baked
# value is a valid MMU-off branch target. (We pass arm64_secondary_main (as a value) in so
# the primary supplies the runtime address.)
def arm64_build_smp_trampoline(secondary_entry: uint64) -> int64:
    a: uint64 = SMP_TRAMPOLINE

    # x9 = SMP_CPU1_STACK_TOP ; mov sp, x9   (ADD sp, x9, #0 = 0x91000000 | (Rn<<5) | 31)
    a = _emit_load_imm64(a, cast[uint64](9), SMP_CPU1_STACK_TOP)
    a = _emit_word(a, cast[uint64](0x91000000) | (cast[uint64](9) << cast[uint64](5)) | cast[uint64](31))

    # x9 = arm64_secondary_main (as a value) ; br x9   (BR Xn = 0xD61F0000 | (Rn<<5))
    a = _emit_load_imm64(a, cast[uint64](9), secondary_entry)
    a = _emit_word(a, cast[uint64](0xD61F0000) | (cast[uint64](9) << cast[uint64](5)))

    # Make the freshly-written instruction words visible to all cores' I-side.
    _dsb_ish()
    _isb()
    return 0


# Phase-10 entry point (invoked from the Phase-9 clean-exit hand-off). Build the
# secondary trampoline, seed the shared cells, issue PSCI CPU_ON to release CPU1,
# then spin (with barriers) until the secondary reports online and its sentinel
# appears — proving real cross-core progress. Prints explicit markers and halts.
def arm64_run_smp() -> int64:
    intro: Ptr[char] = "[arm64] Phase 10: SMP secondary-core bring-up via PSCI\n"
    _uart_puts(intro)

    # Seed the shared cells: this (primary) core counts as 1 online; clear the
    # sentinel + entered flag so their later appearance unambiguously comes from
    # the secondary.
    online: Ptr[uint64] = cast[Ptr[uint64]](SMP_ONLINE)
    sentinel: Ptr[uint64] = cast[Ptr[uint64]](SMP_SENTINEL)
    entered: Ptr[uint64] = cast[Ptr[uint64]](SMP_ENTERED)
    online[0] = cast[uint64](1)
    sentinel[0] = cast[uint64](0)
    entered[0] = cast[uint64](0)
    _dsb_ish()

    # Build the trampoline the secondary will enter at (PSCI entry = its phys
    # address). Pass the Adder body's address as the baked branch target.
    arm64_build_smp_trampoline(cast[uint64](arm64_secondary_main))

    # Release CPU1 via PSCI CPU_ON. ctx (x3) is passed to the secondary in x0;
    # the trampoline ignores it, so 0 is fine.
    status: uint64 = _psci_cpu_on(PSCI_FN_CPU_ON, SMP_CPU1_MPIDR, SMP_TRAMPOLINE, cast[uint64](0))
    if status != PSCI_SUCCESS:
        fm: Ptr[char] = "[arm64] PSCI CPU_ON FAILED status="
        _uart_puts(fm)
        _uart_puthex(status)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        bad: Ptr[char] = "[arm64] SMP bring-up FAIL\n"
        _uart_puts(bad)
        while True:
            _wfi()

    okmsg: Ptr[char] = "[arm64] PSCI CPU_ON issued\n"
    _uart_puts(okmsg)

    # Spin waiting for the secondary to report online. Re-read the shared cells
    # through a dmb ish each iteration so we observe CPU1's publishes. Bound the
    # wait with a large spin budget so a wedged secondary fails loudly instead of
    # hanging the whole test.
    spins: int64 = 0
    seen_online: int64 = 0
    while spins < 200000000:
        _dmb_ish()
        cur: uint64 = online[0]
        if cur >= cast[uint64](2):
            seen_online = 1
            break
        spins = spins + 1

    if seen_online == 0:
        to: Ptr[char] = "[arm64] secondary did not come online (timeout)\n"
        _uart_puts(to)
        bad2: Ptr[char] = "[arm64] SMP bring-up FAIL\n"
        _uart_puts(bad2)
        while True:
            _wfi()

    # The counter reached 2 -> CPU1 is live. Read the entered flag + cross-core
    # sentinel it published (both ordered before the counter store by the
    # secondary's dmb ish barriers). The primary prints these on the secondary's
    # behalf so no UART output ever interleaves across the two cores.
    _dmb_ish()
    obs: uint64 = sentinel[0]
    ent: uint64 = entered[0]

    if ent != cast[uint64](0):
        em: Ptr[char] = "[arm64] secondary core entered\n"
        _uart_puts(em)

    c1msg: Ptr[char] = "[arm64] CPU1 online\n"
    _uart_puts(c1msg)
    smsg: Ptr[char] = "[arm64] CPU1 sentinel -> "
    _uart_puts(smsg)
    _uart_puthex(obs)
    nl2: Ptr[char] = "\n"
    _uart_puts(nl2)

    if obs == SMP_SENTINEL_VALUE:
        pm: Ptr[char] = "[arm64] SMP bring-up OK\n"
        _uart_puts(pm)
    else:
        bad3: Ptr[char] = "[arm64] SMP bring-up FAIL\n"
        _uart_puts(bad3)

    # Phase 10 complete: CPU1 is live. Hand off to Phase 12 (secondary-core
    # scheduling under a real spinlock). The secondary is NOT parked yet — it is
    # spinning on the Phase-12 "go" flag — so the primary drives the contended
    # demo, then hands off to Phase 11. arm64_run_smp_sched() never returns.
    arm64_run_smp_sched()
    while True:
        _wfi()
    return 0


# ---------------------------------------------------------------------------
# Phase 12 — SECONDARY-CORE SCHEDULING under a cache-coherent spinlock.
#
# Phase 10 proved CPU1 is alive but then parked it. Phase 12 puts it to WORK: the
# primary releases both cores into a contended loop where each performs SMP_ITERS
# increments of a SHARED counter, every increment guarded by one spinlock taken
# with ldaxr/stlxr (acquire) and freed with stlr (release). If both cores ran and
# the lock held, the final counter is exactly 2*SMP_ITERS — a deterministic total
# that is WRONG if either core failed to run or the lock dropped an update. The
# primary also checks that CPU1 stamped its id inside a critical section, proving
# the second core genuinely entered the lock. Only the primary touches the UART.
# ---------------------------------------------------------------------------
def arm64_run_smp_sched() -> int64:
    intro: Ptr[char] = "[arm64] Phase 12: secondary-core scheduling under a spinlock\n"
    _uart_puts(intro)

    # Seed the Phase-12 shared cells. Lock free, counter zero, both done flags
    # clear, touch cell clear. The go flag stays 0 until both sides are armed.
    lock: Ptr[uint64] = cast[Ptr[uint64]](SMP_LOCK)
    counter: Ptr[uint64] = cast[Ptr[uint64]](SMP_SHARED_COUNT)
    go: Ptr[uint64] = cast[Ptr[uint64]](SMP_GO)
    cpu0_done: Ptr[uint64] = cast[Ptr[uint64]](SMP_CPU0_DONE)
    cpu1_done: Ptr[uint64] = cast[Ptr[uint64]](SMP_CPU1_DONE)
    touched: Ptr[uint64] = cast[Ptr[uint64]](SMP_CPU1_TOUCHED)
    lock[0] = cast[uint64](0)
    counter[0] = cast[uint64](0)
    cpu0_done[0] = cast[uint64](0)
    cpu1_done[0] = cast[uint64](0)
    touched[0] = cast[uint64](0)
    _dsb_ish()

    # Release both cores into the contended loop together. The secondary is
    # spinning on this cell (with dmb ish); publish it and sev to wake its wfe.
    go[0] = cast[uint64](1)
    _dsb_ish()
    _sev()

    # The primary runs its OWN share of the work (core_id 0) contending with CPU1.
    arm64_smp_worker(cast[uint64](0))
    _dmb_ish()
    cpu0_done[0] = cast[uint64](1)
    _dmb_ish()
    _sev()

    # Wait for the secondary to finish its share. Bound the wait so a wedged core
    # fails loudly instead of hanging.
    spins: int64 = 0
    seen_done: int64 = 0
    while spins < 200000000:
        _dmb_ish()
        if cpu1_done[0] != cast[uint64](0):
            seen_done = 1
            break
        spins = spins + 1

    nl: Ptr[char] = "\n"

    if seen_done == 0:
        to: Ptr[char] = "[arm64] secondary did not finish its work (timeout)\n"
        _uart_puts(to)
        bad: Ptr[char] = "[arm64] SMP scheduling FAIL\n"
        _uart_puts(bad)
        while True:
            _wfi()

    bothmsg: Ptr[char] = "[arm64] both cores finished\n"
    _uart_puts(bothmsg)

    # Read the final shared count and the CPU1 touch stamp through a dmb ish so we
    # observe every locked store from both cores.
    _dmb_ish()
    total: uint64 = counter[0]
    stamp: uint64 = touched[0]

    expected: uint64 = SMP_ITERS + SMP_ITERS

    cmsg: Ptr[char] = "[arm64] shared counter -> "
    _uart_puts(cmsg)
    _uart_puthex(total)
    _uart_puts(nl)
    emsg: Ptr[char] = "[arm64] expected         -> "
    _uart_puts(emsg)
    _uart_puthex(expected)
    _uart_puts(nl)
    smsg: Ptr[char] = "[arm64] CPU1 touched lock -> "
    _uart_puts(smsg)
    _uart_puthex(stamp)
    _uart_puts(nl)

    # PASS iff the total is exactly 2*SMP_ITERS (no lost updates -> the lock held
    # AND both cores ran) AND CPU1 stamped its id (the secondary entered the
    # critical section, so it really executed under the shared lock).
    if total == expected and stamp == cast[uint64](1):
        ranmsg: Ptr[char] = "[arm64] CPU1 ran in scheduler\n"
        _uart_puts(ranmsg)
        heldmsg: Ptr[char] = "[arm64] spinlock held under contention\n"
        _uart_puts(heldmsg)
        okmsg: Ptr[char] = "[arm64] SMP scheduling OK\n"
        _uart_puts(okmsg)
    else:
        failmsg: Ptr[char] = "[arm64] SMP scheduling FAIL\n"
        _uart_puts(failmsg)
        while True:
            _wfi()

    # Phase 12 complete. The secondary is now parked in WFE; the PRIMARY hands off
    # to Phase 11 (EL0 signal delivery). Mask IRQs (deterministic, no timer
    # re-entry); arm64_run_signal_demo() halts after the Phase-11 PASS marker.
    _msr_daifset(2)
    arm64_run_signal_demo()
    while True:
        _wfi()
    return 0


# ---------------------------------------------------------------------------
# Phase 11 — EL0 SIGNAL DELIVERY (push a signal frame, run a user handler,
# sigreturn back to the interrupted EL0 context).
#
# This mirrors the x86 signal-delivery path: a running EL0 task asks the kernel
# to deliver a signal to itself; the kernel saves the interrupted EL0 context
# (resume PC + stack pointer + the syscall's x0 result) into a SIGNAL FRAME it
# pushes onto the task's OWN EL0 stack, redirects EL0 to a user signal HANDLER,
# and ERETs into it. The handler runs entirely in EL0 (it records that it ran
# via a kernel-private syscall) and finally invokes a sigreturn TRAMPOLINE,
# which traps to the kernel; the kernel restores ELR_EL1 + SP_EL0 (and x0) from
# the saved frame and ERETs back to EXACTLY where the original raise() left off.
# The main routine then observes it resumed past the raise and exit(0)s, proving
# a complete deliver -> handle -> return round trip on bare-metal aarch64.
#
# Implementation notes:
#   * The signal frame is pushed BELOW the live SP_EL0 (read via MRS SP_EL0) so
#     it lands in the task's EL0-RWX stack window; SP_EL0 is then lowered past it
#     while the handler runs, and restored to its original value on sigreturn.
#   * raise()/sigreturn() are serviced from arm64_sync_handler's normal return
#     path: that path does NOT overwrite SPSR_EL1/ELR_EL1/SP_EL0 (it only reloads
#     the GPR frame then erets), so mutating ELR_EL1 + SP_EL0 inside the handler
#     and returning 0 makes the stub's ERET resume EL0 at the redirected target.
#   * SPSR_EL1 is left as the trapped EL0t PSTATE for both transitions, so the
#     handler and the resumed mainline both run at EL0t with IRQs masked.
# ---------------------------------------------------------------------------

# Kernel-private Phase-11 syscall numbers (outside the Linux ABI range used by
# write/exit). raise() asks the kernel to deliver the signal; sighandler_ran()
# lets the user handler tell the kernel it executed; sigreturn() asks the kernel
# to restore the interrupted context and resume the mainline.
SYS_RAISE_NR: uint64 = 520
SYS_SIGHANDLER_RAN_NR: uint64 = 521
SYS_SIGRETURN_NR: uint64 = 522

# The signal "number" the demo raises (mirrors a POSIX signal value; here it is
# only a token passed to the handler in x0 so we can prove it arrived intact).
SIG_DEMO_NR: uint64 = 0x11               # 17 — an arbitrary recognizable token

# Phase-11 EL0 layout, all inside the EL0-RWX window (USER_L2_INDEX @ 0x4020_0000):
#   main entry, handler entry, sigreturn trampoline, and the write() message.
SIG_MAIN_CODE: uint64 = 0x40200000       # main routine (== USER_CODE_BASE)
SIG_HANDLER_CODE: uint64 = 0x40208000    # signal handler routine
SIG_RET_TRAMP: uint64 = 0x4020C000       # sigreturn trampoline (handler returns here)
SIG_MSG_BASE: uint64 = 0x40223000        # handler's write() message buffer
SIG_STACK_TOP: uint64 = 0x40270000       # EL0 stack top for the signal demo task

# Phase-11 bookkeeping. arm64_sig_active routes svc into the Phase-11 dispatcher.
# The saved-frame cells latch the interrupted EL0 context across handler
# execution. arm64_sig_handler_ran / arm64_sig_delivered / arm64_sig_returned
# latch the three milestones so exit() can prove the full round trip occurred.
arm64_sig_active: int64 = 0
arm64_sig_saved_pc: uint64 = 0           # ELR_EL1 at raise (resume PC)
arm64_sig_saved_sp: uint64 = 0           # SP_EL0 at raise (resume stack)
arm64_sig_saved_x0: uint64 = 0           # x0 the mainline expects after raise
arm64_sig_delivered: int64 = 0           # set once the frame is pushed + redirected
arm64_sig_handler_ran: int64 = 0         # set when the EL0 handler reports in
arm64_sig_returned: int64 = 0            # set once sigreturn restored the context
arm64_sig_handler_arg: uint64 = 0        # the signal token the handler received

# The return value raise() hands back to the mainline once the handler has run
# and sigreturn has resumed it (a recognizable sentinel so the mainline can
# confirm the kernel restored its x0 across the signal round trip).
SIG_RAISE_RESULT: uint64 = 0x5161        # "Q a" — arbitrary recognizable value


# Materialise the Phase-11 EL0 MAIN routine into SIG_MAIN_CODE:
#   x8 = 520 (raise); svc #0          -> kernel delivers the signal here
#   (control diverts to the handler, runs it, sigreturns back to the next insn)
#   ... resumes here with x0 = SIG_RAISE_RESULT ...
#   write(1, msg, len)                -> echo a "resumed" marker
#   exit(0)
# Because raise() diverts to the handler and only returns AFTER sigreturn, the
# instructions after the raise svc are the resumption point the kernel restores.
def arm64_build_sig_main(msg_len: uint64) -> int64:
    a: uint64 = SIG_MAIN_CODE

    # raise(): x8 = 520; svc #0. The kernel saves THIS post-svc PC as the resume
    # point, delivers the signal, and only resumes here once sigreturn fires.
    a = _emit_load_imm64(a, cast[uint64](8), SYS_RAISE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 64; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), SIG_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0

    # exit(0): x0 = 0; x8 = 93; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0

    _dsb_ish()
    _isb()
    return 0


# Materialise the Phase-11 EL0 signal HANDLER into SIG_HANDLER_CODE. On entry the
# kernel has set x0 = the signal token (SIG_DEMO_NR). The handler:
#   sighandler_ran(x0): x8 = 521; svc #0   -> tell the kernel it executed (passing
#                                             the signal token back for checking)
#   b SIG_RET_TRAMP                         -> jump to the sigreturn trampoline
# The trampoline then issues the sigreturn svc, so the handler never falls off
# its end. (x0 already holds the signal token on entry, courtesy of the kernel.)
def arm64_build_sig_handler() -> int64:
    a: uint64 = SIG_HANDLER_CODE

    # sighandler_ran(token): the kernel placed the token in x0 already; move it to
    # x1 (so x0 can carry nothing in particular) — but simplest is to keep the
    # token in x0 as arg0. x8 = 521; svc #0.
    a = _emit_load_imm64(a, cast[uint64](8), SYS_SIGHANDLER_RAN_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0

    # b SIG_RET_TRAMP : 0x14000000 | imm26; imm26 = (target - here) / 4.
    b_here: uint64 = a
    off_tramp: int64 = cast[int64](SIG_RET_TRAMP) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_tramp >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# Materialise the Phase-11 sigreturn TRAMPOLINE into SIG_RET_TRAMP:
#   x8 = 522 (sigreturn); svc #0   -> kernel restores the interrupted context and
#                                     resumes the mainline (this svc never returns
#                                     to the trampoline; the kernel erets to the
#                                     saved mainline PC instead).
# A real Linux signal frame stores this trampoline address as the handler's
# return address; here the handler branches to it directly, which is equivalent.
def arm64_build_sig_trampoline() -> int64:
    a: uint64 = SIG_RET_TRAMP
    a = _emit_load_imm64(a, cast[uint64](8), SYS_SIGRETURN_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0
    _dsb_ish()
    _isb()
    return 0


# Deliver the signal to the running EL0 task. The trapped ELR_EL1 already points
# at the instruction AFTER the raise svc — that is the resume PC. Saves the
# interrupted context, pushes a signal frame below SP_EL0, redirects ELR_EL1 to
# the handler with the signal token in x0, and lowers SP_EL0 past the frame.
def arm64_sig_do_raise(frame_ptr: Ptr[uint64]) -> int64:
    resume_pc: uint64 = cast[uint64](_mrs_elr_el1())
    cur_sp: uint64 = cast[uint64](_mrs_sp_el0())

    rm: Ptr[char] = "[arm64] EL0 raise() -> delivering signal\n"
    _uart_puts(rm)

    # Save the interrupted context the mainline must see restored. The saved x0 is
    # a sentinel so the resumption can prove the kernel restored x0 round trip.
    arm64_sig_saved_pc = resume_pc
    arm64_sig_saved_sp = cur_sp
    arm64_sig_saved_x0 = SIG_RAISE_RESULT

    # Push a minimal signal frame onto the EL0 stack below the live SP_EL0 (two
    # 8-byte words, 16-byte aligned): the saved PC + SP, mirroring a real
    # sigframe. The kernel reads these back on sigreturn.
    new_sp: uint64 = cur_sp - cast[uint64](16)
    framep: Ptr[uint64] = cast[Ptr[uint64]](new_sp)
    framep[0] = resume_pc
    framep[1] = cur_sp

    pcmsg: Ptr[char] = "[arm64] signal frame pushed; resume PC="
    _uart_puts(pcmsg)
    _uart_puthex(resume_pc)
    nl0: Ptr[char] = "\n"
    _uart_puts(nl0)

    # Redirect EL0 into the user handler on the lowered stack, with the signal
    # token in x0 (the handler's arg0). The sync stub reloads the GPR frame then
    # erets, so writing the frame's x0 slot sets the handler's x0, and setting
    # ELR_EL1 + SP_EL0 here lands the eret on the handler.
    frame_ptr[0] = SIG_DEMO_NR
    _msr_elr_el1(SIG_HANDLER_CODE)
    _msr_sp_el0(new_sp)
    arm64_sig_delivered = 1

    dm: Ptr[char] = "[arm64] redirected EL0 to signal handler\n"
    _uart_puts(dm)
    return 0


# Restore the interrupted EL0 context from the saved signal frame and resume the
# mainline. Reads the frame back off the EL0 stack to prove the pushed layout
# round-tripped, then restores ELR_EL1 + SP_EL0 + x0.
def arm64_sig_do_return(frame_ptr: Ptr[uint64]) -> int64:
    sp_at_ret: uint64 = cast[uint64](_mrs_sp_el0())
    framep: Ptr[uint64] = cast[Ptr[uint64]](sp_at_ret)
    framed_pc: uint64 = framep[0]
    framed_sp: uint64 = framep[1]

    srm: Ptr[char] = "[arm64] EL0 sigreturn() -> restoring context\n"
    _uart_puts(srm)

    # The frame-stored PC/SP must match what raise() saved.
    ok_pc: int64 = 0
    if framed_pc == arm64_sig_saved_pc:
        ok_pc = 1
    ok_sp: int64 = 0
    if framed_sp == arm64_sig_saved_sp:
        ok_sp = 1
    if (ok_pc != 0) and (ok_sp != 0):
        fm: Ptr[char] = "[arm64] sigreturn frame matched saved context OK\n"
        _uart_puts(fm)
    else:
        bm: Ptr[char] = "[arm64] sigreturn frame MISMATCH FAIL\n"
        _uart_puts(bm)

    # Restore ELR_EL1 (resume PC) + SP_EL0 (original stack), and place the saved
    # x0 sentinel into the frame's x0 slot so the mainline resumes with raise()'s
    # return value. SPSR_EL1 is unchanged (still EL0t).
    _msr_elr_el1(arm64_sig_saved_pc)
    _msr_sp_el0(arm64_sig_saved_sp)
    frame_ptr[0] = arm64_sig_saved_x0
    arm64_sig_returned = 1

    dm: Ptr[char] = "[arm64] resuming interrupted EL0 mainline; PC="
    _uart_puts(dm)
    _uart_puthex(arm64_sig_saved_pc)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    return 0


# Phase-11 exit: record the code, print PASS iff the whole signal round trip ran
# cleanly (frame delivered + handler ran with the right token + sigreturn
# restored + resumed), then halt deterministically. Never returns.
def arm64_sig_do_exit(a0: uint64) -> int64:
    arm64_el0_exit_code = cast[int64](a0)
    arm64_el0_exited = 1
    em: Ptr[char] = "[arm64] EL0 exit(11) syscall serviced\n"
    _uart_puts(em)
    ok: int64 = 0
    if a0 == cast[uint64](0):
        if arm64_sig_delivered != 0:
            if arm64_sig_handler_ran != 0:
                if arm64_sig_returned != 0:
                    if arm64_sig_handler_arg == SIG_DEMO_NR:
                        ok = 1
    if ok != 0:
        pm: Ptr[char] = "[arm64] EL0 signal delivery OK\n"
        _uart_puts(pm)
    else:
        fm: Ptr[char] = "[arm64] EL0 signal delivery FAIL\n"
        _uart_puts(fm)
    arm64_sig_active = 0
    # Phase 11 done; hand off to Phase 13 (EL0 FP/SIMD context save/restore across
    # a context switch). Mask IRQs so the cooperative-yield FP demo runs
    # deterministically (no timer re-entry); arm64_run_fp_demo() halts after its
    # own PASS marker and never returns.
    _msr_daifset(2)
    arm64_run_fp_demo()
    # Unreachable safety halt.
    while True:
        _wfi()
    return 0


# Phase-11 signal dispatcher. Routed from arm64_sync_handler while the signal
# demo is live. Services raise (deliver), sighandler_ran (handler reporting in),
# sigreturn (restore + resume), write and exit. raise/sigreturn mutate ELR_EL1 +
# SP_EL0 and return 0 so the sync stub's ERET lands on the redirected target.
def arm64_sig_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_RAISE_NR:
        return arm64_sig_do_raise(frame_ptr)

    if nr == SYS_SIGHANDLER_RAN_NR:
        # The EL0 signal handler is executing and reporting in (a0 = signal token).
        arm64_sig_handler_ran = 1
        arm64_sig_handler_arg = a0
        hm: Ptr[char] = "[arm64] EL0 signal handler ran; token="
        _uart_puts(hm)
        _uart_puthex(a0)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_SIGRETURN_NR:
        return arm64_sig_do_return(frame_ptr)

    if nr == SYS_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(11) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_EXIT_NR:
        return arm64_sig_do_exit(a0)

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 11)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-11 entry point (invoked from the Phase-10 SMP hand-off). Restore the
# kernel's identity TTBR0, build the EL0 main routine + signal handler + sigreturn
# trampoline + handler message, arm Phase-11 dispatch, and ERET into the main
# routine at EL0t with IRQs masked. Never returns (the task's exit() halts).
def arm64_run_signal_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 11: EL0 signal delivery\n"
    _uart_puts(intro)

    # Restore the kernel's identity-only TTBR0 so the EL0 code/stack windows
    # resolve through L1_PGTABLE, then flush the TLB for a clean address space.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Build the three EL0 routines + the handler's write() message.
    sigmsg: Ptr[char] = "Resumed EL0 mainline after signal handler\n"
    msg_len: uint64 = _copy_msg_to(sigmsg, SIG_MSG_BASE)
    arm64_build_sig_main(msg_len)
    arm64_build_sig_handler()
    arm64_build_sig_trampoline()

    # Seed Phase-11 bookkeeping and arm the dispatcher.
    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_sig_delivered = 0
    arm64_sig_handler_ran = 0
    arm64_sig_returned = 0
    arm64_sig_handler_arg = 0
    arm64_sig_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 signal-delivery task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(SIG_MAIN_CODE)        # EL0 entry PC (the main routine)
    _msr_sp_el0(SIG_STACK_TOP)         # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; svc traps re-enter EL1; no return
    return 0


# ---------------------------------------------------------------------------
# Phase 13 — EL0 FP/SIMD CONTEXT SAVE/RESTORE ACROSS A CONTEXT SWITCH.
#
# Linux saves/restores the FP/SIMD register file (the V registers) on every
# context switch; without that, a task's floating-point state would be silently
# corrupted the moment another task ran. The aarch64 port's earlier scheduler
# (Phase 5) only saved the GPRs (x0..x30 + SP/ELR/SPSR), NOT the FP registers, so
# FP state did NOT survive a switch. Phase 13 closes that gap and PROVES it.
#
# Design (deterministic, cooperative — no timer needed):
#   * CPACR_EL1.FPEN is set so EL0 (and the kernel) may execute FP/SIMD ops; until
#     now FP was trapped.
#   * Two EL0 tasks each seed the callee-saved scalar FP register d8 with a
#     DISTINCTIVE 64-bit signature (FP_SIG0 / FP_SIG1) via a hand-emitted
#     `fmov d8, x9`. Each then loops: read d8 back (`fmov x_, d8`), hand the value
#     to the kernel via a private `fpcheck` syscall, then `yield`.
#   * The kernel runs a COOPERATIVE round-robin scheduler keyed off yield. On every
#     yield it SAVES the outgoing task's d8..d15 into that task's FP save area and
#     RESTORES the incoming task's d8..d15 from its save area — the FP half of a
#     real context switch. Between a task's two consecutive yields the OTHER task
#     runs and overwrites the LIVE d8 with its own signature, so WITHOUT the
#     save/restore a task would read back the wrong value. fpcheck FAILs loudly if
#     a task ever observes a value other than its own signature.
#   * After each task has been scheduled FP_YIELD_LIMIT times and every fpcheck
#     matched, the kernel prints the Phase-13 PASS marker and halts. A PASS proves
#     FP/SIMD state is per-task and genuinely survives an EL0<->EL0 context switch
#     on bare-metal aarch64.
# ---------------------------------------------------------------------------

# Kernel-private Phase-13 syscall: an EL0 task reports the current value it read
# back out of d8 so the kernel can verify its FP signature survived the switch.
SYS_FPCHECK_NR: uint64 = 530

# The two task FP signatures (arbitrary recognizable 64-bit values). Each task
# seeds d8 with its own and must always read exactly this back.
FP_SIG0: uint64 = 0x1234567811112222
FP_SIG1: uint64 = 0xCAFEF00D33334444

# Phase-13 EL0 layout — both tasks live inside the EL0-RWX 2 MiB window.
FP_TASK0_CODE: uint64 = 0x40200000
FP_TASK1_CODE: uint64 = 0x40210000
FP_TASK0_STACK_TOP: uint64 = 0x40240000
FP_TASK1_STACK_TOP: uint64 = 0x40250000

# Per-task context blocks (GPR frame, 34 slots) in EL1-only RAM, clear of the
# Phase-5 blocks (0x40104000 / 0x40105000) so the two demos never collide.
FP_TASK0_CTX: uint64 = 0x40106000
FP_TASK1_CTX: uint64 = 0x40107000

# Per-task FP save areas (d8..d15 = 8 doubles = 64 bytes each), EL1-only RAM. A
# task can neither read nor scribble the saved FP state of the other.
FP_TASK0_FPAREA: uint64 = 0x40108000
FP_TASK1_FPAREA: uint64 = 0x40108080

# How many times EACH task must be scheduled (and pass its fpcheck) before the
# demo declares success. Small but >1 so the save/restore is exercised both ways
# multiple times.
FP_YIELD_LIMIT: int64 = 6

# Phase-13 bookkeeping.
arm64_fp_active: int64 = 0           # routes svc into the Phase-13 dispatcher
arm64_fp_cur_task: int64 = 0         # which task is live (0 or 1)
arm64_fp_checks0: int64 = 0          # successful fpchecks by task 0
arm64_fp_checks1: int64 = 0          # successful fpchecks by task 1
arm64_fp_corrupt: int64 = 0          # set if ANY task ever read a wrong value
arm64_fp_current_ctx: uint64 = 0     # ctx block of the live task (for symmetry)


# Materialise a Phase-13 EL0 FP task into `code_base`. The task:
#   x9 = sig ; fmov d8, x9          -> seed its FP signature into d8
#   loop:
#     fmov x0, d8                   -> read d8 back into x0 (arg0)
#     x8 = 530 (fpcheck) ; svc #0   -> kernel verifies x0 == this task's sig
#     x8 = 124 (yield)   ; svc #0   -> cooperatively yield to the other task
#     b loop
# The task never exits; the kernel ends the demo once both tasks have passed
# FP_YIELD_LIMIT fpchecks. fmov encodings:
#   fmov d8, xN  : 0x9E670000 | (N<<5) | 8
#   fmov x0, d8  : 0x9E660000 | (8<<5) | 0
def arm64_build_fp_task(code_base: uint64, sig: uint64) -> int64:
    a: uint64 = code_base

    # x9 = sig ; fmov d8, x9
    a = _emit_load_imm64(a, cast[uint64](9), sig)
    fmov_d8_x9: uint64 = cast[uint64](0x9E670000) | (cast[uint64](9) << cast[uint64](5)) | cast[uint64](8)
    a = _emit_word(a, fmov_d8_x9)

    loop_top: uint64 = a

    # fmov x0, d8  (read the live d8 into x0 as fpcheck's arg0)
    fmov_x0_d8: uint64 = cast[uint64](0x9E660000) | (cast[uint64](8) << cast[uint64](5)) | cast[uint64](0)
    a = _emit_word(a, fmov_x0_d8)

    # fpcheck(x0): x8 = 530 ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_FPCHECK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0

    # yield(): x8 = 124 ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_YIELD_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0

    # b loop_top : 0x14000000 | imm26
    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# Enable EL0/EL1 FP/SIMD access by setting CPACR_EL1.FPEN (bits[21:20] = 0b11).
# Without this, the first fmov (kernel or EL0) traps as an EC=0x07 access fault.
def arm64_fp_enable() -> int64:
    cpacr: uint64 = cast[uint64](_mrs_cpacr_el1())
    cpacr = cpacr | cast[uint64](0x300000)     # FPEN = 0b11 (no trapping)
    _msr_cpacr_el1(cpacr)
    _isb()
    return 0


# Phase-13 cooperative scheduler: invoked from the dispatcher when the running
# task yields. The svc trap path (arm64_lower_sync_entry in vectors.S) reloads the
# GPR frame then erets WITHOUT touching SP_EL0/ELR_EL1/SPSR_EL1 — so, exactly like
# the Phase-11 signal path, we redirect the eret by mutating ELR_EL1 + SP_EL0 here.
#
# Save the OUTGOING task's resume context (the post-yield ELR_EL1 + live SP_EL0)
# into its ctx block AND save its FP registers d8..d15 into its FP save area; then
# pick the OTHER task, restore its FP registers, and program ELR_EL1/SP_EL0/SPSR
# from its ctx block so the stub's eret resumes it where it last yielded (or at its
# entry on the first schedule). This is the FP half of a real context switch
# layered on the GPR-frame reload the vector stub already does.
def arm64_fp_switch() -> uint64:
    out_ctx: uint64 = FP_TASK0_CTX
    out_area: uint64 = FP_TASK0_FPAREA
    in_ctx: uint64 = FP_TASK1_CTX
    in_area: uint64 = FP_TASK1_FPAREA
    if arm64_fp_cur_task == 0:
        out_ctx = FP_TASK0_CTX
        out_area = FP_TASK0_FPAREA
        in_ctx = FP_TASK1_CTX
        in_area = FP_TASK1_FPAREA
        arm64_fp_cur_task = 1
    else:
        out_ctx = FP_TASK1_CTX
        out_area = FP_TASK1_FPAREA
        in_ctx = FP_TASK0_CTX
        in_area = FP_TASK0_FPAREA
        arm64_fp_cur_task = 0

    # Save the outgoing task's resume PC (ELR_EL1, already pointing past its yield
    # svc) and live stack (SP_EL0) so it resumes mid-loop next time it is picked.
    outc: Ptr[uint64] = cast[Ptr[uint64]](out_ctx)
    outc[CTX_ELR] = cast[uint64](_mrs_elr_el1())
    outc[CTX_SP_EL0] = cast[uint64](_mrs_sp_el0())
    outc[CTX_SPSR] = SPSR_EL0T_DAIF

    # Save the outgoing task's FP state, then load the incoming task's FP state
    # into the live registers — the heart of the FP context switch.
    _fp_save_d8_d15(out_area)
    _fp_restore_d8_d15(in_area)

    # Program the eret target from the incoming task's ctx block.
    inc: Ptr[uint64] = cast[Ptr[uint64]](in_ctx)
    _msr_elr_el1(inc[CTX_ELR])
    _msr_sp_el0(inc[CTX_SP_EL0])
    _msr_spsr_el1(inc[CTX_SPSR])

    arm64_fp_current_ctx = in_ctx
    arm64_current_ctx = in_ctx
    return in_ctx


# Phase-13 syscall dispatcher. Services fpcheck (verify a task's FP signature),
# yield (save/restore FP + switch task), write and exit. fpcheck/yield return into
# EL0; the demo ends from inside the dispatcher (it never returns to EL0 then).
def arm64_fp_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_FPCHECK_NR:
        # a0 = the value the task read back out of d8. It must equal the live
        # task's signature; otherwise FP state was lost across a switch.
        expected: uint64 = FP_SIG0
        if arm64_fp_cur_task == 0:
            expected = FP_SIG0
        else:
            expected = FP_SIG1
        if a0 == expected:
            if arm64_fp_cur_task == 0:
                arm64_fp_checks0 = arm64_fp_checks0 + 1
            else:
                arm64_fp_checks1 = arm64_fp_checks1 + 1
            okm: Ptr[char] = "[arm64] fpcheck OK task="
            _uart_puts(okm)
            _uart_puthex(cast[uint64](arm64_fp_cur_task))
            sm: Ptr[char] = " d8="
            _uart_puts(sm)
            _uart_puthex(a0)
            nl: Ptr[char] = "\n"
            _uart_puts(nl)
        else:
            arm64_fp_corrupt = 1
            bm: Ptr[char] = "[arm64] fpcheck CORRUPT task="
            _uart_puts(bm)
            _uart_puthex(cast[uint64](arm64_fp_cur_task))
            gm: Ptr[char] = " got="
            _uart_puts(gm)
            _uart_puthex(a0)
            em: Ptr[char] = " want="
            _uart_puts(em)
            _uart_puthex(expected)
            nl2: Ptr[char] = "\n"
            _uart_puts(nl2)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_YIELD_NR:
        # Both tasks have run enough times AND every fpcheck matched -> success.
        if arm64_fp_checks0 >= FP_YIELD_LIMIT:
            if arm64_fp_checks1 >= FP_YIELD_LIMIT:
                arm64_fp_finish()
                # Unreachable: arm64_fp_finish halts. Safety loop if it falls through.
                while True:
                    _wfi()

        # Otherwise switch FP context to the other task. arm64_fp_switch saves the
        # outgoing FP + resume context and programs ELR_EL1/SP_EL0/SPSR for the
        # incoming task; we then return 0 so the sync stub reloads the GPR frame and
        # erets into the incoming task at its redirected resume point.
        arm64_fp_switch()
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_EXIT_NR:
        arm64_fp_finish()
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 13)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# ERET into the task whose context block is `ctx_base`: program SPSR/ELR/SP_EL0
# from the saved context and eret. Cooperative (no timer), so SPSR keeps IRQs
# masked (SPSR_EL0T_DAIF). Never returns; control resumes in EL0.
def arm64_fp_eret(ctx_base: uint64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](ctx_base)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()
    return 0


# Phase-13 finish: print PASS iff both tasks were scheduled FP_YIELD_LIMIT times
# with every fpcheck matching its signature (so FP state survived every switch)
# and no corruption was ever observed. Halt deterministically. Never returns.
def arm64_fp_finish() -> int64:
    arm64_fp_active = 0
    nl: Ptr[char] = "\n"
    c0m: Ptr[char] = "[arm64] task0 fpchecks passed -> "
    _uart_puts(c0m)
    _uart_puthex(cast[uint64](arm64_fp_checks0))
    _uart_puts(nl)
    c1m: Ptr[char] = "[arm64] task1 fpchecks passed -> "
    _uart_puts(c1m)
    _uart_puthex(cast[uint64](arm64_fp_checks1))
    _uart_puts(nl)

    ok: int64 = 0
    if arm64_fp_corrupt == 0:
        if arm64_fp_checks0 >= FP_YIELD_LIMIT:
            if arm64_fp_checks1 >= FP_YIELD_LIMIT:
                ok = 1
    if ok != 0:
        sm: Ptr[char] = "[arm64] FP state survived context switch\n"
        _uart_puts(sm)
        pm: Ptr[char] = "[arm64] EL0 FP context switch OK\n"
        _uart_puts(pm)
        # Phase 13 complete and clean. Hand off to Phase 14 (demand paging via a
        # translation-fault handler). IRQs stay masked (deterministic); the demand
        # task's exit() halts the boot after the Phase-14 PASS, so this is the
        # Phase 13 -> 14 hand-off point. arm64_run_demand_demo never returns.
        _msr_daifset(2)
        arm64_run_demand_demo()
        # Unreachable safety halt if the Phase-14 launcher ever falls through.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 FP context switch FAIL\n"
        _uart_puts(fm)
    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-13 entry point (invoked from the Phase-11 exit hand-off). Restore the
# kernel's identity TTBR0, enable FP/SIMD, build both EL0 FP tasks + their context
# blocks, seed each task's FP save area with its signature (so the FIRST restore
# of an incoming task loads the right value), arm Phase-13 dispatch, and ERET into
# task 0 at EL0t with IRQs masked. Never returns (the demo halts at its PASS).
def arm64_run_fp_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 13: EL0 FP/SIMD context save/restore\n"
    _uart_puts(intro)

    # Restore the kernel's identity-only TTBR0 (earlier phases may have left a
    # per-task TTBR0 installed), then flush the TLB for a clean address space.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Enable FP/SIMD so the tasks' fmov instructions (and the kernel's FP save/
    # restore) do not trap.
    arm64_fp_enable()
    fpm: Ptr[char] = "[arm64] CPACR_EL1.FPEN enabled\n"
    _uart_puts(fpm)

    # Build both EL0 FP tasks (each seeds d8 with its own signature) and their
    # context blocks (entry PC + stack, EL0t with IRQs masked for determinism).
    arm64_build_fp_task(FP_TASK0_CODE, FP_SIG0)
    arm64_build_fp_task(FP_TASK1_CODE, FP_SIG1)
    arm64_init_ctx(FP_TASK0_CTX, FP_TASK0_CODE, FP_TASK0_STACK_TOP)
    arm64_init_ctx(FP_TASK1_CTX, FP_TASK1_CODE, FP_TASK1_STACK_TOP)
    # arm64_init_ctx sets SPSR to SPSR_EL0T_IRQ (IRQs on). This demo is cooperative
    # with IRQs masked, so force EL0t with DAIF masked in both context blocks.
    ctx0: Ptr[uint64] = cast[Ptr[uint64]](FP_TASK0_CTX)
    ctx1: Ptr[uint64] = cast[Ptr[uint64]](FP_TASK1_CTX)
    ctx0[CTX_SPSR] = SPSR_EL0T_DAIF
    ctx1[CTX_SPSR] = SPSR_EL0T_DAIF

    # Seed each task's FP save area so that the very first time the scheduler
    # RESTORES a task, it loads that task's signature into d8 — though both tasks
    # also re-seed d8 themselves on entry, so this only matters for the inactive
    # task's first restore. Write d8's slot (offset 0) to the signature; the
    # remaining d9..d15 slots are left zero.
    area0: Ptr[uint64] = cast[Ptr[uint64]](FP_TASK0_FPAREA)
    area1: Ptr[uint64] = cast[Ptr[uint64]](FP_TASK1_FPAREA)
    i: int64 = 0
    while i < 8:
        area0[i] = cast[uint64](0)
        area1[i] = cast[uint64](0)
        i = i + 1
    area0[0] = FP_SIG0
    area1[0] = FP_SIG1

    # Seed bookkeeping and arm the dispatcher.
    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_fp_cur_task = 0
    arm64_fp_checks0 = 0
    arm64_fp_checks1 = 0
    arm64_fp_corrupt = 0
    arm64_fp_current_ctx = FP_TASK0_CTX
    arm64_current_ctx = FP_TASK0_CTX
    arm64_fp_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 FP tasks\n"
    _uart_puts(enter)

    arm64_fp_eret(FP_TASK0_CTX)        # -> task 0 at EL0; svc traps re-enter EL1
    return 0


# ---------------------------------------------------------------------------
# Phase 14 — DEMAND PAGING via a translation-fault handler.
#
# An EL0 task stores a sentinel to an UNMAPPED virtual page, then reads it back,
# then repeats for a SECOND unmapped page, then reports both values and exit()s.
# Each first store takes a Data Abort (translation fault) to the synchronous
# vector; the kernel's abort path recognises a translation fault in the demand
# window, maps a fresh physical page into the LIVE TTBR0 tables, and RESUMES the
# faulting store (ERET back into the same instruction) so it completes — true
# first-touch demand paging. The kernel then independently verifies each BACKING
# physical page holds the task's sentinel before printing the Phase-14 PASS.
# ---------------------------------------------------------------------------

# Install the L3 table under the demand window's L2 slot (idempotently): zero a
# fresh L3 table the first time, then point the heap's L2 slot at it with a table
# descriptor + break-before-make TLB maintenance. Subsequent demand faults reuse
# the same L3 table (only the per-page L3 entry is added by the caller).
def arm64_demand_install_l3() -> int64:
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    if l2[cast[int64](P14_DEMAND_L2_INDEX)] != cast[uint64](0):
        return 0                          # L3 already wired under this L2 slot

    # Zero the brand-new L3 table so every still-unmapped 4 KiB slot keeps faulting
    # (so the SECOND page is still a genuine first-touch translation fault).
    l3: Ptr[uint64] = cast[Ptr[uint64]](P14_L3)
    i: int64 = 0
    while i < 512:
        l3[i] = cast[uint64](0)
        i = i + 1
    _dsb_ish()

    # Point the demand window's L2 slot at the new L3 table (table descriptor).
    l2[cast[int64](P14_DEMAND_L2_INDEX)] = P14_L3 | DESC_TABLE
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Map one fresh physical page at demand VA `va` (which must lie in the demand
# window) into the live TTBR0_EL1 tables, EL0 read/write, then flush so EL0 sees
# the new translation. `page_pa` is the backing physical page. Returns the L3
# index that was installed.
def arm64_demand_map_page(va: uint64, page_pa: uint64) -> uint64:
    arm64_demand_install_l3()

    # Zero the backing physical page (a fresh page must start clean).
    pg: Ptr[uint64] = cast[Ptr[uint64]](page_pa)
    j: int64 = 0
    while j < 512:
        pg[j] = cast[uint64](0)
        j = j + 1
    _dsb_ish()

    # L3 index of `va` = VA[20:12].
    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P14_L3)
    l3[cast[int64](l3_index)] = page_pa | P14_PAGE_FLAGS

    # Publish the L3 edit and flush the stale (faulting) translation for this VA.
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return l3_index


# Phase-14 demand-paging fault entry. Called from arm64_sync_handler for a data
# abort from EL0 while the demo is live. Reads ESR_EL1.ISS.DFSC to decide whether
# this is a TRANSLATION fault (page in + resume) or anything else (fall through to
# the reaper). On a translation fault for a recognised demand VA it maps a fresh
# page and returns 1 so the caller resumes EL0 at the faulting instruction (which
# then completes). Returns 0 to defer to the permission-fault reaper.
def arm64_try_demand_page(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        # Not a translation fault (e.g. a permission fault) — not demand-pageable.
        return 0

    far: uint64 = cast[uint64](_mrs_far_el1())
    # Page-align the faulting VA down to 4 KiB to find which demand page to map.
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    if page_va == P14_DEMAND_BASE:
        arm64_demand_map_page(P14_DEMAND_BASE, P14_PAGE0)
        arm64_demand_mapped0 = 1
        arm64_demand_faults = arm64_demand_faults + 1
        m: Ptr[char] = "[arm64] demand fault: paged in VA "
        _uart_puts(m)
        _uart_puthex(P14_DEMAND_BASE)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        return 1

    if page_va == P14_DEMAND_BASE2:
        arm64_demand_map_page(P14_DEMAND_BASE2, P14_PAGE1)
        arm64_demand_mapped1 = 1
        arm64_demand_faults = arm64_demand_faults + 1
        m2: Ptr[char] = "[arm64] demand fault: paged in VA "
        _uart_puts(m2)
        _uart_puthex(P14_DEMAND_BASE2)
        nl2: Ptr[char] = "\n"
        _uart_puts(nl2)
        return 1

    # A translation fault OUTSIDE the demand window is still a real fault.
    return 0


# Materialise the Phase-14 EL0 routine into USER_CODE_BASE:
#   x10 = P14_DEMAND_BASE ; x9 = P14_SENTINEL0
#   str x9, [x10]                  -> FAULTS (page unmapped); kernel pages it in
#                                     and resumes here, so the store now completes
#   x9 = 0 ; ldr x9, [x10]         -> read the sentinel back through the new page
#   x11 = x9                       (stash read-back #0 in x11)
#   x10 = P14_DEMAND_BASE2 ; x9 = P14_SENTINEL1
#   str x9, [x10]                  -> SECOND demand fault on a distinct page
#   x9 = 0 ; ldr x9, [x10]         -> read sentinel #1 back
#   demand_report(x11, x9): x0=x11, x1=x9, x8=540 ; svc #0
#   write(1, msg, len)
#   exit(0)
# The two stores fault transparently; nothing in the task code references the
# kernel page-fault path. fmov-free, GPR-only.
def arm64_build_demand_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE

    # --- page 0: x10 = VA, x9 = sentinel0, str (faults), ldr back into x11 ---
    a = _emit_load_imm64(a, cast[uint64](10), P14_DEMAND_BASE)
    a = _emit_load_imm64(a, cast[uint64](9), P14_SENTINEL0)
    # str x9, [x10]   = 0xF9000000 | (Rn<<5) | Rt
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # x9 = 0 ; ldr x9, [x10]   = 0xF9400000 | (Rn<<5) | Rt
    a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # mov x11, x9  (ORR x11, xzr, x9) = 0xAA0003EB | (Rm<<16) ; Rm=9 -> 0xAA0903EB
    a = _emit_word(a, cast[uint64](0xAA0003EB) | (cast[uint64](9) << cast[uint64](16)))

    # --- page 1: x10 = VA2, x9 = sentinel1, str (faults), ldr back into x9 ---
    a = _emit_load_imm64(a, cast[uint64](10), P14_DEMAND_BASE2)
    a = _emit_load_imm64(a, cast[uint64](9), P14_SENTINEL1)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # demand_report(x11, x9): x0 = x11, x1 = x9, x8 = 540 ; svc #0
    # mov x0, x11  (ORR x0, xzr, x11) = 0xAA0003E0 | (11<<16) = 0xAA0B03E0
    a = _emit_word(a, cast[uint64](0xAA0003E0) | (cast[uint64](11) << cast[uint64](16)))
    # mov x1, x9   (ORR x1, xzr, x9)  = 0xAA0003E1 | (9<<16)  = 0xAA0903E1
    a = _emit_word(a, cast[uint64](0xAA0003E1) | (cast[uint64](9) << cast[uint64](16)))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_DEMAND_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 64; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), P14_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # exit(0): x0 = 0; x8 = 93; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-14 syscall dispatcher. Routed from arm64_sync_handler while the demand-
# paging demo is live. Services the kernel-private demand report (the two read-
# back values), write and exit. write/report return into EL0; exit verifies the
# whole sequence and halts.
def arm64_demand_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_DEMAND_REPORT_NR:
        arm64_demand_reported0 = a0
        arm64_demand_reported1 = a1
        r0: Ptr[char] = "[arm64] EL0 demand read-back #0 -> "
        _uart_puts(r0)
        _uart_puthex(a0)
        nl0: Ptr[char] = "\n"
        _uart_puts(nl0)
        r1: Ptr[char] = "[arm64] EL0 demand read-back #1 -> "
        _uart_puts(r1)
        _uart_puthex(a1)
        nl1: Ptr[char] = "\n"
        _uart_puts(nl1)
        # Independently confirm both BACKING physical pages hold the sentinels, so
        # the demand mappings truly reached P14_PAGE0/P14_PAGE1 (not stale alias).
        back0: Ptr[uint64] = cast[Ptr[uint64]](P14_PAGE0)
        back1: Ptr[uint64] = cast[Ptr[uint64]](P14_PAGE1)
        p0: uint64 = back0[0]
        p1: uint64 = back1[0]
        pm0: Ptr[char] = "[arm64] demand backing phys #0 -> "
        _uart_puts(pm0)
        _uart_puthex(p0)
        nlp0: Ptr[char] = "\n"
        _uart_puts(nlp0)
        pm1: Ptr[char] = "[arm64] demand backing phys #1 -> "
        _uart_puts(pm1)
        _uart_puthex(p1)
        nlp1: Ptr[char] = "\n"
        _uart_puts(nlp1)
        if (a0 == P14_SENTINEL0) and (a1 == P14_SENTINEL1):
            if (p0 == P14_SENTINEL0) and (p1 == P14_SENTINEL1):
                ok: Ptr[char] = "[arm64] demand-paged store/load OK\n"
                _uart_puts(ok)
            else:
                bad: Ptr[char] = "[arm64] demand backing phys mismatch FAIL\n"
                _uart_puts(bad)
        else:
            bad2: Ptr[char] = "[arm64] demand read-back mismatch FAIL\n"
            _uart_puts(bad2)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(14) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_EXIT_NR:
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit(14) syscall serviced\n"
        _uart_puts(em)
        arm64_demand_finish(a0)
        # Unreachable: arm64_demand_finish halts. Safety loop if it falls through.
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 14)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-14 finish: print PASS iff exit(0) AND both pages were demand-paged (one
# translation fault each), AND each read-back matched its sentinel. Report the
# fault count for evidence, then halt deterministically. Never returns.
def arm64_demand_finish(code: uint64) -> int64:
    arm64_demand_active = 0
    nl: Ptr[char] = "\n"
    fc: Ptr[char] = "[arm64] demand faults serviced -> "
    _uart_puts(fc)
    _uart_puthex(cast[uint64](arm64_demand_faults))
    _uart_puts(nl)

    ok: int64 = 0
    if code == cast[uint64](0):
        if arm64_demand_mapped0 != 0:
            if arm64_demand_mapped1 != 0:
                if arm64_demand_faults == 2:
                    if arm64_demand_reported0 == P14_SENTINEL0:
                        if arm64_demand_reported1 == P14_SENTINEL1:
                            ok = 1
    if ok != 0:
        sm: Ptr[char] = "[arm64] first-touch pages faulted in on demand\n"
        _uart_puts(sm)
        pm: Ptr[char] = "[arm64] EL0 demand paging OK\n"
        _uart_puts(pm)
        # Phase 14 complete and clean. Hand off to Phase 15 (safe user-memory
        # access with EFAULT fault-trapping). Mask IRQs (deterministic, no timer
        # re-entry) and run the demo; arm64_run_uaccess_demo halts after PASS.
        # This is the Phase 14 -> 15 hand-off point.
        _msr_daifset(2)
        arm64_run_uaccess_demo()
        # Unreachable: arm64_run_uaccess_demo halts. Safety loop if it falls through.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 demand paging FAIL\n"
        _uart_puts(fm)
    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-14 entry point (invoked from the Phase-13 finish hand-off). Restore the
# kernel's identity TTBR0, ensure the demand window's L2 slot is UNMAPPED (so the
# first EL0 store there genuinely translation-faults), build the EL0 routine +
# message, arm Phase-14 dispatch, and ERET into the demand task at EL0t with IRQs
# masked. Never returns (the task's exit() halts after the PASS marker).
def arm64_run_demand_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 14: demand paging via translation-fault handler\n"
    _uart_puts(intro)

    # Restore the kernel's identity-only TTBR0 (Phase 13 left it installed, but be
    # explicit), then flush the TLB for a clean address space.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Force the demand window's L2 slot UNMAPPED so the first EL0 store there
    # raises a translation Data Abort (a clean, repeatable initial state).
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P14_DEMAND_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Seed Phase-14 bookkeeping.
    arm64_demand_faults = 0
    arm64_demand_mapped0 = 0
    arm64_demand_mapped1 = 0
    arm64_demand_reported0 = cast[uint64](0)
    arm64_demand_reported1 = cast[uint64](0)

    demandmsg: Ptr[char] = "Hello from a demand-paged EL0 page\n"
    msg_len: uint64 = _copy_msg_to(demandmsg, P14_MSG_BASE)
    arm64_build_demand_routine(msg_len)

    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_demand_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 demand-paging task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; first store faults, kernel pages in
    return 0


# ---------------------------------------------------------------------------
# Phase 15 — SAFE USER-MEMORY ACCESS with EFAULT FAULT-TRAPPING.
#
# Entered from the Phase-14 finish hand-off. Runs entirely at EL1 (the kernel
# exercises its OWN copy_from_user / copy_to_user accessors): no EL0 task is
# launched. The kernel's identity-only TTBR0 is restored so the page tables are
# in a known state, the good EL0 scratch cell is seeded, then five accesses are
# performed through the safe accessors and the verdict printed:
#   read-good   : copy_from_user(P15_GOOD_VA)      must succeed + return the seed
#   read-bad #1 : copy_from_user(P15_UNMAPPED_VA)  must return -EFAULT (no crash)
#   read-bad #2 : copy_from_user(P15_UNMAPPED_VA2) must return -EFAULT (no crash)
#   write-bad   : copy_to_user(P15_UNMAPPED_VA)    must return -EFAULT (no crash)
#   write-good  : copy_to_user(P15_GOOD_VA)        must succeed; kernel re-reads it
# Never returns: arm64_uaccess_finish halts in WFI after the PASS/FAIL banner.
# ---------------------------------------------------------------------------
def arm64_uaccess_finish() -> int64:
    nl: Ptr[char] = "\n"
    fc: Ptr[char] = "[arm64] uaccess EFAULTs trapped -> "
    _uart_puts(fc)
    _uart_puthex(cast[uint64](arm64_uaccess_faults))
    _uart_puts(nl)

    ok: int64 = 0
    if arm64_p15_read_ok != 0:
        if arm64_p15_read_val == P15_READ_SENTINEL:
            if arm64_p15_efault0 != 0:
                if arm64_p15_efault1 != 0:
                    if arm64_p15_efault2 != 0:
                        if arm64_p15_write_ok != 0:
                            if arm64_p15_write_seen == P15_WRITE_SENTINEL:
                                if arm64_uaccess_faults == 3:
                                    ok = 1
    if ok != 0:
        sm: Ptr[char] = "[arm64] bad user pointers trapped, valid accesses OK\n"
        _uart_puts(sm)
        pm: Ptr[char] = "[arm64] EL1 safe user access OK\n"
        _uart_puts(pm)
        # Phase 15 complete and clean. Hand off to Phase 16 (EL0 mmap/munmap with
        # demand-paged anonymous mappings). Mask IRQs (deterministic, no timer
        # re-entry) and run the demo; arm64_run_mmap_demo halts after PASS. This is
        # the Phase 15 -> 16 hand-off point.
        _msr_daifset(2)
        arm64_run_mmap_demo()
        # Unreachable: arm64_run_mmap_demo halts. Safety loop if it falls through.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL1 safe user access FAIL\n"
        _uart_puts(fm)
    _msr_daifset(2)
    while True:
        _wfi()
    return 0


def arm64_run_uaccess_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 15: safe user access with EFAULT trapping\n"
    _uart_puts(intro)

    # Restore the kernel's identity-only TTBR0 (Phase 14 left a demand mapping in
    # the live tables) so the page tables are in a clean, known state, then flush.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Seed bookkeeping.
    arm64_uaccess_faults = 0
    arm64_p15_read_ok = 0
    arm64_p15_read_val = cast[uint64](0)
    arm64_p15_write_ok = 0
    arm64_p15_write_seen = cast[uint64](0)
    arm64_p15_efault0 = 0
    arm64_p15_efault1 = 0
    arm64_p15_efault2 = 0

    # Seed the GOOD EL0-accessible cell with the read sentinel (the kernel may
    # write it directly — the page is mapped EL0-RW, also EL1-accessible).
    good: Ptr[uint64] = cast[Ptr[uint64]](P15_GOOD_VA)
    good[0] = P15_READ_SENTINEL
    _dsb_ish()

    out: Ptr[uint64] = cast[Ptr[uint64]](P15_OUT_CELL)
    out[0] = cast[uint64](0)

    # --- read-good: copy_from_user from a valid EL0 address ---
    r0: int64 = arm64_copy_from_user_u64(P15_GOOD_VA, out)
    lr0: Ptr[char] = "[arm64] copy_from_user(good) -> rc "
    _uart_puts(lr0)
    _uart_puthex(cast[uint64](r0))
    vsep: Ptr[char] = " val "
    _uart_puts(vsep)
    _uart_puthex(out[0])
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    if r0 == 0:
        arm64_p15_read_ok = 1
        arm64_p15_read_val = out[0]

    # --- read-bad #1: copy_from_user from a wholly-unmapped VA -> -EFAULT ---
    out[0] = cast[uint64](0)
    r1: int64 = arm64_copy_from_user_u64(P15_UNMAPPED_VA, out)
    lr1: Ptr[char] = "[arm64] copy_from_user(unmapped#1) -> rc "
    _uart_puts(lr1)
    _uart_puthex(cast[uint64](r1))
    _uart_puts(nl)
    if r1 == (cast[int64](0) - EFAULT):
        arm64_p15_efault0 = 1
        e0: Ptr[char] = "[arm64] copy_from_user returned -EFAULT (no crash)\n"
        _uart_puts(e0)

    # --- read-bad #2: a second distinct unmapped VA -> -EFAULT ---
    out[0] = cast[uint64](0)
    r2: int64 = arm64_copy_from_user_u64(P15_UNMAPPED_VA2, out)
    lr2: Ptr[char] = "[arm64] copy_from_user(unmapped#2) -> rc "
    _uart_puts(lr2)
    _uart_puthex(cast[uint64](r2))
    _uart_puts(nl)
    if r2 == (cast[int64](0) - EFAULT):
        arm64_p15_efault1 = 1

    # --- write-bad: copy_to_user to an unmapped VA -> -EFAULT ---
    r3: int64 = arm64_copy_to_user_u64(P15_UNMAPPED_VA, P15_WRITE_SENTINEL)
    lr3: Ptr[char] = "[arm64] copy_to_user(unmapped) -> rc "
    _uart_puts(lr3)
    _uart_puthex(cast[uint64](r3))
    _uart_puts(nl)
    if r3 == (cast[int64](0) - EFAULT):
        arm64_p15_efault2 = 1
        e1: Ptr[char] = "[arm64] copy_to_user returned -EFAULT (no crash)\n"
        _uart_puts(e1)

    # --- write-good: copy_to_user to a valid EL0 address, then re-read it ---
    # Pre-clear the cell so the read-back unambiguously reflects the safe write.
    good[0] = cast[uint64](0)
    _dsb_ish()
    r4: int64 = arm64_copy_to_user_u64(P15_GOOD_VA, P15_WRITE_SENTINEL)
    _dsb_ish()
    seen: uint64 = good[0]
    lr4: Ptr[char] = "[arm64] copy_to_user(good) -> rc "
    _uart_puts(lr4)
    _uart_puthex(cast[uint64](r4))
    _uart_puts(vsep)
    _uart_puthex(seen)
    _uart_puts(nl)
    if r4 == 0:
        arm64_p15_write_ok = 1
        arm64_p15_write_seen = seen

    arm64_uaccess_finish()
    # Unreachable: arm64_uaccess_finish halts. Safety loop if it falls through.
    while True:
        _wfi()
    return 0


# ---------------------------------------------------------------------------
# Phase 16 — EL0 mmap / munmap with DEMAND-PAGED ANONYMOUS MAPPINGS.
# ---------------------------------------------------------------------------

# Install the L3 table under the mmap window's L2 slot (idempotently): zero a fresh
# L3 table the first time, then point the L2 slot at it with a table descriptor +
# break-before-make TLB maintenance. Mirrors arm64_demand_install_l3 for the mmap
# L2 slot. Subsequent map/unmap cycles reuse this L3 table; only the per-page L3
# entry is added/removed by the caller.
def arm64_mmap_install_l3() -> int64:
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    if l2[cast[int64](P16_MMAP_L2_INDEX)] != cast[uint64](0):
        return 0                          # L3 already wired under this L2 slot

    l3: Ptr[uint64] = cast[Ptr[uint64]](P16_L3)
    i: int64 = 0
    while i < 512:
        l3[i] = cast[uint64](0)
        i = i + 1
    _dsb_ish()

    l2[cast[int64](P16_MMAP_L2_INDEX)] = P16_L3 | DESC_TABLE
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Map one fresh physical page at anon VA `va` (which must lie in the mmap window)
# into the live TTBR0_EL1 tables, EL0 read/write, then flush so EL0 sees the new
# translation. `page_pa` is the backing physical page. Mirrors arm64_demand_map_page.
def arm64_mmap_map_page(va: uint64, page_pa: uint64) -> uint64:
    arm64_mmap_install_l3()

    # Zero the backing physical page (a fresh anon page must start clean).
    pg: Ptr[uint64] = cast[Ptr[uint64]](page_pa)
    j: int64 = 0
    while j < 512:
        pg[j] = cast[uint64](0)
        j = j + 1
    _dsb_ish()

    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P16_L3)
    l3[cast[int64](l3_index)] = page_pa | P16_PAGE_FLAGS

    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return l3_index


# Tear down one anon page mapping: clear its L3 entry (back to faulting) and flush.
def arm64_mmap_unmap_page(va: uint64) -> int64:
    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P16_L3)
    l3[cast[int64](l3_index)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Phase-16 anon-mapping fault entry. Called from arm64_sync_handler for a data
# abort from EL0 while the mmap demo is live. Honours the fault ONLY when it is a
# TRANSLATION fault for a VA inside the CURRENTLY-LIVE VMA: maps a fresh page and
# returns 1 so the caller resumes EL0 at the faulting store. Returns 0 otherwise —
# in particular for a touch after munmap (vma_live == 0), which the caller turns
# into a fatal SIGSEGV (proving munmap really removed the mapping).
def arm64_mmap_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0                          # not a translation fault

    if arm64_mmap_vma_live == 0:
        return 0                          # no live VMA -> not demand-pageable

    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    # Is the faulting VA inside the live VMA span [base, base + len)?
    if page_va < arm64_mmap_vma_base:
        return 0
    if page_va >= (arm64_mmap_vma_base + arm64_mmap_vma_len):
        return 0

    # Covered by the live VMA: demand-map a fresh page and resume.
    arm64_mmap_map_page(page_va, P16_PAGE)
    arm64_mmap_paged = 1
    arm64_mmap_faults = arm64_mmap_faults + 1
    m: Ptr[char] = "[arm64] mmap demand fault: paged in anon VA "
    _uart_puts(m)
    _uart_puthex(page_va)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    return 1


# Phase-16 fatal-fault path. Reached only when arm64_mmap_try_fault declined a data
# abort while the mmap demo is live — i.e. the EL0 task touched the anon VA AFTER
# munmap, when no VMA covers it. This is exactly a Linux SIGSEGV: report it, latch
# that the post-munmap touch faulted, and run the Phase-16 verdict. Never returns.
def arm64_mmap_reap(esr: uint64) -> int64:
    far: uint64 = cast[uint64](_mrs_far_el1())
    elr: uint64 = cast[uint64](_mrs_elr_el1())
    m: Ptr[char] = "[arm64] mmap post-munmap fault (no VMA) at VA "
    _uart_puts(m)
    _uart_puthex(far)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    pcm: Ptr[char] = "[arm64] mmap SIGSEGV PC (ELR_EL1)="
    _uart_puts(pcm)
    _uart_puthex(elr)
    _uart_puts(nl)
    arm64_mmap_segv = 1
    seg: Ptr[char] = "[arm64] munmap region unmapped; touch faulted (no re-page)\n"
    _uart_puts(seg)
    arm64_mmap_finish()
    # Unreachable: arm64_mmap_finish halts. Safety loop if it falls through.
    while True:
        _wfi()
    return 0


# Materialise the Phase-16 EL0 routine into USER_CODE_BASE. The kernel patches the
# anon base into x10 (it is returned by the mmap syscall at RUNTIME, but for this
# self-contained demo the base is the fixed P16_MMAP_BASE the kernel hands back, so
# we can build the touch sequence around it). The routine:
#   mmap(len): x0=len; x8=222; svc #0      -> x0 = anon base (== P16_MMAP_BASE)
#   x10 = anon base ; x9 = P16_SENTINEL
#   str x9,[x10]                            -> FAULTS; kernel demand-maps + resumes
#   x9 = 0 ; ldr x9,[x10]                   -> read the sentinel back
#   mmap_report(x9): x0=x9; x8=541; svc #0  -> kernel verifies the demand map
#   write(1,msg,len): x0=1; x1=msg; x2=len; x8=64; svc #0   (echo through the page)
#   munmap(base,len): x0=base; x1=len; x8=215; svc #0
#   x9 = P16_SENTINEL2 ; str x9,[x10]       -> FAULTS AGAIN (no VMA) -> SIGSEGV
# The last store never returns; the reaper takes over. We still emit a trailing
# exit(0) for completeness in case the store were ever (wrongly) re-paged.
def arm64_build_mmap_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE

    # mmap(len): x0 = len; x8 = 222; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P16_MMAP_LEN)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MMAP_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x10 = anon base (== P16_MMAP_BASE); x9 = P16_SENTINEL
    a = _emit_load_imm64(a, cast[uint64](10), P16_MMAP_BASE)
    a = _emit_load_imm64(a, cast[uint64](9), P16_SENTINEL)
    # str x9, [x10]   = 0xF9000000 | (Rn<<5) | Rt   (FAULTS first time)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # x9 = 0 ; ldr x9, [x10]   = 0xF9400000 | (Rn<<5) | Rt
    a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # mmap_report(x9): x0 = x9; x8 = 541; svc #0
    # mov x0, x9  (ORR x0, xzr, x9) = 0xAA0003E0 | (9<<16) = 0xAA0903E0
    a = _emit_word(a, cast[uint64](0xAA0003E0) | (cast[uint64](9) << cast[uint64](16)))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MMAP_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 64; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), P16_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # munmap(base, len): x0 = base; x1 = len; x8 = 215; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P16_MMAP_BASE)
    a = _emit_load_imm64(a, cast[uint64](1), P16_MMAP_LEN)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MUNMAP_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x9 = P16_SENTINEL2 ; str x9, [x10]   (FAULTS AGAIN; reaper takes over)
    a = _emit_load_imm64(a, cast[uint64](9), P16_SENTINEL2)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # exit(0): x0 = 0; x8 = 93; svc #0  (only reached if the touch were re-paged)
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-16 syscall dispatcher. Routed from arm64_sync_handler while the mmap demo
# is live. Services mmap (record VMA + return base), munmap (drop VMA + mapping),
# the kernel-private mmap report (verify the demand-paged value), and a defensive
# exit. The demand page-in happens on the ABORT path (arm64_mmap_try_fault).
def arm64_mmap_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_MMAP_NR:
        # Anonymous mmap: record a single VMA [P16_MMAP_BASE, +len) and return the
        # base. No page is mapped here — it materialises lazily on first touch.
        arm64_mmap_vma_base = P16_MMAP_BASE
        arm64_mmap_vma_len = a0
        arm64_mmap_vma_live = 1
        m: Ptr[char] = "[arm64] EL0 mmap(anon, len="
        _uart_puts(m)
        _uart_puthex(a0)
        sep: Ptr[char] = ") -> base "
        _uart_puts(sep)
        _uart_puthex(P16_MMAP_BASE)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        frame_ptr[0] = P16_MMAP_BASE
        return 0

    if nr == SYS_MMAP_REPORT_NR:
        arm64_mmap_readback = a0
        r: Ptr[char] = "[arm64] EL0 mmap read-back -> "
        _uart_puts(r)
        _uart_puthex(a0)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        # Independently confirm the BACKING physical page holds the sentinel, so the
        # demand map truly reached P16_PAGE (not a stale alias).
        back: Ptr[uint64] = cast[Ptr[uint64]](P16_PAGE)
        pv: uint64 = back[0]
        pm: Ptr[char] = "[arm64] mmap backing phys -> "
        _uart_puts(pm)
        _uart_puthex(pv)
        _uart_puts(nl)
        if a0 == P16_SENTINEL:
            if pv == P16_SENTINEL:
                ok: Ptr[char] = "[arm64] mmap demand-paged store/load OK\n"
                _uart_puts(ok)
            else:
                bad: Ptr[char] = "[arm64] mmap backing phys mismatch FAIL\n"
                _uart_puts(bad)
        else:
            bad2: Ptr[char] = "[arm64] mmap read-back mismatch FAIL\n"
            _uart_puts(bad2)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_MUNMAP_NR:
        # munmap(base, len): drop the VMA and tear the page mapping down so a later
        # touch of the same VA faults fatally. Returns 0 like Linux munmap.
        arm64_mmap_unmap_page(a0)
        arm64_mmap_vma_live = 0
        arm64_mmap_unmapped = 1
        m: Ptr[char] = "[arm64] EL0 munmap(base="
        _uart_puts(m)
        _uart_puthex(a0)
        sep: Ptr[char] = ", len="
        _uart_puts(sep)
        _uart_puthex(a1)
        sep2: Ptr[char] = ") -> 0\n"
        _uart_puts(sep2)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(16) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_EXIT_NR:
        # Reached only if the post-munmap touch were (wrongly) re-paged instead of
        # faulting. The verdict will FAIL because arm64_mmap_segv stays 0.
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit(16) syscall serviced (touch did NOT fault!)\n"
        _uart_puts(em)
        arm64_mmap_finish()
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 16)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-16 finish: print PASS iff the anon page was demand-paged exactly once
# inside its VMA, the read-back matched the sentinel, munmap tore the mapping down,
# AND the post-munmap touch faulted with no live VMA (so it was NOT re-paged).
# Report the fault count for evidence, then halt deterministically. Never returns.
def arm64_mmap_finish() -> int64:
    arm64_mmap_active = 0
    nl: Ptr[char] = "\n"
    fc: Ptr[char] = "[arm64] mmap demand faults serviced -> "
    _uart_puts(fc)
    _uart_puthex(cast[uint64](arm64_mmap_faults))
    _uart_puts(nl)

    ok: int64 = 0
    if arm64_mmap_paged != 0:
        if arm64_mmap_faults == 1:
            if arm64_mmap_readback == P16_SENTINEL:
                if arm64_mmap_unmapped != 0:
                    if arm64_mmap_segv != 0:
                        ok = 1
    if ok != 0:
        sm: Ptr[char] = "[arm64] anon mmap lazily backed; munmap removed it\n"
        _uart_puts(sm)
        pm: Ptr[char] = "[arm64] EL0 mmap/munmap OK\n"
        _uart_puts(pm)
        # Phase 16 complete and clean. Hand off to Phase 17 (EL0 mprotect — change
        # page permissions with a real permission-fault check). IRQs are already
        # masked here; arm64_run_mprotect_demo halts after its own PASS.
        arm64_run_mprotect_demo()
        # Unreachable: arm64_run_mprotect_demo halts. Safety loop if it falls through.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 mmap/munmap FAIL\n"
        _uart_puts(fm)
    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-16 entry point (invoked from the Phase-15 finish hand-off). Restore the
# kernel's identity TTBR0, force the mmap window's L2 slot UNMAPPED (so the first
# EL0 touch genuinely translation-faults), seed bookkeeping, build the EL0 routine,
# arm Phase-16 dispatch, and ERET into the mmap task at EL0t with IRQs masked.
# Never returns (the task faults fatally after munmap, handing off to the reaper).
def arm64_run_mmap_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 16: EL0 mmap/munmap with demand-paged anonymous mappings\n"
    _uart_puts(intro)

    # Restore the kernel's identity-only TTBR0, then flush for a clean state.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Force the mmap window's L2 slot UNMAPPED so the first EL0 touch there raises a
    # translation Data Abort (a clean, repeatable initial state).
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P16_MMAP_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Seed Phase-16 bookkeeping.
    arm64_mmap_vma_base = cast[uint64](0)
    arm64_mmap_vma_len = cast[uint64](0)
    arm64_mmap_vma_live = 0
    arm64_mmap_faults = 0
    arm64_mmap_paged = 0
    arm64_mmap_readback = cast[uint64](0)
    arm64_mmap_unmapped = 0
    arm64_mmap_segv = 0

    mapmsg: Ptr[char] = "Hello from an anonymous mmap region\n"
    msg_len: uint64 = _copy_msg_to(mapmsg, P16_MSG_BASE)
    arm64_build_mmap_routine(msg_len)

    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_mmap_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 mmap/munmap task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; mmap, touch (faults+paged), munmap,
    return 0                           #    touch (faults fatally) -> reaper PASS


# ===========================================================================
# Phase 17 — EL0 mprotect: change page permissions with a permission-fault check.
# ===========================================================================

# Install the L3 table under the mprotect window's L2 slot (idempotently): zero a
# fresh L3 table the first time, then point the L2 slot at it with a table
# descriptor + break-before-make TLB maintenance. Mirrors arm64_mmap_install_l3.
def arm64_mprot_install_l3() -> int64:
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    if l2[cast[int64](P17_MMAP_L2_INDEX)] != cast[uint64](0):
        return 0                          # L3 already wired under this L2 slot

    l3: Ptr[uint64] = cast[Ptr[uint64]](P17_L3)
    i: int64 = 0
    while i < 512:
        l3[i] = cast[uint64](0)
        i = i + 1
    _dsb_ish()

    l2[cast[int64](P17_MMAP_L2_INDEX)] = P17_L3 | DESC_TABLE
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Map one fresh, zeroed physical page at anon VA `va` into the live TTBR0_EL1
# tables with the given L3 `flags` (RW or RO), then flush so EL0 sees the new
# translation. Mirrors arm64_mmap_map_page but takes the descriptor flags.
def arm64_mprot_map_page(va: uint64, page_pa: uint64, flags: uint64) -> uint64:
    arm64_mprot_install_l3()

    # Zero the backing physical page (a fresh anon page must start clean).
    pg: Ptr[uint64] = cast[Ptr[uint64]](page_pa)
    j: int64 = 0
    while j < 512:
        pg[j] = cast[uint64](0)
        j = j + 1
    _dsb_ish()

    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P17_L3)
    l3[cast[int64](l3_index)] = page_pa | flags

    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return l3_index


# Re-point the L3 entry for anon VA `va` at the SAME physical page but with new
# `flags` (used by mprotect to flip AP[2:1] RW->RO). Break-before-make: clear the
# entry, flush, then install the new descriptor, flush again. Does NOT touch the
# page contents — the mapping persists, only its permissions change.
def arm64_mprot_reflag_page(va: uint64, page_pa: uint64, flags: uint64) -> int64:
    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P17_L3)
    l3[cast[int64](l3_index)] = cast[uint64](0)          # break
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    l3[cast[int64](l3_index)] = page_pa | flags          # make (new perms)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Phase-17 fault entry. Called from arm64_sync_handler for a data abort from EL0
# while the mprotect demo is live. Honours ONLY a TRANSLATION fault for a VA inside
# the live VMA: demand-maps a fresh RW page and returns 1 so EL0 resumes its store.
# Returns 0 for anything else — in particular a PERMISSION fault (post-mprotect
# store to the now-RO page), which the caller turns into a fatal SIGSEGV. This is
# the crux of Phase 17: translation faults page in; permission faults kill.
def arm64_mprot_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0                          # not a translation fault (e.g. permission)

    if arm64_mprot_vma_live == 0:
        return 0                          # no live VMA -> not demand-pageable

    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    # Is the faulting VA inside the live VMA span [base, base + len)?
    if page_va < arm64_mprot_vma_base:
        return 0
    if page_va >= (arm64_mprot_vma_base + arm64_mprot_vma_len):
        return 0

    # Covered by the live VMA: demand-map a fresh RW page and resume.
    arm64_mprot_map_page(page_va, P17_PAGE, P17_PAGE_FLAGS_RW)
    arm64_mprot_paged = 1
    arm64_mprot_faults = arm64_mprot_faults + 1
    m: Ptr[char] = "[arm64] mprotect demand fault: paged in RW anon VA "
    _uart_puts(m)
    _uart_puthex(page_va)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    return 1


# Phase-17 fatal-fault path. Reached when arm64_mprot_try_fault declines a data
# abort while the mprotect demo is live — i.e. a PERMISSION fault: the EL0 task
# STORED to the page after mprotect flipped it read-only. This is exactly a Linux
# SIGSEGV (SEGV_ACCERR). Confirm via ESR DFSC that it really is a permission fault,
# latch it, and run the Phase-17 verdict. Never returns.
def arm64_mprot_reap(esr: uint64) -> int64:
    far: uint64 = cast[uint64](_mrs_far_el1())
    elr: uint64 = cast[uint64](_mrs_elr_el1())
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT

    m: Ptr[char] = "[arm64] mprotect store-to-RO fault at VA "
    _uart_puts(m)
    _uart_puthex(far)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    pcm: Ptr[char] = "[arm64] mprotect SIGSEGV PC (ELR_EL1)="
    _uart_puts(pcm)
    _uart_puthex(elr)
    _uart_puts(nl)
    dm: Ptr[char] = "[arm64] mprotect fault DFSC kind (3=permission) -> "
    _uart_puts(dm)
    _uart_puthex(kind)
    _uart_puts(nl)

    if kind == ESR_DFSC_KIND_PERM:
        if arm64_mprot_prot_ro != 0:
            arm64_mprot_segv = 1
            seg: Ptr[char] = "[arm64] mprotect write to read-only page denied (permission fault)\n"
            _uart_puts(seg)
    arm64_mprot_finish()
    # Unreachable: arm64_mprot_finish halts. Safety loop if it falls through.
    while True:
        _wfi()
    return 0


# Materialise the Phase-17 EL0 routine into USER_CODE_BASE:
#   mmap(len): x0=len; x8=222; svc #0       -> x0 = anon base (== P17_MMAP_BASE)
#   x10 = anon base ; x9 = P17_SENTINEL
#   str x9,[x10]                            -> FAULTS (translation); kernel maps RW
#   x9 = 0 ; ldr x9,[x10]                   -> read the sentinel back (RW page)
#   report(x9): x0=x9; x8=542; svc #0       -> kernel verifies the RW store/load
#   mprotect(base,len,PROT_READ): x0=base; x1=len; x2=1; x8=226; svc #0
#   x9 = 0 ; ldr x9,[x10]                   -> READ still works on the RO page
#   rdback(x9): x0=x9; x8=543; svc #0       -> kernel verifies the post-RO read
#   write(1,msg,len): x0=1; x1=msg; x2=len; x8=64; svc #0   (echo through the page)
#   x9 = P17_SENTINEL2 ; str x9,[x10]       -> PERMISSION fault (RO) -> SIGSEGV
# The last store never returns; the reaper takes over. We still emit a trailing
# exit(0) in case the store were ever (wrongly) allowed.
def arm64_build_mprotect_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE

    # mmap(len): x0 = len; x8 = 222; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P17_MMAP_LEN)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MMAP_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x10 = anon base (== P17_MMAP_BASE); x9 = P17_SENTINEL
    a = _emit_load_imm64(a, cast[uint64](10), P17_MMAP_BASE)
    a = _emit_load_imm64(a, cast[uint64](9), P17_SENTINEL)
    # str x9, [x10]   (FAULTS first time -> demand-map RW)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # x9 = 0 ; ldr x9, [x10]   (read the RW sentinel back)
    a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # report(x9): x0 = x9; x8 = 542; svc #0   (mov x0, x9 = ORR x0,xzr,x9)
    a = _emit_word(a, cast[uint64](0xAA0003E0) | (cast[uint64](9) << cast[uint64](16)))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MPROTECT_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # mprotect(base, len, PROT_READ): x0=base; x1=len; x2=1; x8=226; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P17_MMAP_BASE)
    a = _emit_load_imm64(a, cast[uint64](1), P17_MMAP_LEN)
    a = _emit_load_imm64(a, cast[uint64](2), PROT_READ)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MPROTECT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x9 = 0 ; ldr x9, [x10]   (READ still works on the now-RO page)
    a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # rdback(x9): x0 = x9; x8 = 543; svc #0
    a = _emit_word(a, cast[uint64](0xAA0003E0) | (cast[uint64](9) << cast[uint64](16)))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MPROTECT_RDBACK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 64; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), P17_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x9 = P17_SENTINEL2 ; str x9, [x10]   (PERMISSION fault on RO -> reaper)
    a = _emit_load_imm64(a, cast[uint64](9), P17_SENTINEL2)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # exit(0): x0 = 0; x8 = 93; svc #0  (only reached if the RO store were allowed)
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-17 syscall dispatcher. Routed from arm64_sync_handler while the mprotect
# demo is live. Services mmap (record VMA + return base), the RW report (verify the
# demand-paged value), mprotect (flip the live L3 descriptor RW->RO), the post-RO
# read report (the read must still succeed), write, and a defensive exit. The
# page-in (translation fault) and the post-mprotect store fault both happen on the
# ABORT path.
def arm64_mprot_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_MMAP_NR:
        # Anonymous mmap: record a single VMA [P17_MMAP_BASE, +len) and return the
        # base. No page is mapped here — it materialises lazily RW on first touch.
        arm64_mprot_vma_base = P17_MMAP_BASE
        arm64_mprot_vma_len = a0
        arm64_mprot_vma_live = 1
        m: Ptr[char] = "[arm64] EL0 mmap(anon, len="
        _uart_puts(m)
        _uart_puthex(a0)
        sep: Ptr[char] = ") -> base "
        _uart_puts(sep)
        _uart_puthex(P17_MMAP_BASE)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        frame_ptr[0] = P17_MMAP_BASE
        return 0

    if nr == SYS_MPROTECT_REPORT_NR:
        arm64_mprot_readback = a0
        r: Ptr[char] = "[arm64] EL0 mprotect RW read-back -> "
        _uart_puts(r)
        _uart_puthex(a0)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        # Independently confirm the BACKING physical page holds the sentinel.
        back: Ptr[uint64] = cast[Ptr[uint64]](P17_PAGE)
        pv: uint64 = back[0]
        pm: Ptr[char] = "[arm64] mprotect backing phys -> "
        _uart_puts(pm)
        _uart_puthex(pv)
        _uart_puts(nl)
        if a0 == P17_SENTINEL:
            if pv == P17_SENTINEL:
                ok: Ptr[char] = "[arm64] mprotect RW store/load OK\n"
                _uart_puts(ok)
            else:
                bad: Ptr[char] = "[arm64] mprotect backing phys mismatch FAIL\n"
                _uart_puts(bad)
        else:
            bad2: Ptr[char] = "[arm64] mprotect RW read-back mismatch FAIL\n"
            _uart_puts(bad2)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_MPROTECT_NR:
        # mprotect(base, len, prot): downgrade the live mapping to read-only by
        # re-flagging its L3 descriptor AP[2:1] RW(0b01) -> RO(0b11). The mapping
        # persists (same backing page) so a READ still works; a WRITE now PERMISSION-
        # faults. We only implement the PROT_READ downgrade the demo exercises.
        m: Ptr[char] = "[arm64] EL0 mprotect(base="
        _uart_puts(m)
        _uart_puthex(a0)
        sep: Ptr[char] = ", len="
        _uart_puts(sep)
        _uart_puthex(a1)
        sep2: Ptr[char] = ", prot="
        _uart_puts(sep2)
        _uart_puthex(a2)
        nl: Ptr[char] = "\n"
        if a2 == PROT_READ:
            arm64_mprot_reflag_page(a0, P17_PAGE, P17_PAGE_FLAGS_RO)
            arm64_mprot_prot_ro = 1
            sep3: Ptr[char] = ") -> RO; AP[2:1]=0b11\n"
            _uart_puts(sep3)
            rm: Ptr[char] = "[arm64] mprotect set page read-only (PROT_READ)\n"
            _uart_puts(rm)
        else:
            sep3b: Ptr[char] = ") -> unchanged\n"
            _uart_puts(sep3b)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_MPROTECT_RDBACK_NR:
        # The post-mprotect READ reached here -> the RO page is still readable.
        arm64_mprot_rd_after = a0
        arm64_mprot_read_ok = 1
        r: Ptr[char] = "[arm64] EL0 read after mprotect(RO) -> "
        _uart_puts(r)
        _uart_puthex(a0)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        if a0 == P17_SENTINEL:
            ok: Ptr[char] = "[arm64] mprotect read-only page still readable OK\n"
            _uart_puts(ok)
        else:
            bad: Ptr[char] = "[arm64] mprotect post-RO read mismatch FAIL\n"
            _uart_puts(bad)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(17) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_EXIT_NR:
        # Reached only if the post-mprotect STORE were (wrongly) allowed instead of
        # faulting. The verdict will FAIL because arm64_mprot_segv stays 0.
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit(17) serviced (RO store did NOT fault!)\n"
        _uart_puts(em)
        arm64_mprot_finish()
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 17)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-17 finish: print PASS iff the anon page was demand-paged RW exactly once,
# the RW read-back matched, mprotect flipped it RO, the post-mprotect READ still
# succeeded (and matched), AND the post-mprotect WRITE took a genuine PERMISSION
# fault (NOT a translation fault). Report the fault count, then halt. Never returns.
def arm64_mprot_finish() -> int64:
    arm64_mprot_active = 0
    nl: Ptr[char] = "\n"
    fc: Ptr[char] = "[arm64] mprotect demand faults serviced -> "
    _uart_puts(fc)
    _uart_puthex(cast[uint64](arm64_mprot_faults))
    _uart_puts(nl)

    ok: int64 = 0
    if arm64_mprot_paged != 0:
        if arm64_mprot_faults == 1:
            if arm64_mprot_readback == P17_SENTINEL:
                if arm64_mprot_prot_ro != 0:
                    if arm64_mprot_read_ok != 0:
                        if arm64_mprot_rd_after == P17_SENTINEL:
                            if arm64_mprot_segv != 0:
                                ok = 1
    if ok != 0:
        sm: Ptr[char] = "[arm64] mprotect RW->RO enforced; read OK, write denied\n"
        _uart_puts(sm)
        pm: Ptr[char] = "[arm64] EL0 mprotect OK\n"
        _uart_puts(pm)
        # Phase 17 complete and clean. Hand off to Phase 18 (multi-page anon mmap +
        # partial munmap that SPLITS a VMA). IRQs are already masked here;
        # arm64_run_multipage_demo halts after its own PASS.
        arm64_run_multipage_demo()
        # Unreachable: arm64_run_multipage_demo halts. Safety loop if it falls through.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 mprotect FAIL\n"
        _uart_puts(fm)
    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-17 entry point (invoked from the Phase-16 finish hand-off). Restore the
# kernel's identity TTBR0, force the mprotect window's L2 slot UNMAPPED (so the
# first EL0 touch genuinely translation-faults), seed bookkeeping, build the EL0
# routine, arm Phase-17 dispatch, and ERET into the task at EL0t with IRQs masked.
# Never returns (the task faults fatally after mprotect, handing off to the reaper).
def arm64_run_mprotect_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 17: EL0 mprotect (change page permissions, permission-fault check)\n"
    _uart_puts(intro)

    # Restore the kernel's identity-only TTBR0, then flush for a clean state.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Force the mprotect window's L2 slot UNMAPPED so the first EL0 touch there
    # raises a translation Data Abort (a clean, repeatable initial state).
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P17_MMAP_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Seed Phase-17 bookkeeping.
    arm64_mprot_vma_base = cast[uint64](0)
    arm64_mprot_vma_len = cast[uint64](0)
    arm64_mprot_vma_live = 0
    arm64_mprot_prot_ro = 0
    arm64_mprot_faults = 0
    arm64_mprot_paged = 0
    arm64_mprot_readback = cast[uint64](0)
    arm64_mprot_rd_after = cast[uint64](0)
    arm64_mprot_read_ok = 0
    arm64_mprot_segv = 0

    protmsg: Ptr[char] = "Hello from an mprotect read-only region\n"
    msg_len: uint64 = _copy_msg_to(protmsg, P17_MSG_BASE)
    arm64_build_mprotect_routine(msg_len)

    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_mprot_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 mprotect task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; mmap, touch (RW), mprotect RO, read
    return 0                           #    (OK), write (PERMISSION fault) -> reaper


# ===========================================================================
# Phase 18 — Multi-page anon mmap + partial munmap that SPLITS a VMA.
# ===========================================================================

# Install the L3 table under the multi-page window's L2 slot (idempotently): zero a
# fresh L3 table the first time, then point the L2 slot at it with a table
# descriptor + break-before-make TLB maintenance. Mirrors arm64_mprot_install_l3.
def arm64_mp_install_l3() -> int64:
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    if l2[cast[int64](P18_MMAP_L2_INDEX)] != cast[uint64](0):
        return 0                          # L3 already wired under this L2 slot

    l3: Ptr[uint64] = cast[Ptr[uint64]](P18_L3)
    i: int64 = 0
    while i < 512:
        l3[i] = cast[uint64](0)
        i = i + 1
    _dsb_ish()

    l2[cast[int64](P18_MMAP_L2_INDEX)] = P18_L3 | DESC_TABLE
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Pick the backing physical page for anon VA `va` by its page offset within the
# region. Page 0 -> P18_PAGE0, page 1 -> P18_PAGE1, page 2 -> P18_PAGE2. Returns 0
# for an out-of-range offset (never happens for a VA the VMA check already cleared).
def arm64_mp_backing_page(va: uint64) -> uint64:
    off: uint64 = va - P18_MMAP_BASE
    idx: uint64 = off >> cast[uint64](12)
    if idx == cast[uint64](0):
        return P18_PAGE0
    if idx == cast[uint64](1):
        return P18_PAGE1
    if idx == cast[uint64](2):
        return P18_PAGE2
    return cast[uint64](0)


# Map one fresh, zeroed physical page at anon VA `va` into the live TTBR0_EL1
# tables RW, then flush so EL0 sees the new translation. Mirrors the prior phases'
# map-page helpers but picks the per-page backing store. Returns the L3 index used.
def arm64_mp_map_page(va: uint64) -> uint64:
    arm64_mp_install_l3()

    page_pa: uint64 = arm64_mp_backing_page(va)

    # Zero the backing physical page (a fresh anon page must start clean).
    pg: Ptr[uint64] = cast[Ptr[uint64]](page_pa)
    j: int64 = 0
    while j < 512:
        pg[j] = cast[uint64](0)
        j = j + 1
    _dsb_ish()

    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P18_L3)
    l3[cast[int64](l3_index)] = page_pa | P18_PAGE_FLAGS

    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return l3_index


# Clear the live L3 mapping for anon VA `va` (used by the partial munmap to carve
# out the middle page). Break-only: zero the descriptor and flush so a later EL0
# touch genuinely translation-faults. Does NOT touch the surrounding pages.
def arm64_mp_unmap_page(va: uint64) -> int64:
    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P18_L3)
    l3[cast[int64](l3_index)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Walk the VMA table: return 1 iff `va` (page-aligned) lies inside SOME live slot's
# [base, base+len) span, else 0. This is the heart of Phase 18 — a real (small)
# VMA table, not a single latched span, so the split can leave a covered HOLE.
def arm64_mp_va_covered(va: uint64) -> int64:
    s: int64 = 0
    while cast[uint64](s) < P18_VMA_SLOTS:
        if arm64_mp_vma_live[s] != 0:
            base: uint64 = arm64_mp_vma_base[s]
            ln: uint64 = arm64_mp_vma_len[s]
            if va >= base:
                if va < (base + ln):
                    return 1
        s = s + 1
    return 0


# Phase-18 fault entry. Called from arm64_sync_handler for a data abort from EL0
# while the multi-page demo is live. Honours ONLY a TRANSLATION fault for a VA
# covered by a live VMA slot: demand-maps that page's fresh RW backing store and
# returns 1 so EL0 resumes its store. Returns 0 otherwise — in particular for a VA
# in the carved-out hole (no live slot), which the caller turns into a SIGSEGV.
def arm64_mp_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0                          # not a translation fault

    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    if arm64_mp_va_covered(page_va) == 0:
        return 0                          # in no live VMA slot (e.g. the hole)

    arm64_mp_map_page(page_va)
    arm64_mp_paged = 1
    arm64_mp_faults = arm64_mp_faults + 1
    m: Ptr[char] = "[arm64] multipage demand fault: paged in anon VA "
    _uart_puts(m)
    _uart_puthex(page_va)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    return 1


# Phase-18 fatal-fault path. Reached when arm64_mp_try_fault declines a data abort
# while the multi-page demo is live — i.e. EL0 touched a VA covered by NO live VMA
# slot (the carved-out middle page after the partial munmap split). Exactly a Linux
# SIGSEGV. Latch it and run the Phase-18 verdict. Never returns.
def arm64_mp_reap(esr: uint64) -> int64:
    far: uint64 = cast[uint64](_mrs_far_el1())
    elr: uint64 = cast[uint64](_mrs_elr_el1())

    m: Ptr[char] = "[arm64] multipage hole fault at VA "
    _uart_puts(m)
    _uart_puthex(far)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    pcm: Ptr[char] = "[arm64] multipage SIGSEGV PC (ELR_EL1)="
    _uart_puts(pcm)
    _uart_puthex(elr)
    _uart_puts(nl)

    # The hole is only valid as a SIGSEGV once the split has happened.
    if arm64_mp_split != 0:
        arm64_mp_segv = 1
        seg: Ptr[char] = "[arm64] multipage touch of unmapped hole denied (no VMA)\n"
        _uart_puts(seg)
    arm64_mp_finish()
    # Unreachable: arm64_mp_finish halts. Safety loop if it falls through.
    while True:
        _wfi()
    return 0


# Materialise the Phase-18 EL0 routine into USER_CODE_BASE:
#   mmap(3*4KiB): x0=len; x8=222; svc #0       -> x0 = anon base (== P18_MMAP_BASE)
#   x10 = base
#   str s0,[x10+0x0000]   -> translation fault page 0; kernel demand-maps page 0
#   str s1,[x10+0x1000]   -> translation fault page 1; kernel demand-maps page 1
#   str s2,[x10+0x2000]   -> translation fault page 2; kernel demand-maps page 2
#   ldr each back; report(r0,r1,r2): x0,x1,x2; x8=544; svc #0
#   munmap(base+0x1000, 4KiB): x0; x1; x8=215; svc #0   -> SPLITS the VMA
#   ldr base+0; ldr base+0x2000; survive(r0,r2): x0,x1; x8=545; svc #0
#   write(1,msg,len): x8=64; svc #0
#   str s3,[x10+0x1000]   -> translation fault in the HOLE -> SIGSEGV (reaper)
# We reuse the scaled unsigned-offset STR/LDR encodings: the imm12 is the byte
# offset >> 3 (8-byte access scale). offsets 0,0x1000,0x2000 -> imm12 0,512,1024.
def arm64_build_multipage_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE

    # mmap(len): x0 = len; x8 = 222; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P18_MMAP_LEN)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MMAP_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x10 = base (== P18_MMAP_BASE)
    a = _emit_load_imm64(a, cast[uint64](10), P18_MMAP_BASE)

    # str s0,[x10+#0]    (imm12 = 0)   -- FAULTS page 0, demand-maps it
    a = _emit_load_imm64(a, cast[uint64](9), P18_SENTINEL0)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](0) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # str s1,[x10+#0x1000]  (imm12 = 0x1000>>3 = 512) -- FAULTS page 1
    a = _emit_load_imm64(a, cast[uint64](9), P18_SENTINEL1)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](512) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # str s2,[x10+#0x2000]  (imm12 = 0x2000>>3 = 1024) -- FAULTS page 2
    a = _emit_load_imm64(a, cast[uint64](9), P18_SENTINEL2)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](1024) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # ldr x0,[x10+#0]; ldr x1,[x10+#0x1000]; ldr x2,[x10+#0x2000]
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](0) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](512) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](1))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](1024) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](2))
    # report(x0,x1,x2): x8 = 544; svc #0  (x0..x2 already hold the read-backs)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MP_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # munmap(base+0x1000, 4KiB): x0 = base+0x1000; x1 = 0x1000; x8 = 215; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P18_MMAP_BASE + cast[uint64](0x1000))
    a = _emit_load_imm64(a, cast[uint64](1), cast[uint64](0x1000))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MUNMAP_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # ldr x0,[x10+#0]; ldr x1,[x10+#0x2000]   (the two SURVIVING pages)
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](0) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](1024) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](1))
    # survive(x0,x1): x8 = 545; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_MP_SURVIVE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 64; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), P18_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # str s3,[x10+#0x1000]   (HOLE -> translation fault, NO live VMA -> reaper)
    a = _emit_load_imm64(a, cast[uint64](9), P18_SENTINEL3)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](512) << cast[uint64](10)) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # exit(0): only reached if the hole store were (wrongly) allowed
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-18 syscall dispatcher. Routed from arm64_sync_handler while the multi-page
# demo is live. Services mmap (record ONE whole-span VMA + return base), the pre-
# munmap report (verify the three demand-paged read-backs landed in three distinct
# pages), munmap (the PARTIAL middle-page unmap that SPLITS the VMA), the survive
# report (the two surviving pages stayed mapped), write, and a defensive exit.
def arm64_mp_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_MMAP_NR:
        # Anonymous multi-page mmap: record ONE VMA [base, base+len) in slot 0; the
        # other slots stay empty until the split. No page mapped here — lazy.
        arm64_mp_vma_base[0] = P18_MMAP_BASE
        arm64_mp_vma_len[0] = a0
        arm64_mp_vma_live[0] = 1
        s: int64 = 1
        while cast[uint64](s) < P18_VMA_SLOTS:
            arm64_mp_vma_base[s] = cast[uint64](0)
            arm64_mp_vma_len[s] = cast[uint64](0)
            arm64_mp_vma_live[s] = 0
            s = s + 1
        m: Ptr[char] = "[arm64] EL0 mmap(anon multi, len="
        _uart_puts(m)
        _uart_puthex(a0)
        sep: Ptr[char] = ") -> base "
        _uart_puts(sep)
        _uart_puthex(P18_MMAP_BASE)
        _uart_puts(nl)
        frame_ptr[0] = P18_MMAP_BASE
        return 0

    if nr == SYS_MP_REPORT_NR:
        arm64_mp_rd0 = a0
        arm64_mp_rd1 = a1
        arm64_mp_rd2 = a2
        r: Ptr[char] = "[arm64] EL0 multipage read-back p0="
        _uart_puts(r)
        _uart_puthex(a0)
        r1: Ptr[char] = " p1="
        _uart_puts(r1)
        _uart_puthex(a1)
        r2: Ptr[char] = " p2="
        _uart_puts(r2)
        _uart_puthex(a2)
        _uart_puts(nl)
        # Independently confirm each backing physical page holds its sentinel — and
        # that the three pages are DISTINCT (page 1 differs from pages 0/2).
        b0: Ptr[uint64] = cast[Ptr[uint64]](P18_PAGE0)
        b1: Ptr[uint64] = cast[Ptr[uint64]](P18_PAGE1)
        b2: Ptr[uint64] = cast[Ptr[uint64]](P18_PAGE2)
        pm: Ptr[char] = "[arm64] multipage backing phys p0="
        _uart_puts(pm)
        _uart_puthex(b0[0])
        pm1: Ptr[char] = " p1="
        _uart_puts(pm1)
        _uart_puthex(b1[0])
        pm2: Ptr[char] = " p2="
        _uart_puts(pm2)
        _uart_puthex(b2[0])
        _uart_puts(nl)
        good: int64 = 0
        if a0 == P18_SENTINEL0:
            if a1 == P18_SENTINEL1:
                if a2 == P18_SENTINEL2:
                    if b0[0] == P18_SENTINEL0:
                        if b1[0] == P18_SENTINEL1:
                            if b2[0] == P18_SENTINEL2:
                                good = 1
        if good != 0:
            ok: Ptr[char] = "[arm64] multipage 3-page demand store/load OK\n"
            _uart_puts(ok)
        else:
            bad: Ptr[char] = "[arm64] multipage read-back mismatch FAIL\n"
            _uart_puts(bad)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_MUNMAP_NR:
        # PARTIAL munmap of the MIDDLE page: clear its L3 entry AND split the single
        # VMA (slot 0) into the LOW survivor [base, addr) plus the HIGH survivor
        # [addr+len, base+orig_len). The middle [addr, addr+len) becomes a hole.
        m: Ptr[char] = "[arm64] EL0 munmap(partial, addr="
        _uart_puts(m)
        _uart_puthex(a0)
        sep: Ptr[char] = ", len="
        _uart_puts(sep)
        _uart_puthex(a1)
        _uart_puts(nl)

        orig_base: uint64 = arm64_mp_vma_base[0]
        orig_len: uint64 = arm64_mp_vma_len[0]
        orig_end: uint64 = orig_base + orig_len
        hole_end: uint64 = a0 + a1

        # Drop the physical mapping for the carved-out middle page so a later touch
        # genuinely translation-faults.
        arm64_mp_unmap_page(a0)

        # Rewrite the VMA table: slot 0 becomes the LOW survivor, slot 1 the HIGH
        # survivor. If a survivor is empty (zero length) leave its slot dead.
        low_len: uint64 = a0 - orig_base
        if low_len != cast[uint64](0):
            arm64_mp_vma_base[0] = orig_base
            arm64_mp_vma_len[0] = low_len
            arm64_mp_vma_live[0] = 1
        else:
            arm64_mp_vma_live[0] = 0

        high_len: uint64 = orig_end - hole_end
        if high_len != cast[uint64](0):
            arm64_mp_vma_base[1] = hole_end
            arm64_mp_vma_len[1] = high_len
            arm64_mp_vma_live[1] = 1
        else:
            arm64_mp_vma_live[1] = 0

        arm64_mp_split = 1
        sp: Ptr[char] = "[arm64] munmap split VMA: low [base,hole) + high [hole_end,end)\n"
        _uart_puts(sp)
        lo: Ptr[char] = "[arm64] multipage VMA split survivors low_base="
        _uart_puts(lo)
        _uart_puthex(orig_base)
        lo2: Ptr[char] = " low_len="
        _uart_puts(lo2)
        _uart_puthex(low_len)
        hi: Ptr[char] = " high_base="
        _uart_puts(hi)
        _uart_puthex(hole_end)
        hi2: Ptr[char] = " high_len="
        _uart_puts(hi2)
        _uart_puthex(high_len)
        _uart_puts(nl)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_MP_SURVIVE_NR:
        arm64_mp_surv0 = a0
        arm64_mp_surv2 = a1
        r: Ptr[char] = "[arm64] EL0 post-split survivors p0="
        _uart_puts(r)
        _uart_puthex(a0)
        r2: Ptr[char] = " p2="
        _uart_puts(r2)
        _uart_puthex(a1)
        _uart_puts(nl)
        if a0 == P18_SENTINEL0:
            if a1 == P18_SENTINEL2:
                ok: Ptr[char] = "[arm64] multipage split survivors still mapped OK\n"
                _uart_puts(ok)
            else:
                bad: Ptr[char] = "[arm64] multipage survivor mismatch FAIL\n"
                _uart_puts(bad)
        else:
            bad2: Ptr[char] = "[arm64] multipage survivor mismatch FAIL\n"
            _uart_puts(bad2)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(18) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_EXIT_NR:
        # Reached only if the post-split HOLE store were (wrongly) allowed instead of
        # faulting. The verdict will FAIL because arm64_mp_segv stays 0.
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit(18) serviced (hole store did NOT fault!)\n"
        _uart_puts(em)
        arm64_mp_finish()
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 18)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-18 finish: print PASS iff all three anon pages were demand-paged (EXACTLY
# three translation faults), the three pre-munmap read-backs matched their distinct
# sentinels, the partial munmap SPLIT the VMA, the two surviving pages stayed mapped
# (read-backs matched), AND the post-split touch of the carved hole faulted with no
# live VMA. Report the fault count, then halt deterministically. Never returns.
def arm64_mp_finish() -> int64:
    arm64_mp_active = 0
    nl: Ptr[char] = "\n"
    fc: Ptr[char] = "[arm64] multipage demand faults serviced -> "
    _uart_puts(fc)
    _uart_puthex(cast[uint64](arm64_mp_faults))
    _uart_puts(nl)

    ok: int64 = 0
    if arm64_mp_paged != 0:
        if arm64_mp_faults == 3:
            if arm64_mp_rd0 == P18_SENTINEL0:
                if arm64_mp_rd1 == P18_SENTINEL1:
                    if arm64_mp_rd2 == P18_SENTINEL2:
                        if arm64_mp_split != 0:
                            if arm64_mp_surv0 == P18_SENTINEL0:
                                if arm64_mp_surv2 == P18_SENTINEL2:
                                    if arm64_mp_segv != 0:
                                        ok = 1
    if ok != 0:
        sm: Ptr[char] = "[arm64] multipage mmap split; survivors mapped, hole faults\n"
        _uart_puts(sm)
        pm: Ptr[char] = "[arm64] EL0 multipage mmap split OK\n"
        _uart_puts(pm)
        # Phase 18 complete and clean. Hand off to Phase 19 (two preemptively-
        # scheduled EL0 tasks, each in its OWN TTBR0_EL1 address space + ASID, with
        # the timer-IRQ context switch swapping TTBR0+ASID as well as registers).
        # IRQs are masked here; arm64_run_dualspace_demo re-enables the timer and
        # never returns (it halts after its own PASS).
        arm64_run_dualspace_demo()
        # Unreachable: arm64_run_dualspace_demo never returns. Safety loop.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 multipage mmap split FAIL\n"
        _uart_puts(fm)
    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-18 entry point (invoked from the Phase-17 finish hand-off). Restore the
# kernel's identity TTBR0, force the multi-page window's L2 slot UNMAPPED (so the
# first touch of each page genuinely translation-faults), seed bookkeeping, build
# the EL0 routine, arm Phase-18 dispatch, and ERET into the task at EL0t with IRQs
# masked. Never returns (the task faults fatally in the hole, handing to the reaper).
def arm64_run_multipage_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 18: multi-page mmap + partial munmap that splits a VMA\n"
    _uart_puts(intro)

    # Restore the kernel's identity-only TTBR0, then flush for a clean state.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Force the multi-page window's L2 slot UNMAPPED so the first touch of each page
    # raises a translation Data Abort (a clean, repeatable initial state).
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P18_MMAP_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Seed Phase-18 bookkeeping (empty VMA table + cleared latches/counters).
    s: int64 = 0
    while cast[uint64](s) < P18_VMA_SLOTS:
        arm64_mp_vma_base[s] = cast[uint64](0)
        arm64_mp_vma_len[s] = cast[uint64](0)
        arm64_mp_vma_live[s] = 0
        s = s + 1
    arm64_mp_faults = 0
    arm64_mp_paged = 0
    arm64_mp_split = 0
    arm64_mp_rd0 = cast[uint64](0)
    arm64_mp_rd1 = cast[uint64](0)
    arm64_mp_rd2 = cast[uint64](0)
    arm64_mp_surv0 = cast[uint64](0)
    arm64_mp_surv2 = cast[uint64](0)
    arm64_mp_segv = 0

    mpmsg: Ptr[char] = "Hello from a multi-page anonymous mmap region\n"
    msg_len: uint64 = _copy_msg_to(mpmsg, P18_MSG_BASE)
    arm64_build_multipage_routine(msg_len)

    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_mp_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 multi-page mmap task\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; mmap, touch 3 pages (faults), report,
    return 0                           #    partial munmap (split), survive, hole-fault


# ===========================================================================
# Phase 19 — two preemptively-scheduled EL0 tasks, EACH with its OWN TTBR0_EL1
# address space + ASID; the timer-IRQ context switch swaps TTBR0+ASID too.
# ===========================================================================

# Build one task-private address space at (l1_base, l2_base): a full clone of the
# kernel identity map (so the EL0 code window stays fetchable and the kernel stays
# mapped EL1-only) plus an EL0-RWX mapping of P19_SHARED_VA -> this task's PRIVATE
# physical block. Seeds `sentinel` into byte 0 of that block (written through the
# boot identity map, which is still live). data_pa must be 2 MiB-aligned. Mirrors
# arm64_iso_build_space but for the Phase-19 shared VA / L2 slot.
def arm64_p19_build_space(l1_base: uint64, l2_base: uint64, data_pa: uint64, sentinel: uint64) -> int64:
    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    # Zero the L1 table (anything unmapped faults).
    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1

    # L1[0]: VA 0x0..0x3FFF_FFFF -> Device-nGnRE (GIC + UART), EL1-only.
    l1[0] = cast[uint64](0) | DEV_FLAGS

    # L2 covering the RAM 1 GiB block in 2 MiB pieces. Most blocks Normal-WB
    # EL1-only; the EL0 code/stack window (USER_L2_INDEX) is EL0-RWX (so each
    # task's instruction pages + stacks remain reachable under its own TTBR0);
    # the shared-VA block is EL0-RWX but mapped to this task's PRIVATE physical
    # block (the per-task isolation linchpin).
    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0
        elif cast[uint64](j) == P19_SHARED_L2_INDEX:
            l2[j] = data_pa | MEM_FLAGS_EL0
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    # L1[1] = table descriptor -> this task's L2 table.
    l1[1] = l2_base | DESC_TABLE

    # Seed the private data block's sentinel (byte 0) through the boot identity map.
    dp: Ptr[uint8] = cast[Ptr[uint8]](data_pa)
    dp[0] = cast[uint8](sentinel & cast[uint64](0xFF))
    _dsb_ish()
    return 0


# Materialise a Phase-19 EL0 task into `code_base`:
#   loop:
#     x1 = P19_SHARED_VA ; ldrb w0,[x1]    (read this task's private sentinel)
#     x8 = 546 (dual-space report) ; svc #0 (hand the byte to the kernel)
#     x9 = busy ; busy: subs x9,x9,#1 ; b.ne busy
#     b loop
# The report syscall RETURNS to EL0 (unlike Phase 7) so the task keeps looping and
# the timer keeps preempting it. Control only leaves via the preemptive timer IRQ.
def arm64_p19_build_task(code_base: uint64) -> int64:
    a: uint64 = code_base
    loop_top: uint64 = a

    # x1 = P19_SHARED_VA ; ldrb w0,[x1]   (LDRB imm, unsigned offset 0, Wt=0, Xn=1)
    a = _emit_load_imm64(a, cast[uint64](1), P19_SHARED_VA)
    a = _emit_word(a, cast[uint64](0x39400020))
    # x8 = 546 ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P19_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x9 = 0x40000 busy-loop counter (movz x9,#0x4,lsl #16).
    movz_x9: uint64 = cast[uint64](0xD2800000) | (cast[uint64](1) << cast[uint64](21)) | (cast[uint64](4) << cast[uint64](5)) | cast[uint64](9)
    a = _emit_word(a, movz_x9)
    busy_top: uint64 = a
    a = _emit_word(a, cast[uint64](0xF1000529))             # subs x9,x9,#1
    bne_here: uint64 = a
    off_busy: int64 = cast[int64](busy_top) - cast[int64](bne_here)
    imm19_busy: uint64 = cast[uint64](off_busy >> 2) & cast[uint64](0x7FFFF)
    a = _emit_word(a, cast[uint64](0x54000001) | (imm19_busy << cast[uint64](5)))   # b.ne busy

    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)     # b loop

    _dsb_ish()
    _isb()
    return 0


# Compute the TTBR0_EL1 value for task `idx`: the task's private L1 root with its
# ASID baked into bits[63:48]. Distinct ASIDs let both tasks' translations coexist
# in the TLB so a swap needs no broad flush.
def arm64_p19_ttbr0_for(idx: int64) -> uint64:
    if idx == 0:
        return P19_A_L1 | (P19_ASID_A << P19_ASID_SHIFT)
    return P19_B_L1 | (P19_ASID_B << P19_ASID_SHIFT)


# Switch the live address space to task `idx`: point TTBR0_EL1 at its private root
# WITH its ASID, then isb to resynchronise. CRUCIALLY there is NO `tlbi vmalle1is`
# here — the per-ASID tagging is what keeps the two tasks' translations of the
# SAME shared VA distinct. dsb orders the prior table writes before the TTBR0
# write; isb makes the new context effective for the subsequent EL0 fetches/loads.
def arm64_p19_switch_to(idx: int64) -> int64:
    ttbr0: uint64 = arm64_p19_ttbr0_for(idx)
    _dsb_ish()
    _msr_ttbr0_el1(ttbr0)
    _isb()
    return 0


# Phase-19 IRQ scheduler — invoked (via arm64_sched_pick) from the EL0 IRQ vector
# with the running task's register context already saved into its context block.
# Ack + re-arm the timer, round-robin to the OTHER task, swap TTBR0+ASID to that
# task's PRIVATE address space (no broad TLB flush — ASID-tagged), publish its
# context block as current, and return it so the .S stub restores+erets into it.
# After P19_GOAL swaps the demo's invariant (every read stayed private) is proven;
# run the verdict (never returns).
def arm64_p19_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this task
        return cur_ctx

    # Quiesce, re-arm, and EOI the timer.
    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_p19_swaps = arm64_p19_swaps + 1
    swmsg: Ptr[char] = "[arm64] dualspace TTBR0+ASID swap\n"
    _uart_puts(swmsg)

    if arm64_p19_swaps >= P19_GOAL:
        arm64_p19_finish()
        # Unreachable: arm64_p19_finish halts. Safety loop.
        while True:
            _wfi()

    # Round-robin to the other task and swap into its private address space.
    next_ctx: uint64 = P19_B_CTX
    if arm64_p19_cur == 0:
        arm64_p19_cur = 1
        next_ctx = P19_B_CTX
    else:
        arm64_p19_cur = 0
        next_ctx = P19_A_CTX

    arm64_p19_switch_to(arm64_p19_cur)      # TTBR0+ASID -> the incoming task
    arm64_current_ctx = next_ctx            # publish for the next preemption
    return next_ctx


# Phase-19 syscall dispatcher. Routed from arm64_sync_handler while the dual-space
# demo is live. Services the per-task "dual-space report": the byte the running
# task read at P19_SHARED_VA through its OWN TTBR0+ASID. Tally a CORRECT read (the
# task's own sentinel) or a LEAK (the OTHER task's sentinel — would mean an ASID-
# untagged stale TLB entry leaked across the swap). Returns 0 so EL0 resumes its
# loop (the timer, not this syscall, drives the context switches).
def arm64_p19_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P19_REPORT_NR:
        arm64_p19_reports = arm64_p19_reports + 1
        val: uint64 = a0 & cast[uint64](0xFF)
        if arm64_p19_cur == 0:
            # Task A: its own sentinel is A; B's sentinel is a cross-task leak.
            if val == P19_SENTINEL_A:
                arm64_p19_a_correct = arm64_p19_a_correct + 1
            elif val == P19_SENTINEL_B:
                arm64_p19_leaks = arm64_p19_leaks + 1
                lk: Ptr[char] = "[arm64] dualspace LEAK: task A read B's sentinel FAIL\n"
                _uart_puts(lk)
        else:
            if val == P19_SENTINEL_B:
                arm64_p19_b_correct = arm64_p19_b_correct + 1
            elif val == P19_SENTINEL_A:
                arm64_p19_leaks = arm64_p19_leaks + 1
                lk2: Ptr[char] = "[arm64] dualspace LEAK: task B read A's sentinel FAIL\n"
                _uart_puts(lk2)
        # Trace the FIRST report from each task (so the log shows BOTH A and B
        # reading their private sentinel through their own TTBR0+ASID), keeping the
        # rest of the busy-loop's reports out of the log.
        trace: int64 = 0
        if arm64_p19_cur == 0:
            if arm64_p19_a_correct == 1:
                trace = 1
        else:
            if arm64_p19_b_correct == 1:
                trace = 1
        if trace != 0:
            r: Ptr[char] = "[arm64] dualspace report: task "
            _uart_puts(r)
            _uart_puthex(cast[uint64](arm64_p19_cur))
            rv: Ptr[char] = " read VA value="
            _uart_puts(rv)
            _uart_puthex(val)
            _uart_puts(nl)
        frame_ptr[0] = cast[uint64](0)
        return 0

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 19)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-19 verdict. Reached from the scheduler once P19_GOAL TTBR0+ASID swaps have
# happened. PASS iff BOTH tasks actually ran (each reported its own sentinel at
# least once) AND zero cross-task leaks occurred — i.e. across every preemptive
# swap each task's private translation of the SHARED VA stayed private, proving
# ASID-tagged dual-address-space multitasking. Print the tallies, then halt.
def arm64_p19_finish() -> int64:
    arm64_p19_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] dualspace swaps="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p19_swaps))
    am: Ptr[char] = " a_correct="
    _uart_puts(am)
    _uart_puthex(cast[uint64](arm64_p19_a_correct))
    bm: Ptr[char] = " b_correct="
    _uart_puts(bm)
    _uart_puthex(cast[uint64](arm64_p19_b_correct))
    lm: Ptr[char] = " leaks="
    _uart_puts(lm)
    _uart_puthex(cast[uint64](arm64_p19_leaks))
    _uart_puts(nl)

    ok: int64 = 0
    if arm64_p19_a_correct > 0:
        if arm64_p19_b_correct > 0:
            if arm64_p19_leaks == 0:
                ok = 1
    if ok != 0:
        em: Ptr[char] = "[arm64] dualspace both tasks ran private; ASID isolation held\n"
        _uart_puts(em)
        pm: Ptr[char] = "[arm64] EL0 dual-address-space ASID sched OK\n"
        _uart_puts(pm)
        # Phase 19 complete and clean. Hand off to Phase 20 (dynamic task spawn +
        # exit/reaping). IRQs are masked here; arm64_run_spawn_demo re-enables the
        # timer and ERETs into the first task; it never returns.
        arm64_run_spawn_demo()
        # Unreachable: arm64_run_spawn_demo never returns. Safety halt.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 dual-address-space ASID sched FAIL\n"
        _uart_puts(fm)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-19 entry point (invoked from the Phase-18 finish hand-off). Build both
# task-private address spaces (+ seed sentinels), the two EL0 task routines, and
# their context blocks; flush any stale translations for BOTH ASIDs once; then
# ERET into task A under its private TTBR0+ASID with the timer LIVE so the IRQ
# scheduler round-robins the two tasks, swapping TTBR0+ASID on every tick. Never
# returns (the scheduler halts after its own PASS).
def arm64_run_dualspace_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 19: dual-address-space preemptive scheduling with per-task ASID\n"
    _uart_puts(intro)

    # Mask EL1 IRQs while we build everything so a stray timer IRQ cannot run the
    # scheduler mid-setup; re-enable just before the ERET into task A.
    _msr_daifset(2)

    # Build the two private address spaces (clone identity + private shared-VA map)
    # and seed their distinct sentinels.
    arm64_p19_build_space(P19_A_L1, P19_A_L2, P19_A_DATA, P19_SENTINEL_A)
    arm64_p19_build_space(P19_B_L1, P19_B_L2, P19_B_DATA, P19_SENTINEL_B)

    # Build the two EL0 task routines (read-private-sentinel + report + busy-loop).
    arm64_p19_build_task(P19_A_CODE)
    arm64_p19_build_task(P19_B_CODE)

    # Initialise each task's context block to start cleanly at its code entry, on
    # its own stack, in EL0t with IRQs UNMASKED (so the timer preempts it).
    arm64_init_ctx(P19_A_CTX, P19_A_CODE, P19_A_STACK_TOP)
    arm64_init_ctx(P19_B_CTX, P19_B_CODE, P19_B_STACK_TOP)

    # Clear any stale TLB entries for BOTH ASIDs before first use (recycling clean
    # ASIDs), then seed bookkeeping. The per-ASID invalidate is the maintenance a
    # real scheduler does when it (re)assigns an ASID; thereafter swaps need none.
    _dsb_ish()
    _tlbi_aside1is(P19_ASID_A << P19_ASID_SHIFT)
    _tlbi_aside1is(P19_ASID_B << P19_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p19_cur = 0
    arm64_p19_swaps = 0
    arm64_p19_a_correct = 0
    arm64_p19_b_correct = 0
    arm64_p19_leaks = 0
    arm64_p19_reports = 0
    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_current_ctx = P19_A_CTX
    arm64_p19_active = 1

    enter: Ptr[char] = "[arm64] launching dual-address-space EL0 tasks (ASID A=1, B=2)\n"
    _uart_puts(enter)

    # Switch into task A's private address space (TTBR0+ASID A), re-arm + enable the
    # timer, unmask EL1 IRQs, then ERET into task A at EL0t with IRQs unmasked.
    arm64_p19_switch_to(0)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](P19_A_CTX)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> task A at EL0 under TTBR0+ASID A
    return 0


# ===========================================================================
# Phase 20 — DYNAMIC TASK SPAWN + EXIT/REAPING on aarch64.
# ===========================================================================

# Per-slot accessors. Adder has no arrays-of-globals, so route the slot index to
# the slot's fixed constant. (Kept tiny and branchy on purpose — three slots.)
def arm64_p20_l1_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_A_L1
    if idx == 1:
        return P20_B_L1
    return P20_C_L1

def arm64_p20_l2_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_A_L2
    if idx == 1:
        return P20_B_L2
    return P20_C_L2

def arm64_p20_data_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_A_DATA
    if idx == 1:
        return P20_B_DATA
    return P20_C_DATA

def arm64_p20_sentinel_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_SENTINEL_A
    if idx == 1:
        return P20_SENTINEL_B
    return P20_SENTINEL_C

def arm64_p20_asid_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_ASID_A
    if idx == 1:
        return P20_ASID_B
    return P20_ASID_C

def arm64_p20_code_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_A_CODE
    if idx == 1:
        return P20_B_CODE
    return P20_C_CODE

def arm64_p20_stack_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_A_STACK_TOP
    if idx == 1:
        return P20_B_STACK_TOP
    return P20_C_STACK_TOP

def arm64_p20_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P20_A_CTX
    if idx == 1:
        return P20_B_CTX
    return P20_C_CTX

def arm64_p20_state_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p20_state0
    if idx == 1:
        return arm64_p20_state1
    return arm64_p20_state2

def arm64_p20_set_state(idx: int64, st: int64) -> int64:
    if idx == 0:
        arm64_p20_state0 = st
    elif idx == 1:
        arm64_p20_state1 = st
    else:
        arm64_p20_state2 = st
    return 0


# Build slot `idx`'s private address space at its (l1,l2): a full clone of the
# kernel identity map (EL0 code/stack window stays fetchable, kernel stays EL1-
# only) plus an EL0-RWX mapping of P20_SHARED_VA -> this slot's PRIVATE physical
# block, seeded (byte 0) with the slot's sentinel through the boot identity map.
def arm64_p20_build_space(idx: int64) -> int64:
    l1_base: uint64 = arm64_p20_l1_for(idx)
    l2_base: uint64 = arm64_p20_l2_for(idx)
    data_pa: uint64 = arm64_p20_data_for(idx)
    sentinel: uint64 = arm64_p20_sentinel_for(idx)

    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1

    # L1[0]: device window (GIC + UART), EL1-only.
    l1[0] = cast[uint64](0) | DEV_FLAGS

    # L2 for the RAM 1 GiB block: most EL1-only Normal-WB; the EL0 code/stack
    # window EL0-RWX; the shared-VA block EL0-RWX -> this slot's PRIVATE block.
    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0
        elif cast[uint64](j) == P20_SHARED_L2_INDEX:
            l2[j] = data_pa | MEM_FLAGS_EL0
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = l2_base | DESC_TABLE

    dp: Ptr[uint8] = cast[Ptr[uint8]](data_pa)
    dp[0] = cast[uint8](sentinel & cast[uint64](0xFF))
    _dsb_ish()
    return 0


# Materialise slot `idx`'s EL0 routine:
#   loop:
#     x1 = P20_SHARED_VA ; ldrb w0,[x1]           (read this slot's private byte)
#     x8 = 547 (tick) ; svc #0                    (hand the byte to the kernel)
#     busy-loop
#     b loop
# Every slot's emitted routine is the same self-looping read+report+busy body. A
# slot that should EXIT (slot A) is steered into an exit stub kernel-side once its
# report count reaches the threshold (see arm64_p20_dispatch / _redirect_to_exit),
# so the routine itself needs no exit logic baked in.
def arm64_p20_build_task(idx: int64) -> int64:
    code_base: uint64 = arm64_p20_code_for(idx)
    a: uint64 = code_base
    loop_top: uint64 = a

    # x1 = P20_SHARED_VA ; ldrb w0,[x1]  (LDRB imm, offset 0, Wt=0, Xn=1)
    a = _emit_load_imm64(a, cast[uint64](1), P20_SHARED_VA)
    a = _emit_word(a, cast[uint64](0x39400020))
    # x8 = 547 (tick) ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P20_TICK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x9 = 0x40000 busy-loop counter (movz x9,#0x4,lsl #16).
    movz_x9: uint64 = cast[uint64](0xD2800000) | (cast[uint64](1) << cast[uint64](21)) | (cast[uint64](4) << cast[uint64](5)) | cast[uint64](9)
    a = _emit_word(a, movz_x9)
    busy_top: uint64 = a
    a = _emit_word(a, cast[uint64](0xF1000529))             # subs x9,x9,#1
    bne_here: uint64 = a
    off_busy: int64 = cast[int64](busy_top) - cast[int64](bne_here)
    imm19_busy: uint64 = cast[uint64](off_busy >> 2) & cast[uint64](0x7FFFF)
    a = _emit_word(a, cast[uint64](0x54000001) | (imm19_busy << cast[uint64](5)))  # b.ne busy

    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)     # b loop

    _dsb_ish()
    _isb()
    return 0


# TTBR0_EL1 for slot `idx`: its private L1 root with its ASID in bits[63:48].
def arm64_p20_ttbr0_for(idx: int64) -> uint64:
    return arm64_p20_l1_for(idx) | (arm64_p20_asid_for(idx) << P20_ASID_SHIFT)


# Switch the live address space to slot `idx` (TTBR0+ASID). No broad TLB flush —
# per-ASID tagging keeps each slot's translation of the shared VA distinct.
def arm64_p20_switch_to(idx: int64) -> int64:
    _dsb_ish()
    _msr_ttbr0_el1(arm64_p20_ttbr0_for(idx))
    _isb()
    return 0


# Pick the next RUNNABLE slot after `from_idx`, round-robin over slots 0..2,
# skipping EMPTY and REAPED slots. Returns -1 if no slot is runnable.
def arm64_p20_next_runnable(from_idx: int64) -> int64:
    steps: int64 = 0
    idx: int64 = from_idx
    while steps < 3:
        idx = idx + 1
        if idx >= 3:
            idx = 0
        if arm64_p20_state_for(idx) == P20_SLOT_RUNNABLE:
            return idx
        steps = steps + 1
    return -1


# Dynamically spawn slot C at runtime: build its brand-new private address space
# (+ seed sentinel C), a fresh EL0 routine, a fresh context block, recycle ASID C's
# TLB, and mark the slot RUNNABLE. This is the fork-like creation — nothing about
# slot C existed before this call; it is wired up entirely after the demo started.
def arm64_p20_spawn_c() -> int64:
    sp: Ptr[char] = "[arm64] spawn: dynamically creating slot C (ASID 6) at runtime\n"
    _uart_puts(sp)

    arm64_p20_build_space(2)
    arm64_p20_build_task(2)
    arm64_init_ctx(arm64_p20_ctx_for(2), arm64_p20_code_for(2), arm64_p20_stack_for(2))

    # Recycle slot C's ASID in the TLB before first use, as a real scheduler does
    # when (re)assigning an ASID; thereafter swaps into C need no broad flush.
    _dsb_ish()
    _tlbi_aside1is(P20_ASID_C << P20_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p20_set_state(2, P20_SLOT_RUNNABLE)
    arm64_p20_c_spawned = 1
    arm64_p20_swaps_at_spawn = arm64_p20_swaps
    return 0


# Phase-20 IRQ scheduler — invoked (via arm64_sched_pick) from the EL0 IRQ vector
# with the running slot's register context already saved. Ack + re-arm the timer,
# then:
#   * if slot A has just been reaped and slot C has NOT yet been spawned, SPAWN C
#     dynamically (proving runtime task creation);
#   * round-robin to the next RUNNABLE slot, swapping TTBR0+ASID into its PRIVATE
#     space (no broad TLB flush — ASID-tagged), publish its ctx, and return it.
# After P20_GOAL swaps PAST the spawn the demo's invariants are checked; run the
# verdict (never returns).
def arm64_p20_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this slot
        return cur_ctx

    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_p20_swaps = arm64_p20_swaps + 1
    swmsg: Ptr[char] = "[arm64] spawn-demo TTBR0+ASID swap\n"
    _uart_puts(swmsg)

    # Once slot A has been reaped, dynamically spawn slot C (exactly once).
    if arm64_p20_a_reaped != 0:
        if arm64_p20_c_spawned == 0:
            arm64_p20_spawn_c()

    # Verdict once we have run enough swaps AFTER the spawn (so both the survivor B
    # and the freshly-spawned C have demonstrably run preemptively).
    if arm64_p20_c_spawned != 0:
        if (arm64_p20_swaps - arm64_p20_swaps_at_spawn) >= P20_GOAL:
            arm64_p20_finish()
            while True:
                _wfi()

    nxt: int64 = arm64_p20_next_runnable(arm64_p20_cur)
    if nxt < 0:
        # No runnable slot (should not happen while B is alive). Stay put.
        return cur_ctx

    arm64_p20_cur = nxt
    arm64_p20_switch_to(nxt)                 # TTBR0+ASID -> the incoming slot
    next_ctx: uint64 = arm64_p20_ctx_for(nxt)
    arm64_current_ctx = next_ctx
    return next_ctx


# Phase-20 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. Services:
#   SYS_P20_TICK_NR (547): the byte the running slot read at P20_SHARED_VA through
#       its OWN TTBR0+ASID. Tally a CORRECT read (own sentinel) or a LEAK (another
#       slot's sentinel). Slot A, after P20_A_EXIT_AT reports, is steered into an
#       exit stub (its eret ELR is rewritten so its NEXT EL0 instruction issues
#       exit(7)). Returns 0 so EL0 resumes (at the loop, or — for A past the
#       threshold — at the exit stub).
#   SYS_EXIT_NR (93): the running slot exits; mark its slot REAPED so the scheduler
#       never selects it again, then park its dead EL0 PC on a self-branch.
def arm64_p20_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P20_TICK_NR:
        val: uint64 = a0 & cast[uint64](0xFF)
        own: uint64 = arm64_p20_sentinel_for(arm64_p20_cur)

        # Tally correctness / leaks for the running slot.
        if arm64_p20_cur == 0:
            arm64_p20_a_reports = arm64_p20_a_reports + 1
            if val == own:
                arm64_p20_a_correct = arm64_p20_a_correct + 1
        elif arm64_p20_cur == 1:
            arm64_p20_b_reports = arm64_p20_b_reports + 1
            if val == own:
                arm64_p20_b_correct = arm64_p20_b_correct + 1
            if arm64_p20_c_spawned != 0:
                arm64_p20_b_after_spawn = arm64_p20_b_after_spawn + 1
        else:
            arm64_p20_c_reports = arm64_p20_c_reports + 1
            if val == own:
                arm64_p20_c_correct = arm64_p20_c_correct + 1

        # A read of a value that is neither this slot's own sentinel nor 0 is a
        # cross-task leak (a stale, ASID-untagged TLB entry resolving to another
        # slot's private block).
        if val != own:
            if val != cast[uint64](0):
                arm64_p20_leaks = arm64_p20_leaks + 1
                lk: Ptr[char] = "[arm64] spawn-demo LEAK: slot read another slot's sentinel FAIL\n"
                _uart_puts(lk)

        # Trace the FIRST correct report from each slot so the log shows A, B and
        # the dynamically-spawned C each reading their private sentinel.
        trace: int64 = 0
        if arm64_p20_cur == 0:
            if arm64_p20_a_correct == 1:
                trace = 1
        elif arm64_p20_cur == 1:
            if arm64_p20_b_correct == 1:
                trace = 1
        else:
            if arm64_p20_c_correct == 1:
                trace = 1
        if trace != 0:
            r: Ptr[char] = "[arm64] spawn-demo report: slot "
            _uart_puts(r)
            _uart_puthex(cast[uint64](arm64_p20_cur))
            rv: Ptr[char] = " read VA value="
            _uart_puts(rv)
            _uart_puthex(val)
            _uart_puts(nl)

        # Slot A exits after P20_A_EXIT_AT reports: redirect its EL0 PC to its exit
        # stub so its NEXT EL0 instruction issues exit(7), which we reap below.
        if arm64_p20_cur == 0:
            if arm64_p20_a_reports == P20_A_EXIT_AT:
                em: Ptr[char] = "[arm64] spawn-demo: slot A requesting exit(7)\n"
                _uart_puts(em)
                arm64_p20_redirect_to_exit(0, cast[uint64](7))

        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_EXIT_NR:
        # The running slot exits: reap it. The scheduler will never pick it again.
        code: int64 = cast[int64](a0)
        rm: Ptr[char] = "[arm64] spawn-demo: reaping slot "
        _uart_puts(rm)
        _uart_puthex(cast[uint64](arm64_p20_cur))
        cm: Ptr[char] = " exit code="
        _uart_puts(cm)
        _uart_puthex(cast[uint64](code))
        _uart_puts(nl)

        arm64_p20_set_state(arm64_p20_cur, P20_SLOT_REAPED)
        if arm64_p20_cur == 0:
            arm64_p20_a_reaped = 1
            arm64_p20_a_exit_code = code
        frame_ptr[0] = cast[uint64](0)
        # A reaped slot must NOT resume at EL0. Force a context switch now: pick the
        # next runnable slot and arm arm64_current_ctx so the IRQ stub will restore
        # the survivor — but the eret path here would resume the dead slot. Instead
        # we busy-yield: park the dead slot's PC on a wfe and let the timer preempt
        # to the survivor. Simpler + correct: spin the dead EL0 task on an infinite
        # self-branch (it will be preempted out next tick and never re-selected).
        arm64_p20_park_dead_el0()
        return 0

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 20)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Redirect slot `idx`'s EL0 execution to a freshly-emitted exit stub: x0=code,
# x8=93, svc #0. We patch the stub just past the slot's loop body and point the
# slot's SAVED ELR (in its ctx) — actually the LIVE ELR_EL1, since this slot is
# the running one — at the stub, so the NEXT EL0 instruction after this svc
# returns is the exit. Because we are servicing this slot's svc right now, the
# eret will resume at ELR_EL1; rewriting ELR_EL1 steers it to the stub.
def arm64_p20_redirect_to_exit(idx: int64, code: uint64) -> int64:
    # Emit the exit stub at a fixed offset inside the slot's code page (well past
    # its short loop body — 0x800 bytes in, same page, EL0-RWX).
    stub: uint64 = arm64_p20_code_for(idx) + cast[uint64](0x800)
    a: uint64 = stub
    a = _emit_load_imm64(a, cast[uint64](0), code)            # x0 = code
    a = _emit_load_imm64(a, cast[uint64](8), SYS_EXIT_NR)     # x8 = 93
    a = _emit_word(a, cast[uint64](0xD4000001))              # svc #0
    # Loop on itself afterwards (never reached — exit reaps first).
    a = _emit_word(a, cast[uint64](0x14000000))             # b . (offset 0)
    _dsb_ish()
    _isb()
    # Steer the running slot's eret target to the stub.
    _msr_elr_el1(stub)
    _isb()
    return 0


# Park the just-reaped slot's EL0 context on a harmless self-branch so that if it
# is ever (erroneously) eret-ed into, it merely spins until the timer preempts it
# to a runnable slot. We point the LIVE ELR_EL1 at a tiny "b ." stub in the dead
# slot's own EL0 page. The scheduler's runnable-only selection guarantees the dead
# slot is never picked again, so this is belt-and-suspenders.
def arm64_p20_park_dead_el0() -> int64:
    park: uint64 = arm64_p20_code_for(arm64_p20_cur) + cast[uint64](0xC00)
    _emit_word(park, cast[uint64](0x14000000))              # b . (self-loop)
    _dsb_ish()
    _isb()
    _msr_elr_el1(park)
    _isb()
    return 0


# Phase-20 verdict. PASS iff: slot A ran AND exited AND was reaped; slot B ran
# both BEFORE and AFTER the spawn (it survived the whole demo); slot C was
# DYNAMICALLY spawned at runtime AND ran in its own private ASID space; and ZERO
# cross-task sentinel leaks occurred. Print the tallies, then halt.
def arm64_p20_finish() -> int64:
    arm64_p20_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] spawn-demo swaps="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p20_swaps))
    am: Ptr[char] = " a_correct="
    _uart_puts(am)
    _uart_puthex(cast[uint64](arm64_p20_a_correct))
    bm: Ptr[char] = " b_correct="
    _uart_puts(bm)
    _uart_puthex(cast[uint64](arm64_p20_b_correct))
    cm: Ptr[char] = " c_correct="
    _uart_puts(cm)
    _uart_puthex(cast[uint64](arm64_p20_c_correct))
    rm: Ptr[char] = " a_reaped="
    _uart_puts(rm)
    _uart_puthex(cast[uint64](arm64_p20_a_reaped))
    spm: Ptr[char] = " c_spawned="
    _uart_puts(spm)
    _uart_puthex(cast[uint64](arm64_p20_c_spawned))
    bsm: Ptr[char] = " b_after_spawn="
    _uart_puts(bsm)
    _uart_puthex(cast[uint64](arm64_p20_b_after_spawn))
    lm: Ptr[char] = " leaks="
    _uart_puts(lm)
    _uart_puthex(cast[uint64](arm64_p20_leaks))
    _uart_puts(nl)

    ok: int64 = 1
    if arm64_p20_a_correct <= 0:
        ok = 0
    if arm64_p20_a_reaped == 0:
        ok = 0
    if arm64_p20_b_correct <= 0:
        ok = 0
    if arm64_p20_b_after_spawn <= 0:
        ok = 0
    if arm64_p20_c_spawned == 0:
        ok = 0
    if arm64_p20_c_correct <= 0:
        ok = 0
    if arm64_p20_leaks != 0:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] spawn-demo: slot A reaped, slot B survived, slot C dynamically spawned + ran\n"
        _uart_puts(rp)
        pm: Ptr[char] = "[arm64] EL0 dynamic spawn + exit/reaping OK\n"
        _uart_puts(pm)
        # Phase 20 complete and clean. Hand off to Phase 21 (a blocking primitive:
        # sys_nanosleep that DESCHEDULES a task and lets the scheduler run others
        # until a timer deadline wakes it). IRQs are masked here; the Phase-21 entry
        # re-enables the timer and ERETs into the first task; it never returns.
        arm64_run_sleep_demo()
        # Unreachable: arm64_run_sleep_demo never returns. Safety halt.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 dynamic spawn + exit/reaping FAIL\n"
        _uart_puts(fm)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-20 entry point (from the Phase-19 finish hand-off). Build slots A and B's
# private ASID-tagged address spaces + EL0 routines + context blocks; recycle both
# ASIDs once; mark A and B RUNNABLE and C EMPTY; then ERET into slot A under its
# private TTBR0+ASID with the timer LIVE. The IRQ scheduler round-robins the
# RUNNABLE slots, reaps A on its exit, dynamically spawns C, and round-robins
# {B,C}. Never returns (the scheduler halts after the verdict).
def arm64_run_spawn_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 20: dynamic task spawn + exit/reaping\n"
    _uart_puts(intro)

    # Mask EL1 IRQs while we build everything so a stray timer IRQ cannot run the
    # scheduler mid-setup; re-enable just before the ERET into slot A.
    _msr_daifset(2)

    arm64_p20_build_space(0)
    arm64_p20_build_space(1)
    arm64_p20_build_task(0)
    arm64_p20_build_task(1)
    arm64_init_ctx(arm64_p20_ctx_for(0), arm64_p20_code_for(0), arm64_p20_stack_for(0))
    arm64_init_ctx(arm64_p20_ctx_for(1), arm64_p20_code_for(1), arm64_p20_stack_for(1))

    # Recycle slots A and B's ASIDs before first use; C's ASID is recycled at spawn.
    _dsb_ish()
    _tlbi_aside1is(P20_ASID_A << P20_ASID_SHIFT)
    _tlbi_aside1is(P20_ASID_B << P20_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p20_cur = 0
    arm64_p20_set_state(0, P20_SLOT_RUNNABLE)
    arm64_p20_set_state(1, P20_SLOT_RUNNABLE)
    arm64_p20_set_state(2, P20_SLOT_EMPTY)
    arm64_p20_a_reports = 0
    arm64_p20_b_reports = 0
    arm64_p20_c_reports = 0
    arm64_p20_a_correct = 0
    arm64_p20_b_correct = 0
    arm64_p20_c_correct = 0
    arm64_p20_leaks = 0
    arm64_p20_swaps = 0
    arm64_p20_a_reaped = 0
    arm64_p20_c_spawned = 0
    arm64_p20_b_after_spawn = 0
    arm64_p20_swaps_at_spawn = 0
    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_current_ctx = arm64_p20_ctx_for(0)
    arm64_p20_active = 1

    enter: Ptr[char] = "[arm64] launching spawn-demo EL0 tasks (slot A ASID 4, slot B ASID 5)\n"
    _uart_puts(enter)

    arm64_p20_switch_to(0)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](P20_A_CTX)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> slot A at EL0 under TTBR0+ASID A
    return 0


# ===========================================================================
# Phase 21 — A BLOCKING PRIMITIVE: sys_nanosleep that DESCHEDULES a task on
# aarch64, and a scheduler that runs OTHER tasks while it sleeps then WAKES it.
# ===========================================================================

# Per-slot accessors (two slots; Adder has no arrays-of-globals).
def arm64_p21_l1_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_A_L1
    return P21_B_L1

def arm64_p21_l2_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_A_L2
    return P21_B_L2

def arm64_p21_data_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_A_DATA
    return P21_B_DATA

def arm64_p21_sentinel_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_SENTINEL_A
    return P21_SENTINEL_B

def arm64_p21_asid_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_ASID_A
    return P21_ASID_B

def arm64_p21_code_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_A_CODE
    return P21_B_CODE

def arm64_p21_stack_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_A_STACK_TOP
    return P21_B_STACK_TOP

def arm64_p21_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P21_A_CTX
    return P21_B_CTX

def arm64_p21_sleep_for(idx: int64) -> int64:
    if idx == 0:
        return P21_A_SLEEP
    return P21_B_SLEEP

def arm64_p21_state_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p21_state0
    return arm64_p21_state1

def arm64_p21_set_state(idx: int64, st: int64) -> int64:
    if idx == 0:
        arm64_p21_state0 = st
    else:
        arm64_p21_state1 = st
    return 0

def arm64_p21_deadline_for(idx: int64) -> uint64:
    if idx == 0:
        return arm64_p21_deadline0
    return arm64_p21_deadline1

def arm64_p21_set_deadline(idx: int64, dl: uint64) -> int64:
    if idx == 0:
        arm64_p21_deadline0 = dl
    else:
        arm64_p21_deadline1 = dl
    return 0


# Build slot `idx`'s private address space: a clone of the kernel identity map
# (EL0 code/stack window fetchable, kernel EL1-only) plus an EL0-RWX mapping of
# P21_SHARED_VA -> this slot's PRIVATE physical block, seeded with its sentinel.
def arm64_p21_build_space(idx: int64) -> int64:
    l1_base: uint64 = arm64_p21_l1_for(idx)
    l2_base: uint64 = arm64_p21_l2_for(idx)
    data_pa: uint64 = arm64_p21_data_for(idx)
    sentinel: uint64 = arm64_p21_sentinel_for(idx)

    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1

    l1[0] = cast[uint64](0) | DEV_FLAGS

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0
        elif cast[uint64](j) == P21_SHARED_L2_INDEX:
            l2[j] = data_pa | MEM_FLAGS_EL0
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = l2_base | DESC_TABLE

    dp: Ptr[uint8] = cast[Ptr[uint8]](data_pa)
    dp[0] = cast[uint8](sentinel & cast[uint64](0xFF))
    _dsb_ish()
    return 0


# Materialise slot `idx`'s EL0 routine:
#   loop:
#     x1 = P21_SHARED_VA ; ldrb w0,[x1]        (read this slot's private byte)
#     x8 = 548 (tick) ; svc #0                 (hand the byte to the kernel)
#     x0 = sleep_ticks ; x8 = 549 (nanosleep) ; svc #0   (DESCHEDULE for N ticks)
#     b loop
# nanosleep blocks the task kernel-side; on wake the kernel resumes it at the
# instruction AFTER its nanosleep svc (the `b loop`), so the routine itself needs
# no busy-loop — the sleep IS the pacing, and the kernel runs the peer meanwhile.
def arm64_p21_build_task(idx: int64) -> int64:
    code_base: uint64 = arm64_p21_code_for(idx)
    sleep_n: int64 = arm64_p21_sleep_for(idx)
    a: uint64 = code_base
    loop_top: uint64 = a

    # x1 = P21_SHARED_VA ; ldrb w0,[x1]
    a = _emit_load_imm64(a, cast[uint64](1), P21_SHARED_VA)
    a = _emit_word(a, cast[uint64](0x39400020))
    # x8 = 548 (tick) ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P21_TICK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))
    # x0 = sleep_ticks ; x8 = 549 (nanosleep) ; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](sleep_n))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P21_NANOSLEEP_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # b loop
    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# TTBR0_EL1 for slot `idx`: its private L1 root with its ASID in bits[63:48].
def arm64_p21_ttbr0_for(idx: int64) -> uint64:
    return arm64_p21_l1_for(idx) | (arm64_p21_asid_for(idx) << P21_ASID_SHIFT)


# Switch the live address space to slot `idx` (TTBR0+ASID). No broad TLB flush —
# per-ASID tagging keeps each slot's translation of the shared VA distinct.
def arm64_p21_switch_to(idx: int64) -> int64:
    _dsb_ish()
    _msr_ttbr0_el1(arm64_p21_ttbr0_for(idx))
    _isb()
    return 0


# Wake any BLOCKED slot whose CNTVCT_EL0 deadline has passed: mark it RUNNABLE and
# tally the wake (the resume itself happens when the scheduler next selects it and
# the IRQ stub restores its saved ctx). Returns the number of slots woken.
def arm64_p21_wake_expired() -> int64:
    now: uint64 = cast[uint64](_mrs_cntvct_el0())
    woke: int64 = 0
    idx: int64 = 0
    while idx < 2:
        if arm64_p21_state_for(idx) == P21_SLOT_BLOCKED:
            if now >= arm64_p21_deadline_for(idx):
                arm64_p21_set_state(idx, P21_SLOT_RUNNABLE)
                if idx == 0:
                    arm64_p21_a_wakes = arm64_p21_a_wakes + 1
                else:
                    arm64_p21_b_wakes = arm64_p21_b_wakes + 1
                wm: Ptr[char] = "[arm64] sleep-demo: waking slot "
                _uart_puts(wm)
                _uart_puthex(cast[uint64](idx))
                nl: Ptr[char] = " (deadline passed)\n"
                _uart_puts(nl)
                woke = woke + 1
        idx = idx + 1
    return woke


# Pick the next RUNNABLE slot after `from_idx`, round-robin over slots 0..1,
# skipping BLOCKED slots. Returns -1 if neither slot is runnable.
def arm64_p21_next_runnable(from_idx: int64) -> int64:
    steps: int64 = 0
    idx: int64 = from_idx
    while steps < 2:
        idx = idx + 1
        if idx >= 2:
            idx = 0
        if arm64_p21_state_for(idx) == P21_SLOT_RUNNABLE:
            return idx
        steps = steps + 1
    return -1


# Count whether the slot we are about to run will run WHILE the OTHER slot is
# BLOCKED — the crux invariant that a blocked task genuinely yielded the CPU.
def arm64_p21_note_peer_blocked(running: int64) -> int64:
    peer: int64 = 1
    if running == 1:
        peer = 0
    if arm64_p21_state_for(peer) == P21_SLOT_BLOCKED:
        arm64_p21_ran_while_peer_blocked = arm64_p21_ran_while_peer_blocked + 1
    return 0


# Phase-21 IRQ scheduler — invoked (via arm64_sched_pick) from the EL0 IRQ vector
# with the running slot's register context already saved. Ack + re-arm the timer,
# WAKE any BLOCKED slot whose deadline passed, then round-robin to the next
# RUNNABLE slot, swapping TTBR0+ASID into its PRIVATE space. After P21_GOAL swaps
# the demo's invariants are checked; run the verdict (never returns).
def arm64_p21_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this slot
        return cur_ctx

    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_p21_swaps = arm64_p21_swaps + 1
    swmsg: Ptr[char] = "[arm64] sleep-demo TTBR0+ASID swap\n"
    _uart_puts(swmsg)

    # Wake any sleeper whose deadline has passed (BLOCKED -> RUNNABLE).
    arm64_p21_wake_expired()

    # Verdict once enough swaps have run (both tasks have blocked + been woken).
    if arm64_p21_swaps >= P21_GOAL:
        arm64_p21_finish()
        while True:
            _wfi()

    nxt: int64 = arm64_p21_next_runnable(arm64_p21_cur)
    if nxt < 0:
        # Both slots BLOCKED: no runnable task this tick. Stay on the (parked)
        # current ctx — the next tick will wake a sleeper and pick it up. This
        # is the kernel idling while every task sleeps (legitimate, transient).
        return cur_ctx

    arm64_p21_note_peer_blocked(nxt)
    arm64_p21_cur = nxt
    arm64_p21_switch_to(nxt)                 # TTBR0+ASID -> the incoming slot
    next_ctx: uint64 = arm64_p21_ctx_for(nxt)
    arm64_current_ctx = next_ctx
    return next_ctx


# Save the running slot's FULL resume context (x0..x30 from the svc frame, plus
# the post-svc ELR_EL1, SP_EL0 and an EL0+IRQs-on SPSR) into its ctx block, so the
# scheduler can restore it verbatim on wake. x0 is forced to 0 (nanosleep's return
# value once it resumes). The slot is the running one, so ELR_EL1/SP_EL0 are live.
def arm64_p21_save_resume_ctx(frame_ptr: Ptr[uint64], idx: int64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p21_ctx_for(idx))
    i: int64 = 0
    while i < 31:
        ctx[i] = frame_ptr[i]                # x0..x30 from the saved svc frame
        i = i + 1
    ctx[CTX_X0] = cast[uint64](0)            # nanosleep returns 0 on wake
    ctx[CTX_SP_EL0] = cast[uint64](_mrs_sp_el0())
    ctx[CTX_ELR] = cast[uint64](_mrs_elr_el1())   # resume PC = insn after the svc
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ            # EL0t, IRQs enabled (re-preemptible)
    _dsb_ish()
    return 0


# Park the blocking slot's LIVE EL0 context on a harmless self-loop so the svc
# eret merely spins until the next timer tick preempts it. CRUCIAL: point
# arm64_current_ctx at the THROWAWAY park ctx so the preempting IRQ saves the spin
# state THERE, not over the slot's real (just-saved) resume context.
def arm64_p21_park_blocked_el0(idx: int64) -> int64:
    park: uint64 = arm64_p21_code_for(idx) + cast[uint64](0xE00)
    _emit_word(park, cast[uint64](0x14000000))   # b . (self-loop)
    _dsb_ish()
    _isb()
    _msr_elr_el1(park)
    _isb()
    arm64_current_ctx = P21_PARK_CTX             # IRQ spills spin state here
    return 0


# Phase-21 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. Services:
#   SYS_P21_TICK_NR (548): the byte the running slot read at P21_SHARED_VA through
#       its OWN TTBR0+ASID. Tally a CORRECT read (own sentinel) or a LEAK.
#   SYS_P21_NANOSLEEP_NR (549): a0 = scheduler ticks to sleep. DESCHEDULE the
#       running slot — save its full resume context, set a CNTVCT deadline, mark it
#       BLOCKED, and park its EL0 PC on a self-loop (the timer tick switches away).
def arm64_p21_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P21_TICK_NR:
        val: uint64 = a0 & cast[uint64](0xFF)
        own: uint64 = arm64_p21_sentinel_for(arm64_p21_cur)

        if arm64_p21_cur == 0:
            arm64_p21_a_reports = arm64_p21_a_reports + 1
            if val == own:
                arm64_p21_a_correct = arm64_p21_a_correct + 1
        else:
            arm64_p21_b_reports = arm64_p21_b_reports + 1
            if val == own:
                arm64_p21_b_correct = arm64_p21_b_correct + 1

        # A value that is neither this slot's own sentinel nor 0 is a cross-task
        # leak (a stale, ASID-untagged TLB entry resolving to the peer's block).
        if val != own:
            if val != cast[uint64](0):
                arm64_p21_leaks = arm64_p21_leaks + 1
                lk: Ptr[char] = "[arm64] sleep-demo LEAK: slot read another slot's sentinel FAIL\n"
                _uart_puts(lk)

        # Trace the FIRST correct report from each slot.
        trace: int64 = 0
        if arm64_p21_cur == 0:
            if arm64_p21_a_correct == 1:
                trace = 1
        else:
            if arm64_p21_b_correct == 1:
                trace = 1
        if trace != 0:
            r: Ptr[char] = "[arm64] sleep-demo report: slot "
            _uart_puts(r)
            _uart_puthex(cast[uint64](arm64_p21_cur))
            rv: Ptr[char] = " read VA value="
            _uart_puts(rv)
            _uart_puthex(val)
            _uart_puts(nl)

        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P21_NANOSLEEP_NR:
        ticks: int64 = cast[int64](a0)
        if ticks < 1:
            ticks = 1
        cur: int64 = arm64_p21_cur

        # Save the caller's full resume context so it can RESUME past the svc.
        arm64_p21_save_resume_ctx(frame_ptr, cur)

        # Record the wake deadline = now + ticks * one-timer-period (CNTVCT units).
        now: uint64 = cast[uint64](_mrs_cntvct_el0())
        span: uint64 = cast[uint64](ticks) * arm64_timer_period
        arm64_p21_set_deadline(cur, now + span)
        arm64_p21_set_state(cur, P21_SLOT_BLOCKED)

        if cur == 0:
            arm64_p21_a_blocks = arm64_p21_a_blocks + 1
        else:
            arm64_p21_b_blocks = arm64_p21_b_blocks + 1

        bm: Ptr[char] = "[arm64] sleep-demo: slot "
        _uart_puts(bm)
        _uart_puthex(cast[uint64](cur))
        bn: Ptr[char] = " nanosleep -> BLOCKED for "
        _uart_puts(bn)
        _uart_puthex(cast[uint64](ticks))
        bt: Ptr[char] = " ticks\n"
        _uart_puts(bt)

        # Park the blocked slot's EL0 PC on a self-loop; the next timer tick
        # preempts it and the scheduler runs a RUNNABLE peer (or idles if both
        # sleep). arm64_current_ctx now points at the throwaway park ctx so the
        # preempting IRQ does not clobber the saved resume context.
        arm64_p21_park_blocked_el0(cur)
        frame_ptr[0] = cast[uint64](0)
        return 0

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 21)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-21 verdict. PASS iff: BOTH slots ran (read their private sentinel); EACH
# slot BLOCKED at least once AND was WOKEN+resumed (block+wake cycle proven for
# both); at least one tick ran a task while its peer was BLOCKED (the deschedule-
# others pillar); and ZERO cross-task sentinel leaks. Print tallies, then halt.
def arm64_p21_finish() -> int64:
    arm64_p21_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] sleep-demo swaps="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p21_swaps))
    am: Ptr[char] = " a_correct="
    _uart_puts(am)
    _uart_puthex(cast[uint64](arm64_p21_a_correct))
    bm: Ptr[char] = " b_correct="
    _uart_puts(bm)
    _uart_puthex(cast[uint64](arm64_p21_b_correct))
    abm: Ptr[char] = " a_blocks="
    _uart_puts(abm)
    _uart_puthex(cast[uint64](arm64_p21_a_blocks))
    bbm: Ptr[char] = " b_blocks="
    _uart_puts(bbm)
    _uart_puthex(cast[uint64](arm64_p21_b_blocks))
    awm: Ptr[char] = " a_wakes="
    _uart_puts(awm)
    _uart_puthex(cast[uint64](arm64_p21_a_wakes))
    bwm: Ptr[char] = " b_wakes="
    _uart_puts(bwm)
    _uart_puthex(cast[uint64](arm64_p21_b_wakes))
    pm: Ptr[char] = " ran_while_peer_blocked="
    _uart_puts(pm)
    _uart_puthex(cast[uint64](arm64_p21_ran_while_peer_blocked))
    lm: Ptr[char] = " leaks="
    _uart_puts(lm)
    _uart_puthex(cast[uint64](arm64_p21_leaks))
    _uart_puts(nl)

    ok: int64 = 1
    if arm64_p21_a_correct <= 0:
        ok = 0
    if arm64_p21_b_correct <= 0:
        ok = 0
    if arm64_p21_a_blocks <= 0:
        ok = 0
    if arm64_p21_b_blocks <= 0:
        ok = 0
    if arm64_p21_a_wakes <= 0:
        ok = 0
    if arm64_p21_b_wakes <= 0:
        ok = 0
    if arm64_p21_ran_while_peer_blocked <= 0:
        ok = 0
    if arm64_p21_leaks != 0:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] sleep-demo: both tasks blocked + were woken; scheduler ran peers while one slept\n"
        _uart_puts(rp)
        op: Ptr[char] = "[arm64] EL0 nanosleep block/wake scheduling OK\n"
        _uart_puts(op)
        # Phase 21 complete and clean. Hand off to Phase 22 (a futex: block on a
        # memory word, woken by a peer task). IRQs are masked here; the Phase-22
        # entry re-enables the timer and ERETs into the first task; never returns.
        arm64_run_futex_demo()
        # Unreachable: arm64_run_futex_demo never returns. Safety halt.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 nanosleep block/wake scheduling FAIL\n"
        _uart_puts(fm)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-21 entry point (from the Phase-20 finish hand-off). Build both slots'
# private ASID-tagged address spaces + EL0 routines + context blocks; recycle both
# ASIDs once; mark both RUNNABLE; then ERET into slot A under its private
# TTBR0+ASID with the timer LIVE. The IRQ scheduler round-robins the RUNNABLE
# slots, blocks a task on its nanosleep, runs the peer while it sleeps, and wakes
# it when its deadline passes. Never returns (the scheduler halts after verdict).
def arm64_run_sleep_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 21: blocking nanosleep (deschedule + timer-deadline wake)\n"
    _uart_puts(intro)

    # Mask EL1 IRQs while we build everything so a stray timer IRQ cannot run the
    # scheduler mid-setup; re-enable just before the ERET into slot A.
    _msr_daifset(2)

    arm64_p21_build_space(0)
    arm64_p21_build_space(1)
    arm64_p21_build_task(0)
    arm64_p21_build_task(1)
    arm64_init_ctx(arm64_p21_ctx_for(0), arm64_p21_code_for(0), arm64_p21_stack_for(0))
    arm64_init_ctx(arm64_p21_ctx_for(1), arm64_p21_code_for(1), arm64_p21_stack_for(1))

    # Recycle both slots' ASIDs before first use; thereafter swaps need no flush.
    _dsb_ish()
    _tlbi_aside1is(P21_ASID_A << P21_ASID_SHIFT)
    _tlbi_aside1is(P21_ASID_B << P21_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p21_cur = 0
    arm64_p21_set_state(0, P21_SLOT_RUNNABLE)
    arm64_p21_set_state(1, P21_SLOT_RUNNABLE)
    arm64_p21_deadline0 = cast[uint64](0)
    arm64_p21_deadline1 = cast[uint64](0)
    arm64_p21_a_reports = 0
    arm64_p21_b_reports = 0
    arm64_p21_a_correct = 0
    arm64_p21_b_correct = 0
    arm64_p21_a_blocks = 0
    arm64_p21_b_blocks = 0
    arm64_p21_a_wakes = 0
    arm64_p21_b_wakes = 0
    arm64_p21_ran_while_peer_blocked = 0
    arm64_p21_leaks = 0
    arm64_p21_swaps = 0
    arm64_current_ctx = arm64_p21_ctx_for(0)
    arm64_p21_active = 1

    enter: Ptr[char] = "[arm64] launching sleep-demo EL0 tasks (slot A ASID 7, slot B ASID 8)\n"
    _uart_puts(enter)

    arm64_p21_switch_to(0)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](P21_A_CTX)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> slot A at EL0 under TTBR0+ASID A
    return 0


# ===========================================================================
# Phase 22 — EL0 FUTEX: block on a memory word (FUTEX_WAIT), woken by a peer
# task (FUTEX_WAKE), reusing Phase 21's BLOCKED-state + resume-save + park-ctx
# machinery. The ONLY difference from nanosleep is the wake condition: a futex
# waiter wakes when a peer calls FUTEX_WAKE on the matching uaddr key, NOT when a
# timer deadline expires.
# ===========================================================================

# Per-slot accessors (two slots; Adder has no arrays-of-globals).
def arm64_p22_l1_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_A_L1
    return P22_B_L1

def arm64_p22_l2_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_A_L2
    return P22_B_L2

def arm64_p22_sent_data_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_A_SENT_DATA
    return P22_B_SENT_DATA

def arm64_p22_sentinel_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_SENTINEL_A
    return P22_SENTINEL_B

def arm64_p22_asid_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_ASID_A
    return P22_ASID_B

def arm64_p22_code_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_A_CODE
    return P22_B_CODE

def arm64_p22_stack_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_A_STACK_TOP
    return P22_B_STACK_TOP

def arm64_p22_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P22_A_CTX
    return P22_B_CTX

def arm64_p22_state_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p22_state0
    return arm64_p22_state1

def arm64_p22_set_state(idx: int64, st: int64) -> int64:
    if idx == 0:
        arm64_p22_state0 = st
    else:
        arm64_p22_state1 = st
    return 0

def arm64_p22_wait_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p22_wait0
    return arm64_p22_wait1

def arm64_p22_set_wait(idx: int64, w: int64) -> int64:
    if idx == 0:
        arm64_p22_wait0 = w
    else:
        arm64_p22_wait1 = w
    return 0

def arm64_p22_key_for(idx: int64) -> uint64:
    if idx == 0:
        return arm64_p22_key0
    return arm64_p22_key1

def arm64_p22_set_key(idx: int64, k: uint64) -> int64:
    if idx == 0:
        arm64_p22_key0 = k
    else:
        arm64_p22_key1 = k
    return 0

def arm64_p22_deadline_for(idx: int64) -> uint64:
    if idx == 0:
        return arm64_p22_deadline0
    return arm64_p22_deadline1

def arm64_p22_set_deadline(idx: int64, dl: uint64) -> int64:
    if idx == 0:
        arm64_p22_deadline0 = dl
    else:
        arm64_p22_deadline1 = dl
    return 0


# Translate an EL0 futex VA to its STABLE physical match key. Both slots map
# P22_FUTEX_VA to the SAME physical block (P22_FUTEX_DATA), so any waiter's uaddr
# resolves to the same key regardless of which ASID space it ran in — that is
# what makes cross-ASID FUTEX_WAKE matching unambiguous. (Only the one shared VA
# is a valid futex address in this demo; anything else maps to its own VA as the
# key, which simply never matches a waiter and is harmless.)
def arm64_p22_key_of(uaddr: uint64) -> uint64:
    if uaddr == P22_FUTEX_VA:
        return P22_FUTEX_DATA
    return uaddr


# Build slot `idx`'s private address space: a clone of the kernel identity map
# (EL0 code/stack window fetchable, kernel EL1-only) PLUS two EL0-RWX mappings:
#   P22_FUTEX_VA -> the ONE SHARED physical futex block (same for both slots), and
#   P22_SENT_VA  -> this slot's PRIVATE physical sentinel block (seeded).
def arm64_p22_build_space(idx: int64) -> int64:
    l1_base: uint64 = arm64_p22_l1_for(idx)
    l2_base: uint64 = arm64_p22_l2_for(idx)
    sent_pa: uint64 = arm64_p22_sent_data_for(idx)
    sentinel: uint64 = arm64_p22_sentinel_for(idx)

    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1

    l1[0] = cast[uint64](0) | DEV_FLAGS

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0
        elif cast[uint64](j) == P22_FUTEX_L2_INDEX:
            l2[j] = P22_FUTEX_DATA | MEM_FLAGS_EL0     # SHARED futex word (both slots)
        elif cast[uint64](j) == P22_SENT_L2_INDEX:
            l2[j] = sent_pa | MEM_FLAGS_EL0            # PRIVATE per-slot sentinel
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = l2_base | DESC_TABLE

    sp: Ptr[uint8] = cast[Ptr[uint8]](sent_pa)
    sp[0] = cast[uint8](sentinel & cast[uint64](0xFF))
    _dsb_ish()
    return 0


# Seed the shared futex word to 0 (so the WAITER's initial FUTEX_WAIT(F,0) blocks).
def arm64_p22_seed_futex() -> int64:
    fp: Ptr[uint64] = cast[Ptr[uint64]](P22_FUTEX_DATA)
    fp[0] = cast[uint64](0)
    _dsb_ish()
    return 0


# Materialise slot `idx`'s EL0 routine.
#
# WAITER (slot 0 / A):
#   loop:
#     x1 = P22_SENT_VA ; ldrb w0,[x1]                    (read private sentinel)
#     x8 = 550 (tick)  ; svc #0                          (report it)
#     x0 = P22_FUTEX_VA ; x1 = 0 (WAIT) ; x2 = 0 (val) ; x8 = 551 ; svc #0  (FUTEX_WAIT)
#     b loop
#
# WAKER (slot 1 / B):
#   loop:
#     x1 = P22_SENT_VA ; ldrb w0,[x1]                    (read private sentinel)
#     x8 = 550 (tick)  ; svc #0                          (report it)
#     x0 = sleep ; x8 = 552 (nanosleep) ; svc #0         (yield so A blocks first)
#     x0 = P22_FUTEX_VA ; x1 = 1 ; x8 = 553 (poke) ; svc #0   (*F = 1)
#     x0 = P22_FUTEX_VA ; x1 = 1 (WAKE) ; x2 = 1 (cnt) ; x8 = 551 ; svc #0  (FUTEX_WAKE)
#     x0 = P22_FUTEX_VA ; x1 = 0 ; x8 = 553 (poke) ; svc #0   (*F = 0; A re-blocks)
#     b loop
#
# The kernel resolves *F and writes via syscalls (poke) so the futex word edits
# are observed by the kernel-side compare/wake under the running slot's ASID.
def arm64_p22_build_task(idx: int64) -> int64:
    code_base: uint64 = arm64_p22_code_for(idx)
    a: uint64 = code_base
    loop_top: uint64 = a

    # x1 = P22_SENT_VA ; ldrb w0,[x1]
    a = _emit_load_imm64(a, cast[uint64](1), P22_SENT_VA)
    a = _emit_word(a, cast[uint64](0x39400020))
    # x8 = 550 (tick) ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P22_TICK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    if idx == 0:
        # WAITER: FUTEX_WAIT(P22_FUTEX_VA, op=0, val=0)
        a = _emit_load_imm64(a, cast[uint64](0), P22_FUTEX_VA)
        a = _emit_load_imm64(a, cast[uint64](1), P22_FUTEX_WAIT)
        a = _emit_load_imm64(a, cast[uint64](2), cast[uint64](0))
        a = _emit_load_imm64(a, cast[uint64](8), SYS_P22_FUTEX_NR)
        a = _emit_word(a, cast[uint64](0xD4000001))
    else:
        # WAKER: nanosleep(short) so the waiter reliably blocks before we wake it.
        a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](P22_B_SLEEP))
        a = _emit_load_imm64(a, cast[uint64](8), SYS_P22_NANOSLEEP_NR)
        a = _emit_word(a, cast[uint64](0xD4000001))
        # poke(P22_FUTEX_VA, 1): *F = 1
        a = _emit_load_imm64(a, cast[uint64](0), P22_FUTEX_VA)
        a = _emit_load_imm64(a, cast[uint64](1), cast[uint64](1))
        a = _emit_load_imm64(a, cast[uint64](8), SYS_P22_POKE_NR)
        a = _emit_word(a, cast[uint64](0xD4000001))
        # FUTEX_WAKE(P22_FUTEX_VA, op=1, val=1): wake up to 1 waiter
        a = _emit_load_imm64(a, cast[uint64](0), P22_FUTEX_VA)
        a = _emit_load_imm64(a, cast[uint64](1), P22_FUTEX_WAKE)
        a = _emit_load_imm64(a, cast[uint64](2), cast[uint64](1))
        a = _emit_load_imm64(a, cast[uint64](8), SYS_P22_FUTEX_NR)
        a = _emit_word(a, cast[uint64](0xD4000001))
        # poke(P22_FUTEX_VA, 0): *F = 0 so the waiter's next FUTEX_WAIT blocks again
        a = _emit_load_imm64(a, cast[uint64](0), P22_FUTEX_VA)
        a = _emit_load_imm64(a, cast[uint64](1), cast[uint64](0))
        a = _emit_load_imm64(a, cast[uint64](8), SYS_P22_POKE_NR)
        a = _emit_word(a, cast[uint64](0xD4000001))

    # b loop
    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# TTBR0_EL1 for slot `idx`: its private L1 root with its ASID in bits[63:48].
def arm64_p22_ttbr0_for(idx: int64) -> uint64:
    return arm64_p22_l1_for(idx) | (arm64_p22_asid_for(idx) << P22_ASID_SHIFT)


# Switch the live address space to slot `idx` (TTBR0+ASID). No broad TLB flush —
# per-ASID tagging keeps each slot's translation of the shared VAs distinct.
def arm64_p22_switch_to(idx: int64) -> int64:
    _dsb_ish()
    _msr_ttbr0_el1(arm64_p22_ttbr0_for(idx))
    _isb()
    return 0


# Save the running slot's FULL resume context (x0..x30 from the svc frame, plus
# the post-svc ELR_EL1, SP_EL0 and an EL0+IRQs-on SPSR) into its ctx block, so the
# scheduler can restore it verbatim on wake. x0 is forced to 0 (FUTEX_WAIT /
# nanosleep return value once it resumes).
def arm64_p22_save_resume_ctx(frame_ptr: Ptr[uint64], idx: int64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p22_ctx_for(idx))
    i: int64 = 0
    while i < 31:
        ctx[i] = frame_ptr[i]                # x0..x30 from the saved svc frame
        i = i + 1
    ctx[CTX_X0] = cast[uint64](0)            # returns 0 on wake
    ctx[CTX_SP_EL0] = cast[uint64](_mrs_sp_el0())
    ctx[CTX_ELR] = cast[uint64](_mrs_elr_el1())   # resume PC = insn after the svc
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ            # EL0t, IRQs enabled (re-preemptible)
    _dsb_ish()
    return 0


# Park the blocking slot's LIVE EL0 context on a harmless self-loop so the svc
# eret merely spins until the next timer tick preempts it. CRUCIAL: point
# arm64_current_ctx at the THROWAWAY park ctx so the preempting IRQ saves the spin
# state THERE, not over the slot's real (just-saved) resume context.
def arm64_p22_park_blocked_el0(idx: int64) -> int64:
    park: uint64 = arm64_p22_code_for(idx) + cast[uint64](0xE00)
    _emit_word(park, cast[uint64](0x14000000))   # b . (self-loop)
    _dsb_ish()
    _isb()
    _msr_elr_el1(park)
    _isb()
    arm64_current_ctx = P22_PARK_CTX             # IRQ spills spin state here
    return 0


# FUTEX_WAKE(key, count): flip up to `count` slots that are BLOCKED on the futex
# matching `key` back to RUNNABLE. Returns the number woken.
def arm64_p22_futex_wake(key: uint64, count: int64) -> int64:
    woke: int64 = 0
    idx: int64 = 0
    while idx < 2:
        if woke >= count:
            return woke
        if arm64_p22_state_for(idx) == P22_SLOT_BLOCKED:
            if arm64_p22_wait_for(idx) == P22_WAIT_FUTEX:
                if arm64_p22_key_for(idx) == key:
                    arm64_p22_set_state(idx, P22_SLOT_RUNNABLE)
                    arm64_p22_set_wait(idx, P22_WAIT_NONE)
                    if idx == 0:
                        arm64_p22_a_wakes = arm64_p22_a_wakes + 1
                    wm: Ptr[char] = "[arm64] futex-demo: FUTEX_WAKE woke slot "
                    _uart_puts(wm)
                    _uart_puthex(cast[uint64](idx))
                    nl: Ptr[char] = " (peer signalled the word)\n"
                    _uart_puts(nl)
                    woke = woke + 1
        idx = idx + 1
    return woke


# Auto-wake any TIMER-blocked slot whose CNTVCT_EL0 deadline has passed (nanosleep
# pacing path — NOT the futex path; futex waiters are woken only by a peer).
def arm64_p22_wake_timer_expired() -> int64:
    now: uint64 = cast[uint64](_mrs_cntvct_el0())
    woke: int64 = 0
    idx: int64 = 0
    while idx < 2:
        if arm64_p22_state_for(idx) == P22_SLOT_BLOCKED:
            if arm64_p22_wait_for(idx) == P22_WAIT_TIMER:
                if now >= arm64_p22_deadline_for(idx):
                    arm64_p22_set_state(idx, P22_SLOT_RUNNABLE)
                    arm64_p22_set_wait(idx, P22_WAIT_NONE)
                    woke = woke + 1
        idx = idx + 1
    return woke


# Pick the next RUNNABLE slot after `from_idx`, round-robin over slots 0..1,
# skipping BLOCKED slots. Returns -1 if neither slot is runnable.
def arm64_p22_next_runnable(from_idx: int64) -> int64:
    steps: int64 = 0
    idx: int64 = from_idx
    while steps < 2:
        idx = idx + 1
        if idx >= 2:
            idx = 0
        if arm64_p22_state_for(idx) == P22_SLOT_RUNNABLE:
            return idx
        steps = steps + 1
    return -1


# Count whether the slot we are about to run will run WHILE the OTHER slot is
# BLOCKED — the crux invariant that a blocked task genuinely yielded the CPU.
def arm64_p22_note_peer_blocked(running: int64) -> int64:
    peer: int64 = 1
    if running == 1:
        peer = 0
    if arm64_p22_state_for(peer) == P22_SLOT_BLOCKED:
        arm64_p22_ran_while_peer_blocked = arm64_p22_ran_while_peer_blocked + 1
    return 0


# Phase-22 IRQ scheduler — invoked (via arm64_sched_pick) from the EL0 IRQ vector
# with the running slot's register context already saved. Ack + re-arm the timer,
# auto-wake any TIMER-blocked slot whose deadline passed (futex waiters are NOT
# auto-woken here), then round-robin to the next RUNNABLE slot, swapping
# TTBR0+ASID into its PRIVATE space. After P22_GOAL swaps run the verdict.
def arm64_p22_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this slot
        return cur_ctx

    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_p22_swaps = arm64_p22_swaps + 1
    swmsg: Ptr[char] = "[arm64] futex-demo TTBR0+ASID swap\n"
    _uart_puts(swmsg)

    # Auto-wake nanosleep (timer) sleepers whose deadline passed. Futex waiters are
    # woken only by a peer FUTEX_WAKE, never here.
    arm64_p22_wake_timer_expired()

    # Verdict once enough swaps have run.
    if arm64_p22_swaps >= P22_GOAL:
        arm64_p22_finish()
        while True:
            _wfi()

    nxt: int64 = arm64_p22_next_runnable(arm64_p22_cur)
    if nxt < 0:
        # Both slots BLOCKED this tick. If the waiter is futex-blocked and the
        # waker is timer-blocked, the waker will wake next tick and signal — so
        # just idle on the parked ctx; this is a legitimate transient.
        return cur_ctx

    arm64_p22_note_peer_blocked(nxt)
    arm64_p22_cur = nxt
    arm64_p22_switch_to(nxt)                 # TTBR0+ASID -> the incoming slot
    next_ctx: uint64 = arm64_p22_ctx_for(nxt)
    arm64_current_ctx = next_ctx
    return next_ctx


# Phase-22 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. Services:
#   SYS_P22_TICK_NR (550): the private sentinel byte the running slot read at
#       P22_SENT_VA. Tally a CORRECT read (own sentinel) or a LEAK.
#   SYS_P22_FUTEX_NR (551): a0=uaddr, a1=op, a2=val.
#       op=WAIT(0): if *uaddr == val, save resume ctx, record the futex KEY on the
#           slot, mark it BLOCKED-on-futex, and park its EL0 PC (the timer tick
#           switches away). If *uaddr != val, return immediately (EAGAIN).
#       op=WAKE(1): wake up to `val` slots BLOCKED on the matching key (RUNNABLE).
#   SYS_P22_NANOSLEEP_NR (552): a0=ticks. Timer-block the slot (waker pacing).
#   SYS_P22_POKE_NR (553): a0=uaddr, a1=value. *uaddr = value (kernel-side write,
#       so the futex word edit happens under the running slot's live ASID).
def arm64_p22_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P22_TICK_NR:
        val: uint64 = a0 & cast[uint64](0xFF)
        own: uint64 = arm64_p22_sentinel_for(arm64_p22_cur)

        if arm64_p22_cur == 0:
            arm64_p22_a_reports = arm64_p22_a_reports + 1
            if val == own:
                arm64_p22_a_correct = arm64_p22_a_correct + 1
        else:
            arm64_p22_b_reports = arm64_p22_b_reports + 1
            if val == own:
                arm64_p22_b_correct = arm64_p22_b_correct + 1

        # A value that is neither this slot's own sentinel nor 0 is a cross-task
        # leak (a stale, ASID-untagged TLB entry resolving to the peer's block).
        if val != own:
            if val != cast[uint64](0):
                arm64_p22_leaks = arm64_p22_leaks + 1
                lk: Ptr[char] = "[arm64] futex-demo LEAK: slot read another slot's sentinel FAIL\n"
                _uart_puts(lk)

        # Trace the FIRST correct report from each slot.
        trace: int64 = 0
        if arm64_p22_cur == 0:
            if arm64_p22_a_correct == 1:
                trace = 1
        else:
            if arm64_p22_b_correct == 1:
                trace = 1
        if trace != 0:
            r: Ptr[char] = "[arm64] futex-demo report: slot "
            _uart_puts(r)
            _uart_puthex(cast[uint64](arm64_p22_cur))
            rv: Ptr[char] = " read sentinel value="
            _uart_puts(rv)
            _uart_puthex(val)
            _uart_puts(nl)

        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P22_POKE_NR:
        # Kernel-side write of the futex word under the running slot's live ASID.
        wp: Ptr[uint64] = cast[Ptr[uint64]](a0)
        wp[0] = a1
        _dsb_ish()
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P22_NANOSLEEP_NR:
        ticks: int64 = cast[int64](a0)
        if ticks < 1:
            ticks = 1
        cur: int64 = arm64_p22_cur

        arm64_p22_save_resume_ctx(frame_ptr, cur)
        now: uint64 = cast[uint64](_mrs_cntvct_el0())
        span: uint64 = cast[uint64](ticks) * arm64_timer_period
        arm64_p22_set_deadline(cur, now + span)
        arm64_p22_set_key(cur, cast[uint64](0))
        arm64_p22_set_wait(cur, P22_WAIT_TIMER)
        arm64_p22_set_state(cur, P22_SLOT_BLOCKED)
        arm64_p22_park_blocked_el0(cur)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P22_FUTEX_NR:
        op: uint64 = a1
        cur2: int64 = arm64_p22_cur
        key: uint64 = arm64_p22_key_of(a0)

        if op == P22_FUTEX_WAKE:
            cnt: int64 = cast[int64](a2)
            if cnt < 1:
                cnt = 1
            n: int64 = arm64_p22_futex_wake(key, cnt)
            if n > 0:
                arm64_p22_wakes_issued = arm64_p22_wakes_issued + 1
            frame_ptr[0] = cast[uint64](n)
            return 0

        if op == P22_FUTEX_WAIT:
            # Compare *uaddr against the expected val. The word lives at a0 (the
            # EL0 VA) which is mapped into the running slot's live ASID, so the
            # kernel can read it directly.
            wp2: Ptr[uint64] = cast[Ptr[uint64]](a0)
            cur_val: uint64 = wp2[0]
            if cur_val != a2:
                # *uaddr changed already: do NOT block (EAGAIN). Return immediately.
                eg: Ptr[char] = "[arm64] futex-demo: FUTEX_WAIT slot "
                _uart_puts(eg)
                _uart_puthex(cast[uint64](cur2))
                eg2: Ptr[char] = " word already changed -> no block (EAGAIN)\n"
                _uart_puts(eg2)
                frame_ptr[0] = cast[uint64](0)
                return 0

            # *uaddr == val: BLOCK on the futex key.
            arm64_p22_save_resume_ctx(frame_ptr, cur2)
            arm64_p22_set_key(cur2, key)
            arm64_p22_set_deadline(cur2, cast[uint64](0))
            arm64_p22_set_wait(cur2, P22_WAIT_FUTEX)
            arm64_p22_set_state(cur2, P22_SLOT_BLOCKED)
            if cur2 == 0:
                arm64_p22_a_waits = arm64_p22_a_waits + 1

            bm: Ptr[char] = "[arm64] futex-demo: slot "
            _uart_puts(bm)
            _uart_puthex(cast[uint64](cur2))
            bn: Ptr[char] = " FUTEX_WAIT -> BLOCKED on key "
            _uart_puts(bn)
            _uart_puthex(key)
            _uart_puts(nl)

            arm64_p22_park_blocked_el0(cur2)
            frame_ptr[0] = cast[uint64](0)
            return 0

        # Unknown futex op.
        frame_ptr[0] = cast[uint64](0)
        return 0

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 22)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-22 verdict. PASS iff: BOTH slots ran (read their private sentinel); the
# WAITER BLOCKED on the futex at least once AND was WOKEN by a peer FUTEX_WAKE at
# least once (block-on-word / wake-by-peer cycle proven); at least one FUTEX_WAKE
# actually woke a waiter; at least one tick ran a task while its peer was BLOCKED
# (the deschedule-others pillar); and ZERO cross-task sentinel leaks. Print
# tallies, then halt.
def arm64_p22_finish() -> int64:
    arm64_p22_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] futex-demo swaps="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p22_swaps))
    am: Ptr[char] = " a_correct="
    _uart_puts(am)
    _uart_puthex(cast[uint64](arm64_p22_a_correct))
    bm: Ptr[char] = " b_correct="
    _uart_puts(bm)
    _uart_puthex(cast[uint64](arm64_p22_b_correct))
    awm: Ptr[char] = " a_waits="
    _uart_puts(awm)
    _uart_puthex(cast[uint64](arm64_p22_a_waits))
    akm: Ptr[char] = " a_wakes="
    _uart_puts(akm)
    _uart_puthex(cast[uint64](arm64_p22_a_wakes))
    wim: Ptr[char] = " wakes_issued="
    _uart_puts(wim)
    _uart_puthex(cast[uint64](arm64_p22_wakes_issued))
    pm: Ptr[char] = " ran_while_peer_blocked="
    _uart_puts(pm)
    _uart_puthex(cast[uint64](arm64_p22_ran_while_peer_blocked))
    lm: Ptr[char] = " leaks="
    _uart_puts(lm)
    _uart_puthex(cast[uint64](arm64_p22_leaks))
    _uart_puts(nl)

    ok: int64 = 1
    if arm64_p22_a_correct <= 0:
        ok = 0
    if arm64_p22_b_correct <= 0:
        ok = 0
    if arm64_p22_a_waits <= 0:
        ok = 0
    if arm64_p22_a_wakes <= 0:
        ok = 0
    if arm64_p22_wakes_issued <= 0:
        ok = 0
    if arm64_p22_ran_while_peer_blocked <= 0:
        ok = 0
    if arm64_p22_leaks != 0:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] futex-demo: waiter blocked on a word + was woken by a peer FUTEX_WAKE; scheduler ran the peer while it blocked\n"
        _uart_puts(rp)
        op: Ptr[char] = "[arm64] EL0 futex wait/wake scheduling OK\n"
        _uart_puts(op)
        # Phase 22 complete and clean. Hand off to Phase 23 (EL0 thread-local
        # storage via TPIDR_EL0 / SETTLS, saved+restored per-thread across every
        # preemptive context switch). IRQs are masked here; the Phase-23 entry
        # re-enables the timer and ERETs into the first task; never returns.
        arm64_run_tls_demo()
        # Unreachable: arm64_run_tls_demo never returns. Safety halt.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 futex wait/wake scheduling FAIL\n"
        _uart_puts(fm)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-22 entry point (from the Phase-21 finish hand-off). Build both slots'
# private ASID-tagged address spaces (each mapping the SHARED futex word + its
# OWN private sentinel) + EL0 routines + context blocks; seed the futex word to
# 0; recycle both ASIDs once; mark both RUNNABLE; then ERET into slot A (the
# WAITER) under its private TTBR0+ASID with the timer LIVE. The waiter blocks on
# the futex word; the waker writes it + FUTEX_WAKEs the waiter; the scheduler
# round-robins RUNNABLE slots. Never returns (the scheduler halts after verdict).
def arm64_run_futex_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 22: EL0 futex (FUTEX_WAIT on a word + peer FUTEX_WAKE)\n"
    _uart_puts(intro)

    # Mask EL1 IRQs while we build everything so a stray timer IRQ cannot run the
    # scheduler mid-setup; re-enable just before the ERET into slot A.
    _msr_daifset(2)

    arm64_p22_build_space(0)
    arm64_p22_build_space(1)
    arm64_p22_seed_futex()
    arm64_p22_build_task(0)
    arm64_p22_build_task(1)
    arm64_init_ctx(arm64_p22_ctx_for(0), arm64_p22_code_for(0), arm64_p22_stack_for(0))
    arm64_init_ctx(arm64_p22_ctx_for(1), arm64_p22_code_for(1), arm64_p22_stack_for(1))

    # Recycle both slots' ASIDs before first use; thereafter swaps need no flush.
    _dsb_ish()
    _tlbi_aside1is(P22_ASID_A << P22_ASID_SHIFT)
    _tlbi_aside1is(P22_ASID_B << P22_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p22_cur = 0
    arm64_p22_set_state(0, P22_SLOT_RUNNABLE)
    arm64_p22_set_state(1, P22_SLOT_RUNNABLE)
    arm64_p22_set_wait(0, P22_WAIT_NONE)
    arm64_p22_set_wait(1, P22_WAIT_NONE)
    arm64_p22_key0 = cast[uint64](0)
    arm64_p22_key1 = cast[uint64](0)
    arm64_p22_deadline0 = cast[uint64](0)
    arm64_p22_deadline1 = cast[uint64](0)
    arm64_p22_a_reports = 0
    arm64_p22_b_reports = 0
    arm64_p22_a_correct = 0
    arm64_p22_b_correct = 0
    arm64_p22_a_waits = 0
    arm64_p22_a_wakes = 0
    arm64_p22_wakes_issued = 0
    arm64_p22_ran_while_peer_blocked = 0
    arm64_p22_leaks = 0
    arm64_p22_swaps = 0
    arm64_current_ctx = arm64_p22_ctx_for(0)
    arm64_p22_active = 1

    enter: Ptr[char] = "[arm64] launching futex-demo EL0 tasks (waiter ASID 9, waker ASID 10)\n"
    _uart_puts(enter)

    arm64_p22_switch_to(0)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](P22_A_CTX)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> slot A (waiter) at EL0 under ASID 9
    return 0


# ===========================================================================
# Phase 23 — EL0 THREAD-LOCAL STORAGE via TPIDR_EL0: each EL0 thread installs
# its OWN thread pointer (TPIDR_EL0) once with a SETTLS syscall, then reads its
# thread-local data with a bare `mrs tpidr_el0` (no syscall). The scheduler
# SAVES the outgoing thread's TPIDR_EL0 and RESTORES the incoming thread's on
# every preemptive context switch, so two threads running the SAME EL0 code each
# keep their OWN thread pointer and see their OWN thread-local sentinel. This is
# the real register+scheduler wiring the AArch64 pthread TLS ABI relies on.
# ===========================================================================

# Per-slot accessors (two slots; Adder has no arrays-of-globals).
def arm64_p23_l1_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_A_L1
    return P23_B_L1

def arm64_p23_l2_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_A_L2
    return P23_B_L2

def arm64_p23_tls_data_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_A_TLS_DATA
    return P23_B_TLS_DATA

def arm64_p23_sentinel_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_SENTINEL_A
    return P23_SENTINEL_B

def arm64_p23_asid_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_ASID_A
    return P23_ASID_B

def arm64_p23_code_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_A_CODE
    return P23_B_CODE

def arm64_p23_stack_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_A_STACK_TOP
    return P23_B_STACK_TOP

def arm64_p23_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P23_A_CTX
    return P23_B_CTX

def arm64_p23_tls_for(idx: int64) -> uint64:
    if idx == 0:
        return arm64_p23_tls0
    return arm64_p23_tls1

def arm64_p23_set_tls(idx: int64, v: uint64) -> int64:
    if idx == 0:
        arm64_p23_tls0 = v
    else:
        arm64_p23_tls1 = v
    return 0

def arm64_p23_isset_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p23_set0
    return arm64_p23_set1

def arm64_p23_mark_set(idx: int64) -> int64:
    if idx == 0:
        arm64_p23_set0 = 1
    else:
        arm64_p23_set1 = 1
    return 0


# Build slot `idx`'s private address space: a clone of the kernel identity map
# (EL0 code/stack window fetchable, kernel EL1-only) PLUS one EL0-RWX mapping:
#   P23_TLS_VA -> this slot's PRIVATE physical TLS block (seeded with its own
#   thread-local sentinel). Both slots use the SAME TLS VA but it resolves
#   (through each slot's own TTBR0+ASID) to a DIFFERENT physical block.
def arm64_p23_build_space(idx: int64) -> int64:
    l1_base: uint64 = arm64_p23_l1_for(idx)
    l2_base: uint64 = arm64_p23_l2_for(idx)
    tls_pa: uint64 = arm64_p23_tls_data_for(idx)
    sentinel: uint64 = arm64_p23_sentinel_for(idx)

    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1

    l1[0] = cast[uint64](0) | DEV_FLAGS

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0
        elif cast[uint64](j) == P23_TLS_L2_INDEX:
            l2[j] = tls_pa | MEM_FLAGS_EL0             # PRIVATE per-thread TLS block
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = l2_base | DESC_TABLE

    tp: Ptr[uint8] = cast[Ptr[uint8]](tls_pa)
    tp[0] = cast[uint8](sentinel & cast[uint64](0xFF))
    _dsb_ish()
    return 0


# Materialise slot `idx`'s EL0 routine:
#   entry:
#     x0 = P23_TLS_VA ; x8 = 560 (settls) ; svc #0     (install TPIDR_EL0 once)
#   loop:
#     mrs x1, tpidr_el0 ; ldrb w0,[x1]                  (read TLS sentinel, NO syscall)
#     x8 = 561 (tick)   ; svc #0                        (report it)
#     b loop
# Both slots share identical code; only their PRIVATE TPIDR_EL0 (installed by
# settls, preserved by the scheduler) distinguishes what each thread reads.
def arm64_p23_build_task(idx: int64) -> int64:
    code_base: uint64 = arm64_p23_code_for(idx)
    a: uint64 = code_base

    # x0 = P23_TLS_VA ; x8 = 560 (settls) ; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P23_TLS_VA)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P23_SETTLS_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    loop_top: uint64 = a
    # mrs x1, tpidr_el0
    a = _emit_word(a, cast[uint64](0xD53BD041))
    # ldrb w0, [x1]
    a = _emit_word(a, cast[uint64](0x39400020))
    # x8 = 561 (tick) ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P23_TICK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # b loop
    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# TTBR0_EL1 for slot `idx`: its private L1 root with its ASID in bits[63:48].
def arm64_p23_ttbr0_for(idx: int64) -> uint64:
    return arm64_p23_l1_for(idx) | (arm64_p23_asid_for(idx) << P23_ASID_SHIFT)


# Switch the live address space to slot `idx` (TTBR0+ASID). Per-ASID tagging
# keeps each slot's translation of the shared TLS VA distinct (no broad flush).
def arm64_p23_switch_to(idx: int64) -> int64:
    _dsb_ish()
    _msr_ttbr0_el1(arm64_p23_ttbr0_for(idx))
    _isb()
    return 0


# Phase-23 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. Services:
#   SYS_P23_SETTLS_NR (560): a0 = TLS base VA. Write it into TPIDR_EL0 (the live
#       thread pointer) AND record it on the slot so the scheduler restores it on
#       every wake. Read it straight back to confirm the write landed.
#   SYS_P23_TICK_NR (561): a0 = the byte the thread read through its OWN
#       TPIDR_EL0. Tally a CORRECT read (own thread-local sentinel) or a LEAK
#       (the OTHER thread's sentinel — would mean TPIDR_EL0 was not preserved).
def arm64_p23_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"
    cur: int64 = arm64_p23_cur

    if nr == SYS_P23_SETTLS_NR:
        # Install the running thread's thread pointer into TPIDR_EL0.
        _msr_tpidr_el0(a0)
        _isb()
        # Read it straight back to confirm the system register took the value.
        got: uint64 = cast[uint64](_mrs_tpidr_el0())
        arm64_p23_set_tls(cur, got)
        arm64_p23_mark_set(cur)
        if cur == 0:
            arm64_p23_a_settls = arm64_p23_a_settls + 1
        else:
            arm64_p23_b_settls = arm64_p23_b_settls + 1

        sm: Ptr[char] = "[arm64] tls-demo: slot "
        _uart_puts(sm)
        _uart_puthex(cast[uint64](cur))
        s2: Ptr[char] = " SETTLS -> TPIDR_EL0="
        _uart_puts(s2)
        _uart_puthex(got)
        _uart_puts(nl)

        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P23_TICK_NR:
        val: uint64 = a0 & cast[uint64](0xFF)
        own: uint64 = arm64_p23_sentinel_for(cur)

        if cur == 0:
            arm64_p23_a_reads = arm64_p23_a_reads + 1
            if val == own:
                arm64_p23_a_correct = arm64_p23_a_correct + 1
        else:
            arm64_p23_b_reads = arm64_p23_b_reads + 1
            if val == own:
                arm64_p23_b_correct = arm64_p23_b_correct + 1

        # A value that is neither this thread's own sentinel nor 0 means the
        # thread read through the WRONG TPIDR_EL0 — a TLS leak across a switch.
        if val != own:
            if val != cast[uint64](0):
                arm64_p23_leaks = arm64_p23_leaks + 1
                lk: Ptr[char] = "[arm64] tls-demo LEAK: thread read another thread's TLS sentinel FAIL\n"
                _uart_puts(lk)

        # Trace the FIRST correct read from each thread.
        trace: int64 = 0
        if cur == 0:
            if arm64_p23_a_correct == 1:
                trace = 1
        else:
            if arm64_p23_b_correct == 1:
                trace = 1
        if trace != 0:
            r: Ptr[char] = "[arm64] tls-demo report: slot "
            _uart_puts(r)
            _uart_puthex(cast[uint64](cur))
            rv: Ptr[char] = " read TLS sentinel value="
            _uart_puts(rv)
            _uart_puthex(val)
            _uart_puts(nl)

        frame_ptr[0] = cast[uint64](0)
        return 0

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 23)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-23 IRQ scheduler — invoked (via arm64_sched_pick) from the EL0 IRQ
# vector with the running thread's register context already saved. Ack + re-arm
# the timer, SAVE the outgoing thread's live TPIDR_EL0 into its slot, round-
# robin to the peer slot, swap TTBR0+ASID, and RESTORE the incoming thread's
# saved TPIDR_EL0. After P23_GOAL swaps run the verdict. This save+restore of
# TPIDR_EL0 across the switch is exactly what keeps each thread's TLS private.
def arm64_p23_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this thread
        return cur_ctx

    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    # SAVE the OUTGOING thread's live thread pointer (it may have run settls or
    # could in principle mutate TPIDR_EL0); persist it on its slot.
    out_idx: int64 = arm64_p23_cur
    out_tls: uint64 = cast[uint64](_mrs_tpidr_el0())
    arm64_p23_set_tls(out_idx, out_tls)

    arm64_p23_swaps = arm64_p23_swaps + 1
    swmsg: Ptr[char] = "[arm64] tls-demo TPIDR_EL0-preserving swap\n"
    _uart_puts(swmsg)

    # Verdict once enough swaps have run.
    if arm64_p23_swaps >= P23_GOAL:
        arm64_p23_finish()
        while True:
            _wfi()

    # Round-robin to the peer slot (both threads are always RUNNABLE here).
    nxt: int64 = out_idx + 1
    if nxt >= 2:
        nxt = 0

    # Count switches that occur while BOTH threads are TLS-active AND each has
    # already read its OWN thread-local sentinel correctly — direct evidence the
    # scheduler is round-robining two threads whose TPIDR_EL0 it preserves so each
    # keeps reading its own (distinct) thread-local block across the switches.
    # (Both threads install the SAME thread-pointer VA — 0x42000000 — but it maps,
    # per ASID, to a DIFFERENT physical TLS block, which is why the sentinels they
    # read differ; the proof of preservation is correct-own-reads + zero leaks.)
    in_tls: uint64 = arm64_p23_tls_for(nxt)
    if arm64_p23_isset_for(out_idx) != 0:
        if arm64_p23_isset_for(nxt) != 0:
            if arm64_p23_a_correct > 0:
                if arm64_p23_b_correct > 0:
                    arm64_p23_both_ran_split = arm64_p23_both_ran_split + 1

    arm64_p23_cur = nxt
    arm64_p23_switch_to(nxt)                 # TTBR0+ASID -> the incoming thread

    # RESTORE the INCOMING thread's saved thread pointer into TPIDR_EL0 so it
    # resumes seeing its OWN thread-local block, regardless of what the outgoing
    # thread's TPIDR_EL0 was.
    _msr_tpidr_el0(in_tls)
    _isb()

    next_ctx: uint64 = arm64_p23_ctx_for(nxt)
    arm64_current_ctx = next_ctx
    return next_ctx


# Phase-23 verdict. PASS iff: BOTH threads installed a TLS pointer (settls);
# BOTH read their OWN thread-local sentinel through TPIDR_EL0 (no syscall); the
# scheduler preserved each thread's distinct TPIDR_EL0 across MANY switches (the
# split-TLS pillar); and ZERO cross-thread TLS leaks. Print tallies, then halt.
def arm64_p23_finish() -> int64:
    arm64_p23_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] tls-demo swaps="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p23_swaps))
    am: Ptr[char] = " a_correct="
    _uart_puts(am)
    _uart_puthex(cast[uint64](arm64_p23_a_correct))
    bm: Ptr[char] = " b_correct="
    _uart_puts(bm)
    _uart_puthex(cast[uint64](arm64_p23_b_correct))
    atm: Ptr[char] = " a_settls="
    _uart_puts(atm)
    _uart_puthex(cast[uint64](arm64_p23_a_settls))
    bsm: Ptr[char] = " b_settls="
    _uart_puts(bsm)
    _uart_puthex(cast[uint64](arm64_p23_b_settls))
    spm: Ptr[char] = " tls_split_switches="
    _uart_puts(spm)
    _uart_puthex(cast[uint64](arm64_p23_both_ran_split))
    lm: Ptr[char] = " leaks="
    _uart_puts(lm)
    _uart_puthex(cast[uint64](arm64_p23_leaks))
    _uart_puts(nl)

    ok: int64 = 1
    if arm64_p23_a_settls <= 0:
        ok = 0
    if arm64_p23_b_settls <= 0:
        ok = 0
    if arm64_p23_a_correct <= 0:
        ok = 0
    if arm64_p23_b_correct <= 0:
        ok = 0
    if arm64_p23_both_ran_split <= 0:
        ok = 0
    if arm64_p23_leaks != 0:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] tls-demo: both threads installed a TPIDR_EL0 + read their OWN thread-local sentinel; scheduler preserved each thread pointer across switches\n"
        _uart_puts(rp)
        op: Ptr[char] = "[arm64] EL0 thread-local storage (TPIDR_EL0) scheduling OK\n"
        _uart_puts(op)
        # Phase 23 complete and clean. Hand off to Phase 24 (EL0 demand paging
        # across a fresh unmapped VA window). Mask IRQs (deterministic, no timer
        # re-entry) and run the demo; arm64_run_demand_paging24_demo halts after
        # PASS. This is the Phase 23 -> 24 hand-off point.
        _msr_daifset(2)
        arm64_run_demand_paging24_demo()
        # Unreachable: arm64_run_demand_paging24_demo halts. Safety loop.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] EL0 thread-local storage scheduling FAIL\n"
        _uart_puts(fm)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-23 entry point (from the Phase-22 finish hand-off). Build both slots'
# private ASID-tagged address spaces (each mapping the SHARED TLS VA to its OWN
# private TLS block, seeded with its own sentinel) + EL0 routines + context
# blocks; recycle both ASIDs once; then ERET into slot A under its private
# TTBR0+ASID with the timer LIVE. Each thread installs its thread pointer via
# settls, then reads its thread-local sentinel through TPIDR_EL0 every tick; the
# scheduler save/restores TPIDR_EL0 per switch. Never returns (halts at verdict).
def arm64_run_tls_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 23: EL0 thread-local storage (TPIDR_EL0 / SETTLS, per-thread, scheduler-preserved)\n"
    _uart_puts(intro)

    # Mask EL1 IRQs while we build everything so a stray timer IRQ cannot run the
    # scheduler mid-setup; re-enable just before the ERET into slot A.
    _msr_daifset(2)

    arm64_p23_build_space(0)
    arm64_p23_build_space(1)
    arm64_p23_build_task(0)
    arm64_p23_build_task(1)
    arm64_init_ctx(arm64_p23_ctx_for(0), arm64_p23_code_for(0), arm64_p23_stack_for(0))
    arm64_init_ctx(arm64_p23_ctx_for(1), arm64_p23_code_for(1), arm64_p23_stack_for(1))

    # Recycle both slots' ASIDs before first use; thereafter swaps need no flush.
    _dsb_ish()
    _tlbi_aside1is(P23_ASID_A << P23_ASID_SHIFT)
    _tlbi_aside1is(P23_ASID_B << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p23_cur = 0
    arm64_p23_tls0 = cast[uint64](0)
    arm64_p23_tls1 = cast[uint64](0)
    arm64_p23_set0 = 0
    arm64_p23_set1 = 0
    arm64_p23_a_reads = 0
    arm64_p23_b_reads = 0
    arm64_p23_a_correct = 0
    arm64_p23_b_correct = 0
    arm64_p23_a_settls = 0
    arm64_p23_b_settls = 0
    arm64_p23_leaks = 0
    arm64_p23_swaps = 0
    arm64_p23_both_ran_split = 0
    arm64_current_ctx = arm64_p23_ctx_for(0)
    arm64_p23_active = 1

    enter: Ptr[char] = "[arm64] launching tls-demo EL0 threads (slot A ASID 11, slot B ASID 12)\n"
    _uart_puts(enter)

    # Slot A starts with a clean TPIDR_EL0 (it will install its own via settls).
    _msr_tpidr_el0(cast[uint64](0))
    arm64_p23_switch_to(0)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](P23_A_CTX)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> slot A at EL0 under ASID 11
    return 0


# ===========================================================================
# Phase 24 — EL0 DEMAND PAGING across a fresh, wholly-unmapped VA window.
# ===========================================================================

# Per-page sentinel the EL0 task stores then reads back. Distinct per page so a
# read-back proves the RIGHT page paged in.
def arm64_p24_sentinel_for(idx: int64) -> uint64:
    u: uint64 = cast[uint64](idx)
    return P24_SENTINEL_BASE | (u << cast[uint64](8)) | u


# VA of page `idx` inside the demand window.
def arm64_p24_va_for(idx: int64) -> uint64:
    return P24_WINDOW_BASE + (cast[uint64](idx) * P24_PAGE_SIZE)


# Install the window's L3 table under its (currently UNMAPPED) L2 slot, zeroed so
# every 4 KiB slot still translation-faults on first touch. Idempotent: if the L2
# slot already points at an L3 table it returns without re-wiring.
def arm64_p24_install_l3() -> int64:
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    if l2[cast[int64](P24_WINDOW_L2_INDEX)] != cast[uint64](0):
        return 0                          # L3 already wired under this L2 slot

    # Zero the brand-new L3 table so every still-unmapped 4 KiB slot keeps
    # faulting (each page is a genuine first-touch translation fault).
    l3: Ptr[uint64] = cast[Ptr[uint64]](P24_L3)
    i: int64 = 0
    while i < 512:
        l3[i] = cast[uint64](0)
        i = i + 1
    _dsb_ish()

    # Point the window's L2 slot at the new L3 table (table descriptor).
    l2[cast[int64](P24_WINDOW_L2_INDEX)] = P24_L3 | DESC_TABLE
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    return 0


# Allocate the next fresh physical page from the per-phase pool, install it as the
# L3 PTE backing VA `va` with EL0 RW permissions, then invalidate ONLY that VA's
# stale translation (tlbi vaae1is) so EL0 sees the new mapping. Returns the L3
# index installed.
def arm64_p24_map_page(va: uint64) -> uint64:
    arm64_p24_install_l3()

    # Hand out the next pool page (the handler only ever fires N_PAGES times).
    page_pa: uint64 = P24_POOL_BASE + (cast[uint64](arm64_p24_next_page) * P24_PAGE_SIZE)
    arm64_p24_next_page = arm64_p24_next_page + 1

    # Zero the backing physical page (a fresh page must start clean).
    pg: Ptr[uint64] = cast[Ptr[uint64]](page_pa)
    j: int64 = 0
    while j < 512:
        pg[j] = cast[uint64](0)
        j = j + 1
    _dsb_ish()

    # L3 index of `va` = VA[20:12].
    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P24_L3)
    l3[cast[int64](l3_index)] = page_pa | P24_PAGE_FLAGS

    # Publish the L3 edit, then flush ONLY this page's stale (faulting)
    # translation. The TLBI VAAE1IS operand is the VA's page number (VA >> 12).
    _dsb_ish()
    _tlbi_vaae1is(va >> cast[uint64](12))
    _dsb_ish()
    _isb()
    return l3_index


# Phase-24 demand-paging fault entry. Called from arm64_sync_handler for a data
# abort from EL0 while the demo is live. Decodes ESR_EL1.ISS.DFSC: a TRANSLATION
# fault (0b0001xx) on a page INSIDE the window is paged in (return 1 -> resume EL0
# at the faulting instruction, which retries). Anything else (permission fault, or
# a translation fault OUTSIDE the window) returns 0 so the fatal-fault reaper runs
# — real bugs are never masked.
def arm64_p24_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        # Not a translation fault (e.g. a permission fault) — not demand-pageable.
        return 0

    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    # Is the faulting page inside the demand window [BASE, BASE + N_PAGES*4KiB)?
    win_top: uint64 = P24_WINDOW_BASE + (cast[uint64](P24_N_PAGES) * P24_PAGE_SIZE)
    if page_va < P24_WINDOW_BASE:
        arm64_p24_outside = arm64_p24_outside + 1
        return 0
    if page_va >= win_top:
        arm64_p24_outside = arm64_p24_outside + 1
        return 0

    idx: int64 = cast[int64]((page_va - P24_WINDOW_BASE) >> cast[uint64](12))
    arm64_p24_map_page(page_va)
    arm64_p24_mapped_mask = arm64_p24_mapped_mask | (cast[uint64](1) << cast[uint64](idx))
    arm64_p24_faults = arm64_p24_faults + 1

    m: Ptr[char] = "[arm64] Phase 24 demand fault: paged in VA "
    _uart_puts(m)
    _uart_puthex(page_va)
    pi: Ptr[char] = " (page "
    _uart_puts(pi)
    _uart_puthex(cast[uint64](idx))
    cl: Ptr[char] = ")\n"
    _uart_puts(cl)
    return 1


# Materialise the Phase-24 EL0 routine into USER_CODE_BASE. For each of N_PAGES
# pages: load the page VA + its sentinel, str (FAULTS first touch; kernel pages it
# in then resumes here so the store completes), then ldr it back and hand (idx,
# value) to the kernel via SYS_P24_REPORT_NR. Finally write(1, msg, len), exit(0).
# Stores/loads fault transparently; nothing in the task references the page-fault
# path. GPR-only (no FP).
def arm64_build_p24_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE
    idx: int64 = 0
    while idx < P24_N_PAGES:
        va: uint64 = arm64_p24_va_for(idx)
        sent: uint64 = arm64_p24_sentinel_for(idx)

        # x10 = VA ; x9 = sentinel ; str x9,[x10] (faults -> demand-paged)
        a = _emit_load_imm64(a, cast[uint64](10), va)
        a = _emit_load_imm64(a, cast[uint64](9), sent)
        a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
        # x9 = 0 ; ldr x9,[x10]  (read the sentinel back through the new page)
        a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
        a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
        # report(idx, value): x0 = idx ; x1 = x9 ; x8 = 570 ; svc #0
        a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](idx))
        # mov x1, x9  (ORR x1, xzr, x9) = 0xAA0003E1 | (9<<16) = 0xAA0903E1
        a = _emit_word(a, cast[uint64](0xAA0003E1) | (cast[uint64](9) << cast[uint64](16)))
        a = _emit_load_imm64(a, cast[uint64](8), SYS_P24_REPORT_NR)
        a = _emit_word(a, cast[uint64](0xD4000001))
        idx = idx + 1

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 571; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), P24_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P24_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # exit(0): x0 = 0; x8 = 572; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P24_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-24 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. REPORT records + verifies one (page idx, read-back value) pair; write
# emits to the UART; exit runs the verdict + halts.
def arm64_p24_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P24_REPORT_NR:
        idx: int64 = cast[int64](a0)
        arm64_p24_reports = arm64_p24_reports + 1
        want: uint64 = arm64_p24_sentinel_for(idx)

        r0: Ptr[char] = "[arm64] Phase 24 read-back page "
        _uart_puts(r0)
        _uart_puthex(a0)
        ar: Ptr[char] = " -> "
        _uart_puts(ar)
        _uart_puthex(a1)
        _uart_puts(nl)

        if a1 == want:
            # Independently confirm the BACKING physical page holds the sentinel,
            # so the demand mapping truly reached the pool page (not a stale alias).
            back: Ptr[uint64] = cast[Ptr[uint64]](P24_POOL_BASE + (cast[uint64](idx) * P24_PAGE_SIZE))
            if back[0] == want:
                arm64_p24_correct_mask = arm64_p24_correct_mask | (cast[uint64](1) << cast[uint64](idx))
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P24_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(24) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_P24_EXIT_NR:
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit(24) syscall serviced\n"
        _uart_puts(em)
        arm64_p24_finish(a0)
        # Unreachable: arm64_p24_finish halts. Safety loop if it falls through.
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 24)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-24 verdict. PASS iff exit(0) AND exactly N_PAGES translation faults were
# serviced (one per page), AND every page was mapped, AND every read-back matched
# its sentinel, AND no translation fault fired OUTSIDE the window. Print the fault
# count + the required summary lines, then halt deterministically. Never returns.
def arm64_p24_finish(code: uint64) -> int64:
    arm64_p24_active = 0
    nl: Ptr[char] = "\n"

    fc: Ptr[char] = "[arm64] Phase 24 demand-paging: "
    _uart_puts(fc)
    _uart_puthex(cast[uint64](arm64_p24_faults))
    fs: Ptr[char] = " faults serviced\n"
    _uart_puts(fs)

    full: uint64 = (cast[uint64](1) << cast[uint64](P24_N_PAGES)) - cast[uint64](1)

    ok: int64 = 0
    if code == cast[uint64](0):
        if arm64_p24_faults == P24_N_PAGES:
            if arm64_p24_mapped_mask == full:
                if arm64_p24_correct_mask == full:
                    if arm64_p24_outside == 0:
                        if arm64_p24_reports == P24_N_PAGES:
                            ok = 1

    if ok != 0:
        sm: Ptr[char] = "[arm64] Phase 24 first-touch pages faulted in on demand across the window\n"
        _uart_puts(sm)
        pm: Ptr[char] = "[arm64] Phase 24 PASS\n"
        _uart_puts(pm)
        # Phase 24 complete and clean. Hand off to Phase 25 (COW fork for an EL0
        # task). IRQs stay masked (deterministic, abort-driven). The demo halts
        # after its PASS marker; this is the Phase 24 -> 25 hand-off point.
        _msr_daifset(2)
        arm64_run_cow_fork25_demo()
        # Unreachable: arm64_run_cow_fork25_demo halts. Safety loop.
        while True:
            _wfi()
    else:
        fm: Ptr[char] = "[arm64] Phase 24 demand-paging FAIL\n"
        _uart_puts(fm)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-24 entry point (from the Phase-23 finish hand-off). Restore the kernel's
# identity TTBR0, force the window's L2 slot UNMAPPED (so the first touch of every
# page genuinely translation-faults), build the EL0 routine + message, arm
# Phase-24 dispatch, and ERET into the demand task at EL0t with IRQs masked
# (deterministic; the page-ins all happen on the synchronous abort path). Never
# returns (the task's exit() halts after the PASS marker).
def arm64_run_demand_paging24_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 24: EL0 demand paging across an unmapped VA window\n"
    _uart_puts(intro)

    # Mask EL1 IRQs: Phase 24 is a single-task, abort-driven demo; no scheduler.
    _msr_daifset(2)

    # Restore the kernel's identity-only TTBR0 (be explicit), then flush the TLB.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Force the window's L2 slot UNMAPPED so the first touch of every page raises a
    # translation Data Abort (a clean, repeatable initial state).
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P24_WINDOW_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Seed Phase-24 bookkeeping.
    arm64_p24_faults = 0
    arm64_p24_next_page = 0
    arm64_p24_mapped_mask = cast[uint64](0)
    arm64_p24_correct_mask = cast[uint64](0)
    arm64_p24_outside = 0
    arm64_p24_reports = 0

    p24msg: Ptr[char] = "Hello from a demand-paged EL0 window\n"
    msg_len: uint64 = _copy_msg_to(p24msg, P24_MSG_BASE)
    arm64_build_p24_routine(msg_len)

    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_p24_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 demand-paging window task (4 pages)\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; first store faults, kernel pages in
    # Unreachable: the task's exit() halts after the PASS marker.
    while True:
        _wfi()
    return 0


# ===========================================================================
# Phase 25 — COPY-ON-WRITE fork() for an EL0 task.
# ===========================================================================

# Per-space accessors (idx: 0 = child, 1 = parent).
def arm64_p25_l1_for(idx: int64) -> uint64:
    if idx == 0:
        return P25_CHILD_L1
    return P25_PARENT_L1


def arm64_p25_l2_for(idx: int64) -> uint64:
    if idx == 0:
        return P25_CHILD_L2
    return P25_PARENT_L2


def arm64_p25_l3_for(idx: int64) -> uint64:
    if idx == 0:
        return P25_CHILD_L3
    return P25_PARENT_L3


def arm64_p25_asid_for(idx: int64) -> uint64:
    if idx == 0:
        return P25_CHILD_ASID
    return P25_PARENT_ASID


def arm64_p25_stack_for(idx: int64) -> uint64:
    if idx == 0:
        return P25_CHILD_STACK_TOP
    return P25_PARENT_STACK_TOP


def arm64_p25_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P25_CHILD_CTX
    return P25_PARENT_CTX


# TTBR0_EL1 for space `idx`: its private L1 root + its ASID in bits[63:48].
def arm64_p25_ttbr0_for(idx: int64) -> uint64:
    return arm64_p25_l1_for(idx) | (arm64_p25_asid_for(idx) << P23_ASID_SHIFT)


# Switch the live translation to space `idx` (TTBR0+ASID). Per-ASID tagging keeps
# each space's COW mapping of P25_DATA_VA distinct.
def arm64_p25_switch_to(idx: int64) -> int64:
    _dsb_ish()
    _msr_ttbr0_el1(arm64_p25_ttbr0_for(idx))
    _isb()
    return 0


# Build space `idx`'s private translation tree: a fresh L1 (entry 0 device, entry
# 1 -> a fresh RAM L2 that block-maps the 1 GiB RAM Normal-WB, granting the EL0
# RWX window EL0 access), with the COW data VA's 2 MiB L2 slot pointing at a fresh
# L3 table whose single live entry (L3 idx 0) maps P25_DATA_VA to `data_pa` with
# `page_flags`. Used both for the parent (initial RW-private page) and the child
# (aliasing the SAME page RO at fork).
def arm64_p25_build_space(idx: int64, data_pa: uint64, page_flags: uint64) -> int64:
    l1_base: uint64 = arm64_p25_l1_for(idx)
    l2_base: uint64 = arm64_p25_l2_for(idx)
    l3_base: uint64 = arm64_p25_l3_for(idx)

    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)
    l3: Ptr[uint64] = cast[Ptr[uint64]](l3_base)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1
    l1[0] = cast[uint64](0) | DEV_FLAGS

    # Zero the data VA's L3 so every slot but idx 0 stays translation-faulting.
    k: int64 = 0
    while k < 512:
        l3[k] = cast[uint64](0)
        k = k + 1
    # Map the COW data page (P25_DATA_VA, L3 idx 0) to data_pa with page_flags.
    dl3: uint64 = (P25_DATA_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3[cast[int64](dl3)] = data_pa | page_flags

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0        # shared EL0 RWX code/stack window
        elif cast[uint64](j) == P25_DATA_L2_INDEX:
            l2[j] = l3_base | DESC_TABLE          # COW data VA -> private L3 table
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = l2_base | DESC_TABLE
    _dsb_ish()
    return 0


# Flip space `idx`'s COW data page L3 PTE to `page_flags` (used to mark the shared
# page RO in BOTH spaces at fork). Operates on that space's OWN L3 table.
def arm64_p25_set_data_flags(idx: int64, data_pa: uint64, page_flags: uint64) -> int64:
    l3: Ptr[uint64] = cast[Ptr[uint64]](arm64_p25_l3_for(idx))
    dl3: uint64 = (P25_DATA_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3[cast[int64](dl3)] = data_pa | page_flags
    _dsb_ish()
    return 0


# Materialise the shared EL0 fork routine at P25_CODE_BASE. Both spaces map this
# same text at the same VA. Flow:
#   entry:  x10=DATA_VA ; x9=SEED ; str x9,[x10]        (parent RW-private: no fault)
#           x8=FORK ; svc #0                            (-> x0: 0=child, 1=parent)
#           cbz x0, child                               (split on the fork return)
#   parent: x10=DATA_VA ; x9=PARENT_VAL ; str x9,[x10]  (PERMISSION fault -> COW)
#           ldr x9,[x10]                                (read back own private value)
#           x0=1 ; x1=x9 ; x8=REPORT ; svc #0
#           x0=0 ; x8=EXIT ; svc #0                     (verdict + halt)
#   child:  x10=DATA_VA ; x9=CHILD_VAL ; str x9,[x10]   (PERMISSION fault -> COW)
#           ldr x9,[x10]
#           x0=0 ; x1=x9 ; x8=REPORT ; svc #0
#           x8=DONE ; svc #0                            (kernel resumes the parent)
# Returns the EL0 VA of the instruction AFTER the FORK svc (the post-fork resume
# PC both sides re-enter at).
def arm64_build_p25_routine() -> uint64:
    a: uint64 = P25_CODE_BASE

    # pre-fork: x10=DATA_VA ; x9=SEED ; str x9,[x10]
    a = _emit_load_imm64(a, cast[uint64](10), P25_DATA_VA)
    a = _emit_load_imm64(a, cast[uint64](9), P25_SEED)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # fork(): x8 = 580 ; svc #0
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P25_FORK_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # The post-FORK resume PC is the NEXT instruction (the cbz).
    resume_pc: uint64 = a

    # cbz x0, child  (forward branch; patched once `child` is known). Placeholder.
    cbz_addr: uint64 = a
    a = _emit_word(a, cast[uint64](0xB4000000))   # cbz x0, +0 (fixed up below)

    # ---- parent path ----
    a = _emit_load_imm64(a, cast[uint64](10), P25_DATA_VA)
    a = _emit_load_imm64(a, cast[uint64](9), P25_PARENT_VAL)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # ldr x9,[x10]
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # report(which=1, value): x0=1 ; mov x1,x9 ; x8=581 ; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_word(a, cast[uint64](0xAA0003E1) | (cast[uint64](9) << cast[uint64](16)))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P25_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))
    # exit(0): x0=0 ; x8=583 ; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P25_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # ---- child path ----
    child_addr: uint64 = a
    a = _emit_load_imm64(a, cast[uint64](10), P25_DATA_VA)
    a = _emit_load_imm64(a, cast[uint64](9), P25_CHILD_VAL)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # ldr x9,[x10]
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # report(which=0, value): x0=0 ; mov x1,x9 ; x8=581 ; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xAA0003E1) | (cast[uint64](9) << cast[uint64](16)))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P25_REPORT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))
    # done(): x8=582 ; svc #0  (kernel resumes the parent)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P25_DONE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # Patch the cbz: imm19 = (child_addr - cbz_addr) / 4, Rt = x0.
    off_child: int64 = cast[int64](child_addr) - cast[int64](cbz_addr)
    imm19: uint64 = cast[uint64](off_child >> 2) & cast[uint64](0x7FFFF)
    _emit_word(cbz_addr, cast[uint64](0xB4000000) | (imm19 << cast[uint64](5)))

    _dsb_ish()
    _isb()
    return resume_pc


# Phase-25 COW permission-fault entry. Called from arm64_sync_handler for a data
# abort from EL0 while the demo is live. A genuine COW write is a PERMISSION fault
# (DFSC 0b0011xx) that is a WRITE (ESR.ISS.WnR, bit 6) on the COW data page. We
# allocate a FRESH physical page, copy the shared page into it, remap the LIVE
# space's (arm64_p25_cur) L3 PTE for P25_DATA_VA to the fresh page RW-PRIVATE,
# flush that ASID, and return 1 so EL0 retries the store. Anything else returns 0
# so the fatal-fault reaper runs (real bugs stay fatal).
def arm64_p25_try_cow(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_PERM:
        return 0                              # not a permission fault — not COW
    wnr: uint64 = (esr >> cast[uint64](6)) & cast[uint64](1)
    if wnr == cast[uint64](0):
        return 0                              # a read perm-fault is a real bug

    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)
    if page_va != P25_DATA_VA:
        return 0                              # fault outside the COW page — fatal

    idx: int64 = arm64_p25_cur

    # Hand out the next fresh COW page from the pool.
    fresh_pa: uint64 = P25_COW_POOL_BASE + (cast[uint64](arm64_p25_next_cow) * P25_PAGE_SIZE)
    arm64_p25_next_cow = arm64_p25_next_cow + 1

    # Copy the (still-shared) backing page into the fresh private page.
    src: Ptr[uint64] = cast[Ptr[uint64]](P25_SHARED_DATA_PA)
    dst: Ptr[uint64] = cast[Ptr[uint64]](fresh_pa)
    n: int64 = 0
    while n < 512:
        dst[n] = src[n]
        n = n + 1
    _dsb_ish()

    # Remap ONLY the faulting space's L3 PTE to the fresh page, RW-PRIVATE.
    arm64_p25_set_data_flags(idx, fresh_pa, P25_PAGE_RW)

    # Record the private page for the verdict (per side).
    if idx == 0:
        arm64_p25_child_pa = fresh_pa
    else:
        arm64_p25_parent_pa = fresh_pa

    # Flush this ASID's stale (RO) translation so EL0 sees the new RW mapping.
    _dsb_ish()
    _tlbi_aside1is(arm64_p25_asid_for(idx) << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p25_cow_faults = arm64_p25_cow_faults + 1

    m: Ptr[char] = "[arm64] Phase 25 COW fault: "
    _uart_puts(m)
    if idx == 0:
        cm: Ptr[char] = "child"
        _uart_puts(cm)
    else:
        pm: Ptr[char] = "parent"
        _uart_puts(pm)
    vm: Ptr[char] = " privatised VA "
    _uart_puts(vm)
    _uart_puthex(P25_DATA_VA)
    am: Ptr[char] = " -> fresh PA "
    _uart_puts(am)
    _uart_puthex(fresh_pa)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    return 1


# fork(): build the CHILD address space aliasing the parent's shared COW page,
# flip BOTH spaces' data PTE to read-only, then ERET into the CHILD (x0=0) to run
# it to completion; the child's DONE syscall resumes the parent. `frame_ptr` is
# the parent's saved register frame at the FORK svc.
def arm64_p25_do_fork(frame_ptr: Ptr[uint64]) -> int64:
    arm64_p25_forked = 1

    # Stamp the resume PC + the parent's SP_EL0 (its EL0 stack at the FORK svc).
    arm64_p25_resume_pc = cast[uint64](_mrs_elr_el1())
    arm64_p25_parent_sp = cast[uint64](_mrs_sp_el0())

    # Build the child's wholly-private space aliasing the SAME backing page.
    arm64_p25_build_space(0, P25_SHARED_DATA_PA, P25_PAGE_RO)
    # Mark the parent's view of the page read-only too (copy-on-write share).
    arm64_p25_set_data_flags(1, P25_SHARED_DATA_PA, P25_PAGE_RO)

    # Recycle the child ASID, then flush both ASIDs' stale data-page translations.
    _dsb_ish()
    _tlbi_aside1is(P25_CHILD_ASID << P23_ASID_SHIFT)
    _tlbi_aside1is(P25_PARENT_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()

    fm: Ptr[char] = "[arm64] Phase 25 fork: built child space (ASID "
    _uart_puts(fm)
    _uart_puthex(P25_CHILD_ASID)
    a2: Ptr[char] = ") COW-sharing data page; parent ASID "
    _uart_puts(a2)
    _uart_puthex(P25_PARENT_ASID)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)

    # Cooperatively ENTER the child at the post-fork PC with x0=0 (child return).
    arm64_p25_cur = 0
    arm64_p25_switch_to(0)
    _msr_spsr_el1(SPSR_EL0T_DAIF)            # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(arm64_p25_resume_pc)
    _msr_sp_el0(P25_CHILD_STACK_TOP)
    # Child's x0 = 0; clear the rest of its caller-saved state to a clean slate by
    # only setting x0 (the routine reloads everything it needs).
    _isb()
    _eret_x0(cast[uint64](0))               # -> child at EL0 with x0 = 0
    # Unreachable: the child runs until its DONE syscall resumes the parent.
    while True:
        _wfi()
    return 0


# Resume the PARENT past the fork (x0=1) after the child's DONE syscall.
def arm64_p25_resume_parent() -> int64:
    rp: Ptr[char] = "[arm64] Phase 25: child done -> resuming parent past fork\n"
    _uart_puts(rp)
    arm64_p25_cur = 1
    arm64_p25_switch_to(1)
    _msr_spsr_el1(SPSR_EL0T_DAIF)
    _msr_elr_el1(arm64_p25_resume_pc)
    _msr_sp_el0(arm64_p25_parent_sp)
    _isb()
    _eret_x0(cast[uint64](1))               # -> parent at EL0 with x0 = 1
    while True:
        _wfi()
    return 0


# Phase-25 syscall dispatcher. fork() forks + runs the child; report() records a
# side's read-back; done() resumes the parent; exit() runs the verdict + halts.
def arm64_p25_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P25_FORK_NR:
        arm64_p25_do_fork(frame_ptr)
        # Unreachable: do_fork ERETs into the child and never returns.
        while True:
            _wfi()

    if nr == SYS_P25_REPORT_NR:
        which: int64 = cast[int64](a0)
        r0: Ptr[char] = "[arm64] Phase 25 read-back ("
        _uart_puts(r0)
        if which == 0:
            cm: Ptr[char] = "child"
            _uart_puts(cm)
            arm64_p25_child_val = a1
            arm64_p25_child_reported = 1
        else:
            pm: Ptr[char] = "parent"
            _uart_puts(pm)
            arm64_p25_parent_val = a1
            arm64_p25_parent_reported = 1
        ar: Ptr[char] = ") -> "
        _uart_puts(ar)
        _uart_puthex(a1)
        _uart_puts(nl)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P25_DONE_NR:
        arm64_p25_resume_parent()
        # Unreachable: resume_parent ERETs into the parent.
        while True:
            _wfi()

    if nr == SYS_P25_EXIT_NR:
        arm64_p25_finish(a0)
        # Unreachable: finish halts.
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 25)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-25 verdict. PASS iff: fork built the child; BOTH sides reported; the child
# read back its OWN value AND the parent read back its OWN value (each saw its own,
# not the other's or the seed); EXACTLY 2 COW permission faults were serviced (one
# per side); and the two PRIVATE backing physical pages DIVERGED (distinct PAs,
# each holding its own value) — i.e. genuine copy-on-write address-space isolation.
def arm64_p25_finish(code: uint64) -> int64:
    arm64_p25_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] Phase 25 COW summary: cow_faults="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p25_cow_faults))
    cm: Ptr[char] = " child_val="
    _uart_puts(cm)
    _uart_puthex(arm64_p25_child_val)
    pm: Ptr[char] = " parent_val="
    _uart_puts(pm)
    _uart_puthex(arm64_p25_parent_val)
    cpm: Ptr[char] = " child_pa="
    _uart_puts(cpm)
    _uart_puthex(arm64_p25_child_pa)
    ppm: Ptr[char] = " parent_pa="
    _uart_puts(ppm)
    _uart_puthex(arm64_p25_parent_pa)
    _uart_puts(nl)

    # Independently confirm each PRIVATE backing page holds its OWN side's value,
    # and that the OTHER side never overwrote the original shared page's content.
    child_back: Ptr[uint64] = cast[Ptr[uint64]](arm64_p25_child_pa)
    parent_back: Ptr[uint64] = cast[Ptr[uint64]](arm64_p25_parent_pa)

    ok: int64 = 1
    if code != cast[uint64](0):
        ok = 0
    if arm64_p25_forked == 0:
        ok = 0
    if arm64_p25_child_reported == 0:
        ok = 0
    if arm64_p25_parent_reported == 0:
        ok = 0
    if arm64_p25_cow_faults != 2:
        ok = 0
    # Each side read back its OWN value (divergence proven from EL0).
    if arm64_p25_child_val != P25_CHILD_VAL:
        ok = 0
    if arm64_p25_parent_val != P25_PARENT_VAL:
        ok = 0
    # The two private pages are DISTINCT physical pages.
    if arm64_p25_child_pa == arm64_p25_parent_pa:
        ok = 0
    if arm64_p25_child_pa == cast[uint64](0):
        ok = 0
    if arm64_p25_parent_pa == cast[uint64](0):
        ok = 0
    # And each private page independently holds its own side's value.
    if child_back[0] != P25_CHILD_VAL:
        ok = 0
    if parent_back[0] != P25_PARENT_VAL:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 25: fork gave child a private COW address space; a write by either side privatised its own page, leaving the other's untouched\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 25 PASS\n"
        _uart_puts(pp)
        # Phase 25 complete and clean. Hand off to Phase 26 (a real ELF64 loader +
        # execute). IRQs stay masked (deterministic, abort-driven). This is the
        # Phase 25 -> 26 hand-off point; the loaded program halts after its PASS.
        _msr_daifset(2)
        arm64_run_elf_loader26_demo()
        # Unreachable: arm64_run_elf_loader26_demo halts. Safety loop.
        while True:
            _wfi()
    else:
        fp: Ptr[char] = "[arm64] Phase 25 COW-fork FAIL\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-25 entry point (from the Phase-24 finish hand-off). Build the PARENT's
# private ASID-tagged space (mapping the COW data VA RW-private to the shared
# backing page seeded with P25_SEED), build the shared EL0 routine, arm Phase-25
# dispatch, and ERET into the parent at EL0t with IRQs masked. The parent writes,
# forks, and the COW page-ins all happen on the synchronous svc/abort paths.
# Never returns (the parent's exit() halts after the PASS marker).
def arm64_run_cow_fork25_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 25: copy-on-write fork() for an EL0 task\n"
    _uart_puts(intro)

    # Deterministic, abort-driven: no scheduler, EL1 IRQs masked.
    _msr_daifset(2)

    # Seed the shared backing physical data page (byte 0 = P25_SEED, rest 0).
    seedp: Ptr[uint64] = cast[Ptr[uint64]](P25_SHARED_DATA_PA)
    z: int64 = 0
    while z < 512:
        seedp[z] = cast[uint64](0)
        z = z + 1
    sb: Ptr[uint8] = cast[Ptr[uint8]](P25_SHARED_DATA_PA)
    sb[0] = cast[uint8](P25_SEED & cast[uint64](0xFF))
    _dsb_ish()

    # Build the parent space: COW data page mapped RW-PRIVATE initially (the parent
    # writes the pre-fork value with no fault; the fork flips it RO).
    arm64_p25_build_space(1, P25_SHARED_DATA_PA, P25_PAGE_RW)
    arm64_init_ctx(P25_PARENT_CTX, P25_CODE_BASE, P25_PARENT_STACK_TOP)
    arm64_init_ctx(P25_CHILD_CTX, P25_CODE_BASE, P25_CHILD_STACK_TOP)

    # Recycle both ASIDs before first use.
    _dsb_ish()
    _tlbi_aside1is(P25_PARENT_ASID << P23_ASID_SHIFT)
    _tlbi_aside1is(P25_CHILD_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_build_p25_routine()

    # Seed Phase-25 bookkeeping.
    arm64_p25_cur = 1
    arm64_p25_next_cow = 0
    arm64_p25_cow_faults = 0
    arm64_p25_forked = 0
    arm64_p25_child_reported = 0
    arm64_p25_parent_reported = 0
    arm64_p25_child_val = cast[uint64](0)
    arm64_p25_parent_val = cast[uint64](0)
    arm64_p25_child_pa = cast[uint64](0)
    arm64_p25_parent_pa = cast[uint64](0)
    arm64_p25_resume_pc = cast[uint64](0)
    arm64_p25_parent_sp = cast[uint64](0)
    arm64_p25_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 COW-fork parent task (ASID 13)\n"
    _uart_puts(enter)

    arm64_p25_switch_to(1)                  # parent's TTBR0+ASID
    _msr_spsr_el1(SPSR_EL0T_DAIF)           # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(P25_CODE_BASE)             # EL0 entry PC
    _msr_sp_el0(P25_PARENT_STACK_TOP)       # EL0 stack pointer
    _isb()
    _eret()                                 # -> parent at EL0; write, then fork
    # Unreachable: the parent's exit() halts after the PASS marker.
    while True:
        _wfi()
    return 0


# ===========================================================================
# Phase 26 — a real AArch64 ELF64 LOADER + execute.
# ===========================================================================

# --- little-endian writers into the module-scope ELF image buffer ----------
def _p26_img_u8(off: uint64, v: uint64) -> int64:
    arm64_p26_image[cast[int64](off)] = cast[uint8](v & cast[uint64](0xFF))
    return 0


def _p26_img_u16(off: uint64, v: uint64) -> int64:
    _p26_img_u8(off, v)
    _p26_img_u8(off + cast[uint64](1), v >> cast[uint64](8))
    return 0


def _p26_img_u32(off: uint64, v: uint64) -> int64:
    _p26_img_u8(off, v)
    _p26_img_u8(off + cast[uint64](1), v >> cast[uint64](8))
    _p26_img_u8(off + cast[uint64](2), v >> cast[uint64](16))
    _p26_img_u8(off + cast[uint64](3), v >> cast[uint64](24))
    return 0


def _p26_img_u64(off: uint64, v: uint64) -> int64:
    _p26_img_u32(off, v)
    _p26_img_u32(off + cast[uint64](4), v >> cast[uint64](32))
    return 0


# Store one 32-bit AArch64 instruction word at image byte offset `off`.
def _p26_img_word(off: uint64, word: uint64) -> uint64:
    _p26_img_u32(off, word)
    return off + cast[uint64](4)


# Assemble a movz + 3x movk sequence building `value` into xd, into the image at
# byte offset `off` (mirrors _emit_load_imm64 but targets the file buffer).
def _p26_img_load_imm64(off: uint64, xd: uint64, value: uint64) -> uint64:
    a: uint64 = off
    h0: uint64 = value & cast[uint64](0xFFFF)
    h1: uint64 = (value >> cast[uint64](16)) & cast[uint64](0xFFFF)
    h2: uint64 = (value >> cast[uint64](32)) & cast[uint64](0xFFFF)
    h3: uint64 = (value >> cast[uint64](48)) & cast[uint64](0xFFFF)
    a = _p26_img_word(a, cast[uint64](0xD2800000) | (h0 << cast[uint64](5)) | xd)
    a = _p26_img_word(a, cast[uint64](0xF2800000) | (cast[uint64](1) << cast[uint64](21)) | (h1 << cast[uint64](5)) | xd)
    a = _p26_img_word(a, cast[uint64](0xF2800000) | (cast[uint64](2) << cast[uint64](21)) | (h2 << cast[uint64](5)) | xd)
    a = _p26_img_word(a, cast[uint64](0xF2800000) | (cast[uint64](3) << cast[uint64](21)) | (h3 << cast[uint64](5)) | xd)
    return a


# Assemble the genuine ELF64 file image into arm64_p26_image:
#   * an Elf64_Ehdr (ET_EXEC, EM_AARCH64, ELFCLASS64/LSB) whose e_entry points at
#     the text segment's first instruction and e_phoff/e_phnum/e_phentsize
#     describe the two program headers that immediately follow,
#   * two Elf64_Phdr's: PT_LOAD #1 (PF_R|PF_X) for the text segment (code + an
#     embedded message), PT_LOAD #2 (PF_R|PF_W) for the data segment with a BSS
#     tail (p_memsz > p_filesz),
#   * the text-segment file content: the EL0 program code, padded to P26_MSG_OFF,
#     then the message bytes,
#   * the data-segment file content: P26_DATA_FILESZ initialised bytes.
# Returns the EL0 entry VA (== e_entry the loader will parse back out).
def arm64_p26_assemble_image() -> uint64:
    # Zero the whole image buffer first.
    i: int64 = 0
    while i < cast[int64](P26_IMG_MAX):
        arm64_p26_image[i] = cast[uint8](0)
        i = i + 1

    # ---- the message bytes (stored at text file offset TEXT_FOFF + MSG_OFF) ----
    msg_foff: uint64 = P26_TEXT_FOFF + P26_MSG_OFF
    m0: uint64 = cast[uint64](0x48)   # 'H'
    msgstr: Ptr[char] = "Hello from a real ELF64 loaded on aarch64\n"
    mp: Ptr[uint8] = cast[Ptr[uint8]](msgstr)
    msg_len: uint64 = cast[uint64](0)
    while mp[cast[int64](msg_len)] != 0:
        _p26_img_u8(msg_foff + msg_len, cast[uint64](mp[cast[int64](msg_len)]))
        msg_len = msg_len + cast[uint64](1)

    # ---- the EL0 program code (text segment file content) ----
    # write(1, MSG_VA, msg_len): x0=1; x1=MSG_VA; x2=len; x8=SYS_P26_WRITE_NR; svc
    a: uint64 = P26_TEXT_FOFF
    a = _p26_img_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _p26_img_load_imm64(a, cast[uint64](1), P26_MSG_VA)
    a = _p26_img_load_imm64(a, cast[uint64](2), msg_len)
    a = _p26_img_load_imm64(a, cast[uint64](8), SYS_P26_WRITE_NR)
    a = _p26_img_word(a, cast[uint64](0xD4000001))                 # svc #0
    # read a byte out of the data segment's zeroed BSS tail:
    #   x10 = BSS_VA ; ldrb w9,[x10] ; mov x0,x9 ; x8=SYS_P26_BSS_NR ; svc #0
    a = _p26_img_load_imm64(a, cast[uint64](10), P26_BSS_VA)
    a = _p26_img_word(a, cast[uint64](0x39400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))  # ldrb w9,[x10]
    a = _p26_img_word(a, cast[uint64](0xAA0003E0) | (cast[uint64](9) << cast[uint64](16)))                     # mov x0,x9
    a = _p26_img_load_imm64(a, cast[uint64](8), SYS_P26_BSS_NR)
    a = _p26_img_word(a, cast[uint64](0xD4000001))                 # svc #0
    # exit(P26_EXIT_CODE): x0=code ; x8=SYS_P26_EXIT_NR ; svc #0
    a = _p26_img_load_imm64(a, cast[uint64](0), P26_EXIT_CODE)
    a = _p26_img_load_imm64(a, cast[uint64](8), SYS_P26_EXIT_NR)
    a = _p26_img_word(a, cast[uint64](0xD4000001))                 # svc #0

    # ---- data segment file content: P26_DATA_FILESZ initialised bytes ----
    data_foff: uint64 = msg_foff + msg_len
    # Round up to keep the data file content clear of the message.
    if (data_foff & cast[uint64](7)) != cast[uint64](0):
        data_foff = (data_foff + cast[uint64](8)) & cast[uint64](0xFFFFFFFFFFFFFFF8)
    d: int64 = 0
    while d < cast[int64](P26_DATA_FILESZ):
        _p26_img_u8(data_foff + cast[uint64](d), cast[uint64](0xC0) + cast[uint64](d))
        d = d + 1

    img_end: uint64 = data_foff + P26_DATA_FILESZ
    arm64_p26_image_len = img_end

    # ---- Elf64_Ehdr ----
    _p26_img_u8(cast[uint64](0), ELF_EI_MAG0)
    _p26_img_u8(cast[uint64](1), ELF_EI_MAG1)
    _p26_img_u8(cast[uint64](2), ELF_EI_MAG2)
    _p26_img_u8(cast[uint64](3), ELF_EI_MAG3)
    _p26_img_u8(cast[uint64](4), ELFCLASS64)        # EI_CLASS
    _p26_img_u8(cast[uint64](5), ELFDATA2LSB)       # EI_DATA (little-endian)
    _p26_img_u8(cast[uint64](6), cast[uint64](1))   # EI_VERSION = EV_CURRENT
    _p26_img_u16(EH_TYPE, ET_EXEC)                  # e_type
    _p26_img_u16(EH_MACHINE, EM_AARCH64)            # e_machine
    _p26_img_u32(cast[uint64](20), cast[uint64](1)) # e_version
    _p26_img_u64(EH_ENTRY, P26_TEXT_VA)             # e_entry = first text insn VA
    _p26_img_u64(EH_PHOFF, EHDR_SIZE)               # e_phoff = 64 (phdrs follow)
    _p26_img_u16(cast[uint64](52), EHDR_SIZE)       # e_ehsize
    _p26_img_u16(EH_PHENTSIZE, PHDR_SIZE)           # e_phentsize = 56
    _p26_img_u16(EH_PHNUM, cast[uint64](2))         # e_phnum = 2

    # ---- Elf64_Phdr #1: text segment (PT_LOAD, R+X) ----
    p1: uint64 = EHDR_SIZE                          # 64
    _p26_img_u32(p1 + PH_TYPE, PT_LOAD)
    _p26_img_u32(p1 + PH_FLAGS, PF_R | PF_X)
    _p26_img_u64(p1 + PH_OFFSET, P26_TEXT_FOFF)
    _p26_img_u64(p1 + PH_VADDR, P26_TEXT_VA)
    _p26_img_u64(p1 + cast[uint64](24), P26_TEXT_VA)      # p_paddr (unused)
    # text file size spans through the message; mem size == file size (no BSS).
    text_filesz: uint64 = (msg_foff + msg_len) - P26_TEXT_FOFF
    _p26_img_u64(p1 + PH_FILESZ, text_filesz)
    _p26_img_u64(p1 + PH_MEMSZ, text_filesz)
    _p26_img_u64(p1 + cast[uint64](48), P26_PAGE_SIZE)    # p_align

    # ---- Elf64_Phdr #2: data segment (PT_LOAD, R+W, with a BSS tail) ----
    p2: uint64 = EHDR_SIZE + PHDR_SIZE              # 120
    _p26_img_u32(p2 + PH_TYPE, PT_LOAD)
    _p26_img_u32(p2 + PH_FLAGS, PF_R | PF_W)
    _p26_img_u64(p2 + PH_OFFSET, data_foff)
    _p26_img_u64(p2 + PH_VADDR, P26_DATA_VA)
    _p26_img_u64(p2 + cast[uint64](24), P26_DATA_VA)      # p_paddr (unused)
    _p26_img_u64(p2 + PH_FILESZ, P26_DATA_FILESZ)         # 8 init bytes
    _p26_img_u64(p2 + PH_MEMSZ, P26_DATA_MEMSZ)           # mem > file => BSS tail
    _p26_img_u64(p2 + cast[uint64](48), P26_PAGE_SIZE)    # p_align

    _dsb_ish()
    return P26_TEXT_VA


# Derive the L3 PAGE flags for a segment from its parsed ELF p_flags (W^X):
#   PF_X (and not PF_W) -> EL0 read-only + executable (text).
#   PF_W               -> EL0 read/write + non-exec (data; W^X).
#   else               -> EL0 read-only + non-exec.
def arm64_p26_flags_for(pflags: uint64) -> uint64:
    if (pflags & PF_W) != cast[uint64](0):
        return P26_PAGE_RW
    if (pflags & PF_X) != cast[uint64](0):
        return P26_PAGE_RX
    return P26_PAGE_RO


# Build the loaded program's fresh EL0 address space: a private L1 (entry 0 device,
# entry 1 -> a fresh RAM L2 block-mapping the 1 GiB RAM Normal-WB EL1-only) with
# the text / data / stack 2 MiB slots redirected to private (zeroed) L3 tables.
# The loader stamps the segment pages into those L3 tables; first touch then takes
# a translation fault the abort path accounts and resumes.
def arm64_p26_build_space() -> int64:
    l1: Ptr[uint64] = cast[Ptr[uint64]](P26_L1)
    l2: Ptr[uint64] = cast[Ptr[uint64]](P26_L2)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1
    l1[0] = cast[uint64](0) | DEV_FLAGS

    # Zero the three private L3 tables (every slot translation-faults until mapped).
    tl3: Ptr[uint64] = cast[Ptr[uint64]](P26_TEXT_L3)
    dl3: Ptr[uint64] = cast[Ptr[uint64]](P26_DATA_L3)
    sl3: Ptr[uint64] = cast[Ptr[uint64]](P26_STACK_L3)
    k: int64 = 0
    while k < 512:
        tl3[k] = cast[uint64](0)
        dl3[k] = cast[uint64](0)
        sl3[k] = cast[uint64](0)
        k = k + 1

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == P26_TEXT_L2_INDEX:
            l2[j] = P26_TEXT_L3 | DESC_TABLE
        elif cast[uint64](j) == P26_DATA_L2_INDEX:
            l2[j] = P26_DATA_L3 | DESC_TABLE
        elif cast[uint64](j) == P26_STACK_L2_INDEX:
            l2[j] = P26_STACK_L3 | DESC_TABLE
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = P26_L2 | DESC_TABLE
    _dsb_ish()

    # Map the EL0 stack page now (RW non-exec) so the program has a stack on entry.
    sidx: uint64 = (P26_STACK_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    sl3[cast[int64](sidx)] = P26_STACK_PA | P26_PAGE_RW
    sp: Ptr[uint64] = cast[Ptr[uint64]](P26_STACK_PA)
    z: int64 = 0
    while z < 512:
        sp[z] = cast[uint64](0)
        z = z + 1
    _dsb_ish()
    return 0


# Map [seg_va, seg_va + memsz) of a loaded segment onto `seg_pa` with `page_flags`
# in its 2 MiB slot's private L3 table. The backing page is pre-cleared, the
# p_filesz file bytes copied in from the image, and the BSS tail left zeroed. Only
# the segment's first 4 KiB page is wired (our test segments fit in one page).
def arm64_p26_map_segment(seg_va: uint64, seg_pa: uint64, foff: uint64, filesz: uint64, memsz: uint64, l3_base: uint64, page_flags: uint64) -> int64:
    # Clear the backing page (the BSS tail beyond filesz must read as zero).
    pg: Ptr[uint8] = cast[Ptr[uint8]](seg_pa)
    c: int64 = 0
    while c < cast[int64](P26_PAGE_SIZE):
        pg[c] = cast[uint8](0)
        c = c + 1

    # Copy p_filesz file bytes from the image into the backing page.
    n: uint64 = cast[uint64](0)
    while n < filesz:
        pg[cast[int64](n)] = arm64_p26_image[cast[int64](foff + n)]
        n = n + cast[uint64](1)
    _dsb_ish()

    # Stamp the segment's first-page L3 PTE with the W^X-derived permissions.
    l3: Ptr[uint64] = cast[Ptr[uint64]](l3_base)
    idx: uint64 = (seg_va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3[cast[int64](idx)] = seg_pa | page_flags
    _dsb_ish()
    _isb()
    return 0


# Parse + load the assembled ELF64 image into the fresh EL0 space. Validates the
# header, walks the program-header table, and maps every PT_LOAD. Returns e_entry
# on success, 0 on a validation failure.
def arm64_p26_load_elf() -> uint64:
    arm64_p26_parse_ok = 0
    arm64_p26_segs_loaded = 0

    # --- validate e_ident magic + class + data ---
    if cast[uint64](arm64_p26_image[0]) != ELF_EI_MAG0:
        return cast[uint64](0)
    if cast[uint64](arm64_p26_image[1]) != ELF_EI_MAG1:
        return cast[uint64](0)
    if cast[uint64](arm64_p26_image[2]) != ELF_EI_MAG2:
        return cast[uint64](0)
    if cast[uint64](arm64_p26_image[3]) != ELF_EI_MAG3:
        return cast[uint64](0)
    if cast[uint64](arm64_p26_image[4]) != ELFCLASS64:
        return cast[uint64](0)
    if cast[uint64](arm64_p26_image[5]) != ELFDATA2LSB:
        return cast[uint64](0)

    # --- read header fields ---
    e_type: uint64 = _p26_rd16(EH_TYPE)
    e_machine: uint64 = _p26_rd16(EH_MACHINE)
    e_entry: uint64 = _p26_rd64(EH_ENTRY)
    e_phoff: uint64 = _p26_rd64(EH_PHOFF)
    e_phentsize: uint64 = _p26_rd16(EH_PHENTSIZE)
    e_phnum: uint64 = _p26_rd16(EH_PHNUM)

    if e_type != ET_EXEC:
        return cast[uint64](0)
    if e_machine != EM_AARCH64:
        return cast[uint64](0)

    hm: Ptr[char] = "[arm64] Phase 26 ELF: class64 LSB, machine=AArch64, type=EXEC, entry="
    _uart_puts(hm)
    _uart_puthex(e_entry)
    pm: Ptr[char] = " phoff="
    _uart_puts(pm)
    _uart_puthex(e_phoff)
    nm: Ptr[char] = " phnum="
    _uart_puts(nm)
    _uart_puthex(e_phnum)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)

    arm64_p26_parse_ok = 1
    arm64_p26_entry = e_entry

    # --- walk the program-header table; map every PT_LOAD ---
    ph: uint64 = 0
    while ph < e_phnum:
        base: uint64 = e_phoff + (ph * e_phentsize)
        p_type: uint64 = _p26_rd32(base + PH_TYPE)
        if p_type == PT_LOAD:
            p_flags: uint64 = _p26_rd32(base + PH_FLAGS)
            p_offset: uint64 = _p26_rd64(base + PH_OFFSET)
            p_vaddr: uint64 = _p26_rd64(base + PH_VADDR)
            p_filesz: uint64 = _p26_rd64(base + PH_FILESZ)
            p_memsz: uint64 = _p26_rd64(base + PH_MEMSZ)
            page_flags: uint64 = arm64_p26_flags_for(p_flags)

            # Route the segment to its dedicated backing page + L3 by its VADDR.
            seg_pa: uint64 = cast[uint64](0)
            l3_base: uint64 = cast[uint64](0)
            if p_vaddr == P26_TEXT_VA:
                seg_pa = P26_TEXT_PA
                l3_base = P26_TEXT_L3
            elif p_vaddr == P26_DATA_VA:
                seg_pa = P26_DATA_PA
                l3_base = P26_DATA_L3
            else:
                # An unexpected PT_LOAD vaddr — fail loud rather than mis-map.
                return cast[uint64](0)

            arm64_p26_map_segment(p_vaddr, seg_pa, p_offset, p_filesz, p_memsz, l3_base, page_flags)
            arm64_p26_segs_loaded = arm64_p26_segs_loaded + 1

            sm: Ptr[char] = "[arm64] Phase 26 PT_LOAD: vaddr="
            _uart_puts(sm)
            _uart_puthex(p_vaddr)
            fm: Ptr[char] = " filesz="
            _uart_puts(fm)
            _uart_puthex(p_filesz)
            mm: Ptr[char] = " memsz="
            _uart_puts(mm)
            _uart_puthex(p_memsz)
            xm: Ptr[char] = " flags="
            _uart_puts(xm)
            _uart_puthex(p_flags)
            am: Ptr[char] = " -> pa="
            _uart_puts(am)
            _uart_puthex(seg_pa)
            _uart_puts(nl)
        ph = ph + cast[uint64](1)

    return e_entry


# Little-endian readers out of the image buffer (used by the parser).
def _p26_rd16(off: uint64) -> uint64:
    b0: uint64 = cast[uint64](arm64_p26_image[cast[int64](off)])
    b1: uint64 = cast[uint64](arm64_p26_image[cast[int64](off + cast[uint64](1))])
    return b0 | (b1 << cast[uint64](8))


def _p26_rd32(off: uint64) -> uint64:
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 4:
        r = r | (cast[uint64](arm64_p26_image[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


def _p26_rd64(off: uint64) -> uint64:
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 8:
        r = r | (cast[uint64](arm64_p26_image[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


# Phase-26 demand-fault entry. A first touch of a loaded segment page takes a
# TRANSLATION fault (the loader pre-stamped the PTE, so this is the AF/translation
# of the freshly-mapped page within the live ASID). We confirm the faulting VA is
# inside a loaded segment, account it, flush that VA, and resume (return 1). A
# fault outside the loaded segments returns 0 -> the fatal-fault reaper.
def arm64_p26_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0

    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    in_seg: int64 = 0
    if page_va == P26_TEXT_VA:
        arm64_p26_text_faults = arm64_p26_text_faults + 1
        in_seg = 1
    elif page_va == P26_DATA_VA:
        arm64_p26_data_faults = arm64_p26_data_faults + 1
        in_seg = 1
    if in_seg == 0:
        return 0

    _dsb_ish()
    _tlbi_vaae1is(page_va >> cast[uint64](12))
    _dsb_ish()
    _isb()

    m: Ptr[char] = "[arm64] Phase 26 segment fault: paged in VA "
    _uart_puts(m)
    _uart_puthex(page_va)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    return 1


# Phase-26 syscall dispatcher. Routed while the loaded program runs. write() emits
# its message to the UART; bss-report records the byte it read from the BSS tail;
# exit() runs the loader verdict + halts.
def arm64_p26_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P26_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[cast[int64](n)])
            n = n + cast[uint64](1)
        arm64_p26_msg_bytes = cast[int64](a2)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_P26_BSS_NR:
        arm64_p26_bss_val = a0
        arm64_p26_bss_reported = 1
        bm: Ptr[char] = "[arm64] Phase 26 program read BSS-tail byte -> "
        _uart_puts(bm)
        _uart_puthex(a0)
        _uart_puts(nl)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P26_EXIT_NR:
        arm64_p26_exit_code = a0
        arm64_p26_exited = 1
        arm64_p26_finish(a0)
        # Unreachable: finish halts.
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 26)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-26 verdict. PASS iff: the ELF header validated; BOTH PT_LOAD segments were
# mapped; the program wrote its full message (it ran from the loaded text mapping);
# it read back a ZERO byte from the BSS tail (BSS zeroing worked); and it exited
# with the expected status (proving e_entry executed the loaded code end-to-end).
def arm64_p26_finish(code: uint64) -> int64:
    arm64_p26_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] Phase 26 loader summary: parse_ok="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p26_parse_ok))
    g1: Ptr[char] = " segs="
    _uart_puts(g1)
    _uart_puthex(cast[uint64](arm64_p26_segs_loaded))
    g2: Ptr[char] = " text_faults="
    _uart_puts(g2)
    _uart_puthex(cast[uint64](arm64_p26_text_faults))
    g3: Ptr[char] = " msg_bytes="
    _uart_puts(g3)
    _uart_puthex(cast[uint64](arm64_p26_msg_bytes))
    g4: Ptr[char] = " bss_val="
    _uart_puts(g4)
    _uart_puthex(arm64_p26_bss_val)
    g5: Ptr[char] = " exit="
    _uart_puts(g5)
    _uart_puthex(arm64_p26_exit_code)
    _uart_puts(nl)

    ok: int64 = 1
    if arm64_p26_parse_ok == 0:
        ok = 0
    if arm64_p26_segs_loaded != 2:
        ok = 0
    if arm64_p26_msg_bytes <= 0:
        ok = 0
    if arm64_p26_bss_reported == 0:
        ok = 0
    if arm64_p26_bss_val != cast[uint64](0):
        ok = 0
    if arm64_p26_exited == 0:
        ok = 0
    if code != P26_EXIT_CODE:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 26: loaded a genuine AArch64 ELF64 (parsed header + 2 PT_LOADs, W^X-mapped, BSS-zeroed) and ran it at EL0 to exit\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 26 PASS\n"
        _uart_puts(pp)
        # Phase 26 complete and clean. Hand off to Phase 27 (a REAL preemptive
        # round-robin scheduler between two concurrent EL0 user tasks, each in its
        # own ASID-tagged address space, driven involuntarily by the generic
        # timer). This is the Phase 26 -> 27 hand-off point. arm64_p27_run never
        # returns (its finish halts after the verdict).
        arm64_p27_run()
        # Unreachable: arm64_p27_run halts. Safety loop.
        while True:
            _wfi()
    else:
        fp: Ptr[char] = "[arm64] Phase 26 ELF-loader FAIL\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-26 entry point (from the Phase-25 finish hand-off). Assemble the ELF64
# image, build a fresh EL0 address space, PARSE + LOAD the ELF (mapping its
# PT_LOAD segments with W^X protections), then ERET into e_entry at EL0t with IRQs
# masked. The segment page-ins happen on the synchronous abort path; the loaded
# program's write()/exit() syscalls drive the rest. Never returns.
def arm64_run_elf_loader26_demo() -> int64:
    intro: Ptr[char] = "[arm64] Phase 26: AArch64 ELF64 loader + execute\n"
    _uart_puts(intro)

    # Deterministic, abort-driven: no scheduler, EL1 IRQs masked.
    _msr_daifset(2)

    # Seed Phase-26 bookkeeping.
    arm64_p26_segs_loaded = 0
    arm64_p26_text_faults = 0
    arm64_p26_data_faults = 0
    arm64_p26_msg_bytes = 0
    arm64_p26_bss_val = cast[uint64](0xFF)
    arm64_p26_bss_reported = 0
    arm64_p26_exit_code = cast[uint64](0xFFFF)
    arm64_p26_exited = 0
    arm64_p26_parse_ok = 0
    arm64_p26_entry = cast[uint64](0)

    # Assemble the genuine ELF64 file image, then build the program's EL0 space.
    arm64_p26_assemble_image()
    arm64_p26_build_space()

    am: Ptr[char] = "[arm64] Phase 26: assembled ELF64 image ("
    _uart_puts(am)
    _uart_puthex(arm64_p26_image_len)
    bm: Ptr[char] = " bytes); parsing + loading\n"
    _uart_puts(bm)

    # Recycle this ASID before first use.
    _dsb_ish()
    _tlbi_aside1is(P26_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()

    # Switch to the program's TTBR0+ASID so the loader's mapping edits are live.
    _msr_ttbr0_el1(P26_L1 | (P26_ASID << P23_ASID_SHIFT))
    _dsb_ish()
    _tlbi_aside1is(P26_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()

    entry: uint64 = arm64_p26_load_elf()
    if entry == cast[uint64](0):
        fp: Ptr[char] = "[arm64] Phase 26 ELF-loader FAIL\n"
        _uart_puts(fp)
        _msr_daifset(2)
        while True:
            _wfi()

    arm64_p26_active = 1

    enter: Ptr[char] = "[arm64] launching loaded ELF program at EL0 (ASID 15), entry "
    _uart_puts(enter)
    _uart_puthex(entry)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)

    _msr_spsr_el1(SPSR_EL0T_DAIF)           # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(entry)                     # EL0 entry PC = parsed e_entry
    _msr_sp_el0(P26_STACK_TOP)              # EL0 stack pointer
    _isb()
    _eret()                                 # -> EL0; segments fault in, program runs
    # Unreachable: the program's exit() halts after the PASS marker.
    while True:
        _wfi()
    return 0


# ===========================================================================
# Phase 27 — TIMER-PREEMPTIVE ROUND-ROBIN between two concurrent EL0 tasks.
#
# Two independent EL0 user tasks (T0 = slot 0, T1 = slot 1) each run in their
# OWN ASID-tagged address space (reusing the Phase-25 slot machinery: separate
# ASID, TTBR0, L1/L2/L3, EL0 stack and saved register-context block). Both run
# the SAME small EL0 routine at the SAME virtual address (P25_CODE_BASE) — a
# pure busy loop that endlessly increments a per-task counter at the SAME EL0
# virtual address (P25_DATA_VA). But that VA maps, per ASID, to a DIFFERENT
# PHYSICAL page in each space (P27_T0_DATA_PA vs P27_T1_DATA_PA), so each task
# increments its OWN counter, proving genuine address-space isolation.
#
# Neither task ever issues a syscall or yields: the ONLY thing that moves
# control between them is the generic timer. On each timer IRQ at EL1 the
# generic .S vector (arm64_lower_irq_entry) saves the interrupted task's FULL
# register context (x0..x30, SP_EL0, ELR_EL1, SPSR_EL1) into that task's
# context block and calls arm64_sched_pick(), which (while arm64_p27_active)
# routes here: we ack + re-arm the timer, EOI to the GIC, round-robin to the
# OTHER task, swap TTBR0+ASID (arm64_p25_switch_to), publish the next task's
# context block, and the .S stub restores it + ERETs into the next task with
# IRQs UNMASKED in its SPSR (SPSR_EL0T_IRQ) so the timer keeps preempting.
#
# After P27_TICK_GOAL preemptions we stop scheduling and run the verdict: PASS
# iff BOTH counters advanced (> 0), enough involuntary preemptions occurred
# (>= P27_SWITCH_MIN), and the two counters live at the same EL0 VA but in
# DISTINCT physical pages (own-address-space proof).
# ===========================================================================

# Two DISTINCT physical backing pages for the per-task counter, both 2 MiB
# clear of Phase 25's shared data page (0x4300_0000) and each other.
P27_T0_DATA_PA: uint64 = 0x43200000
P27_T1_DATA_PA: uint64 = 0x43400000

# How many preemptive ticks to run before the verdict, and the minimum number
# of involuntary context switches the verdict demands as proof of real
# preemption (not a single switch).
P27_TICK_GOAL: int64 = 60
P27_SWITCH_MIN: int64 = 4

# Phase 27 bookkeeping. arm64_p27_active routes the timer IRQ into this picker
# while the demo is live. arm64_p27_cur is the live slot (0=T0, 1=T1).
arm64_p27_active: int64 = 0
arm64_p27_cur: int64 = 0
arm64_p27_switches: int64 = 0
# Per-task run-tally: how many ticks each task was the OUTGOING (running) task,
# i.e. how many times the timer actually caught it executing.
arm64_p27_t0_runs: int64 = 0
arm64_p27_t1_runs: int64 = 0


# Materialise the shared Phase-27 EL0 busy-increment routine at P25_CODE_BASE.
# Both tasks map this identical text at the same VA; it endlessly increments the
# 64-bit counter at P25_DATA_VA (which is a DIFFERENT physical page per ASID):
#   entry:  x10 = P25_DATA_VA
#   loop:   ldr  x9, [x10]
#           add  x9, x9, #1
#           str  x9, [x10]
#           b    loop
# No syscall, no yield: only the timer preempts it.
def arm64_build_p27_routine() -> int64:
    a: uint64 = P25_CODE_BASE

    # x10 = P25_DATA_VA (the per-task counter VA).
    a = _emit_load_imm64(a, cast[uint64](10), P25_DATA_VA)

    loop_top: uint64 = a
    # ldr x9, [x10]   = 0xF9400000 | (x10 << 5) | x9
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # add x9, x9, #1  = 0x91000400 | (x9 << 5) | x9  (imm12=1 in bits[21:10])
    a = _emit_word(a, cast[uint64](0x91000000) | (cast[uint64](1) << cast[uint64](10)) | (cast[uint64](9) << cast[uint64](5)) | cast[uint64](9))
    # str x9, [x10]   = 0xF9000000 | (x10 << 5) | x9
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
    # b loop_top : 0x14000000 | imm26 ; imm26 = (loop_top - here) / 4.
    b_here: uint64 = a
    off_loop: int64 = cast[int64](loop_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# Phase-27 timer-IRQ scheduler — invoked (via arm64_sched_pick) from the EL0 IRQ
# vector with the interrupted task's register context already saved by the .S
# stub. Ack + re-arm the timer, EOI to the GIC, tally the outgoing task's run,
# round-robin to the peer slot, swap TTBR0+ASID into its private space, publish
# its context block, and return it so the stub restores+ERETs into it. After
# P27_TICK_GOAL preemptions, run the verdict (never returns).
def arm64_p27_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this task
        return cur_ctx

    # Quiesce, re-arm, and EOI the timer for the next tick.
    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    # Tally which task the timer just caught running (the OUTGOING task).
    out_idx: int64 = arm64_p27_cur
    if out_idx == 0:
        arm64_p27_t0_runs = arm64_p27_t0_runs + 1
    else:
        arm64_p27_t1_runs = arm64_p27_t1_runs + 1

    arm64_p27_switches = arm64_p27_switches + 1
    swmsg: Ptr[char] = "[arm64] Phase 27 preempt switch\n"
    _uart_puts(swmsg)

    # Verdict once enough involuntary preemptions have run.
    if arm64_p27_switches >= P27_TICK_GOAL:
        arm64_p27_finish()
        while True:
            _wfi()

    # Round-robin to the peer slot (both tasks are always RUNNABLE here).
    nxt: int64 = out_idx + 1
    if nxt >= 2:
        nxt = 0

    arm64_p27_cur = nxt
    arm64_p25_switch_to(nxt)                  # TTBR0+ASID -> the incoming task

    next_ctx: uint64 = arm64_p25_ctx_for(nxt)
    arm64_current_ctx = next_ctx              # publish for the .S restore path
    return next_ctx


# Phase-27 verdict. PASS iff: BOTH per-task counters advanced (each > 0, proving
# the timer ran BOTH distinct EL0 contexts, not just one); enough involuntary
# preemptions occurred (>= P27_SWITCH_MIN); the timer caught EACH task running
# at least once; and the two counters live at the SAME EL0 VA (P25_DATA_VA) but
# in DISTINCT physical pages (so T0's increments never touched T1's counter).
# Print the summary, the PASS/FAIL marker, then halt (this is the last phase).
def arm64_p27_finish() -> int64:
    arm64_p27_active = 0
    nl: Ptr[char] = "\n"

    # Read each task's counter straight from its OWN physical backing page.
    t0p: Ptr[uint64] = cast[Ptr[uint64]](P27_T0_DATA_PA)
    t1p: Ptr[uint64] = cast[Ptr[uint64]](P27_T1_DATA_PA)
    t0: uint64 = t0p[0]
    t1: uint64 = t1p[0]

    asid_flips: int64 = arm64_p27_switches    # every switch flipped TTBR0 ASID

    sm: Ptr[char] = "[arm64] Phase 27 summary: t0="
    _uart_puts(sm)
    _uart_puthex(t0)
    s2: Ptr[char] = " t1="
    _uart_puts(s2)
    _uart_puthex(t1)
    s3: Ptr[char] = " switches="
    _uart_puts(s3)
    _uart_puthex(cast[uint64](arm64_p27_switches))
    s4: Ptr[char] = " asid_flips="
    _uart_puts(s4)
    _uart_puthex(cast[uint64](asid_flips))
    _uart_puts(nl)

    ok: int64 = 1
    # BOTH tasks made forward progress under involuntary preemption.
    if t0 == cast[uint64](0):
        ok = 0
    if t1 == cast[uint64](0):
        ok = 0
    # Enough preemptions occurred (not a single switch).
    if arm64_p27_switches < P27_SWITCH_MIN:
        ok = 0
    # The timer actually caught EACH task running at least once.
    if arm64_p27_t0_runs <= 0:
        ok = 0
    if arm64_p27_t1_runs <= 0:
        ok = 0
    # Own-address-space proof: the two counters live in DISTINCT physical pages.
    if P27_T0_DATA_PA == P27_T1_DATA_PA:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 27: the generic timer preemptively round-robined two EL0 tasks in separate ASID address spaces; each advanced its OWN counter (same VA, distinct physical pages) with no syscall/yield\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 27 PASS\n"
        _uart_puts(pp)
        # Phase 27 complete and clean. Hand off to Phase 28 (a REAL blocking
        # scheduler with a per-task RUNNABLE/SLEEPING state model across THREE EL0
        # tasks: each task increments its own counter, then issues a blocking
        # sleep syscall; the timer-IRQ scheduler skips SLEEPING tasks and wakes
        # them when their deadline passes). This is the Phase 27 -> 28 hand-off.
        # arm64_p28_run never returns (its finish halts after the verdict).
        arm64_p28_run()
        # Unreachable: arm64_p28_run halts. Safety loop.
        while True:
            _wfi()
    else:
        fp: Ptr[char] = "[arm64] Phase 27 FAIL\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-27 entry point (from the Phase-26 finish hand-off). Build both tasks'
# private ASID-tagged address spaces (each mapping the SHARED counter VA to its
# OWN distinct physical page, pre-zeroed) + the shared EL0 busy-increment
# routine + per-task context blocks; recycle both ASIDs once; then ERET into
# task 0 under its private TTBR0+ASID with the timer LIVE and IRQs UNMASKED in
# EL0 (via the context SPSR) so the timer involuntarily preempts and
# round-robins the two tasks. Never returns (halts at the verdict).
def arm64_p27_run() -> int64:
    intro: Ptr[char] = "[arm64] Phase 27: timer-preemptive round-robin between two EL0 tasks\n"
    _uart_puts(intro)

    # Mask EL1 IRQs while we build everything so a stray timer IRQ cannot run the
    # scheduler mid-setup; re-enable just before the ERET into task 0.
    _msr_daifset(2)

    # Zero each task's private counter page (counter at offset 0).
    z0: Ptr[uint64] = cast[Ptr[uint64]](P27_T0_DATA_PA)
    z1: Ptr[uint64] = cast[Ptr[uint64]](P27_T1_DATA_PA)
    z0[0] = cast[uint64](0)
    z1[0] = cast[uint64](0)
    _dsb_ish()

    # Build each task's private space (slot 0 -> T0's data page, slot 1 -> T1's
    # data page), the shared EL0 routine, and each task's context block.
    arm64_p25_build_space(0, P27_T0_DATA_PA, P25_PAGE_RW)
    arm64_p25_build_space(1, P27_T1_DATA_PA, P25_PAGE_RW)
    arm64_build_p27_routine()
    arm64_init_ctx(arm64_p25_ctx_for(0), P25_CODE_BASE, arm64_p25_stack_for(0))
    arm64_init_ctx(arm64_p25_ctx_for(1), P25_CODE_BASE, arm64_p25_stack_for(1))

    # Recycle both slots' ASIDs before first use; thereafter swaps need no flush.
    _dsb_ish()
    _tlbi_aside1is(arm64_p25_asid_for(0) << P23_ASID_SHIFT)
    _tlbi_aside1is(arm64_p25_asid_for(1) << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p27_cur = 0
    arm64_p27_switches = 0
    arm64_p27_t0_runs = 0
    arm64_p27_t1_runs = 0
    arm64_current_ctx = arm64_p25_ctx_for(0)
    arm64_p27_active = 1

    enter: Ptr[char] = "[arm64] launching two preemptive EL0 tasks (T0 slot 0, T1 slot 1; separate ASIDs)\n"
    _uart_puts(enter)

    # Switch to task 0's private space, re-arm + enable the timer, unmask EL1
    # IRQs, then ERET into task 0 at EL0t WITH IRQs unmasked (via its context
    # SPSR == SPSR_EL0T_IRQ) so the timer preempts it.
    arm64_p25_switch_to(0)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p25_ctx_for(0))
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> task 0 at EL0; never returns here
    return 0


# ===========================================================================
# Phase 28 — a REAL BLOCKING SCHEDULER with a per-task state model + a blocking
# sleep/yield syscall + timer-driven wake, scaled to THREE concurrent EL0 tasks.
#
# Three independent EL0 tasks (T0/T1/T2 = slots 0/1/2) each run in their OWN
# ASID-tagged address space (separate ASID, TTBR0, L1/L2/L3, EL0 stack and saved
# register-context block — the same per-slot machinery Phases 21/27 use, here
# built for a THIRD slot). Each task runs the SAME small EL0 routine at the SAME
# virtual address: increment a 64-bit counter at the SAME EL0 VA (P28_DATA_VA)
# a few times, then issue a BLOCKING sleep syscall (x8 = SYS_P28_SLEEP_NR,
# x0 = ticks). That VA maps, per ASID, to a DIFFERENT PHYSICAL page per task, so
# each task advances its OWN counter — genuine per-ASID address-space isolation.
#
# Unlike Phase 27 (pure timer round-robin, no syscall), Phase 28 adds a real
# task-state model: every task is RUNNABLE or SLEEPING. The sleep syscall DESCH-
# EDULES the caller: it saves the caller's full resume context, records a wake
# deadline = current_tick + a0, marks it SLEEPING (incrementing `sleeps`), parks
# its EL0 PC on a harmless self-loop and points arm64_current_ctx at a throwaway
# park ctx, so the immediate svc-eret merely spins until the next timer tick.
#
# On each timer IRQ the scheduler (arm64_p28_sched_pick) FIRST advances a logical
# tick, then WAKES any SLEEPING task whose deadline has passed (back to RUNNABLE,
# incrementing `wakes`), THEN picks the next RUNNABLE task round-robin — SKIPPING
# any SLEEPING task (incrementing `skips` for each one passed over). It swaps
# TTBR0+ASID into the chosen task and ERETs into it. A SLEEPING task is therefore
# genuinely never dispatched until the timer wakes it: real block -> yield -> wake.
#
# After P28_TICK_GOAL ticks the verdict asserts: all three counters advanced
# (each task ran); enough tasks blocked AND were woken (sleeps>=3, wakes>=3,
# wakes==sleeps so no lost wakeups / nothing left stuck SLEEPING); the picker
# genuinely skipped SLEEPING tasks at least once (skips>0); and the three
# counters live at the same VA in DISTINCT physical pages (per-ASID isolation).
# ===========================================================================

# Per-task counter VA (resolved per-ASID to a DIFFERENT private physical page).
# 2 MiB-aligned, L2 index 25 (0x4320_0000) — a fresh VA slot clear of every prior
# phase's EL0 windows. NOTE: this is a VIRTUAL address; each slot's L2 maps it to
# its OWN physical block, so the three tasks never touch each other's counter.
P28_DATA_VA: uint64 = 0x43200000
P28_DATA_L2_INDEX: uint64 = 25           # (0x4320_0000 - 0x4000_0000) / 2 MiB

# THREE DISTINCT physical backing pages for the per-task counter, each 2 MiB
# clear of every prior phase's data block (P26 stack page ends at 0x4360_0000)
# and of each other. These are read directly by the verdict to prove isolation.
P28_T0_DATA_PA: uint64 = 0x43800000
P28_T1_DATA_PA: uint64 = 0x43A00000
P28_T2_DATA_PA: uint64 = 0x43C00000

# Per-slot private translation roots (4 KiB EL1-only RAM pages) + RAM L2 tables,
# in free EL1-only RAM above the Phase-26 page-table scratch (ends 0x401B_5000)
# and below the EL0 RWX window (0x4020_0000).
P28_S0_L1: uint64 = 0x401C0000
P28_S0_L2: uint64 = 0x401C1000
P28_S1_L1: uint64 = 0x401C2000
P28_S1_L2: uint64 = 0x401C3000
P28_S2_L1: uint64 = 0x401C4000
P28_S2_L2: uint64 = 0x401C5000

# Per-slot context blocks (34 x 8-byte slots) + a throwaway "park" ctx, in
# EL1-only RAM above the per-slot L1/L2 scratch (ends 0x401C_6000).
P28_S0_CTX: uint64 = 0x401C6000
P28_S1_CTX: uint64 = 0x401C7000
P28_S2_CTX: uint64 = 0x401C8000
P28_PARK_CTX: uint64 = 0x401C9000

# Per-slot ASIDs, distinct from every prior phase's ASIDs (..,13,14). A swap
# between these tagged spaces needs no broad TLB flush.
P28_S0_ASID: uint64 = 20
P28_S1_ASID: uint64 = 21
P28_S2_ASID: uint64 = 22
P28_ASID_SHIFT: uint64 = 48

# Per-slot EL0 code + stacks inside the shared EL0 RWX window (USER_L2_INDEX),
# above Phase 27's code/stacks (P25 code at 0x4024_0000, P25 stacks <=0x402C_8000)
# and below the EL0 window top (0x4040_0000).
P28_S0_CODE: uint64 = 0x40250000
P28_S1_CODE: uint64 = 0x40254000
P28_S2_CODE: uint64 = 0x40258000
P28_S0_STACK_TOP: uint64 = 0x402D0000
P28_S1_STACK_TOP: uint64 = 0x402D8000
P28_S2_STACK_TOP: uint64 = 0x402E0000

# How many counter-increments each task performs between sleeps (a few, so the
# counter advances visibly), and how many ticks each task sleeps. T0 sleeps LONG,
# T1 medium, T2 SHORT, so at any instant some tasks are SLEEPING while others run
# — the scheduler must keep dispatching the RUNNABLE ones and skipping sleepers.
P28_S0_WORK: int64 = 6
P28_S1_WORK: int64 = 6
P28_S2_WORK: int64 = 6
P28_S0_SLEEP: int64 = 5
P28_S1_SLEEP: int64 = 3
P28_S2_SLEEP: int64 = 1

# Kernel-private syscall numbers (clear of every prior private nr).
SYS_P28_SLEEP_NR: uint64 = 600       # a0 = number of timer ticks to sleep (block)

# Task-state model: RUNNABLE => eligible to be scheduled; SLEEPING => descheduled
# until the timer's logical tick reaches the task's wake deadline.
P28_RUNNABLE: int64 = 1
P28_SLEEPING: int64 = 2

# How many timer ticks to run before the verdict.
P28_TICK_GOAL: int64 = 90

# Phase 28 bookkeeping. arm64_p28_active routes svc + timer IRQ into the Phase-28
# path while the demo is live. arm64_p28_cur is the live slot (0/1/2).
arm64_p28_active: int64 = 0
arm64_p28_cur: int64 = 0
arm64_p28_tick: int64 = 0            # logical scheduler tick (advanced per timer IRQ)
arm64_p28_switches: int64 = 0        # TTBR0+ASID swaps performed
arm64_p28_sleeps: int64 = 0          # times a task was put to SLEEPING via the syscall
arm64_p28_wakes: int64 = 0           # times a SLEEPING task's deadline expired -> RUNNABLE
arm64_p28_skips: int64 = 0           # times the picker passed over a SLEEPING task

# Per-slot state + wake-deadline (logical-tick units). Module-scope globals match
# the file's style (Phase 21 uses the same per-slot-global pattern).
arm64_p28_state0: int64 = 0
arm64_p28_state1: int64 = 0
arm64_p28_state2: int64 = 0
arm64_p28_deadline0: int64 = 0
arm64_p28_deadline1: int64 = 0
arm64_p28_deadline2: int64 = 0


# ---- per-slot accessors (idx: 0 = T0, 1 = T1, 2 = T2) ---------------------
def arm64_p28_l1_for(idx: int64) -> uint64:
    if idx == 0:
        return P28_S0_L1
    if idx == 1:
        return P28_S1_L1
    return P28_S2_L1

def arm64_p28_l2_for(idx: int64) -> uint64:
    if idx == 0:
        return P28_S0_L2
    if idx == 1:
        return P28_S1_L2
    return P28_S2_L2

def arm64_p28_data_for(idx: int64) -> uint64:
    if idx == 0:
        return P28_T0_DATA_PA
    if idx == 1:
        return P28_T1_DATA_PA
    return P28_T2_DATA_PA

def arm64_p28_asid_for(idx: int64) -> uint64:
    if idx == 0:
        return P28_S0_ASID
    if idx == 1:
        return P28_S1_ASID
    return P28_S2_ASID

def arm64_p28_code_for(idx: int64) -> uint64:
    if idx == 0:
        return P28_S0_CODE
    if idx == 1:
        return P28_S1_CODE
    return P28_S2_CODE

def arm64_p28_stack_for(idx: int64) -> uint64:
    if idx == 0:
        return P28_S0_STACK_TOP
    if idx == 1:
        return P28_S1_STACK_TOP
    return P28_S2_STACK_TOP

def arm64_p28_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P28_S0_CTX
    if idx == 1:
        return P28_S1_CTX
    return P28_S2_CTX

def arm64_p28_work_for(idx: int64) -> int64:
    if idx == 0:
        return P28_S0_WORK
    if idx == 1:
        return P28_S1_WORK
    return P28_S2_WORK

def arm64_p28_sleep_for(idx: int64) -> int64:
    if idx == 0:
        return P28_S0_SLEEP
    if idx == 1:
        return P28_S1_SLEEP
    return P28_S2_SLEEP

def arm64_p28_state_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p28_state0
    if idx == 1:
        return arm64_p28_state1
    return arm64_p28_state2

def arm64_p28_set_state(idx: int64, st: int64) -> int64:
    if idx == 0:
        arm64_p28_state0 = st
    elif idx == 1:
        arm64_p28_state1 = st
    else:
        arm64_p28_state2 = st
    return 0

def arm64_p28_deadline_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p28_deadline0
    if idx == 1:
        return arm64_p28_deadline1
    return arm64_p28_deadline2

def arm64_p28_set_deadline(idx: int64, dl: int64) -> int64:
    if idx == 0:
        arm64_p28_deadline0 = dl
    elif idx == 1:
        arm64_p28_deadline1 = dl
    else:
        arm64_p28_deadline2 = dl
    return 0


# Build slot `idx`'s private translation tree: a fresh L1 (entry 0 device, entry 1
# -> a fresh RAM L2 block-mapping the 1 GiB RAM Normal-WB, with the EL0 RWX window
# (USER_L2_INDEX) EL0-accessible) and the per-task counter VA's 2 MiB L2 slot
# (P28_DATA_L2_INDEX) mapped EL0-RW to this slot's OWN private physical block. All
# three slots map the SAME counter VA, but each to a DIFFERENT physical page.
def arm64_p28_build_space(idx: int64) -> int64:
    l1_base: uint64 = arm64_p28_l1_for(idx)
    l2_base: uint64 = arm64_p28_l2_for(idx)
    data_pa: uint64 = arm64_p28_data_for(idx)

    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1
    l1[0] = cast[uint64](0) | DEV_FLAGS

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0       # shared EL0 RWX code/stack window
        elif cast[uint64](j) == P28_DATA_L2_INDEX:
            l2[j] = data_pa | MEM_FLAGS_EL0      # per-task counter VA -> private block
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = l2_base | DESC_TABLE
    _dsb_ish()
    return 0


# Materialise slot `idx`'s EL0 routine at its private code page:
#   entry:  x10 = P28_DATA_VA              (this task's counter VA)
#   outer:  <work> increments: load/add/store the counter `work` times
#           x0 = sleep_ticks ; x8 = 600 (sleep) ; svc #0   (BLOCK for N ticks)
#           b outer                                          (resume here on wake)
# The sleep BLOCKS the task kernel-side; the scheduler runs RUNNABLE peers while
# it sleeps and wakes it at its deadline, resuming it at the `b outer` after svc.
def arm64_p28_build_task(idx: int64) -> int64:
    code_base: uint64 = arm64_p28_code_for(idx)
    work: int64 = arm64_p28_work_for(idx)
    sleep_n: int64 = arm64_p28_sleep_for(idx)
    a: uint64 = code_base

    # x10 = P28_DATA_VA (the per-task counter VA). Loaded once at entry.
    a = _emit_load_imm64(a, cast[uint64](10), P28_DATA_VA)

    outer_top: uint64 = a

    # <work> increments of the 64-bit counter at [x10].
    w: int64 = 0
    while w < work:
        # ldr x9, [x10]
        a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
        # add x9, x9, #1
        a = _emit_word(a, cast[uint64](0x91000000) | (cast[uint64](1) << cast[uint64](10)) | (cast[uint64](9) << cast[uint64](5)) | cast[uint64](9))
        # str x9, [x10]
        a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
        w = w + 1

    # x0 = sleep_ticks ; x8 = SYS_P28_SLEEP_NR ; svc #0  (blocking sleep)
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](sleep_n))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P28_SLEEP_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # b outer_top
    b_here: uint64 = a
    off_loop: int64 = cast[int64](outer_top) - cast[int64](b_here)
    imm26: uint64 = cast[uint64](off_loop >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# TTBR0_EL1 for slot `idx`: its private L1 root + its ASID in bits[63:48].
def arm64_p28_ttbr0_for(idx: int64) -> uint64:
    return arm64_p28_l1_for(idx) | (arm64_p28_asid_for(idx) << P28_ASID_SHIFT)


# Switch the live translation to slot `idx` (TTBR0+ASID). Per-ASID tagging keeps
# each slot's mapping of the counter VA distinct, so no broad TLB flush is needed.
def arm64_p28_switch_to(idx: int64) -> int64:
    _dsb_ish()
    _msr_ttbr0_el1(arm64_p28_ttbr0_for(idx))
    _isb()
    return 0


# Wake any SLEEPING task whose logical-tick deadline has passed: mark it RUNNABLE
# and tally the wake. The resume itself happens when the scheduler next selects it
# and the IRQ stub restores its saved ctx. Returns the number of tasks woken.
def arm64_p28_wake_expired() -> int64:
    woke: int64 = 0
    idx: int64 = 0
    while idx < 3:
        if arm64_p28_state_for(idx) == P28_SLEEPING:
            if arm64_p28_tick >= arm64_p28_deadline_for(idx):
                arm64_p28_set_state(idx, P28_RUNNABLE)
                arm64_p28_wakes = arm64_p28_wakes + 1
                wm: Ptr[char] = "[arm64] Phase 28: waking task "
                _uart_puts(wm)
                _uart_puthex(cast[uint64](idx))
                nl: Ptr[char] = " (deadline passed)\n"
                _uart_puts(nl)
                woke = woke + 1
        idx = idx + 1
    return woke


# Pick the next RUNNABLE slot after `from_idx`, round-robin over slots 0..2,
# SKIPPING SLEEPING slots (each skip is tallied as proof sleepers were passed
# over). Returns -1 if no slot is runnable (all three sleeping this tick).
def arm64_p28_next_runnable(from_idx: int64) -> int64:
    steps: int64 = 0
    idx: int64 = from_idx
    while steps < 3:
        idx = idx + 1
        if idx >= 3:
            idx = 0
        if arm64_p28_state_for(idx) == P28_RUNNABLE:
            return idx
        # Passed over a SLEEPING slot — record the skip (genuine skip proof).
        arm64_p28_skips = arm64_p28_skips + 1
        steps = steps + 1
    return -1


# Phase-28 timer-IRQ scheduler — invoked (via arm64_sched_pick) from the EL0 IRQ
# vector with the running slot's register context already saved by the .S stub.
# Ack + re-arm the timer, EOI the GIC, advance the logical tick, WAKE any SLEEPING
# task whose deadline passed, then round-robin to the next RUNNABLE slot (skipping
# sleepers), swap TTBR0+ASID into it and return its ctx so the stub ERETs into it.
# After P28_TICK_GOAL ticks, run the verdict (never returns).
def arm64_p28_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this slot
        return cur_ctx

    # Quiesce, re-arm, and EOI the timer for the next tick.
    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    # Advance the logical scheduler tick (the unit deadlines are measured in).
    arm64_p28_tick = arm64_p28_tick + 1

    # Wake any sleeper whose deadline has passed (SLEEPING -> RUNNABLE) BEFORE
    # picking — proving timer-driven wake, not task-self-wake.
    arm64_p28_wake_expired()

    # Verdict once enough ticks have run (tasks blocked + were woken repeatedly).
    # Before the verdict, DRAIN every still-SLEEPING task: keep advancing the
    # logical tick past the furthest deadline and waking each sleeper, so no task
    # is left blocked at the boundary and every sleep has its matching wake
    # (wakes == sleeps — no lost wakeups). This makes the cutoff deterministic
    # rather than slicing a task mid-sleep.
    if arm64_p28_tick >= P28_TICK_GOAL:
        guard: int64 = 0
        while guard < 64:
            pending: int64 = 0
            k: int64 = 0
            while k < 3:
                if arm64_p28_state_for(k) == P28_SLEEPING:
                    pending = pending + 1
                k = k + 1
            if pending == 0:
                guard = 64
            else:
                arm64_p28_tick = arm64_p28_tick + 1
                arm64_p28_wake_expired()
                guard = guard + 1
        arm64_p28_finish()
        while True:
            _wfi()

    nxt: int64 = arm64_p28_next_runnable(arm64_p28_cur)
    if nxt < 0:
        # All three SLEEPING this tick: no runnable task. Stay on the (parked)
        # current ctx; the next tick will wake a sleeper and pick it up. This is
        # the kernel idling while every task sleeps (legitimate, transient).
        return cur_ctx

    arm64_p28_switches = arm64_p28_switches + 1
    arm64_p28_cur = nxt
    arm64_p28_switch_to(nxt)                 # TTBR0+ASID -> the incoming slot
    next_ctx: uint64 = arm64_p28_ctx_for(nxt)
    arm64_current_ctx = next_ctx             # publish for the .S restore path
    return next_ctx


# Save the running slot's FULL resume context (x0..x30 from the svc frame, plus
# the post-svc ELR_EL1, SP_EL0 and an EL0+IRQs-on SPSR) into its ctx block, so the
# scheduler can restore it verbatim on wake. x0 is forced to 0 (sleep's return
# value once it resumes). The slot is the running one, so ELR_EL1/SP_EL0 are live.
def arm64_p28_save_resume_ctx(frame_ptr: Ptr[uint64], idx: int64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p28_ctx_for(idx))
    i: int64 = 0
    while i < 31:
        ctx[i] = frame_ptr[i]                # x0..x30 from the saved svc frame
        i = i + 1
    ctx[CTX_X0] = cast[uint64](0)            # sleep returns 0 on wake
    ctx[CTX_SP_EL0] = cast[uint64](_mrs_sp_el0())
    ctx[CTX_ELR] = cast[uint64](_mrs_elr_el1())   # resume PC = insn after the svc
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ            # EL0t, IRQs enabled (re-preemptible)
    _dsb_ish()
    return 0


# Park the blocking slot's LIVE EL0 context on a harmless self-loop so the svc
# eret merely spins until the next timer tick preempts it. CRUCIAL: point
# arm64_current_ctx at the THROWAWAY park ctx so the preempting IRQ saves the spin
# state THERE, not over the slot's real (just-saved) resume context.
def arm64_p28_park_blocked_el0(idx: int64) -> int64:
    park: uint64 = arm64_p28_code_for(idx) + cast[uint64](0xE00)
    _emit_word(park, cast[uint64](0x14000000))   # b . (self-loop)
    _dsb_ish()
    _isb()
    _msr_elr_el1(park)
    _isb()
    arm64_current_ctx = P28_PARK_CTX             # IRQ spills spin state here
    return 0


# Phase-28 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. Services SYS_P28_SLEEP_NR (600): a0 = ticks to sleep. DESCHEDULE the
# running slot — save its full resume context, set a logical-tick wake deadline,
# mark it SLEEPING (tally `sleeps`), and park its EL0 PC on a self-loop so the next
# timer tick switches to a RUNNABLE peer. The scheduler wakes it at its deadline.
def arm64_p28_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_P28_SLEEP_NR:
        ticks: int64 = cast[int64](a0)
        if ticks < 1:
            ticks = 1
        cur: int64 = arm64_p28_cur

        # Save the caller's full resume context so it can RESUME past the svc.
        arm64_p28_save_resume_ctx(frame_ptr, cur)

        # Wake deadline in logical-tick units = current tick + requested ticks.
        arm64_p28_set_deadline(cur, arm64_p28_tick + ticks)
        arm64_p28_set_state(cur, P28_SLEEPING)
        arm64_p28_sleeps = arm64_p28_sleeps + 1

        bm: Ptr[char] = "[arm64] Phase 28: task "
        _uart_puts(bm)
        _uart_puthex(cast[uint64](cur))
        bn: Ptr[char] = " sleep -> SLEEPING for "
        _uart_puts(bn)
        _uart_puthex(cast[uint64](ticks))
        bt: Ptr[char] = " ticks\n"
        _uart_puts(bt)

        # Park the blocked slot's EL0 PC on a self-loop; the next timer tick
        # preempts it and the scheduler runs a RUNNABLE peer (or idles if all
        # three sleep). arm64_current_ctx now points at the throwaway park ctx so
        # the preempting IRQ does not clobber the saved resume context.
        arm64_p28_park_blocked_el0(cur)
        frame_ptr[0] = cast[uint64](0)
        return 0

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 28)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-28 verdict. PASS iff: all THREE counters advanced (each task ran); enough
# tasks blocked AND were woken (sleeps>=3 AND wakes>=3 AND wakes==sleeps, so no
# lost wakeups and nothing left stuck SLEEPING); the picker genuinely skipped a
# SLEEPING task at least once (skips>0); and the three counters live at the SAME
# VA in DISTINCT physical pages. Print the summary + marker, then halt (last phase).
def arm64_p28_finish() -> int64:
    arm64_p28_active = 0
    nl: Ptr[char] = "\n"

    # Read each task's counter straight from its OWN physical backing page.
    t0p: Ptr[uint64] = cast[Ptr[uint64]](P28_T0_DATA_PA)
    t1p: Ptr[uint64] = cast[Ptr[uint64]](P28_T1_DATA_PA)
    t2p: Ptr[uint64] = cast[Ptr[uint64]](P28_T2_DATA_PA)
    t0: uint64 = t0p[0]
    t1: uint64 = t1p[0]
    t2: uint64 = t2p[0]

    sm: Ptr[char] = "[arm64] Phase 28 summary: t0="
    _uart_puts(sm)
    _uart_puthex(t0)
    s1: Ptr[char] = " t1="
    _uart_puts(s1)
    _uart_puthex(t1)
    s2: Ptr[char] = " t2="
    _uart_puts(s2)
    _uart_puthex(t2)
    s3: Ptr[char] = " sleeps="
    _uart_puts(s3)
    _uart_puthex(cast[uint64](arm64_p28_sleeps))
    s4: Ptr[char] = " wakes="
    _uart_puts(s4)
    _uart_puthex(cast[uint64](arm64_p28_wakes))
    s5: Ptr[char] = " skips="
    _uart_puts(s5)
    _uart_puthex(cast[uint64](arm64_p28_skips))
    s6: Ptr[char] = " switches="
    _uart_puts(s6)
    _uart_puthex(cast[uint64](arm64_p28_switches))
    _uart_puts(nl)

    ok: int64 = 1
    # All three tasks made forward progress (the 3-way scheduler dispatched each).
    if t0 == cast[uint64](0):
        ok = 0
    if t1 == cast[uint64](0):
        ok = 0
    if t2 == cast[uint64](0):
        ok = 0
    # Real block/wake cycles: enough sleeps + wakes, and every sleeper woke.
    if arm64_p28_sleeps < 3:
        ok = 0
    if arm64_p28_wakes < 3:
        ok = 0
    if arm64_p28_wakes != arm64_p28_sleeps:
        ok = 0
    # The picker genuinely passed over SLEEPING tasks at least once.
    if arm64_p28_skips <= 0:
        ok = 0
    # No task left stuck SLEEPING at the verdict (all back to RUNNABLE / runnable).
    if arm64_p28_state_for(0) == P28_SLEEPING:
        ok = 0
    if arm64_p28_state_for(1) == P28_SLEEPING:
        ok = 0
    if arm64_p28_state_for(2) == P28_SLEEPING:
        ok = 0
    # Own-address-space proof: the three counters live in DISTINCT physical pages.
    if P28_T0_DATA_PA == P28_T1_DATA_PA:
        ok = 0
    if P28_T0_DATA_PA == P28_T2_DATA_PA:
        ok = 0
    if P28_T1_DATA_PA == P28_T2_DATA_PA:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 28: a blocking scheduler with per-task RUNNABLE/SLEEPING state round-robined THREE EL0 tasks, blocking each on a sleep syscall and waking it by timer deadline; sleepers were genuinely skipped; each advanced its OWN counter (same VA, distinct physical pages)\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 28 PASS\n"
        _uart_puts(pp)
        # Hand off to Phase 29 (EL0 task exit + wait/reap). It builds its own
        # tasks/spaces and never returns (its finish halts after the verdict).
        arm64_p29_run()
        # Unreachable: arm64_p29_run halts. Safety loop.
        _msr_daifset(2)
        while True:
            _wfi()
    else:
        fp: Ptr[char] = "[arm64] Phase 28 FAIL\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-28 entry point (from the Phase-27 finish hand-off). Build all THREE tasks'
# private ASID-tagged address spaces (each mapping the SHARED counter VA to its OWN
# distinct physical page, pre-zeroed) + per-task EL0 routines + context blocks;
# recycle all three ASIDs once; mark all RUNNABLE; then ERET into task 0 under its
# private TTBR0+ASID with the timer LIVE and IRQs UNMASKED in EL0 so the timer
# preempts and the blocking scheduler runs. Never returns (halts at the verdict).
def arm64_p28_run() -> int64:
    intro: Ptr[char] = "[arm64] Phase 28: blocking scheduler (RUNNABLE/SLEEPING) across three EL0 tasks\n"
    _uart_puts(intro)

    # Mask EL1 IRQs while we build everything so a stray timer IRQ cannot run the
    # scheduler mid-setup; re-enable just before the ERET into task 0.
    _msr_daifset(2)

    # Zero each task's private counter page (counter at offset 0).
    z0: Ptr[uint64] = cast[Ptr[uint64]](P28_T0_DATA_PA)
    z1: Ptr[uint64] = cast[Ptr[uint64]](P28_T1_DATA_PA)
    z2: Ptr[uint64] = cast[Ptr[uint64]](P28_T2_DATA_PA)
    z0[0] = cast[uint64](0)
    z1[0] = cast[uint64](0)
    z2[0] = cast[uint64](0)
    _dsb_ish()

    # Build each task's private space + EL0 routine + context block.
    i: int64 = 0
    while i < 3:
        arm64_p28_build_space(i)
        arm64_p28_build_task(i)
        arm64_init_ctx(arm64_p28_ctx_for(i), arm64_p28_code_for(i), arm64_p28_stack_for(i))
        arm64_p28_set_state(i, P28_RUNNABLE)
        arm64_p28_set_deadline(i, 0)
        i = i + 1

    # Recycle all three slots' ASIDs before first use; thereafter swaps need no
    # broad flush.
    _dsb_ish()
    _tlbi_aside1is(arm64_p28_asid_for(0) << P28_ASID_SHIFT)
    _tlbi_aside1is(arm64_p28_asid_for(1) << P28_ASID_SHIFT)
    _tlbi_aside1is(arm64_p28_asid_for(2) << P28_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p28_cur = 0
    arm64_p28_tick = 0
    arm64_p28_switches = 0
    arm64_p28_sleeps = 0
    arm64_p28_wakes = 0
    arm64_p28_skips = 0
    arm64_current_ctx = arm64_p28_ctx_for(0)
    arm64_p28_active = 1

    enter: Ptr[char] = "[arm64] launching three blocking EL0 tasks (T0 slot 0, T1 slot 1, T2 slot 2; separate ASIDs)\n"
    _uart_puts(enter)

    # Switch to task 0's private space, re-arm + enable the timer, unmask EL1
    # IRQs, then ERET into task 0 at EL0t WITH IRQs unmasked (via its context
    # SPSR == SPSR_EL0T_IRQ) so the timer preempts it.
    arm64_p28_switch_to(0)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p28_ctx_for(0))
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> task 0 at EL0; never returns here
    return 0


# ===========================================================================
# Phase 29 — EL0 TASK EXIT + PARENT WAIT/REAP, the Linux-style process-exit
# lifecycle, layered directly on Phase 28's blocking-scheduler state machine and
# scaled to THREE concurrent EL0 tasks.
#
# Three independent EL0 tasks (T0/T1/T2 = slots 0/1/2) each run in their OWN
# ASID-tagged address space (separate ASID, TTBR0, L1/L2, EL0 stack and saved
# register-context block — cloned from the Phase-28 per-slot machinery). Each
# task increments a 64-bit counter at a SHARED EL0 VA (P29_DATA_VA) that maps,
# per ASID, to a DIFFERENT PHYSICAL page, then EXITS with a DISTINCT status:
# task i exits with status (0x10 + i). Task 0 first BLOCKS on a sleep syscall
# (reusing the Phase-28 sleep semantics) before exiting, proving exit composes
# with the existing RUNNABLE/SLEEPING blocking-state machine.
#
# Task-state model extends Phase 28's RUNNABLE/SLEEPING with two terminal states:
#   EXITED  — the task called exit(status); it is a ZOMBIE (status recorded, but
#             not yet collected). The scheduler must NEVER dispatch it.
#   DEAD    — the reaper collected (reaped) its exit status; fully gone.
#
# The exit syscall (SYS_P29_EXIT_NR = 601, status in x0) records the caller's
# status, marks it EXITED, and parks its EL0 PC on a self-loop. On each timer IRQ
# the scheduler advances a logical tick, WAKES expired sleepers, then REAPS any
# EXITED task (collecting its status into exit_status[i], EXITED -> DEAD, bumping
# a reap counter), then round-robins the RUNNABLE tasks (SKIPPING SLEEPING ones
# and never selecting EXITED/DEAD ones). Once all three tasks are DEAD the verdict
# runs: every task reached EXITED then DEAD; each exit_status matches the distinct
# value the task passed; reaps == 3 (each reaped exactly once); each private
# counter advanced; the three data pages are at distinct physical addresses.
# ===========================================================================

# Per-task counter VA (resolved per-ASID to a DIFFERENT private physical page).
# 2 MiB-aligned, a fresh L2 slot clear of every prior phase's EL0 windows.
P29_DATA_VA: uint64 = 0x44200000
P29_DATA_L2_INDEX: uint64 = 33           # (0x4420_0000 - 0x4000_0000) / 2 MiB

# THREE DISTINCT physical backing pages for the per-task counter, each 2 MiB and
# clear of every prior phase's data block (Phase 28's end at 0x43C0_0000) and of
# each other. These are read directly by the verdict to prove isolation.
P29_T0_DATA_PA: uint64 = 0x44800000
P29_T1_DATA_PA: uint64 = 0x44A00000
P29_T2_DATA_PA: uint64 = 0x44C00000

# Per-slot private translation roots (4 KiB EL1-only RAM pages) + RAM L2 tables,
# in free EL1-only RAM above the Phase-28 page-table scratch (ends 0x401C_A000).
P29_S0_L1: uint64 = 0x401CA000
P29_S0_L2: uint64 = 0x401CB000
P29_S1_L1: uint64 = 0x401CC000
P29_S1_L2: uint64 = 0x401CD000
P29_S2_L1: uint64 = 0x401CE000
P29_S2_L2: uint64 = 0x401CF000

# Per-slot context blocks (34 x 8-byte slots) + a throwaway "park" ctx, in
# EL1-only RAM above the per-slot L1/L2 scratch (ends 0x401D_0000).
P29_S0_CTX: uint64 = 0x401D0000
P29_S1_CTX: uint64 = 0x401D1000
P29_S2_CTX: uint64 = 0x401D2000
P29_PARK_CTX: uint64 = 0x401D3000

# Per-slot ASIDs, distinct from every prior phase's ASIDs (Phase 28 used 20..22).
P29_S0_ASID: uint64 = 23
P29_S1_ASID: uint64 = 24
P29_S2_ASID: uint64 = 25
P29_ASID_SHIFT: uint64 = 48

# Per-slot EL0 code + stacks inside the shared EL0 RWX window (USER_L2_INDEX),
# above Phase 28's code/stacks (P28 code <=0x4025_8000, stacks <=0x402E_0000)
# and below the EL0 window top (0x4040_0000).
P29_S0_CODE: uint64 = 0x40260000
P29_S1_CODE: uint64 = 0x40264000
P29_S2_CODE: uint64 = 0x40268000
P29_S0_STACK_TOP: uint64 = 0x402E8000
P29_S1_STACK_TOP: uint64 = 0x402F0000
P29_S2_STACK_TOP: uint64 = 0x402F8000

# How many counter-increments each task performs before exiting (a few, so the
# counter advances visibly). Task 0 ALSO sleeps this many ticks before exiting.
P29_S0_WORK: int64 = 5
P29_S1_WORK: int64 = 7
P29_S2_WORK: int64 = 9
P29_S0_SLEEP: int64 = 4        # only T0 sleeps before exit (composes with blocking)

# DISTINCT per-task exit statuses: task i exits with status (0x10 + i).
P29_T0_STATUS: int64 = 0x10
P29_T1_STATUS: int64 = 0x11
P29_T2_STATUS: int64 = 0x12

# Kernel-private syscall numbers (clear of every prior private nr; 600 is Phase
# 28's sleep, which Phase 29 reuses by number for the same blocking semantics).
SYS_P29_EXIT_NR: uint64 = 601        # a0 = exit status (terminate -> EXITED zombie)

# Task-state model: RUNNABLE / SLEEPING reuse Phase 28's numbering; EXITED is a
# zombie (status recorded, awaiting reap); DEAD is fully reaped.
P29_RUNNABLE: int64 = 1
P29_SLEEPING: int64 = 2
P29_EXITED: int64 = 3                 # zombie: called exit, not yet reaped
P29_DEAD: int64 = 4                  # reaped: status collected, fully gone

# How many tasks (and therefore how many reaps the verdict requires).
P29_NTASKS: int64 = 3

# Phase 29 bookkeeping. arm64_p29_active routes svc + timer IRQ into the Phase-29
# path while the demo is live. arm64_p29_cur is the live slot (0/1/2).
arm64_p29_active: int64 = 0
arm64_p29_cur: int64 = 0
arm64_p29_tick: int64 = 0            # logical scheduler tick
arm64_p29_switches: int64 = 0        # TTBR0+ASID swaps performed
arm64_p29_sleeps: int64 = 0          # times a task blocked via the sleep syscall
arm64_p29_wakes: int64 = 0           # times a SLEEPING task's deadline expired
arm64_p29_exits: int64 = 0           # times a task called exit (RUNNABLE -> EXITED)
arm64_p29_reaps: int64 = 0           # times the reaper collected a zombie (EXITED -> DEAD)

# Per-slot state + wake-deadline (logical-tick units) + recorded exit status.
arm64_p29_state0: int64 = 0
arm64_p29_state1: int64 = 0
arm64_p29_state2: int64 = 0
arm64_p29_deadline0: int64 = 0
arm64_p29_deadline1: int64 = 0
arm64_p29_deadline2: int64 = 0
arm64_p29_status0: int64 = -1        # exit status recorded by exit(); -1 = unset
arm64_p29_status1: int64 = -1
arm64_p29_status2: int64 = -1
arm64_p29_reaped0: int64 = 0         # per-task reap count (must end == 1)
arm64_p29_reaped1: int64 = 0
arm64_p29_reaped2: int64 = 0


# ===========================================================================
# PHASE 30 — virtio-mmio BLOCK DEVICE: read real sectors off a backing drive.
# ===========================================================================
# qemu `-machine virt` exposes 32 virtio-mmio transports starting at
# 0x0a00_0000, each window 0x200 bytes apart, with device IRQs as GIC SPIs from
# 48 upward. QEMU 10.x presents MODERN (version 2) virtio-mmio. We probe the 32
# windows for a virtio-blk device (MagicValue "virt" + DeviceID 2), bring it up
# per the virtio 1.x spec (reset -> ACKNOWLEDGE -> DRIVER -> feature negotiate ->
# FEATURES_OK -> program ONE split virtqueue -> DRIVER_OK), then issue a
# VIRTIO_BLK_T_IN read of sector 0 (and a couple more) into a buffer and verify
# the known boot tag the test wrote at sector 0. Pure POLLED MMIO — we busy-poll
# the used ring rather than take the device IRQ, so Phase 30 needs no GIC wiring.
#
# The transports live in entry[0] of the L1 map (VA 0x0000_0000..0x3FFF_FFFF),
# which arm64_mmu_init() maps Device-nGnRE — exactly right for MMIO registers.
# Our rings + buffers live in a fresh 2 MiB Normal-WB RAM block at 0x4500_0000,
# clear of every prior phase's data (Phase 29 ends at 0x44C0_0000).
# ---------------------------------------------------------------------------
VIRTIO_MMIO_BASE: uint64 = 0x0A000000        # transport 0
VIRTIO_MMIO_STRIDE: uint64 = 0x200           # bytes between transports
VIRTIO_MMIO_COUNT: int64 = 32                # number of transport windows
VIRTIO_MAGIC: uint64 = 0x74726976            # "virt"
VIRTIO_ID_BLOCK: uint64 = 2                  # DeviceID for a block device

# LEGACY (version 1) virtio-mmio register offsets. QEMU `-M virt` defaults its
# virtio-mmio transports to the LEGACY interface (Version==1), so we drive that.
VMMIO_MAGIC: uint64 = 0x000
VMMIO_VERSION: uint64 = 0x004
VMMIO_DEVICE_ID: uint64 = 0x008
VMMIO_HOST_FEATURES: uint64 = 0x010          # device features (read)
VMMIO_HOST_FEATURES_SEL: uint64 = 0x014
VMMIO_GUEST_FEATURES: uint64 = 0x020         # driver features (write)
VMMIO_GUEST_FEATURES_SEL: uint64 = 0x024
VMMIO_GUEST_PAGE_SIZE: uint64 = 0x028        # legacy: driver page size for PFN math
VMMIO_QUEUE_SEL: uint64 = 0x030
VMMIO_QUEUE_NUM_MAX: uint64 = 0x034
VMMIO_QUEUE_NUM: uint64 = 0x038
VMMIO_QUEUE_ALIGN: uint64 = 0x03C            # legacy: used-ring alignment
VMMIO_QUEUE_PFN: uint64 = 0x040              # legacy: queue page-frame number
VMMIO_QUEUE_NOTIFY: uint64 = 0x050
VMMIO_INTERRUPT_STATUS: uint64 = 0x060
VMMIO_INTERRUPT_ACK: uint64 = 0x064
VMMIO_STATUS: uint64 = 0x070

# Legacy version value.
VIRTIO_VERSION_LEGACY: uint64 = 1

# Legacy guest page size + queue alignment (4 KiB).
P30_PAGE_SIZE: uint64 = 4096
P30_QUEUE_ALIGN: uint64 = 4096

# Device status bits.
VSTATUS_ACKNOWLEDGE: uint32 = 1
VSTATUS_DRIVER: uint32 = 2
VSTATUS_DRIVER_OK: uint32 = 4
VSTATUS_FAILED: uint32 = 128

# Virtqueue descriptor flags.
VRING_DESC_F_NEXT: uint16 = 1                 # descriptor chains to .next
VRING_DESC_F_WRITE: uint16 = 2               # device writes (driver reads)

# virtio-blk request header layout + types.
VIRTIO_BLK_T_IN: uint32 = 0                   # read from device
VIRTIO_BLK_T_OUT: uint32 = 1                  # write to device (Phase 35)
VIRTIO_BLK_S_OK: uint8 = 0                    # request status: success

# Our split virtqueue size (power of 2, <= QueueNumMax). 8 is plenty for a few
# in-flight single-sector reads done one at a time.
P30_QSIZE: int64 = 8

# LEGACY split-virtqueue layout: the WHOLE queue is ONE page-aligned contiguous
# region at PFN*P30_PAGE_SIZE, laid out as:
#   desc[QSIZE]  : 16 * QSIZE = 128 bytes  @ +0
#   avail ring   : flags(2)+idx(2)+ring[QSIZE]*2+used_event(2)  @ +128
#   <pad to QueueAlign (4096)>
#   used ring    : flags(2)+idx(2)+used_elem[QSIZE]*8+avail_event(2)  @ +4096
# So a QSIZE=8 queue fits in two 4 KiB pages. We place it page-aligned in a
# private Normal-WB 2 MiB RAM block (identity mapped), clear of every prior phase.
P30_RING_BASE: uint64 = 0x45000000           # page-aligned queue base (== PFN*4096)
P30_DESC_PA: uint64 = 0x45000000             # descriptor table     (+0)
P30_AVAIL_PA: uint64 = 0x45000080            # available ring       (+128)
P30_USED_PA: uint64 = 0x45001000             # used ring (QueueAlign +4096)
P30_HDR_PA: uint64 = 0x45003000              # 16-byte virtio-blk request header
P30_DATA_PA: uint64 = 0x45004000             # 512-byte sector data buffer
P30_STATUS_PA: uint64 = 0x45005000           # 1-byte request status byte

SECTOR_SIZE: int64 = 512

# Phase 30 bookkeeping.
arm64_p30_active: int64 = 0
arm64_p30_mmio_base: uint64 = 0              # base of the located virtio-blk transport
arm64_p30_avail_idx: uint16 = 0              # driver's running avail index


# ===========================================================================
# PHASE 33 — native virtio-net over virtio-mmio (qemu-virt). Reuses the SAME
# legacy virtio-mmio transport plumbing as the Phase-30 block driver; the only
# differences are DeviceID==1 (net), TWO virtqueues (queue 0 = RX, queue 1 = TX),
# and the 10-byte struct virtio_net_hdr prepended to every frame on both rings.
# ===========================================================================

VIRTIO_ID_NET: uint64 = 1                    # DeviceID for a network device

# virtio-net feature bits (host/guest feature word 0).
VIRTIO_NET_F_MAC: uint32 = 0x20              # bit 5 — config.mac is valid

# Legacy virtio-mmio device-specific config window (MAC lives at +0).
VMMIO_CONFIG: uint64 = 0x100

# struct virtio_net_hdr WITHOUT F_MRG_RXBUF — exactly 10 bytes:
#   u8 flags; u8 gso_type; u16 hdr_len; u16 gso_size; u16 csum_start; u16 csum_offset
P33_NET_HDR_LEN: uint64 = 10

# Two split virtqueues (RX=0, TX=1), QSIZE entries each. 8 is plenty for a
# deterministic single ARP round-trip with a handful of posted RX buffers.
P33_QSIZE: int64 = 8

# Ring + buffer region for Phase 33 — a private 2 MiB-clear area at 0x4600_0000,
# distinct from Phase 30's 0x4500_0000 block region. Each virtqueue's whole
# split ring is a single page-aligned contiguous PFN region (legacy scheme):
#   desc[QSIZE] @ +0 ; avail ring @ +128 ; used ring @ +4096 (QueueAlign).
P33_RX_RING_BASE: uint64 = 0x46000000        # RX queue (queue 0)
P33_RX_DESC_PA:   uint64 = 0x46000000
P33_RX_AVAIL_PA:  uint64 = 0x46000080
P33_RX_USED_PA:   uint64 = 0x46001000
P33_TX_RING_BASE: uint64 = 0x46002000        # TX queue (queue 1)
P33_TX_DESC_PA:   uint64 = 0x46002000
P33_TX_AVAIL_PA:  uint64 = 0x46002080
P33_TX_USED_PA:   uint64 = 0x46003000

# RX receive buffers: P33_QSIZE slots, each big enough for the 10-byte net hdr
# plus a full 1514-byte Ethernet frame. Use 2 KiB stride for alignment headroom.
P33_RXBUF_BASE: uint64 = 0x46010000          # rx buffer pool base
P33_RXBUF_STRIDE: uint64 = 0x800             # 2 KiB per slot

# TX scratch: one net hdr (10 B) + the outgoing Ethernet frame.
P33_TX_HDR_PA:   uint64 = 0x46020000         # 10-byte virtio_net_hdr (zeroed)
P33_TX_FRAME_PA: uint64 = 0x46020800         # outgoing Ethernet frame

# Ethernet / ARP layout constants.
P33_ETH_HDR_LEN: int64 = 14
P33_ARP_LEN: int64 = 28
P33_ETHERTYPE_ARP: uint64 = 0x0806
P33_ARP_REQUEST: uint64 = 1
P33_ARP_REPLY: uint64 = 2

# QEMU user-net (SLIRP) topology: guest 10.0.2.15, gateway 10.0.2.2. An ARP
# request for 10.0.2.2 is answered by SLIRP deterministically.
P33_GUEST_IP0: uint8 = 10
P33_GUEST_IP1: uint8 = 0
P33_GUEST_IP2: uint8 = 2
P33_GUEST_IP3: uint8 = 15
P33_GW_IP0: uint8 = 10
P33_GW_IP1: uint8 = 0
P33_GW_IP2: uint8 = 2
P33_GW_IP3: uint8 = 2

# Phase 33 bookkeeping.
arm64_p33_mmio_base: uint64 = 0              # located virtio-net transport base
arm64_p33_rx_avail_idx: uint16 = 0           # driver's running RX avail index
arm64_p33_tx_avail_idx: uint16 = 0           # driver's running TX avail index
arm64_p33_mac0: uint8 = 0                    # device MAC, 6 bytes
arm64_p33_mac1: uint8 = 0
arm64_p33_mac2: uint8 = 0
arm64_p33_mac3: uint8 = 0
arm64_p33_mac4: uint8 = 0
arm64_p33_mac5: uint8 = 0
arm64_p33_tx_done: int64 = 0                 # TX used-ring completion observed
arm64_p33_rx_len: int64 = 0                  # received frame length (incl. net hdr)
arm64_p33_rx_is_arp_reply: int64 = 0         # received frame was an ARP reply

# Gateway (10.0.2.2) hardware address, learned from the Phase-33 ARP reply's
# sender-HW field. Phase 34 reuses this as the Ethernet destination for its IPv4
# frames, so it never has to re-ARP.
arm64_p33_gw_mac0: uint8 = 0
arm64_p33_gw_mac1: uint8 = 0
arm64_p33_gw_mac2: uint8 = 0
arm64_p33_gw_mac3: uint8 = 0
arm64_p33_gw_mac4: uint8 = 0
arm64_p33_gw_mac5: uint8 = 0
arm64_p33_gw_mac_valid: int64 = 0            # 1 once the ARP reply filled it in


# ---- per-slot accessors (idx: 0 = T0, 1 = T1, 2 = T2) ---------------------
def arm64_p29_l1_for(idx: int64) -> uint64:
    if idx == 0:
        return P29_S0_L1
    if idx == 1:
        return P29_S1_L1
    return P29_S2_L1

def arm64_p29_l2_for(idx: int64) -> uint64:
    if idx == 0:
        return P29_S0_L2
    if idx == 1:
        return P29_S1_L2
    return P29_S2_L2

def arm64_p29_data_for(idx: int64) -> uint64:
    if idx == 0:
        return P29_T0_DATA_PA
    if idx == 1:
        return P29_T1_DATA_PA
    return P29_T2_DATA_PA

def arm64_p29_asid_for(idx: int64) -> uint64:
    if idx == 0:
        return P29_S0_ASID
    if idx == 1:
        return P29_S1_ASID
    return P29_S2_ASID

def arm64_p29_code_for(idx: int64) -> uint64:
    if idx == 0:
        return P29_S0_CODE
    if idx == 1:
        return P29_S1_CODE
    return P29_S2_CODE

def arm64_p29_stack_for(idx: int64) -> uint64:
    if idx == 0:
        return P29_S0_STACK_TOP
    if idx == 1:
        return P29_S1_STACK_TOP
    return P29_S2_STACK_TOP

def arm64_p29_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P29_S0_CTX
    if idx == 1:
        return P29_S1_CTX
    return P29_S2_CTX

def arm64_p29_work_for(idx: int64) -> int64:
    if idx == 0:
        return P29_S0_WORK
    if idx == 1:
        return P29_S1_WORK
    return P29_S2_WORK

# Ticks this task sleeps before exiting (0 = no sleep). Only T0 sleeps.
def arm64_p29_sleep_for(idx: int64) -> int64:
    if idx == 0:
        return P29_S0_SLEEP
    return 0

# The DISTINCT exit status this task passes to exit().
def arm64_p29_target_status_for(idx: int64) -> int64:
    if idx == 0:
        return P29_T0_STATUS
    if idx == 1:
        return P29_T1_STATUS
    return P29_T2_STATUS

def arm64_p29_state_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p29_state0
    if idx == 1:
        return arm64_p29_state1
    return arm64_p29_state2

def arm64_p29_set_state(idx: int64, st: int64) -> int64:
    if idx == 0:
        arm64_p29_state0 = st
    elif idx == 1:
        arm64_p29_state1 = st
    else:
        arm64_p29_state2 = st
    return 0

def arm64_p29_deadline_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p29_deadline0
    if idx == 1:
        return arm64_p29_deadline1
    return arm64_p29_deadline2

def arm64_p29_set_deadline(idx: int64, dl: int64) -> int64:
    if idx == 0:
        arm64_p29_deadline0 = dl
    elif idx == 1:
        arm64_p29_deadline1 = dl
    else:
        arm64_p29_deadline2 = dl
    return 0

def arm64_p29_status_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p29_status0
    if idx == 1:
        return arm64_p29_status1
    return arm64_p29_status2

def arm64_p29_set_status(idx: int64, s: int64) -> int64:
    if idx == 0:
        arm64_p29_status0 = s
    elif idx == 1:
        arm64_p29_status1 = s
    else:
        arm64_p29_status2 = s
    return 0

def arm64_p29_reaped_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p29_reaped0
    if idx == 1:
        return arm64_p29_reaped1
    return arm64_p29_reaped2

def arm64_p29_bump_reaped(idx: int64) -> int64:
    if idx == 0:
        arm64_p29_reaped0 = arm64_p29_reaped0 + 1
    elif idx == 1:
        arm64_p29_reaped1 = arm64_p29_reaped1 + 1
    else:
        arm64_p29_reaped2 = arm64_p29_reaped2 + 1
    return 0


# Build slot `idx`'s private translation tree (clone of arm64_p28_build_space):
# a fresh L1 (entry 0 device, entry 1 -> a fresh RAM L2 block-mapping the 1 GiB
# RAM Normal-WB, with the shared EL0 RWX window EL0-accessible) and the per-task
# counter VA's 2 MiB L2 slot mapped EL0-RW to this slot's OWN private physical
# block. All three slots map the SAME counter VA, but each to a DIFFERENT page.
def arm64_p29_build_space(idx: int64) -> int64:
    l1_base: uint64 = arm64_p29_l1_for(idx)
    l2_base: uint64 = arm64_p29_l2_for(idx)
    data_pa: uint64 = arm64_p29_data_for(idx)

    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1
    l1[0] = cast[uint64](0) | DEV_FLAGS

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == USER_L2_INDEX:
            l2[j] = blk_pa | MEM_FLAGS_EL0       # shared EL0 RWX code/stack window
        elif cast[uint64](j) == P29_DATA_L2_INDEX:
            l2[j] = data_pa | MEM_FLAGS_EL0      # per-task counter VA -> private block
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = l2_base | DESC_TABLE
    _dsb_ish()
    return 0


# Materialise slot `idx`'s EL0 routine at its private code page:
#   x10 = P29_DATA_VA                 (this task's counter VA)
#   <work> increments: load/add/store the counter `work` times
#   [if sleep_n > 0]:  x0 = sleep_n ; x8 = 600 (sleep) ; svc #0   (BLOCK)
#   x0 = exit_status ; x8 = 601 (exit) ; svc #0                    (TERMINATE)
#   b .                                                            (never reached)
# The exit BLOCKS the task forever kernel-side (EXITED zombie); the scheduler
# reaps it and runs the remaining RUNNABLE peers.
def arm64_p29_build_task(idx: int64) -> int64:
    code_base: uint64 = arm64_p29_code_for(idx)
    work: int64 = arm64_p29_work_for(idx)
    sleep_n: int64 = arm64_p29_sleep_for(idx)
    status: int64 = arm64_p29_target_status_for(idx)
    a: uint64 = code_base

    # x10 = P29_DATA_VA (the per-task counter VA). Loaded once at entry.
    a = _emit_load_imm64(a, cast[uint64](10), P29_DATA_VA)

    # <work> increments of the 64-bit counter at [x10].
    w: int64 = 0
    while w < work:
        # ldr x9, [x10]
        a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
        # add x9, x9, #1
        a = _emit_word(a, cast[uint64](0x91000000) | (cast[uint64](1) << cast[uint64](10)) | (cast[uint64](9) << cast[uint64](5)) | cast[uint64](9))
        # str x9, [x10]
        a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
        w = w + 1

    # Optional blocking sleep BEFORE exit (proves exit composes with blocking).
    if sleep_n > 0:
        a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](sleep_n))
        a = _emit_load_imm64(a, cast[uint64](8), SYS_P28_SLEEP_NR)
        a = _emit_word(a, cast[uint64](0xD4000001))         # svc #0 (block)

    # x0 = exit_status ; x8 = SYS_P29_EXIT_NR ; svc #0  (terminate)
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](status))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P29_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))             # svc #0 (exit)

    # b . — a self-loop guard; exit never returns here, but keep the page sane.
    a = _emit_word(a, cast[uint64](0x14000000))

    _dsb_ish()
    _isb()
    return 0


# TTBR0_EL1 for slot `idx`: its private L1 root + its ASID in bits[63:48].
def arm64_p29_ttbr0_for(idx: int64) -> uint64:
    return arm64_p29_l1_for(idx) | (arm64_p29_asid_for(idx) << P29_ASID_SHIFT)


# Switch the live translation to slot `idx` (TTBR0+ASID).
def arm64_p29_switch_to(idx: int64) -> int64:
    _dsb_ish()
    _msr_ttbr0_el1(arm64_p29_ttbr0_for(idx))
    _isb()
    return 0


# Wake any SLEEPING task whose logical-tick deadline has passed: mark it RUNNABLE
# and tally the wake. Returns the number of tasks woken.
def arm64_p29_wake_expired() -> int64:
    woke: int64 = 0
    idx: int64 = 0
    while idx < P29_NTASKS:
        if arm64_p29_state_for(idx) == P29_SLEEPING:
            if arm64_p29_tick >= arm64_p29_deadline_for(idx):
                arm64_p29_set_state(idx, P29_RUNNABLE)
                arm64_p29_wakes = arm64_p29_wakes + 1
                wm: Ptr[char] = "[arm64] Phase 29: waking task "
                _uart_puts(wm)
                _uart_puthex(cast[uint64](idx))
                nl: Ptr[char] = " (deadline passed)\n"
                _uart_puts(nl)
                woke = woke + 1
        idx = idx + 1
    return woke


# The REAPER. Collect any EXITED (zombie) task: copy its recorded exit status into
# its exit_status slot (already there — this is where a parent's wait() reads it),
# bump its per-task reap count and the global reap counter, and transition it
# EXITED -> DEAD so the scheduler never touches it again. Returns tasks reaped.
def arm64_p29_reap_zombies() -> int64:
    reaped: int64 = 0
    idx: int64 = 0
    while idx < P29_NTASKS:
        if arm64_p29_state_for(idx) == P29_EXITED:
            st: int64 = arm64_p29_status_for(idx)
            arm64_p29_bump_reaped(idx)
            arm64_p29_reaps = arm64_p29_reaps + 1
            arm64_p29_set_state(idx, P29_DEAD)
            rm: Ptr[char] = "[arm64] Phase 29: reaped task "
            _uart_puts(rm)
            _uart_puthex(cast[uint64](idx))
            rs: Ptr[char] = " status="
            _uart_puts(rs)
            _uart_puthex(cast[uint64](st))
            nl: Ptr[char] = " (EXITED -> DEAD)\n"
            _uart_puts(nl)
            reaped = reaped + 1
        idx = idx + 1
    return reaped


# True (1) iff every task has reached DEAD (all exited AND all reaped).
def arm64_p29_all_dead() -> int64:
    idx: int64 = 0
    while idx < P29_NTASKS:
        if arm64_p29_state_for(idx) != P29_DEAD:
            return 0
        idx = idx + 1
    return 1


# Pick the next RUNNABLE slot after `from_idx`, round-robin over slots 0..2.
# SLEEPING slots are SKIPPED (tallied as proof sleepers were passed over);
# EXITED/DEAD slots are simply never selected (terminal). Returns -1 if no slot
# is currently runnable (all sleeping/terminal this tick).
def arm64_p29_next_runnable(from_idx: int64) -> int64:
    steps: int64 = 0
    idx: int64 = from_idx
    while steps < P29_NTASKS:
        idx = idx + 1
        if idx >= P29_NTASKS:
            idx = 0
        if arm64_p29_state_for(idx) == P29_RUNNABLE:
            return idx
        steps = steps + 1
    return -1


# Phase-29 timer-IRQ scheduler — invoked (via arm64_sched_pick) from the EL0 IRQ
# vector with the running slot's register context already saved by the .S stub.
# Ack + re-arm the timer, EOI the GIC, advance the logical tick, WAKE expired
# sleepers, REAP exited zombies, then — once all tasks are DEAD — run the verdict
# (never returns). Otherwise round-robin to the next RUNNABLE slot, swap TTBR0+
# ASID into it and return its ctx so the stub ERETs into it.
def arm64_p29_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this slot
        return cur_ctx

    # Quiesce, re-arm, and EOI the timer for the next tick.
    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    # Advance the logical scheduler tick.
    arm64_p29_tick = arm64_p29_tick + 1

    # Wake expired sleepers, then reap exited zombies (collect status, -> DEAD).
    arm64_p29_wake_expired()
    arm64_p29_reap_zombies()

    # Once every task is DEAD (all exited and all reaped), run the verdict. Drain
    # any still-SLEEPING task first so no task is left blocked at the boundary.
    if arm64_p29_all_dead() != 0:
        arm64_p29_finish()
        while True:
            _wfi()

    nxt: int64 = arm64_p29_next_runnable(arm64_p29_cur)
    if nxt < 0:
        # No RUNNABLE task this tick (all sleeping/terminal): stay on the parked
        # current ctx; the next tick wakes/reaps and picks up. Legitimate idle.
        return cur_ctx

    arm64_p29_switches = arm64_p29_switches + 1
    arm64_p29_cur = nxt
    arm64_p29_switch_to(nxt)                  # TTBR0+ASID -> the incoming slot
    next_ctx: uint64 = arm64_p29_ctx_for(nxt)
    arm64_current_ctx = next_ctx              # publish for the .S restore path
    return next_ctx


# Save the running slot's FULL resume context (for the sleep path), identical to
# Phase 28's: x0..x30 from the svc frame, plus post-svc ELR/SP_EL0 and an EL0+
# IRQs-on SPSR. x0 is forced to 0 (sleep's return value on wake).
def arm64_p29_save_resume_ctx(frame_ptr: Ptr[uint64], idx: int64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p29_ctx_for(idx))
    i: int64 = 0
    while i < 31:
        ctx[i] = frame_ptr[i]
        i = i + 1
    ctx[CTX_X0] = cast[uint64](0)
    ctx[CTX_SP_EL0] = cast[uint64](_mrs_sp_el0())
    ctx[CTX_ELR] = cast[uint64](_mrs_elr_el1())
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ
    _dsb_ish()
    return 0


# Park slot `idx`'s LIVE EL0 context on a harmless self-loop so the svc eret
# merely spins until the next timer tick. Point arm64_current_ctx at the throwaway
# park ctx so the preempting IRQ saves the spin state THERE, not over real state.
def arm64_p29_park_blocked_el0(idx: int64) -> int64:
    park: uint64 = arm64_p29_code_for(idx) + cast[uint64](0xE00)
    _emit_word(park, cast[uint64](0x14000000))    # b . (self-loop)
    _dsb_ish()
    _isb()
    _msr_elr_el1(park)
    _isb()
    arm64_current_ctx = P29_PARK_CTX              # IRQ spills spin state here
    return 0


# Phase-29 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. Services SYS_P28_SLEEP_NR (600, block like Phase 28) and SYS_P29_EXIT_NR
# (601): a0 = exit status. exit() records the caller's status, marks it EXITED
# (zombie, tallying `exits`), and parks its EL0 PC so it never runs again; the
# scheduler reaps it (EXITED -> DEAD) on the next tick.
def arm64_p29_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    cur: int64 = arm64_p29_cur

    if nr == SYS_P28_SLEEP_NR:
        ticks: int64 = cast[int64](a0)
        if ticks < 1:
            ticks = 1
        # Save the caller's full resume context so it can RESUME past the svc.
        arm64_p29_save_resume_ctx(frame_ptr, cur)
        arm64_p29_set_deadline(cur, arm64_p29_tick + ticks)
        arm64_p29_set_state(cur, P29_SLEEPING)
        arm64_p29_sleeps = arm64_p29_sleeps + 1

        bm: Ptr[char] = "[arm64] Phase 29: task "
        _uart_puts(bm)
        _uart_puthex(cast[uint64](cur))
        bn: Ptr[char] = " sleep -> SLEEPING for "
        _uart_puts(bn)
        _uart_puthex(cast[uint64](ticks))
        bt: Ptr[char] = " ticks\n"
        _uart_puts(bt)

        arm64_p29_park_blocked_el0(cur)
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P29_EXIT_NR:
        status: int64 = cast[int64](a0)
        # Record the exit status and transition the task to the terminal EXITED
        # (zombie) state. The reaper collects this on the next scheduler tick.
        arm64_p29_set_status(cur, status)
        arm64_p29_set_state(cur, P29_EXITED)
        arm64_p29_exits = arm64_p29_exits + 1

        em: Ptr[char] = "[arm64] Phase 29: task "
        _uart_puts(em)
        _uart_puthex(cast[uint64](cur))
        en: Ptr[char] = " exit(status="
        _uart_puts(en)
        _uart_puthex(cast[uint64](status))
        et: Ptr[char] = ") -> EXITED (zombie)\n"
        _uart_puts(et)

        # Park its EL0 PC on a self-loop so the immediate eret merely spins until
        # the next timer tick preempts it; the scheduler will then NEVER pick it
        # (EXITED/DEAD), and reap it. arm64_current_ctx -> throwaway park ctx so
        # the preempting IRQ does not clobber anything real.
        arm64_p29_park_blocked_el0(cur)
        frame_ptr[0] = cast[uint64](0)
        return 0

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 29)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-29 verdict. PASS iff: every task reached EXITED then DEAD; each recorded
# exit_status matches the DISTINCT value the task passed (0x10 + i); each was
# reaped EXACTLY once (per-task reaped==1) and the global reap count == NTASKS;
# every private counter advanced (each task ran in its OWN page); the three data
# pages are at DISTINCT physical addresses. Print summary + marker, then halt.
def arm64_p29_finish() -> int64:
    arm64_p29_active = 0
    nl: Ptr[char] = "\n"

    # Read each task's counter straight from its OWN physical backing page.
    t0p: Ptr[uint64] = cast[Ptr[uint64]](P29_T0_DATA_PA)
    t1p: Ptr[uint64] = cast[Ptr[uint64]](P29_T1_DATA_PA)
    t2p: Ptr[uint64] = cast[Ptr[uint64]](P29_T2_DATA_PA)
    t0: uint64 = t0p[0]
    t1: uint64 = t1p[0]
    t2: uint64 = t2p[0]

    sm: Ptr[char] = "[arm64] Phase 29 summary: t0="
    _uart_puts(sm)
    _uart_puthex(t0)
    s1: Ptr[char] = " t1="
    _uart_puts(s1)
    _uart_puthex(t1)
    s2: Ptr[char] = " t2="
    _uart_puts(s2)
    _uart_puthex(t2)
    sx: Ptr[char] = " st0="
    _uart_puts(sx)
    _uart_puthex(cast[uint64](arm64_p29_status_for(0)))
    sy: Ptr[char] = " st1="
    _uart_puts(sy)
    _uart_puthex(cast[uint64](arm64_p29_status_for(1)))
    sz: Ptr[char] = " st2="
    _uart_puts(sz)
    _uart_puthex(cast[uint64](arm64_p29_status_for(2)))
    s3: Ptr[char] = " exits="
    _uart_puts(s3)
    _uart_puthex(cast[uint64](arm64_p29_exits))
    s4: Ptr[char] = " reaps="
    _uart_puts(s4)
    _uart_puthex(cast[uint64](arm64_p29_reaps))
    s5: Ptr[char] = " sleeps="
    _uart_puts(s5)
    _uart_puthex(cast[uint64](arm64_p29_sleeps))
    s6: Ptr[char] = " wakes="
    _uart_puts(s6)
    _uart_puthex(cast[uint64](arm64_p29_wakes))
    _uart_puts(nl)

    ok: int64 = 1

    # Every task reached the terminal DEAD state (exited AND reaped).
    idx: int64 = 0
    while idx < P29_NTASKS:
        if arm64_p29_state_for(idx) != P29_DEAD:
            ok = 0
        # Each task's recorded exit status matches the DISTINCT value it passed.
        if arm64_p29_status_for(idx) != arm64_p29_target_status_for(idx):
            ok = 0
        # Each task was reaped EXACTLY once.
        if arm64_p29_reaped_for(idx) != 1:
            ok = 0
        idx = idx + 1

    # Global accounting: exactly NTASKS exits and NTASKS reaps.
    if arm64_p29_exits != P29_NTASKS:
        ok = 0
    if arm64_p29_reaps != P29_NTASKS:
        ok = 0

    # At least one task genuinely blocked and was woken (exit composes with sleep).
    if arm64_p29_sleeps < 1:
        ok = 0
    if arm64_p29_wakes != arm64_p29_sleeps:
        ok = 0

    # All three tasks made forward progress (each ran in its OWN private page).
    if t0 == cast[uint64](0):
        ok = 0
    if t1 == cast[uint64](0):
        ok = 0
    if t2 == cast[uint64](0):
        ok = 0

    # Own-address-space proof: the three counters live in DISTINCT physical pages.
    if P29_T0_DATA_PA == P29_T1_DATA_PA:
        ok = 0
    if P29_T0_DATA_PA == P29_T2_DATA_PA:
        ok = 0
    if P29_T1_DATA_PA == P29_T2_DATA_PA:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 29: THREE EL0 tasks each ran in its OWN address space, then EXITED with a DISTINCT status; the scheduler never dispatched an EXITED task, the reaper collected each zombie's status EXACTLY once (EXITED -> DEAD), and exit composed with the blocking sleep state machine\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 29 PASS\n"
        _uart_puts(pp)
        # Hand off to Phase 30 (virtio-mmio block device read). It owns the rest
        # of the boot and never returns (its run halts after the verdict).
        arm64_p30_run()
        # Unreachable: arm64_p30_run halts. Safety loop.
        _msr_daifset(2)
        while True:
            _wfi()
    else:
        fp: Ptr[char] = "[arm64] Phase 29 FAIL\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-29 entry point (from the Phase-28 finish hand-off). Build all THREE tasks'
# private ASID-tagged address spaces (each mapping the SHARED counter VA to its
# OWN distinct physical page, pre-zeroed) + per-task EL0 routines (work, optional
# sleep, exit) + context blocks; recycle all three ASIDs once; mark all RUNNABLE;
# then ERET into task 0 under its private TTBR0+ASID with the timer LIVE and IRQs
# UNMASKED in EL0. Never returns (halts at the verdict).
def arm64_p29_run() -> int64:
    intro: Ptr[char] = "[arm64] Phase 29: EL0 task exit + wait/reap across three EL0 tasks\n"
    _uart_puts(intro)

    # Mask EL1 IRQs while we build everything; re-enable just before the ERET.
    _msr_daifset(2)

    # Zero each task's private counter page (counter at offset 0).
    z0: Ptr[uint64] = cast[Ptr[uint64]](P29_T0_DATA_PA)
    z1: Ptr[uint64] = cast[Ptr[uint64]](P29_T1_DATA_PA)
    z2: Ptr[uint64] = cast[Ptr[uint64]](P29_T2_DATA_PA)
    z0[0] = cast[uint64](0)
    z1[0] = cast[uint64](0)
    z2[0] = cast[uint64](0)
    _dsb_ish()

    # Build each task's private space + EL0 routine + context block.
    i: int64 = 0
    while i < P29_NTASKS:
        arm64_p29_build_space(i)
        arm64_p29_build_task(i)
        arm64_init_ctx(arm64_p29_ctx_for(i), arm64_p29_code_for(i), arm64_p29_stack_for(i))
        arm64_p29_set_state(i, P29_RUNNABLE)
        arm64_p29_set_deadline(i, 0)
        arm64_p29_set_status(i, -1)
        i = i + 1

    # Recycle all three slots' ASIDs before first use.
    _dsb_ish()
    _tlbi_aside1is(arm64_p29_asid_for(0) << P29_ASID_SHIFT)
    _tlbi_aside1is(arm64_p29_asid_for(1) << P29_ASID_SHIFT)
    _tlbi_aside1is(arm64_p29_asid_for(2) << P29_ASID_SHIFT)
    _dsb_ish()
    _isb()

    arm64_p29_cur = 0
    arm64_p29_tick = 0
    arm64_p29_switches = 0
    arm64_p29_sleeps = 0
    arm64_p29_wakes = 0
    arm64_p29_exits = 0
    arm64_p29_reaps = 0
    arm64_current_ctx = arm64_p29_ctx_for(0)
    arm64_p29_active = 1

    enter: Ptr[char] = "[arm64] launching three EL0 tasks that exit with distinct statuses (T0 sleeps first)\n"
    _uart_puts(enter)

    # Switch to task 0's private space, re-arm + enable the timer, unmask EL1
    # IRQs, then ERET into task 0 at EL0t WITH IRQs unmasked.
    arm64_p29_switch_to(0)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                          # EL1 IRQs on

    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p29_ctx_for(0))
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                  # -> task 0 at EL0; never returns here
    return 0


# ===========================================================================
# PHASE 30 helpers — virtio-mmio block driver (polled).
# ===========================================================================

# 32-bit MMIO read/write to a Device-nGnRE register. addr is the absolute
# register address (transport base + offset).
def _vmmio_r32(addr: uint64) -> uint32:
    p: Ptr[uint32] = cast[Ptr[uint32]](addr)
    v: uint32 = p[0]
    return v


def _vmmio_w32(addr: uint64, val: uint32) -> int64:
    p: Ptr[uint32] = cast[Ptr[uint32]](addr)
    p[0] = val
    _dsb_ish()
    return 0


# Probe the 32 virtio-mmio transport windows for a virtio BLOCK device with a
# valid magic + version + non-zero VendorID. Returns the transport base address,
# or 0 if none found.
def arm64_p30_find_blk() -> uint64:
    i: int64 = 0
    while i < VIRTIO_MMIO_COUNT:
        base: uint64 = VIRTIO_MMIO_BASE + (cast[uint64](i) * VIRTIO_MMIO_STRIDE)
        magic: uint32 = _vmmio_r32(base + VMMIO_MAGIC)
        if cast[uint64](magic) == VIRTIO_MAGIC:
            ver: uint32 = _vmmio_r32(base + VMMIO_VERSION)
            did: uint32 = _vmmio_r32(base + VMMIO_DEVICE_ID)
            # version 1 == legacy transport; DeviceID 2 == block device.
            if cast[uint64](did) == VIRTIO_ID_BLOCK:
                if cast[uint64](ver) == VIRTIO_VERSION_LEGACY:
                    return base
        i = i + 1
    return 0


# Zero a contiguous byte range (used to wipe ring + buffer pages before setup).
def arm64_p30_bzero(pa: uint64, nbytes: int64) -> int64:
    p: Ptr[uint8] = cast[Ptr[uint8]](pa)
    i: int64 = 0
    while i < nbytes:
        p[i] = cast[uint8](0)
        i = i + 1
    _dsb_ish()
    return 0


# Write a split-virtqueue descriptor at index `idx`: addr(8) flags... 16 bytes:
#   +0  u64 addr
#   +8  u32 len
#   +12 u16 flags
#   +14 u16 next
def arm64_p30_set_desc(idx: int64, addr: uint64, length: uint32, flags: uint16, nxt: uint16) -> int64:
    base: uint64 = P30_DESC_PA + (cast[uint64](idx) * cast[uint64](16))
    a: Ptr[uint64] = cast[Ptr[uint64]](base + cast[uint64](0))
    a[0] = addr
    l: Ptr[uint32] = cast[Ptr[uint32]](base + cast[uint64](8))
    l[0] = length
    f: Ptr[uint16] = cast[Ptr[uint16]](base + cast[uint64](12))
    f[0] = flags
    n: Ptr[uint16] = cast[Ptr[uint16]](base + cast[uint64](14))
    n[0] = nxt
    return 0


# Bring up the located LEGACY transport: reset, ACKNOWLEDGE+DRIVER, negotiate
# features (we need none for a plain read), set the guest page size, program
# queue 0's single contiguous split ring via QueuePFN, DRIVER_OK. Returns 1 on
# success, 0 on any failure.
def arm64_p30_setup(base: uint64) -> int64:
    # 1. Reset the device (status = 0).
    _vmmio_w32(base + VMMIO_STATUS, cast[uint32](0))
    _dsb_ish()

    # 2. ACKNOWLEDGE — we noticed the device.
    st: uint32 = VSTATUS_ACKNOWLEDGE
    _vmmio_w32(base + VMMIO_STATUS, st)
    # 3. DRIVER — we know how to drive it.
    st = st | VSTATUS_DRIVER
    _vmmio_w32(base + VMMIO_STATUS, st)
    _dsb_ish()

    # 4. Feature negotiation. A plain VIRTIO_BLK_T_IN read needs NO optional
    #    features, so accept none. (Legacy has no FEATURES_OK gating step.)
    _vmmio_w32(base + VMMIO_HOST_FEATURES_SEL, cast[uint32](0))
    _vmmio_r32(base + VMMIO_HOST_FEATURES)                       # read+discard word 0
    _vmmio_w32(base + VMMIO_GUEST_FEATURES_SEL, cast[uint32](0))
    _vmmio_w32(base + VMMIO_GUEST_FEATURES, cast[uint32](0))     # word 0: accept none
    _vmmio_w32(base + VMMIO_GUEST_FEATURES_SEL, cast[uint32](1))
    _vmmio_w32(base + VMMIO_GUEST_FEATURES, cast[uint32](0))     # word 1: accept none
    _dsb_ish()

    # 5. Legacy: declare the driver page size for the PFN-based queue address.
    _vmmio_w32(base + VMMIO_GUEST_PAGE_SIZE, cast[uint32](P30_PAGE_SIZE))
    _dsb_ish()

    # 6. Program virtqueue 0.
    _vmmio_w32(base + VMMIO_QUEUE_SEL, cast[uint32](0))
    _dsb_ish()
    qmax: uint32 = _vmmio_r32(base + VMMIO_QUEUE_NUM_MAX)
    if qmax == cast[uint32](0):
        return 0
    qsz: uint32 = cast[uint32](P30_QSIZE)
    if cast[uint64](qsz) > cast[uint64](qmax):
        qsz = qmax
    _vmmio_w32(base + VMMIO_QUEUE_NUM, qsz)
    _vmmio_w32(base + VMMIO_QUEUE_ALIGN, cast[uint32](P30_QUEUE_ALIGN))

    # Wipe the whole contiguous queue region (desc + avail + pad + used = 2 pages).
    arm64_p30_bzero(P30_RING_BASE, 8192)

    # Hand the device the queue's page-frame number (legacy single-PFN scheme):
    #   PFN = queue_base / page_size.
    pfn: uint64 = P30_RING_BASE / P30_PAGE_SIZE
    _vmmio_w32(base + VMMIO_QUEUE_PFN, cast[uint32](pfn))
    _dsb_ish()

    # 7. DRIVER_OK — device fully live.
    st = st | VSTATUS_DRIVER_OK
    _vmmio_w32(base + VMMIO_STATUS, st)
    _dsb_ish()

    arm64_p30_avail_idx = cast[uint16](0)
    return 1


# Read used.idx (u16 at offset 2 of the used ring).
def arm64_p30_used_idx() -> uint16:
    p: Ptr[uint16] = cast[Ptr[uint16]](P30_USED_PA + cast[uint64](2))
    v: uint16 = p[0]
    return v


# Issue ONE VIRTIO_BLK_T_IN read of `sector` into the caller-chosen physical
# buffer `dst` (must be at least 512 bytes). Polls the used ring until the device
# completes the request. Returns 1 on a clean completion with status == OK, else 0.
def arm64_p30_read_sector_into(base: uint64, sector: uint64, dst: uint64) -> int64:
    # Build the request header at P30_HDR_PA: type(u32) reserved(u32) sector(u64).
    ht: Ptr[uint32] = cast[Ptr[uint32]](P30_HDR_PA + cast[uint64](0))
    ht[0] = VIRTIO_BLK_T_IN
    hr: Ptr[uint32] = cast[Ptr[uint32]](P30_HDR_PA + cast[uint64](4))
    hr[0] = cast[uint32](0)
    hs: Ptr[uint64] = cast[Ptr[uint64]](P30_HDR_PA + cast[uint64](8))
    hs[0] = sector

    # Pre-poison the data buffer + status byte so a stale read can't masquerade
    # as a fresh device write.
    arm64_p30_bzero(dst, SECTOR_SIZE)
    sbp: Ptr[uint8] = cast[Ptr[uint8]](P30_STATUS_PA)
    sbp[0] = cast[uint8](0xFF)
    _dsb_ish()

    # Three-descriptor chain: header (R) -> data (W) -> status (W).
    #   desc 0: header,  16 bytes, F_NEXT -> 1
    #   desc 1: data,    512 bytes, F_NEXT | F_WRITE -> 2
    #   desc 2: status,  1 byte,    F_WRITE
    arm64_p30_set_desc(0, P30_HDR_PA, cast[uint32](16), VRING_DESC_F_NEXT, cast[uint16](1))
    arm64_p30_set_desc(1, dst, cast[uint32](SECTOR_SIZE), VRING_DESC_F_NEXT | VRING_DESC_F_WRITE, cast[uint16](2))
    arm64_p30_set_desc(2, P30_STATUS_PA, cast[uint32](1), VRING_DESC_F_WRITE, cast[uint16](0))
    _dsb_ish()

    # Publish descriptor head 0 into the avail ring at the current slot, then
    # bump avail.idx with a release barrier so the device sees the entry.
    slot: uint64 = cast[uint64](arm64_p30_avail_idx) & cast[uint64](P30_QSIZE - 1)
    aring: Ptr[uint16] = cast[Ptr[uint16]](P30_AVAIL_PA + cast[uint64](4) + (slot * cast[uint64](2)))
    aring[0] = cast[uint16](0)                       # head descriptor index = 0
    _dsb_ish()
    arm64_p30_avail_idx = arm64_p30_avail_idx + cast[uint16](1)
    aidx: Ptr[uint16] = cast[Ptr[uint16]](P30_AVAIL_PA + cast[uint64](2))
    aidx[0] = arm64_p30_avail_idx
    _dsb_ish()

    # Snapshot used.idx, notify the device on queue 0, then poll for completion.
    before: uint16 = arm64_p30_used_idx()
    _vmmio_w32(base + VMMIO_QUEUE_NOTIFY, cast[uint32](0))
    _dsb_ish()

    spins: int64 = 0
    while spins < 200000000:
        _dsb_ish()
        now: uint16 = arm64_p30_used_idx()
        if now != before:
            # Ack the device interrupt-status bit (polled path still must ack).
            isr: uint32 = _vmmio_r32(base + VMMIO_INTERRUPT_STATUS)
            if isr != cast[uint32](0):
                _vmmio_w32(base + VMMIO_INTERRUPT_ACK, isr)
            _dsb_ish()
            stp: Ptr[uint8] = cast[Ptr[uint8]](P30_STATUS_PA)
            if cast[uint64](stp[0]) == cast[uint64](VIRTIO_BLK_S_OK):
                return 1
            return 0
        spins = spins + 1
    return 0     # timed out: device never completed the request


# Thin wrapper: read `sector` into the shared P30_DATA_PA buffer (Phase 30's
# original single-buffer behavior; kept so Phase 30's call sites are unchanged).
def arm64_p30_read_sector(base: uint64, sector: uint64) -> int64:
    return arm64_p30_read_sector_into(base, sector, P30_DATA_PA)


# Issue ONE VIRTIO_BLK_T_OUT write of `sector` FROM the caller-chosen physical
# buffer `src` (must hold at least 512 bytes). Same request virtqueue + polling
# scheme as the read path; the only differences are the header type (T_OUT) and
# the data descriptor being DEVICE-READABLE (no F_WRITE) instead of device-writable.
# Returns 1 on a clean completion with status == OK, else 0. (Phase 35.)
def arm64_p30_write_sector_from(base: uint64, sector: uint64, src: uint64) -> int64:
    # Build the request header at P30_HDR_PA: type(u32) reserved(u32) sector(u64).
    ht: Ptr[uint32] = cast[Ptr[uint32]](P30_HDR_PA + cast[uint64](0))
    ht[0] = VIRTIO_BLK_T_OUT
    hr: Ptr[uint32] = cast[Ptr[uint32]](P30_HDR_PA + cast[uint64](4))
    hr[0] = cast[uint32](0)
    hs: Ptr[uint64] = cast[Ptr[uint64]](P30_HDR_PA + cast[uint64](8))
    hs[0] = sector

    # Poison the status byte so a stale OK can't masquerade as a fresh completion.
    sbp: Ptr[uint8] = cast[Ptr[uint8]](P30_STATUS_PA)
    sbp[0] = cast[uint8](0xFF)
    _dsb_ish()

    # Three-descriptor chain: header (R) -> data (R) -> status (W).
    #   desc 0: header,  16 bytes, F_NEXT -> 1
    #   desc 1: data,    512 bytes, F_NEXT (device-READABLE: the bytes to write)
    #   desc 2: status,  1 byte,    F_WRITE
    arm64_p30_set_desc(0, P30_HDR_PA, cast[uint32](16), VRING_DESC_F_NEXT, cast[uint16](1))
    arm64_p30_set_desc(1, src, cast[uint32](SECTOR_SIZE), VRING_DESC_F_NEXT, cast[uint16](2))
    arm64_p30_set_desc(2, P30_STATUS_PA, cast[uint32](1), VRING_DESC_F_WRITE, cast[uint16](0))
    _dsb_ish()

    # Publish descriptor head 0 into the avail ring at the current slot, then
    # bump avail.idx with a release barrier so the device sees the entry.
    slot: uint64 = cast[uint64](arm64_p30_avail_idx) & cast[uint64](P30_QSIZE - 1)
    aring: Ptr[uint16] = cast[Ptr[uint16]](P30_AVAIL_PA + cast[uint64](4) + (slot * cast[uint64](2)))
    aring[0] = cast[uint16](0)                       # head descriptor index = 0
    _dsb_ish()
    arm64_p30_avail_idx = arm64_p30_avail_idx + cast[uint16](1)
    aidx: Ptr[uint16] = cast[Ptr[uint16]](P30_AVAIL_PA + cast[uint64](2))
    aidx[0] = arm64_p30_avail_idx
    _dsb_ish()

    # Snapshot used.idx, notify the device on queue 0, then poll for completion.
    before: uint16 = arm64_p30_used_idx()
    _vmmio_w32(base + VMMIO_QUEUE_NOTIFY, cast[uint32](0))
    _dsb_ish()

    spins: int64 = 0
    while spins < 200000000:
        _dsb_ish()
        now: uint16 = arm64_p30_used_idx()
        if now != before:
            isr: uint32 = _vmmio_r32(base + VMMIO_INTERRUPT_STATUS)
            if isr != cast[uint32](0):
                _vmmio_w32(base + VMMIO_INTERRUPT_ACK, isr)
            _dsb_ish()
            stp: Ptr[uint8] = cast[Ptr[uint8]](P30_STATUS_PA)
            if cast[uint64](stp[0]) == cast[uint64](VIRTIO_BLK_S_OK):
                return 1
            return 0
        spins = spins + 1
    return 0     # timed out: device never completed the request


# Phase 30 entry point (hand-off from arm64_p29_finish on success). Find the
# virtio-blk transport, bring it up, read sector 0 (and a couple more), verify
# the known tag the test wrote at sector 0, print the PASS/FAIL verdict, halt.
def arm64_p30_run() -> int64:
    arm64_p30_active = 1
    intro: Ptr[char] = "[arm64] Phase 30: virtio-mmio block device read (sector 0)\n"
    _uart_puts(intro)

    base: uint64 = arm64_p30_find_blk()
    if base == cast[uint64](0):
        fp: Ptr[char] = "[arm64] Phase 30 FAIL: no virtio-blk transport found\n"
        _uart_puts(fp)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    arm64_p30_mmio_base = base

    fb: Ptr[char] = "[arm64] Phase 30: found virtio-blk transport @ "
    _uart_puts(fb)
    _uart_puthex(base)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)

    if arm64_p30_setup(base) != 1:
        fp2: Ptr[char] = "[arm64] Phase 30 FAIL: device bring-up failed\n"
        _uart_puts(fp2)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    sb: Ptr[char] = "[arm64] Phase 30: device live (DRIVER_OK), reading sectors\n"
    _uart_puts(sb)

    # Read sector 0 — the test image carries an ASCII tag here.
    if arm64_p30_read_sector(base, cast[uint64](0)) != 1:
        fp3: Ptr[char] = "[arm64] Phase 30 FAIL: sector 0 read did not complete OK\n"
        _uart_puts(fp3)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    # The first 8 bytes of sector 0 are the verification tag. Print them as a hex
    # word and check they equal the known little-endian tag the test wrote.
    dp: Ptr[uint64] = cast[Ptr[uint64]](P30_DATA_PA)
    tag: uint64 = dp[0]

    tm: Ptr[char] = "[arm64] Phase 30: sector 0 first-8-bytes = "
    _uart_puts(tm)
    _uart_puthex(tag)
    _uart_puts(nl)

    # Also read sectors 1 and 2 to prove repeated requests work (data not checked
    # for content, only that the requests complete cleanly through the ring).
    r1: int64 = arm64_p30_read_sector(base, cast[uint64](1))
    r2: int64 = arm64_p30_read_sector(base, cast[uint64](2))

    # Expected tag: ASCII "HAMNIXAR" in the first 8 bytes, little-endian.
    #   'H'=0x48 'A'=0x41 'M'=0x4D 'N'=0x4E 'I'=0x49 'X'=0x58 'A'=0x41 'R'=0x52
    # Little-endian u64 = 0x52415849_4E4D4148.
    want: uint64 = cast[uint64](0x52415849)
    want = (want << cast[uint64](32)) | cast[uint64](0x4E4D4148)

    ok: int64 = 1
    if tag != want:
        ok = 0
    if r1 != 1:
        ok = 0
    if r2 != 1:
        ok = 0

    arm64_p30_active = 0
    if ok != 0:
        sm: Ptr[char] = "[arm64] Phase 30 summary: tag_ok=1 sec1_ok=1 sec2_ok=1 read sector 0 -> HAMNIXARM\n"
        _uart_puts(sm)
        pp: Ptr[char] = "[arm64] Phase 30 PASS: virtio-blk read sector 0 -> HAMNIXARM\n"
        _uart_puts(pp)
        # Hand off to Phase 31 (parse a real FAT16 filesystem off the same
        # virtio-blk device). It reuses our live, brought-up transport `base`.
        arm64_p31_run(base)
        # Unreachable: arm64_p31_run halts. Safety loop.
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    else:
        sm2: Ptr[char] = "[arm64] Phase 30 summary: tag="
        _uart_puts(sm2)
        _uart_puthex(tag)
        sw: Ptr[char] = " want="
        _uart_puts(sw)
        _uart_puthex(want)
        sr: Ptr[char] = " sec1_ok="
        _uart_puts(sr)
        _uart_puthex(cast[uint64](r1))
        sr2: Ptr[char] = " sec2_ok="
        _uart_puts(sr2)
        _uart_puthex(cast[uint64](r2))
        _uart_puts(nl)
        fp4: Ptr[char] = "[arm64] Phase 30 FAIL: tag/readback mismatch\n"
        _uart_puts(fp4)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# ===========================================================================
# PHASE 31 — parse a real FAT16 filesystem off the SAME virtio-blk device.
# ===========================================================================
# Phase 30 brings up the polled virtio-mmio block transport and proves a raw
# sector read. Phase 31 builds directly on that: it reuses the live transport
# (handed in as `base`) and the generalized read-sector primitive
# (arm64_p30_read_sector_into) to read FILESYSTEM blocks, then parses a minimal
# READ-ONLY FAT16 volume entirely INLINE:
#   1. read the boot sector (LBA 0) and parse the BPB — bytes/sector,
#      sectors/cluster, reserved sectors, #FATs, root-dir entry count,
#      sectors/FAT — and derive the FAT, root-dir and data-region LBAs.
#   2. scan the root directory for the 8.3 file "HELLO   TXT".
#   3. follow its cluster chain through FAT16 (16-bit entries; >=0xFFF8 = EOC),
#      reading each cluster's sectors and copying the file's bytes out.
#   4. verify the file's bytes equal the known ASCII payload "HAMNIX-ARM64-FS-OK".
# No write, no LFN, no subdirectories — minimal robust read path.
#
# Our scratch buffers live in fresh Normal-WB RAM at 0x4510_0000, clear of
# Phase 30's ring/buffer region (0x4500_0000..0x4500_6000).
# ---------------------------------------------------------------------------
P31_SEC_PA: uint64 = 0x45100000              # 512-byte scratch sector buffer
P31_FILE_PA: uint64 = 0x45101000             # assembled file-content buffer
P31_FILE_CAP: int64 = 4096                   # max file bytes we assemble

# Known target file (8.3, space-padded to 11 chars) + expected payload.
P31_NAME0: uint8 = 0x48                       # 'H'
P31_NAME1: uint8 = 0x45                       # 'E'
P31_NAME2: uint8 = 0x4C                       # 'L'
P31_NAME3: uint8 = 0x4C                       # 'L'
P31_NAME4: uint8 = 0x4F                       # 'O'
P31_NAME5: uint8 = 0x20                       # ' '
P31_NAME6: uint8 = 0x20                       # ' '
P31_NAME7: uint8 = 0x20                       # ' '
P31_NAME8: uint8 = 0x54                       # 'T'
P31_NAME9: uint8 = 0x58                       # 'X'
P31_NAME10: uint8 = 0x54                      # 'T'

# Parsed BPB fields (module-scope so the helpers can share them).
arm64_p31_bytes_per_sec: int64 = 0
arm64_p31_sec_per_clus: int64 = 0
arm64_p31_reserved: int64 = 0
arm64_p31_num_fats: int64 = 0
arm64_p31_root_ent_cnt: int64 = 0
arm64_p31_sec_per_fat: int64 = 0
arm64_p31_fat_lba: int64 = 0                 # first FAT sector
arm64_p31_root_lba: int64 = 0                # first root-dir sector
arm64_p31_root_secs: int64 = 0              # # sectors in the root dir
arm64_p31_data_lba: int64 = 0               # first sector of cluster 2

# ---------------------------------------------------------------------------
# Phase 35 scratch buffers — a private Normal-WB region clear of every prior
# phase's buffers (P30 ring @0x4500_0000, P31 @0x4510_0000, P32 @0x4520_0000).
# We reuse the live virtio-blk transport + the P31 BPB/FAT helpers; these two
# 512-byte pages back the raw round-trip and the FS-level rewrite/read-back.
# ---------------------------------------------------------------------------
P35_WBUF_PA: uint64 = 0x45300000             # 512-byte WRITE source buffer
P35_RBUF_PA: uint64 = 0x45301000             # 512-byte READ-BACK buffer
# A high scratch sector well beyond the 2 MiB image's used FAT16 area (data
# region starts ~sector 65 and the planted files occupy a handful of clusters);
# sector 4000 is inside the 4096-sector volume but holds no FS metadata we need.
P35_SCRATCH_LBA: uint64 = 4000


# ===========================================================================
# PHASE 32 — load a REAL ELF binary off the FAT16 disk and execute it at EL0.
# ===========================================================================
# Phase 32 combines the Phase-26 AArch64 ELF64 loader with the Phase-31 FAT16
# reader: instead of assembling a hand-embedded ELF image in RAM, it reads a
# genuine ELF EXECUTABLE ("PROG    ELF") out of the same virtio-mmio-backed
# FAT16 volume, parses its header + program headers, maps its PT_LOAD segments
# into a FRESH EL0 address space, and ERETs into e_entry at EL0. The loaded
# program issues a write() syscall (emitting its message to the UART via the
# EL0 svc path) and exit()s — proving a real on-disk program -> EL0 pipeline.
#
# All P32 buffers/tables/backing-pages live in fresh Normal-WB RAM clear of the
# Phase-31 buffers (0x4510_0000..0x4510_2000) and every prior phase.
# ---------------------------------------------------------------------------
P32_FILE_PA: uint64 = 0x45200000             # raw ELF file bytes read off disk
P32_FILE_CAP: int64 = 8192                   # max ELF file bytes we read

# The on-disk ELF's program layout (must match the planted PROG.ELF in the
# test's FAT16 builder). Reuses the Phase-26 segment VAs (valid EL0 VAs; P26
# long completed) but distinct PA backing + page tables.
P32_TEXT_VA: uint64 = 0x42600000             # PT_LOAD #1 (RX): code + message
P32_DATA_VA: uint64 = 0x42800000             # PT_LOAD #2 (RW): data + BSS tail
P32_TEXT_L2_INDEX: uint64 = 19               # (0x4260_0000 - 0x4000_0000) / 2 MiB
P32_DATA_L2_INDEX: uint64 = 20               # (0x4280_0000 - 0x4000_0000) / 2 MiB
P32_STACK_L2_INDEX: uint64 = 21              # (0x42A0_0000 - 0x4000_0000) / 2 MiB

# Fresh page tables (distinct from P26's 0x401B_xxxx).
P32_L1: uint64 = 0x45210000
P32_L2: uint64 = 0x45211000
P32_TEXT_L3: uint64 = 0x45212000
P32_DATA_L3: uint64 = 0x45213000
P32_STACK_L3: uint64 = 0x45214000
P32_ASID: uint64 = 16                        # distinct from every prior ASID

# Fresh backing pages.
P32_TEXT_PA: uint64 = 0x45220000
P32_DATA_PA: uint64 = 0x45230000

P32_STACK_VA: uint64 = 0x42A00000
P32_STACK_L3_IDX: uint64 = 0                 # filled at build time
P32_STACK_PA: uint64 = 0x45240000
P32_STACK_TOP: uint64 = 0x42A01000           # 16B-aligned top of the stack page

# W^X page permissions (identical encoding to Phase 26).
P32_PAGE_RX: uint64 = 0x7C7
P32_PAGE_RW: uint64 = 0x40000000000747
P32_PAGE_RO: uint64 = 0x400000000007C7

# Syscall numbers the loaded program uses (distinct from prior phases).
SYS_P32_WRITE_NR: uint64 = 600     # write(1, buf, len): emit to UART
SYS_P32_EXIT_NR: uint64 = 601      # exit(code): verdict + halt
P32_EXIT_CODE: uint64 = 0x37       # the program's expected exit status (== 55)

# Target on-disk file name (8.3, space-padded to 11 chars): "PROG    ELF".
P32_NAME0: uint8 = 0x50                       # 'P'
P32_NAME1: uint8 = 0x52                       # 'R'
P32_NAME2: uint8 = 0x4F                       # 'O'
P32_NAME3: uint8 = 0x47                       # 'G'
P32_NAME4: uint8 = 0x20                       # ' '
P32_NAME5: uint8 = 0x20                       # ' '
P32_NAME6: uint8 = 0x20                       # ' '
P32_NAME7: uint8 = 0x20                       # ' '
P32_NAME8: uint8 = 0x45                       # 'E'
P32_NAME9: uint8 = 0x4C                       # 'L'
P32_NAME10: uint8 = 0x46                      # 'F'

# Phase-32 bookkeeping (routes EL0 aborts + svc into the P32 loader path).
arm64_p32_active: int64 = 0
arm64_p32_parse_ok: int64 = 0
arm64_p32_segs_loaded: int64 = 0
arm64_p32_text_faults: int64 = 0
arm64_p32_data_faults: int64 = 0
arm64_p32_file_len: int64 = 0
arm64_p32_msg_bytes: int64 = 0
arm64_p32_exited: int64 = 0
arm64_p32_exit_code: uint64 = 0xFFFF
arm64_p32_entry: uint64 = 0


# Read a little-endian u16 from byte offset `off` of buffer `pa`.
def arm64_p31_rd16(pa: uint64, off: int64) -> int64:
    p: Ptr[uint8] = cast[Ptr[uint8]](pa)
    b0: int64 = cast[int64](p[off])
    b1: int64 = cast[int64](p[off + 1])
    return b0 | (b1 << 8)


# Read a little-endian u32 from byte offset `off` of buffer `pa`.
def arm64_p31_rd32(pa: uint64, off: int64) -> int64:
    p: Ptr[uint8] = cast[Ptr[uint8]](pa)
    b0: int64 = cast[int64](p[off])
    b1: int64 = cast[int64](p[off + 1])
    b2: int64 = cast[int64](p[off + 2])
    b3: int64 = cast[int64](p[off + 3])
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)


# Parse the BPB out of the boot sector already loaded at P31_SEC_PA, fill the
# module globals + derived region LBAs. Returns 1 if the geometry looks sane.
def arm64_p31_parse_bpb() -> int64:
    arm64_p31_bytes_per_sec = arm64_p31_rd16(P31_SEC_PA, 11)
    pp: Ptr[uint8] = cast[Ptr[uint8]](P31_SEC_PA)
    arm64_p31_sec_per_clus = cast[int64](pp[13])
    arm64_p31_reserved = arm64_p31_rd16(P31_SEC_PA, 14)
    arm64_p31_num_fats = cast[int64](pp[16])
    arm64_p31_root_ent_cnt = arm64_p31_rd16(P31_SEC_PA, 17)
    arm64_p31_sec_per_fat = arm64_p31_rd16(P31_SEC_PA, 22)

    # Geometry sanity: we only handle the simple FAT16 case we build the disk as.
    if arm64_p31_bytes_per_sec != 512:
        return 0
    if arm64_p31_sec_per_clus < 1:
        return 0
    if arm64_p31_num_fats < 1:
        return 0
    if arm64_p31_sec_per_fat < 1:
        return 0
    if arm64_p31_root_ent_cnt < 1:
        return 0

    # Derived region layout (all in sectors):
    #   FAT(s)      start at  reserved
    #   root dir    starts at reserved + num_fats * sec_per_fat
    #   data region starts at root_lba + root_secs (cluster 2 lives here)
    arm64_p31_fat_lba = arm64_p31_reserved
    arm64_p31_root_lba = arm64_p31_reserved + (arm64_p31_num_fats * arm64_p31_sec_per_fat)
    root_bytes: int64 = arm64_p31_root_ent_cnt * 32
    arm64_p31_root_secs = (root_bytes + (arm64_p31_bytes_per_sec - 1)) / arm64_p31_bytes_per_sec
    arm64_p31_data_lba = arm64_p31_root_lba + arm64_p31_root_secs
    return 1


# Compare the 11-byte 8.3 name at byte offset `off` of buffer `pa` against the
# known target name. Returns 1 on a full match, else 0.
def arm64_p31_name_matches(pa: uint64, off: int64) -> int64:
    p: Ptr[uint8] = cast[Ptr[uint8]](pa)
    if p[off + 0] != P31_NAME0:
        return 0
    if p[off + 1] != P31_NAME1:
        return 0
    if p[off + 2] != P31_NAME2:
        return 0
    if p[off + 3] != P31_NAME3:
        return 0
    if p[off + 4] != P31_NAME4:
        return 0
    if p[off + 5] != P31_NAME5:
        return 0
    if p[off + 6] != P31_NAME6:
        return 0
    if p[off + 7] != P31_NAME7:
        return 0
    if p[off + 8] != P31_NAME8:
        return 0
    if p[off + 9] != P31_NAME9:
        return 0
    if p[off + 10] != P31_NAME10:
        return 0
    return 1


# Look up the FAT16 successor of cluster `clus`: read the FAT sector holding the
# 16-bit entry at byte offset clus*2 and return that entry. Returns -1 on a read
# failure. Values >= 0xFFF8 mean end-of-chain.
def arm64_p31_fat_next(base: uint64, clus: int64) -> int64:
    fat_byte: int64 = clus * 2
    sec_in_fat: int64 = fat_byte / arm64_p31_bytes_per_sec
    off_in_sec: int64 = fat_byte - (sec_in_fat * arm64_p31_bytes_per_sec)
    lba: int64 = arm64_p31_fat_lba + sec_in_fat
    if arm64_p30_read_sector_into(base, cast[uint64](lba), P31_SEC_PA) != 1:
        return -1
    return arm64_p31_rd16(P31_SEC_PA, off_in_sec)


# Copy `n` bytes from src_pa+src_off into P31_FILE_PA+dst_off. Returns new dst_off.
def arm64_p31_copy_bytes(src_pa: uint64, src_off: int64, dst_off: int64, n: int64) -> int64:
    s: Ptr[uint8] = cast[Ptr[uint8]](src_pa)
    d: Ptr[uint8] = cast[Ptr[uint8]](P31_FILE_PA)
    i: int64 = 0
    o: int64 = dst_off
    while i < n:
        if o < P31_FILE_CAP:
            d[o] = s[src_off + i]
            o = o + 1
        i = i + 1
    return o


# Phase 31 entry point: hand-off from arm64_p30_run on success, with the live
# virtio-blk transport `base`. Parse the FAT16 volume, find HELLO.TXT, follow its
# cluster chain, read its bytes, verify against the known payload, print verdict.
def arm64_p31_run(base: uint64) -> int64:
    intro: Ptr[char] = "[arm64] Phase 31: parse FAT16 filesystem off virtio-blk\n"
    _uart_puts(intro)
    nl: Ptr[char] = "\n"

    # --- 1. read + parse the boot sector (BPB) -----------------------------
    if arm64_p30_read_sector_into(base, cast[uint64](0), P31_SEC_PA) != 1:
        fp: Ptr[char] = "[arm64] Phase 31 FAIL: boot-sector read did not complete\n"
        _uart_puts(fp)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    if arm64_p31_parse_bpb() != 1:
        fp2: Ptr[char] = "[arm64] Phase 31 FAIL: BPB geometry not a supported FAT16\n"
        _uart_puts(fp2)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    bm: Ptr[char] = "[arm64] Phase 31: BPB bps="
    _uart_puts(bm)
    _uart_puthex(cast[uint64](arm64_p31_bytes_per_sec))
    bm2: Ptr[char] = " spc="
    _uart_puts(bm2)
    _uart_puthex(cast[uint64](arm64_p31_sec_per_clus))
    bm3: Ptr[char] = " rsvd="
    _uart_puts(bm3)
    _uart_puthex(cast[uint64](arm64_p31_reserved))
    bm4: Ptr[char] = " nfat="
    _uart_puts(bm4)
    _uart_puthex(cast[uint64](arm64_p31_num_fats))
    bm5: Ptr[char] = " spf="
    _uart_puts(bm5)
    _uart_puthex(cast[uint64](arm64_p31_sec_per_fat))
    bm6: Ptr[char] = " rootent="
    _uart_puts(bm6)
    _uart_puthex(cast[uint64](arm64_p31_root_ent_cnt))
    _uart_puts(nl)

    rm: Ptr[char] = "[arm64] Phase 31: layout fat_lba="
    _uart_puts(rm)
    _uart_puthex(cast[uint64](arm64_p31_fat_lba))
    rm2: Ptr[char] = " root_lba="
    _uart_puts(rm2)
    _uart_puthex(cast[uint64](arm64_p31_root_lba))
    rm3: Ptr[char] = " data_lba="
    _uart_puts(rm3)
    _uart_puthex(cast[uint64](arm64_p31_data_lba))
    _uart_puts(nl)

    # --- 2. scan the root directory for HELLO.TXT --------------------------
    first_clus: int64 = -1
    file_size: int64 = 0
    s: int64 = 0
    while s < arm64_p31_root_secs:
        lba: int64 = arm64_p31_root_lba + s
        if arm64_p30_read_sector_into(base, cast[uint64](lba), P31_SEC_PA) != 1:
            fp3: Ptr[char] = "[arm64] Phase 31 FAIL: root-dir sector read failed\n"
            _uart_puts(fp3)
            _msr_daifset(2)
            while True:
                _wfi()
            return 0
        e: int64 = 0
        while e < arm64_p31_bytes_per_sec:
            pp: Ptr[uint8] = cast[Ptr[uint8]](P31_SEC_PA)
            first_byte: uint8 = pp[e]
            # 0x00 = end of directory; 0xE5 = deleted; skip volume-label/dir.
            if cast[uint64](first_byte) == cast[uint64](0):
                s = arm64_p31_root_secs            # break outer loop
                e = arm64_p31_bytes_per_sec
            else:
                if arm64_p31_name_matches(P31_SEC_PA, e) == 1:
                    first_clus = arm64_p31_rd16(P31_SEC_PA, e + 26)
                    file_size = arm64_p31_rd32(P31_SEC_PA, e + 28)
                    s = arm64_p31_root_secs        # found it: break outer
                    e = arm64_p31_bytes_per_sec
                else:
                    e = e + 32
        s = s + 1

    if first_clus < 0:
        fp4: Ptr[char] = "[arm64] Phase 31 FAIL: HELLO.TXT not found in root dir\n"
        _uart_puts(fp4)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    fm: Ptr[char] = "[arm64] Phase 31: found HELLO.TXT first_clus="
    _uart_puts(fm)
    _uart_puthex(cast[uint64](first_clus))
    fm2: Ptr[char] = " size="
    _uart_puts(fm2)
    _uart_puthex(cast[uint64](file_size))
    _uart_puts(nl)

    # --- 3. follow the cluster chain, assembling file bytes ----------------
    sec_per_clus: int64 = arm64_p31_sec_per_clus
    clus_bytes: int64 = sec_per_clus * arm64_p31_bytes_per_sec
    dst_off: int64 = 0
    clus: int64 = first_clus
    remaining: int64 = file_size
    guard: int64 = 0                         # bound the walk (corruption guard)
    while remaining > 0:
        if clus < 2:
            break
        if clus >= 0xFFF8:
            break
        if guard > 4096:
            break
        guard = guard + 1
        # cluster N's first sector = data_lba + (N - 2) * sec_per_clus.
        clus_lba: int64 = arm64_p31_data_lba + ((clus - 2) * sec_per_clus)
        sc: int64 = 0
        while sc < sec_per_clus:
            if remaining <= 0:
                sc = sec_per_clus
            else:
                if arm64_p30_read_sector_into(base, cast[uint64](clus_lba + sc), P31_SEC_PA) != 1:
                    fp5: Ptr[char] = "[arm64] Phase 31 FAIL: data sector read failed\n"
                    _uart_puts(fp5)
                    _msr_daifset(2)
                    while True:
                        _wfi()
                    return 0
                take: int64 = arm64_p31_bytes_per_sec
                if remaining < take:
                    take = remaining
                dst_off = arm64_p31_copy_bytes(P31_SEC_PA, 0, dst_off, take)
                remaining = remaining - take
                sc = sc + 1
        # advance to the next cluster in the chain.
        nxt: int64 = arm64_p31_fat_next(base, clus)
        if nxt < 0:
            fp6: Ptr[char] = "[arm64] Phase 31 FAIL: FAT chain read failed\n"
            _uart_puts(fp6)
            _msr_daifset(2)
            while True:
                _wfi()
            return 0
        clus = nxt

    # --- 4. verify the assembled bytes equal the known payload -------------
    # Expected payload: "HAMNIX-ARM64-FS-OK" (18 bytes).
    payload: Ptr[char] = "HAMNIX-ARM64-FS-OK"
    pb: Ptr[uint8] = cast[Ptr[uint8]](payload)
    fbuf: Ptr[uint8] = cast[Ptr[uint8]](P31_FILE_PA)
    want_len: int64 = 0
    while pb[want_len] != 0:
        want_len = want_len + 1

    ok: int64 = 1
    if file_size != want_len:
        ok = 0
    if dst_off != want_len:
        ok = 0
    if ok != 0:
        i: int64 = 0
        while i < want_len:
            if fbuf[i] != pb[i]:
                ok = 0
            i = i + 1

    if ok != 0:
        sm: Ptr[char] = "[arm64] Phase 31 summary: parsed FAT16, read HELLO.TXT ("
        _uart_puts(sm)
        _uart_puthex(cast[uint64](dst_off))
        sm2: Ptr[char] = " bytes) = HAMNIX-ARM64-FS-OK\n"
        _uart_puts(sm2)
        pp2: Ptr[char] = "[arm64] Phase 31 PASS: FAT16 read HELLO.TXT -> HAMNIX-ARM64-FS-OK\n"
        _uart_puts(pp2)
        # Phase 31 complete and clean. Hand off to Phase 32 (load a REAL ELF
        # binary off the SAME FAT16 disk and execute it at EL0). The parsed BPB
        # + derived FAT16 layout (arm64_p31_* globals) are still live, so P32
        # reuses them to locate + read PROG.ELF. arm64_p32_run never returns.
        arm64_p32_run(base)
        # Unreachable: arm64_p32_run halts after its verdict.
        while True:
            _wfi()
    else:
        em: Ptr[char] = "[arm64] Phase 31 summary: got_len="
        _uart_puts(em)
        _uart_puthex(cast[uint64](dst_off))
        em2: Ptr[char] = " want_len="
        _uart_puts(em2)
        _uart_puthex(cast[uint64](want_len))
        em3: Ptr[char] = " file_size="
        _uart_puts(em3)
        _uart_puthex(cast[uint64](file_size))
        _uart_puts(nl)
        fp7: Ptr[char] = "[arm64] Phase 31 FAIL: HELLO.TXT content mismatch\n"
        _uart_puts(fp7)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# ===========================================================================
# Phase 32 — load a REAL ELF binary off the FAT16 disk and execute it at EL0.
# ===========================================================================

# Little-endian readers out of the on-disk ELF file buffer (P32_FILE_PA).
def _p32_rd16(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P32_FILE_PA)
    b0: uint64 = cast[uint64](p[cast[int64](off)])
    b1: uint64 = cast[uint64](p[cast[int64](off + cast[uint64](1))])
    return b0 | (b1 << cast[uint64](8))


def _p32_rd32(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P32_FILE_PA)
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 4:
        r = r | (cast[uint64](p[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


def _p32_rd64(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P32_FILE_PA)
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 8:
        r = r | (cast[uint64](p[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


# Match the 8.3 "PROG    ELF" name at directory-entry offset `off` of buffer `pa`.
def arm64_p32_name_matches(pa: uint64, off: int64) -> int64:
    p: Ptr[uint8] = cast[Ptr[uint8]](pa)
    if p[off + 0] != P32_NAME0:
        return 0
    if p[off + 1] != P32_NAME1:
        return 0
    if p[off + 2] != P32_NAME2:
        return 0
    if p[off + 3] != P32_NAME3:
        return 0
    if p[off + 4] != P32_NAME4:
        return 0
    if p[off + 5] != P32_NAME5:
        return 0
    if p[off + 6] != P32_NAME6:
        return 0
    if p[off + 7] != P32_NAME7:
        return 0
    if p[off + 8] != P32_NAME8:
        return 0
    if p[off + 9] != P32_NAME9:
        return 0
    if p[off + 10] != P32_NAME10:
        return 0
    return 1


# Read PROG.ELF off the live FAT16 volume into P32_FILE_PA, reusing the BPB +
# layout already parsed by Phase 31 (arm64_p31_* globals). Scans the root dir
# for the 8.3 name, follows its FAT16 cluster chain, copies its bytes out.
# Returns the byte length on success, -1 on any read / not-found failure.
def arm64_p32_read_file(base: uint64) -> int64:
    nl: Ptr[char] = "\n"

    # --- scan the root directory for PROG.ELF ---
    first_clus: int64 = -1
    file_size: int64 = 0
    s: int64 = 0
    while s < arm64_p31_root_secs:
        lba: int64 = arm64_p31_root_lba + s
        if arm64_p30_read_sector_into(base, cast[uint64](lba), P31_SEC_PA) != 1:
            return -1
        e: int64 = 0
        while e < arm64_p31_bytes_per_sec:
            pp: Ptr[uint8] = cast[Ptr[uint8]](P31_SEC_PA)
            first_byte: uint8 = pp[e]
            if cast[uint64](first_byte) == cast[uint64](0):
                s = arm64_p31_root_secs            # 0x00 = end of directory
                e = arm64_p31_bytes_per_sec
            else:
                if arm64_p32_name_matches(P31_SEC_PA, e) == 1:
                    first_clus = arm64_p31_rd16(P31_SEC_PA, e + 26)
                    file_size = arm64_p31_rd32(P31_SEC_PA, e + 28)
                    s = arm64_p31_root_secs        # found it: break outer
                    e = arm64_p31_bytes_per_sec
                else:
                    e = e + 32
        s = s + 1

    if first_clus < 0:
        return -1

    fm: Ptr[char] = "[arm64] Phase 32: found PROG.ELF first_clus="
    _uart_puts(fm)
    _uart_puthex(cast[uint64](first_clus))
    fm2: Ptr[char] = " size="
    _uart_puts(fm2)
    _uart_puthex(cast[uint64](file_size))
    _uart_puts(nl)

    # --- follow the FAT16 cluster chain, copying bytes into P32_FILE_PA ---
    sec_per_clus: int64 = arm64_p31_sec_per_clus
    dst_off: int64 = 0
    want_len: int64 = file_size
    clus: int64 = first_clus
    guard: int64 = 0
    dst: Ptr[uint8] = cast[Ptr[uint8]](P32_FILE_PA)
    src: Ptr[uint8] = cast[Ptr[uint8]](P31_SEC_PA)
    while clus >= 2 and clus < 0xFFF8 and dst_off < want_len:
        guard = guard + 1
        if guard > 4096:
            return -1
        clus_lba: int64 = arm64_p31_data_lba + ((clus - 2) * sec_per_clus)
        sc: int64 = 0
        while sc < sec_per_clus:
            if dst_off < want_len:
                if arm64_p30_read_sector_into(base, cast[uint64](clus_lba + sc), P31_SEC_PA) != 1:
                    return -1
                take: int64 = arm64_p31_bytes_per_sec
                if dst_off + take > want_len:
                    take = want_len - dst_off
                i: int64 = 0
                while i < take:
                    if dst_off < P32_FILE_CAP:
                        dst[dst_off] = src[i]
                        dst_off = dst_off + 1
                    else:
                        i = take
                    i = i + 1
            sc = sc + 1
        nxt: int64 = arm64_p31_fat_next(base, clus)
        if nxt < 0:
            return -1
        clus = nxt

    return dst_off


# Derive the L3 PAGE flags for a parsed ELF segment (W^X), mirroring Phase 26.
def arm64_p32_flags_for(pflags: uint64) -> uint64:
    if (pflags & PF_W) != cast[uint64](0):
        return P32_PAGE_RW
    if (pflags & PF_X) != cast[uint64](0):
        return P32_PAGE_RX
    return P32_PAGE_RO


# Build the loaded program's fresh EL0 address space (private L1/L2 + three 2 MiB
# slots redirected to private L3 tables for text/data/stack). The EL0 stack page
# is wired RW immediately; segment pages fault in on first touch. Mirrors P26.
def arm64_p32_build_space() -> int64:
    l1: Ptr[uint64] = cast[Ptr[uint64]](P32_L1)
    l2: Ptr[uint64] = cast[Ptr[uint64]](P32_L2)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1
    l1[0] = cast[uint64](0) | DEV_FLAGS

    tl3: Ptr[uint64] = cast[Ptr[uint64]](P32_TEXT_L3)
    dl3: Ptr[uint64] = cast[Ptr[uint64]](P32_DATA_L3)
    sl3: Ptr[uint64] = cast[Ptr[uint64]](P32_STACK_L3)
    k: int64 = 0
    while k < 512:
        tl3[k] = cast[uint64](0)
        dl3[k] = cast[uint64](0)
        sl3[k] = cast[uint64](0)
        k = k + 1

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == P32_TEXT_L2_INDEX:
            l2[j] = P32_TEXT_L3 | DESC_TABLE
        elif cast[uint64](j) == P32_DATA_L2_INDEX:
            l2[j] = P32_DATA_L3 | DESC_TABLE
        elif cast[uint64](j) == P32_STACK_L2_INDEX:
            l2[j] = P32_STACK_L3 | DESC_TABLE
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = P32_L2 | DESC_TABLE
    _dsb_ish()

    # Wire the EL0 stack page (RW non-exec) so the program has a stack on entry.
    sidx: uint64 = (P32_STACK_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    sl3[cast[int64](sidx)] = P32_STACK_PA | P32_PAGE_RW
    sp: Ptr[uint64] = cast[Ptr[uint64]](P32_STACK_PA)
    z: int64 = 0
    while z < 512:
        sp[z] = cast[uint64](0)
        z = z + 1
    _dsb_ish()
    return 0


# Map [seg_va, seg_va + memsz) onto seg_pa with page_flags in its 2 MiB slot's
# private L3. The backing page is pre-cleared (BSS tail reads zero), p_filesz
# file bytes copied in from the on-disk ELF buffer. One 4 KiB page (test segments
# fit in one page). Mirrors P26's mapper but sources bytes from P32_FILE_PA.
def arm64_p32_map_segment(seg_va: uint64, seg_pa: uint64, foff: uint64, filesz: uint64, l3_base: uint64, page_flags: uint64) -> int64:
    pg: Ptr[uint8] = cast[Ptr[uint8]](seg_pa)
    c: int64 = 0
    while c < cast[int64](P26_PAGE_SIZE):
        pg[c] = cast[uint8](0)
        c = c + 1

    fbuf: Ptr[uint8] = cast[Ptr[uint8]](P32_FILE_PA)
    n: uint64 = cast[uint64](0)
    while n < filesz:
        pg[cast[int64](n)] = fbuf[cast[int64](foff + n)]
        n = n + cast[uint64](1)
    _dsb_ish()

    l3: Ptr[uint64] = cast[Ptr[uint64]](l3_base)
    idx: uint64 = (seg_va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3[cast[int64](idx)] = seg_pa | page_flags
    _dsb_ish()
    _isb()
    return 0


# Parse + load the on-disk ELF64 (already read into P32_FILE_PA). Validates the
# header, walks the program-header table, maps every PT_LOAD by its VADDR.
# Returns e_entry on success, 0 on a validation failure.
def arm64_p32_load_elf() -> uint64:
    arm64_p32_parse_ok = 0
    arm64_p32_segs_loaded = 0
    nl: Ptr[char] = "\n"
    fbuf: Ptr[uint8] = cast[Ptr[uint8]](P32_FILE_PA)

    # --- validate e_ident magic + class + data ---
    if cast[uint64](fbuf[0]) != ELF_EI_MAG0:
        return cast[uint64](0)
    if cast[uint64](fbuf[1]) != ELF_EI_MAG1:
        return cast[uint64](0)
    if cast[uint64](fbuf[2]) != ELF_EI_MAG2:
        return cast[uint64](0)
    if cast[uint64](fbuf[3]) != ELF_EI_MAG3:
        return cast[uint64](0)
    if cast[uint64](fbuf[4]) != ELFCLASS64:
        return cast[uint64](0)
    if cast[uint64](fbuf[5]) != ELFDATA2LSB:
        return cast[uint64](0)

    e_type: uint64 = _p32_rd16(EH_TYPE)
    e_machine: uint64 = _p32_rd16(EH_MACHINE)
    e_entry: uint64 = _p32_rd64(EH_ENTRY)
    e_phoff: uint64 = _p32_rd64(EH_PHOFF)
    e_phentsize: uint64 = _p32_rd16(EH_PHENTSIZE)
    e_phnum: uint64 = _p32_rd16(EH_PHNUM)

    if e_type != ET_EXEC:
        return cast[uint64](0)
    if e_machine != EM_AARCH64:
        return cast[uint64](0)

    hm: Ptr[char] = "[arm64] Phase 32 ELF: class64 LSB, machine=AArch64, type=EXEC, entry="
    _uart_puts(hm)
    _uart_puthex(e_entry)
    pm: Ptr[char] = " phoff="
    _uart_puts(pm)
    _uart_puthex(e_phoff)
    nm: Ptr[char] = " phnum="
    _uart_puts(nm)
    _uart_puthex(e_phnum)
    _uart_puts(nl)

    arm64_p32_parse_ok = 1
    arm64_p32_entry = e_entry

    ph: uint64 = 0
    while ph < e_phnum:
        base: uint64 = e_phoff + (ph * e_phentsize)
        p_type: uint64 = _p32_rd32(base + PH_TYPE)
        if p_type == PT_LOAD:
            p_flags: uint64 = _p32_rd32(base + PH_FLAGS)
            p_offset: uint64 = _p32_rd64(base + PH_OFFSET)
            p_vaddr: uint64 = _p32_rd64(base + PH_VADDR)
            p_filesz: uint64 = _p32_rd64(base + PH_FILESZ)
            p_memsz: uint64 = _p32_rd64(base + PH_MEMSZ)
            page_flags: uint64 = arm64_p32_flags_for(p_flags)

            seg_pa: uint64 = cast[uint64](0)
            l3_base: uint64 = cast[uint64](0)
            if p_vaddr == P32_TEXT_VA:
                seg_pa = P32_TEXT_PA
                l3_base = P32_TEXT_L3
            elif p_vaddr == P32_DATA_VA:
                seg_pa = P32_DATA_PA
                l3_base = P32_DATA_L3
            else:
                return cast[uint64](0)

            arm64_p32_map_segment(p_vaddr, seg_pa, p_offset, p_filesz, l3_base, page_flags)
            arm64_p32_segs_loaded = arm64_p32_segs_loaded + 1

            sm: Ptr[char] = "[arm64] Phase 32 PT_LOAD: vaddr="
            _uart_puts(sm)
            _uart_puthex(p_vaddr)
            fm: Ptr[char] = " filesz="
            _uart_puts(fm)
            _uart_puthex(p_filesz)
            mm: Ptr[char] = " memsz="
            _uart_puts(mm)
            _uart_puthex(p_memsz)
            xm: Ptr[char] = " flags="
            _uart_puts(xm)
            _uart_puthex(p_flags)
            am: Ptr[char] = " -> pa="
            _uart_puts(am)
            _uart_puthex(seg_pa)
            _uart_puts(nl)
        ph = ph + cast[uint64](1)

    return e_entry


# Phase-32 demand-fault entry. A first touch of a loaded segment page takes a
# TRANSLATION fault (loader pre-stamped the PTE). Confirm the VA lies in a loaded
# segment, account it, flush that VA, and resume (return 1); else return 0.
def arm64_p32_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0

    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    in_seg: int64 = 0
    if page_va == P32_TEXT_VA:
        arm64_p32_text_faults = arm64_p32_text_faults + 1
        in_seg = 1
    elif page_va == P32_DATA_VA:
        arm64_p32_data_faults = arm64_p32_data_faults + 1
        in_seg = 1
    if in_seg == 0:
        return 0

    _dsb_ish()
    _tlbi_vaae1is(page_va >> cast[uint64](12))
    _dsb_ish()
    _isb()

    m: Ptr[char] = "[arm64] Phase 32 segment fault: paged in VA "
    _uart_puts(m)
    _uart_puthex(page_va)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    return 1


# Phase-32 verdict. PASS iff: the on-disk ELF header validated; BOTH PT_LOADs
# were mapped; the program wrote its full message (it ran from the loaded text);
# and it exited with the expected status (e_entry executed the on-disk code).
def arm64_p32_finish(code: uint64) -> int64:
    arm64_p32_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] Phase 32 summary: file_len="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p32_file_len))
    g0: Ptr[char] = " parse_ok="
    _uart_puts(g0)
    _uart_puthex(cast[uint64](arm64_p32_parse_ok))
    g1: Ptr[char] = " segs="
    _uart_puts(g1)
    _uart_puthex(cast[uint64](arm64_p32_segs_loaded))
    g2: Ptr[char] = " text_faults="
    _uart_puts(g2)
    _uart_puthex(cast[uint64](arm64_p32_text_faults))
    g3: Ptr[char] = " msg_bytes="
    _uart_puts(g3)
    _uart_puthex(cast[uint64](arm64_p32_msg_bytes))
    g5: Ptr[char] = " exit="
    _uart_puts(g5)
    _uart_puthex(arm64_p32_exit_code)
    _uart_puts(nl)

    ok: int64 = 1
    if arm64_p32_file_len <= 0:
        ok = 0
    if arm64_p32_parse_ok == 0:
        ok = 0
    if arm64_p32_segs_loaded != 2:
        ok = 0
    if arm64_p32_msg_bytes <= 0:
        ok = 0
    if arm64_p32_exited == 0:
        ok = 0
    if code != P32_EXIT_CODE:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 32: read a genuine AArch64 ELF64 off the FAT16 disk, parsed + W^X-mapped its PT_LOADs into a fresh EL0 space, and ran it at EL0 to exit\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 32 PASS: loaded PROG.ELF from FAT16 disk and ran it at EL0\n"
        _uart_puts(pp)
        # Hand off to Phase 33 (native virtio-net ARP round-trip over virtio-mmio).
        # The block transport (TTBR0=program ASID) is irrelevant here; Phase 33
        # enumerates a fresh virtio-net transport and uses the kernel identity map.
        arm64_p33_run()
        # Unreachable: arm64_p33_run halts. Safety loop.
    else:
        fp: Ptr[char] = "[arm64] Phase 32 FAIL: on-disk ELF load/execute verdict failed\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-32 syscall dispatcher. Routed while the on-disk ELF program runs.
# write() emits the program's message to the UART; exit() runs the verdict.
def arm64_p32_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_P32_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[cast[int64](n)])
            n = n + cast[uint64](1)
        arm64_p32_msg_bytes = cast[int64](a2)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_P32_EXIT_NR:
        arm64_p32_exit_code = a0
        arm64_p32_exited = 1
        arm64_p32_finish(a0)
        while True:
            _wfi()

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 32)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-32 entry point (hand-off from arm64_p31_run on success), with the live
# virtio-blk transport `base`. Read PROG.ELF off the FAT16 disk, build a fresh
# EL0 space, parse + load the on-disk ELF (W^X-mapping its PT_LOADs), then ERET
# into e_entry at EL0t with IRQs masked. Segment page-ins happen on the sync
# abort path; the loaded program's write()/exit() syscalls drive the rest.
def arm64_p32_run(base: uint64) -> int64:
    intro: Ptr[char] = "[arm64] Phase 32: load a real ELF binary off the FAT16 disk + run at EL0\n"
    _uart_puts(intro)
    nl: Ptr[char] = "\n"

    # Deterministic, abort-driven: no scheduler, EL1 IRQs masked.
    _msr_daifset(2)

    arm64_p32_active = 0
    arm64_p32_parse_ok = 0
    arm64_p32_segs_loaded = 0
    arm64_p32_text_faults = 0
    arm64_p32_data_faults = 0
    arm64_p32_msg_bytes = 0
    arm64_p32_exited = 0
    arm64_p32_exit_code = cast[uint64](0xFFFF)
    arm64_p32_entry = cast[uint64](0)
    arm64_p32_file_len = 0

    # --- read the ELF off the disk ---
    flen: int64 = arm64_p32_read_file(base)
    if flen <= 0:
        fp: Ptr[char] = "[arm64] Phase 32 FAIL: could not read PROG.ELF off the FAT16 disk\n"
        _uart_puts(fp)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    arm64_p32_file_len = flen

    rm: Ptr[char] = "[arm64] Phase 32: read PROG.ELF off disk ("
    _uart_puts(rm)
    _uart_puthex(cast[uint64](flen))
    rm2: Ptr[char] = " bytes); parsing + loading\n"
    _uart_puts(rm2)

    # --- build the program's fresh EL0 space ---
    arm64_p32_build_space()

    # Recycle this ASID before first use.
    _dsb_ish()
    _tlbi_aside1is(P32_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()

    # Switch to the program's TTBR0 + ASID so the loader's mapping edits are live.
    _msr_ttbr0_el1(P32_L1 | (P32_ASID << P23_ASID_SHIFT))
    _dsb_ish()
    _tlbi_aside1is(P32_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()

    entry: uint64 = arm64_p32_load_elf()
    if entry == cast[uint64](0):
        fp2: Ptr[char] = "[arm64] Phase 32 FAIL: on-disk ELF failed header/phdr validation\n"
        _uart_puts(fp2)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    arm64_p32_active = 1

    enter: Ptr[char] = "[arm64] launching on-disk ELF program at EL0 (ASID 16), entry "
    _uart_puts(enter)
    _uart_puthex(entry)
    _uart_puts(nl)

    _msr_spsr_el1(SPSR_EL0T_DAIF)           # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(entry)                     # EL0 entry PC = parsed e_entry
    _msr_sp_el0(P32_STACK_TOP)              # EL0 stack pointer
    _isb()
    _eret()                                 # -> EL0; segments fault in, program runs
    # Unreachable: the program's exit() halts after the verdict.
    while True:
        _wfi()
    return 0


# ===========================================================================
# PHASE 33 driver — native virtio-net over the legacy virtio-mmio transport.
# ===========================================================================

# Probe the 32 virtio-mmio transport windows for a legacy (version 1) NET device
# (MagicValue "virt" + DeviceID 1). Returns the transport base, or 0 if none.
def arm64_p33_find_net() -> uint64:
    i: int64 = 0
    while i < VIRTIO_MMIO_COUNT:
        base: uint64 = VIRTIO_MMIO_BASE + (cast[uint64](i) * VIRTIO_MMIO_STRIDE)
        magic: uint32 = _vmmio_r32(base + VMMIO_MAGIC)
        if cast[uint64](magic) == VIRTIO_MAGIC:
            ver: uint32 = _vmmio_r32(base + VMMIO_VERSION)
            did: uint32 = _vmmio_r32(base + VMMIO_DEVICE_ID)
            if cast[uint64](did) == VIRTIO_ID_NET:
                if cast[uint64](ver) == VIRTIO_VERSION_LEGACY:
                    return base
        i = i + 1
    return 0


# Write a split-virtqueue descriptor (16 bytes) into the descriptor table that
# begins at `desc_base`, at index `idx`.
def arm64_p33_set_desc(desc_base: uint64, idx: int64, addr: uint64, length: uint32, flags: uint16, nxt: uint16) -> int64:
    b: uint64 = desc_base + (cast[uint64](idx) * cast[uint64](16))
    a: Ptr[uint64] = cast[Ptr[uint64]](b + cast[uint64](0))
    a[0] = addr
    l: Ptr[uint32] = cast[Ptr[uint32]](b + cast[uint64](8))
    l[0] = length
    f: Ptr[uint16] = cast[Ptr[uint16]](b + cast[uint64](12))
    f[0] = flags
    n: Ptr[uint16] = cast[Ptr[uint16]](b + cast[uint64](14))
    n[0] = nxt
    return 0


# Read a used-ring idx (u16 at offset 2 of the used ring at `used_base`).
def arm64_p33_used_idx(used_base: uint64) -> uint16:
    p: Ptr[uint16] = cast[Ptr[uint16]](used_base + cast[uint64](2))
    v: uint16 = p[0]
    return v


# Program ONE legacy virtqueue `qidx` whose contiguous split-ring region begins
# at `ring_base`. Selects the queue, sizes it, wipes the region, hands the device
# the PFN. Returns the negotiated queue size, or 0 on failure.
def arm64_p33_setup_queue(base: uint64, qidx: uint32, ring_base: uint64) -> int64:
    _vmmio_w32(base + VMMIO_QUEUE_SEL, qidx)
    _dsb_ish()
    qmax: uint32 = _vmmio_r32(base + VMMIO_QUEUE_NUM_MAX)
    if qmax == cast[uint32](0):
        return 0
    qsz: uint32 = cast[uint32](P33_QSIZE)
    if cast[uint64](qsz) > cast[uint64](qmax):
        qsz = qmax
    _vmmio_w32(base + VMMIO_QUEUE_NUM, qsz)
    _vmmio_w32(base + VMMIO_QUEUE_ALIGN, cast[uint32](P30_QUEUE_ALIGN))
    # Wipe the whole queue region (desc + avail + pad + used = 2 pages).
    arm64_p30_bzero(ring_base, 8192)
    pfn: uint64 = ring_base / P30_PAGE_SIZE
    _vmmio_w32(base + VMMIO_QUEUE_PFN, cast[uint32](pfn))
    _dsb_ish()
    return cast[int64](qsz)


# Bring up the located legacy virtio-net transport: reset, ACKNOWLEDGE+DRIVER,
# negotiate F_MAC only (NOT F_MRG_RXBUF, so the net hdr stays 10 bytes), set the
# guest page size, program queue 0 (RX) and queue 1 (TX), DRIVER_OK. Returns 1 on
# success, 0 on any failure.
def arm64_p33_setup(base: uint64) -> int64:
    # 1. Reset.
    _vmmio_w32(base + VMMIO_STATUS, cast[uint32](0))
    _dsb_ish()
    # 2/3. ACKNOWLEDGE | DRIVER.
    st: uint32 = VSTATUS_ACKNOWLEDGE
    _vmmio_w32(base + VMMIO_STATUS, st)
    st = st | VSTATUS_DRIVER
    _vmmio_w32(base + VMMIO_STATUS, st)
    _dsb_ish()
    # 4. Feature negotiation. Read host features word 0; accept ONLY F_MAC if the
    #    host offers it. Crucially DO NOT accept F_MRG_RXBUF (the net hdr must stay
    #    10 bytes for our fixed layout). Word 1 (F_VERSION_1 etc.): accept none —
    #    this is the LEGACY transport, so the driver stays version-0 shaped.
    _vmmio_w32(base + VMMIO_HOST_FEATURES_SEL, cast[uint32](0))
    host0: uint32 = _vmmio_r32(base + VMMIO_HOST_FEATURES)
    guest0: uint32 = host0 & VIRTIO_NET_F_MAC
    _vmmio_w32(base + VMMIO_GUEST_FEATURES_SEL, cast[uint32](0))
    _vmmio_w32(base + VMMIO_GUEST_FEATURES, guest0)
    _vmmio_w32(base + VMMIO_GUEST_FEATURES_SEL, cast[uint32](1))
    _vmmio_w32(base + VMMIO_GUEST_FEATURES, cast[uint32](0))
    _dsb_ish()
    # 5. Legacy guest page size for the PFN math.
    _vmmio_w32(base + VMMIO_GUEST_PAGE_SIZE, cast[uint32](P30_PAGE_SIZE))
    _dsb_ish()
    # 6. Program queue 0 (RX) and queue 1 (TX).
    if arm64_p33_setup_queue(base, cast[uint32](0), P33_RX_RING_BASE) == 0:
        return 0
    if arm64_p33_setup_queue(base, cast[uint32](1), P33_TX_RING_BASE) == 0:
        return 0
    # 7. DRIVER_OK.
    st = st | VSTATUS_DRIVER_OK
    _vmmio_w32(base + VMMIO_STATUS, st)
    _dsb_ish()
    arm64_p33_rx_avail_idx = cast[uint16](0)
    arm64_p33_tx_avail_idx = cast[uint16](0)
    return 1


# Read the device MAC out of the legacy device-config window (+0x100). Valid when
# F_MAC was offered; SLIRP always assigns one regardless. Stash all 6 bytes.
def arm64_p33_read_mac(base: uint64) -> int64:
    p: Ptr[uint8] = cast[Ptr[uint8]](base + VMMIO_CONFIG)
    arm64_p33_mac0 = p[0]
    arm64_p33_mac1 = p[1]
    arm64_p33_mac2 = p[2]
    arm64_p33_mac3 = p[3]
    arm64_p33_mac4 = p[4]
    arm64_p33_mac5 = p[5]
    return 0


# Post all P33_QSIZE RX buffers into queue 0: each is one device-writable
# descriptor covering net hdr + frame (P33_RXBUF_STRIDE bytes). The whole pool is
# pre-zeroed so a stale read can't masquerade as a received frame.
def arm64_p33_post_rx(base: uint64) -> int64:
    arm64_p30_bzero(P33_RXBUF_BASE, cast[int64](P33_RXBUF_STRIDE) * P33_QSIZE)
    i: int64 = 0
    while i < P33_QSIZE:
        buf: uint64 = P33_RXBUF_BASE + (cast[uint64](i) * P33_RXBUF_STRIDE)
        # One write-only descriptor per RX slot (device fills it).
        arm64_p33_set_desc(P33_RX_DESC_PA, i, buf, cast[uint32](P33_RXBUF_STRIDE), VRING_DESC_F_WRITE, cast[uint16](0))
        # Publish descriptor head `i` into the RX avail ring.
        slot: uint64 = cast[uint64](arm64_p33_rx_avail_idx) & cast[uint64](P33_QSIZE - 1)
        ar: Ptr[uint16] = cast[Ptr[uint16]](P33_RX_AVAIL_PA + cast[uint64](4) + (slot * cast[uint64](2)))
        ar[0] = cast[uint16](i)
        arm64_p33_rx_avail_idx = arm64_p33_rx_avail_idx + cast[uint16](1)
        i = i + 1
    _dsb_ish()
    # Publish the new RX avail.idx with a release barrier, then notify queue 0.
    ai: Ptr[uint16] = cast[Ptr[uint16]](P33_RX_AVAIL_PA + cast[uint64](2))
    ai[0] = arm64_p33_rx_avail_idx
    _dsb_ish()
    _vmmio_w32(base + VMMIO_QUEUE_NOTIFY, cast[uint32](0))
    _dsb_ish()
    return 0


# Store a 16-bit big-endian value at byte offset `off` of buffer `b`.
def arm64_p33_put_be16(b: uint64, off: int64, val: uint64) -> int64:
    p: Ptr[uint8] = cast[Ptr[uint8]](b + cast[uint64](off))
    p[0] = cast[uint8]((val >> cast[uint64](8)) & cast[uint64](0xFF))
    p[1] = cast[uint8](val & cast[uint64](0xFF))
    return 0


# Read a 16-bit big-endian value from byte offset `off` of buffer `b`.
def arm64_p33_get_be16(b: uint64, off: int64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](b + cast[uint64](off))
    hi: uint64 = cast[uint64](p[0])
    lo: uint64 = cast[uint64](p[1])
    return (hi << cast[uint64](8)) | lo


# Build an Ethernet+ARP request for the SLIRP gateway (10.0.2.2) into the TX
# frame buffer. Source MAC = our device MAC; destination MAC = broadcast. Returns
# the total Ethernet frame length (14 + 28 = 42 bytes).
def arm64_p33_build_arp() -> int64:
    f: uint64 = P33_TX_FRAME_PA
    arm64_p30_bzero(f, 64)
    eth: Ptr[uint8] = cast[Ptr[uint8]](f)
    # --- Ethernet header: dst (broadcast), src (our MAC), ethertype ARP ---
    eth[0] = cast[uint8](0xFF)
    eth[1] = cast[uint8](0xFF)
    eth[2] = cast[uint8](0xFF)
    eth[3] = cast[uint8](0xFF)
    eth[4] = cast[uint8](0xFF)
    eth[5] = cast[uint8](0xFF)
    eth[6] = arm64_p33_mac0
    eth[7] = arm64_p33_mac1
    eth[8] = arm64_p33_mac2
    eth[9] = arm64_p33_mac3
    eth[10] = arm64_p33_mac4
    eth[11] = arm64_p33_mac5
    arm64_p33_put_be16(f, 12, P33_ETHERTYPE_ARP)
    # --- ARP payload (offset 14) ---
    a: uint64 = f + cast[uint64](14)
    arm64_p33_put_be16(a, 0, cast[uint64](1))            # HTYPE = Ethernet
    arm64_p33_put_be16(a, 2, cast[uint64](0x0800))       # PTYPE = IPv4
    pa: Ptr[uint8] = cast[Ptr[uint8]](a)
    pa[4] = cast[uint8](6)                               # HLEN = 6
    pa[5] = cast[uint8](4)                               # PLEN = 4
    arm64_p33_put_be16(a, 6, P33_ARP_REQUEST)            # OPER = request
    # Sender HW addr = our MAC.
    pa[8] = arm64_p33_mac0
    pa[9] = arm64_p33_mac1
    pa[10] = arm64_p33_mac2
    pa[11] = arm64_p33_mac3
    pa[12] = arm64_p33_mac4
    pa[13] = arm64_p33_mac5
    # Sender protocol addr = guest IP 10.0.2.15.
    pa[14] = P33_GUEST_IP0
    pa[15] = P33_GUEST_IP1
    pa[16] = P33_GUEST_IP2
    pa[17] = P33_GUEST_IP3
    # Target HW addr = 0 (unknown).
    # Target protocol addr = gateway 10.0.2.2.
    pa[24] = P33_GW_IP0
    pa[25] = P33_GW_IP1
    pa[26] = P33_GW_IP2
    pa[27] = P33_GW_IP3
    _dsb_ish()
    return P33_ETH_HDR_LEN + P33_ARP_LEN


# Transmit one frame of length `frame_len` (bytes, excluding the net hdr) on
# queue 1. Chains a read-only net-hdr descriptor -> read-only frame descriptor,
# bumps TX avail.idx, notifies queue 1, and polls the TX used ring. Returns 1 if
# the device reported the buffer used (the frame really went out), else 0.
def arm64_p33_tx(base: uint64, frame_len: int64) -> int64:
    # Zero the 10-byte virtio_net_hdr (no offload, no GSO).
    arm64_p30_bzero(P33_TX_HDR_PA, cast[int64](P33_NET_HDR_LEN))
    _dsb_ish()
    # Two-descriptor chain: hdr (R) -> frame (R).
    arm64_p33_set_desc(P33_TX_DESC_PA, 0, P33_TX_HDR_PA, cast[uint32](P33_NET_HDR_LEN), VRING_DESC_F_NEXT, cast[uint16](1))
    arm64_p33_set_desc(P33_TX_DESC_PA, 1, P33_TX_FRAME_PA, cast[uint32](frame_len), cast[uint16](0), cast[uint16](0))
    _dsb_ish()
    # Publish head 0 into the TX avail ring at the current slot.
    slot: uint64 = cast[uint64](arm64_p33_tx_avail_idx) & cast[uint64](P33_QSIZE - 1)
    ar: Ptr[uint16] = cast[Ptr[uint16]](P33_TX_AVAIL_PA + cast[uint64](4) + (slot * cast[uint64](2)))
    ar[0] = cast[uint16](0)
    _dsb_ish()
    arm64_p33_tx_avail_idx = arm64_p33_tx_avail_idx + cast[uint16](1)
    ai: Ptr[uint16] = cast[Ptr[uint16]](P33_TX_AVAIL_PA + cast[uint64](2))
    ai[0] = arm64_p33_tx_avail_idx
    _dsb_ish()
    before: uint16 = arm64_p33_used_idx(P33_TX_USED_PA)
    _vmmio_w32(base + VMMIO_QUEUE_NOTIFY, cast[uint32](1))
    _dsb_ish()
    spins: int64 = 0
    while spins < 200000000:
        _dsb_ish()
        now: uint16 = arm64_p33_used_idx(P33_TX_USED_PA)
        if now != before:
            isr: uint32 = _vmmio_r32(base + VMMIO_INTERRUPT_STATUS)
            if isr != cast[uint32](0):
                _vmmio_w32(base + VMMIO_INTERRUPT_ACK, isr)
            _dsb_ish()
            return 1
        spins = spins + 1
    return 0


# Read the length the device wrote into RX used-ring element `eidx` (the second
# u32 of the 8-byte used element). The used element array starts at used_base+4.
def arm64_p33_rx_used_len(used_base: uint64, eidx: uint16) -> uint32:
    slot: uint64 = cast[uint64](eidx) & cast[uint64](P33_QSIZE - 1)
    elem: uint64 = used_base + cast[uint64](4) + (slot * cast[uint64](8))
    lp: Ptr[uint32] = cast[Ptr[uint32]](elem + cast[uint64](4))
    return lp[0]


# Read the descriptor id of RX used-ring element `eidx` (first u32 of the elem),
# i.e. which RX buffer slot the device filled.
def arm64_p33_rx_used_id(used_base: uint64, eidx: uint16) -> uint32:
    slot: uint64 = cast[uint64](eidx) & cast[uint64](P33_QSIZE - 1)
    elem: uint64 = used_base + cast[uint64](4) + (slot * cast[uint64](8))
    ip: Ptr[uint32] = cast[Ptr[uint32]](elem + cast[uint64](0))
    return ip[0]


# Harvest one completed RX used-ring element at driver index `before`: record the
# frame length and (if ARP) whether it is a REPLY. Returns the descriptor id of
# the filled RX buffer.
def arm64_p33_rx_harvest(base: uint64, before: uint16) -> int64:
    isr: uint32 = _vmmio_r32(base + VMMIO_INTERRUPT_STATUS)
    if isr != cast[uint32](0):
        _vmmio_w32(base + VMMIO_INTERRUPT_ACK, isr)
    _dsb_ish()
    did: uint32 = arm64_p33_rx_used_id(P33_RX_USED_PA, before)
    ulen: uint32 = arm64_p33_rx_used_len(P33_RX_USED_PA, before)
    arm64_p33_rx_len = cast[int64](ulen)
    # Locate the filled buffer; the Ethernet frame begins after the net hdr.
    buf: uint64 = P33_RXBUF_BASE + (cast[uint64](did) * P33_RXBUF_STRIDE)
    frame: uint64 = buf + P33_NET_HDR_LEN
    # Ethertype at frame offset 12. If ARP, check OPER at payload+6.
    etype: uint64 = arm64_p33_get_be16(frame, 12)
    if etype == P33_ETHERTYPE_ARP:
        oper: uint64 = arm64_p33_get_be16(frame + cast[uint64](14), 6)
        if oper == P33_ARP_REPLY:
            arm64_p33_rx_is_arp_reply = 1
            # Learn the gateway MAC from the ARP reply's sender-HW field
            # (ARP payload offset 8). Phase 34 reuses it for IPv4 framing.
            ap: Ptr[uint8] = cast[Ptr[uint8]](frame + cast[uint64](14) + cast[uint64](8))
            arm64_p33_gw_mac0 = ap[0]
            arm64_p33_gw_mac1 = ap[1]
            arm64_p33_gw_mac2 = ap[2]
            arm64_p33_gw_mac3 = ap[3]
            arm64_p33_gw_mac4 = ap[4]
            arm64_p33_gw_mac5 = ap[5]
            arm64_p33_gw_mac_valid = 1
    return cast[int64](did)


# Poll the RX used ring for a received frame. SLIRP injects its ARP reply on the
# QEMU host main loop, which only advances between vCPU translation blocks; a
# single tight spin can starve it, so we run OUTER rounds: each round spins a
# bounded budget, and between rounds we RE-TRANSMIT the ARP request (SLIRP answers
# every ARP) and RE-NOTIFY the RX queue, giving the host many chances to inject
# the reply into our RX ring. On a completion, inspect the frame (skipping the
# 10-byte net hdr). Returns 1 if a frame was received, 0 after all rounds time out.
def arm64_p33_rx_poll(base: uint64) -> int64:
    before: uint16 = arm64_p33_used_idx(P33_RX_USED_PA)
    rounds: int64 = 0
    while rounds < 4000:
        spins: int64 = 0
        while spins < 100000:
            _dsb_ish()
            now: uint16 = arm64_p33_used_idx(P33_RX_USED_PA)
            if now != before:
                arm64_p33_rx_harvest(base, before)
                return 1
            spins = spins + 1
        # No frame yet this round: re-poke the device. Re-notify RX queue 0 (in
        # case the device coalesced), and re-transmit the ARP so SLIRP re-replies.
        _vmmio_w32(base + VMMIO_QUEUE_NOTIFY, cast[uint32](0))
        _dsb_ish()
        arm64_p33_tx(base, P33_ETH_HDR_LEN + P33_ARP_LEN)
        rounds = rounds + 1
    return 0


# Print the device MAC as XX:XX:XX:XX:XX:XX (2 hex digits per byte).
def arm64_p33_print_mac() -> int64:
    arm64_p33_print_hex8(arm64_p33_mac0)
    c: Ptr[char] = ":"
    _uart_puts(c)
    arm64_p33_print_hex8(arm64_p33_mac1)
    _uart_puts(c)
    arm64_p33_print_hex8(arm64_p33_mac2)
    _uart_puts(c)
    arm64_p33_print_hex8(arm64_p33_mac3)
    _uart_puts(c)
    arm64_p33_print_hex8(arm64_p33_mac4)
    _uart_puts(c)
    arm64_p33_print_hex8(arm64_p33_mac5)
    return 0


# Print one byte as exactly two hex digits.
def arm64_p33_print_hex8(b: uint8) -> int64:
    v: uint64 = cast[uint64](b)
    hi: uint64 = (v >> cast[uint64](4)) & cast[uint64](0xF)
    lo: uint64 = v & cast[uint64](0xF)
    if hi < cast[uint64](10):
        _uart_putc(cast[uint8](cast[uint64](0x30) + hi))
    else:
        _uart_putc(cast[uint8](cast[uint64](0x37) + hi))
    if lo < cast[uint64](10):
        _uart_putc(cast[uint8](cast[uint64](0x30) + lo))
    else:
        _uart_putc(cast[uint8](cast[uint64](0x37) + lo))
    return 0


# Phase 33 entry point (hand-off from arm64_p32_finish on a Phase-32 PASS). Find
# the legacy virtio-net transport, bring it up, read the MAC, post RX buffers,
# transmit an ARP request for the SLIRP gateway, observe the TX used-ring
# completion, then poll the RX ring for SLIRP's answer. Prints the PASS/FAIL
# verdict, then halts. Polled throughout (EL1 IRQs masked); never returns.
def arm64_p33_run() -> int64:
    intro: Ptr[char] = "[arm64] Phase 33: native virtio-net over virtio-mmio (ARP round-trip)\n"
    _uart_puts(intro)
    nl: Ptr[char] = "\n"

    # Deterministic, polled: EL1 IRQs masked.
    _msr_daifset(2)

    arm64_p33_tx_done = 0
    arm64_p33_rx_len = 0
    arm64_p33_rx_is_arp_reply = 0

    base: uint64 = arm64_p33_find_net()
    if base == cast[uint64](0):
        fp: Ptr[char] = "[arm64] Phase 33 FAIL: no virtio-net transport found\n"
        _uart_puts(fp)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    arm64_p33_mmio_base = base

    fb: Ptr[char] = "[arm64] Phase 33: found virtio-net transport @ "
    _uart_puts(fb)
    _uart_puthex(base)
    _uart_puts(nl)

    if arm64_p33_setup(base) != 1:
        fp2: Ptr[char] = "[arm64] Phase 33 FAIL: device bring-up failed\n"
        _uart_puts(fp2)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    arm64_p33_read_mac(base)
    mm: Ptr[char] = "[arm64] Phase 33: device MAC = "
    _uart_puts(mm)
    arm64_p33_print_mac()
    _uart_puts(nl)

    lb: Ptr[char] = "[arm64] Phase 33: device live (DRIVER_OK), RX+TX queues programmed\n"
    _uart_puts(lb)

    # Post all RX buffers BEFORE transmitting, so SLIRP's reply has somewhere to land.
    arm64_p33_post_rx(base)
    rb: Ptr[char] = "[arm64] Phase 33: posted RX buffers, transmitting ARP request for 10.0.2.2\n"
    _uart_puts(rb)

    # Build + transmit the ARP request; require a real TX used-ring completion.
    flen: int64 = arm64_p33_build_arp()
    tx_ok: int64 = arm64_p33_tx(base, flen)
    if tx_ok != 1:
        fp3: Ptr[char] = "[arm64] Phase 33 FAIL: TX never completed (no used-ring entry)\n"
        _uart_puts(fp3)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    arm64_p33_tx_done = 1
    tb: Ptr[char] = "[arm64] Phase 33: TX used-ring completion observed (frame len="
    _uart_puts(tb)
    _uart_puthex(cast[uint64](flen))
    _uart_puts(nl)

    # Poll the RX ring for SLIRP's reply.
    rx_ok: int64 = arm64_p33_rx_poll(base)
    if rx_ok != 1:
        fp4: Ptr[char] = "[arm64] Phase 33 FAIL: RX never received a frame (no used-ring entry)\n"
        _uart_puts(fp4)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    rxm: Ptr[char] = "[arm64] Phase 33: RX used-ring completion observed (frame len="
    _uart_puts(rxm)
    _uart_puthex(cast[uint64](arm64_p33_rx_len))
    am: Ptr[char] = " arp_reply="
    _uart_puts(am)
    _uart_puthex(cast[uint64](arm64_p33_rx_is_arp_reply))
    _uart_puts(nl)

    sm: Ptr[char] = "[arm64] Phase 33 summary: tx_done="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p33_tx_done))
    s2: Ptr[char] = " rx_len="
    _uart_puts(s2)
    _uart_puthex(cast[uint64](arm64_p33_rx_len))
    s3: Ptr[char] = " arp_reply="
    _uart_puts(s3)
    _uart_puthex(cast[uint64](arm64_p33_rx_is_arp_reply))
    _uart_puts(nl)

    ok: int64 = 1
    if arm64_p33_tx_done == 0:
        ok = 0
    if arm64_p33_rx_len <= 0:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 33: brought up a native virtio-net device over virtio-mmio, transmitted an ARP request through the TX ring, and received a frame back through the RX ring\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 33 PASS: virtio-net ARP round-trip (TX used + RX frame) over virtio-mmio\n"
        _uart_puts(pp)
        # Hand off to Phase 34 (IPv4 + ICMP echo round-trip) on the SAME live
        # virtio-net device. Phase 34 reuses this transport base, the device MAC,
        # the gateway MAC learned from the ARP reply, and the TX/RX primitives.
        arm64_p34_run(base)
    else:
        fp5: Ptr[char] = "[arm64] Phase 33 FAIL: round-trip verdict failed\n"
        _uart_puts(fp5)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# ===========================================================================
# PHASE 34 — a minimal but REAL IPv4 path on top of the Phase-33 native
# virtio-net device: build + transmit an IPv4/ICMP Echo Request (ping) to the
# SLIRP gateway 10.0.2.2 (with real IPv4 + ICMP checksums), then receive and
# validate the ICMP Echo Reply (type 0, proto 1, matching id/seq, checksum-valid).
# All framing is hand-rolled here in kmain.ad and reuses the Phase-33 Ethernet
# TX/RX ring primitives — nothing under drivers/net is touched.
# ===========================================================================

P34_ETHERTYPE_IPV4: uint64 = 0x0800
P34_IP_PROTO_ICMP: uint64 = 1
P34_IP_PROTO_UDP: uint64 = 17
P34_ICMP_ECHO_REQUEST: uint64 = 8
P34_ICMP_ECHO_REPLY: uint64 = 0

P34_IP_HDR_LEN: int64 = 20                   # no IPv4 options
P34_ICMP_HDR_LEN: int64 = 8                  # type/code/csum/id/seq
P34_ICMP_PAYLOAD_LEN: int64 = 16             # arbitrary echo payload

P34_ICMP_ID: uint64 = 0xBEEF                 # our echo identifier
P34_ICMP_SEQ: uint64 = 1                     # our echo sequence number

# Phase 34 bookkeeping.
arm64_p34_tx_done: int64 = 0                 # ICMP request TX used-ring completion
arm64_p34_rx_len: int64 = 0                  # received reply frame length (incl net hdr)
arm64_p34_echo_reply_ok: int64 = 0           # 1 once a valid echo reply was validated
arm64_p34_rx_icmp_type: int64 = -1           # ICMP type of the validated reply
arm64_p34_rx_id: int64 = -1                  # ICMP id echoed back
arm64_p34_rx_seq: int64 = -1                 # ICMP seq echoed back


# 16-bit ones-complement Internet checksum over `n` bytes at `b`. Sums 16-bit
# big-endian words (padding a trailing odd byte with a zero low half), folds the
# carries, and returns the one's complement, all in a 16-bit result.
def arm64_p34_checksum(b: uint64, n: int64) -> uint64:
    sum: uint64 = 0
    i: int64 = 0
    while i + 1 < n:
        sum = sum + arm64_p33_get_be16(b, i)
        i = i + 2
    if i < n:
        p: Ptr[uint8] = cast[Ptr[uint8]](b + cast[uint64](i))
        sum = sum + (cast[uint64](p[0]) << cast[uint64](8))
    # Fold carries until the high half is zero.
    while (sum >> cast[uint64](16)) != cast[uint64](0):
        sum = (sum & cast[uint64](0xFFFF)) + (sum >> cast[uint64](16))
    return (~sum) & cast[uint64](0xFFFF)


# Store a 32-bit big-endian value at byte offset `off` of buffer `b`.
def arm64_p34_put_be32(b: uint64, off: int64, val: uint64) -> int64:
    p: Ptr[uint8] = cast[Ptr[uint8]](b + cast[uint64](off))
    p[0] = cast[uint8]((val >> cast[uint64](24)) & cast[uint64](0xFF))
    p[1] = cast[uint8]((val >> cast[uint64](16)) & cast[uint64](0xFF))
    p[2] = cast[uint8]((val >> cast[uint64](8)) & cast[uint64](0xFF))
    p[3] = cast[uint8](val & cast[uint64](0xFF))
    return 0


# Build an Ethernet + IPv4 + ICMP Echo Request into the shared Phase-33 TX frame
# buffer. dst MAC = the gateway MAC learned from the Phase-33 ARP reply; src MAC =
# our device MAC. Real IPv4 + ICMP checksums are computed. Returns total Ethernet
# frame length (14 + 20 + 8 + payload).
def arm64_p34_build_icmp() -> int64:
    f: uint64 = P33_TX_FRAME_PA
    total: int64 = P33_ETH_HDR_LEN + P34_IP_HDR_LEN + P34_ICMP_HDR_LEN + P34_ICMP_PAYLOAD_LEN
    arm64_p30_bzero(f, cast[int64](total) + 4)
    eth: Ptr[uint8] = cast[Ptr[uint8]](f)
    # --- Ethernet header: dst = gateway MAC, src = our MAC, ethertype IPv4 ---
    eth[0] = arm64_p33_gw_mac0
    eth[1] = arm64_p33_gw_mac1
    eth[2] = arm64_p33_gw_mac2
    eth[3] = arm64_p33_gw_mac3
    eth[4] = arm64_p33_gw_mac4
    eth[5] = arm64_p33_gw_mac5
    eth[6] = arm64_p33_mac0
    eth[7] = arm64_p33_mac1
    eth[8] = arm64_p33_mac2
    eth[9] = arm64_p33_mac3
    eth[10] = arm64_p33_mac4
    eth[11] = arm64_p33_mac5
    arm64_p33_put_be16(f, 12, P34_ETHERTYPE_IPV4)

    # --- IPv4 header (offset 14) ---
    ip: uint64 = f + cast[uint64](P33_ETH_HDR_LEN)
    ipp: Ptr[uint8] = cast[Ptr[uint8]](ip)
    ipp[0] = cast[uint8](0x45)                          # version 4, IHL 5 (20 bytes)
    ipp[1] = cast[uint8](0)                             # DSCP/ECN
    iptotal: uint64 = cast[uint64](P34_IP_HDR_LEN + P34_ICMP_HDR_LEN + P34_ICMP_PAYLOAD_LEN)
    arm64_p33_put_be16(ip, 2, iptotal)                  # total length
    arm64_p33_put_be16(ip, 4, cast[uint64](0x1234))     # identification
    arm64_p33_put_be16(ip, 6, cast[uint64](0))          # flags/fragment offset = 0
    ipp[8] = cast[uint8](64)                            # TTL
    ipp[9] = cast[uint8](P34_IP_PROTO_ICMP)             # protocol = ICMP
    arm64_p33_put_be16(ip, 10, cast[uint64](0))         # checksum placeholder
    # src = guest 10.0.2.15
    ipp[12] = P33_GUEST_IP0
    ipp[13] = P33_GUEST_IP1
    ipp[14] = P33_GUEST_IP2
    ipp[15] = P33_GUEST_IP3
    # dst = gateway 10.0.2.2
    ipp[16] = P33_GW_IP0
    ipp[17] = P33_GW_IP1
    ipp[18] = P33_GW_IP2
    ipp[19] = P33_GW_IP3
    ipcsum: uint64 = arm64_p34_checksum(ip, P34_IP_HDR_LEN)
    arm64_p33_put_be16(ip, 10, ipcsum)

    # --- ICMP Echo Request (offset 14 + 20) ---
    icmp: uint64 = ip + cast[uint64](P34_IP_HDR_LEN)
    icp: Ptr[uint8] = cast[Ptr[uint8]](icmp)
    icp[0] = cast[uint8](P34_ICMP_ECHO_REQUEST)         # type 8
    icp[1] = cast[uint8](0)                             # code 0
    arm64_p33_put_be16(icmp, 2, cast[uint64](0))        # checksum placeholder
    arm64_p33_put_be16(icmp, 4, P34_ICMP_ID)            # identifier
    arm64_p33_put_be16(icmp, 6, P34_ICMP_SEQ)           # sequence number
    # Fill the payload with a recognizable ramp.
    j: int64 = 0
    while j < P34_ICMP_PAYLOAD_LEN:
        pp: Ptr[uint8] = cast[Ptr[uint8]](icmp + cast[uint64](P34_ICMP_HDR_LEN + j))
        pp[0] = cast[uint8](cast[uint64](0x40 + j) & cast[uint64](0xFF))
        j = j + 1
    icmpcsum: uint64 = arm64_p34_checksum(icmp, P34_ICMP_HDR_LEN + P34_ICMP_PAYLOAD_LEN)
    arm64_p33_put_be16(icmp, 2, icmpcsum)

    _dsb_ish()
    return total


# Validate a received frame at RX buffer descriptor `did` as an ICMP Echo Reply
# to OUR request. Checks ethertype 0x0800, IPv4 (version 4, proto 1, src=gateway,
# dst=guest), a valid ICMP checksum over the ICMP message, type 0, and matching
# id/seq. Records type/id/seq into the bookkeeping globals. Returns 1 if it is a
# valid echo reply, else 0.
def arm64_p34_validate_reply(did: int64) -> int64:
    buf: uint64 = P33_RXBUF_BASE + (cast[uint64](did) * P33_RXBUF_STRIDE)
    frame: uint64 = buf + P33_NET_HDR_LEN
    etype: uint64 = arm64_p33_get_be16(frame, 12)
    if etype != P34_ETHERTYPE_IPV4:
        return 0
    ip: uint64 = frame + cast[uint64](P33_ETH_HDR_LEN)
    ipp: Ptr[uint8] = cast[Ptr[uint8]](ip)
    ver: uint64 = (cast[uint64](ipp[0]) >> cast[uint64](4)) & cast[uint64](0xF)
    if ver != cast[uint64](4):
        return 0
    ihl: uint64 = cast[uint64](ipp[0]) & cast[uint64](0xF)
    if ihl < cast[uint64](5):
        return 0
    proto: uint64 = cast[uint64](ipp[9])
    if proto != P34_IP_PROTO_ICMP:
        return 0
    # src must be the gateway 10.0.2.2; dst must be our guest 10.0.2.15.
    if ipp[12] != P33_GW_IP0:
        return 0
    if ipp[13] != P33_GW_IP1:
        return 0
    if ipp[14] != P33_GW_IP2:
        return 0
    if ipp[15] != P33_GW_IP3:
        return 0
    if ipp[16] != P33_GUEST_IP0:
        return 0
    if ipp[17] != P33_GUEST_IP1:
        return 0
    if ipp[18] != P33_GUEST_IP2:
        return 0
    if ipp[19] != P33_GUEST_IP3:
        return 0
    # ICMP message begins after the (variable-length) IPv4 header.
    iphl: int64 = cast[int64](ihl) * 4
    icmp: uint64 = ip + cast[uint64](iphl)
    icp: Ptr[uint8] = cast[Ptr[uint8]](icmp)
    itype: uint64 = cast[uint64](icp[0])
    arm64_p34_rx_icmp_type = cast[int64](itype)
    if itype != P34_ICMP_ECHO_REPLY:
        return 0
    # Validate the ICMP checksum over the ICMP message (total IP len - IP hdr).
    iptotal: uint64 = arm64_p33_get_be16(ip, 2)
    icmplen: int64 = cast[int64](iptotal) - iphl
    if icmplen < P34_ICMP_HDR_LEN:
        return 0
    csum: uint64 = arm64_p34_checksum(icmp, icmplen)
    if csum != cast[uint64](0):
        return 0
    rid: uint64 = arm64_p33_get_be16(icmp, 4)
    rseq: uint64 = arm64_p33_get_be16(icmp, 6)
    arm64_p34_rx_id = cast[int64](rid)
    arm64_p34_rx_seq = cast[int64](rseq)
    if rid != P34_ICMP_ID:
        return 0
    if rseq != P34_ICMP_SEQ:
        return 0
    return 1


# Poll the RX ring for an ICMP Echo Reply. Mirrors the Phase-33 bounded
# re-notify pattern: each outer round spins a bounded budget watching the RX
# used-ring index; between rounds it RE-TRANSMITS the ICMP request and RE-NOTIFIES
# the RX queue so SLIRP's host main loop gets repeated chances to inject the
# reply. On each completion it harvests the descriptor and validates it; a
# non-matching frame (e.g. a stray ARP/broadcast) is skipped and polling
# continues. Returns 1 on a validated echo reply, 0 after all rounds time out.
def arm64_p34_rx_poll(base: uint64) -> int64:
    before: uint16 = arm64_p33_used_idx(P33_RX_USED_PA)
    rounds: int64 = 0
    while rounds < 4000:
        spins: int64 = 0
        while spins < 100000:
            _dsb_ish()
            now: uint16 = arm64_p33_used_idx(P33_RX_USED_PA)
            if now != before:
                did: int64 = arm64_p33_rx_harvest(base, before)
                arm64_p34_rx_len = arm64_p33_rx_len
                if arm64_p34_validate_reply(did) == 1:
                    return 1
                # Not our reply; advance past this used element and keep polling.
                before = before + cast[uint16](1)
            spins = spins + 1
        # No matching frame yet: re-poke the device and re-send the request so
        # SLIRP re-answers, giving its host main loop more injection windows.
        _vmmio_w32(base + VMMIO_QUEUE_NOTIFY, cast[uint32](0))
        _dsb_ish()
        arm64_p34_build_icmp()
        arm64_p33_tx(base, P33_ETH_HDR_LEN + P34_IP_HDR_LEN + P34_ICMP_HDR_LEN + P34_ICMP_PAYLOAD_LEN)
        rounds = rounds + 1
    return 0


# Phase 34 entry point (hand-off from arm64_p33_run on a Phase-33 PASS). Reuses
# the live virtio-net transport `base`, the device MAC, and the gateway MAC
# learned from the ARP reply. Builds + transmits a real IPv4/ICMP Echo Request,
# then polls for and validates the Echo Reply. Prints PASS only on a verified,
# checksum-valid reply with matching id/seq. Never returns (caller halts).
def arm64_p34_run(base: uint64) -> int64:
    intro: Ptr[char] = "[arm64] Phase 34: IPv4/ICMP echo round-trip over native virtio-net\n"
    _uart_puts(intro)
    nl: Ptr[char] = "\n"

    arm64_p34_tx_done = 0
    arm64_p34_rx_len = 0
    arm64_p34_echo_reply_ok = 0
    arm64_p34_rx_icmp_type = -1
    arm64_p34_rx_id = -1
    arm64_p34_rx_seq = -1

    # Require the gateway MAC learned from the Phase-33 ARP reply.
    if arm64_p33_gw_mac_valid == 0:
        fp: Ptr[char] = "[arm64] Phase 34 FAIL: no gateway MAC (ARP reply did not resolve 10.0.2.2)\n"
        _uart_puts(fp)
        return 0
    gm: Ptr[char] = "[arm64] Phase 34: gateway 10.0.2.2 is at "
    _uart_puts(gm)
    arm64_p33_print_hex8(arm64_p33_gw_mac0)
    c: Ptr[char] = ":"
    _uart_puts(c)
    arm64_p33_print_hex8(arm64_p33_gw_mac1)
    _uart_puts(c)
    arm64_p33_print_hex8(arm64_p33_gw_mac2)
    _uart_puts(c)
    arm64_p33_print_hex8(arm64_p33_gw_mac3)
    _uart_puts(c)
    arm64_p33_print_hex8(arm64_p33_gw_mac4)
    _uart_puts(c)
    arm64_p33_print_hex8(arm64_p33_gw_mac5)
    _uart_puts(nl)

    # The Phase-33 RX buffers are already posted; the device keeps filling them.
    bm: Ptr[char] = "[arm64] Phase 34: transmitting IPv4/ICMP Echo Request to 10.0.2.2\n"
    _uart_puts(bm)

    # Build + transmit the ICMP echo request; require a real TX used completion.
    flen: int64 = arm64_p34_build_icmp()
    tx_ok: int64 = arm64_p33_tx(base, flen)
    if tx_ok != 1:
        fp2: Ptr[char] = "[arm64] Phase 34 FAIL: TX never completed (ICMP request not sent)\n"
        _uart_puts(fp2)
        return 0
    arm64_p34_tx_done = 1
    tb: Ptr[char] = "[arm64] Phase 34: TX used-ring completion observed (ICMP request len="
    _uart_puts(tb)
    _uart_puthex(cast[uint64](flen))
    _uart_puts(nl)

    # Poll the RX ring for the validated Echo Reply.
    rx_ok: int64 = arm64_p34_rx_poll(base)
    if rx_ok != 1:
        fp3: Ptr[char] = "[arm64] Phase 34 FAIL: no valid ICMP Echo Reply received (type="
        _uart_puts(fp3)
        _uart_puthex(cast[uint64](arm64_p34_rx_icmp_type))
        s: Ptr[char] = " id="
        _uart_puts(s)
        _uart_puthex(cast[uint64](arm64_p34_rx_id))
        s2: Ptr[char] = " seq="
        _uart_puts(s2)
        _uart_puthex(cast[uint64](arm64_p34_rx_seq))
        cp: Ptr[char] = ")\n"
        _uart_puts(cp)
        return 0
    arm64_p34_echo_reply_ok = 1

    rxm: Ptr[char] = "[arm64] Phase 34: RX Echo Reply validated (icmp_type="
    _uart_puts(rxm)
    _uart_puthex(cast[uint64](arm64_p34_rx_icmp_type))
    s3: Ptr[char] = " id="
    _uart_puts(s3)
    _uart_puthex(cast[uint64](arm64_p34_rx_id))
    s4: Ptr[char] = " seq="
    _uart_puts(s4)
    _uart_puthex(cast[uint64](arm64_p34_rx_seq))
    s5: Ptr[char] = " rx_len="
    _uart_puts(s5)
    _uart_puthex(cast[uint64](arm64_p34_rx_len))
    cp2: Ptr[char] = ")\n"
    _uart_puts(cp2)

    sm: Ptr[char] = "[arm64] Phase 34 summary: tx_done="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p34_tx_done))
    sm2: Ptr[char] = " echo_reply_ok="
    _uart_puts(sm2)
    _uart_puthex(cast[uint64](arm64_p34_echo_reply_ok))
    _uart_puts(nl)

    ok: int64 = 1
    if arm64_p34_tx_done == 0:
        ok = 0
    if arm64_p34_echo_reply_ok == 0:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 34: hand-rolled an IPv4 header + ICMP Echo Request (real IPv4 + ICMP checksums), sent it through the virtio-net TX ring to the SLIRP gateway, and validated the checksum-correct Echo Reply (matching id/seq) off the RX ring\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 34 PASS: IPv4/ICMP echo round-trip (ping 10.0.2.2) over native virtio-net\n"
        _uart_puts(pp)
        # Hand off to Phase 35 (writable virtio-blk + a real FAT16 FS write). The
        # net device used here is irrelevant to P35: it re-finds + re-brings-up the
        # SAME virtio-blk transport (idempotent) and reuses the P31 FAT16 helpers.
        arm64_p35_run()
    else:
        fp4: Ptr[char] = "[arm64] Phase 34 FAIL: echo round-trip verdict failed\n"
        _uart_puts(fp4)
    return 0


# ===========================================================================
# PHASE 35 — make the virtio-mmio block path WRITABLE and prove a real
# round-trip filesystem WRITE on qemu-virt.
#
# Phases 30/31 proved the polled virtio-mmio block transport can READ raw
# sectors and parse a FAT16 volume. Phase 35 adds the WRITE direction
# (VIRTIO_BLK_T_OUT over the same request virtqueue) and proves durability two
# ways:
#   1. RAW round-trip: write a known pattern to a high scratch sector (clear of
#      FS metadata), read it back, confirm the bytes match.
#   2. FS-level round-trip: rewrite HELLO.TXT's data cluster with NEW bytes and
#      update its directory-entry size on disk, then re-locate the file and
#      re-read it through the normal FAT16 chain READ path — proving the new
#      bytes come back through the real filesystem read.
# All buffers live in fresh Normal-WB RAM (P35_*); the transport + FAT helpers
# are reused. arm64_p35_run never returns (it halts after the verdict).
# ===========================================================================

# The new HELLO.TXT content this phase writes through the filesystem. Same
# length as the original ("HAMNIX-ARM64-FS-OK", 18 bytes) so it fits the single
# planted data cluster without growing the FAT chain — the proof is a content
# change that survives a real FAT-chain read.
P35_NEW0: uint8 = 0x41                        # 'A'
P35_NEW1: uint8 = 0x52                        # 'R'
P35_NEW2: uint8 = 0x4D                        # 'M'
P35_NEW3: uint8 = 0x36                        # '6'
P35_NEW4: uint8 = 0x34                        # '4'
P35_NEW5: uint8 = 0x2D                        # '-'
P35_NEW6: uint8 = 0x57                        # 'W'
P35_NEW7: uint8 = 0x52                        # 'R'
P35_NEW8: uint8 = 0x49                        # 'I'
P35_NEW9: uint8 = 0x54                        # 'T'
P35_NEW10: uint8 = 0x45                       # 'E'
P35_NEW11: uint8 = 0x2D                       # '-'
P35_NEW12: uint8 = 0x4F                       # 'O'
P35_NEW13: uint8 = 0x4B                       # 'K'
P35_NEW14: uint8 = 0x2D                       # '-'
P35_NEW15: uint8 = 0x41                       # 'A'
P35_NEW16: uint8 = 0x36                       # '6'
P35_NEW17: uint8 = 0x34                       # '4'
P35_NEW_LEN: int64 = 18

arm64_p35_active: int64 = 0


# Fetch the j-th expected new-payload byte (helper avoids a big inline table).
def arm64_p35_new_byte(j: int64) -> uint8:
    if j == 0:
        return P35_NEW0
    if j == 1:
        return P35_NEW1
    if j == 2:
        return P35_NEW2
    if j == 3:
        return P35_NEW3
    if j == 4:
        return P35_NEW4
    if j == 5:
        return P35_NEW5
    if j == 6:
        return P35_NEW6
    if j == 7:
        return P35_NEW7
    if j == 8:
        return P35_NEW8
    if j == 9:
        return P35_NEW9
    if j == 10:
        return P35_NEW10
    if j == 11:
        return P35_NEW11
    if j == 12:
        return P35_NEW12
    if j == 13:
        return P35_NEW13
    if j == 14:
        return P35_NEW14
    if j == 15:
        return P35_NEW15
    if j == 16:
        return P35_NEW16
    return P35_NEW17


# Phase 35 entry point (hand-off from arm64_p34_run on a Phase-34 PASS). Never
# returns: halts after printing the verdict.
def arm64_p35_run() -> int64:
    arm64_p35_active = 1
    intro: Ptr[char] = "[arm64] Phase 35: writable virtio-blk + real FAT16 filesystem write\n"
    _uart_puts(intro)
    nl: Ptr[char] = "\n"

    # --- 0. (re)acquire the virtio-blk transport ---------------------------
    base: uint64 = arm64_p30_find_blk()
    if base == cast[uint64](0):
        fp: Ptr[char] = "[arm64] Phase 35 FAIL: no virtio-blk transport found\n"
        _uart_puts(fp)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    if arm64_p30_setup(base) != 1:
        fp2: Ptr[char] = "[arm64] Phase 35 FAIL: block device bring-up failed\n"
        _uart_puts(fp2)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    # --- 1. RAW write -> read-back round-trip on a scratch sector ----------
    # Fill the write buffer with a known, position-dependent pattern.
    wp: Ptr[uint8] = cast[Ptr[uint8]](P35_WBUF_PA)
    i: int64 = 0
    while i < SECTOR_SIZE:
        wp[i] = cast[uint8]((i * 7 + 0x5A) & 0xFF)
        i = i + 1
    _dsb_ish()

    if arm64_p30_write_sector_from(base, P35_SCRATCH_LBA, P35_WBUF_PA) != 1:
        fp3: Ptr[char] = "[arm64] Phase 35 FAIL: scratch-sector write did not complete OK\n"
        _uart_puts(fp3)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    if arm64_p30_read_sector_into(base, P35_SCRATCH_LBA, P35_RBUF_PA) != 1:
        fp4: Ptr[char] = "[arm64] Phase 35 FAIL: scratch-sector read-back did not complete\n"
        _uart_puts(fp4)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    rp: Ptr[uint8] = cast[Ptr[uint8]](P35_RBUF_PA)
    raw_ok: int64 = 1
    i = 0
    while i < SECTOR_SIZE:
        if rp[i] != cast[uint8]((i * 7 + 0x5A) & 0xFF):
            raw_ok = 0
        i = i + 1
    if raw_ok == 0:
        fp5: Ptr[char] = "[arm64] Phase 35 FAIL: scratch read-back bytes did not match the written pattern\n"
        _uart_puts(fp5)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    rm: Ptr[char] = "[arm64] Phase 35: raw write->read-back of scratch sector "
    _uart_puts(rm)
    _uart_puthex(P35_SCRATCH_LBA)
    rm2: Ptr[char] = " verified (512 bytes match)\n"
    _uart_puts(rm2)

    # --- 2. re-parse the FAT16 BPB off sector 0 ----------------------------
    if arm64_p30_read_sector_into(base, cast[uint64](0), P31_SEC_PA) != 1:
        fp6: Ptr[char] = "[arm64] Phase 35 FAIL: boot-sector read for FS write failed\n"
        _uart_puts(fp6)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    if arm64_p31_parse_bpb() != 1:
        fp7: Ptr[char] = "[arm64] Phase 35 FAIL: BPB geometry not a supported FAT16\n"
        _uart_puts(fp7)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    # --- 3. locate HELLO.TXT's directory entry (sector LBA + offset) -------
    dir_lba: int64 = -1
    ent_off: int64 = -1
    first_clus: int64 = -1
    s: int64 = 0
    while s < arm64_p31_root_secs:
        lba: int64 = arm64_p31_root_lba + s
        if arm64_p30_read_sector_into(base, cast[uint64](lba), P31_SEC_PA) != 1:
            fp8: Ptr[char] = "[arm64] Phase 35 FAIL: root-dir sector read failed\n"
            _uart_puts(fp8)
            _msr_daifset(2)
            while True:
                _wfi()
            return 0
        e: int64 = 0
        while e < arm64_p31_bytes_per_sec:
            pp: Ptr[uint8] = cast[Ptr[uint8]](P31_SEC_PA)
            first_byte: uint8 = pp[e]
            if cast[uint64](first_byte) == cast[uint64](0):
                s = arm64_p31_root_secs
                e = arm64_p31_bytes_per_sec
            else:
                if arm64_p31_name_matches(P31_SEC_PA, e) == 1:
                    dir_lba = lba
                    ent_off = e
                    first_clus = arm64_p31_rd16(P31_SEC_PA, e + 26)
                    s = arm64_p31_root_secs
                    e = arm64_p31_bytes_per_sec
                else:
                    e = e + 32
        s = s + 1

    if first_clus < 2:
        fp9: Ptr[char] = "[arm64] Phase 35 FAIL: HELLO.TXT not found for FS write\n"
        _uart_puts(fp9)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    fm: Ptr[char] = "[arm64] Phase 35: HELLO.TXT dir_lba="
    _uart_puts(fm)
    _uart_puthex(cast[uint64](dir_lba))
    fm2: Ptr[char] = " ent_off="
    _uart_puts(fm2)
    _uart_puthex(cast[uint64](ent_off))
    fm3: Ptr[char] = " first_clus="
    _uart_puts(fm3)
    _uart_puthex(cast[uint64](first_clus))
    _uart_puts(nl)

    # --- 4. rewrite the file's data cluster with the NEW payload -----------
    # The payload (18 bytes) fits within the single data cluster, so we read the
    # cluster's first sector, overwrite the leading bytes, and write it back.
    clus_lba: int64 = arm64_p31_data_lba + ((first_clus - 2) * arm64_p31_sec_per_clus)
    if arm64_p30_read_sector_into(base, cast[uint64](clus_lba), P35_WBUF_PA) != 1:
        fp10: Ptr[char] = "[arm64] Phase 35 FAIL: data-cluster read-modify-write read failed\n"
        _uart_puts(fp10)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    dwp: Ptr[uint8] = cast[Ptr[uint8]](P35_WBUF_PA)
    j: int64 = 0
    while j < P35_NEW_LEN:
        dwp[j] = arm64_p35_new_byte(j)
        j = j + 1
    _dsb_ish()
    if arm64_p30_write_sector_from(base, cast[uint64](clus_lba), P35_WBUF_PA) != 1:
        fp11: Ptr[char] = "[arm64] Phase 35 FAIL: data-cluster write did not complete OK\n"
        _uart_puts(fp11)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    # --- 5. update the directory entry's size field (offset +28, u32) ------
    # Re-read the dir sector, set the 4-byte size to the new length, write back.
    if arm64_p30_read_sector_into(base, cast[uint64](dir_lba), P35_WBUF_PA) != 1:
        fp12: Ptr[char] = "[arm64] Phase 35 FAIL: dir-entry read-modify-write read failed\n"
        _uart_puts(fp12)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    szp: Ptr[uint8] = cast[Ptr[uint8]](P35_WBUF_PA + cast[uint64](ent_off + 28))
    szp[0] = cast[uint8](P35_NEW_LEN & 0xFF)
    szp[1] = cast[uint8]((P35_NEW_LEN >> 8) & 0xFF)
    szp[2] = cast[uint8]((P35_NEW_LEN >> 16) & 0xFF)
    szp[3] = cast[uint8]((P35_NEW_LEN >> 24) & 0xFF)
    _dsb_ish()
    if arm64_p30_write_sector_from(base, cast[uint64](dir_lba), P35_WBUF_PA) != 1:
        fp13: Ptr[char] = "[arm64] Phase 35 FAIL: dir-entry size write did not complete OK\n"
        _uart_puts(fp13)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    wmsg: Ptr[char] = "[arm64] Phase 35: rewrote HELLO.TXT data cluster + dir size via virtio-blk WRITE\n"
    _uart_puts(wmsg)

    # --- 6. re-read HELLO.TXT through the normal FAT16 read path -----------
    # Re-locate the file fresh (proving the on-disk dir entry is consistent) and
    # follow its FAT chain, assembling the bytes into P31_FILE_PA.
    rd_clus: int64 = -1
    rd_size: int64 = 0
    s = 0
    while s < arm64_p31_root_secs:
        lba2: int64 = arm64_p31_root_lba + s
        if arm64_p30_read_sector_into(base, cast[uint64](lba2), P31_SEC_PA) != 1:
            fp14: Ptr[char] = "[arm64] Phase 35 FAIL: re-read root-dir sector failed\n"
            _uart_puts(fp14)
            _msr_daifset(2)
            while True:
                _wfi()
            return 0
        e2: int64 = 0
        while e2 < arm64_p31_bytes_per_sec:
            pp2: Ptr[uint8] = cast[Ptr[uint8]](P31_SEC_PA)
            fb2: uint8 = pp2[e2]
            if cast[uint64](fb2) == cast[uint64](0):
                s = arm64_p31_root_secs
                e2 = arm64_p31_bytes_per_sec
            else:
                if arm64_p31_name_matches(P31_SEC_PA, e2) == 1:
                    rd_clus = arm64_p31_rd16(P31_SEC_PA, e2 + 26)
                    rd_size = arm64_p31_rd32(P31_SEC_PA, e2 + 28)
                    s = arm64_p31_root_secs
                    e2 = arm64_p31_bytes_per_sec
                else:
                    e2 = e2 + 32
        s = s + 1

    if rd_clus < 2:
        fp15: Ptr[char] = "[arm64] Phase 35 FAIL: HELLO.TXT not found on FAT re-read\n"
        _uart_puts(fp15)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    spc: int64 = arm64_p31_sec_per_clus
    dst_off: int64 = 0
    clus: int64 = rd_clus
    remaining: int64 = rd_size
    guard: int64 = 0
    while remaining > 0:
        if clus < 2:
            remaining = 0
        else:
            if clus >= 0xFFF8:
                remaining = 0
            else:
                if guard > 4096:
                    remaining = 0
                else:
                    guard = guard + 1
                    cl: int64 = arm64_p31_data_lba + ((clus - 2) * spc)
                    sc: int64 = 0
                    while sc < spc:
                        if remaining <= 0:
                            sc = spc
                        else:
                            if arm64_p30_read_sector_into(base, cast[uint64](cl + sc), P31_SEC_PA) != 1:
                                fp16: Ptr[char] = "[arm64] Phase 35 FAIL: FAT-chain data read failed\n"
                                _uart_puts(fp16)
                                _msr_daifset(2)
                                while True:
                                    _wfi()
                                return 0
                            take: int64 = arm64_p31_bytes_per_sec
                            if remaining < take:
                                take = remaining
                            dst_off = arm64_p31_copy_bytes(P31_SEC_PA, 0, dst_off, take)
                            remaining = remaining - take
                            sc = sc + 1
                    nxt: int64 = arm64_p31_fat_next(base, clus)
                    if nxt < 0:
                        fp17: Ptr[char] = "[arm64] Phase 35 FAIL: FAT-chain link read failed\n"
                        _uart_puts(fp17)
                        _msr_daifset(2)
                        while True:
                            _wfi()
                        return 0
                    clus = nxt

    # --- 7. verify the re-read bytes equal the NEW payload -----------------
    fbuf: Ptr[uint8] = cast[Ptr[uint8]](P31_FILE_PA)
    fs_ok: int64 = 1
    if rd_size != P35_NEW_LEN:
        fs_ok = 0
    if dst_off != P35_NEW_LEN:
        fs_ok = 0
    if fs_ok != 0:
        k: int64 = 0
        while k < P35_NEW_LEN:
            if fbuf[k] != arm64_p35_new_byte(k):
                fs_ok = 0
            k = k + 1

    sm: Ptr[char] = "[arm64] Phase 35 summary: raw_ok=1 fs_read_len="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](dst_off))
    sm2: Ptr[char] = " new_len="
    _uart_puts(sm2)
    _uart_puthex(cast[uint64](P35_NEW_LEN))
    _uart_puts(nl)

    if fs_ok != 0:
        rpd: Ptr[char] = "[arm64] Phase 35: wrote a scratch sector and read it back byte-for-byte, then rewrote HELLO.TXT's data cluster + dir-entry size over the virtio-blk WRITE path and read the new content back through the real FAT16 chain (ARM64-WRITE-OK-A64)\n"
        _uart_puts(rpd)
        pp: Ptr[char] = "[arm64] Phase 35 PASS: virtio-blk WRITE + FAT16 filesystem write round-trip -> ARM64-WRITE-OK-A64\n"
        _uart_puts(pp)
        # Hand off to Phase 36 (on-disk multi-process userland scenario): load
        # INITA.ELF + run it at EL0; it does a real open/write/read/close file
        # round-trip on the FAT16 disk, spawns CHILDB.ELF (a second EL0 process)
        # which writes a marker file, then reaps the child's exit status and
        # confirms the marker — proving the EL0 syscall surface is rich enough to
        # run actual cooperating programs. arm64_p36_run never returns.
        arm64_p36_run(base)
        # Unreachable: arm64_p36_run halts after its verdict.
    else:
        fp18: Ptr[char] = "[arm64] Phase 35 FAIL: FAT16 re-read content did not match the written payload\n"
        _uart_puts(fp18)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# ===========================================================================
# PHASE 36 — a real multi-process, filesystem-using userland scenario.
#
# Phase 36 composes everything the prior phases built — the P32 on-disk-ELF
# loader, the P31 FAT16 READ path, the P35 FAT16 WRITE path, and a fresh EL0
# address space per program — into an actual cooperating two-program workload,
# proving the EL0 syscall surface is rich enough to support real programs.
#
# Program A (INITA.ELF, loaded off the FAT16 disk, run at EL0):
#   1. open("WORK.TXT"), write 16 bytes, close   -> durable FAT16 WRITE
#   2. open("WORK.TXT"), read it back, verify     -> FAT16 READ round-trip
#      (proves the EL0 open/write/close/read path reaches the real filesystem)
#   3. spawn("CHILDB.ELF")  -> the kernel synchronously loads + runs a SECOND
#      EL0 program (Program B) in its OWN private ASID-tagged address space.
#      Program B opens "MARK.TXT", writes a marker byte sequence, and exits with
#      a known status. spawn() returns B's exit status to A (the reap).
#   4. A opens "MARK.TXT", reads it, and confirms B actually ran (the marker is
#      present) AND that the reaped exit status matches      -> ORDERING proof.
#   5. A exit()s with its own status; the kernel runs the verdict.
#
# EL0 syscalls added/wired for Phase 36 (real, FS-backed, no faked results):
#   SYS_P36_OPEN  (700): a0 = name-id (0=WORK.TXT,1=MARK.TXT,2=CHILDB.ELF)
#                         -> fd >= 0, or -1.  Loads the file's bytes into the
#                            open-file's RAM buffer (or marks "new/empty").
#   SYS_P36_WRITE (701): a0=fd a1=buf a2=len. fd 1 = UART; else append into the
#                            open file's RAM buffer (flushed to disk on close).
#   SYS_P36_READ  (702): a0=fd a1=buf a2=len -> bytes read from the file buffer.
#   SYS_P36_CLOSE (703): a0=fd. Flushes the (possibly grown) buffer to the file's
#                            FAT16 data cluster + updates its dir-entry size.
#   SYS_P36_SPAWN (704): a0 = prog-id (only CHILDB supported) -> child exit status.
#                            Saves the caller's full EL0 resume context, loads the
#                            child ELF into its OWN EL0 space, ERETs into it; the
#                            child's exit() restores the parent verbatim with x0
#                            = child status (the synchronous reap).
#   SYS_P36_EXIT  (705): a0 = status. Child -> resume parent past its spawn svc.
#                            Parent -> run the Phase-36 verdict + halt.
#
# Everything stays inside kmain.ad. The two on-disk ELFs (INITA.ELF, CHILDB.ELF)
# are planted on the FAT16 disk by scripts/test_arm64_phase36.sh. Deterministic,
# abort-driven (EL1 IRQs masked), segment page-ins via arm64_p36_try_fault.
# ===========================================================================

# --- Phase-36 fresh RAM region (clear of P32 0x4520_xxxx + P35 0x4530_xxxx) ---
P36_FILE_PA: uint64 = 0x45400000             # raw on-disk ELF bytes (A or B)
P36_FILE_CAP: int64 = 8192                   # max ELF file bytes we read

# Program A (INITA.ELF) private EL0 space. Reuses the P32 segment VAs (valid EL0
# VAs) but with distinct PA backing + page tables + ASID.
P36A_TEXT_VA: uint64 = 0x42600000
P36A_DATA_VA: uint64 = 0x42800000
P36A_STACK_VA: uint64 = 0x42A00000
P36A_TEXT_L2_INDEX: uint64 = 19              # (0x4260_0000 - 0x4000_0000) / 2 MiB
P36A_DATA_L2_INDEX: uint64 = 20
P36A_STACK_L2_INDEX: uint64 = 21
P36A_L1: uint64 = 0x45410000
P36A_L2: uint64 = 0x45411000
P36A_TEXT_L3: uint64 = 0x45412000
P36A_DATA_L3: uint64 = 0x45413000
P36A_STACK_L3: uint64 = 0x45414000
P36A_TEXT_PA: uint64 = 0x45420000
P36A_DATA_PA: uint64 = 0x45430000
P36A_STACK_PA: uint64 = 0x45440000
P36A_STACK_TOP: uint64 = 0x42A01000
P36A_ASID: uint64 = 24                       # distinct from every prior ASID

# Program B (CHILDB.ELF) private EL0 space. DISTINCT segment VAs (a different
# 2 MiB window) so the demand-fault handler attributes faults unambiguously.
P36B_TEXT_VA: uint64 = 0x42C00000
P36B_DATA_VA: uint64 = 0x42E00000
P36B_STACK_VA: uint64 = 0x43000000
P36B_TEXT_L2_INDEX: uint64 = 22              # (0x42C0_0000 - 0x4000_0000) / 2 MiB
P36B_DATA_L2_INDEX: uint64 = 23
P36B_STACK_L2_INDEX: uint64 = 24
P36B_L1: uint64 = 0x45450000
P36B_L2: uint64 = 0x45451000
P36B_TEXT_L3: uint64 = 0x45452000
P36B_DATA_L3: uint64 = 0x45453000
P36B_STACK_L3: uint64 = 0x45454000
P36B_TEXT_PA: uint64 = 0x45460000
P36B_DATA_PA: uint64 = 0x45470000
P36B_STACK_PA: uint64 = 0x45480000
P36B_STACK_TOP: uint64 = 0x43001000
P36B_ASID: uint64 = 25

# Per-open-file RAM data buffers (one each for the two files the demo touches).
P36_WORK_BUF_PA: uint64 = 0x45490000         # WORK.TXT data buffer
P36_MARK_BUF_PA: uint64 = 0x454A0000         # MARK.TXT data buffer
P36_FILE_BUF_CAP: int64 = 512                # one cluster fits the demo payloads

# W^X page permissions (identical encoding to Phase 32).
P36_PAGE_RX: uint64 = 0x7C7
P36_PAGE_RW: uint64 = 0x40000000000747
P36_PAGE_RO: uint64 = 0x400000000007C7

# Phase-36 EL0 syscall numbers (clear of every prior phase's private nrs).
SYS_P36_OPEN: uint64 = 700
SYS_P36_WRITE: uint64 = 701
SYS_P36_READ: uint64 = 702
SYS_P36_CLOSE: uint64 = 703
SYS_P36_SPAWN: uint64 = 704
SYS_P36_EXIT: uint64 = 705
SYS_P36_REPORT: uint64 = 706                  # a0=check-id a1=buf a2=len/value

# name-ids handed to open() (x0).
P36_NID_WORK: uint64 = 0                      # WORK.TXT
P36_NID_MARK: uint64 = 1                      # MARK.TXT

# prog-id handed to spawn() (x0).
P36_PROG_CHILDB: uint64 = 0

# Expected exit statuses (the test asserts these are observed).
P36_CHILD_EXIT: uint64 = 0x2A                # 42 — Program B's exit status
P36_PARENT_EXIT: uint64 = 0x5B               # 91 — Program A's exit status

# Known payloads the two programs write (the kernel verifies the FS round-trip
# AND the cross-process marker against these). INITA's WORK.TXT payload is a
# fixed 16-byte pattern; CHILDB's MARK.TXT marker is a fixed 12-byte sequence.
# (The kernel computes the byte at index i so no big inline table is needed.)
P36_WORK_LEN: int64 = 16                      # INITA's WORK.TXT payload length
P36_MARK_LEN: int64 = 12                      # CHILDB's MARK.TXT marker length

# check-ids for SYS_P36_REPORT (x0).
P36_CHK_WORK: uint64 = 0                       # A reports WORK.TXT read-back bytes
P36_CHK_MARK: uint64 = 1                       # A reports MARK.TXT (B's) marker bytes
P36_CHK_STATUS: uint64 = 2                     # A reports the reaped spawn() status


# The expected i-th byte of INITA's WORK.TXT payload: 'A','B',... position-coded.
def arm64_p36_work_byte(i: int64) -> uint8:
    return cast[uint8]((0x41 + (i * 3)) & 0x7F)


# The expected i-th byte of CHILDB's MARK.TXT marker: 'M','m',... position-coded.
def arm64_p36_mark_byte(i: int64) -> uint8:
    return cast[uint8]((0x4D + (i * 5)) & 0x7F)

# --- Phase-36 bookkeeping --------------------------------------------------
arm64_p36_active: int64 = 0
arm64_p36_cur_prog: int64 = 0                # 0 = A (parent), 1 = B (child)
arm64_p36_a_text_faults: int64 = 0
arm64_p36_a_data_faults: int64 = 0
arm64_p36_b_text_faults: int64 = 0
arm64_p36_b_data_faults: int64 = 0
arm64_p36_blk_base: uint64 = 0              # the live virtio-blk transport base

# Workflow evidence (read by the verdict).
arm64_p36_a_file_rt_ok: int64 = 0           # A's WORK.TXT write->read round-trip OK
arm64_p36_b_ran: int64 = 0                  # Program B actually executed (entered EL0)
arm64_p36_b_wrote_mark: int64 = 0           # B's MARK.TXT close flushed to disk
arm64_p36_child_status: uint64 = 0xFFFF     # the reaped child exit status (spawn ret)
arm64_p36_a_saw_mark: int64 = 0             # A re-read MARK.TXT and confirmed B's marker
arm64_p36_a_saw_status: uint64 = 0xFFFF     # the status value A observed from spawn
arm64_p36_a_exited: int64 = 0
arm64_p36_a_exit_code: uint64 = 0xFFFF

# Saved parent (Program A) EL0 resume context across a spawn (synchronous reap).
P36_PCTX: uint64 = 0x454B0000               # 34 x 8-byte slots (x0..x30,SP,ELR,SPSR)

# Open-file table: ONE live slot is enough for the demo (files are opened, used,
# and closed strictly one at a time). Records the located dir entry + which RAM
# buffer holds the file's bytes + the live byte length.
arm64_p36_of_used: int64 = 0                 # 1 if a file is currently open
arm64_p36_of_nid: uint64 = 0xFFFF            # name-id of the open file
arm64_p36_of_dir_lba: int64 = -1
arm64_p36_of_ent_off: int64 = -1
arm64_p36_of_first_clus: int64 = -1
arm64_p36_of_len: int64 = 0                  # current logical length (bytes)
arm64_p36_of_buf: uint64 = 0                 # PA of the file's RAM data buffer
arm64_p36_of_rpos: int64 = 0                 # read cursor (bytes consumed by read())


# ---- the 8.3 directory names this phase touches (space-padded to 11) ------
# Fill an 11-byte name buffer at `dst` with the 8.3 name selected by `nid`.
def arm64_p36_fill_name(dst: uint64, nid: uint64) -> int64:
    p: Ptr[uint8] = cast[Ptr[uint8]](dst)
    i: int64 = 0
    while i < 11:
        p[i] = cast[uint8](0x20)             # space-pad
        i = i + 1
    if nid == P36_NID_WORK:
        # "WORK    TXT"
        p[0] = cast[uint8](0x57)             # W
        p[1] = cast[uint8](0x4F)             # O
        p[2] = cast[uint8](0x52)             # R
        p[3] = cast[uint8](0x4B)             # K
        p[8] = cast[uint8](0x54)             # T
        p[9] = cast[uint8](0x58)             # X
        p[10] = cast[uint8](0x54)            # T
    else:
        # "MARK    TXT"
        p[0] = cast[uint8](0x4D)             # M
        p[1] = cast[uint8](0x41)             # A
        p[2] = cast[uint8](0x52)             # R
        p[3] = cast[uint8](0x4B)             # K
        p[8] = cast[uint8](0x54)             # T
        p[9] = cast[uint8](0x58)             # X
        p[10] = cast[uint8](0x54)            # T
    return 0


# The 8.3 name of the spawnable child program: "CHILDB  ELF".
P36_CHILDB0: uint8 = 0x43                     # C
P36_CHILDB1: uint8 = 0x48                     # H
P36_CHILDB2: uint8 = 0x49                     # I
P36_CHILDB3: uint8 = 0x4C                     # L
P36_CHILDB4: uint8 = 0x44                     # D
P36_CHILDB5: uint8 = 0x42                     # B
P36_CHILDB6: uint8 = 0x20                     # ' '
P36_CHILDB7: uint8 = 0x20                     # ' '
P36_CHILDB8: uint8 = 0x45                     # E
P36_CHILDB9: uint8 = 0x4C                     # L
P36_CHILDB10: uint8 = 0x46                    # F

# "INITA   ELF" — Program A's on-disk ELF name.
P36_INITA0: uint8 = 0x49                      # I
P36_INITA1: uint8 = 0x4E                      # N
P36_INITA2: uint8 = 0x49                      # I
P36_INITA3: uint8 = 0x54                      # T
P36_INITA4: uint8 = 0x41                      # A
P36_INITA5: uint8 = 0x20                      # ' '
P36_INITA6: uint8 = 0x20                      # ' '
P36_INITA7: uint8 = 0x20                      # ' '
P36_INITA8: uint8 = 0x45                      # E
P36_INITA9: uint8 = 0x4C                      # L
P36_INITA10: uint8 = 0x46                     # F


# Compare the 11-byte dir-entry name at `pa`+`off` against an 11-byte name buffer
# at `name_pa`. Returns 1 on a full match, else 0.
def arm64_p36_name_eq(pa: uint64, off: int64, name_pa: uint64) -> int64:
    p: Ptr[uint8] = cast[Ptr[uint8]](pa)
    q: Ptr[uint8] = cast[Ptr[uint8]](name_pa)
    i: int64 = 0
    while i < 11:
        if p[off + i] != q[i]:
            return 0
        i = i + 1
    return 1


# Locate the 8.3 file named by the 11-byte buffer at `name_pa` in the root dir.
# On success records dir_lba/ent_off/first_clus/size into the four out-globals
# (arm64_p36_loc_*) and returns 1; returns 0 if not found, -1 on a read error.
arm64_p36_loc_dir_lba: int64 = -1
arm64_p36_loc_ent_off: int64 = -1
arm64_p36_loc_first_clus: int64 = -1
arm64_p36_loc_size: int64 = 0

def arm64_p36_locate(base: uint64, name_pa: uint64) -> int64:
    arm64_p36_loc_dir_lba = -1
    arm64_p36_loc_ent_off = -1
    arm64_p36_loc_first_clus = -1
    arm64_p36_loc_size = 0
    s: int64 = 0
    while s < arm64_p31_root_secs:
        lba: int64 = arm64_p31_root_lba + s
        if arm64_p30_read_sector_into(base, cast[uint64](lba), P31_SEC_PA) != 1:
            return -1
        e: int64 = 0
        while e < arm64_p31_bytes_per_sec:
            pp: Ptr[uint8] = cast[Ptr[uint8]](P31_SEC_PA)
            first_byte: uint8 = pp[e]
            if cast[uint64](first_byte) == cast[uint64](0):
                s = arm64_p31_root_secs            # 0x00 = end of directory
                e = arm64_p31_bytes_per_sec
            else:
                if arm64_p36_name_eq(P31_SEC_PA, e, name_pa) == 1:
                    arm64_p36_loc_dir_lba = lba
                    arm64_p36_loc_ent_off = e
                    arm64_p36_loc_first_clus = arm64_p31_rd16(P31_SEC_PA, e + 26)
                    arm64_p36_loc_size = arm64_p31_rd32(P31_SEC_PA, e + 28)
                    s = arm64_p31_root_secs
                    e = arm64_p31_bytes_per_sec
                else:
                    e = e + 32
        s = s + 1
    if arm64_p36_loc_dir_lba < 0:
        return 0
    return 1


# Read the file's data cluster (its first sector — payloads fit one cluster) into
# `dst_pa` and return its size. Caller has already located the entry.
def arm64_p36_read_file_into(base: uint64, first_clus: int64, size: int64, dst_pa: uint64) -> int64:
    d: Ptr[uint8] = cast[Ptr[uint8]](dst_pa)
    z: int64 = 0
    while z < P36_FILE_BUF_CAP:
        d[z] = cast[uint8](0)
        z = z + 1
    if first_clus < 2:
        return 0
    clus_lba: int64 = arm64_p31_data_lba + ((first_clus - 2) * arm64_p31_sec_per_clus)
    if arm64_p30_read_sector_into(base, cast[uint64](clus_lba), P31_SEC_PA) != 1:
        return -1
    src: Ptr[uint8] = cast[Ptr[uint8]](P31_SEC_PA)
    take: int64 = size
    if take > P36_FILE_BUF_CAP:
        take = P36_FILE_BUF_CAP
    i: int64 = 0
    while i < take:
        d[i] = src[i]
        i = i + 1
    return take


# Flush the open file's buffer to its FAT16 data cluster (first sector) and update
# its directory-entry size on disk — the real P35-style WRITE path. Returns 1 OK.
def arm64_p36_flush_file(base: uint64) -> int64:
    if arm64_p36_of_first_clus < 2:
        return 0
    # 1. write the data cluster's first sector from the file buffer.
    clus_lba: int64 = arm64_p31_data_lba + ((arm64_p36_of_first_clus - 2) * arm64_p31_sec_per_clus)
    # Stage the (zero-padded) buffer into the shared write buffer.
    w: Ptr[uint8] = cast[Ptr[uint8]](P35_WBUF_PA)
    src: Ptr[uint8] = cast[Ptr[uint8]](arm64_p36_of_buf)
    i: int64 = 0
    while i < arm64_p31_bytes_per_sec:
        if i < arm64_p36_of_len:
            w[i] = src[i]
        else:
            w[i] = cast[uint8](0)
        i = i + 1
    _dsb_ish()
    if arm64_p30_write_sector_from(base, cast[uint64](clus_lba), P35_WBUF_PA) != 1:
        return 0
    # 2. update the dir-entry size field (offset +28, u32).
    if arm64_p30_read_sector_into(base, cast[uint64](arm64_p36_of_dir_lba), P35_WBUF_PA) != 1:
        return 0
    szp: Ptr[uint8] = cast[Ptr[uint8]](P35_WBUF_PA + cast[uint64](arm64_p36_of_ent_off + 28))
    szp[0] = cast[uint8](arm64_p36_of_len & 0xFF)
    szp[1] = cast[uint8]((arm64_p36_of_len >> 8) & 0xFF)
    szp[2] = cast[uint8]((arm64_p36_of_len >> 16) & 0xFF)
    szp[3] = cast[uint8]((arm64_p36_of_len >> 24) & 0xFF)
    _dsb_ish()
    if arm64_p30_write_sector_from(base, cast[uint64](arm64_p36_of_dir_lba), P35_WBUF_PA) != 1:
        return 0
    return 1


# ---- the on-disk ELF loader, parameterized per program (A or B) -----------
# Little-endian readers out of the Phase-36 ELF file buffer (P36_FILE_PA).
def _p36_rd16(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P36_FILE_PA)
    b0: uint64 = cast[uint64](p[cast[int64](off)])
    b1: uint64 = cast[uint64](p[cast[int64](off + cast[uint64](1))])
    return b0 | (b1 << cast[uint64](8))


def _p36_rd32(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P36_FILE_PA)
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 4:
        r = r | (cast[uint64](p[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


def _p36_rd64(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P36_FILE_PA)
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 8:
        r = r | (cast[uint64](p[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


# Read the on-disk ELF named by the 11-byte name at `name_pa` off the live FAT16
# volume into P36_FILE_PA (following its cluster chain). Returns byte length, or
# -1 on not-found / read error.
def arm64_p36_read_elf(base: uint64, name_pa: uint64) -> int64:
    loc: int64 = arm64_p36_locate(base, name_pa)
    if loc != 1:
        return -1
    first_clus: int64 = arm64_p36_loc_first_clus
    file_size: int64 = arm64_p36_loc_size
    if first_clus < 2:
        return -1
    sec_per_clus: int64 = arm64_p31_sec_per_clus
    dst_off: int64 = 0
    want_len: int64 = file_size
    clus: int64 = first_clus
    guard: int64 = 0
    dst: Ptr[uint8] = cast[Ptr[uint8]](P36_FILE_PA)
    src: Ptr[uint8] = cast[Ptr[uint8]](P31_SEC_PA)
    while clus >= 2 and clus < 0xFFF8 and dst_off < want_len:
        guard = guard + 1
        if guard > 4096:
            return -1
        clus_lba: int64 = arm64_p31_data_lba + ((clus - 2) * sec_per_clus)
        sc: int64 = 0
        while sc < sec_per_clus:
            if dst_off < want_len:
                if arm64_p30_read_sector_into(base, cast[uint64](clus_lba + sc), P31_SEC_PA) != 1:
                    return -1
                take: int64 = arm64_p31_bytes_per_sec
                if dst_off + take > want_len:
                    take = want_len - dst_off
                i: int64 = 0
                while i < take:
                    if dst_off < P36_FILE_CAP:
                        dst[dst_off] = src[i]
                        dst_off = dst_off + 1
                    else:
                        i = take
                    i = i + 1
            sc = sc + 1
        nxt: int64 = arm64_p31_fat_next(base, clus)
        if nxt < 0:
            return -1
        clus = nxt
    return dst_off


# Derive the L3 PAGE flags for a parsed ELF segment (W^X).
def arm64_p36_flags_for(pflags: uint64) -> uint64:
    if (pflags & PF_W) != cast[uint64](0):
        return P36_PAGE_RW
    if (pflags & PF_X) != cast[uint64](0):
        return P36_PAGE_RX
    return P36_PAGE_RO


# Build program `prog` (0=A,1=B)'s fresh private EL0 address space (L1/L2 + three
# 2 MiB slots redirected to private L3 tables) and wire its EL0 stack page RW.
def arm64_p36_build_space(prog: int64) -> int64:
    l1_base: uint64 = P36A_L1
    l2_base: uint64 = P36A_L2
    text_l3: uint64 = P36A_TEXT_L3
    data_l3: uint64 = P36A_DATA_L3
    stack_l3: uint64 = P36A_STACK_L3
    text_l2i: uint64 = P36A_TEXT_L2_INDEX
    data_l2i: uint64 = P36A_DATA_L2_INDEX
    stack_l2i: uint64 = P36A_STACK_L2_INDEX
    stack_va: uint64 = P36A_STACK_VA
    stack_pa: uint64 = P36A_STACK_PA
    if prog == 1:
        l1_base = P36B_L1
        l2_base = P36B_L2
        text_l3 = P36B_TEXT_L3
        data_l3 = P36B_DATA_L3
        stack_l3 = P36B_STACK_L3
        text_l2i = P36B_TEXT_L2_INDEX
        data_l2i = P36B_DATA_L2_INDEX
        stack_l2i = P36B_STACK_L2_INDEX
        stack_va = P36B_STACK_VA
        stack_pa = P36B_STACK_PA

    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1
    l1[0] = cast[uint64](0) | DEV_FLAGS

    tl3: Ptr[uint64] = cast[Ptr[uint64]](text_l3)
    dl3: Ptr[uint64] = cast[Ptr[uint64]](data_l3)
    sl3: Ptr[uint64] = cast[Ptr[uint64]](stack_l3)
    k: int64 = 0
    while k < 512:
        tl3[k] = cast[uint64](0)
        dl3[k] = cast[uint64](0)
        sl3[k] = cast[uint64](0)
        k = k + 1

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == text_l2i:
            l2[j] = text_l3 | DESC_TABLE
        elif cast[uint64](j) == data_l2i:
            l2[j] = data_l3 | DESC_TABLE
        elif cast[uint64](j) == stack_l2i:
            l2[j] = stack_l3 | DESC_TABLE
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = l2_base | DESC_TABLE
    _dsb_ish()

    # Wire the EL0 stack page (RW non-exec).
    sidx: uint64 = (stack_va >> cast[uint64](12)) & cast[uint64](0x1FF)
    sl3[cast[int64](sidx)] = stack_pa | P36_PAGE_RW
    sp: Ptr[uint64] = cast[Ptr[uint64]](stack_pa)
    z: int64 = 0
    while z < 512:
        sp[z] = cast[uint64](0)
        z = z + 1
    _dsb_ish()
    return 0


# Map [seg_va, seg_va+memsz) onto seg_pa with page_flags in its 2 MiB slot's
# private L3. Backing page pre-cleared (BSS reads zero), p_filesz bytes copied in.
def arm64_p36_map_segment(seg_va: uint64, seg_pa: uint64, foff: uint64, filesz: uint64, l3_base: uint64, page_flags: uint64) -> int64:
    pg: Ptr[uint8] = cast[Ptr[uint8]](seg_pa)
    c: int64 = 0
    while c < cast[int64](P26_PAGE_SIZE):
        pg[c] = cast[uint8](0)
        c = c + 1
    fbuf: Ptr[uint8] = cast[Ptr[uint8]](P36_FILE_PA)
    n: uint64 = cast[uint64](0)
    while n < filesz:
        pg[cast[int64](n)] = fbuf[cast[int64](foff + n)]
        n = n + cast[uint64](1)
    _dsb_ish()
    l3: Ptr[uint64] = cast[Ptr[uint64]](l3_base)
    idx: uint64 = (seg_va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3[cast[int64](idx)] = seg_pa | page_flags
    _dsb_ish()
    _isb()
    return 0


# Parse + load the on-disk ELF64 in P36_FILE_PA into program `prog`'s space.
# Validates the header, walks the phdrs, maps each PT_LOAD by its VADDR onto that
# program's private PA backing. Returns e_entry, or 0 on a validation failure.
def arm64_p36_load_elf(prog: int64) -> uint64:
    fbuf: Ptr[uint8] = cast[Ptr[uint8]](P36_FILE_PA)
    nl: Ptr[char] = "\n"

    if cast[uint64](fbuf[0]) != ELF_EI_MAG0:
        return cast[uint64](0)
    if cast[uint64](fbuf[1]) != ELF_EI_MAG1:
        return cast[uint64](0)
    if cast[uint64](fbuf[2]) != ELF_EI_MAG2:
        return cast[uint64](0)
    if cast[uint64](fbuf[3]) != ELF_EI_MAG3:
        return cast[uint64](0)
    if cast[uint64](fbuf[4]) != ELFCLASS64:
        return cast[uint64](0)
    if cast[uint64](fbuf[5]) != ELFDATA2LSB:
        return cast[uint64](0)

    e_type: uint64 = _p36_rd16(EH_TYPE)
    e_machine: uint64 = _p36_rd16(EH_MACHINE)
    e_entry: uint64 = _p36_rd64(EH_ENTRY)
    e_phoff: uint64 = _p36_rd64(EH_PHOFF)
    e_phentsize: uint64 = _p36_rd16(EH_PHENTSIZE)
    e_phnum: uint64 = _p36_rd16(EH_PHNUM)

    if e_type != ET_EXEC:
        return cast[uint64](0)
    if e_machine != EM_AARCH64:
        return cast[uint64](0)

    text_va: uint64 = P36A_TEXT_VA
    data_va: uint64 = P36A_DATA_VA
    text_pa: uint64 = P36A_TEXT_PA
    data_pa: uint64 = P36A_DATA_PA
    text_l3: uint64 = P36A_TEXT_L3
    data_l3: uint64 = P36A_DATA_L3
    if prog == 1:
        text_va = P36B_TEXT_VA
        data_va = P36B_DATA_VA
        text_pa = P36B_TEXT_PA
        data_pa = P36B_DATA_PA
        text_l3 = P36B_TEXT_L3
        data_l3 = P36B_DATA_L3

    hm: Ptr[char] = "[arm64] Phase 36 ELF: prog="
    _uart_puts(hm)
    _uart_puthex(cast[uint64](prog))
    hm2: Ptr[char] = " entry="
    _uart_puts(hm2)
    _uart_puthex(e_entry)
    hm3: Ptr[char] = " phnum="
    _uart_puts(hm3)
    _uart_puthex(e_phnum)
    _uart_puts(nl)

    segs: int64 = 0
    ph: uint64 = 0
    while ph < e_phnum:
        b: uint64 = e_phoff + (ph * e_phentsize)
        p_type: uint64 = _p36_rd32(b + PH_TYPE)
        if p_type == PT_LOAD:
            p_flags: uint64 = _p36_rd32(b + PH_FLAGS)
            p_offset: uint64 = _p36_rd64(b + PH_OFFSET)
            p_vaddr: uint64 = _p36_rd64(b + PH_VADDR)
            p_filesz: uint64 = _p36_rd64(b + PH_FILESZ)
            page_flags: uint64 = arm64_p36_flags_for(p_flags)

            sm: Ptr[char] = "[arm64] Phase 36 PT_LOAD: vaddr="
            _uart_puts(sm)
            _uart_puthex(p_vaddr)
            fm: Ptr[char] = " filesz="
            _uart_puts(fm)
            _uart_puthex(p_filesz)
            xm: Ptr[char] = " flags="
            _uart_puts(xm)
            _uart_puthex(p_flags)
            _uart_puts(nl)

            seg_pa: uint64 = cast[uint64](0)
            l3_base: uint64 = cast[uint64](0)
            if p_vaddr == text_va:
                seg_pa = text_pa
                l3_base = text_l3
            elif p_vaddr == data_va:
                seg_pa = data_pa
                l3_base = data_l3
            else:
                return cast[uint64](0)

            arm64_p36_map_segment(p_vaddr, seg_pa, p_offset, p_filesz, l3_base, page_flags)
            segs = segs + 1
        ph = ph + cast[uint64](1)

    if segs < 1:
        return cast[uint64](0)
    return e_entry


# TTBR0_EL1 for program `prog`: its private L1 root + its ASID in bits[63:48].
def arm64_p36_ttbr0_for(prog: int64) -> uint64:
    if prog == 1:
        return P36B_L1 | (P36B_ASID << P23_ASID_SHIFT)
    return P36A_L1 | (P36A_ASID << P23_ASID_SHIFT)


# Recycle program `prog`'s ASID and make its private TTBR0 live.
def arm64_p36_switch_to(prog: int64) -> int64:
    asid: uint64 = P36A_ASID
    if prog == 1:
        asid = P36B_ASID
    _dsb_ish()
    _tlbi_aside1is(asid << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()
    _msr_ttbr0_el1(arm64_p36_ttbr0_for(prog))
    _dsb_ish()
    _tlbi_aside1is(asid << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()
    return 0


# Phase-36 demand-fault entry. A first touch of a loaded segment page of the LIVE
# program (A or B) takes a translation fault (loader pre-stamped the PTE). Confirm
# the VA lies in a loaded segment of the current program, account it, flush the
# VA, and resume (return 1); anything else -> 0 (fall through to the reaper).
def arm64_p36_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0
    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    in_seg: int64 = 0
    if arm64_p36_cur_prog == 0:
        if page_va == P36A_TEXT_VA:
            arm64_p36_a_text_faults = arm64_p36_a_text_faults + 1
            in_seg = 1
        elif page_va == P36A_DATA_VA:
            arm64_p36_a_data_faults = arm64_p36_a_data_faults + 1
            in_seg = 1
    else:
        if page_va == P36B_TEXT_VA:
            arm64_p36_b_text_faults = arm64_p36_b_text_faults + 1
            in_seg = 1
        elif page_va == P36B_DATA_VA:
            arm64_p36_b_data_faults = arm64_p36_b_data_faults + 1
            in_seg = 1
    if in_seg == 0:
        return 0

    _dsb_ish()
    _tlbi_vaae1is(page_va >> cast[uint64](12))
    _dsb_ish()
    _isb()
    return 1


# open(nid): locate the file on the FAT16 disk, load its bytes into the file's
# RAM buffer, set up the single open-file slot. Returns fd (0) or -1.
def arm64_p36_do_open(nid: uint64) -> int64:
    if arm64_p36_of_used != 0:
        return -1
    base: uint64 = arm64_p36_blk_base
    arm64_p36_fill_name(P31_FILE_PA, nid)        # stage the 11-byte name
    loc: int64 = arm64_p36_locate(base, P31_FILE_PA)
    if loc != 1:
        return -1
    buf: uint64 = P36_WORK_BUF_PA
    if nid == P36_NID_MARK:
        buf = P36_MARK_BUF_PA
    got: int64 = arm64_p36_read_file_into(base, arm64_p36_loc_first_clus, arm64_p36_loc_size, buf)
    if got < 0:
        return -1
    arm64_p36_of_used = 1
    arm64_p36_of_nid = nid
    arm64_p36_of_dir_lba = arm64_p36_loc_dir_lba
    arm64_p36_of_ent_off = arm64_p36_loc_ent_off
    arm64_p36_of_first_clus = arm64_p36_loc_first_clus
    arm64_p36_of_len = arm64_p36_loc_size
    arm64_p36_of_buf = buf
    arm64_p36_of_rpos = 0
    return 0


# write(fd, buf, len): fd 1 = UART; else OVERWRITE the open file's buffer from the
# start (truncating-write, like a freshly-opened file). Returns bytes written.
def arm64_p36_do_write(fd: uint64, ubuf: uint64, ulen: uint64) -> int64:
    if fd == cast[uint64](1):
        b: Ptr[uint8] = cast[Ptr[uint8]](ubuf)
        n: uint64 = cast[uint64](0)
        while n < ulen:
            _uart_putc(b[cast[int64](n)])
            n = n + cast[uint64](1)
        return cast[int64](ulen)
    if arm64_p36_of_used == 0:
        return -1
    n2: int64 = cast[int64](ulen)
    if n2 > P36_FILE_BUF_CAP:
        n2 = P36_FILE_BUF_CAP
    src: Ptr[uint8] = cast[Ptr[uint8]](ubuf)
    dst: Ptr[uint8] = cast[Ptr[uint8]](arm64_p36_of_buf)
    i: int64 = 0
    while i < n2:
        dst[i] = src[i]
        i = i + 1
    arm64_p36_of_len = n2                         # truncating write: file len = bytes written
    return n2


# read(fd, buf, len): copy up to `len` bytes from the open file's buffer (from the
# read cursor) into the EL0 buffer. Returns bytes read (0 at EOF).
def arm64_p36_do_read(fd: uint64, ubuf: uint64, ulen: uint64) -> int64:
    if arm64_p36_of_used == 0:
        return -1
    avail: int64 = arm64_p36_of_len - arm64_p36_of_rpos
    if avail < 0:
        avail = 0
    take: int64 = cast[int64](ulen)
    if take > avail:
        take = avail
    src: Ptr[uint8] = cast[Ptr[uint8]](arm64_p36_of_buf + cast[uint64](arm64_p36_of_rpos))
    dst: Ptr[uint8] = cast[Ptr[uint8]](ubuf)
    i: int64 = 0
    while i < take:
        dst[i] = src[i]
        i = i + 1
    arm64_p36_of_rpos = arm64_p36_of_rpos + take
    return take


# close(fd): flush the open file's buffer to the FAT16 disk (data cluster + dir
# size) and release the open-file slot. Returns 1 OK, -1 on error.
def arm64_p36_do_close(fd: uint64) -> int64:
    if arm64_p36_of_used == 0:
        return -1
    base: uint64 = arm64_p36_blk_base
    nid: uint64 = arm64_p36_of_nid
    ok: int64 = arm64_p36_flush_file(base)
    # Evidence: the child (Program B) durably flushed MARK.TXT to the FAT16 disk.
    if ok == 1:
        if arm64_p36_cur_prog == 1:
            if nid == P36_NID_MARK:
                arm64_p36_b_wrote_mark = 1
    arm64_p36_of_used = 0
    arm64_p36_of_nid = cast[uint64](0xFFFF)
    if ok != 1:
        return -1
    return 1


# spawn(prog-id): synchronously load + run the child program in its own EL0 space.
# Saves the caller's (Program A's) full EL0 resume context into P36_PCTX, builds
# the child space, loads CHILDB.ELF into it, switches TTBR0 + ERETs into the
# child. NEVER returns here — the child's exit() restores the parent. The frame is
# the parent's saved svc frame (used to capture x0..x30).
def arm64_p36_do_spawn(frame_ptr: Ptr[uint64], progid: uint64) -> int64:
    nl: Ptr[char] = "\n"
    base: uint64 = arm64_p36_blk_base

    # 1. Save the parent (A)'s FULL EL0 resume context so the child's exit() can
    #    restore it verbatim, resuming A right after this spawn svc.
    pctx: Ptr[uint64] = cast[Ptr[uint64]](P36_PCTX)
    i: int64 = 0
    while i < 31:
        pctx[i] = frame_ptr[i]                    # x0..x30
        i = i + 1
    pctx[31] = cast[uint64](_mrs_sp_el0())        # SP_EL0
    pctx[32] = cast[uint64](_mrs_elr_el1())       # ELR_EL1 = PC after spawn svc
    pctx[33] = SPSR_EL0T_DAIF                      # resume PSTATE: EL0t, IRQs masked
    _dsb_ish()

    # 2. Read CHILDB.ELF off the FAT16 disk into the ELF file buffer.
    nm: uint64 = P31_FILE_PA
    np: Ptr[uint8] = cast[Ptr[uint8]](nm)
    np[0] = P36_CHILDB0
    np[1] = P36_CHILDB1
    np[2] = P36_CHILDB2
    np[3] = P36_CHILDB3
    np[4] = P36_CHILDB4
    np[5] = P36_CHILDB5
    np[6] = P36_CHILDB6
    np[7] = P36_CHILDB7
    np[8] = P36_CHILDB8
    np[9] = P36_CHILDB9
    np[10] = P36_CHILDB10
    flen: int64 = arm64_p36_read_elf(base, nm)
    if flen <= 0:
        fp: Ptr[char] = "[arm64] Phase 36 FAIL: could not read CHILDB.ELF off the FAT16 disk\n"
        _uart_puts(fp)
        arm64_p36_finish()
        while True:
            _wfi()

    sm: Ptr[char] = "[arm64] Phase 36: read CHILDB.ELF off disk ("
    _uart_puts(sm)
    _uart_puthex(cast[uint64](flen))
    sm2: Ptr[char] = " bytes); building child EL0 space + launching\n"
    _uart_puts(sm2)

    # 3. Build the child's fresh space, load the ELF, switch in, mark it live.
    arm64_p36_build_space(1)
    arm64_p36_switch_to(1)
    entry: uint64 = arm64_p36_load_elf(1)
    if entry == cast[uint64](0):
        fp2: Ptr[char] = "[arm64] Phase 36 FAIL: CHILDB.ELF failed header/phdr validation\n"
        _uart_puts(fp2)
        arm64_p36_finish()
        while True:
            _wfi()

    arm64_p36_cur_prog = 1
    arm64_p36_b_ran = 1

    em: Ptr[char] = "[arm64] Phase 36: launching child CHILDB at EL0 (ASID 25), entry "
    _uart_puts(em)
    _uart_puthex(entry)
    _uart_puts(nl)

    # 4. ERET into the child. A clean frame (x0..x30 = 0) is restored by the svc
    #    stub; we set ELR/SP_EL0/SPSR for the child entry.
    j: int64 = 0
    while j < 31:
        frame_ptr[j] = cast[uint64](0)
        j = j + 1
    _msr_spsr_el1(SPSR_EL0T_DAIF)
    _msr_elr_el1(entry)
    _msr_sp_el0(P36B_STACK_TOP)
    _isb()
    return 0                                       # stub ERETs into the child entry


# exit(status): child -> reap (resume the parent past its spawn svc with x0 =
# status). parent -> run the verdict. Routed from the dispatcher.
def arm64_p36_do_exit(frame_ptr: Ptr[uint64], status: uint64) -> int64:
    nl: Ptr[char] = "\n"
    if arm64_p36_cur_prog == 1:
        # --- child exit: synchronous reap, resume the parent (Program A) ---
        arm64_p36_child_status = status
        cm: Ptr[char] = "[arm64] Phase 36: child CHILDB exit(status="
        _uart_puts(cm)
        _uart_puthex(status)
        cm2: Ptr[char] = ") -> reaping, resuming parent INITA\n"
        _uart_puts(cm2)

        # Switch TTBR0 back to the parent (A) and restore its full EL0 context.
        arm64_p36_cur_prog = 0
        arm64_p36_switch_to(0)
        pctx: Ptr[uint64] = cast[Ptr[uint64]](P36_PCTX)
        i: int64 = 0
        while i < 31:
            frame_ptr[i] = pctx[i]                 # x0..x30 restored
            i = i + 1
        frame_ptr[0] = status                      # spawn() returns the child status
        _msr_sp_el0(pctx[31])
        _msr_elr_el1(pctx[32])
        _msr_spsr_el1(pctx[33])
        _isb()
        return 0                                   # stub ERETs back into the parent

    # --- parent exit: record + run the verdict ---
    arm64_p36_a_exit_code = status
    arm64_p36_a_exited = 1
    arm64_p36_finish()
    while True:
        _wfi()
    return 0


# report(check-id, buf, len/value): Program A reports a result it computed in its
# OWN address space; the kernel cross-checks it against the genuine expected
# state, recording the verified evidence the verdict reads. This keeps the PASS
# kernel-verified (the program cannot fake a result — the kernel compares the
# reported user bytes against what it knows must be on disk).
#   CHK_WORK   : a1 = A's read-back of WORK.TXT, a2 = len. Kernel confirms it
#                equals the known 16-byte payload -> a_file_rt_ok.
#   CHK_MARK   : a1 = A's read-back of MARK.TXT (B's marker), a2 = len. Kernel
#                confirms it equals the known 12-byte marker -> a_saw_mark.
#   CHK_STATUS : a2 = the spawn() return value A observed -> a_saw_status.
def arm64_p36_do_report(chk: uint64, ubuf: uint64, val: uint64) -> int64:
    if chk == P36_CHK_WORK:
        if cast[int64](val) != P36_WORK_LEN:
            return 0
        ub: Ptr[uint8] = cast[Ptr[uint8]](ubuf)
        ok: int64 = 1
        i: int64 = 0
        while i < P36_WORK_LEN:
            if ub[i] != arm64_p36_work_byte(i):
                ok = 0
            i = i + 1
        if ok != 0:
            arm64_p36_a_file_rt_ok = 1
        return ok
    if chk == P36_CHK_MARK:
        if cast[int64](val) != P36_MARK_LEN:
            return 0
        ub2: Ptr[uint8] = cast[Ptr[uint8]](ubuf)
        ok2: int64 = 1
        j: int64 = 0
        while j < P36_MARK_LEN:
            if ub2[j] != arm64_p36_mark_byte(j):
                ok2 = 0
            j = j + 1
        if ok2 != 0:
            arm64_p36_a_saw_mark = 1
        return ok2
    if chk == P36_CHK_STATUS:
        arm64_p36_a_saw_status = val
        return 1
    return 0


# Phase-36 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. Services the real EL0 file/process ABI (open/write/read/close/spawn/exit).
def arm64_p36_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_P36_OPEN:
        fd: int64 = arm64_p36_do_open(a0)
        frame_ptr[0] = cast[uint64](fd)
        return 0
    if nr == SYS_P36_WRITE:
        n: int64 = arm64_p36_do_write(a0, a1, a2)
        frame_ptr[0] = cast[uint64](n)
        return 0
    if nr == SYS_P36_READ:
        n2: int64 = arm64_p36_do_read(a0, a1, a2)
        frame_ptr[0] = cast[uint64](n2)
        return 0
    if nr == SYS_P36_CLOSE:
        r: int64 = arm64_p36_do_close(a0)
        frame_ptr[0] = cast[uint64](r)
        return 0
    if nr == SYS_P36_REPORT:
        r2: int64 = arm64_p36_do_report(a0, a1, a2)
        frame_ptr[0] = cast[uint64](r2)
        return 0
    if nr == SYS_P36_SPAWN:
        return arm64_p36_do_spawn(frame_ptr, a0)
    if nr == SYS_P36_EXIT:
        return arm64_p36_do_exit(frame_ptr, a0)

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 36)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-36 verdict. PASS iff the full workflow verified:
#   - Program A's WORK.TXT write->read round-trip matched (real FS open/write/
#     close/read against FAT16);
#   - Program B actually ran at EL0 (entered + executed);
#   - B durably wrote MARK.TXT (close flushed it to the FAT16 disk);
#   - A re-read MARK.TXT and saw B's marker (ORDERING: B ran before A re-read);
#   - A observed (reaped) B's exit status, and it matched the expected value;
#   - A exited with its own expected status.
def arm64_p36_finish() -> int64:
    arm64_p36_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] Phase 36 summary: a_file_rt_ok="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p36_a_file_rt_ok))
    g1: Ptr[char] = " b_ran="
    _uart_puts(g1)
    _uart_puthex(cast[uint64](arm64_p36_b_ran))
    g2: Ptr[char] = " b_wrote_mark="
    _uart_puts(g2)
    _uart_puthex(cast[uint64](arm64_p36_b_wrote_mark))
    g3: Ptr[char] = " a_saw_mark="
    _uart_puts(g3)
    _uart_puthex(cast[uint64](arm64_p36_a_saw_mark))
    g4: Ptr[char] = " child_status="
    _uart_puts(g4)
    _uart_puthex(arm64_p36_child_status)
    g5: Ptr[char] = " a_saw_status="
    _uart_puts(g5)
    _uart_puthex(arm64_p36_a_saw_status)
    g6: Ptr[char] = " a_exit="
    _uart_puts(g6)
    _uart_puthex(arm64_p36_a_exit_code)
    _uart_puts(nl)

    ok: int64 = 1
    if arm64_p36_a_file_rt_ok == 0:
        ok = 0
    if arm64_p36_b_ran == 0:
        ok = 0
    if arm64_p36_b_wrote_mark == 0:
        ok = 0
    if arm64_p36_a_saw_mark == 0:
        ok = 0
    if arm64_p36_child_status != P36_CHILD_EXIT:
        ok = 0
    if arm64_p36_a_saw_status != P36_CHILD_EXIT:
        ok = 0
    if arm64_p36_a_exited == 0:
        ok = 0
    if arm64_p36_a_exit_code != P36_PARENT_EXIT:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 36: ran INITA.ELF at EL0 (real open/write/close/read FAT16 round-trip), it spawned CHILDB.ELF as a SECOND EL0 process in its own address space, the child wrote a marker file + exited, and the parent reaped the child's exit status and confirmed the marker — a real multi-process, filesystem-using userland\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 36 PASS: multi-process FAT16 userland (INITA file round-trip + spawned CHILDB + reaped exit status + ordering)\n"
        _uart_puts(pp)
        # Hand off to Phase 37 (a real BLOCKING in-kernel pipe between two on-disk
        # EL0 processes) on the SAME live virtio-blk transport. arm64_p37_run never
        # returns (its verdict halts after the pipe round-trip).
        arm64_p37_run(arm64_p36_blk_base)
        # Unreachable: arm64_p37_run halts. Safety loop.
        _msr_daifset(2)
        while True:
            _wfi()
    else:
        fp: Ptr[char] = "[arm64] Phase 36 FAIL: multi-process userland workflow verdict failed\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-36 entry point (hand-off from arm64_p35_run on a Phase-35 PASS), with the
# live virtio-blk transport `base`. Re-parse the FAT16 BPB (Phase 35 left the
# transport live but we re-read the boot sector to be safe), read INITA.ELF off
# the disk, build Program A's fresh EL0 space, load it, and ERET into it at EL0t
# with IRQs masked. INITA drives the rest via its syscalls. Never returns.
def arm64_p36_run(base: uint64) -> int64:
    intro: Ptr[char] = "[arm64] Phase 36: multi-process FAT16 userland (INITA + spawned CHILDB)\n"
    _uart_puts(intro)
    nl: Ptr[char] = "\n"

    _msr_daifset(2)                              # deterministic: EL1 IRQs masked
    arm64_p36_blk_base = base
    arm64_p36_cur_prog = 0

    # Re-parse the FAT16 BPB off sector 0 (fills arm64_p31_* geometry globals).
    if arm64_p30_read_sector_into(base, cast[uint64](0), P31_SEC_PA) != 1:
        fp: Ptr[char] = "[arm64] Phase 36 FAIL: boot-sector read failed\n"
        _uart_puts(fp)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    if arm64_p31_parse_bpb() != 1:
        fp2: Ptr[char] = "[arm64] Phase 36 FAIL: BPB geometry not a supported FAT16\n"
        _uart_puts(fp2)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    # Read INITA.ELF off the disk.
    nm: uint64 = P31_FILE_PA
    np: Ptr[uint8] = cast[Ptr[uint8]](nm)
    np[0] = P36_INITA0
    np[1] = P36_INITA1
    np[2] = P36_INITA2
    np[3] = P36_INITA3
    np[4] = P36_INITA4
    np[5] = P36_INITA5
    np[6] = P36_INITA6
    np[7] = P36_INITA7
    np[8] = P36_INITA8
    np[9] = P36_INITA9
    np[10] = P36_INITA10
    flen: int64 = arm64_p36_read_elf(base, nm)
    if flen <= 0:
        fp3: Ptr[char] = "[arm64] Phase 36 FAIL: could not read INITA.ELF off the FAT16 disk\n"
        _uart_puts(fp3)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    rm: Ptr[char] = "[arm64] Phase 36: read INITA.ELF off disk ("
    _uart_puts(rm)
    _uart_puthex(cast[uint64](flen))
    rm2: Ptr[char] = " bytes); building parent EL0 space + launching\n"
    _uart_puts(rm2)

    # Build Program A's fresh EL0 space, switch in, load the ELF.
    arm64_p36_build_space(0)
    arm64_p36_switch_to(0)
    entry: uint64 = arm64_p36_load_elf(0)
    if entry == cast[uint64](0):
        fp4: Ptr[char] = "[arm64] Phase 36 FAIL: INITA.ELF failed header/phdr validation\n"
        _uart_puts(fp4)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    arm64_p36_active = 1

    em: Ptr[char] = "[arm64] Phase 36: launching parent INITA at EL0 (ASID 24), entry "
    _uart_puts(em)
    _uart_puthex(entry)
    _uart_puts(nl)

    _msr_spsr_el1(SPSR_EL0T_DAIF)               # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(entry)
    _msr_sp_el0(P36A_STACK_TOP)
    _isb()
    _eret()                                      # -> EL0; INITA runs, drives the rest
    # Unreachable: INITA's exit() halts after the verdict.
    while True:
        _wfi()
    return 0


# ===========================================================================
# Phase 37 — a REAL BLOCKING IN-KERNEL PIPE for IPC between TWO on-disk EL0
# user processes running CONCURRENTLY under the live preemptive timer scheduler.
#
# Two on-disk ELF64 programs are loaded off the live FAT16 disk, each into its
# OWN private ASID-tagged EL0 address space (reusing the Phase-36 segment-loader
# shape, here built fresh for Phase 37 with distinct PA backing + ASIDs):
#
#   PRODA.ELF (producer, slot 0): writes a known PROD_LEN-byte sequence into the
#     pipe with ONE pipe_write syscall, then exit()s.
#   CONSB.ELF (consumer, slot 1): repeatedly pipe_read()s into its data segment.
#     On an EMPTY pipe the read BLOCKS the consumer (it is descheduled — its full
#     resume context is saved, it is marked BLOCKED, its EL0 PC is parked on a
#     self-loop — so the scheduler runs the producer instead and NEVER dispatches
#     the consumer again until it is woken). The producer's pipe_write fills the
#     ring buffer AND wakes the blocked reader, physically delivering the queued
#     bytes into the consumer's backing pages and setting its resumed read() return
#     value. The consumer loops until it has all PROD_LEN bytes, then report()s the
#     received bytes (the kernel cross-checks them byte-for-byte against the known
#     sequence) and exit()s.
#
# This is a GENUINE blocking pipe, NOT a faked round-trip:
#   * The pipe is a real ring buffer with head/tail indices + a byte count.
#   * The consumer GENUINELY blocks (enters the BLOCKED state, is parked, and is
#     skipped by the round-robin picker — arm64_p37_reader_blocked counts how many
#     times it actually slept on the empty pipe; the verdict requires it be > 0).
#   * The wake is driven by the WRITE, not the timer (arm64_p37_woken_by_write is
#     set only inside pipe_write; the verdict requires it).
#   * The bytes the consumer reports must equal the producer's known sequence
#     byte-for-byte (kernel-verified), else FAIL.
#
# Both processes run preemptively: the EL1 generic-timer IRQ round-robins the two
# slots' private (TTBR0+ASID) address spaces exactly like the Phase-28 blocking
# scheduler, here extended with a pipe-blocked task state + an EXITED/reaped state.
#
# EL0 syscalls added/wired for Phase 37 (free numbers, documented here):
#   SYS_P37_PIPE_WRITE (710): a0 = buf VA, a1 = len. Append `len` bytes from the
#                             caller's buffer into the pipe ring; if a reader is
#                             blocked, deliver queued bytes into its buffer + wake
#                             it. Returns bytes accepted into the ring.
#   SYS_P37_PIPE_READ  (711): a0 = buf VA, a1 = len. If the ring has bytes, copy up
#                             to `len` out and return the count (>=1). If the ring
#                             is EMPTY and the writer has not closed, BLOCK the
#                             caller until a write wakes it (then it returns the
#                             delivered count). Returns 0 only at clean EOF.
#   SYS_P37_REPORT     (712): a0 = check-id, a1 = buf VA, a2 = len/value. The
#                             consumer reports the bytes it received; the kernel
#                             confirms they equal the known producer sequence.
#   SYS_P37_EXIT       (713): a0 = status. Mark the caller EXITED (the scheduler
#                             reaps it); when both processes are DEAD, run verdict.
#
# Fresh RAM regions (clear of every prior phase's blocks). EL1-only page tables +
# context blocks live in free EL1 RAM above the Phase-28 scratch (<=0x401D_4000)
# and below the EL0 window (0x4020_0000). Data PA backing lives above Phase 36's
# top block (P36_PCTX at 0x454B_0000), starting at 0x4550_0000.
# ===========================================================================

# --- Phase-37 fresh RAM region (clear of P36 <=0x454B_xxxx) ----------------
P37_FILE_PA: uint64 = 0x45500000             # raw on-disk ELF bytes (producer/consumer)
P37_FILE_CAP: int64 = 8192                   # max ELF file bytes we read

# Producer (PRODA.ELF) private EL0 space. Reuses Phase-36 program-A segment VAs
# (valid EL0 VAs) but with distinct PA backing + page tables + ASID.
P37A_TEXT_VA: uint64 = 0x42600000
P37A_DATA_VA: uint64 = 0x42800000
P37A_STACK_VA: uint64 = 0x42A00000
P37A_TEXT_L2_INDEX: uint64 = 19              # (0x4260_0000 - 0x4000_0000) / 2 MiB
P37A_DATA_L2_INDEX: uint64 = 20
P37A_STACK_L2_INDEX: uint64 = 21
P37A_STACK_TOP: uint64 = 0x42A01000
P37A_ASID: uint64 = 26                       # distinct from every prior ASID

# Consumer (CONSB.ELF) private EL0 space. DISTINCT segment VAs (a different 2 MiB
# window) so the demand-fault handler attributes faults unambiguously.
P37B_TEXT_VA: uint64 = 0x42C00000
P37B_DATA_VA: uint64 = 0x42E00000
P37B_STACK_VA: uint64 = 0x43000000
P37B_TEXT_L2_INDEX: uint64 = 22              # (0x42C0_0000 - 0x4000_0000) / 2 MiB
P37B_DATA_L2_INDEX: uint64 = 23
P37B_STACK_L2_INDEX: uint64 = 24
P37B_STACK_TOP: uint64 = 0x43001000
P37B_ASID: uint64 = 27

# Per-slot EL1-only page tables (L1/L2 + three L3) + context blocks, in free EL1
# RAM above the Phase-28 scratch (P28 ends <=0x401D_4000) and below 0x4020_0000.
P37A_L1: uint64 = 0x401D4000
P37A_L2: uint64 = 0x401D5000
P37A_TEXT_L3: uint64 = 0x401D6000
P37A_DATA_L3: uint64 = 0x401D7000
P37A_STACK_L3: uint64 = 0x401D8000
P37B_L1: uint64 = 0x401D9000
P37B_L2: uint64 = 0x401DA000
P37B_TEXT_L3: uint64 = 0x401DB000
P37B_DATA_L3: uint64 = 0x401DC000
P37B_STACK_L3: uint64 = 0x401DD000
P37A_CTX: uint64 = 0x401DE000                # 34 x 8-byte resume-context slots
P37B_CTX: uint64 = 0x401DF000
P37_PARK_CTX: uint64 = 0x401E0000            # throwaway ctx for a parked blocked task

# Data PA backing for the two processes' segments + stacks.
P37A_TEXT_PA: uint64 = 0x45520000
P37A_DATA_PA: uint64 = 0x45530000
P37A_STACK_PA: uint64 = 0x45540000
P37B_TEXT_PA: uint64 = 0x45560000
P37B_DATA_PA: uint64 = 0x45570000
P37B_STACK_PA: uint64 = 0x45580000

# W^X page permissions (identical encoding to Phase 36).
P37_PAGE_RX: uint64 = 0x7C7
P37_PAGE_RW: uint64 = 0x40000000000747
P37_PAGE_RO: uint64 = 0x400000000007C7

# Phase-37 EL0 syscall numbers (free; documented in the header above).
SYS_P37_PIPE_WRITE: uint64 = 710
SYS_P37_PIPE_READ: uint64 = 711
SYS_P37_REPORT: uint64 = 712
SYS_P37_EXIT: uint64 = 713

# check-id for SYS_P37_REPORT.
P37_CHK_PIPE: uint64 = 0                      # consumer reports the received bytes

# Task-state model: reuse the Phase-28 numbering; BLOCKED = parked on the empty
# pipe (woken only by a peer write); EXITED = called exit (scheduler reaps); DEAD
# = reaped (never dispatched again).
P37_RUNNABLE: int64 = 1
P37_BLOCKED: int64 = 2
P37_EXITED: int64 = 3
P37_DEAD: int64 = 4

# The known PROD_LEN-byte sequence the producer writes (position-coded so no big
# inline table is needed). The kernel verifies the consumer received exactly this.
P37_PROD_LEN: int64 = 24
def arm64_p37_prod_byte(i: int64) -> uint8:
    return cast[uint8]((0x21 + (i * 7)) & 0x7F)

# Expected exit statuses (the verdict asserts these are observed).
P37_PROD_EXIT: uint64 = 0x33                 # 51 — producer's exit status
P37_CONS_EXIT: uint64 = 0x44                 # 68 — consumer's exit status

# The pipe: a ring buffer with head (read cursor), tail (write cursor) and a live
# byte count. Capacity is a power-of-two-free fixed size that holds the sequence.
P37_PIPE_CAP: int64 = 64
P37_PIPE_BUF_PA: uint64 = 0x45590000         # the ring buffer's backing page
arm64_p37_pipe_head: int64 = 0               # next byte to read
arm64_p37_pipe_tail: int64 = 0               # next slot to write
arm64_p37_pipe_count: int64 = 0              # live bytes in the ring
arm64_p37_pipe_writer_closed: int64 = 0      # producer finished writing (EOF)

# --- Phase-37 bookkeeping --------------------------------------------------
arm64_p37_active: int64 = 0
arm64_p37_cur: int64 = 0                      # live slot (0 = producer, 1 = consumer)
arm64_p37_tick: int64 = 0                     # logical scheduler tick
arm64_p37_switches: int64 = 0                 # TTBR0+ASID swaps performed
arm64_p37_reader_blocked: int64 = 0           # times the consumer slept on an empty pipe
arm64_p37_woken_by_write: int64 = 0           # set when a write woke the blocked reader
arm64_p37_bytes_written: int64 = 0            # total bytes the producer pushed
arm64_p37_bytes_read: int64 = 0               # total bytes the consumer pulled
arm64_p37_skips: int64 = 0                    # times the picker passed over a BLOCKED slot

# Per-slot state.
arm64_p37_state0: int64 = 0
arm64_p37_state1: int64 = 0
arm64_p37_exit0: uint64 = 0xFFFF
arm64_p37_exit1: uint64 = 0xFFFF
arm64_p37_a_text_faults: int64 = 0
arm64_p37_a_data_faults: int64 = 0
arm64_p37_b_text_faults: int64 = 0
arm64_p37_b_data_faults: int64 = 0
arm64_p37_blk_base: uint64 = 0

# When the consumer blocks on an empty pipe, record its pending read request so a
# later write can deliver bytes straight into the consumer's backing pages and set
# its resumed read() return value.
arm64_p37_pending_buf_va: uint64 = 0          # consumer's read buffer VA
arm64_p37_pending_len: int64 = 0              # consumer's requested length

# Verdict evidence.
arm64_p37_rt_ok: int64 = 0                     # consumer's received bytes matched
arm64_p37_prod_exited: int64 = 0
arm64_p37_cons_exited: int64 = 0


# ---- per-slot accessors (idx: 0 = producer, 1 = consumer) -----------------
def arm64_p37_state_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p37_state0
    return arm64_p37_state1

def arm64_p37_set_state(idx: int64, st: int64) -> int64:
    if idx == 0:
        arm64_p37_state0 = st
    else:
        arm64_p37_state1 = st
    return 0

def arm64_p37_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P37A_CTX
    return P37B_CTX

def arm64_p37_asid_for(idx: int64) -> uint64:
    if idx == 0:
        return P37A_ASID
    return P37B_ASID

def arm64_p37_l1_for(idx: int64) -> uint64:
    if idx == 0:
        return P37A_L1
    return P37B_L1

def arm64_p37_data_pa_for(idx: int64) -> uint64:
    if idx == 0:
        return P37A_DATA_PA
    return P37B_DATA_PA

def arm64_p37_data_va_for(idx: int64) -> uint64:
    if idx == 0:
        return P37A_DATA_VA
    return P37B_DATA_VA


# Translate a DATA-segment VA in slot `idx` to its physical backing address. The
# data segment is one 2 MiB-mapped window (P37x_DATA_VA -> P37x_DATA_PA); a VA in
# [data_va, data_va+page) maps to data_pa + (va - data_va). Returns 0 if the VA is
# not inside the slot's data segment page.
def arm64_p37_data_va_to_pa(idx: int64, va: uint64) -> uint64:
    base_va: uint64 = arm64_p37_data_va_for(idx)
    if va < base_va:
        return cast[uint64](0)
    off: uint64 = va - base_va
    if off >= P26_PAGE_SIZE:
        return cast[uint64](0)
    return arm64_p37_data_pa_for(idx) + off


# Build process `prog` (0=producer,1=consumer)'s fresh private EL0 address space
# (L1/L2 + three 2 MiB slots redirected to private L3 tables) and wire its EL0
# stack page RW. Mirrors arm64_p36_build_space but over the Phase-37 globals.
def arm64_p37_build_space(prog: int64) -> int64:
    l1_base: uint64 = P37A_L1
    l2_base: uint64 = P37A_L2
    text_l3: uint64 = P37A_TEXT_L3
    data_l3: uint64 = P37A_DATA_L3
    stack_l3: uint64 = P37A_STACK_L3
    text_l2i: uint64 = P37A_TEXT_L2_INDEX
    data_l2i: uint64 = P37A_DATA_L2_INDEX
    stack_l2i: uint64 = P37A_STACK_L2_INDEX
    stack_va: uint64 = P37A_STACK_VA
    stack_pa: uint64 = P37A_STACK_PA
    if prog == 1:
        l1_base = P37B_L1
        l2_base = P37B_L2
        text_l3 = P37B_TEXT_L3
        data_l3 = P37B_DATA_L3
        stack_l3 = P37B_STACK_L3
        text_l2i = P37B_TEXT_L2_INDEX
        data_l2i = P37B_DATA_L2_INDEX
        stack_l2i = P37B_STACK_L2_INDEX
        stack_va = P37B_STACK_VA
        stack_pa = P37B_STACK_PA

    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1
    l1[0] = cast[uint64](0) | DEV_FLAGS

    tl3: Ptr[uint64] = cast[Ptr[uint64]](text_l3)
    dl3: Ptr[uint64] = cast[Ptr[uint64]](data_l3)
    sl3: Ptr[uint64] = cast[Ptr[uint64]](stack_l3)
    k: int64 = 0
    while k < 512:
        tl3[k] = cast[uint64](0)
        dl3[k] = cast[uint64](0)
        sl3[k] = cast[uint64](0)
        k = k + 1

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == text_l2i:
            l2[j] = text_l3 | DESC_TABLE
        elif cast[uint64](j) == data_l2i:
            l2[j] = data_l3 | DESC_TABLE
        elif cast[uint64](j) == stack_l2i:
            l2[j] = stack_l3 | DESC_TABLE
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = l2_base | DESC_TABLE
    _dsb_ish()

    # Wire the EL0 stack page (RW non-exec).
    sidx: uint64 = (stack_va >> cast[uint64](12)) & cast[uint64](0x1FF)
    sl3[cast[int64](sidx)] = stack_pa | P37_PAGE_RW
    sp: Ptr[uint64] = cast[Ptr[uint64]](stack_pa)
    z: int64 = 0
    while z < 512:
        sp[z] = cast[uint64](0)
        z = z + 1
    _dsb_ish()
    return 0


# Map [seg_va, seg_va+filesz) onto seg_pa with page_flags in its 2 MiB slot's
# private L3, copying p_filesz bytes from the Phase-37 ELF file buffer. The backing
# page is pre-cleared (BSS reads zero). Identical shape to arm64_p36_map_segment.
def arm64_p37_map_segment(seg_va: uint64, seg_pa: uint64, foff: uint64, filesz: uint64, l3_base: uint64, page_flags: uint64) -> int64:
    pg: Ptr[uint8] = cast[Ptr[uint8]](seg_pa)
    c: int64 = 0
    while c < cast[int64](P26_PAGE_SIZE):
        pg[c] = cast[uint8](0)
        c = c + 1
    fbuf: Ptr[uint8] = cast[Ptr[uint8]](P37_FILE_PA)
    n: uint64 = cast[uint64](0)
    while n < filesz:
        pg[cast[int64](n)] = fbuf[cast[int64](foff + n)]
        n = n + cast[uint64](1)
    _dsb_ish()
    l3: Ptr[uint64] = cast[Ptr[uint64]](l3_base)
    idx: uint64 = (seg_va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3[cast[int64](idx)] = seg_pa | page_flags
    _dsb_ish()
    _isb()
    return 0


# Little-endian readers out of the Phase-37 ELF file buffer.
def _p37_rd16(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P37_FILE_PA)
    b0: uint64 = cast[uint64](p[cast[int64](off)])
    b1: uint64 = cast[uint64](p[cast[int64](off + cast[uint64](1))])
    return b0 | (b1 << cast[uint64](8))


def _p37_rd32(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P37_FILE_PA)
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 4:
        r = r | (cast[uint64](p[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


def _p37_rd64(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P37_FILE_PA)
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 8:
        r = r | (cast[uint64](p[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


def arm64_p37_flags_for(pflags: uint64) -> uint64:
    if (pflags & PF_W) != cast[uint64](0):
        return P37_PAGE_RW
    if (pflags & PF_X) != cast[uint64](0):
        return P37_PAGE_RX
    return P37_PAGE_RO


# Read the on-disk ELF named by the 11-byte name at `name_pa` off the live FAT16
# volume into P37_FILE_PA (following its cluster chain). Returns byte length, or
# -1 on not-found / read error. Mirrors arm64_p36_read_elf over P37_FILE_PA.
def arm64_p37_read_elf(base: uint64, name_pa: uint64) -> int64:
    loc: int64 = arm64_p36_locate(base, name_pa)
    if loc != 1:
        return -1
    first_clus: int64 = arm64_p36_loc_first_clus
    file_size: int64 = arm64_p36_loc_size
    if first_clus < 2:
        return -1
    sec_per_clus: int64 = arm64_p31_sec_per_clus
    dst_off: int64 = 0
    want_len: int64 = file_size
    clus: int64 = first_clus
    guard: int64 = 0
    dst: Ptr[uint8] = cast[Ptr[uint8]](P37_FILE_PA)
    src: Ptr[uint8] = cast[Ptr[uint8]](P31_SEC_PA)
    while clus >= 2 and clus < 0xFFF8 and dst_off < want_len:
        guard = guard + 1
        if guard > 4096:
            return -1
        clus_lba: int64 = arm64_p31_data_lba + ((clus - 2) * sec_per_clus)
        sc: int64 = 0
        while sc < sec_per_clus:
            if dst_off < want_len:
                if arm64_p30_read_sector_into(base, cast[uint64](clus_lba + sc), P31_SEC_PA) != 1:
                    return -1
                take: int64 = arm64_p31_bytes_per_sec
                if dst_off + take > want_len:
                    take = want_len - dst_off
                i: int64 = 0
                while i < take:
                    if dst_off < P37_FILE_CAP:
                        dst[dst_off] = src[i]
                        dst_off = dst_off + 1
                    else:
                        i = take
                    i = i + 1
            sc = sc + 1
        nxt: int64 = arm64_p31_fat_next(base, clus)
        if nxt < 0:
            return -1
        clus = nxt
    return dst_off


# Parse + load the on-disk ELF64 in P37_FILE_PA into process `prog`'s space. Same
# validation/phdr walk as arm64_p36_load_elf. Returns e_entry, or 0 on failure.
def arm64_p37_load_elf(prog: int64) -> uint64:
    fbuf: Ptr[uint8] = cast[Ptr[uint8]](P37_FILE_PA)
    nl: Ptr[char] = "\n"

    if cast[uint64](fbuf[0]) != ELF_EI_MAG0:
        return cast[uint64](0)
    if cast[uint64](fbuf[1]) != ELF_EI_MAG1:
        return cast[uint64](0)
    if cast[uint64](fbuf[2]) != ELF_EI_MAG2:
        return cast[uint64](0)
    if cast[uint64](fbuf[3]) != ELF_EI_MAG3:
        return cast[uint64](0)
    if cast[uint64](fbuf[4]) != ELFCLASS64:
        return cast[uint64](0)
    if cast[uint64](fbuf[5]) != ELFDATA2LSB:
        return cast[uint64](0)

    e_type: uint64 = _p37_rd16(EH_TYPE)
    e_machine: uint64 = _p37_rd16(EH_MACHINE)
    e_entry: uint64 = _p37_rd64(EH_ENTRY)
    e_phoff: uint64 = _p37_rd64(EH_PHOFF)
    e_phentsize: uint64 = _p37_rd16(EH_PHENTSIZE)
    e_phnum: uint64 = _p37_rd16(EH_PHNUM)

    if e_type != ET_EXEC:
        return cast[uint64](0)
    if e_machine != EM_AARCH64:
        return cast[uint64](0)

    text_va: uint64 = P37A_TEXT_VA
    data_va: uint64 = P37A_DATA_VA
    text_pa: uint64 = P37A_TEXT_PA
    data_pa: uint64 = P37A_DATA_PA
    text_l3: uint64 = P37A_TEXT_L3
    data_l3: uint64 = P37A_DATA_L3
    if prog == 1:
        text_va = P37B_TEXT_VA
        data_va = P37B_DATA_VA
        text_pa = P37B_TEXT_PA
        data_pa = P37B_DATA_PA
        text_l3 = P37B_TEXT_L3
        data_l3 = P37B_DATA_L3

    hm: Ptr[char] = "[arm64] Phase 37 ELF: prog="
    _uart_puts(hm)
    _uart_puthex(cast[uint64](prog))
    hm2: Ptr[char] = " entry="
    _uart_puts(hm2)
    _uart_puthex(e_entry)
    hm3: Ptr[char] = " phnum="
    _uart_puts(hm3)
    _uart_puthex(e_phnum)
    _uart_puts(nl)

    segs: int64 = 0
    ph: uint64 = 0
    while ph < e_phnum:
        b: uint64 = e_phoff + (ph * e_phentsize)
        p_type: uint64 = _p37_rd32(b + PH_TYPE)
        if p_type == PT_LOAD:
            p_flags: uint64 = _p37_rd32(b + PH_FLAGS)
            p_offset: uint64 = _p37_rd64(b + PH_OFFSET)
            p_vaddr: uint64 = _p37_rd64(b + PH_VADDR)
            p_filesz: uint64 = _p37_rd64(b + PH_FILESZ)
            page_flags: uint64 = arm64_p37_flags_for(p_flags)

            seg_pa: uint64 = cast[uint64](0)
            l3_base: uint64 = cast[uint64](0)
            if p_vaddr == text_va:
                seg_pa = text_pa
                l3_base = text_l3
            elif p_vaddr == data_va:
                seg_pa = data_pa
                l3_base = data_l3
            else:
                return cast[uint64](0)

            arm64_p37_map_segment(p_vaddr, seg_pa, p_offset, p_filesz, l3_base, page_flags)
            segs = segs + 1
        ph = ph + cast[uint64](1)

    if segs < 1:
        return cast[uint64](0)
    return e_entry


# TTBR0_EL1 for process `prog`: its private L1 root + its ASID in bits[63:48].
def arm64_p37_ttbr0_for(prog: int64) -> uint64:
    if prog == 1:
        return P37B_L1 | (P37B_ASID << P23_ASID_SHIFT)
    return P37A_L1 | (P37A_ASID << P23_ASID_SHIFT)


# Recycle process `prog`'s ASID and make its private TTBR0 live.
def arm64_p37_switch_to(prog: int64) -> int64:
    asid: uint64 = P37A_ASID
    if prog == 1:
        asid = P37B_ASID
    _dsb_ish()
    _tlbi_aside1is(asid << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()
    _msr_ttbr0_el1(arm64_p37_ttbr0_for(prog))
    _dsb_ish()
    _tlbi_aside1is(asid << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()
    return 0


# Initialise process `prog`'s resume-context block for a clean first ERET into its
# entry, on its own EL0 stack, in EL0t with IRQs UNMASKED (so the timer preempts).
def arm64_p37_init_ctx(prog: int64, entry: uint64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p37_ctx_for(prog))
    i: int64 = 0
    while i < 34:
        ctx[i] = cast[uint64](0)
        i = i + 1
    stack_top: uint64 = P37A_STACK_TOP
    if prog == 1:
        stack_top = P37B_STACK_TOP
    ctx[CTX_SP_EL0] = stack_top
    ctx[CTX_ELR] = entry
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ
    return 0


# Phase-37 demand-fault entry. A first touch of a loaded segment page of the LIVE
# process (producer or consumer) takes a translation fault (loader pre-stamped the
# PTE). Confirm the VA lies in a loaded segment of the current process, account it,
# flush the VA, and resume (return 1); anything else -> 0 (fall through to reaper).
def arm64_p37_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0
    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    in_seg: int64 = 0
    if arm64_p37_cur == 0:
        if page_va == P37A_TEXT_VA:
            arm64_p37_a_text_faults = arm64_p37_a_text_faults + 1
            in_seg = 1
        elif page_va == P37A_DATA_VA:
            arm64_p37_a_data_faults = arm64_p37_a_data_faults + 1
            in_seg = 1
    else:
        if page_va == P37B_TEXT_VA:
            arm64_p37_b_text_faults = arm64_p37_b_text_faults + 1
            in_seg = 1
        elif page_va == P37B_DATA_VA:
            arm64_p37_b_data_faults = arm64_p37_b_data_faults + 1
            in_seg = 1
    if in_seg == 0:
        return 0

    _dsb_ish()
    _tlbi_vaae1is(page_va >> cast[uint64](12))
    _dsb_ish()
    _isb()
    return 1


# ---- the ring-buffer pipe -------------------------------------------------
# Push one byte into the ring. Returns 1 if accepted, 0 if the ring was full.
def arm64_p37_ring_push(byte: uint8) -> int64:
    if arm64_p37_pipe_count >= P37_PIPE_CAP:
        return 0
    rb: Ptr[uint8] = cast[Ptr[uint8]](P37_PIPE_BUF_PA)
    rb[arm64_p37_pipe_tail] = byte
    arm64_p37_pipe_tail = arm64_p37_pipe_tail + 1
    if arm64_p37_pipe_tail >= P37_PIPE_CAP:
        arm64_p37_pipe_tail = 0
    arm64_p37_pipe_count = arm64_p37_pipe_count + 1
    return 1


# Pop one byte out of the ring into *out_pa. Returns 1 if a byte was popped, 0 if
# the ring was empty.
def arm64_p37_ring_pop(out_pa: uint64) -> int64:
    if arm64_p37_pipe_count <= 0:
        return 0
    rb: Ptr[uint8] = cast[Ptr[uint8]](P37_PIPE_BUF_PA)
    o: Ptr[uint8] = cast[Ptr[uint8]](out_pa)
    o[0] = rb[arm64_p37_pipe_head]
    arm64_p37_pipe_head = arm64_p37_pipe_head + 1
    if arm64_p37_pipe_head >= P37_PIPE_CAP:
        arm64_p37_pipe_head = 0
    arm64_p37_pipe_count = arm64_p37_pipe_count - 1
    return 1


# Drain up to `len` bytes from the ring into the slot `idx` data-segment buffer at
# VA `buf_va` (translated to its physical backing). Returns bytes delivered.
def arm64_p37_drain_into(idx: int64, buf_va: uint64, len: int64) -> int64:
    delivered: int64 = 0
    one: uint64 = P37_PIPE_BUF_PA + cast[uint64](P37_PIPE_CAP)   # scratch byte slot
    while delivered < len:
        if arm64_p37_pipe_count <= 0:
            delivered = delivered   # ring drained
            return delivered
        dst_pa: uint64 = arm64_p37_data_va_to_pa(idx, buf_va + cast[uint64](delivered))
        if dst_pa == cast[uint64](0):
            return delivered
        if arm64_p37_ring_pop(one) != 1:
            return delivered
        sb: Ptr[uint8] = cast[Ptr[uint8]](one)
        db: Ptr[uint8] = cast[Ptr[uint8]](dst_pa)
        db[0] = sb[0]
        delivered = delivered + 1
    return delivered


# pipe_write(buf_va, len): append `len` bytes from the CURRENT (producer's) buffer
# into the ring. The producer is live, so buf_va resolves through the live TTBR0 —
# we read it directly. After enqueuing, if the consumer is BLOCKED on an empty read
# we deliver queued bytes straight into its backing pages, set its resumed read()
# return value (x0) and WAKE it (BLOCKED -> RUNNABLE). Returns bytes accepted.
def arm64_p37_do_pipe_write(buf_va: uint64, len: int64) -> int64:
    src: Ptr[uint8] = cast[Ptr[uint8]](buf_va)
    accepted: int64 = 0
    i: int64 = 0
    while i < len:
        if arm64_p37_ring_push(src[i]) != 1:
            i = len            # ring full; stop (the consumer will drain + this
                               # producer would re-write — but the demo fits cap)
        else:
            accepted = accepted + 1
            i = i + 1
    arm64_p37_bytes_written = arm64_p37_bytes_written + accepted

    wm: Ptr[char] = "[arm64] Phase 37: producer pipe_write "
    _uart_puts(wm)
    _uart_puthex(cast[uint64](accepted))
    wm2: Ptr[char] = " bytes (ring count now "
    _uart_puts(wm2)
    _uart_puthex(cast[uint64](arm64_p37_pipe_count))
    wm3: Ptr[char] = ")\n"
    _uart_puts(wm3)

    # If the consumer is blocked waiting on the pipe, deliver + wake it.
    if arm64_p37_state_for(1) == P37_BLOCKED:
        delivered: int64 = arm64_p37_drain_into(1, arm64_p37_pending_buf_va, arm64_p37_pending_len)
        if delivered > 0:
            arm64_p37_bytes_read = arm64_p37_bytes_read + delivered
            cctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p37_ctx_for(1))
            cctx[CTX_X0] = cast[uint64](delivered)   # the woken read() returns this
            _dsb_ish()
            arm64_p37_set_state(1, P37_RUNNABLE)
            arm64_p37_woken_by_write = 1
            km: Ptr[char] = "[arm64] Phase 37: write woke the BLOCKED consumer, delivered "
            _uart_puts(km)
            _uart_puthex(cast[uint64](delivered))
            km2: Ptr[char] = " bytes -> RUNNABLE\n"
            _uart_puts(km2)
    return accepted


# pipe_read(frame_ptr, buf_va, len): if the ring has bytes, drain up to `len` into
# the caller's (consumer's) buffer and return the count (>=1). If the ring is EMPTY
# and the writer has not closed, BLOCK the caller: save its full resume context,
# record its pending read request, mark it BLOCKED, and park its EL0 PC on a self-
# loop so the next timer tick runs the producer. The producer's write delivers the
# bytes + wakes it. Returns 0 only at clean EOF (writer closed AND ring empty).
def arm64_p37_do_pipe_read(frame_ptr: Ptr[uint64], buf_va: uint64, len: int64) -> int64:
    if arm64_p37_pipe_count > 0:
        got: int64 = arm64_p37_drain_into(1, buf_va, len)
        arm64_p37_bytes_read = arm64_p37_bytes_read + got
        frame_ptr[0] = cast[uint64](got)
        return 0

    if arm64_p37_pipe_writer_closed != 0:
        frame_ptr[0] = cast[uint64](0)            # clean EOF
        return 0

    # Empty pipe, writer still open -> BLOCK the consumer (slot 1).
    cur: int64 = arm64_p37_cur

    # Save the caller's full resume context (so it RESUMES past the svc on wake).
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p37_ctx_for(cur))
    i: int64 = 0
    while i < 31:
        ctx[i] = frame_ptr[i]                     # x0..x30 from the saved svc frame
        i = i + 1
    ctx[CTX_X0] = cast[uint64](0)                 # overwritten with the delivered count
    ctx[CTX_SP_EL0] = cast[uint64](_mrs_sp_el0())
    ctx[CTX_ELR] = cast[uint64](_mrs_elr_el1())   # resume PC = insn after the svc
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ                 # EL0t, IRQs on (re-preemptible)
    _dsb_ish()

    # Record the pending read request so a later write delivers straight into the
    # consumer's backing pages.
    arm64_p37_pending_buf_va = buf_va
    arm64_p37_pending_len = len

    arm64_p37_set_state(cur, P37_BLOCKED)
    arm64_p37_reader_blocked = arm64_p37_reader_blocked + 1

    bm: Ptr[char] = "[arm64] Phase 37: consumer pipe_read on EMPTY pipe -> BLOCKED (sleep #"
    _uart_puts(bm)
    _uart_puthex(cast[uint64](arm64_p37_reader_blocked))
    bm2: Ptr[char] = ")\n"
    _uart_puts(bm2)

    # Park the blocked slot's LIVE EL0 PC on a self-loop word in its OWN executable
    # TEXT page so the immediate svc-eret merely spins until the next timer tick
    # preempts it (it makes NO observable progress). CRUCIAL: point arm64_current_ctx
    # at the throwaway park ctx so the preempting IRQ spills the spin state THERE,
    # not over the slot's real (just-saved) resume context.
    park: uint64 = arm64_p37_park_addr(cur)
    _msr_elr_el1(park)
    _isb()
    frame_ptr[0] = cast[uint64](0)
    arm64_current_ctx = P37_PARK_CTX
    return 0


# Materialise a one-instruction self-loop (`b .`) at the end of slot `idx`'s TEXT
# page (an executable EL0 page) and return its EL0 VA. Used to park a blocked
# task's EL0 PC harmlessly until the next timer tick preempts it.
def arm64_p37_park_addr(idx: int64) -> uint64:
    text_pa: uint64 = P37A_TEXT_PA
    text_va: uint64 = P37A_TEXT_VA
    if idx == 1:
        text_pa = P37B_TEXT_PA
        text_va = P37B_TEXT_VA
    off: uint64 = cast[uint64](0xFFC)              # last word of the text page
    _emit_word(text_pa + off, cast[uint64](0x14000000))   # b . (self-loop)
    _dsb_ish()
    _isb()
    return text_va + off


# report(check-id, buf_va, len/value): the consumer reports the bytes it received
# through the pipe; the kernel cross-checks them byte-for-byte against the known
# producer sequence (so the consumer cannot fake a PASS). Returns 1 if they match.
def arm64_p37_do_report(chk: uint64, buf_va: uint64, val: uint64) -> int64:
    if chk == P37_CHK_PIPE:
        if cast[int64](val) != P37_PROD_LEN:
            return 0
        ub: Ptr[uint8] = cast[Ptr[uint8]](buf_va)
        ok: int64 = 1
        i: int64 = 0
        while i < P37_PROD_LEN:
            if ub[i] != arm64_p37_prod_byte(i):
                ok = 0
            i = i + 1
        if ok != 0:
            arm64_p37_rt_ok = 1
        return ok
    return 0


# exit(status): mark the caller EXITED (the scheduler reaps it). If the producer
# exits, mark the pipe writer closed so a future empty read returns clean EOF.
def arm64_p37_do_exit(frame_ptr: Ptr[uint64], status: uint64) -> int64:
    cur: int64 = arm64_p37_cur
    if cur == 0:
        arm64_p37_exit0 = status
        arm64_p37_prod_exited = 1
        arm64_p37_pipe_writer_closed = 1
    else:
        arm64_p37_exit1 = status
        arm64_p37_cons_exited = 1
    arm64_p37_set_state(cur, P37_EXITED)

    em: Ptr[char] = "[arm64] Phase 37: "
    _uart_puts(em)
    if cur == 0:
        pn: Ptr[char] = "producer"
        _uart_puts(pn)
    else:
        cn: Ptr[char] = "consumer"
        _uart_puts(cn)
    em2: Ptr[char] = " exit(status="
    _uart_puts(em2)
    _uart_puthex(status)
    em3: Ptr[char] = ") -> EXITED\n"
    _uart_puts(em3)

    # Park the exiting task's EL0 PC on a self-loop so the immediate svc-eret spins
    # until the next timer tick reaps it. Redirect arm64_current_ctx to the park
    # ctx so the preempting IRQ does not clobber anything meaningful.
    park: uint64 = arm64_p37_park_addr(cur)
    _msr_elr_el1(park)
    _isb()
    frame_ptr[0] = cast[uint64](0)
    arm64_current_ctx = P37_PARK_CTX
    return 0


# Phase-37 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. Services the blocking-pipe ABI (pipe_write / pipe_read / report / exit).
def arm64_p37_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_P37_PIPE_WRITE:
        n: int64 = arm64_p37_do_pipe_write(a0, cast[int64](a1))
        frame_ptr[0] = cast[uint64](n)
        return 0
    if nr == SYS_P37_PIPE_READ:
        return arm64_p37_do_pipe_read(frame_ptr, a0, cast[int64](a1))
    if nr == SYS_P37_REPORT:
        r: int64 = arm64_p37_do_report(a0, a1, a2)
        frame_ptr[0] = cast[uint64](r)
        return 0
    if nr == SYS_P37_EXIT:
        return arm64_p37_do_exit(frame_ptr, a0)

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 37)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Pick the next non-BLOCKED, non-DEAD slot after `from_idx`, round-robin over the
# two slots. A BLOCKED slot is SKIPPED (tallied — proof the blocked reader is
# genuinely passed over). Returns -1 if neither slot is runnable this tick.
def arm64_p37_next_runnable(from_idx: int64) -> int64:
    steps: int64 = 0
    idx: int64 = from_idx
    while steps < 2:
        idx = idx + 1
        if idx >= 2:
            idx = 0
        st: int64 = arm64_p37_state_for(idx)
        if st == P37_RUNNABLE:
            return idx
        if st == P37_BLOCKED:
            arm64_p37_skips = arm64_p37_skips + 1
        steps = steps + 1
    return -1


# Reap any EXITED slot (EXITED -> DEAD). Returns the number of slots reaped.
def arm64_p37_reap() -> int64:
    reaped: int64 = 0
    idx: int64 = 0
    while idx < 2:
        if arm64_p37_state_for(idx) == P37_EXITED:
            arm64_p37_set_state(idx, P37_DEAD)
            reaped = reaped + 1
        idx = idx + 1
    return reaped


# Phase-37 timer-IRQ scheduler. Ack/re-arm the timer, EOI, advance the logical
# tick, REAP any EXITED slot, and if both processes are DEAD run the verdict. A
# BLOCKED reader is NEVER woken here (only a peer write wakes it) — it is skipped.
# Round-robin to the next runnable slot, swap TTBR0+ASID into it, return its ctx.
def arm64_p37_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this slot
        return cur_ctx

    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_p37_tick = arm64_p37_tick + 1

    # Reap any process that called exit (EXITED -> DEAD).
    arm64_p37_reap()

    # Both processes done -> verdict.
    if arm64_p37_state_for(0) == P37_DEAD:
        if arm64_p37_state_for(1) == P37_DEAD:
            arm64_p37_finish()
            while True:
                _wfi()

    # Safety: a runaway tick budget ends the demo (prevents an infinite boot if a
    # logic bug ever leaves both processes wedged). Generous so the real workload
    # always completes first.
    if arm64_p37_tick >= 4000:
        arm64_p37_finish()
        while True:
            _wfi()

    nxt: int64 = arm64_p37_next_runnable(arm64_p37_cur)
    if nxt < 0:
        # No runnable slot this tick (e.g. the consumer is BLOCKED and the producer
        # has already exited+been reaped — shouldn't persist; the next tick's reap/
        # verdict resolves it). Stay on the current parked ctx and idle.
        return cur_ctx

    arm64_p37_switches = arm64_p37_switches + 1
    arm64_p37_cur = nxt
    arm64_p37_switch_to(nxt)
    next_ctx: uint64 = arm64_p37_ctx_for(nxt)
    arm64_current_ctx = next_ctx
    return next_ctx


# Phase-37 verdict. PASS iff: the consumer GENUINELY blocked on the empty pipe at
# least once; the wake was driven by the producer's WRITE (not the timer); the
# producer wrote and the consumer read the full known sequence; the consumer's
# received bytes matched byte-for-byte (kernel-verified); the picker skipped the
# blocked reader at least once; and both processes exited with their expected
# statuses. Prints the summary + PASS marker, then halts (last phase).
def arm64_p37_finish() -> int64:
    arm64_p37_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] Phase 37 summary: bytes_written="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p37_bytes_written))
    s1: Ptr[char] = " bytes_read="
    _uart_puts(s1)
    _uart_puthex(cast[uint64](arm64_p37_bytes_read))
    s2: Ptr[char] = " reader_blocked="
    _uart_puts(s2)
    _uart_puthex(cast[uint64](arm64_p37_reader_blocked))
    s3: Ptr[char] = " woken_by_write="
    _uart_puts(s3)
    _uart_puthex(cast[uint64](arm64_p37_woken_by_write))
    s4: Ptr[char] = " skips="
    _uart_puts(s4)
    _uart_puthex(cast[uint64](arm64_p37_skips))
    s5: Ptr[char] = " switches="
    _uart_puts(s5)
    _uart_puthex(cast[uint64](arm64_p37_switches))
    s6: Ptr[char] = " rt_ok="
    _uart_puts(s6)
    _uart_puthex(cast[uint64](arm64_p37_rt_ok))
    s7: Ptr[char] = " prod_exit="
    _uart_puts(s7)
    _uart_puthex(arm64_p37_exit0)
    s8: Ptr[char] = " cons_exit="
    _uart_puts(s8)
    _uart_puthex(arm64_p37_exit1)
    _uart_puts(nl)

    ok: int64 = 1
    # The consumer genuinely blocked on the empty pipe at least once.
    if arm64_p37_reader_blocked < 1:
        ok = 0
    # The wake was driven by the producer's write, not the timer.
    if arm64_p37_woken_by_write == 0:
        ok = 0
    # The full known sequence round-tripped through the pipe.
    if arm64_p37_bytes_written != P37_PROD_LEN:
        ok = 0
    if arm64_p37_bytes_read != P37_PROD_LEN:
        ok = 0
    # The consumer's received bytes matched the producer's known sequence.
    if arm64_p37_rt_ok == 0:
        ok = 0
    # Both processes exited with their expected statuses.
    if arm64_p37_prod_exited == 0:
        ok = 0
    if arm64_p37_cons_exited == 0:
        ok = 0
    if arm64_p37_exit0 != P37_PROD_EXIT:
        ok = 0
    if arm64_p37_exit1 != P37_CONS_EXIT:
        ok = 0
    # No process left wedged BLOCKED at the verdict.
    if arm64_p37_state_for(1) == P37_BLOCKED:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 37: a real in-kernel ring-buffer pipe carried a known byte sequence between TWO on-disk EL0 processes running concurrently under the preemptive timer scheduler; the consumer genuinely BLOCKED on the empty pipe (descheduled + skipped by the picker) and was woken by the producer's write, then received the sequence byte-for-byte\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 37 PASS: pipe IPC blocking round-trip (consumer blocked on empty pipe, woken by producer write, received the known 24-byte sequence byte-identically)\n"
        _uart_puts(pp)
        # Hand off to Phase 38 (shared-memory IPC between two on-disk EL0 processes)
        # on the SAME live virtio-blk transport. arm64_p38_run never returns (its
        # verdict halts after the shm round-trip).
        arm64_p38_run(arm64_p37_blk_base)
        # Unreachable: arm64_p38_run halts. Safety loop.
        _msr_daifset(2)
        while True:
            _wfi()
    else:
        fp: Ptr[char] = "[arm64] Phase 37 FAIL: blocking-pipe IPC verdict failed\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-37 entry point (hand-off from arm64_p36_finish on a Phase-36 PASS), with
# the live virtio-blk transport `base`. Read PRODA.ELF + CONSB.ELF off the FAT16
# disk, build each process's fresh private EL0 space, load each ELF, init both
# resume contexts, mark both RUNNABLE, then ERET into the producer at EL0t with the
# timer LIVE and IRQs UNMASKED so the timer preempts and both processes run
# concurrently. The consumer blocks on the empty pipe; the producer's write wakes
# it. Never returns (halts at the verdict).
def arm64_p37_run(base: uint64) -> int64:
    intro: Ptr[char] = "[arm64] Phase 37: blocking in-kernel pipe IPC (two on-disk EL0 processes: PRODA + CONSB)\n"
    _uart_puts(intro)
    nl: Ptr[char] = "\n"

    _msr_daifset(2)                              # mask EL1 IRQs while we build
    arm64_p37_blk_base = base
    arm64_p37_cur = 0

    # Reset the pipe + bookkeeping.
    arm64_p37_pipe_head = 0
    arm64_p37_pipe_tail = 0
    arm64_p37_pipe_count = 0
    arm64_p37_pipe_writer_closed = 0
    rb: Ptr[uint8] = cast[Ptr[uint8]](P37_PIPE_BUF_PA)
    z: int64 = 0
    while z < (P37_PIPE_CAP + 1):
        rb[z] = cast[uint8](0)
        z = z + 1

    # Re-parse the FAT16 BPB off sector 0 (fills arm64_p31_* geometry globals).
    if arm64_p30_read_sector_into(base, cast[uint64](0), P31_SEC_PA) != 1:
        fp: Ptr[char] = "[arm64] Phase 37 FAIL: boot-sector read failed\n"
        _uart_puts(fp)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    if arm64_p31_parse_bpb() != 1:
        fp2: Ptr[char] = "[arm64] Phase 37 FAIL: BPB geometry not a supported FAT16\n"
        _uart_puts(fp2)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    # Build + load the PRODUCER (PRODA.ELF, slot 0).
    nm: uint64 = P31_FILE_PA
    np: Ptr[uint8] = cast[Ptr[uint8]](nm)
    # "PRODA   ELF"
    np[0] = cast[uint8](0x50)    # P
    np[1] = cast[uint8](0x52)    # R
    np[2] = cast[uint8](0x4F)    # O
    np[3] = cast[uint8](0x44)    # D
    np[4] = cast[uint8](0x41)    # A
    np[5] = cast[uint8](0x20)
    np[6] = cast[uint8](0x20)
    np[7] = cast[uint8](0x20)
    np[8] = cast[uint8](0x45)    # E
    np[9] = cast[uint8](0x4C)    # L
    np[10] = cast[uint8](0x46)   # F
    flen: int64 = arm64_p37_read_elf(base, nm)
    if flen <= 0:
        fp3: Ptr[char] = "[arm64] Phase 37 FAIL: could not read PRODA.ELF off the FAT16 disk\n"
        _uart_puts(fp3)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    rm: Ptr[char] = "[arm64] Phase 37: read PRODA.ELF off disk ("
    _uart_puts(rm)
    _uart_puthex(cast[uint64](flen))
    rm2: Ptr[char] = " bytes); building producer EL0 space\n"
    _uart_puts(rm2)
    arm64_p37_build_space(0)
    arm64_p37_switch_to(0)
    entry_a: uint64 = arm64_p37_load_elf(0)
    if entry_a == cast[uint64](0):
        fp4: Ptr[char] = "[arm64] Phase 37 FAIL: PRODA.ELF failed header/phdr validation\n"
        _uart_puts(fp4)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    arm64_p37_init_ctx(0, entry_a)
    arm64_p37_set_state(0, P37_RUNNABLE)

    # Build + load the CONSUMER (CONSB.ELF, slot 1).
    np[0] = cast[uint8](0x43)    # C
    np[1] = cast[uint8](0x4F)    # O
    np[2] = cast[uint8](0x4E)    # N
    np[3] = cast[uint8](0x53)    # S
    np[4] = cast[uint8](0x42)    # B
    np[5] = cast[uint8](0x20)
    np[6] = cast[uint8](0x20)
    np[7] = cast[uint8](0x20)
    np[8] = cast[uint8](0x45)    # E
    np[9] = cast[uint8](0x4C)    # L
    np[10] = cast[uint8](0x46)   # F
    flen2: int64 = arm64_p37_read_elf(base, nm)
    if flen2 <= 0:
        fp5: Ptr[char] = "[arm64] Phase 37 FAIL: could not read CONSB.ELF off the FAT16 disk\n"
        _uart_puts(fp5)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    rm3: Ptr[char] = "[arm64] Phase 37: read CONSB.ELF off disk ("
    _uart_puts(rm3)
    _uart_puthex(cast[uint64](flen2))
    rm4: Ptr[char] = " bytes); building consumer EL0 space\n"
    _uart_puts(rm4)
    arm64_p37_build_space(1)
    arm64_p37_switch_to(1)
    entry_b: uint64 = arm64_p37_load_elf(1)
    if entry_b == cast[uint64](0):
        fp6: Ptr[char] = "[arm64] Phase 37 FAIL: CONSB.ELF failed header/phdr validation\n"
        _uart_puts(fp6)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    arm64_p37_init_ctx(1, entry_b)
    arm64_p37_set_state(1, P37_RUNNABLE)

    arm64_p37_active = 1

    em: Ptr[char] = "[arm64] Phase 37: launching producer PRODA (ASID 26) + consumer CONSB (ASID 27) concurrently under the timer; entry_a="
    _uart_puts(em)
    _uart_puthex(entry_a)
    em2: Ptr[char] = " entry_b="
    _uart_puts(em2)
    _uart_puthex(entry_b)
    _uart_puts(nl)

    # Start the CONSUMER (slot 1) running FIRST so it reaches its pipe_read on the
    # still-EMPTY pipe and GENUINELY BLOCKS before the producer ever writes — a
    # deterministic blocking ordering. The blocked consumer is then descheduled and
    # the round-robin picker dispatches the producer, whose pipe_write fills the ring
    # and wakes the consumer. ERET with IRQs UNMASKED so the timer round-robins both.
    arm64_p37_cur = 1
    arm64_p37_switch_to(1)
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p37_ctx_for(1))
    arm64_current_ctx = arm64_p37_ctx_for(1)
    # Re-arm the timer but keep EL1 IRQs MASKED until the ERET. The consumer's ctx
    # SPSR (SPSR_EL0T_IRQ) has IRQs UNMASKED, so the ERET atomically drops to EL0
    # with the timer live; any pending tick fires in EL0 (-> arm64_sched_pick), NOT
    # in EL1 (which would hit the Phase-3 handler and restart the phase sequence).
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                      # -> EL0; both processes run
    # Unreachable: the verdict halts.
    while True:
        _wfi()
    return 0


# ===========================================================================
# Phase 38 — REAL SHARED-MEMORY IPC between TWO on-disk EL0 user processes
# running CONCURRENTLY under the live preemptive timer scheduler on qemu-virt.
#
# This complements Phase 37's blocking pipe with a second, ZERO-COPY IPC
# mechanism: a SHARED anonymous physical region (one page of RAM) mapped into
# BOTH the producer's and the consumer's PRIVATE EL0 address spaces at the same
# EL0 VA — but each through its OWN page tables (own L1/L2/L3 + ASID). A write
# by one process is observed by the other because both virtual mappings resolve
# to the SAME physical frame (P38_SHM_PA), NOT a copy.
#
# Two on-disk ELF64 programs are loaded off the live FAT16 disk, each into its
# OWN private ASID-tagged EL0 space (built fresh for Phase 38, mirroring the
# Phase-37 loader shape with distinct PA backing + ASIDs):
#
#   PRODA38.ELF (producer, slot 0): shm_get() to obtain the shared region,
#     shm_attach() to map it into its OWN EL0 space, writes a known
#     P38_SHM_LEN-byte sequence into the shared region, signal()s the consumer
#     (which wakes a blocked waiter), then exit()s.
#   CONSB38.ELF (consumer, slot 1): shm_get() + shm_attach() (its OWN mapping of
#     the SAME physical frame), wait()s on the shm-ready flag — on an unsignalled
#     flag the consumer GENUINELY BLOCKS (descheduled, marked BLOCKED, parked on a
#     self-loop, SKIPPED by the round-robin picker, NOT spinning) until the
#     producer's signal wakes it; then it reads P38_SHM_LEN bytes from ITS OWN shm
#     VA mapping, report()s them (the kernel cross-checks them byte-for-byte
#     against the producer's known sequence) and exit()s.
#
# This is GENUINE shared memory, NOT a faked round-trip:
#   * The two processes have INDEPENDENT page tables; the shared page is mapped
#     into each via that process's OWN private shm L3 table, both PTEs pointing
#     at P38_SHM_PA. The kernel asserts (at attach AND at the verdict) that the
#     producer's shm-VA and the consumer's shm-VA both translate to P38_SHM_PA.
#   * The consumer reads the value AFTER both attached AND after the producer
#     wrote it (the producer's write happens-before the consumer's read because
#     the consumer is gated by the blocking signal/wait — no reliance on luck).
#   * The bytes the consumer reports must equal the producer's known sequence
#     byte-for-byte (kernel-verified), else FAIL.
#
# Both processes run preemptively: the EL1 generic-timer IRQ round-robins the two
# slots' private (TTBR0+ASID) spaces, here extended with a shm-wait BLOCKED state
# and an EXITED/reaped state (same scheduler shape as Phase 37).
#
# EL0 syscalls added/wired for Phase 38 (free numbers, documented here):
#   SYS_P38_SHM_GET    (720): a0 = key (ignored; single region). Obtain/create the
#                             shared region. Returns a shm-id (0).
#   SYS_P38_SHM_ATTACH (721): a0 = shmid. Map the shared physical region into the
#                             CALLER's OWN EL0 space at P38_SHM_VA (stamp the
#                             caller's private shm L3 PTE -> P38_SHM_PA). Returns
#                             the EL0 VA the region is attached at.
#   SYS_P38_SIGNAL     (722): a0 = value. Producer publishes the shm-ready flag and
#                             WAKES a blocked waiter (BLOCKED -> RUNNABLE).
#   SYS_P38_WAIT       (723): If the shm-ready flag is already set, return it. Else
#                             BLOCK the caller until a signal wakes it (then return
#                             the flag). The blocked waiter is descheduled + parked.
#   SYS_P38_REPORT     (724): a0 = check-id, a1 = buf VA, a2 = len. The consumer
#                             reports the bytes it read out of its OWN shm mapping;
#                             the kernel confirms they equal the producer sequence.
#   SYS_P38_EXIT       (725): a0 = status. Mark the caller EXITED (scheduler reaps);
#                             when both processes are DEAD, run the verdict.
#
# Fresh RAM regions (clear of every prior phase's blocks). EL1-only page tables +
# context blocks live in free EL1 RAM above the Phase-37 region (P37 ends at the
# P37_PARK_CTX page <=0x401E_0FFF) and below the EL0 window (0x4020_0000). Data PA
# backing lives above Phase 37's top block (P37 ring buf at 0x4559_0000), starting
# at 0x455A_0000. The SHARED frame is P38_SHM_PA (0x455D_0000).
# ===========================================================================

# --- Phase-38 fresh RAM region (clear of P37 <=0x4559_xxxx) ----------------
P38_FILE_PA: uint64 = 0x455A0000             # raw on-disk ELF bytes (producer/consumer)
P38_FILE_CAP: int64 = 8192                   # max ELF file bytes we read

# Producer (PRODA38.ELF) private EL0 space. Reuses the Phase-36/37 program-A
# segment VAs (valid EL0 VAs) but with distinct PA backing + page tables + ASID.
P38A_TEXT_VA: uint64 = 0x42600000
P38A_DATA_VA: uint64 = 0x42800000
P38A_STACK_VA: uint64 = 0x42A00000
P38A_TEXT_L2_INDEX: uint64 = 19              # (0x4260_0000 - 0x4000_0000) / 2 MiB
P38A_DATA_L2_INDEX: uint64 = 20
P38A_STACK_L2_INDEX: uint64 = 21
P38A_STACK_TOP: uint64 = 0x42A01000
P38A_ASID: uint64 = 28                       # distinct from every prior ASID

# Consumer (CONSB38.ELF) private EL0 space. DISTINCT segment VAs (a different
# 2 MiB window) so the demand-fault handler attributes faults unambiguously.
P38B_TEXT_VA: uint64 = 0x42C00000
P38B_DATA_VA: uint64 = 0x42E00000
P38B_STACK_VA: uint64 = 0x43000000
P38B_TEXT_L2_INDEX: uint64 = 22             # (0x42C0_0000 - 0x4000_0000) / 2 MiB
P38B_DATA_L2_INDEX: uint64 = 23
P38B_STACK_L2_INDEX: uint64 = 24
P38B_STACK_TOP: uint64 = 0x43001000
P38B_ASID: uint64 = 29

# The SHARED EL0 VA. BOTH processes attach the shared frame at this SAME VA, each
# through its own private shm L3 table (a distinct 2 MiB window, L2 index 26 =
# (0x4340_0000 - 0x4000_0000) / 2 MiB). The two PTEs both point at P38_SHM_PA.
P38_SHM_VA: uint64 = 0x43400000
P38_SHM_L2_INDEX: uint64 = 26
P38_SHM_PA: uint64 = 0x455D0000              # the ONE shared physical frame
P38_SHM_LEN: int64 = 28                      # known sequence length

# Per-slot EL1-only page tables (L1/L2 + four L3: text/data/stack/shm) + context
# blocks, in free EL1 RAM above the Phase-37 region (<=0x401E_0FFF) and below
# 0x4020_0000.
P38A_L1: uint64 = 0x401E1000
P38A_L2: uint64 = 0x401E2000
P38A_TEXT_L3: uint64 = 0x401E3000
P38A_DATA_L3: uint64 = 0x401E4000
P38A_STACK_L3: uint64 = 0x401E5000
P38A_SHM_L3: uint64 = 0x401E6000
P38B_L1: uint64 = 0x401E7000
P38B_L2: uint64 = 0x401E8000
P38B_TEXT_L3: uint64 = 0x401E9000
P38B_DATA_L3: uint64 = 0x401EA000
P38B_STACK_L3: uint64 = 0x401EB000
P38B_SHM_L3: uint64 = 0x401EC000
P38A_CTX: uint64 = 0x401ED000                # 34 x 8-byte resume-context slots
P38B_CTX: uint64 = 0x401EE000
P38_PARK_CTX: uint64 = 0x401EF000            # throwaway ctx for a parked blocked task

# Data PA backing for the two processes' segments + stacks.
P38A_TEXT_PA: uint64 = 0x455B0000
P38A_DATA_PA: uint64 = 0x455B1000
P38A_STACK_PA: uint64 = 0x455B2000
P38B_TEXT_PA: uint64 = 0x455C0000
P38B_DATA_PA: uint64 = 0x455C1000
P38B_STACK_PA: uint64 = 0x455C2000

# W^X page permissions (identical encoding to Phase 37).
P38_PAGE_RX: uint64 = 0x7C7
P38_PAGE_RW: uint64 = 0x40000000000747
P38_PAGE_RO: uint64 = 0x400000000007C7

# Phase-38 EL0 syscall numbers (free; documented in the header above).
SYS_P38_SHM_GET: uint64 = 720
SYS_P38_SHM_ATTACH: uint64 = 721
SYS_P38_SIGNAL: uint64 = 722
SYS_P38_WAIT: uint64 = 723
SYS_P38_REPORT: uint64 = 724
SYS_P38_EXIT: uint64 = 725

# check-id for SYS_P38_REPORT.
P38_CHK_SHM: uint64 = 0                       # consumer reports the bytes it read

# Task-state model (reuse the Phase-37 numbering).
P38_RUNNABLE: int64 = 1
P38_BLOCKED: int64 = 2
P38_EXITED: int64 = 3
P38_DEAD: int64 = 4

# The known P38_SHM_LEN-byte sequence the producer writes into the shared region
# (position-coded). The kernel verifies the consumer read exactly this.
def arm64_p38_shm_byte(i: int64) -> uint8:
    return cast[uint8]((0x31 + (i * 11)) & 0x7F)

# Expected exit statuses (the verdict asserts these are observed).
P38_PROD_EXIT: uint64 = 0x55                 # 85 — producer's exit status
P38_CONS_EXIT: uint64 = 0x66                 # 102 — consumer's exit status

# The shm-ready flag: set by the producer's signal(), read by the consumer's
# wait(). A live waiter blocked on an unsignalled flag is woken by signal().
arm64_p38_shm_flag: uint64 = 0
arm64_p38_shm_flag_set: int64 = 0

# --- Phase-38 bookkeeping --------------------------------------------------
arm64_p38_active: int64 = 0
arm64_p38_cur: int64 = 0                      # live slot (0 = producer, 1 = consumer)
arm64_p38_tick: int64 = 0                     # logical scheduler tick
arm64_p38_switches: int64 = 0                 # TTBR0+ASID swaps performed
arm64_p38_waiter_blocked: int64 = 0           # times the consumer slept on the flag
arm64_p38_woken_by_signal: int64 = 0          # set when a signal woke the blocked waiter
arm64_p38_skips: int64 = 0                    # times the picker passed over a BLOCKED slot
arm64_p38_blk_base: uint64 = 0

# Per-slot state.
arm64_p38_state0: int64 = 0
arm64_p38_state1: int64 = 0
arm64_p38_exit0: uint64 = 0xFFFF
arm64_p38_exit1: uint64 = 0xFFFF

# shm attach bookkeeping (proof both mappings resolve to the SAME physical frame).
arm64_p38_a_attached: int64 = 0
arm64_p38_b_attached: int64 = 0
arm64_p38_a_attach_pa: uint64 = 0             # producer's shm-VA -> PA at attach time
arm64_p38_b_attach_pa: uint64 = 0             # consumer's shm-VA -> PA at attach time

# Per-process segment + shm fault accounting.
arm64_p38_a_text_faults: int64 = 0
arm64_p38_a_data_faults: int64 = 0
arm64_p38_a_shm_faults: int64 = 0
arm64_p38_b_text_faults: int64 = 0
arm64_p38_b_data_faults: int64 = 0
arm64_p38_b_shm_faults: int64 = 0

# Verdict evidence.
arm64_p38_prod_wrote: int64 = 0               # producer wrote the known sequence
arm64_p38_rt_ok: int64 = 0                    # consumer's read bytes matched
arm64_p38_same_frame: int64 = 0               # both attach PAs == P38_SHM_PA
arm64_p38_prod_exited: int64 = 0
arm64_p38_cons_exited: int64 = 0


# ---- per-slot accessors (idx: 0 = producer, 1 = consumer) -----------------
def arm64_p38_state_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p38_state0
    return arm64_p38_state1

def arm64_p38_set_state(idx: int64, st: int64) -> int64:
    if idx == 0:
        arm64_p38_state0 = st
    else:
        arm64_p38_state1 = st
    return 0

def arm64_p38_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P38A_CTX
    return P38B_CTX

def arm64_p38_shm_l3_for(idx: int64) -> uint64:
    if idx == 0:
        return P38A_SHM_L3
    return P38B_SHM_L3


# Build process `prog` (0=producer,1=consumer)'s fresh private EL0 address space
# (L1/L2 + FOUR 2 MiB slots redirected to private L3 tables: text/data/stack/shm)
# and wire its EL0 stack page RW. The shm slot's L3 is CLEARED here (NOT mapped);
# the shared frame is stamped later, on demand, by SYS_P38_SHM_ATTACH — so each
# process maps the shared frame through its OWN page tables. Mirrors
# arm64_p37_build_space over the Phase-38 globals + the extra shm slot.
def arm64_p38_build_space(prog: int64) -> int64:
    l1_base: uint64 = P38A_L1
    l2_base: uint64 = P38A_L2
    text_l3: uint64 = P38A_TEXT_L3
    data_l3: uint64 = P38A_DATA_L3
    stack_l3: uint64 = P38A_STACK_L3
    shm_l3: uint64 = P38A_SHM_L3
    text_l2i: uint64 = P38A_TEXT_L2_INDEX
    data_l2i: uint64 = P38A_DATA_L2_INDEX
    stack_l2i: uint64 = P38A_STACK_L2_INDEX
    stack_va: uint64 = P38A_STACK_VA
    stack_pa: uint64 = P38A_STACK_PA
    if prog == 1:
        l1_base = P38B_L1
        l2_base = P38B_L2
        text_l3 = P38B_TEXT_L3
        data_l3 = P38B_DATA_L3
        stack_l3 = P38B_STACK_L3
        shm_l3 = P38B_SHM_L3
        text_l2i = P38B_TEXT_L2_INDEX
        data_l2i = P38B_DATA_L2_INDEX
        stack_l2i = P38B_STACK_L2_INDEX
        stack_va = P38B_STACK_VA
        stack_pa = P38B_STACK_PA

    l1: Ptr[uint64] = cast[Ptr[uint64]](l1_base)
    l2: Ptr[uint64] = cast[Ptr[uint64]](l2_base)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1
    l1[0] = cast[uint64](0) | DEV_FLAGS

    tl3: Ptr[uint64] = cast[Ptr[uint64]](text_l3)
    dl3: Ptr[uint64] = cast[Ptr[uint64]](data_l3)
    sl3: Ptr[uint64] = cast[Ptr[uint64]](stack_l3)
    hl3: Ptr[uint64] = cast[Ptr[uint64]](shm_l3)
    k: int64 = 0
    while k < 512:
        tl3[k] = cast[uint64](0)
        dl3[k] = cast[uint64](0)
        sl3[k] = cast[uint64](0)
        hl3[k] = cast[uint64](0)
        k = k + 1

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == text_l2i:
            l2[j] = text_l3 | DESC_TABLE
        elif cast[uint64](j) == data_l2i:
            l2[j] = data_l3 | DESC_TABLE
        elif cast[uint64](j) == stack_l2i:
            l2[j] = stack_l3 | DESC_TABLE
        elif cast[uint64](j) == P38_SHM_L2_INDEX:
            l2[j] = shm_l3 | DESC_TABLE
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = l2_base | DESC_TABLE
    _dsb_ish()

    # Wire the EL0 stack page (RW non-exec).
    sidx: uint64 = (stack_va >> cast[uint64](12)) & cast[uint64](0x1FF)
    sl3[cast[int64](sidx)] = stack_pa | P38_PAGE_RW
    sp: Ptr[uint64] = cast[Ptr[uint64]](stack_pa)
    z: int64 = 0
    while z < 512:
        sp[z] = cast[uint64](0)
        z = z + 1
    _dsb_ish()
    return 0


# Map [seg_va, seg_va+filesz) onto seg_pa with page_flags in its 2 MiB slot's
# private L3, copying p_filesz bytes from the Phase-38 ELF file buffer. The backing
# page is pre-cleared (BSS reads zero). Identical shape to arm64_p37_map_segment.
def arm64_p38_map_segment(seg_va: uint64, seg_pa: uint64, foff: uint64, filesz: uint64, l3_base: uint64, page_flags: uint64) -> int64:
    pg: Ptr[uint8] = cast[Ptr[uint8]](seg_pa)
    c: int64 = 0
    while c < cast[int64](P26_PAGE_SIZE):
        pg[c] = cast[uint8](0)
        c = c + 1
    fbuf: Ptr[uint8] = cast[Ptr[uint8]](P38_FILE_PA)
    n: uint64 = cast[uint64](0)
    while n < filesz:
        pg[cast[int64](n)] = fbuf[cast[int64](foff + n)]
        n = n + cast[uint64](1)
    _dsb_ish()
    l3: Ptr[uint64] = cast[Ptr[uint64]](l3_base)
    idx: uint64 = (seg_va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3[cast[int64](idx)] = seg_pa | page_flags
    _dsb_ish()
    _isb()
    return 0


# Little-endian readers out of the Phase-38 ELF file buffer.
def _p38_rd16(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P38_FILE_PA)
    b0: uint64 = cast[uint64](p[cast[int64](off)])
    b1: uint64 = cast[uint64](p[cast[int64](off + cast[uint64](1))])
    return b0 | (b1 << cast[uint64](8))


def _p38_rd32(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P38_FILE_PA)
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 4:
        r = r | (cast[uint64](p[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


def _p38_rd64(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P38_FILE_PA)
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 8:
        r = r | (cast[uint64](p[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


def arm64_p38_flags_for(pflags: uint64) -> uint64:
    if (pflags & PF_W) != cast[uint64](0):
        return P38_PAGE_RW
    if (pflags & PF_X) != cast[uint64](0):
        return P38_PAGE_RX
    return P38_PAGE_RO


# Read the on-disk ELF named by the 11-byte name at `name_pa` off the live FAT16
# volume into P38_FILE_PA (following its cluster chain). Returns byte length, or
# -1 on not-found / read error. Mirrors arm64_p37_read_elf over P38_FILE_PA.
def arm64_p38_read_elf(base: uint64, name_pa: uint64) -> int64:
    loc: int64 = arm64_p36_locate(base, name_pa)
    if loc != 1:
        return -1
    first_clus: int64 = arm64_p36_loc_first_clus
    file_size: int64 = arm64_p36_loc_size
    if first_clus < 2:
        return -1
    sec_per_clus: int64 = arm64_p31_sec_per_clus
    dst_off: int64 = 0
    want_len: int64 = file_size
    clus: int64 = first_clus
    guard: int64 = 0
    dst: Ptr[uint8] = cast[Ptr[uint8]](P38_FILE_PA)
    src: Ptr[uint8] = cast[Ptr[uint8]](P31_SEC_PA)
    while clus >= 2 and clus < 0xFFF8 and dst_off < want_len:
        guard = guard + 1
        if guard > 4096:
            return -1
        clus_lba: int64 = arm64_p31_data_lba + ((clus - 2) * sec_per_clus)
        sc: int64 = 0
        while sc < sec_per_clus:
            if dst_off < want_len:
                if arm64_p30_read_sector_into(base, cast[uint64](clus_lba + sc), P31_SEC_PA) != 1:
                    return -1
                take: int64 = arm64_p31_bytes_per_sec
                if dst_off + take > want_len:
                    take = want_len - dst_off
                i: int64 = 0
                while i < take:
                    if dst_off < P38_FILE_CAP:
                        dst[dst_off] = src[i]
                        dst_off = dst_off + 1
                    else:
                        i = take
                    i = i + 1
            sc = sc + 1
        nxt: int64 = arm64_p31_fat_next(base, clus)
        if nxt < 0:
            return -1
        clus = nxt
    return dst_off


# Parse + load the on-disk ELF64 in P38_FILE_PA into process `prog`'s space. Same
# validation/phdr walk as arm64_p37_load_elf. Returns e_entry, or 0 on failure.
def arm64_p38_load_elf(prog: int64) -> uint64:
    fbuf: Ptr[uint8] = cast[Ptr[uint8]](P38_FILE_PA)
    nl: Ptr[char] = "\n"

    if cast[uint64](fbuf[0]) != ELF_EI_MAG0:
        return cast[uint64](0)
    if cast[uint64](fbuf[1]) != ELF_EI_MAG1:
        return cast[uint64](0)
    if cast[uint64](fbuf[2]) != ELF_EI_MAG2:
        return cast[uint64](0)
    if cast[uint64](fbuf[3]) != ELF_EI_MAG3:
        return cast[uint64](0)
    if cast[uint64](fbuf[4]) != ELFCLASS64:
        return cast[uint64](0)
    if cast[uint64](fbuf[5]) != ELFDATA2LSB:
        return cast[uint64](0)

    e_type: uint64 = _p38_rd16(EH_TYPE)
    e_machine: uint64 = _p38_rd16(EH_MACHINE)
    e_entry: uint64 = _p38_rd64(EH_ENTRY)
    e_phoff: uint64 = _p38_rd64(EH_PHOFF)
    e_phentsize: uint64 = _p38_rd16(EH_PHENTSIZE)
    e_phnum: uint64 = _p38_rd16(EH_PHNUM)

    if e_type != ET_EXEC:
        return cast[uint64](0)
    if e_machine != EM_AARCH64:
        return cast[uint64](0)

    text_va: uint64 = P38A_TEXT_VA
    data_va: uint64 = P38A_DATA_VA
    text_pa: uint64 = P38A_TEXT_PA
    data_pa: uint64 = P38A_DATA_PA
    text_l3: uint64 = P38A_TEXT_L3
    data_l3: uint64 = P38A_DATA_L3
    if prog == 1:
        text_va = P38B_TEXT_VA
        data_va = P38B_DATA_VA
        text_pa = P38B_TEXT_PA
        data_pa = P38B_DATA_PA
        text_l3 = P38B_TEXT_L3
        data_l3 = P38B_DATA_L3

    hm: Ptr[char] = "[arm64] Phase 38 ELF: prog="
    _uart_puts(hm)
    _uart_puthex(cast[uint64](prog))
    hm2: Ptr[char] = " entry="
    _uart_puts(hm2)
    _uart_puthex(e_entry)
    hm3: Ptr[char] = " phnum="
    _uart_puts(hm3)
    _uart_puthex(e_phnum)
    _uart_puts(nl)

    segs: int64 = 0
    ph: uint64 = 0
    while ph < e_phnum:
        b: uint64 = e_phoff + (ph * e_phentsize)
        p_type: uint64 = _p38_rd32(b + PH_TYPE)
        if p_type == PT_LOAD:
            p_flags: uint64 = _p38_rd32(b + PH_FLAGS)
            p_offset: uint64 = _p38_rd64(b + PH_OFFSET)
            p_vaddr: uint64 = _p38_rd64(b + PH_VADDR)
            p_filesz: uint64 = _p38_rd64(b + PH_FILESZ)
            page_flags: uint64 = arm64_p38_flags_for(p_flags)

            seg_pa: uint64 = cast[uint64](0)
            l3_base: uint64 = cast[uint64](0)
            if p_vaddr == text_va:
                seg_pa = text_pa
                l3_base = text_l3
            elif p_vaddr == data_va:
                seg_pa = data_pa
                l3_base = data_l3
            else:
                return cast[uint64](0)

            arm64_p38_map_segment(p_vaddr, seg_pa, p_offset, p_filesz, l3_base, page_flags)
            segs = segs + 1
        ph = ph + cast[uint64](1)

    if segs < 1:
        return cast[uint64](0)
    return e_entry


# TTBR0_EL1 for process `prog`: its private L1 root + its ASID in bits[63:48].
def arm64_p38_ttbr0_for(prog: int64) -> uint64:
    if prog == 1:
        return P38B_L1 | (P38B_ASID << P23_ASID_SHIFT)
    return P38A_L1 | (P38A_ASID << P23_ASID_SHIFT)


# Recycle process `prog`'s ASID and make its private TTBR0 live.
def arm64_p38_switch_to(prog: int64) -> int64:
    asid: uint64 = P38A_ASID
    if prog == 1:
        asid = P38B_ASID
    _dsb_ish()
    _tlbi_aside1is(asid << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()
    _msr_ttbr0_el1(arm64_p38_ttbr0_for(prog))
    _dsb_ish()
    _tlbi_aside1is(asid << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()
    return 0


# Initialise process `prog`'s resume-context block for a clean first ERET into its
# entry, on its own EL0 stack, in EL0t with IRQs UNMASKED (so the timer preempts).
def arm64_p38_init_ctx(prog: int64, entry: uint64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p38_ctx_for(prog))
    i: int64 = 0
    while i < 34:
        ctx[i] = cast[uint64](0)
        i = i + 1
    stack_top: uint64 = P38A_STACK_TOP
    if prog == 1:
        stack_top = P38B_STACK_TOP
    ctx[CTX_SP_EL0] = stack_top
    ctx[CTX_ELR] = entry
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ
    return 0


# Phase-38 demand-fault entry. A first touch of a loaded segment page (text/data/
# stack) OR of the attached SHARED page of the LIVE process takes a translation
# fault (loader/attach pre-stamped the PTE). Confirm the VA lies in a mapped page
# of the current process, account it, flush the VA, and resume (return 1);
# anything else -> 0 (fall through to the fatal-fault reaper).
def arm64_p38_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0
    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    in_seg: int64 = 0
    if arm64_p38_cur == 0:
        if page_va == P38A_TEXT_VA:
            arm64_p38_a_text_faults = arm64_p38_a_text_faults + 1
            in_seg = 1
        elif page_va == P38A_DATA_VA:
            arm64_p38_a_data_faults = arm64_p38_a_data_faults + 1
            in_seg = 1
        elif page_va == P38_SHM_VA:
            arm64_p38_a_shm_faults = arm64_p38_a_shm_faults + 1
            in_seg = 1
    else:
        if page_va == P38B_TEXT_VA:
            arm64_p38_b_text_faults = arm64_p38_b_text_faults + 1
            in_seg = 1
        elif page_va == P38B_DATA_VA:
            arm64_p38_b_data_faults = arm64_p38_b_data_faults + 1
            in_seg = 1
        elif page_va == P38_SHM_VA:
            arm64_p38_b_shm_faults = arm64_p38_b_shm_faults + 1
            in_seg = 1
    if in_seg == 0:
        return 0

    _dsb_ish()
    _tlbi_vaae1is(page_va >> cast[uint64](12))
    _dsb_ish()
    _isb()
    return 1


# Translate the shm VA in slot `idx` to the physical frame the slot's private shm
# L3 actually maps it to (reads the live PTE). Returns 0 if the shm page is not
# mapped in that slot. Used to PROVE both private mappings resolve to P38_SHM_PA.
def arm64_p38_shm_va_to_pa(idx: int64) -> uint64:
    l3: Ptr[uint64] = cast[Ptr[uint64]](arm64_p38_shm_l3_for(idx))
    sidx: uint64 = (P38_SHM_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    pte: uint64 = l3[cast[int64](sidx)]
    if (pte & cast[uint64](0x1)) == cast[uint64](0):
        return cast[uint64](0)                    # not valid -> not mapped
    # The output-address field of a stage-1 page descriptor is bits[47:12]; the
    # upper attribute bits (UXN/PXN etc, set by P38_PAGE_RW) and the low 12 attr
    # bits must both be masked off to recover the physical frame address.
    return pte & cast[uint64](0x0000FFFFFFFFF000)


# ---- Phase-38 EL0 syscall handlers ----------------------------------------

# shm_get(key): obtain/create the single shared region. Returns shm-id 0.
def arm64_p38_do_shm_get(key: uint64) -> int64:
    return 0


# shm_attach(shmid): map the shared physical frame P38_SHM_PA into the CALLER's OWN
# EL0 space at P38_SHM_VA by stamping the caller's PRIVATE shm L3 PTE (RW). Both
# processes attach the SAME frame through their OWN page tables. Records the PA the
# caller's mapping resolves to (proof it is the shared frame). Returns the EL0 VA.
def arm64_p38_do_shm_attach(shmid: uint64) -> uint64:
    cur: int64 = arm64_p38_cur
    l3: Ptr[uint64] = cast[Ptr[uint64]](arm64_p38_shm_l3_for(cur))
    sidx: uint64 = (P38_SHM_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3[cast[int64](sidx)] = P38_SHM_PA | P38_PAGE_RW
    _dsb_ish()
    _tlbi_vaae1is(P38_SHM_VA >> cast[uint64](12))
    _dsb_ish()
    _isb()

    pa: uint64 = arm64_p38_shm_va_to_pa(cur)
    if cur == 0:
        arm64_p38_a_attached = 1
        arm64_p38_a_attach_pa = pa
    else:
        arm64_p38_b_attached = 1
        arm64_p38_b_attach_pa = pa

    am: Ptr[char] = "[arm64] Phase 38: "
    _uart_puts(am)
    if cur == 0:
        pn: Ptr[char] = "producer"
        _uart_puts(pn)
    else:
        cn: Ptr[char] = "consumer"
        _uart_puts(cn)
    am2: Ptr[char] = " shm_attach VA="
    _uart_puts(am2)
    _uart_puthex(P38_SHM_VA)
    am3: Ptr[char] = " -> PA="
    _uart_puts(am3)
    _uart_puthex(pa)
    am4: Ptr[char] = "\n"
    _uart_puts(am4)
    return P38_SHM_VA


# signal(value): the producer publishes the shm-ready flag and WAKES a blocked
# waiter (BLOCKED -> RUNNABLE). The waiter's resumed wait() returns the flag.
def arm64_p38_do_signal(value: uint64) -> int64:
    arm64_p38_shm_flag = value
    arm64_p38_shm_flag_set = 1
    _dsb_ish()

    sm: Ptr[char] = "[arm64] Phase 38: producer signal value="
    _uart_puts(sm)
    _uart_puthex(value)
    sm2: Ptr[char] = "\n"
    _uart_puts(sm2)

    if arm64_p38_state_for(1) == P38_BLOCKED:
        cctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p38_ctx_for(1))
        cctx[CTX_X0] = value                      # the woken wait() returns the flag
        _dsb_ish()
        arm64_p38_set_state(1, P38_RUNNABLE)
        arm64_p38_woken_by_signal = 1
        km: Ptr[char] = "[arm64] Phase 38: signal woke the BLOCKED consumer (waiter) -> RUNNABLE\n"
        _uart_puts(km)
    return 0


# wait(frame_ptr): if the shm-ready flag is already set, return it. Else BLOCK the
# caller (the consumer): save its full resume context, mark it BLOCKED, and park
# its EL0 PC on a self-loop so the next timer tick runs the producer. The
# producer's signal sets the flag + wakes it. Returns the flag value on wake.
def arm64_p38_do_wait(frame_ptr: Ptr[uint64]) -> int64:
    if arm64_p38_shm_flag_set != 0:
        frame_ptr[0] = arm64_p38_shm_flag
        return 0

    cur: int64 = arm64_p38_cur

    # Save the caller's full resume context (so it RESUMES past the svc on wake).
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p38_ctx_for(cur))
    i: int64 = 0
    while i < 31:
        ctx[i] = frame_ptr[i]                     # x0..x30 from the saved svc frame
        i = i + 1
    ctx[CTX_X0] = cast[uint64](0)                 # overwritten with the flag on wake
    ctx[CTX_SP_EL0] = cast[uint64](_mrs_sp_el0())
    ctx[CTX_ELR] = cast[uint64](_mrs_elr_el1())   # resume PC = insn after the svc
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ                 # EL0t, IRQs on (re-preemptible)
    _dsb_ish()

    arm64_p38_set_state(cur, P38_BLOCKED)
    arm64_p38_waiter_blocked = arm64_p38_waiter_blocked + 1

    bm: Ptr[char] = "[arm64] Phase 38: consumer wait on unsignalled shm flag -> BLOCKED (sleep #"
    _uart_puts(bm)
    _uart_puthex(cast[uint64](arm64_p38_waiter_blocked))
    bm2: Ptr[char] = ")\n"
    _uart_puts(bm2)

    # Park the blocked slot's LIVE EL0 PC on a self-loop word in its OWN executable
    # TEXT page so the immediate svc-eret merely spins until the next timer tick
    # preempts it. Point arm64_current_ctx at the throwaway park ctx so the
    # preempting IRQ spills the spin state THERE, not over the just-saved ctx.
    park: uint64 = arm64_p38_park_addr(cur)
    _msr_elr_el1(park)
    _isb()
    frame_ptr[0] = cast[uint64](0)
    arm64_current_ctx = P38_PARK_CTX
    return 0


# Materialise a one-instruction self-loop (`b .`) at the end of slot `idx`'s TEXT
# page (an executable EL0 page) and return its EL0 VA. Used to park a blocked
# task's EL0 PC harmlessly until the next timer tick preempts it.
def arm64_p38_park_addr(idx: int64) -> uint64:
    text_pa: uint64 = P38A_TEXT_PA
    text_va: uint64 = P38A_TEXT_VA
    if idx == 1:
        text_pa = P38B_TEXT_PA
        text_va = P38B_TEXT_VA
    off: uint64 = cast[uint64](0xFFC)              # last word of the text page
    _emit_word(text_pa + off, cast[uint64](0x14000000))   # b . (self-loop)
    _dsb_ish()
    _isb()
    return text_va + off


# report(check-id, buf_va, len): the consumer reports the bytes it READ out of its
# OWN shm mapping; the kernel cross-checks them byte-for-byte against the producer's
# known sequence (so the consumer cannot fake a PASS). The buf_va is the consumer's
# shm VA, live under the consumer's TTBR0 — we read it directly. Returns 1 if match.
def arm64_p38_do_report(chk: uint64, buf_va: uint64, val: uint64) -> int64:
    if chk == P38_CHK_SHM:
        if cast[int64](val) != P38_SHM_LEN:
            return 0
        ub: Ptr[uint8] = cast[Ptr[uint8]](buf_va)
        ok: int64 = 1
        i: int64 = 0
        while i < P38_SHM_LEN:
            if ub[i] != arm64_p38_shm_byte(i):
                ok = 0
            i = i + 1
        if ok != 0:
            arm64_p38_rt_ok = 1
        rm: Ptr[char] = "[arm64] Phase 38: consumer report shm bytes match="
        _uart_puts(rm)
        _uart_puthex(cast[uint64](ok))
        rm2: Ptr[char] = "\n"
        _uart_puts(rm2)
        return ok
    return 0


# exit(status): mark the caller EXITED (the scheduler reaps it).
def arm64_p38_do_exit(frame_ptr: Ptr[uint64], status: uint64) -> int64:
    cur: int64 = arm64_p38_cur
    if cur == 0:
        arm64_p38_exit0 = status
        arm64_p38_prod_exited = 1
    else:
        arm64_p38_exit1 = status
        arm64_p38_cons_exited = 1
    arm64_p38_set_state(cur, P38_EXITED)

    em: Ptr[char] = "[arm64] Phase 38: "
    _uart_puts(em)
    if cur == 0:
        pn: Ptr[char] = "producer"
        _uart_puts(pn)
    else:
        cn: Ptr[char] = "consumer"
        _uart_puts(cn)
    em2: Ptr[char] = " exit(status="
    _uart_puts(em2)
    _uart_puthex(status)
    em3: Ptr[char] = ") -> EXITED\n"
    _uart_puts(em3)

    park: uint64 = arm64_p38_park_addr(cur)
    _msr_elr_el1(park)
    _isb()
    frame_ptr[0] = cast[uint64](0)
    arm64_current_ctx = P38_PARK_CTX
    return 0


# The producer's pipe_write equivalent here is a DIRECT shared-memory write done
# in EL0 (no kernel copy): the producer stores the known sequence into its OWN shm
# mapping. So the kernel observes the write only via the consumer's later report.
# To still record producer-side evidence (prod_wrote), the producer additionally
# emits SYS_P38_SIGNAL, and we cross-check the bytes are present in the SHARED
# physical frame at signal time (read directly from P38_SHM_PA, independent of any
# process VA). This proves the producer's EL0 store landed in the shared frame.
def arm64_p38_check_shared_frame() -> int64:
    sp: Ptr[uint8] = cast[Ptr[uint8]](P38_SHM_PA)
    ok: int64 = 1
    i: int64 = 0
    while i < P38_SHM_LEN:
        if sp[i] != arm64_p38_shm_byte(i):
            ok = 0
        i = i + 1
    if ok != 0:
        arm64_p38_prod_wrote = 1
    return ok


# Phase-38 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. Services the shared-memory IPC ABI.
def arm64_p38_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_P38_SHM_GET:
        n: int64 = arm64_p38_do_shm_get(a0)
        frame_ptr[0] = cast[uint64](n)
        return 0
    if nr == SYS_P38_SHM_ATTACH:
        va: uint64 = arm64_p38_do_shm_attach(a0)
        frame_ptr[0] = va
        return 0
    if nr == SYS_P38_SIGNAL:
        # Verify the producer's EL0 store landed in the SHARED physical frame
        # (read straight from P38_SHM_PA, independent of any process VA) before we
        # publish the flag + wake the waiter.
        arm64_p38_check_shared_frame()
        arm64_p38_do_signal(a0)
        frame_ptr[0] = cast[uint64](0)
        return 0
    if nr == SYS_P38_WAIT:
        return arm64_p38_do_wait(frame_ptr)
    if nr == SYS_P38_REPORT:
        r: int64 = arm64_p38_do_report(a0, a1, a2)
        frame_ptr[0] = cast[uint64](r)
        return 0
    if nr == SYS_P38_EXIT:
        return arm64_p38_do_exit(frame_ptr, a0)

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 38)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Pick the next non-BLOCKED, non-DEAD slot after `from_idx`, round-robin over the
# two slots. A BLOCKED slot is SKIPPED (tallied — proof the blocked waiter is
# genuinely passed over). Returns -1 if neither slot is runnable this tick.
def arm64_p38_next_runnable(from_idx: int64) -> int64:
    steps: int64 = 0
    idx: int64 = from_idx
    while steps < 2:
        idx = idx + 1
        if idx >= 2:
            idx = 0
        st: int64 = arm64_p38_state_for(idx)
        if st == P38_RUNNABLE:
            return idx
        if st == P38_BLOCKED:
            arm64_p38_skips = arm64_p38_skips + 1
        steps = steps + 1
    return -1


# Reap any EXITED slot (EXITED -> DEAD). Returns the number of slots reaped.
def arm64_p38_reap() -> int64:
    reaped: int64 = 0
    idx: int64 = 0
    while idx < 2:
        if arm64_p38_state_for(idx) == P38_EXITED:
            arm64_p38_set_state(idx, P38_DEAD)
            reaped = reaped + 1
        idx = idx + 1
    return reaped


# Phase-38 timer-IRQ scheduler. Ack/re-arm the timer, EOI, advance the logical
# tick, REAP any EXITED slot, and if both processes are DEAD run the verdict. A
# BLOCKED waiter is NEVER woken here (only a peer signal wakes it) — it is skipped.
# Round-robin to the next runnable slot, swap TTBR0+ASID into it, return its ctx.
def arm64_p38_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar                  # spurious: EOI, stay on this slot
        return cur_ctx

    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_p38_tick = arm64_p38_tick + 1

    arm64_p38_reap()

    if arm64_p38_state_for(0) == P38_DEAD:
        if arm64_p38_state_for(1) == P38_DEAD:
            arm64_p38_finish()
            while True:
                _wfi()

    if arm64_p38_tick >= 4000:
        arm64_p38_finish()
        while True:
            _wfi()

    nxt: int64 = arm64_p38_next_runnable(arm64_p38_cur)
    if nxt < 0:
        return cur_ctx

    arm64_p38_switches = arm64_p38_switches + 1
    arm64_p38_cur = nxt
    arm64_p38_switch_to(nxt)
    next_ctx: uint64 = arm64_p38_ctx_for(nxt)
    arm64_current_ctx = next_ctx
    return next_ctx


# Phase-38 verdict. PASS iff: BOTH processes attached the shared region and BOTH
# private mappings resolved to the SAME physical frame (P38_SHM_PA); the producer's
# EL0 store landed in that shared frame (verified directly off P38_SHM_PA); the
# consumer GENUINELY blocked on the unsignalled flag at least once and was woken by
# the producer's SIGNAL (not the timer); the picker skipped the blocked waiter at
# least once; the consumer read the producer's known sequence byte-for-byte out of
# its OWN shm mapping (kernel-verified); and both processes exited with their
# expected statuses. Prints the summary + PASS marker, then halts (last phase).
def arm64_p38_finish() -> int64:
    arm64_p38_active = 0
    nl: Ptr[char] = "\n"

    # Final independent proof: re-read both slots' live shm PTEs and confirm both
    # resolve to the SAME physical frame.
    pa_a: uint64 = arm64_p38_shm_va_to_pa(0)
    pa_b: uint64 = arm64_p38_shm_va_to_pa(1)
    if pa_a == P38_SHM_PA:
        if pa_b == P38_SHM_PA:
            arm64_p38_same_frame = 1

    sm: Ptr[char] = "[arm64] Phase 38 summary: a_attached="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p38_a_attached))
    s1: Ptr[char] = " b_attached="
    _uart_puts(s1)
    _uart_puthex(cast[uint64](arm64_p38_b_attached))
    s2: Ptr[char] = " a_pa="
    _uart_puts(s2)
    _uart_puthex(pa_a)
    s3: Ptr[char] = " b_pa="
    _uart_puts(s3)
    _uart_puthex(pa_b)
    s4: Ptr[char] = " shm_pa="
    _uart_puts(s4)
    _uart_puthex(P38_SHM_PA)
    s5: Ptr[char] = " same_frame="
    _uart_puts(s5)
    _uart_puthex(cast[uint64](arm64_p38_same_frame))
    _uart_puts(nl)

    s6: Ptr[char] = "[arm64] Phase 38 summary: prod_wrote="
    _uart_puts(s6)
    _uart_puthex(cast[uint64](arm64_p38_prod_wrote))
    s7: Ptr[char] = " waiter_blocked="
    _uart_puts(s7)
    _uart_puthex(cast[uint64](arm64_p38_waiter_blocked))
    s8: Ptr[char] = " woken_by_signal="
    _uart_puts(s8)
    _uart_puthex(cast[uint64](arm64_p38_woken_by_signal))
    s9: Ptr[char] = " skips="
    _uart_puts(s9)
    _uart_puthex(cast[uint64](arm64_p38_skips))
    s10: Ptr[char] = " switches="
    _uart_puts(s10)
    _uart_puthex(cast[uint64](arm64_p38_switches))
    s11: Ptr[char] = " rt_ok="
    _uart_puts(s11)
    _uart_puthex(cast[uint64](arm64_p38_rt_ok))
    s12: Ptr[char] = " prod_exit="
    _uart_puts(s12)
    _uart_puthex(arm64_p38_exit0)
    s13: Ptr[char] = " cons_exit="
    _uart_puts(s13)
    _uart_puthex(arm64_p38_exit1)
    _uart_puts(nl)

    ok: int64 = 1
    # Both processes attached the shared region.
    if arm64_p38_a_attached == 0:
        ok = 0
    if arm64_p38_b_attached == 0:
        ok = 0
    # Both private mappings resolve to the SAME physical frame (zero-copy proof).
    if arm64_p38_a_attach_pa != P38_SHM_PA:
        ok = 0
    if arm64_p38_b_attach_pa != P38_SHM_PA:
        ok = 0
    if arm64_p38_same_frame == 0:
        ok = 0
    # The producer's EL0 store landed in the shared frame.
    if arm64_p38_prod_wrote == 0:
        ok = 0
    # The consumer genuinely blocked on the unsignalled flag at least once.
    if arm64_p38_waiter_blocked < 1:
        ok = 0
    # The wake was driven by the producer's signal, not the timer. (Combined with
    # waiter_blocked>=1 this is the genuine-block proof: the consumer was
    # descheduled into BLOCKED and resumed ONLY because of the peer's signal — the
    # round-robin timer never wakes a BLOCKED slot. skips is reported as additional
    # evidence but, like Phase 37, is not gated on: the deterministic signal can
    # wake the waiter before a tick ever has to round-robin over it.)
    if arm64_p38_woken_by_signal == 0:
        ok = 0
    # The consumer read the producer's known sequence byte-for-byte (kernel-verified).
    if arm64_p38_rt_ok == 0:
        ok = 0
    # Both processes exited with their expected statuses.
    if arm64_p38_prod_exited == 0:
        ok = 0
    if arm64_p38_cons_exited == 0:
        ok = 0
    if arm64_p38_exit0 != P38_PROD_EXIT:
        ok = 0
    if arm64_p38_exit1 != P38_CONS_EXIT:
        ok = 0
    # No process left wedged BLOCKED at the verdict.
    if arm64_p38_state_for(1) == P38_BLOCKED:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 38: a SHARED anonymous physical frame was mapped into BOTH on-disk EL0 processes' PRIVATE address spaces (own page tables + ASID) at the same EL0 VA; both mappings resolved to the SAME physical frame; the producer wrote a known sequence into its OWN mapping, signalled the consumer (waking it from a genuine block), and the consumer read the sequence back BYTE-IDENTICALLY out of ITS OWN independent mapping — zero-copy shared-memory IPC, not a copy\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 38 PASS: shm IPC zero-copy round-trip (shared frame mapped into two private EL0 spaces, producer wrote, consumer read the known 28-byte sequence byte-identically through its own mapping)\n"
        _uart_puts(pp)
        # Hand off to Phase 39 (EL0 futex-based thread synchronization: TWO threads
        # sharing ONE address space, a real wait-queue keyed on a user VA). The
        # Phase-39 run never returns (its verdict halts after the futex handoff).
        arm64_p39_run(arm64_p38_blk_base)
        # Unreachable: arm64_p39_run halts. Safety loop.
        _msr_daifset(2)
        while True:
            _wfi()
    else:
        fp: Ptr[char] = "[arm64] Phase 38 FAIL: shared-memory IPC verdict failed\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-38 entry point (hand-off from arm64_p37_finish on a Phase-37 PASS), with
# the live virtio-blk transport `base`. Read PRODA38.ELF + CONSB38.ELF off the
# FAT16 disk, build each process's fresh private EL0 space, load each ELF, init
# both resume contexts, mark both RUNNABLE, then ERET into the consumer at EL0t
# with the timer LIVE and IRQs UNMASKED so the timer preempts and both processes
# run concurrently. The consumer attaches the shm + blocks on the flag; the
# producer attaches the SAME shm, writes it, and signals. Never returns (halts at
# the verdict).
def arm64_p38_run(base: uint64) -> int64:
    intro: Ptr[char] = "[arm64] Phase 38: shared-memory IPC (two on-disk EL0 processes: PRODA38 + CONSB38)\n"
    _uart_puts(intro)
    nl: Ptr[char] = "\n"

    _msr_daifset(2)                              # mask EL1 IRQs while we build
    arm64_p38_blk_base = base
    arm64_p38_cur = 0

    # Reset the shm flag + bookkeeping + clear the shared frame.
    arm64_p38_shm_flag = cast[uint64](0)
    arm64_p38_shm_flag_set = 0
    shm: Ptr[uint8] = cast[Ptr[uint8]](P38_SHM_PA)
    z: int64 = 0
    while z < cast[int64](P26_PAGE_SIZE):
        shm[z] = cast[uint8](0)
        z = z + 1
    _dsb_ish()

    # Re-parse the FAT16 BPB off sector 0 (fills arm64_p31_* geometry globals).
    if arm64_p30_read_sector_into(base, cast[uint64](0), P31_SEC_PA) != 1:
        fp: Ptr[char] = "[arm64] Phase 38 FAIL: boot-sector read failed\n"
        _uart_puts(fp)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    if arm64_p31_parse_bpb() != 1:
        fp2: Ptr[char] = "[arm64] Phase 38 FAIL: BPB geometry not a supported FAT16\n"
        _uart_puts(fp2)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    # Build + load the PRODUCER (PRODA38.ELF, slot 0).
    nm: uint64 = P31_FILE_PA
    np: Ptr[uint8] = cast[Ptr[uint8]](nm)
    # "PRODA38 ELF"
    np[0] = cast[uint8](0x50)    # P
    np[1] = cast[uint8](0x52)    # R
    np[2] = cast[uint8](0x4F)    # O
    np[3] = cast[uint8](0x44)    # D
    np[4] = cast[uint8](0x41)    # A
    np[5] = cast[uint8](0x33)    # 3
    np[6] = cast[uint8](0x38)    # 8
    np[7] = cast[uint8](0x20)
    np[8] = cast[uint8](0x45)    # E
    np[9] = cast[uint8](0x4C)    # L
    np[10] = cast[uint8](0x46)   # F
    flen: int64 = arm64_p38_read_elf(base, nm)
    if flen <= 0:
        fp3: Ptr[char] = "[arm64] Phase 38 FAIL: could not read PRODA38.ELF off the FAT16 disk\n"
        _uart_puts(fp3)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    rm: Ptr[char] = "[arm64] Phase 38: read PRODA38.ELF off disk ("
    _uart_puts(rm)
    _uart_puthex(cast[uint64](flen))
    rm2: Ptr[char] = " bytes); building producer EL0 space\n"
    _uart_puts(rm2)
    arm64_p38_build_space(0)
    arm64_p38_switch_to(0)
    entry_a: uint64 = arm64_p38_load_elf(0)
    if entry_a == cast[uint64](0):
        fp4: Ptr[char] = "[arm64] Phase 38 FAIL: PRODA38.ELF failed header/phdr validation\n"
        _uart_puts(fp4)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    arm64_p38_init_ctx(0, entry_a)
    arm64_p38_set_state(0, P38_RUNNABLE)

    # Build + load the CONSUMER (CONSB38.ELF, slot 1).
    np[0] = cast[uint8](0x43)    # C
    np[1] = cast[uint8](0x4F)    # O
    np[2] = cast[uint8](0x4E)    # N
    np[3] = cast[uint8](0x53)    # S
    np[4] = cast[uint8](0x42)    # B
    np[5] = cast[uint8](0x33)    # 3
    np[6] = cast[uint8](0x38)    # 8
    np[7] = cast[uint8](0x20)
    np[8] = cast[uint8](0x45)    # E
    np[9] = cast[uint8](0x4C)    # L
    np[10] = cast[uint8](0x46)   # F
    flen2: int64 = arm64_p38_read_elf(base, nm)
    if flen2 <= 0:
        fp5: Ptr[char] = "[arm64] Phase 38 FAIL: could not read CONSB38.ELF off the FAT16 disk\n"
        _uart_puts(fp5)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    rm3: Ptr[char] = "[arm64] Phase 38: read CONSB38.ELF off disk ("
    _uart_puts(rm3)
    _uart_puthex(cast[uint64](flen2))
    rm4: Ptr[char] = " bytes); building consumer EL0 space\n"
    _uart_puts(rm4)
    arm64_p38_build_space(1)
    arm64_p38_switch_to(1)
    entry_b: uint64 = arm64_p38_load_elf(1)
    if entry_b == cast[uint64](0):
        fp6: Ptr[char] = "[arm64] Phase 38 FAIL: CONSB38.ELF failed header/phdr validation\n"
        _uart_puts(fp6)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    arm64_p38_init_ctx(1, entry_b)
    arm64_p38_set_state(1, P38_RUNNABLE)

    arm64_p38_active = 1

    em: Ptr[char] = "[arm64] Phase 38: launching producer PRODA38 (ASID 28) + consumer CONSB38 (ASID 29) concurrently under the timer; entry_a="
    _uart_puts(em)
    _uart_puthex(entry_a)
    em2: Ptr[char] = " entry_b="
    _uart_puts(em2)
    _uart_puthex(entry_b)
    _uart_puts(nl)

    # Start the CONSUMER (slot 1) running FIRST so it attaches the shm + reaches its
    # wait() on the still-unsignalled flag and GENUINELY BLOCKS before the producer
    # ever writes/signals — a deterministic blocking ordering. The blocked consumer
    # is then descheduled and the round-robin picker dispatches the producer, which
    # attaches the SAME shm, writes the known sequence into its OWN mapping, then
    # signals — waking the consumer, which reads the sequence out of ITS OWN mapping.
    arm64_p38_cur = 1
    arm64_p38_switch_to(1)
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p38_ctx_for(1))
    arm64_current_ctx = arm64_p38_ctx_for(1)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                      # -> EL0; both processes run
    # Unreachable: the verdict halts.
    while True:
        _wfi()
    return 0


# ===========================================================================
# Phase 39 — EL0 FUTEX-BASED THREAD SYNCHRONIZATION between TWO EL0 THREADS that
# SHARE ONE address space (CLONE_VM-style), running CONCURRENTLY under the live
# preemptive timer scheduler on qemu-virt. This is the real Linux pthread
# foundation.
#
# Distinct from Phase 38 (two SEPARATE private address spaces sharing one frame),
# here the two threads share the SAME page-table tree and the SAME ASID — they are
# two threads of ONE process. Each thread has its OWN stack VA and OWN register/
# resume context, but BOTH run under one TTBR0+ASID, so they observe ALL of each
# other's user memory DIRECTLY (no per-thread mapping). The futex word and the
# handoff value both live in the single shared DATA page, seen identically by both.
#
# Two on-disk ELF64 programs are loaded off the live FAT16 disk INTO THE SAME
# address space at DISTINCT text/stack VAs (so the demand-fault handler attributes
# faults unambiguously) and a SHARED data VA (same bytes for both):
#
#   THRDA39.ELF (thread A, slot 0 — the WAITER): futex_wait(&futex, EXPECTED) on a
#     shared futex word still holding EXPECTED. The check *uaddr==expected holds, so
#     thread A GENUINELY BLOCKS (descheduled, marked BLOCKED, parked on a self-loop,
#     SKIPPED by the round-robin picker — NOT spinning) on the kernel wait-queue
#     keyed by the futex's user VA. When woken, it reads the handoff value thread B
#     wrote into the SHARED data page (through the shared address space) and
#     report()s it; the kernel cross-checks it equals the known handoff value.
#     Then exit().
#   THRDB39.ELF (thread B, slot 1 — the WAKER): stores a known handoff value into
#     the SHARED data page, bumps the futex word (so a late waiter would not block),
#     then futex_wake(&futex, 1) to wake thread A. Then exit().
#
# This is a GENUINE futex, NOT a faked round-trip:
#   * One address space: a SINGLE L1/L2/L3 tree + ONE ASID maps both threads' text,
#     both stacks, and the shared data/futex page. The kernel asserts both threads
#     resolve the futex uaddr to the SAME physical memory (they must — it is one AS).
#   * futex_wait reads *uaddr in kernel (through the live shared TTBR0) and only
#     blocks if it still equals the caller's expected value (the classic futex
#     compare-and-block that closes the lost-wakeup race).
#   * The blocked waiter is descheduled into BLOCKED and is provably skipped by the
#     round-robin picker (tallied); it resumes ONLY because thread B's futex_wake
#     moved it BLOCKED->RUNNABLE — never the timer (a futex-blocked slot is never
#     timer-woken). So the wake is a real wake, not a timeout/poll.
#   * The handoff value the waiter reports must equal the known value byte-for-byte
#     (kernel-verified), proving thread B's write was observed through the shared AS.
#
# EL0 syscalls added/wired for Phase 39 (free numbers):
#   SYS_P39_FUTEX_WAIT (730): a0 = futex uaddr, a1 = expected. If *uaddr==expected,
#                             BLOCK the caller on the wait-queue keyed by uaddr
#                             (descheduled + parked). On wake, returns 0. If
#                             *uaddr!=expected, returns immediately (EAGAIN-shape).
#   SYS_P39_FUTEX_WAKE (731): a0 = futex uaddr, a1 = max waiters to wake. Wakes up to
#                             a1 waiters parked on uaddr (BLOCKED->RUNNABLE). Returns
#                             the number woken.
#   SYS_P39_REPORT     (732): a0 = check-id, a1 = value/buf. The waiter reports the
#                             handoff value it read out of the shared page; the
#                             kernel confirms it equals the known handoff value.
#   SYS_P39_EXIT       (733): a0 = status. Mark the caller EXITED (scheduler reaps);
#                             when both threads are DEAD, run the verdict.
#
# Fresh RAM regions (clear of every prior phase's blocks). EL1-only page tables +
# context blocks live above the Phase-38 region (P38 ends at the P38_PARK_CTX page
# <=0x401E_FFFF) and below the EL0 window (0x4020_0000). Data PA backing lives above
# Phase 38's top blocks (P38 shm frame at 0x455D_0000), starting at 0x455E_0000.
# ===========================================================================

# --- Phase-39 fresh RAM region (clear of P38 <=0x455D_xxxx) ----------------
P39_FILE_PA: uint64 = 0x455E0000             # raw on-disk ELF bytes (thread A/B)
P39_FILE_CAP: int64 = 8192                   # max ELF file bytes we read

# The TWO threads share ONE address space (one L1/L2/L3 tree + ONE ASID). Each
# thread gets its OWN text VA + OWN stack VA (distinct 2 MiB windows, so the
# demand-fault handler attributes faults unambiguously); BOTH share the SAME data
# VA (the futex word + the handoff value live there — one page, observed by both).
P39A_TEXT_VA: uint64 = 0x42600000            # thread A text  (L2 idx 19)
P39A_STACK_VA: uint64 = 0x42800000           # thread A stack (L2 idx 20)
P39B_TEXT_VA: uint64 = 0x42A00000            # thread B text  (L2 idx 21)
P39B_STACK_VA: uint64 = 0x42C00000           # thread B stack (L2 idx 22)
P39_DATA_VA: uint64 = 0x42E00000             # SHARED data    (L2 idx 23)
P39A_TEXT_L2_INDEX: uint64 = 19
P39A_STACK_L2_INDEX: uint64 = 20
P39B_TEXT_L2_INDEX: uint64 = 21
P39B_STACK_L2_INDEX: uint64 = 22
P39_DATA_L2_INDEX: uint64 = 23
P39A_STACK_TOP: uint64 = 0x42801000
P39B_STACK_TOP: uint64 = 0x42C01000
P39_ASID: uint64 = 30                        # the ONE shared ASID (distinct from prior)

# The futex word + the handoff value both live in the single shared data page.
P39_FUTEX_OFF: uint64 = 0x0                   # futex word at data+0   (4 bytes)
P39_HANDOFF_OFF: uint64 = 0x40                # handoff value at data+0x40 (4 bytes)
P39_FUTEX_VA: uint64 = 0x42E00000             # = P39_DATA_VA + P39_FUTEX_OFF
P39_HANDOFF_VA: uint64 = 0x42E00040           # = P39_DATA_VA + P39_HANDOFF_OFF
P39_FUTEX_INIT: uint64 = 0x11                 # the futex word's initial value
P39_FUTEX_EXPECTED: uint64 = 0x11             # thread A waits while *futex == this
P39_HANDOFF_VAL: uint64 = 0x5AC3              # the known value thread B hands off

# Per-process (single AS) EL1-only page tables (ONE L1/L2 + FIVE L3: textA/stackA/
# textB/stackB/data) + two thread context blocks + a park ctx, in free EL1 RAM above
# the Phase-38 region (<=0x401E_FFFF) and below 0x4020_0000.
P39_L1: uint64 = 0x401F0000
P39_L2: uint64 = 0x401F1000
P39A_TEXT_L3: uint64 = 0x401F2000
P39A_STACK_L3: uint64 = 0x401F3000
P39B_TEXT_L3: uint64 = 0x401F4000
P39B_STACK_L3: uint64 = 0x401F5000
P39_DATA_L3: uint64 = 0x401F6000
P39A_CTX: uint64 = 0x401F7000                 # 34 x 8-byte resume-context slots
P39B_CTX: uint64 = 0x401F8000
P39_PARK_CTX: uint64 = 0x401F9000             # throwaway ctx for a parked blocked thread

# Data PA backing for the two threads' text + stacks + the one shared data page.
P39A_TEXT_PA: uint64 = 0x455F0000
P39A_STACK_PA: uint64 = 0x455F1000
P39B_TEXT_PA: uint64 = 0x455F2000
P39B_STACK_PA: uint64 = 0x455F3000
P39_DATA_PA: uint64 = 0x455F4000              # the ONE shared data/futex page

# W^X page permissions (identical encoding to Phase 38).
P39_PAGE_RX: uint64 = 0x7C7
P39_PAGE_RW: uint64 = 0x40000000000747
P39_PAGE_RO: uint64 = 0x400000000007C7

# Phase-39 EL0 syscall numbers (free).
SYS_P39_FUTEX_WAIT: uint64 = 730
SYS_P39_FUTEX_WAKE: uint64 = 731
SYS_P39_REPORT: uint64 = 732
SYS_P39_EXIT: uint64 = 733

# check-id for SYS_P39_REPORT.
P39_CHK_HANDOFF: uint64 = 0                    # waiter reports the handoff value it read

# Task-state model (reuse the Phase-38 numbering).
P39_RUNNABLE: int64 = 1
P39_BLOCKED: int64 = 2
P39_EXITED: int64 = 3
P39_DEAD: int64 = 4

# Expected exit statuses (the verdict asserts these are observed).
P39_A_EXIT: uint64 = 0x77                      # 119 — thread A (waiter) exit status
P39_B_EXIT: uint64 = 0x88                      # 136 — thread B (waker) exit status

# --- Phase-39 bookkeeping --------------------------------------------------
arm64_p39_active: int64 = 0
arm64_p39_cur: int64 = 0                       # live slot (0 = waiter A, 1 = waker B)
arm64_p39_tick: int64 = 0                      # logical scheduler tick
arm64_p39_switches: int64 = 0                  # thread switches performed
arm64_p39_waiter_blocked: int64 = 0            # times the waiter slept on the futex
arm64_p39_woken_by_wake: int64 = 0             # set when futex_wake woke the waiter
arm64_p39_skips: int64 = 0                     # times the picker passed over a BLOCKED slot
arm64_p39_blk_base: uint64 = 0

# The kernel wait-queue keyed on a user VA: a futex-blocked slot records the uaddr
# it parked on; futex_wake wakes exactly the slots parked on a matching uaddr.
arm64_p39_wq_uaddr0: uint64 = 0                # uaddr slot 0 is parked on (0 = none)
arm64_p39_wq_uaddr1: uint64 = 0

# Per-slot state.
arm64_p39_state0: int64 = 0
arm64_p39_state1: int64 = 0
arm64_p39_exit0: uint64 = 0xFFFF
arm64_p39_exit1: uint64 = 0xFFFF

# Per-thread segment fault accounting (over the SINGLE shared address space).
arm64_p39_a_text_faults: int64 = 0
arm64_p39_a_stack_faults: int64 = 0
arm64_p39_b_text_faults: int64 = 0
arm64_p39_b_stack_faults: int64 = 0
arm64_p39_data_faults: int64 = 0

# Verdict evidence.
arm64_p39_b_wrote: int64 = 0                   # thread B wrote the handoff (seen at futex_wake)
arm64_p39_rt_ok: int64 = 0                     # waiter's reported handoff value matched
arm64_p39_same_pa: int64 = 0                   # both threads' futex uaddr -> same PA
arm64_p39_a_exited: int64 = 0
arm64_p39_b_exited: int64 = 0
arm64_p39_wait_eagain: int64 = 0               # times futex_wait returned w/o blocking


# ---- per-slot accessors (idx: 0 = waiter A, 1 = waker B) -------------------
def arm64_p39_state_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p39_state0
    return arm64_p39_state1

def arm64_p39_set_state(idx: int64, st: int64) -> int64:
    if idx == 0:
        arm64_p39_state0 = st
    else:
        arm64_p39_state1 = st
    return 0

def arm64_p39_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P39A_CTX
    return P39B_CTX

def arm64_p39_wq_for(idx: int64) -> uint64:
    if idx == 0:
        return arm64_p39_wq_uaddr0
    return arm64_p39_wq_uaddr1

def arm64_p39_set_wq(idx: int64, ua: uint64) -> int64:
    if idx == 0:
        arm64_p39_wq_uaddr0 = ua
    else:
        arm64_p39_wq_uaddr1 = ua
    return 0


# Build the ONE shared EL0 address space (CLONE_VM): a single L1/L2 + FIVE 2 MiB
# slots redirected to private L3 tables (textA/stackA/textB/stackB/data). Stamp BOTH
# threads' stack pages RW and the shared data page RW here; text pages are stamped by
# the loader. Both threads run under this one tree + ONE ASID, so they share all of
# user memory directly.
def arm64_p39_build_space() -> int64:
    l1: Ptr[uint64] = cast[Ptr[uint64]](P39_L1)
    l2: Ptr[uint64] = cast[Ptr[uint64]](P39_L2)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1
    l1[0] = cast[uint64](0) | DEV_FLAGS

    ta: Ptr[uint64] = cast[Ptr[uint64]](P39A_TEXT_L3)
    sa: Ptr[uint64] = cast[Ptr[uint64]](P39A_STACK_L3)
    tb: Ptr[uint64] = cast[Ptr[uint64]](P39B_TEXT_L3)
    sb: Ptr[uint64] = cast[Ptr[uint64]](P39B_STACK_L3)
    dl: Ptr[uint64] = cast[Ptr[uint64]](P39_DATA_L3)
    k: int64 = 0
    while k < 512:
        ta[k] = cast[uint64](0)
        sa[k] = cast[uint64](0)
        tb[k] = cast[uint64](0)
        sb[k] = cast[uint64](0)
        dl[k] = cast[uint64](0)
        k = k + 1

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == P39A_TEXT_L2_INDEX:
            l2[j] = P39A_TEXT_L3 | DESC_TABLE
        elif cast[uint64](j) == P39A_STACK_L2_INDEX:
            l2[j] = P39A_STACK_L3 | DESC_TABLE
        elif cast[uint64](j) == P39B_TEXT_L2_INDEX:
            l2[j] = P39B_TEXT_L3 | DESC_TABLE
        elif cast[uint64](j) == P39B_STACK_L2_INDEX:
            l2[j] = P39B_STACK_L3 | DESC_TABLE
        elif cast[uint64](j) == P39_DATA_L2_INDEX:
            l2[j] = P39_DATA_L3 | DESC_TABLE
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = P39_L2 | DESC_TABLE
    _dsb_ish()

    # Wire BOTH threads' EL0 stack pages (RW non-exec) + zero them.
    sidx_a: uint64 = (P39A_STACK_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    sa[cast[int64](sidx_a)] = P39A_STACK_PA | P39_PAGE_RW
    spa: Ptr[uint64] = cast[Ptr[uint64]](P39A_STACK_PA)
    za: int64 = 0
    while za < 512:
        spa[za] = cast[uint64](0)
        za = za + 1
    sidx_b: uint64 = (P39B_STACK_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    sb[cast[int64](sidx_b)] = P39B_STACK_PA | P39_PAGE_RW
    spb: Ptr[uint64] = cast[Ptr[uint64]](P39B_STACK_PA)
    zb: int64 = 0
    while zb < 512:
        spb[zb] = cast[uint64](0)
        zb = zb + 1

    # Wire the SHARED data/futex page (RW non-exec), zero it, then seed the futex
    # word with its initial value so a wait while *futex==EXPECTED genuinely blocks.
    didx: uint64 = (P39_DATA_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    dl[cast[int64](didx)] = P39_DATA_PA | P39_PAGE_RW
    dp: Ptr[uint64] = cast[Ptr[uint64]](P39_DATA_PA)
    zd: int64 = 0
    while zd < 512:
        dp[zd] = cast[uint64](0)
        zd = zd + 1
    fw: Ptr[uint32] = cast[Ptr[uint32]](P39_DATA_PA + P39_FUTEX_OFF)
    fw[0] = cast[uint32](P39_FUTEX_INIT)
    _dsb_ish()
    _isb()
    return 0


# Map [seg_va, seg_va+filesz) onto seg_pa with page_flags in the shared L3 `l3_base`,
# copying p_filesz bytes from the Phase-39 ELF file buffer. The backing page is
# pre-cleared (BSS reads zero). Identical shape to arm64_p38_map_segment.
def arm64_p39_map_segment(seg_va: uint64, seg_pa: uint64, foff: uint64, filesz: uint64, l3_base: uint64, page_flags: uint64) -> int64:
    pg: Ptr[uint8] = cast[Ptr[uint8]](seg_pa)
    c: int64 = 0
    while c < cast[int64](P26_PAGE_SIZE):
        pg[c] = cast[uint8](0)
        c = c + 1
    fbuf: Ptr[uint8] = cast[Ptr[uint8]](P39_FILE_PA)
    n: uint64 = cast[uint64](0)
    while n < filesz:
        pg[cast[int64](n)] = fbuf[cast[int64](foff + n)]
        n = n + cast[uint64](1)
    _dsb_ish()
    l3: Ptr[uint64] = cast[Ptr[uint64]](l3_base)
    idx: uint64 = (seg_va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3[cast[int64](idx)] = seg_pa | page_flags
    _dsb_ish()
    _isb()
    return 0


# Little-endian readers out of the Phase-39 ELF file buffer.
def _p39_rd16(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P39_FILE_PA)
    b0: uint64 = cast[uint64](p[cast[int64](off)])
    b1: uint64 = cast[uint64](p[cast[int64](off + cast[uint64](1))])
    return b0 | (b1 << cast[uint64](8))


def _p39_rd32(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P39_FILE_PA)
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 4:
        r = r | (cast[uint64](p[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


def _p39_rd64(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P39_FILE_PA)
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 8:
        r = r | (cast[uint64](p[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


def arm64_p39_flags_for(pflags: uint64) -> uint64:
    if (pflags & PF_W) != cast[uint64](0):
        return P39_PAGE_RW
    if (pflags & PF_X) != cast[uint64](0):
        return P39_PAGE_RX
    return P39_PAGE_RO


# Read the on-disk ELF named by the 11-byte name at `name_pa` off the live FAT16
# volume into P39_FILE_PA (following its cluster chain). Returns byte length, or
# -1 on not-found / read error. Mirrors arm64_p38_read_elf over P39_FILE_PA.
def arm64_p39_read_elf(base: uint64, name_pa: uint64) -> int64:
    loc: int64 = arm64_p36_locate(base, name_pa)
    if loc != 1:
        return -1
    first_clus: int64 = arm64_p36_loc_first_clus
    file_size: int64 = arm64_p36_loc_size
    if first_clus < 2:
        return -1
    sec_per_clus: int64 = arm64_p31_sec_per_clus
    dst_off: int64 = 0
    want_len: int64 = file_size
    clus: int64 = first_clus
    guard: int64 = 0
    dst: Ptr[uint8] = cast[Ptr[uint8]](P39_FILE_PA)
    src: Ptr[uint8] = cast[Ptr[uint8]](P31_SEC_PA)
    while clus >= 2 and clus < 0xFFF8 and dst_off < want_len:
        guard = guard + 1
        if guard > 4096:
            return -1
        clus_lba: int64 = arm64_p31_data_lba + ((clus - 2) * sec_per_clus)
        sc: int64 = 0
        while sc < sec_per_clus:
            if dst_off < want_len:
                if arm64_p30_read_sector_into(base, cast[uint64](clus_lba + sc), P31_SEC_PA) != 1:
                    return -1
                take: int64 = arm64_p31_bytes_per_sec
                if dst_off + take > want_len:
                    take = want_len - dst_off
                i: int64 = 0
                while i < take:
                    if dst_off < P39_FILE_CAP:
                        dst[dst_off] = src[i]
                        dst_off = dst_off + 1
                    else:
                        i = take
                    i = i + 1
            sc = sc + 1
        nxt: int64 = arm64_p31_fat_next(base, clus)
        if nxt < 0:
            return -1
        clus = nxt
    return dst_off


# Parse + load the on-disk ELF64 in P39_FILE_PA into the SHARED address space for
# thread `prog` (0=A,1=B): thread A's text into the textA L3, thread B's text into
# the textB L3 (both in the one shared tree). Returns e_entry, or 0 on failure.
def arm64_p39_load_elf(prog: int64) -> uint64:
    fbuf: Ptr[uint8] = cast[Ptr[uint8]](P39_FILE_PA)
    nl: Ptr[char] = "\n"

    if cast[uint64](fbuf[0]) != ELF_EI_MAG0:
        return cast[uint64](0)
    if cast[uint64](fbuf[1]) != ELF_EI_MAG1:
        return cast[uint64](0)
    if cast[uint64](fbuf[2]) != ELF_EI_MAG2:
        return cast[uint64](0)
    if cast[uint64](fbuf[3]) != ELF_EI_MAG3:
        return cast[uint64](0)
    if cast[uint64](fbuf[4]) != ELFCLASS64:
        return cast[uint64](0)
    if cast[uint64](fbuf[5]) != ELFDATA2LSB:
        return cast[uint64](0)

    e_type: uint64 = _p39_rd16(EH_TYPE)
    e_machine: uint64 = _p39_rd16(EH_MACHINE)
    e_entry: uint64 = _p39_rd64(EH_ENTRY)
    e_phoff: uint64 = _p39_rd64(EH_PHOFF)
    e_phentsize: uint64 = _p39_rd16(EH_PHENTSIZE)
    e_phnum: uint64 = _p39_rd16(EH_PHNUM)

    if e_type != ET_EXEC:
        return cast[uint64](0)
    if e_machine != EM_AARCH64:
        return cast[uint64](0)

    text_va: uint64 = P39A_TEXT_VA
    text_pa: uint64 = P39A_TEXT_PA
    text_l3: uint64 = P39A_TEXT_L3
    if prog == 1:
        text_va = P39B_TEXT_VA
        text_pa = P39B_TEXT_PA
        text_l3 = P39B_TEXT_L3

    hm: Ptr[char] = "[arm64] Phase 39 ELF: thread="
    _uart_puts(hm)
    _uart_puthex(cast[uint64](prog))
    hm2: Ptr[char] = " entry="
    _uart_puts(hm2)
    _uart_puthex(e_entry)
    hm3: Ptr[char] = " phnum="
    _uart_puts(hm3)
    _uart_puthex(e_phnum)
    _uart_puts(nl)

    segs: int64 = 0
    ph: uint64 = 0
    while ph < e_phnum:
        b: uint64 = e_phoff + (ph * e_phentsize)
        p_type: uint64 = _p39_rd32(b + PH_TYPE)
        if p_type == PT_LOAD:
            p_flags: uint64 = _p39_rd32(b + PH_FLAGS)
            p_offset: uint64 = _p39_rd64(b + PH_OFFSET)
            p_vaddr: uint64 = _p39_rd64(b + PH_VADDR)
            p_filesz: uint64 = _p39_rd64(b + PH_FILESZ)
            page_flags: uint64 = arm64_p39_flags_for(p_flags)

            if p_vaddr == text_va:
                arm64_p39_map_segment(p_vaddr, text_pa, p_offset, p_filesz, text_l3, page_flags)
                segs = segs + 1
            elif p_vaddr == P39_DATA_VA:
                # Both threads' ELFs may declare the SHARED data segment; it is
                # already wired RW + seeded by arm64_p39_build_space. Do NOT map/
                # clobber it (it would overwrite the seeded futex word). Just count it.
                segs = segs + 1
            else:
                return cast[uint64](0)
        ph = ph + cast[uint64](1)

    if segs < 1:
        return cast[uint64](0)
    return e_entry


# TTBR0_EL1 for the SHARED address space: the one L1 root + the one ASID.
def arm64_p39_ttbr0() -> uint64:
    return P39_L1 | (P39_ASID << P23_ASID_SHIFT)


# Make the SHARED TTBR0 live (one ASID for both threads — no swap between them, but
# called once at launch and harmless if re-called).
def arm64_p39_switch_to_as() -> int64:
    _dsb_ish()
    _tlbi_aside1is(P39_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()
    _msr_ttbr0_el1(arm64_p39_ttbr0())
    _dsb_ish()
    _tlbi_aside1is(P39_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()
    return 0


# Initialise thread `prog`'s resume-context block for a clean first ERET into its
# entry, on ITS OWN EL0 stack, in EL0t with IRQs UNMASKED (so the timer preempts).
def arm64_p39_init_ctx(prog: int64, entry: uint64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p39_ctx_for(prog))
    i: int64 = 0
    while i < 34:
        ctx[i] = cast[uint64](0)
        i = i + 1
    stack_top: uint64 = P39A_STACK_TOP
    if prog == 1:
        stack_top = P39B_STACK_TOP
    ctx[CTX_SP_EL0] = stack_top
    ctx[CTX_ELR] = entry
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ
    return 0


# Phase-39 demand-fault entry. A first touch of a mapped page of the SINGLE shared
# address space (either thread's text/stack, or the shared data/futex page) takes a
# translation fault (loader/build pre-stamped the PTE). Confirm the VA lies in a
# mapped page, account it, flush the VA, and resume (return 1); else 0.
def arm64_p39_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0
    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    in_seg: int64 = 0
    if page_va == P39A_TEXT_VA:
        arm64_p39_a_text_faults = arm64_p39_a_text_faults + 1
        in_seg = 1
    elif page_va == P39A_STACK_VA:
        arm64_p39_a_stack_faults = arm64_p39_a_stack_faults + 1
        in_seg = 1
    elif page_va == P39B_TEXT_VA:
        arm64_p39_b_text_faults = arm64_p39_b_text_faults + 1
        in_seg = 1
    elif page_va == P39B_STACK_VA:
        arm64_p39_b_stack_faults = arm64_p39_b_stack_faults + 1
        in_seg = 1
    elif page_va == P39_DATA_VA:
        arm64_p39_data_faults = arm64_p39_data_faults + 1
        in_seg = 1
    if in_seg == 0:
        return 0

    _dsb_ish()
    _tlbi_vaae1is(page_va >> cast[uint64](12))
    _dsb_ish()
    _isb()
    return 1


# Translate the futex user VA `va` to the physical frame the SHARED address space
# maps it to (reads the live data L3 PTE). Returns 0 if not mapped. Used to PROVE
# both threads resolve the futex uaddr to the SAME physical memory (one AS).
def arm64_p39_va_to_pa(va: uint64) -> uint64:
    l3: Ptr[uint64] = cast[Ptr[uint64]](P39_DATA_L3)
    idx: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    pte: uint64 = l3[cast[int64](idx)]
    if (pte & cast[uint64](0x1)) == cast[uint64](0):
        return cast[uint64](0)
    return (pte & cast[uint64](0x0000FFFFFFFFF000)) | (va & cast[uint64](0xFFF))


# Read the 32-bit futex word at user VA `uaddr` through the kernel (the shared
# TTBR0 maps it, and the kernel runs with the shared address space live).
def arm64_p39_read_futex(uaddr: uint64) -> uint64:
    fp: Ptr[uint32] = cast[Ptr[uint32]](uaddr)
    return cast[uint64](fp[0])


# ---- Phase-39 EL0 syscall handlers ----------------------------------------

# futex_wait(uaddr, expected): the classic compare-and-block. Read *uaddr in the
# kernel; if it != expected, return immediately without blocking (EAGAIN-shape, the
# race-closing fast path). Else save the caller's full resume context, record the
# uaddr it parks on, mark it BLOCKED, park its EL0 PC on a self-loop, and switch the
# park ctx so the next timer tick runs the peer. Woken by a peer's futex_wake.
def arm64_p39_do_futex_wait(frame_ptr: Ptr[uint64], uaddr: uint64, expected: uint64) -> int64:
    cur: int64 = arm64_p39_cur
    val: uint64 = arm64_p39_read_futex(uaddr)

    wm: Ptr[char] = "[arm64] Phase 39: thread A futex_wait uaddr="
    _uart_puts(wm)
    _uart_puthex(uaddr)
    wm2: Ptr[char] = " *uaddr="
    _uart_puts(wm2)
    _uart_puthex(val)
    wm3: Ptr[char] = " expected="
    _uart_puts(wm3)
    _uart_puthex(expected)
    nlw: Ptr[char] = "\n"
    _uart_puts(nlw)

    if val != expected:
        # Value already changed — do NOT block (closes the lost-wakeup race).
        arm64_p39_wait_eagain = arm64_p39_wait_eagain + 1
        frame_ptr[0] = cast[uint64](0)
        return 0

    # Save the caller's full resume context (so it RESUMES past the svc on wake).
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p39_ctx_for(cur))
    i: int64 = 0
    while i < 31:
        ctx[i] = frame_ptr[i]                      # x0..x30 from the saved svc frame
        i = i + 1
    ctx[CTX_X0] = cast[uint64](0)                  # the woken futex_wait returns 0
    ctx[CTX_SP_EL0] = cast[uint64](_mrs_sp_el0())
    ctx[CTX_ELR] = cast[uint64](_mrs_elr_el1())    # resume PC = insn after the svc
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ                  # EL0t, IRQs on (re-preemptible)
    _dsb_ish()

    arm64_p39_set_wq(cur, uaddr)                   # enqueue on the wait-queue keyed by uaddr
    arm64_p39_set_state(cur, P39_BLOCKED)
    arm64_p39_waiter_blocked = arm64_p39_waiter_blocked + 1

    bm: Ptr[char] = "[arm64] Phase 39: thread A futex_wait on unchanged futex word -> BLOCKED (parked on uaddr, sleep #"
    _uart_puts(bm)
    _uart_puthex(cast[uint64](arm64_p39_waiter_blocked))
    bm2: Ptr[char] = ")\n"
    _uart_puts(bm2)

    # Park the blocked slot's LIVE EL0 PC on a self-loop word in its OWN text page so
    # the immediate svc-eret merely spins until the next timer tick preempts it.
    park: uint64 = arm64_p39_park_addr(cur)
    _msr_elr_el1(park)
    _isb()
    frame_ptr[0] = cast[uint64](0)
    arm64_current_ctx = P39_PARK_CTX
    return 0


# Materialise a one-instruction self-loop (`b .`) at the end of thread `idx`'s TEXT
# page (an executable EL0 page) and return its EL0 VA. Used to park a blocked
# thread's EL0 PC harmlessly until the next timer tick preempts it.
def arm64_p39_park_addr(idx: int64) -> uint64:
    text_pa: uint64 = P39A_TEXT_PA
    text_va: uint64 = P39A_TEXT_VA
    if idx == 1:
        text_pa = P39B_TEXT_PA
        text_va = P39B_TEXT_VA
    off: uint64 = cast[uint64](0xFFC)              # last word of the text page
    _emit_word(text_pa + off, cast[uint64](0x14000000))   # b . (self-loop)
    _dsb_ish()
    _isb()
    return text_va + off


# futex_wake(uaddr, n): wake up to `n` waiters parked on `uaddr` (BLOCKED->RUNNABLE).
# Each woken thread's futex_wait returns 0. Returns the number woken.
def arm64_p39_do_futex_wake(uaddr: uint64, n: uint64) -> int64:
    woke: int64 = 0
    idx: int64 = 0
    while idx < 2:
        if cast[uint64](woke) < n:
            if arm64_p39_state_for(idx) == P39_BLOCKED:
                if arm64_p39_wq_for(idx) == uaddr:
                    wctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p39_ctx_for(idx))
                    wctx[CTX_X0] = cast[uint64](0)     # the woken futex_wait returns 0
                    _dsb_ish()
                    arm64_p39_set_state(idx, P39_RUNNABLE)
                    arm64_p39_set_wq(idx, cast[uint64](0))
                    arm64_p39_woken_by_wake = 1
                    woke = woke + 1
        idx = idx + 1

    km: Ptr[char] = "[arm64] Phase 39: thread B futex_wake uaddr="
    _uart_puts(km)
    _uart_puthex(uaddr)
    km2: Ptr[char] = " n="
    _uart_puts(km2)
    _uart_puthex(n)
    km3: Ptr[char] = " woke="
    _uart_puts(km3)
    _uart_puthex(cast[uint64](woke))
    nlk: Ptr[char] = "\n"
    _uart_puts(nlk)
    if woke > 0:
        wk: Ptr[char] = "[arm64] Phase 39: futex_wake woke the BLOCKED waiter (thread A) -> RUNNABLE\n"
        _uart_puts(wk)
    return woke


# report(check-id, value): the waiter reports the handoff value it READ out of the
# SHARED data page (through the shared address space); the kernel cross-checks it
# equals the known handoff value (so the waiter cannot fake a PASS). Returns 1 if it
# matches.
def arm64_p39_do_report(chk: uint64, value: uint64) -> int64:
    if chk == P39_CHK_HANDOFF:
        ok: int64 = 0
        if value == P39_HANDOFF_VAL:
            ok = 1
            arm64_p39_rt_ok = 1
        rm: Ptr[char] = "[arm64] Phase 39: thread A report handoff value="
        _uart_puts(rm)
        _uart_puthex(value)
        rm2: Ptr[char] = " match="
        _uart_puts(rm2)
        _uart_puthex(cast[uint64](ok))
        rm3: Ptr[char] = "\n"
        _uart_puts(rm3)
        return ok
    return 0


# exit(status): mark the caller EXITED (the scheduler reaps it).
def arm64_p39_do_exit(frame_ptr: Ptr[uint64], status: uint64) -> int64:
    cur: int64 = arm64_p39_cur
    if cur == 0:
        arm64_p39_exit0 = status
        arm64_p39_a_exited = 1
    else:
        arm64_p39_exit1 = status
        arm64_p39_b_exited = 1
    arm64_p39_set_state(cur, P39_EXITED)

    em: Ptr[char] = "[arm64] Phase 39: thread "
    _uart_puts(em)
    if cur == 0:
        an: Ptr[char] = "A"
        _uart_puts(an)
    else:
        bn: Ptr[char] = "B"
        _uart_puts(bn)
    em2: Ptr[char] = " exit(status="
    _uart_puts(em2)
    _uart_puthex(status)
    em3: Ptr[char] = ") -> EXITED\n"
    _uart_puts(em3)

    park: uint64 = arm64_p39_park_addr(cur)
    _msr_elr_el1(park)
    _isb()
    frame_ptr[0] = cast[uint64](0)
    arm64_current_ctx = P39_PARK_CTX
    return 0


# Independent kernel proof that thread B's EL0 store of the handoff value landed in
# the SHARED data page (read directly off P39_DATA_PA, independent of any VA). Called
# at futex_wake time. Sets b_wrote on a match.
def arm64_p39_check_handoff() -> int64:
    hp: Ptr[uint32] = cast[Ptr[uint32]](P39_DATA_PA + P39_HANDOFF_OFF)
    ok: int64 = 0
    if cast[uint64](hp[0]) == P39_HANDOFF_VAL:
        ok = 1
        arm64_p39_b_wrote = 1
    return ok


# Phase-39 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. Services the futex thread-sync ABI.
def arm64_p39_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_P39_FUTEX_WAIT:
        return arm64_p39_do_futex_wait(frame_ptr, a0, a1)
    if nr == SYS_P39_FUTEX_WAKE:
        # Verify thread B's handoff store landed in the SHARED page (off P39_DATA_PA,
        # independent of any VA) before we wake the waiter.
        arm64_p39_check_handoff()
        w: int64 = arm64_p39_do_futex_wake(a0, a1)
        frame_ptr[0] = cast[uint64](w)
        return 0
    if nr == SYS_P39_REPORT:
        r: int64 = arm64_p39_do_report(a0, a1)
        frame_ptr[0] = cast[uint64](r)
        return 0
    if nr == SYS_P39_EXIT:
        return arm64_p39_do_exit(frame_ptr, a0)

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 39)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Pick the next non-BLOCKED, non-DEAD slot after `from_idx`, round-robin over the
# two threads. A BLOCKED (futex-waiting) slot is SKIPPED (tallied — proof the
# blocked waiter is genuinely passed over). Returns -1 if neither is runnable.
def arm64_p39_next_runnable(from_idx: int64) -> int64:
    steps: int64 = 0
    idx: int64 = from_idx
    while steps < 2:
        idx = idx + 1
        if idx >= 2:
            idx = 0
        st: int64 = arm64_p39_state_for(idx)
        if st == P39_RUNNABLE:
            return idx
        if st == P39_BLOCKED:
            arm64_p39_skips = arm64_p39_skips + 1
        steps = steps + 1
    return -1


# Reap any EXITED slot (EXITED -> DEAD). Returns the number of slots reaped.
def arm64_p39_reap() -> int64:
    reaped: int64 = 0
    idx: int64 = 0
    while idx < 2:
        if arm64_p39_state_for(idx) == P39_EXITED:
            arm64_p39_set_state(idx, P39_DEAD)
            reaped = reaped + 1
        idx = idx + 1
    return reaped


# Phase-39 timer-IRQ scheduler. Ack/re-arm the timer, EOI, advance the tick, REAP
# any EXITED slot, and if both threads are DEAD run the verdict. A futex-BLOCKED
# waiter is NEVER woken here (only a peer futex_wake wakes it) — it is skipped.
# Round-robin to the next runnable thread (both share ONE TTBR0+ASID, so no AS swap
# is needed), return its ctx.
def arm64_p39_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar
        return cur_ctx

    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_p39_tick = arm64_p39_tick + 1

    arm64_p39_reap()

    if arm64_p39_state_for(0) == P39_DEAD:
        if arm64_p39_state_for(1) == P39_DEAD:
            arm64_p39_finish()
            while True:
                _wfi()

    if arm64_p39_tick >= 4000:
        arm64_p39_finish()
        while True:
            _wfi()

    nxt: int64 = arm64_p39_next_runnable(arm64_p39_cur)
    if nxt < 0:
        return cur_ctx

    arm64_p39_switches = arm64_p39_switches + 1
    arm64_p39_cur = nxt
    next_ctx: uint64 = arm64_p39_ctx_for(nxt)
    arm64_current_ctx = next_ctx
    return next_ctx


# Phase-39 verdict. PASS iff: the futex uaddr resolved to the SAME physical memory
# for both threads (one shared address space); thread B's handoff store landed in
# the shared page (verified directly off P39_DATA_PA); thread A GENUINELY blocked in
# futex_wait on the unchanged futex word at least once and was woken by thread B's
# futex_wake (not the timer); the picker skipped the blocked waiter at least once;
# the handoff value thread A reported equals the known value (kernel-verified); and
# both threads exited with their expected statuses. Prints summary + PASS, then halts.
def arm64_p39_finish() -> int64:
    arm64_p39_active = 0
    nl: Ptr[char] = "\n"

    # Final independent proof: resolve the futex uaddr to a PA twice (the shared AS
    # is one tree, so both threads see the same PA by construction; re-resolve to
    # confirm it is mapped and stable).
    pa: uint64 = arm64_p39_va_to_pa(P39_FUTEX_VA)
    if pa != cast[uint64](0):
        if pa == (P39_DATA_PA + P39_FUTEX_OFF):
            arm64_p39_same_pa = 1

    sm: Ptr[char] = "[arm64] Phase 39 summary: futex_va="
    _uart_puts(sm)
    _uart_puthex(P39_FUTEX_VA)
    s1: Ptr[char] = " futex_pa="
    _uart_puts(s1)
    _uart_puthex(pa)
    s2: Ptr[char] = " data_pa="
    _uart_puts(s2)
    _uart_puthex(P39_DATA_PA)
    s3: Ptr[char] = " same_pa="
    _uart_puts(s3)
    _uart_puthex(cast[uint64](arm64_p39_same_pa))
    _uart_puts(nl)

    s4: Ptr[char] = "[arm64] Phase 39 summary: b_wrote="
    _uart_puts(s4)
    _uart_puthex(cast[uint64](arm64_p39_b_wrote))
    s5: Ptr[char] = " waiter_blocked="
    _uart_puts(s5)
    _uart_puthex(cast[uint64](arm64_p39_waiter_blocked))
    s6: Ptr[char] = " woken_by_wake="
    _uart_puts(s6)
    _uart_puthex(cast[uint64](arm64_p39_woken_by_wake))
    s7: Ptr[char] = " skips="
    _uart_puts(s7)
    _uart_puthex(cast[uint64](arm64_p39_skips))
    s8: Ptr[char] = " switches="
    _uart_puts(s8)
    _uart_puthex(cast[uint64](arm64_p39_switches))
    s9: Ptr[char] = " rt_ok="
    _uart_puts(s9)
    _uart_puthex(cast[uint64](arm64_p39_rt_ok))
    s10: Ptr[char] = " a_exit="
    _uart_puts(s10)
    _uart_puthex(arm64_p39_exit0)
    s11: Ptr[char] = " b_exit="
    _uart_puts(s11)
    _uart_puthex(arm64_p39_exit1)
    _uart_puts(nl)

    ok: int64 = 1
    # The futex uaddr resolves to the shared physical page (one address space).
    if arm64_p39_same_pa == 0:
        ok = 0
    # Thread B's handoff store landed in the shared page.
    if arm64_p39_b_wrote == 0:
        ok = 0
    # Thread A genuinely blocked in futex_wait at least once.
    if arm64_p39_waiter_blocked < 1:
        ok = 0
    # The wake was driven by thread B's futex_wake, not the timer.
    if arm64_p39_woken_by_wake == 0:
        ok = 0
    # The handoff value thread A read+reported equals the known value.
    if arm64_p39_rt_ok == 0:
        ok = 0
    # Both threads exited with their expected statuses.
    if arm64_p39_a_exited == 0:
        ok = 0
    if arm64_p39_b_exited == 0:
        ok = 0
    if arm64_p39_exit0 != P39_A_EXIT:
        ok = 0
    if arm64_p39_exit1 != P39_B_EXIT:
        ok = 0
    # No thread left wedged BLOCKED at the verdict.
    if arm64_p39_state_for(0) == P39_BLOCKED:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 39: TWO EL0 threads shared ONE address space (same page tables + ASID, distinct stacks + register contexts); thread A blocked in a real futex_wait on a wait-queue keyed by the futex user VA (descheduled + skipped by the picker, NOT polling); thread B wrote a known handoff value into the SHARED memory both threads see directly and futex_wake'd thread A; the waiter woke, read the value through the shared address space, and it matched byte-for-byte — a genuine futex mutex handoff, the Linux pthread foundation\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 39 PASS: futex thread-sync round-trip (two threads in one address space, futex_wait blocked the waiter, futex_wake woke it, handoff value matched through shared memory)\n"
        _uart_puts(pp)
        # Hand off to Phase 40 (real in-guest TCP loopback handshake + data + teardown).
        # Phase 40 needs no disk/net device; it runs two TCBs entirely in kernel RAM and
        # delivers full IPv4/TCP segments through an in-guest loopback datapath.
        arm64_p40_run()
    else:
        fp: Ptr[char] = "[arm64] Phase 39 FAIL: futex thread-sync verdict failed\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-39 entry point (hand-off from arm64_p38_finish on a Phase-38 PASS), with the
# live virtio-blk transport `base`. Read THRDA39.ELF + THRDB39.ELF off the FAT16
# disk, build ONE shared EL0 address space, load BOTH ELFs into it at distinct
# text/stack VAs + a shared data VA, init both thread resume contexts, mark both
# RUNNABLE, then ERET into thread A (the waiter) at EL0t with the timer LIVE and
# IRQs UNMASKED so the timer preempts and both threads run concurrently. Thread A
# futex_wait-blocks on the shared futex word; thread B writes the handoff + wakes
# it. Never returns (halts at the verdict).
def arm64_p39_run(base: uint64) -> int64:
    intro: Ptr[char] = "[arm64] Phase 39: futex thread synchronization (two EL0 threads sharing ONE address space: THRDA39 + THRDB39)\n"
    _uart_puts(intro)
    nl: Ptr[char] = "\n"

    _msr_daifset(2)                              # mask EL1 IRQs while we build
    arm64_p39_blk_base = base
    arm64_p39_cur = 0

    # Build the ONE shared address space (page tables + stacks + shared data/futex
    # page seeded with P39_FUTEX_INIT). Make it live so the loader's segment copies
    # + the futex seed are coherent under the shared TTBR0.
    arm64_p39_build_space()
    arm64_p39_switch_to_as()

    # Re-parse the FAT16 BPB off sector 0 (fills arm64_p31_* geometry globals).
    if arm64_p30_read_sector_into(base, cast[uint64](0), P31_SEC_PA) != 1:
        fp: Ptr[char] = "[arm64] Phase 39 FAIL: boot-sector read failed\n"
        _uart_puts(fp)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    if arm64_p31_parse_bpb() != 1:
        fp2: Ptr[char] = "[arm64] Phase 39 FAIL: BPB geometry not a supported FAT16\n"
        _uart_puts(fp2)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    # Build + load THREAD A (THRDA39.ELF, slot 0 — the waiter).
    nm: uint64 = P31_FILE_PA
    np: Ptr[uint8] = cast[Ptr[uint8]](nm)
    # "THRDA39 ELF"
    np[0] = cast[uint8](0x54)    # T
    np[1] = cast[uint8](0x48)    # H
    np[2] = cast[uint8](0x52)    # R
    np[3] = cast[uint8](0x44)    # D
    np[4] = cast[uint8](0x41)    # A
    np[5] = cast[uint8](0x33)    # 3
    np[6] = cast[uint8](0x39)    # 9
    np[7] = cast[uint8](0x20)
    np[8] = cast[uint8](0x45)    # E
    np[9] = cast[uint8](0x4C)    # L
    np[10] = cast[uint8](0x46)   # F
    flen: int64 = arm64_p39_read_elf(base, nm)
    if flen <= 0:
        fp3: Ptr[char] = "[arm64] Phase 39 FAIL: could not read THRDA39.ELF off the FAT16 disk\n"
        _uart_puts(fp3)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    rm: Ptr[char] = "[arm64] Phase 39: read THRDA39.ELF off disk ("
    _uart_puts(rm)
    _uart_puthex(cast[uint64](flen))
    rm2: Ptr[char] = " bytes); loading thread A into the shared EL0 space\n"
    _uart_puts(rm2)
    entry_a: uint64 = arm64_p39_load_elf(0)
    if entry_a == cast[uint64](0):
        fp4: Ptr[char] = "[arm64] Phase 39 FAIL: THRDA39.ELF failed header/phdr validation\n"
        _uart_puts(fp4)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    arm64_p39_init_ctx(0, entry_a)
    arm64_p39_set_state(0, P39_RUNNABLE)

    # Build + load THREAD B (THRDB39.ELF, slot 1 — the waker).
    np[0] = cast[uint8](0x54)    # T
    np[1] = cast[uint8](0x48)    # H
    np[2] = cast[uint8](0x52)    # R
    np[3] = cast[uint8](0x44)    # D
    np[4] = cast[uint8](0x42)    # B
    np[5] = cast[uint8](0x33)    # 3
    np[6] = cast[uint8](0x39)    # 9
    np[7] = cast[uint8](0x20)
    np[8] = cast[uint8](0x45)    # E
    np[9] = cast[uint8](0x4C)    # L
    np[10] = cast[uint8](0x46)   # F
    flen2: int64 = arm64_p39_read_elf(base, nm)
    if flen2 <= 0:
        fp5: Ptr[char] = "[arm64] Phase 39 FAIL: could not read THRDB39.ELF off the FAT16 disk\n"
        _uart_puts(fp5)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    rm3: Ptr[char] = "[arm64] Phase 39: read THRDB39.ELF off disk ("
    _uart_puts(rm3)
    _uart_puthex(cast[uint64](flen2))
    rm4: Ptr[char] = " bytes); loading thread B into the shared EL0 space\n"
    _uart_puts(rm4)
    entry_b: uint64 = arm64_p39_load_elf(1)
    if entry_b == cast[uint64](0):
        fp6: Ptr[char] = "[arm64] Phase 39 FAIL: THRDB39.ELF failed header/phdr validation\n"
        _uart_puts(fp6)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    arm64_p39_init_ctx(1, entry_b)
    arm64_p39_set_state(1, P39_RUNNABLE)

    arm64_p39_active = 1

    em: Ptr[char] = "[arm64] Phase 39: launching thread A (waiter) + thread B (waker) in ONE address space (ASID 30) concurrently under the timer; entry_a="
    _uart_puts(em)
    _uart_puthex(entry_a)
    em2: Ptr[char] = " entry_b="
    _uart_puts(em2)
    _uart_puthex(entry_b)
    _uart_puts(nl)

    # Start THREAD A (slot 0, the waiter) running FIRST so it reaches its futex_wait
    # on the still-unchanged futex word and GENUINELY BLOCKS before thread B ever
    # wakes it — a deterministic blocking ordering. The blocked waiter is descheduled
    # and the round-robin picker dispatches thread B, which writes the handoff value
    # into the SHARED page and futex_wake's thread A — waking it to read the value.
    arm64_p39_cur = 0
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p39_ctx_for(0))
    arm64_current_ctx = arm64_p39_ctx_for(0)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                      # -> EL0; both threads run
    # Unreachable: the verdict halts.
    while True:
        _wfi()
    return 0


# ===========================================================================
# PHASE 40 — a real TCP/IPv4 three-way handshake + bidirectional data exchange
# + orderly FIN teardown, entirely in-guest over a deterministic loopback
# datapath on bare aarch64 (qemu-virt). NO external peer, NO SLIRP, NO ELF,
# NO disk: two TCP control blocks (a passive-open server + an active-open
# client) live in kernel RAM and exchange full Ethernet+IPv4+TCP segments
# through an in-guest loopback that hands each transmitted frame straight to
# the matching endpoint's receive path. Every segment carries a real 20-byte
# TCP header, real sequence/acknowledgement numbers, and a real TCP checksum
# over the IPv4 pseudo-header (src/dst/zero/proto/tcp-len) + header + payload,
# validated on receipt. The state machines walk LISTEN/SYN_SENT/SYN_RCVD/
# ESTABLISHED/FIN_WAIT_1/FIN_WAIT_2/CLOSE_WAIT/LAST_ACK/CLOSED exactly as a
# real stack does. The kernel VERIFIES: both sides reached ESTABLISHED, the
# payload bytes arrived byte-identical in BOTH directions, the ack numbers
# advanced by exactly the bytes consumed, and both sides reached CLOSED.
# arm64_p40_run never returns (it halts after the verdict).
#
# This mirrors the native x86 TCP state machine in drivers/net/tcp.ad
# (SYN/SYN-ACK/ACK handshake, seq/ack numbering, pseudo-header checksum, FIN
# teardown), reimplemented self-contained for the arm64 loopback path.
# ===========================================================================

# --- TCP states (match drivers/net/tcp.ad numbering) -----------------------
P40_CLOSED:      int64 = 0
P40_LISTEN:      int64 = 1
P40_SYN_SENT:    int64 = 2
P40_SYN_RCVD:    int64 = 3
P40_ESTABLISHED: int64 = 4
P40_FIN_WAIT_1:  int64 = 5
P40_FIN_WAIT_2:  int64 = 6
P40_CLOSE_WAIT:  int64 = 7
P40_LAST_ACK:    int64 = 8
P40_TIME_WAIT:   int64 = 9

# --- TCP flag bits ---------------------------------------------------------
P40_FIN: uint64 = 0x01
P40_SYN: uint64 = 0x02
P40_RST: uint64 = 0x04
P40_PSH: uint64 = 0x08
P40_ACK: uint64 = 0x10

# --- framing geometry ------------------------------------------------------
P40_ETH_HDR:  int64 = 14
P40_IP_HDR:   int64 = 20
P40_TCP_HDR:  int64 = 20
P40_ETHERTYPE_IPV4: uint64 = 0x0800
P40_IP_PROTO_TCP:   uint64 = 6

# --- loopback addressing: both endpoints are 127.0.0.1 --------------------
P40_LOOP_IP0: uint8 = 127
P40_LOOP_IP1: uint8 = 0
P40_LOOP_IP2: uint8 = 0
P40_LOOP_IP3: uint8 = 1
P40_SRV_PORT: uint64 = 7777          # server listens here
P40_CLI_PORT: uint64 = 50000         # client ephemeral port

# Initial sequence numbers (deterministic, distinct, non-trivial — they must
# survive arithmetic + wrap correctness independent of each other).
P40_CLI_ISN: uint64 = 0x10000000
P40_SRV_ISN: uint64 = 0x70000000

# Slot identifiers.
P40_SLOT_SRV: int64 = 0              # passive open (LISTEN/accept)
P40_SLOT_CLI: int64 = 1              # active open (connect)

# --- TCB state (two slots: 0=server, 1=client) ----------------------------
arm64_p40_state:    Array[2, int64]
arm64_p40_snd_nxt:  Array[2, uint64]   # next seq we will send
arm64_p40_snd_una:  Array[2, uint64]   # oldest unacked seq
arm64_p40_rcv_nxt:  Array[2, uint64]   # next seq we expect from the peer
arm64_p40_iss:      Array[2, uint64]   # our initial send sequence
arm64_p40_irs:      Array[2, uint64]   # initial receive sequence (peer's ISN)
arm64_p40_lport:    Array[2, uint64]   # our local TCP port
arm64_p40_rport:    Array[2, uint64]   # the peer's TCP port
arm64_p40_estab:    Array[2, int64]    # latched 1 when this side hit ESTABLISHED
arm64_p40_closed:   Array[2, int64]    # latched 1 when this side hit CLOSED

# Per-slot reassembled receive buffer (data delivered in-order to the app).
P40_RXCAP: int64 = 256
arm64_p40_rx0: Array[256, uint8]       # server's delivered bytes
arm64_p40_rx1: Array[256, uint8]       # client's delivered bytes
arm64_p40_rxlen: Array[2, int64]       # bytes delivered to each side

# --- run-wide bookkeeping / verification flags ----------------------------
arm64_p40_csum_bad:   int64 = 0        # any received segment failed checksum
arm64_p40_segs_in:    int64 = 0        # total segments delivered via loopback
arm64_p40_loop_depth: int64 = 0        # current loopback recursion depth
arm64_p40_loop_max:   int64 = 0        # max recursion depth observed
arm64_p40_srv_data_ok: int64 = 0       # server received the client payload identically
arm64_p40_cli_data_ok: int64 = 0       # client received the server payload identically
arm64_p40_handshake_seen: int64 = 0    # both sides reached ESTABLISHED

# Frame scratch (one builder buffer; the loopback consumes it synchronously
# before the next build, so a single buffer suffices). Generously sized at a
# clear high PA so it cannot overflow into any prior-phase global.
P40_FRAME_PA: uint64 = 0x46100000      # Eth+IPv4+TCP build/deliver frame
P40_PHDR_PA:  uint64 = 0x46101000      # checksum pseudo-header scratch

# The two app payloads exchanged once ESTABLISHED. Distinct content + lengths
# so a cross-wire or truncation cannot silently pass.
P40_CLI_MSG_LEN: int64 = 26
P40_SRV_MSG_LEN: int64 = 22


# Client->server application payload byte i (deterministic ramp + offset).
def arm64_p40_cli_msg_byte(i: int64) -> uint8:
    return cast[uint8](cast[uint64](0x41 + i * 3) & cast[uint64](0xFF))


# Server->client application payload byte i (a different ramp).
def arm64_p40_srv_msg_byte(i: int64) -> uint8:
    return cast[uint8](cast[uint64](0x53 + i * 5) & cast[uint64](0xFF))


# Store a 32-bit big-endian value at byte offset `off` of buffer `b`.
def arm64_p40_put_be32(b: uint64, off: int64, val: uint64) -> int64:
    p: Ptr[uint8] = cast[Ptr[uint8]](b + cast[uint64](off))
    p[0] = cast[uint8]((val >> cast[uint64](24)) & cast[uint64](0xFF))
    p[1] = cast[uint8]((val >> cast[uint64](16)) & cast[uint64](0xFF))
    p[2] = cast[uint8]((val >> cast[uint64](8)) & cast[uint64](0xFF))
    p[3] = cast[uint8](val & cast[uint64](0xFF))
    return 0


# Read a 32-bit big-endian value from byte offset `off` of buffer `b`.
def arm64_p40_get_be32(b: uint64, off: int64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](b + cast[uint64](off))
    b0: uint64 = cast[uint64](p[0])
    b1: uint64 = cast[uint64](p[1])
    b2: uint64 = cast[uint64](p[2])
    b3: uint64 = cast[uint64](p[3])
    return (b0 << cast[uint64](24)) | (b1 << cast[uint64](16)) | (b2 << cast[uint64](8)) | b3


# 32-bit sequence-space add (mod 2^32), matching real TCP wraparound.
def arm64_p40_seq_add(a: uint64, b: uint64) -> uint64:
    return (a + b) & cast[uint64](0xFFFFFFFF)


# Deliver the per-slot reassembled byte i (slot-indexed receive buffer).
def arm64_p40_rx_byte(slot: int64, i: int64) -> uint8:
    if slot == P40_SLOT_SRV:
        return arm64_p40_rx0[i]
    return arm64_p40_rx1[i]


# Append `n` bytes from `src` to slot's in-order receive buffer.
def arm64_p40_rx_append(slot: int64, src: uint64, n: int64) -> int64:
    cur: int64 = arm64_p40_rxlen[slot]
    i: int64 = 0
    while i < n:
        if cur + i >= P40_RXCAP:
            return 0
        sp: Ptr[uint8] = cast[Ptr[uint8]](src + cast[uint64](i))
        bv: uint8 = sp[0]
        if slot == P40_SLOT_SRV:
            arm64_p40_rx0[cur + i] = bv
        else:
            arm64_p40_rx1[cur + i] = bv
        i = i + 1
    arm64_p40_rxlen[slot] = cur + n
    return n


# 16-bit ones-complement Internet checksum over `n` bytes at `b`.
def arm64_p40_checksum(b: uint64, n: int64) -> uint64:
    sum: uint64 = 0
    i: int64 = 0
    while i + 1 < n:
        sum = sum + arm64_p33_get_be16(b, i)
        i = i + 2
    if i < n:
        p: Ptr[uint8] = cast[Ptr[uint8]](b + cast[uint64](i))
        sum = sum + (cast[uint64](p[0]) << cast[uint64](8))
    while (sum >> cast[uint64](16)) != cast[uint64](0):
        sum = (sum & cast[uint64](0xFFFF)) + (sum >> cast[uint64](16))
    return (~sum) & cast[uint64](0xFFFF)


# Compute the TCP checksum over the IPv4 pseudo-header + TCP header + payload.
# `tcp` points at the TCP header; `tcplen` is header+payload length. The
# pseudo-header (src ip, dst ip, 0, proto=6, tcp length) is laid into the
# P40_PHDR_PA scratch followed by the TCP segment bytes, then summed.
def arm64_p40_tcp_checksum(tcp: uint64, tcplen: int64) -> uint64:
    p: uint64 = P40_PHDR_PA
    pp: Ptr[uint8] = cast[Ptr[uint8]](p)
    # Both endpoints are 127.0.0.1.
    pp[0] = P40_LOOP_IP0
    pp[1] = P40_LOOP_IP1
    pp[2] = P40_LOOP_IP2
    pp[3] = P40_LOOP_IP3
    pp[4] = P40_LOOP_IP0
    pp[5] = P40_LOOP_IP1
    pp[6] = P40_LOOP_IP2
    pp[7] = P40_LOOP_IP3
    pp[8] = cast[uint8](0)
    pp[9] = cast[uint8](P40_IP_PROTO_TCP)
    arm64_p33_put_be16(p, 10, cast[uint64](tcplen))
    # Copy the TCP segment after the 12-byte pseudo-header.
    i: int64 = 0
    while i < tcplen:
        sp: Ptr[uint8] = cast[Ptr[uint8]](tcp + cast[uint64](i))
        dp: Ptr[uint8] = cast[Ptr[uint8]](p + cast[uint64](12 + i))
        dp[0] = sp[0]
        i = i + 1
    return arm64_p40_checksum(p, 12 + tcplen)


# Build a full Ethernet+IPv4+TCP frame for `slot` into P40_FRAME_PA and deliver
# it synchronously to the loopback input path. `flags` is the TCP flag byte,
# `seq`/`ack` the sequence/ack numbers to stamp, `payload`/`plen` the optional
# data. Returns the total Ethernet frame length built.
def arm64_p40_send(slot: int64, flags: uint64, seq: uint64, ack: uint64, payload: uint64, plen: int64) -> int64:
    f: uint64 = P40_FRAME_PA
    total: int64 = P40_ETH_HDR + P40_IP_HDR + P40_TCP_HDR + plen
    arm64_p30_bzero(f, total + 8)

    eth: Ptr[uint8] = cast[Ptr[uint8]](f)
    # Loopback: dst MAC == src MAC == a fixed local MAC. Irrelevant to TCP but
    # keeps the frame well-formed end to end.
    eth[0] = cast[uint8](0x02)
    eth[1] = cast[uint8](0x00)
    eth[2] = cast[uint8](0x00)
    eth[3] = cast[uint8](0x00)
    eth[4] = cast[uint8](0x00)
    eth[5] = cast[uint8](0x01)
    eth[6] = cast[uint8](0x02)
    eth[7] = cast[uint8](0x00)
    eth[8] = cast[uint8](0x00)
    eth[9] = cast[uint8](0x00)
    eth[10] = cast[uint8](0x00)
    eth[11] = cast[uint8](0x01)
    arm64_p33_put_be16(f, 12, P40_ETHERTYPE_IPV4)

    # --- IPv4 header (offset 14) ---
    ip: uint64 = f + cast[uint64](P40_ETH_HDR)
    ipp: Ptr[uint8] = cast[Ptr[uint8]](ip)
    ipp[0] = cast[uint8](0x45)                           # version 4, IHL 5
    ipp[1] = cast[uint8](0)
    iptotal: uint64 = cast[uint64](P40_IP_HDR + P40_TCP_HDR + plen)
    arm64_p33_put_be16(ip, 2, iptotal)
    arm64_p33_put_be16(ip, 4, cast[uint64](0x4000))      # identification
    arm64_p33_put_be16(ip, 6, cast[uint64](0))
    ipp[8] = cast[uint8](64)                             # TTL
    ipp[9] = cast[uint8](P40_IP_PROTO_TCP)               # protocol = TCP
    arm64_p33_put_be16(ip, 10, cast[uint64](0))          # checksum placeholder
    ipp[12] = P40_LOOP_IP0
    ipp[13] = P40_LOOP_IP1
    ipp[14] = P40_LOOP_IP2
    ipp[15] = P40_LOOP_IP3
    ipp[16] = P40_LOOP_IP0
    ipp[17] = P40_LOOP_IP1
    ipp[18] = P40_LOOP_IP2
    ipp[19] = P40_LOOP_IP3
    ipcsum: uint64 = arm64_p40_checksum(ip, P40_IP_HDR)
    arm64_p33_put_be16(ip, 10, ipcsum)

    # --- TCP header (offset 14 + 20) ---
    tcp: uint64 = ip + cast[uint64](P40_IP_HDR)
    arm64_p33_put_be16(tcp, 0, arm64_p40_lport[slot])    # source port
    arm64_p33_put_be16(tcp, 2, arm64_p40_rport[slot])    # dest port
    arm64_p40_put_be32(tcp, 4, seq)                      # sequence number
    arm64_p40_put_be32(tcp, 8, ack)                      # acknowledgement
    tcpp: Ptr[uint8] = cast[Ptr[uint8]](tcp)
    tcpp[12] = cast[uint8]((P40_TCP_HDR / 4) << 4)       # data offset (5 words)
    tcpp[13] = cast[uint8](flags & cast[uint64](0xFF))   # flags
    arm64_p33_put_be16(tcp, 14, cast[uint64](0x8000))    # window
    arm64_p33_put_be16(tcp, 16, cast[uint64](0))         # checksum placeholder
    arm64_p33_put_be16(tcp, 18, cast[uint64](0))         # urgent pointer
    # Payload.
    j: int64 = 0
    while j < plen:
        dp: Ptr[uint8] = cast[Ptr[uint8]](tcp + cast[uint64](P40_TCP_HDR + j))
        sp: Ptr[uint8] = cast[Ptr[uint8]](payload + cast[uint64](j))
        dp[0] = sp[0]
        j = j + 1
    tcpcsum: uint64 = arm64_p40_tcp_checksum(tcp, P40_TCP_HDR + plen)
    arm64_p33_put_be16(tcp, 16, tcpcsum)

    _dsb_ish()
    # Hand the built frame straight to the in-guest loopback receive path.
    arm64_p40_input(f, total)
    return total


# The peer slot for a given slot (loopback: server<->client).
def arm64_p40_peer(slot: int64) -> int64:
    if slot == P40_SLOT_SRV:
        return P40_SLOT_CLI
    return P40_SLOT_SRV


# Loopback receive path: a frame built by arm64_p40_send is delivered here.
# Parse Ethernet+IPv4+TCP, VALIDATE the IPv4 + TCP checksums, identify the
# destination TCB by (dst ip, dst port), and run the TCP state machine. This
# is the real input half of the stack: every state transition (SYN -> SYN-ACK,
# SYN-ACK -> ACK + ESTABLISHED, data -> ACK, FIN -> ACK + state move) and every
# ack-number advance happens here against genuinely received bytes.
def arm64_p40_input(frame: uint64, flen: int64) -> int64:
    arm64_p40_loop_depth = arm64_p40_loop_depth + 1
    if arm64_p40_loop_depth > arm64_p40_loop_max:
        arm64_p40_loop_max = arm64_p40_loop_depth

    etype: uint64 = arm64_p33_get_be16(frame, 12)
    if etype != P40_ETHERTYPE_IPV4:
        arm64_p40_loop_depth = arm64_p40_loop_depth - 1
        return 0
    ip: uint64 = frame + cast[uint64](P40_ETH_HDR)
    ipp: Ptr[uint8] = cast[Ptr[uint8]](ip)
    ver: uint64 = (cast[uint64](ipp[0]) >> cast[uint64](4)) & cast[uint64](0xF)
    if ver != cast[uint64](4):
        arm64_p40_loop_depth = arm64_p40_loop_depth - 1
        return 0
    if cast[uint64](ipp[9]) != P40_IP_PROTO_TCP:
        arm64_p40_loop_depth = arm64_p40_loop_depth - 1
        return 0
    # Validate the IPv4 header checksum.
    if arm64_p40_checksum(ip, P40_IP_HDR) != cast[uint64](0):
        arm64_p40_csum_bad = 1
        arm64_p40_loop_depth = arm64_p40_loop_depth - 1
        return 0
    iptotal: int64 = cast[int64](arm64_p33_get_be16(ip, 2))
    tcp: uint64 = ip + cast[uint64](P40_IP_HDR)
    tcplen: int64 = iptotal - P40_IP_HDR
    # Validate the TCP checksum over the pseudo-header + segment.
    if arm64_p40_tcp_checksum(tcp, tcplen) != cast[uint64](0):
        arm64_p40_csum_bad = 1
        arm64_p40_loop_depth = arm64_p40_loop_depth - 1
        return 0
    arm64_p40_segs_in = arm64_p40_segs_in + 1

    dport: uint64 = arm64_p33_get_be16(tcp, 2)
    sport: uint64 = arm64_p33_get_be16(tcp, 0)
    seq: uint64 = arm64_p40_get_be32(tcp, 4)
    ack: uint64 = arm64_p40_get_be32(tcp, 8)
    tcpp: Ptr[uint8] = cast[Ptr[uint8]](tcp)
    doff: int64 = cast[int64]((cast[uint64](tcpp[12]) >> cast[uint64](4)) & cast[uint64](0xF)) * 4
    flags: uint64 = cast[uint64](tcpp[13])
    payload: uint64 = tcp + cast[uint64](doff)
    plen: int64 = tcplen - doff

    # Identify the destination TCB by local port.
    slot: int64 = -1
    if dport == arm64_p40_lport[P40_SLOT_SRV]:
        slot = P40_SLOT_SRV
    else:
        if dport == arm64_p40_lport[P40_SLOT_CLI]:
            slot = P40_SLOT_CLI
    if slot < 0:
        arm64_p40_loop_depth = arm64_p40_loop_depth - 1
        return 0

    arm64_p40_handle(slot, flags, seq, ack, payload, plen)
    arm64_p40_loop_depth = arm64_p40_loop_depth - 1
    return 0


# The TCP state machine for one received segment on `slot`.
def arm64_p40_handle(slot: int64, flags: uint64, seq: uint64, ack: uint64, payload: uint64, plen: int64) -> int64:
    st: int64 = arm64_p40_state[slot]
    is_syn: int64 = 0
    if (flags & P40_SYN) != cast[uint64](0):
        is_syn = 1
    is_ack: int64 = 0
    if (flags & P40_ACK) != cast[uint64](0):
        is_ack = 1
    is_fin: int64 = 0
    if (flags & P40_FIN) != cast[uint64](0):
        is_fin = 1

    # --- LISTEN: a SYN opens a passive connection -> SYN_RCVD + SYN-ACK ----
    if st == P40_LISTEN:
        if is_syn == 1:
            arm64_p40_irs[slot] = seq
            arm64_p40_rcv_nxt[slot] = arm64_p40_seq_add(seq, cast[uint64](1))   # SYN consumes 1 seq
            arm64_p40_iss[slot] = P40_SRV_ISN
            arm64_p40_snd_una[slot] = P40_SRV_ISN
            arm64_p40_snd_nxt[slot] = P40_SRV_ISN
            arm64_p40_state[slot] = P40_SYN_RCVD
            bm: Ptr[char] = "[arm64] Phase 40: server LISTEN -> recv SYN -> SYN_RCVD, sending SYN-ACK\n"
            _uart_puts(bm)
            # Send SYN-ACK: seq = our ISS, ack = rcv_nxt; SYN consumes a seq.
            arm64_p40_snd_nxt[slot] = arm64_p40_seq_add(arm64_p40_iss[slot], cast[uint64](1))
            arm64_p40_send(slot, P40_SYN | P40_ACK, arm64_p40_iss[slot], arm64_p40_rcv_nxt[slot], cast[uint64](0), 0)
        return 0

    # --- SYN_SENT: expect SYN-ACK -> send ACK -> ESTABLISHED --------------
    if st == P40_SYN_SENT:
        if is_syn == 1:
            if is_ack == 1:
                # SYN-ACK must acknowledge our SYN (ack == iss+1).
                if ack != arm64_p40_seq_add(arm64_p40_iss[slot], cast[uint64](1)):
                    return 0
                arm64_p40_irs[slot] = seq
                arm64_p40_rcv_nxt[slot] = arm64_p40_seq_add(seq, cast[uint64](1))
                arm64_p40_snd_una[slot] = ack
                arm64_p40_snd_nxt[slot] = ack
                arm64_p40_state[slot] = P40_ESTABLISHED
                arm64_p40_estab[slot] = 1
                em: Ptr[char] = "[arm64] Phase 40: client SYN_SENT -> recv SYN-ACK -> ESTABLISHED, sending ACK\n"
                _uart_puts(em)
                arm64_p40_send(slot, P40_ACK, arm64_p40_snd_nxt[slot], arm64_p40_rcv_nxt[slot], cast[uint64](0), 0)
        return 0

    # --- SYN_RCVD: the final ACK of the handshake -> ESTABLISHED ----------
    if st == P40_SYN_RCVD:
        if is_ack == 1:
            if ack == arm64_p40_seq_add(arm64_p40_iss[slot], cast[uint64](1)):
                arm64_p40_snd_una[slot] = ack
                arm64_p40_state[slot] = P40_ESTABLISHED
                arm64_p40_estab[slot] = 1
                em: Ptr[char] = "[arm64] Phase 40: server SYN_RCVD -> recv ACK -> ESTABLISHED\n"
                _uart_puts(em)
                # If this ACK also carried data (piggybacked), fall through to
                # the ESTABLISHED data handling below.
                if plen > 0:
                    arm64_p40_rx_data(slot, seq, payload, plen)
        return 0

    # --- ESTABLISHED: deliver in-order data + ACK it; handle peer FIN -----
    if st == P40_ESTABLISHED:
        if plen > 0:
            arm64_p40_rx_data(slot, seq, payload, plen)
        # A new outbound ACK number reflects bytes consumed; if the segment
        # acked our data, advance snd_una.
        if is_ack == 1:
            arm64_p40_snd_una[slot] = ack
        if is_fin == 1:
            # Peer is closing: FIN consumes one sequence number.
            arm64_p40_rcv_nxt[slot] = arm64_p40_seq_add(seq, cast[uint64](plen) + cast[uint64](1))
            arm64_p40_state[slot] = P40_CLOSE_WAIT
            fm: Ptr[char] = "[arm64] Phase 40: ESTABLISHED -> recv FIN -> CLOSE_WAIT, ACKing FIN\n"
            _uart_puts(fm)
            arm64_p40_send(slot, P40_ACK, arm64_p40_snd_nxt[slot], arm64_p40_rcv_nxt[slot], cast[uint64](0), 0)
        return 0

    # --- FIN_WAIT_1: the ACK of our FIN -> FIN_WAIT_2 (or simultaneous) ----
    if st == P40_FIN_WAIT_1:
        if is_ack == 1:
            if ack == arm64_p40_snd_nxt[slot]:
                arm64_p40_snd_una[slot] = ack
                arm64_p40_state[slot] = P40_FIN_WAIT_2
                wm: Ptr[char] = "[arm64] Phase 40: FIN_WAIT_1 -> recv ACK of our FIN -> FIN_WAIT_2\n"
                _uart_puts(wm)
        # A peer FIN here (it closes too) -> ACK it and move toward CLOSED.
        if is_fin == 1:
            arm64_p40_rcv_nxt[slot] = arm64_p40_seq_add(seq, cast[uint64](plen) + cast[uint64](1))
            arm64_p40_send(slot, P40_ACK, arm64_p40_snd_nxt[slot], arm64_p40_rcv_nxt[slot], cast[uint64](0), 0)
            arm64_p40_state[slot] = P40_TIME_WAIT
        return 0

    # --- FIN_WAIT_2: peer FIN -> ACK -> CLOSED (skip TIME_WAIT for the test) -
    if st == P40_FIN_WAIT_2:
        if is_fin == 1:
            arm64_p40_rcv_nxt[slot] = arm64_p40_seq_add(seq, cast[uint64](plen) + cast[uint64](1))
            cm: Ptr[char] = "[arm64] Phase 40: FIN_WAIT_2 -> recv peer FIN -> ACKing -> CLOSED\n"
            _uart_puts(cm)
            arm64_p40_send(slot, P40_ACK, arm64_p40_snd_nxt[slot], arm64_p40_rcv_nxt[slot], cast[uint64](0), 0)
            arm64_p40_state[slot] = P40_CLOSED
            arm64_p40_closed[slot] = 1
        return 0

    # --- LAST_ACK: the final ACK of our FIN -> CLOSED ---------------------
    if st == P40_LAST_ACK:
        if is_ack == 1:
            if ack == arm64_p40_snd_nxt[slot]:
                arm64_p40_snd_una[slot] = ack
                arm64_p40_state[slot] = P40_CLOSED
                arm64_p40_closed[slot] = 1
                lm: Ptr[char] = "[arm64] Phase 40: LAST_ACK -> recv final ACK -> CLOSED\n"
                _uart_puts(lm)
        return 0

    return 0


# Deliver in-order received data on `slot`: only accept the segment if its seq
# matches the expected rcv_nxt (real in-order semantics), append the bytes to
# the slot's reassembly buffer, advance rcv_nxt by the byte count, and send a
# pure ACK acknowledging the new rcv_nxt.
def arm64_p40_rx_data(slot: int64, seq: uint64, payload: uint64, plen: int64) -> int64:
    if seq != arm64_p40_rcv_nxt[slot]:
        # Out-of-order / duplicate: re-ACK the current rcv_nxt, drop the data.
        arm64_p40_send(slot, P40_ACK, arm64_p40_snd_nxt[slot], arm64_p40_rcv_nxt[slot], cast[uint64](0), 0)
        return 0
    arm64_p40_rx_append(slot, payload, plen)
    arm64_p40_rcv_nxt[slot] = arm64_p40_seq_add(seq, cast[uint64](plen))
    dm: Ptr[char] = "[arm64] Phase 40: delivered "
    _uart_puts(dm)
    _uart_puthex(cast[uint64](plen))
    dm2: Ptr[char] = " in-order bytes to slot "
    _uart_puts(dm2)
    _uart_puthex(cast[uint64](slot))
    dm3: Ptr[char] = ", ACKing rcv_nxt="
    _uart_puts(dm3)
    _uart_puthex(arm64_p40_rcv_nxt[slot])
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    arm64_p40_send(slot, P40_ACK, arm64_p40_snd_nxt[slot], arm64_p40_rcv_nxt[slot], cast[uint64](0), 0)
    return 0


# Initialize both TCBs to a fresh, CLOSED-derived starting state.
def arm64_p40_init() -> int64:
    arm64_p40_state[P40_SLOT_SRV] = P40_CLOSED
    arm64_p40_state[P40_SLOT_CLI] = P40_CLOSED
    arm64_p40_estab[P40_SLOT_SRV] = 0
    arm64_p40_estab[P40_SLOT_CLI] = 0
    arm64_p40_closed[P40_SLOT_SRV] = 0
    arm64_p40_closed[P40_SLOT_CLI] = 0
    arm64_p40_rxlen[P40_SLOT_SRV] = 0
    arm64_p40_rxlen[P40_SLOT_CLI] = 0
    # Server: local port = SRV_PORT (peer is the client port).
    arm64_p40_lport[P40_SLOT_SRV] = P40_SRV_PORT
    arm64_p40_rport[P40_SLOT_SRV] = P40_CLI_PORT
    # Client: local port = CLI_PORT (peer is the server port).
    arm64_p40_lport[P40_SLOT_CLI] = P40_CLI_PORT
    arm64_p40_rport[P40_SLOT_CLI] = P40_SRV_PORT
    arm64_p40_iss[P40_SLOT_SRV] = 0
    arm64_p40_iss[P40_SLOT_CLI] = 0
    arm64_p40_snd_nxt[P40_SLOT_SRV] = 0
    arm64_p40_snd_nxt[P40_SLOT_CLI] = 0
    arm64_p40_snd_una[P40_SLOT_SRV] = 0
    arm64_p40_snd_una[P40_SLOT_CLI] = 0
    arm64_p40_rcv_nxt[P40_SLOT_SRV] = 0
    arm64_p40_rcv_nxt[P40_SLOT_CLI] = 0
    arm64_p40_csum_bad = 0
    arm64_p40_segs_in = 0
    arm64_p40_loop_depth = 0
    arm64_p40_loop_max = 0
    arm64_p40_srv_data_ok = 0
    arm64_p40_cli_data_ok = 0
    arm64_p40_handshake_seen = 0
    return 0


# Compare slot's reassembled receive buffer against the expected payload bytes
# of `which` (0 = client message, 1 = server message). Returns 1 on a
# byte-identical match of exactly `n` bytes, else 0.
def arm64_p40_verify_rx(slot: int64, which: int64, n: int64) -> int64:
    if arm64_p40_rxlen[slot] != n:
        return 0
    i: int64 = 0
    while i < n:
        got: uint8 = arm64_p40_rx_byte(slot, i)
        exp: uint8 = cast[uint8](0)
        if which == 0:
            exp = arm64_p40_cli_msg_byte(i)
        else:
            exp = arm64_p40_srv_msg_byte(i)
        if got != exp:
            return 0
        i = i + 1
    return 1


# Phase-40 entry point (hand-off from arm64_p39_finish on a Phase-39 PASS).
# Runs the full TCP loopback scenario synchronously and halts at the verdict.
def arm64_p40_run() -> int64:
    intro: Ptr[char] = "[arm64] Phase 40: in-guest TCP loopback (127.0.0.1) three-way handshake + bidirectional data + FIN teardown\n"
    _uart_puts(intro)
    nl: Ptr[char] = "\n"

    arm64_p40_init()

    # --- passive open: the server LISTENs on port 7777 --------------------
    arm64_p40_state[P40_SLOT_SRV] = P40_LISTEN
    lm: Ptr[char] = "[arm64] Phase 40: server tcp_listen on 127.0.0.1:7777 -> LISTEN\n"
    _uart_puts(lm)

    # --- active open: the client tcp_connect()s -> SYN_SENT + send SYN -----
    arm64_p40_iss[P40_SLOT_CLI] = P40_CLI_ISN
    arm64_p40_snd_una[P40_SLOT_CLI] = P40_CLI_ISN
    # SYN consumes one sequence number, so snd_nxt advances past it.
    arm64_p40_snd_nxt[P40_SLOT_CLI] = arm64_p40_seq_add(P40_CLI_ISN, cast[uint64](1))
    arm64_p40_state[P40_SLOT_CLI] = P40_SYN_SENT
    cm: Ptr[char] = "[arm64] Phase 40: client tcp_connect 127.0.0.1:7777 -> SYN_SENT, sending SYN\n"
    _uart_puts(cm)
    # Sending the SYN drives the whole handshake synchronously through the
    # loopback: SYN -> (server) SYN-ACK -> (client) ACK -> both ESTABLISHED.
    arm64_p40_send(P40_SLOT_CLI, P40_SYN, P40_CLI_ISN, cast[uint64](0), cast[uint64](0), 0)

    # Handshake verification.
    if arm64_p40_estab[P40_SLOT_CLI] == 1:
        if arm64_p40_estab[P40_SLOT_SRV] == 1:
            arm64_p40_handshake_seen = 1
    hm: Ptr[char] = "[arm64] Phase 40: handshake complete; client_estab="
    _uart_puts(hm)
    _uart_puthex(cast[uint64](arm64_p40_estab[P40_SLOT_CLI]))
    hm2: Ptr[char] = " server_estab="
    _uart_puts(hm2)
    _uart_puthex(cast[uint64](arm64_p40_estab[P40_SLOT_SRV]))
    _uart_puts(nl)

    # --- data exchange: client -> server, then server -> client -----------
    # Lay the client's outbound payload into a scratch buffer at FRAME+0x800
    # region? No: build payloads in dedicated clear scratch. Reuse PHDR area's
    # neighbour at a fresh PA to avoid clobbering the frame builder mid-send.
    climsg: uint64 = 0x46102000
    i: int64 = 0
    while i < P40_CLI_MSG_LEN:
        cp: Ptr[uint8] = cast[Ptr[uint8]](climsg + cast[uint64](i))
        cp[0] = arm64_p40_cli_msg_byte(i)
        i = i + 1
    srvmsg: uint64 = 0x46103000
    k: int64 = 0
    while k < P40_SRV_MSG_LEN:
        sp: Ptr[uint8] = cast[Ptr[uint8]](srvmsg + cast[uint64](k))
        sp[0] = arm64_p40_srv_msg_byte(k)
        k = k + 1

    # Client sends its payload (PSH|ACK). The server delivers + ACKs in-order
    # synchronously through the loopback.
    if arm64_p40_handshake_seen == 1:
        dm: Ptr[char] = "[arm64] Phase 40: client sending "
        _uart_puts(dm)
        _uart_puthex(cast[uint64](P40_CLI_MSG_LEN))
        dm2: Ptr[char] = "-byte payload to server\n"
        _uart_puts(dm2)
        seqc: uint64 = arm64_p40_snd_nxt[P40_SLOT_CLI]
        arm64_p40_send(P40_SLOT_CLI, P40_PSH | P40_ACK, seqc, arm64_p40_rcv_nxt[P40_SLOT_CLI], climsg, P40_CLI_MSG_LEN)
        arm64_p40_snd_nxt[P40_SLOT_CLI] = arm64_p40_seq_add(seqc, cast[uint64](P40_CLI_MSG_LEN))

        # Server replies with its own payload (PSH|ACK).
        sm: Ptr[char] = "[arm64] Phase 40: server sending "
        _uart_puts(sm)
        _uart_puthex(cast[uint64](P40_SRV_MSG_LEN))
        sm2: Ptr[char] = "-byte payload to client\n"
        _uart_puts(sm2)
        seqs: uint64 = arm64_p40_snd_nxt[P40_SLOT_SRV]
        arm64_p40_send(P40_SLOT_SRV, P40_PSH | P40_ACK, seqs, arm64_p40_rcv_nxt[P40_SLOT_SRV], srvmsg, P40_SRV_MSG_LEN)
        arm64_p40_snd_nxt[P40_SLOT_SRV] = arm64_p40_seq_add(seqs, cast[uint64](P40_SRV_MSG_LEN))

    # Verify byte-identical delivery in both directions.
    if arm64_p40_verify_rx(P40_SLOT_SRV, 0, P40_CLI_MSG_LEN) == 1:
        arm64_p40_srv_data_ok = 1
    if arm64_p40_verify_rx(P40_SLOT_CLI, 1, P40_SRV_MSG_LEN) == 1:
        arm64_p40_cli_data_ok = 1

    # --- teardown: the client closes first (active close) -----------------
    if arm64_p40_handshake_seen == 1:
        tm: Ptr[char] = "[arm64] Phase 40: client tcp_close -> FIN_WAIT_1, sending FIN\n"
        _uart_puts(tm)
        # Client sends FIN (FIN|ACK). The server ACKs (-> CLOSE_WAIT), then the
        # server closes too (FIN), the client ACKs and CLOSEs. We orchestrate
        # the server's matching close right after its CLOSE_WAIT transition.
        finseq: uint64 = arm64_p40_snd_nxt[P40_SLOT_CLI]
        arm64_p40_state[P40_SLOT_CLI] = P40_FIN_WAIT_1
        arm64_p40_snd_nxt[P40_SLOT_CLI] = arm64_p40_seq_add(finseq, cast[uint64](1))   # FIN consumes a seq
        arm64_p40_send(P40_SLOT_CLI, P40_FIN | P40_ACK, finseq, arm64_p40_rcv_nxt[P40_SLOT_CLI], cast[uint64](0), 0)

        # The server is now in CLOSE_WAIT (it ACKed the client's FIN). It closes:
        # send its FIN (-> LAST_ACK); the client ACKs it (-> CLOSED) and the
        # client's FIN_WAIT_2 receives the server FIN (-> CLOSED).
        if arm64_p40_state[P40_SLOT_SRV] == P40_CLOSE_WAIT:
            sm3: Ptr[char] = "[arm64] Phase 40: server tcp_close -> LAST_ACK, sending FIN\n"
            _uart_puts(sm3)
            sfin: uint64 = arm64_p40_snd_nxt[P40_SLOT_SRV]
            arm64_p40_state[P40_SLOT_SRV] = P40_LAST_ACK
            arm64_p40_snd_nxt[P40_SLOT_SRV] = arm64_p40_seq_add(sfin, cast[uint64](1))
            arm64_p40_send(P40_SLOT_SRV, P40_FIN | P40_ACK, sfin, arm64_p40_rcv_nxt[P40_SLOT_SRV], cast[uint64](0), 0)

    # --- verdict ----------------------------------------------------------
    sm4: Ptr[char] = "[arm64] Phase 40 summary: segs_in="
    _uart_puts(sm4)
    _uart_puthex(cast[uint64](arm64_p40_segs_in))
    s1: Ptr[char] = " loop_max_depth="
    _uart_puts(s1)
    _uart_puthex(cast[uint64](arm64_p40_loop_max))
    s2: Ptr[char] = " csum_bad="
    _uart_puts(s2)
    _uart_puthex(cast[uint64](arm64_p40_csum_bad))
    _uart_puts(nl)

    s3: Ptr[char] = "[arm64] Phase 40 summary: cli_estab="
    _uart_puts(s3)
    _uart_puthex(cast[uint64](arm64_p40_estab[P40_SLOT_CLI]))
    s4: Ptr[char] = " srv_estab="
    _uart_puts(s4)
    _uart_puthex(cast[uint64](arm64_p40_estab[P40_SLOT_SRV]))
    s5: Ptr[char] = " srv_rx_ok="
    _uart_puts(s5)
    _uart_puthex(cast[uint64](arm64_p40_srv_data_ok))
    s6: Ptr[char] = " cli_rx_ok="
    _uart_puts(s6)
    _uart_puthex(cast[uint64](arm64_p40_cli_data_ok))
    _uart_puts(nl)

    s7: Ptr[char] = "[arm64] Phase 40 summary: cli_state="
    _uart_puts(s7)
    _uart_puthex(cast[uint64](arm64_p40_state[P40_SLOT_CLI]))
    s8: Ptr[char] = " srv_state="
    _uart_puts(s8)
    _uart_puthex(cast[uint64](arm64_p40_state[P40_SLOT_SRV]))
    s9: Ptr[char] = " cli_closed="
    _uart_puts(s9)
    _uart_puthex(cast[uint64](arm64_p40_closed[P40_SLOT_CLI]))
    s10: Ptr[char] = " srv_closed="
    _uart_puts(s10)
    _uart_puthex(cast[uint64](arm64_p40_closed[P40_SLOT_SRV]))
    _uart_puts(nl)

    # Independent ack-number cross-check: each side's rcv_nxt must have advanced
    # past the peer's ISN by exactly (1 SYN + payload bytes + 1 FIN).
    cli_expect_rcv: uint64 = arm64_p40_seq_add(P40_SRV_ISN, cast[uint64](1 + P40_SRV_MSG_LEN + 1))
    srv_expect_rcv: uint64 = arm64_p40_seq_add(P40_CLI_ISN, cast[uint64](1 + P40_CLI_MSG_LEN + 1))
    ack_ok: int64 = 1
    if arm64_p40_rcv_nxt[P40_SLOT_CLI] != cli_expect_rcv:
        ack_ok = 0
    if arm64_p40_rcv_nxt[P40_SLOT_SRV] != srv_expect_rcv:
        ack_ok = 0
    a1: Ptr[char] = "[arm64] Phase 40 summary: cli_rcv_nxt="
    _uart_puts(a1)
    _uart_puthex(arm64_p40_rcv_nxt[P40_SLOT_CLI])
    a2: Ptr[char] = " (expect "
    _uart_puts(a2)
    _uart_puthex(cli_expect_rcv)
    a3: Ptr[char] = ") srv_rcv_nxt="
    _uart_puts(a3)
    _uart_puthex(arm64_p40_rcv_nxt[P40_SLOT_SRV])
    a4: Ptr[char] = " (expect "
    _uart_puts(a4)
    _uart_puthex(srv_expect_rcv)
    a5: Ptr[char] = ") ack_ok="
    _uart_puts(a5)
    _uart_puthex(cast[uint64](ack_ok))
    _uart_puts(nl)

    ok: int64 = 1
    # Both endpoints completed the three-way handshake.
    if arm64_p40_handshake_seen == 0:
        ok = 0
    if arm64_p40_estab[P40_SLOT_CLI] == 0:
        ok = 0
    if arm64_p40_estab[P40_SLOT_SRV] == 0:
        ok = 0
    # Both payloads arrived byte-identical.
    if arm64_p40_srv_data_ok == 0:
        ok = 0
    if arm64_p40_cli_data_ok == 0:
        ok = 0
    # Every received segment passed its checksum.
    if arm64_p40_csum_bad != 0:
        ok = 0
    # The ack numbers advanced by exactly the bytes consumed (SYN+data+FIN).
    if ack_ok == 0:
        ok = 0
    # Both sides reached CLOSED after the orderly teardown.
    if arm64_p40_closed[P40_SLOT_CLI] == 0:
        ok = 0
    if arm64_p40_closed[P40_SLOT_SRV] == 0:
        ok = 0
    if arm64_p40_state[P40_SLOT_CLI] != P40_CLOSED:
        ok = 0
    if arm64_p40_state[P40_SLOT_SRV] != P40_CLOSED:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 40: two in-kernel TCP control blocks (a passive-open server + an active-open client, both 127.0.0.1) completed a real three-way handshake (SYN -> SYN-ACK -> ACK) over an in-guest loopback datapath, each segment carrying a real 20-byte TCP header with real seq/ack numbers and a real TCP checksum over the IPv4 pseudo-header; both sides reached ESTABLISHED, exchanged distinct payloads in BOTH directions that arrived byte-identical with ack numbers advancing exactly by the bytes consumed, then tore the connection down with a real FIN/ACK exchange to CLOSED on both sides\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 40 PASS: TCP loopback three-way handshake + bidirectional data + FIN teardown (both sides ESTABLISHED->CLOSED, payloads byte-identical, real seq/ack + pseudo-header checksum)\n"
        _uart_puts(pp)
        # Hand off to Phase 41 (real EL0 demand-paged anonymous mmap + munmap).
        # Phase 41 needs no disk/net; it runs a single EL0 task whose first touch
        # of an unmapped anon window faults pages in on demand, then munmaps and
        # re-faults to prove the mapping is truly gone. IRQs masked (deterministic;
        # the page-ins all happen on the synchronous abort path).
        arm64_p41_run()
    else:
        fp: Ptr[char] = "[arm64] Phase 40 FAIL: TCP loopback verdict failed\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# ===========================================================================
# Phase 41 — REAL EL0 demand-paged anonymous mmap (fault-backed) + munmap.
# ===========================================================================

# Distinct per-page sentinel so a read-back proves the RIGHT page paged in.
def arm64_p41_sentinel_for(idx: int64) -> uint64:
    u: uint64 = cast[uint64](idx)
    return P41_SENTINEL_BASE | (u << cast[uint64](8)) | u


# VA of page `idx` inside the demand window.
def arm64_p41_va_for(idx: int64) -> uint64:
    return P41_WINDOW_BASE + (cast[uint64](idx) * P41_PAGE_SIZE)


# Install the window's L3 table under its (currently UNMAPPED) L2 slot, zeroed so
# every 4 KiB slot still translation-faults on first touch. Idempotent.
def arm64_p41_install_l3() -> int64:
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    if l2[cast[int64](P41_WINDOW_L2_INDEX)] != cast[uint64](0):
        arm64_p41_l3_wired = 1
        return 0                          # L3 already wired under this L2 slot

    # Zero the brand-new L3 table so every still-unmapped 4 KiB slot keeps
    # faulting (each page is a genuine first-touch translation fault).
    l3: Ptr[uint64] = cast[Ptr[uint64]](P41_L3)
    i: int64 = 0
    while i < 512:
        l3[i] = cast[uint64](0)
        i = i + 1
    _dsb_ish()

    # Point the window's L2 slot at the new L3 table (table descriptor).
    l2[cast[int64](P41_WINDOW_L2_INDEX)] = P41_L3 | DESC_TABLE
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    arm64_p41_l3_wired = 1
    return 0


# Allocate the next fresh ZEROED physical page from the per-phase pool, install it
# as the L3 PTE backing VA `va` with EL0 RW + non-exec + inner-shareable attrs,
# then invalidate ONLY that VA's stale translation so EL0 sees the new mapping.
def arm64_p41_map_page(va: uint64) -> uint64:
    arm64_p41_install_l3()

    # Hand out the next pool page.
    page_pa: uint64 = P41_POOL_BASE + (cast[uint64](arm64_p41_next_page) * P41_PAGE_SIZE)
    arm64_p41_next_page = arm64_p41_next_page + 1

    # Zero the backing physical page (a fresh anonymous page must start clean).
    pg: Ptr[uint64] = cast[Ptr[uint64]](page_pa)
    j: int64 = 0
    while j < 512:
        pg[j] = cast[uint64](0)
        j = j + 1
    _dsb_ish()

    # L3 index of `va` = VA[20:12].
    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P41_L3)
    l3[cast[int64](l3_index)] = page_pa | P41_PAGE_FLAGS

    # Publish the L3 edit, then flush ONLY this page's stale (faulting)
    # translation. The TLBI VAAE1IS operand is the VA's page number (VA >> 12).
    _dsb_ish()
    _tlbi_vaae1is(va >> cast[uint64](12))
    _dsb_ish()
    _isb()
    return l3_index


# Tear the whole region down (the munmap teardown): zero EVERY page's L3 PTE,
# wipe the backing pool pages, reset the pool cursor, drop the L2->L3 table link,
# and flush the TLB so a subsequent EL0 touch translation-faults afresh.
def arm64_p41_unmap_region() -> int64:
    l3: Ptr[uint64] = cast[Ptr[uint64]](P41_L3)
    idx: int64 = 0
    while idx < P41_N_PAGES:
        va: uint64 = arm64_p41_va_for(idx)
        l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
        # Drop the PTE.
        l3[cast[int64](l3_index)] = cast[uint64](0)
        # Wipe the backing physical page (free it back clean).
        pg: Ptr[uint64] = cast[Ptr[uint64]](P41_POOL_BASE + (cast[uint64](idx) * P41_PAGE_SIZE))
        j: int64 = 0
        while j < 512:
            pg[j] = cast[uint64](0)
            j = j + 1
        idx = idx + 1
    _dsb_ish()

    # Drop the window's L2 slot entirely (no L3 table reachable -> translation
    # fault at the L2 level on the next touch).
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P41_WINDOW_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    arm64_p41_next_page = 0
    arm64_p41_l3_wired = 0
    arm64_p41_unmapped = 1
    return 0


# Phase-41 demand-paging fault entry. Called from arm64_sync_handler for a data
# abort from EL0 while the demo is live. Decodes ESR_EL1.ISS.DFSC: a TRANSLATION
# fault inside the window is either (a) a first-touch demand-page (region LIVE):
# allocate a fresh page, install the EL0-RW non-exec PTE, resume EL0 (return 1);
# or (b) a post-munmap touch (region UNMAPPED): the mapping is truly gone — DO
# NOT re-page; latch it and run the verdict cleanly (never returns). Anything
# else (permission fault, or a translation fault OUTSIDE the window) returns 0 so
# the fatal-fault reaper runs — real bugs are never masked.
def arm64_p41_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        # Not a translation fault (e.g. a permission fault) — not demand-pageable.
        return 0

    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    # Is the faulting page inside the demand window [BASE, BASE + N_PAGES*4KiB)?
    win_top: uint64 = P41_WINDOW_BASE + (cast[uint64](P41_N_PAGES) * P41_PAGE_SIZE)
    if page_va < P41_WINDOW_BASE:
        arm64_p41_outside = arm64_p41_outside + 1
        return 0
    if page_va >= win_top:
        arm64_p41_outside = arm64_p41_outside + 1
        return 0

    # Inside the window. If the region has already been UNMAPPED, this is the
    # post-munmap re-touch: the mapping is genuinely gone. Catch it CLEANLY (do
    # not re-page, do not crash the kernel), latch it, and run the verdict.
    if arm64_p41_unmapped != 0:
        rfm: Ptr[char] = "[arm64] Phase 41: post-munmap touch of VA "
        _uart_puts(rfm)
        _uart_puthex(page_va)
        rfm2: Ptr[char] = " faulted again (region truly unmapped; no re-page)\n"
        _uart_puts(rfm2)
        arm64_p41_refault_ok = 1
        arm64_p41_finish(cast[uint64](0))
        # Unreachable: arm64_p41_finish halts. Safety loop if it falls through.
        while True:
            _wfi()

    # Region LIVE: first-touch demand-page this window page and resume EL0.
    idx: int64 = cast[int64]((page_va - P41_WINDOW_BASE) >> cast[uint64](12))
    arm64_p41_map_page(page_va)
    arm64_p41_mapped_mask = arm64_p41_mapped_mask | (cast[uint64](1) << cast[uint64](idx))
    arm64_p41_faults = arm64_p41_faults + 1

    m: Ptr[char] = "[arm64] Phase 41 demand fault: paged in anon VA "
    _uart_puts(m)
    _uart_puthex(page_va)
    pi: Ptr[char] = " (page "
    _uart_puts(pi)
    _uart_puthex(cast[uint64](idx))
    cl: Ptr[char] = ")\n"
    _uart_puts(cl)
    return 1


# Materialise the Phase-41 EL0 routine into USER_CODE_BASE. For each of N_PAGES
# pages: load the page VA + its sentinel, str (FAULTS first touch; kernel pages
# in then resumes here so the store completes), then ldr it back and hand
# (idx, value) to the kernel via SYS_P41_REPORT_NR. Then write(1, msg, len),
# munmap(base, len) the region, and FINALLY str to page 0 again (FAULTS AGAIN —
# the region is gone; the kernel catches it cleanly and runs the verdict). A
# trailing exit(0) is emitted for safety in case the re-touch were ever re-paged.
# GPR-only (no FP).
def arm64_build_p41_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE
    idx: int64 = 0
    while idx < P41_N_PAGES:
        va: uint64 = arm64_p41_va_for(idx)
        sent: uint64 = arm64_p41_sentinel_for(idx)

        # x10 = VA ; x9 = sentinel ; str x9,[x10] (faults -> demand-paged)
        a = _emit_load_imm64(a, cast[uint64](10), va)
        a = _emit_load_imm64(a, cast[uint64](9), sent)
        a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
        # x9 = 0 ; ldr x9,[x10]  (read the sentinel back through the new page)
        a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
        a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
        # report(idx, value): x0 = idx ; x1 = x9 ; x8 = 590 ; svc #0
        a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](idx))
        # mov x1, x9  (ORR x1, xzr, x9) = 0xAA0003E1 | (9<<16) = 0xAA0903E1
        a = _emit_word(a, cast[uint64](0xAA0003E1) | (cast[uint64](9) << cast[uint64](16)))
        a = _emit_load_imm64(a, cast[uint64](8), SYS_P41_REPORT_NR)
        a = _emit_word(a, cast[uint64](0xD4000001))
        idx = idx + 1

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 592; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), P41_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P41_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # munmap(base, len): x0 = base; x1 = N_PAGES*4KiB; x8 = 591; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P41_WINDOW_BASE)
    a = _emit_load_imm64(a, cast[uint64](1), cast[uint64](P41_N_PAGES) * P41_PAGE_SIZE)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P41_MUNMAP_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x10 = page0 VA ; x9 = a fresh value ; str x9,[x10]  (FAULTS AGAIN; region
    # gone -> kernel catches cleanly + runs the verdict; never returns here)
    a = _emit_load_imm64(a, cast[uint64](10), P41_WINDOW_BASE)
    a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0xDEAD41DEAD41DEAD))
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # exit(0): x0 = 0; x8 = 593; svc #0  (only reached if the re-touch were re-paged)
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P41_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-41 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. REPORT records + verifies one (page idx, read-back value) pair; MUNMAP
# tears the region down; write emits to the UART; exit runs the verdict + halts.
def arm64_p41_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P41_REPORT_NR:
        idx: int64 = cast[int64](a0)
        arm64_p41_reports = arm64_p41_reports + 1
        want: uint64 = arm64_p41_sentinel_for(idx)

        r0: Ptr[char] = "[arm64] Phase 41 read-back page "
        _uart_puts(r0)
        _uart_puthex(a0)
        ar: Ptr[char] = " -> "
        _uart_puts(ar)
        _uart_puthex(a1)
        _uart_puts(nl)

        if a1 == want:
            # Independently confirm the BACKING physical page holds the sentinel,
            # so the demand mapping truly reached the pool page (not a stale alias).
            back: Ptr[uint64] = cast[Ptr[uint64]](P41_POOL_BASE + (cast[uint64](idx) * P41_PAGE_SIZE))
            if back[0] == want:
                arm64_p41_correct_mask = arm64_p41_correct_mask | (cast[uint64](1) << cast[uint64](idx))
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P41_MUNMAP_NR:
        um: Ptr[char] = "[arm64] Phase 41 munmap: tearing down anon region [base="
        _uart_puts(um)
        _uart_puthex(a0)
        um2: Ptr[char] = " len="
        _uart_puts(um2)
        _uart_puthex(a1)
        um3: Ptr[char] = "] (drop PTEs + free pages + flush TLB)\n"
        _uart_puts(um3)
        arm64_p41_unmap_region()
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P41_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(41) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_P41_EXIT_NR:
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit(41) syscall serviced\n"
        _uart_puts(em)
        arm64_p41_finish(a0)
        # Unreachable: arm64_p41_finish halts. Safety loop if it falls through.
        while True:
            _wfi()

    bm: Ptr[char] = "[arm64] EL0 unknown syscall (phase 41)\n"
    _uart_puts(bm)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-41 verdict. PASS iff: exactly N_PAGES demand faults serviced (one per
# page), every page mapped, every read-back matched its sentinel (incl. the
# backing physical page), no translation fault fired OUTSIDE the window, both
# report syscalls arrived, the region was UNMAPPED, AND the post-munmap re-touch
# faulted again cleanly (the mapping is truly gone). Print the summary, then halt
# deterministically. Never returns.
def arm64_p41_finish(code: uint64) -> int64:
    arm64_p41_active = 0
    nl: Ptr[char] = "\n"

    fc: Ptr[char] = "[arm64] Phase 41 demand-paging: "
    _uart_puts(fc)
    _uart_puthex(cast[uint64](arm64_p41_faults))
    fs: Ptr[char] = " faults serviced\n"
    _uart_puts(fs)

    sm: Ptr[char] = "[arm64] Phase 41 summary: faults="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p41_faults))
    sm2: Ptr[char] = " mapped_mask="
    _uart_puts(sm2)
    _uart_puthex(arm64_p41_mapped_mask)
    sm3: Ptr[char] = " correct_mask="
    _uart_puts(sm3)
    _uart_puthex(arm64_p41_correct_mask)
    sm4: Ptr[char] = " reports="
    _uart_puts(sm4)
    _uart_puthex(cast[uint64](arm64_p41_reports))
    sm5: Ptr[char] = " outside="
    _uart_puts(sm5)
    _uart_puthex(cast[uint64](arm64_p41_outside))
    sm6: Ptr[char] = " unmapped="
    _uart_puts(sm6)
    _uart_puthex(cast[uint64](arm64_p41_unmapped))
    sm7: Ptr[char] = " refault_ok="
    _uart_puts(sm7)
    _uart_puthex(cast[uint64](arm64_p41_refault_ok))
    _uart_puts(nl)

    full: uint64 = (cast[uint64](1) << cast[uint64](P41_N_PAGES)) - cast[uint64](1)

    ok: int64 = 1
    # The post-munmap re-touch is what drives this verdict (code==0 from the
    # clean refault path), but a defensive exit(0) reaches here too.
    if arm64_p41_faults != P41_N_PAGES:
        ok = 0
    if arm64_p41_mapped_mask != full:
        ok = 0
    if arm64_p41_correct_mask != full:
        ok = 0
    if arm64_p41_outside != 0:
        ok = 0
    if arm64_p41_reports != P41_N_PAGES:
        ok = 0
    if arm64_p41_unmapped == 0:
        ok = 0
    if arm64_p41_refault_ok == 0:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 41: an EL0 task reserved an UNMAPPED anonymous VA window; the first touch of each of two distinct pages raised a translation Data Abort that the kernel serviced by allocating a fresh zeroed physical page and installing an EL0 RW + non-executable + inner-shareable L3 PTE, resuming the faulting store so it retried and completed; a known per-page sentinel written from EL0 read back byte-identical (verified through both the EL0 mapping AND the backing physical page); the task then munmap'd the region (PTEs dropped, backing pages freed, TLB flushed) and re-touched it, which faulted ANEW (the mapping is truly gone) and the kernel caught that fault cleanly without re-paging or crashing\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 41 PASS: EL0 demand-paged anonymous mmap (fault-backed) + munmap (two pages faulted in on demand, sentinel round-tripped, region unmapped, re-touch faulted again cleanly)\n"
        _uart_puts(pp)
        # Hand off to Phase 42 (real EL0 FILE-backed mmap, demand-paged from disk).
        # Phase 42 reuses the Phase-30 virtio-blk primitive to pull each faulting
        # page's bytes off the on-disk file extent; IRQs masked (deterministic; the
        # page-ins + disk reads all happen on the synchronous abort path).
        arm64_p42_run()
    else:
        fp: Ptr[char] = "[arm64] Phase 41 FAIL: demand-paged anon mmap + munmap verdict failed\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-41 entry point (hand-off from arm64_p40_run on a Phase-40 PASS). Restore
# the kernel's identity TTBR0, force the window's L2 slot UNMAPPED (so the first
# touch of every page genuinely translation-faults), build the EL0 routine +
# message, arm Phase-41 dispatch, and ERET into the demand task at EL0t with IRQs
# masked (deterministic; the page-ins all happen on the synchronous abort path).
# Never returns (the task's post-munmap re-fault runs the verdict + halts).
def arm64_p41_run() -> int64:
    intro: Ptr[char] = "[arm64] Phase 41: EL0 demand-paged anonymous mmap (fault-backed) + munmap\n"
    _uart_puts(intro)

    # Mask EL1 IRQs: Phase 41 is a single-task, abort-driven demo; no scheduler.
    _msr_daifset(2)

    # Restore the kernel's identity-only TTBR0 (be explicit), then flush the TLB.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Force the window's L2 slot UNMAPPED so the first touch of every page raises
    # a translation Data Abort (a clean, repeatable initial state).
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P41_WINDOW_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Seed Phase-41 bookkeeping.
    arm64_p41_faults = 0
    arm64_p41_next_page = 0
    arm64_p41_l3_wired = 0
    arm64_p41_mapped_mask = cast[uint64](0)
    arm64_p41_correct_mask = cast[uint64](0)
    arm64_p41_outside = 0
    arm64_p41_reports = 0
    arm64_p41_unmapped = 0
    arm64_p41_refault_ok = 0

    p41msg: Ptr[char] = "Hello from a demand-paged + munmap'd EL0 anon mapping\n"
    msg_len: uint64 = _copy_msg_to(p41msg, P41_MSG_BASE)
    arm64_build_p41_routine(msg_len)

    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_p41_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 demand-paged anon mmap task (2 pages, then munmap + re-fault)\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; first store faults, kernel pages in
    # Unreachable: the task's post-munmap re-fault runs the verdict + halts.
    while True:
        _wfi()
    return 0


# ===========================================================================
# Phase 42 — REAL EL0 FILE-backed mmap, demand-paged from the on-disk device.
# ===========================================================================

# The known on-disk file signature for page `idx` (first 8 bytes of that page's
# disk extent). Distinct per page so a read-back proves the RIGHT file offset
# paged in. The test seeds the disk with exactly this value at sector
# P42_FILE_LBA + idx*SECTORS_PER_PAGE (little-endian).
def arm64_p42_file_sig_for(idx: int64) -> uint64:
    u: uint64 = cast[uint64](idx)
    return P42_FILE_SIG_BASE | (u << cast[uint64](8)) | u


# VA of page `idx` inside the file-backed window.
def arm64_p42_va_for(idx: int64) -> uint64:
    return P42_WINDOW_BASE + (cast[uint64](idx) * P42_PAGE_SIZE)


# First disk sector (LBA) backing page `idx`.
def arm64_p42_lba_for(idx: int64) -> uint64:
    return P42_FILE_LBA + (cast[uint64](idx) * P42_SECTORS_PER_PAGE)


# Install the window's L3 table under its (currently UNMAPPED) L2 slot, zeroed so
# every 4 KiB slot still translation-faults on first touch. Idempotent.
def arm64_p42_install_l3() -> int64:
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    if l2[cast[int64](P42_WINDOW_L2_INDEX)] != cast[uint64](0):
        arm64_p42_l3_wired = 1
        return 0                          # L3 already wired under this L2 slot

    l3: Ptr[uint64] = cast[Ptr[uint64]](P42_L3)
    i: int64 = 0
    while i < 512:
        l3[i] = cast[uint64](0)
        i = i + 1
    _dsb_ish()

    l2[cast[int64](P42_WINDOW_L2_INDEX)] = P42_L3 | DESC_TABLE
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()
    arm64_p42_l3_wired = 1
    return 0


# Read the 4 KiB file page backing VA-page `idx` off the virtio-blk device into
# physical page `page_pa`. Issues SECTORS_PER_PAGE single-sector reads, each into
# the matching 512-byte slice of the page. Returns 1 iff every sector read OK.
def arm64_p42_read_page_from_disk(idx: int64, page_pa: uint64) -> int64:
    base: uint64 = arm64_p42_disk_base
    lba0: uint64 = arm64_p42_lba_for(idx)
    s: uint64 = cast[uint64](0)
    ok: int64 = 1
    while s < P42_SECTORS_PER_PAGE:
        dst: uint64 = page_pa + (s * cast[uint64](SECTOR_SIZE))
        r: int64 = arm64_p30_read_sector_into(base, lba0 + s, dst)
        if r == 0:
            ok = 0
        s = s + cast[uint64](1)
    _dsb_ish()
    return ok


# Allocate the next fresh physical page from the per-phase pool, READ the file
# bytes for VA `va`'s page off disk into it (REAL disk read, not memset), install
# it as the L3 PTE backing `va` with EL0 RO + non-exec + inner-shareable attrs,
# then invalidate ONLY that VA's stale translation so EL0 sees the new mapping.
def arm64_p42_map_page(va: uint64) -> uint64:
    arm64_p42_install_l3()

    idx: int64 = cast[int64]((va - P42_WINDOW_BASE) >> cast[uint64](12))

    # Hand out the next pool page.
    page_pa: uint64 = P42_POOL_BASE + (cast[uint64](arm64_p42_next_page) * P42_PAGE_SIZE)
    arm64_p42_next_page = arm64_p42_next_page + 1

    # Fill the backing page from the file's on-disk bytes (real virtio-blk read).
    rok: int64 = arm64_p42_read_page_from_disk(idx, page_pa)
    if rok != 0:
        arm64_p42_reads_ok = arm64_p42_reads_ok + 1

    # L3 index of `va` = VA[20:12].
    l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3: Ptr[uint64] = cast[Ptr[uint64]](P42_L3)
    l3[cast[int64](l3_index)] = page_pa | P42_PAGE_FLAGS

    _dsb_ish()
    _tlbi_vaae1is(va >> cast[uint64](12))
    _dsb_ish()
    _isb()
    return l3_index


# Tear the whole region down (the munmap teardown): zero EVERY page's L3 PTE,
# wipe the backing pool pages, reset the pool cursor, drop the L2->L3 table link,
# and flush the TLB so a subsequent EL0 touch translation-faults afresh.
def arm64_p42_unmap_region() -> int64:
    l3: Ptr[uint64] = cast[Ptr[uint64]](P42_L3)
    idx: int64 = 0
    while idx < P42_N_PAGES:
        va: uint64 = arm64_p42_va_for(idx)
        l3_index: uint64 = (va >> cast[uint64](12)) & cast[uint64](0x1FF)
        l3[cast[int64](l3_index)] = cast[uint64](0)
        pg: Ptr[uint64] = cast[Ptr[uint64]](P42_POOL_BASE + (cast[uint64](idx) * P42_PAGE_SIZE))
        j: int64 = 0
        while j < 512:
            pg[j] = cast[uint64](0)
            j = j + 1
        idx = idx + 1
    _dsb_ish()

    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P42_WINDOW_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    arm64_p42_next_page = 0
    arm64_p42_l3_wired = 0
    arm64_p42_unmapped = 1
    return 0


# Phase-42 demand-paging fault entry. Called from arm64_sync_handler for a data
# abort from EL0 while the demo is live. A TRANSLATION fault inside the window is
# either (a) a first-touch demand-page (region LIVE): allocate a fresh page, READ
# the file bytes off disk, install the EL0-RO non-exec PTE, resume EL0 (return 1);
# or (b) a post-munmap touch (region UNMAPPED): the mapping is truly gone — DO NOT
# re-page; latch it and run the verdict cleanly (never returns). Anything else
# (permission fault, or a translation fault OUTSIDE the window) returns 0 so the
# fatal-fault reaper runs — real bugs are never masked.
def arm64_p42_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0

    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    win_top: uint64 = P42_WINDOW_BASE + (cast[uint64](P42_N_PAGES) * P42_PAGE_SIZE)
    if page_va < P42_WINDOW_BASE:
        arm64_p42_outside = arm64_p42_outside + 1
        return 0
    if page_va >= win_top:
        arm64_p42_outside = arm64_p42_outside + 1
        return 0

    # Inside the window. If already UNMAPPED, this is the post-munmap re-touch:
    # the mapping is genuinely gone. Catch it CLEANLY, latch it, run the verdict.
    if arm64_p42_unmapped != 0:
        rfm: Ptr[char] = "[arm64] Phase 42: post-munmap touch of VA "
        _uart_puts(rfm)
        _uart_puthex(page_va)
        rfm2: Ptr[char] = " faulted again (region truly unmapped; no re-page)\n"
        _uart_puts(rfm2)
        arm64_p42_refault_ok = 1
        arm64_p42_finish(cast[uint64](0))
        while True:
            _wfi()

    # Region LIVE: first-touch demand-page this window page from disk + resume EL0.
    idx: int64 = cast[int64]((page_va - P42_WINDOW_BASE) >> cast[uint64](12))
    arm64_p42_map_page(page_va)
    arm64_p42_mapped_mask = arm64_p42_mapped_mask | (cast[uint64](1) << cast[uint64](idx))
    arm64_p42_faults = arm64_p42_faults + 1

    m: Ptr[char] = "[arm64] Phase 42 demand fault: paged in file VA "
    _uart_puts(m)
    _uart_puthex(page_va)
    pi: Ptr[char] = " from disk LBA "
    _uart_puts(pi)
    _uart_puthex(arm64_p42_lba_for(idx))
    cl: Ptr[char] = ")\n"
    _uart_puts(cl)
    return 1


# Materialise the Phase-42 EL0 routine into USER_CODE_BASE. For each of N_PAGES
# pages: load the page VA, ldr the first 8 bytes (FAULTS first touch; kernel reads
# the file bytes off disk, installs the RO PTE, then resumes here so the load
# completes), then hand (idx, value) to the kernel via SYS_P42_REPORT_NR. Then
# write(1, msg, len), munmap(base, len) the region, and FINALLY ldr from page 0
# again (FAULTS AGAIN — the region is gone; the kernel catches it cleanly and runs
# the verdict). A trailing exit(0) is emitted for safety. GPR-only (no FP).
def arm64_build_p42_routine(msg_len: uint64) -> int64:
    a: uint64 = USER_CODE_BASE
    idx: int64 = 0
    while idx < P42_N_PAGES:
        va: uint64 = arm64_p42_va_for(idx)

        # x10 = VA ; x9 = 0 ; ldr x9,[x10]  (FAULTS -> demand-paged from disk)
        a = _emit_load_imm64(a, cast[uint64](10), va)
        a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
        a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))
        # report(idx, value): x0 = idx ; x1 = x9 ; x8 = 594 ; svc #0
        a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](idx))
        # mov x1, x9  (ORR x1, xzr, x9) = 0xAA0003E1 | (9<<16) = 0xAA0903E1
        a = _emit_word(a, cast[uint64](0xAA0003E1) | (cast[uint64](9) << cast[uint64](16)))
        a = _emit_load_imm64(a, cast[uint64](8), SYS_P42_REPORT_NR)
        a = _emit_word(a, cast[uint64](0xD4000001))
        idx = idx + 1

    # write(1, msg, len): x0 = 1; x1 = msg; x2 = len; x8 = 596; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](1), P42_MSG_BASE)
    a = _emit_load_imm64(a, cast[uint64](2), msg_len)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P42_WRITE_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # munmap(base, len): x0 = base; x1 = N_PAGES*4KiB; x8 = 595; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P42_WINDOW_BASE)
    a = _emit_load_imm64(a, cast[uint64](1), cast[uint64](P42_N_PAGES) * P42_PAGE_SIZE)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P42_MUNMAP_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    # x10 = page0 VA ; x9 = 0 ; ldr x9,[x10]  (FAULTS AGAIN; region gone -> kernel
    # catches cleanly + runs the verdict; never returns here)
    a = _emit_load_imm64(a, cast[uint64](10), P42_WINDOW_BASE)
    a = _emit_load_imm64(a, cast[uint64](9), cast[uint64](0))
    a = _emit_word(a, cast[uint64](0xF9400000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # exit(0): x0 = 0; x8 = 597; svc #0  (only reached if the re-touch were re-paged)
    a = _emit_load_imm64(a, cast[uint64](0), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P42_EXIT_NR)
    a = _emit_word(a, cast[uint64](0xD4000001))

    _dsb_ish()
    _isb()
    return 0


# Phase-42 syscall dispatcher. Routed from arm64_sync_handler while the demo is
# live. REPORT records + verifies one (page idx, read-back value) pair against the
# file's known on-disk signature; MUNMAP tears the region down; write emits to the
# UART; exit runs the verdict + halts.
def arm64_p42_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    nl: Ptr[char] = "\n"

    if nr == SYS_P42_REPORT_NR:
        idx: int64 = cast[int64](a0)
        arm64_p42_reports = arm64_p42_reports + 1
        want: uint64 = arm64_p42_file_sig_for(idx)

        r0: Ptr[char] = "[arm64] Phase 42 read-back page "
        _uart_puts(r0)
        _uart_puthex(a0)
        ar: Ptr[char] = " -> "
        _uart_puts(ar)
        _uart_puthex(a1)
        aw: Ptr[char] = " (want "
        _uart_puts(aw)
        _uart_puthex(want)
        aw2: Ptr[char] = ")\n"
        _uart_puts(aw2)

        if a1 == want:
            # Independently confirm the BACKING physical page holds the file bytes,
            # so the demand mapping truly reached the disk-filled pool page.
            back: Ptr[uint64] = cast[Ptr[uint64]](P42_POOL_BASE + (cast[uint64](idx) * P42_PAGE_SIZE))
            if back[0] == want:
                arm64_p42_correct_mask = arm64_p42_correct_mask | (cast[uint64](1) << cast[uint64](idx))
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P42_MUNMAP_NR:
        um: Ptr[char] = "[arm64] Phase 42 munmap: tearing down file-backed region [base="
        _uart_puts(um)
        _uart_puthex(a0)
        um2: Ptr[char] = " len="
        _uart_puts(um2)
        _uart_puthex(a1)
        um3: Ptr[char] = "] (drop PTEs + free pages + flush TLB)\n"
        _uart_puts(um3)
        arm64_p42_unmap_region()
        frame_ptr[0] = cast[uint64](0)
        return 0

    if nr == SYS_P42_WRITE_NR:
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        n: uint64 = cast[uint64](0)
        while n < a2:
            _uart_putc(buf[n])
            n = n + cast[uint64](1)
        wm: Ptr[char] = "[arm64] EL0 write(42) syscall serviced\n"
        _uart_puts(wm)
        frame_ptr[0] = a2
        return 0

    if nr == SYS_P42_EXIT_NR:
        arm64_el0_exit_code = cast[int64](a0)
        arm64_el0_exited = 1
        em: Ptr[char] = "[arm64] EL0 exit(42) syscall serviced\n"
        _uart_puts(em)
        arm64_p42_finish(a0)
        while True:
            _wfi()

    bm: Ptr[char] = "[arm64] EL0 unknown syscall (phase 42)\n"
    _uart_puts(bm)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-42 verdict. PASS iff: exactly N_PAGES demand faults serviced (one per
# page), every page mapped, every disk read OK, every read-back matched the file's
# on-disk signature (incl. the backing physical page), no translation fault fired
# OUTSIDE the window, both report syscalls arrived, the region was UNMAPPED, AND
# the post-munmap re-touch faulted again cleanly. Print the summary, then halt
# deterministically. Never returns.
def arm64_p42_finish(code: uint64) -> int64:
    arm64_p42_active = 0
    nl: Ptr[char] = "\n"

    fc: Ptr[char] = "[arm64] Phase 42 file demand-paging: "
    _uart_puts(fc)
    _uart_puthex(cast[uint64](arm64_p42_faults))
    fs: Ptr[char] = " faults serviced\n"
    _uart_puts(fs)

    sm: Ptr[char] = "[arm64] Phase 42 summary: faults="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p42_faults))
    sm2: Ptr[char] = " mapped_mask="
    _uart_puts(sm2)
    _uart_puthex(arm64_p42_mapped_mask)
    sm3: Ptr[char] = " correct_mask="
    _uart_puts(sm3)
    _uart_puthex(arm64_p42_correct_mask)
    sm4: Ptr[char] = " reads_ok="
    _uart_puts(sm4)
    _uart_puthex(cast[uint64](arm64_p42_reads_ok))
    sm5: Ptr[char] = " reports="
    _uart_puts(sm5)
    _uart_puthex(cast[uint64](arm64_p42_reports))
    sm6: Ptr[char] = " outside="
    _uart_puts(sm6)
    _uart_puthex(cast[uint64](arm64_p42_outside))
    sm7: Ptr[char] = " unmapped="
    _uart_puts(sm7)
    _uart_puthex(cast[uint64](arm64_p42_unmapped))
    sm8: Ptr[char] = " refault_ok="
    _uart_puts(sm8)
    _uart_puthex(cast[uint64](arm64_p42_refault_ok))
    _uart_puts(nl)

    full: uint64 = (cast[uint64](1) << cast[uint64](P42_N_PAGES)) - cast[uint64](1)

    ok: int64 = 1
    if arm64_p42_faults != P42_N_PAGES:
        ok = 0
    if arm64_p42_mapped_mask != full:
        ok = 0
    if arm64_p42_correct_mask != full:
        ok = 0
    if arm64_p42_reads_ok != P42_N_PAGES:
        ok = 0
    if arm64_p42_outside != 0:
        ok = 0
    if arm64_p42_reports != P42_N_PAGES:
        ok = 0
    if arm64_p42_unmapped == 0:
        ok = 0
    if arm64_p42_refault_ok == 0:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 42: an EL0 task mapped a FILE (a known on-disk extent) as a lazily-backed read-only window; the first touch of each of two distinct pages raised a translation Data Abort that the kernel serviced by allocating a fresh physical page, READING that page's file bytes off the virtio-blk device (a real disk read of 8 sectors per page from two DIFFERENT file offsets), installing an EL0 RO + non-executable + inner-shareable L3 PTE, and resuming the faulting load so it retried and observed the file's real bytes; each page's first 8 bytes read back byte-identical to the file's on-disk signature (verified through both the EL0 mapping AND the backing physical page); the task then munmap'd the region (PTEs dropped, backing pages freed, TLB flushed) and re-touched it, which faulted ANEW (the mapping is truly gone) and the kernel caught that fault cleanly without re-paging or crashing\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 42 PASS: EL0 file-backed mmap demand-paged from disk (two pages read off virtio-blk on first touch from two file offsets, signatures matched, region unmapped, re-touch faulted again cleanly)\n"
        _uart_puts(pp)
        # Hand off to Phase 43 (real blocking PIPE IPC between two EL0 tasks). It
        # needs no disk/net: a kernel pipe ring buffer + two EL0 tasks built from a
        # hand-assembled on-disk-shaped routine, run under the live timer scheduler.
        arm64_p43_run()
    else:
        fp: Ptr[char] = "[arm64] Phase 42 FAIL: file-backed mmap demand-paged from disk verdict failed\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-42 entry point (hand-off from arm64_p41_finish on a Phase-41 PASS). Locate
# + bring up the virtio-blk transport (reusing the Phase-30 primitives), restore
# the kernel's identity TTBR0, force the window's L2 slot UNMAPPED (so the first
# touch of every page genuinely translation-faults), build the EL0 routine +
# message, arm Phase-42 dispatch, and ERET into the file-backed task at EL0t with
# IRQs masked (deterministic; the page-ins + disk reads all happen on the
# synchronous abort path). Never returns (the post-munmap re-fault runs verdict).
def arm64_p42_run() -> int64:
    intro: Ptr[char] = "[arm64] Phase 42: EL0 file-backed mmap demand-paged from the virtio-blk disk\n"
    _uart_puts(intro)

    # Mask EL1 IRQs: Phase 42 is a single-task, abort-driven demo; no scheduler.
    _msr_daifset(2)

    # Locate + bring up the virtio-blk transport (re-init is safe; Phase 30/35
    # already used it, but a fresh reset/DRIVER_OK leaves a clean queue state).
    base: uint64 = arm64_p30_find_blk()
    if base == cast[uint64](0):
        fp: Ptr[char] = "[arm64] Phase 42 FAIL: no virtio-blk transport found\n"
        _uart_puts(fp)
        _msr_daifset(2)
        while True:
            _wfi()
    if arm64_p30_setup(base) == 0:
        fp2: Ptr[char] = "[arm64] Phase 42 FAIL: virtio-blk bring-up failed\n"
        _uart_puts(fp2)
        _msr_daifset(2)
        while True:
            _wfi()
    arm64_p42_disk_base = base

    fb: Ptr[char] = "[arm64] Phase 42: virtio-blk live @ "
    _uart_puts(fb)
    _uart_puthex(base)
    fb2: Ptr[char] = "; file extent starts at disk LBA "
    _uart_puts(fb2)
    _uart_puthex(P42_FILE_LBA)
    fb3: Ptr[char] = "\n"
    _uart_puts(fb3)

    # Restore the kernel's identity-only TTBR0 (be explicit), then flush the TLB.
    _dsb_ish()
    _msr_ttbr0_el1(L1_PGTABLE)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Force the window's L2 slot UNMAPPED so the first touch of every page raises
    # a translation Data Abort (a clean, repeatable initial state).
    l2: Ptr[uint64] = cast[Ptr[uint64]](L2_PGTABLE)
    l2[cast[int64](P42_WINDOW_L2_INDEX)] = cast[uint64](0)
    _dsb_ish()
    _tlbi_vmalle1is()
    _dsb_ish()
    _isb()

    # Seed Phase-42 bookkeeping.
    arm64_p42_faults = 0
    arm64_p42_next_page = 0
    arm64_p42_l3_wired = 0
    arm64_p42_mapped_mask = cast[uint64](0)
    arm64_p42_correct_mask = cast[uint64](0)
    arm64_p42_outside = 0
    arm64_p42_reports = 0
    arm64_p42_unmapped = 0
    arm64_p42_refault_ok = 0
    arm64_p42_reads_ok = 0

    p42msg: Ptr[char] = "Hello from a demand-paged FILE-backed + munmap'd EL0 mapping\n"
    msg_len: uint64 = _copy_msg_to(p42msg, P42_MSG_BASE)
    arm64_build_p42_routine(msg_len)

    arm64_el0_exited = 0
    arm64_el0_exit_code = -1
    arm64_p42_active = 1

    enter: Ptr[char] = "[arm64] launching EL0 file-backed mmap task (2 pages demand-read from disk, then munmap + re-fault)\n"
    _uart_puts(enter)

    _msr_spsr_el1(SPSR_EL0T_DAIF)      # EL0t, IRQ/FIQ masked (deterministic)
    _msr_elr_el1(USER_CODE_BASE)       # EL0 entry PC
    _msr_sp_el0(USER_STACK_TOP)        # EL0 stack pointer
    _isb()
    _eret()                            # -> EL0; first load faults, kernel reads from disk
    # Unreachable: the task's post-munmap re-fault runs the verdict + halts.
    while True:
        _wfi()
    return 0


# ===========================================================================
# PHASE 43 — REAL BLOCKING PIPE IPC between TWO EL0 user tasks on bare aarch64
# (qemu-virt). A reader task and a writer task run concurrently under the live
# preemptive timer scheduler. The pipe is a genuine kernel ring buffer (head/
# tail/count). The reader, run FIRST, calls pipe_read on the EMPTY pipe and
# GENUINELY BLOCKS (descheduled into a SLEEPING state, parked on a self-loop,
# SKIPPED by the round-robin picker — it is NOT polling). The writer then pushes
# a known multi-byte message into the ring; the kernel delivers queued bytes into
# the blocked reader's buffer and WAKES it (SLEEPING -> RUNNABLE). The ring is
# small (PIPE_CAP) and the message is larger, so the writer ALSO blocks when the
# ring fills, until the reader drains it — proving the REVERSE direction too. The
# reader loops until it has the whole message, copies it into the shared data
# page, report()s it (the kernel cross-checks it byte-for-byte against the known
# sequence — the reader cannot fake the round-trip), and both tasks exit.
#
# Reuses the Phase-27/28/39 blocking-scheduler primitives: a shared ASID-tagged
# EL0 address space, per-slot resume contexts, a SLEEPING/RUNNABLE/EXITED/DEAD
# task-state model, and a wait/wake handoff driven by the peer's pipe op (NOT the
# timer). The two EL0 routines are read off the FAT16 disk as REAL on-disk ELFs
# (READER43.ELF + WRITER43.ELF), loaded into the one shared address space.
#
# EL0 syscalls (free numbers):
#   SYS_P43_PIPE_READ  (740): a0 = buf VA, a1 = len. If the ring has bytes, copy up
#                             to `len` out and return the count (>=1). If the ring
#                             is EMPTY, BLOCK the caller (SLEEPING) until a write
#                             wakes it (then it returns the delivered count).
#   SYS_P43_PIPE_WRITE (741): a0 = buf VA, a1 = len. Append up to ring-free bytes
#                             from the caller's buffer into the ring; deliver to a
#                             blocked reader + wake it. If the ring is FULL, BLOCK
#                             the caller (SLEEPING) until a read drains it. Returns
#                             bytes accepted into the ring on this call.
#   SYS_P43_REPORT     (742): a0 = check-id, a1 = buf VA, a2 = len. The reader
#                             reports the bytes it received; the kernel confirms they
#                             equal the known writer sequence.
#   SYS_P43_EXIT       (743): a0 = status. Mark the caller EXITED (scheduler reaps).
# ===========================================================================

# --- Phase-43 fresh RAM region (clear of every prior phase) ----------------
P43_FILE_PA: uint64 = 0x46200000             # raw on-disk ELF bytes (reader/writer)
P43_FILE_CAP: int64 = 8192                   # max ELF file bytes we read

# The TWO tasks share ONE address space (one L1/L2/L3 tree + ONE ASID). Each task
# gets its OWN text VA + OWN stack VA (distinct 2 MiB windows so the demand-fault
# handler attributes faults unambiguously); BOTH share the SAME data VA (the reader
# copies the bytes it received there for report()).
P43A_TEXT_VA: uint64 = 0x42600000            # task A (reader) text  (L2 idx 19)
P43A_STACK_VA: uint64 = 0x42800000           # task A (reader) stack (L2 idx 20)
P43B_TEXT_VA: uint64 = 0x42A00000            # task B (writer) text  (L2 idx 21)
P43B_STACK_VA: uint64 = 0x42C00000           # task B (writer) stack (L2 idx 22)
P43_DATA_VA: uint64 = 0x42E00000             # SHARED data           (L2 idx 23)
P43A_TEXT_L2_INDEX: uint64 = 19
P43A_STACK_L2_INDEX: uint64 = 20
P43B_TEXT_L2_INDEX: uint64 = 21
P43B_STACK_L2_INDEX: uint64 = 22
P43_DATA_L2_INDEX: uint64 = 23
P43A_STACK_TOP: uint64 = 0x42801000
P43B_STACK_TOP: uint64 = 0x42C01000
P43_ASID: uint64 = 31                        # the ONE shared ASID (distinct from prior)

# The writer's source buffer + the reader's receive buffer both live in the shared
# data page (distinct offsets). The reader copies what it pulled to RECV_OFF.
P43_SRC_OFF: uint64 = 0x0                     # writer's source message  (data+0)
P43_RECV_OFF: uint64 = 0x80                   # reader's reassembled bytes (data+0x80)
P43_SRC_VA: uint64 = 0x42E00000              # = P43_DATA_VA + P43_SRC_OFF
P43_RECV_VA: uint64 = 0x42E00080             # = P43_DATA_VA + P43_RECV_OFF

# Per-process (single AS) EL1-only page tables (ONE L1/L2 + FIVE L3) + two task
# context blocks + a park ctx, in free RAM well clear of every prior phase.
P43_L1: uint64 = 0x46000000
P43_L2: uint64 = 0x46001000
P43A_TEXT_L3: uint64 = 0x46002000
P43A_STACK_L3: uint64 = 0x46003000
P43B_TEXT_L3: uint64 = 0x46004000
P43B_STACK_L3: uint64 = 0x46005000
P43_DATA_L3: uint64 = 0x46006000
P43A_CTX: uint64 = 0x46007000                # 34 x 8-byte resume-context slots
P43B_CTX: uint64 = 0x46008000
P43_PARK_CTX: uint64 = 0x46009000            # throwaway ctx for a parked blocked task

# Data PA backing for the two tasks' text + stacks + the one shared data page.
P43A_TEXT_PA: uint64 = 0x46100000
P43A_STACK_PA: uint64 = 0x46101000
P43B_TEXT_PA: uint64 = 0x46102000
P43B_STACK_PA: uint64 = 0x46103000
P43_DATA_PA: uint64 = 0x46104000             # the ONE shared data page

# W^X page permissions (identical encoding to Phase 39).
P43_PAGE_RX: uint64 = 0x7C7
P43_PAGE_RW: uint64 = 0x40000000000747
P43_PAGE_RO: uint64 = 0x400000000007C7

# Phase-43 EL0 syscall numbers (free).
SYS_P43_PIPE_READ: uint64 = 740
SYS_P43_PIPE_WRITE: uint64 = 741
SYS_P43_REPORT: uint64 = 742
SYS_P43_EXIT: uint64 = 743

# check-id for SYS_P43_REPORT.
P43_CHK_PIPE: uint64 = 0                       # reader reports the received bytes

# Task-state model (reuse the Phase-39 numbering). SLEEPING == blocked on the pipe.
P43_RUNNABLE: int64 = 1
P43_SLEEPING: int64 = 2
P43_EXITED: int64 = 3
P43_DEAD: int64 = 4

# Expected exit statuses (the verdict asserts these are observed).
P43_A_EXIT: uint64 = 0x52                      # 82 — task A (reader) exit status
P43_B_EXIT: uint64 = 0x57                      # 87 — task B (writer) exit status

# The known message the writer sends. Position-coded (no big inline table). The
# kernel verifies the reader received exactly this. MSG_LEN > PIPE_CAP so the
# writer also blocks on a full ring, proving the reverse direction.
P43_MSG_LEN: int64 = 40
def arm64_p43_msg_byte(i: int64) -> uint8:
    return cast[uint8]((0x23 + (i * 5)) & 0x7F)

# The pipe: a kernel ring buffer with head (read cursor), tail (write cursor) and a
# live byte count. CAP is deliberately small (< MSG_LEN) so a single write cannot
# hold the whole message — the writer blocks until the reader drains the ring.
P43_PIPE_CAP: int64 = 16
arm64_p43_ring: Array[16, uint8]
arm64_p43_pipe_head: int64 = 0                # next byte to read
arm64_p43_pipe_tail: int64 = 0                # next slot to write
arm64_p43_pipe_count: int64 = 0               # live bytes in the ring

# --- Phase-43 bookkeeping --------------------------------------------------
arm64_p43_active: int64 = 0
arm64_p43_cur: int64 = 0                       # live slot (0 = reader A, 1 = writer B)
arm64_p43_tick: int64 = 0                      # logical scheduler tick
arm64_p43_switches: int64 = 0                  # task switches performed
arm64_p43_reader_blocked: int64 = 0            # times the reader slept on an empty pipe
arm64_p43_writer_blocked: int64 = 0            # times the writer slept on a full pipe
arm64_p43_woken_by_write: int64 = 0            # set when a write woke the blocked reader
arm64_p43_woken_by_read: int64 = 0             # set when a read woke the blocked writer
arm64_p43_skips: int64 = 0                     # times the picker passed over a SLEEPING slot
arm64_p43_bytes_written: int64 = 0             # total bytes the writer pushed into the ring
arm64_p43_bytes_read: int64 = 0                # total bytes the reader pulled from the ring
arm64_p43_blk_base: uint64 = 0

# Per-slot state.
arm64_p43_state0: int64 = 0
arm64_p43_state1: int64 = 0
arm64_p43_exit0: uint64 = 0xFFFF
arm64_p43_exit1: uint64 = 0xFFFF

# Per-task segment fault accounting (over the SINGLE shared address space).
arm64_p43_a_text_faults: int64 = 0
arm64_p43_a_stack_faults: int64 = 0
arm64_p43_b_text_faults: int64 = 0
arm64_p43_b_stack_faults: int64 = 0
arm64_p43_data_faults: int64 = 0

# When the reader blocks on an empty pipe, record its pending read request so a later
# write can deliver bytes straight into its buffer + set its resumed read() return.
arm64_p43_rd_pending: int64 = 0                # 1 while the reader is parked on a read
arm64_p43_rd_buf_va: uint64 = 0                # reader's pending buffer VA
arm64_p43_rd_len: int64 = 0                    # reader's requested length

# When the writer blocks on a full pipe, record its pending write request so a later
# read can resume the write + set its resumed write() return. `wr_done` accumulates
# the bytes accepted SO FAR for the in-flight pipe_write call so the woken syscall can
# return the full byte count for that call (keeping the EL0 writer loop simple).
arm64_p43_wr_pending: int64 = 0                # 1 while the writer is parked on a write
arm64_p43_wr_buf_va: uint64 = 0                # next unwritten byte VA of this call
arm64_p43_wr_len: int64 = 0                    # remaining bytes to push for this call
arm64_p43_wr_done: int64 = 0                   # bytes accepted so far for this call

# Verdict evidence.
arm64_p43_rt_ok: int64 = 0                     # reader's reported bytes matched
arm64_p43_a_exited: int64 = 0
arm64_p43_b_exited: int64 = 0


# ---- per-slot accessors (idx: 0 = reader A, 1 = writer B) ------------------
def arm64_p43_state_for(idx: int64) -> int64:
    if idx == 0:
        return arm64_p43_state0
    return arm64_p43_state1

def arm64_p43_set_state(idx: int64, st: int64) -> int64:
    if idx == 0:
        arm64_p43_state0 = st
    else:
        arm64_p43_state1 = st
    return 0

def arm64_p43_ctx_for(idx: int64) -> uint64:
    if idx == 0:
        return P43A_CTX
    return P43B_CTX


# Build the ONE shared EL0 address space (CLONE_VM): a single L1/L2 + FIVE 2 MiB
# slots redirected to private L3 tables (textA/stackA/textB/stackB/data). Stamp BOTH
# tasks' stack pages RW and the shared data page RW; text pages are stamped by the
# loader. Both tasks run under this one tree + ONE ASID. Mirrors arm64_p39_build_space.
def arm64_p43_build_space() -> int64:
    l1: Ptr[uint64] = cast[Ptr[uint64]](P43_L1)
    l2: Ptr[uint64] = cast[Ptr[uint64]](P43_L2)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1
    l1[0] = cast[uint64](0) | DEV_FLAGS

    ta: Ptr[uint64] = cast[Ptr[uint64]](P43A_TEXT_L3)
    sa: Ptr[uint64] = cast[Ptr[uint64]](P43A_STACK_L3)
    tb: Ptr[uint64] = cast[Ptr[uint64]](P43B_TEXT_L3)
    sb: Ptr[uint64] = cast[Ptr[uint64]](P43B_STACK_L3)
    dl: Ptr[uint64] = cast[Ptr[uint64]](P43_DATA_L3)
    k: int64 = 0
    while k < 512:
        ta[k] = cast[uint64](0)
        sa[k] = cast[uint64](0)
        tb[k] = cast[uint64](0)
        sb[k] = cast[uint64](0)
        dl[k] = cast[uint64](0)
        k = k + 1

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == P43A_TEXT_L2_INDEX:
            l2[j] = P43A_TEXT_L3 | DESC_TABLE
        elif cast[uint64](j) == P43A_STACK_L2_INDEX:
            l2[j] = P43A_STACK_L3 | DESC_TABLE
        elif cast[uint64](j) == P43B_TEXT_L2_INDEX:
            l2[j] = P43B_TEXT_L3 | DESC_TABLE
        elif cast[uint64](j) == P43B_STACK_L2_INDEX:
            l2[j] = P43B_STACK_L3 | DESC_TABLE
        elif cast[uint64](j) == P43_DATA_L2_INDEX:
            l2[j] = P43_DATA_L3 | DESC_TABLE
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = P43_L2 | DESC_TABLE
    _dsb_ish()

    # Wire BOTH tasks' EL0 stack pages (RW non-exec) + zero them.
    sidx_a: uint64 = (P43A_STACK_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    sa[cast[int64](sidx_a)] = P43A_STACK_PA | P43_PAGE_RW
    spa: Ptr[uint64] = cast[Ptr[uint64]](P43A_STACK_PA)
    za: int64 = 0
    while za < 512:
        spa[za] = cast[uint64](0)
        za = za + 1
    sidx_b: uint64 = (P43B_STACK_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    sb[cast[int64](sidx_b)] = P43B_STACK_PA | P43_PAGE_RW
    spb: Ptr[uint64] = cast[Ptr[uint64]](P43B_STACK_PA)
    zb: int64 = 0
    while zb < 512:
        spb[zb] = cast[uint64](0)
        zb = zb + 1

    # Wire the SHARED data page (RW non-exec), zero it, then seed the writer's source
    # message at SRC_OFF so the writer's loads read the known sequence.
    didx: uint64 = (P43_DATA_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    dl[cast[int64](didx)] = P43_DATA_PA | P43_PAGE_RW
    dp: Ptr[uint64] = cast[Ptr[uint64]](P43_DATA_PA)
    zd: int64 = 0
    while zd < 512:
        dp[zd] = cast[uint64](0)
        zd = zd + 1
    src: Ptr[uint8] = cast[Ptr[uint8]](P43_DATA_PA + P43_SRC_OFF)
    m: int64 = 0
    while m < P43_MSG_LEN:
        src[m] = arm64_p43_msg_byte(m)
        m = m + 1
    _dsb_ish()
    _isb()
    return 0


# Map [seg_va, seg_va+filesz) onto seg_pa with page_flags in the shared L3 `l3_base`,
# copying p_filesz bytes from the Phase-43 ELF file buffer. The backing page is
# pre-cleared. Identical shape to arm64_p39_map_segment.
def arm64_p43_map_segment(seg_va: uint64, seg_pa: uint64, foff: uint64, filesz: uint64, l3_base: uint64, page_flags: uint64) -> int64:
    pg: Ptr[uint8] = cast[Ptr[uint8]](seg_pa)
    c: int64 = 0
    while c < cast[int64](P26_PAGE_SIZE):
        pg[c] = cast[uint8](0)
        c = c + 1
    fbuf: Ptr[uint8] = cast[Ptr[uint8]](P43_FILE_PA)
    n: uint64 = cast[uint64](0)
    while n < filesz:
        pg[cast[int64](n)] = fbuf[cast[int64](foff + n)]
        n = n + cast[uint64](1)
    _dsb_ish()
    l3: Ptr[uint64] = cast[Ptr[uint64]](l3_base)
    idx: uint64 = (seg_va >> cast[uint64](12)) & cast[uint64](0x1FF)
    l3[cast[int64](idx)] = seg_pa | page_flags
    _dsb_ish()
    _isb()
    return 0


# Little-endian readers out of the Phase-43 ELF file buffer.
def _p43_rd16(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P43_FILE_PA)
    b0: uint64 = cast[uint64](p[cast[int64](off)])
    b1: uint64 = cast[uint64](p[cast[int64](off + cast[uint64](1))])
    return b0 | (b1 << cast[uint64](8))


def _p43_rd32(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P43_FILE_PA)
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 4:
        r = r | (cast[uint64](p[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


def _p43_rd64(off: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](P43_FILE_PA)
    r: uint64 = cast[uint64](0)
    i: int64 = 0
    while i < 8:
        r = r | (cast[uint64](p[cast[int64](off + cast[uint64](i))]) << cast[uint64](i * 8))
        i = i + 1
    return r


def arm64_p43_flags_for(pflags: uint64) -> uint64:
    if (pflags & PF_W) != cast[uint64](0):
        return P43_PAGE_RW
    if (pflags & PF_X) != cast[uint64](0):
        return P43_PAGE_RX
    return P43_PAGE_RO


# Read the on-disk ELF named by the 11-byte name at `name_pa` off the live FAT16
# volume into P43_FILE_PA (following its cluster chain). Returns byte length, or
# -1 on not-found / read error. Mirrors arm64_p39_read_elf over P43_FILE_PA.
def arm64_p43_read_elf(base: uint64, name_pa: uint64) -> int64:
    loc: int64 = arm64_p36_locate(base, name_pa)
    if loc != 1:
        return -1
    first_clus: int64 = arm64_p36_loc_first_clus
    file_size: int64 = arm64_p36_loc_size
    if first_clus < 2:
        return -1
    sec_per_clus: int64 = arm64_p31_sec_per_clus
    dst_off: int64 = 0
    want_len: int64 = file_size
    clus: int64 = first_clus
    guard: int64 = 0
    dst: Ptr[uint8] = cast[Ptr[uint8]](P43_FILE_PA)
    src: Ptr[uint8] = cast[Ptr[uint8]](P31_SEC_PA)
    while clus >= 2 and clus < 0xFFF8 and dst_off < want_len:
        guard = guard + 1
        if guard > 4096:
            return -1
        clus_lba: int64 = arm64_p31_data_lba + ((clus - 2) * sec_per_clus)
        sc: int64 = 0
        while sc < sec_per_clus:
            if dst_off < want_len:
                if arm64_p30_read_sector_into(base, cast[uint64](clus_lba + sc), P31_SEC_PA) != 1:
                    return -1
                take: int64 = arm64_p31_bytes_per_sec
                if dst_off + take > want_len:
                    take = want_len - dst_off
                i: int64 = 0
                while i < take:
                    if dst_off < P43_FILE_CAP:
                        dst[dst_off] = src[i]
                        dst_off = dst_off + 1
                    else:
                        i = take
                    i = i + 1
            sc = sc + 1
        nxt: int64 = arm64_p31_fat_next(base, clus)
        if nxt < 0:
            return -1
        clus = nxt
    return dst_off


# Parse + load the on-disk ELF64 in P43_FILE_PA into the SHARED address space for
# task `prog` (0=reader,1=writer): its text into the matching text L3. The shared
# data segment (if declared) is already wired + seeded by build_space; skip it.
# Returns e_entry, or 0 on failure. Mirrors arm64_p39_load_elf.
def arm64_p43_load_elf(prog: int64) -> uint64:
    fbuf: Ptr[uint8] = cast[Ptr[uint8]](P43_FILE_PA)
    nl: Ptr[char] = "\n"

    if cast[uint64](fbuf[0]) != ELF_EI_MAG0:
        return cast[uint64](0)
    if cast[uint64](fbuf[1]) != ELF_EI_MAG1:
        return cast[uint64](0)
    if cast[uint64](fbuf[2]) != ELF_EI_MAG2:
        return cast[uint64](0)
    if cast[uint64](fbuf[3]) != ELF_EI_MAG3:
        return cast[uint64](0)
    if cast[uint64](fbuf[4]) != ELFCLASS64:
        return cast[uint64](0)
    if cast[uint64](fbuf[5]) != ELFDATA2LSB:
        return cast[uint64](0)

    e_type: uint64 = _p43_rd16(EH_TYPE)
    e_machine: uint64 = _p43_rd16(EH_MACHINE)
    e_entry: uint64 = _p43_rd64(EH_ENTRY)
    e_phoff: uint64 = _p43_rd64(EH_PHOFF)
    e_phentsize: uint64 = _p43_rd16(EH_PHENTSIZE)
    e_phnum: uint64 = _p43_rd16(EH_PHNUM)

    if e_type != ET_EXEC:
        return cast[uint64](0)
    if e_machine != EM_AARCH64:
        return cast[uint64](0)

    text_va: uint64 = P43A_TEXT_VA
    text_pa: uint64 = P43A_TEXT_PA
    text_l3: uint64 = P43A_TEXT_L3
    if prog == 1:
        text_va = P43B_TEXT_VA
        text_pa = P43B_TEXT_PA
        text_l3 = P43B_TEXT_L3

    hm: Ptr[char] = "[arm64] Phase 43 ELF: task="
    _uart_puts(hm)
    _uart_puthex(cast[uint64](prog))
    hm2: Ptr[char] = " entry="
    _uart_puts(hm2)
    _uart_puthex(e_entry)
    hm3: Ptr[char] = " phnum="
    _uart_puts(hm3)
    _uart_puthex(e_phnum)
    _uart_puts(nl)

    segs: int64 = 0
    ph: uint64 = 0
    while ph < e_phnum:
        b: uint64 = e_phoff + (ph * e_phentsize)
        p_type: uint64 = _p43_rd32(b + PH_TYPE)
        if p_type == PT_LOAD:
            p_flags: uint64 = _p43_rd32(b + PH_FLAGS)
            p_offset: uint64 = _p43_rd64(b + PH_OFFSET)
            p_vaddr: uint64 = _p43_rd64(b + PH_VADDR)
            p_filesz: uint64 = _p43_rd64(b + PH_FILESZ)
            page_flags: uint64 = arm64_p43_flags_for(p_flags)

            if p_vaddr == text_va:
                arm64_p43_map_segment(p_vaddr, text_pa, p_offset, p_filesz, text_l3, page_flags)
                segs = segs + 1
            elif p_vaddr == P43_DATA_VA:
                # Shared data segment: already wired RW + seeded by build_space.
                # Do NOT clobber it (it carries the writer's source message). Count it.
                segs = segs + 1
            else:
                return cast[uint64](0)
        ph = ph + cast[uint64](1)

    if segs < 1:
        return cast[uint64](0)
    return e_entry


# TTBR0_EL1 for the SHARED address space: the one L1 root + the one ASID.
def arm64_p43_ttbr0() -> uint64:
    return P43_L1 | (P43_ASID << P23_ASID_SHIFT)


# Make the SHARED TTBR0 live (one ASID for both tasks).
def arm64_p43_switch_to_as() -> int64:
    _dsb_ish()
    _tlbi_aside1is(P43_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()
    _msr_ttbr0_el1(arm64_p43_ttbr0())
    _dsb_ish()
    _tlbi_aside1is(P43_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()
    return 0


# Initialise task `prog`'s resume-context block for a clean first ERET into its
# entry, on ITS OWN EL0 stack, in EL0t with IRQs UNMASKED (so the timer preempts).
def arm64_p43_init_ctx(prog: int64, entry: uint64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p43_ctx_for(prog))
    i: int64 = 0
    while i < 34:
        ctx[i] = cast[uint64](0)
        i = i + 1
    stack_top: uint64 = P43A_STACK_TOP
    if prog == 1:
        stack_top = P43B_STACK_TOP
    ctx[CTX_SP_EL0] = stack_top
    ctx[CTX_ELR] = entry
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ
    return 0


# Phase-43 demand-fault entry. A first touch of a mapped page of the SINGLE shared
# address space takes a translation fault (loader/build pre-stamped the PTE).
# Confirm the VA lies in a mapped page, account it, flush the VA, and resume (1).
def arm64_p43_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0
    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    in_seg: int64 = 0
    if page_va == P43A_TEXT_VA:
        arm64_p43_a_text_faults = arm64_p43_a_text_faults + 1
        in_seg = 1
    elif page_va == P43A_STACK_VA:
        arm64_p43_a_stack_faults = arm64_p43_a_stack_faults + 1
        in_seg = 1
    elif page_va == P43B_TEXT_VA:
        arm64_p43_b_text_faults = arm64_p43_b_text_faults + 1
        in_seg = 1
    elif page_va == P43B_STACK_VA:
        arm64_p43_b_stack_faults = arm64_p43_b_stack_faults + 1
        in_seg = 1
    elif page_va == P43_DATA_VA:
        arm64_p43_data_faults = arm64_p43_data_faults + 1
        in_seg = 1
    if in_seg == 0:
        return 0

    _dsb_ish()
    _tlbi_vaae1is(page_va >> cast[uint64](12))
    _dsb_ish()
    _isb()
    return 1


# Materialise a one-instruction self-loop (`b .`) at the end of task `idx`'s TEXT
# page and return its EL0 VA. Used to park a blocked task's EL0 PC harmlessly until
# the next timer tick preempts it. Mirrors arm64_p39_park_addr.
def arm64_p43_park_addr(idx: int64) -> uint64:
    text_pa: uint64 = P43A_TEXT_PA
    text_va: uint64 = P43A_TEXT_VA
    if idx == 1:
        text_pa = P43B_TEXT_PA
        text_va = P43B_TEXT_VA
    off: uint64 = cast[uint64](0xFFC)              # last word of the text page
    _emit_word(text_pa + off, cast[uint64](0x14000000))   # b . (self-loop)
    _dsb_ish()
    _isb()
    return text_va + off


# Save the caller's full resume context into its slot ctx so it RESUMES past the svc
# on wake. retval becomes the woken syscall's x0. Mirrors the Phase-39 block save.
def arm64_p43_save_ctx(idx: int64, frame_ptr: Ptr[uint64], retval: uint64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p43_ctx_for(idx))
    i: int64 = 0
    while i < 31:
        ctx[i] = frame_ptr[i]                      # x0..x30 from the saved svc frame
        i = i + 1
    ctx[CTX_X0] = retval                           # the woken syscall returns retval
    ctx[CTX_SP_EL0] = cast[uint64](_mrs_sp_el0())
    ctx[CTX_ELR] = cast[uint64](_mrs_elr_el1())    # resume PC = insn after the svc
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ                  # EL0t, IRQs on (re-preemptible)
    _dsb_ish()
    return 0


# Park the CURRENT slot (idx): mark it SLEEPING, save its resume ctx (retval=0 placeholder,
# overwritten on wake), point its live EL0 PC at a self-loop, and switch arm64_current_ctx
# to the throwaway park ctx so the immediate svc-eret merely spins until the next tick.
def arm64_p43_park_current(idx: int64, frame_ptr: Ptr[uint64]) -> int64:
    arm64_p43_save_ctx(idx, frame_ptr, cast[uint64](0))
    arm64_p43_set_state(idx, P43_SLEEPING)
    park: uint64 = arm64_p43_park_addr(idx)
    _msr_elr_el1(park)
    _isb()
    frame_ptr[0] = cast[uint64](0)
    arm64_current_ctx = P43_PARK_CTX
    return 0


# Copy up to `n` bytes from user VA `va` (in the shared data page) into the kernel
# ring tail, advancing tail/count. Returns bytes accepted (<= ring free, <= n).
def arm64_p43_ring_push(va: uint64, n: int64) -> int64:
    src: Ptr[uint8] = cast[Ptr[uint8]](va)
    pushed: int64 = 0
    while pushed < n and arm64_p43_pipe_count < P43_PIPE_CAP:
        arm64_p43_ring[arm64_p43_pipe_tail] = src[pushed]
        arm64_p43_pipe_tail = (arm64_p43_pipe_tail + 1) % P43_PIPE_CAP
        arm64_p43_pipe_count = arm64_p43_pipe_count + 1
        pushed = pushed + 1
    return pushed


# Copy up to `n` bytes from the kernel ring head into user VA `va`, advancing
# head/count. Returns bytes delivered (<= ring count, <= n).
def arm64_p43_ring_pop(va: uint64, n: int64) -> int64:
    dst: Ptr[uint8] = cast[Ptr[uint8]](va)
    popped: int64 = 0
    while popped < n and arm64_p43_pipe_count > 0:
        dst[popped] = arm64_p43_ring[arm64_p43_pipe_head]
        arm64_p43_pipe_head = (arm64_p43_pipe_head + 1) % P43_PIPE_CAP
        arm64_p43_pipe_count = arm64_p43_pipe_count - 1
        popped = popped + 1
    return popped


# ---- Phase-43 EL0 syscall handlers ----------------------------------------

# pipe_read(buf, len): SINGLE-SHOT. If the ring has bytes, pop up to len out and
# return the count (userspace loops to read the rest). Popping frees ring space, so if
# the writer is parked on a FULL ring, WAKE it (x0=0 -> its userspace pipe_write
# re-issues against the now-drained ring). If the ring is EMPTY, BLOCK the caller
# (SLEEPING) until a write delivers bytes + wakes it.
def arm64_p43_do_pipe_read(frame_ptr: Ptr[uint64], buf_va: uint64, length: int64) -> int64:
    cur: int64 = arm64_p43_cur

    if arm64_p43_pipe_count > 0:
        got: int64 = arm64_p43_ring_pop(buf_va, length)
        arm64_p43_bytes_read = arm64_p43_bytes_read + got
        # A read drained the ring — if the writer is parked on a full ring, WAKE it so
        # its userspace pipe_write loop re-issues against the freed space (x0=0: the
        # blocked call accepted nothing yet).
        if arm64_p43_wr_pending != 0:
            wctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p43_ctx_for(1))
            wctx[CTX_X0] = cast[uint64](0)
            _dsb_ish()
            arm64_p43_wr_pending = 0
            arm64_p43_set_state(1, P43_RUNNABLE)
            arm64_p43_woken_by_read = 1
            wk: Ptr[char] = "[arm64] Phase 43: a read drained the ring -> woke the BLOCKED writer (task B) -> RUNNABLE\n"
            _uart_puts(wk)
        rm: Ptr[char] = "[arm64] Phase 43: task A pipe_read got "
        _uart_puts(rm)
        _uart_puthex(cast[uint64](got))
        rm2: Ptr[char] = " bytes (ring not empty)\n"
        _uart_puts(rm2)
        frame_ptr[0] = cast[uint64](got)
        return 0

    # Ring EMPTY: BLOCK the reader until a write delivers bytes + wakes it.
    arm64_p43_rd_pending = 1
    arm64_p43_rd_buf_va = buf_va
    arm64_p43_rd_len = length
    arm64_p43_reader_blocked = arm64_p43_reader_blocked + 1

    bm: Ptr[char] = "[arm64] Phase 43: task A pipe_read on EMPTY pipe -> SLEEPING (parked, sleep #"
    _uart_puts(bm)
    _uart_puthex(cast[uint64](arm64_p43_reader_blocked))
    bm2: Ptr[char] = ")\n"
    _uart_puts(bm2)

    arm64_p43_park_current(cur, frame_ptr)
    return 0


# pipe_write(buf, len): SINGLE-SHOT. If the ring has free space, push up to (free, len)
# bytes and return the count (userspace loops to write the rest). Pushing makes the ring
# non-empty, so if the reader is parked on an EMPTY ring, WAKE it (x0=0 -> its userspace
# pipe_read re-issues against the now-filled ring). If the ring is FULL, BLOCK the caller
# (SLEEPING) until a read drains it + wakes it (the reverse blocking direction).
def arm64_p43_do_pipe_write(frame_ptr: Ptr[uint64], buf_va: uint64, length: int64) -> int64:
    cur: int64 = arm64_p43_cur

    if arm64_p43_pipe_count < P43_PIPE_CAP:
        pushed: int64 = arm64_p43_ring_push(buf_va, length)
        arm64_p43_bytes_written = arm64_p43_bytes_written + pushed

        wm: Ptr[char] = "[arm64] Phase 43: task B pipe_write pushed "
        _uart_puts(wm)
        _uart_puthex(cast[uint64](pushed))
        wm2: Ptr[char] = " bytes into the ring (count="
        _uart_puts(wm2)
        _uart_puthex(cast[uint64](arm64_p43_pipe_count))
        wm3: Ptr[char] = ")\n"
        _uart_puts(wm3)

        # The ring is now non-empty — if a reader is parked on an empty-pipe read, WAKE
        # it so its userspace pipe_read re-issues against the filled ring (x0=0).
        if arm64_p43_rd_pending != 0:
            rctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p43_ctx_for(0))
            rctx[CTX_X0] = cast[uint64](0)
            _dsb_ish()
            arm64_p43_rd_pending = 0
            arm64_p43_set_state(0, P43_RUNNABLE)
            arm64_p43_woken_by_write = 1
            wk: Ptr[char] = "[arm64] Phase 43: pipe_write delivered to + woke the BLOCKED reader (task A) -> RUNNABLE\n"
            _uart_puts(wk)

        frame_ptr[0] = cast[uint64](pushed)
        return 0

    # Ring FULL: BLOCK the writer until a read drains it + wakes it.
    arm64_p43_wr_pending = 1
    arm64_p43_wr_buf_va = buf_va
    arm64_p43_wr_len = length
    arm64_p43_writer_blocked = arm64_p43_writer_blocked + 1

    fm: Ptr[char] = "[arm64] Phase 43: task B pipe_write filled the ring (rem="
    _uart_puts(fm)
    _uart_puthex(cast[uint64](length))
    fm2: Ptr[char] = ") -> SLEEPING (parked, sleep #"
    _uart_puts(fm2)
    _uart_puthex(cast[uint64](arm64_p43_writer_blocked))
    fm3: Ptr[char] = ")\n"
    _uart_puts(fm3)

    arm64_p43_park_current(cur, frame_ptr)
    return 0


# report(check-id, buf, len): the reader reports the bytes it received (out of the
# shared data page); the kernel cross-checks them byte-for-byte against the known
# writer sequence (so the reader cannot fake a PASS). Returns 1 if it matches.
def arm64_p43_do_report(chk: uint64, buf_va: uint64, length: int64) -> int64:
    if chk == P43_CHK_PIPE:
        buf: Ptr[uint8] = cast[Ptr[uint8]](buf_va)
        ok: int64 = 1
        if length != P43_MSG_LEN:
            ok = 0
        i: int64 = 0
        while i < P43_MSG_LEN:
            if cast[uint64](buf[i]) != cast[uint64](arm64_p43_msg_byte(i)):
                ok = 0
            i = i + 1
        if ok != 0:
            arm64_p43_rt_ok = 1
        rm: Ptr[char] = "[arm64] Phase 43: task A report received "
        _uart_puts(rm)
        _uart_puthex(cast[uint64](length))
        rm2: Ptr[char] = " bytes; match="
        _uart_puts(rm2)
        _uart_puthex(cast[uint64](ok))
        rm3: Ptr[char] = "\n"
        _uart_puts(rm3)
        return ok
    return 0


# exit(status): mark the caller EXITED (the scheduler reaps it). Mirrors p39_do_exit.
def arm64_p43_do_exit(frame_ptr: Ptr[uint64], status: uint64) -> int64:
    cur: int64 = arm64_p43_cur
    if cur == 0:
        arm64_p43_exit0 = status
        arm64_p43_a_exited = 1
    else:
        arm64_p43_exit1 = status
        arm64_p43_b_exited = 1
    arm64_p43_set_state(cur, P43_EXITED)

    em: Ptr[char] = "[arm64] Phase 43: task "
    _uart_puts(em)
    if cur == 0:
        an: Ptr[char] = "A (reader)"
        _uart_puts(an)
    else:
        bn: Ptr[char] = "B (writer)"
        _uart_puts(bn)
    em2: Ptr[char] = " exit(status="
    _uart_puts(em2)
    _uart_puthex(status)
    em3: Ptr[char] = ") -> EXITED\n"
    _uart_puts(em3)

    park: uint64 = arm64_p43_park_addr(cur)
    _msr_elr_el1(park)
    _isb()
    frame_ptr[0] = cast[uint64](0)
    arm64_current_ctx = P43_PARK_CTX
    return 0


# Phase-43 syscall dispatcher. Routed from arm64_sync_handler while the demo is live.
def arm64_p43_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_P43_PIPE_READ:
        return arm64_p43_do_pipe_read(frame_ptr, a0, cast[int64](a1))
    if nr == SYS_P43_PIPE_WRITE:
        return arm64_p43_do_pipe_write(frame_ptr, a0, cast[int64](a1))
    if nr == SYS_P43_REPORT:
        r: int64 = arm64_p43_do_report(a0, a1, cast[int64](a2))
        frame_ptr[0] = cast[uint64](r)
        return 0
    if nr == SYS_P43_EXIT:
        return arm64_p43_do_exit(frame_ptr, a0)

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 43)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Pick the next non-SLEEPING, non-DEAD slot after `from_idx`, round-robin over the
# two tasks. A SLEEPING (pipe-blocked) slot is SKIPPED (tallied — proof the blocked
# task is genuinely passed over). Returns -1 if neither is runnable.
def arm64_p43_next_runnable(from_idx: int64) -> int64:
    # If the CURRENT slot is parked SLEEPING, the picker is passing it over to find a
    # runnable peer — tally that (genuine proof the blocked task is descheduled, not
    # polling). With a tight 2-task handoff the blocked task is the from_idx itself.
    if arm64_p43_state_for(from_idx) == P43_SLEEPING:
        arm64_p43_skips = arm64_p43_skips + 1
    steps: int64 = 0
    idx: int64 = from_idx
    while steps < 2:
        idx = idx + 1
        if idx >= 2:
            idx = 0
        st: int64 = arm64_p43_state_for(idx)
        if st == P43_RUNNABLE:
            return idx
        if st == P43_SLEEPING:
            arm64_p43_skips = arm64_p43_skips + 1
        steps = steps + 1
    return -1


# Reap any EXITED slot (EXITED -> DEAD). Returns the number of slots reaped.
def arm64_p43_reap() -> int64:
    reaped: int64 = 0
    idx: int64 = 0
    while idx < 2:
        if arm64_p43_state_for(idx) == P43_EXITED:
            arm64_p43_set_state(idx, P43_DEAD)
            reaped = reaped + 1
        idx = idx + 1
    return reaped


# Phase-43 timer-IRQ scheduler. Ack/re-arm the timer, EOI, advance the tick, REAP any
# EXITED slot, and if both tasks are DEAD run the verdict. A pipe-SLEEPING task is
# NEVER woken here (only a peer pipe op wakes it) — it is skipped. Round-robin to the
# next runnable task (both share ONE TTBR0+ASID), return its ctx. Mirrors p39_sched_pick.
def arm64_p43_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar
        return cur_ctx

    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_p43_tick = arm64_p43_tick + 1

    arm64_p43_reap()

    if arm64_p43_state_for(0) == P43_DEAD:
        if arm64_p43_state_for(1) == P43_DEAD:
            arm64_p43_finish()
            while True:
                _wfi()

    if arm64_p43_tick >= 4000:
        arm64_p43_finish()
        while True:
            _wfi()

    nxt: int64 = arm64_p43_next_runnable(arm64_p43_cur)
    if nxt < 0:
        return cur_ctx

    arm64_p43_switches = arm64_p43_switches + 1
    arm64_p43_cur = nxt
    next_ctx: uint64 = arm64_p43_ctx_for(nxt)
    arm64_current_ctx = next_ctx
    return next_ctx


# Phase-43 verdict. PASS iff: the reader GENUINELY blocked on an empty pipe at least
# once and was woken by the writer's pipe_write (not the timer); the writer GENUINELY
# blocked on a full ring at least once and was woken by the reader's pipe_read; the
# picker skipped the blocked task(s) at least once; the full known message round-
# tripped (bytes_written == bytes_read == MSG_LEN, reader's reported bytes matched
# byte-for-byte); and both tasks exited with their expected statuses. Prints summary +
# PASS, then halts. Never returns.
def arm64_p43_finish() -> int64:
    arm64_p43_active = 0
    nl: Ptr[char] = "\n"

    sm: Ptr[char] = "[arm64] Phase 43 summary: reader_blocked="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p43_reader_blocked))
    s1: Ptr[char] = " writer_blocked="
    _uart_puts(s1)
    _uart_puthex(cast[uint64](arm64_p43_writer_blocked))
    s2: Ptr[char] = " woken_by_write="
    _uart_puts(s2)
    _uart_puthex(cast[uint64](arm64_p43_woken_by_write))
    s3: Ptr[char] = " woken_by_read="
    _uart_puts(s3)
    _uart_puthex(cast[uint64](arm64_p43_woken_by_read))
    s4: Ptr[char] = " skips="
    _uart_puts(s4)
    _uart_puthex(cast[uint64](arm64_p43_skips))
    s5: Ptr[char] = " switches="
    _uart_puts(s5)
    _uart_puthex(cast[uint64](arm64_p43_switches))
    _uart_puts(nl)

    s6: Ptr[char] = "[arm64] Phase 43 summary: bytes_written="
    _uart_puts(s6)
    _uart_puthex(cast[uint64](arm64_p43_bytes_written))
    s7: Ptr[char] = " bytes_read="
    _uart_puts(s7)
    _uart_puthex(cast[uint64](arm64_p43_bytes_read))
    s8: Ptr[char] = " msg_len="
    _uart_puts(s8)
    _uart_puthex(cast[uint64](P43_MSG_LEN))
    s9: Ptr[char] = " rt_ok="
    _uart_puts(s9)
    _uart_puthex(cast[uint64](arm64_p43_rt_ok))
    s10: Ptr[char] = " a_exit="
    _uart_puts(s10)
    _uart_puthex(arm64_p43_exit0)
    s11: Ptr[char] = " b_exit="
    _uart_puts(s11)
    _uart_puthex(arm64_p43_exit1)
    _uart_puts(nl)

    ok: int64 = 1
    # The reader genuinely slept on the empty pipe at least once.
    if arm64_p43_reader_blocked < 1:
        ok = 0
    # The writer genuinely slept on the full ring at least once (reverse direction).
    if arm64_p43_writer_blocked < 1:
        ok = 0
    # The blocked reader was woken by the writer's pipe_write, not the timer.
    if arm64_p43_woken_by_write == 0:
        ok = 0
    # The blocked writer was woken by the reader's pipe_read, not the timer.
    if arm64_p43_woken_by_read == 0:
        ok = 0
    # The picker skipped the blocked task at least once.
    if arm64_p43_skips < 1:
        ok = 0
    # The full known message round-tripped through the ring.
    if arm64_p43_bytes_written != P43_MSG_LEN:
        ok = 0
    if arm64_p43_bytes_read != P43_MSG_LEN:
        ok = 0
    # The reader's reported bytes matched the writer's sequence byte-for-byte.
    if arm64_p43_rt_ok == 0:
        ok = 0
    # Both tasks exited with their expected statuses.
    if arm64_p43_a_exited == 0:
        ok = 0
    if arm64_p43_b_exited == 0:
        ok = 0
    if arm64_p43_exit0 != P43_A_EXIT:
        ok = 0
    if arm64_p43_exit1 != P43_B_EXIT:
        ok = 0
    # No task left wedged SLEEPING at the verdict.
    if arm64_p43_state_for(0) == P43_SLEEPING:
        ok = 0
    if arm64_p43_state_for(1) == P43_SLEEPING:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 43: TWO EL0 tasks ran concurrently under the live timer scheduler; the reader called pipe_read on an EMPTY kernel ring and GENUINELY BLOCKED (descheduled into SLEEPING, parked, skipped by the picker, NOT polling); the writer pushed a known message into the ring, the kernel delivered the queued bytes into the blocked reader's buffer and WOKE it; the small ring also filled mid-message so the writer BLOCKED on a FULL ring until the reader's next pipe_read drained it and WOKE the writer; the whole message round-tripped and the reader's received bytes matched the writer's sequence byte-for-byte\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 43 PASS: EL0 blocking pipe IPC (reader slept on empty pipe, writer woke it; writer slept on full pipe, reader woke it; message round-tripped byte-for-byte)\n"
        _uart_puts(pp)
        # Hand off to Phase 44 (EL0 userspace signal delivery + sigreturn). It needs no
        # disk/net: a single EL0 task runs a computation loop, the timer ASYNCHRONOUSLY
        # delivers a signal that pushes a real frame on its EL0 stack + redirects it into
        # a user handler, and sigreturn restores the frame so the loop resumes exactly.
        arm64_p44_run()
    else:
        fp: Ptr[char] = "[arm64] Phase 43 FAIL: blocking pipe IPC verdict failed\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-43 entry point (hand-off from arm64_p42_finish on a Phase-42 PASS), with the
# live virtio-blk transport reused via arm64_p42_disk_base. Read READER43.ELF +
# WRITER43.ELF off the FAT16 disk, build ONE shared EL0 address space, load BOTH into
# it at distinct text/stack VAs + a shared data VA (seeded with the writer's source
# message), init both task resume contexts, mark both RUNNABLE, then re-arm the timer,
# UNMASK IRQs, and ERET into the reader (task A) at EL0t so the timer preempts and both
# tasks run concurrently. The reader pipe_read-blocks on the empty ring; the writer
# pipe_writes the message + wakes it (and itself blocks on the full ring). Never
# returns (halts at the verdict).
def arm64_p43_run() -> int64:
    intro: Ptr[char] = "[arm64] Phase 43: blocking pipe IPC (two EL0 tasks, one address space: READER43 + WRITER43)\n"
    _uart_puts(intro)
    nl: Ptr[char] = "\n"

    _msr_daifset(2)                              # mask EL1 IRQs while we build
    base: uint64 = arm64_p42_disk_base
    arm64_p43_blk_base = base
    arm64_p43_cur = 0

    if base == cast[uint64](0):
        fp: Ptr[char] = "[arm64] Phase 43 FAIL: no live virtio-blk transport\n"
        _uart_puts(fp)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    # Build the ONE shared address space (page tables + stacks + shared data page
    # seeded with the writer's source message). Make it live so segment copies +
    # the seed are coherent under the shared TTBR0.
    arm64_p43_build_space()
    arm64_p43_switch_to_as()

    # Re-parse the FAT16 BPB off sector 0 (fills arm64_p31_* geometry globals).
    if arm64_p30_read_sector_into(base, cast[uint64](0), P31_SEC_PA) != 1:
        fp2: Ptr[char] = "[arm64] Phase 43 FAIL: boot-sector read failed\n"
        _uart_puts(fp2)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    if arm64_p31_parse_bpb() != 1:
        fp3: Ptr[char] = "[arm64] Phase 43 FAIL: BPB geometry not a supported FAT16\n"
        _uart_puts(fp3)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0

    # Build + load TASK A (READER43.ELF, slot 0 — the reader).
    nm: uint64 = P31_FILE_PA
    np: Ptr[uint8] = cast[Ptr[uint8]](nm)
    # "READER43 ELF"  (11-byte 8.3 name, space-padded)
    np[0] = cast[uint8](0x52)    # R
    np[1] = cast[uint8](0x45)    # E
    np[2] = cast[uint8](0x41)    # A
    np[3] = cast[uint8](0x44)    # D
    np[4] = cast[uint8](0x45)    # E
    np[5] = cast[uint8](0x52)    # R
    np[6] = cast[uint8](0x34)    # 4
    np[7] = cast[uint8](0x33)    # 3
    np[8] = cast[uint8](0x45)    # E
    np[9] = cast[uint8](0x4C)    # L
    np[10] = cast[uint8](0x46)   # F
    flen: int64 = arm64_p43_read_elf(base, nm)
    if flen <= 0:
        fp4: Ptr[char] = "[arm64] Phase 43 FAIL: could not read READER43.ELF off the FAT16 disk\n"
        _uart_puts(fp4)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    rm: Ptr[char] = "[arm64] Phase 43: read READER43.ELF off disk ("
    _uart_puts(rm)
    _uart_puthex(cast[uint64](flen))
    rm2: Ptr[char] = " bytes); loading task A into the shared EL0 space\n"
    _uart_puts(rm2)
    entry_a: uint64 = arm64_p43_load_elf(0)
    if entry_a == cast[uint64](0):
        fp5: Ptr[char] = "[arm64] Phase 43 FAIL: READER43.ELF failed header/phdr validation\n"
        _uart_puts(fp5)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    arm64_p43_init_ctx(0, entry_a)
    arm64_p43_set_state(0, P43_RUNNABLE)

    # Build + load TASK B (WRITER43.ELF, slot 1 — the writer).
    np[0] = cast[uint8](0x57)    # W
    np[1] = cast[uint8](0x52)    # R
    np[2] = cast[uint8](0x49)    # I
    np[3] = cast[uint8](0x54)    # T
    np[4] = cast[uint8](0x45)    # E
    np[5] = cast[uint8](0x52)    # R
    np[6] = cast[uint8](0x34)    # 4
    np[7] = cast[uint8](0x33)    # 3
    np[8] = cast[uint8](0x45)    # E
    np[9] = cast[uint8](0x4C)    # L
    np[10] = cast[uint8](0x46)   # F
    flen2: int64 = arm64_p43_read_elf(base, nm)
    if flen2 <= 0:
        fp6: Ptr[char] = "[arm64] Phase 43 FAIL: could not read WRITER43.ELF off the FAT16 disk\n"
        _uart_puts(fp6)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    rm3: Ptr[char] = "[arm64] Phase 43: read WRITER43.ELF off disk ("
    _uart_puts(rm3)
    _uart_puthex(cast[uint64](flen2))
    rm4: Ptr[char] = " bytes); loading task B into the shared EL0 space\n"
    _uart_puts(rm4)
    entry_b: uint64 = arm64_p43_load_elf(1)
    if entry_b == cast[uint64](0):
        fp7: Ptr[char] = "[arm64] Phase 43 FAIL: WRITER43.ELF failed header/phdr validation\n"
        _uart_puts(fp7)
        _msr_daifset(2)
        while True:
            _wfi()
        return 0
    arm64_p43_init_ctx(1, entry_b)
    arm64_p43_set_state(1, P43_RUNNABLE)

    # Reset the pipe ring to empty.
    arm64_p43_pipe_head = 0
    arm64_p43_pipe_tail = 0
    arm64_p43_pipe_count = 0

    arm64_p43_active = 1

    em: Ptr[char] = "[arm64] Phase 43: launching task A (reader) + task B (writer) in ONE address space (ASID 31) concurrently under the timer; entry_a="
    _uart_puts(em)
    _uart_puthex(entry_a)
    em2: Ptr[char] = " entry_b="
    _uart_puts(em2)
    _uart_puthex(entry_b)
    _uart_puts(nl)

    # Start TASK A (slot 0, the reader) FIRST so it reaches its pipe_read on the EMPTY
    # ring and GENUINELY BLOCKS before task B ever writes — a deterministic blocking
    # ordering. The blocked reader is descheduled and the picker dispatches task B,
    # which pushes the message + wakes the reader (and itself blocks on the full ring).
    arm64_p43_cur = 0
    ctx: Ptr[uint64] = cast[Ptr[uint64]](arm64_p43_ctx_for(0))
    arm64_current_ctx = arm64_p43_ctx_for(0)
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                              # UNMASK EL1 IRQs (Phase 42 masked them)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                      # -> EL0; both tasks run
    # Unreachable: the verdict halts.
    while True:
        _wfi()
    return 0


# ===========================================================================
# Phase 44 — EL0 USERSPACE SIGNAL DELIVERY + SIGRETURN (async, to a RUNNING task)
#
# A single EL0 task runs a deterministic COMPUTATION LOOP (accumulate the integers
# 0..N-1 into a register). While it is RUNNING at EL0, the generic timer fires and
# traps to the EL1 IRQ vector, which saves the full interrupted EL0 context (all GP
# regs x0..x30 + SP_EL0 + ELR_EL1 + SPSR_EL1) into the task's context block. The
# Phase-44 scheduler decides — on a deterministic tick AFTER the loop has genuinely
# started — to DELIVER A SIGNAL: it
#   1. pushes a REAL signal frame onto the task's OWN EL0 stack: a copy of all 34
#      saved context slots (the interrupted GP regs + PC + SP + PSTATE), 16-byte
#      aligned, just below the live SP_EL0;
#   2. rewrites the saved context so the IRQ-return ERET lands in the USER signal
#      HANDLER, with the signal number in x0 (arg0), on the lowered stack, at EL0t;
#   3. records the frame VA so sigreturn can find it.
# The IRQ stub then restores that (rewritten) context and ERETs into the handler.
#
# The HANDLER runs entirely at EL0. It STORES an observable sentinel (a known magic
# value) plus the received signal number to a known user VA, calls a report syscall
# (so the kernel cross-checks the handler genuinely ran with the right signal), then
# branches to a sigreturn TRAMPOLINE. The trampoline issues the sigreturn svc.
#
# SIGRETURN (svc) restores the FULL 34-slot frame off the EL0 stack back into the
# saved context block and rewinds SP_EL0, so the IRQ-style restore resumes the task
# at EXACTLY the instruction it was preempted on, with EVERY GP register restored —
# even though the handler clobbered scratch regs. The loop therefore continues from
# where it left off and runs to completion, producing the EXACT expected accumulator
# value, which the task report()s (kernel verifies) before exit(). PASS requires:
# the signal was delivered while the loop was mid-flight, the handler ran with the
# right signal number, the sentinel landed in user memory, sigreturn restored the
# frame, and the resumed loop's final value equals the kernel-computed expected sum.
#
# Distinct ASID (44) + a fresh EL0 VA window, clear of every prior phase.
#
# EL0 syscalls (free numbers):
#   SYS_P44_HANDLER_RAN (750): a0 = signal number the handler received. The handler
#                              reports it ran; the kernel checks a0 == the delivered
#                              signal number.
#   SYS_P44_SIGRETURN   (751): restore the interrupted frame off the EL0 stack +
#                              resume the loop (never returns to the trampoline).
#   SYS_P44_REPORT      (752): a0 = final accumulator value. The kernel checks it
#                              equals the expected sum 0+1+...+(N-1).
#   SYS_P44_EXIT        (753): a0 = status. Mark the task EXITED (scheduler reaps).
# ===========================================================================

# --- Phase-44 fresh EL0 VA window (clear of every prior phase) -------------
P44_TEXT_VA: uint64 = 0x44000000             # task text   (L1 idx1, L2 idx 32)
P44_STACK_VA: uint64 = 0x44200000            # task stack  (L2 idx 33)
P44_DATA_VA: uint64 = 0x44400000             # sentinel data page (L2 idx 34)
P44_TEXT_L2_INDEX: uint64 = 32
P44_STACK_L2_INDEX: uint64 = 33
P44_DATA_L2_INDEX: uint64 = 34
P44_STACK_TOP: uint64 = 0x44201000           # EL0 stack top (top of the single mapped stack page)
P44_ASID: uint64 = 44                        # distinct ASID

# EL0 code sub-addresses inside the text page.
P44_MAIN_CODE: uint64 = 0x44000000           # main computation-loop routine
P44_HANDLER_CODE: uint64 = 0x44000800        # signal handler routine
P44_RET_TRAMP: uint64 = 0x44000C00           # sigreturn trampoline

# Observable sentinel + signum land here in the user data page.
P44_SENTINEL_VA: uint64 = 0x44400000         # handler stores the sentinel magic here
P44_SIGNUM_VA: uint64 = 0x44400008           # handler stores the received signum here
P44_SENTINEL_MAGIC: uint64 = 0x5169A5C344000044   # recognizable observable value

# Fresh EL1-only page tables + context blocks (PA region clear of every prior phase).
P44_L1: uint64 = 0x48000000
P44_L2: uint64 = 0x48001000
P44_TEXT_L3: uint64 = 0x48002000
P44_STACK_L3: uint64 = 0x48003000
P44_DATA_L3: uint64 = 0x48004000
P44_CTX: uint64 = 0x48005000                 # 34 x 8-byte resume-context slots

# Data PA backing for the task's text + stack + sentinel data page.
P44_TEXT_PA: uint64 = 0x48100000
P44_STACK_PA: uint64 = 0x48101000
P44_DATA_PA: uint64 = 0x48102000

# W^X page permissions (identical encoding to Phase 43).
P44_PAGE_RX: uint64 = 0x7C7
P44_PAGE_RW: uint64 = 0x40000000000747

# Phase-44 EL0 syscall numbers (free).
SYS_P44_HANDLER_RAN: uint64 = 750
SYS_P44_SIGRETURN: uint64 = 751
SYS_P44_REPORT: uint64 = 752
SYS_P44_EXIT: uint64 = 753

# The signal number we deliver (a recognizable token, like a POSIX signo).
P44_SIGNO: uint64 = 0x2A                      # 42

# check-id for SYS_P44_REPORT.
P44_CHK_RESULT: uint64 = 0

# The computation: accumulate 0+1+...+(N-1). N chosen large enough that the timer
# tick lands INSIDE the loop (proving async delivery to a genuinely running task).
P44_LOOP_N: int64 = 0x40000                   # 262144 iterations

# Expected accumulator = N*(N-1)/2 (kernel computes it directly to cross-check).
def arm64_p44_expected_sum() -> uint64:
    n: uint64 = cast[uint64](P44_LOOP_N)
    return (n * (n - cast[uint64](1))) / cast[uint64](2)

# Task-state model (reuse the Phase-43 numbering).
P44_RUNNABLE: int64 = 1
P44_EXITED: int64 = 3
P44_DEAD: int64 = 4

# Expected exit status (the verdict asserts this is observed).
P44_EXIT_CODE: uint64 = 0x6C                   # 108

# --- Phase-44 bookkeeping --------------------------------------------------
arm64_p44_active: int64 = 0
arm64_p44_tick: int64 = 0                      # logical scheduler tick count
arm64_p44_loop_started: int64 = 0             # set once the task entered its loop region
arm64_p44_delivered: int64 = 0                # set once the signal frame was pushed + redirected
arm64_p44_handler_ran: int64 = 0              # set when the EL0 handler reported in
arm64_p44_handler_signo: uint64 = 0xFFFF      # signal number the handler received
arm64_p44_returned: int64 = 0                 # set once sigreturn restored the frame
arm64_p44_state: int64 = 0                     # task state
arm64_p44_exit_status: uint64 = 0xFFFF
arm64_p44_exited: int64 = 0
arm64_p44_result: uint64 = 0xFFFFFFFFFFFFFFFF  # the final accumulator the task reported
arm64_p44_result_ok: int64 = 0                # set when the reported result == expected sum

# Per-segment fault accounting.
arm64_p44_text_faults: int64 = 0
arm64_p44_stack_faults: int64 = 0
arm64_p44_data_faults: int64 = 0

# Saved interruption evidence: the PC the signal was delivered at (must lie inside the
# loop region), and the SP/PC the sigreturn restored (must match the pushed frame).
arm64_p44_deliver_pc: uint64 = 0
arm64_p44_frame_va: uint64 = 0                # VA of the pushed signal frame on the EL0 stack
arm64_p44_saved_sp: uint64 = 0                # SP_EL0 at delivery (frame restores to this)
arm64_p44_resumed_pc: uint64 = 0              # PC sigreturn resumed at (== deliver_pc)


# Build the task's EL0 address space: ONE L1/L2 + THREE L3 tables (text/stack/data),
# under ONE ASID. Stamp the stack page RW + the sentinel data page RW (zeroed); the
# text page is stamped RX by the routine builder. Mirrors arm64_p43_build_space.
def arm64_p44_build_space() -> int64:
    l1: Ptr[uint64] = cast[Ptr[uint64]](P44_L1)
    l2: Ptr[uint64] = cast[Ptr[uint64]](P44_L2)

    i: int64 = 0
    while i < 512:
        l1[i] = cast[uint64](0)
        i = i + 1
    l1[0] = cast[uint64](0) | DEV_FLAGS

    tt: Ptr[uint64] = cast[Ptr[uint64]](P44_TEXT_L3)
    st: Ptr[uint64] = cast[Ptr[uint64]](P44_STACK_L3)
    dt: Ptr[uint64] = cast[Ptr[uint64]](P44_DATA_L3)
    k: int64 = 0
    while k < 512:
        tt[k] = cast[uint64](0)
        st[k] = cast[uint64](0)
        dt[k] = cast[uint64](0)
        k = k + 1

    j: int64 = 0
    while j < 512:
        blk_pa: uint64 = RAM_BASE + (cast[uint64](j) * L2_BLOCK_SIZE)
        if cast[uint64](j) == P44_TEXT_L2_INDEX:
            l2[j] = P44_TEXT_L3 | DESC_TABLE
        elif cast[uint64](j) == P44_STACK_L2_INDEX:
            l2[j] = P44_STACK_L3 | DESC_TABLE
        elif cast[uint64](j) == P44_DATA_L2_INDEX:
            l2[j] = P44_DATA_L3 | DESC_TABLE
        else:
            l2[j] = blk_pa | MEM_FLAGS
        j = j + 1

    l1[1] = P44_L2 | DESC_TABLE
    _dsb_ish()

    # Wire the EL0 stack page (RW non-exec) + zero it.
    sidx: uint64 = (P44_STACK_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    st[cast[int64](sidx)] = P44_STACK_PA | P44_PAGE_RW
    spa: Ptr[uint64] = cast[Ptr[uint64]](P44_STACK_PA)
    zs: int64 = 0
    while zs < 512:
        spa[zs] = cast[uint64](0)
        zs = zs + 1

    # Wire the sentinel data page (RW non-exec) + zero it (so the post-run read-back
    # truly observes the handler's write, not stale residue).
    didx: uint64 = (P44_DATA_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    dt[cast[int64](didx)] = P44_DATA_PA | P44_PAGE_RW
    dpa: Ptr[uint64] = cast[Ptr[uint64]](P44_DATA_PA)
    zd: int64 = 0
    while zd < 512:
        dpa[zd] = cast[uint64](0)
        zd = zd + 1

    # Wire the text page (RX) so the routine builder's stores + the EL0 fetch resolve.
    tidx: uint64 = (P44_TEXT_VA >> cast[uint64](12)) & cast[uint64](0x1FF)
    tt[cast[int64](tidx)] = P44_TEXT_PA | P44_PAGE_RX
    _dsb_ish()
    _isb()
    return 0


# TTBR0_EL1 for the task's address space (its L1 root + its ASID).
def arm64_p44_ttbr0() -> uint64:
    return P44_L1 | (P44_ASID << P23_ASID_SHIFT)


# Make the task's TTBR0 live.
def arm64_p44_switch_to_as() -> int64:
    _dsb_ish()
    _tlbi_aside1is(P44_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()
    _msr_ttbr0_el1(arm64_p44_ttbr0())
    _dsb_ish()
    _tlbi_aside1is(P44_ASID << P23_ASID_SHIFT)
    _dsb_ish()
    _isb()
    return 0


# Materialise the EL0 MAIN routine into P44_MAIN_CODE. Built so the timer interrupts
# it MID-LOOP. Registers used (all callee/loop-private):
#   x19 = accumulator (starts 0)
#   x20 = loop index i (starts 0)
#   x21 = loop bound N
# Loop body: x19 += x20 ; x20 += 1 ; cmp x20, x21 ; b.lt loop.  The loop is long
# (P44_LOOP_N iterations) so a timer tick lands inside it. After the loop the routine
# reports the accumulator and exits. The text PA must be written here (it is mapped
# RX in EL0 but the kernel writes the backing PA directly through the identity map).
def arm64_p44_build_main() -> int64:
    a: uint64 = P44_TEXT_PA + (P44_MAIN_CODE - P44_TEXT_VA)

    # x19 = 0 (accumulator), x20 = 0 (i), x21 = N (bound)
    a = _emit_load_imm64(a, cast[uint64](19), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](20), cast[uint64](0))
    a = _emit_load_imm64(a, cast[uint64](21), cast[uint64](P44_LOOP_N))

    # loop:  (EL0 VA of this instruction, for the b.lt back-branch)
    loop_va: uint64 = P44_MAIN_CODE + (a - (P44_TEXT_PA + (P44_MAIN_CODE - P44_TEXT_VA)))
    # add x19, x19, x20     : 0x8B000000 | (Rm<<16) | (Rn<<5) | Rd
    a = _emit_word(a, cast[uint64](0x8B000000) | (cast[uint64](20) << cast[uint64](16)) | (cast[uint64](19) << cast[uint64](5)) | cast[uint64](19))
    # add x20, x20, #1      : 0x91000400 | (Rn<<5) | Rd
    a = _emit_word(a, cast[uint64](0x91000400) | (cast[uint64](20) << cast[uint64](5)) | cast[uint64](20))
    # cmp x20, x21          : subs xzr, x20, x21 = 0xEB000000 | (Rm<<16) | (Rn<<5) | 31
    a = _emit_word(a, cast[uint64](0xEB000000) | (cast[uint64](21) << cast[uint64](16)) | (cast[uint64](20) << cast[uint64](5)) | cast[uint64](31))
    # b.lt loop : 0x54000000 | (imm19<<5) | 0xB  ; imm19 = (loop_va - here)/4
    br_va: uint64 = P44_MAIN_CODE + (a - (P44_TEXT_PA + (P44_MAIN_CODE - P44_TEXT_VA)))
    rel: int64 = cast[int64](loop_va) - cast[int64](br_va)
    imm19: uint64 = cast[uint64](rel >> 2) & cast[uint64](0x7FFFF)
    a = _emit_word(a, cast[uint64](0x54000000) | (imm19 << cast[uint64](5)) | cast[uint64](0xB))

    # report(CHK_RESULT, acc): x0 = CHK_RESULT; x1 = x19 (acc); x8 = 752; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P44_CHK_RESULT)
    # mov x1, x19 : orr x1, xzr, x19 = 0xAA0003E0 | (Rm<<16) | Rd
    a = _emit_word(a, cast[uint64](0xAA0003E0) | (cast[uint64](19) << cast[uint64](16)) | cast[uint64](1))
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P44_REPORT)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0

    # exit(EXIT_CODE): x0 = EXIT_CODE; x8 = 753; svc #0
    a = _emit_load_imm64(a, cast[uint64](0), P44_EXIT_CODE)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P44_EXIT)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0

    _dsb_ish()
    _isb()
    return 0


# Materialise the EL0 signal HANDLER into P44_HANDLER_CODE. On entry the kernel has
# set x0 = the signal number. The handler:
#   * stores the sentinel magic to P44_SENTINEL_VA and the signal number to
#     P44_SIGNUM_VA (the observable side effect — set in genuine user memory);
#   * reports it ran via SYS_P44_HANDLER_RAN(signo) so the kernel cross-checks;
#   * branches to the sigreturn trampoline.
# Scratch regs x9/x10/x11 are deliberately clobbered — proof the full-frame restore
# returns the loop's x19/x20/x21 intact across the handler.
def arm64_p44_build_handler() -> int64:
    a: uint64 = P44_TEXT_PA + (P44_HANDLER_CODE - P44_TEXT_VA)

    # Keep the signal number safe in x11 (handler arg arrives in x0).
    # mov x11, x0 : orr x11, xzr, x0 = 0xAA0003E0 | (0<<16) | 11
    a = _emit_word(a, cast[uint64](0xAA0003E0) | (cast[uint64](0) << cast[uint64](16)) | cast[uint64](11))

    # x9 = SENTINEL_MAGIC ; x10 = SENTINEL_VA ; str x9, [x10]
    a = _emit_load_imm64(a, cast[uint64](9), P44_SENTINEL_MAGIC)
    a = _emit_load_imm64(a, cast[uint64](10), P44_SENTINEL_VA)
    # str x9, [x10] : 0xF9000000 | (imm12<<10) | (Rn<<5) | Rt   (imm12 scaled by 8)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](9))

    # x10 = SIGNUM_VA ; str x11, [x10]   (store the received signal number)
    a = _emit_load_imm64(a, cast[uint64](10), P44_SIGNUM_VA)
    a = _emit_word(a, cast[uint64](0xF9000000) | (cast[uint64](10) << cast[uint64](5)) | cast[uint64](11))

    # handler_ran(signo): x0 = x11 (signo); x8 = 750; svc #0
    a = _emit_word(a, cast[uint64](0xAA0003E0) | (cast[uint64](11) << cast[uint64](16)) | cast[uint64](0))   # mov x0, x11
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P44_HANDLER_RAN)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0

    # b P44_RET_TRAMP : 0x14000000 | imm26 ; imm26 = (target - here)/4
    here_va: uint64 = P44_HANDLER_CODE + (a - (P44_TEXT_PA + (P44_HANDLER_CODE - P44_TEXT_VA)))
    off: int64 = cast[int64](P44_RET_TRAMP) - cast[int64](here_va)
    imm26: uint64 = cast[uint64](off >> 2) & cast[uint64](0x3FFFFFF)
    a = _emit_word(a, cast[uint64](0x14000000) | imm26)

    _dsb_ish()
    _isb()
    return 0


# Materialise the sigreturn TRAMPOLINE into P44_RET_TRAMP: x8 = 751; svc #0. The
# kernel restores the interrupted frame + resumes the loop (this svc never returns
# to the trampoline). A real Linux sigframe stores this trampoline as the handler's
# return address; here the handler branches to it, which is equivalent.
def arm64_p44_build_trampoline() -> int64:
    a: uint64 = P44_TEXT_PA + (P44_RET_TRAMP - P44_TEXT_VA)
    a = _emit_load_imm64(a, cast[uint64](8), SYS_P44_SIGRETURN)
    a = _emit_word(a, cast[uint64](0xD4000001))                # svc #0
    _dsb_ish()
    _isb()
    return 0


# Initialise the task's resume-context block for a clean first ERET into its entry,
# on its OWN EL0 stack, at EL0t with IRQs UNMASKED (so the timer preempts it).
def arm64_p44_init_ctx(entry: uint64) -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](P44_CTX)
    i: int64 = 0
    while i < 34:
        ctx[i] = cast[uint64](0)
        i = i + 1
    ctx[CTX_SP_EL0] = P44_STACK_TOP
    ctx[CTX_ELR] = entry
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ
    return 0


# Phase-44 demand-fault entry. A first touch of a mapped page of the task's address
# space takes a translation fault (build pre-stamped the PTE). Confirm the VA lies in
# a mapped page, account it, flush, and resume (1). Mirrors arm64_p43_try_fault.
def arm64_p44_try_fault(esr: uint64) -> int64:
    dfsc: uint64 = esr & ESR_DFSC_MASK
    kind: uint64 = dfsc >> ESR_DFSC_KIND_SHIFT
    if kind != ESR_DFSC_KIND_XLAT:
        return 0
    far: uint64 = cast[uint64](_mrs_far_el1())
    page_va: uint64 = far & cast[uint64](0xFFFFFFFFFFFFF000)

    in_seg: int64 = 0
    if page_va == P44_TEXT_VA:
        arm64_p44_text_faults = arm64_p44_text_faults + 1
        in_seg = 1
    elif page_va == P44_STACK_VA:
        arm64_p44_stack_faults = arm64_p44_stack_faults + 1
        in_seg = 1
    elif page_va == P44_DATA_VA:
        arm64_p44_data_faults = arm64_p44_data_faults + 1
        in_seg = 1
    if in_seg == 0:
        return 0

    _dsb_ish()
    _tlbi_vaae1is(page_va >> cast[uint64](12))
    _dsb_ish()
    _isb()
    return 1


# Deliver the signal to the RUNNING EL0 task. Called from the Phase-44 scheduler at the
# delivery tick, with the interrupted EL0 context ALREADY saved into P44_CTX by the IRQ
# stub (slots 0..30 = x0..x30, 31 = SP_EL0, 32 = ELR_EL1 (resume PC), 33 = SPSR_EL1).
# Push a real signal frame (a verbatim copy of all 34 slots) onto the task's EL0 stack
# just below SP_EL0, 16-byte aligned; then rewrite the ctx so the IRQ-return ERET lands
# in the user handler (x0 = signal number, ELR = handler, SP_EL0 lowered past the frame,
# SPSR = EL0t IRQs-on). sigreturn later restores the 34 slots from the frame.
def arm64_p44_deliver_signal() -> int64:
    ctx: Ptr[uint64] = cast[Ptr[uint64]](P44_CTX)

    saved_pc: uint64 = ctx[CTX_ELR]
    saved_sp: uint64 = ctx[CTX_SP_EL0]
    arm64_p44_deliver_pc = saved_pc
    arm64_p44_saved_sp = saved_sp

    # Frame size: 34 slots * 8 bytes = 272, round up to a 16-byte multiple (288 keeps
    # 16-byte SP alignment). Place it just below the live SP_EL0.
    frame_bytes: uint64 = cast[uint64](288)
    frame_va: uint64 = saved_sp - frame_bytes
    arm64_p44_frame_va = frame_va

    fr: Ptr[uint64] = cast[Ptr[uint64]](frame_va)
    i: int64 = 0
    while i < 34:
        fr[i] = ctx[i]                          # verbatim copy of the interrupted context
        i = i + 1
    _dsb_ish()

    # Redirect the saved context into the handler: signal number in x0, PC -> handler,
    # SP -> lowered (past the frame), PSTATE -> EL0t with IRQs on. The IRQ stub restores
    # THIS ctx and erets into the handler.
    ctx[CTX_X0] = P44_SIGNO
    ctx[CTX_ELR] = P44_HANDLER_CODE
    ctx[CTX_SP_EL0] = frame_va
    ctx[CTX_SPSR] = SPSR_EL0T_IRQ
    _dsb_ish()

    arm64_p44_delivered = 1

    dm: Ptr[char] = "[arm64] Phase 44: timer delivered signal to the RUNNING EL0 task; pushed signal frame @ "
    _uart_puts(dm)
    _uart_puthex(frame_va)
    dm2: Ptr[char] = " interrupted PC="
    _uart_puts(dm2)
    _uart_puthex(saved_pc)
    dm3: Ptr[char] = " saved SP="
    _uart_puts(dm3)
    _uart_puthex(saved_sp)
    dm4: Ptr[char] = " signo="
    _uart_puts(dm4)
    _uart_puthex(P44_SIGNO)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    return 0


# sigreturn: restore the interrupted EL0 context from the signal frame on the EL0 stack
# back into P44_CTX, and rewind. Reads the 34-slot frame at the current SP_EL0 (which the
# handler/trampoline left at frame_va), copies it verbatim back into the ctx, and patches
# the live svc frame + ELR_EL1 + SP_EL0 so THIS svc's eret resumes the loop exactly. The
# loop's x19/x20/x21 are restored from the frame, so the accumulation continues correctly.
def arm64_p44_do_sigreturn(frame_ptr: Ptr[uint64]) -> int64:
    sp_at_ret: uint64 = cast[uint64](_mrs_sp_el0())
    fr: Ptr[uint64] = cast[Ptr[uint64]](sp_at_ret)

    # Cross-check the frame is where we pushed it.
    if sp_at_ret == arm64_p44_frame_va:
        mm: Ptr[char] = "[arm64] Phase 44: sigreturn found the signal frame at the expected SP\n"
        _uart_puts(mm)
    else:
        bm: Ptr[char] = "[arm64] Phase 44: sigreturn frame SP MISMATCH\n"
        _uart_puts(bm)

    ctx: Ptr[uint64] = cast[Ptr[uint64]](P44_CTX)

    # Restore the full 34-slot interrupted context from the user-stack frame into the
    # ctx block (so the NEXT timer-preemption save/restore is consistent too) AND into
    # the live svc frame's GP slots (so THIS svc's eret resumes with them).
    resume_pc: uint64 = fr[CTX_ELR]
    resume_sp: uint64 = fr[CTX_SP_EL0]
    resume_spsr: uint64 = fr[CTX_SPSR]

    i: int64 = 0
    while i < 31:
        ctx[i] = fr[i]                          # x0..x30 back into the ctx
        frame_ptr[i] = fr[i]                    # x0..x30 back into the live svc frame
        i = i + 1
    ctx[CTX_SP_EL0] = resume_sp
    ctx[CTX_ELR] = resume_pc
    ctx[CTX_SPSR] = resume_spsr
    _dsb_ish()

    # Patch the live exception-return state so this svc's eret lands back on the
    # interrupted instruction with the original SP. (The sync stub does NOT reload
    # SP_EL0/ELR/SPSR from the frame — it only reloads GP regs — so set the sysregs.)
    _msr_elr_el1(resume_pc)
    _msr_sp_el0(resume_sp)
    _msr_spsr_el1(resume_spsr)
    _isb()

    arm64_p44_returned = 1
    arm64_p44_resumed_pc = resume_pc

    rm: Ptr[char] = "[arm64] Phase 44: sigreturn restored the interrupted frame; resuming EL0 loop at PC="
    _uart_puts(rm)
    _uart_puthex(resume_pc)
    rm2: Ptr[char] = " SP="
    _uart_puts(rm2)
    _uart_puthex(resume_sp)
    nl: Ptr[char] = "\n"
    _uart_puts(nl)
    return 0


# report(chk, value): the task reports its final accumulator value; the kernel checks it
# equals the expected sum 0+1+...+(N-1). Returns 1 if it matches.
def arm64_p44_do_report(chk: uint64, value: uint64) -> int64:
    if chk == P44_CHK_RESULT:
        arm64_p44_result = value
        exp: uint64 = arm64_p44_expected_sum()
        ok: int64 = 0
        if value == exp:
            ok = 1
            arm64_p44_result_ok = 1
        rm: Ptr[char] = "[arm64] Phase 44: task reported final accumulator="
        _uart_puts(rm)
        _uart_puthex(value)
        rm2: Ptr[char] = " expected="
        _uart_puts(rm2)
        _uart_puthex(exp)
        rm3: Ptr[char] = " match="
        _uart_puts(rm3)
        _uart_puthex(cast[uint64](ok))
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        return ok
    return 0


# exit(status): mark the task EXITED (the scheduler reaps it). Parks its EL0 PC at a
# self-loop and switches to a throwaway return so the immediate svc-eret spins until
# the next tick reaps it. Mirrors arm64_p43_do_exit (single task).
def arm64_p44_do_exit(frame_ptr: Ptr[uint64], status: uint64) -> int64:
    arm64_p44_exit_status = status
    arm64_p44_exited = 1
    arm64_p44_state = P44_EXITED

    em: Ptr[char] = "[arm64] Phase 44: task exit(status="
    _uart_puts(em)
    _uart_puthex(status)
    em2: Ptr[char] = ") -> EXITED\n"
    _uart_puts(em2)

    # Park the EL0 PC at a self-loop at the end of the text page until the reaper runs.
    off: uint64 = cast[uint64](0xFFC)
    _emit_word(P44_TEXT_PA + off, cast[uint64](0x14000000))    # b . (self-loop)
    _dsb_ish()
    _isb()
    _msr_elr_el1(P44_TEXT_VA + off)
    _isb()
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-44 syscall dispatcher. Routed from arm64_sync_handler while the demo is live.
def arm64_p44_dispatch(frame_ptr: Ptr[uint64], nr: uint64, a0: uint64, a1: uint64, a2: uint64) -> int64:
    if nr == SYS_P44_HANDLER_RAN:
        arm64_p44_handler_ran = 1
        arm64_p44_handler_signo = a0
        hm: Ptr[char] = "[arm64] Phase 44: EL0 signal handler ran; signo="
        _uart_puts(hm)
        _uart_puthex(a0)
        nl: Ptr[char] = "\n"
        _uart_puts(nl)
        frame_ptr[0] = cast[uint64](0)
        return 0
    if nr == SYS_P44_SIGRETURN:
        return arm64_p44_do_sigreturn(frame_ptr)
    if nr == SYS_P44_REPORT:
        r: int64 = arm64_p44_do_report(a0, a1)
        frame_ptr[0] = cast[uint64](r)
        return 0
    if nr == SYS_P44_EXIT:
        return arm64_p44_do_exit(frame_ptr, a0)

    um: Ptr[char] = "[arm64] EL0 unknown syscall (phase 44)\n"
    _uart_puts(um)
    frame_ptr[0] = cast[uint64](0)
    return 0


# Phase-44 timer-IRQ scheduler. Each tick ASYNCHRONOUSLY interrupted the running EL0
# task (the IRQ stub already saved its full context into P44_CTX). Ack/re-arm the timer,
# EOI, advance the tick. Until the signal is delivered we let a few ticks pass so the
# task GENUINELY enters + runs its loop (proving delivery to a running task, not at a
# syscall boundary); then on the delivery tick we push the signal frame + redirect into
# the handler. If the task EXITED, run the verdict. Always returns P44_CTX (the single
# task), which the stub restores + erets into. Mirrors arm64_p43_sched_pick's shape.
def arm64_p44_sched_pick(cur_ctx: uint64) -> uint64:
    gicc_iar: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_IAR)
    gicc_eoir: Ptr[uint32] = cast[Ptr[uint32]](GICC_BASE + GICC_EOIR)

    iar: uint32 = gicc_iar[0]
    intid: uint64 = cast[uint64](iar) & cast[uint64](0x3FF)

    if intid != VTIMER_INTID:
        gicc_eoir[0] = iar
        return cur_ctx

    _msr_cntv_ctl_el0(cast[uint64](0))
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    gicc_eoir[0] = iar

    arm64_p44_tick = arm64_p44_tick + 1

    ctx: Ptr[uint64] = cast[Ptr[uint64]](P44_CTX)

    # If the task already EXITED, reap + run the verdict.
    if arm64_p44_state == P44_EXITED:
        arm64_p44_state = P44_DEAD
        arm64_p44_finish()
        while True:
            _wfi()

    # The saved resume PC tells us whether the task is genuinely inside its loop region.
    # The loop body sits between P44_MAIN_CODE+0x10 (after the 3 imm64 setups = 12 words)
    # and the report svc. We use a conservative window: PC in [MAIN_CODE, RET_TRAMP) and
    # NOT yet redirected. Mark loop_started once we observe a PC inside the text page.
    cur_pc: uint64 = ctx[CTX_ELR]
    if arm64_p44_loop_started == 0:
        if cur_pc >= P44_MAIN_CODE:
            if cur_pc < P44_HANDLER_CODE:
                arm64_p44_loop_started = 1

    # Deliver the signal on a deterministic tick AFTER the loop has started running, but
    # only ONCE, and only while the interrupted PC is genuinely inside the main loop
    # region (so the signal lands on a RUNNING task mid-computation, never on the handler
    # or a parked self-loop).
    if arm64_p44_delivered == 0:
        if arm64_p44_loop_started != 0:
            if cur_pc >= P44_MAIN_CODE:
                if cur_pc < P44_HANDLER_CODE:
                    arm64_p44_deliver_signal()

    if arm64_p44_tick >= 200000:
        # Safety bail-out: run the verdict so the test cannot hang forever.
        arm64_p44_finish()
        while True:
            _wfi()

    arm64_current_ctx = P44_CTX
    return P44_CTX


# Phase-44 verdict. PASS iff: the signal was delivered to the RUNNING task while its PC
# was genuinely inside the loop region; the handler ran with the right signal number;
# the observable sentinel (and the signal number) landed in the user data page; sigreturn
# restored the frame and resumed at exactly the interrupted PC; the resumed loop produced
# the EXACT expected sum (kernel-verified); and the task exited with the expected status.
# Prints a summary + PASS, then halts. Never returns.
def arm64_p44_finish() -> int64:
    arm64_p44_active = 0
    nl: Ptr[char] = "\n"

    # Read the observable sentinel + signum back out of the user data page (the PA, via
    # the identity map — the handler wrote it through the EL0 VA onto the SAME frame).
    sent: Ptr[uint64] = cast[Ptr[uint64]](P44_DATA_PA)
    sentinel_val: uint64 = sent[0]
    signum_val: uint64 = sent[1]

    sentinel_ok: int64 = 0
    if sentinel_val == P44_SENTINEL_MAGIC:
        sentinel_ok = 1
    signum_ok: int64 = 0
    if signum_val == P44_SIGNO:
        signum_ok = 1
    # The delivery PC must lie inside the loop region (proof it interrupted a running task).
    deliver_in_loop: int64 = 0
    if arm64_p44_deliver_pc >= P44_MAIN_CODE:
        if arm64_p44_deliver_pc < P44_HANDLER_CODE:
            deliver_in_loop = 1
    # The resume PC (after sigreturn) must equal the delivery PC (exact resume).
    resume_match: int64 = 0
    if arm64_p44_resumed_pc == arm64_p44_deliver_pc:
        resume_match = 1

    sm: Ptr[char] = "[arm64] Phase 44 summary: delivered="
    _uart_puts(sm)
    _uart_puthex(cast[uint64](arm64_p44_delivered))
    s1: Ptr[char] = " handler_ran="
    _uart_puts(s1)
    _uart_puthex(cast[uint64](arm64_p44_handler_ran))
    s2: Ptr[char] = " handler_signo="
    _uart_puts(s2)
    _uart_puthex(arm64_p44_handler_signo)
    s3: Ptr[char] = " returned="
    _uart_puts(s3)
    _uart_puthex(cast[uint64](arm64_p44_returned))
    s4: Ptr[char] = " sentinel_ok="
    _uart_puts(s4)
    _uart_puthex(cast[uint64](sentinel_ok))
    s5: Ptr[char] = " signum_ok="
    _uart_puts(s5)
    _uart_puthex(cast[uint64](signum_ok))
    _uart_puts(nl)

    s6: Ptr[char] = "[arm64] Phase 44 summary: deliver_pc="
    _uart_puts(s6)
    _uart_puthex(arm64_p44_deliver_pc)
    s7: Ptr[char] = " resume_pc="
    _uart_puts(s7)
    _uart_puthex(arm64_p44_resumed_pc)
    s8: Ptr[char] = " resume_match="
    _uart_puts(s8)
    _uart_puthex(cast[uint64](resume_match))
    s9: Ptr[char] = " result_ok="
    _uart_puts(s9)
    _uart_puthex(cast[uint64](arm64_p44_result_ok))
    s10: Ptr[char] = " exit_status="
    _uart_puts(s10)
    _uart_puthex(arm64_p44_exit_status)
    _uart_puts(nl)

    ok: int64 = 1
    if arm64_p44_delivered == 0:
        ok = 0
    if deliver_in_loop == 0:
        ok = 0
    if arm64_p44_handler_ran == 0:
        ok = 0
    if arm64_p44_handler_signo != P44_SIGNO:
        ok = 0
    if sentinel_ok == 0:
        ok = 0
    if signum_ok == 0:
        ok = 0
    if arm64_p44_returned == 0:
        ok = 0
    if resume_match == 0:
        ok = 0
    if arm64_p44_result_ok == 0:
        ok = 0
    if arm64_p44_exited == 0:
        ok = 0
    if arm64_p44_exit_status != P44_EXIT_CODE:
        ok = 0

    if ok != 0:
        rp: Ptr[char] = "[arm64] Phase 44: a single EL0 task ran a long accumulation loop under the live timer; while it was GENUINELY RUNNING mid-loop the timer IRQ delivered a signal: the kernel pushed a REAL signal frame (all 34 saved GP regs + PC + SP + PSTATE) onto the task's OWN EL0 stack and redirected EL0 into a user handler with the signal number in x0; the handler ran at EL0, stored an observable sentinel + the signal number into user memory, reported in, and branched to a sigreturn trampoline; sigreturn restored the full frame off the EL0 stack so the loop resumed at EXACTLY the interrupted PC with all registers intact and ran to completion, producing the kernel-verified expected sum; the task then exited with its expected status\n"
        _uart_puts(rp)
        pp: Ptr[char] = "[arm64] Phase 44 PASS: EL0 userspace signal delivery + sigreturn (timer delivered a signal to a running task, pushed a real frame on its EL0 stack, ran a user handler that set an observable sentinel, and sigreturn restored the frame so the interrupted loop resumed and completed with the expected value)\n"
        _uart_puts(pp)
    else:
        fp: Ptr[char] = "[arm64] Phase 44 FAIL: EL0 signal delivery + sigreturn verdict failed\n"
        _uart_puts(fp)

    _msr_daifset(2)
    while True:
        _wfi()
    return 0


# Phase-44 entry point (hand-off from arm64_p43_finish on a Phase-43 PASS). Build the
# task's fresh EL0 address space + ASID, materialise the main loop + handler + sigreturn
# trampoline into its text page, init its resume context, mark it RUNNABLE, re-arm the
# timer, UNMASK IRQs, and ERET into the loop at EL0t so the timer ASYNCHRONOUSLY preempts
# it mid-loop and the kernel delivers the signal. Never returns (halts at the verdict).
def arm64_p44_run() -> int64:
    intro: Ptr[char] = "[arm64] Phase 44: EL0 userspace signal delivery + sigreturn (async timer-delivered signal to a running EL0 task)\n"
    _uart_puts(intro)
    nl: Ptr[char] = "\n"

    _msr_daifset(2)                              # mask EL1 IRQs while we build

    # Reset bookkeeping.
    arm64_p44_tick = 0
    arm64_p44_loop_started = 0
    arm64_p44_delivered = 0
    arm64_p44_handler_ran = 0
    arm64_p44_handler_signo = 0xFFFF
    arm64_p44_returned = 0
    arm64_p44_exited = 0
    arm64_p44_exit_status = 0xFFFF
    arm64_p44_result = 0xFFFFFFFFFFFFFFFF
    arm64_p44_result_ok = 0
    arm64_p44_text_faults = 0
    arm64_p44_stack_faults = 0
    arm64_p44_data_faults = 0
    arm64_p44_deliver_pc = 0
    arm64_p44_frame_va = 0
    arm64_p44_saved_sp = 0
    arm64_p44_resumed_pc = 0

    # Build the address space (page tables + stack + sentinel page), make it live so the
    # routine builder's stores into the text page resolve coherently, then build the EL0
    # code (main loop + handler + sigreturn trampoline).
    arm64_p44_build_space()
    arm64_p44_switch_to_as()
    arm64_p44_build_main()
    arm64_p44_build_handler()
    arm64_p44_build_trampoline()

    arm64_p44_init_ctx(P44_MAIN_CODE)
    arm64_p44_state = P44_RUNNABLE
    arm64_p44_active = 1

    em: Ptr[char] = "[arm64] Phase 44: launching EL0 signal task (ASID 44) under the timer; entry="
    _uart_puts(em)
    _uart_puthex(P44_MAIN_CODE)
    em2: Ptr[char] = " expected_sum="
    _uart_puts(em2)
    _uart_puthex(arm64_p44_expected_sum())
    _uart_puts(nl)

    ctx: Ptr[uint64] = cast[Ptr[uint64]](P44_CTX)
    arm64_current_ctx = P44_CTX
    _msr_cntv_tval_el0(arm64_timer_period)
    _msr_cntv_ctl_el0(cast[uint64](1))
    _msr_daifclr(2)                              # UNMASK EL1 IRQs (Phase 43 masked them)
    _msr_spsr_el1(ctx[CTX_SPSR])
    _msr_elr_el1(ctx[CTX_ELR])
    _msr_sp_el0(ctx[CTX_SP_EL0])
    _isb()
    _eret()                                      # -> EL0; the loop runs, the timer preempts it
    # Unreachable: the verdict halts.
    while True:
        _wfi()
    return 0


def kmain() -> int64:
    # Select the board descriptor (BOARD_SEL) into the runtime board globals
    # before any console output, so UART/GIC/RAM addresses match the target.
    board_init()

    banner: Ptr[char] = "HAMNIX aarch64 boot OK\n"
    _uart_puts(banner)

    arm64_mmu_init()
    mmu_msg: Ptr[char] = "[arm64] MMU enabled\n"
    _uart_puts(mmu_msg)

    arm64_gic_init()
    arm64_timer_init()
    gic_msg: Ptr[char] = "[arm64] GICv2 + timer up\n"
    _uart_puts(gic_msg)

    # Wait for timer IRQs. After TICK_LIMIT ticks the IRQ handler runs the
    # Phase-4 single-task EL0 svc demo; on that task's exit() the syscall
    # dispatcher hands off to Phase 5 (preemptive two-task scheduling). Control
    # never returns here.
    while True:
        _wfi()
    return 0

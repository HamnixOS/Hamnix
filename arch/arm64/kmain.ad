# arch/arm64/kmain.ad — Phase 2 bare-metal aarch64 kernel entry.
#
# This is the first Adder code that runs on bare aarch64 (no Linux, no libc).
# The boot stub arch/arm64/boot.S sets up a stack and branches here. We write
# a recognizable banner to QEMU virt's PL011 UART (MMIO at 0x0900_0000), then
# halt forever in a wfi loop.
#
# Everything here stays inside the Phase 1 arm64 codegen subset: plain
# function defs, while loops, pointer indexing, casts, and volatile MMIO
# stores (a write through a cast[Ptr[uint8]](addr) pointer). No structs,
# globals-with-init, classes, or syscalls — there is no OS underneath.

# QEMU `virt` PL011 UART, primary instance.
#   data register (DR)   : base + 0x00  — write a byte to transmit it
#   flag register (FR)   : base + 0x18  — bit 5 (0x20) = TX FIFO full (TXFF)
PL011_BASE: uint64 = 0x09000000
PL011_FR_TXFF: uint64 = 0x20


def _uart_putc(c: uint8) -> int64:
    # Spin while the transmit FIFO is full so we never drop a byte. QEMU's
    # emulated PL011 drains instantly, but polling keeps this correct on
    # real PL011 silicon too.
    fr: Ptr[uint8] = cast[Ptr[uint8]](PL011_BASE + 0x18)
    while (cast[uint64](fr[0]) & PL011_FR_TXFF) != 0:
        pass
    dr: Ptr[uint8] = cast[Ptr[uint8]](PL011_BASE)
    dr[0] = c
    return 0


def _uart_puts(s: Ptr[char]) -> int64:
    # Write a NUL-terminated string to the UART, byte by byte.
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    i: int64 = 0
    while p[i] != 0:
        _uart_putc(p[i])
        i = i + 1
    return i


def kmain() -> int64:
    banner: Ptr[char] = "HAMNIX aarch64 boot OK\n"
    _uart_puts(banner)
    # Boot stub halts on return; return cleanly.
    return 0

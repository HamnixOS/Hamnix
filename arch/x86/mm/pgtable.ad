# arch/x86/mm/pgtable.ad
#
# Dynamic post-e820 identity-map extension.
#
# Background:
#   The boot stub (arch/x86/boot/header.S for multiboot1, arch/x86/boot/
#   efi_stub.S for UEFI direct boot) installs a fixed identity map: 4
#   PDPT entries pointing at 1 GiB pages covering 0..4 GiB. That's
#   enough to reach LAPIC / IOAPIC / HPET MMIO under 4 GiB and to
#   identity-cover the kernel image / boot stack / early-allocator
#   pool. But QEMU `-m 6G` or a real laptop with 5 GiB / 8 GiB / 16 GiB
#   reports RAM extending beyond 4 GiB in the e820 / multiboot mmap,
#   and the moment page_alloc_init() carves a page from above 4 GiB
#   the kernel write into that page traps #PF (vector 0x0e, err=0x02 —
#   "kernel-mode write to not-present").
#
# Fix:
#   After e820_init() has parsed the firmware memory map (which we
#   re-walk here — e820.ad doesn't expose a public iterator yet), stamp
#   one PDPT entry per 1 GiB page covering every E820_RAM (type=1)
#   region. Already-present entries (the first 4 GiB stamped by the
#   boot stub) are skipped, so this is idempotent.
#
# Design notes:
#   - We read the PDPT base from CR3 (CR3 -> PML4 phys; PML4[0] holds
#     the PDPT phys with the lower 12 bits being flags). This works
#     uniformly on the multiboot1 boot path (kernel `pml4`/`pdpt` in
#     .pgtables) AND the UEFI direct-boot path (efi_stub's private
#     efi_pml4/efi_pdpt in the stub's .bss). Both arrangements satisfy
#     PML4[0] -> PDPT -> 4× 1 GiB pages at PDPT[0..3].
#   - Flags on new entries: PS|RW|P (0x83). U=0: kernel-only. NX=0:
#     deferred to a separate W^X hardening pass.
#   - Whole 1 GiB pages: if an E820_RAM region is only e.g. 100 MiB,
#     we still stamp a full 1 GiB. The overshoot just identity-maps a
#     non-RAM hole; nothing writes there because page_alloc only
#     allocates from memblock, and memblock only tracks the one
#     selected region from e820.ad. Harmless.
#   - TLB flush: page-walkers don't cache absent PDPT entries on x86,
#     so strictly speaking we don't need a flush after adding entries.
#     But a full reload via `mov %cr3,%rax; mov %rax,%cr3` costs
#     < 1 microsecond and shuts the door on any speculative-prefetch
#     edge case. Done via load_cr3(get_bsp_cr3()).
#
# Theoretical ceiling: PDPT has 512 entries × 1 GiB = 512 GiB. Beyond
# that we'd need to widen PML4 (4-level paging) or move to LA57. Both
# are deliberately out of scope; the 512 GiB ceiling covers every
# current x86_64 server config Hamnix targets.

from kernel.printk.printk import printk0, printk1, printk2
from mm.page_alloc import alloc_page, free_page

extern def get_mb_info() -> uint64
extern def get_mb_magic() -> uint64
extern def get_bsp_cr3() -> uint64
extern def load_cr3(value: uint64)
extern def read_msr(index: uint32) -> uint64
extern def write_msr(index: uint32, value: uint64)

# --- virt_to_phys / phys_to_virt -----------------------------------
#
# Hamnix is a HIGHER-HALF kernel: its .text/.rodata/.data/.bss are
# LINKED and run at KERNEL_VBASE (0xffffffff80000000) + offset, but the
# image is LOADED into low physical RAM. The boot stub maps the kernel
# image at BOTH the low identity address AND the high half; it also
# keeps a full low identity map (PML4[0]) so the kernel can touch
# physical RAM directly.
#
# Consequence for DMA: hardware (virtio, AHCI, NVMe, NICs, USB HCs)
# DMAs to/from PHYSICAL addresses. A pointer to a kernel GLOBAL is now
# a high-half virtual address (0xffffffff80...); handing that to a
# device as a DMA target makes the device write to physical
# 0xffffffff80... — garbage. Every address passed to a device must
# first go through virt_to_phys().
#
# Two address regimes the kernel deals with:
#   - High-half kernel image addresses (>= KERNEL_VBASE): a global, a
#     function, a .bss buffer. phys = va - KERNEL_VBASE.
#   - Low addresses (< KERNEL_VBASE): already physical. alloc_page() /
#     kmalloc() / memblock_alloc() all return LOW physical addresses
#     (which are also valid VAs via the low identity map). These pass
#     through unchanged.
#
# phys_to_virt() is the inverse for the high-half image only; a low
# physical address maps to itself (identity). Most kernel code can
# dereference a low physical address directly, so phys_to_virt() is
# mainly a documentation/asymmetry helper.
PGT_KERNEL_VBASE: uint64 = 0xffffffff80000000


def virt_to_phys(va: uint64) -> uint64:
    # Convert a kernel virtual address to the physical address a device
    # can DMA to. THREE regimes, checked high-to-low so a high-half image
    # VA (which is numerically also >= PGT_PAGE_OFFSET) resolves via the
    # image branch, never the page_offset branch:
    #   1. High-half kernel IMAGE (>= PGT_KERNEL_VBASE, 0xffffffff80..):
    #      a global / .text / .bss byte. phys = va - KERNEL_VBASE.
    #   2. page_offset DIRECT-MAP alias ([PGT_PAGE_OFFSET, PGT_KERNEL_VBASE),
    #      0xffff8880.. .. 0xffffffff80..): the kernel-private high-half
    #      window onto physical RAM installed by KPTI #94 step 1. This is
    #      the alias a KPTI-isolated slab/kstack/PT allocation is reached
    #      through. phys = va - PGT_PAGE_OFFSET.
    #   3. Low identity (< PGT_PAGE_OFFSET): an alloc_page/kmalloc/memblock
    #      result today (already identity-mapped == physical). Passes
    #      through unchanged.
    # Branch 2 is DEAD until a consumer flip (Brick B[4/4]) starts handing
    # out alias VAs — no current caller passes a [PGT_PAGE_OFFSET, VBASE)
    # address — so adding it is semantics-preserving for every present DMA
    # site. It is the CENTRAL prerequisite for that flip: once slab returns
    # alias VAs, ~15 DMA sites doing virt_to_phys(buf) resolve correctly
    # here instead of feeding the raw alias VA to hardware as a "physical"
    # address.
    if va >= PGT_KERNEL_VBASE:
        return va - PGT_KERNEL_VBASE
    if va >= PGT_PAGE_OFFSET:
        return va - PGT_PAGE_OFFSET
    return va


def phys_to_virt(pa: uint64) -> uint64:
    # Canonical kernel virtual address for a physical RAM byte, and the
    # inverse of virt_to_phys's alias branch. Once the page_offset direct
    # map is live (KPTI #94 step 1; pgt_page_offset_ready==1) the canonical
    # kernel view of RAM is the kernel-private high-half alias, so we return
    # pa + PGT_PAGE_OFFSET — which round-trips an alias-backed buffer exactly
    # (phys_to_virt(virt_to_phys(alias_va)) == alias_va). Before the map is
    # built (very early boot) we fall back to the high-half IMAGE alias for
    # the narrow image-footprint symmetry this helper historically served.
    # A low physical address is ALSO a valid VA through the low identity map,
    # so callers that just want to dereference physical RAM can still use
    # `pa` directly; nothing in-tree calls this in a hot path.
    if pgt_page_offset_ready != 0:
        return pa + PGT_PAGE_OFFSET
    return pa + PGT_KERNEL_VBASE


# --- KPTI #94, Brick B[4/4]: the disciplined __pa()/__va() split -----
#
# The load-bearing prerequisite for relocating the kernel allocator onto
# the page_offset alias (0xffff8880..). A page-table PAGE has TWO
# identities the code must never conflate:
#   * its VIRTUAL address  — how the kernel dereferences it to read/write
#     its 512 entries (`cast[Ptr[uint64]](page + idx*8)`), and
#   * its PHYSICAL frame base — the value the CPU page walker consumes,
#     i.e. what is stored into the PARENT entry (`parent[i] = base | flags`)
#     and what is loaded into CR3.
# Today alloc_page() returns a LOW identity address where VA==PA, so the
# two happen to be the same number and the distinction is invisible. The
# moment alloc_page() hands out an alias VA (the eventual flip), writing
# the raw alloc result into a PTE as a "physical base" stores 0xffff8880..
# into the hardware walker → instant corruption (the exact hazard Brick
# B[3/4] stopped on). The fix is a disciplined vocabulary applied at every
# page-table builder:
#   __pa(va)  — call at the MOMENT of storing a page pointer into a parent
#               entry or CR3. Converts a (possibly-alias) VA to the phys
#               base the walker needs. Today a pass-through no-op for the
#               low VAs alloc_page returns, so it changes NO current boot.
#   __va(pa)  — call the MOMENT a child pointer is read back OUT of an
#               entry (`child = entry & ADDR_MASK`) before dereferencing
#               it. Converts a phys base to a dereferenceable kernel VA.
# These are thin, self-documenting aliases of virt_to_phys/phys_to_virt so
# a reviewer sees INTENT at the call site ("this number is about to be
# treated as a physical base / about to be dereferenced") rather than a
# bare arithmetic helper. Keeping the split in the vocabulary is what makes
# the future allocator flip a localized, auditable change instead of a
# hunt across every builder.
def __pa(va: uint64) -> uint64:
    return virt_to_phys(va)


def __va(pa: uint64) -> uint64:
    return phys_to_virt(pa)


# --- KPTI #94, step 1: high-half kernel direct map (page_offset) -----
#
# THE WALL (cpu_mitigations.ad KPTI block): Hamnix reaches all physical
# RAM — kmalloc heap, kstacks, page tables, task_structs, per-CPU areas —
# through the LOW identity map in PML4[0]. But PML4[0] is ALSO the subtree
# that backs user pages, so a Meltdown-protective user CR3 can't drop it
# without unmapping user memory, and keeping it re-exposes the whole kernel
# heap. Real isolation needs the kernel's view of physical RAM RELOCATED
# out of the user-shared low half into a kernel-private high-half window.
#
# This is that window: a Linux-style `page_offset` direct map at
# PGT_PAGE_OFFSET (0xffff888000000000, PML4[273]) that aliases ALL physical
# RAM with 1 GiB kernel-only (US=0) pages. It is installed ADDITIVELY at
# mem_init time and the low identity map is KEPT (dual-mapped), so nothing
# breaks: existing vaddr==phys consumers keep working through PML4[0] while
# new/converted consumers can reach RAM through the high-half alias via
# page_offset_va(). The end state of KPTI #94 is that kernel dynamic memory
# is reached ONLY through this alias, so the user CR3 can drop PML4[0]'s
# identity exposure. That consumer flip (alloc_page/kmalloc/kstack callers)
# is the remaining large mm work; this commit lands the alias + proof.
#
# US=0 is the whole point: the high-half direct map is kernel-private, so
# even before the consumer flip a live user CR3 that strips PML4[273] hides
# it from a CPL3 probe.
PGT_PAGE_OFFSET:          uint64 = 0xffff888000000000
PGT_PAGE_OFFSET_PML4_IDX: uint64 = 273        # 0xffff888000000000 >> 39 & 0x1FF
# PML4-entry flags pointing at the direct-map PDPT: P|RW, US=0 (kernel-only).
PGT_PML4E_KERN_FLAGS:     uint64 = 0x3
# 1 GiB leaf flags for the direct map: PS|RW|P, US=0 (0x83). Kernel-only,
# deliberately NOT matching the identity map's US=1 (0x87) — this alias is
# never reachable from CPL3.
PGT_DMAP_1GB_FLAGS:       uint64 = 0x83

# Published once pgtable_build_page_offset_map() has installed PML4[273].
pgt_page_offset_ready: uint64 = 0


def page_offset_va(pa: uint64) -> uint64:
    # Kernel-private high-half virtual address for a physical RAM byte,
    # through the page_offset direct map (PML4[273]). This is the alias a
    # KPTI-isolated kernel uses instead of the low identity map. Only valid
    # after pgtable_build_page_offset_map(); before that, callers must use
    # the low identity VA (== pa).
    return pa + PGT_PAGE_OFFSET


def page_offset_pa(va: uint64) -> uint64:
    # Inverse of page_offset_va: recover the physical address from a
    # page_offset direct-map VA.
    return va - PGT_PAGE_OFFSET


def phys_to_hhdm(pa: uint64) -> uint64:
    # High-half direct-map (HHDM) VA for a physical RAM byte, GATED on the
    # map being live. Returns the kernel-private page_offset alias
    # (PML4[273], 0xffff8880..) once pgtable_build_page_offset_map() has run
    # — an address a user task's LOW-half mapping can never punch (PML4[273]
    # is US=0 and is not the subtree an ET_EXEC's low-vaddr BSS registration
    # cracks) — and falls back to the low identity VA (== pa) before the map
    # exists (very early boot). This is the helper a kernel RAM consumer uses
    # to reach a physical buffer IMMUNE to a user CR3's low-half punch,
    # mirroring Linux accessing all RAM through the page_offset direct map so
    # a user mapping can never alias/hide kernel RAM. Distinct from
    # page_offset_va (which is unconditional): callers that may run before
    # the map is built must use this gated form.
    if pgt_page_offset_ready != 0:
        return pa + PGT_PAGE_OFFSET
    return pa


def pgtable_page_offset_ready() -> uint64:
    # 1 iff the high-half direct map is installed (selftest accessor).
    return pgt_page_offset_ready


def pgtable_build_page_offset_map():
    # Install the kernel-private high-half direct map at PML4[273]
    # (PGT_PAGE_OFFSET). Allocates one PDPT page and stamps 512 × 1 GiB
    # US=0 leaves aliasing physical [0, 512 GiB). ADDITIVE: the low
    # identity map in PML4[0] is untouched, so this cannot break any
    # existing vaddr==phys consumer — it only ADDS a second, kernel-only
    # window onto the same RAM.
    #
    # Must run AFTER page_alloc_init() (needs alloc_page) and BEFORE the
    # first task clone, so the full-page PML4 memcpy in kernel/sched/core.ad
    # propagates PML4[273] to every per-task address space automatically
    # (the kernel executes on the task's CR3 during syscalls, so it needs
    # the direct map mapped there too).
    pdpt: uint64 = alloc_page()
    if pdpt == 0:
        printk0("[pgtable] page_offset: OOM allocating direct-map PDPT\n")
        return
    # Fill 512 × 1 GiB US=0 leaves: PDPT[i] -> phys i*1GiB.
    i: uint64 = 0
    while i < PGT_PDPT_ENTRIES:
        phys: uint64 = i << PGT_1GB_SHIFT
        cast[Ptr[uint64]](pdpt + i * 8)[0] = phys | PGT_DMAP_1GB_FLAGS
        i = i + 1
    # Install the PML4[273] -> PDPT link in the live BSP PML4. `pdpt` is the
    # alloc_page VA we filled above (dereferenced through its own mapping);
    # __pa() converts it to the PHYSICAL base the walker consumes for this
    # entry. Today a no-op pass-through (alloc returns low VA==PA); once the
    # allocator flips to alias VAs this is what keeps a 0xffff8880.. pointer
    # from being stamped into the PML4 as a phys base. The `pml4` root itself
    # is the boot PML4 taken from CR3 (a phys the CPU already walks) and stays
    # identity-mapped, so it is dereferenced directly — and note this runs
    # while BUILDING the alias (pgt_page_offset_ready still 0), so __va() is
    # deliberately NOT used on the root here.
    cr3:  uint64 = get_bsp_cr3()
    pml4: uint64 = cr3 & PGT_ADDR_MASK
    cast[Ptr[uint64]](pml4 + PGT_PAGE_OFFSET_PML4_IDX * 8)[0] = \
        __pa(pdpt) | PGT_PML4E_KERN_FLAGS
    # Flush the TLB so the new high-half window is live immediately.
    load_cr3(cr3)
    pgt_page_offset_ready = 1
    printk2("[pgtable] page_offset direct map: PML4[%d] -> PDPT %p\n",
            PGT_PAGE_OFFSET_PML4_IDX, pdpt)
    printk1("[pgtable] page_offset base=%p (512 GiB, US=0, dual-mapped)\n",
            PGT_PAGE_OFFSET)


def pgtable_page_offset_selftest() -> uint64:
    # Prove the high-half direct map aliases the SAME physical RAM as the
    # low identity map. Alloc a page, write a sentinel through its LOW
    # identity VA (== phys), read it back through the page_offset alias,
    # and assert equality. This is the boot-marker proof that KPTI step 1
    # (relocatable kernel view of RAM) actually resolves. Non-destructive
    # (frees the page). Returns 1 PASS / 0 FAIL.
    if pgt_page_offset_ready == 0:
        printk0("[pgtable] page_offset selftest SKIP: map not built\n")
        return 0
    p: uint64 = alloc_page()
    if p == 0:
        printk0("[pgtable] page_offset selftest SKIP: OOM\n")
        return 0
    sentinel: uint64 = 0x5A17E00DDEADC0DE
    cast[Ptr[uint64]](p)[0] = sentinel            # write via low identity
    alias: uint64 = page_offset_va(p)
    got: uint64 = cast[Ptr[uint64]](alias)[0]     # read via high-half alias
    ok: uint64 = 0
    if got == sentinel:
        ok = 1
        printk2("[pgtable] page_offset PASS phys=%p alias=%p", p, alias)
        printk0(" reads the same RAM\n")
    else:
        printk2("[pgtable] page_offset FAIL phys=%p alias=%p", p, alias)
        printk1(" got=%p\n", got)
    free_page(p)
    return ok


def pgtable_dma_roundtrip_selftest() -> uint64:
    # KPTI #94, Brick B[3/4] DMA-safety proof. Before slab / PT-page backing
    # can be relocated onto the page_offset alias, virt_to_phys() and
    # phys_to_virt() MUST resolve an alias VA to the SAME physical address a
    # low-identity VA does. This is load-bearing for DMA: every device site
    # (virtio-gpu/-modern/-ring/-net, ahci, nvme, r8169) computes its DMA
    # target with virt_to_phys(kmalloc/alloc_pages result). If the allocator
    # starts returning alias VAs and virt_to_phys mis-resolved them, the
    # device would DMA to a garbage physical address — SILENT disk/net/GPU
    # corruption, not a clean fault. Prove BOTH regimes here on every boot.
    #
    # Checks (non-destructive; frees its page):
    #   (1) low-identity buffer: virt_to_phys(p) passes through == p (phys).
    #   (2) alias buffer: virt_to_phys(page_offset_va(p)) rebases to the SAME
    #       physical page p.
    #   (3) same-RAM: a sentinel written through the low-identity VA reads
    #       back through the alias VA (both name one physical frame — exactly
    #       what a device would DMA to).
    #   (4) inverse: phys_to_virt(virt_to_phys(alias)) round-trips the alias.
    # Returns 1 PASS / 0 FAIL.
    if pgt_page_offset_ready == 0:
        printk0("[pgtable] dma-roundtrip SKIP: page_offset map not built\n")
        return 0
    p: uint64 = alloc_page()            # low-identity VA == physical address
    if p == 0:
        printk0("[pgtable] dma-roundtrip SKIP: OOM\n")
        return 0
    alias:  uint64 = page_offset_va(p)
    lo_pa:  uint64 = virt_to_phys(p)      # (1) pass-through
    hi_pa:  uint64 = virt_to_phys(alias)  # (2) alias rebased to phys
    ok: uint64 = 1
    if lo_pa != p:
        printk2("[pgtable] dma-roundtrip FAIL: low-identity v2p(%p)=%p\n",
                p, lo_pa)
        ok = 0
    if hi_pa != p:
        printk2("[pgtable] dma-roundtrip FAIL: alias v2p(%p)=%p", alias, hi_pa)
        printk1(" (expected phys %p)\n", p)
        ok = 0
    # (3) Same-RAM: write through low identity, read through the alias.
    sentinel: uint64 = 0xDEADBEEFCAFEF00D
    cast[Ptr[uint64]](p)[0] = sentinel
    got: uint64 = cast[Ptr[uint64]](alias)[0]
    if got != sentinel:
        printk2("[pgtable] dma-roundtrip FAIL: alias %p read %p", alias, got)
        printk0(" (not the same RAM as the low-identity VA)\n")
        ok = 0
    # (4) Inverse: phys_to_virt returns the canonical alias, round-tripping.
    back: uint64 = phys_to_virt(hi_pa)
    if back != alias:
        printk2("[pgtable] dma-roundtrip FAIL: phys_to_virt(%p)=%p", hi_pa, back)
        printk1(" (expected alias %p)\n", alias)
        ok = 0
    free_page(p)
    if ok == 1:
        printk2("[pgtable] dma-roundtrip PASS: phys=%p alias=%p", p, alias)
        printk0(" v2p/p2v resolve the same RAM (low-identity + alias)\n")
    return ok


# --- KPTI #94, Brick A: cpu_entry_area -------------------------------
#
# A live KPTI trampoline runs from the USER CR3 for the first handful of
# instructions after a CPL3->CPL0 transition, BEFORE it can reload the
# kernel CR3. During that window the CPU must be able to reach, at their
# mapped VAs: the entry .text stub it is executing, the IDT gate it
# vectored through, the per-CPU GDT/TSS (RSP0 for the stack switch), the
# #DF IST stack, and the MDS VERW selector word (mds_verw_sel). In Hamnix
# those pages are SCATTERED across the high-half kernel image (PML4[511]
# .text/.rodata/.bss) — which the user CR3 strips — so a live switch would
# triple-fault on the very first fetch.
#
# The cpu_entry_area collects exactly those pages into a dedicated,
# kernel-private VA window at PML4[274] (PGT_CEA_BASE). It is built
# ADDITIVELY: the pages stay where they are; we add a SECOND mapping at a
# CEA VA that aliases each one. Every CEA leaf is US=0 (kernel-only), and
# the window is propagated to every per-task PML4 by the same full-page
# PML4 memcpy in kernel/sched/core.ad that carries PML4[273]/page_offset —
# so a future user CR3 will already carry the entry window while the rest
# of the kernel image stays stripped. This commit builds + proves the
# window; wiring the entry stubs to reference the CEA VAs (and flipping
# KPTI_LIVE_ENABLE) is the follow-up.
#
# ADDRESS SCHEME: every mapped page keeps its position RELATIVE to the
# kernel .text base, i.e. CEA_VA(kva) = PGT_CEA_BASE + (kva - text_start).
# So a single uniform bias translates any kernel-image symbol to its CEA
# alias, which is exactly what the entry-stub rewrite will need. The span
# from .text base to the per-CPU .bss structures is < 1 GiB, so the whole
# window lives under PML4[274] -> PDPT[0] -> one PD, with PT pages
# allocated lazily only for the (sparse) PDs that actually carry mapped
# pages (.text at the low end; IDT/TSS/GDT/#DF-stack in .bss near the top).
#
# We map only what the entry path provably needs: ALL of executable .text
# (so every syscall/trap/irq stub is covered without a fragile per-stub
# section split — code carries no secret a Meltdown probe couldn't read
# from the on-disk ELF), plus the specific IDT / GDT / TSS / #DF-stack /
# VERW DATA pages. The confidentiality-sensitive kernel .data/.bss heap is
# deliberately NOT bulk-mapped here.
PGT_CEA_PML4_IDX: uint64 = 274                # 0xffff890000000000 >> 39 & 0x1FF
PGT_CEA_BASE:     uint64 = 0xffff890000000000
# US=0 RW P for both the CEA non-leaf links and its 4 KiB leaves. Kernel-
# private: never reachable from CPL3 even before the entry-stub rewrite.
PGT_CEA_FLAGS:    uint64 = 0x3

# Region sizes (bytes) of the discrete entry structures, mirroring
# arch/x86/kernel/tss_asm.S (.equ NR_TSS_CPUS 16, strides) and idt.ad
# (idt_table: Array[512, uint64]).
PGT_CEA_IDT_BYTES:      uint64 = 4096         # 512 * 8
PGT_CEA_TSS_BYTES:      uint64 = 2048         # TSS_STRIDE 128 * 16 CPUs
PGT_CEA_GDT_BYTES:      uint64 = 1024         # GDT_STRIDE 64 * 16 CPUs
PGT_CEA_DF_BYTES:       uint64 = 65536        # DF_STK_SIZE 4096 * 16 CPUs
PGT_CEA_VERW_BYTES:     uint64 = 8            # a 16-bit word, rounded up

# Kernel VAs of the entry structures (arch/x86/kernel/cpu_entry_area_asm.S).
extern def cea_idt_addr() -> uint64
extern def cea_tss_addr() -> uint64
extern def cea_gdt_addr() -> uint64
extern def cea_df_stack_addr() -> uint64
extern def cea_verw_addr() -> uint64
extern def cea_entry_text_start() -> uint64
extern def cea_entry_text_end() -> uint64

# Published once pgtable_build_cpu_entry_area() has installed PML4[274].
pgt_cea_ready:      uint64 = 0
# Recorded at build time so CEA_VA() and the selftest agree on the bias.
pgt_cea_text_start: uint64 = 0
# The CEA PDPT base (VA) — root of the window under PML4[274]. The mapper
# walks from here, lazily allocating a PD per touched 1 GiB PDPT slot and a
# PT per touched 2 MiB PD slot, so the window can span the WHOLE kernel
# image no matter how far the entry .bss structures sit from .text (a large
# embedded initramfs/rootfs can push the IDT/GDT/TSS/#DF past the first
# GiB; a single fixed PD silently dropped them — KPTI CEA UEFI divergence).
pgt_cea_pdpt_base:  uint64 = 0


def pgtable_cea_ready() -> uint64:
    # 1 iff the cpu_entry_area is installed (selftest accessor).
    return pgt_cea_ready


def pgtable_cea_va(kva: uint64) -> uint64:
    # Translate a kernel-image VA to its cpu_entry_area alias VA. Uniform
    # bias off the .text base recorded at build time. Only meaningful for
    # pages actually mapped into the CEA (entry .text + the IDT/GDT/TSS/
    # #DF/VERW structures); a caller must ensure kva is one of those.
    return PGT_CEA_BASE + (kva - pgt_cea_text_start)


def _cea_zero_page(pa: uint64):
    # Zero a freshly-allocated table page (alloc_page does not guarantee
    # zeroed). pa is a low identity address == its own VA.
    i: uint64 = 0
    while i < cast[uint64](512):
        cast[Ptr[uint64]](pa + i * 8)[0] = cast[uint64](0)
        i = i + 1


def _cea_walk_child(parent: uint64, idx: uint64) -> uint64:
    # Return a dereferenceable VA for the child table under parent[idx],
    # lazily allocating + linking it if absent. Both parent and the returned
    # child are handled as VIRTUAL addresses; __pa() converts a freshly
    # allocated child to the physical base stamped into the entry, and __va()
    # rebases an existing child's physical base back to a kernel VA. Runs
    # AFTER pgtable_build_page_offset_map() so __va() targets a live alias.
    # Returns 0 on OOM.
    slot: Ptr[uint64] = cast[Ptr[uint64]](parent + idx * 8)
    ent: uint64 = slot[0]
    if (ent & PGT_FLAG_P) == 0:
        child: uint64 = alloc_page()
        if child == 0:
            return 0
        _cea_zero_page(child)
        slot[0] = __pa(child) | PGT_CEA_FLAGS
        return child
    return __va(ent & PGT_ADDR_MASK)


def _cea_map_page(kva: uint64) -> int32:
    # Alias the 4 KiB page containing kernel-image VA `kva` into the CEA
    # window at CEA_VA(kva). Walks the CEA's OWN indices from the PDPT root
    # (pgt_cea_pdpt_base), lazily allocating the PD for kva's 1 GiB slot and
    # the PT for its 2 MiB slot. Keyed on the CEA VA's indices — NOT a fixed
    # single PD — so a structure any distance past .text (e.g. a .bss IDT
    # beyond the first GiB when a large embedded rootfs bloats .data) still
    # maps. Returns 1 on success, 0 on OOM.
    cea: uint64 = pgtable_cea_va(kva)
    pdpt_idx: uint64 = (cea >> PGT_1GB_SHIFT) & cast[uint64](0x1FF)
    pd_idx:   uint64 = (cea >> PGT_2M_SHIFT) & cast[uint64](0x1FF)
    pt_idx:   uint64 = (cea >> 12) & cast[uint64](0x1FF)
    pd: uint64 = _cea_walk_child(pgt_cea_pdpt_base, pdpt_idx)
    if pd == 0:
        return 0
    pt: uint64 = _cea_walk_child(pd, pd_idx)
    if pt == 0:
        return 0
    # Leaf: phys of the image page (high-half VA rebased to low phys).
    phys: uint64 = virt_to_phys(kva & ~cast[uint64](4095))
    cast[Ptr[uint64]](pt + pt_idx * 8)[0] = phys | PGT_CEA_FLAGS
    return 1


def _cea_map_range(start: uint64, end: uint64) -> uint64:
    # Map every 4 KiB page in [start, end) into the CEA window. Returns the
    # number of pages mapped (0 on the first OOM — partial maps are harmless
    # because nothing references the CEA VAs yet).
    cur: uint64 = start & ~cast[uint64](4095)
    mapped: uint64 = 0
    while cur < end:
        if _cea_map_page(cur) == 0:
            return mapped
        mapped = mapped + 1
        cur = cur + 4096
    return mapped


def pgtable_build_cpu_entry_area():
    # Build the cpu_entry_area (PML4[274]): alias the entry .text + the
    # IDT/GDT/TSS/#DF-stack/VERW pages into a kernel-private window at their
    # CEA VAs. ADDITIVE — the originals stay mapped in PML4[511]/PML4[0], so
    # this cannot break the running kernel; it only ADDS a second window.
    #
    # Must run AFTER page_alloc_init() (needs alloc_page) and BEFORE the
    # first task clone, so the full-page PML4 memcpy in kernel/sched/core.ad
    # propagates PML4[274] to every per-task address space (alongside the
    # PML4[273] page_offset entry from step 1).
    text_start: uint64 = cea_entry_text_start()
    text_end:   uint64 = cea_entry_text_end()
    pgt_cea_text_start = text_start

    pdpt: uint64 = alloc_page()
    if pdpt == 0:
        printk0("[pgtable] cpu_entry_area: OOM allocating CEA PDPT\n")
        return
    _cea_zero_page(pdpt)
    pgt_cea_pdpt_base = pdpt

    # Link PML4[274] -> PDPT (US=0). The per-1 GiB PDs and per-2 MiB PTs are
    # allocated LAZILY by _cea_map_page as ranges are mapped, so the window
    # can span the whole kernel image regardless of how far the entry .bss
    # structures sit from .text. `pdpt` is dereferenced through its alloc VA;
    # __pa() converts it to the phys base the parent entry must hold (no-op
    # today, alloc VA==PA). The `pml4` root is the boot PML4 from CR3 and
    # stays identity-mapped, so it is dereferenced directly.
    cr3:  uint64 = get_bsp_cr3()
    pml4: uint64 = cr3 & PGT_ADDR_MASK
    cast[Ptr[uint64]](pml4 + PGT_CEA_PML4_IDX * 8)[0] = __pa(pdpt) | PGT_CEA_FLAGS

    # Map executable .text (every entry stub) contiguously, then the discrete
    # entry data structures. Each returns the pages mapped; a short count
    # means alloc_page() ran dry building a lazy PD/PT — surfaced below so an
    # incomplete CEA is never mistaken for a healthy one.
    idt_kva:  uint64 = cea_idt_addr()
    gdt_kva:  uint64 = cea_gdt_addr()
    tss_kva:  uint64 = cea_tss_addr()
    df_kva:   uint64 = cea_df_stack_addr()
    verw_kva: uint64 = cea_verw_addr()
    text_pages: uint64 = _cea_map_range(text_start, text_end)
    m_idt:  uint64 = _cea_map_range(idt_kva,  idt_kva  + PGT_CEA_IDT_BYTES)
    m_gdt:  uint64 = _cea_map_range(gdt_kva,  gdt_kva  + PGT_CEA_GDT_BYTES)
    m_tss:  uint64 = _cea_map_range(tss_kva,  tss_kva  + PGT_CEA_TSS_BYTES)
    m_df:   uint64 = _cea_map_range(df_kva,   df_kva   + PGT_CEA_DF_BYTES)
    m_verw: uint64 = _cea_map_range(verw_kva, verw_kva + PGT_CEA_VERW_BYTES)
    if (m_idt == 0) | (m_gdt == 0) | (m_tss == 0) | (m_df == 0) \
            | (m_verw == 0):
        printk0("[pgtable] cpu_entry_area: WARN OOM mapping an entry"
                " structure (incomplete CEA)\n")

    # Flush the TLB so the new window is live immediately.
    load_cr3(cr3)
    pgt_cea_ready = 1
    printk2("[pgtable] cpu_entry_area: PML4[%d] base=%p\n",
            PGT_CEA_PML4_IDX, PGT_CEA_BASE)
    printk2("[pgtable] cpu_entry_area: entry .text %d pages aliased (text_start=%p)\n",
            text_pages, text_start)


def _cea_alias_matches(kva: uint64) -> uint64:
    # Read a qword through both the original kernel VA and its CEA alias and
    # return 1 iff they agree (proving the alias reaches the SAME RAM) AND
    # the alias resolves to a present leaf. Read-only, non-destructive.
    cea: uint64 = pgtable_cea_va(kva)
    if pgtable_walk(cea) == 0:
        return 0
    a: uint64 = cast[Ptr[uint64]](kva)[0]
    b: uint64 = cast[Ptr[uint64]](cea)[0]
    if a == b:
        return 1
    return 0


def pgtable_cpu_entry_area_selftest() -> uint64:
    # Prove the cpu_entry_area resolves the entry structures: each of the
    # IDT, GDT, TSS, #DF stack, VERW word and the entry .text base must walk
    # to a PRESENT leaf through the CEA VA, and reading the alias must return
    # the SAME bytes as the original kernel VA. Read-only (no CR3 switch) so
    # it is triple-fault-proof and runs on every boot. Returns 1 PASS / 0.
    if pgt_cea_ready == 0:
        printk0("[pgtable] cpu_entry_area selftest SKIP: not built\n")
        return 0
    idt_ok:  uint64 = _cea_alias_matches(cea_idt_addr())
    gdt_ok:  uint64 = _cea_alias_matches(cea_gdt_addr())
    tss_ok:  uint64 = _cea_alias_matches(cea_tss_addr())
    df_ok:   uint64 = _cea_alias_matches(cea_df_stack_addr())
    verw_ok: uint64 = _cea_alias_matches(cea_verw_addr())
    text_ok: uint64 = _cea_alias_matches(cea_entry_text_start())
    printk2("[pgtable] cpu_entry_area walk: IDT=%d GDT=%d\n", idt_ok, gdt_ok)
    printk2("[pgtable] cpu_entry_area walk: TSS=%d DF-stack=%d\n", tss_ok, df_ok)
    printk2("[pgtable] cpu_entry_area walk: VERW=%d entry.text=%d\n",
            verw_ok, text_ok)
    all_ok: uint64 = idt_ok & gdt_ok & tss_ok & df_ok & verw_ok & text_ok
    if all_ok == 1:
        printk0("[pgtable] cpu_entry_area PASS: IDT/GDT/TSS/DF/VERW/entry.text"
                " resolve through the entry window (same RAM)\n")
    else:
        printk0("[pgtable] cpu_entry_area FAIL: an entry structure did not"
                " resolve through the CEA window\n")
    return all_ok

# Multiboot1 constants (mirror arch/x86/kernel/e820.ad — kept inline
# rather than imported to avoid coupling to e820.ad's private surface).
PGT_MB_MAGIC:        uint64 = 0x2BADB002
PGT_MB_MMAP_BIT:     uint64 = 0x40            # flags bit 6
PGT_MMAP_TYPE_RAM:   uint64 = 1

# Address-mask constants for page-table walks. CR3 / PDPT-entry layout:
#   bits  0..11  flags (P/RW/US/PWT/PCD/A/PS/...)
#   bits 12..51  physical address (40-bit phys on most CPUs; we treat
#                it as the lower 52 bits and mask off everything below
#                bit 12). The mask 0x000FFFFFFFFFF000 isolates the
#                physical-frame-number field independent of which
#                flag bits the boot stub set (0x7 multiboot path vs.
#                0x3 EFI path).
PGT_ADDR_MASK:       uint64 = 0x000FFFFFFFFFF000

# PDPT-entry flags for a 1 GiB page:
#   bit 0 P   = present
#   bit 1 RW  = writable
#   bit 2 US  = user-accessible
#   bit 7 PS  = 1 GiB page (terminal entry at PDPT level)
#
# We set US=1 to match what arch/x86/boot/header.S stamps on the first
# 4 GiB (0x87 = PS|US|RW|P). The intuition "kernel pages should be
# kernel-only" doesn't hold for the Hamnix identity map today: user
# tasks created by SYS_SPAWN clone the BSP's PML4 and share the same
# PDPT; ET_DYN user binaries (the common case for /init, hamsh,
# coreutils) run from identity-mapped physical RAM rather than from a
# private overlay (elf_apply_last_user_mapping is a no-op for ET_DYN,
# per fs/elf.ad). If alloc_page hands a user task a page above 4 GiB,
# the task's instruction fetch lands in our new PDPT entries; without
# US=1 they #PF with err=0x05 the moment CPL=3 touches them. Matching
# the boot-stub flag set is the minimum invasive change. NX-bit
# enforcement / per-task user-private overlays are tracked separately
# under the W^X hardening line item.
PGT_FLAG_P:    uint64 = 0x1
PGT_FLAG_PS:   uint64 = 0x80
PGT_NEW_FLAGS: uint64 = 0x87        # PS | US | RW | P (matches boot stub)

# 1 GiB in bytes, and the corresponding shift for PDPT-entry index.
PGT_1GB:       uint64 = 0x40000000
PGT_1GB_SHIFT: uint64 = 30

# PDPT has 512 entries → 512 GiB maximum coverage with 1 GiB pages.
PGT_PDPT_ENTRIES: uint64 = 512

# Multiboot1 mmap entry-type codes (mirrors arch/x86/kernel/e820.ad's
# MMAP_TYPE_* constants). Kept inline so the per-entry diagnostic log
# line in pgtable_extend_from_e820 doesn't have to import e820's
# private surface.
PGT_MMAP_TYPE_RESERVED:     uint64 = 2
PGT_MMAP_TYPE_ACPI_RECLAIM: uint64 = 3
PGT_MMAP_TYPE_NVS:          uint64 = 4
PGT_MMAP_TYPE_BAD:          uint64 = 5


def _pgtable_type_name(t: uint64) -> Ptr[char]:
    # Short 4-char identifier for the per-entry log line. Matches the
    # _type_name() helper in arch/x86/kernel/e820.ad so a side-by-side
    # diff of the two log streams is readable in a real-hardware boot
    # capture.
    if t == PGT_MMAP_TYPE_RAM:
        return "RAM "
    if t == PGT_MMAP_TYPE_RESERVED:
        return "RSVD"
    if t == PGT_MMAP_TYPE_ACPI_RECLAIM:
        return "ACPI"
    if t == PGT_MMAP_TYPE_NVS:
        return "NVS "
    if t == PGT_MMAP_TYPE_BAD:
        return "BAD "
    return "????"


def _pgtable_pdpt_base() -> uint64:
    # Locate the live PDPT by reading CR3 -> PML4 -> PML4[0] -> PDPT
    # phys. Works for both boot paths (multiboot1 .pgtables and EFI
    # stub .bss arrangements) because they share the PML4[0] -> PDPT
    # convention. Assumes we are still identity-mapped, which is
    # exactly the regime we run in throughout early boot.
    cr3:  uint64 = get_bsp_cr3()
    pml4: uint64 = cr3 & PGT_ADDR_MASK
    pml4e0: uint64 = cast[Ptr[uint64]](pml4)[0]
    return pml4e0 & PGT_ADDR_MASK


def _pgtable_stamp_1gb(pdpt_base: uint64, idx: uint64) -> int32:
    # Stamp PDPT[idx] with a 1 GiB page mapping at phys = idx * 1 GiB.
    # Returns 1 if a new entry was written, 0 if the slot was already
    # present (so callers can count newly-covered GiB for the log).
    if idx >= PGT_PDPT_ENTRIES:
        return 0
    slot: Ptr[uint64] = cast[Ptr[uint64]](pdpt_base + idx * 8)
    existing: uint64 = slot[0]
    if (existing & PGT_FLAG_P) != 0:
        return 0
    phys: uint64 = idx << PGT_1GB_SHIFT
    slot[0] = phys | PGT_NEW_FLAGS
    return 1


def _pgtable_force_stamp_1gb(pdpt_base: uint64, idx: uint64) -> int32:
    # Belt-and-suspenders variant: UNCONDITIONALLY rewrite PDPT[idx]
    # with the canonical (idx << 30) | 0x87 value, regardless of any
    # existing flags. Used on the EFI early-return path (M16.154) to
    # immunise the live identity map against any boot-stub stamping
    # mismatch between the M16.152 efi_stub.S 512-entry loop and what
    # CR3 → PML4 → PML4[0] → PDPT actually points at on real silicon.
    #
    # H1 from M16.153's bisect was that the kernel might be looking at
    # a different physical PDPT page than the one the boot stub
    # stamped (e.g. if start_kernel later allocates a fresh PML4 with
    # a fresh PDPT). Code inspection refutes this for the EFI path:
    # _kthread_create_user (kernel/sched/core.ad) clones the BSP PML4
    # by memcpy of PML4[0], so per-task PML4[0] points at the SAME
    # efi_pdpt the boot stub stamped. BUT: a force-stamp through the
    # live CR3 walk is cheap (512 8-byte stores at boot, well under a
    # microsecond) and removes "what if some firmware-side address-
    # translation quirk makes the stub-time efi_pdpt phys differ from
    # the CR3-walk-time PDPT phys" from the suspect list entirely.
    # If the next Asus real-hw capture STILL triple-faults on the
    # iretq, the failure is provably NOT in the PDPT contents and we
    # can narrow the bisect to GDT / TSS / MSR / CR4 state.
    #
    # Returns 1 always (the slot was written), so the caller's "new
    # entries" accumulator stays a useful "we did do work" indicator.
    if idx >= PGT_PDPT_ENTRIES:
        return 0
    slot: Ptr[uint64] = cast[Ptr[uint64]](pdpt_base + idx * 8)
    phys: uint64 = idx << PGT_1GB_SHIFT
    slot[0] = phys | PGT_NEW_FLAGS
    return 1


def pgtable_extend_from_e820():
    # Re-walk the multiboot1 memory map and stamp PDPT entries for
    # every 1 GiB page that overlaps an E820_RAM region. Called from
    # mem_init() between e820_init() and page_alloc_init() so the
    # page allocator sees a fully-mapped identity window for every
    # RAM byte the firmware reported.
    #
    # If the boot path didn't supply a multiboot1 info struct (the
    # UEFI direct-boot path), there's nothing to extend FROM the
    # multiboot mmap — but the EFI stub already stamped the FULL
    # 512-entry PDPT (M16.152), so every byte e820.ad's EFI walker
    # might hand to memblock is already identity-mapped. Return early
    # and emit a log line so the absence is visible.
    #
    # ALSO dump the live PDPT base + current 1 GiB coverage on this
    # branch so a UEFI real-hardware capture shows the same shape of
    # diagnostic as the multiboot1 path. Without this, a UEFI hang
    # diagnosed via serial console can't be told apart from "we
    # silently skipped extension" vs. "extension ran and produced
    # bogus entries".
    magic: uint64 = get_mb_magic()
    if magic != PGT_MB_MAGIC:
        # M16.154: Asus iretq-triple-fault diagnostic + hardening.
        #
        # Code inspection (this commit's message body) confirmed that
        # the EFI boot stub's efi_pdpt page IS the live PDPT the kernel
        # CR3 → PML4 → PML4[0] walk lands on: arch/x86/boot/efi_stub.S
        # plants efi_pml4 in CR3 at STEP 10, efi_pml4[0] points at
        # efi_pdpt, and kernel/sched/core.ad's _kthread_create_user
        # memcpy's PML4[0] verbatim into per-task PML4s — so the
        # boot-stub-stamped efi_pdpt[0..511] entries are visible to
        # every task. The M16.151 H1 hypothesis ("kernel allocates a
        # NEW PDPT after start_kernel") is REFUTED by code inspection.
        #
        # HOWEVER: the Asus laptop still triple-faults on the iretq into
        # /init's _start (M16.153 bisect localised it to this gate).
        # That means one of:
        #   - Boot-stub stamping ran but landed in a different physical
        #     page than what CR3 currently points at (e.g. firmware
        #     remapped the EFI image post-stamp — vanishingly unlikely
        #     but provable here),
        #   - Some entry the stub stamped got corrupted between then
        #     and now (a stray kernel write through a bogus pointer
        #     into the PDPT page),
        #   - The fault is NOT in the PDPT at all and the next-leaf
        #     diagnostic in start_first_task will narrow it elsewhere.
        #
        # Defensive action: walk the LIVE CR3 → PML4 → PML4[0] → PDPT,
        # then RE-STAMP every slot [0..512) with the canonical
        # (i << 30) | 0x87. If the stub-time PDPT is already correct
        # this is a no-op (same bytes back). If the stub-time PDPT was
        # somehow wrong, the live PDPT is now provably right going
        # forward. Either way the post-condition dump immediately
        # after shows what the CPU will actually use.
        printk0("[pgtable] no multiboot1 mmap; EFI path — diagnose + re-stamp PDPT\n")
        cr3_efi: uint64 = get_bsp_cr3()
        pml4_efi: uint64 = cr3_efi & PGT_ADDR_MASK
        pml4e0_efi: uint64 = cast[Ptr[uint64]](pml4_efi)[0]
        pdpt_base_efi: uint64 = pml4e0_efi & PGT_ADDR_MASK
        # Surface the FULL live-walk chain so a real-hw capture can
        # be diffed against the QEMU gold capture: identical chain
        # means M16.154's H1-falsification (PDPT page is shared) is
        # confirmed in vivo, divergent chain means the firmware did
        # something exotic and we now know exactly what to chase.
        printk2("[pgtable-live] CR3=%p PML4=%p\n", cr3_efi, pml4_efi)
        printk2("[pgtable-live] PML4[0]=%p PDPT phys=%p\n",
                pml4e0_efi, pdpt_base_efi)
        # Pre-stamp dump: 16 slots so a 5 GiB Asus log shows slots
        # 0..7 (boot-stub 4 GiB region + first M16.152-stamped
        # over-4-GiB slot) AND slots 8..15 (high RAM coverage that
        # QEMU's small -m sizes don't normally exercise). Lets us
        # spot non-zero slots above slot 5 on real hardware.
        i_pre: uint64 = 0
        while i_pre < 16:
            slot_addr_pre: uint64 = pdpt_base_efi + i_pre * 8
            entry_pre: uint64 = cast[Ptr[uint64]](slot_addr_pre)[0]
            printk2("[pgtable-live] pre  pdpt[%d]=%p\n", i_pre, entry_pre)
            i_pre = i_pre + 1
        # Force-stamp all 512 entries. Idempotent on a correctly-
        # stamped PDPT (writes the same bytes back); corrective on
        # any corrupted slot. Cost: 512 × 8 B = 4 KiB store-stream,
        # well under a microsecond on any x86_64 CPU we target.
        # We use _pgtable_force_stamp_1gb (not _pgtable_stamp_1gb)
        # because the latter early-returns on P=1 — exactly the
        # slots we'd be most suspicious of on a corruption-induced
        # bug. Force-stamping all 512 also covers any 240..256 MiB
        # ACPI-reclaim region that firmware might want us NOT to
        # touch as 1 GiB-page RAM; we accept that overshoot — the
        # boot stub already overshoots PDPT[0..3] the same way and
        # the kernel only touches memory via memblock-reported
        # ranges (2..240 MiB on EFI today), so 240 MiB..512 GiB of
        # PDPT entries are pure address-space placeholders, not RAM.
        i_stamp: uint64 = 0
        forced_count: uint64 = 0
        while i_stamp < PGT_PDPT_ENTRIES:
            forced_count = forced_count + cast[uint64](
                _pgtable_force_stamp_1gb(pdpt_base_efi, i_stamp))
            i_stamp = i_stamp + 1
        # Reload CR3 to flush the TLB; absent entries weren't cached
        # but our force-stamp may have rewritten present entries
        # (which WERE cached) — TLB flush guarantees the next ifetch
        # sees the new values.
        load_cr3(cr3_efi)
        printk1("[pgtable-live] force-stamped %d PDPT entries\n",
                forced_count)
        # Post-stamp dump: same 16 slots so a side-by-side
        # pre/post diff is a one-look operation in the serial log.
        # If pre and post differ for any slot, the corruption /
        # mismatch hypothesis was right and this commit fixed it.
        i_post: uint64 = 0
        while i_post < 16:
            slot_addr_post: uint64 = pdpt_base_efi + i_post * 8
            entry_post: uint64 = cast[Ptr[uint64]](slot_addr_post)[0]
            printk2("[pgtable-live] post pdpt[%d]=%p\n",
                    i_post, entry_post)
            i_post = i_post + 1
        return

    info: uint64 = get_mb_info()
    if info == 0:
        printk0("[pgtable] mb_info null; identity map unchanged\n")
        return

    flags: uint64 = cast[uint64](cast[Ptr[uint32]](info)[0])
    if (flags & PGT_MB_MMAP_BIT) == 0:
        printk0("[pgtable] mmap bit clear; identity map unchanged\n")
        return

    mmap_length: uint64 = cast[uint64](cast[Ptr[uint32]](info + 44)[0])
    mmap_addr:   uint64 = cast[uint64](cast[Ptr[uint32]](info + 48)[0])

    pdpt_base: uint64 = _pgtable_pdpt_base()
    printk2("[pgtable] pdpt_base=%p mmap=%p\n", pdpt_base, mmap_addr)

    # Track total reported RAM (for the post-condition log line) and
    # newly-stamped 1 GiB pages (so we can confirm we did real work
    # when memory > 4 GiB is present).
    total_ram_bytes: uint64 = 0
    new_entries:     uint64 = 0
    entry_idx:       uint64 = 0

    pos: uint64 = mmap_addr
    end: uint64 = mmap_addr + mmap_length
    while pos < end:
        entry_size: uint64 = cast[uint64](cast[Ptr[uint32]](pos)[0])
        base:       uint64 = cast[Ptr[uint64]](pos + 4)[0]
        length:     uint64 = cast[Ptr[uint64]](pos + 12)[0]
        type_code:  uint64 = cast[uint64](cast[Ptr[uint32]](pos + 20)[0])

        # Per-entry diagnostic: dump every walked e820 record with its
        # type tag and chosen action (map / skip). On real hardware the
        # serial log shows exactly which firmware-reported regions we
        # consumed vs. ignored. Reading this back tells us at a glance
        # whether (a) the firmware advertised any RAM above 4 GiB at
        # all, (b) we mapped the regions we should have, and (c) we
        # left Reserved/MMIO/ACPI alone (NOT pulling those into the
        # 1 GiB-page identity window — they'd mask real RAM otherwise).
        printk2("[pgtable] e820[%d] base=%p ", entry_idx, base)
        printk2("len=%p type=%d ", length, type_code)
        if type_code == PGT_MMAP_TYPE_RAM:
            printk1("(%s) action=map\n", cast[uint64](_pgtable_type_name(type_code)))
        else:
            printk1("(%s) action=skip\n", cast[uint64](_pgtable_type_name(type_code)))

        if type_code == PGT_MMAP_TYPE_RAM:
            total_ram_bytes = total_ram_bytes + length

            # Round base DOWN and (base+length) UP to 1 GiB boundary.
            # This guarantees we cover every byte in the region without
            # having to worry about per-byte granularity within the
            # 1 GiB page (we deliberately overshoot — see file header).
            region_start: uint64 = base & ~(PGT_1GB - 1)
            region_end:   uint64 = (base + length + PGT_1GB - 1) & ~(PGT_1GB - 1)

            # Iterate by 1 GiB page index. Skip indices 0..3 implicitly
            # via the "already present" check inside _pgtable_stamp_1gb
            # (the boot stub pre-stamped those four). Indices >= 512
            # are clamped inside the helper too.
            cur: uint64 = region_start
            while cur < region_end:
                idx: uint64 = cur >> PGT_1GB_SHIFT
                new_entries = new_entries + cast[uint64](_pgtable_stamp_1gb(pdpt_base, idx))
                cur = cur + PGT_1GB

        pos = pos + entry_size + 4
        entry_idx = entry_idx + 1

    # If we actually added new entries, flush the TLB. x86 page-walkers
    # don't cache absent entries, so this is defensive — costs < 1 μs
    # and shuts the door on any speculative-prefetch edge case.
    if new_entries > 0:
        load_cr3(get_bsp_cr3())

    # Round total RAM to GiB for the log line. Use ceil division so a
    # ~4.78 GiB Asus laptop logs "5 GiB" — matches what the user sees
    # printed on a marketing sticker / dmesg one-liner.
    total_gb: uint64 = (total_ram_bytes + PGT_1GB - 1) >> PGT_1GB_SHIFT
    printk2("[pgtable] extended identity map: %d GiB total RAM via e820 (+%d new 1GiB entries)\n",
            total_gb, new_entries)


# --- pgtable_walk / pgtable_assert_mapped --------------------------
#
# Diagnostic page-table walker. Given a virtual address, walks the
# active page tables (CR3 -> PML4 -> PDPT -> [PD -> PT]) and returns
# either the leaf entry (with its flags in the low 12 bits) or 0 if
# any level along the way is not-present.
#
# Why we need this:
#   The first kmalloc inside p9_smoke_test()'s pipe_alloc has been
#   the silent-hang point on Asus UEFI real hardware. The symptom is
#   "kernel writes [p9smoke] start, never writes [p9smoke] pipes
#   tx=N rx=N". If pipe_alloc's kmalloc returns a physical address
#   whose backing 1 GiB / 2 MiB page isn't actually present in the
#   live page tables, the very next instruction that touches the
#   returned pointer faults #PF (vector 0x0e), and because we have
#   no productive kernel-mode #PF handler the box triple-faults
#   into the firmware reset path — silent hang from the serial
#   console's perspective.
#
#   pgtable_walk() is the post-mortem: call it on the suspect
#   address BEFORE the first store/load, log the result, and the
#   serial capture tells us whether the mapping exists. A non-zero
#   return with the P bit set means "mapped" — anything else is the
#   smoking gun.
#
# Return-value encoding:
#   0                          - not mapped at any level (P=0 found)
#   non-zero & PGT_FLAG_P == 0 - shouldn't happen (defensive: any
#                                non-zero return guarantees P=1
#                                because we only return on P=1)
#   non-zero & PGT_FLAG_PS != 0 - leaf was a huge page (1 GiB at
#                                 PDPT level or 2 MiB at PD level);
#                                 the high bits hold the page's
#                                 physical base, the low 12 bits
#                                 hold the leaf flags.
#   non-zero & PGT_FLAG_PS == 0 - leaf was a 4 KiB PTE; ordinary
#                                 page-table walk result.
#
# We deliberately use the SAME PGT_ADDR_MASK we use everywhere else
# in this file so behavioural drift between extension-time and
# walk-time is impossible. Intel SDM Vol 3A §4.5 confirms bits
# 12..M-1 (M typically 52) hold the physical frame for every level.
PGT_FLAG_PS_BIT: uint64 = 0x80         # bit 7 — PS for huge pages

def pgtable_walk(va: uint64) -> uint64:
    # 4-level page walk. PML4 -> PDPT -> PD -> PT, with early-out on
    # huge-page PS bits at PDPT (1 GiB) or PD (2 MiB) level.
    pml4_idx: uint64 = (va >> 39) & 0x1FF
    pdpt_idx: uint64 = (va >> 30) & 0x1FF
    pd_idx:   uint64 = (va >> 21) & 0x1FF
    pt_idx:   uint64 = (va >> 12) & 0x1FF

    cr3:   uint64 = get_bsp_cr3()
    pml4:  uint64 = cr3 & PGT_ADDR_MASK
    pml4e: uint64 = cast[Ptr[uint64]](pml4 + pml4_idx * 8)[0]
    if (pml4e & PGT_FLAG_P) == 0:
        return 0

    pdpt:  uint64 = pml4e & PGT_ADDR_MASK
    pdpte: uint64 = cast[Ptr[uint64]](pdpt + pdpt_idx * 8)[0]
    if (pdpte & PGT_FLAG_P) == 0:
        return 0
    if (pdpte & PGT_FLAG_PS_BIT) != 0:
        # 1 GiB huge page — pdpte IS the leaf.
        return pdpte

    pd:   uint64 = pdpte & PGT_ADDR_MASK
    pde:  uint64 = cast[Ptr[uint64]](pd + pd_idx * 8)[0]
    if (pde & PGT_FLAG_P) == 0:
        return 0
    if (pde & PGT_FLAG_PS_BIT) != 0:
        # 2 MiB huge page — pde IS the leaf.
        return pde

    pt:  uint64 = pde & PGT_ADDR_MASK
    pte: uint64 = cast[Ptr[uint64]](pt + pt_idx * 8)[0]
    if (pte & PGT_FLAG_P) == 0:
        return 0
    return pte


def pgtable_dump_mapping(label: Ptr[char], va: uint64):
    # Diagnostic: print whether `va` is mapped, and if so what the
    # leaf entry looks like. Designed to be called from any point in
    # boot AFTER mem_init() (page tables must be live). Safe to call
    # with any 64-bit address; pgtable_walk is read-only.
    #
    # Output shape (one line, fits in a printk2 column):
    #   [pgtable] <label> va=<va> -> UNMAPPED
    #   [pgtable] <label> va=<va> -> leaf=<entry> (1G | 2M | 4K)
    #
    # On the Asus real-hardware UEFI hang case the expected gold
    # output is "1G | flags=0x87" for any address inside the
    # boot-stub's 4 GiB identity window, and "UNMAPPED" for anything
    # above 4 GiB until pgtable_extend_from_e820 has run an EFI
    # memmap parse. UNMAPPED above 4 GiB IS the smoking gun if a
    # subsequent kmalloc returned that address.
    leaf: uint64 = pgtable_walk(va)
    if leaf == 0:
        printk2("[pgtable] %s va=%p -> UNMAPPED\n",
                cast[uint64](label), va)
        return
    # Bit 7 set = huge page. At PDPT level that's a 1 GiB page; at PD
    # level a 2 MiB page. We can't tell which level from `leaf`
    # alone, so we synthesise the answer by re-walking and checking
    # whether the PDPT entry already carried PS=1 — but for the
    # diagnostic line a single hint string is enough.
    if (leaf & PGT_FLAG_PS_BIT) != 0:
        printk2("[pgtable] %s va=%p -> leaf=", cast[uint64](label), va)
        printk1("%p (huge page, PS=1)\n", leaf)
    else:
        printk2("[pgtable] %s va=%p -> leaf=", cast[uint64](label), va)
        printk1("%p (4 KiB page)\n", leaf)


def pgtable_assert_mapped(va: uint64) -> uint64:
    # Public single-call API: returns the leaf entry (with flags) or
    # 0 if not mapped. Callers that just want a bool/yes/no use
    # `pgtable_assert_mapped(va) != 0`. Callers that want flags can
    # consume the return value directly — bits 0..11 are the leaf
    # PDPT/PD/PT entry's flag word per Intel SDM Vol 3A §4.5.4 Table
    # 4-15 (1 GiB page) / Table 4-17 (2 MiB page) / Table 4-19
    # (4 KiB page). 0 means "not mapped" (P=0 on at least one level).
    return pgtable_walk(va)


# --- MMIO cache-attribute control ------------------------------------
#
# Background: PCI BAR regions must be mapped uncached (UC) on x86. A
# cached read of an MMIO BAR causes the CPU to issue a cache-line fill
# transaction to the host bridge; the bridge has no DRAM to fill from,
# and on real silicon (observed on Intel Sunrise Point-H, NUC6i7KYK
# Skull Canyon, 2026-05-24) the load instruction NEVER RETIRES —
# the box hangs in a way no software timeout can recover from. QEMU's
# emulated host bridge transparently fields MMIO regardless of cache
# attribute, which is why this works in CI but freezes on metal.
#
# Hamnix's boot stub stamps the first 4 GiB as 1 GiB huge pages with
# flags 0x87 (PS|US|RW|P) — default cache attribute = WB (writeback).
# PCI BARs on x86 typically live in the 3..4 GiB window (PCI_HOLE)
# which our PDPT[3] entry covers as WB. We need that whole 1 GiB
# remapped as UC.
#
# Mechanism: set PCD|PWT bits on the 1 GiB PDPT entry. With the
# default PAT layout (PAT3 = UC at PCD=1, PWT=1, Intel SDM Vol 3A
# §11.12.4), this routes accesses to PAT3 = UC. Reload CR3 to flush
# TLB entries that cached the old WB attributes.
#
# Safety: the 1 GiB chunk containing the BAR is overwhelmingly MMIO
# on every modern x86 platform — host bridge / PCIe root complex
# expose ~all of the 3..4 GiB region as PCI memory space. If a box
# happens to have RAM there, making it UC will tank performance for
# that RAM, but won't corrupt anything. The architecturally clean
# version splits the 1 GiB huge page into 2 MiB / 4 KiB pages and
# marks only the BAR pages UC; that's tracked as a future hardening
# task. The 1 GiB-granularity version here is the minimum-invasive
# fix that unblocks real-hardware NIC bring-up.

PGT_FLAG_PWT: uint64 = 0x08          # bit 3 — page-level write-through
PGT_FLAG_PCD: uint64 = 0x10          # bit 4 — page-level cache disable


def pgtable_mark_phys_uc(phys: uint64) -> int32:
    # Find the 1 GiB PDPT entry covering `phys`, set PCD|PWT so the
    # mapping is UC (uncached), then reload CR3 to flush TLB entries
    # that cached the old WB attributes. Returns 1 on success, 0 if
    # `phys` is above the 512 GiB PDPT ceiling or the slot was empty
    # (the latter shouldn't happen for a valid BAR — the boot stub +
    # pgtable_extend_from_e820 between them stamp every 1 GiB chunk
    # the firmware tells us about).
    idx: uint64 = phys >> PGT_1GB_SHIFT
    if idx >= PGT_PDPT_ENTRIES:
        printk2("[pgtable] mark_uc: idx=%d out of range (phys=%p)\n",
                idx, phys)
        return 0
    pdpt_base: uint64 = _pgtable_pdpt_base()
    slot: Ptr[uint64] = cast[Ptr[uint64]](pdpt_base + idx * 8)
    entry: uint64 = slot[0]
    printk2("[pgtable] mark_uc: PDPT[%d] before=%p\n", idx, entry)
    if (entry & PGT_FLAG_P) == 0:
        # Empty slot — would need to allocate a fresh 1 GiB mapping
        # to attach the UC attribute to. That's out of scope for this
        # path; if it ever fires we'll know there's a coverage gap to
        # close in pgtable_extend_from_e820.
        printk2("[pgtable] mark_uc: PDPT[%d] not present (phys=%p)\n",
                idx, phys)
        return 0
    new_entry: uint64 = entry | PGT_FLAG_PCD | PGT_FLAG_PWT
    if new_entry == entry:
        # Already UC — idempotent no-op (no TLB flush needed).
        printk1("[pgtable] mark_uc: PDPT[%d] already UC\n", idx)
        return 1
    slot[0] = new_entry
    # TLB flush. Stale entries with WB cache attribute would let the
    # CPU keep issuing cached MMIO reads until they evict naturally;
    # we want the new UC attribute to take effect on the very next
    # access from the driver. load_cr3 with the current CR3 value
    # is the cheap, broadly-correct hammer.
    load_cr3(get_bsp_cr3())
    printk2("[pgtable] mark_uc: PDPT[%d] -> UC, after=%p\n",
            idx, new_entry)
    return 1


# --- 2 MiB-granularity UC -----------------------------------------
#
# pgtable_mark_phys_uc operates at 1 GiB granularity. That's fine for
# MMIO BAR space (the whole 3..4 GiB hole is MMIO anyway) but not OK
# for descriptor rings that live in low RAM (PDPT[0], the kernel BSS
# region). Making PDPT[0] UC would also UC the kernel .text/.rodata/
# .data — boot would take minutes due to uncached instruction fetch.
#
# Solution: split the 1 GiB PDPT entry into a PD with 512 2 MiB
# huge pages, all initialized WB. Then flip just ONE 2 MiB entry to
# UC — the chunk containing the target physical address. Result:
# everything else in the 1 GiB stays cached; only the 2 MiB chunk
# holding the descriptor ring + its surrounding RAM is UC.
#
# Storage for the PD: BSS Array sized for one PD per 1 GiB chunk we
# might want to split. We only ever split PDPT[0] today; if a future
# caller needs to split a different PDPT entry we'll need to extend
# the storage.

PGT_FLAG_P_RW_US: uint64 = 0x07     # P|RW|US (no PS) — for non-leaf entries
PGT_2M_SHIFT:     uint64 = 21
PGT_2M_BYTES:     uint64 = 0x200000

# 8 KiB BSS reserved for one PD (4 KiB) + 4 KiB padding to align.
# The PD itself must be 4 KiB aligned for CPU page-walk hardware.
pgt_pd_storage_pdpt0: Array[8192, uint8]
pgt_pd_storage_pdpt0_initialized: int32 = 0


def _pgt_pd_phys_for_pdpt0() -> uint64:
    # Return the 4 KiB-aligned physical address inside our 8 KiB BSS
    # storage. .bss is in the kernel image; virt_to_phys turns the
    # high-half VA into the low physical address the CPU page walker
    # will dereference.
    va: uint64 = cast[uint64](&pgt_pd_storage_pdpt0[0])
    phys: uint64 = virt_to_phys(va)
    # Round UP to a 4 KiB boundary.
    return (phys + 4095) & ~cast[uint64](4095)


def pgtable_mark_phys_uc_2m(phys: uint64) -> int32:
    # Mark the 2 MiB page containing `phys` as UC. If the covering
    # PDPT entry is still a 1 GiB huge page, split it into 512 2 MiB
    # huge pages first (default WB), then flip the target one to UC.
    #
    # Currently only PDPT[0] is supported (single static PD storage).
    # Returns 1 on success, 0 on failure.
    pdpt_idx: uint64 = phys >> PGT_1GB_SHIFT
    if pdpt_idx != 0:
        printk1("[pgtable] mark_uc_2m: only PDPT[0] supported (got idx=%d)\n",
                pdpt_idx)
        return 0
    pdpt_base: uint64 = _pgtable_pdpt_base()
    pdpt_slot: Ptr[uint64] = cast[Ptr[uint64]](pdpt_base + pdpt_idx * 8)
    pdpt_entry: uint64 = pdpt_slot[0]
    if (pdpt_entry & PGT_FLAG_P) == 0:
        printk0("[pgtable] mark_uc_2m: PDPT[0] not present\n")
        return 0

    pd_phys: uint64 = _pgt_pd_phys_for_pdpt0()

    if pgt_pd_storage_pdpt0_initialized == 0:
        # First call — populate the PD with 512 2 MiB WB huge-page
        # entries covering 0..1 GiB linearly.
        i: uint64 = 0
        while i < 512:
            pd_entry: uint64 = (i << PGT_2M_SHIFT) | PGT_NEW_FLAGS
            cast[Ptr[uint64]](pd_phys + i * 8)[0] = pd_entry
            i = i + 1
        # Replace PDPT[0] to point at our PD (PS=0, frame=pd_phys).
        new_pdpt: uint64 = pd_phys | PGT_FLAG_P_RW_US
        pdpt_slot[0] = new_pdpt
        pgt_pd_storage_pdpt0_initialized = 1
        printk2("[pgtable] split PDPT[0] -> 512 x 2 MiB pages (pd_phys=%p new_pdpt=%p)\n",
                pd_phys, new_pdpt)
        # Reload CR3 so the split takes effect.
        load_cr3(get_bsp_cr3())

    # Now mark the specific 2 MiB page UC.
    pd_idx: uint64 = (phys >> PGT_2M_SHIFT) & 0x1FF
    pd_slot: Ptr[uint64] = cast[Ptr[uint64]](pd_phys + pd_idx * 8)
    pd_entry: uint64 = pd_slot[0]
    pd_slot[0] = pd_entry | PGT_FLAG_PCD | PGT_FLAG_PWT
    load_cr3(get_bsp_cr3())
    printk2("[pgtable] mark_uc_2m: PD[%d] -> UC (covers phys=%p)\n",
            pd_idx, phys & ~(PGT_2M_BYTES - 1))
    return 1


# --- PAT / write-combining for the linear framebuffer ----------------
#
# Background: the EFI GOP / VBE linear framebuffer is MMIO device memory.
# The boot stub maps the first 4 GiB as 1 GiB huge pages with the WB
# (write-back) cache attribute (flags 0x87). On a software compositor
# the cost is dominated by STOREs into scanout; with a WB mapping over
# MMIO every full-frame blit thrashes the cache and each store is a slow
# serialized write. Linux maps framebuffers WRITE-COMBINING (ioremap_wc)
# for exactly this reason: WC lets the CPU coalesce consecutive stores
# into burst writes, which is typically a multiple-x speedup for the
# full-frame blits the hamUI compositor and the text console both do.
#
# x86 selects the cache type for a page from the Page Attribute Table
# (IA32_PAT, MSR 0x277), indexed by the PTE bits {PAT, PCD, PWT}. The
# RESET-DEFAULT PAT has NO write-combining entry:
#   PA0 (PAT=0,PCD=0,PWT=0) = WB
#   PA1 (PAT=0,PCD=0,PWT=1) = WT
#   PA2 (PAT=0,PCD=1,PWT=0) = UC-
#   PA3 (PAT=0,PCD=1,PWT=1) = UC
#   PA4..PA7 mirror PA0..PA3 (PAT=1).
# So to get WC we MUST reprogram one PAT slot. We reprogram PA1 (the
# selector {PAT=0,PCD=0,PWT=1}) from its default WT to WC. Choosing PA1
# is deliberate: its selector needs only PWT=1 with PAT=0, so it works
# IDENTICALLY for 4 KiB pages and for 1 GiB / 2 MiB HUGE pages without
# touching the page-level PAT bit (which sits at a different position in
# a huge-page entry, bit 12, vs bit 7 in a 4 KiB PTE). WT is essentially
# unused in Hamnix, so repurposing PA1 costs nothing. PA0=WB, PA2=UC-,
# PA3=UC are all left at their architectural defaults, so every existing
# mapping (WB RAM via PA0, the UC MMIO BAR path above via PA3) is
# UNCHANGED. This mirrors the classic Linux PAT layout that keeps the
# low four entries close to default and only swaps WT->WC.
#
# IMPORTANT: this PAT layout only takes effect for a page once that
# page's PTE selects PA1 (PWT=1, PCD=0). Plain WB RAM (the virtio-gpu
# backing buffer, kernel heap, descriptor rings, user pages) keeps
# PWT=0/PCD=0 -> PA0 = WB and is therefore never affected. Only the
# real MMIO framebuffer range, marked via pgtable_mark_phys_wc below,
# becomes write-combining.

IA32_PAT_MSR: uint32 = 0x277

# PAT memory-type encodings (Intel SDM Vol 3A §11.12.2).
PAT_TYPE_UC: uint64 = 0x00
PAT_TYPE_WC: uint64 = 0x01
PAT_TYPE_WT: uint64 = 0x04
PAT_TYPE_WB: uint64 = 0x06
PAT_TYPE_UC_MINUS: uint64 = 0x07

# Our chosen PAT layout: identical to reset default except PA1 = WC.
#   PA0=WB(06) PA1=WC(01) PA2=UC-(07) PA3=UC(00)
#   PA4=WB(06) PA5=WC(01) PA6=UC-(07) PA7=UC(00)
# Each entry is a byte in the 64-bit MSR; PAn occupies bits [8n .. 8n+2].
PGT_PAT_WC_VALUE: uint64 = 0x0007010600070106

pgt_pat_initialized: int32 = 0


def pgtable_pat_init() -> int32:
    # Program IA32_PAT so selector PA1 ({PWT=1,PCD=0,PAT=0}) = WC.
    # Idempotent: a second call is a no-op. Called once early in boot
    # (before any framebuffer mapping is marked WC). Returns 1 if the
    # PAT was (re)programmed or already in the desired state, 0 only if
    # the platform somehow rejects the read-back (defensive).
    #
    # Per Intel SDM Vol 3A §11.12.4, the recommended sequence to change
    # the PAT without disturbing in-flight cached lines is a full cache
    # flush bracketed around the wrmsr. We run this BEFORE the
    # framebuffer (or anything else) is ever mapped through PA1, and the
    # only entry we change is the unused WT slot, so the lighter weight
    # "wrmsr then CR3 reload" is sufficient here: no existing mapping
    # selects PA1, so no cached line can carry the stale WT attribute
    # into the new WC regime. Marking the framebuffer WC later does its
    # own CR3 reload.
    if pgt_pat_initialized != 0:
        return 1
    old: uint64 = read_msr(IA32_PAT_MSR)
    printk1("[pgtable] PAT before = %p\n", old)
    write_msr(IA32_PAT_MSR, PGT_PAT_WC_VALUE)
    # Reload CR3 to flush the TLB so future walks re-derive the cache
    # type from the new PAT for any page we subsequently mark WC.
    load_cr3(get_bsp_cr3())
    back: uint64 = read_msr(IA32_PAT_MSR)
    printk1("[pgtable] PAT after  = %p (PA1=WC)\n", back)
    pgt_pat_initialized = 1
    if back != PGT_PAT_WC_VALUE:
        # Some emulators ignore PAT writes. Report it but don't claim
        # success — the caller can still proceed; a WC mark just falls
        # back to whatever PA1 actually decodes to (WT default = still
        # cached, so correctness is preserved, only speed is lost).
        printk0("[pgtable] WARNING: PAT write-back mismatch (WC may be inactive)\n")
        return 0
    return 1


def pgtable_mark_phys_wc(phys: uint64) -> int32:
    # Mark the 1 GiB PDPT entry covering `phys` as WRITE-COMBINING by
    # selecting PAT slot PA1 (set PWT=1, ensure PCD=0, ensure the huge-
    # page PAT bit is 0). pgtable_pat_init() must have run first so PA1
    # decodes to WC; we call it defensively here too (idempotent).
    #
    # This is the framebuffer fast-path: the real GOP/VBE linear FB base
    # lives below 4 GiB on every x86 platform we target, so it falls
    # inside one of the boot-stub 1 GiB identity pages. Setting PWT on
    # that 1 GiB entry makes the whole GiB WC. The framebuffer is the
    # overwhelming majority of any GiB it sits in (it is MMIO aperture,
    # not RAM), and WC is strictly faster than WB for write-only scanout
    # AND correct for it, so the 1 GiB granularity overshoot is benign —
    # mirrors how pgtable_mark_phys_uc treats the MMIO BAR hole.
    #
    # Returns 1 on success, 0 if `phys` is above the 512 GiB PDPT ceiling
    # or its slot is empty.
    pgtable_pat_init()
    idx: uint64 = phys >> PGT_1GB_SHIFT
    if idx >= PGT_PDPT_ENTRIES:
        printk2("[pgtable] mark_wc: idx=%d out of range (phys=%p)\n",
                idx, phys)
        return 0
    pdpt_base: uint64 = _pgtable_pdpt_base()
    slot: Ptr[uint64] = cast[Ptr[uint64]](pdpt_base + idx * 8)
    entry: uint64 = slot[0]
    printk2("[pgtable] mark_wc: PDPT[%d] before=%p\n", idx, entry)
    if (entry & PGT_FLAG_P) == 0:
        printk2("[pgtable] mark_wc: PDPT[%d] not present (phys=%p)\n",
                idx, phys)
        return 0
    # WC via PA1 = {PAT=0, PCD=0, PWT=1}. Set PWT, clear PCD. The huge-
    # page PAT bit (bit 12) must stay 0 too; the boot-stub entries never
    # set it, so PGT_NEW_FLAGS-derived entries are already PAT=0.
    new_entry: uint64 = (entry | PGT_FLAG_PWT) & ~PGT_FLAG_PCD
    if new_entry == entry:
        printk1("[pgtable] mark_wc: PDPT[%d] already WC\n", idx)
        return 1
    slot[0] = new_entry
    load_cr3(get_bsp_cr3())
    printk2("[pgtable] mark_wc: PDPT[%d] -> WC, after=%p\n",
            idx, new_entry)
    return 1

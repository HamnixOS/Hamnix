# arch/x86/mm/init.ad
#
# Mirrors arch/x86/mm/init.c. Drives early MM bring-up by calling into
# mm/memblock.ad and (later) the page allocator. For M16.3 the only
# job is `mem_init()`, which initializes the bump allocator with the
# fixed RAM region defined in mm/memblock.ad.
#
# Future M16.x work expands this with:
#   - parsing the multiboot info struct (saved at mb_info by header.S)
#     to discover real e820-equivalent memory ranges
#   - reserving the kernel image range so memblock_alloc never returns
#     a chunk that overlaps .text/.rodata/.data/.bss/.pgtables
#   - bringing up the page allocator on top of memblock
#
# For M16.3 we trust the static MEMBLOCK_BASE > end-of-kernel-image,
# which holds for our image (~ 0x108000 < 0x200000).

from mm.memblock import memblock_init, memblock_region_top
from mm.page_alloc import page_alloc_init
from mm.slab import slab_init
from mm.cow import cow_init
from arch.x86.kernel.e820 import e820_init
from arch.x86.mm.pgtable import pgtable_extend_from_e820
from kernel.printk.printk import printk0, printk1, printk2


HIMEM_4G:        uint64 = 0x100000000
HIMEM_PAGE:      uint64 = 4096
HIMEM_SENTINEL:  uint64 = 0xA5C3F00DDEADBEEF


def _himem_selftest():
    # Boot-time proof that physical RAM ABOVE 4 GiB is reachable. The
    # boot stub now identity-maps the low 512 GiB (header.S: pdpt_low
    # 512× 1 GiB pages), so any frame the firmware reported above the
    # 4 GiB hole is addressable through the low identity map.
    #
    # We take the memblock region top (the high water mark e820_init
    # installed — on a > 4 GiB machine this is the big above-4-GiB
    # region) and, if it extends past 4 GiB, grab the LAST page-aligned
    # frame below the top. That frame's physical address is provably
    # >= 4 GiB; under the identity map its virtual address equals its
    # physical address, so we write a sentinel through it, read it back,
    # and report PASS / FAIL. The top frame is the very last one the
    # bump allocator would ever hand out, so touching it here is
    # harmless.
    top: uint64 = memblock_region_top()
    if top <= HIMEM_4G:
        printk1("[himem] SKIP region top=%p <= 4 GiB (no high RAM to test)\n",
                top)
        return
    frame: uint64 = (top - HIMEM_PAGE) & ~(HIMEM_PAGE - 1)
    if frame < HIMEM_4G:
        printk1("[himem] SKIP frame=%p below 4 GiB after alignment\n", frame)
        return
    p: Ptr[uint64] = cast[Ptr[uint64]](frame)
    p[0] = HIMEM_SENTINEL
    readback: uint64 = p[0]
    if readback == HIMEM_SENTINEL:
        printk2("[himem] PASS phys=%p sentinel=%p\n", frame, readback)
    else:
        printk2("[himem] FAIL phys=%p got=%p\n", frame, readback)


def mem_init():
    # Mirrors the layered bring-up of arch/x86/mm/init.c's setup_arch
    # → mem_init() path: lower allocators come up before higher ones.
    # memblock owns "all RAM" (initially with a known-safe fallback
    # range; e820_init() then widens it from the multiboot memory
    # map); page_alloc takes pages from memblock on demand; slab
    # takes pages from page_alloc.
    memblock_init()
    e820_init()
    # Identity map extension MUST run before any allocator that may
    # hand out pages above 4 GiB. The boot stub installs a fixed
    # 4 GiB identity map (4× 1 GiB PDPT entries); on a host with
    # > 4 GiB RAM (Asus laptop with ~5 GiB, ThinkPad with 16 GiB,
    # server with 64 GiB...) e820 reports memory extending well
    # beyond that. Without this call page_alloc_init's first write
    # into a freshly-carved high page traps #PF (vector 0x0e
    # err=0x02 — kernel write to not-present), which is exactly
    # what real-hardware UEFI boot was hitting at rip≈0x1c6019.
    pgtable_extend_from_e820()
    # Prove a frame above 4 GiB is reachable now that the identity map
    # covers the high region. One-shot diagnostic; emits [himem] PASS
    # on a > 4 GiB machine, [himem] SKIP otherwise.
    _himem_selftest()
    # COW refcount table: one uint16 per physical page frame, carved
    # from memblock BEFORE the buddy allocator starts (so the table is
    # never itself handed out as a COW-able page). Must run after
    # e820_init() so memblock_region_top() reflects real RAM extent.
    cow_init()
    page_alloc_init()
    slab_init()

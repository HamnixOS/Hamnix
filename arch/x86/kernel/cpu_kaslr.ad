# arch/x86/kernel/cpu_kaslr.ad
#
# KASLR v2: per-boot randomization of the kernel module-mapping window.
#
# THE STATE OF KASLR IN HAMNIX (v2)
#
# The kernel image proper (.text/.rodata/.data/.bss) is linked at the
# canonical higher-half base `0xffffffff80000000` (PML4 entry 511) in
# arch/x86/kernel/kernel.lds. That base is BAKED into the linker script
# and into every absolute 64-bit relocation (R_X86_64_64) in the
# elf64 image; the kernel is `-static -no-pie` and carries NO relocation
# table. The boot stub (arch/x86/boot/header.S) builds the high-half
# PML4 hard-coded to that base, and arch/x86/mm/pgtable.ad's
# virt_to_phys subtracts it as a constant.
#
# Moving the STATIC IMAGE base at boot would therefore require either
#   (a) a full Linux-style PIE relocation pass that walks an emitted
#       reloc table and patches every absolute before the high-half
#       jump (head_64.S) — invasive and high-risk in hand assembly for
#       an image with countless absolute address loads, or
#   (b) copying the ~87 MiB running image to a randomized physical base
#       and atomically flipping the page tables + virt_to_phys — equally
#       high-risk (the copy executes from the image being copied).
# Both are deferred; see "WHAT v2 DOES vs DOESN'T RANDOMIZE" below.
#
# WHAT v2 DOES — module-mapping-window randomization
#
# The one kernel-VA window that is CONSTRUCTED AT RUNTIME and handed to
# attacker-influenceable code is the MODULE MAPPING window in
# arch/x86/mm/module_map.ad: it splits the high-half PDPT[510]/[511]
# 1 GiB pages into 2-MiB-granular PDs and hands out 2 MiB slots from a
# free-slot bitmap. Today the first .ko lands at a FULLY PREDICTABLE
# high-half VA (kernel_image_end rounded up to 2 MiB). That is the
# classic KASLR target — Linux randomizes MODULES_VADDR for exactly this
# reason (ROP/JOP against loaded-module .text depends on knowing where
# it is).
#
# v2 picks a per-boot random slide (a 2 MiB-granular count, bounded so
# it stays inside PDPT[510]'s 1 GiB above the kernel image) from
# hardware entropy (RDRAND, RDTSC fallback). module_map.ad reserves that
# many additional leading free slots, so the .ko pool starts at a
# randomized, unpredictable high-half VA every boot. `kaslr_offset` is
# that slide in bytes — a REAL non-zero per-boot value that the page
# tables actually honor.
#
# WHAT v2 DOES vs DOESN'T RANDOMIZE (honest)
#
#   RANDOMIZED  : the high-half VA base of the module-mapping window,
#                 i.e. where loaded-module .text/.rodata/.data lands.
#                 Successive boots place .ko code at different,
#                 2-MiB-granular, hardware-entropy-chosen high-half VAs.
#   NOT RANDOM. : the static kernel image base (.text/.rodata/.data/.bss)
#                 and its physical load address. Core-kernel gadget
#                 addresses are fixed (the -no-pie image can't move
#                 without (a)/(b) above). This is a strict superset of
#                 v1 (which moved NOTHING) and is honestly "module-window
#                 KASLR", not full-image KASLR.
#
# NEXT STEP (KASLR v3): full-image base randomization via emitted
# relocations (Option A) or a one-shot physical image relocation. Pair
# with KPTI for full Meltdown mitigation.

from kernel.printk.printk import printk0, printk1, printk2

# RDRAND/RDTSC hardware entropy (arch/x86/kernel/cpuregs_asm.S).
extern def arch_get_random_u64() -> uint64
# CPUID dispatcher (arch/x86/kernel/cpuregs_asm.S) — gate RDRAND on
# CPUID.01h:ECX bit 30 so we never #UD on pre-IvyBridge silicon.
extern def cpuid_get(leaf: uint32, subleaf: uint32, out: Ptr[uint32])
# Timestamp counter (arch/x86/kernel/syscall_64.S) — entropy fallback on
# the rare CPU that lacks the RDRAND opcode entirely.
extern def read_tsc() -> uint64

# 2 MiB — the module-mapping window's native slot granularity.
KASLR_2M:       uint64 = 0x200000
KASLR_2M_SHIFT: uint64 = 21

# Module-window slide bound, in 2 MiB slots. PDPT[510] has 512 slots
# (1 GiB). The kernel image occupies the low ~16-44 slots; reserving up
# to KASLR_MAX_SLOT_SLIDE leading free slots leaves the rest (hundreds
# of slots = hundreds of MiB) for the .ko pool, which on the heaviest
# wifi boot needs only a few dozen 2 MiB slots. 128 slots = 256 MiB of
# randomization range — the same order as Linux CONFIG_RANDOMIZE_BASE's
# kernel-text window — while guaranteeing the pool never overflows
# PDPT[510] into [511].
KASLR_MAX_SLOT_SLIDE: uint64 = 128

# CPUID.01h:ECX bit 30 = RDRAND support.
KASLR_CPUID_RDRAND_BIT: uint32 = 0x40000000

# Live KASLR state for THIS boot.
#   kaslr_offset            : the module-window slide in BYTES (slide
#                             slots << 21). Real, non-zero, per-boot.
#   kaslr_module_slot_slide : the slide in 2 MiB slots, consumed by
#                             arch/x86/mm/module_map.ad to reserve that
#                             many additional leading free slots.
kaslr_offset:            uint64 = 0
kaslr_module_slot_slide: uint64 = 0


def _kaslr_have_rdrand() -> int32:
    # CPUID.01h:ECX bit 30. Returns 1 if RDRAND is decodable, else 0.
    regs: Array[4, uint32]
    cpuid_get(cast[uint32](1), cast[uint32](0),
              cast[Ptr[uint32]](&regs[0]))
    ecx: uint32 = regs[2]
    if (ecx & KASLR_CPUID_RDRAND_BIT) != cast[uint32](0):
        return 1
    return 0


def setup_kaslr():
    # Pick a per-boot random module-window slide and record it. Runs in
    # start_kernel BEFORE mem_init() and well before any module load, so
    # module_map.ad's _kmod_init sees kaslr_module_slot_slide already
    # set. Entropy: RDRAND when supported, RDTSC fallback (folded into
    # arch_get_random_u64) otherwise — so this never stalls and always
    # yields a varying value.
    raw: uint64 = 0
    if _kaslr_have_rdrand() != 0:
        raw = arch_get_random_u64()
    else:
        # No RDRAND opcode (pre-IvyBridge): executing arch_get_random_u64
        # would #UD, so we must NOT call it. Derive the seed from the
        # timestamp counter instead, read via arch_read_tsc(). The TSC
        # low bits vary boot-to-boot by the non-deterministic time the
        # CPU takes to reach this point — enough entropy for the bounded
        # [0,128) slot range on the rare no-RDRAND target.
        raw = read_tsc()

    # Reduce to a slide in [0, KASLR_MAX_SLOT_SLIDE).
    slide_slots: uint64 = raw % KASLR_MAX_SLOT_SLIDE
    kaslr_module_slot_slide = slide_slots
    kaslr_offset = slide_slots << KASLR_2M_SHIFT

    printk2("[kaslr] offset=%p (module-window slide=%p 2MiB-slots)\n",
            kaslr_offset, slide_slots)


def cpu_kaslr_offset() -> uint64:
    return kaslr_offset


def cpu_kaslr_module_slot_slide() -> uint64:
    # Consumed by arch/x86/mm/module_map.ad::_kmod_init to reserve this
    # many additional leading free 2 MiB slots in PDPT[510], so the .ko
    # pool starts at a randomized high-half VA.
    return kaslr_module_slot_slide

# arch/x86/kernel/cpu_kaslr.ad
#
# KASLR scaffolding (v1: build-time, runtime telemetry only).
#
# THE STATE OF KASLR IN HAMNIX
#
# The kernel is linked at the canonical higher-half base
# `0xffffffff80000000` (PML4 entry 511) in arch/x86/kernel/kernel.lds.
# That base is BAKED into the linker script and into every absolute
# 64-bit relocation in the elf64 image; the boot stub
# (arch/x86/boot/header.S) builds the high-half PML4 hard-coded to it.
# Actually relocating the kernel at boot needs a PIE-style image with a
# small relocation pass — that's the full Linux KASLR design, but it
# touches the linker script, head_64.S, the EFI stub, and the trampoline.
#
# WHAT THIS FILE DOES (v1)
#
# It records a 64-bit per-boot offset in a global so:
#   1. The /proc/kallsyms-shape security-introspection paths have a
#      single place to ADD the offset to a symbol address as a forward
#      step toward real KASLR.
#   2. The boot-log carries a "[kaslr] offset=0x..." line so a tester
#      can see the value advertised even when the kernel hasn't yet
#      moved.
#
# The offset is currently HARD-WIRED TO 0 (no actual movement) because
# v1 doesn't yet relocate. This is intentional v1 scaffold — see the
# NEXT-STEP block below.
#
# NEXT STEP (KASLR v2 — when ready to spend the budget)
#
#   1. Build the kernel as a PIE so addresses are RIP-relative.
#   2. Add an early relocation table walker in head_64.S that, BEFORE
#      paging is enabled, applies the chosen offset to all 64-bit
#      absolute relocations.
#   3. Make the chosen offset come from RDRAND (or PIT/TSC fallback)
#      and lift to 16 MiB granularity over a 256 MiB range — exactly
#      the layout of Linux's CONFIG_RANDOMIZE_BASE.
#   4. Pair with KPTI (separate user/kernel pagetable) for full
#      Meltdown mitigation.
#
# An alternative cheaper-to-land v1.5 is BUILD-TIME KASLR — generate
# a different kernel.lds with a randomized base per .img build,
# rebuild the image, and ship that. That's a CI/build-script change
# rather than a runtime change. Either path is documented; we ship
# v1 (the global + the boot log line) so the security-suite test has
# something to assert on.

from kernel.printk.printk import printk0, printk1, printk2

# Live KASLR offset for THIS boot. v1: always 0.
kaslr_offset: uint64 = 0


def setup_kaslr():
    # v1: announce the offset on the boot log. Even at 0 this gives
    # the security test a stable marker to grep for. When v2 lands
    # this becomes the place that picks a random offset and applies
    # it to the live page tables.
    kaslr_offset = 0
    printk1("[kaslr] offset=%p (v1 scaffold; runtime relocation is v2)\n",
            kaslr_offset)


def cpu_kaslr_offset() -> uint64:
    return kaslr_offset

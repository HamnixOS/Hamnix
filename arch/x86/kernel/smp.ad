# arch/x86/kernel/smp.ad
#
# SMP bring-up: discover ALL present CPU APIC IDs from the ACPI MADT
# and wake each AP via the Intel-spec INIT-SIPI-SIPI sequence through
# the real-mode trampoline (arch/x86/realmode/trampoline.S).
#
# Sequence (mirrors do_boot_cpu in Linux):
#   1. Parse MADT via acpi_cpu_count() / acpi_cpu_apic_id() to build
#      the list of AP hardware APIC IDs. Falls back to APIC ID 1 if
#      no MADT is available (QEMU legacy / bare-metal fallback).
#   2. Copy the trampoline bytes to physical 0x8000 (SIPI vector 8).
#   3. For each AP (up to MAX_CPUS - 1):
#        a. Allocate a kernel stack for the AP.
#        b. Patch trampoline slots: cr3_value, landing_addr, stack_top,
#           and the NEW ap_cpu_id slot so the AP knows which CPU it is.
#        c. Send INIT IPI -> 10ms wait -> SIPI -> 200µs -> SIPI
#           (two SIPIs as the Intel spec requires).
#        d. Poll cpus_online until it advances by 1 (timeout ~100ms).
#   4. Each AP, on entry to ap_main_hamnix:
#        a. Sets up its own per-CPU %gs area via setup_ap_percpu_area.
#        b. Enables its local APIC + timer via lapic_ap_init.
#        c. Bumps cpus_online.
#        d. Parks in the idle loop (scheduler integration is a follow-up).
#
# MAX_CPUS: cap at 16. Matches ACPI_MAX_CPUS in drivers/acpi/acpi.ad.
#
# The BSP's boot path is unchanged: setup_per_cpu_areas() still
# allocates the BSP's per-CPU area, stamps cpu_id_pcpu=0, and runs
# first (before smp_boot_aps). Each AP gets a HIGHER logical id.
#
# Scheduler integration note:
#   APs park in a HLT loop after bumping cpus_online. Wiring them into
#   the per-CPU run queues (or a shared spinlock-protected queue) is
#   the next milestone. The BSP-only scheduling path is UNMODIFIED:
#   the existing runqueue, schedule(), and timer ISR path are untouched.

from mm.page_alloc import alloc_page
from kernel.printk.printk import printk0, printk1, printk2
from arch.x86.kernel.apic import (
    lapic_send_init, lapic_send_sipi,
    lapic_enable_this_cpu,
)
from arch.x86.kernel.idt import idt_load_ap
from arch.x86.kernel.setup_percpu import setup_ap_percpu_area
from drivers.acpi.acpi import (
    acpi_init, acpi_cpu_count, acpi_cpu_apic_id,
)
from kernel.sched.core import sched_ap_launch

extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]
extern def get_bsp_cr3() -> uint64
extern def ap_trampoline_load_addr() -> uint64
extern def ap_trampoline_size() -> uint64
extern def ap_cr3_value_addr() -> uint64
extern def ap_landing_addr_addr() -> uint64
extern def ap_stack_top_addr() -> uint64
extern def ap_cpu_id_slot_addr() -> uint64
extern def ap_main_64()
extern def cpu_relax()

# is_bare_metal() depends on the same CPUID dispatcher kernel/sched/core.ad
# uses for its M16.156 XSAVE check.
extern def cpuid_get(leaf: uint32, subleaf: uint32, out: Ptr[uint32])
# CR4 / XCR0 primitives (arch/x86/kernel/{smp_asm,cpuregs_asm}.S). CR4 and
# XCR0 are PER-CPU: the BSP arms OSXSAVE+XCR0 in start_first_task, but each
# AP must do the same or an AVX (VEX) instruction in a user task scheduled
# onto that AP #UDs (and the #UD halts the kernel).
extern def read_cr4() -> uint64
extern def write_cr4(value: uint64)
extern def xsetbv_xcr0(value: uint64)

# Per-CPU TSS+GDT bring-up (arch/x86/kernel/tss_asm.S). Each AP installs
# its OWN TSS+GDT so a ring3->ring0 transition (IRQ/syscall from a user
# task) on that AP loads RSP0 from its private TSS instead of faulting.
extern def tss64_percpu_init(cpu_id: uint64, rsp0: uint64, ist1: uint64)
extern def get_percpu_df_stack_top(cpu_id: uint64) -> uint64
# Stage A: arm this AP's per-CPU SYSCALL MSRs (STAR/LSTAR/FMASK/EFER.SCE).
extern def syscall_init_this_cpu()

AP_TRAMPOLINE_PHYS: uint64 = 0x8000
AP_SIPI_VECTOR:     uint32 = 0x08             # 0x08 * 0x1000 = 0x8000
# MAX_CPUS — the SINGLE SOURCE OF TRUTH for the logical-CPU hard cap. It is the
# literal dimension of every per-CPU array (cpu_apic_id here, rq_locks/rq_head/
# the per-CPU runqueue tables in kernel/sched/core.ad's NR_RQ, the ACPI lapic
# cache's ACPI_MAX_CPUS, the AP idle-slot map's AP_MAX_CPUS). Adder forbids
# initialising one global from another, so those siblings are SEPARATE literals
# that MUST stay equal to this one — scripts/test_max_cpus_lockstep.sh is the
# drift guard that fails the build if any diverges.
#
# DYNAMIC bring-up (not a fixed 16): smp_boot_aps() reads the ACPI MADT CPU
# count (acpi_cpu_count()) and brings up only min(MADT_count, MAX_CPUS) - 1
# APs. The scheduler's placement / work-steal loops iterate
# `c < get_cpus_online() AND c < NR_RQ`, so per-CPU runqueue work is sized to
# the CPUs ACTUALLY ONLINE, with MAX_CPUS/NR_RQ only as the static array bound.
# Per-CPU CPU state (GDT/TSS/SYSCALL MSRs/%gs area/idle kthread) is allocated
# and armed PER AP as it comes online (tss64_percpu_init / setup_ap_percpu_area
# / sched_prepare_ap_idle), never eagerly for a fixed 16.
MAX_CPUS:           uint64 = 16

# SMP_BOOT_MAX_CPUS — a SEPARATE, temporary bring-up cap (NOT the array
# bound MAX_CPUS). We enumerate every CPU the MADT reports (correct — see
# #105, drivers/acpi/acpi.ad now finds the RSDP via the EFI config table so
# UEFI/real-HW boots see all cores + the real IOAPIC), but we only actually
# START min(enumerated, SMP_BOOT_MAX_CPUS) of them. Reason: #12/#13 — an AP
# beyond core 2 traps at rip=0xffffffff0000001c in the AP task-scheduler
# (futex-sweep lock ordering) and hard-kills the VM/box. Before #105 fixed
# enumeration this was hidden (UEFI boots enumerated 0 → APIC-ID-1 fallback →
# 2 cores by accident); with correct enumeration a 4-core Asus/NUC would now
# bring up all 4 and crash on boot. Capping at 2 preserves the real-HW boot
# (2 cores, alive) + the IOAPIC-routing win while #13 is unsolved. RAISE this
# (ideally to MAX_CPUS) the moment #13/#12 land. -smp 1/2 are unaffected.
SMP_BOOT_MAX_CPUS:  uint64 = 2

# Boot-state counter: number of CPUs that have entered ap_main_hamnix.
# Starts at 1 (the BSP itself); each AP increments atomically. BSP
# polls this after each INIT-SIPI-SIPI pair.
cpus_online: uint64 = 1

# Per-AP "CPU ID" slot in the trampoline, planted by BSP before each
# SIPI round so ap_main_hamnix knows its logical CPU number.
# ap_cpu_id_slot_addr() returns its VMA (like the other plant slots).
ap_cpu_id: uint64 = 0

# Per-CPU runqueue work (#6): logical-CPU-id -> physical-LAPIC-id map.
# Built during boot so the scheduler can send a DIRECTED reschedule IPI
# to exactly the CPU that owns the runqueue a task was just enqueued on
# (smp_send_reschedule_cpu), instead of broadcasting to all-but-self.
#   index = logical CPU id (0 = BSP, 1.. = APs)
#   value = that CPU's hardware LAPIC ID, or 0xFFFFFFFF = "no such CPU"
# Slot 0 (BSP) is filled in smp_record_bsp_apic_id(); AP slots are filled
# in _smp_boot_one_ap right before INIT-SIPI. cpu_online_map tracks which
# logical CPUs actually came online (bit c set <=> cpu c is live), so a
# directed IPI to a never-booted slot is suppressed.
SMP_NO_APIC: uint32 = 0xFFFFFFFF
cpu_apic_id: Array[16, uint32]
cpu_online_map: uint64 = 1               # bit 0 (BSP) always set
_cpu_apic_inited: uint64 = 0


def _smp_init_apic_map():
    # Idempotent: mark every logical slot "absent" once. Called lazily from
    # the record helpers so static-init ordering doesn't matter.
    if _cpu_apic_inited != 0:
        return
    _cpu_apic_inited = 1
    i: uint64 = 0
    while i < MAX_CPUS:
        cpu_apic_id[i] = SMP_NO_APIC
        i = i + 1


def smp_record_bsp_apic_id(apic_id: uint32):
    # Record the BSP's (logical CPU 0) LAPIC id. Called once from the early
    # LAPIC bring-up after the BSP reads its own LAPIC_ID_REG.
    _smp_init_apic_map()
    cpu_apic_id[0] = apic_id
    cpu_online_map = cpu_online_map | 1


def smp_cpu_apic_id(cpu: uint64) -> uint32:
    if cpu >= MAX_CPUS:
        return SMP_NO_APIC
    return cpu_apic_id[cpu]


def smp_cpu_is_online(cpu: uint64) -> uint64:
    if cpu >= MAX_CPUS:
        return 0
    bit: uint64 = cast[uint64](1) << cpu
    if (cpu_online_map & bit) != 0:
        return 1
    return 0


def ap_main_hamnix():
    # Entered by the AP after the trampoline far-jumps to ap_main_64.
    # We are in 64-bit long mode, sharing BSP page tables, on our own
    # kernel stack. The BSP planted ap_cpu_id in the trampoline before
    # sending SIPI; read it now (it's the stack-local variable since
    # the trampoline wrote it to the ap_cpu_id global slot and we only
    # need the value, not the address).
    #
    # Step 1: Capture the logical CPU id the BSP left in the trampoline.
    my_cpu_id: uint64 = cast[Ptr[uint64]](ap_cpu_id_slot_addr())[0]

    # Step 2: Set up this AP's per-CPU %gs area so get_cpu_id() works
    # and Percpu[T] accesses are valid from here on.
    setup_ap_percpu_area(my_cpu_id)

    printk1("SMP: AP cpu%d (APIC) online, gs set up\n", my_cpu_id)

    # Step 2b: Install THIS AP's per-CPU TSS + per-CPU GDT and ltr it.
    # Must run AFTER setup_ap_percpu_area (so %gs/get_cpu_id() is live and
    # tss_set_rsp0/tss_set_ist1 index the right per_cpu_tss slot) and
    # BEFORE this AP can take an IRQ/syscall from a user task. Without a
    # loaded TR an AP has no RSP0 to load on a CPL3->0 transition and would
    # fault; that is exactly why _pick_next used to pin user tasks to the
    # BSP. RSP0 is seeded with a scratch kernel stack (schedule() rewrites
    # it to the dispatched task's kstack_top on every context switch); IST1
    # gets this AP's OWN dedicated #DF stack so two CPUs faulting at once
    # don't corrupt a single shared scratch stack.
    ap_rsp0_seed: uint64 = alloc_page() + 4096
    ap_df_top: uint64 = get_percpu_df_stack_top(my_cpu_id)
    tss64_percpu_init(my_cpu_id, ap_rsp0_seed, ap_df_top)
    printk1("SMP: AP cpu%d TSS+GDT installed (ltr)\n", my_cpu_id)

    # Step 2c: Arm THIS AP's SYSCALL MSRs (STAR/LSTAR/FMASK/EFER.SCE).
    # These are PER-CPU MSRs — syscall_init() arms them on the BSP only.
    # Without this an AP-resident user task's `syscall` instruction is
    # #UD (the SYSCALL opcode is gated on IA32_EFER.SCE per logical CPU).
    # NXE is already set for this AP by the realmode trampoline, so the
    # minimal _this_cpu helper (no NXE, no printks) is exactly right.
    # Must run after %gs is live (LSTAR is a global, but keep it grouped
    # with the rest of the per-CPU CPU-state arming above).
    syscall_init_this_cpu()
    printk1("SMP: AP cpu%d SYSCALL MSRs armed\n", my_cpu_id)

    # Step 2d: Arm THIS AP's CR4.OSXSAVE + XCR0 (SSE+AVX state). CR4 and
    # XCR0 are per-CPU; the BSP set them in start_first_task. Without this,
    # a user task running a VEX-encoded (AVX) instruction — real Debian
    # coreutils (wc/sort), glibc AVX memcpy/decompression — that the
    # scheduler dispatches onto this AP would #UD, and the #UD halts the
    # kernel. AVX (XCR0 bit2) is gated on CPUID.01h:ECX bit28; bit1 (SSE)
    # always enabled when XSAVE (bit26) is present.
    cpuid_ap: Array[4, uint32]
    cpuid_get(cast[uint32](1), cast[uint32](0), &cpuid_ap[0])
    ap_ecx: uint64 = cast[uint64](cpuid_ap[2])
    # Legacy SSE control bits: CR4.OSFXSR (bit 9) enables FXSAVE/FXRSTOR + SSE,
    # CR4.OSXMMEXCPT (bit 10) routes SSE numeric faults to #XF instead of #UD.
    # The realmode trampoline sets these during the AP's 32-bit bring-up, but
    # set them here too (unconditionally, not gated on XSAVE) so the FPU
    # context-switch save/restore (which uses FXSAVE on the non-XSAVE fallback
    # and needs OSFXSR either way) can never #UD on an AP whose early CR4 was
    # perturbed. Cheap and idempotent — a re-OR of already-set bits.
    ap_cr4_base: uint64 = read_cr4()
    ap_cr4_base = ap_cr4_base | (cast[uint64](1) << 9) | (cast[uint64](1) << 10)
    if ((ap_ecx >> 26) & 0x1) != 0:                # XSAVE supported
        ap_cr4_base = ap_cr4_base | (cast[uint64](1) << 18)   # CR4.OSXSAVE
    write_cr4(ap_cr4_base)
    if ((ap_ecx >> 26) & 0x1) != 0:                # XSAVE supported
        ap_xcr0: uint64 = 0x3                       # x87 | SSE
        if ((ap_ecx >> 28) & 0x1) != 0:            # AVX supported
            ap_xcr0 = 0x7                           # x87 | SSE | AVX
        xsetbv_xcr0(ap_xcr0)
        printk1("SMP: AP cpu%d XCR0 armed (SSE+AVX)\n", my_cpu_id)
    else:
        printk1("SMP: AP cpu%d CR4.OSFXSR/OSXMMEXCPT armed (no XSAVE)\n", my_cpu_id)

    # Step 3: Bring up THIS AP's interrupt delivery so it can take the
    # cross-CPU reschedule IPI (vector 0xF2) that wakes it out of HLT.
    # Linux mirror: an idle CPU HLTs with IF=1 and is woken by a directed
    # RESCHEDULE IPI — no global jiffies poll. Two pieces are required and
    # BOTH are safe for the ring0-only idle task (no privilege change → no
    # per-AP TSS.RSP0 needed):
    #
    #   (a) Load the IDT on this AP. The trampoline lgdt's the kernel GDT
    #       but never lidt's an IDT, so without this the AP would #DF/triple
    #       -fault on the first interrupt. idt_table is the global BSP-built
    #       table; its higher-half stubs work from any CPU.
    #   (b) Software-enable this AP's own LAPIC SVR (lapic_enable_this_cpu,
    #       NOT lapic_ensure_enabled — the latter is globally guarded and
    #       would no-op here, leaving this LAPIC dropping every IPI).
    #
    # The old MWAIT-on-jiffies idle hack (which needed neither) is gone: the
    # AP now HLTs and is woken by the IPI. See sched_ap_idle_loop's no-work
    # branch.
    idt_load_ap()
    lapic_enable_this_cpu()

    # Step 4: Bump the online counter. On x86 a single aligned 8-byte
    # store is atomic; the BSP polls this value and only proceeds after
    # it advances, which provides the ordering guarantee we need.
    cpus_online = cpus_online + 1

    # Step 5: Enter the per-CPU scheduler via the pre-allocated idle
    # kthread.  sched_ap_launch() never returns — from this point the AP
    # is a full scheduler participant, running sched_ap_idle_loop() as its
    # idle task and picking up STATE_READY kernel threads as they appear.
    sched_ap_launch(my_cpu_id)


def _smp_wait_ap(expected: uint64, spins_per_iter: uint64) -> int32:
    # Spin until cpus_online >= expected, or we time out.
    # Returns 1 on success, 0 on timeout.
    spins: uint64 = 0
    LIMIT: uint64 = 50000000
    while spins < LIMIT and cpus_online < expected:
        cpu_relax()
        spins = spins + 1
    if cpus_online >= expected:
        return 1
    return 0


def _smp_boot_one_ap(ap_idx: uint64, apic_id: uint32) -> int32:
    # Boot one AP with hardware APIC ID `apic_id`. This is the inner
    # loop body: patch trampoline slots, INIT-SIPI-SIPI, poll.
    # Returns 1 if the AP came online, 0 if it timed out.

    # Patch slot 1: AP's CR3 (shared BSP page tables).
    cast[Ptr[uint64]](ap_cr3_value_addr())[0] = get_bsp_cr3()

    # Patch slot 2: 64-bit landing address.
    cast[Ptr[uint64]](ap_landing_addr_addr())[0] = cast[uint64](&ap_main_64)

    # Patch slot 3: AP kernel stack (4 KiB; top = base + 4096).
    ap_stack: uint64 = alloc_page() + 4096
    cast[Ptr[uint64]](ap_stack_top_addr())[0] = ap_stack

    # Patch slot 4: logical CPU id for this AP.
    logical_id: uint64 = ap_idx + 1          # 0 is the BSP
    cast[Ptr[uint64]](ap_cpu_id_slot_addr())[0] = logical_id

    # Per-CPU rq (#6): record this AP's logical->APIC mapping so the
    # scheduler can later send a DIRECTED reschedule IPI to it. Done before
    # SIPI; the online bit is set only once the AP confirms it came up.
    _smp_init_apic_map()
    if logical_id < MAX_CPUS:
        cpu_apic_id[logical_id] = apic_id

    printk2("SMP: booting AP cpu%d APIC id=%d\n",
            logical_id, cast[uint64](apic_id))

    # INIT IPI.
    lapic_send_init(apic_id)

    # Intel spec says wait 10 ms after INIT before sending SIPIs.
    # We busy-spin on cpu_relax — on QEMU TCG this is equivalent to a
    # short delay. On real hardware the LAPIC's ICR-busy poll in
    # lapic_send_init already serialises; the 10 ms is a minimum.
    # We use ~1 million cpu_relax iterations as a conservative proxy
    # (much faster than 10 ms on TCG, but QEMU's INIT handling is
    # deterministic so the AP will be in WFS state immediately).
    delay: uint64 = 0
    while delay < 1000000:
        cpu_relax()
        delay = delay + 1

    # First SIPI.
    lapic_send_sipi(apic_id, AP_SIPI_VECTOR)

    # Wait ~200 µs between the two SIPIs (spec requirement).
    delay = 0
    while delay < 200000:
        cpu_relax()
        delay = delay + 1

    # Second SIPI (Intel SDM Vol.3 §8.4.4.1).
    lapic_send_sipi(apic_id, AP_SIPI_VECTOR)

    # Poll for the AP to bump cpus_online. We expect it to reach
    # (ap_idx + 2) since we track total CPUs including BSP.
    expected: uint64 = ap_idx + 2
    ok: int32 = _smp_wait_ap(expected, 0)
    if ok != 0:
        # Mark this logical CPU online so smp_send_reschedule_cpu will
        # actually deliver a directed IPI to it.
        if logical_id < MAX_CPUS:
            cpu_online_map = cpu_online_map | (cast[uint64](1) << logical_id)
        printk2("SMP: AP cpu%d online (cpus_online=%d)\n",
                logical_id, cpus_online)
    else:
        printk2("SMP: AP cpu%d (APIC id=%d) timed out\n",
                logical_id, cast[uint64](apic_id))
    return ok


def smp_boot_secondary():
    # Legacy single-AP entry-point. Kept for backward compatibility
    # with the boot sequence in init/main.ad which calls this by name.
    # Delegates to smp_boot_aps().
    smp_boot_aps()


def smp_boot_aps():
    # Discover all APs from ACPI MADT and wake each one.
    #
    # Step 1: Copy the trampoline bytes to physical 0x8000. This only
    # needs to happen once; subsequent APs re-use the same copy
    # (they each get different stack/id slots patched in before SIPI).
    #
    # Linux-mirror idle: idle APs now HLT and wake on a reschedule IPI
    # (vector 0xF2), so no MONITOR/MWAIT capability probe is needed — the
    # old jiffies-poll thermal hack is gone. HLT is itself the low-power
    # idle state, and the AP is woken precisely when work appears.
    src: uint64 = ap_trampoline_load_addr()
    size: uint64 = ap_trampoline_size()
    printk2("SMP: copying trampoline (%d bytes from %p) -> 0x8000\n",
            size, src)
    memcpy(cast[Ptr[uint8]](AP_TRAMPOLINE_PHYS),
           cast[Ptr[uint8]](src), size)

    # Step 2: Ensure ACPI MADT is parsed (idempotent).
    acpi_init()

    n_cpus: uint32 = acpi_cpu_count()
    printk1("SMP: MADT reports %d CPU(s)\n", cast[uint64](n_cpus))

    if n_cpus == 0:
        # No MADT or no enabled CPUs — fall back to booting APIC ID 1.
        printk0("SMP: no MADT CPU list, trying APIC ID 1 fallback\n")
        _smp_boot_one_ap(0, cast[uint32](1))
        return

    # The MADT slot 0 is conventionally the BSP's APIC ID. Skip it
    # and boot slots 1..n_cpus-1 (the APs), but bring up at most
    # SMP_BOOT_MAX_CPUS total (see the constant — #12/#13 crash past core 2).
    if cast[uint64](n_cpus) > SMP_BOOT_MAX_CPUS:
        printk2("SMP: MADT enumerated %d CPU(s); bringing up %d (rest parked, see #13)\n",
                cast[uint64](n_cpus), SMP_BOOT_MAX_CPUS)
    i: uint32 = 1
    while i < n_cpus and cast[uint64](i) < MAX_CPUS and cast[uint64](i) < SMP_BOOT_MAX_CPUS:
        ap_apic_id: uint32 = acpi_cpu_apic_id(i)
        if ap_apic_id != 0xFF:
            ok: int32 = _smp_boot_one_ap(cast[uint64](i - 1), ap_apic_id)
            if ok == 0:
                printk1("SMP: AP%d failed to come online\n",
                        cast[uint64](i))
        i = i + 1


def get_cpus_online() -> uint64:
    return cpus_online


# --- Bare-metal vs. hypervisor detection -------------------------
#
# Returns 1 iff the CPU is running on bare-metal silicon (no
# hypervisor underneath); 0 if a hypervisor (KVM, QEMU/TCG, VMware,
# Hyper-V, Xen, etc.) is in the loop.
#
# Primary signal: CPUID.1:ECX bit 31 — the architecturally-defined
# "hypervisor present" bit (Intel SDM Vol.2A §3.2 CPUID, AMD APM
# Vol.3 §E.4.2). Reserved-zero on real silicon, set by every
# commonly-deployed hypervisor. This is the strong signal: real
# silicon must NOT set it. The previous detection used CPUID leaf
# 0x40000000 EBX==0 as the only check, but that's a soft signal —
# leaf 0x40000000 is reserved/undefined on bare metal, and some
# firmwares leak non-zero garbage there (observed on at least one
# Intel NUC i7-6770HQ, 2026-05-23). The hypervisor-present bit is
# the architectural fix.
#
# Secondary signal: CPUID leaf 0x40000000 vendor signature. Every
# hypervisor stashes a signature there:
#
#   KVM           "KVMKVMKVM\0\0\0"  in EBX/ECX/EDX
#   TCG QEMU      "TCGTCGTCGTCG"     in EBX/ECX/EDX
#   VMware        "VMwareVMware"     in EBX/ECX/EDX
#   Hyper-V       "Microsoft Hv"     in EBX/ECX/EDX
#   Xen           "XenVMMXenVMM"     in EBX/ECX/EDX
#
# We test the signature only when the primary signal is clear; if
# CPUID.1:ECX[31]==1 we already know it's a hypervisor and skip the
# second CPUID.
#
# is_bare_metal_with_diag() returns the result AND the raw values so
# the caller can log them. Used by xhci_init on first invocation to
# capture what real silicon actually reports — invaluable when this
# detection ever needs a third belt.
#
# Safe at any CPL=0 context. CPUID has no side effects beyond
# clobbering EAX/EBX/ECX/EDX, which the asm dispatcher saves +
# restores around the instruction.

def is_bare_metal() -> int32:
    leaf1: Array[4, uint32]
    cpuid_get(cast[uint32](1), cast[uint32](0), &leaf1[0])
    # ECX bit 31 set => hypervisor present per Intel SDM. Architectural.
    if (leaf1[2] & cast[uint32](0x80000000)) != 0:
        return 0
    # Secondary: leaf 0x40000000 EBX == 0 implies no hypervisor signature.
    # We trust the primary; this is here for paranoia.
    leaf_hv: Array[4, uint32]
    cpuid_get(cast[uint32](0x40000000), cast[uint32](0), &leaf_hv[0])
    if leaf_hv[1] == 0:
        return 1
    # Hypervisor-present bit clear but signature non-zero — unusual
    # firmware. Treat as bare metal since the architectural bit is
    # the authoritative signal.
    return 1


# Diagnostic variant: returns the result and writes the four raw
# CPUID dwords from leaf 1 and leaf 0x40000000 into out[0..7] so the
# caller can print them. Only meant for first-invocation logging on
# code paths where a wrong detection would wedge the box.
def is_bare_metal_with_diag(out: Ptr[uint32]) -> int32:
    leaf1: Array[4, uint32]
    cpuid_get(cast[uint32](1), cast[uint32](0), &leaf1[0])
    leaf_hv: Array[4, uint32]
    cpuid_get(cast[uint32](0x40000000), cast[uint32](0), &leaf_hv[0])
    out[0] = leaf1[0]
    out[1] = leaf1[1]
    out[2] = leaf1[2]
    out[3] = leaf1[3]
    out[4] = leaf_hv[0]
    out[5] = leaf_hv[1]
    out[6] = leaf_hv[2]
    out[7] = leaf_hv[3]
    if (leaf1[2] & cast[uint32](0x80000000)) != 0:
        return 0
    if leaf_hv[1] == 0:
        return 1
    return 1

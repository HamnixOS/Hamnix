# arch/x86/kernel/time.ad
#
# Mirrors arch/x86/kernel/time.c + the PIT bits of
# arch/x86/kernel/i8253.c in Linux. Programs the 8253/8254
# Programmable Interval Timer (chip behind IRQ 0) to fire at ~100 Hz
# and exposes a Hamnix-side timer interrupt handler that bumps a
# `jiffies` counter and acknowledges the PIC.
#
# Why PIT and not HPET / TSC-deadline / LAPIC timer? PIT is the
# universally-present option that needs zero ACPI parsing — perfect
# for first boot. Linux walks the same path: setup_default_timer_irq()
# falls back to PIT when nothing more capable is available.
#
# PIT divisor math:
#   PIT base = 1193182 Hz (≈ 1.193 MHz). At target HZ:
#     divisor = base / HZ = 1193182 / 100 = 11931 ≈ 0x2E9B
#   We pick 100 Hz as Linux's classic HZ; cheap, precise enough for
#   wall-clock and scheduler ticks.

from arch.x86.kernel.i8259 import i8259_send_eoi, i8259_unmask_irq
from arch.x86.kernel.apic import lapic_send_eoi
from kernel.printk.printk import printk1
from kernel.sched.core import (
    schedule, signal_post_to_foreground, SIGINT, SIGTSTP, preempt_tick,
    current_task_account_tick, console_input_wake,
    itimer_real_tick_all,
)
# §13: real system-load accounting. loadavg_tick() folds the per-tick
# idle / EWMA-sampling work into a self-contained module so this file
# only gains one call. See kernel/sched/loadavg.ad.
from kernel.sched.loadavg import loadavg_tick, cpu_is_idle
# QA-N32b: the global hrtimer queue + clockevent are a SINGLE shared
# structure with no cross-CPU lock. Only the BSP (cpu 0) is allowed to
# drive the hrtimer expiry pass / reprogram the clockevent from the timer
# IRQ — an AP that took a (local backstop) timer IRQ must NOT mutate the
# shared queue concurrently with the BSP, or the self-rearming scheduler-
# tick hrtimer can be dropped mid-walk and the BSP tick freezes forever
# (jiffies stop, every tick-dependent waiter hangs). See the BSP-only
# guard on hrtimer_tick_hook below.
from arch.x86.kernel.setup_percpu import get_cpu_id

# read_tsc() lives in arch/x86/kernel/syscall_64.S — it issues an
# LFENCE-ordered RDTSC and returns the 64-bit Time Stamp Counter.
extern def read_tsc() -> uint64
from drivers.tty.serial.early_8250 import uart_drain_hw_to_fifo
from drivers.input.atkbd import atkbd_poll, atkbd_diag_tick
# V1 USB HID: drain the xHCI Event Ring + dispatch interrupt-IN
# transfer completions to the HID layer. No-op when no USB keyboard
# was successfully attached at boot (xhci.kbd_enabled stays 0).
from drivers.usb.xhci import xhci_poll
# V1 USB 2.0 HID: drain the EHCI periodic interrupt-IN qTD. No-op
# when no USB 2.0 keyboard was attached at boot (ehci.kbd_enabled 0).
from drivers.usb.ehci import ehci_poll
# LIVE-MOUSE FIX: drain the HW mouse ring + route to the scene compositor.
from sys.src.port9.port.devmouse import mouse_pump_to_compositor
# BUG 1 FIX (keyboard exclusivity): drain the HW keyboard FIFO + UART RX
# ring and route to the focused scene window while the DE owns the screen.
from sys.src.port9.port.devcons import kbd_pump_to_compositor
# #169 vDSO: republish the shared time data page each tick so a
# userspace __vdso_clock_gettime read sees a fresh, seqlock-consistent
# clock. No-op until vdso_init() runs (vdso_data_phys still 0).
#
# F4 #449 leaf inversion: this used to `from linux_abi.vdso import
# vdso_update_time` and call it directly, which made the native arch
# core a static consumer of a linux_abi/ symbol. Now we publish a hook
# pointer the linux_abi/vdso.ad init body registers. Default null = no-
# op (a pure-native build never advances the vDSO seqlock, which is
# correct: there is no vDSO data page in that build).
vdso_tick_hook: Fn[None]


def register_vdso_tick_hook(hook: Fn[None]):
    # linux_abi/vdso.ad's init body calls this once. The timer tick then
    # republishes the shared time-data page through this pointer. See
    # the F4 #449 hook-table inversion plan.
    vdso_tick_hook = hook

# Softirq bottom-half tick hook. Same leaf-inversion discipline as
# vdso_tick_hook: the native arch timer must NOT statically import
# kernel/softirq.ad (softirq -> api_timer -> arch.time would cycle). So
# softirq_init() publishes a hook here; the timer tick raises TIMER_SOFTIRQ
# and runs the IRQ-return softirq pass through it. Null = no-op (pre-init).
softirq_tick_hook: Fn[None]


def register_softirq_tick_hook(hook: Fn[None]):
    # kernel/softirq.ad's softirq_init() calls this once.
    softirq_tick_hook = hook

# Hi-res timer tick hook. kernel/time/tick.ad registers tick_handle_
# interrupt() here at boot:16.time; the timer ISR then runs the hrtimer
# expiry pass + clockevent reprogram through this pointer on every firing
# (periodic tick OR one-shot). Hook-pointer indirection (same pattern as
# vdso_tick_hook) keeps arch/ from a static import of kernel/time/, which
# would form a cycle (kernel.time.tick imports get_jiffies from here).
# Default null = no-op (a build without the time subsystem keeps the
# legacy jiffies tick).
hrtimer_tick_hook: Fn[None]


def register_hrtimer_tick_hook(hook: Fn[None]):
    hrtimer_tick_hook = hook

# Linux-ABI no-syscall watchdog tick hook. When a Linux-ABI (is_linux_
# userspace) task spins in userspace without issuing a syscall for N
# seconds, the running instruction never traps — the only kernel entry
# left is this timer IRQ. The watchdog fires from the tick: it compares
# jiffies against the task's last-syscall stamp and, past the threshold,
# dumps the interrupted RIP/RSP + the containing VMA (library+offset) to
# serial. mm/vma.ad owns the body (it has vma_find + the VMA fields +
# uaccess); it registers the hook at boot. Null = no-op (pure-native
# build has no Linux-ABI tasks to watch).
#   args: (user_ctx, interrupted_rip, interrupted_rsp)
# Linux-ABI bounded-futex-park tick hook. Same leaf-inversion discipline as
# vdso_tick_hook / linux_nosyscall_wd_hook: arch/ must not statically import a
# linux_abi/ symbol, so linux_abi/u_syscalls.ad publishes a hook here at boot.
#
# WHY A TICK IS REQUIRED. A FUTEX_WAIT parker in the large-thread-group arm
# sleeps in STATE_WAIT off the runqueue. Its "bounded recheck" deadline is
# evaluated only by its OWN loop in wq_wait_commit_timeout — and that loop only
# keeps running while nothing else is runnable (the sti;hlt idle arm). The
# instant it hands off via schedule(), _pick_next will never select it again
# (STATE_WAIT), so nothing can service its deadline. Without an independent
# clock the "bounded" park is INFINITE, and a futex word mutated with the
# FUTEX_WAKE elided (glibc/musl/cairo/pango do this whenever no waiter is
# registered) parks the thread for the life of the process. This hook is that
# clock. Null = no-op (pure-native boot with no Linux ABI).
linux_futex_tick_hook: Fn[None]


def register_linux_futex_tick_hook(hook: Fn[None]):
    # Publish the Layer-2 bounded-futex-park sweep. Called from
    # u_syscalls_init(); the arch timer never names the Layer-2 symbol.
    linux_futex_tick_hook = hook


linux_nosyscall_wd_hook: Fn[None, uint64, uint64, uint64]


def register_linux_nosyscall_wd_hook(hook: Fn[None, uint64, uint64, uint64]):
    linux_nosyscall_wd_hook = hook


PIT_CHANNEL0_DATA: int32 = 0x40
PIT_CMD:           int32 = 0x43

# Command byte: channel 0, lobyte/hibyte access, mode 3 (square wave),
# binary count. = 0x36.
PIT_CMD_CH0_LOHI_MODE3: int32 = 0x36

HZ:           uint64 = 100
PIT_BASE_HZ:  uint64 = 1193182

jiffies: uint64 = 0

# /proc/stat 3-way CPU-time split. Each timer tick charges EXACTLY one
# of these buckets, classified from user_ctx + the pure-instrumentation
# idle flag (kernel/sched/loadavg.ad cpu_is_idle):
#   * user   — the timer froze ring-3 (userland) code.
#   * idle   — non-userland AND the CPU was parked in an idle-wait hlt.
#   * system — non-userland AND NOT idle: the kernel was doing real work.
# These are independent of loadavg.ad's _la_idle_jiffies (which folds
# idle+system into one "non-userland" bucket and is depended on by a
# devloadavg test — left untouched). devstat.ad renders these three as
# the real user / system / idle columns of /proc/stat.
g_stat_user_jiffies:   uint64 = 0
g_stat_system_jiffies: uint64 = 0
g_stat_idle_jiffies:   uint64 = 0

# Per-CPU tick counter — proves Percpu[T] codegen works for both
# read and write in interrupt context. Each CPU keeps its own count;
# on uniprocessor we expect this to track `jiffies`.
local_timer_ticks: Percpu[uint64]


def time_init():
    # Program PIT channel 0 for HZ Hz square-wave interrupts.
    divisor: uint64 = PIT_BASE_HZ / HZ
    div_lo: int32 = cast[int32](divisor & 0xFF)
    div_hi: int32 = cast[int32]((divisor >> 8) & 0xFF)

    outb(PIT_CMD_CH0_LOHI_MODE3, PIT_CMD)
    outb(div_lo, PIT_CHANNEL0_DATA)
    outb(div_hi, PIT_CHANNEL0_DATA)

    # Unmask IRQ 0 on the PIC so the timer line can actually fire.
    # CPU interrupts (EFLAGS.IF) are still off here — caller is
    # responsible for `sti` once IDT vector 32 is populated.
    i8259_unmask_irq(0)


def timer_interrupt(interrupted_cs: uint64, interrupted_rip: uint64,
                    interrupted_rsp: uint64):
    # Called from do_irq() when vector 32 fires.  Since M16.22 the
    # interrupt source is the Local APIC timer (periodic, configured
    # in arch/x86/kernel/apic.ad); pre-M16.22 it was the PIT through
    # the 8259. The dispatch vector is identical so do_irq routes
    # the same way; the only change is which controller we EOI.
    #
    # `interrupted_cs` is the CS selector the CPU pushed in the iret
    # frame — the privilege level of the code this interrupt froze.
    # (interrupted_cs & 3) == 3 means ring 3 (userland); that is the
    # only context the preemption gate (preempt_tick) will switch out
    # of. See preempt_tick() in kernel/sched/core.ad for the policy.
    jiffies = jiffies + 1
    # Per-CPU counter (M16.14 Percpu[T] demo path). Codegen assigns its
    # %gs displacement; cpu_id_pcpu is pinned to offset 0, so this lands
    # after it, NOT at offset 0 — see compiler/codegen_x86.py and
    # arch/x86/kernel/setup_percpu_asm.S.
    local_timer_ticks = local_timer_ticks + 1
    # #169 vDSO: refresh the shared time data page so a userspace
    # __vdso_clock_gettime / __vdso_gettimeofday / __vdso_time read
    # sees the current clock without trapping into the kernel. The TSC
    # advances continuously, so a sub-tick read interpolates a slightly
    # stale value (granularity ~one tick = 10 ms), which is exactly the
    # accuracy contract Linux's CLOCK_*_COARSE-style vDSO fast path
    # gives. No-op before vdso_init() registers the hook (the data
    # page isn't allocated). F4 #449: dispatched through the registered
    # hook pointer rather than a static linux_abi import.
    if vdso_tick_hook != cast[Fn[None]](0):
        vdso_tick_hook()
    # M16.39: drain whatever the UART has into the software RX
    # FIFO, watching for Ctrl-C. If we saw one, post SIGINT to
    # every foreground task (pid > 1). The actual termination
    # happens when the signal'd task next hits a syscall return
    # or a yield_to_others — no preemption-with-signals yet.
    tctl: int32 = uart_drain_hw_to_fifo()
    if (tctl & 1) != 0:
        signal_post_to_foreground(SIGINT)
    if (tctl & 2) != 0:
        signal_post_to_foreground(SIGTSTP)
    # Event-driven belt-and-braces: the timer drain still runs every tick
    # to cover the window where IF was masked (no UART RX IRQ). Wake any
    # console-input sleeper after the drain so a byte buffered during a
    # masked window is consumed without a further tick of latency.
    console_input_wake()
    # M16.75: drain the PS/2 keyboard the same way. Lets the kernel
    # accept input from a real keyboard at boot, not just serial —
    # required for non-QEMU machines that don't expose a UART.
    atkbd_poll()
    # Real-hardware keyboard instrumentation: emit a periodic
    # [atkbd-diag] line (every ~5 s; the function self-rate-limits)
    # showing irq1_count / poll_calls / bytes_from_0x60 / fifo_depth.
    # On the dead-keyboard Asus laptop this transcript is what tells
    # us whether IRQ 1 fires, the tick poll runs, and any byte ever
    # leaves port 0x60.
    atkbd_diag_tick()
    # V1 USB HID: drain the xHCI Event Ring + dispatch any interrupt-IN
    # completions. xhci_poll() is a no-op if V1 enumeration didn't
    # reach kbd_enabled — so this is safe to call unconditionally.
    xhci_poll()
    # V1 USB 2.0 HID: drain the EHCI interrupt-IN qTD the same way.
    # ehci_poll() is a no-op if EHCI V1 didn't arm a keyboard.
    ehci_poll()
    # LIVE-MOUSE FIX: drain whatever the PS/2 (IRQ12) and USB-HID producers
    # pushed onto the shared mouse ring this tick and route each event to
    # the scene compositor (cursor move + hit-test + window-local forward).
    # No-op until the DE owns the screen (wsys_de_is_live), so a userspace
    # /dev/mouse reader still owns the ring before the rl5 flip.
    mouse_pump_to_compositor()
    # BUG 1 FIX: keyboard twin of the mouse pump. Drain the PS/2 keyboard
    # FIFO + UART RX ring and route each byte to the focused scene window's
    # /keys stream. No-op until the DE owns the screen (wsys_de_is_live).
    kbd_pump_to_compositor()
    # EOI the LAPIC NOW — before any possible context switch. The EOI
    # clears the timer vector's in-service bit; if we deferred it past
    # the schedule() below it would only land when THIS task is
    # rescheduled, and the task we switch to would never receive
    # another timer IRQ (its in-service bit would still be set). This
    # is also why do_irq() no longer EOIs the timer vector itself.
    lapic_send_eoi()
    # Bottom-half pass on the timer IRQ-return. The hook (registered by
    # softirq_init) raises TIMER_SOFTIRQ — whose handler drives the L9
    # timer wheel + hrtimers — then runs do_softirq() to drain TIMER plus
    # any tasklet/NET_RX raised since the last pass. Runs BEFORE the
    # preemption gate so a switch-out doesn't strand pending softirqs.
    # Null until softirq_init(); the pure-native early-boot tick is a
    # no-op here.
    if softirq_tick_hook != cast[Fn[None]](0):
        softirq_tick_hook()
    # Hi-res timer subsystem (kernel/time/): run the hrtimer expiry pass
    # against the live ns clocksource and reprogram the clockevent for the
    # next earliest deadline. In one-shot mode this is what RE-ARMS the
    # LAPIC for the next hrtimer; in periodic mode it still fires any due
    # hrtimers at ns-accurate deadlines. Done AFTER the EOI so the one-shot
    # reprogram lands on a clean in-service state. No-op before boot:16.time
    # registers the hook (legacy jiffies tick only).
    #
    # QA-N32b BSP-ONLY GUARD: run the hrtimer expiry + clockevent reprogram
    # ONLY on the BSP (cpu 0). The hrtimer queue (kernel/time/hrtimer.ad
    # ht_q/ht_qlen) and clockevent state are global and unlocked; the self-
    # rearming scheduler-tick hrtimer keeps the BSP LAPIC firing. If an AP —
    # woken by its local LAPIC backstop (kernel/sched/core.ad
    # sched_ap_idle_loop) — also ran this pass, two CPUs would mutate the
    # shared queue at once, occasionally dropping the sched-tick timer and
    # wedging the whole box with jiffies frozen (the long-parked #9 wedge).
    # APs still bump jiffies + run preempt_tick above; only the shared-state
    # hrtimer drive is BSP-exclusive. On UP (cpu 0 only) this is a no-op.
    if hrtimer_tick_hook != cast[Fn[None]](0) and get_cpu_id() == 0:
        hrtimer_tick_hook()
    # setitimer(2) ITIMER_REAL: decrement every armed task's wall-clock
    # countdown by one tick and post SIGALRM on expiry. BSP-only — the counters
    # are global task_table state with no cross-CPU lock, and ITIMER_REAL is
    # wall-clock (one decrement per real tick, not per CPU), so an AP backstop
    # tick must NOT also decrement or a 100 ms timer would fire early on SMP.
    # This is what lets xeyes/xclock (and most X/GTK apps) redraw off SIGALRM.
    if get_cpu_id() == 0:
        itimer_real_tick_all()
    # Preemption gate. preempt_tick() ages this task's quantum and
    # returns 1 only when the quantum is spent AND the timer caught
    # ring-3 (userland) code AND another task is STATE_READY. Ring-0
    # ticks (kthreads / IRQ context) never trigger a switch — kernel
    # code is treated as non-preemptible; the cooperative yields
    # already cover it. Only on a 1 do we run schedule(), whose
    # __switch_to_asm saves THIS task's full interrupted state (the
    # IRQ frame + caller-saved are already on its kstack) and resumes
    # the next task; when this task is later picked again, schedule()
    # returns here and we unwind back through do_irq -> common_irq's
    # iretq into the exact userland instruction we interrupted.
    user_ctx: uint64 = 0
    if (interrupted_cs & 3) == 3:
        user_ctx = 1
    # Linux-ABI no-syscall watchdog. Runs before the preemption gate so a
    # switch-out doesn't skip the check. Passes the interrupted RIP/RSP so
    # the hook can pin a userspace spin to a library+offset. No-op until
    # mm/vma.ad registers it; internally a no-op unless the running task is
    # a Linux-ABI task past the no-syscall threshold.
    if linux_nosyscall_wd_hook \
            != cast[Fn[None, uint64, uint64, uint64]](0):
        linux_nosyscall_wd_hook(user_ctx, interrupted_rip, interrupted_rsp)
    # Bounded-futex-park sweep: directed-wake any FUTEX_WAIT parker whose
    # recheck interval elapsed (see linux_futex_tick_hook above). IRQ-context
    # safe: the hook trylocks the futex table and simply skips this tick if the
    # interrupted code holds it.
    if linux_futex_tick_hook != cast[Fn[None]](0):
        linux_futex_tick_hook()
    # §13: per-tick load accounting — idle-jiffies bump (this tick
    # caught a non-userland context iff user_ctx == 0) plus the
    # 5-second EWMA sampler. Cheap; runs before the preemption gate
    # so a switch-out doesn't skip the sample.
    loadavg_tick(user_ctx)
    # getrusage(2): charge this tick to the running task — user time if it
    # caught ring-3 code, system time otherwise. Runs before the
    # preemption gate so a switch-out doesn't skip the accounting.
    current_task_account_tick(user_ctx)
    # /proc/stat 3-way split: charge this tick to EXACTLY one global
    # bucket. user if the timer froze ring-3 code; else idle if the CPU
    # was parked in an idle-wait hlt (pure-instrumentation flag); else
    # system (kernel doing real non-userland work). See devstat.ad.
    if user_ctx == 1:
        g_stat_user_jiffies = g_stat_user_jiffies + 1
    elif cpu_is_idle() != 0:
        g_stat_idle_jiffies = g_stat_idle_jiffies + 1
    else:
        g_stat_system_jiffies = g_stat_system_jiffies + 1
    if preempt_tick(user_ctx) != 0:
        schedule()


def get_local_timer_ticks() -> uint64:
    return local_timer_ticks


def get_jiffies() -> uint64:
    return jiffies


def stat_user_jiffies() -> uint64:
    # Ticks the timer froze ring-3 (userland) code. /proc/stat user col.
    return g_stat_user_jiffies


def stat_system_jiffies() -> uint64:
    # Ticks the kernel was doing real non-idle work. /proc/stat system col.
    return g_stat_system_jiffies


def stat_idle_jiffies() -> uint64:
    # Ticks the CPU was parked in an idle-wait hlt. /proc/stat idle col.
    return g_stat_idle_jiffies


# -- PIT-counter monotonic microsecond clock ---------------------------
#
# `jiffies` is bumped by the LAPIC timer interrupt; it FREEZES whenever
# CPU interrupts are masked. A SYSCALL entry clears EFLAGS.IF (IA32_FMASK
# = 0x0200), so for the whole duration of a userland read(2)/write(2)
# syscall `jiffies` does not advance — a `while get_jiffies() < deadline`
# loop in that context degenerates into `while True`.
#
# The 8254 PIT channel 0, by contrast, is a free-running hardware
# counter: it keeps decrementing at PIT_BASE_HZ (~1.193 MHz) regardless
# of EFLAGS.IF. By latching and reading its 16-bit count we get a time
# source that ADVANCES during a syscall. pit_monotonic_us() turns that
# into a monotonic microsecond counter: each call latches the counter,
# measures how far it moved since the previous call, and accumulates the
# elapsed microseconds. It MUST be polled often enough that the counter
# does not wrap more than once between calls (one wrap ≈ divisor/1.193MHz
# ≈ 10 ms at HZ=100) — the network poll loops that use it call it every
# virtio_net_poll() iteration, far faster than that.
#
# Channel 0 runs in mode 3 (square wave). In mode 3 the 8254 decrements
# the count by TWO on every PIT input clock, so the latched count value
# sweeps the full [0, divisor) range in only divisor/2 input clocks. The
# accumulator below measures count-VALUE units traversed; to convert to
# real elapsed time it must divide by 2 (a count-units delta of N
# corresponds to N/2 PIT input clocks at PIT_BASE_HZ). The pre-fix code
# omitted that /2 and over-reported elapsed time by exactly 2x — see the
# `(2 * PIT_BASE_HZ)` divisor in pit_monotonic_us().

pit_us_accum:   uint64 = 0      # accumulated microseconds since first call
pit_last_count: uint64 = 0      # last latched PIT counter value
pit_us_inited:  uint8  = 0      # 0 until the first pit_monotonic_us call
# Sub-microsecond remainder carried between calls so the integer divide
# by PIT_BASE_HZ does not drop fractional ticks over a long poll.
pit_tick_rem:   uint64 = 0


def _pit_read_count() -> uint64:
    # Latch channel 0 (counter-latch command: bits 7:6 = 00 select
    # channel 0, bits 5:4 = 00 = latch) then read lo, hi from the data
    # port. Returns the 16-bit count.
    outb(0x00, PIT_CMD)
    lo: uint64 = cast[uint64](inb(PIT_CHANNEL0_DATA)) & 0xFF
    hi: uint64 = cast[uint64](inb(PIT_CHANNEL0_DATA)) & 0xFF
    return (hi << 8) | lo


def pit_monotonic_us() -> uint64:
    # Free-running microsecond counter, valid even with CPU interrupts
    # masked. See the banner above. The first call seeds the baseline
    # and returns 0; each later call adds the elapsed microseconds.
    divisor: uint64 = PIT_BASE_HZ / HZ
    cur: uint64 = _pit_read_count()
    if pit_us_inited == 0:
        pit_us_inited = 1
        pit_last_count = cur
        pit_us_accum = 0
        pit_tick_rem = 0
        return 0
    # PIT counts DOWN. ticks elapsed = last - cur when it did not wrap;
    # on a wrap (cur > last) the counter reloaded, so the elapsed span
    # is (last - 0) + (divisor - cur) = last + divisor - cur.
    ticks: uint64 = 0
    if cur <= pit_last_count:
        ticks = pit_last_count - cur
    else:
        ticks = pit_last_count + divisor - cur
    pit_last_count = cur
    # Convert traversed count-units to microseconds. Channel 0 is mode 3
    # (square wave): the count decrements by 2 per PIT input clock, so
    # `ticks` count-units == ticks/2 input clocks. Therefore
    #   us = (ticks / 2) * 1e6 / PIT_BASE_HZ = ticks * 1e6 / (2*PIT_BASE_HZ)
    # Doing the *1e6 before the divide (and carrying the remainder)
    # keeps sub-microsecond precision over a long poll.
    num: uint64 = ticks * 1000000 + pit_tick_rem
    pit_us_accum = pit_us_accum + (num / (2 * PIT_BASE_HZ))
    pit_tick_rem = num % (2 * PIT_BASE_HZ)
    return pit_us_accum


# -- TSC-based high-resolution monotonic clock -------------------------
#
# `jiffies` has 10 ms granularity and freezes whenever EFLAGS.IF is
# clear; pit_monotonic_us() has microsecond granularity but needs a
# 16-bit PIT latch + two `inb`s per call and depends on being polled
# faster than the ~10 ms PIT wrap. The CPU Time Stamp Counter is the
# real high-resolution monotonic source: a 64-bit register the CPU
# increments at a (constant, on every CPU we target) rate, readable in
# a handful of cycles by RDTSC. At a few GHz it gives sub-nanosecond
# resolution and a 64-bit counter does not wrap for ~100 years.
#
# To turn raw TSC ticks into nanoseconds we must know the TSC
# frequency. We measure it the same way calibrate_APIC_clock() in
# arch/x86/kernel/apic.ad measures the LAPIC: gate PIT channel 2 on
# for a precise 10 ms one-shot, sample RDTSC at both ends, and the
# delta is "TSC ticks per 10 ms". ×100 gives the TSC frequency in Hz.
#
# Conversion ns = ticks * 1e9 / tsc_hz is done as a fixed-point
# multiply: we precompute tsc_ns_mult = (1e9 << TSC_SHIFT) / tsc_hz
# once at calibration time, then each query is
#     ns = (delta_ticks * tsc_ns_mult) >> TSC_SHIFT
# which is a single 64-bit multiply + shift, no per-call division.
# TSC_SHIFT = 20 keeps the multiplier comfortably inside 64 bits for
# any plausible TSC frequency (at 1e12 Hz the multiplier is still only
# ~1e9) while giving ~1e-6 relative precision.
#
# Overflow note: `delta_ticks * tsc_ns_mult` is a 64-bit product. At a
# ~4 GHz TSC, tsc_ns_mult ≈ 2^18, so the product overflows once
# delta_ticks exceeds ~2^46 ticks ≈ several hours of uptime. That is
# well beyond any test horizon; a wrap-free multi-day clock would need
# a 128-bit intermediate (or periodic re-basing of tsc_base from a
# timer-driven seconds accumulator) — noted as a follow-up.

# Same PIT channel 2 wiring the LAPIC calibration uses. Channel 2 is
# the one channel whose GATE we can software-control (port 0x61 bit 0)
# and whose OUT pin we can poll (port 0x61 bit 5).
TSC_PIT_CH2_DATA:  int32 = 0x42
TSC_PIT_CTRL_PORT: int32 = 0x61
# Channel 2, lobyte/hibyte, mode 0 (one-shot), binary = 0xB0.
TSC_PIT_CMD_CH2:   int32 = 0xB0
# 10 ms at 1193182 Hz: 11932 = 0x2E9C.
TSC_PIT_10MS_DIV:  int32 = 0x2E9C
TSC_CAL_MS:        uint64 = 10
# Port 0x61: bit 0 GATE2, bit 1 speaker, bit 5 channel-2 OUT.
TSC_PIT_GATE:  int32 = 0x01
TSC_PIT_SPEAK: int32 = 0x02
TSC_PIT_OUT:   int32 = 0x20

# Fixed-point shift for the ticks->ns multiply (see banner).
TSC_SHIFT: uint64 = 20

tsc_hz:      uint64 = 0    # measured TSC frequency, Hz (0 until calibrated)
tsc_ns_mult: uint64 = 0    # (1e9 << TSC_SHIFT) / tsc_hz
tsc_base:    uint64 = 0    # RDTSC value captured at calibration ("t=0")
tsc_ready:   uint8  = 0    # 1 once tsc_init() succeeded


def _tsc_pit_gate_off():
    cur: int32 = inb(TSC_PIT_CTRL_PORT)
    outb(cur & ~(TSC_PIT_GATE | TSC_PIT_SPEAK), TSC_PIT_CTRL_PORT)


def _tsc_pit_gate_on():
    cur: int32 = inb(TSC_PIT_CTRL_PORT)
    outb((cur & ~TSC_PIT_SPEAK) | TSC_PIT_GATE, TSC_PIT_CTRL_PORT)


def tsc_init():
    # Calibrate the TSC frequency against a PIT channel 2 10 ms
    # one-shot, then derive the fixed-point ns multiplier and capture
    # the monotonic-clock zero point. Safe to call once, after the PIT
    # exists (post-time_init). Interrupts should be off; the busy-poll
    # below would otherwise be perturbed by an IRQ — but a perturbation
    # only stretches the measured window, it cannot make TSC run
    # backwards, so calibration stays monotonic-safe regardless.

    # Stop channel 2 + silence the speaker before programming.
    _tsc_pit_gate_off()

    # Program channel 2: mode 0 one-shot, 10 ms divisor.
    outb(TSC_PIT_CMD_CH2, PIT_CMD)
    outb(TSC_PIT_10MS_DIV & 0xFF, TSC_PIT_CH2_DATA)
    outb((TSC_PIT_10MS_DIV >> 8) & 0xFF, TSC_PIT_CH2_DATA)

    # Open the gate and immediately snapshot the TSC: t0.
    _tsc_pit_gate_on()
    t0: uint64 = read_tsc()

    # Spin until the channel-2 OUT pin (port 0x61 bit 5) goes high —
    # that is the 10 ms terminal count.
    while (inb(TSC_PIT_CTRL_PORT) & TSC_PIT_OUT) == 0:
        pass

    t1: uint64 = read_tsc()
    _tsc_pit_gate_off()

    delta: uint64 = t1 - t0
    # delta TSC ticks elapsed in TSC_CAL_MS milliseconds.
    # tsc_hz = delta * 1000 / TSC_CAL_MS.
    tsc_hz = delta * 1000 / TSC_CAL_MS

    # Guard: a wildly implausible measurement (PIT poll exited early,
    # or RDTSC unavailable) would poison every later conversion. If the
    # frequency is outside a sane window [1 MHz, 100 GHz], fall back to
    # a nominal 1 GHz so the clock still advances rather than dividing
    # by something absurd. Real CPUs and QEMU/TCG both land well inside.
    if tsc_hz < 1000000 or tsc_hz > 100000000000:
        printk1("tsc: calibration implausible (%d Hz) — fallback 1 GHz\n",
                tsc_hz)
        tsc_hz = 1000000000

    # Precompute the fixed-point ns multiplier: tsc_ns_mult such that
    # ns = (ticks * tsc_ns_mult) >> TSC_SHIFT  ≈  ticks * 1e9 / tsc_hz.
    tsc_ns_mult = (1000000000 << TSC_SHIFT) / tsc_hz

    # Capture the zero point. tsc_monotonic_ns() reports time since
    # this instant.
    tsc_base = read_tsc()
    tsc_ready = 1

    mhz: uint64 = tsc_hz / 1000000
    printk1("tsc: calibrated %d MHz", mhz)
    printk1(" (%d Hz)\n", tsc_hz)


def tsc_calibrated() -> uint64:
    # 1 once tsc_init() has run, else 0. Lets callers fall back to the
    # jiffies clock before the TSC is up.
    return cast[uint64](tsc_ready)


def tsc_hz_get() -> uint64:
    return tsc_hz


def tsc_monotonic_ns() -> uint64:
    # Nanoseconds since tsc_init() captured the zero point. Monotonic
    # and high-resolution; valid with CPU interrupts masked (RDTSC does
    # not depend on EFLAGS.IF). Before calibration, fall back to the
    # jiffies clock (10 ms granularity) so callers still get a sane,
    # advancing value.
    if tsc_ready == 0:
        return get_jiffies() * 10000000
    now: uint64 = read_tsc()
    # TSC is a free-running up-counter; `now` cannot be below tsc_base
    # in normal operation. Guard the subtraction anyway so a spurious
    # reading can never produce a gigantic unsigned wrap.
    delta: uint64 = 0
    if now > tsc_base:
        delta = now - tsc_base
    return (delta * tsc_ns_mult) >> TSC_SHIFT


def tsc_monotonic_us() -> uint64:
    # Microsecond form of tsc_monotonic_ns().
    return tsc_monotonic_ns() / 1000

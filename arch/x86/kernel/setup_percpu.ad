# arch/x86/kernel/setup_percpu.ad
#
# Mirrors arch/x86/kernel/setup_percpu.c in Linux. Brings the per-CPU
# subsystem online by allocating a per-CPU area for each CPU (just the
# boot CPU for M16.14 — SMP startup comes later), memcpy'ing the
# `.data..percpu` template the linker stashed at __per_cpu_load into
# that area, and pointing IA32_GS_BASE at the area's base. From then
# on every Percpu[T] global declared in Hamnix source resolves through
# `%gs:name` to the right slot — see the codegen path in
# compiler/codegen_x86.py:gen_identifier / gen_assignment.
#
# This replaces the M16.4 hand-rolled approach where setup_per_cpu_areas
# allocated a one-page area and manually wrote a `cpu_id` value at
# offset 0. Now `cpu_id_pcpu` is a real first-class per-CPU global,
# declared below as `Percpu[uint64]`, and the codegen handles all the
# offset arithmetic.

from mm.memblock import memblock_alloc
from drivers.tty.serial.early_8250 import early_puts, early_print_hex64
from kernel.printk.printk import printk1, printk2

extern def wrmsr_gsbase(value: uint64)
extern def read_cpu_id_percpu() -> uint64
extern def get_per_cpu_load() -> uint64
extern def get_per_cpu_size() -> uint64
extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]


# First per-CPU global ever: the logical CPU id, accessed at the offset
# 0 slot of every per-CPU area. The convention "offset 0 = cpu id" lets
# read_cpu_id_percpu() be a single-instruction `mov %gs:0, %rax` in
# arch/x86/kernel/setup_percpu_asm.S — but with Percpu[T] support, this
# is now an ordinary Hamnix global the codegen routes through %gs.
#
# Declared in the file expected to "own" the per-CPU subsystem; future
# subsystems (sched/core.ad, time.ad, etc.) will declare their own
# Percpu[T] globals in their own files, all packed into .data..percpu
# by the linker.
cpu_id_pcpu: Percpu[uint64]

# Saved pointer to the boot CPU's per-CPU area, kept globally so the
# code that later wants to re-derive it (debug dumps, SMP bring-up of
# secondary CPUs that need a different base) doesn't have to re-read
# the GS MSR. Note: this is a REGULAR global (in .bss), not Percpu —
# it's a property of the booting machine, not per-CPU.
boot_pcpu_area: uint64 = 0

# Set to 1 once setup_per_cpu_areas() has installed the BSP's per-CPU
# area and pointed IA32_GS_BASE at it. Until then, %gs.base is 0 (BSS
# default) and a %gs-relative read of cpu_id_pcpu returns garbage from
# low physical RAM — so get_cpu_id() MUST NOT dereference %gs before
# this flips. Some early start_kernel self-tests (mm/uaccess
# uaccess_smoke_test, which drives vma_demand_fault) run BEFORE
# setup_per_cpu_areas(); on the BSP the only logical CPU is 0, so
# returning 0 in that window is exactly correct. (A regular .bss global,
# read with GS.base==0-safe absolute addressing, not a Percpu[T].)
percpu_ready: uint64 = 0


# ---------------------------------------------------------------------
# Linux ABI per-CPU `current_task` slot.
#
# Stock Linux .ko modules (cfg80211.ko, mac80211.ko, e1000e.ko, ...)
# read the currently-running task via the x86_64 per-CPU variable
# `current_task` — codegen'd as `mov %gs:0x0,%rax` whose disp32 field
# carries an R_X86_64_32S relocation against the symbol `current_task`.
# The effective address the CPU forms is `GS_base + sign_extend(disp32)`,
# so that relocation MUST resolve to a small OFFSET inside this CPU's
# %gs per-CPU area, NOT to an absolute kernel address (an absolute
# address added to GS_base wraps non-canonical and #GPs — the historical
# wifi/e1000e bug). The loader (linux_abi/loader.ad) special-cases the
# per-CPU symbol names and resolves them to linux_current_task_offset()
# below.
#
# This Percpu[uint64] global reserves one 8-byte slot in the per-CPU
# template at a codegen-assigned offset. Its value is a pointer to a
# live task_struct so a Linux module that derefs `current->...` (e.g.
# cfg80211's regulatory_init reads `current + 0xb90`) reads valid,
# zeroed memory instead of faulting.
linux_current_task_pcpu: Percpu[uint64]

# Backing dummy task_struct for the Linux ABI `current_task` slot.
#
# Linux's struct task_struct on a 6.x x86_64 build is ~9-10 KiB; the
# only init-time field cfg80211 touches is at offset 0xb90 (2960). We
# size this comfortably past that (8 KiB, zeroed BSS) so any plausible
# init-time `current->field` read lands in-bounds and returns 0 — a
# benign default for every field a module init path inspects. The slot
# is populated once, in setup_per_cpu_areas() (BSP) and
# setup_ap_percpu_area() (APs), before any .ko is loaded.
linux_dummy_task: Array[8192, uint8]

extern def linux_current_task_offset() -> uint64


def setup_per_cpu_areas():
    # Linux iterates over present CPUs and allocates one area per. We
    # have one CPU for now, so the loop body runs once. memblock_alloc
    # gives us a 4 KiB-aligned chunk sized to the linker-reported
    # `__per_cpu_size`. The minimum size is a page so the area maps to
    # a single 4 KiB virtual frame even if the template is tiny —
    # makes future cache-line / page-aligned per-CPU statics free.
    size: uint64 = get_per_cpu_size()
    if size < 4096:
        size = 4096
    area: uint64 = memblock_alloc(size, 4096)
    if area == 0:
        early_puts("Hamnix: setup_per_cpu_areas OOM\n")
        asm_volatile("cli")
        while True:
            asm_volatile("hlt")

    # Copy the master template into this CPU's area. Bytes 0..size from
    # __per_cpu_load are the initialised values of every Percpu[T]
    # variable, packed in the order the linker placed them.
    load: uint64 = get_per_cpu_load()
    memcpy(cast[Ptr[uint8]](area),
           cast[Ptr[uint8]](load),
           get_per_cpu_size())

    boot_pcpu_area = area
    wrmsr_gsbase(area)

    # Now that %gs is anchored we can read/write Percpu[T] globals
    # safely. Stamp this CPU's logical id.
    cpu_id_pcpu = 0

    # %gs.base now points at a real per-CPU area; get_cpu_id() may safely
    # dereference %gs from here on. Anything reading the cpu id BEFORE
    # this point (early start_kernel self-tests) is on the BSP only and
    # reads back the correct logical id 0 via the guard in get_cpu_id().
    percpu_ready = 1

    # Seed the Linux-ABI `current_task` per-CPU slot with a pointer to
    # the dummy task_struct so stock .ko modules that read `current`
    # (cfg80211/mac80211/e1000e) get a valid, derefenceable pointer the
    # moment their init_module runs. See the linux_current_task_pcpu
    # comment above for the full rationale.
    linux_current_task_pcpu = cast[uint64](&linux_dummy_task[0])

    printk2("Hamnix: per-CPU area @ %p, size = %d bytes\n",
            area, get_per_cpu_size())


def get_cpu_id() -> uint64:
    # smp_processor_id() equivalent. Reads via the Percpu[uint64]
    # global — codegen lowers this to `mov %gs:cpu_id_pcpu, %rax`.
    #
    # GS-base-safety guard: before setup_per_cpu_areas() runs, IA32_GS_BASE
    # is still 0, so a %gs-relative load reads garbage from low physical
    # RAM (observed: the 0xf000ff53 BIOS fill pattern). A garbage id then
    # indexes per-CPU arrays (rcu_cpu_read_nesting[], per_cpu_tss[]) at a
    # non-canonical address → #GP. The Wave-3 scalable fault path
    # (vma_demand_fault → vma_lock_fault_vma → rcu_read_lock → get_cpu_id)
    # is exercised by uaccess_smoke_test() which start_kernel runs BEFORE
    # setup_per_cpu_areas(), so this window is real and load-bearing. On
    # the BSP the only logical CPU in that window is 0, so return 0 until
    # the per-CPU area is anchored. (Reads of percpu_ready are absolute,
    # not %gs-relative, so they are valid even with GS.base == 0.)
    if percpu_ready == 0:
        return 0
    return cpu_id_pcpu


def setup_ap_percpu_area(logical_cpu_id: uint64):
    # Called by each AP from ap_main_hamnix() to set up its own
    # per-CPU area. Mirrors setup_per_cpu_areas() but uses
    # memblock_alloc for the area (which is BSP-safe since the AP
    # hasn't entered the scheduler yet and memblock is lock-free
    # by construction — the BSP has finished using it for the heap
    # before smp_boot_aps() is called).
    #
    # After this returns %gs points at the AP's private area, and
    # cpu_id_pcpu holds `logical_cpu_id`, so get_cpu_id() works on
    # the AP exactly as on the BSP.
    size: uint64 = get_per_cpu_size()
    if size < 4096:
        size = 4096
    area: uint64 = memblock_alloc(size, 4096)
    if area == 0:
        # OOM: the AP cannot continue; park it here.
        asm_volatile("cli")
        while True:
            asm_volatile("hlt")

    # Copy the master template into this CPU's per-CPU area.
    load: uint64 = get_per_cpu_load()
    memcpy(cast[Ptr[uint8]](area),
           cast[Ptr[uint8]](load),
           get_per_cpu_size())

    # Point %gs at this AP's private area.
    wrmsr_gsbase(area)

    # Stamp the logical CPU id into slot 0.
    cpu_id_pcpu = logical_cpu_id

    # Seed this AP's Linux-ABI `current_task` slot (same dummy backing
    # as the BSP — a single zeroed task_struct is sufficient for the
    # init-time deref contract; per-CPU correctness of `current` for
    # actually-scheduled Linux tasks is a future milestone).
    linux_current_task_pcpu = cast[uint64](&linux_dummy_task[0])

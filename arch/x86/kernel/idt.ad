# arch/x86/kernel/idt.ad
#
# Mirrors arch/x86/kernel/idt.c in Linux. Owns the 256-entry IDT and
# the per-gate setup logic. The low-level per-vector entry stubs live
# in arch/x86/kernel/idt_asm.S (`trap_stub_0` ... `trap_stub_31`,
# indexed via `get_trap_stub`); this file populates the gate
# descriptors and loads them with `idt_load`.
#
# x86_64 IDT gate descriptor (16 bytes per entry):
#
#   Quad 0 (low):
#     bits  0..15  offset_low   (handler bits 0..15)
#     bits 16..31  selector     (CS for the handler, 0x08 in our GDT)
#     bits 32..34  IST          (0 — keep the interrupted stack)
#     bits 35..39  reserved
#     bits 40..47  type_attr    (0x8E = present | DPL=0 | 64-bit
#                                       interrupt gate)
#     bits 48..63  offset_mid   (handler bits 16..31)
#
#   Quad 1 (high):
#     bits  0..31  offset_high  (handler bits 32..63)
#     bits 32..63  reserved
#
# Layout is intentionally close to `gate_struct` in Linux's
# arch/x86/include/asm/desc_defs.h so future readers can diff.

extern def get_trap_stub(vector: uint64) -> uint64
extern def get_irq_stub(vector: uint64) -> uint64
extern def idt_load(idt_table_addr: uint64)
# KPTI: the IDT is read by the CPU during interrupt-vector delivery, which
# can occur while CR3 = the user PML4. So the table must live in the .kpti
# section (mapped in every user PML4), NOT in the Adder-codegen .bss (which
# is part of the kernel image bulk the user table hides). kpti_asm.S owns a
# 4 KiB .kpti.bss buffer `kpti_idt_table`; this accessor returns its
# high-half VMA. We populate gates by storing directly through this pointer.
extern def kpti_idt_table_addr() -> uint64
# Dedicated stub for the cross-CPU TLB-flush IPI (vector 240 / 0xF0).
# Lives outside the 32..95 irq_stub_table range so we expose it
# directly via a named extern rather than extending the table.
extern def irq_stub_240()
# Dedicated stub for the cross-CPU RESCHEDULE IPI (vector 242 / 0xF2).
# Same out-of-band treatment as irq_stub_240; wakes an idle AP from HLT.
extern def irq_stub_242()
# Dedicated stub for the cross-CPU CPU-STOP IPI (vector 243 / 0xF3). Parks
# an AP permanently in cli;hlt — used by the poweroff/reboot path so no core
# spins/overheats if the platform's S5 transition fails to cut power.
extern def irq_stub_243()

KERNEL_CS:      uint64 = 0x08    # 64-bit code segment in boot GDT
GATE_TYPE_ATTR: uint64 = 0x8E    # present | DPL=0 | 64-bit interrupt gate

# 256 IDT entries * 2 uint64 per entry = 512 quads (4 KiB total). The
# storage lives in kpti_asm.S (.kpti.bss); we reach it as a Ptr[uint64].
def _idt_table() -> Ptr[uint64]:
    return cast[Ptr[uint64]](kpti_idt_table_addr())


def idt_set_gate(vector: uint64, handler: uint64):
    # Quad 0: offset_mid<<48 | type_attr<<40 | ist<<32 | sel<<16 | offset_low.
    # ist = 0, so we omit that term.
    q0: uint64 = handler & 0xFFFF
    q0 = q0 | (KERNEL_CS << 16)
    q0 = q0 | (GATE_TYPE_ATTR << 40)
    q0 = q0 | (((handler >> 16) & 0xFFFF) << 48)

    # Quad 1: high 32 bits of the handler (rest of the entry is zero).
    q1: uint64 = (handler >> 32) & 0xFFFFFFFF

    idx: uint64 = vector * 2
    t: Ptr[uint64] = _idt_table()
    t[idx] = q0
    t[idx + 1] = q1


# M16.154-trapdiag: variant of idt_set_gate that takes an explicit
# IST index. Needed by trap_diag.ad to install vector 0x08 (#DF) with
# IST=1 so the handler runs on a fresh stack even if RSP was wrecked
# at #DF entry. Vectors with IST=0 still keep the interrupted stack
# (same as idt_set_gate). Layout matches AMD64 gate descriptor: IST
# is 3 bits at quad-0 bits 32..34.
def idt_set_gate_with_ist(vector: uint64, handler: uint64, ist: uint64):
    q0: uint64 = handler & 0xFFFF
    q0 = q0 | (KERNEL_CS << 16)
    q0 = q0 | ((ist & 0x7) << 32)
    q0 = q0 | (GATE_TYPE_ATTR << 40)
    q0 = q0 | (((handler >> 16) & 0xFFFF) << 48)

    q1: uint64 = (handler >> 32) & 0xFFFFFFFF

    idx: uint64 = vector * 2
    t: Ptr[uint64] = _idt_table()
    t[idx] = q0
    t[idx + 1] = q1


def idt_init():
    # Vectors 0..31: CPU exceptions, halt-on-fault traps.
    i: uint64 = 0
    while i < 32:
        handler: uint64 = get_trap_stub(i)
        idt_set_gate(i, handler)
        i = i + 1

    # Vectors 32..47: legacy 8259 IRQs (after the i8259 remap). These
    # use the iretq-returning IRQ entry path, not the halt-on-fault
    # trap path.
    #
    # Vectors 48..95: device IRQ band — IOAPIC-routed PCI INTx and
    # MSI/MSI-X handlers land here. virtio-net INTx is 0x40 (64);
    # AHCI / NVMe / virtio-blk / r8169 / PS-2 / e1000e claim 0x41..
    # 0x47; r8169-gigabit MSI is 0x48; virtio-net's per-queue MSI-X
    # vectors land at 0x49..0x4B. The band runs to 0x5F so a
    # multi-vector MSI-X device has room without another IDT-rewire
    # commit — idt_table has 256 slots, so this is free headroom.
    i = 32
    while i < 96:
        handler: uint64 = get_irq_stub(i)
        idt_set_gate(i, handler)
        i = i + 1

    # Vector 240 (0xF0): cross-CPU TLB-flush IPI.  Dedicated stub lives
    # outside the 32..95 band; wire it directly by its extern address.
    idt_set_gate(240, cast[uint64](&irq_stub_240))

    # Vector 242 (0xF2): cross-CPU RESCHEDULE IPI.  Same out-of-band
    # treatment; an idle AP takes this in ring0 to fall out of HLT.
    idt_set_gate(242, cast[uint64](&irq_stub_242))

    # Vector 243 (0xF3): cross-CPU CPU-STOP IPI.  Sent from the poweroff /
    # reboot path; the recipient AP parks permanently in cli;hlt so no core
    # spins/overheats if S5 fails to power the board down.
    idt_set_gate(243, cast[uint64](&irq_stub_243))

    idt_load(kpti_idt_table_addr())


def idt_load_ap():
    # Load the (global, BSP-built) IDT on a secondary CPU. The AP
    # trampoline lgdt's the kernel GDT but never lidt's an IDT, so an AP
    # could not take ANY interrupt — including the reschedule IPI that
    # wakes it from HLT. idt_table is shared (the gates point at the same
    # higher-half stubs that work from any CPU), so the AP just points its
    # IDTR at it. Called from ap_main_hamnix() before the AP enables
    # interrupt delivery. No re-init of the gates: idt_init() already
    # populated idt_table once on the BSP.
    idt_load(kpti_idt_table_addr())

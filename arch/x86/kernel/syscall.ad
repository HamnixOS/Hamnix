        # always switches to the FULL identity of the target user, not
        # a uid-only persona. Future fine-grained setresgid is out of
        # scope per docs/security.md ("no capabilities / ACLs in v1").
        new_uid: uint32 = cast[uint32](a0 & 0xFFFFFFFF)
        set_current_task_uid(new_uid)
        set_current_task_gid(new_uid)
        return 0

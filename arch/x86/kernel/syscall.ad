            if a1 == 0:
                set_current_errstr("netcfg: null route buffer")
                return cast[uint64](cast[int64](-1))
            ncr_stage: Array[13, uint8]
            if copy_from_user(cast[uint64](&ncr_stage[0]), a1,
                              ncr_len) != 0:
                set_current_errstr("netcfg: bad route buffer")
                return cast[uint64](-14)         # -EFAULT
            return cast[uint64](do_netcfg(a0,
                                          cast[uint64](&ncr_stage[0]),
                                          a2))
        if a0 == 5:
            # ROUTE_GET: do_netcfg fills 13 bytes for slot a2.
            if a1 == 0:
                set_current_errstr("netcfg: null route buffer")
                return cast[uint64](cast[int64](-1))
            if access_ok(a1, 13) == 0:
                set_current_errstr("netcfg: bad route buffer")
                return cast[uint64](-14)         # -EFAULT
            ncq_stage: Array[13, uint8]
            ncq_rc: int64 = do_netcfg(5, cast[uint64](&ncq_stage[0]),
                                      a2)
            if ncq_rc >= 0:
                if copy_to_user(a1, cast[uint64](&ncq_stage[0]),
                                13) != 0:
                    set_current_errstr("netcfg: bad route buffer")
                    return cast[uint64](-14)     # -EFAULT
            return cast[uint64](ncq_rc)

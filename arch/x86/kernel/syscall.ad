        # stack here. a0 = op; see SYS_NETCFG's comment above and
        # do_netcfg for the per-op argument layout.
        #
        # F2 #447 (DEPRECATED — Plan-9-shape replacement): the GET path
        # is /net/addr + /net/dns reads; the SET_ADDR/SET_GW arms move
        # onto /net/ipifc/ctl (verbs `add addr A mask M`, `add gw G`);
        # SET_DNS moves onto /net/dns (verb `server X.Y.Z.W`); the
        # ROUTE_ADD/ROUTE_DEL arms move onto /net/ipifc/ctl (verbs
        # `route add ...` / `route del ...`); the ROUTE_GET enumeration
        # remains as a SYS_NETCFG arm for now (a future
        # /net/ipifc/route directory would close the loop). The number
        # stays reserved (286) — do not reuse.
        #
        # uaccess (#163): the buffer-carrying ops (0=GET 24B out,
        # 4=ROUTE_ADD 13B in, 5=ROUTE_GET 13B out, 6=ROUTE_DEL 12B in)
        # are staged through kernel buffers here at the dispatch
        # boundary; do_netcfg only ever sees kernel memory (which also
        # keeps netcfg_smoke_test, which drives do_netcfg directly with
        # kernel buffers, honest). Scalar ops pass through unchanged.
        if a0 == 0:
            # GET: do_netcfg fills 24 bytes; copy them out.
            if a1 == 0:
                set_current_errstr("netcfg: null buffer")
                return cast[uint64](cast[int64](-1))
            if access_ok(a1, 24) == 0:
                set_current_errstr("netcfg: bad buffer address")
                return cast[uint64](-14)         # -EFAULT
            ncg_stage: Array[24, uint8]
            ncg_rc: int64 = do_netcfg(0, cast[uint64](&ncg_stage[0]), 0)
            if ncg_rc == 0:
                if copy_to_user(a1, cast[uint64](&ncg_stage[0]),
                                24) != 0:
                    set_current_errstr("netcfg: bad buffer address")
                    return cast[uint64](-14)     # -EFAULT
            return cast[uint64](ncg_rc)

        # open("/net/dns/rlookup", OWRITE), write "<a.b.c.d>\n", then
        # read the same fd to get the PTR name. The number stays
        # reserved (301) — do not reuse.
        # a0 = the target IPv4 packed big-endian in the low 32 bits
        # (octet 0 in bits 31:24, the same packing SYS_RESOLVE returns);
        # a1 = a userland buffer the decoded NUL-terminated PTR name is
        # copied into; a2 = that buffer's capacity. Builds the
        # in-addr.arpa QNAME and issues a PTR/type-12 query over the
        # same UDP/53 path SYS_RESOLVE uses. Returns 0 on success (name
        # written through a1), -2 (-ENOENT) on a null buffer / lookup
        # failure (timeout / NXDOMAIN / no DNS server).
        if a1 == 0 or a2 == 0:
            set_current_errstr("resolve_ptr: null buffer")
            return cast[uint64](-2)            # -ENOENT

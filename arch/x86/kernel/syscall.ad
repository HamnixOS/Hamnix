        # #sysroot's chan ref + partuuid (same partition). The next
        # boot's sentinel parse re-registers it from .hamnix-roots; this
        # just makes the home usable immediately without a remount.
        ua_sysroot: Array[8, uint8]
        ua_sysroot[0] = 0x73                       # 's'
        ua_sysroot[1] = 0x79                       # 'y'
        ua_sysroot[2] = 0x73                       # 's'
        ua_sysroot[3] = 0x72                       # 'r'
        ua_sysroot[4] = 0x6F                       # 'o'
        ua_sysroot[5] = 0x6F                       # 'o'
        ua_sysroot[6] = 0x74                       # 't'
        ua_sysroot[7] = 0
        sr_ref: uint64 = name_lookup_at(&ua_sysroot[0], 1)

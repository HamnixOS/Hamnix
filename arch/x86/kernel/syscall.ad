            # "table full". The two cases share an error string at
            # this milestone — `errstr` callers see one of these
            # two literals; a finer-grained distinction is V4.5 work
            # if a userspace tool needs to differentiate.
            set_current_errstr("srv: name in use or table full")
            return cast[uint64](-1)
        return 0
    if nr == SYS_SRV_OPEN:
        # Phase D / V4: look up (name) and dup the poster's underlying
        # file/pipe into the CALLER's fd table. a0 = NUL-terminated
        # leaf name (Ptr[char]). Returns the new fd on success or -1
        # with errstr on miss. The dup pattern follows sys_pipe and
        # sys_dup — _alloc_fd in the current task, then copy_fd_entry
        # bumps any pipe refcount so closing the poster's end doesn't
        # collapse the channel under the opener.
        if access_ok_str(a0) == 0:
            set_current_errstr("srv: bad name address")
            return cast[uint64](-14)             # -EFAULT
        srv_kname2: Array[64, uint8]
        if copyin_path(a0, &srv_kname2[0], 64) < 0:
            set_current_errstr("srv: bad name address")
            return cast[uint64](-14)             # -EFAULT
        nm2: Ptr[char] = cast[Ptr[char]](&srv_kname2[0])
        if _srv_name_valid(nm2) == 0:
            set_current_errstr("srv: bad name")
            return cast[uint64](-1)
        src_slot: int32 = -1
        src_fd:   int32 = -1
        rc2: int32 = devsrv_lookup_full(nm2, &src_slot, &src_fd)
        if rc2 < 0:
            set_current_errstr("srv: not posted")
            return cast[uint64](-1)
        if src_slot < 0:
            # Kernel-posted entry (devsrv_post via the V3 entry point);
            # no source TaskStruct to dup from. The opener gets a clear
            # error rather than a silent ENOENT.
            set_current_errstr("srv: kernel-only")
            return cast[uint64](-1)
        src_task: Ptr[TaskStruct] = task_struct_at(src_slot)
        if cast[uint64](src_task) == 0:
            set_current_errstr("srv: poster gone")
            return cast[uint64](-1)
        new_fd: int32 = vfs_srv_dup_into_current(src_task,
                                                 cast[uint64](src_fd))
        if new_fd < 0:
            set_current_errstr("srv: dup failed")
            return cast[uint64](-1)
        return cast[uint64](new_fd)
    if nr == SYS_REBOOT:
        # reboot(2). a0=magic1, a1=magic2, a2=cmd, a3=arg. Validate the
        # two magics (Linux rejects a bad magic with -EINVAL to guard
        # against accidental calls), gate on hostowner (same threat
        # model as SYS_SETUID / SYS_SET_REALTIME — only PID-1's uid-1
        # supervisor should be able to power the box), decode the cmd to
        # a POWER_* action, then funnel into the shared power_action
        # core. On the power-taking commands power_action never returns.
        if a0 != LINUX_REBOOT_MAGIC1 or a1 != LINUX_REBOOT_MAGIC2:
            set_current_errstr("reboot: bad magic")
            return cast[uint64](cast[int64](-22))            # -EINVAL
        # arch audit §3.2: power_action is kernel termination — no
        # /dev/reboot server file owns it. Gate through the named
        # helper so a future Plan-9 reshape moves policy in one place.
        if _syscall_require_hostowner("reboot") != 0:
            return cast[uint64](cast[int64](-1))
        if a2 == LINUX_REBOOT_CMD_POWER_OFF:
            power_action(POWER_POWEROFF)                     # never returns
            return 0
        if a2 == LINUX_REBOOT_CMD_RESTART:
            power_action(POWER_REBOOT)                       # never returns
            return 0
        if a2 == LINUX_REBOOT_CMD_HALT:
            power_action(POWER_HALT)                         # never returns
            return 0
        # Other Linux reboot cmds (CAD_ON/OFF, SW_SUSPEND, RESTART2,
        # KEXEC) are not modelled — accept the magics but no-op so a
        # guest's reboot(LINUX_REBOOT_CMD_CAD_OFF) startup call (glibc
        # does this) succeeds instead of erroring.
        return 0
    if nr == SYS_INIT_MODULE:
        # Linux-ABI .ko loader (L1). a0=Ptr[uint8] image, a1=size,
        # a2=Ptr[char] params (param string, NUL-terminated; can be
        # NULL or empty). Returns module slot id (>= 1) on success
        # or -errno on parse / OOM failure. The L1 loader ignores
        # `params`; the L2 milestone parses MODULE_PARM_DESC entries
        # and pushes the values into the module's .data section.
        #
        # uaccess (#163) DELIBERATE EXCEPTION: the .ko image can be
        # multiple MiB (iwlwifi + firmware), far beyond any fixed
        # kernel staging buffer, and the loader parses the ELF image
        # in place — converting this site needs either a chunked
        # module-image cursor in the loader or a large contiguous
        # kernel allocation (no vmalloc-equivalent exists). insmod is
        # a privileged provisioning path; the image pointer is range-
        # validated here and the raw read below still relies on the
        # identity map. Tracked as the follow-up to #163.
        if access_ok(a0, a1) == 0:
            set_current_errstr("init_module: bad image address")
            return cast[uint64](-14)             # -EFAULT
        # F4 #449: dispatch through the registered Layer-2 loader hook.
        # A pure-native build (no Linux .ko loader registered) returns
        # -ENOSYS so init_module fails cleanly rather than silently no-
        # op'ing.
        if kmod_linux_load_hook_sys \
                == cast[Fn[int32, Ptr[uint8], uint64]](0):
            set_current_errstr("init_module: no Linux .ko loader bound")
            return cast[uint64](cast[int64](-38))  # -ENOSYS
        rc: int32 = kmod_linux_load_hook_sys(cast[Ptr[uint8]](a0), a1)
        if rc < 0:
            set_current_errstr("init_module: bad image or out of slots")
        return cast[uint64](rc)
    if nr == SYS_DELETE_MODULE:
        # delete_module(name, flags). For L1 we ignore `name` (no
        # /proc/modules name index yet) and treat a0 as the slot id
        # returned by SYS_INIT_MODULE. Wrapped this way so userland
        # rmmod can write `delete_module(name=<slot encoded>, 0)`
        # without spinning up a full name->slot lookup. L2 grows the
        # name index.
        if kmod_linux_unload_hook_sys \
                == cast[Fn[int32, int32]](0):
            set_current_errstr("delete_module: no Linux .ko loader bound")
            return cast[uint64](cast[int64](-38))  # -ENOSYS
        rc: int32 = kmod_linux_unload_hook_sys(cast[int32](a0))
        if rc < 0:
            set_current_errstr("delete_module: not loaded")
        return cast[uint64](rc)
    # §142: native mmap/munmap/mprotect for Adder userland.
    # Arguments follow the Linux 6-arg mmap ABI: a0=addr, a1=length,
    # a2=prot, a3=flags, a4=fd, a5=offset. The entry stub already
    # forwards all six args (see M16.35 / U7 widening at line ~1751).
    if nr == SYS_MMAP:
        mmap_len: uint64 = a1
        if mmap_len == 0:
            set_current_errstr("mmap: zero length")
            return cast[uint64](cast[int64](-22))  # -EINVAL
        # Overflow check: addr + length must not wrap around.
        if a0 != 0:
            if a0 + mmap_len < a0:
                set_current_errstr("mmap: addr+len overflow")
                return cast[uint64](cast[int64](-22))
        mmap_prot:  int32 = cast[int32](a2)
        mmap_flags: int32 = cast[int32](a3)
        mmap_slot: uint64 = current_idx_get()
        # Detect fd=-1 (anonymous): both all-ones 32-bit and 64-bit forms.
        mmap_is_anon: int32 = 0
        if (mmap_flags & cast[int32](VMA_MAP_ANONYMOUS)) != 0:
            mmap_is_anon = 1
        elif a4 == cast[uint64](0xFFFFFFFFFFFFFFFF):
            mmap_is_anon = 1
        elif a4 == cast[uint64](0xFFFFFFFF):
            mmap_is_anon = 1
        if mmap_is_anon == 0:
            # §file-mmap: REAL file-backed mmap. Snapshot the fd's stable
            # backing identity (marker + backing id + total size) while it
            # is still open — the user may close the fd right after mmap
            # (POSIX) — then create a demand-paged file VMA. Each page is
            # read from the backing file lazily on #PF (vma_demand_fault's
            # is_file branch); a sub-page EOF tail reads as zero.
            fb_marker:  uint32 = 0
            fb_backing: uint64 = 0
            fb_size:    uint64 = 0
            fb_fd: int32 = cast[int32](a4)
            fb_rc: int32 = vfs_fd_backing_info(fb_fd, &fb_marker,
                                               &fb_backing, &fb_size)
            if fb_rc < 0:
                set_current_errstr("mmap: fd not a mappable file")
                return cast[uint64](cast[int64](fb_rc))
            # §shared-mmap: MAP_SHARED *writable* file-backed mmap. Dirty
            # pages are written back to the backing file on msync(MS_SYNC)
            # and on munmap/teardown (mm/vma.ad::vma_writeback_range via the
            # is_file_shared VMA). This requires a WRITABLE backing store —
            # an initramfs (cpio) file is read-only, so reject a MAP_SHARED
            # writable mapping over one with -EROFS rather than mapping
            # pages we can never flush. tmpfs / ext4 / buffer backings are
            # writable and route to vfs_pwrite_backing. MAP_SHARED read-only
            # and any MAP_PRIVATE mapping keep the demand path unchanged.
            fb_is_shared: int32 = 0
            if (mmap_flags & cast[int32](VMA_MAP_SHARED)) != 0:
                fb_is_shared = 1
            if fb_is_shared != 0 and (mmap_prot & cast[int32](VMA_PROT_WRITE)) != 0:
                if fb_marker == FD_FILEMMAP_INITRAMFS:
                    set_current_errstr("mmap: MAP_SHARED writable on read-only initramfs")
                    return cast[uint64](cast[int64](-30))  # -EROFS
                smrc: int64 = vma_alloc_file_shared(mmap_slot, a0, mmap_len,
                                                    mmap_prot, mmap_flags,
                                                    cast[int32](fb_marker),
                                                    fb_backing, fb_size, a5)
                if smrc < 0:
                    set_current_errstr("mmap: MAP_SHARED file-backed allocation failed")
                return cast[uint64](smrc)
            fmrc: int64 = vma_alloc_file_demand(mmap_slot, a0, mmap_len,
                                                mmap_prot, mmap_flags,
                                                cast[int32](fb_marker),
                                                fb_backing, fb_size, a5)
            if fmrc < 0:
                set_current_errstr("mmap: file-backed allocation failed")
            return cast[uint64](fmrc)
        # §hugepage: MAP_HUGETLB anonymous mmap — back the region with real
        # 2 MiB huge pages (one PS=1 PDE per 2 MiB) instead of 4 KiB pages.
        # Linux/hugetlbfs requires the LENGTH to be a multiple of the huge
        # size (2 MiB); reject an unaligned length with -EINVAL. A non-zero
        # MAP_FIXED addr must also be 2 MiB-aligned (re-checked in the
        # allocator). MAP_SHARED hugetlb is not modelled here (sharing huge
        # frames needs the eager/refcount path); reject it -EINVAL so the
        # caller can fall back to a MAP_PRIVATE huge mapping or 4 KiB pages.
        if (mmap_flags & cast[int32](VMA_MAP_HUGETLB)) != 0:
            if (mmap_len & (VMA_HUGE_SIZE - 1)) != 0:
                set_current_errstr("mmap: MAP_HUGETLB length not 2MiB-aligned")
                return cast[uint64](cast[int64](-22))  # -EINVAL
            if (mmap_flags & cast[int32](VMA_MAP_SHARED)) != 0:
                set_current_errstr("mmap: MAP_SHARED|MAP_HUGETLB unsupported")
                return cast[uint64](cast[int64](-22))  # -EINVAL
            hmrc: int64 = vma_alloc_huge_demand(mmap_slot, a0, mmap_len,
                                                mmap_prot, mmap_flags)
            if hmrc < 0:
                set_current_errstr("mmap: MAP_HUGETLB allocation failed")
            return cast[uint64](hmrc)
        # MAP_SHARED anonymous: use eager allocation (sharing requires
        # pages to exist and be visible in both tasks).
        is_shared_mmap: int32 = 0
        if (mmap_flags & cast[int32](VMA_MAP_SHARED)) != 0:
            is_shared_mmap = 1
        if is_shared_mmap != 0:
            mrc: int64 = vma_alloc(mmap_slot, a0, mmap_len, mmap_prot,
                                   mmap_flags, -1, 0)
            if mrc < 0:
                set_current_errstr("mmap: MAP_SHARED allocation failed")
            return cast[uint64](mrc)
        # Anonymous MAP_PRIVATE: use demand-paged allocation (§142).
        dmrc: int64 = vma_alloc_demand(mmap_slot, a0, mmap_len, mmap_prot,
                                       mmap_flags)
        if dmrc < 0:
            set_current_errstr("mmap: demand allocation failed")
        return cast[uint64](dmrc)
    if nr == SYS_MPROTECT:
        mprot_slot: uint64 = current_idx_get()
        mprot_rc: int64 = vma_protect(mprot_slot, a0, a1, cast[int32](a2))
        if mprot_rc < 0:
            set_current_errstr("mprotect: failed")
        return cast[uint64](mprot_rc)
    if nr == SYS_MUNMAP:
        munmap_slot: uint64 = current_idx_get()
        munmap_rc: int64 = vma_unmap(munmap_slot, a0, a1)
        if munmap_rc < 0:
            set_current_errstr("munmap: failed")
        return cast[uint64](munmap_rc)
    # §shared-mmap: msync(addr, len, flags). a2=flags (MS_ASYNC=1,
    # MS_INVALIDATE=2, MS_SYNC=4). For a MAP_SHARED writable file-backed
    # mapping, flush the dirtied resident pages in [addr, addr+len) back
    # to the backing file. We treat MS_SYNC and MS_ASYNC identically
    # (synchronous flush — there is no deferred write-back queue), and a
    # range with no file-shared VMA is a successful no-op (like Linux
    # msync of an anonymous / read-only mapping). addr must be page-
    # aligned, matching POSIX.
    if nr == SYS_MSYNC:
        if (a0 & (0x1000 - 1)) != 0:
            set_current_errstr("msync: addr not page-aligned")
            return cast[uint64](cast[int64](-22))   # -EINVAL
        msync_slot: uint64 = current_idx_get()
        msync_rc: int64 = vma_writeback_range(msync_slot, a0, a1)
        if msync_rc < 0:
            set_current_errstr("msync: writeback failed")
        return cast[uint64](msync_rc)
    # #458 F10-6: Plan 9 Dir-record directory read. a0=path,
    # a1=user buf, a2=count. Renders the directory at `path` as a
    # stream of Dir wire-format records (see lib/p9dir.ad) into a
    # bounce buffer, then copy_to_user's into a1. v1 routes /srv to
    # devsrv_list_dir; other paths return -ENOSYS until their backings
    # migrate. Co-exists with the legacy NAME\n directory read path.
    if nr == SYS_LISTDIR_RECORDS:
        if access_ok_str(a0) == 0:
            set_current_errstr("listdir_records: bad path address")
            return cast[uint64](-14)             # -EFAULT
        ldr_path: Array[256, uint8]
        if copyin_path(a0, &ldr_path[0], 256) < 0:
            set_current_errstr("listdir_records: path too long")
            return cast[uint64](-14)             # -EFAULT
        # Bounce buffer cap. Same shape as SYS_READ — kernel renders
        # into a fixed BSS buffer then copy_to_user's the requested
        # tail. 4 KiB matches the userspace cursor's _p9_diread_buf cap.
        ldr_cap: uint64 = a2
        if ldr_cap > 4096:
            ldr_cap = 4096
        ldr_bounce: Array[4096, uint8]
        # /srv: devsrv_list_dir emitter.
        ldr_n: int64 = -38                       # -ENOSYS sentinel
        ldr_routed: int32 = 0
        if devsrv_is_srv_dir(cast[Ptr[char]](&ldr_path[0])) != 0:
            ldr_n = devsrv_list_dir(
                cast[Ptr[uint8]](&ldr_bounce[0]), ldr_cap)
            ldr_routed = 1
        # #458 F10-6 expansion: /proc, /proc/<pid>, /proc/self/...
        if ldr_routed == 0:
            if ldr_path[0] == 47 and ldr_path[1] == 112 \
                    and ldr_path[2] == 114 and ldr_path[3] == 111 \
                    and ldr_path[4] == 99 \
                    and (ldr_path[5] == 0 or ldr_path[5] == 47):
                # subpath after "/proc": "" or "/<pid>"
                ldr_sub: Ptr[char] = cast[Ptr[char]](&ldr_path[5])
                ldr_n = devproc_list_dir(
                    ldr_sub,
                    cast[Ptr[uint8]](&ldr_bounce[0]), ldr_cap)
                ldr_routed = 1
        # #458 F10-6 expansion: /net, /net/<sub>
        if ldr_routed == 0:
            if ldr_path[0] == 47 and ldr_path[1] == 110 \
                    and ldr_path[2] == 101 and ldr_path[3] == 116 \
                    and (ldr_path[4] == 0 or ldr_path[4] == 47):
                ldr_sub2: Ptr[char] = cast[Ptr[char]](&ldr_path[4])
                ldr_n = devnet_list_dir(
                    ldr_sub2,
                    cast[Ptr[uint8]](&ldr_bounce[0]), ldr_cap)
                ldr_routed = 1
        # #458 F10-6 expansion: /dev/blk (whole-disk + partition list).
        if ldr_routed == 0:
            if ldr_path[0] == 47 and ldr_path[1] == 100 \
                    and ldr_path[2] == 101 and ldr_path[3] == 118 \
                    and ldr_path[4] == 47 and ldr_path[5] == 98 \
                    and ldr_path[6] == 108 and ldr_path[7] == 107 \
                    and ldr_path[8] == 0:
                ldr_n = blk_list_dir(
                    cast[Ptr[uint8]](&ldr_bounce[0]), ldr_cap)
                ldr_routed = 1
        # #458 F10-6 (this wave): /dev/auth — devauth slot list.
        # Matched BEFORE the generic /dev arm below because "/dev/auth"
        # also matches the /dev prefix walk; route the more-specific
        # path first.
        if ldr_routed == 0:
            if ldr_path[0] == 47 and ldr_path[1] == 100 \
                    and ldr_path[2] == 101 and ldr_path[3] == 118 \
                    and ldr_path[4] == 47 and ldr_path[5] == 97 \
                    and ldr_path[6] == 117 and ldr_path[7] == 116 \
                    and ldr_path[8] == 104 and ldr_path[9] == 0:
                ldr_n = devauth_list_dir(
                    cast[Ptr[uint8]](&ldr_bounce[0]), ldr_cap)
                ldr_routed = 1
        # #458 F10-6 (this wave): /dev — devcons-served #c dev-server.
        # Matched AFTER the more-specific /dev/blk and /dev/auth arms.
        if ldr_routed == 0:
            if ldr_path[0] == 47 and ldr_path[1] == 100 \
                    and ldr_path[2] == 101 and ldr_path[3] == 118 \
                    and ldr_path[4] == 0:
                ldr_n = devcons_list_dir(
                    cast[Ptr[uint8]](&ldr_bounce[0]), ldr_cap)
                ldr_routed = 1
        # #458 F10-6 (this wave): /tmp[/...] + /var[/...] — tmpfs.
        if ldr_routed == 0:
            if ldr_path[0] == 47 and ldr_path[1] == 116 \
                    and ldr_path[2] == 109 and ldr_path[3] == 112 \
                    and (ldr_path[4] == 0 or ldr_path[4] == 47):
                ldr_n = tmpfs_list_dir(
                    cast[Ptr[char]](&ldr_path[0]),
                    cast[Ptr[uint8]](&ldr_bounce[0]), ldr_cap)
                ldr_routed = 1
        if ldr_routed == 0:
            if ldr_path[0] == 47 and ldr_path[1] == 118 \
                    and ldr_path[2] == 97 and ldr_path[3] == 114 \
                    and (ldr_path[4] == 0 or ldr_path[4] == 47):
                ldr_n = tmpfs_list_dir(
                    cast[Ptr[char]](&ldr_path[0]),
                    cast[Ptr[uint8]](&ldr_bounce[0]), ldr_cap)
                ldr_routed = 1
        if ldr_routed != 0:
            if ldr_n < 0:
                set_current_errstr("listdir_records: emit failed")
                return cast[uint64](cast[int64](-5))   # -EIO
            if copy_to_user(a1, cast[uint64](&ldr_bounce[0]),
                            cast[uint64](ldr_n)) != 0:
                set_current_errstr("listdir_records: bad buffer address")
                return cast[uint64](-14)            # -EFAULT
            return cast[uint64](ldr_n)
        # Other directory backings keep emitting NAME\n until migrated.
        # Return -ENOSYS so callers can fall back to p9_listdir.
        set_current_errstr("listdir_records: backing not Dir-mode yet")
        return cast[uint64](cast[int64](-38))    # -ENOSYS
    # F10-6 followup: SYS_CHAN_DIR_MODE — flip a dir fd's Chan into
    # Dir-record mode. a0=fd, a1=mode, a2=path (parent path for stat).
    if nr == SYS_CHAN_DIR_MODE:
        cdm_fd: int32 = cast[int32](a0)
        if cdm_fd < 0 or cdm_fd >= 16:
            set_current_errstr("chan_dir_mode: bad fd")
            return cast[uint64](cast[int64](-9))      # -EBADF
        if access_ok_str(a2) == 0:
            set_current_errstr("chan_dir_mode: bad path address")
            return cast[uint64](-14)                  # -EFAULT
        cdm_path: Array[256, uint8]
        if copyin_path(a2, &cdm_path[0], 256) < 0:
            set_current_errstr("chan_dir_mode: path too long")
            return cast[uint64](-14)                  # -EFAULT
        cdm_task: Ptr[TaskStruct] = fd_owner_task(current_task())
        cdm_fdu: uint64 = cast[uint64](cdm_fd)
        cdm_file_idx: uint32 = cdm_task[0].fd_idx[cdm_fdu]
        if cdm_file_idx != FD_CHAN_MARK:
            set_current_errstr("chan_dir_mode: not a chan fd")
            return cast[uint64](cast[int64](-9))      # -EBADF
        cdm_cid: int32 = cast[int32](cast[uint32](cdm_task[0].fd_buf[cdm_fdu]))
        cdm_rc: int32 = vfs_chan_p9_dir_mode_set(
            cdm_cid, cast[int32](a1),
            cast[Ptr[uint8]](&cdm_path[0]))
        if cdm_rc != 0:
            set_current_errstr("chan_dir_mode: flip failed")
            return cast[uint64](cast[int64](-22))     # -EINVAL
        return 0
    # M16.x §links: symlink(2) — create a symbolic link.
    # a0 = target string (content of the symlink, what it points to)
    # a1 = linkpath (where the symlink is created in the namespace)
    # Both must be user-readable NUL-terminated strings.
    if nr == SYS_SYMLINK:
        if access_ok_str(a0) == 0:
            set_current_errstr("symlink: bad target address")
            return cast[uint64](-14)             # -EFAULT
        if access_ok_str(a1) == 0:
            set_current_errstr("symlink: bad linkpath address")
            return cast[uint64](-14)             # -EFAULT
        sym_tgt: Array[256, uint8]
        if copyin_path(a0, &sym_tgt[0], 256) < 0:
            set_current_errstr("symlink: bad target address")
            return cast[uint64](-14)             # -EFAULT
        sym_link: Array[256, uint8]
        if copyin_path(a1, &sym_link[0], 256) < 0:
            set_current_errstr("symlink: bad linkpath address")
            return cast[uint64](-14)             # -EFAULT
        sym_abs: Array[256, uint8]
        sym_rc: int32 = resolve_path(cast[Ptr[char]](&sym_link[0]), &sym_abs[0], 256)
        if sym_rc != 0:
            set_current_errstr("symlink: linkpath too long")
            return cast[uint64](sym_rc)
        sym_res: int32 = vfs_symlink(cast[Ptr[char]](&sym_tgt[0]),
                                      cast[Ptr[char]](&sym_abs[0]))
        if sym_res < 0:
            set_current_errstr("symlink: cannot create symlink")
        return cast[uint64](sym_res)
    # M16.x §links: link(2) — create a hard link with namespace/file-server
    # boundary enforcement.
    # a0 = oldpath (the existing file)
    # a1 = newpath (the new name to create)
    # Rejects cross-file-server links with -EXDEV (-18). The rejection
    # is based on the file SERVER in the caller's namespace (Plan 9 model),
    # NOT on POSIX uid/gid/mode bits.
    if nr == SYS_LINK:
        if access_ok_str(a0) == 0:
            set_current_errstr("link: bad oldpath address")
            return cast[uint64](-14)             # -EFAULT
        if access_ok_str(a1) == 0:
            set_current_errstr("link: bad newpath address")
            return cast[uint64](-14)             # -EFAULT
        lnk_uold: Array[256, uint8]
        lnk_unew: Array[256, uint8]
        if copyin_path(a0, &lnk_uold[0], 256) < 0:
            set_current_errstr("link: bad oldpath address")
            return cast[uint64](-14)             # -EFAULT
        if copyin_path(a1, &lnk_unew[0], 256) < 0:
            set_current_errstr("link: bad newpath address")
            return cast[uint64](-14)             # -EFAULT
        lnk_old: Array[256, uint8]
        lnk_new: Array[256, uint8]
        lnk_rc: int32 = resolve_path(cast[Ptr[char]](&lnk_uold[0]), &lnk_old[0], 256)
        if lnk_rc != 0:
            set_current_errstr("link: oldpath too long")
            return cast[uint64](lnk_rc)
        lnk_rc = resolve_path(cast[Ptr[char]](&lnk_unew[0]), &lnk_new[0], 256)
        if lnk_rc != 0:
            set_current_errstr("link: newpath too long")
            return cast[uint64](lnk_rc)
        lnk_res: int32 = vfs_link(cast[Ptr[char]](&lnk_old[0]),
                                    cast[Ptr[char]](&lnk_new[0]))
        if lnk_res == EXDEV_LINK:
            set_current_errstr("link: cross-server link not permitted")
        elif lnk_res < 0:
            set_current_errstr("link: cannot create link")
        return cast[uint64](lnk_res)
    # §146: SYS_CLOCK_GETTIME — write struct timespec {i64 tv_sec; i64 tv_nsec}
    # to user pointer a1. Resolution: TSC nanoseconds (calibrated at boot);
    # falls back to 10 ms jiffies before TSC calibration completes.
    #
    # clockid 0 = CLOCK_REALTIME:  wall clock = RTC boot epoch + monotonic delta.
    # clockid 1 = CLOCK_MONOTONIC: nanoseconds since tsc_init() (boot).
    if nr == SYS_CLOCK_GETTIME:
        if a1 == 0:
            set_current_errstr("clock_gettime: null timespec")
            return cast[uint64](cast[int64](-22))     # -EINVAL
        cgt_clk: uint64 = a0
        if cgt_clk != CLOCK_REALTIME and cgt_clk != CLOCK_MONOTONIC:
            set_current_errstr("clock_gettime: unknown clockid")
            return cast[uint64](cast[int64](-22))     # -EINVAL
        if access_ok(a1, 16) == 0:
            set_current_errstr("clock_gettime: bad timespec pointer")
            return cast[uint64](cast[int64](-14))     # -EFAULT
        cgt_mono_ns: uint64 = tsc_monotonic_ns()
        cgt_sec:  uint64 = 0
        cgt_nsec: uint64 = 0
        if cgt_clk == CLOCK_REALTIME:
            cgt_base: uint64 = rtc_boot_epoch_get()
            cgt_sec  = cgt_base + (cgt_mono_ns / 1000000000)
            cgt_nsec = cgt_mono_ns % 1000000000
        else:
            cgt_sec  = cgt_mono_ns / 1000000000
            cgt_nsec = cgt_mono_ns % 1000000000
        # Stage B: write the timespec back through the translated
        # uaccess path rather than a raw deref. put_user_64 walks the
        # current task's page tables; under today's identity map this is
        # the same physical write, but it stays correct once the user
        # stack / mmap region sits at a vaddr != phys (ASLR).
        if put_user_64(cgt_sec, a1) != 0:
            set_current_errstr("clock_gettime: bad timespec pointer")
            return cast[uint64](cast[int64](-14))     # -EFAULT
        if put_user_64(cgt_nsec, a1 + 8) != 0:
            set_current_errstr("clock_gettime: bad timespec pointer")
            return cast[uint64](cast[int64](-14))     # -EFAULT
        return 0
    # §146: SYS_NANOSLEEP — cooperative sleep for the duration in *a0.
    # Reads struct timespec {i64 tv_sec; i64 tv_nsec} from user pointer a0.
    # On return, *a1 (if non-zero) holds the remaining time (always zero on
    # normal completion — we never deliver partial-sleep semantics at this
    # scale). Accuracy: jiffy-granular (10 ms at HZ=100). The task yields
    # cooperatively via kernel_cond_resched (sti+hlt+cli per loop iteration)
    # so other tasks run during the sleep — it does NOT busy-spin.
    if nr == SYS_NANOSLEEP:
        if a0 == 0:
            set_current_errstr("nanosleep: null req")
            return cast[uint64](cast[int64](-22))     # -EINVAL
        if access_ok(a0, 16) == 0:
            set_current_errstr("nanosleep: bad req pointer")
            return cast[uint64](cast[int64](-14))     # -EFAULT
        # Stage B: read the request timespec through the translated
        # uaccess path. get_user_64 walks the current task's page tables.
        ns_req_sec:  uint64 = 0
        ns_req_nsec: uint64 = 0
        if get_user_64(a0, &ns_req_sec) != 0 \
                or get_user_64(a0 + 8, &ns_req_nsec) != 0:
            set_current_errstr("nanosleep: bad req pointer")
            return cast[uint64](cast[int64](-14))     # -EFAULT
        # Convert request to nanoseconds for TSC-based deadline.
        ns_dur_ns: uint64 = ns_req_sec * 1000000000 + ns_req_nsec
        if ns_dur_ns == 0:
            # Zero duration — yield once, return immediately.
            yield_to_others()
            if a1 != 0 and access_ok(a1, 16) != 0:
                # Stage B: zero the remaining-time struct through the
                # translated path (ignore residual — best-effort rem).
                clear_user(a1, 16)
            return 0
        ns_start: uint64 = tsc_monotonic_ns()
        ns_deadline: uint64 = ns_start + ns_dur_ns
        # Spin-with-yield: each iteration does sti+hlt+cli (at most 10 ms)
        # then re-checks the TSC. The hlt ensures the CPU idles and the LAPIC
        # timer fires, advancing jiffies and allowing other tasks to schedule.
        while tsc_monotonic_ns() < ns_deadline:
            kernel_cond_resched()
        if a1 != 0 and access_ok(a1, 16) != 0:
            # Stage B: zero the remaining-time struct through the
            # translated path (ignore residual — best-effort rem).
            clear_user(a1, 16)
        return 0
    # §146: SYS_TIMERFD_CREATE — allocate a timerfd from the u_epoll.ad
    # pool and return a real fd. clockid 0 (CLOCK_REALTIME) and 1
    # (CLOCK_MONOTONIC) are both accepted; both use the same jiffy-clock
    # backend (10 ms resolution). The fd becomes readable after the timer
    # set by SYS_TIMERFD_SETTIME expires; read(8) returns the expiry count.
    if nr == SYS_TIMERFD_CREATE:
        tfd_clk: uint64 = a0
        if tfd_clk != CLOCK_REALTIME and tfd_clk != CLOCK_MONOTONIC:
            set_current_errstr("timerfd_create: unsupported clockid")
            return cast[uint64](cast[int64](-22))     # -EINVAL
        # F4 #449: dispatch through the registered timerfd-pool hooks.
        # No hook registered → no timerfd pool in this build → -ENOSYS.
        if timerfd_alloc_hook == cast[Fn[int32]](0) \
                or timerfd_mark_hook == cast[Fn[uint32]](0):
            set_current_errstr("timerfd_create: no timerfd pool bound")
            return cast[uint64](cast[int64](-38))     # -ENOSYS
        tfd_ts: int32 = timerfd_alloc_hook()
        if tfd_ts < 0:
            set_current_errstr("timerfd_create: object pool exhausted")
            return cast[uint64](cast[int64](-24))     # -EMFILE
        tfd_fd: int32 = vfs_alloc_l2_fd(timerfd_mark_hook())
        if tfd_fd < 0:
            set_current_errstr("timerfd_create: out of fd slots")
            return cast[uint64](cast[int64](-24))     # -EMFILE
        if vfs_l2_fd_set_buf(tfd_fd, cast[uint64](tfd_ts + 1)) != 0:
            vfs_close(tfd_fd)
            return cast[uint64](cast[int64](-9))      # -EBADF
        return cast[uint64](tfd_fd)
    # §146: SYS_TIMERFD_SETTIME — arm or disarm a timerfd.
    # a0=fd, a1=flags (ignored at this scale), a2=Ptr[itimerspec new],
    # a3=Ptr[itimerspec old] (may be 0; receives the previous setting).
    # struct itimerspec { struct timespec it_interval; struct timespec it_value; }
    # — it_interval at offset 0 (16 bytes), it_value at offset 16.
    # One-shot: it_interval = {0,0}. Periodic: it_interval = repeat period.
    # Disarm: it_value = {0,0}.
    if nr == SYS_TIMERFD_SETTIME:
        tst_fd: int32 = cast[int32](a0)
        # F4 #449: same hook dispatch as SYS_TIMERFD_CREATE.
        if timerfd_mark_hook == cast[Fn[uint32]](0) \
                or timerfd_valid_hook == cast[Fn[int32, int32]](0) \
                or timerfd_arm_hook == cast[Fn[int64, int32, uint64, uint64]](0):
            set_current_errstr("timerfd_settime: no timerfd pool bound")
            return cast[uint64](cast[int64](-38))     # -ENOSYS
        if vfs_fd_marker(tst_fd) != timerfd_mark_hook():
            set_current_errstr("timerfd_settime: not a timerfd")
            return cast[uint64](cast[int64](-9))      # -EBADF
        tst_ts: int32 = cast[int32](vfs_l2_fd_get_buf(tst_fd)) - 1
        if timerfd_valid_hook(tst_ts) == 0:
            set_current_errstr("timerfd_settime: bad timerfd slot")
            return cast[uint64](cast[int64](-9))      # -EBADF
        if a2 == 0:
            set_current_errstr("timerfd_settime: null itimerspec")
            return cast[uint64](cast[int64](-22))     # -EINVAL
        if access_ok(a2, 32) == 0:
            set_current_errstr("timerfd_settime: bad new pointer")
            return cast[uint64](cast[int64](-14))     # -EFAULT
        # uaccess: read the itimerspec through get_user_64 (page-table
        # walked) rather than raw cast[Ptr[uint64]](a2)[..] derefs.
        # it_interval: offset 0 = sec (8 bytes), offset 8 = nsec (8 bytes)
        tst_iv_sec:  uint64 = 0
        tst_iv_nsec: uint64 = 0
        # it_value: offset 16 = sec, offset 24 = nsec
        tst_vl_sec:  uint64 = 0
        tst_vl_nsec: uint64 = 0
        if get_user_64(a2, &tst_iv_sec) != 0 \
                or get_user_64(a2 + 8, &tst_iv_nsec) != 0 \
                or get_user_64(a2 + 16, &tst_vl_sec) != 0 \
                or get_user_64(a2 + 24, &tst_vl_nsec) != 0:
            set_current_errstr("timerfd_settime: bad new pointer")
            return cast[uint64](cast[int64](-14))     # -EFAULT
        # Convert timespec -> jiffies (HZ=100 -> 1 jiffy = 10 ms).
        # Sub-jiffy durations round up to 1 jiffy so even a tiny delay fires.
        tst_iv_j: uint64 = tst_iv_sec * 100 + tst_iv_nsec / 10000000
        if tst_iv_j == 0:
            if tst_iv_sec != 0 or tst_iv_nsec != 0:
                tst_iv_j = 1
        tst_vl_j: uint64 = tst_vl_sec * 100 + tst_vl_nsec / 10000000
        if tst_vl_j == 0:
            if tst_vl_sec != 0 or tst_vl_nsec != 0:
                tst_vl_j = 1
        # If caller wants the old setting, write it before arming.
        if a3 != 0 and access_ok(a3, 32) != 0:
            tst_old_iv: uint64 = 0
            tst_old_rm: uint64 = 0
            if timerfd_gettime_interval_hook \
                    != cast[Fn[uint64, int32]](0):
                tst_old_iv = timerfd_gettime_interval_hook(tst_ts)
            if timerfd_gettime_remaining_hook \
                    != cast[Fn[uint64, int32]](0):
                tst_old_rm = timerfd_gettime_remaining_hook(tst_ts)
            # uaccess: write the old itimerspec through put_user_64.
            # it_interval (old)
            put_user_64(tst_old_iv / 100, a3)
            put_user_64((tst_old_iv % 100) * 10000000, a3 + 8)
            # it_value (old remaining)
            put_user_64(tst_old_rm / 100, a3 + 16)
            put_user_64((tst_old_rm % 100) * 10000000, a3 + 24)
        tst_rc: int64 = timerfd_arm_hook(tst_ts, tst_vl_j, tst_iv_j)
        if tst_rc < 0:
            set_current_errstr("timerfd_settime: arm failed")
        return cast[uint64](tst_rc)
    printk2("Hamnix: unknown syscall nr=%d a0=%x\n", nr, a0)
    set_current_errstr("unknown syscall")
    return cast[uint64](-1)


# --- SYS_NETCFG: network info + static configuration ----------------
#
# The single kernel choke point behind the `ifconfig` command. The
# IPv4 stack's address / netmask / gateway live in drivers/net/ip.ad;
# the DNS resolver in drivers/net/dns.ad; the DHCP lease state in
# drivers/net/dhcp.ad. do_netcfg bridges all three to userland.
#
# op 0 (GET): a1 = Ptr to a 24-byte buffer. Layout (every IP is 4
#   bytes, network order):
#     [0..3]   our IPv4 address       (zeros if unset)
#     [4..7]   netmask                (zeros if unset)
#     [8..11]  default gateway        (zeros if unset)
#     [12..15] DNS server             (zeros if unset)
#     [16]     have_addr   (0/1)
#     [17]     have_mask   (0/1)
#     [18]     have_gw     (0/1)
#     [19]     have_dns    (0/1)
#     [20]     cfg_source  (0=none, 1=DHCP, 2=static)  — for addr/gw
#     [21]     dns_source  (0=DHCP, 1=static)
#     [22..23] reserved (zeroed)
#   Returns 0.
#
# op 1 (SET_ADDR): a1 = address packed (octet0<<24 | .. | octet3),
#   a2 = netmask packed the same way. Installs a STATIC address +
#   mask (latches ip_cfg_source = static). Returns 0.
#
# op 2 (SET_GW): a1 = gateway packed. Installs a STATIC gateway.
#   Returns 0.
#
# op 3 (SET_DNS): a1 = DNS server packed. Pins a STATIC resolver.
#   Returns 0.
#
# op 4 (ROUTE_ADD): a1 = Ptr to a 13-byte route descriptor; a2 unused.
#   Installs (or replaces) an IPv4 FIB route — the native Plan-9-style
#   ctl path behind `route add -net <net> netmask <m> gw <gw>`. Layout:
#     [0..3]   destination network (network order)
#     [4..7]   netmask             (network order)
#     [8..11]  gateway             (network order; ignored when on-link)
#     [12]     onlink flag (1 = directly reachable, ARP dst not gw)
#   Returns 0 on success, -1 if the FIB is full or the buffer is bad.
#
# op 5 (ROUTE_GET): a1 = Ptr to a buffer, a2 = slot index. Reads one
#   operator FIB slot. Buffer layout (13 bytes, mirrors ROUTE_ADD plus a
#   used flag):
#     [0..3]   network   [4..7] netmask   [8..11] gateway
#     [12]     flags: bit0 = in-use, bit1 = on-link
#   Returns the FIB capacity (number of slots) so the caller can bound
#   its iteration, or -1 on a bad buffer / out-of-range slot. Each ECMP
#   nexthop of a multipath prefix occupies its own slot, so iterating
#   slots surfaces the whole nexthop group (several rows, same net/mask,
#   different gateways).
#
# op 6 (ROUTE_DEL): a1 = Ptr to a 12-byte descriptor (net[4] mask[4]
#   gw[4]); a2 unused. Removes a SINGLE nexthop (net, mask, gw) from the
#   FIB — for an ECMP group this deletes just that one path and leaves
#   the rest intact. Returns 0 if a nexthop was removed, -1 otherwise.
#
# Any other op returns -1 with errstr.

def do_netcfg(op: uint64, a1: uint64, a2: uint64) -> int64:
    if op == 0:
        # GET — fill the caller's 24-byte buffer.
        if a1 == 0:
            set_current_errstr("netcfg: null buffer")
            return -1
        # a1 is a KERNEL staging buffer: the dispatch boundary (#163)
        # already access_ok'd the user pointer and copy_to_user's the
        # result back out. Do NOT access_ok(a1) here — a kernel address
        # is >= USER_ADDR_MAX and would spuriously fail (the GET-returns
        # -EFAULT regression that made `ifconfig`/hamctl/route report
        # "cannot read network config").
        buf: Ptr[uint8] = cast[Ptr[uint8]](a1)
        i: uint64 = 0
        while i < 24:
            buf[i] = 0
            i = i + 1
        have_addr: int32 = ip_have_our_ip()
        have_gw:   int32 = ip_have_gateway()
        have_mask: int32 = ip_have_netmask()
        if have_addr == 1:
            buf[0] = ip_our_ip_b(0)
            buf[1] = ip_our_ip_b(1)
            buf[2] = ip_our_ip_b(2)
            buf[3] = ip_our_ip_b(3)
            buf[16] = 1
        if have_mask == 1:
            buf[4] = ip_netmask_b(0)
            buf[5] = ip_netmask_b(1)
            buf[6] = ip_netmask_b(2)
            buf[7] = ip_netmask_b(3)
            buf[17] = 1
        else:
            # ip.ad has no mask of its own — surface what DHCP knows
            # (option 1 from the OFFER/ACK) so the display is honest
            # even if the install path didn't carry the mask.
            dmask: Array[4, uint8]
            if dhcp_get_mask(cast[Ptr[uint8]](&dmask[0])) == 0:
                buf[4] = dmask[0]
                buf[5] = dmask[1]
                buf[6] = dmask[2]
                buf[7] = dmask[3]
                buf[17] = 1
        if have_gw == 1:
            buf[8]  = ip_gateway_b(0)
            buf[9]  = ip_gateway_b(1)
            buf[10] = ip_gateway_b(2)
            buf[11] = ip_gateway_b(3)
            buf[18] = 1
        dns_tmp: Array[4, uint8]
        dns_rc: int32 = dns_get_server(cast[Ptr[uint8]](&dns_tmp[0]))
        if dns_rc >= 0:
            buf[12] = dns_tmp[0]
            buf[13] = dns_tmp[1]
            buf[14] = dns_tmp[2]
            buf[15] = dns_tmp[3]
            buf[19] = 1
            if dns_rc == 1:
                buf[21] = 1
        buf[20] = ip_cfg_source_get()
        return 0
    if op == 1:
        # SET_ADDR — a1 = packed address, a2 = packed netmask.
        addr0: uint8 = cast[uint8]((a1 >> 24) & 0xFF)
        addr1: uint8 = cast[uint8]((a1 >> 16) & 0xFF)
        addr2: uint8 = cast[uint8]((a1 >> 8) & 0xFF)
        addr3: uint8 = cast[uint8](a1 & 0xFF)
        mask0: uint8 = cast[uint8]((a2 >> 24) & 0xFF)
        mask1: uint8 = cast[uint8]((a2 >> 16) & 0xFF)
        mask2: uint8 = cast[uint8]((a2 >> 8) & 0xFF)
        mask3: uint8 = cast[uint8](a2 & 0xFF)
        ip_apply_static_addr(addr0, addr1, addr2, addr3,
                             mask0, mask1, mask2, mask3)
        return 0
    if op == 2:
        # SET_GW — a1 = packed gateway.
        gw0: uint8 = cast[uint8]((a1 >> 24) & 0xFF)
        gw1: uint8 = cast[uint8]((a1 >> 16) & 0xFF)
        gw2: uint8 = cast[uint8]((a1 >> 8) & 0xFF)
        gw3: uint8 = cast[uint8](a1 & 0xFF)
        ip_apply_static_gw(gw0, gw1, gw2, gw3)
        return 0
    if op == 3:
        # SET_DNS — a1 = packed DNS server.
        d0: uint8 = cast[uint8]((a1 >> 24) & 0xFF)
        d1: uint8 = cast[uint8]((a1 >> 16) & 0xFF)
        d2: uint8 = cast[uint8]((a1 >> 8) & 0xFF)
        d3: uint8 = cast[uint8](a1 & 0xFF)
        dns_set_static_server(d0, d1, d2, d3)
        return 0
    if op == 4:
        # ROUTE_ADD — a1 = Ptr to a 13-byte route descriptor.
        if a1 == 0:
            set_current_errstr("netcfg: null route buffer")
            return -1
        # Kernel staging buffer (see the GET arm): no access_ok here.
        rb: Ptr[uint8] = cast[Ptr[uint8]](a1)
        rc: int32 = ip_route_add(
            rb[0], rb[1], rb[2], rb[3],
            rb[4], rb[5], rb[6], rb[7],
            rb[8], rb[9], rb[10], rb[11],
            rb[12])
        if rc != 0:
            set_current_errstr("netcfg: route table full")
            return -1
        return 0
    if op == 5:
        # ROUTE_GET — a1 = Ptr to a 13-byte buffer, a2 = slot index.
        if a1 == 0:
            set_current_errstr("netcfg: null route buffer")
            return -1
        # Kernel staging buffer (see the GET arm): no access_ok here.
        cap: uint64 = ip_fib_max()
        if a2 >= cap:
            set_current_errstr("netcfg: route slot out of range")
            return -1
        gb: Ptr[uint8] = cast[Ptr[uint8]](a1)
        z: uint64 = 0
        while z < 13:
            gb[z] = 0
            z = z + 1
        if ip_fib_slot_used(a2) == 1:
            gb[0]  = ip_fib_slot_net_b(a2, 0)
            gb[1]  = ip_fib_slot_net_b(a2, 1)
            gb[2]  = ip_fib_slot_net_b(a2, 2)
            gb[3]  = ip_fib_slot_net_b(a2, 3)
            gb[4]  = ip_fib_slot_mask_b(a2, 0)
            gb[5]  = ip_fib_slot_mask_b(a2, 1)
            gb[6]  = ip_fib_slot_mask_b(a2, 2)
            gb[7]  = ip_fib_slot_mask_b(a2, 3)
            gb[8]  = ip_fib_slot_gw_b(a2, 0)
            gb[9]  = ip_fib_slot_gw_b(a2, 1)
            gb[10] = ip_fib_slot_gw_b(a2, 2)
            gb[11] = ip_fib_slot_gw_b(a2, 3)
            flags: uint8 = 1
            if ip_fib_slot_onlink(a2) == 1:
                flags = flags | 2
            gb[12] = flags
        return cast[int64](cap)
    if op == 6:
        # ROUTE_DEL — a1 = Ptr to a 12-byte (net[4] mask[4] gw[4])
        # descriptor. Removes one ECMP nexthop, leaving the rest of the
        # group intact.
        if a1 == 0:
            set_current_errstr("netcfg: null route buffer")
            return -1
        # Kernel staging buffer (see the GET arm): no access_ok here.
        db: Ptr[uint8] = cast[Ptr[uint8]](a1)
        drc: int32 = ip_route_del(
            db[0], db[1], db[2], db[3],
            db[4], db[5], db[6], db[7],
            db[8], db[9], db[10], db[11])
        if drc != 0:
            set_current_errstr("netcfg: no such route")
            return -1
        return 0
    set_current_errstr("netcfg: bad op")
    return -1


def _netcfg_pack(b0: uint8, b1: uint8, b2: uint8, b3: uint8) -> uint64:
    # Pack a 4-octet IPv4 into a uint64 the way the `ifconfig` command
    # does for the SYS_NETCFG SET_* ops (octet 0 in bits 31:24).
    return (cast[uint64](b0) << 24) | (cast[uint64](b1) << 16) \
         | (cast[uint64](b2) << 8) | cast[uint64](b3)


def netcfg_smoke_test():
    # In-kernel smoke test for the SYS_NETCFG path (the syscall behind
    # the `ifconfig` command). Runs after the live SLIRP DHCP path has
    # reached BOUND so we can prove both:
    #   1. GET reflects the DHCP-assigned address as cfg_source == DHCP.
    #   2. A static SET_ADDR / SET_GW / SET_DNS takes effect and the
    #      following GET shows cfg_source == static with the new values.
    #
    # GATED on /etc/netcfg-test (the test pins a static config, which
    # would perturb downstream net tests; only scripts/test_net_cfg.sh
    # plants the marker). Drives do_netcfg directly — exactly the path
    # SYS_NETCFG dispatches to.
    #
    # PASS markers (consumed by scripts/test_net_cfg.sh):
    #   [netcfg] dhcp-reflect PASS  — GET showed the DHCP lease
    #   [netcfg] static-addr PASS   — SET_ADDR took effect
    #   [netcfg] static-gw PASS     — SET_GW took effect
    #   [netcfg] static-dns PASS    — SET_DNS took effect
    #   [netcfg] PASS               — all four observed
    buf: Array[24, uint8]
    bp: uint64 = cast[uint64](&buf[0])

    # --- 1. GET reflects the DHCP lease -----------------------------
    if do_netcfg(0, bp, 0) != 0:
        printk0("[netcfg] FAIL (GET op returned non-zero)\n")
        return
    if buf[16] != 1:
        printk0("[netcfg] FAIL (GET: no address — DHCP not bound?)\n")
        return
    if buf[20] != 1:
        printk1("[netcfg] FAIL (GET: cfg_source=%d expected 1=DHCP)\n",
                cast[uint64](buf[20]))
        return
    printk0("[netcfg] dhcp-reflect PASS ip=")
    printk1("%d", cast[uint64](buf[0]))
    printk0(".")
    printk1("%d", cast[uint64](buf[1]))
    printk0(".")
    printk1("%d", cast[uint64](buf[2]))
    printk0(".")
    printk1("%d", cast[uint64](buf[3]))
    printk0(" source=dhcp\n")

    # --- 2. SET_ADDR: pin 192.168.50.10 / 255.255.255.0 -------------
    if do_netcfg(1, _netcfg_pack(192, 168, 50, 10),
                 _netcfg_pack(255, 255, 255, 0)) != 0:
        printk0("[netcfg] FAIL (SET_ADDR returned non-zero)\n")
        return
    if do_netcfg(0, bp, 0) != 0:
        printk0("[netcfg] FAIL (GET after SET_ADDR)\n")
        return
    if buf[0] != 192 or buf[1] != 168 or buf[2] != 50 or buf[3] != 10:
        printk0("[netcfg] FAIL (SET_ADDR: address not applied)\n")
        return
    if buf[4] != 255 or buf[5] != 255 or buf[6] != 255 or buf[7] != 0:
        printk0("[netcfg] FAIL (SET_ADDR: netmask not applied)\n")
        return
    if buf[20] != 2:
        printk1("[netcfg] FAIL (SET_ADDR: cfg_source=%d expected 2)\n",
                cast[uint64](buf[20]))
        return
    printk0("[netcfg] static-addr PASS ip=192.168.50.10/24 source=static\n")

    # --- 3. SET_GW: pin 192.168.50.1 --------------------------------
    if do_netcfg(2, _netcfg_pack(192, 168, 50, 1), 0) != 0:
        printk0("[netcfg] FAIL (SET_GW returned non-zero)\n")
        return
    if do_netcfg(0, bp, 0) != 0:
        printk0("[netcfg] FAIL (GET after SET_GW)\n")
        return
    if buf[8] != 192 or buf[9] != 168 or buf[10] != 50 or buf[11] != 1:
        printk0("[netcfg] FAIL (SET_GW: gateway not applied)\n")
        return
    printk0("[netcfg] static-gw PASS gw=192.168.50.1\n")

    # --- 4. SET_DNS: pin 1.1.1.1 ------------------------------------
    if do_netcfg(3, _netcfg_pack(1, 1, 1, 1), 0) != 0:
        printk0("[netcfg] FAIL (SET_DNS returned non-zero)\n")
        return
    if do_netcfg(0, bp, 0) != 0:
        printk0("[netcfg] FAIL (GET after SET_DNS)\n")
        return
    if buf[12] != 1 or buf[13] != 1 or buf[14] != 1 or buf[15] != 1:
        printk0("[netcfg] FAIL (SET_DNS: server not applied)\n")
        return
    if buf[21] != 1:
        printk1("[netcfg] FAIL (SET_DNS: dns_source=%d expected 1)\n",
                cast[uint64](buf[21]))
        return
    printk0("[netcfg] static-dns PASS dns=1.1.1.1 source=static\n")

    printk0("[netcfg] PASS\n")


# ===================================================================
# uaccess SYSCALL-level proof — the decoupling, exercised end-to-end.
#
# mm/uaccess.ad::uaccess_smoke_test already proves the copy_to_user /
# copy_from_user PRIMITIVES translate a vaddr != phys mapping. This test
# proves the CONVERTED SYSCALL HANDLERS do too: it drives do_syscall()
# for SYS_GETCWD against a user buffer whose physical frame is
# DELIBERATELY NOT EQUAL to its virtual address, then asserts:
#
#   1. the cwd bytes land at the PHYSICAL frame P (the translated
#      destination), NOT at the raw vaddr V,
#   2. the syscall return value matches the (string length + NUL),
#   3. the OLD raw-deref path would have been WRONG — we pre-poison P
#      so a no-op (untranslated) write would leave the poison intact;
#      a poison-free, correct-bytes frame is the proof the handler
#      translated rather than dereferenced V directly.
#
# The test vaddr sits high in the canonical user half (0x5555_6000_0000),
# well above any identity-mapped RAM, so it can ONLY resolve via the PTE
# we install. A handler that still raw-deref'd V would touch unmapped
# memory and never reach P.
#
# Gated by the caller (init/main.ad runs it unconditionally at boot,
# right after uaccess_smoke_test). PASS markers consumed by
# scripts/test_uaccess_translate.sh.
# ===================================================================

UA_SC_TEST_VADDR: uint64 = 0x0000555560000000
# A canonical user-half address that is NEVER mapped — the -EFAULT
# probes below feed it to converted handlers and assert -14 comes back.
# NOTE: must stay clear of UA_LXABI_TEST_VADDR (0x555570000000), which
# linux_abi_uaccess_translate_test MAPS in the same boot pml4 right
# after this test.
UA_SC_BAD_VADDR: uint64 = 0x00005555DEAD0000


def uaccess_syscall_test():
    printk0("Hamnix: uaccess syscall test (SYS_GETCWD via vaddr != phys)\n")
    slot: uint64 = current_idx_get()
    pml4: uint64 = uaccess_current_pml4()

    # SAVE the boot task's existing cwd so the probe below doesn't
    # perturb later boot. We restore it before returning.
    cwd_save: Array[128, uint8]
    cwd_cur: Ptr[uint8] = get_cwd_buf(slot)
    si: uint64 = 0
    while si < 128:
        cwd_save[si] = cwd_cur[si]
        si = si + 1

    # Install a known cwd in the task's kernel-side cwd[] so the
    # converted SYS_GETCWD has a deterministic string to copy out.
    cwd_probe: Array[16, uint8]
    cwd_probe[0] = cast[uint8](47)        # '/'
    cwd_probe[1] = cast[uint8](117)       # 'u'
    cwd_probe[2] = cast[uint8](97)        # 'a'
    cwd_probe[3] = cast[uint8](120)       # 'x'
    cwd_probe[4] = 0
    set_task_cwd(slot, &cwd_probe[0])     # expected copy-out: "/uax\0", 5 bytes

    # Map a fresh physical page at a NON-IDENTITY user vaddr (V != P).
    p: uint64 = alloc_page()
    if p == 0:
        printk0("  [uaccess-sc] SKIP: alloc_page failed\n")
        return
    # Pre-poison the physical frame: if SYS_GETCWD failed to translate
    # (the old raw-deref-of-V behaviour) the poison would survive.
    memset(cast[Ptr[uint8]](p), 0xCD, 4096)
    if vm_map_user_page(pml4, UA_SC_TEST_VADDR, p, 1) < 0:
        printk0("  [uaccess-sc] FAIL: could not install test mapping\n")
        free_page(p)
        return
    printk2("  [uaccess-sc] mapped V=%p -> P=%p (writable)\n",
            UA_SC_TEST_VADDR, p)

    # Drive the CONVERTED syscall: write the cwd into the user buffer V.
    ret: uint64 = do_syscall(SYS_GETCWD, UA_SC_TEST_VADDR, 16,
                             0, 0, 0, 0)

    # 1. The bytes MUST appear at the physical frame P (translated dst).
    phys_view: Ptr[uint8] = cast[Ptr[uint8]](p)
    ok: int32 = 1
    if phys_view[0] != 47 or phys_view[1] != 117 \
            or phys_view[2] != 97 or phys_view[3] != 120 \
            or phys_view[4] != 0:
        ok = 0
    # 2. Return value is "/uax" (4) + NUL (1) = 5.
    if ret != 5:
        printk1("  [uaccess-sc] FAIL: ret=%p (expected 5)\n", ret)
        ok = 0
    if ok != 0:
        printk0("  [uaccess-sc] PASS: SYS_GETCWD copied to the physical frame\n")
    else:
        printk2("  [uaccess-sc] FAIL: frame[0..1]=%p,%p (poison=0xCD => untranslated)\n",
                cast[uint64](phys_view[0]), cast[uint64](phys_view[1]))

    # ---------------------------------------------------------------
    # #163 EFAULT probes: drive the freshly converted handlers with an
    # UNMAPPED canonical user pointer and assert each returns -EFAULT
    # (-14) instead of raw-derefing kernel-side (which would wedge or
    # corrupt). The address sits in the user half but has no PTE, so
    # uaccess_resolve must reject it.
    # ---------------------------------------------------------------
    bad: uint64 = UA_SC_BAD_VADDR
    efault: uint64 = cast[uint64](-14)
    eok: int32 = 1
    er: uint64 = do_syscall(SYS_STAT_P9, bad, bad, 16, 0, 0, 0)
    if er != efault:
        printk1("  [uaccess-sc] FAIL: SYS_STAT_P9 bad ptr ret=%p\n", er)
        eok = 0
    er = do_syscall(SYS_WAITFDS, bad, 2, 0, 0, 0, 0)
    if er != efault:
        printk1("  [uaccess-sc] FAIL: SYS_WAITFDS bad ptr ret=%p\n", er)
        eok = 0
    # #450 F6: SYS_LISTDIR is retired (number 18 reserved). uaccess
    # for directory reads now happens at SYS_OPEN + SYS_READ, both
    # of which are already covered by this test's positive arm (the
    # SYS_GETCWD probe right above) and by the userland path through
    # lib/p9.ad's p9_listdir() (open + read + close, each separately
    # uaccess-protected).
    er = do_syscall(SYS_WSTAT, bad, bad, 49, 0, 0, 0)
    if er != efault:
        printk1("  [uaccess-sc] FAIL: SYS_WSTAT bad ptr ret=%p\n", er)
        eok = 0
    if eok != 0:
        printk0("  [uaccess-sc] PASS: converted handlers -EFAULT on unmapped pointers\n")

    free_page(p)
    # Restore the boot task's original cwd.
    set_task_cwd(slot, &cwd_save[0])
    printk0("  [uaccess-sc] done\n")

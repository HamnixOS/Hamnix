        # tmpfs / memfd fds (FD_CHAN_MARK / DEV_TMPFS_FILE chans) are
        # supported today; other backends return -1 with
        # "fwstat: backend not supported".
        if access_ok(a1, a2) == 0:
            set_current_errstr("fwstat: bad buffer address")
            return cast[uint64](-14)             # -EFAULT

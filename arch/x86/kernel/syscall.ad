    if nr == SYS_GETUID:
        # Returns the current task's uid widened to uint64 (always fits;
        # uid is uint32 in TaskStruct).
        return cast[uint64](current_task_uid())
    if nr == SYS_GETGID:
        return cast[uint64](current_task_gid())
    if nr == SYS_SETUID:
        # Privileged: only hostowner (uid 1) can change identity. /dev/auth
        # is the legitimate caller — it authenticates against /etc/shadow
        # FIRST, then (still in kernel context, on PID 1's behalf during
        # `newshell`) calls SYS_SETUID to flip the spawning task's uid.
        # The kernel-side restriction is "current uid must be 1", which
        # closes downgrade-only — a regular user can never elevate, only
        # downgrade themselves. /dev/auth runs on a kernel thread or
        # service path that hostowner controls; userland calls from a
        # non-hostowner task fall through to -EPERM.
        # arch audit §3.2: route via _syscall_require_hostowner so the
        # policy can move in ONE place when /dev/auth grows a proper
        # Plan-9 reshape (right now SYS_SETUID has no server file —
        # it mutates TaskStruct directly).

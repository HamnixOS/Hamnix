        ptr_b1: uint8 = cast[uint8]((a0 >> 16) & 0xFF)
        ptr_b2: uint8 = cast[uint8]((a0 >> 8) & 0xFF)
        ptr_b3: uint8 = cast[uint8](a0 & 0xFF)

# arch/x86/kernel/syscall.ad
#
# Mirrors arch/x86/kernel/cpu/common.c::syscall_init() and the
# arch/x86/entry/common.c::do_syscall_64() handler in Linux at minimal
# scale: configures the SYSCALL/SYSRET MSRs once at boot, and provides
# the C-side dispatch that the asm stub (syscall_64.S) tail-calls.
#
# MSRs touched:
#
#   IA32_EFER   0xC0000080   bit 0 SCE  - enable SYSCALL/SYSRET at all
#   IA32_STAR   0xC0000081   bits 47:32 SYSCALL CS:SS base
#                            bits 63:48 SYSRET CS:SS base
#   IA32_LSTAR  0xC0000082   64-bit SYSCALL entry RIP
#   IA32_FMASK  0xC0000084   RFLAGS bits to clear on SYSCALL entry
#
# STAR encoding chosen for our boot GDT:
#   SYSCALL CS = 0x08 (kernel code), SS = 0x10 (kernel data)
#   SYSRET  CS = 0x20 + RPL(3) = 0x23 (user code)
#           SS = 0x18 + RPL(3) = 0x1B (user data)
# That means STAR[47:32] = 0x08 and STAR[63:48] = 0x10 — verified by
# the SYSRET hardware-imposed offsets (CS = base+16, SS = base+8).
#
# FMASK = 0x0200 (only IF) so SYSCALL entry runs with interrupts off.
# Linux additionally clears DF and a few others; we'll add as needed.

from drivers.tty.serial.early_8250 import early_putc_user
from kernel.printk.printk import printk0, printk1, printk2, printk_set_level
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_WARN
# §6: classic-BPF seccomp filter inheritance hook.
from kernel.seccomp_bpf import bpf_inherit_to_child
from arch.x86.kernel.time import get_jiffies, tsc_monotonic_ns, read_tsc
from kernel.sched.core import (
    TaskStruct, current_task,
    create_user_task, create_user_task_argv, create_user_thread,
    task_exit_current,
    current_task_pid, task_lookup_by_pid, task_state, task_exit_code,
    task_pid_at, task_reap, yield_to_others, STATE_EXITED,
    get_task_term_sig, copy_sig_state_to_child,
    dup_fd_to_child,
    # #147 / ptrace(2): wait4 reports a traced child's syscall-enter/exit
    # stop as WIFSTOPPED. These read the per-task ptrace stop state set
    # by the tracee at its stop point (linux_abi/u_ptrace.ad).
    get_task_pt_stop_state, get_task_pt_tracer_pid,
    get_task_pt_stop_reported, set_task_pt_stop_reported,
    get_task_pt_options,
    # Job control: process-group + stop/continue plumbing.
    task_set_job_pgid, task_get_job_pgid, signal_post_to_pgid,
    task_is_stopped, task_stop_sig, task_take_cont_pending,
    set_terminal_fg_pgid, get_terminal_fg_pgid, STATE_STOPPED,
    signal_post, signal_check_and_handle, signal_deliver_on_return,
    get_cwd_buf, set_task_cwd, current_idx_get,
    set_linux_userspace_mode,
    # #160 / seccomp-lite: a fork/clone child inherits the parent's
    # seccomp mode + filter bitmap (the filter is irrevocable AND
    # inherited, matching Linux). Read/written through these accessors;
    # syscall.ad keeps no static dependency on the linux_abi layer.
    get_task_seccomp_mode, set_task_seccomp_mode,
    get_task_seccomp_filter, set_task_seccomp_filter,
    # F10-8 / #457: NATIVE seccomp-lite. Reached through accessors for
    # the same one-directional reason as the Layer-2 fields above —
    # arch/x86/kernel/syscall.ad consults the per-task filter at
    # do_syscall entry, and inherits it across fork/clone in
    # seccomp_inherit_to_child below.
    get_task_seccomp_native_armed, set_task_seccomp_native_armed,
    get_task_seccomp_native_filter, set_task_seccomp_native_filter,
    seccomp_native_check_entry,
    task_vfork_done, set_task_vfork_done,
    set_task_fs_base, set_task_clear_child_tid,
    task_pml4, set_task_cr3, task_publish_thread_ready,
    set_current_errstr, get_current_errstr,
    # Per-process address space (fork). do_execve records the loaded
    # image span + user-stack region; do_clone copies them into the
    # child's private pages.
    set_task_image_range, set_task_ustack_range,
    set_task_image_phys, set_task_ustack_phys, set_task_interp_phys,
    # Leak fix: execve replaces the image in place; free the OUTGOING
    # owner-only image/interp/ustack regions before recording the new
    # ones, else the pre-execve spans leak for the rest of the boot.
    task_free_owner_regions,
    task_image_lo, task_image_hi, task_ustack_lo, task_ustack_sz,
    task_brk_base, task_brk_end, task_brk_max, set_task_brk_range,
    # V4: srv_open needs a Ptr[TaskStruct] for the poster's slot so
    # vfs_srv_dup_into_current can copy_fd_entry from the poster's
    # table to the caller's. task_struct_at returns 0 (NULL) for
    # out-of-range slot indices — the syscall body bails with errstr
    # "srv: kernel-only" in that case.
    task_struct_at,
    # SYS_SPAWN namespace inheritance — task_pgrp / set_task_pgrp
    # read/write the per-task Pgrp pointer. sys_spawn has two cases:
    #  - SPAWN_STDIO_NS (the shell spawning a command): the child gets
    #    its OWN Pgrp — a COW copy of the caller's ambient namespace
    #    (HAMSH §7/§9), so it has a private /fd-name table (pgrp_clone).
    #  - legacy path (apt/dpkg/nsrun/sshd, real integer fds): the child
    #    shares the parent's Pgrp so a process spawned inside an
    #    nsrun/distrorun distro-shape namespace sees the mounted
    #    distrofs trees (pgrp_ref_inc bumps the share refcount).
    task_pgrp, set_task_pgrp,
    # docs/security.md: Plan-9-shape uid/gid accessors. SYS_GETUID /
    # SYS_GETGID return the current task's value; SYS_SETUID is the
    # privileged setter the /dev/auth post-auth path (and the boot
    # bring-up) call to flip identity.
    current_task_uid, current_task_gid,
    set_current_task_uid, set_current_task_gid,
    # hamUI Phase 2: SYS_WSYS_ALLOC marks the wsys-bound child task as
    # detached so hamUI exiting doesn't strand it as a zombie. Same
    # accessors rfork(RFNOWAIT) uses.
    set_task_detached, set_task_parent_pid,
    # §146: nanosleep cooperative blocking loop (sti+hlt+cli per jiffy).
    kernel_cond_resched,
    # #151 / CFS-lite scheduling: SYS_NICE / setpriority adjust a task's
    # nice value (and recomputed load weight); fork/clone inherit it.
    # sched_cpu_runs surfaces the per-CPU dispatch counter for /proc and
    # the SMP load-balance test.
    sched_set_nice, sched_get_nice, sched_inherit_nice_to_child,
    sched_cpu_runs,
)
from fs.vfs import (
    vfs_open, vfs_open_write, vfs_pipe, vfs_read, vfs_read_nb, vfs_write,
    vfs_waitfds,
    vfs_close, vfs_lseek, vfs_dup, vfs_dup2, vfs_listdir,
    # #450 F6 / Phase G: vfs_listdir_ns is now ONLY used inside fs/vfs.ad
    # (by _open_dir_with via chan_dir_mount_children); the SYS_LISTDIR
    # arm that used to drive it from here is retired. Kept in the
    # import list so any future helper that needs it can find it.
    vfs_listdir_ns,
    # #450 F6: stamp the caller's CONVENTIONAL path so _open_dir_with
    # can synthesize mtab children that hang off the orig name (the
    # `bind '#c' /dev` shows up as `dev` in `ls /` case).
    vfs_open_set_orig_path,
    vfs_unlink, vfs_mkdir, vfs_fd_is_dir, vfs_fd_is_open,
    resolve_path,
    # §4: namespace-aware blob lookup — execve / spawn resolve the
    # target binary through the calling process's Pgrp mount table
    # (resolve_path's ns_walk rewrite) so a binary launched
    # inside a distro-shaped namespace finds its image in the distro
    # tree. ns_blob_* is a verbatim lookup when no mount entry matches.
    ns_blob_ptr, ns_blob_size,
    # docs/security.md Phase 5: exec-time permission check. do_execve
    # consults this before ELF-loading the target so an exec of a
    # non-executable-for-caller binary fails cleanly with -EPERM
    # rather than half-replacing the address space.
    vfs_perm_check_exec,
    # V4: cross-task fd dup helper. sys_srv_open hands it the
    # poster's Ptr[TaskStruct] and the poster-relative srvfd; it
    # returns a new fd in the caller's table or -errno.
    vfs_srv_dup_into_current,
    # V5: bidirectional socketpair. SYS_SOCKETPAIR (Linux number 53)
    # returns two bidirectional endpoints — the transport rio + future
    # 9P clients want instead of two unidirectional pipes.
    vfs_socketpair,
    # docs/security.md Phase 4: SYS_SETUID_AUTH maps an open /dev/auth
    # fd to its devauth slot index so the kernel can flip identity to
    # the slot's verified uid.
    vfs_fd_auth_slot,
    # M16.x §links: symlink create + hardlink create with namespace /
    # file-server boundary enforcement.
    vfs_symlink, vfs_link, EXDEV_LINK,
    # §146: Layer-2 fd allocation for timerfd. vfs_alloc_l2_fd creates an
    # fd-table entry with a special marker; vfs_fd_marker reads it back;
    # vfs_l2_fd_{set,get}_buf stores/retrieves the associated object slot.
    vfs_alloc_l2_fd, vfs_fd_marker, vfs_l2_fd_set_buf, vfs_l2_fd_get_buf,
    # §file-mmap: snapshot an fd's stable backing identity so a
    # file-backed mmap can fault pages in from the file even after the
    # user closes the fd (POSIX). FD_FILEMMAP_INITRAMFS marks a read-only
    # cpio backing — rejected for MAP_SHARED writable mappings.
    vfs_fd_backing_info, FD_FILEMMAP_INITRAMFS,
    # F10-6 followup: per-Chan p9_dir_mode opt-in.
    vfs_chan_p9_dir_mode_set,
)
from sys.src.port9.port.devauth import (
    devauth_verified_uid, devauth_verified_gid,
)
from fs.procfs import (
    # /proc/svc Phase 6 — kernel-side service-mirror update. SYS_SVC_PUBLISH
    # forwards a (name, 400-byte payload) tuple from the userland
    # supervisor (user/hamsh.ad) into the mirror table that backs
    # `/proc/svc/<name>` reads.
    svc_proc_publish, svc_proc_unpublish,
    # /proc/svc control mailbox — native-command -> PID-1-supervisor RPC
    # backing SYS_SVC_CTL. Enqueue from any process; dequeue from PID 1.
    svc_ctl_enqueue, svc_ctl_dequeue, svc_ctl_out_name_ptr,
    # F2 #447 / audit §4 thin-shim conversion: SYS_SVC_CTL producer verbs
    # (1..6) delegate to the shared /proc/svc/ctl text parser so the syscall
    # and ctl-file share one policy + enqueue path.
    svc_ctl_text_apply,
)
from fs.elf import (
    elf_load_blob, elf_last_was_linux,
    elf_last_load_base, elf_last_phoff, elf_last_phnum,
    elf_apply_last_user_mapping,
    # M16.36: per-task PT-entry installation for the user stack — so
    # the stack pages no longer depend on the BSP's inherited 1 GiB
    # identity stamp. Same shape the ELF image install uses.
    elf_install_user_stack,
    # U42: dynamic-ELF interpreter. The kernel still receives the
    # ENTRY (user-mode RIP) from elf_load_blob — for static binaries
    # that's the app's e_entry; for dynamic binaries that's the
    # INTERPRETER's e_entry. Auxv plants AT_ENTRY = app e_entry
    # (elf_last_app_entry_user) and AT_BASE = interp base
    # (elf_last_interp_base, = 0 on the static path).
    elf_last_interp_base, elf_last_app_entry_user,
    # Per-process address space (fork): the loaded ELF image span +
    # the private-copy machinery do_clone uses to give a forked child
    # its own physical pages remapped at the same virtual addresses.
    elf_last_img_lo_get, elf_last_img_hi_get, elf_last_img_phys_get,
    # Interp-image reclaim: a dynamic ELF loads ld-linux as a separate
    # region; SYS_SPAWN / do_execve record its phys+span on the owning
    # task so task_reap frees it (closing the per-dynamic-spawn leak).
    elf_last_interp_img_phys_get, elf_last_interp_img_sz_get,
    vm_cow_share_all,
    # uaccess syscall self-test: install a user PTE at a deliberately
    # non-identity vaddr so the converted SYS_GETCWD copy-out proves it
    # translates rather than raw-derefs.
    vm_map_user_page,
    # U52 ET_DYN load-bias ASLR: arm the per-exec randomized virtual base
    # for the next ELF image (app + interpreter) before elf_load_blob.
    elf_set_aslr_vbases,
)
# #169 vDSO: map the AT_SYSINFO_EHDR shared-time mini-ELF + data page
# into each Linux guest's address space at exec/spawn time.
#
# F4 #449 leaf inversion: the static `from linux_abi.vdso import …` line
# that USED to live here is gone. The Layer-2 vDSO module registers its
# routines through the hook block further down. A pure-native build never
# installs the hook; the call sites become harmless no-ops (vdso_user_code_vaddr
# returns 0 → AT_SYSINFO_EHDR omitted, vdso_map_into_user becomes a no-op).
from mm.page_alloc import alloc_page, alloc_pages, free_page
from mm.slab import kmalloc, kfree
# Real uaccess translation layer. copy_to_user / copy_from_user /
# get_user / put_user / strncpy_from_user walk the CURRENT task's page
# tables to translate a user vaddr -> physical frame before touching it,
# so a user mapping no longer has to sit at vaddr == phys (the invariant
# that blocked ET_DYN / mmap-base ASLR). Faults return an -EFAULT-shaped
# residual instead of #PF-panicking.
from mm.uaccess import (
    copy_to_user, copy_from_user,
    get_user_64, put_user_64, strncpy_from_user, clear_user,
    uaccess_current_pml4,
    _ua_stac, _ua_clac,
)
# U42 follow-up: per-task VMA list. do_execve clears the outgoing
# image's mappings before ELF-loading the incoming image so the new
# program starts with a clean vma_list. Subsequent mmap() calls from
# the new image extend the list via mm/vma.ad::vma_alloc.
from mm.vma import (
    vma_clear, vma_fork_copy, vma_free_reserved_range,
    vma_alloc, vma_alloc_demand, vma_alloc_file_demand,
    vma_alloc_huge_demand,
    vma_alloc_file_shared, vma_writeback_range,
    vma_unmap, vma_protect,
    VMA_MAP_ANONYMOUS, VMA_MAP_PRIVATE, VMA_MAP_FIXED, VMA_MAP_SHARED,
    VMA_MAP_HUGETLB, VMA_HUGE_SIZE,
    VMA_PROT_WRITE,
    # U52 mmap-base ASLR: randomize the virtual base of the windowed mmap
    # allocator (large/demand/file-shared anon regions) per-exec.
    vma_set_mmap_base,
)
# F4 #449 leaf inversion: the static imports for the Linux .ko loader
# (kmod_linux_load / kmod_linux_unload) and for the Linux syscall fall-
# through dispatcher (linux_u_syscall_dispatch) are GONE. Layer-2 plants
# the routines into the hook pointers further down at boot. The block
# comment about retired native BSD socket arms (ARCH §10) is kept inline
# at the dispatch site below; nothing imported here.
# U-resolve: the in-kernel DNS resolver (drivers/net/dns.ad). The
# native SYS_RESOLVE (269) arm in do_syscall() hands a userland
# hostname straight to dns_lookup so user binaries (user/apt.ad) can
# connect to a host by name. dns_lookup is the same blocking,
# virtio_net_poll-driven body init/main.ad's boot smoke and
# drivers/net/http.ad already call — so it is safe from syscall
# context (apt already does blocking TCP from a syscall the same way).
from drivers.net.dns import dns_lookup, dns_set_static_server, \
    dns_get_server, dns_lookup_ptr
from drivers.net.ip import ip_our_ip_b, ip_gateway_b, ip_netmask_b, \

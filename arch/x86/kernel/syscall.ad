        # multi-user box (forging cert validity, backdating mtimes for
        # build cache poisoning, ...) live in the same threat model as
        # SYS_SVC_PUBLISH / SYS_SETUID, so we gate on uid == 1.
        # arch audit §3.2: wall clock is system-wide kernel state, not
        # a server file — gate through the named helper. A future
        # /dev/realtime ctl-file could move the policy there.
        if _syscall_require_hostowner("set_realtime") != 0:
            return cast[uint64](cast[int64](-1))
        rrc: int32 = rtc_boot_epoch_set_now(a0)
        if rrc != 0:
            set_current_errstr("set_realtime: bad epoch")
            return cast[uint64](cast[int64](-1))
        return 0
    if nr == SYS_WSYS_ALLOC:
        # hamUI Phase 2: /bin/hamUI spawned a child shell with sys_spawn;
        # claim a wid for it and bind the child's pid into the wsys table.
        # a0 = child pid. Returns the wid (>=2) / -1.
        #
        # F2 #447 / audit §4 thin-shim conversion: this arm now FORMATS
        # "alloc <pid>\n" into a kernel buffer and delegates to
        # devwsys_ctl_write — exactly what a userland write to
        # /dev/wsys/ctl would do. devwsys_ctl_write enforces the
        # hostowner gate, the self-registration refusal, the pid lookup,
        # the wsys_alloc_wid call, and the detach/parent-clear (one
        # policy path, shared with userland). wsys_last_alloc_wid_consume
        # pulls back the assigned wid. The number stays reserved (293) —
        # do not reuse.
        wsa_buf: Array[40, uint8]
        wsa_n: uint64 = _fmt_ctl_u64_arg(&wsa_buf[0], 40, "alloc ", a0)
        wsa_rc: int64 = devwsys_ctl_write(&wsa_buf[0], wsa_n)
        if wsa_rc < 0:
            return cast[uint64](cast[int64](-1))
        wsa_wid: int32 = wsys_last_alloc_wid_consume()
        return cast[uint64](cast[int64](wsa_wid))
    if nr == SYS_WSYS_FREE:
        # hamUI Phase 2: release a wid. a0 = wid. F2 #447 / audit §4: same
        # text-delegation pattern as SYS_WSYS_ALLOC — format "free <wid>\n"
        # and hand off to devwsys_ctl_write. Number reserved (294).
        wsf_buf: Array[40, uint8]
        wsf_n: uint64 = _fmt_ctl_u64_arg(&wsf_buf[0], 40, "free ", a0)
        wsf_rc: int64 = devwsys_ctl_write(&wsf_buf[0], wsf_n)
        if wsf_rc < 0:
            return cast[uint64](cast[int64](-1))
        return 0
    if nr == SYS_VK_WINDOW_FRAME:
        # GPU track #183: hamUId asks the kernel to render native Vulkan
        # frame a2 into window a0's draw-surface fb layer "vk".
        #
        # F2 #447 / audit §4 thin-shim conversion: format
        # "frame <wid> <frame>\n" and delegate to devwsys_ctl_write. The
        # ctl-file writer enforces hostowner gate, range-checks the wid,
        # and dispatches to vk_window_render_frame — one policy path,
        # shared with userland writes to /dev/wsys/ctl. Number reserved
        # (312).
        vkw_buf: Array[64, uint8]
        vkw_n: uint64 = _fmt_ctl_u64_pair(&vkw_buf[0], 64, "frame ",
                                          a0, a2)
        vkw_rc: int64 = devwsys_ctl_write(&vkw_buf[0], vkw_n)
        if vkw_rc < 0:
            return cast[uint64](cast[int64](-1))
        return 0
    if nr == SYS_PIPECHAN:
        # HAMSH §7: create a local pipe Chan pair; returns the pipe
        # SLOT id (not fds). The shell threads the slot into two
        # SYS_FDBIND calls — write end at the producer's /fd/1, read
        # end at the consumer's /fd/0. A local pipe never speaks 9P.
        return cast[uint64](do_pipechan())
    if nr == SYS_OPENCHAN:
        # HAMSH §7: open an on-disk file as a namespace-shareable
        # channel. a0=path, a1=mode (0=read/lookup, 1=create+trunc,
        # 2=create+APPEND — preserve existing size; pair with a
        # DEVFD_FILE_APPEND fdbind for write-at-EOF semantics).
        # Returns the tmpfs slot — the shell binds it at a child's
        # /fd/N for `cmd > file` / `cmd < file`. The svc supervisor
        # uses mode=2 for /var/log/svc/<name>.log capture.
        return cast[uint64](do_openchan(a0, cast[int32](a1)))
    if nr == SYS_NSID:
        # HAMSH §13: an opaque, stable per-Pgrp namespace identity —
        # the calling task's Pgrp pointer. rfork(RFNAMEG) (every
        # `ns {}` / `enter` / `spawn`) gives the child a fresh Pgrp,
        # hence a fresh nsid. A live handle records the nsid it was
        # created under; using it where sys_nsid() differs is the
        # cross-namespace-handle error.
        return pgrp_current()

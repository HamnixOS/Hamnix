        if a1 == 0 or copyin_path(a1, &svc_cname[0], 64) < 0:
            set_current_errstr("svc_ctl: bad name address")
            return cast[uint64](cast[int64](-14))      # -EFAULT
        svc_line: Array[96, uint8]
        svc_n: uint64 = _fmt_svc_ctl_line(&svc_line[0], 96, verb_ctl,
                                          &svc_cname[0])
        if svc_n == 0:
            set_current_errstr("svc_ctl: bad verb")
            return cast[uint64](cast[int64](-1))
        svc_rc: int32 = svc_ctl_text_apply(&svc_line[0], svc_n)
        return cast[uint64](cast[int64](svc_rc))

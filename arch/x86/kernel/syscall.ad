        # fs/namei.c::do_mkdirat(). tmpfs is a real tree now (V1):
        # mkdir creates a directory entry under the resolved parent.
        # Resolve to an absolute path first so vfs_mkdir's prefix
        # routing + tmpfs's component walk see the canonical form
        # (matches SYS_OPEN / SYS_UNLINK). Non-tmpfs paths return
        # -EROFS (cpio is read-only; ext4 mkdir is a later job).
        if access_ok_str(a0) == 0:
            set_current_errstr("mkdir: bad address")
            return cast[uint64](-14)             # -EFAULT
        u_path: Array[256, uint8]
        if copyin_path(a0, &u_path[0], 256) < 0:
            set_current_errstr("mkdir: bad address")
            return cast[uint64](-14)             # -EFAULT
        abs_path: Array[256, uint8]
        rc: int32 = resolve_path(cast[Ptr[char]](&u_path[0]), &abs_path[0], 256)
        if rc != 0:
            set_current_errstr("mkdir: path too long")
            return cast[uint64](rc)
        rc = vfs_mkdir(cast[Ptr[char]](&abs_path[0]))
        if rc < 0:
            set_current_errstr("mkdir: cannot create directory")

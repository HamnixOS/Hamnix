        # SYS_SETUID: provisioning a top-level partition subtree +
        # editing .hamnix-roots is a privileged disk mutation that only
        # PID 1's useradd path should drive.
        # arch audit §3.2: useradd PROVISIONS a server binding
        # (name_push + ext4 subtree) — no existing server file owns the
        # "may create new top-level roots" decision, so the gate stays
        # kernel-internal but routes through the named helper.
        if _syscall_require_hostowner("useradd") != 0:
            return cast[uint64](cast[int64](-1))
        if a0 == 0:
            set_current_errstr("useradd: NULL username")
            return cast[uint64](cast[int64](-22))
        # uaccess (#163): pull the username string into a kernel buffer
        # (page-table-walked) before the ext4 provisioning path or the
        # name_push registration below reads it.
        ua_kname: Array[40, uint8]
        if copyin_path(a0, &ua_kname[0], 40) < 0:
            set_current_errstr("useradd: bad username address")
            return cast[uint64](-14)               # -EFAULT
        ua_name: Ptr[char] = cast[Ptr[char]](&ua_kname[0])
        ua_rc: int32 = ext4_useradd_root(ua_name)
        if ua_rc != 0:
            if ua_rc == -17:
                set_current_errstr("useradd: name already a file-server root")
            elif ua_rc == -30:
                set_current_errstr("useradd: no ext4 root / .hamnix-roots absent")
            elif ua_rc == -22:
                set_current_errstr("useradd: invalid username for root")
            else:

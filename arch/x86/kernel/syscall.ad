        # the path is pulled into a kernel buffer here and do_create
        # only ever sees kernel memory. (The do_* bodies stay kernel-
        # pointer-pure so the in-kernel selftests that drive them with
        # kernel buffers keep working.)
        if access_ok_str(a0) == 0:
            set_current_errstr("create failed: bad path address")
            return cast[uint64](-14)             # -EFAULT
        cr_kpath: Array[256, uint8]
        if copyin_path(a0, &cr_kpath[0], 256) < 0:
            set_current_errstr("create failed: bad path address")
            return cast[uint64](-14)             # -EFAULT

    # through a real namespace file now; see the constant-block note.)
    if nr == SYS_NSLABEL:
        # HAMSH §14: mount handles. a0=op (0=stamp a label onto the
        # mount at a2[/a3], 1=unmount the entry carrying label a1).
        # `mount $srv /to as L` and `unmount L` both route here; a
        # label is the unique handle that lets a union branch be
        # named in /proc/self/ns and peeled off precisely.

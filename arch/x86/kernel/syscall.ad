        # uaccess (#163): path copied in; the Dir record is produced
        # into a kernel stage and copy_to_user'd out. A full record is
        # bounded by 49 + name(<=255) + 3*user-name bytes, well under
        # the 560-byte stage.
        if access_ok_str(a0) == 0:
            set_current_errstr("stat: bad path address")
            return cast[uint64](-14)             # -EFAULT
        if access_ok(a1, a2) == 0:
            set_current_errstr("stat: bad buffer address")
            return cast[uint64](-14)             # -EFAULT
        st_kpath: Array[256, uint8]
        if copyin_path(a0, &st_kpath[0], 256) < 0:
            set_current_errstr("stat: bad path address")
            return cast[uint64](-14)             # -EFAULT
        st_cap: uint64 = a2
        if st_cap > 560:
            st_cap = 560
        st_stage: Array[560, uint8]
        st_n: int64 = do_stat(cast[uint64](&st_kpath[0]),
                              cast[uint64](&st_stage[0]), st_cap)
        if st_n > 0:
            if copy_to_user(a1, cast[uint64](&st_stage[0]),
                            cast[uint64](st_n)) != 0:

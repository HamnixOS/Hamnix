            set_current_errstr("srv: bad name address")
            return cast[uint64](-14)             # -EFAULT
        srv_kname: Array[64, uint8]
        if copyin_path(a0, &srv_kname[0], 64) < 0:
            set_current_errstr("srv: bad name address")
            return cast[uint64](-14)             # -EFAULT

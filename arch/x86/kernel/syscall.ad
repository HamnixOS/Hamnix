# SYS_USERADD_ROOT: hostowner-only provisioning of a per-user home file
# server on the shared ext4 root (docs/security.md). ext4_useradd_root
# edits .hamnix-roots + mkdir's the top-level subtree (kernel-side
# because `/` is bound to #sysroot, so userland can't touch the
# partition root). After the on-disk edit we live-register `#<name>`
# against the SAME partition — recovered from the ext4 root block slot
# via the by-id registry — so the home is usable THIS boot, not just
# after the next sentinel parse. Keying on the block slot (not a root
# WORD) is what makes useradd work on BOTH the installed disk (root
# mounted as #sysroot) and the LIVE medium (root mounted as #distro).
from fs.ext4 import ext4_useradd_root, ext4_root_blockdev_slot
from sys.src.port9.port.chan import (
    name_push, byid_partuuid_for_chan_ref,
)
# Legacy integer-fd SYS_SPAWN path needs to read the child's just-installed
# fd entries to mirror them into the child's /fd/0,1,2 namespace bindings
# (so a subsequent SPAWN_STDIO_NS spawn from the child sees a coherent
# stdio namespace, not the parent's stale /fd table). Marks live in
# kernel/sched/core.ad next to fd_idx.
from kernel.sched.core import (
    FD_STDIN_MARK, FD_STDOUT_MARK, FD_STDERR_MARK,
    NTASKS, NR_FDS,
)
# Linux-ABI no-syscall watchdog: stamp the last-syscall clock on every
# Linux syscall so the timer-tick watchdog can detect a userspace spin.
from kernel.sched.core import task_note_syscall_now
# /dev/cons opens as an FD_CHAN_MARK fd carrying an inline namec chan id
# (DEV_CONS); the legacy FD_CONS_MARK is retired. The stdio-namespace
# mirror resolves the chan dev_type to detect a console-backed fd.
# Phase 4c: pipe ends are DEV_PIPE_R / DEV_PIPE_W pool chans — the
# mirror recovers the ring slot via namec_chan_back_slot to bind the
# child's /fd/N.
from sys.src.port9.port.namec import (
    FD_CHAN_MARK, namec_chan_dev_type, DEV_CONS,
    DEV_PIPE_R, DEV_PIPE_W, namec_chan_back_slot,
    # Phase 4c: SPAWN_STDIO_NS stamps the child's 0/1/2 as DEV_DEVFD
    # inline chans (the FD_CHAN_MARK successor to FD_DEVFD_MARK).
    namec_chan_id_devfd,
)
# Phase C / M16.109: Plan 9 note (signal) primitives. Bodies live in
# sys/src/9/port/sysnote.ad — mirrors 9front's notify(2)/noted(2) shape.
# Imported through the port9 directory alias for the same identifier
# reason as error.ad / sysproc.ad above.
from sys.src.port9.port.sysnote import do_notify, do_noted, note_check_and_handle
# Phase D / V4: devsrv post + structured lookup. devsrv_post_from
# records the poster's task_table slot index so sys_srv_open (276)
# can later copy_fd_entry the underlying file/pipe into the opener's
# fd table. Body lives in sys/src/9/port/devsrv.ad.
from sys.src.port9.port.devsrv import (
    devsrv_post_from, devsrv_lookup_full,
    devsrv_list_dir, devsrv_is_srv_dir,
)
# #458 F10-6 expansion: Dir-record emitters for the devproc / devnet /
# devblk backings the audit (docs/audit_arch_shortcuts_2026-06-13.md §8)
# called out as still emitting NAME\n. SYS_LISTDIR_RECORDS now routes
# /proc, /proc/<pid>, /net, /net/<sub>, and /dev/blk to these emitters
# instead of returning -ENOSYS.
from sys.src.port9.port.devproc import devproc_list_dir
from drivers.net.devnet import devnet_list_dir
from kernel.block.blk import blk_list_dir
# #458 F10-6 (this wave): Dir-record emitters for the remaining
# perm-body-stub backings called out as still emitting NAME\n lines:
# tmpfs (#t — /tmp, /var), devcons (#c — /dev), devauth (#auth —
# /dev/auth).
from fs.tmpfs import tmpfs_list_dir
from sys.src.port9.port.devcons import devcons_list_dir
from sys.src.port9.port.devauth import devauth_list_dir
# SYS_SET_REALTIME anchors the kernel-side wall clock from userland
# (ntpd writes here after an NTP exchange). The setter mutates
# rtc_boot_epoch in cmos.ad so that base + TSC-delta = caller-supplied
# Unix epoch from this instant forward.
from drivers.rtc.cmos import rtc_boot_epoch_set_now, rtc_boot_epoch_get
# SYS_CLOCK_GETTIME / SYS_NANOSLEEP: tsc_monotonic_ns already imported above.
# SYS_NANOSLEEP / SYS_TIMERFD_*: cooperative task blocking and timerfd pool
# from the Linux ABI layer (u_epoll.ad). Same objects back both the Linux-ABI
# timerfd_create/settime and the native SYS_TIMERFD_CREATE/SETTIME — there is
# only one timer pool. Native code reaching Layer-2 timers is intentional and
# consistent with the two-tier (Adder + hamsh) app-language model.
#
# F4 #449 leaf inversion: the timerfd pool operations and the FD_TIMERFD_MARK
# constant USED to come in as a direct `from linux_abi.u_epoll import …`. They
# now reach this file via the timerfd hook block further down; linux_abi/
# u_epoll.ad plants them at boot. A native build without u_epoll registered
# answers -ENOSYS at SYS_TIMERFD_CREATE/SETTIME — the right thing for a build
# that has no timerfd pool.
# Power control: reboot(2)=169 funnels into the SAME kernel routine the
# native /dev/reboot cdev uses. Importing power here also pulls power.ad
# into the kernel compilation unit so namec.ad's extern reference to
# power_action resolves at link time.
from arch.x86.kernel.power import (
    power_action, POWER_HALT, POWER_REBOOT, POWER_POWEROFF,
    LINUX_REBOOT_MAGIC1, LINUX_REBOOT_MAGIC2,
    LINUX_REBOOT_CMD_RESTART, LINUX_REBOOT_CMD_HALT,
    LINUX_REBOOT_CMD_POWER_OFF,
)

extern def do_execve_finish(new_rip: uint64, new_rsp: uint64,
                            argc: uint64, argv: uint64)

extern def write_msr(index: uint32, value: uint64)
extern def read_msr(index: uint32) -> uint64
extern def set_efer_sce()
extern def set_efer_nxe()
extern def syscall_entry()
extern def enter_user_mode(entry: uint64, stack: uint64)
extern def user_demo_entry()
extern def local_irq_disable()
# Nesting-safe IRQ mask used to make the fork/clone create+COW-share
# critical section atomic w.r.t. timer preemption (see do_clone): the
# child is STATE_READY out of create_user_task_argv but its address
# space isn't COW-shared until after, so a preemption could dispatch it
# onto an empty PML4.
extern def local_irq_save() -> uint64
extern def local_irq_restore(flags: uint64)
extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]
extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]
extern def load_cr3(value: uint64)


# =====================================================================
# F4 #449 linux_abi hook block — leaf inversion
# =====================================================================
#
# This file used to import a handful of linux_abi symbols directly:
# the vDSO mapping routines, the Linux .ko (de)loader, the Linux
# syscall fall-through dispatcher, and the timerfd pool operations.
# Each import made the native arch core a static consumer of Layer-2
# code — the inversion the F4 audit identified.
#
# The Layer-2 modules now register their entry points at boot through
# the register_* functions below. Each hook starts null; a pure-native
# build that never links Layer-2 leaves them null and the call sites
# choose a safe fallback (no-op, omit, -ENOSYS) without any branch on a
# Layer-2 symbol.
#
# Registration is one-time, from linux_abi/init.ad's linux_abi_init().
# Read paths are lock-free (single writer, monotonic null → live).

# #169 vDSO (linux_abi/vdso.ad):
#   vdso_map_into_user_hook  : install the AT_SYSINFO_EHDR mini-ELF +
#                              time-data page into a user PML4. Returns
#                              the user vaddr of the code page (the
#                              AT_SYSINFO_EHDR value) or 0 on miss.
#   vdso_user_code_vaddr_hook: read the FIXED user vaddr the vDSO code
#                              page lands at, for AT_SYSINFO_EHDR planting
#                              before the child task exists. Returns 0
#                              when the vDSO isn't ready.
vdso_map_into_user_hook:   Fn[uint64, uint64]
vdso_user_code_vaddr_hook: Fn[uint64]
#   sig_trampoline_user_vaddr_hook: read the CPL=3-reachable (identity-low,
#                              US=1 RO+X) vaddr of the §3 signal trampoline,
#                              which linux_abi/vdso.ad maps per Linux task.
#                              Returns 0 before any Linux task has been
#                              mapped. The signal-delivery path (kernel/
#                              sched/core.ad) uses it instead of the
#                              kernel-text &sig_trampoline VA, which is US=0
#                              under SMEP and NX-faults a CPL=3 fetch.
sig_trampoline_user_vaddr_hook: Fn[uint64]


def register_vdso_map_into_user_hook(hook: Fn[uint64, uint64]):
    vdso_map_into_user_hook = hook


def register_vdso_user_code_vaddr_hook(hook: Fn[uint64]):
    vdso_user_code_vaddr_hook = hook


def register_sig_trampoline_user_vaddr_hook(hook: Fn[uint64]):
    sig_trampoline_user_vaddr_hook = hook


def sig_trampoline_user_vaddr_get() -> uint64:
    # The user-reachable trampoline VA, or 0 if no Linux task has mapped it
    # yet (pre-first-Linux-exec window).
    if sig_trampoline_user_vaddr_hook == cast[Fn[uint64]](0):
        return 0
    return sig_trampoline_user_vaddr_hook()


def vdso_map_into_user(pml4_phys: uint64) -> uint64:
    # F4 inversion thunk: invoke through the registered hook, or return
    # 0 (vDSO not ready / not in this build). Existing callers spell out
    # the unchanged name so the call sites stay identical — only the
    # symbol resolution moved from a Layer-2 import to a hook pointer.
    if vdso_map_into_user_hook == cast[Fn[uint64, uint64]](0):
        return 0
    return vdso_map_into_user_hook(pml4_phys)


def vdso_user_code_vaddr() -> uint64:
    if vdso_user_code_vaddr_hook == cast[Fn[uint64]](0):
        return 0
    return vdso_user_code_vaddr_hook()


# Linux .ko (de)loader (linux_abi/loader.ad):
#   kmod_linux_load_hook  : load and link a stock Linux 6.12 ET_REL
#                           .ko image. Returns the loaded-module slot
#                           id (>= 1) on success, or a negative errno.
#   kmod_linux_unload_hook: unload a module by slot id.
# Used by SYS_INIT_MODULE / SYS_DELETE_MODULE.
kmod_linux_load_hook_sys:   Fn[int32, Ptr[uint8], uint64]
kmod_linux_unload_hook_sys: Fn[int32, int32]


def register_kmod_linux_load_hook_sys(
        hook: Fn[int32, Ptr[uint8], uint64]):
    kmod_linux_load_hook_sys = hook


def register_kmod_linux_unload_hook_sys(
        hook: Fn[int32, int32]):
    kmod_linux_unload_hook_sys = hook


# Track 4 UMDF privileged-primitive hooks. Bodies in
# linux_abi/umdf_kernel.ad; registered by loader_init() at bring-up so
# Layer 1 (this dispatcher) never statically names the Linux-ABI module.
# A native-only build leaves them null and the UMDF syscalls return
# -ENOSYS.
umdf_mmio_map_hook:  Fn[uint64, uint64, uint64]            # (phys,len)->VA
umdf_dma_alloc_hook: Fn[uint64, uint64, Ptr[uint64]]       # (len,&phys)->VA
umdf_irq_open_hook:  Fn[int32, uint64]                     # (vector)->fd
umdf_irq_is_fd_hook: Fn[int32, int32]                      # (fd)->0/1
umdf_irq_read_hook:  Fn[uint64, int32]                     # (fd)->count/-errno


def register_umdf_mmio_map_hook(hook: Fn[uint64, uint64, uint64]):
    umdf_mmio_map_hook = hook


def register_umdf_dma_alloc_hook(hook: Fn[uint64, uint64, Ptr[uint64]]):
    umdf_dma_alloc_hook = hook


def register_umdf_irq_open_hook(hook: Fn[int32, uint64]):
    umdf_irq_open_hook = hook


def register_umdf_irq_io_hooks(is_fd: Fn[int32, int32],
                               rd: Fn[uint64, int32]):
    umdf_irq_is_fd_hook = is_fd
    umdf_irq_read_hook = rd


# Linux syscall fall-through dispatcher (linux_abi/u_syscalls.ad):
#   The do_syscall() body in this file hands every syscall request
#   that arrives from an is_linux_userspace task to this hook. A
#   native-only build never registers it; an is_linux_userspace task
#   reaching that code path then gets -ENOSYS (which is the correct
#   answer for a build with no Linux ABI bound in).
linux_u_syscall_dispatch_hook: Fn[int64, uint64, uint64, uint64,
                                  uint64, uint64, uint64, uint64]


def register_linux_u_syscall_dispatch_hook(
        hook: Fn[int64, uint64, uint64, uint64,
                 uint64, uint64, uint64, uint64]):
    linux_u_syscall_dispatch_hook = hook


# timerfd pool (linux_abi/u_epoll.ad):
#   Shared between Linux-ABI timerfd_create/settime and native
#   SYS_TIMERFD_CREATE/SETTIME. The pool is one object; the hooks let
#   native code reach it without statically depending on u_epoll.ad.
#   timerfd_mark_hook returns the FD_TIMERFD_MARK constant the pool's
#   read-side dispatcher in fs/vfs.ad uses to recognise a timerfd; the
#   ops are direct pointers.
timerfd_mark_hook:               Fn[uint32]
timerfd_alloc_hook:              Fn[int32]
timerfd_valid_hook:              Fn[int32, int32]
timerfd_arm_hook:                Fn[int64, int32, uint64, uint64]
timerfd_gettime_remaining_hook:  Fn[uint64, int32]
timerfd_gettime_interval_hook:   Fn[uint64, int32]


def register_timerfd_ops_hook(mark_op:        Fn[uint32],
                              alloc_op:       Fn[int32],
                              valid_op:       Fn[int32, int32],
                              arm_op:         Fn[int64, int32, uint64, uint64],
                              remain_op:      Fn[uint64, int32],
                              interval_op:    Fn[uint64, int32]):
    timerfd_mark_hook              = mark_op
    timerfd_alloc_hook             = alloc_op
    timerfd_valid_hook             = valid_op
    timerfd_arm_hook               = arm_op
    timerfd_gettime_remaining_hook = remain_op
    timerfd_gettime_interval_hook  = interval_op


# =====================================================================


IA32_STAR:  uint32 = 0xC0000081
IA32_LSTAR: uint32 = 0xC0000082
IA32_FMASK: uint32 = 0xC0000084

# Syscall numbers — kept tiny and demo-focused.
SYS_PUTC:        uint64 = 0
SYS_EXIT:        uint64 = 1
SYS_GET_JIFFIES: uint64 = 2
SYS_CLONE:       uint64 = 3                    # a0 = entry, returns new pid
SYS_GETPID:      uint64 = 4
SYS_OPEN:        uint64 = 5                    # a0 = name ptr, returns fd
SYS_READ:        uint64 = 6                    # a0=fd, a1=buf, a2=count
SYS_CLOSE:       uint64 = 7
SYS_WRITE:       uint64 = 8                    # a0=fd, a1=buf, a2=count
SYS_LSEEK:       uint64 = 9                    # a0=fd, a1=offset, a2=whence
SYS_EXECVE:      uint64 = 10                   # a0=path, a1=argv, a2=envp (Linux ABI only); never returns on success
SYS_SPAWN:       uint64 = 11                   # #450 F6: RETIRED (number reserved); use lib/p9.ad's spawn() — rfork(RFPROC|RFFDG|RFNAMEG) + execve
SYS_WAITPID:     uint64 = 12                   # a0=pid, a1=flags (bit0=WNOHANG); returns child exit_code or -EAGAIN if WNOHANG and child still alive
SYS_OPEN_WRITE:  uint64 = 13                   # a0=path; creates/truncates, returns fd
SYS_PIPE:        uint64 = 14                   # a0=Ptr[int32 fds[2]]; returns 0 on success
SYS_KILL:        uint64 = 15                   # #450 F6: NEGATIVE-pid only (job-control kill(-pgid, sig)); positive pid -> -ENOSYS, use /proc/<pid>/note
SYS_DUP:         uint64 = 16                   # a0=oldfd; returns newfd
SYS_DUP2:        uint64 = 17                   # a0=oldfd, a1=newfd; returns newfd
SYS_LISTDIR:     uint64 = 18                   # #450 F6: RETIRED (number reserved); use lib/p9.ad's p9_listdir() — open(dir) + read(buf) + close
SYS_CHDIR:       uint64 = 19                   # a0=path; returns 0 / -E2BIG
SYS_GETCWD:      uint64 = 20                   # a0=buf, a1=count; returns bytes (incl NUL)
SYS_UNLINK:      uint64 = 21                   # a0=path; returns 0 / -errno
SYS_MKDIR:       uint64 = 22                   # a0=path; real for tmpfs (V1 tree)
SYS_READ_NB:     uint64 = 23                   # a0=fd, a1=buf, a2=count; non-blocking read: >0 bytes, 0 would-block, -1 EOF/error
SYS_YIELD:       uint64 = 24                   # cooperative yield: drop the CPU to any other ready task; returns 0

# Phase B / M16.93: Plan 9-shape native syscall number block. Reserved
# 256..274 in docs/native-api.md (Phase B). All but SYS_ERRSTR are
# stubs that return -ENOSYS at this milestone; Phase C lands real
# implementations one at a time. The numbers themselves are stable
# from here — userland binaries can write `syscall6(265, ...)` for
# errstr today and the call site won't shift when rfork/bind/mount
# land their bodies.
SYS_RFORK:       uint64 = 256                  # Phase C: stub -ENOSYS
SYS_BIND:        uint64 = 257                  # Phase C: stub -ENOSYS
SYS_MOUNT:       uint64 = 258                  # Phase C: stub -ENOSYS
SYS_UNMOUNT:     uint64 = 259                  # Phase C: stub -ENOSYS
SYS_CREATE:      uint64 = 260                  # Phase C: stub -ENOSYS
# SYS_STAT_P9 / SYS_FSTAT_P9 are suffixed _P9 to avoid colliding with
# any future Linux-shape SYS_STAT we'd want to reserve. The native
# binary calls them by literal number 261 / 262 either way.
SYS_STAT_P9:     uint64 = 261                  # Phase C: stub -ENOSYS
SYS_FSTAT_P9:    uint64 = 262                  # Phase C: stub -ENOSYS
SYS_REMOVE:      uint64 = 263                  # Phase C: stub -ENOSYS
SYS_FD2PATH:     uint64 = 264                  # Phase C: stub -ENOSYS
SYS_ERRSTR:      uint64 = 265                  # a0=buf, a1=nbuf; read/install error string
# Phase C / native wstat: the last two Plan 9 reserved syscalls in the
# 256..271 block. Bodies live in sys/src/9/port/sysfile.ad as
# do_wstat / do_fwstat. wstat honours the `name` field (rename) and
# accepts `mode` as a successful no-op (no per-inode mode storage
# yet); length / mtime / gid / muid stay sentinel-only.
SYS_WSTAT:       uint64 = 266                  # a0=path, a1=buf, a2=nbuf
SYS_FWSTAT:      uint64 = 267                  # a0=fd, a1=buf, a2=nbuf
# Phase C / M16.109: Plan 9 note (signal) primitives. Reserved numbers
# 270 / 271 in docs/native-api.md; bodies in sys/src/9/port/sysnote.ad.
SYS_NOTIFY:      uint64 = 270                  # a0=handler RIP (0 = clear); returns 0
SYS_NOTED:       uint64 = 271                  # a0=action (NCONT/NDFLT/NSAVE/NRSTR); returns 0
# U-resolve: native-ABI hostname -> IPv4 resolver. Number 269 is the
# one free slot in the Plan 9 reserved block (268 = fauth reserved,
# 270/271 = notify/noted). a0 = Ptr to a NUL-terminated hostname,
# a1 = hostname byte length (excl NUL; advisory bound). Returns the
# resolved IPv4 packed big-endian into the low 32 bits — octet 0 in
# bits 31:24 — so a positive return is always a valid address and a
# negative return is an errno. -2 (-ENOENT) means "cannot resolve".
SYS_RESOLVE:     uint64 = 269                  # a0=hostname ptr, a1=len; returns packed IPv4 / -errno
# Phase D / V4: Plan 9 `srv` post/open. Numbers 272..274 are reserved
# in docs/native-api.md (awake/segattach/segdetach — none implemented),
# so SYS_SRV_POST / SYS_SRV_OPEN pick the next two free slots above
# the reserved block. Bodies live inline below (validation + a thin
# wrapper around sys/src/9/port/devsrv.ad). This is the userspace
# surface that unblocks V4 — without it /srv stays empty, hamwd has
# no way to publish itself, and `mount` over a posted srvfd is
# bootstrap-only.
SYS_SRV_POST:    uint64 = 275                  # a0=name, a1=srvfd; returns 0/-1
SYS_SRV_OPEN:    uint64 = 276                  # a0=name; returns new fd / -1
# U-TLS: native-ABI tls_connect(2). Number 277 is the next free slot
# above the SYS_SRV_OPEN (276) block — outside the 272..274 reserved
# range (awake/segattach/segdetach).
# ARCH §10: SYS_TLS_CONNECT (277) is RETIRED — TLS is a Plan-9-shaped
# upgrade of a /net connection, not a syscall. Native code runs the
# TLS 1.3 handshake by writing a `tls <host>` ctl command to a
# connected /net/tcp conn (user/net9.ad's net_dial_tls -> the `tls`
# arm in drivers/net/devnet.ad -> drivers/net/tls.ad). The number 277
# is left unassigned — the constant below is kept only as a record of
# the freed slot.
SYS_TLS_CONNECT_RETIRED: uint64 = 277          # retired — see /net `tls` ctl (devnet.ad)
# HAMSH §7: the `#d`-fd-device namespace primitives. /fd/N is a name
# in a process's Pgrp; pipe / redirect / dup all reduce to "bind a
# Chan at /fd/N". 278..280 are the next free slots above 277.
SYS_FDBIND:      uint64 = 278  # a0=pid(0=self), a1=fdnum, a2=kind, a3=arg; THE bind primitive (pipe/redirect/dup)
# 279 is intentionally reserved/skipped — no syscall has ever occupied
# it. The gap is deliberate (it leaves a slot free between the /fd-bind
# primitive and the pipe-chan primitive), not a missing entry.
SYS_PIPECHAN:    uint64 = 280  # returns a pipe SLOT id (not fds); the chan ends for an /fd bind
SYS_OPENCHAN:    uint64 = 281  # a0=path, a1=write; opens a file as a channel, returns the tmpfs slot
SYS_NSID:        uint64 = 282  # returns an opaque per-Pgrp namespace identity (the Pgrp pointer)
# 283/284 — RETIRED, never reuse. They were SYS_DFS_LOAD/SYS_DFS_SAVE,
# a private kernel backing-store channel for user/distrofs.ad's
# snapshot. That bypassed the namespace (a userland file server
# persisting through a magic syscall instead of a file); distrofs now
# writes its snapshot to a real file opened through its own namespace
# ("#part0/distrofs<inst>.dat" by default) and gets durability from
# the /dev/sync barrier cdev. Old binaries calling 283/284 get the
# default -ENOSYS arm.
SYS_NSLABEL:     uint64 = 285  # a0=op(0=stamp,1=unmount), a1=label, a2=to_path, a3=from_path; HAMSH §14 mount handles
# Network-config syscall. The `ifconfig` command reads and writes the
# IPv4 stack's current address / netmask / gateway / DNS through this
# single multiplexed entry point. a0 selects the operation:
#   op 0 (GET)      a1 = Ptr to a 24-byte buffer; the kernel fills it
#                   with the current config (see do_netcfg for the
#                   byte layout). Returns 0.
#   op 1 (SET_ADDR) a1..a4 unused; the 4 address + 4 mask octets are
#                   packed: a1 = addr (octet0<<24..octet3), a2 = mask
#                   (same packing). Latches a static config. Returns 0.
#   op 2 (SET_GW)   a1 = gateway packed octet0<<24..octet3. Returns 0.
#   op 3 (SET_DNS)  a1 = DNS server packed octet0<<24..octet3. Returns 0.
# A static SET_* pins ip_cfg_source / dns_server_static so a racing
# DHCP ACK can't clobber the operator's config. 286 is the next free
# slot above SYS_NSLABEL.
SYS_NETCFG:      uint64 = 286
# HAMSH §7: query the DEVFD_* kind currently bound at /fd/<fdnum> in a
# process's Pgrp. Returns DEVFD_NONE (0) if the slot is unbound. Used by
# hamsh's startup so it can avoid clobbering an /fd/N binding the kernel
# (or an earlier task in the chain) already set up — e.g. an SSH-spawned
# hamsh whose /fd/0,1,2 were pre-bound by the legacy-fd SYS_SPAWN path's
# auto-populate. a0 = pid (0 = self), a1 = fdnum. Returns the int32 kind
# value (DEVFD_NONE / DEVFD_CONS / DEVFD_PIPE_R / DEVFD_PIPE_W / DEVFD_FILE).
SYS_FDSLOT_KIND: uint64 = 287
# Sibling of SYS_FDSLOT_KIND: read the int32 ARG bound at /fd/<a1> in pid
# a0 (0=self) — the pipe/file/dup slot. hamsh's `enter NS { }` captures the
# parent's (kind,arg) for fd 0/1/2 and re-binds them into a clean-namespace
# child so the child's stdout reaches the same pipe/pane, not the console.
SYS_FDSLOT_ARG:  uint64 = 324
# docs/security.md: Plan-9-shape uid/gid syscalls. uid 1 is the
# hostowner; >= 1000 a regular user; 2..999 system uids (services).
# uid 0 doesn't exist in Hamnix's model. SETUID is privileged; the
# only legitimate userland path is /dev/auth post-auth in newshell.
#
# Number pick: next free above SYS_FDSLOT_KIND (287), still in the
# Plan-9 256+ range.
SYS_GETUID:      uint64 = 288  # () -> uint32 current uid
SYS_GETGID:      uint64 = 289  # () -> uint32 current gid
SYS_SETUID:      uint64 = 290  # a0=uid; only hostowner (uid==1) can call; sets uid+gid to a0
# /proc/svc Phase 6: kernel-side service-mirror publish. The supervisor
# (user/hamsh.ad) holds the live svc registry in its own address space.
# `cat /proc/svc/<name>` needs the kernel to know that state; this
# syscall updates a fixed-size mirror table in fs/procfs.ad whenever
# the supervisor mutates a slot. a0=name (Ptr[char]), a1=400-byte
# packed payload (NULL means unpublish/remove). Hostowner-only: same
# rationale as SYS_SETUID — only PID 1's supervisor has any business
# writing to /proc/svc, and a non-hostowner caller forging an entry
# would be a confused-deputy escalation.
SYS_SVC_PUBLISH: uint64 = 291  # a0=name, a1=payload (0=unpublish); returns 0/-1
SYS_SET_REALTIME: uint64 = 292 # a0=unix_epoch_seconds; anchors rtc_boot_epoch on a0 - (TSC delta). user/ntpd.ad calls this.
# hamUI Phase 2: per-wid window registration. The userland /bin/hamUI
# tool sys_spawns a detached hamsh, then calls SYS_WSYS_ALLOC(child_pid)
# to claim a wid for it. SYS_WSYS_FREE(wid) releases the slot at close
# time (after SIGTERM'ing the bound shell). Hostowner-only, same
# rationale as SYS_SVC_PUBLISH — only the supervisor / hamUI tool has
# any business mutating the wsys table. Numbers 293/294 because F2's
# SYS_SET_REALTIME took 292.
SYS_WSYS_ALLOC:  uint64 = 293  # a0=pid; returns the assigned wid (>=2), -1 on full
SYS_WSYS_FREE:   uint64 = 294  # a0=wid; returns 0/-1
# useradd: provision a per-user home file server on the shared ext4
# root. a0 = username (Ptr[char]). Hostowner-only (same rationale as
# SYS_SETUID): editing .hamnix-roots + mkdir'ing a top-level partition
# subtree is a privileged disk mutation. Returns 0 or a negative errno
# (-1 EPERM, -17 EEXIST, -22 EINVAL, -28 ENOSPC, -30 no-ext4). See
# fs/ext4.ad::ext4_useradd_root + user/useradd.ad.
SYS_USERADD_ROOT: uint64 = 295  # a0=username; hostowner-only; returns 0/-errno
# Service-control mailbox (service / init native commands -> PID-1
# supervisor). a0 = verb, a1 = name (Ptr[char], may be 0). Verbs:
#   0 = poll (PID-1 only): dequeue the next pending request; the kernel
#       returns the verb (0 = empty) and stages the name at the buffer
#       reachable via SYS_SVC_CTL verb 7 (read-out). 1=start 2=stop
#       3=restart 4=enable 5=disable 6=runlevel. Verb 7 = copy the last
#       dequeued name into the caller buffer at a1 (cap a2). Producer
#       verbs (1..6) are open to any process: a service-control request
#       is no more privileged than typing the command; the supervisor
#       enforces policy when it acts. Poll/read-out (0/7) are gated to
#       hostowner (uid 1) since only PID 1 should drain the queue.
SYS_SVC_CTL:      uint64 = 296  # a0=verb, a1=name, a2=cap; see above
# Job control (hamsh fg/bg/jobs/Ctrl-Z). Three native primitives:
#  SYS_SETPGID    — a0=pid (0=self), a1=pgid (0=use pid). Place the
#                   task in process group a1; the shell calls it to put
#                   a backgrounded pipeline in its own group. Returns 0
#                   or -ESRCH.
#  SYS_TCSETPGRP  — a0=pgid. Make a1 the terminal's FOREGROUND group:
#                   Ctrl-C/Ctrl-Z then signal only that group. The
#                   shell sets it to a job's pgid on fg, back to 1 when
#                   the job exits/stops. pgid 0 → "no foreground job"
#                   (bare-prompt; terminal signals are dropped). 0.
#  SYS_WAITPID_JC — a0=pid, a1=&status (Ptr[int64]). Non-blocking
#                   job-control wait: returns the pid and writes a
#                   status word distinguishing EXITED / STOPPED /
#                   CONTINUED; returns 0 when nothing to report. The
#                   status encoding lives in the SYS_WAITPID_JC arm.
SYS_SETPGID:     uint64 = 297  # a0=pid(0=self), a1=pgid(0=pid); returns 0/-ESRCH
SYS_TCSETPGRP:   uint64 = 298  # a0=pgid; sets terminal foreground group; returns 0
SYS_WAITPID_JC:  uint64 = 299  # a0=pid, a1=&status; non-blocking; returns pid/0
# docs/security.md Phase 4: /dev/auth-mediated identity change. a0 = an
# open /dev/auth fd that has SUCCESSFULLY verified a (user, pass) pair.
# The kernel recovers the fd's devauth slot, confirms it verified, and
# sets the calling task's uid+gid to the slot's verified pair. Unlike
# SYS_SETUID (hostowner-only, downgrade-only), this is the Plan-9
# "prove the password, the kernel changes you" idiom: ANY task that
# authenticated on the fd may drop INTO that freshly-validated identity.
# This is what lets login/su switch a fresh process to the authenticated
# user even when the spawning context is not the hostowner — the gate is
# the password proof carried in the fd's slot, not the caller's prior
# uid. Returns the new uid (>=0) on success, -1 if the fd isn't an
# /dev/auth fd or hasn't verified.
SYS_SETUID_AUTH: uint64 = 300  # a0=/dev/auth fd; sets uid+gid to the slot's verified pair
SYS_RESOLVE_PTR: uint64 = 301  # a0=packed IPv4 (octet0 high), a1=out name buf, a2=buf cap; reverse (PTR) lookup. returns 0 / -errno
# §142: native mmap/munmap/mprotect for Adder userland. Numbers 302-304
# are the next free slots above SYS_RESOLVE_PTR (301). These are
# NATIVE syscall numbers (NOT Linux's 9/10/11 which are taken by
# SYS_LSEEK/SYS_EXECVE/SYS_SPAWN in the Hamnix native ABI).
# Linux binaries continue to use the Linux ABI path (linux_u_syscall_
# dispatch → _u_mmap/_u_mprotect/_u_munmap in linux_abi/u_syscalls.ad).
# Native Adder programs call these via sys_mmap/sys_mprotect/sys_munmap
# wrappers in user/runtime.S.
#   a0=addr, a1=len, a2=prot, a3=flags, a4=fd, a5=offset (6-arg)
SYS_MMAP:     uint64 = 302  # void* mmap(addr,len,prot,flags,fd,off); returns mapped addr / -errno
SYS_MPROTECT: uint64 = 303  # int mprotect(addr,len,prot); returns 0 / -errno
SYS_MUNMAP:   uint64 = 304  # int munmap(addr,len); returns 0 / -errno
# SYS_MSYNC renumbered 305 → 317 (#445): VFS §links owns 305/306
# (SYS_SYMLINK/SYS_LINK predate the mmap family here; a later msync
# commit re-took 305 and shadowed SYS_SYMLINK in the dispatcher).
# 314-316 are the sem family (#443). Native msync has no userland
# wrapper today; the Linux ABI msync(2) (linux_abi/u_syscalls.ad)
# carries its own Linux number and is unaffected. Do NOT reuse
# 305/306 for anything but the link family.
SYS_MSYNC:    uint64 = 317  # int msync(addr,len,flags); writeback MAP_SHARED file pages
# #458 F10-6: Plan 9 Dir-record directory read. a0=path (Ptr[char]),
# a1=user buf (Ptr[uint8]), a2=count (bytes the caller will accept).
# Returns bytes copied to a1 (>= 0) or -errno. Wire format defined in
# lib/p9dir.ad. v1 routes /srv to devsrv_list_dir; other paths return
# -ENOSYS (-38) until their backings migrate (incremental F10-6 rollout).
SYS_LISTDIR_RECORDS: uint64 = 318
# F10-6 followup: flip a directory fd into Dir-record mode. a0 = fd
# (must be a DEV_DIR_FILE FD_CHAN_MARK fd), a1 = mode (1 = on, 0 = off
# — flip-back is not supported once the transform has run), a2 = the
# absolute parent path the fd was opened against (needed by the
# kernel-side transform helper to stat each NAME\n entry for its real
# metadata). Returns 0 on success, -errno on failure (-EBADF on a
# non-dir fd, -EINVAL on a bad mode, -ENOMEM on transform alloc fail).
# Co-exists with SYS_LISTDIR_RECORDS (318): callers that already use
# p9_listdir_records bypass the per-fd flag entirely.
SYS_CHAN_DIR_MODE: uint64 = 319
# M16.x §links: namespace-aware link syscalls.
# SYS_SYMLINK: a0=target (Ptr[char]), a1=linkpath (Ptr[char]); creates a
#   symlink at linkpath whose content is target. Returns 0 / -errno.
SYS_SYMLINK:  uint64 = 305
# SYS_LINK: a0=oldpath (Ptr[char]), a1=newpath (Ptr[char]); creates a
#   hardlink. Rejects cross-file-server links with -EXDEV (-18). Returns
#   0 / -errno. Boundary check is namespace/file-server, NOT POSIX mode bits.
SYS_LINK:     uint64 = 306
# §146: high-resolution time — TSC-based clock, cooperative sleep, timer fds.
# Renumbered to 307–310 (VFS §links owns 305/306).
SYS_CLOCK_GETTIME:   uint64 = 307  # a0=clockid, a1=Ptr[timespec]; returns 0/-errno
SYS_NANOSLEEP:       uint64 = 308  # a0=Ptr[timespec req], a1=Ptr[timespec rem] (may be 0); blocks cooperatively; returns 0/-errno
SYS_TIMERFD_CREATE:  uint64 = 309  # a0=clockid, a1=flags; returns fd / -errno
SYS_TIMERFD_SETTIME: uint64 = 310  # a0=fd, a1=flags, a2=Ptr[itimerspec new], a3=Ptr[itimerspec old] (may be 0); returns 0/-errno
# #151 / CFS-lite. SYS_NICE adjusts the CALLING task's scheduling nice
# value (and thereby its load weight). Two modes, distinguished by a1:
#   a1 == 0 (SET):  set absolute nice = (int)a0, clamped to [-20, +19].
#                   Returns the new nice value (0..39 biased? no — the
#                   RAW signed nice, sign-extended into uint64).
#   a1 == 1 (GET):  return the calling task's current nice value (a0
#                   ignored). Lets userland/tests read back the effective
#                   priority without a separate getpriority syscall.
# This is a native Layer-1 facility (the scheduler is Layer-1); it is
# also reachable by Linux guests via the Linux setpriority forwarding in
# linux_abi. Returns the resulting nice value on success.
SYS_NICE:            uint64 = 311  # a0=nice (SET) / ignored (GET), a1=op(0=set,1=get); returns nice
# GPU track #183: render native Vulkan frame `frame` into window `wid`'s
# draw surface fb layer ("vk"). The kernel-side lib/vk software
# rasterizer renders a rotating triangle and presents it into the SAME
# per-window draw FILE SURFACE a normal app paints into, so the userland
# desktop compositor (hamUId) composites it like any other window. This
# is the kernel/userland bridge: lib/vk is kernel-only, the DE is
# userland; the daemon calls this once per frame to drive live animated
# Vulkan window content. Hostowner-only (mirrors SYS_WSYS_ALLOC).
# a0=wid, a1=reserved(0), a2=frame index. Returns 0 / -errno.
SYS_VK_WINDOW_FRAME: uint64 = 312

# SYS_WAITFDS — native multi-fd readiness wait (the Plan 9-flavoured
# alternative to select/poll for native apps; the compositor's event
# loop blocks here instead of spinning SYS_READ_NB polls).
# a0=user ptr to int32 fds[], a1=nfds (<= NR_FDS), a2=timeout_ms.
# Returns the lowest READY index, -1 on timeout, -EINTR on signal.
# Readiness = "a read would return now" (vfs_waitfds_probe).
SYS_WAITFDS: uint64 = 313

# #443: native Plan 9-shape user semaphores (sys/src/9/port/sems.ad) —
# THE native synchronisation primitives lib/thread.ad's mutex/join/
# channels are built on. Native code does NOT get a futex clone; futex
# stays confined to the linux_abi shim. The semaphore word is a user
# uint32; the userland fast path uses the compiler's LOCK-prefixed
# atomic intrinsics and only syscalls on contention.
#   SYS_SEMACQUIRE: a0=&sem word, a1=block. Wait until *a0 > 0, atomic
#                   decrement, return 1. block==0 → never sleeps,
#                   returns 0 if unavailable. -EINTR on signal,
#                   -EFAULT on a bad address.
#   SYS_SEMRELEASE: a0=&sem word, a1=count (>0). Atomic *a0 += count,
#                   wake all waiters. Returns count / -errno.
#   SYS_SETEXITSEM: a0=&sem word (0 clears). Registers the CURRENT
#                   task's exit-notification semaphore: on exit the
#                   kernel semreleases it after the task is off its
#                   user stack — thread_join() == semacquire(&t.done).
SYS_SEMACQUIRE: uint64 = 314
SYS_SEMRELEASE: uint64 = 315
SYS_SETEXITSEM: uint64 = 316

# F10-8 / #457: NATIVE seccomp-lite userland arming surface. Bodies +
# per-task store live in kernel/sched/core.ad; the do_syscall entry gate
# is above (search "seccomp_native_check_entry"). This syscall is the
# ONLY way userland can arm or extend its own native allow-list — once
# armed the filter is IRREVOCABLE (matches the Linux seccomp(2) ratchet)
# and inherits across fork/rfork/clone via seccomp_inherit_to_child.
# Layer-2 (Linux ABI) tasks arm via the Linux prctl(PR_SET_SECCOMP) /
# seccomp(2) path — this syscall covers ONLY the native nr surface.
#   a0 = op:
#        0 = ARM with the bitmap pointed to by a1 (a Ptr[uint64] of 4
#            words, low word first, bit `nr & 63` of word `nr >> 6` ==
#            ALLOW). Returns 0 on success, -1 on bad address.
#        1 = NARROW: AND the bitmap at a1 into the existing allow-list.
#            Can only clear allow-bits (further restrict), never set
#            them — the irrevocable ratchet says you may shrink the
#            surface but never widen it. Returns 0 on success, -1 if
#            not yet armed or bad address.
#        2 = QUERY: returns 1 if armed, 0 if disarmed.
#   a1 = Ptr[Array[4, uint64]] (op 0/1) / ignored (op 2).
# Self-only — there is no slot argument; this targets current_task. The
# bitmap is 256-bit (matches the per-task store); nrs >= 256 are
# implicitly denied once armed (deny-by-default-out-of-range), so e.g.
# SYS_RFORK=256 stays unblocked only while the filter is disarmed.
#
# NOTE: numbered 320 (NOT 318) — 318 was already taken by
# SYS_LISTDIR_RECORDS (the F10-6 Dir-record directory read). The seccomp
# commit originally assigned 318 here too, which silently shadowed
# SYS_LISTDIR_RECORDS (the seccomp-native dispatch arm runs first), so
# every sys_listdir_records() returned the seccomp-native verdict instead
# of a Dir-record stream and `ls -l` of /proc, /net, /dev/blk broke.
SYS_SECCOMP_NATIVE: uint64 = 320

# Track 4 UMDF (User-Mode Driver Framework) privileged primitives. A
# userland driver host requests these over the syscall channel; bodies
# live in linux_abi/umdf_kernel.ad, reached through the hooks below so
# Layer 1 stays free of a static Linux-ABI import.
SYS_UMDF_MMIO_MAP: uint64 = 321    # a0=phys, a1=len; -> user VA / -errno
SYS_UMDF_DMA_ALLOC: uint64 = 322   # a0=len, a1=&out_phys; -> user VA / -errno
SYS_UMDF_IRQ_OPEN: uint64 = 323    # a0=vector; -> irq fd / -errno

# §146: clockid constants for SYS_CLOCK_GETTIME / SYS_TIMERFD_CREATE.
# Values match POSIX / Linux so userland can use the same literals.
CLOCK_REALTIME:  uint64 = 0
CLOCK_MONOTONIC: uint64 = 1
# HAMSH §7: sys_spawn's stdin_fd / stdout_fd sentinel. When the caller
# passes SPAWN_STDIO_NS, the child's standard streams are NAMES in its
# namespace (/fd/0,1,2 via the `#d` device), not dup'd integer fds —
# the caller wires them via SYS_FDBIND. -2 is outside the [0,16) valid-
# fd band and distinct from the -1 "inherit" sentinel.
SPAWN_STDIO_NS:  int32  = -2

# Linux-numbered syscalls (L-track, linux_abi/). We use the stock
# Linux 6.12 x86_64 numbers so userspace tools built against Linux's
# unistd_64.h can call them by literal number.
# U-socket: native-ABI socket(2)/connect(2). The numbers match
# Linux's so a binary that hard-codes the Linux socket syscall numbers
# lands here unchanged.
# ARCH §10: ALL native BSD socket syscalls are RETIRED from the NATIVE
# dispatch table — socket()/connect()/bind()/listen()/accept() are
# BSD/Linux concepts, and Layer 1 is Plan-9-shaped, so native code uses
# the /net file tree (user/net9.ad's net_dial / net_dial_tls /
# net_announce / net_accept). The _u_socket / _u_connect / _u_tls_connect
# / _u_accept / _u_bind / _u_listen bodies survive in
# linux_abi/u_syscalls.ad — they are still reached by the Linux ABI's
# OWN dispatcher for stock Linux socket(2)/connect(2)/bind(2)/... ELF
# binaries, and those shims drive /net internally as Layer-2 consumers.
# Numbers 41/42/43/49/50 are left unassigned natively. The constants
# below are kept only as documentation of the freed numbers.
SYS_SOCKET_RETIRED:      uint64 = 41            # retired — see /net (devnet.ad)
SYS_CONNECT_RETIRED:     uint64 = 42            # retired — see /net (devnet.ad)
SYS_SOCKETPAIR:     uint64 = 53                 # a0=domain, a1=type, a2=protocol, a3=Ptr[int32 sv[2]]; returns 0/-1
SYS_ACCEPT_SOCK_RETIRED: uint64 = 43            # retired — see /net (devnet.ad)
SYS_BIND_SOCK_RETIRED:   uint64 = 49            # retired — see /net (devnet.ad)
SYS_LISTEN_SOCK_RETIRED: uint64 = 50            # retired — see /net (devnet.ad)
SYS_INIT_MODULE:    uint64 = 175                # a0=image, a1=size, a2=params
SYS_DELETE_MODULE:  uint64 = 176                # a0=name, a1=flags
# reboot(2): the stock Linux x86_64 number, so a Linux guest binary's
# reboot()/poweroff() lands here. a0=magic1, a1=magic2, a2=cmd, a3=arg.
# Funnels into the same power_action core the native /dev/reboot cdev
# uses. The magics and cmd constants are the real Linux values.
SYS_REBOOT:         uint64 = 169                # a0=magic1, a1=magic2, a2=cmd, a3=arg
# LINUX_REBOOT_* magics/cmds are imported from arch.x86.kernel.power
# (the single source of truth, shared with the Linux-ABI _u_reboot).

# M16.35: the previous user_rsp_save / kernel_rsp globals were
# retired in favour of a per-task syscall stack. syscall_entry now
# reads the current task's kstack_top out of TSS.RSP0 (which
# schedule() keeps current on every context switch) and parks the
# user RSP on that stack instead of in a shared global. That lets
# SYS_WAITPID yield to another task mid-syscall without a sibling
# syscall clobbering the saved slot.


# Maximum argv we'll honour. Picked to comfortably exceed a shell's
# typical needs while keeping the user-stack reservation small (each
# pointer is 8 bytes, each string capped at MAX_ARG_BYTES). Tight
# fixed caps are fine until hamsh asks for more.
#
# Bumped 16 -> 32: the graphical installer (haminstallui -> /bin/install)
# marshals 17 argv words (--auto/disk + --repo + --esp-mb + --part-mode +
# --hostname + --user + --user-pass + --root-pass, each a flag+value pair).
# At the old cap of 16, _argv_count() truncated the vector to 16 entries,
# dropping the trailing --root-pass VALUE. /bin/install then saw
# --root-pass as argc-1 (no following arg) and bailed with
# "unknown option: --root-pass". 32 restores headroom for that and more.
MAX_ARGV:      uint64 = 32
MAX_ARG_BYTES: uint64 = 256

# U17: matching caps for envp[] on the Linux process init-stack.
# Each env string is the literal "NAME=VALUE\0" bytes; both name and
# value share the per-string byte budget. 64 entries comfortably
# covers anything hamsh can stuff into its 8-slot variable table plus
# headroom for what future export semantics might add.
MAX_ENVP:      uint64 = 64
MAX_ENV_BYTES: uint64 = 256

# Linux ELF user stack: 2 MiB (512 pages = buddy order 9), DECOUPLED to a
# high USER VA (LINUX_USTACK_VBASE) over a low alloc_pages() phys run.
#
# STACK-UNDERSIZED-vs-RLIMIT fix (2026-06-25): the stack used to be 256 KiB
# (order 6). But the Linux-ABI shim seeds RLIMIT_STACK = 8 MiB
# (kernel/sched/core.ad rlimit_init_task), so glibc/coreutils believe they
# own a multi-MiB growsdown stack and probe / touch memory BELOW the mapped
# top. Before the high-VA decouple (a6816e0c) the stack lived in low
# identity RAM where adjacent buddy frames happened to be mapped, hiding the
# under-mapping; the decouple exposed it as a hard SIGSEGV — e.g.
# `wc -l /etc/os-release` faulted at VBASE - 0x488, i.e. only ~0x488 bytes
# below the 256 KiB top (glibc placed its frames just past the mapping).
#
# This kernel has NO demand-growsdown stack (a tree-mutating growsdown-VMA
# experiment regressed the VMA interval tree into a #DF on dynamic binaries).
# The robust fix is a FIXED 1 MiB pre-mapped stack whose size is STRICTLY
# GREATER than the seeded RLIMIT_STACK (768 KiB, kernel/sched/core.ad
# rlimit_init_task). glibc's main-thread startup computes its stack LOW bound
# as (stacktop - RLIMIT_STACK) and guard-probes just below it; with the mapped
# window 256 KiB larger than the rlimit (more than the max 64 KiB ASLR slide),
# that bound + probe land INSIDE the mapping instead of below the window
# bottom (the `wc -l` VBASE-0x488 SIGSEGV). 1 MiB is order 8, well under the
# buddy MAX_ORDER=10 (4 MiB) single-alloc ceiling (a 2 MiB order-9 stack
# shifted the buddy free-list enough to re-expose the latent ET_DYN /
# kernel-stack aliasing #PF — order 8 is verified clear of it), and is freed
# on task_reap — bounded per process (cf. the 32 MiB brk reserve), so it does
# NOT reintroduce the eager-BSS OOM the demand path was built to avoid.
# do_clone COW-shares this whole region by VA on fork().
LINUX_USTACK_ORDER: int32  = 8
LINUX_USTACK_SIZE:  uint64 = 1048576     # 256 * 4096 = 1 MiB

# LOW-RAM / ANTI-FRAGMENTATION STACK BACKING (fix/execve-ustack-oom).
# The 1 MiB fixed stack window [VBASE, VBASE+SIZE) is no longer backed by a
# single EAGER order-8 (1 MiB) CONTIGUOUS alloc_pages() run. Under memory
# fragmentation that order-8 run fails even with many MiB free, and — worse —
# the old code passed the resulting phys 0 straight to elf_install_user_range,
# which stamped the window's US=1 leaves onto physical [0, 1 MiB) (the boot
# page tables / AP trampoline) and #DF-halted the box when the DE launched
# apps at low RAM. Now only a small CONTIGUOUS PREFIX at the TOP of the window
# is eager-allocated (order-6, 256 KiB) — where the argv/envp/auxv builder
# writes and where glibc's __libc_stack_end lands — and the LOWER remainder
# [VBASE, prefix_lo) is a DEMAND-ZERO VMA that faults in page-by-page as the
# program pushes (reusing the proven BSS demand machinery, #195/#196). Total
# LOGICAL size is unchanged (1 MiB, matching the seeded RLIMIT_STACK); the
# stack still never grows PAST VBASE. Order-6 is 4x more fragmentation-
# tolerant than order-8, and a pre-PONR pages_can_alloc() guard + a hard
# null-check make a genuine OOM a clean -ENOMEM (caller intact) instead of a
# corrupting past-the-point-of-no-return failure. ASLR_STACK_MAX_PAGES (16 =
# 64 KiB) + realistic argv/env stay well inside the 256 KiB prefix.
LINUX_USTACK_EAGER_ORDER: int32  = 6
LINUX_USTACK_EAGER_SIZE:  uint64 = 262144     # 64 * 4096 = 256 KiB

# DIRECT-MAP / KERNEL-STACK ALIASING FIX (2026-06-25): the Linux user
# stack's USER virtual base now lives HIGH — above the 4 GiB kernel
# direct-map, alongside the ET_DYN load-bias (4 GiB) / interp (5 GiB) /
# brk (6 GiB) windows. It was the LAST user-data region still IDENTITY-
# mapped (vaddr == phys) at low RAM (the brk arena was decoupled to 6 GiB
# in 7224d2c2/d-m-aliasing-fix; the image/mmap were decoupled earlier).
#
# Identity-mapping the stack at its low alloc_pages() physical address made
# the 256 KiB stack window ALIAS the exact low frames the buddy allocator
# hands back for OTHER purposes — including a freshly-spawned task's KERNEL
# STACK (kstack_top ~0x0ffe0000). On a broad Debian closure (larger
# initramfs shifts the buddy free-list), a COW-shared user stack frame and
# a live kernel stack frame land adjacent in the same low band; a CPL=3
# stack push to the US=1 RO COW page resolves against a frame the kernel
# also reaches as identity, and the unrecoverable supervisor #PF the brief
# captured (cr2==rsp, pte phys inside the kstack region) fires.
#
# Decoupling vaddr (HIGH) from phys (LOW alloc_pages run) restores the
# invariant that NO physical frame is simultaneously a live US=1 user
# mapping AND a kernel-reachable identity / direct-map slot at the SAME
# translation — exactly the brk fix, applied to the one region that still
# ran identity. elf_install_user_range already supports phys_base != vlow
# (it computes chunk_phys = phys_base + (vaddr - vlow) per page), and the
# argv/envp/auxv builder writes through the just-installed high-VA US=1
# leaves under STAC with cur_pml4 loaded, so no builder change is needed —
# only the VA it starts from moves high. copy_to/from_user (mm/uaccess.ad)
# PML4-walks the high VA to its low phys so kernel derefs of stack pointers
# keep working.
#
# 7 GiB base: image=[4,5) GiB, interp=[5,6) GiB, brk=[6 GiB, 6 GiB+32 MiB),
# stack=[7 GiB, 7 GiB+1 MiB). The whole 1 MiB span sits inside ONE 1 GiB
# PDPT slot (PDPT[7] of PML4[0]) and never crosses a 1 GiB boundary, so
# elf_install_user_range lays it down in a single per-task PD/PT subtree.
# The mmap window is [8 GiB, ~16 GiB) (mm/vma.ad VMA_LARGE_BASE), so the
# stack is clear of every other Linux user region. The 1 MiB size matches the
# seeded RLIMIT_STACK (kernel/sched/core.ad) exactly — the stack is FIXED
# (no demand growsdown), so glibc must never believe it has more.
LINUX_USTACK_VBASE: uint64 = 0x1C0000000     # 7 GiB


# ===========================================================================
# Stage 2 ASLR — initial-RSP (stack base) randomization.
#
# Audit gating (Stage 3, see docs banner / task report): every user-memory
# path in this kernel assumes a vaddr == phys identity map. The argv/envp/
# auxv builders below directly dereference user pointers and directly STORE
# into the user stack via raw `cast[Ptr[uint64]](str_sp)[0] = ...`; the
# page-table installers (fs/elf.ad::elf_install_user_stack / _range / _heap)
# map [vlow, vhigh) -> phys_base with phys_base == vlow; and the anonymous
# mmap base is the raw alloc_pages() physical address. Randomizing the
# *virtual* base of the image (ET_DYN load bias) or of mmap independently of
# its physical backing would make vaddr != phys and break every one of those
# direct derefs. Those two ASLR forms are therefore DEFERRED until proper
# copy_to/from_user translation helpers exist.
#
# The ONE form that is SAFE today is stack-base randomization expressed as an
# INTRA-REGION slide: the user stack is one identity-mapped alloc_pages()
# run [ustack_base, ustack_base + LINUX_USTACK_SIZE). Every address inside
# that run satisfies vaddr == phys, so perturbing the starting RSP DOWN by a
# random page multiple keeps the whole stack inside the same identity-mapped
# region — vaddr == phys is preserved, no uaccess path changes meaning. The
# argv/auxv builders simply start writing from a slightly lower top.
#
# Bounds: the slide is 0..ASLR_STACK_MAX_PAGES pages (page-aligned). We cap
# it well below the 64-page stack so the argv/envp/auxv block + program
# headroom never runs off the bottom of the allocation. With a 64-page
# (256 KiB) stack, reserving up to 16 pages (64 KiB) of slide leaves 48
# pages (192 KiB) of live stack below the randomized top — ample for glibc
# static-PIE startup and a forked unwind tower.
ASLR_STACK_MAX_PAGES: uint64 = 16        # up to 64 KiB of entropy slide
ASLR_PAGE:            uint64 = 4096

# Per-exec entropy counter. Stirred into the TSC each call so two execs that
# happen to read an identical (low-resolution) TSC value still diverge.
_aslr_stream: uint64 = 0

# --- ASLR deterministic-repro SEED (debug) ---------------------------------
# When non-zero, _aslr_rand64() ignores the TSC/monotonic entropy and draws
# from a pure splitmix64 stream seeded ONLY from this constant. Because the
# per-boot exec order is otherwise deterministic, a fixed seed reproduces the
# EXACT same mmap/stack/load-bias layout on EVERY boot — turning the
# ASLR-flaky apt "Reading package lists" VMA fault into a repeatable crash so
# it can be root-caused and proven fixed. 0 = off (real per-exec entropy).
# KEEP AT 0 on main; set only for a repro build. See docs/aslr_pin knobs.
aslr_det_seed: uint64 = 0

# Set to 1 to disable stack ASLR (e.g. for a deterministic boot diff). Left
# at 0 (enabled) in normal operation. Kept as a global so a future sysctl /
# boot arg can flip it without touching the call sites.
aslr_disabled: int32 = 0

# --- ASLR deterministic-repro pin knobs ------------------------------------
# When non-sentinel, each helper below returns the pinned value INSTEAD of a
# random draw. This turns an ASLR-dependent intermittent fault into a
# deterministic one: pin the exact bias/slide of a captured failing run and
# every boot reproduces it (this is how the #438 reserved-bit #PF was made
# deterministic and then proven fixed). 0 is a legal slide, so the
# stack-slide pin uses ~0 as its "off" sentinel; the bias/base pins use 0
# (no legal bias is 0). These are debug/test knobs — keep them OFF (at the
# sentinels below) on main.
aslr_pin_load_bias:   uint64 = 0                 # 0 = off
aslr_pin_interp_bias: uint64 = 0                 # 0 = off
aslr_pin_mmap_base:   uint64 = 0                 # 0 = off
aslr_pin_stack_slide: uint64 = 0xFFFFFFFFFFFFFFFF  # ~0 = off (0 is legal)


def _aslr_rand64() -> uint64:
    # Real in-kernel entropy: the CPU time-stamp counter (read_tsc, an
    # rdtsc in syscall_64.S) advances every core clock, so its low bits
    # differ wildly between two execs even microseconds apart. We fold the
    # raw TSC together with tsc_monotonic_ns() (a second independent view)
    # and a per-call stream counter, then run the splitmix64 finalizer
    # (the same 0x9E3779B97F4A7C15 mix kernel/stack_protect.ad uses for the
    # stack canary) so the low/high bits are both well diffused. This is
    # NOT crypto-grade, but it is genuine per-exec entropy, not a constant.
    _aslr_stream = _aslr_stream + cast[uint64](0x9E3779B97F4A7C15)
    x: uint64 = read_tsc()
    x = x ^ tsc_monotonic_ns()
    x = x ^ _aslr_stream
    # Deterministic-repro override: derive x from the fixed seed + the
    # per-call stream counter ONLY (no TSC), so the whole boot's draw
    # sequence — and thus the entire ASLR layout — is byte-for-byte
    # reproducible across boots. Off (aslr_det_seed==0) in normal operation.
    if aslr_det_seed != 0:
        x = aslr_det_seed ^ _aslr_stream
    # splitmix64 finalizer.
    x = (x ^ (x >> 30)) * cast[uint64](0xBF58476D1CE4E5B9)
    x = (x ^ (x >> 27)) * cast[uint64](0x94D049BB133111EB)
    x = x ^ (x >> 31)
    return x


# Last stack-ASLR slide chosen, in BYTES. Exported for the proof test: the
# kernel logs it (see the [aslr] sentinel) so two boots can be diffed to
# prove the value is per-exec random. A test reads two boot logs and asserts
# the sentinel value differs.
aslr_last_stack_slide: uint64 = 0


def aslr_stack_slide() -> uint64:
    # Return a page-aligned random slide in [0, ASLR_STACK_MAX_PAGES*PAGE)
    # to subtract from the initial user-stack top. Page-aligned so *rsp
    # stays 16-byte aligned after the argv/auxv builder's own alignment.
    # Returns 0 when ASLR is disabled (deterministic boot mode).
    if aslr_disabled != 0:
        aslr_last_stack_slide = 0
        return 0
    npages: uint64 = _aslr_rand64() % (ASLR_STACK_MAX_PAGES + 1)
    slide: uint64 = npages * ASLR_PAGE
    if aslr_pin_stack_slide != cast[uint64](0xFFFFFFFFFFFFFFFF):
        slide = aslr_pin_stack_slide
    aslr_last_stack_slide = slide
    # Sentinel for the proof test (test_u51_aslr_stack.sh). One line per
    # exec; the test greps it out of two independent boot logs and asserts
    # the value differs across runs while the program still ran correctly.
    #
    # Emit at the default INFO severity. INFO reaches the live console
    # during early boot (the console-loglevel gate is wide-open until the
    # shell goes interactive — see drivers/tty/serial/early_8250.ad) but is
    # suppressed from the live console once interactive, so it no longer
    # floods the line the user is editing in `enter linux`. The line is
    # ALWAYS pushed into the kernel printk ring buffer, so the U51/U52 proof
    # tests retrieve it post-interactively via `dmesg` (which replays the
    # ring) rather than scraping the live console.
    printk1("[aslr] stack slide = %p\n", slide)
    return slide


# ===========================================================================
# U52 ASLR — ET_DYN load-bias + mmap-base randomization.
#
# These two forms were DEFERRED (see the Stage 2 banner above) until proper
# copy_to/from_user translation existed, because randomizing a virtual base
# independently of its physical backing makes vaddr != phys and would have
# broken every raw user-pointer deref. mm/uaccess.ad now provides that
# translation, and the load paths we randomize here NEVER raw-deref the
# biased vaddr from kernel code:
#
#   * ET_DYN load bias: fs/elf.ad copies PT_LOAD bytes to the identity-
#     mapped physical `region`, then elf_install_user_range maps the
#     randomized [vbase, vbase+span) -> [region, region+span). The auxv
#     builder's AT_PHDR/AT_ENTRY just carry the biased vaddrs (plain
#     integers); they're never dereferenced kernel-side. The user stack
#     stays an intra-region identity slide, so the argv/envp/auxv builder's
#     stores into the stack remain valid (the stack's vaddr == phys).
#   * mmap base: the windowed mmap allocator overlays its physical chunks
#     at the window vaddr (kernel writes hit the identity phys, not the
#     window vaddr) or demand-faults pages in at the window vaddr — both
#     already vaddr != phys safe. Perturbing the window start adds no new
#     deref hazard.
#
# Both honour aslr_disabled (deterministic boot => identity layout, no
# slide). Bounds are page/4-MiB-aligned and sized to this kernel's address
# map (read mm/vma.ad's VMA_LARGE_BASE/LIMIT before changing them).

# ET_DYN image-ASLR window. The biased image base lives at [4,5) GiB, below
# the [8 GiB, ~16 GiB) windowed-mmap region and above the low identity band
# that small-anon occupies, so a biased image can never collide with them.
# Base at 4 GiB; up to 1 GiB of page-aligned entropy slide => images land
# in [4 GiB, 5 GiB). 18 bits of page entropy (0x40000 pages). The
# application and the interpreter (ld.so) draw INDEPENDENT bases from this
# window so their relative offset is also randomized.
ASLR_LOADBIAS_BASE:      uint64 = 0x100000000     # 4 GiB
ASLR_LOADBIAS_SLIDE_MAX: uint64 = 0x40000000      # up to 1 GiB of slide
ASLR_INTERP_BASE:        uint64 = 0x140000000     # 5 GiB (interp window)

# mmap-base ASLR bounds. Mirror mm/vma.ad's window constants
# (VMA_LARGE_BASE = 8 GiB, VMA_MMAP_ASLR_SLIDE_MAX = 256 MiB, 4-MiB
# alignment) so the [aslr] mmap-base sentinel logged here matches the
# window start vma_set_mmap_base() actually installs.
ASLR_MMAP_WINDOW_BASE:   uint64 = 0x200000000     # 8 GiB (VMA_LARGE_BASE)
ASLR_MMAP_SLIDE_MAX:     uint64 = 0x10000000      # 256 MiB
ASLR_MMAP_BLOCK:         uint64 = 0x400000        # 4 MiB

# Exported proof sentinels. do_execve logs each via the [aslr] sentinel so
# two boots can be diffed (mirrors aslr_last_stack_slide). aslr_last_load_bias
# is the application image's randomized virtual base; aslr_last_interp_bias
# the interpreter's; aslr_last_mmap_base the mmap-window start.
aslr_last_load_bias:   uint64 = 0
aslr_last_interp_bias: uint64 = 0
aslr_last_mmap_base:   uint64 = 0


def _aslr_reloc_floor() -> uint64:
    # >4 GiB-RAM DIRECT-MAP ALIASING FIX. The fixed ET_DYN app (4 GiB) and
    # interp (5 GiB) ASLR windows were chosen on the assumption that
    # [4 GiB, 6 GiB) holds NO real RAM (true only on <=4 GiB machines). On a
    # box with more RAM those windows fall INSIDE physical RAM's low-identity
    # direct map. When elf_install_user_mapping cracks the 1 GiB window to
    # install the image's user leaves, every UNTOUCHED 2 MiB sibling is seeded
    # ABSENT — but _is_boot_identity_stamp's anti-alias rule only recognises a
    # window AT/ABOVE ram_top, so a within-RAM window is treated as a real
    # direct-map and its holes are NOT backfilled. A later kmalloc whose
    # PHYSICAL page lands in that same 1 GiB window is then UNMAPPED under the
    # per-task cr3; a kernel memcpy into it (e.g. brd_read_sectors filling a
    # file-slurp buffer during exec) #PFs on a not-present kernel page and the
    # trap-diag HALTS the machine (observed loading WebKitGTK's ld.so on a 6 GiB
    # guest: cr2 in [4 GiB,5 GiB), pde absent under the task cr3, present as a
    # 1 GiB identity huge page under the boot cr3).
    #
    # Fix: when RAM extends past the static 4 GiB base, relocate the app+interp
    # windows ABOVE both ram_top and the (unchanged) 8 GiB mmap window, into
    # 1 GiB PDPT slots the boot stub identity-maps but that hold no real RAM.
    # There _is_boot_identity_stamp fires (va_base >= ram_top) so untouched
    # siblings are seeded absent AND — crucially — no real-RAM identity entry is
    # ever cracked, so every kernel direct-map access to a >4 GiB page resolves
    # under any cr3. Returns 0 when the static 4 GiB base already clears RAM
    # (<=4 GiB machines — the CI/gate case: byte-identical behaviour, and the
    # ASLR-proof gates keep their pinned 4 GiB/5 GiB windows).
    rt: uint64 = memblock_region_top()
    if rt <= ASLR_LOADBIAS_BASE:
        return 0
    mmap_top: uint64 = ASLR_MMAP_WINDOW_BASE + ASLR_MMAP_SLIDE_MAX
    floor: uint64 = rt
    if mmap_top > floor:
        floor = mmap_top
    # Round up to a 1 GiB boundary so app / interp each occupy a clean PDPT slot.
    floor = (floor + 0x3FFFFFFF) & ~cast[uint64](0x3FFFFFFF)
    return floor


def linux_ustack_vbase() -> uint64:
    # >4 GiB-RAM DIRECT-MAP ALIASING FIX — the STACK residual of the app/interp
    # reloc (_aslr_reloc_floor). The Linux-ABI user stack lives at a FIXED high
    # VA window (LINUX_USTACK_VBASE = 7 GiB, 1 MiB wide). On a guest with >7 GiB
    # RAM that window falls INSIDE real RAM's low-identity direct map (the boot
    # stub identity-maps the whole low 512 GiB). execve then cracks the 1 GiB
    # window to install the stack's US=1 leaves; because the window base is
    # BELOW ram_top, fs/elf.ad::_is_boot_identity_stamp does NOT fire, so every
    # untouched 2 MiB sibling is reproduced as a REAL identity (US=0) direct-map
    # frame — and, worse, the installed US=1 stack leaves now SHADOW whatever
    # kernel object physically lives at 7 GiB. A kernel CPL=0 access to that
    # phys-7 GiB object via its identity VA then lands on the task's US=1 user-
    # stack page and #PFs under CR4.SMAP (err P=1,W=0,U=0 — the SMAP read
    # signature). The fault-delivery push re-faults on the SAME US=1 page, so
    # the #PF handler entry double-faults -> #DF -> one-shot trap-diag halt.
    # USER-observed on a large-RAM boot right after "window N mapped pid=M"
    # (a Linux DE client's stack came up in the 7 GiB window); intermittent
    # because it needs a kernel object to land in [7 GiB, 7 GiB+1 MiB) while a
    # Linux task's cr3 is the live one.
    #
    # Fix: mirror aslr_load_bias / aslr_interp_bias — when RAM extends past the
    # static 4 GiB base, relocate the stack window ABOVE ram_top, one 1 GiB slot
    # past the relocated interp window (app = reloc, interp = reloc + SLIDE_MAX;
    # both SLIDE_MAX = 1 GiB wide). There _is_boot_identity_stamp fires
    # (base >= ram_top) so the window's siblings are seeded ABSENT and it backs
    # NO real RAM — no identity alias, SMAP-clean under every cr3. On <=4 GiB
    # machines _aslr_reloc_floor returns 0 and the base stays the pinned 7 GiB
    # (CI/gate byte-identical; the <=7 GiB case was already safe because 7 GiB
    # >= ram_top made _is_boot_identity_stamp fire).
    reloc: uint64 = _aslr_reloc_floor()
    if reloc == 0:
        return LINUX_USTACK_VBASE
    base: uint64 = reloc + cast[uint64](2) * ASLR_LOADBIAS_SLIDE_MAX
    # Already 1 GiB-aligned (reloc + 2 GiB); round up defensively.
    base = (base + 0x3FFFFFFF) & ~cast[uint64](0x3FFFFFFF)
    return base


def aslr_load_bias() -> uint64:
    # Return a page-aligned randomized base in [ASLR_LOADBIAS_BASE,
    # ASLR_LOADBIAS_BASE + ASLR_LOADBIAS_SLIDE_MAX) for an ET_DYN
    # application image. Returns 0 when ASLR is disabled — fs/elf.ad treats
    # a 0 vbase as "load identity at the physical region", the exact
    # pre-U52 deterministic layout. Logs the chosen base for the proof test.
    if aslr_disabled != 0:
        aslr_last_load_bias = 0
        return 0
    # >4 GiB-RAM: relocate the app window above ram_top (see _aslr_reloc_floor).
    base_lo: uint64 = ASLR_LOADBIAS_BASE
    reloc: uint64 = _aslr_reloc_floor()
    if reloc != 0:
        base_lo = reloc
    npages: uint64 = _aslr_rand64() % (ASLR_LOADBIAS_SLIDE_MAX / ASLR_PAGE)
    base: uint64 = base_lo + npages * ASLR_PAGE
    if aslr_pin_load_bias != 0:
        base = aslr_pin_load_bias
    aslr_last_load_bias = base
    # Default INFO: shown on the live console pre-interactive, ring-buffer
    # only once interactive (retrieved by U52 via dmesg). See the stack-slide
    # sentinel above for the full rationale.
    printk1("[aslr] load bias = %p\n", base)
    return base


def aslr_interp_bias() -> uint64:
    # Independent randomized base for the PT_INTERP (ld.so) image, drawn
    # from a window above the application's so the two never collide.
    # 0 when disabled.
    if aslr_disabled != 0:
        aslr_last_interp_bias = 0
        return 0
    # >4 GiB-RAM: place the interp window one 1 GiB slot ABOVE the relocated app
    # window (which starts at reloc) so the two never collide; else keep the
    # static 5 GiB window (see _aslr_reloc_floor).
    base_lo: uint64 = ASLR_INTERP_BASE
    reloc: uint64 = _aslr_reloc_floor()
    if reloc != 0:
        base_lo = reloc + ASLR_LOADBIAS_SLIDE_MAX
    npages: uint64 = _aslr_rand64() % (ASLR_LOADBIAS_SLIDE_MAX / ASLR_PAGE)
    base: uint64 = base_lo + npages * ASLR_PAGE
    if aslr_pin_interp_bias != 0:
        base = aslr_pin_interp_bias
    aslr_last_interp_bias = base
    # Default INFO (ring-buffer only once interactive). See above.
    printk1("[aslr] interp bias = %p\n", base)
    return base


def aslr_mmap_slide() -> uint64:
    # Return a 4-MiB-aligned randomized slide in [0,
    # VMA_MMAP_ASLR_SLIDE_MAX) to add to the mmap-window base. Returns 0
    # when ASLR is disabled (deterministic window start). do_execve passes
    # the result to vma_set_mmap_base() and logs the resulting base.
    if aslr_disabled != 0:
        aslr_last_mmap_base = 0
        return 0
    # ASLR_MMAP_SLIDE_MAX is 256 MiB; align the random pick to 4 MiB so
    # every windowed chunk install stays inside one 1 GiB PDPT entry.
    nblocks: uint64 = _aslr_rand64() % (ASLR_MMAP_SLIDE_MAX / ASLR_MMAP_BLOCK)
    slide: uint64 = nblocks * ASLR_MMAP_BLOCK
    if aslr_pin_mmap_base != 0:
        slide = aslr_pin_mmap_base - ASLR_MMAP_WINDOW_BASE
    aslr_last_mmap_base = ASLR_MMAP_WINDOW_BASE + slide
    # Default INFO (ring-buffer only once interactive). See above.
    printk1("[aslr] mmap base = %p\n", aslr_last_mmap_base)
    return slide


# ---------------------------------------------------------------------------
# access_ok — syscall-boundary pointer/length validator.
#
# Returns 1 (true) when the entire range [uptr, uptr+len) is:
#   1. Non-NULL (uptr != 0 unless len == 0).
#   2. Free of pointer+length integer overflow (uptr + len >= uptr).
#   3. Within canonical x86_64 user space [1, USER_ADDR_MAX).
#      USER_ADDR_MAX is the top of the non-canonical hole (bit 47 = 0
#      required → 0x0000800000000000). Any pointer with bits 63:47 set
#      is either kernel-higher-half (≥ 0xffff800000000000) or a
#      non-canonical trap address — both are invalid from userland.
#   4. (Sanity cap) len ≤ 256 MiB — rejects absurd lengths that could
#      overflow downstream size arithmetic even without wrapping.
#
# Returns 0 (false) on any violation. Callers return -EFAULT (-14).
#
# NOTE: This is a FAST RANGE CHECK, not a page-present check. We trust
# the hardware to trap on actually-unmapped pages; this layer stops the
# common cases (kernel pointer, NULL, wild overflow) from ever reaching
# a dereference. A proper per-VMA check would require walking mm/vma.ad
# at O(N_vma) cost per syscall — acceptable once we add hardware PTR
# tracking but too expensive as a blanket gate today.
#
# Zero-length ranges: len == 0 is always OK regardless of uptr (the
# caller will perform no memory access). len == 0 and uptr == 0 is the
# common "optional buffer absent" pattern; callers that require a non-NULL
# pointer must check uptr != 0 separately before calling access_ok.
# ---------------------------------------------------------------------------

# Canonical-address upper bound for user pointers: bit 47 must be 0.
USER_ADDR_MAX: uint64 = 0x0000800000000000

# Maximum sane I/O length (256 MiB). Exceeding this indicates a bug or
# attack — real read/write/recv/send never need more than ~32 MiB in
# a single call.
ACCESS_OK_MAX_LEN: uint64 = 0x10000000

# Kernel bounce-buffer size for SYS_READ / SYS_WRITE. These syscalls no
# longer raw-deref the user buffer: they stage data through a fixed
# kernel buffer and copy_to_user / copy_from_user it across the user/
# kernel boundary (translating the user vaddr through the current task's
# page tables). 4 KiB == one page; read(2) returns whatever a single
# bounce-fill yields, write(2) loops bounce-sized chunks. Keep this in
# sync with the `Array[4096, uint8]` bounce locals in those handlers.
UA_BOUNCE_SZ: uint64 = 4096

# SYS_WRITE-only bounce size. The rio v2 blit protocol ships one whole
# verb per write(2) — a 'B' payload at the v2 backbuffer cap
# (1280x800 px) is 18 + 4,096,000 bytes, which trips the 4 KiB
# chunking + the parser's "B short payload" reject. Bumping to 4 MiB
# (kmalloc'd, not stack) fits a full-screen v2 commit in ONE chunk so
# commit_rect ships intact. Heap-allocated to keep kstack pressure
# unchanged. 4 MiB is the kmalloc MAX_ORDER ceiling (mm/page_alloc.ad).
UA_WR_BOUNCE_SZ: uint64 = 4194304


def access_ok(uptr: uint64, length: uint64) -> int32:
    # Zero-length: always pass — no memory will be accessed.
    if length == 0:
        return 1
    # NULL pointer with non-zero length: always fail.
    if uptr == 0:
        return 0
    # Absurd length guard (prevents overflow in uptr + length below too).
    if length > ACCESS_OK_MAX_LEN:
        return 0
    # Integer-overflow guard: uptr + length must not wrap.
    end_addr: uint64 = uptr + length
    if end_addr < uptr:
        return 0
    # Canonical-user-space range: [uptr, end_addr) must be entirely below
    # USER_ADDR_MAX. end_addr is the EXCLUSIVE end, so the last byte is at
    # end_addr - 1; checking end_addr <= USER_ADDR_MAX is sufficient.
    if end_addr > USER_ADDR_MAX:
        return 0
    return 1


# access_ok_str — validate a NUL-terminated user string pointer.
# Checks only that uptr itself (single byte) is in user space; the
# actual string walk (_argv_strlen / resolve_path) already caps at
# MAX_ARG_BYTES so no additional length bound is needed here. Returns
# 1 on pass, 0 on fail.
def access_ok_str(uptr: uint64) -> int32:
    if uptr == 0:
        return 0
    if uptr >= USER_ADDR_MAX:
        return 0
    return 1


# copyin_path — uaccess-safe pull of a NUL-terminated user path string into
# a kernel bounce buffer. This is the #163 (batch 2) replacement for the old
# `resolve_path(cast[Ptr[char]](a0), ...)` pattern that RAW-DEREFERENCED the
# user pointer and so only worked while user vaddr == phys. We translate the
# string through the current task's page tables (strncpy_from_user) into the
# caller-supplied kernel buffer, then path syscalls operate on the KERNEL copy
# and feed THAT to resolve_path / the file servers — never the raw user vaddr.
#
#   uptr  = user virtual address of the NUL-terminated path
#   kdst  = kernel buffer the path is copied into (always NUL-terminated)
#   cap   = capacity of kdst in bytes (incl. the NUL)
#
# Returns the string length copied (>= 0) on success, or -EFAULT (-14) if the
# user pointer faults during translation. A 0-length result (empty string) is
# a valid success. The caller already validates uptr with access_ok_str; this
# adds the real page-walked copy on top.
def copyin_path(uptr: uint64, kdst: Ptr[uint8], cap: uint64) -> int64:
    r: int64 = strncpy_from_user(cast[uint64](kdst), uptr, cap)
    if r < 0:
        return cast[int64](-14)                  # -EFAULT
    return r


# ===========================================================================
# uaccess (#163, keystone final piece): kernel-side snapshot of the caller's
# argv[]/envp[] — the LAST raw user-pointer deref in the exec path.
#
# do_execve tears down the outgoing address space (vma_clear) and reinstalls
# the new image's mappings into the task's PML4 (elf_apply_last_user_mapping +
# load_cr3) BEFORE the init-stack builders run. The builders historically
# raw-dereferenced the caller's argv/envp (a1/a2) at that late point, which
# only worked because low memory was identity-mapped (vaddr == phys) and the
# old mappings happened to survive the in-place PML4 mutation. That is exactly
# the cheat #163 exists to kill: it makes ET_DYN / mmap-base ASLR impossible.
#
# The fix mirrors Linux's copy_strings(): deep-copy the argv/envp arrays AND
# their strings into kernel BSS at the very TOP of do_execve — while the
# caller's page tables still fully map its address space — translating every
# user pointer through the current task's PML4 via get_user_64 /
# strncpy_from_user. The builders then consume these kernel-resident arrays
# (reachable in every CR3, higher-half), so they stay correct even once the
# new image's user vaddr != phys. A faulting user pointer returns -EFAULT
# here, BEFORE any teardown, leaving the caller intact.
#
# Single global snapshot: execve is already serialized at this granularity
# (elf_load_blob uses global elf_last_* state), so one BSS buffer is correct.
EXEC_ARG_BLOB_SZ: uint64 = 28672              # argv(32*256) + envp(64*256) + slack
_exec_str_blob:  Array[28672, uint8]
_exec_argv_ptrs: Array[33, uint64]            # MAX_ARGV + NULL terminator
_exec_envp_ptrs: Array[65, uint64]            # MAX_ENVP + NULL terminator

# binfmt_script (shebang) support. When do_execve's target begins with
# "#!", the kernel must run the named interpreter with the script path as
# an argument (Linux fs/binfmt_script.c). These hold the rewritten argv:
# _shebang_interp holds the interpreter path (and optional single arg)
# parsed from the "#!" line; _shebang_script holds the original script
# path. The rebuilt argv becomes [interp, (optarg,) scriptpath, orig
# argv[1:]...]. Kept in dedicated BSS so the rewrite does not collide with
# the _exec_str_blob bump arena already holding the snapshotted argv/envp.
_shebang_interp: Array[256, uint8]            # interp path
_shebang_optarg: Array[256, uint8]            # optional single arg after interp
_shebang_script: Array[256, uint8]            # the script path itself
_shebang_argv_ptrs: Array[20, uint64]         # rebuilt argv (NULL-terminated)


def _exec_parse_shebang(blob: uint64, sz: uint64,
                        interp: Ptr[uint8], optarg: Ptr[uint8]) -> int32:
    # Parse a "#!" interpreter line from the head of `blob`. On a match,
    # fills `interp` with the interpreter path and `optarg` with the single
    # optional argument (empty string if none) and returns 1. Returns 0 if
    # the blob is not a shebang script. Mirrors Linux fs/binfmt_script.c:
    # skip "#!", skip leading blanks, the interpreter is the first
    # whitespace-delimited token, and EVERYTHING after the first blank that
    # follows it (trimmed) is ONE argument (Linux does not split further).
    interp[0] = 0
    optarg[0] = 0
    if sz < 2:
        return 0
    b: Ptr[uint8] = cast[Ptr[uint8]](blob)
    if b[0] != 0x23 or b[1] != 0x21:              # '#' '!'
        return 0
    i: uint64 = 2
    # Bound the scan to the first line and a sane length cap.
    lim: uint64 = sz
    if lim > 255:
        lim = 255
    # Skip blanks after "#!".
    while i < lim and (b[i] == 0x20 or b[i] == 0x09):
        i = i + 1
    # Interpreter token: up to the next blank / newline / NUL.
    o: uint64 = 0
    while i < lim and b[i] != 0x20 and b[i] != 0x09 \
            and b[i] != 0x0A and b[i] != 0:
        if o < 255:
            interp[o] = b[i]
            o = o + 1
        i = i + 1
    interp[o] = 0
    if o == 0:
        return 0                                   # "#!" with no interpreter
    # Skip blanks before the optional argument.
    while i < lim and (b[i] == 0x20 or b[i] == 0x09):
        i = i + 1
    # The remainder of the line (to newline/NUL) is a SINGLE argument.
    oa: uint64 = 0
    while i < lim and b[i] != 0x0A and b[i] != 0:
        if oa < 255:
            optarg[oa] = b[i]
            oa = oa + 1
        i = i + 1
    # Trim trailing blanks from the optional argument.
    while oa > 0 and (optarg[oa - 1] == 0x20 or optarg[oa - 1] == 0x09):
        oa = oa - 1
    optarg[oa] = 0
    return 1


def _str_copy_z(dst: Ptr[uint8], src: Ptr[char]) -> uint64:
    # Copy a NUL-terminated string; returns the length (excl. NUL).
    n: uint64 = 0
    while src[n] != 0 and n < 255:
        dst[n] = cast[uint8](src[n])
        n = n + 1
    dst[n] = 0
    return n


def _exec_snapshot_one(arr_user: uint64, out_ptrs: Ptr[uint64],
                       max_entries: uint64, max_bytes: uint64,
                       blob_base: uint64, blob_off_io: Ptr[uint64]) -> int64:
    # Copy one NULL-terminated user array of cstring pointers (argv or envp)
    # into the kernel blob. out_ptrs[] receives kernel addresses of each
    # copied string and is NULL-terminated. blob_off_io is the shared bump
    # cursor into _exec_str_blob (advanced past each string + its NUL).
    # Returns the entry count (>= 0) on success, or -14 (-EFAULT) on a
    # faulting user pointer. arr_user == 0 yields an empty (count 0) array.
    n: uint64 = 0
    if arr_user != 0:
        while n < max_entries:
            slot: uint64 = 0
            if get_user_64(arr_user + n * 8, &slot) < 0:
                return cast[int64](-14)
            if slot == 0:
                break
            off: uint64 = blob_off_io[0]
            cap: uint64 = max_bytes
            if off + cap > EXEC_ARG_BLOB_SZ:
                cap = EXEC_ARG_BLOB_SZ - off
            if cap == 0:
                break                              # blob exhausted; stop early
            r: int64 = strncpy_from_user(blob_base + off, slot, cap)
            if r < 0:
                return cast[int64](-14)
            out_ptrs[n] = blob_base + off
            blob_off_io[0] = off + cast[uint64](r) + 1   # incl. NUL
            n = n + 1
    out_ptrs[n] = 0                                # NULL-terminate
    return cast[int64](n)


def exec_snapshot_args(argv_user: uint64, envp_user: uint64) -> int64:
    # Front-load BOTH argv and envp into kernel BSS before any address-space
    # teardown. Returns 0 on success, -14 (-EFAULT) if any user pointer
    # faults. On return, _exec_argv_ptrs / _exec_envp_ptrs are kernel-resident
    # NULL-terminated arrays the init-stack builders consume in place of the
    # raw user a1/a2.
    blob_base: uint64 = cast[uint64](&_exec_str_blob[0])
    blob_off: uint64 = 0
    ra: int64 = _exec_snapshot_one(argv_user, &_exec_argv_ptrs[0],
                                   MAX_ARGV, MAX_ARG_BYTES,
                                   blob_base, &blob_off)
    if ra < 0:
        return ra
    re: int64 = _exec_snapshot_one(envp_user, &_exec_envp_ptrs[0],
                                   MAX_ENVP, MAX_ENV_BYTES,
                                   blob_base, &blob_off)
    if re < 0:
        # envp is OPTIONAL. argv faulting is a genuine error (the program
        # has no arguments — fail the exec), but a garbage/unreadable envp
        # must degrade to an EMPTY environment, NOT abort the whole exec.
        # The native 2-arg sys_execve(path, argv) carries NO env; its asm
        # stub zeros %rdx, but a caller that reaches SYS_EXECVE without that
        # stub (or any path that leaves %rdx holding a small non-pointer
        # like 0x35) would otherwise fault the envp walk and -EFAULT the
        # exec — which regressed /init's exec of /bin/hamsh (the native
        # heartbeat). access_ok can't catch a low-but-non-null garbage
        # value, so we tolerate it here: an un-snapshottable envp yields an
        # empty env. A VALID 3-arg envp (sys_execve_env) snapshots fine and
        # is unaffected.
        _exec_envp_ptrs[0] = 0                     # empty env, NUL-terminated
    return 0


def _argv_strlen(s: uint64) -> uint64:
    n: uint64 = 0
    while cast[Ptr[uint8]](s + n)[0] != 0 and n < MAX_ARG_BYTES:
        n = n + 1
    return n


def _argv_count(argv: uint64) -> uint64:
    # Walk a NULL-terminated array of 8-byte pointers, capped at
    # MAX_ARGV so a malformed argv can't run away. argv == 0 means
    # "no argv" — count is 0.
    if argv == 0:
        return 0
    n: uint64 = 0
    while n < MAX_ARGV:
        p: uint64 = cast[Ptr[uint64]](argv + n * 8)[0]
        if p == 0:
            return n
        n = n + 1
    return n


def _envp_strlen(s: uint64) -> uint64:
    n: uint64 = 0
    while cast[Ptr[uint8]](s + n)[0] != 0 and n < MAX_ENV_BYTES:
        n = n + 1
    return n


def _envp_count(envp: uint64) -> uint64:
    # Same shape as _argv_count but uses the env-side caps so a
    # malformed envp can't run away. envp == 0 (caller passed no
    # environment) means "empty env" — count is 0.
    if envp == 0:
        return 0
    n: uint64 = 0
    while n < MAX_ENVP:
        p: uint64 = cast[Ptr[uint64]](envp + n * 8)[0]
        if p == 0:
            return n
        n = n + 1
    return n


def _build_user_argv(ustack_top: uint64, argv_user: uint64,
                     out_argc: Ptr[uint64],
                     out_argv: Ptr[uint64]) -> uint64:
    # Native-Hamnix-ABI argv layout. Strings + NULL-terminated pointer
    # array at the top of the user stack; out_argc / out_argv get the
    # values _start should see in %rdi / %rsi.
    #
    # Layout (growing down from ustack_top):
    #
    #   high:  "arg0\0arg1\0..."        each NUL-terminated string
    #          [pad to 8 bytes]
    #          argv[0]  -> &"arg0"
    #          argv[1]  -> &"arg1"
    #          ...
    #          argv[N]  = 0             NULL terminator
    #          [pad to 16 bytes]        SysV stack alignment for _start
    #   low:   <new RSP>
    #
    # Native-Hamnix binaries read argc / argv from %rdi / %rsi (set up
    # by the SYS_EXECVE / SYS_SPAWN plumbing); they never look at *rsp.
    # Linux binaries (musl, glibc) ignore the SysV register handoff and
    # read directly from *rsp per the Linux process init-stack ABI —
    # see _build_user_argv_linux below for that path.
    argc: uint64 = _argv_count(argv_user)

    # SMAP v3c: every write below targets the new task's user stack
    # (US=1 page reached through the just-installed per-task PML4).
    # Bracket the whole build with STAC/CLAC so the CPL=0 stores are
    # legal under CR4.SMAP=1. argv_user is a kernel snapshot
    # (_exec_argv_ptrs[]) so the reads off it stay CPL=0/US=0.
    _ua_stac()
    # Copy strings down from ustack_top. Track the bottom of the
    # string region; that's where the argv pointer array begins.
    str_sp: uint64 = ustack_top
    str_addrs: Array[16, uint64]
    i: uint64 = 0
    while i < argc:
        src: uint64 = cast[Ptr[uint64]](argv_user + i * 8)[0]
        n:   uint64 = _argv_strlen(src) + 1            # incl. NUL
        str_sp = str_sp - n
        memcpy(cast[Ptr[uint8]](str_sp),
               cast[Ptr[uint8]](src), n)
        str_addrs[i] = str_sp
        i = i + 1

    # 8-byte align the pointer array.
    str_sp = str_sp & ~cast[uint64](7)

    # Write argv[N] = NULL then argv[N-1] .. argv[0] (top-down).
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = 0
    i = argc
    while i > 0:
        i = i - 1
        str_sp = str_sp - 8
        cast[Ptr[uint64]](str_sp)[0] = str_addrs[i]

    argv_addr: uint64 = str_sp

    # 16-byte align RSP for SysV. The argv array is already 8-aligned;
    # mask to a 16-byte boundary by potentially dropping 8 bytes of pad
    # below it. After _start's `call main` the stack is again 16-aligned.
    str_sp = str_sp & ~cast[uint64](15)
    _ua_clac()

    out_argc[0] = argc
    out_argv[0] = argv_addr
    return str_sp


# Auxv type numbers (Linux include/uapi/linux/auxvec.h subset).
AT_NULL:    uint64 = 0
AT_PHDR:    uint64 = 3
AT_PHENT:   uint64 = 4
AT_PHNUM:   uint64 = 5
AT_PAGESZ:  uint64 = 6
AT_BASE:    uint64 = 7
AT_ENTRY:   uint64 = 9
# AT_SECURE (23): 0 = the process is NOT running with elevated privilege
# (no setuid/setgid transition). glibc's __libc_enable_secure and GLib's
# g_check_setuid() call getauxval(AT_SECURE); when the auxv entry is ABSENT
# getauxval returns 0 AND sets errno=ENOENT, which GLib treats as a FATAL
# error ("GLib-ERROR: getauxval() failed: No such file or directory") and
# aborts — Firefox died here before mapping a window. Emitting the entry
# (even value 0) makes getauxval succeed.
AT_SECURE:  uint64 = 23
AT_RANDOM:  uint64 = 25
# #169 vDSO: AT_SYSINFO_EHDR (33) advertises the user vaddr of the
# vDSO mini-ELF page. glibc/musl parse that ELF and call
# __vdso_clock_gettime et al. directly, skipping the syscall trap.
AT_SYSINFO_EHDR: uint64 = 33


def _build_user_argv_linux(ustack_top: uint64, argv_user: uint64,
                           envp_user: uint64,
                           entry_addr: uint64, region: uint64,
                           vdso_ehdr: uint64) -> uint64:
    # Linux process init-stack layout. musl's _start does
    # `mov %rsp,%rdi; call _start_c`; _start_c then reads
    # `argc = *(int*)rdi`, `argv = rdi+8`, walks envp from there, and
    # finally reads auxv. So *rsp at user-mode entry MUST be argc.
    #
    # Layout (growing down from ustack_top):
    #
    #   high:  "arg0\0arg1\0..."          NUL-terminated argv strings
    #          "ENV0=VAL\0ENV1=VAL\0..."  NUL-terminated env strings
    #          [16-byte AT_RANDOM blob]   zeroes — no entropy source yet
    #          [pad to 16-byte alignment]
    #          AT_NULL pair  (0, 0)
    #          AT_RANDOM pair (25, &random_blob)
    #          AT_ENTRY pair  (9, region + e_entry - lowest_v)
    #          AT_BASE pair   (7, 0)
    #          AT_PAGESZ pair (6, 4096)
    #          AT_PHNUM pair  (5, e_phnum)
    #          AT_PHENT pair  (4, 56)
    #          AT_PHDR pair   (3, region + e_phoff)
    #          NULL                       envp terminator
    #          envp[envc-1] -> &"NAMEn-1=VAL"
    #          ...
    #          envp[0]      -> &"NAME0=VAL"
    #          NULL                       argv terminator
    #          argv[argc-1] -> &"argN-1"
    #          ...
    #          argv[0]      -> &"arg0"
    #          argc
    #   low:   <new RSP>
    #
    # SysV requires *rsp to be 16-byte aligned at function entry for
    # musl's _start. _start_c is called via `call`, which pushes 8
    # bytes of return address, so it sees rsp at 8 mod 16 — fine. We
    # achieve the 16-byte alignment for *rsp by counting the variable
    # part (argc-cell + argv-pointers + 2 NULLs + envp-pointers + 6
    # auxv pairs) and padding the string-region bottom appropriately.
    #
    # U17 extends the U16 layout with a real envp[] block populated
    # from envp_user (a user-side NUL-terminated array of pointers to
    # "NAME=VALUE\0" strings). envp_user == 0 still works — yields the
    # exact U16 layout (envp = [NULL]).
    argc: uint64 = _argv_count(argv_user)
    envc: uint64 = _envp_count(envp_user)

    # SMAP v3c: every write below targets the new task's user stack
    # (US=1 page reached through the just-installed per-task PML4).
    # Bracket the whole Linux init-stack build with STAC/CLAC so the
    # CPL=0 stores are legal under CR4.SMAP=1. The reads off argv_user/
    # envp_user are kernel snapshots (_exec_argv_ptrs / _exec_envp_ptrs)
    # so they remain CPL=0/US=0 — STAC only buys the WRITES below.
    _ua_stac()
    # 1. Copy argv strings down from ustack_top.
    str_sp: uint64 = ustack_top
    str_addrs: Array[16, uint64]
    i: uint64 = 0
    while i < argc:
        src: uint64 = cast[Ptr[uint64]](argv_user + i * 8)[0]
        n:   uint64 = _argv_strlen(src) + 1            # incl. NUL
        str_sp = str_sp - n
        memcpy(cast[Ptr[uint8]](str_sp),
               cast[Ptr[uint8]](src), n)
        str_addrs[i] = str_sp
        i = i + 1

    # 1b. Copy envp strings just below the argv strings. Each entry
    #     is "NAME=VALUE\0" verbatim — we don't reparse it. envp_user
    #     pointers point into the parent's address space; we own the
    #     copy now, so subsequent edits to the parent's env table
    #     can't disturb the child's view.
    env_addrs: Array[64, uint64]
    i = 0
    while i < envc:
        src: uint64 = cast[Ptr[uint64]](envp_user + i * 8)[0]
        n:   uint64 = _envp_strlen(src) + 1            # incl. NUL
        str_sp = str_sp - n
        memcpy(cast[Ptr[uint8]](str_sp),
               cast[Ptr[uint8]](src), n)
        env_addrs[i] = str_sp
        i = i + 1

    # 2. 16 bytes of AT_RANDOM material. Hamnix has no entropy source
    #    yet so we leave the bytes zero. glibc seeds its stack-protector
    #    canary from these (resulting in a zero canary), which is a
    #    weakness, not a correctness issue — every saved canary on the
    #    stack and every live TCB canary compare 0==0. A non-zero
    #    canary would only be needed once a real RNG lands.
    str_sp = str_sp - 16
    cast[Ptr[uint64]](str_sp)[0]     = 0
    cast[Ptr[uint64]](str_sp + 8)[0] = 0
    random_addr: uint64 = str_sp

    # 3. Compute *rsp = argc cell address after every fixed-size cell
    #    is accounted for, so we can pre-align the bottom of the string
    #    region to land *rsp on a 16-byte boundary.
    #
    #    Variable contents below the strings/random blob (each 8 bytes):
    #      - 8 auxv pairs * 2 cells   = 16 cells   = 128 bytes
    #      - envp NULL                 =  1 cell   =  8 bytes
    #      - envp pointers (envc)      =  envc     = envc*8 bytes
    #      - argv NULL                 =  1 cell   =  8 bytes
    #      - argv pointers (argc)      =  argc     = argc*8 bytes
    #      - argc cell                 =  1 cell   =  8 bytes
    #    Total = (19 + argc + envc) * 8 bytes
    #
    #    For *rsp (= argc cell) to be 16-aligned, ((19 + argc + envc) *
    #    8) aligned-from str_sp must satisfy that bottom = 16-aligned.
    #    We pre-bump str_sp down 0 or 8 bytes to make it so.
    str_sp = str_sp & ~cast[uint64](7)
    # Base fixed cells = 19 (8 auxv pairs + envp/argv NULLs + argc). When
    # the vDSO is present we add ONE more auxv pair (AT_SYSINFO_EHDR) =
    # 2 cells, so the alignment pre-bump accounts for it.
    aux_extra: uint64 = 0
    if vdso_ehdr != 0:
        aux_extra = 2
    # Base fixed cells = 21: 9 always-present auxv pairs (AT_NULL, AT_SECURE,
    # AT_RANDOM, AT_ENTRY, AT_BASE, AT_PAGESZ, AT_PHNUM, AT_PHENT, AT_PHDR)
    # = 18 cells, + envp NULL + argv NULL + argc = 21. AT_SYSINFO_EHDR adds
    # aux_extra=2 when the vDSO is mapped.
    fixed_bytes: uint64 = (cast[uint64](21) + aux_extra + argc + envc) * 8
    bottom: uint64 = str_sp - fixed_bytes
    if (bottom & cast[uint64](15)) != 0:
        str_sp = str_sp - 8                            # align pad

    # 4. Push auxv from top down: AT_NULL first (highest addr), then
    #    each (type, value) pair top-down so that the resulting in-
    #    memory order — low to high — is the canonical Linux order.
    #
    #    U20: AT_PHDR / AT_PHNUM / AT_ENTRY are populated from the
    #    just-loaded ELF (passed in by the caller as region + phoff
    #    plus entry_addr). glibc / musl's _start reads these to drive
    #    its own _dl_relocate_static_pie pass — without them static-
    #    PIE binaries can't fix up RELATIVE / IRELATIVE / GLOB_DAT
    #    slots. AT_BASE=0 says "no dynamic linker"; static-PIE doesn't
    #    use it but glibc reads the cell unconditionally.
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = 0                   # AT_NULL.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_NULL             # AT_NULL.type

    # #169 vDSO: AT_SYSINFO_EHDR points at the user vaddr of the vDSO
    # mini-ELF page. Emitted only when do_execve successfully mapped
    # the vDSO (vdso_ehdr != 0); otherwise the entry is omitted and
    # glibc/musl fall back to the clock_gettime syscall. Auxv ordering
    # is irrelevant to the loader (it scans to AT_NULL), so we plant it
    # just below AT_NULL.
    if vdso_ehdr != 0:
        str_sp = str_sp - 8
        cast[Ptr[uint64]](str_sp)[0] = vdso_ehdr       # AT_SYSINFO_EHDR.value
        str_sp = str_sp - 8
        cast[Ptr[uint64]](str_sp)[0] = AT_SYSINFO_EHDR

    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = random_addr         # AT_RANDOM.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_RANDOM

    # AT_SECURE = 0: no setuid/setgid privilege transition on this exec.
    # Always emitted so getauxval(AT_SECURE) succeeds (GLib's g_check_setuid
    # aborts fatally if the entry is missing — see the AT_SECURE comment).
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = 0                    # AT_SECURE.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_SECURE

    # U42: AT_ENTRY is the APPLICATION's e_entry — what ld.so finally
    # jumps to once it's done relocating. For static binaries that's
    # the same as entry_addr (the user-mode RIP we'll SYSRETQ to); for
    # dynamic binaries entry_addr is the interpreter's entry and
    # elf_last_app_entry_user holds the app's. fs/elf.ad mirrors
    # entry_addr into elf_last_app_entry_user on the static path so
    # this expression evaluates correctly in both cases.
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = elf_last_app_entry_user  # AT_ENTRY.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_ENTRY

    # U42: AT_BASE is the interpreter's load base (the kernel-chosen
    # memblock region for ld.so's image). glibc / musl's ld.so reads
    # this to compute "where am I?" — its own _start needs to know
    # its load address to walk its own DT_RELA, fix up its own GOT,
    # and then process the application's DT_DYNAMIC. For static
    # binaries fs/elf.ad pins elf_last_interp_base = 0, matching the
    # pre-U42 hardcoded "no dyn-linker" semantics — static-PIE glibc
    # tolerates AT_BASE = 0 and uses AT_PHDR/AT_ENTRY exclusively.
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = elf_last_interp_base    # AT_BASE.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_BASE

    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = 4096                # AT_PAGESZ.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_PAGESZ

    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = cast[uint64](elf_last_phnum)  # AT_PHNUM.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_PHNUM

    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = 56                  # AT_PHENT.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_PHENT

    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = region + elf_last_phoff  # AT_PHDR.value
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = AT_PHDR

    # 5. envp array: NULL terminator then envp[envc-1] .. envp[0].
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = 0
    i = envc
    while i > 0:
        i = i - 1
        str_sp = str_sp - 8
        cast[Ptr[uint64]](str_sp)[0] = env_addrs[i]

    # 6. argv array: NULL terminator then argv[N-1] .. argv[0].
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = 0
    i = argc
    while i > 0:
        i = i - 1
        str_sp = str_sp - 8
        cast[Ptr[uint64]](str_sp)[0] = str_addrs[i]

    # 7. argc — the user's new *rsp.
    str_sp = str_sp - 8
    cast[Ptr[uint64]](str_sp)[0] = argc
    _ua_clac()

    return str_sp


# --- concurrent-execve serialization -----------------------------------
# do_execve records the loaded image through the ELF loader's SHARED global
# result state (elf_last_* in fs/elf.ad) and stages the path / argv / envp /
# shebang rewrite in shared kernel BSS (exec_kpath, _exec_argv_ptrs,
# _shebang_*, exec_snapshot_args). The whole path was written assuming a
# single task execs at a time ("no fork+exec races at this scale"). Once a
# concurrent server (httpd's per-connection workers) has >1 task execve at
# once on -smp>1, two loads clobber each other's elf_last_* image coords:
# both region_alloc, then one reads the OTHER's phys back and BOTH map +
# record the SAME image region. One task's task_reap then region_free's a
# region the other still runs from -> the next execve reuses it -> cross-
# image corruption + a full-guest wedge (observed: pid 11 and pid 12 both
# at image phys=0x0a849000). T85 locked the region free-list RMW but left
# this larger loader-global race open.
#
# Fix: serialize the entire do_execve body so only one task is inside the
# loader-global critical section (elf_last_* + region record) at a time.
# execve is not a hot path (Linux itself takes heavy locks here) and the
# connection SERVING (tcp recv/send) still overlaps fully — only the brief
# image load is serialized.
#
# QA-N28 — WHY THIS IS A COOPERATIVE (YIELDING) MUTEX, NOT A RAW SPINLOCK.
# _do_execve_inner is NOT a straight-line non-yielding critical section: it
# resolves + reads the image through the caller's namespace (ns_blob_ptr ->
# vfs_read), and for a binary served by the userland distrofs 9P daemon
# (every `enter linux { <debian binary> }`) that read — and the PT_INTERP
# ld.so read nested inside elf_load_blob — issues a 9P RPC that parks on
# yield_to_others() until the daemon task is scheduled to reply
# (sys/src/9/port/9p_client.ad). So this lock IS held across reschedule
# points. A raw busy-wait spinlock (spinlock_lock = LOCK XCHG + PAUSE loop,
# no IRQ enable, no reschedule) held across a yield VIOLATES the core.ad
# kernel_cond_resched contract ("MUST be called only when no kernel spinlock
# is held"): once the holder yields, ANY second task that then reaches
# do_execve busy-spins on the held word with EFLAGS.IF=0 inside its own
# syscall (kernel mode is non-preemptible — preempt_tick only switches on a
# ring-3 tick). On a UP guest that spinner pins the one CPU forever, so the
# yielded holder (and the distrofs daemon it is waiting on, and the hamsh
# heartbeat) can NEVER run again — the whole box wedges. This is exactly the
# reported wedge: `enter linux { <debian binary> }` under a fully-populated
# DE (many STATE_READY tasks -> a concurrent execve is likely) freezes the
# guest, heartbeat included; a memory-resident cpio applet (no 9P RPC, no
# yield) does NOT wedge because the lock is never held across a reschedule.
#
# The cure keeps the same mutual exclusion (spinlock_trylock is one atomic
# XCHG) but makes a WAITER cooperatively yield_to_others() instead of
# busy-spinning. A waiter that yields lets the lock holder — and the 9P
# daemon it depends on — get scheduled and finish, so the section can be
# safely held across the 9P yield on both UP and SMP. do_execve is never
# called recursively, so the holder never waits on itself.
extern def spinlock_lock(ptr: Ptr[uint32])
extern def spinlock_unlock(ptr: Ptr[uint32])
extern def spinlock_trylock(ptr: Ptr[uint32]) -> uint32
_execve_lock: uint32 = 0


def _execve_lock_acquire():
    # Cooperative mutex acquire (see the QA-N28 note above). One atomic
    # trylock attempt per turn; on contention yield_to_others() so the
    # current holder (blocked on a 9P image read) can make progress rather
    # than us pinning the CPU with a busy-spin. Safe to yield here: this
    # runs at the very top of do_execve, before any of the caller's
    # address space has been torn down.
    while spinlock_trylock(&_execve_lock) == 0:
        yield_to_others()


def do_execve(a0: uint64, a1: uint64, a2: uint64) -> int64:
    # Serializing wrapper (see _execve_lock). _do_execve_inner runs the
    # actual mechanics. On SUCCESS the inner releases the lock itself right
    # before do_execve_finish() SYSRETQs (which never returns here), so this
    # wrapper's unlock runs ONLY on the error-return paths — which all
    # funnel back through this single call site. Exactly one unlock per path.
    _execve_lock_acquire()
    rc: int64 = _do_execve_inner(a0, a1, a2)
    spinlock_unlock(&_execve_lock)
    return rc


def _do_execve_inner(a0: uint64, a1: uint64, a2: uint64) -> int64:
    # The actual execve mechanics, shared by the native SYS_EXECVE
    # branch in do_syscall() and the Linux-ABI SYS_execve (59) handler
    # in linux_abi/u_syscalls.ad::_u_execve. Adder merges all modules
    # into one global symbol table, so u_syscalls.ad can call this
    # directly without any explicit cross-module import.
    #
    # Look up `path` in the initramfs, ELF-load, build argv on a
    # fresh user stack, and SYSRETQ directly to the new entry. The
    # current task's task_struct and per-task fd table are preserved
    # (no fork+exec races at this scale; we behave more like a Linux
    # exec() that replaces the user image but keeps the kernel-side
    # context). a1 = argv (Ptr[uint64] NULL-terminated array of
    # cstring pointers), or 0 for none. a2 = envp (same shape) or 0.
    # Only honoured on the Linux-ABI path — native binaries get
    # argc/argv via %rdi/%rsi and have no env concept yet.
    #
    # Return: negative Linux errno on failure (-ENOENT / -ENOEXEC).
    # On success do_execve_finish() does the SYSRETQ and we never
    # return here at all. The return type matches the Linux ABI
    # convention so _u_execve can just forward the int64 unchanged.
    # §4: resolve the target binary through the calling process's
    # namespace (Pgrp mount table) rather than a verbatim initramfs
    # match. A binary launched inside a distrorun distro-shape
    # namespace finds its image in the grafted distro tree; a native
    # process resolves the path verbatim (no matching mount entry).
    # uaccess (#163 batch 2): pull the path STRING into a kernel bounce
    # buffer through the page-table-walking strncpy_from_user, so the
    # ns_blob_ptr / vfs_perm_check_exec lookups operate on a kernel copy
    # rather than raw-dereferencing the user vaddr (vaddr != phys safe).
    # uaccess (#163 keystone final): the argv (a1) / envp (a2) ARRAYS are now
    # ALSO pulled through the page-table-walking uaccess layer — see
    # exec_snapshot_args() below, called before any address-space teardown.
    # The builders consume that kernel-resident snapshot, so NO raw user
    # deref remains in the exec path. (The builders still STORE into the
    # identity-mapped new user stack; flipping that stack to vaddr != phys is
    # the separate ET_DYN / mmap-base ASLR enablement step.)
    exec_kpath: Array[256, uint8]
    if copyin_path(a0, &exec_kpath[0], 256) < 0:
        # DIAG (NUC execve-FATAL hunt): the uaccess walk that copies the
        # path string failed. On real HW init loads >4 GiB (phys
        # 0x1034xxxxx, PML4 0x1024xxxxx), so this dumps the live PML4 and
        # the resolve() verdict for the user ptr — a 0 resolve means the
        # >4 GiB direct-map can't reach init's page tables / image page.
        diag_pml4: uint64 = uaccess_current_pml4()
        diag_phys: uint64 = uaccess_resolve(diag_pml4, a0, 0)
        printk2("execve: copyin_path FAIL uptr=%p pml4=%p\n", a0, diag_pml4)
        printk1("execve: copyin_path FAIL resolve(uptr)=%p (0=fault)\n",
                diag_phys)
        set_current_errstr("execve: bad path address")
        return cast[int64](-14)           # -EFAULT
    path: Ptr[char] = cast[Ptr[char]](&exec_kpath[0])
    # docs/security.md Phase 5: exec permission check BEFORE we begin
    # tearing the outgoing VMAs down (vma_clear) — otherwise a denied
    # exec would leave the caller half-disassembled. Hostowner bypasses
    # the check; a regular user without PERM_X on the target gets
    # -EPERM here with errstr "permission denied".
    if vfs_perm_check_exec(path) != 0:
        printk1("execve: perm_check_exec DENIED '%s' (-EPERM)\n",
                cast[uint64](&exec_kpath[0]))
        set_current_errstr("execve: permission denied")
        return cast[int64](-1)            # -EPERM
    blob: uint64 = ns_blob_ptr(path)
    if blob == 0:
        printk1("execve: '%s' not in namespace\n", cast[uint64](&exec_kpath[0]))
        set_current_errstr("execve: file does not exist")
        return cast[int64](-2)            # -ENOENT
    sz: uint64 = ns_blob_size(path)
    # uaccess (#163 keystone final): snapshot the caller's argv/envp into
    # kernel BSS NOW — before vma_clear / load_cr3 tear down and replace the
    # caller's address space. The init-stack builders below then read these
    # kernel-resident arrays instead of raw-dereferencing a1/a2, so they stay
    # correct once the new image's user vaddr != phys (ET_DYN / mmap ASLR).
    # A faulting user pointer returns -EFAULT here, while the caller is still
    # fully intact (no teardown has happened yet).
    if exec_snapshot_args(a1, a2) < 0:
        printk2("execve: snapshot_args FAIL argv=%p envp=%p (-EFAULT)\n",
                a1, a2)
        set_current_errstr("execve: bad argv/envp address")
        return cast[int64](-14)           # -EFAULT
    # binfmt_script: if the target is a "#!" script, re-point this exec at
    # the named interpreter and rewrite argv to [interp, (optarg,)
    # scriptpath, orig argv[1:]...]. MUST run here — after the argv/envp
    # snapshot but BEFORE any address-space teardown — so a missing /
    # malformed interpreter fails cleanly with the caller still intact
    # (the old behaviour fell into elf_load_blob with bad "#!" magic AFTER
    # vma_clear, returning -ENOEXEC to a half-disassembled task = a hang).
    # Without this, a freshly dpkg-installed shell script — /usr/bin/hamhello
    # = "#!/bin/sh\necho ..." — could not be run by `enter linux { ... }`.
    if _exec_parse_shebang(blob, sz, &_shebang_interp[0],
                           &_shebang_optarg[0]) != 0:
        # Stash the ORIGINAL script path before `path` is repointed.
        _str_copy_z(&_shebang_script[0], path)
        # Re-resolve the interpreter through the namespace.
        ipath: Ptr[char] = cast[Ptr[char]](&_shebang_interp[0])
        if vfs_perm_check_exec(ipath) != 0:
            set_current_errstr("execve: shebang interp not executable")
            return cast[int64](-1)         # -EPERM
        iblob: uint64 = ns_blob_ptr(ipath)
        if iblob == 0:
            printk1("execve: shebang interp '%s' not found\n",
                    cast[uint64](&_shebang_interp[0]))
            set_current_errstr("execve: shebang interpreter not found")
            return cast[int64](-2)         # -ENOENT
        isz: uint64 = ns_blob_size(ipath)
        # Rebuild argv: interp [optarg] scriptpath orig-argv[1:].
        ai: uint64 = 0
        _shebang_argv_ptrs[ai] = cast[uint64](&_shebang_interp[0])
        ai = ai + 1
        if _shebang_optarg[0] != 0:
            _shebang_argv_ptrs[ai] = cast[uint64](&_shebang_optarg[0])
            ai = ai + 1
        _shebang_argv_ptrs[ai] = cast[uint64](&_shebang_script[0])
        ai = ai + 1
        # Append the original argv from index 1 onward (argv[0] = the
        # script name is replaced by scriptpath above).
        si: uint64 = 1
        while _exec_argv_ptrs[si] != 0 and ai < 19:
            _shebang_argv_ptrs[ai] = _exec_argv_ptrs[si]
            ai = ai + 1
            si = si + 1
        _shebang_argv_ptrs[ai] = 0
        # Adopt the rebuilt argv as THE snapshotted argv the init-stack
        # builders consume, and re-point the exec at the interpreter image.
        k: uint64 = 0
        while k <= ai:
            _exec_argv_ptrs[k] = _shebang_argv_ptrs[k]
            k = k + 1
        path = ipath
        blob = iblob
        sz = isz
    # #112 EXECVE OOM PRE-CHECK — restore execve atomicity under memory
    # pressure. do_execve is otherwise NON-atomic across the point-of-no-
    # return: for a fork CHILD (image_cow_shared=1) the teardown block below
    # clears its COW-inherited image/interp/stack PTEs, and THEN elf_load_blob
    # runs the native loader's eager CONTIGUOUS region_alloc, which OOMs on a
    # large Linux-ABI binary (/bin/sshd, /bin/login, /bin/hamdesktop) under
    # -m256M. execve then returned -ENOMEM PAST the point-of-no-return, so the
    # child resumed its now-UNMAPPED inherited RIP -> instruction-fetch
    # SIGSEGV at image+0x622a7 (root-caused by log correlation, #112).
    #
    # The fix: BEFORE any teardown (address space still fully intact — this
    # sits ahead of vma_reset_mm_owner / vma_clear / the COW teardown), size
    # the eager contiguous region the loader will demand for the top-level
    # image and confirm it will fit. If it will NOT, abort execve cleanly with
    # -ENOMEM while the caller keeps its OLD image — exactly Linux execve(2)
    # failure semantics (the fork-child's inherited image stays runnable and
    # it handles the -ENOMEM), instead of running unmapped code. A size of 0
    # means the header couldn't be sized (bad/odd ELF) — skip the pre-check
    # and let the normal load path produce its verdict; region_can_alloc's
    # tiny window is not a hard guarantee under SMP, so the past-PONR failure
    # arm below (elf_load_blob == 0) is also hardened to a deterministic kill.
    exec_eager_bytes: uint64 = elf_eager_region_bytes(
        cast[Ptr[uint8]](blob), sz)
    if exec_eager_bytes != 0 and region_can_alloc(exec_eager_bytes) == 0:
        printk2("execve: image '%s' needs %d contiguous bytes; not available (-ENOMEM, caller intact)\n",
                cast[uint64](&exec_kpath[0]), exec_eager_bytes)
        set_current_errstr("execve: out of memory")
        return cast[int64](-12)           # -ENOMEM, BEFORE point-of-no-return
    # EAGER USER-STACK PREFIX pre-check (fix/execve-ustack-oom). The stack
    # setup below EAGER-allocates a small CONTIGUOUS prefix via
    # alloc_pages(LINUX_USTACK_EAGER_ORDER) PAST the point-of-no-return
    # (vma_clear). If that order-6 run is unavailable under fragmentation and
    # we only discovered it there, alloc_pages returns 0 and — historically —
    # phys 0 got stamped into the fixed stack window's US=1 leaves, aliasing
    # physical [0, ...) (boot page tables / AP trampoline) and #DF-halting the
    # box. Confirm the run is available HERE, while the caller's address space
    # is still fully intact, so a genuine OOM fails execve cleanly with
    # -ENOMEM (Linux semantics) and the DE stays alive. The real alloc below
    # keeps a hard null-check backstop for the SMP race window.
    if pages_can_alloc(LINUX_USTACK_EAGER_ORDER) == 0:
        printk1("execve: user-stack prefix (%d bytes contiguous) not available (-ENOMEM, caller intact)\n",
                LINUX_USTACK_EAGER_SIZE)
        set_current_errstr("execve: out of memory")
        return cast[int64](-12)           # -ENOMEM, BEFORE point-of-no-return
    # U42 VMA: drop the outgoing image's mappings BEFORE we load the
    # new ELF. Without this, the new program would inherit the parent
    # image's stack/heap/mmap VMAs and a subsequent mprotect or munmap
    # could touch addresses that no longer belong to the new image's
    # address-space namespace. We do this after the initramfs lookup
    # (so a failed execve doesn't destroy the caller's address space)
    # but before elf_load_blob — the new PT_LOAD-derived VMAs land on
    # the cleared list. Note: at this scale (single Linux task at a
    # time, no per-process pagetables enforcing isolation between
    # tasks) the backing-page free here is what matters for
    # bookkeeping; the actual ELF-image pages were memblock-allocated
    # via elf_load_blob's allocator path and aren't tracked through
    # vma_list yet, so they leak across execve same as before. The
    # VMAs being cleared here are anonymous + file-backed mmaps the
    # OUTGOING program made (glibc-malloc arenas, mmap'd libc DSOs)
    # — those are correctly freed.
    # execve establishes a FRESH address space for this task, so it now
    # owns its own mm group (any prior CLONE_VM thread-group link is void —
    # POSIX execve terminates sibling threads). Reset to self BEFORE
    # vma_clear so the (self-owned) outgoing VMAs are actually freed rather
    # than skipped by vma_clear's non-owner-thread guard. See mm/vma.ad.
    vma_reset_mm_owner(current_idx_get())
    vma_clear(current_idx_get())
    # Free the OUTGOING program's brk heap reserve (32 MiB, lazily
    # reserved by glibc-malloc's first brk()) BEFORE the new image is
    # loaded, while the old address space is still fully mapped. The new
    # program re-reserves a fresh brk arena on its own first brk(), so a
    # stale 32 MiB window would otherwise leak across every execve-replace
    # — the same dominant per-spawn drain task_reap now reclaims at exit.
    # OWNER-SAFE: vma_free_reserved_range routes each frame through
    # cow_drop_page, so a brk page still COW-shared by a forked relative
    # (refcount > 1) is left for that holder. Zero the cursors so the new
    # image's first brk() lazily reserves cleanly.
    exec_slot: uint64 = current_idx_get()
    if task_brk_base(exec_slot) != 0:
        vma_free_reserved_range(exec_slot, task_brk_base(exec_slot),
                                task_brk_max(exec_slot))
        set_task_brk_range(exec_slot, 0, 0, 0)
    # FORK+EXEC COW-IMAGE ISOLATION (apt dpkg-split blocker, T26).
    # A fork CHILD that now execve's COW-SHARES its PARENT's ELF image +
    # interp: do_clone walked vm_cow_share_all/_range over [image_lo,image_hi)
    # and [interp_lo,interp_hi), bumping each frame's per-PFN refcount 1->2,
    # and set image_cow_shared = 1 on this child. The OLD execve path leaked
    # the outgoing image: vma_clear does not touch it (it is a region, not a
    # VMA) and task_free_owner_regions skips it (image_phys == 0 on a fork
    # child). So the stale COW image mapping survived into the new image load
    # and the bumped refcount was never dropped — the child kept aliasing the
    # parent's LIVE image frames and a write (glibc __fork walking
    # _dl_stack_used) corrupted the parent's struct pthread -> the parent's
    # next __fork SIGSEGV'd at image_lo + 0x328. Fix: tear the outgoing image
    # + interp down through the COW-safe path (vma_free_reserved_range ->
    # _vma_free_cow_range -> cow_drop_page): the refcount falls 2->1 (the
    # parent keeps the frame) and the child's stale PTEs are cleared, so the
    # fresh per-exec image loads into a clean address space with no parent
    # alias. The new region-owned image is recorded AFTER elf_load_blob and
    # reclaimed by region_free at reap as before.
    #
    # GATED ON image_cow_shared, NOT on image_phys == 0. The rejected
    # verify-apt-471 attempt gated on image_phys == 0, which over-fired: the
    # boot init -> hamsh exec (and any directly-launched task) can also carry
    # image_phys == 0 over a NON-COW image it holds outright, and
    # cow_drop'ing those frames tore down pages the new process still needed
    # and wedged boot before the hamsh prompt. image_cow_shared is set ONLY
    # by do_clone after a real COW-share, so the teardown now fires for a
    # genuine fork-child alias and NEVER for the normal owner-image exec.
    if task_image_cow_shared(exec_slot) != 0:
        # LIVE-TASK UAF FIX (dfd59371 regression): use vma_release_forked_
        # range, NOT vma_free_reserved_range. The image / interp spans are
        # region_alloc()'d and OWNED by the parent — this fork child never
        # owns them (image_phys/interp_phys == 0) and must ONLY drop its COW
        # reference + clear its stale PTEs, never free_page() an owner frame.
        # vma_free_reserved_range's free-at-refcount-0 arm returned a shared
        # .text frame the LIVE parent still maps to the BUDDY pool (a frame
        # whose count momentarily hit 1 under app-spawn load), so the parent
        # NX-faulted on a reused US=0 frame (code=139). The child still drops
        # its reference (parent count 2 -> 1, never stranded), so the
        # original fork+exec poison stays fixed; only child-private COW
        # copies (refcount 0, buddy-owned) are reclaimed here.
        ci_lo: uint64 = task_image_lo(exec_slot)
        ci_hi: uint64 = task_image_hi(exec_slot)
        if ci_lo != 0 and ci_hi > ci_lo:
            vma_release_forked_range(exec_slot, ci_lo, ci_hi)
        cn_lo: uint64 = task_interp_lo(exec_slot)
        cn_hi: uint64 = task_interp_hi(exec_slot)
        if cn_lo != 0 and cn_hi > cn_lo:
            vma_release_forked_range(exec_slot, cn_lo, cn_hi)
        # FORK+EXEC COW-STACK ISOLATION (Phase-5c COW refcount-poison hole).
        # do_clone COW-shared the parent's ENTIRE user stack [ust_lo, ust_sz)
        # into this child (vm_cow_share_all), bumping every present stack
        # frame's per-PFN refcount 1->2 — and the child carries ustack_phys
        # == 0 (it never owned the stack; the parent's task_reap frees the
        # backing run). The OLD execve path then installed a FRESH stack at
        # the SAME high VA (LINUX_USTACK_VBASE is a constant) by OVERWRITING
        # the child's stack PTEs, WITHOUT ever dropping those bumped COW
        # refcounts (the historical "previous user stack page is leaked for
        # now" comment below). That left every shared stack frame stuck at
        # refcount 2 with only ONE real mapper (the parent), so:
        #   * the parent's next stack write COW-COPIES unnecessarily and
        #     cow_drop's 2->1, stranding the original frame at refcount 1
        #     with NO mapper — and
        #   * frames the parent never touches stay at 2, then task_reap
        #     free_pages() the whole run back to the buddy allocator with a
        #     STALE non-zero refcount-table entry.
        # Either way a poisoned refcount entry rides a recycled frame into a
        # later COW share (cow_share_page sees cur!=0 so it bumps N->N+1
        # instead of 0->2), so a subsequent teardown's cow_drop arithmetic is
        # off-by-the-stale-count and the frame is freed while still COW-mapped
        # elsewhere (or leaked forever) — the fork+exec COW-frame corruption
        # family this closes. Tear the outgoing COW stack down through the
        # SAME COW-safe path as image/interp/brk (cow_drop 2->1, the parent
        # keeps the frame; a child-private COW-faulted frame at refcount 0 is
        # freed) and clear the child's stale stack PTEs BEFORE the fresh stack
        # is installed over the same VA. Gated on image_cow_shared, so it
        # fires ONLY for a genuine fork/vfork child alias and NEVER for the
        # normal owner-image exec (whose stack task_free_owner_regions frees).
        # The user stack is the PARENT's alloc_pages() run (freed by the
        # parent's task_reap via free_pages(ustack_phys)); this child carries
        # ustack_phys == 0. Same owner-frame rule as image/interp: drop our
        # COW ref + clear PTEs, never free_page a frame the live parent owns.
        cu_lo: uint64 = task_ustack_lo(exec_slot)
        cu_sz: uint64 = task_ustack_sz(exec_slot)
        if cu_lo != 0 and cu_sz != 0:
            vma_release_forked_range(exec_slot, cu_lo, cu_lo + cu_sz)
        # The outgoing COW alias is gone; the new image loaded below is
        # region-owned (recorded via set_task_image_phys), not COW-shared.
        set_task_image_cow_shared(exec_slot, 0)
    # U52 ASLR (load bias + mmap base). Draw per-exec randomized bases and
    # arm them BEFORE the ELF load / first mmap. elf_set_aslr_vbases tells
    # the loader where to place the ET_DYN application + interpreter images
    # (vaddr != phys, mapped through the per-task PML4); vma_set_mmap_base
    # shifts the windowed-mmap allocator's start. Both collapse to the
    # identity layout when aslr_disabled is set (the helpers return 0).
    # Only ET_DYN images move under elf_set_aslr_vbases — an ET_EXEC binary
    # ignores the vbases (it must run at its baked-in link address), so this
    # is harmless for those.
    aslr_app_vbase:    uint64 = aslr_load_bias()
    aslr_interp_vbase: uint64 = aslr_interp_bias()
    elf_set_aslr_vbases(aslr_app_vbase, aslr_interp_vbase)
    vma_set_mmap_base(exec_slot, aslr_mmap_slide())
    entry: uint64 = elf_load_blob(cast[Ptr[uint8]](blob), sz)
    if entry == 0:
        # #106 GRACEFUL OOM. Two bugs converged here into a boot-wedge:
        #   (1) this print dereffed the RAW USER pointer `a0` via %s, but by
        #       now vma_clear() (above) has torn the caller's address space
        #       down, so `a0` is UNMAPPED — printk's %s walk kernel-#PF'd and
        #       wedged the CPU (the truncated "execve: ELF load of '" with no
        #       newline). Every sibling failure-print already used the kernel
        #       copy &exec_kpath[0]; this one did not. Use the kernel buffer so
        #       the diagnostic COMPLETES and never faults.
        #   (2) an OOM (region_alloc failed) was reported as -ENOEXEC. Read the
        #       loader's OOM flag and return -ENOMEM so the caller/shell sees a
        #       truthful "out of memory", not "bad executable".
        # #112 PAST-PONR DETERMINISTIC KILL. This site is UNCONDITIONALLY past
        # the point-of-no-return — vma_clear() (and, for a fork-child, the COW
        # image/interp/stack teardown) has already run, so the caller's own
        # instruction stream is gone. Returning an errno here SYSRETQ'd back
        # into a torn-down/unmapped user image, and a fork-child then resumed
        # its now-unmapped inherited RIP -> a mysterious later instruction-
        # fetch SIGSEGV at image+0x622a7 (the #112 signature). The #112 pre-
        # check above now aborts the common OOM case BEFORE any teardown with
        # the caller intact; anything that STILL fails here (TOCTOU under SMP,
        # an interpreter-image OOM, a genuinely bad ELF, or an unparse-able
        # header that skipped the pre-check) must die DETERMINISTICALLY at the
        # exec site — exactly like Linux, which force_sigsegv/SIGKILLs a task
        # whose exec fails past the point-of-no-return — instead of resuming
        # unmapped code. Release the execve serialization lock FIRST (the
        # do_execve wrapper's unlock never runs once task_exit_current schedules
        # away and never returns), record the exit disposition, and terminate.
        if elf_last_load_oom != 0:
            printk1("execve: ELF load of '%s' failed past PONR: out of memory — killing task\n",
                    cast[uint64](&exec_kpath[0]))
            set_current_errstr("execve: out of memory")
        else:
            printk1("execve: ELF load of '%s' failed past PONR (bad image) — killing task\n",
                    cast[uint64](&exec_kpath[0]))
            set_current_errstr("execve: bad ELF image")
        # Release the execve serialization lock FIRST (task_exit_current
        # schedules away and never returns, so do_execve's wrapper unlock at
        # the error-return site would otherwise be skipped -> a leaked lock
        # deadlocks every future execve), then terminate with 128+SIGSEGV(11)
        # = 139, the conventional "killed by SIGSEGV" wait-status.
        spinlock_unlock(&_execve_lock)
        task_exit_current(cast[int64](139))
        # Not reached (task_exit_current schedules away and never returns).
        return cast[int64](-12)
    # POSIX execve(2): reset every CAUGHT-signal disposition to SIG_DFL — a
    # handler address is a .text VA into the image we just replaced, so a
    # signal delivered to an inherited/stale handler after exec would jump
    # into the NEW image's .data/.bss (a non-exec page) and NX-fault. This is
    # the Phase-5b X-display gate: a fork+exec'd helper inherited a SIGCHLD
    # handler and, on a grandchild exit, jumped to a stale VA in its own .bss.
    # SIG_IGN is preserved; the signal mask + pending set are kept. Done at the
    # exec point-of-no-return (new image is committed), before any new sigaction.
    exec_reset_signal_dispositions(current_idx_get())
    # execve(2) closes every fd marked O_CLOEXEC / FD_CLOEXEC. This is the
    # semantic that unwedges the fork + O_CLOEXEC-sync-pipe + exec idiom
    # (foot / posix_spawn / every terminal emulator / Firefox content-proc
    # launch): the parent read()s a pipe whose CLOEXEC write end the child
    # holds, and gets EOF only once THIS exec closes it. Without it the
    # parent blocks in read() forever (foot never reaches get_xdg_surface).
    # At the point-of-no-return so a clean-fail path never loses fds.
    exec_close_cloexec_fds(current_idx_get())
    # U5: exec replaces current image. If the loaded image is a
    # Linux-ABI ELF, flip the current task's is_linux_userspace
    # flag so subsequent syscalls dispatch via u_syscalls. If the
    # caller was already in Linux-ABI mode (U25 path: glibc calling
    # SYS_execve(59) into another Linux binary), this is a no-op;
    # if a native binary is exec-ing into a Linux ELF, this flip is
    # what activates the u_syscalls dispatcher for the new image.
    is_linux: int32 = elf_last_was_linux
    if is_linux != 0:
        set_linux_userspace_mode(
            cast[int32](current_idx_get()), 1)
    # Stamp this task's name0 / comm from the executed program's basename so
    # /proc/tasks (and ps / hammon / the System Monitor) show the running
    # program name instead of the creation-time "__rfork_" tag every spawned
    # process otherwise carries. exec_kpath is the kernel copy of the path.
    set_task_name0_from_path(current_idx_get(), cast[Ptr[char]](&exec_kpath[0]))
    # U30: ET_EXEC binaries (busybox-static, etc.) need their
    # link-time vaddr range mapped to the physical region we just
    # copied them into. ET_DYN (PIE) leaves this a no-op. We install
    # into the CURRENT task's PML4 because execve replaces this task's
    # image in place. Force a TLB flush afterwards by reloading the
    # same CR3 — the BSP identity map for [0x400000, 0x600000) is
    # still cached as a 1 GiB entry and would shadow the new finer
    # mapping otherwise.
    # The collision guard in elf_install_user_mapping refuses BEFORE
    # mutating the PML4, so a < 0 return here leaves cur_pml4 intact —
    # the current task survives the -ENOEXEC return instead of the box
    # freezing on a half-built address space.
    cur_pml4: uint64 = task_pml4(cast[int32](current_idx_get()))
    if elf_apply_last_user_mapping(cur_pml4) < 0:
        printk0("execve: user-mapping install failed (kernel-image collision?)\n")
        set_current_errstr("execve: cannot map binary")
        return cast[int64](-8)             # -ENOEXEC
    load_cr3(cur_pml4)
    # DEMAND-BSS: the loader eagerly mapped only the image's file extent.
    # Register the BSS tail [bss_lo, bss_hi) as a demand-zero anon RW NX
    # VMA so do_page_fault zero-fills it page by page on first touch
    # instead of the loader eagerly allocating one ~8 MiB CONTIGUOUS
    # physical region per app (which OOM'd the DE after a few hamui
    # clients, each linking ~8.2 MiB of static BSS). No-op when the image
    # has no BSS tail (bss_hi <= bss_lo).
    if vma_register_bss_demand(current_idx_get(), cur_pml4,
                               elf_last_app_bss_lo_get(),
                               elf_last_app_bss_hi_get()) < 0:
        printk0("execve: BSS demand-VMA register failed (OOM)\n")
        set_current_errstr("execve: cannot register BSS")
        return cast[int64](-12)            # -ENOMEM
    load_cr3(cur_pml4)
    # Fresh user stack for the new program. The previous user
    # stack page is leaked for now (no per-task ustack tracking
    # in this code path); proper teardown comes with mm_struct.
    # U38: 16 KiB was enough for glibc's static-PIE startup. The
    # per-process-address-space fork (this commit) eager-copies the
    # whole user stack on fork(); a child that returns from fork()
    # then unwinds through glibc's fork epilogue + atexit + _IO_cleanup
    # on its private stack. 256 KiB (64 pages, buddy order 6) gives
    # that call tower comfortable headroom and matches the floor the
    # mission set for the Linux user stack.
    # The USER VIRTUAL base of the stack is DECOUPLED to a HIGH window
    # (7 GiB, LINUX_USTACK_VBASE) so the stack is no longer identity-mapped
    # at low RAM where its frames could alias a live kernel stack / direct-
    # map slot — see the LINUX_USTACK_VBASE comment block. The user sees a
    # virtually-contiguous [VBASE, VBASE+SIZE) stack; the kernel reaches its
    # bytes through the low phys (uaccess PML4-walk) and through the high-VA
    # US=1 leaves the builder writes under STAC.
    # >4 GiB-RAM DIRECT-MAP ALIASING FIX: relocate the stack window above
    # ram_top when RAM is large so it never aliases real RAM's direct map under
    # CR4.SMAP (see linux_ustack_vbase). Byte-identical (== LINUX_USTACK_VBASE)
    # on <=4 GiB machines.
    new_ustack_vbase: uint64 = linux_ustack_vbase()
    # ANTI-FRAGMENTATION BACKING (fix/execve-ustack-oom): back only a small
    # CONTIGUOUS PREFIX at the TOP of the window eagerly; demand-page the rest.
    #   prefix = [ustack_prefix_lo, ustack_prefix_hi) = the top EAGER_SIZE bytes
    #   tail   = [new_ustack_vbase, ustack_prefix_lo)  = demand-zero VMA
    # The builder writes argv/envp/auxv from the top down (well inside the
    # prefix, since ASLR slide <=64 KiB + realistic argv/env << 256 KiB), and
    # glibc's __libc_stack_end lands in the prefix. Deeper stack use faults in
    # from the demand tail. This eliminates the old order-8 (1 MiB) contiguous
    # requirement that failed under fragmentation at low RAM.
    ustack_prefix_hi: uint64 = new_ustack_vbase + LINUX_USTACK_SIZE
    ustack_prefix_lo: uint64 = ustack_prefix_hi - LINUX_USTACK_EAGER_SIZE
    # The PHYSICAL backing of the eager stack prefix: one small contiguous
    # alloc_pages() run. HARD NULL-CHECK: alloc_pages returns 0 on OOM; the
    # pre-PONR pages_can_alloc() guard above already rejected a genuine OOM
    # with the caller intact, but an SMP rival could drain the run in the
    # window since — so if it fails HERE (past the point-of-no-return) fail the
    # execve deterministically WITHOUT ever passing phys 0 to
    # elf_install_user_range (which would stamp the fixed window's US=1 leaves
    # onto physical [0, ...) — the boot page tables / AP trampoline — and #DF-
    # halt the box). The caller's address space is already torn down here, so
    # -ENOMEM terminates this task cleanly rather than corrupting kernel memory.
    new_ustack_phys: uint64 = alloc_pages(LINUX_USTACK_EAGER_ORDER)
    if new_ustack_phys == 0:
        printk0("execve: user-stack prefix alloc OOM past PONR -> clean -ENOMEM (no phys-0 map)\n")
        set_current_errstr("execve: cannot back stack")
        return cast[int64](-12)             # -ENOMEM (address space already torn down)
    # Stage 2 ASLR (stack base): perturb the initial RSP DOWN by a random
    # page multiple inside the stack VA window. The slide stays an INTRA-
    # region virtual offset, so the high-VA top simply starts a few pages
    # lower; the builder's stores (now high-VA, US=1) and the kernel's
    # uaccess walks both honour it.
    new_ustack_top:  uint64 = ustack_prefix_hi - aslr_stack_slide()
    # Install per-task PT entries mapping the HIGH user VA PREFIX onto the LOW
    # physical run (phys_base = new_ustack_phys, decoupled from vlow).
    # elf_install_user_range stamps US=1 | RW | NX leaves and supports
    # phys_base != vlow. A < 0 return is an OOM cracking page tables (the
    # prefix alloc_pages above already succeeded) -> free it and return -ENOMEM.
    if elf_install_user_range(cur_pml4, ustack_prefix_lo,
                              ustack_prefix_hi,
                              new_ustack_phys, "stack",
                              PT_FLAG_NX | PT_FLAG_RW) < 0:
        free_pages(new_ustack_phys, LINUX_USTACK_EAGER_ORDER)
        printk0("execve: user-stack install failed (OOM in page-table walk?)\n")
        set_current_errstr("execve: cannot map stack")
        return cast[int64](-12)             # -ENOMEM
    # Register the LOWER remainder [vbase, prefix_lo) as a demand-zero anon
    # RW+NX VMA (BSS-style). Deeper stack pushes fault it in page-by-page; a
    # (rare) argv-builder overflow below the prefix also lands here and is
    # serviced by do_page_fault's kernel-mode demand path. MUST be registered
    # BEFORE the argv builder runs so any such overflow hits a live VMA.
    if vma_register_stack_demand(current_idx_get(), cur_pml4,
                                 new_ustack_vbase, ustack_prefix_lo) < 0:
        free_pages(new_ustack_phys, LINUX_USTACK_EAGER_ORDER)
        printk0("execve: stack demand-VMA register failed (OOM)\n")
        set_current_errstr("execve: cannot register stack")
        return cast[int64](-12)             # -ENOMEM
    load_cr3(cur_pml4)
    # Record the loaded image span + the user stack region on THIS
    # task so a later fork() can give the child a private copy of
    # each, remapped at the same virtual address.
    set_task_image_range(current_idx_get(),
                         elf_last_img_lo_get(),
                         elf_last_img_hi_get())
    # Record the dynamic-linker (PT_INTERP / ld.so) VIRTUAL image span so a
    # later fork (do_clone) COW-shares it into the child. The interp lives
    # in its own 1 GiB ASLR window (ASLR_INTERP_BASE=5 GiB); execve cracked
    # the boot identity PS=1 huge page over it into US=1 leaves, but a
    # fork's verbatim PML4 clone does NOT inherit that crack — without
    # sharing the range the child's CPL=3 ld.so access faults err=0x05
    # (present/user/read on a supervisor leaf). 0/0 for a static binary
    # (no PT_INTERP) — the helper skips an empty range.
    set_task_interp_range(current_idx_get(),
                          elf_last_interp_img_vlow_get(),
                          elf_last_interp_img_vhigh_get())
    # ustack RANGE is the eager CONTIGUOUS PREFIX at the top of the window
    # (fix/execve-ustack-oom). fork() COW-shares THIS range by VA and
    # task_reap free_pages() it as one order-6 run — both machineries stay
    # unchanged, just over the prefix. The demand TAIL below the prefix is a
    # separate VMA that vma_fork_copy mirrors to a child and vma_clear frees
    # at reap (the proven BSS demand path), DISJOINT from this by-VA range so
    # there is no double-processing. /proc/self/maps' synthetic [stack] line
    # (mm/vma.ad) reports this prefix; it contains __libc_stack_end, and glibc
    # sizes the main-thread stack from RLIMIT_STACK (still 1 MiB), so a shorter
    # reported range is safe.
    set_task_ustack_range(current_idx_get(),
                          ustack_prefix_lo, LINUX_USTACK_EAGER_SIZE)
    # Leak 2 fix: free the task's PRE-execve OWNER-ONLY regions (old ELF
    # image, old interp, old user stack) BEFORE overwriting the owner
    # fields with the new image's coords. On the direct-spawn-then-execve
    # path SYS_SPAWN gave this task its OWN image/interp/ustack regions;
    # without freeing them here the old spans leak for the rest of the
    # boot. task_free_owner_regions is OWNER-SAFE: it frees only fields
    # that are != 0 (i.e. regions THIS task allocated). A task that
    # reached execve via fork+exec COW-shares the parent's image and has
    # image_phys/interp_phys == 0 — those are left untouched, never
    # double-freed. The new region just installed above lives in a fresh
    # region_alloc chunk and cannot alias the outgoing one. Mirrors
    # task_reap's image/interp/ustack arms exactly.
    task_free_owner_regions(current_idx_get())
    # Resource-reclaim ownership for THIS task's new image + stack +
    # interp so task_reap returns them when the task eventually exits.
    set_task_image_phys(current_idx_get(),
                        elf_last_img_phys_get(),
                        elf_last_img_hi_get() - elf_last_img_lo_get())
    # ustack PHYS is the LOW alloc_pages() run backing the eager PREFIX
    # (task_reap free_pages it as one order-6 run; _order_for_bytes(EAGER_SIZE)
    # == LINUX_USTACK_EAGER_ORDER). The demand-tail pages are owned by the
    # stack demand VMA and freed via vma_clear at reap, not through this field.
    set_task_ustack_phys(current_idx_get(),
                        new_ustack_phys, LINUX_USTACK_EAGER_SIZE)
    set_task_interp_phys(current_idx_get(),
                        elf_last_interp_img_phys_get(),
                        elf_last_interp_img_sz_get())
    argc_out: uint64 = 0
    argv_out: uint64 = 0
    new_rsp: uint64 = 0
    if is_linux != 0:
        # #169 vDSO: map the shared vDSO mini-ELF + time data page into
        # THIS task's address space (the same cur_pml4 the image + stack
        # were just installed into) and capture the user vaddr of the
        # ELF page for AT_SYSINFO_EHDR. Returns 0 if the vDSO isn't ready
        # or the mapping failed — in which case the auxv entry is simply
        # omitted and glibc/musl fall back to the clock_gettime syscall.
        vdso_ehdr: uint64 = vdso_map_into_user(cur_pml4)
        load_cr3(cur_pml4)                 # publish the new vDSO PTEs
        # U16: Linux process init-stack — *rsp points to argc;
        # argv/envp/auxv all reachable from rsp+8. musl ignores
        # %rdi/%rsi, so we pass argc=0/argv=0 in the SysV slots.
        # U17: forward envp (a2) into the init-stack builder so
        # getenv() works in musl-built binaries.
        # U20: pass entry + load base so the auxv carries
        # AT_ENTRY / AT_PHDR / AT_PHNUM for glibc/musl's own
        # _dl_relocate_static_pie pass.
        # uaccess (#163): builders consume the kernel-resident argv/envp
        # snapshot (exec_snapshot_args above), NOT raw user a1/a2 — those no
        # longer resolve now that CR3 holds the new image's mappings.
        new_rsp = _build_user_argv_linux(new_ustack_top,
                                         cast[uint64](&_exec_argv_ptrs[0]),
                                         cast[uint64](&_exec_envp_ptrs[0]),
                                         entry, elf_last_load_base,
                                         vdso_ehdr)
    else:
        new_rsp = _build_user_argv(new_ustack_top,
                                   cast[uint64](&_exec_argv_ptrs[0]),
                                   &argc_out, &argv_out)
    printk2("execve: jumping to %p with stack %p\n",
            entry, new_rsp)
    # U26: if this task is a vfork-style child still sharing its
    # parent's user image, signal the parent that we've replaced the
    # image and it's safe to resume. The parent is spinning on
    # task_vfork_done in do_clone; setting this here is the last
    # moment before SYSRETQ swaps to the new user RIP/RSP. A regular
    # (non-forked) execve still sets this — harmless, nobody's polling.
    set_task_vfork_done(cast[int32](current_idx_get()), 1)
    # SUCCESS: all shared loader-global reads (elf_last_*, _exec_argv_ptrs,
    # elf_last_load_base) are done above. Release the execve serialization
    # lock HERE, before do_execve_finish() SYSRETQs to the new user image
    # and never returns to the wrapper. This is the one success-path unlock;
    # every error path returns to the wrapper which unlocks there instead.
    spinlock_unlock(&_execve_lock)
    do_execve_finish(entry, new_rsp, argc_out, argv_out)
    # Not reached.
    return 0


# U27: clone-flag bits we branch on. Numerically identical to the
# Linux <linux/sched.h> values — kept local so the kernel surface
# doesn't depend on the linux_abi headers just for a constant.
CLONE_VM:                uint64 = 0x100
CLONE_VFORK:             uint64 = 0x4000
CLONE_FS:                uint64 = 0x200
CLONE_FILES:             uint64 = 0x400
CLONE_SIGHAND:           uint64 = 0x800
CLONE_THREAD:            uint64 = 0x10000
CLONE_SETTLS:            uint64 = 0x80000
CLONE_PARENT_SETTID:     uint64 = 0x100000
CLONE_CHILD_CLEARTID:    uint64 = 0x200000
# Plan-9-did-containers-first: CLONE_NEWNS is Linux's "give the child a
# fresh mount namespace" bit. Hamnix's native per-process mount table is
# the Plan 9 Pgrp; a clone()/fork() carrying this bit deep-copies the
# parent's Pgrp into a private ref=1 copy for the child (pgrp_clone)
# instead of leaving the child to resolve the shared root Pgrp. After
# the clone, binds/mounts in either task are invisible to the other.
# The CLONE_NEWNS constant itself is defined once in linux_abi/
# u_syscalls.ad (these modules merge into one program, so the global
# name is shared); do_clone below references it directly.


# #160 / seccomp-lite: copy the parent's seccomp mode + allow-list
# bitmap onto a fork/clone child. The filter is irrevocable AND
# inherited (Linux semantics), so a confined parent can never produce an
# unconfined child. A no-op when the parent has no filter (mode 0).
def seccomp_inherit_to_child(child_slot: uint64, parent_slot: uint64):
    mode: uint64 = get_task_seccomp_mode(parent_slot)
    if mode != 0:
        w: uint64 = 0
        while w < 4:
            set_task_seccomp_filter(child_slot, w,
                                    get_task_seccomp_filter(parent_slot, w))
            w = w + 1
        set_task_seccomp_mode(child_slot, mode)
    # F10-8 / #457: NATIVE seccomp filter inherits the same way — the
    # parent's allow-list bitmap + armed bit propagate to the child, so
    # a confined parent cannot produce an unconfined child. A no-op
    # when the parent has nothing armed.
    if get_task_seccomp_native_armed(parent_slot) != 0:
        nw: uint64 = 0
        while nw < 4:
            set_task_seccomp_native_filter(child_slot, nw,
                                           get_task_seccomp_native_filter(parent_slot, nw))
            nw = nw + 1
        set_task_seccomp_native_armed(child_slot, 1)
    # §6: classic-BPF seccomp programs (kernel/seccomp_bpf.ad). Each
    # parent filter is duplicated into a fresh child pool slot in the
    # same order, so a confined parent can never produce an unconfined
    # child via fork/clone (matches the bitmap-filter rule above).
    bpf_inherit_to_child(child_slot, parent_slot)


def do_clone(flags: uint64, child_stack: uint64,
             ptid: uint64, ctid: uint64, tls: uint64,
             user_r9: uint64,
             user_rdx: uint64, user_r8: uint64,
             user_rdi: uint64) -> int64:
    # user_rdi: the parent's %rdi at the clone(2)/vfork(2) syscall entry.
    # Only load-bearing on the CLONE_VFORK fork path: glibc's hand-written
    # __vfork (sysdeps/unix/sysv/linux/x86_64/vfork.S) pops its return
    # address OFF the shared stack INTO %rdi before the syscall, and pushes
    # it back AFTER (`popq %rdi; syscall; pushq %rdi; ret`). The vfork
    # contract shares the stack between parent and child (CLONE_VM), so the
    # return address is parked in a register, not stack memory, to survive
    # both control flows. A Hamnix vfork child gets a COW *copy* of the
    # stack and resumes at the post-syscall `pushq %rdi` — so it MUST come
    # back with the parent's %rdi, or it pushes a zero and `ret`s to NULL
    # (the historic `[pf] NX exec-fault va=0` that killed every dpkg/apt
    # fork-helper). SYS_SPAWN / clone(2)-with-stack / fork(2) pass 0 — they
    # don't ride the vfork register-return trick.
    # Branches on CLONE_VM | CLONE_THREAD:
    #
    #   * Thread path  (CLONE_VM | CLONE_THREAD set): the caller is
    #     musl's pthread_create / glibc's pthread_create. It already
    #     mmap'd a thread stack and populated `child_stack` with the
    #     entry-point trampoline frame; we use that pointer verbatim
    #     as the child's RSP, do NOT copy the parent's stack page,
    #     schedule the child STATE_READY, and return immediately.
    #     Parent and child run concurrently from here. CLONE_SETTLS
    #     plants `tls` into the child's per-task fs_base so the next
    #     context switch restores it. PARENT_SETTID writes the new
    #     pid into *ptid; CHILD_CLEARTID stashes ctid in the child's
    #     clear_child_tid slot so task_exit_current zeroes it +
    #     futex-wakes a joiner on the way out. user_r9 propagates the
    #     parent's syscall-entry %r9 because musl's __clone wrapper
    #     parks the worker function there and the child does
    #     `call *%r9` after the syscall returns.
    #
    #   * Fork path  (no CLONE_VM): the legacy U26 vfork-style behaviour
    #     — deep-copy the parent's user stack page onto a fresh page,
    #     create a child whose RIP/RSP resume at the parent's syscall
    #     return, BLOCK the parent until the child execve's or exits.
    #     This is what plain fork() and vfork() pass us (SIGCHLD only).
    parent: Ptr[TaskStruct] = current_task()
    kstack_top: uint64 = parent[0].kstack_top
    # syscall_64.S parks the user's NATURAL RSP at kstack_top-8 (the entry
    # stub no longer touches the user stack — it spills scratch to per-CPU
    # slots — so the stored RSP is the caller's real RSP, no fixup needed),
    # r11/RFLAGS at -16, and rcx/user_RIP at -24 (both unchanged from the
    # old layout). See arch/x86/kernel/syscall_64.S for the full frame map.
    parent_user_rsp: uint64 = cast[Ptr[uint64]](kstack_top - 8)[0]
    parent_user_rip: uint64 = cast[Ptr[uint64]](kstack_top - 24)[0]

    # --- thread path -----------------------------------------------
    is_thread: int32 = 0
    if (flags & CLONE_VM) != 0 and (flags & CLONE_THREAD) != 0:
        is_thread = 1

    if is_thread != 0:
        # Caller-supplied stack — must be non-zero for a real
        # pthread_create. Honour it verbatim: musl/glibc has already
        # laid out the trampoline (return-to-__clone_func then
        # start_routine) at the top of the mmap'd thread stack and
        # handed us a pointer just below it. We don't allocate a new
        # page or copy from the parent — that would corrupt the
        # trampoline the libc just wrote.
        if child_stack == 0:
            set_current_errstr("clone: thread needs child stack")
            return cast[int64](-22)           # -EINVAL
        # create_user_thread plants user_r9 into the iret frame's r9
        # slot. musl's __clone wrapper saves the worker function in
        # %r9 across the syscall and the child does `call *%r9` after
        # the syscall returns. Without preserving user_r9 here, the
        # child calls into NULL.
        # CLONE_VM: the thread SHARES the creator's address space — its
        # cr3 points at the creator's PML4 from the moment of creation
        # (share_cr3 param), so per-task page-table overlays (mm/vma.ad's
        # multi-chunk VMA backing for an >4 MiB mmap such as the 8 MiB
        # glibc pthread stack) are visible to it immediately. The thread
        # comes back STATE_EMBRYO — invisible to EVERY dispatcher on
        # EVERY cpu (the old IRQ-mask-around-set_task_cr3 dance never
        # stopped the OTHER cpu's steal/pull path from dispatching the
        # half-built thread) — until task_publish_thread_ready() below,
        # after the last inheritance store. No disposable boot-clone
        # PML4 exists anymore: nothing leaks per spawn, and there is
        # nothing to free out from under a concurrently-dispatched
        # thread (a free-at-repoint frees a potentially LIVE CR3 ->
        # reallocated + scribbled page tables -> the latent-#DF family).
        child_slot: int32 = create_user_thread(parent_user_rip,
                                               0x5f5f7468725f5f5f,    # "__thr___"
                                               child_stack, 0, 0,
                                               user_r9,
                                               user_rdx, user_r8,
                                               task_pml4(cast[int32](current_idx_get())),
                                               0)
        if child_slot < 0:
            set_current_errstr("clone: out of tasks")
            return cast[int64](-11)           # -EAGAIN
        # Inherit Linux-ABI mode (pthread_create only happens in
        # Linux user binaries; defensive against future native callers).
        if parent[0].is_linux_userspace != 0:
            set_linux_userspace_mode(child_slot, 1)
        # #160 / seccomp-lite: a thread inherits the creator's seccomp
        # filter (Linux: TSYNC aside, a CLONE_THREAD child shares the
        # filter). Copy mode + the 4-word allow-list bitmap.
        seccomp_inherit_to_child(cast[uint64](child_slot), current_idx_get())
        # #151: a CLONE_THREAD child inherits the creator's nice/weight.
        sched_inherit_nice_to_child(cast[uint64](child_slot), current_idx_get())
        # SHARE the fd table (CLONE_FILES, #71 — the Firefox / threaded-GUI
        # gate). A thread MUST share one fd table with its group: an fd opened
        # by ANY thread is visible to ALL, and a close by one closes for all
        # (glibc's GIO worker reads the inotify fd the main thread created).
        # We do a REAL share now — point the child at the parent's owner slot
        # and bump the owner's live-sharer refcount — instead of the old
        # snapshot COPY, which left a worker thread reading its own stale table
        # (read() -> EBADF -> GLib g_error abort). fork() (no CLONE_THREAD)
        # still COPIES, further down.
        fd_table_share_to_thread(child_slot, cast[int32](current_idx_get()))
        # Share cwd (CLONE_FS). Hamnix tracks cwd per-task by value, not
        # by reference, so technically threads have independent cwd
        # views — fixing that is a separate refactor. Most pthread code
        # doesn't chdir, so the divergence is harmless at this scale.
        set_task_cwd(cast[uint64](child_slot),
                     get_cwd_buf(current_idx_get()))
        # NAMESPACE (Plan 9 Pgrp) inheritance — the gap that wedged Firefox.
        # create_user_thread leaves the child's pgrp at 0, and a 0 pgrp
        # collapses to the ROOT namespace in resolve_path. So a CLONE_THREAD
        # worker resolved EVERY path in the root namespace, NOT the
        # `spawn/enter linux { … }` distro namespace its own process runs in.
        # A distro-only deep path then ENOENT'd on a worker thread while the
        # main thread (correct pgrp, inherited on the fork branch below)
        # resolved it fine: fontconfig's access("/etc/fonts/fonts.conf")
        # returned -1 on Firefox's font-init WORKER thread, FcInitLoadConfig
        # failed, that worker aborted WITHOUT signalling the main thread's
        # join-futex, and the whole thread group deadlocked (13 parked threads,
        # no window). A thread SHARES its creator's mount namespace by
        # definition (CLONE_THREAD implies namespace sharing), so bind the
        # child to the creator's Pgrp and bump its refcount — exactly the
        # plain-fork branch's share-the-parent's-Pgrp contract. Each thread
        # holds its own ref; task_exit_current's pgrp_ref_dec balances it.
        thr_pg: uint64 = task_pgrp(cast[int32](current_idx_get()))
        if thr_pg == 0:
            thr_pg = pgrp_current()
            set_task_pgrp(cast[int32](current_idx_get()), thr_pg)
        if thr_pg != 0:
            set_task_pgrp(child_slot, thr_pg)
            pgrp_ref_inc(thr_pg)
        # CLONE_SETTLS: child's fs_base = tls. Schedule()'s wrmsr
        # restores this when it next picks the thread; we don't
        # write MSR_FS_BASE here because the parent is still
        # running and a wrmsr would clobber HER %fs.
        if (flags & CLONE_SETTLS) != 0:
            set_task_fs_base(child_slot, tls)
        # CLONE_PARENT_SETTID: write the new tid into *ptid for the
        # parent to read on syscall return. The parent passes a
        # pointer into ITS own thread descriptor; the address is in
        # the shared address space so it's reachable from kernel mode.
        child_pid: uint64 = task_pid_at(child_slot)
        if (flags & CLONE_PARENT_SETTID) != 0 and ptid != 0:
            # QA-N32: page-fault-safe store (was a raw CPL=0 store). *ptid is
            # a USER vaddr; if its page is not present in the parent's cr3 a
            # raw store #PF's in kernel mode and the trap-diag HALTS the box.
            # put_user_32 walks the page table (faulting-in a VMA-backed page)
            # and returns -EFAULT instead of faulting on a bad address.
            put_user_32(cast[uint32](child_pid), ptid)
        # CLONE_CHILD_CLEARTID: stash ctid in the child so its
        # task_exit_current zeros *ctid + futex-wakes pthread_join.
        if (flags & CLONE_CHILD_CLEARTID) != 0 and ctid != 0:
            set_task_clear_child_tid(child_slot, ctid)
        # vfork_done is irrelevant on the thread path — set it to 1 so
        # nothing in a future audit can spin-wait on it. The parent
        # never reads this for a thread because we don't enter the
        # blocking yield loop below.
        set_task_vfork_done(child_slot, 1)
        # ALL inheritance stores done — flip EMBRYO -> READY. From this
        # store on, any CPU's dispatcher may pick the thread; every
        # field it needs (cr3, fs_base, fds, seccomp, cwd, tid hooks)
        # is in place. We return the tid (which is the pid at this
        # scale) to the libc; parent and child run concurrently.
        task_publish_thread_ready(child_slot)
        printk1("clone: thread created, child_pid=%d\n",
                cast[int32](child_pid))
        return cast[int64](child_pid)

    # --- fork path: real per-process address space ------------------
    #
    # Hamnix runs ET_DYN binaries identity-mapped, so a forked child
    # MUST get a PRIVATE physical copy of every writable region the
    # parent has, each remapped at the SAME virtual address in the
    # child's own PML4. Then the child runs at identical virtual
    # addresses but on private physical memory — every absolute
    # pointer it inherited (saved %rbp chain, return addresses,
    # glibc's _IO_2_1_stdout_ FILE struct, the TCB at fs_base) stays
    # valid, and parent and child no longer trample each other's
    # heap / stack / .data.
    #
    # Regions copied (each at the same vaddr in the child's PML4):
    #   * the whole loaded ELF image (code + rodata + data + bss),
    #   * the brk heap [brk_base, brk_end),
    #   * the user stack [ustack_lo, ustack_lo + ustack_sz),
    #   * every anonymous / file-backed mmap VMA.
    #
    # The child's RSP is IDENTICAL to the parent's user RSP — the
    # stack is copied byte-for-byte to the same virtual address, so
    # every saved-rbp / return-address in it is already correct from
    # the child's point of view. We pass parent_user_rsp straight
    # into create_user_task_argv; the non-zero value tells it to skip
    # the fresh-stack allocation and plant our RSP into the iret frame.
    parent_idx: uint64 = current_idx_get()
    # ADDRESS-SPACE-LEAK FIX: before allocating a slot + address space for the
    # child, reclaim any DETACHED (RFNOWAIT / `spawn detached`) zombies whose
    # full address space + slot + cgroup pids charge would otherwise leak (the
    # exiting detached task cannot free its own kstack/cr3 — see task_exit_current).
    # Doing the sweep here means a dead detached task's resources are recycled
    # exactly when the next fork needs them, so a pipeline's clone() can't fail
    # -EAGAIN just because earlier fire-and-forget DE/service spawns bled the pool.
    reap_orphan_zombies()
    # cgroup v2 pids.max: reject a fork that would push the parent's
    # cgroup PAST its pids.max. Checked BEFORE any task-slot allocation
    # so an over-limit fork costs nothing and returns -EAGAIN, exactly
    # like Linux's pids_cgroup (kernel/cgroup/pids.c::pids_can_fork).
    if cgroup_pids_can_fork(parent_idx) == 0:
        set_current_errstr("fork: pids.max reached")
        return cast[int64](-11)               # -EAGAIN
    # RACE FIX: mask IRQs across create + COW-share. create_user_task_argv
    # marks the child STATE_READY, but its address space is not populated
    # until vm_cow_share_all / vma_fork_copy below. A timer preemption in
    # between would let _pick_next() dispatch the child onto its fresh
    # (empty) PML4 -> wild jump. The COW helpers' own boot-CR3 IRQ
    # save/restore nests safely under this mask (they save IF=0, restore
    # it, leaving IRQs masked).
    # vfork resume-%rdi: on the CLONE_VFORK path the child must come back
    # from the syscall with the parent's %rdi (glibc __vfork's saved return
    # address — see the user_rdi contract at the top of do_clone). We plant
    # it via the argc slot of create_user_task_argv, which _build_initial_-
    # kstack writes into the child's iret-frame %rdi position. A plain
    # fork(2) / clone(2)-with-stack child returns into glibc's fork epilogue
    # (not _start) and never reads %rdi as argc, so 0 is correct there.
    _child_rdi: uint64 = 0
    if (flags & CLONE_VFORK) != 0:
        _child_rdi = user_rdi
    # clone(2)/clone3(2) with a CALLER-SUPPLIED child_stack but WITHOUT
    # CLONE_THREAD — glibc/musl posix_spawn() + system() + popen() do exactly
    # this: clone(CLONE_VM|CLONE_VFORK|SIGCHLD, child_stack, ...) to run a
    # worker (__spawni_child) that execve's the target. The child MUST resume
    # on ITS OWN stack running the worker the libc parked in %rdx/%r8 (clone3)
    # or on the child stack (legacy clone) — NOT on the parent's copied RSP.
    # The pre-fix code reused parent_user_rsp for every non-thread clone, so
    # the child (and, via glibc's __clone epilogue, the woken CLONE_VFORK
    # parent) popped a bogus return address off the wrong stack and `ret`d
    # into it: the `[pf] NX exec-fault on user page va=<ustack>` that killed
    # Xwayland the instant it posix_spawn'd xkbcomp. Honour child_stack +
    # forward the worker-fn registers exactly like the CLONE_THREAD path, but
    # KEEP the COW-copied private address space + CLONE_VFORK parent-block
    # (fork semantics) so the child's execve can never corrupt the parent.
    # child_stack==0 (plain fork()/vfork()) keeps the resume-on-parent-RSP
    # behaviour those two rely on.
    _child_rsp: uint64 = parent_user_rsp
    _c_r9:  uint64 = 0
    _c_rdx: uint64 = 0
    _c_r8:  uint64 = 0
    if child_stack != 0:
        _child_rsp = child_stack
        _c_r9  = user_r9
        _c_rdx = user_rdx
        _c_r8  = user_r8
    _fork_irq: uint64 = local_irq_save()
    # FORK<->STEAL RACE (#413 class) FIX: publish the child STATE_EMBRYO, not
    # READY. The local IRQ mask above only fences THIS cpu; on -smp 2 the
    # OTHER cpu's work-steal/pull dispatcher could grab a READY child and run
    # it against the half-populated PML4 we are about to COW-share below (a
    # libapt .text PTE not yet present/executable -> NX exec-fault, or a
    # not-yet-mapped page -> va=0 read-fault -> SIGSEGV in apt's worker). An
    # EMBRYO child is on NO run-list, so neither _pick_next nor the steal walk
    # can see it. We flip it READY (task_publish_thread_ready) only AFTER the
    # whole address space is COW-shared + a write barrier, so any CPU that
    # observes the child READY also observes its fully-populated page table.
    # create_user_task_argv_embryo is the child_stack==0 special case of this
    # call (r9/rdx/r8 == 0, RSP == parent's). Call create_user_thread directly
    # so a child_stack!=0 clone can also forward the worker-fn registers while
    # still publishing STATE_EMBRYO (publish_embryo=1) for the #413 fork<->steal
    # fence and taking the COW-copy path (share_cr3=0).
    slot: int32 = create_user_thread(parent_user_rip,
                                        0x5f5f666f726b5f5f,        # "__fork__"
                                        _child_rsp, _child_rdi, 0,
                                        _c_r9, _c_rdx, _c_r8,
                                        0, 1)
    if slot < 0:
        local_irq_restore(_fork_irq)
        set_current_errstr("fork: out of tasks")
        return cast[int64](-11)               # -EAGAIN
    child_pml4: uint64 = task_pml4(slot)
    parent_pml4: uint64 = task_pml4(cast[int32](parent_idx))
    cslot: uint64 = cast[uint64](slot)

    # cgroup v2: the child joins the parent's cgroup and bumps
    # pids.current. (cgroup_pids_can_fork already gated us above; this is
    # the accounting commit now that the child slot exists.)
    cgroup_pids_charge_fork(parent_idx, cslot)

    # Copy-on-write the three fixed writable regions. Instead of
    # eager-copying ~33 MiB of pages, vm_cow_share_all marks every
    # writable user page READ-ONLY + COW in BOTH the parent's and the
    # child's PML4, pointing both at the SAME physical pages. The first
    # write by either side faults into do_page_fault, which copies (or
    # just unshares) exactly that one 4 KiB page. Regions covered:
    #
    #   * the loaded ELF image (code + rodata + data + bss) — the
    #     read-only .text pages stay shared forever; only writable
    #     .data / .bss ever get copied, lazily, on first write;
    #   * the brk heap across its ENTIRE reserved window
    #     [brk_base, brk_max) — glibc-malloc's sysmalloc grows the
    #     arena PAST the current break, so the whole reservation must
    #     be COW-shared (the static-PIE glibc TLS/TCB block is
    #     sbrk-allocated, so this also covers the child's private TCB);
    #   * the user stack — the whole recorded region.
    img_lo: uint64 = task_image_lo(parent_idx)
    img_hi: uint64 = task_image_hi(parent_idx)
    brk_lo: uint64 = task_brk_base(parent_idx)
    brk_mx: uint64 = task_brk_max(parent_idx)
    ust_lo: uint64 = task_ustack_lo(parent_idx)
    ust_sz: uint64 = task_ustack_sz(parent_idx)
    if vm_cow_share_all(parent_pml4, child_pml4, img_lo, img_hi,
                        brk_lo, brk_mx, ust_lo, ust_sz,
                        parent_user_rsp) < 0:
        local_irq_restore(_fork_irq)
        set_current_errstr("fork: address-space COW share OOM")
        return cast[int64](-12)               # -ENOMEM

    # COW-share the dynamic-linker (PT_INTERP / ld.so) image span. vm_cow_
    # share_all covers only image/brk/stack; the interp lives in its OWN
    # 1 GiB ASLR window (ASLR_INTERP_BASE=5 GiB), separate from all three.
    # do_execve cracked the boot identity PS=1 (US=0) huge page over that
    # window into per-task US=1 leaves, but the child's verbatim PML4 clone
    # re-inherits the uncracked supervisor huge page. vm_cow_share_range
    # walks [interp_lo, interp_hi) and (via _cow_resolve_pte_slot) CRACKS
    # the child's PDPTE/PD/PT down to US=1 leaves that COW-point at the
    # parent's interp frames — so the forked child's CPL=3 ld.so / PLT
    # access resolves instead of faulting err=0x05. Skipped (empty range)
    # for a static binary. interp_phys stays owner-only/0 on the child
    # (it COW-shares, never frees) — this shares only the VIRTUAL mapping.
    interp_lo: uint64 = task_interp_lo(parent_idx)
    interp_hi: uint64 = task_interp_hi(parent_idx)
    if interp_lo != 0 and interp_hi > interp_lo:
        if vm_cow_share_range(parent_pml4, child_pml4,
                              interp_lo, interp_hi) < 0:
            local_irq_restore(_fork_irq)
            set_current_errstr("fork: interp COW share OOM")
            return cast[int64](-12)           # -ENOMEM
        # vm_cow_share_range dropped RW on the PARENT's interp pages but
        # only invlpg'd per page. If any interp page was reached through a
        # lingering 2 MiB / 1 GiB huge-page TLB entry, a stale WRITABLE
        # entry could let the parent write a still-COW-shared interp page
        # WITHOUT faulting and race the child onto the same frame. Reload
        # the parent's CR3 to drop every non-global TLB entry — the same
        # bulletproofing _vm_cow_share_all_locked does for image/brk/stack.
        load_cr3(parent_pml4)

    # Copy 4: anonymous + file-backed mmap VMAs (glibc-malloc arenas,
    # ld.so DSO maps). vma_fork_copy COW-shares each VMA's pages between
    # parent and child — read-only + COW-marked in both PML4s, the first
    # write by either side faults into do_page_fault and copies just
    # that page — and lands a mirrored VmaNode on the child's list so
    # the child's own munmap / mremap stays honest. This makes the WHOLE
    # address space (image + brk + stack + mmap) copy-on-write on fork.
    if vma_fork_copy(cslot, parent_idx, child_pml4) < 0:
        local_irq_restore(_fork_irq)
        set_current_errstr("fork: vma copy OOM")
        return cast[int64](-12)               # -ENOMEM

    # Propagate the address-space bookkeeping so a GRANDCHILD fork
    # finds the same regions to copy.
    set_task_image_range(cslot, img_lo, img_hi)
    # Propagate the interp VA span so a GRANDCHILD fork re-shares the same
    # ld.so window. interp_phys stays 0 on the child (owner-only reclaim);
    # this is the VIRTUAL range only, which fork children DO inherit.
    set_task_interp_range(cslot, interp_lo, interp_hi)
    set_task_ustack_range(cslot, ust_lo, ust_sz)
    # FORK+EXEC COW-image discriminator (apt dpkg-split blocker, T26).
    # We have just COW-shared the parent's ELF image (vm_cow_share_all over
    # [img_lo,img_hi)) + interp into the child: every present image frame's
    # per-PFN refcount went 1->2 and the child's image_phys stays 0. Mark
    # the child so a LATER do_execve in this child tears the outgoing image
    # down through the COW-safe path (cow_drop, 2->1, parent keeps the
    # frame, child's stale PTEs cleared) instead of leaking the shared
    # mapping into the new image load and corrupting the parent's live
    # image. Gated on img_lo != 0 (an imageless/kernel-thread clone shares
    # nothing). The flag is CLEARED by do_execve once the fresh region-owned
    # image is loaded, and never propagates to a grandchild except through a
    # fresh do_clone (which re-evaluates this same condition).
    if img_lo != 0 and img_hi > img_lo:
        set_task_image_cow_shared(cslot, 1)
    # brk cursors: the child's heap is a private copy at the same
    # vaddrs, so the cursors carry over unchanged. base/end track the
    # used heap; max bounds the reserved window.
    set_task_brk_range(cslot, brk_lo, task_brk_end(parent_idx), brk_mx)
    # End of the create+COW critical section: the child's PML4 is fully
    # populated (COW image/brk/stack + mmap VMAs). It is now safe for the
    # scheduler to dispatch it; re-enable IRQs (restore caller's prior
    # IF). The signal/fd/seccomp inheritance below only refines an
    # already-runnable, address-space-complete child.
    #
    # NOTE: the child is STILL STATE_EMBRYO here (off every run-list). It is
    # NOT published READY yet — the fs_base/seccomp/fd-table/pgrp inheritance
    # below must complete first, or the AP could dispatch the child before its
    # fd table / namespace exist (a second, fd/ns-flavoured steal race). The
    # EMBRYO->READY flip happens at the very END of do_clone, after the last
    # inheritance store. The local IRQ mask is dropped here (the address-space
    # critical section is done); EMBRYO alone fences the steal window now.
    local_irq_restore(_fork_irq)
    printk1("fork: child pid=%d given a private address space\n",
            cast[int32](task_pid_at(slot)))

    # Inherit parent's fs_base so the child's first syscall sees the
    # same TLS the parent had — and because copy 2 gave the child a
    # private heap, that same fs_base value resolves into the child's
    # own TCB copy, not the parent's.
    set_task_fs_base(slot, parent[0].fs_base)
    # Make the child's first read of the wake flag explicit. It's also
    # zeroed by bss/_find_free_slot reuse, but defensive setting here
    # keeps the contract obvious.
    set_task_vfork_done(slot, 0)
    # Mirror the parent's Linux-ABI mode onto the child so the child's
    # first syscall (likely _exit / execve) routes through u_syscalls.
    if parent[0].is_linux_userspace != 0:
        set_linux_userspace_mode(slot, 1)
    # #160 / seccomp-lite: the fork child inherits the parent's seccomp
    # mode + allow-list bitmap. A seccomp'd parent cannot fork an
    # unconfined child — the filter is both irrevocable AND inherited,
    # matching Linux semantics exactly.
    seccomp_inherit_to_child(cslot, parent_idx)
    # #151: the fork child inherits the parent's nice/weight (POSIX).
    sched_inherit_nice_to_child(cslot, parent_idx)
    # §3: POSIX signal inheritance — the fork child inherits the
    # parent's signal handlers, sa_flags, and blocked-signal mask, but
    # NOT the pending-signal set (cleared in the child). This lets a
    # daemon fork workers that keep its SIGTERM / SIGCHLD dispositions.
    copy_sig_state_to_child(slot, parent_idx)
    # Copy parent's fd table into the child. The fresh slot already
    # has stdin/stdout/stderr pre-opened by _init_fd_table; overwrite
    # those plus walk the rest of the table so opened files / pipes /
    # FAT entries propagate. dup_fd_to_child bumps the shared chan
    # refcount on FD_CHAN_MARK entries (pipes included — Phase 4c) so
    # closing the parent's end doesn't punch the channel out from
    # under the child.
    i: uint64 = 0
    while i < NR_FDS:
        dup_fd_to_child(slot, i, parent, i)
        i = i + 1
    # cwd inheritance: _inherit_cwd_from_parent was already called
    # inside create_user_task_argv (it reads current_idx's cwd). Make
    # it explicit here too so future refactors of that helper don't
    # silently break fork(). set_task_cwd is idempotent.
    set_task_cwd(cast[uint64](slot), get_cwd_buf(current_idx_get()))
    # CLONE_NEWNS: "Plan 9 did containers first." When the clone carries
    # the Linux new-mount-namespace bit, the child gets a PRIVATE deep
    # copy of the parent's Pgrp (the native per-process mount table)
    # rather than the default share-the-root behaviour create_user_task_-
    # argv left it with (pgrp == 0 -> resolves to the root Pgrp). After
    # this, binds/mounts the child makes are invisible to the parent and
    # vice-versa — exactly the container-build primitive. We translate
    # the Linux flag (0x00020000) into the native pgrp_clone path here
    # rather than passing Linux flags into any RF* code (different bit
    # spaces). Mirrors the SPAWN_STDIO_NS private-Pgrp shape above:
    # resolve the parent's Pgrp through pgrp_current() so a 0 (BSS
    # default) collapses to the root pointer, then deep-copy. On
    # pgrp_clone OOM we fall back to sharing the parent's Pgrp (ref_inc)
    # so the child still runs, just without isolation — same defensive
    # contract _rfork_setup_namespace uses for fork-side OOM.
    # NAMESPACE inheritance. On Linux a plain fork(2) child SHARES the
    # parent's mount namespace; only CLONE_NEWNS (or unshare) gives it a
    # private one. Hamnix's per-process namespace is the Plan 9 Pgrp, so
    # the child MUST point at the parent's Pgrp — otherwise it falls back
    # to the ROOT Pgrp (create_user_task_argv leaves the slot's pgrp at
    # its BSS/reuse value, typically 0 -> root) and every path the child
    # resolves after fork is looked up in the root namespace, NOT the
    # `enter linux { … }` namespace the parent was running in. That broke
    # apt/dpkg/dash/bash inside the linux ns: dash forks then execs
    # `/bin/echo`, but the forked child resolved `/bin/echo` against root
    # (where the distro tree lives at /var/lib/distros/default/...) and
    # either ENOENT'd (bash: "/bin/echo: No such file or directory",
    # exit 127) or mis-resolved to a wrong blob and faulted (SIGSEGV). So
    # ALWAYS bind the child to a namespace derived from the parent:
    parent_pg: uint64 = task_pgrp(cast[int32](parent_idx))
    if parent_pg == 0:
        # Materialise the parent's effective Pgrp (a 0 slot value collapses
        # to the root pointer) and record it so a grandchild fork sees a
        # coherent value too.
        parent_pg = pgrp_current()
        set_task_pgrp(cast[int32](parent_idx), parent_pg)
    if (flags & CLONE_NEWNS) != 0:
        # CLONE_NEWNS: private deep COW copy (the container-build verb).
        ns_copy: uint64 = pgrp_clone(parent_pg)
        if ns_copy == 0:
            # pgrp_clone OOM: fall back to sharing (still runs, no isolation).
            set_task_pgrp(slot, parent_pg)
            pgrp_ref_inc(parent_pg)
        else:
            set_task_pgrp(slot, ns_copy)
    else:
        # Plain fork(2): SHARE the parent's Pgrp (bump its refcount so the
        # parent exiting first doesn't free the namespace out from under
        # the child). This is what makes a forked-then-exec'd binary inside
        # `enter linux { … }` resolve its paths in the linux namespace.
        set_task_pgrp(slot, parent_pg)
        pgrp_ref_inc(parent_pg)
    # fork(2) callee-saved inheritance. The child's fresh __switch_to
    # frame zeroes %rbx/%rbp/%r12/%r13/%r14/%r15; a forked child must
    # instead resume the caller with the PARENT's callee-saved set, or a
    # register-held pointer (e.g. a musl program keeping a stack-buffer
    # base in %r14 across a syscall) reads as 0 in the child and the next
    # syscall faults. syscall_64.S now spills ALL SIX user callee-saved
    # registers onto the KERNEL stack (the entry stub no longer touches the
    # user stack — it spills scratch to per-CPU slots — so no user-stack
    # deref / SMAP bracket is needed here). Frame from kstack_top:
    #   -8 RSP, -16 RFLAGS, -24 RIP, -32 %r13, -40 %r12,
    #   -48 %rbx, -56 %rbp, -64 %r14, -72 %r15.
    p_r13: uint64 = cast[Ptr[uint64]](kstack_top - 32)[0]
    p_r12: uint64 = cast[Ptr[uint64]](kstack_top - 40)[0]
    p_rbx: uint64 = cast[Ptr[uint64]](kstack_top - 48)[0]
    p_rbp: uint64 = cast[Ptr[uint64]](kstack_top - 56)[0]
    p_r14: uint64 = cast[Ptr[uint64]](kstack_top - 64)[0]
    p_r15: uint64 = cast[Ptr[uint64]](kstack_top - 72)[0]
    fork_seed_callee_saved(slot, p_rbx, p_rbp, p_r12, p_r13, p_r14, p_r15)

    # FORK<->STEAL RACE (#413 class) FIX — PUBLISH POINT. Everything the child
    # needs is now in place: its COW address space (image/brk/stack/interp +
    # mmap VMAs), fs_base TLS, seccomp filter, fd table, cwd, namespace (Pgrp),
    # signal dispositions, and its kstack iret frame's callee-saved register
    # seed. ONLY NOW flip the EMBRYO child -> STATE_READY and link it onto its
    # runqueue. Until this point the child was STATE_EMBRYO (on no run-list),
    # so neither _pick_next nor the cross-CPU work-steal walk could dispatch a
    # half-built child on the other CPU. The EMBRYO->READY flip runs under the
    # owning rq's lock inside task_publish_thread_ready (LOCK-prefixed
    # acquire/release = full barrier), so any CPU that subsequently picks the
    # child observes every store above — the consistent page table AND the
    # fd/ns/TLS/callee-saved state. This closes the apt-worker SIGSEGV
    # (NX exec-fault on a not-yet-shared libapt .text PTE / va=0 read-fault).
    task_publish_thread_ready(slot)

    child_pid: uint64 = task_pid_at(slot)
    # PLAIN fork(2): parent returns immediately; parent + child run
    # concurrently. Earlier U26..U37 code blocked EVERY fork here on
    # task_vfork_done to approximate POSIX vfork — that worked for the
    # simple system() / posix_spawn() (fork → immediate exec) pattern but
    # broke pipelines: a shell building `echo a | grep a` needs the read
    # end of the pipe to have a live reader BEFORE the writer fills it, and
    # blocking the parent until the first stage exec'd meant the second
    # stage never got forked, so the pipeline deadlocked. So for a plain
    # fork (NO CLONE_VFORK) we DON'T block — the child has a fully PRIVATE
    # COW address space, so both can run glibc fork-epilogue / atexit /
    # _IO_cleanup concurrently without trampling each other.
    #
    # TRUE vfork(2) (CLONE_VFORK): the Linux contract REQUIRES the parent
    # to be SUSPENDED until the child execve's or _exit's. dash's simple-
    # command exec (`dash -c "cat x"`) rides this: its vforkexec parent
    # path assumes, on resume, that the child has ALREADY exec'd (it shares
    # bookkeeping state across the vfork). With the parent running
    # concurrently it raced the child's exec and aborted with exit 255
    # (then orphaned the half-loaded child). Pipelines DON'T use vfork —
    # they use plain fork — so gating the block on CLONE_VFORK restores the
    # synchronous vfork semantics WITHOUT reintroducing the pipeline
    # deadlock. The child sets vfork_done=1 in do_execve (just before its
    # SYSRETQ into the new image) and in task_exit_current (the exec-less
    # _exit path), so this loop wakes on either transition. We yield rather
    # than spin so the child actually gets CPU to reach its execve/_exit.
    if (flags & CLONE_VFORK) != 0:
        do:
            if task_vfork_done(slot) != 0:
                return cast[int64](child_pid)
            yield_to_others()
        while 1
    return cast[int64](child_pid)


# §3: scan for any reapable child of `parent_pid`. Returns the slot
# index of an EXITED child, or -1 if none is currently a zombie.
def _wait_any_zombie_child(parent_pid: uint64) -> int32:
    i: uint64 = 0
    while i < NTASKS:
        t: Ptr[TaskStruct] = task_struct_at(cast[int32](i))
        if cast[uint64](t) != 0:
            if task_state(cast[int32](i)) == STATE_EXITED \
                    and t[0].parent_pid == parent_pid:
                return cast[int32](i)
        i = i + 1
    return -1


# §3: does `parent_pid` still have at least one live (non-free) child?
# Used to decide -ECHILD vs "keep blocking" in the wait_any (waitpid(-1))
# path.
#
# ROOT-CAUSE FIX (Firefox / every multi-process Linux app): the old
# predicate counted a child ONLY in STATE_READY(1) / STATE_RUNNING(2) /
# STATE_EXITED(3). It OMITTED every OTHER live state — most importantly
# STATE_WAIT(6), the state of a task BLOCKED in a syscall (poll/epoll/read/
# futex), which is where a running child spends nearly all of its time; and
# also STATE_STOPPED(4), STATE_PARKED(5), STATE_EMBRYO(7), STATE_REAPING(8).
# So the instant a parent called waitpid(-1) while all its children happened
# to be blocked (the NORMAL steady state of any event-driven multi-process
# program), _has_live_child returned 0 and wait4 handed back a SPURIOUS
# -ECHILD. For a shell/launcher (dash's vforkexec parent, Firefox's launcher
# process) that surfaced as the "child vanished" path -> the documented
# exit-255 orphaning of a still-live child; for a SIGCHLD reap loop
# (`while (waitpid(-1,&st,WNOHANG) > 0)`) it looked like "all my children
# died", tearing down the child-process manager and stalling the browser's
# GPU/content-process bring-up before any window maps.
#
# The correct POSIX predicate: the caller still has a child as long as SOME
# task slot with parent_pid == caller is NOT STATE_FREE. STATE_FREE(0) is the
# only non-child disposition — it covers a genuinely free slot, a fully
# reaped child, and the transient mid-clone embryo window (which flips to
# READY within microseconds; the wait loop yields and re-scans). Every other
# state (1,2,4,5,6,7,8) is a real, still-owned child: keep blocking (or, if it
# is a STATE_EXITED zombie, _wait_any_zombie_child reaps it this pass). A
# reaped/free slot never carries a stale parent_pid into a false positive
# because we require state != STATE_FREE.
def _has_live_child(parent_pid: uint64) -> int32:
    i: uint64 = 0
    while i < NTASKS:
        t: Ptr[TaskStruct] = task_struct_at(cast[int32](i))
        if cast[uint64](t) != 0:
            st: uint64 = task_state(cast[int32](i))
            if t[0].parent_pid == parent_pid and st != STATE_FREE:
                return 1
        i = i + 1
    return 0


# §3: encode a Linux wait-status word. WIFSIGNALED if the child was
# killed by a signal (low 7 bits = signal); else WIFEXITED (bits 15:8
# = exit code, low byte 0). glibc/musl W* macros decode this directly.
def _encode_wstatus(slot: int32) -> int32:
    su: uint64 = cast[uint64](slot)
    tsig: uint64 = get_task_term_sig(su)
    if tsig != 0:
        # WIFSIGNALED: (status & 0x7f) is the signal, non-zero and
        # != 0x7f. WTERMSIG(status) == status & 0x7f.
        return cast[int32](tsig & 0x7F)
    code: int64 = task_exit_code(slot)
    return cast[int32]((code & 0xFF) << 8)


# WNOHANG — wait4 option bit 0. Return immediately (0) if no child is
# reapable, instead of blocking.
WNOHANG: uint64 = 1


# #147 / ptrace(2): scan for a traced child of `parent_pid` (the tracer)
# that is currently parked at a ptrace stop the tracer has not yet
# observed. `want_pid` / `wait_any` mirror wait4's pid argument: when
# wait_any==0, only the child whose pid == want_pid qualifies. Returns
# the stopped task's slot, or -1 if none is reportable this pass.
#
# A task counts as "reportable" when pt_stop_state != 0 (it is at a
# stop), pt_tracer_pid == the caller's pid (we are its tracer), and
# pt_stop_reported == 0 (we haven't already handed this stop to the
# tracer's wait4). The tracee clears pt_stop_reported each time it
# enters a fresh stop, so each enter/exit gets reported exactly once.
def _wait_traced_stop_child(parent_pid: uint64, want_pid: uint64,
                            wait_any: int32) -> int32:
    i: uint64 = 0
    while i < NTASKS:
        t: Ptr[TaskStruct] = task_struct_at(cast[int32](i))
        if cast[uint64](t) != 0:
            if get_task_pt_stop_state(i) != 0 \
                    and get_task_pt_tracer_pid(i) == parent_pid \
                    and get_task_pt_stop_reported(i) == 0:
                if wait_any != 0 or task_pid_at(cast[int32](i)) == want_pid:
                    return cast[int32](i)
        i = i + 1
    return -1


# #147: encode the WIFSTOPPED wait-status for a ptrace stop. Linux's
# encoding for a stopped child is ((sig << 8) | 0x7f) — WIFSTOPPED is
# true when (status & 0xff) == 0x7f, and WSTOPSIG(status) == (status >>
# 8) & 0xff. Ptrace stops report SIGTRAP (5); a syscall-enter/exit stop
# additionally OR's 0x80 into the signal when PTRACE_O_TRACESYSGOOD is
# set (so strace can tell a real SIGTRAP from a syscall stop).
def _encode_ptrace_stopstatus(slot: int32) -> int32:
    su: uint64 = cast[uint64](slot)
    st: uint64 = get_task_pt_stop_state(su)
    sig: uint64 = 5                              # SIGTRAP
    is_syscall_stop: int32 = 0
    if st == 1 or st == 2:                       # enter / exit
        is_syscall_stop = 1
    if is_syscall_stop != 0 and (get_task_pt_options(su) & 1) != 0:
        sig = sig | 0x80                         # SIGTRAP|0x80 (TRACESYSGOOD)
    return cast[int32](((sig & 0xFF) << 8) | 0x7F)


def do_wait4(pid: uint64, wstatus_ptr: uint64,
             options: uint64, rusage: uint64) -> int64:
    # Linux-shape waitpid / wait4. Writes the result into *wstatus_ptr
    # using the Linux wait-status encoding (WIFEXITED / WIFSIGNALED).
    #
    # §3: two waiting modes —
    #   * pid == (pid_t)-1  (0xFFFFFFFFFFFFFFFF, or 0): reap ANY child
    #     of the caller. This is the form a SIGCHLD handler / daemon
    #     reap loop uses (`while (waitpid(-1, &st, WNOHANG) > 0)`).
    #   * pid > 0: reap that specific child.
    # WNOHANG is honoured: with no reapable child it returns 0 rather
    # than blocking. `rusage` is accepted for ABI compatibility but
    # not filled (Hamnix has no per-task rusage accounting yet).
    my_pid: uint64 = current_task_pid()
    wait_any: int32 = 0
    if pid == cast[uint64](-1) or pid == 0:
        wait_any = 1

    do:
        # #147 / ptrace(2): a traced child that has reached a ptrace stop
        # (syscall-enter/exit, or attach/signal stop) is reported to the
        # tracer as WIFSTOPPED *before* any exit/zombie reaping — the
        # tracee is still alive and parked in its stop loop, waiting for
        # the tracer to issue PTRACE_CONT / PTRACE_SYSCALL. We report the
        # stop exactly once (pt_stop_reported gates re-reports) and do NOT
        # reap the task. The tracer's GETREGS reads the captured snapshot.
        stopped: int32 = _wait_traced_stop_child(my_pid, pid, wait_any)
        if stopped >= 0:
            if wstatus_ptr != 0:
                # QA-N32: page-fault-safe store (was a raw CPL=0 store that
                # #PF-HALTS the box when *wstatus is in a not-present user
                # page). put_user_32 page-table-walks + returns EFAULT on a
                # bad address instead of faulting. Ignore the result (the
                # stop is still reported; a lost status word is a userspace
                # bug, not a kernel-wedge cause).
                put_user_32(cast[uint32](_encode_ptrace_stopstatus(stopped)),
                            wstatus_ptr)
            set_task_pt_stop_reported(cast[uint64](stopped), 1)
            return cast[int64](task_pid_at(stopped))

        target: int32 = -1
        if wait_any != 0:
            target = _wait_any_zombie_child(my_pid)
            if target < 0 and _has_live_child(my_pid) == 0:
                set_current_errstr("wait: no children")
                return cast[int64](-10)       # -ECHILD
        else:
            target = task_lookup_by_pid(pid)
            if target < 0:
                set_current_errstr("wait: no such child")
                return cast[int64](-10)       # -ECHILD
            if task_state(target) != STATE_EXITED:
                target = -1                   # not reapable yet
        if target >= 0:
            if wstatus_ptr != 0:
                # QA-N32: page-fault-safe store (was a raw CPL=0 store that
                # #PF-HALTS the box when *wstatus is in a not-present user
                # page — reachable under the fork+wait storm). put_user_32
                # walks the page table + returns EFAULT on a bad address.
                put_user_32(cast[uint32](_encode_wstatus(target)), wstatus_ptr)
            reaped_pid: uint64 = task_pid_at(target)
            task_reap(target)
            return cast[int64](reaped_pid)
        # No reapable child this pass.
        if (options & WNOHANG) != 0:
            return 0                          # POSIX: WNOHANG → 0
        yield_to_others()
    while 1
    # Unreachable — the loop only exits via an explicit return.
    return 0


def syscall_init_this_cpu():
    # Stage A (per-CPU TSS / USER-on-AP): the SYSCALL MSRs (STAR,
    # LSTAR, FMASK, EFER.SCE) are PER-CPU. syscall_init() below arms
    # them on the BSP with full diagnostic printks; an AP must arm the
    # same four MSRs during bring-up or `syscall` is #UD on that CPU.
    # This is the minimal CPU-independent core (no printks). Called from
    # both the BSP path (syscall_init) and ap_main_hamnix after %gs/TSS
    # setup.
    #
    # The values are identical on every CPU: STAR/LSTAR/FMASK are
    # global constants, and EFER.SCE just enables the SYSCALL opcode.
    star: uint64 = (cast[uint64](0x10) << 48) | (cast[uint64](0x08) << 32)
    write_msr(IA32_STAR, star)
    write_msr(IA32_LSTAR, cast[uint64](&syscall_entry))
    write_msr(IA32_FMASK, 0x0200)
    set_efer_sce()
    # W^X / GAP-3 defensive: guarantee IA32_EFER.NXE (bit 11) on EVERY
    # logical CPU before it can dispatch a user task. The AP realmode
    # trampoline (arch/x86/realmode/trampoline.S) is *supposed* to set NXE
    # alongside LME, but a reserved-bit #PF was observed under -smp 2 when
    # a task migrated to an AP running with NXE clear (cr2==rsp, PF
    # err=0x0d RSVD=1, PTE leaf with only NX(63) "unusual"). With NXE=0,
    # bit 63 of any loaded PTE is RESERVED and faults. set_efer_nxe() is a
    # read-modify-write OR of bit 11, so calling it here is idempotent on
    # the BSP (syscall_init re-arms it too) and closes the trampoline-
    # timing window on every AP. NXE must be live before the first user
    # dispatch on this CPU — this runs during bring-up, well before it.
    set_efer_nxe()


def syscall_init():
    # M16.35: no longer takes a stack arg — the entry stub reads the
    # current task's kernel stack from TSS.RSP0 each time it's called,
    # so there is no single boot-time slot to install. Linux's
    # syscall_init() reads from cpu_tss_rw.x86_tss.sp0 in exactly the
    # same way.
    #
    # Diagnostic printks (May 2026): one Asus laptop wedges silently
    # between "parent task PML4 = ..." and "syscall MSRs armed" on
    # legacy BIOS only — QEMU and UEFI both reach the second line
    # cleanly. Each side-effecting write in this body now sandwiches
    # itself between `pre-<step>` and `post-<step>` lines so the next
    # real-hw run pin-points the offending wrmsr. The pre line also
    # echoes the value about to be written for canonicality checks
    # (LSTAR must be canonical or wrmsr #GPs on real CPUs).

    printk0("Hamnix: syscall_init: entry\n")

    # IA32_STAR encoding:
    #   bits 31:0  reserved
    #   bits 47:32 = 0x08  (SYSCALL kernel CS; SS = +8 = 0x10)
    #   bits 63:48 = 0x10  (SYSRET base; user CS = +16, SS = +8)
    star: uint64 = (cast[uint64](0x10) << 48) | (cast[uint64](0x08) << 32)
    printk1("Hamnix: syscall_init: pre-wrmsr STAR  = %p\n", star)
    write_msr(IA32_STAR, star)
    printk0("Hamnix: syscall_init: post-wrmsr STAR\n")

    # SYSCALL entry point: %rip after SYSCALL = IA32_LSTAR.
    lstar_val: uint64 = cast[uint64](&syscall_entry)
    printk1("Hamnix: syscall_init: pre-wrmsr LSTAR = %p\n", lstar_val)
    write_msr(IA32_LSTAR, lstar_val)
    printk0("Hamnix: syscall_init: post-wrmsr LSTAR\n")

    # FMASK = 0x0200 clears IF on entry. SYSCALL hands off with
    # interrupts off until the stub explicitly re-enables them (we
    # don't; preemption while servicing a syscall is deferred work).
    printk0("Hamnix: syscall_init: pre-wrmsr FMASK\n")
    write_msr(IA32_FMASK, 0x0200)
    printk0("Hamnix: syscall_init: post-wrmsr FMASK\n")

    # EFER current value — useful if the rdmsr/wrmsr pair inside
    # set_efer_sce blows up: we want to know what we read so future
    # patches can either short-circuit (already-set) or apply a CPU
    # quirk before flipping SCE.
    efer_before: uint64 = read_msr(0xC0000080)
    printk1("Hamnix: syscall_init: EFER before SCE = %p\n", efer_before)

    # Finally flip IA32_EFER.SCE so SYSCALL stops being #UD.
    printk0("Hamnix: syscall_init: pre-set_efer_sce\n")
    set_efer_sce()
    printk0("Hamnix: syscall_init: post-set_efer_sce\n")

    efer_after: uint64 = read_msr(0xC0000080)
    printk1("Hamnix: syscall_init: EFER after  SCE = %p\n", efer_after)

    # W^X Stage 1a: enable IA32_EFER.NXE (bit 11) on the BSP so PTEs
    # carrying bit 63 (NX) can be loaded without a reserved-bit #PF.
    # APs flip NXE in the realmode trampoline (arch/x86/realmode/
    # trampoline.S) alongside EFER.LME. Print before/after exactly like
    # the SCE flip above so the boot log proves NXE is set. This MUST
    # happen before any user task installs an NX data page (it does —
    # syscall_init runs at boot:39, long before start_first_task).
    efer_nxe_before: uint64 = read_msr(0xC0000080)
    printk1("Hamnix: syscall_init: EFER before NXE = %p\n", efer_nxe_before)
    set_efer_nxe()
    efer_nxe_after: uint64 = read_msr(0xC0000080)
    printk1("Hamnix: syscall_init: EFER after  NXE = %p\n", efer_nxe_after)

    printk0("Hamnix: syscall MSRs armed (SYSCALL/SYSRET enabled)\n")


def _srv_name_valid(name: Ptr[char]) -> int32:
    # V4: validate `/srv/<leaf>` candidates from userspace. Rules
    # match docs/native-api.md's `/srv/<name>` reserved-path entry:
    #   * non-NUL first byte (no empty name)
    #   * <= 32 bytes including NUL
    #   * ASCII printable only (32 < c < 127); excludes control chars
    #   * no '/' (would collide with path traversal in fs/vfs.ad's
    #     _open_srv_name nested-path bail)
    #   * not "." or "..", and no leading '.' (those would land at the
    #     same path as the directory itself / parent in the future
    #     namespace-aware open path)
    # Returns 1 on accept, 0 on reject.
    if cast[uint64](name) == 0:
        return 0
    c0: int32 = name[0]
    if c0 == 0:
        return 0
    if c0 == 46:                                    # '.'
        return 0
    i: uint64 = 0
    while i < 33:
        c: int32 = name[i]
        if c == 0:
            if i == 0:
                return 0
            return 1
        if c <= 32 or c >= 127:
            return 0
        if c == 47:                                 # '/'
            return 0
        i = i + 1
    # 33 bytes scanned without NUL — name is too long (>32 incl NUL).
    return 0


# --- arch audit §3.2: single-named hostowner gate for kernel-internal ops -
#
# Seven syscall arms gate on `current_task_uid() == 1` for operations
# that DO NOT correspond to a server-owned resource — there is no
# `_perm_check_<X>` boundary to push the policy down to:
#
#   * SYS_SETUID         — flips the calling task's identity in
#                          TaskStruct; pure kernel state mutation.
#   * SYS_USERADD_ROOT   — provisions a new top-level subtree on the
#                          ext4 root and edits .hamnix-roots; not a
#                          server file op (it CREATES the server-shaped
#                          binding by name_push).
#   * SYS_SVC_PUBLISH    — pushes a 400-byte binary registry slot into
#                          PID 1's supervisor mirror; the supervisor IS
#                          the kernel-of-resource for its own table.
#                          The /proc/svc text ctl surface (start/stop/
#                          restart/...) covers human verbs; this is the
#                          binary publish path that has no text shape.
#   * SYS_SET_REALTIME   — re-anchors rtc_boot_epoch; clock skew is a
#                          system-wide property, not a file.
#   * SYS_REBOOT         — power_action; kernel terminates the box.
#   * SYS_SVC_CTL v0     — supervisor-side queue dequeue (poll); the
#                          PID-1 supervisor IS the kernel-of-resource
#                          for its mailbox, no ctl-file consumer peer.
#   * SYS_SVC_CTL v7     — supervisor-side read-out of the last-
#                          dequeued name; same shape as v0.
#
# These all stay hostowner-only, but the policy is routed through ONE
# named helper so a future Plan-9 reshape (e.g. /dev/reboot, /dev/auth-
# mediated SETUID) can move the gate in ONE place. The helper also
# stamps a uniform "hostowner-required" reason into errstr so userland
# (SYS_ERRSTR) and the perm-boundary test can grep for a single shape.
#
# The other thin-shim arms that USED to carry raw uid==1 checks
# (SYS_WSYS_ALLOC, SYS_WSYS_FREE, SYS_VK_WINDOW_FRAME, SYS_SVC_CTL
# producer verbs 1..6) had their gates pushed down into the relevant
# devwsys / procfs ctl-file write bodies by F2 #447 — the inline
# checks here are gone, the bodies are thin formatters that delegate.

def _syscall_require_hostowner(op_name: Ptr[char]) -> int32:
    # Returns 0 if the calling task is hostowner (uid 1) and the syscall
    # arm may proceed; returns -1 with errstr pre-set to a uniform
    # "<op>: hostowner-required (uid=N)" line otherwise. The string
    # is built in a stack-local buffer and handed to set_current_errstr
    # so SYS_ERRSTR returns it without retaining a reference to op_name.
    if current_task_is_hostowner() != 0:
        return 0
    # Compose the rejection string. Format:
    #   "<op>: hostowner-required (uid=NNNN)"
    # 64 bytes is plenty: longest op is "vk_window_frame" (15) +
    # ": hostowner-required (uid=" (27) + up to 10 digits + ")" + NUL.
    msg: Array[64, uint8]
    i: uint64 = 0
    while i < 24 and op_name[i] != 0:
        msg[i] = cast[uint8](op_name[i])
        i = i + 1
    tail_a: Array[28, uint8]
    tail_a[0]  = 58                                # ':'
    tail_a[1]  = 32                                # ' '
    tail_a[2]  = 104                               # 'h'
    tail_a[3]  = 111                               # 'o'
    tail_a[4]  = 115                               # 's'
    tail_a[5]  = 116                               # 't'
    tail_a[6]  = 111                               # 'o'
    tail_a[7]  = 119                               # 'w'
    tail_a[8]  = 110                               # 'n'
    tail_a[9]  = 101                               # 'e'
    tail_a[10] = 114                               # 'r'
    tail_a[11] = 45                                # '-'
    tail_a[12] = 114                               # 'r'
    tail_a[13] = 101                               # 'e'
    tail_a[14] = 113                               # 'q'
    tail_a[15] = 117                               # 'u'
    tail_a[16] = 105                               # 'i'
    tail_a[17] = 114                               # 'r'
    tail_a[18] = 101                               # 'e'
    tail_a[19] = 100                               # 'd'
    tail_a[20] = 32                                # ' '
    tail_a[21] = 40                                # '('
    tail_a[22] = 117                               # 'u'
    tail_a[23] = 105                               # 'i'
    tail_a[24] = 100                               # 'd'
    tail_a[25] = 61                                # '='
    tail_a[26] = 0
    j: uint64 = 0
    while tail_a[j] != 0 and i < 60:
        msg[i] = tail_a[j]
        i = i + 1
        j = j + 1
    # Decimal uid (uint32 fits in 10 digits).
    uid_v: uint32 = current_task_uid()
    uid_u: uint64 = cast[uint64](uid_v)
    if uid_u == 0:
        msg[i] = 48                                # '0'
        i = i + 1
    else:
        digits: Array[12, uint8]
        n: uint64 = 0
        while uid_u != 0 and n < 12:
            digits[n] = cast[uint8](uid_u % 10) + 48
            uid_u = uid_u / 10
            n = n + 1
        while n > 0 and i < 62:
            n = n - 1
            msg[i] = digits[n]
            i = i + 1
    if i < 63:
        msg[i] = 41                                # ')'
        i = i + 1
    msg[i] = 0
    set_current_errstr(&msg[0])
    return -1


# --- #438: out-of-lined do_syscall arms ---------------------------------
#
# The Adder compiler gives EVERY local — including each branch arm's
# locals — its own permanent slot in the enclosing function's frame
# (no liveness-based slot reuse; Python-style function scoping makes
# naive scope-reuse unsound). do_syscall's dispatcher accumulated the
# union of every arm's buffers into a single 28 KiB (0x6e10) frame,
# which sat under EVERY syscall — including the Linux-ABI read/write
# paths whose own bounce buffers (u_read_body 8.4 KiB, u_vfs_*_user
# 4.1 KiB each) stacked on top, overflowing the 32 KiB kstack by
# several KiB on every Linux read(2)/write(2). The overflow silently
# scribbled kernel return addresses over whatever physical pages the
# buddy allocator had handed out just below the kstack block — in the
# #438 failure that was the task's own ELF-image page table, turning
# leaf PTEs into kernel text pointers (reserved-bit #PF err=0x1d on
# the next instruction fetch, err=0x9 on the kernel's coredump read).
#
# Fix: the arms that declare KiB-scale buffers live in their own
# functions, so their frames exist only for the duration of that one
# arm instead of padding every syscall's stack. Keep it that way —
# do NOT declare large Array locals directly inside do_syscall.

# F2 #447 / audit §4 thin-shim helpers: the SYS_WSYS_ALLOC / SYS_WSYS_FREE
# / SYS_VK_WINDOW_FRAME / SYS_SVC_CTL arms format a small ctl-file text
# line on the stack and delegate to the shared ctl-file write parser
# instead of carrying duplicate parsing/policy code. The helpers below
# render a NUL-free "<verb> <args>\n" line into a caller-supplied buffer
# and return its length. They keep the syscall arms tiny so the syscall
# and ctl-file paths run one parser.
def _fmt_ctl_u64_dec(dst: Ptr[uint8], cap: uint64, off: uint64,
                     v: uint64) -> uint64:
    # Render `v` as decimal (no leading zeros) into dst starting at off.
    # Returns the new offset. Bounded — callers size dst so 20 digits +
    # surrounding text always fit. v == 0 renders as a single '0'.
    if v == 0:
        if off < cap:
            dst[off] = 48                               # '0'
            off = off + 1
        return off
    digs: Array[20, uint8]
    d: uint64 = 0
    while v > 0 and d < 20:
        digs[d] = cast[uint8](v % 10) + 48
        v = v / 10
        d = d + 1
    while d > 0 and off < cap:
        d = d - 1
        dst[off] = digs[d]
        off = off + 1
    return off


def _fmt_ctl_lit(dst: Ptr[uint8], cap: uint64, off: uint64,
                 lit: Ptr[uint8]) -> uint64:
    # Copy NUL-terminated literal `lit` into dst at off; return new off.
    i: uint64 = 0
    while lit[i] != 0 and off < cap:
        dst[off] = lit[i]
        off = off + 1
        i = i + 1
    return off


def _fmt_ctl_u64_arg(dst: Ptr[uint8], cap: uint64,
                     verb: Ptr[uint8], v: uint64) -> uint64:
    # "<verb><v>\n" — verb already carries its trailing space (e.g.
    # "alloc " / "free "). Returns the rendered length.
    off: uint64 = 0
    off = _fmt_ctl_lit(dst, cap, off, verb)
    off = _fmt_ctl_u64_dec(dst, cap, off, v)
    if off < cap:
        dst[off] = 10                                   # '\n'
        off = off + 1
    return off


def _fmt_ctl_u64_pair(dst: Ptr[uint8], cap: uint64,
                      verb: Ptr[uint8], a: uint64, b: uint64) -> uint64:
    # "<verb><a> <b>\n" — for the "frame <wid> <frame>" verb.
    off: uint64 = 0
    off = _fmt_ctl_lit(dst, cap, off, verb)
    off = _fmt_ctl_u64_dec(dst, cap, off, a)
    if off < cap:
        dst[off] = 32                                   # ' '
        off = off + 1
    off = _fmt_ctl_u64_dec(dst, cap, off, b)
    if off < cap:
        dst[off] = 10                                   # '\n'
        off = off + 1
    return off


def _fmt_svc_ctl_line(dst: Ptr[uint8], cap: uint64, verb: int32,
                      name: Ptr[uint8]) -> uint64:
    # Build "<word> <name>\n" for SYS_SVC_CTL producer verbs (1..6),
    # mirroring the /proc/svc/ctl verb table in fs/procfs.ad. Returns
    # the rendered length, or 0 on an unknown verb (callers should
    # have already range-checked, but we double-guard).
    word: Ptr[uint8] = cast[Ptr[uint8]](0)
    if verb == 1:
        word = "start "
    if verb == 2:
        word = "stop "
    if verb == 3:
        word = "restart "
    if verb == 4:
        word = "enable "
    if verb == 5:
        word = "disable "
    if verb == 6:
        word = "runlevel "
    if word == cast[Ptr[uint8]](0):
        return 0
    off: uint64 = 0
    off = _fmt_ctl_lit(dst, cap, off, word)
    # Copy NUL-terminated name (the dispatcher already copyin_path'd it
    # into a 64-byte kernel buffer, so it's NUL-terminated).
    i: uint64 = 0
    while name[i] != 0 and off < cap:
        dst[off] = name[i]
        off = off + 1
        i = i + 1
    if off < cap:
        dst[off] = 10                                   # '\n'
        off = off + 1
    return off


def _sysarm_read(a0: uint64, a1: uint64, a2: uint64) -> uint64:
    # SYS_READ: read(2) via a kernel BOUNCE buffer + copy_to_user, NOT a
    # raw write into the user vaddr. vfs_read fills the kernel bounce;
    # copy_to_user then WALKS the current task's page tables to land
    # the bytes at the (possibly non-identity) physical frame backing
    # a1. read(2) returns as soon as ANY data is available, so a
    # single bounce-sized vfs_read is the correct shape: we never
    # spin to fill the whole user buffer. For counts larger than the
    # bounce we cap at the bounce size — a short read is legal.
    if access_ok(a1, a2) == 0:
        set_current_errstr("read: bad address")
        return cast[uint64](-14)             # -EFAULT
    rd_n: uint64 = a2
    if rd_n > UA_BOUNCE_SZ:
        rd_n = UA_BOUNCE_SZ
    rd_bounce: Array[4096, uint8]
    n: int64 = vfs_read(cast[int32](a0),
                        cast[Ptr[uint8]](&rd_bounce[0]), rd_n)
    if n < 0:
        set_current_errstr("read: bad fd")
        return cast[uint64](n)
    if n > 0:
        resid: uint64 = copy_to_user(a1, cast[uint64](&rd_bounce[0]),
                                     cast[uint64](n))
        if resid != 0:
            # The user buffer faulted partway. Report only the bytes
            # that actually landed (read(2) cannot un-consume the fd
            # data, so the residual is lost — same hazard Linux has).
            set_current_errstr("read: bad address")
            copied: uint64 = cast[uint64](n) - resid
            if copied == 0:
                return cast[uint64](-14)     # -EFAULT
            return copied
    return cast[uint64](n)


def _sysarm_read_nb(a0: uint64, a1: uint64, a2: uint64) -> uint64:
    # SYS_READ_NB: non-blocking read. Used by single-threaded event-loop
    # daemons (user/sshd.ad) that must poll a socket fd and a pipe fd in
    # one task. Returns >0 bytes ready now, 0 if the fd is open but has
    # no data this instant ("would block"), or -1 on a true EOF /
    # error. Unlike SYS_READ this never yields-and-spins; the caller
    # owns the poll cadence.
    if access_ok(a1, a2) == 0:
        set_current_errstr("read_nb: bad address")
        return cast[uint64](-14)             # -EFAULT
    # uaccess (#163): same bounce-buffer shape as SYS_READ — fill a
    # kernel buffer, then copy_to_user (page-table-walked) instead
    # of letting vfs_read_nb scribble through the raw user vaddr.
    # A short read is legal for the non-blocking contract, so
    # capping a single call at the bounce size is correct.
    rnb_n: uint64 = a2
    if rnb_n > UA_BOUNCE_SZ:
        rnb_n = UA_BOUNCE_SZ
    rnb_bounce: Array[4096, uint8]
    n: int64 = vfs_read_nb(cast[int32](a0),
                           cast[Ptr[uint8]](&rnb_bounce[0]), rnb_n)
    if n > 0:
        rnb_resid: uint64 = copy_to_user(a1,
                                         cast[uint64](&rnb_bounce[0]),
                                         cast[uint64](n))
        if rnb_resid != 0:
            set_current_errstr("read_nb: bad address")
            rnb_copied: uint64 = cast[uint64](n) - rnb_resid
            if rnb_copied == 0:
                return cast[uint64](-14)     # -EFAULT
            return rnb_copied
    return cast[uint64](n)


def _sysarm_write(a0: uint64, a1: uint64, a2: uint64) -> uint64:
    # SYS_WRITE: write(2) via copy_from_user + a kernel BOUNCE buffer,
    # NOT a raw read of the user vaddr. copy_from_user WALKS the current
    # task's page tables to fetch each chunk from the (possibly
    # non-identity) physical frame backing a1; vfs_write then consumes
    # the kernel copy. We chunk at the bounce size and loop so a >4 KiB
    # write still transfers in full, accumulating the bytes written. A
    # short vfs_write (e.g. a pipe filling up) stops the loop and we
    # return the partial count — standard write(2) semantics.
    if access_ok(a1, a2) == 0:
        set_current_errstr("write: bad address")
        return cast[uint64](-14)             # -EFAULT
    wr_total: uint64 = 0
    wr_left: uint64 = a2
    wr_u: uint64 = a1
    # Stack fast-path bounce: 4 KiB covers the overwhelming common case
    # (ctl-file lines, log writes, pipe-shaped streams). Larger writes
    # — notably rio v2 blit 'B' verbs that must ship one whole verb per
    # write(2) — spill into a heap-allocated UA_WR_BOUNCE_SZ buffer so
    # the parser never sees a fragmented verb.
    wr_bounce: Array[4096, uint8]
    wr_big_addr: uint64 = 0
    wr_buf: Ptr[uint8] = cast[Ptr[uint8]](&wr_bounce[0])
    wr_cap: uint64 = UA_BOUNCE_SZ
    if a2 > UA_BOUNCE_SZ:
        # Size the heap bounce to fit (capped at UA_WR_BOUNCE_SZ ==
        # kmalloc MAX_ORDER ceiling). This keeps small-ish writes cheap
        # (one ~64 KiB alloc rather than always 4 MiB) while letting a
        # full-screen v2 commit ride in a single chunk.
        wr_big_sz: uint64 = a2
        if wr_big_sz > UA_WR_BOUNCE_SZ:
            wr_big_sz = UA_WR_BOUNCE_SZ
        wr_big_addr = kmalloc(wr_big_sz)
        if wr_big_addr != 0:
            wr_buf = cast[Ptr[uint8]](wr_big_addr)
            wr_cap = wr_big_sz
        # kmalloc-failure falls back to the 4 KiB stack bounce; the
        # write still completes, just with the legacy chunking.
    while wr_left > 0:
        wr_chunk: uint64 = wr_left
        if wr_chunk > wr_cap:
            wr_chunk = wr_cap
        if copy_from_user(cast[uint64](wr_buf), wr_u, wr_chunk) != 0:
            set_current_errstr("write: bad address")
            if wr_big_addr != 0:
                kfree(wr_big_addr)
            if wr_total == 0:
                return cast[uint64](-14)     # -EFAULT
            return wr_total
        wn: int64 = vfs_write(cast[int32](a0), wr_buf, wr_chunk)
        if wn < 0:
            set_current_errstr("write: bad fd")
            if wr_big_addr != 0:
                kfree(wr_big_addr)
            if wr_total == 0:
                return cast[uint64](wn)
            return wr_total
        wr_total = wr_total + cast[uint64](wn)
        # A short write means the sink could not take more right now;
        # stop and report what we've sent so far.
        if cast[uint64](wn) < wr_chunk:
            if wr_big_addr != 0:
                kfree(wr_big_addr)
            return wr_total
        wr_left = wr_left - wr_chunk
        wr_u = wr_u + wr_chunk
    if wr_big_addr != 0:
        kfree(wr_big_addr)
    return wr_total


# #450 F6 / Phase G: _sysarm_listdir is RETIRED. The native SYS_LISTDIR
# arm is gone; lib/p9.ad's p9_listdir() is the userland replacement, doing
# open(path, OREAD) + read(fd, buf, count) + close(fd). The dir-fd's
# DEV_DIR_FILE backing (sys/src/9/port/namec.ad::_dirfile_read) emits the
# SAME "NAME\n" packed listing this function used to assemble (it gets
# its bytes from vfs_listdir_ns too, just via the open/read path rather
# than as a one-shot syscall). The mount-table-children synthesis that
# made `bind '#c' /dev` show up as `dev` in `ls /` still works there —
# vfs_listdir_ns is now called from inside the open-dir handler, not
# from _sysarm_listdir.


def do_syscall(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> uint64:
    # Tail of the syscall entry path. nr is the user's %rax; a0..a5
    # are the user's %rdi/%rsi/%rdx/%r10/%r8/%r9 (the syscall ABI; the
    # entry stub already shuffles them into SysV positions — a0..a4
    # arrive in regs and a5 spills onto the stack per SysV).
    #
    # M16.39: a pending signal terminates the task before the syscall
    # runs. Catches Ctrl-C arrivals between user-mode bursts and any
    # other async post (SYS_KILL on self, etc.). Mid-syscall yields
    # check their own pending state in yield_to_others.
    signal_check_and_handle()
    # §3 deferred note-delivery drain. When notes_enabled is armed (off
    # by default; see sys/src/9/port/sysnote.ad), a cross-task note
    # parked on this task's note_pending by post_note_to_group /
    # post_note_to_pid (the /proc/<pid>/note + note-group walker paths)
    # is consumed HERE — retarget the saved-user-RIP at the installed
    # handler so SYSRETQ lands in it, or terminate the task if no handler
    # is installed. Runs before the syscall body for the same reason
    # signal_check_and_handle does: an in-flight notify-then-syscall race
    # must execute the handler first.
    note_check_and_handle()
    # U1: per-task syscall ABI fork. Tasks created by the Linux ELF
    # loader have task_struct.is_linux_userspace==1 and route to
    # linux_u_syscall_dispatch, which interprets `nr` using Linux
    # x86_64 numbering (read=0, write=1, ...). Hamnix-native binaries
    # — everything currently in initramfs except the host-built
    # /bin/u_* fixtures — leave the field at 0 and fall through to
    # the existing 0..22 + 175/176 ladder unchanged.
    #
    # U7: the entry stub was widened to forward all 6 args (a0..a5)
    # so Linux's 6-arg syscalls (mmap, mremap, etc.) see %r8 / %r9.
    # Native syscalls only use a0..a3 so a4/a5 are simply ignored on
    # that branch.
    task: Ptr[TaskStruct] = current_task()
    # F10-8 / #457: NATIVE seccomp-lite entry gate. Consults the per-task
    # native allow-list bitmap (kernel/sched/core.ad). Returns 1 if `nr`
    # is BLOCKED (filter armed and bit not set); we bounce with -EPERM
    # in %rax — no SIGSYS, native ABI does not promise the Linux
    # SIGSYS-on-deny shape. Bypassed entirely for is_linux_userspace
    # tasks: the Layer-2 seccomp probe (seccomp_check_entry) inside
    # linux_u_syscall_dispatch covers the Linux syscall surface and
    # delivers the Linux-shape SIGSYS — running BOTH gates would
    # double-fault a confined Linux task. nr numbering also diverges
    # (native SYS_PUTC=0 vs Linux read=0), so this filter only makes
    # sense for native nrs.
    if task[0].is_linux_userspace == 0:
        if seccomp_native_check_entry(current_idx_get(), nr) != 0:
            return cast[uint64](-1)              # -EPERM
    if task[0].is_linux_userspace != 0:
        # Linux-ABI no-syscall watchdog: this task just issued a syscall, so
        # reset its no-syscall clock. A userspace first-frame render spin
        # (cairo/pixman) issues NO syscalls, so this stamp then goes stale and
        # the timer-tick watchdog dumps the spinning RIP.
        task_note_syscall_now(current_idx_get(), nr, a0)
        # F4 #449: dispatch through the registered Layer-2 hook. A pure-
        # native build leaves the hook null; an is_linux_userspace task
        # then gets -ENOSYS, the right answer when the Linux ABI is not
        # bound into this kernel image.
        rc: int64 = cast[int64](-38)                    # -ENOSYS
        if linux_u_syscall_dispatch_hook \
                != cast[Fn[int64, uint64, uint64, uint64,
                            uint64, uint64, uint64, uint64]](0):
            rc = linux_u_syscall_dispatch_hook(nr, a0, a1, a2, a3, a4, a5)
        # Firefox-deadlock diagnostic (lever 1): stamp the RETURN VALUE + push
        # (nr,rc) into this task's syscall-history ring BEFORE signal delivery,
        # so the parked-wd group dump can show each thread's last outcomes. A
        # blocking syscall that yields internally re-enters do_syscall on wake
        # and re-stamps, so the recorded rc is always the FINAL return.
        task_note_syscall_ret(current_idx_get(), nr, rc)
        # §3: exit-side signal delivery. This is the ONLY place that
        # may build a user-handler rt_sigframe, because it knows the
        # syscall's return value (rc) and stashes it into the frame's
        # %rax slot so rt_sigreturn restores the interrupted code's
        # %rax correctly. Catches signals posted by the syscall itself
        # (kill(getpid()), write→SIGPIPE) so the handler runs at THIS
        # sysretq. signal_deliver_on_return returns rc unchanged.
        return cast[uint64](signal_deliver_on_return(cast[uint64](rc)))
    if nr == SYS_PUTC:
        # Legacy single-byte putc. SYS_PUTC is userland-initiated
        # (a userland program emitting a byte to the console), so it
        # routes through the userland write path — no kernel
        # "[NNNNNN] " line-prefix stamping.
        early_putc_user(cast[int32](a0 & 0xFF))
        return 0
    if nr == SYS_EXIT:
        # Mark current task EXITED with the user-supplied exit code,
        # then yield. task_exit_current halts the box if there are
        # no other live tasks. M16.35: a0 carries the exit code so
        # SYS_WAITPID can return something meaningful to the parent.
        task_exit_current(cast[int64](a0))
        # Not reached unless schedule() somehow returns. Be defensive.
        local_irq_disable()
        while True:
            asm_volatile("hlt")
    if nr == SYS_GET_JIFFIES:
        return get_jiffies()
    if nr == SYS_CLONE:
        # a0 = entry point address of new user task. We don't have a
        # real binary loader yet, so callers pass the address of a
        # pre-existing user-mode function baked into the kernel image.
        # The child is a brand-new task; when schedule() picks it up
        # the iretq lands in `entry` directly (not in this syscall
        # return path) — so the child never sees this return value.
        # The parent gets back the child's slot index + 1 as a stand-
        # in pid.
        slot: int32 = create_user_task(a0, 0x5f5f636c6f6e655f)
        if slot < 0:
            set_current_errstr("clone: out of tasks")
            return cast[uint64](-1)
        return cast[uint64](slot) + 1
    if nr == SYS_GETPID:
        return current_task_pid()
    if nr == SYS_OPEN:
        # TODO net-item closure (per-backend errstr): clear errstr at
        # entry so the post-vfs_open fallback can distinguish "backend
        # set a specific string" from "stale errstr from a prior
        # failed syscall". Plan 9 contract: errstr is a per-process
        # slot that the LAST failing call wrote — clearing here keeps
        # SUCCESS-then-FAILURE round-trips clean.
        set_current_errstr(cast[Ptr[uint8]](0))
        if access_ok_str(a0) == 0:
            set_current_errstr("open: bad address")
            return cast[uint64](-14)             # -EFAULT
        u_path: Array[256, uint8]
        if copyin_path(a0, &u_path[0], 256) < 0:
            set_current_errstr("open: bad address")
            return cast[uint64](-14)             # -EFAULT
        # F10-1 (#454): SYS_OPEN passes the user path DIRECTLY to
        # vfs_open; the resolve_path call lives at the top of vfs_open
        # itself (before chan_permission_check + _vfs_open_post_perm)
        # so the F1 substrate gate fires there for EVERY caller (this
        # arm, vfs_open_kernel, every in-kernel direct caller), not
        # just this one. Pre-F10-1 the syscall arm resolve_path'd into
        # abs_path and vfs_open ALSO re-resolved — but the second
        # resolve is NOT idempotent for paths whose binding rewrites
        # them to a NEW name (e.g. /onlyetc/inittab -> /etc/inittab
        # through a bind, where the second resolve fails because /etc
        # is unbound in the same Pgrp). Resolve ONCE, in vfs_open, on
        # the user's exact bytes.
        # #450 F6 (Phase G, SYS_LISTDIR retirement): stash the
        # CONVENTIONAL pre-ns_walk path so _open_dir_with can key
        # chan_dir_mount_children off it on the way down (`bind '#c'
        # /dev` => `dev` in `ls /` case). u_path is the user's exact
        # string; mtab children synthesis ignores `#`-prefixed targets.
        vfs_open_set_orig_path(&u_path[0])
        rc: int32 = vfs_open(cast[Ptr[char]](&u_path[0]))
        # Reset the stash so a subsequent open that ISN'T a directory
        # (or doesn't go through SYS_OPEN, e.g. _u_open) doesn't see
        # stale orig bytes.
        vfs_open_set_orig_path(cast[Ptr[uint8]](0))
        # Phase B / M16.93: integrate Plan 9 errstr so SYS_ERRSTR (265)
        # has something to report. vfs_open returns -ENOENT (-2) on
        # lookup miss; -EACCES on permission denied; we install fixed
        # human-readable strings so user code surfaces the cause.
        # TODO net-item closure (per-backend errstr): only install the
        # generic fallback if the backend (ext4/tmpfs/devnet/...) didn't
        # already set a more specific "<backend>: <reason>" string.
        if rc < 0:
            cur: Ptr[uint8] = get_current_errstr()
            if cur[0] == 0:
                if rc == -2:
                    set_current_errstr("file does not exist")
                else:
                    set_current_errstr("open: failed")
        return cast[uint64](rc)
    if nr == SYS_OPEN_WRITE:
        # TODO net-item closure (per-backend errstr): clear at entry so
        # the post-vfs fallback only fires when no backend installed a
        # specific "<backend>: <reason>" string.
        set_current_errstr(cast[Ptr[uint8]](0))
        if access_ok_str(a0) == 0:
            set_current_errstr("open_write: bad address")
            return cast[uint64](-14)             # -EFAULT
        u_path: Array[256, uint8]
        if copyin_path(a0, &u_path[0], 256) < 0:
            set_current_errstr("open_write: bad address")
            return cast[uint64](-14)             # -EFAULT
        # F10-1: same single-resolve discipline as SYS_OPEN above.
        rc: int32 = vfs_open_write(cast[Ptr[char]](&u_path[0]))
        if rc < 0:
            cur: Ptr[uint8] = get_current_errstr()
            if cur[0] == 0:
                set_current_errstr("open for write: failed")
        return cast[uint64](rc)
    if nr == SYS_READ:
        # Track 4: a read on a UMDF irq fd blocks until the vector fires,
        # then returns the accumulated fire count as a little-endian
        # uint64 written into the caller's buffer (the "everything is a
        # file" IRQ primitive). Dispatch here before the generic VFS read
        # since an irq fd is not a VFS fd.
        if umdf_irq_is_fd_hook != cast[Fn[int32, int32]](0):
            if umdf_irq_is_fd_hook(cast[int32](a0)) != 0:
                if a2 < 8:
                    set_current_errstr("umdf irq read: buf < 8 bytes")
                    return cast[uint64](cast[int64](-22))  # -EINVAL
                if access_ok(a1, 8) == 0:
                    set_current_errstr("umdf irq read: bad address")
                    return cast[uint64](cast[int64](-14))  # -EFAULT
                cnt: uint64 = umdf_irq_read_hook(cast[int32](a0))
                if cast[int64](cnt) < 0:
                    return cnt                              # -errno
                # SMAP: `a1` is a user buffer (US=1) — write the IRQ count
                # through the page tables instead of a raw CPL=0 deref.
                if put_user_64(cnt, a1) != 0:
                    return cast[uint64](cast[int64](-14))  # -EFAULT
                return 8
        # #438: out-of-lined — the 4 KiB bounce lives in _sysarm_read's
        # frame, not in every syscall's.
        return _sysarm_read(a0, a1, a2)
    if nr == SYS_READ_NB:
        return _sysarm_read_nb(a0, a1, a2)
    if nr == SYS_WAITFDS:
        # Native multi-fd readiness wait: park on the shared waitfds
        # queue until any of the user's fds would read without blocking.
        # a0=Ptr[int32] fds, a1=nfds, a2=timeout_ms (int64 via cast).
        if a1 == 0:
            return cast[uint64](-22)             # -EINVAL
        if access_ok(a0, a1 * 4) == 0:
            set_current_errstr("waitfds: bad address")
            return cast[uint64](-14)             # -EFAULT
        # uaccess (#163): snapshot the caller's fd array into a kernel
        # copy via copy_from_user BEFORE parking on the wait queue —
        # vfs_waitfds re-scans the array on every wake, and a raw user
        # pointer would be re-dereferenced from kernel context each
        # time. nfds is capped at the per-task fd table size (16), the
        # same clamp vfs_waitfds applies internally.
        wf_nfds: uint64 = a1
        if wf_nfds > 16:
            wf_nfds = 16
        wf_fds: Array[16, int32]
        if copy_from_user(cast[uint64](&wf_fds[0]), a0,
                          wf_nfds * 4) != 0:
            set_current_errstr("waitfds: bad address")
            return cast[uint64](-14)             # -EFAULT
        wf: int64 = vfs_waitfds(&wf_fds[0], wf_nfds,
                                cast[int64](a2))
        return cast[uint64](wf)
    if nr == SYS_SEMACQUIRE:
        # #443: native Plan 9 semacquire(2). a0=&sem word (user uint32),
        # a1=block. Sleeps OFF the runqueue on the hashed sem wait
        # queues (sys/src/9/port/sems.ad) until a semrelease — or the
        # exit-time exit-sem release — makes the word positive.
        return cast[uint64](do_semacquire(a0, cast[int32](a1)))
    if nr == SYS_SEMRELEASE:
        # #443: native Plan 9 semrelease(2). a0=&sem word, a1=count.
        return cast[uint64](do_semrelease(a0, cast[int64](a1)))
    if nr == SYS_SETEXITSEM:
        # #443: register the calling task's exit-notification semaphore
        # (the native thread_join handshake). a0=&sem word, 0 clears.
        return cast[uint64](do_setexitsem(a0))
    if nr == SYS_YIELD:
        # Cooperative yield. Hamnix multitasks COOPERATIVELY: a task
        # only gives up the CPU inside a blocking syscall (SYS_WAITPID,
        # a blocking pipe / stdin read) — there is no working timer
        # preemption to rotate the runqueue underneath a task that
        # never blocks. A single-threaded non-blocking event-loop
        # daemon (user/sshd.ad's SSH<->hamsh bridge) therefore MUST
        # call SYS_YIELD explicitly on every idle poll iteration, or
        # it monopolises the CPU and the very task it is bridging to
        # (hamsh, and every command hamsh spawns) is starved forever —
        # STATE_READY but never scheduled. yield_to_others() rotates
        # to any other ready task and, when nobody else wants the CPU,
        # does an sti/hlt/cli so interrupts (UART RX, virtio-net) can
        # still make progress. Returns 0 unconditionally.
        yield_to_others()
        return 0
    if nr == SYS_NICE:
        # #151 / CFS-lite: set or get the calling task's nice value.
        # a1 == 1 → GET; otherwise SET to (int)a0.
        #
        # F2 #447 / audit §4 thin-shim conversion: SYS_NICE already IS
        # the thin shim — it calls `sched_set_nice` / `sched_get_nice`,
        # the SAME backend `/proc/<pid>/ctl pri <n>` calls (devproc.ad's
        # write arm dispatches into `sched_set_nice` after parsing). The
        # clamp ([-20, +19]) lives inside `sched_set_nice` so both paths
        # honour it — no policy duplication. Migrated callers should
        # prefer `write("/proc/<pid>/ctl", "pri <n>\n")` for Plan-9
        # shape; the syscall stays so existing native code keeps booting
        # while user-side migration finishes. Number reserved (311).
        nidx: uint64 = current_idx_get()
        if a1 == 1:
            return cast[uint64](sched_get_nice(nidx))
        sched_set_nice(nidx, cast[int64](a0))
        return cast[uint64](sched_get_nice(nidx))
    if nr == SYS_SECCOMP_NATIVE:
        # F10-8 / #457: userland arming surface for the per-task native
        # allow-list bitmap. Entry-side filter check is above (the
        # seccomp_native_check_entry call). Self-only — there's no slot
        # argument; this targets current_task. Per the irrevocable
        # ratchet, op=0 is rejected once already armed (caller must use
        # op=1 to extend, never relax).
        scn_self: uint64 = current_idx_get()
        if a0 == 2:
            # QUERY: armed bit, no fault path.
            return cast[uint64](get_task_seccomp_native_armed(scn_self))
        if a0 != 0 and a0 != 1:
            set_current_errstr("seccomp_native: bad op")
            return cast[uint64](-22)                 # -EINVAL
        # ARM (0) and EXTEND (1) both need 32 bytes of user filter.
        if access_ok(a1, 32) == 0:
            set_current_errstr("seccomp_native: bad filter address")
            return cast[uint64](-14)                 # -EFAULT
        uptr: Ptr[uint64] = cast[Ptr[uint64]](a1)
        if a0 == 0:
            # ARM. Refuse a re-arm of an already-armed task — the
            # ratchet says you may only extend (op=1), never replace.
            if get_task_seccomp_native_armed(scn_self) != 0:
                set_current_errstr("seccomp_native: already armed (use op=1 to extend)")
                return cast[uint64](-1)              # -EPERM
            scn_w: uint64 = 0
            while scn_w < 4:
                set_task_seccomp_native_filter(scn_self, scn_w, uptr[scn_w])
                scn_w = scn_w + 1
            set_task_seccomp_native_armed(scn_self, 1)
            return 0
        # NARROW (a0 == 1). Must already be armed. The supplied bitmap
        # is AND-ed into the existing allow-list — clearing a bit DENIES
        # that nr, setting it is a no-op against a denied bit. The
        # ratchet only allows shrinking the surface, never widening, so
        # AND is the correct combinator. Treat narrow-before-arm as an
        # error so callers don't accidentally arm with op=1.
        if get_task_seccomp_native_armed(scn_self) == 0:
            set_current_errstr("seccomp_native: narrow before arm")
            return cast[uint64](-1)                  # -EPERM
        scn_e: uint64 = 0
        while scn_e < 4:
            cur: uint64 = get_task_seccomp_native_filter(scn_self, scn_e)
            set_task_seccomp_native_filter(scn_self, scn_e, cur & uptr[scn_e])
            scn_e = scn_e + 1
        return 0
    if nr == SYS_UMDF_MMIO_MAP:
        # Track 4: map a device BAR (a0=phys, a1=len) uncacheably into the
        # calling user-mode driver host's own address space. Returns user
        # VA or -errno. Privileged provisioning path; the body validates.
        if umdf_mmio_map_hook == cast[Fn[uint64, uint64, uint64]](0):
            set_current_errstr("umdf_mmio_map: no UMDF bound")
            return cast[uint64](cast[int64](-38))    # -ENOSYS
        return umdf_mmio_map_hook(a0, a1)
    if nr == SYS_UMDF_DMA_ALLOC:
        # Track 4: allocate a physically-contiguous DMA buffer (a0=len),
        # map it into the host's user VA, and write the physical base to
        # *a1 (Ptr[uint64]). Returns user VA or -errno.
        if umdf_dma_alloc_hook == cast[Fn[uint64, uint64, Ptr[uint64]]](0):
            set_current_errstr("umdf_dma_alloc: no UMDF bound")
            return cast[uint64](cast[int64](-38))    # -ENOSYS
        if a1 != 0 and access_ok(a1, 8) == 0:
            set_current_errstr("umdf_dma_alloc: bad out_phys address")
            return cast[uint64](cast[int64](-14))    # -EFAULT
        return umdf_dma_alloc_hook(a0, cast[Ptr[uint64]](a1))
    if nr == SYS_UMDF_IRQ_OPEN:
        # Track 4: register CPU vector a0 and return a readable irq fd the
        # host blocks on (via SYS_READ) to wait for device interrupts.
        if umdf_irq_open_hook == cast[Fn[int32, uint64]](0):
            set_current_errstr("umdf_irq_open: no UMDF bound")
            return cast[uint64](cast[int64](-38))    # -ENOSYS
        rc_io: int32 = umdf_irq_open_hook(a0)
        return cast[uint64](cast[int64](rc_io))
    if nr == SYS_CLOSE:
        rc: int32 = vfs_close(cast[int32](a0))
        if rc < 0:
            set_current_errstr("close: bad fd")
        return cast[uint64](rc)
    if nr == SYS_WRITE:
        # #438: out-of-lined — the 4 KiB bounce lives in _sysarm_write's
        # frame, not in every syscall's.
        return _sysarm_write(a0, a1, a2)
    if nr == SYS_LSEEK:
        n: int64 = vfs_lseek(cast[int32](a0),
                             cast[int64](a1), cast[int32](a2))
        if n < 0:
            set_current_errstr("seek: not seekable")
        return cast[uint64](n)
    if nr == SYS_EXECVE:
        if access_ok_str(a0) == 0:
            set_current_errstr("execve: bad path address")
            return cast[uint64](-14)             # -EFAULT
        # SYS_EXECVE serves BOTH the 2-arg native sys_execve(path, argv)
        # AND the 3-arg sys_execve_env(path, argv, envp) used by hamsh's
        # spawn(), login, and su (lib/p9.ad). The 3-arg form carries a real
        # envp in a2 — forwarding it is what makes getenv("PATH") work for an
        # exec'd Debian binary inside `enter linux { … }`. The 2-arg form has
        # NO env: its sys_execve asm stub now zeros %rdx so a2 arrives as 0
        # (previously a2 was an UNINITIALIZED register — VM saw 0, but real HW
        # saw garbage 0x35 which exec_snapshot_args walked and faulted -EFAULT,
        # wedging /init's exec of /bin/hamsh). We additionally guard with
        # access_ok: a non-canonical / kernel-range a2 is treated as empty env
        # rather than handed to the snapshot walk, so a stray garbage register
        # can never fault the exec. A valid user envp (the 3-arg case) passes
        # straight through. The Linux-ABI execve (nr 59) has its own _u_execve.
        envp_a2: uint64 = a2
        if access_ok(a2, 8) == 0:
            envp_a2 = 0
        return cast[uint64](do_execve(a0, a1, envp_a2))
    # #450 F6 / Phase G: SYS_SPAWN (number 11) is RETIRED. The
    # 200+ line stdio/fd/Pgrp inheritance block that used to live
    # here is gone — the entire spawn() story now lives in userland
    # at lib/p9.ad. Native code calls spawn(path, argv, sin, sout,
    # envp) which rfork(RFPROC|RFFDG|RFNAMEG)s a child whose private
    # COW Pgrp + private fd table copy IS the inheritance — no
    # kernel-side magic. The child handles legacy integer-fd sin/sout
    # cases (in [0, 16)) with sys_dup2 between rfork and execve;
    # SPAWN_STDIO_NS (-2) callers (hamsh) rebind the child's /fd/N
    # via sys_fdbind on the just-rforked pid before yielding.
    #
    # The syscall number 11 stays RESERVED — matches the F2 #447
    # retirement pattern; do not re-use. A nr==11 call now falls
    # through to the unknown-syscall handler at the tail of
    # do_syscall (set_current_errstr("unknown syscall") + return -1).
    if nr == SYS_PIPE:
        # Hand a pair of (rfd, wfd) back to the calling task. The
        # fds are stored at *(int32*)a0[0..1] — the caller passes
        # a Ptr[int32] to a two-element buffer.
        if access_ok(a0, 8) == 0:
            set_current_errstr("pipe: bad fds address")
            return cast[uint64](-14)             # -EFAULT
        # uaccess: vfs_pipe writes the (rfd, wfd) pair into a KERNEL
        # bounce buffer; we then copy_to_user the 8 bytes out so the
        # int fds[2] store goes through the page-table translation.
        pipe_kfds: Array[2, int32]
        rc: int32 = vfs_pipe(&pipe_kfds[0])
        if rc < 0:
            set_current_errstr("pipe: out of fds")
            return cast[uint64](rc)
        if copy_to_user(a0, cast[uint64](&pipe_kfds[0]), 8) != 0:
            set_current_errstr("pipe: bad fds address")
            return cast[uint64](-14)             # -EFAULT
        return cast[uint64](rc)
    # ARCH §10: ALL native BSD socket syscalls are RETIRED — Layer 1 is
    # Plan-9-shaped, so networking is the /net file tree, NOT a socket()
    # syscall family. SYS_SOCKET (41) / SYS_CONNECT (42) — active open;
    # SYS_ACCEPT_SOCK (43) — accept; SYS_BIND_SOCK (49) / SYS_LISTEN_SOCK
    # (50) — passive open; SYS_TLS_CONNECT — TLS handshake: every one of
    # those native arms is gone. Native clients dial / TLS-upgrade /
    # announce / accept by open/read/write on /net/tcp (user/net9.ad's
    # net_dial / net_dial_tls / net_announce / net_accept) — a TLS
    # connection is a `tls <host>` ctl command on a connected /net/tcp
    # conn, which runs the in-kernel TLS 1.3 handshake over the
    # connection (drivers/net/devnet.ad + drivers/net/tls.ad). The
    # _u_socket / _u_connect / _u_tls_connect / _u_bind / _u_listen /
    # _u_accept bodies survive only in linux_abi/u_syscalls.ad's OWN
    # dispatcher, which still serves stock Linux socket(2)/connect(2)/...
    # ELFs as a Layer-2 consumer of the same /net surface. Numbers
    # 41/42/43/49/50 (and SYS_TLS_CONNECT) are unassigned here.
    if nr == SYS_SOCKETPAIR:
        # V5: Linux socketpair(2). Hand back two bidirectional fds in
        # *(int32*)a3[0..1]. Domain (a0) and protocol (a2) are
        # ignored at this scope (caller passes AF_UNIX=1, 0). Type
        # (a1) must be SOCK_STREAM (1) or SOCK_DGRAM (2); anything
        # else is EINVAL. Mirrors the SYS_PIPE failure-path shape
        # above.
        sp_type: uint64 = a1
        if sp_type != 1 and sp_type != 2:
            set_current_errstr("socketpair: bad type")
            return cast[uint64](-22)           # -EINVAL
        if access_ok(a3, 8) == 0:
            set_current_errstr("socketpair: bad sv address")
            return cast[uint64](-14)           # -EFAULT
        # uaccess: same bounce-buffer shape as SYS_PIPE — fill a kernel
        # pair then copy_to_user the int sv[2] out.
        sp_kfds: Array[2, int32]
        rc: int32 = vfs_socketpair(&sp_kfds[0])
        if rc < 0:
            set_current_errstr("socketpair: out of fds")
            return cast[uint64](rc)
        if copy_to_user(a3, cast[uint64](&sp_kfds[0]), 8) != 0:
            set_current_errstr("socketpair: bad sv address")
            return cast[uint64](-14)           # -EFAULT
        return cast[uint64](rc)
    if nr == SYS_KILL:
        # #450 F6 / Phase G: the POSITIVE-pid kill drift arm is RETIRED.
        # Positive-pid kills now go through Plan-9-shape /proc/<pid>/note
        # writes (lib/p9.ad's p9_note). What survives here is the
        # NEGATIVE-pid job-control branch — Unix kill(-pgid, sig), used by
        # hamsh to broadcast SIGCONT/SIGTERM/SIGKILL across a process group
        # at once. F2 #447 deliberately left the POSIX job-control family
        # (SETPGID / TCSETPGRP / WAITPID_JC) in place as follow-up scope;
        # the matching negative-pid SYS_KILL path is part of that surface.
        # Userland reaches it through user/runtime.S's sys_pgrp_kill(pgid,
        # sig) wrapper, which negates pgid before issuing the syscall.
        a0_signed: int64 = cast[int64](a0)
        if a0_signed >= 0:
            # Positive pid -> retired. Errstr points the caller at the
            # Plan-9 replacement. -ENOSYS (-38) is the canonical
            # "syscall arm removed" return; userland code that uses
            # lib/p9.ad's p9_note never hits this path.
            set_current_errstr("kill: positive-pid retired; use /proc/<pid>/note")
            return cast[uint64](cast[int64](-38))   # -ENOSYS
        # Job control: deliver `sig` to EVERY member of process group
        # |a0|. PID 1 is never signalled by the group path
        # (signal_post_to_pgid guards it).
        kpgid: uint64 = cast[uint64](-a0_signed)
        khit: int32 = signal_post_to_pgid(kpgid, a1)
        if khit == 0:
            set_current_errstr("kill: no such process group")
            return cast[uint64](-3)            # -ESRCH
        return 0
    if nr == SYS_SETPGID:
        # a0 = pid (0 = self), a1 = pgid (0 = use the target's pid, i.e.
        # the task becomes its own group leader). Job control: the shell
        # calls this on a freshly-spawned child to drop it into a new
        # process group before wiring the terminal foreground. Returns 0
        # or -ESRCH.
        sp_pid: uint64 = a0
        if sp_pid == 0:
            sp_pid = current_task_pid()
        sp_slot: int32 = task_lookup_by_pid(sp_pid)
        if sp_slot < 0:
            set_current_errstr("setpgid: no such pid")
            return cast[uint64](-3)            # -ESRCH
        sp_pgid: uint64 = a1
        if sp_pgid == 0:
            sp_pgid = sp_pid
        task_set_job_pgid(cast[uint64](sp_slot), sp_pgid)
        return 0
    if nr == SYS_TCSETPGRP:
        # a0 = pgid to install as the terminal's foreground process
        # group. Ctrl-C/Ctrl-Z (signal_post_to_foreground) then route
        # only to this group. The shell sets it to a job's pgid when it
        # foregrounds the job and back to its own pgid (1) when the job
        # exits/stops. pgid 0 = "no foreground job" (terminal signals
        # dropped at the bare prompt). Always succeeds.
        set_terminal_fg_pgid(a0)
        return 0
    if nr == SYS_WAITPID_JC:
        # Non-blocking job-control wait. a0 = pid, a1 = Ptr[int64]
        # status. Returns the pid (>0) when there is something to
        # report and writes a status word; returns 0 when the child is
        # still running with nothing new; returns -ECHILD (-10) if the
        # pid is unknown.
        #
        # Status word encoding (low byte = kind, high bytes = detail):
        #   kind 0  WAITJC_RUNNING  — alive, nothing new (also rc 0)
        #   kind 1  WAITJC_EXITED   — status>>8 & 0xFF = exit code; slot
        #                             is REAPED here (freed).
        #   kind 2  WAITJC_STOPPED  — status>>8 & 0xFF = stop signal
        #                             (SIGTSTP/SIGSTOP/...); slot stays.
        #   kind 3  WAITJC_CONTINUED— resumed since last report; slot
        #                             stays. Reported once per resume.
        # a1 == 0 is the "don't write status" sentinel — skip the check.
        if a1 != 0 and access_ok(a1, 8) == 0:
            set_current_errstr("waitpid_jc: bad status address")
            return cast[uint64](-14)             # -EFAULT
        jc_slot: int32 = task_lookup_by_pid(a0)
        if jc_slot < 0:
            set_current_errstr("waitjc: no such child")
            return cast[uint64](-10)           # -ECHILD
        # uaccess: the status word is written via put_user_64 (which
        # walks the current task's page tables) rather than a raw
        # cast[Ptr[int64]](a1)[0] store, so vaddr != phys is honoured.
        jc_st: uint64 = task_state(jc_slot)
        if jc_st == STATE_EXITED:
            jc_code: int64 = task_exit_code(jc_slot)
            task_reap(jc_slot)
            if a1 != 0:
                jc_w: int64 = (cast[int64](jc_code & 0xFF) << 8) \
                            | cast[int64](1)        # WAITJC_EXITED
                put_user_64(cast[uint64](jc_w), a1)
            return a0
        if jc_st == STATE_STOPPED:
            # Report the stop exactly once: clear cont_pending so a
            # later resume re-reports, but the STOPPED state itself is
            # idempotent here — the shell already printed "Stopped" on
            # the Ctrl-Z that set it, then polls; re-reporting STOPPED
            # is harmless and the shell de-dups by job state.
            jc_ssig: uint64 = task_stop_sig(jc_slot)
            if a1 != 0:
                jc_w: int64 = (cast[int64](jc_ssig) << 8) \
                            | cast[int64](2)        # WAITJC_STOPPED
                put_user_64(cast[uint64](jc_w), a1)
            return a0
        # Running. Surface a one-shot CONTINUED report if a SIGCONT
        # resumed it since the shell last looked.
        if task_take_cont_pending(jc_slot) != 0:
            if a1 != 0:
                put_user_64(cast[uint64](3), a1)     # WAITJC_CONTINUED
            return a0
        if a1 != 0:
            put_user_64(cast[uint64](0), a1)         # WAITJC_RUNNING
        return 0
    if nr == SYS_DUP:
        rc: int32 = vfs_dup(cast[int32](a0))
        if rc < 0:
            set_current_errstr("dup: bad fd")
        return cast[uint64](rc)
    if nr == SYS_DUP2:
        rc: int32 = vfs_dup2(cast[int32](a0), cast[int32](a1))
        if rc < 0:
            set_current_errstr("dup2: bad fd")
        return cast[uint64](rc)
    # #450 F6 / Phase G: SYS_LISTDIR (number 18) is RETIRED. Native code
    # uses lib/p9.ad's p9_listdir() — open(path, OREAD) + read(fd, buf,
    # count) + close(fd). The dir-fd's DEV_DIR_FILE backing (_dirfile_read
    # in sys/src/9/port/namec.ad) emits the SAME "NAME\n" packed listing
    # the retired syscall used to produce, so userland glob parsing is
    # byte-identical. Number 18 stays reserved. A nr==18 call falls through
    # to the unknown-syscall handler at the tail of do_syscall.
    if nr == SYS_CHDIR:
        # Resolve to the CANONICAL NAMESPACE path (cwd-prepended,
        # absolute, "."/".."-compacted) for the stored cwd. We must NOT
        # store resolve_path's ns_walk output: that rewrites a bound
        # name to its backend device form (e.g. `/srv` -> `#s`), which
        # is correct for OPENING the dir but wrong for the cwd string
        # that SYS_GETCWD / `pwd` reports. In Plan 9 getwd reconstructs
        # the path you WALKED (the bind point `/srv`), not the device
        # the name resolves to. resolve_path_canonical stops before the
        # ns_walk rewrite, so `cd srv; pwd` -> `/srv`, not `#s`.
        if access_ok_str(a0) == 0:
            set_current_errstr("chdir: bad address")
            return cast[uint64](-14)             # -EFAULT
        u_path: Array[256, uint8]
        if copyin_path(a0, &u_path[0], 256) < 0:
            set_current_errstr("chdir: bad address")
            return cast[uint64](-14)             # -EFAULT
        abs_path: Array[256, uint8]
        rc: int32 = resolve_path_canonical(cast[Ptr[char]](&u_path[0]),
                                           &abs_path[0], 256)
        if rc != 0:
            return cast[uint64](rc)
        # Validate the resolved path is an existing directory BEFORE
        # we install it as the task cwd. Without this, real-hardware
        # testing on GNOME Boxes showed `cd nope/nope/nope` silently
        # accumulating bogus segments into per-task cwd and
        # `cd SUBDIR; ls` listing root. Strategy: open the path;
        # require the fd to be a directory marker (FD_DIR_MARK, set
        # by vfs.ad::_open_dir_*); close it. vfs_listdir() was the
        # obvious candidate but only routes /mnt + /ext today, so
        # /etc/{...} would spuriously fail.
        # F10-1 (#454): the probe must pass the UNRESOLVED user path —
        # vfs_open runs resolve_path internally, and the path-resolved
        # form is NOT idempotent through a second resolve_path call
        # when a bind rewrites a name to a path that has no covering
        # bind in the same Pgrp (e.g. /onlyetc/inittab → /etc/inittab
        # in an RFCNAMEG child with ONLY /onlyetc bound). set_task_cwd
        # receives the CANONICAL namespace path (abs_path) so the cwd
        # is the bind-point name the user walked, not the ns_walk
        # backend rewrite.
        probe_fd: int32 = vfs_open(cast[Ptr[char]](&u_path[0]))
        if probe_fd < 0:
            set_current_errstr("chdir: no such directory")
            return cast[uint64](-2)            # -ENOENT
        if vfs_fd_is_dir(probe_fd) == 0:
            vfs_close(probe_fd)
            set_current_errstr("chdir: not a directory")
            return cast[uint64](-20)           # -ENOTDIR
        vfs_close(probe_fd)
        rc = set_task_cwd(current_idx_get(), &abs_path[0])
        if rc < 0:
            set_current_errstr("chdir: path too long")
            return cast[uint64](-7)            # -E2BIG

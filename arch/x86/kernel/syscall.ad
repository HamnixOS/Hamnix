                set_current_errstr("netcfg: bad route buffer")
                return cast[uint64](-14)         # -EFAULT
            ncq_stage: Array[13, uint8]
            ncq_rc: int64 = do_netcfg(5, cast[uint64](&ncq_stage[0]),
                                      a2)
            if ncq_rc >= 0:

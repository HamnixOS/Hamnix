        if copyin_path(a0, &ws_kpath[0], 256) < 0:
            set_current_errstr("wstat: bad path address")
            return cast[uint64](-14)             # -EFAULT
        ws_nbuf: uint64 = a2
        if ws_nbuf > 560:
            ws_nbuf = 560
        ws_stage: Array[560, uint8]
        if copy_from_user(cast[uint64](&ws_stage[0]), a1, ws_nbuf) != 0:

        # including the NUL terminator. Returns the number of bytes
        # written (incl NUL) or -ERANGE if a1 is 0.
        #
        # The cwd lives in the task's kernel-side cwd[] (128 bytes). We
        # build the NUL-terminated copy-out image in a kernel buffer and
        # push it to the user buffer through copy_to_user, which WALKS
        # the current task's page tables to translate `a0`. The old
        # byte-by-byte `dst[i] = c` raw deref only worked while every
        # user page was identity-mapped (vaddr == phys); copy_to_user
        # is correct even when the destination frame != its vaddr.
        if a1 == 0:
            set_current_errstr("getcwd: buffer too small")
            return cast[uint64](-34)           # -ERANGE
        if access_ok(a0, a1) == 0:
            set_current_errstr("getcwd: bad address")
            return cast[uint64](-14)           # -EFAULT
        # uaccess: assemble the result in a kernel bounce buffer, then
        # copy_to_user it out — never write the raw user vaddr directly.
        src: Ptr[uint8] = get_cwd_buf(current_idx_get())
        cwd_out: Array[128, uint8]
        # Bound the copy-out length by the user's buffer (a1) AND the
        # kernel cwd capacity (128, incl NUL). i counts bytes BEFORE the
        # terminator; we always write a trailing NUL.
        gw_max: uint64 = a1
        if gw_max > 128:
            gw_max = 128
        i: uint64 = 0
        gw_hit_nul: int32 = 0
        while i + 1 < gw_max:
            c: uint8 = src[i]
            cwd_out[i] = c
            if c == 0:
                gw_hit_nul = 1
                break

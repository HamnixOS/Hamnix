                # WNOHANG: child still alive, don't block. Returning
                # -EAGAIN (-11) is distinguishable from any real exit
                # code (which is the low 8 bits, 0..255).
                return cast[uint64](-11)       # -EAGAIN
            yield_to_others()
            target = task_lookup_by_pid(a0)
            if target < 0:
                set_current_errstr("wait: no such child")
                return cast[uint64](-10)

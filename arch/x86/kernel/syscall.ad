        if fst_cap > 560:
            fst_cap = 560
        fst_stage: Array[560, uint8]
        fst_n: int64 = do_fstat(cast[int32](a0),
                                cast[uint64](&fst_stage[0]), fst_cap)
        if fst_n > 0:
            if copy_to_user(a1, cast[uint64](&fst_stage[0]),
                            cast[uint64](fst_n)) != 0:

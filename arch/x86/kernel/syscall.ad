        # Phase C: Plan 9 wstat — rename + chmod + truncate + utime
        # unified. a0=path, a1=Dir buf, a2=nbuf. This commit honours
        # the `name` (rename, tmpfs-only) and `mode` (no-op success)
        # fields; length / mtime / gid / muid must be sentinels.
        # Body in sys/src/9/port/sysfile.ad::do_wstat.
        if access_ok_str(a0) == 0:
            set_current_errstr("wstat: bad path address")
            return cast[uint64](-14)             # -EFAULT
        if access_ok(a1, a2) == 0:
            set_current_errstr("wstat: bad buffer address")
            return cast[uint64](-14)             # -EFAULT
        # uaccess (#163): copy the path AND the caller's Dir record
        # into kernel staging; do_wstat parses kernel memory only. A
        # valid record we can honour is bounded well under 560 bytes
        # (name <= 255, gid/muid must be empty), so clamping nbuf to
        # the stage size only ever truncates records we'd reject.
        ws_kpath: Array[256, uint8]
        if copyin_path(a0, &ws_kpath[0], 256) < 0:
            set_current_errstr("wstat: bad path address")
            return cast[uint64](-14)             # -EFAULT
        ws_nbuf: uint64 = a2
        if ws_nbuf > 560:
            ws_nbuf = 560
        ws_stage: Array[560, uint8]
        if copy_from_user(cast[uint64](&ws_stage[0]), a1, ws_nbuf) != 0:
            set_current_errstr("wstat: bad buffer address")
            return cast[uint64](-14)             # -EFAULT
        return cast[uint64](do_wstat(cast[uint64](&ws_kpath[0]),
                                     cast[uint64](&ws_stage[0]),
                                     ws_nbuf))

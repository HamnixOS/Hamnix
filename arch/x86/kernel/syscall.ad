        # Phase C / M16.101: Plan 9-shape unlink. a0=path. Wraps
        # vfs_unlink. Replaces SYS_UNLINK (21) semantically; Phase G
        # retires the old number. uaccess: path copied in at the
        # dispatch boundary.
        if access_ok_str(a0) == 0:
            set_current_errstr("remove: bad path address")
            return cast[uint64](-14)             # -EFAULT
        rm_kpath: Array[256, uint8]
        if copyin_path(a0, &rm_kpath[0], 256) < 0:
            set_current_errstr("remove: bad path address")
            return cast[uint64](-14)             # -EFAULT
        return cast[uint64](do_remove(cast[uint64](&rm_kpath[0])))
    if nr == SYS_FD2PATH:
        # Phase C / M16.101: recover path from an open fd. a0=fd,
        # a1=buf, a2=nbuf. Best-effort: returns the canonical archive
        # name for initramfs fds (may differ from the open()-time
        # path); synthetic /dev path for FD_*_MARK fds; -1 +
        # "backend has no path" for pipes / sockets / tmpfs / fat /
        # ext4 (Phase G adds per-fd path tracking). uaccess: the path
        # is emitted into a kernel stage and copy_to_user'd out.
        if access_ok(a1, a2) == 0:
            set_current_errstr("fd2path: bad buffer address")
            return cast[uint64](-14)             # -EFAULT
        f2p_cap: uint64 = a2
        if f2p_cap > 256:
            f2p_cap = 256
        f2p_stage: Array[256, uint8]
        f2p_n: int64 = do_fd2path(cast[int32](a0),
                                  cast[uint64](&f2p_stage[0]), f2p_cap)
        if f2p_n > 0:
            if copy_to_user(a1, cast[uint64](&f2p_stage[0]),
                            cast[uint64](f2p_n)) != 0:
                set_current_errstr("fd2path: bad buffer address")
                return cast[uint64](-14)         # -EFAULT
        return cast[uint64](f2p_n)

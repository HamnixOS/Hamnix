        # a kernel buffer (page-table-walked) before the DNS resolver
        # reads it to build the QNAME.
        resolve_kname: Array[256, uint8]
        if copyin_path(a0, &resolve_kname[0], 256) < 0:
            set_current_errstr("resolve: bad hostname address")
            return cast[uint64](-14)           # -EFAULT
        # dns_lookup writes the 4-byte IPv4 (network order, octet 0
        # first) through this pointer. 200 jiffies (~2 s @ HZ=100)
        # matches the boot smoke + http.ad lookup budget.
        resolve_ip: Array[4, uint8]
        rc: int32 = dns_lookup(&resolve_kname[0],
                               cast[Ptr[uint8]](&resolve_ip[0]), 200)
        if rc != 0:
            set_current_errstr("resolve: cannot resolve hostname")
            return cast[uint64](-2)            # -ENOENT
        resolve_packed: uint64 = (cast[uint64](resolve_ip[0]) << 24) \

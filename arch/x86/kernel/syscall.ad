        # docs/security.md Phase 4: /dev/auth-mediated identity change.
        # a0 = an open /dev/auth fd that has SUCCESSFULLY verified a
        # (user, pass) pair. We recover the fd's devauth slot, confirm
        # it verified, and set THIS task's uid+gid to the slot's verified
        # pair. Unlike SYS_SETUID (hostowner-only, downgrade-only), the
        # gate here is the PASSWORD PROOF carried in the slot — so a
        # freshly-spawned login/su process can drop INTO the
        # authenticated identity regardless of whether the spawning
        # context was the hostowner. This closes the documented
        # "regular user can't enter a freshly-authenticated identity"
        # gap in newshell: the kernel honours the just-validated
        # /dev/auth slot as proof of identity, which is the Plan-9
        # factotum idiom (prove the password, the kernel changes you).
        au_fd: int32 = cast[int32](a0 & 0xFFFFFFFF)
        au_slot: int32 = vfs_fd_auth_slot(au_fd)
        if au_slot < 0:
            set_current_errstr("setuid_auth: not an /dev/auth fd")
            return cast[uint64](cast[int64](-1))
        v_uid: int32 = devauth_verified_uid(au_slot)
        v_gid: int32 = devauth_verified_gid(au_slot)
        if v_uid < 0:
            set_current_errstr("setuid_auth: fd has not authenticated")
            return cast[uint64](cast[int64](-1))
        set_current_task_uid(cast[uint32](v_uid))
        if v_gid >= 0:
            set_current_task_gid(cast[uint32](v_gid))

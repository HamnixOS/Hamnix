            set_current_errstr("fstat: bad buffer address")
            return cast[uint64](-14)             # -EFAULT
        fst_cap: uint64 = a2
        if fst_cap > 560:
            fst_cap = 560
        fst_stage: Array[560, uint8]
        fst_n: int64 = do_fstat(cast[int32](a0),
                                cast[uint64](&fst_stage[0]), fst_cap)
        if fst_n > 0:
            if copy_to_user(a1, cast[uint64](&fst_stage[0]),
                            cast[uint64](fst_n)) != 0:
                set_current_errstr("fstat: bad buffer address")
                return cast[uint64](-14)         # -EFAULT
        return cast[uint64](fst_n)

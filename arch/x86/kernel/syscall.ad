# SYS_SPAWN namespace inheritance: pgrp_current resolves the caller's
# Pgrp (collapsing the BSS-default 0 onto the root Pgrp). The
# SPAWN_STDIO_NS path uses pgrp_clone (private COW Pgrp, HAMSH §7/§9);
# the legacy path uses pgrp_ref_inc to share the parent's Pgrp. The
# child's SPAWN_STDIO_NS stdio fds 0/1/2 are FD_DEVFD_MARK — the
# Layer-2 mapping onto the names /fd/0,1,2.
from sys.src.port9.port.chan import pgrp_clone, pgrp_ref_inc, pgrp_current
# hamUI Phase 2: /bin/hamUI tool registers a spawned child's pid against
# a wid. Mirror SYS_SVC_PUBLISH's hostowner-only gate so only the
# legitimate path mutates the wsys table.
from sys.src.port9.port.devwsys import (
    # F2 #447 / audit §4 thin-shim conversion: the SYS_WSYS_ALLOC /
    # SYS_WSYS_FREE / SYS_VK_WINDOW_FRAME syscall arms now format a
    # ctl-file text line and delegate to devwsys_ctl_write so the
    # syscall and /dev/wsys/ctl writers share one policy path. The
    # wsys_last_alloc_wid slot is the response channel the writer uses
    # to publish a successful "alloc <pid>" result; the syscall arm
    # reads it back like a /dev/wsys/ctl readback would.
    wsys_alloc_wid, wsys_free_wid,
    devwsys_ctl_write,
    wsys_last_alloc_wid_consume,
)
# GPU track #183: kernel-side native Vulkan renderer for window content.
from lib.vk.vk_window_demo import vk_window_render_frame
from sys.src.port9.port.devfd import (
    devfd_bind_cons,
    devfd_bind_pipe_r, devfd_bind_pipe_w,

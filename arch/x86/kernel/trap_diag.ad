# arch/x86/kernel/trap_diag.ad - M16.154-trapdiag.
#
# Adder side of the post-iretq triple-fault diagnostic. Companion file
# to arch/x86/kernel/trap_asm.S.
#
# Goal (single-purpose, no fix in scope): when the Asus box dies after
# the kernel's `iretq` into ring 3, we need to know whether
#   (a) iretq itself triple-faults,                         (no print)
#   (b) iretq succeeds, user's first instr faults → #DF,    (vec 0x08)
#   (c) iretq succeeds, user runs briefly, then faults.     (vec 0x06
#                                                            / 0x0d /
#                                                            0x0e)
# trap_diag_install() overwrites the IDT entries that idt_init() just
# installed for vectors 6 / 8 / 13 / 14 with the richer handlers in
# trap_asm.S, and points TSS.IST1 at a 4 KiB scratch stack so #DF can
# survive even when the interrupted RSP is unusable. Called from
# init/main.ad right before start_first_task(), so we're the LAST
# writer to those four IDT slots before the ring-3 transition.
#
# The handlers PRINT and HALT — they do not return to user. This is
# diagnostic-only; recovery / signal delivery is out of scope.
#
# Diag-line format emitted by do_trap_diag_5 + do_trap_diag_2:
#
#   [trap-diag] vec=0x0d err=0x0000000000000018 rip=0x...
#   [trap-diag] cs=0x... flags=0x...
#   [trap-diag] rsp=0x... ss=0x...
#
# Real-hw interpretation guide (also in the commit message):
#   - vec=0x0d  → #GP at first user instruction; err encodes the
#                 selector index / TI / RPL bits.
#   - vec=0x0e  → #PF at first user instruction; err bits =
#                   P  (0) not-present  /  (1) protection
#                   RW (0) read         /  (1) write
#                   US (0) supervisor   /  (1) user      ← expect 1
#                   RSVD (1) reserved-bit set in pgtable
#                   I/D (1) instruction fetch fault     ← typical here
#   - vec=0x06  → #UD; bytes at user RIP are not a valid opcode.
#                 (Also lit by the M16.155-cr0-probe UD2 overwrite —
#                 if the marker /etc/ring3-probe-ud2 is in cpio and
#                 the first 4 bytes of /init were rewritten to ud2+nop,
#                 a #UD print here means ring-3 transition WORKS and
#                 the original /init bytes were the trigger.)
#   - vec=0x07  → #NM; device-not-available. CR0.TS=1 or CR0.EM=1
#                 traps the first FPU/SIMD op in user mode. The
#                 cpu-diag block prints CR0.TS / CR0.EM right before
#                 SYSRETQ — if either is 1 here, that's the bug.
#   - vec=0x08  → #DF; ring-3 transition path took a fault whose
#                 handler ALSO faulted — already in double-fault
#                 territory.
#   - vec=0x10  → #MF; x87 floating-point error in user code (rare;
#                 typically a fresh ring-3 program doesn't have a
#                 pending FP exception unless CR0.NE/NE-emulation is
#                 misconfigured).
#   - vec=0x13  → #XF; SIMD floating-point exception. If the first
#                 user instruction is a SIMD op and CR4.OSXMMEXCPT=1
#                 with a pending SSE exception flag, this fires.
#   - NOTHING new prints (only the reboot loop)
#                → iretq itself is the immediate triple-fault. Next
#                  step is SYSRETQ instead of IRETQ for the first
#                  transition.

from kernel.printk.printk import printk0, printk1, printk2, printk_set_level
# TEMP_DEBUG_TRAP_VISIBILITY: every trap-side printk below gets
# stamped with EMERG so it survives the post-interactive console
# log-level gate (013fe0c). Without this, a #PF / #GP / #UD that
# fires AFTER userland has gone interactive (e.g. immediately after a
# successful SYSRETQ on the execve return path) goes to the dmesg
# ring buffer only — no byte ever reaches the framebuffer the user
# is photographing. EMERG is severity 0, strictly below every gate
# threshold the console-split shipped, so a trap-time message is
# guaranteed visible on the live console.
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG
from kernel.printk.esp_log import esp_log_flush
from arch.x86.kernel.idt import idt_set_gate_with_ist
# SMAP v3e: trap-diag dumps user RIP bytes (US=1 user-text page) at CPL=0;
# need STAC/CLAC around the two qword loads or those reads #PF under
# CR4.SMAP=1. Imported even though the existing v3c brackets in core.ad
# already pull these in — Adder import surface is per-module.
from mm.uaccess import _ua_stac, _ua_clac, uaccess_resolve
# COW page-fault resolution. cow_handle_write_fault inspects the
# faulting task's PTE and either resolves a copy-on-write fault or
# reports "not a COW fault" so the diagnostic halt still fires.
from fs.elf import cow_handle_write_fault, _cow_resolve_pte_slot
# §142: demand-paging fault handler.
# #167: swap-in fault handler — restores a swapped-out anon page.
from mm.vma import vma_demand_fault, vma_swap_in_fault, \
    vma_resolve_write_perm_fault, vma_resolve_exec_perm_fault, \
    vma_dbg_dump_cover, _vma_pte_lookup
# task #112: read THIS CPU's logical id at the #PF decision point. An
# intermittent -smp 2 user SIGSEGV on a supposedly-mapped VA needs the
# faulting CPU stamped on the diagnostic so BSP-vs-AP divergence is visible.
from arch.x86.kernel.setup_percpu import get_cpu_id
# userfaultfd(2): a fault in a range registered with an active uffd for the
# faulting task is owned by the USERSPACE handler — it enqueues a uffd_msg and
# suppresses the demand-zero path (the page stays not-present until UFFDIO_COPY/
# ZEROPAGE resolves it). uffd_pagefault_hook is a cheap no-op for the common
# case (no uffd registered — every native process).
#
# F4 #449 leaf inversion: the static import from linux_abi.u_userfaultfd is
# gone. The Layer-2 uffd module registers its pagefault routine through
# register_uffd_pagefault_hook() at bring-up; a pure-native build leaves the
# pointer null and the call is a no-op. Default null deliberately mirrors the
# old "no uffd registered" cheap path.
#
# Named `..._fn` (the function pointer) rather than `uffd_pagefault_hook`
# because Adder flat-merges public symbols across modules: the Layer-2
# implementation in linux_abi/u_userfaultfd.ad still uses the original
# `uffd_pagefault_hook` name, so the native-side pointer takes a distinct
# spelling to avoid a duplicate-definition merge collision.
uffd_pagefault_hook_fn: Fn[int32, uint64, uint64, int32]


def register_uffd_pagefault_hook(
        hook: Fn[int32, uint64, uint64, int32]):
    # linux_abi/u_userfaultfd.ad calls this once at boot. The not-present
    # user-fault arm of do_page_fault then routes through this pointer.
    uffd_pagefault_hook_fn = hook
from kernel.sched.core import current_idx_get, task_pml4, \
    deliver_fault_sigsegv, current_task_account_minor_fault, \
    current_task_account_major_fault, task_kstack_top, \
    task_image_lo, task_image_hi, task_interp_lo, task_interp_hi, \
    dbg_dump_sig_for_va, task_fs_base
from mm.cow import cow_boot_cr3
# Diag-walk self-fault guard: the cr2 page-walk dereferences table pages
# as raw physical pointers under the boot CR3's identity map. A corrupt /
# garbage higher-level entry can point at a physical address that is NOT
# backed by mapped RAM; dereferencing it #PF's INSIDE the diagnostic (the
# secondary kernel #PF the user saw: a second [trap-diag] line, cs=0x08).
# memblock_region_top() is the highest physical RAM address the boot CR3
# identity-maps; the walk skips any table-page pointer at/above it.
from mm.memblock import memblock_region_top

# trap_asm.S — per-vector stubs + IST1 stack + tss_set_ist1 helper.
extern def read_cr2() -> uint64
extern def read_cr3() -> uint64
extern def load_cr3(cr3: uint64)
extern def get_trap_diag_stub(vector: uint64) -> uint64
extern def get_trap_diag_ist_stack_top() -> uint64
extern def tss_set_ist1(top: uint64)


def smap_probe_arm():
    # mm/uaccess.ad arms the one-shot SMAP probe extable before the
    # un-stac'd asm load, and disarms after reading the verdict.
    smap_probe_armed = 1
    smap_probe_faulted = 0


def smap_probe_disarm():
    smap_probe_armed = 0


def smap_probe_did_fault() -> uint64:
    return smap_probe_faulted


def trap_diag_pte_walk(cr3: uint64, va: uint64):
    # Diagnostic 4-level page walk of `va` under `cr3`, printing each
    # level's raw entry. Pure physical-pointer reads — caller must be on
    # a CR3 that identity-maps the table pages (the diag path is; the
    # boot CR3 maps all of low RAM). Used to pin down the intermittent
    # "kstack page vanished mid-syscall" corruption (#410 live-root):
    # shows whether a not-present / remapped kstack page is a cleared
    # 4 KiB PTE in a cracked PT, a freed-and-reused table page (garbage
    # entries), or a missing higher-level entry.
    m: uint64 = PF_CR3_ADDR_MASK
    i4: uint64 = (va >> 39) & 0x1FF
    i3: uint64 = (va >> 30) & 0x1FF
    i2: uint64 = (va >> 21) & 0x1FF
    i1: uint64 = (va >> 12) & 0x1FF
    # Self-fault guard: highest identity-mapped physical RAM address. Any
    # table-page pointer at/above this is NOT backed by the boot CR3's
    # identity map; dereferencing it would #PF inside the diagnostic (the
    # secondary kernel #PF in the repro). Bail with a note instead.
    ram_top: uint64 = memblock_region_top()
    pml4_pa: uint64 = cr3 & m
    if pml4_pa == 0 or (ram_top != 0 and pml4_pa >= ram_top):
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[trap-diag]   pml4 phys %p unmapped, walk skipped\n",
                pml4_pa)
        return
    pml4: Ptr[uint64] = cast[Ptr[uint64]](pml4_pa)
    e4: uint64 = pml4[i4]
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[trap-diag]   pml4e[%d]=%p\n", i4, e4)
    if (e4 & 0x1) == 0:
        return
    e4_pa: uint64 = e4 & m
    if e4_pa == 0 or (ram_top != 0 and e4_pa >= ram_top):
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[trap-diag]   pdpt phys %p unmapped, walk skipped\n",
                e4_pa)
        return
    pdpt: Ptr[uint64] = cast[Ptr[uint64]](e4_pa)
    e3: uint64 = pdpt[i3]
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[trap-diag]   pdpte[%d]=%p\n", i3, e3)
    if (e3 & 0x1) == 0 or (e3 & 0x80) != 0:
        return
    e3_pa: uint64 = e3 & m
    if e3_pa == 0 or (ram_top != 0 and e3_pa >= ram_top):
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[trap-diag]   pd phys %p unmapped, walk skipped\n",
                e3_pa)
        return
    pd: Ptr[uint64] = cast[Ptr[uint64]](e3_pa)
    e2: uint64 = pd[i2]
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[trap-diag]   pde[%d]=%p\n", i2, e2)
    if (e2 & 0x1) == 0 or (e2 & 0x80) != 0:
        return
    e2_pa: uint64 = e2 & m
    if e2_pa == 0 or (ram_top != 0 and e2_pa >= ram_top):
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[trap-diag]   pt phys %p unmapped, walk skipped\n",
                e2_pa)
        return
    pt: Ptr[uint64] = cast[Ptr[uint64]](e2_pa)
    e1: uint64 = pt[i1]
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[trap-diag]   pte[%d]=%p\n", i1, e1)


# #PF error-code bits (Intel SDM Vol 3A 4.7).
PF_ERR_P:  uint64 = 0x1        # 1 = protection violation (page present)
PF_ERR_W:  uint64 = 0x2        # 1 = the access was a write
PF_ERR_U:  uint64 = 0x4        # 1 = fault occurred in user mode
PF_ERR_RSVD: uint64 = 0x8      # 1 = reserved bit set in a paging entry
PF_ERR_ID: uint64 = 0x10       # 1 = instruction-fetch (NX) fault (I/D)

# CR3 -> PML4 physical address: low 12 bits are flags.
PF_CR3_ADDR_MASK: uint64 = 0x000FFFFFFFFFF000

# --- SMAP positive-test single-entry exception table (v3g) -----------
# mm/uaccess.ad::smap_enforced_test() arms this before calling the asm
# probe smap_probe_load(), which does an un-stac'd CPL=0 read of a
# genuinely-US=1 user leaf. Under CR4.SMAP=1 that read #PF's (P=1, U=0 —
# kernel-mode). do_page_fault recognises the fault RIP == the probe's
# faulting instruction and, instead of halting, records the fault and
# advances the iret RIP to the probe's fixup label so the probe returns
# cleanly. This is a deliberately minimal one-entry extable, scoped to
# the boot-time SMAP enforcement proof; it is disarmed immediately after.
smap_probe_armed:   uint64 = 0      # 1 while the probe load is live
smap_probe_faulted: uint64 = 0      # set to 1 by the recovery hook

# task #112 — SMP spurious not-present #PF recovery counters. A user #PF
# whose CPU-walk saw P=0 but whose LIVE leaf PTE is already present (a
# sibling CPU resolved the page in the window between the faulting walk and
# this handler) is SPURIOUS: re-running the instruction succeeds because
# x86 never negatively-caches translations. `pf_spurious_recovered` counts
# how many times the guard fired (proof the race is real + being masked
# correctly, not silently). Rate-limit the log so a fault storm can't drown
# the console.
pf_spurious_recovered: uint64 = 0
_pf_spurious_logs:      uint64 = 0


def pf_spurious_recovered_count() -> uint64:
    # Test/selftest accessor: how many spurious not-present faults the SMP
    # re-validation guard has absorbed since boot. A repro that drives heavy
    # cross-CPU shared-page demand churn asserts this is > 0 (the race fires)
    # AND that no false SIGSEGV was delivered.
    return pf_spurious_recovered
extern def smap_probe_fault_rip()   # the faulting `movb` RIP (asm symbol)
extern def smap_probe_fixup()       # recovery landing pad (asm symbol)

# Lower-canonical boundary: every legal USER virtual address is strictly
# below this (the x86-64 lower-half ends at 0x00007FFF_FFFFFFFF; the kernel
# higher-half begins at 0xFFFF8000_00000000). A #PF cr2 below this is a
# user-range fault; at/above it is a kernel-half address. Used to decide
# whether a kernel-mode (U=0) write fault is the kernel acting on a user
# task's behalf (per-process SIGSEGV) vs a true kernel-pointer bug (halt).
PF_USER_VA_LIMIT: uint64 = 0x0000800000000000


def do_page_fault(error_code: uint64, fault_va: uint64,
                  cr3: uint64, iret_frame: Ptr[uint64]) -> int64:
    # Productive #PF handler — COW write faults + §142 demand paging.
    #
    # Called from trap_diag_stub_0e (arch/x86/kernel/trap_asm.S) with
    # the CPU-pushed error code, the faulting linear address (CR2), and
    # the faulting task's CR3. Return value drives the asm stub:
    #
    #   1  -> the fault was recoverable (COW or demand-page) and has
    #         been resolved; the stub restores all GPRs and iretq's so
    #         the faulting instruction re-runs.
    #   0  -> NOT a recoverable fault (genuine unmapped access, write to
    #         a truly read-only page, kernel-mode fault, ...). The stub
    #         falls through to common_trap_diag's print-and-halt —
    #         genuine segfaults are deliberately NOT masked.
    #
    # Two productive cases:
    #   (a) COW write fault: P=1, W=1 — page is present but read-only
    #       because it was COW-marked at fork. cow_handle_write_fault
    #       copies the page and marks both sides writable.
    #   (b) Demand-page fault: P=0, W=0 or W=1 — page is NOT present
    #       because it belongs to a is_demand VMA (SYS_MMAP §142).
    #       vma_demand_fault allocates a physical page, zeros it, and
    #       maps it at the faulting address.
    #
    # All other shapes (P=0 outside a demand VMA, fault in kernel mode,
    # protection fault on a genuinely read-only page) go to the halt.
    pml4_phys: uint64 = cr3 & PF_CR3_ADDR_MASK

    # RSVD (bit 3) — a paging-structure entry on the walk of fault_va had a
    # reserved bit set (P=1 + reserved). This is NEVER a recoverable MM fault
    # (COW / demand / swap / stale-perm all assume well-formed entries): a
    # poisoned page-table entry means the tables were corrupted (historically
    # the high-ASLR memcpy-from-physical-page-0 PDPT-seed bug in
    # elf_prepare_demand_range / _cow_resolve_pte_slot, now fixed, which left
    # reserved/all-ones leaves). Decode it explicitly BEFORE the P=1 branches
    # below misclassify it as a COW/read-prot fault: dump the full 4-level
    # walk (which level carries the reserved bits), then deliver SIGSEGV to a
    # user faulter / halt for a kernel faulter. This keeps a corrupted-PTE
    # fault from silently entering the COW copy path with a wild phys.
    if (error_code & PF_ERR_RSVD) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[pf] RSVD (reserved-bit) fault va=%p err=%p\n",
                fault_va, error_code)
        trap_diag_pte_walk(cr3, fault_va)
        if (error_code & PF_ERR_U) != 0:
            rsvd_rc: int32 = deliver_fault_sigsegv(iret_frame)
            if rsvd_rc == 1:
                return cast[int64](1)
        return cast[int64](0)

    # SMAP positive-test recovery (v3g): if the SMAP enforcement probe is
    # armed and THIS fault is the probe's un-stac'd CPL=0 read of a US=1
    # user leaf (P=1, U=0 — the SMAP signature), record the fault and
    # resume at the probe's fixup label instead of halting. Scoped tight:
    # only fires while smap_probe_armed==1 AND the faulting RIP matches the
    # probe's load instruction, so it can never mask a genuine kernel bug.
    if smap_probe_armed == 1:
        if iret_frame[0] == cast[uint64](&smap_probe_fault_rip):
            smap_probe_faulted = 1
            iret_frame[0] = cast[uint64](&smap_probe_fixup)
            return cast[int64](1)

    # W^X Stage 1a: an instruction-fetch fault (I/D=1) on a PRESENT (P=1)
    # USER (U=1) page is a No-Execute violation — the task tried to
    # execute a page stamped NX (its stack / heap / anon mmap). This is a
    # hard protection error, NEVER a COW (which needs W=1) or a demand
    # page (which needs P=0): deliver SIGSEGV to the user. The discrimination
    # is explicit so an NX fetch fault is never mis-routed into the COW
    # copy path below (a fetch is a read, W=0, so it wouldn't be anyway —
    # but checking I/D up front makes the intent unambiguous).
    if (error_code & PF_ERR_P) != 0 and (error_code & PF_ERR_U) != 0 \
            and (error_code & PF_ERR_ID) != 0:
        # EXEC-PERM RECOVERY (apt 'Reading package lists' / gpgv-method NX
        # exec-fault): an instruction fetch on a PRESENT/USER/NX leaf that
        # a covering VMA legitimately grants PROT_EXEC is a STALE-NX leaf,
        # not a W^X violation — ld.so's reserve(PROT_READ,NX)+MAP_FIXED-
        # overlay(PROT_EXEC) idiom left a boundary/hole page NX. Mirror the
        # write-perm resolver: if ANY covering VMA grants exec, clear NX on
        # the leaf and re-run. Only if NO covering VMA grants exec (a real
        # wild-jump / W^X violation) do we fall through to SIGSEGV.
        nx_slot: uint64 = current_idx_get()
        nx_pml4: uint64 = task_pml4(cast[int32](nx_slot))
        if nx_pml4 != 0:
            ex_rc: int32 = vma_resolve_exec_perm_fault(nx_slot, nx_pml4,
                                                       fault_va)
            if ex_rc == 1:
                return cast[int64](1)
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[pf] NX exec-fault on user page va=%p -> SIGSEGV\n",
                fault_va)
        # DIAG: dump the covering VMA(s) + leaf PTE so we can see whether an
        # EXEC-permitting VMA had its leaf PTE re-stamped NX (the apt repro).
        vma_dbg_dump_cover(nx_slot, fault_va)
        # DIAG (Phase-5b): is fault_va a REGISTERED signal handler? Dump the
        # faulting task's handler table + in-flight-handler state.
        dbg_dump_sig_for_va(nx_slot, fault_va)
        # DIAG (Phase-5b): the fetch target is a .bss address that dash jumps
        # to during NORMAL execution (in_handler=0). Dump the user RSP + top
        # stack words: the topmost is the return address of whatever `call`ed
        # this bad pointer -> pins the dash call site. Non-faulting reads.
        _nx_urip: uint64 = iret_frame[0]
        _nx_ursp: uint64 = iret_frame[3]
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[nxstk] urip=%p ursp=%p\n", _nx_urip, _nx_ursp)
        _nx_i: uint64 = 0
        while _nx_i < 8:
            _nx_a: uint64 = _nx_ursp + _nx_i * 8
            _nx_phys: uint64 = uaccess_resolve(nx_pml4, _nx_a, 0)
            if _nx_phys != 0:
                printk_set_level(PRINTK_LEVEL_EMERG)
                printk2("[nxstk]   [%p]=%p\n", _nx_a,
                        cast[Ptr[uint64]](_nx_phys)[0])
            _nx_i = _nx_i + 1
        # CALLER RESOLUTION: ursp[0] is the return address of the `call` that
        # jumped to the bad pointer. Resolve its covering VMA (library base +
        # file_offset + path) so (retaddr - base + file_off) maps to a symbol
        # via objdump of the staged .so — pins the exact crashing call site.
        _nx_ret_phys: uint64 = uaccess_resolve(nx_pml4, _nx_ursp, 0)
        if _nx_ret_phys != 0:
            _nx_ret: uint64 = cast[Ptr[uint64]](_nx_ret_phys)[0]
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk1("[nxcaller] return-addr / call-site VMA for %p:\n", _nx_ret)
            vma_dbg_dump_cover(nx_slot, _nx_ret)
        # TLS / pointer-guard probe: glibc PTR_DEMANGLE's exit-handler fn
        # pointers with the guard at %fs:0x30. A deterministic-wrong fn (same
        # offset in every process) points at either a guard mismatch (fs_base
        # wrong at exit vs registration) or a mis-applied .fini_array RELATIVE
        # reloc. Dump fs_base, guard@fs+0x30, and .fini_array[0] (dash: should
        # be image_lo+0x4800; the R_X86_64_RELATIVE addend).
        _nx_fs: uint64 = task_fs_base(cast[int32](nx_slot))
        _nx_img: uint64 = task_image_lo(nx_slot)
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[nxtls] fs_base=%p image_lo=%p\n", _nx_fs, _nx_img)
        _nx_gp: uint64 = uaccess_resolve(nx_pml4, _nx_fs + 0x30, 0)
        if _nx_gp != 0:
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk1("[nxtls] guard@fs+0x30=%p\n",
                    cast[Ptr[uint64]](_nx_gp)[0])
        _nx_fa: uint64 = uaccess_resolve(nx_pml4, _nx_img + 0x1de38, 0)
        if _nx_fa != 0:
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk2("[nxtls] fini_array[0]@%p=%p\n", _nx_img + 0x1de38,
                    cast[Ptr[uint64]](_nx_fa)[0])
        # deliver_fault_sigsegv returns 1 if a user handler was staged
        # into the iret frame (the asm stub then iretq's into it); it
        # does NOT return on the default-terminate path.
        sd_rc: int32 = deliver_fault_sigsegv(iret_frame)
        if sd_rc == 1:
            return cast[int64](1)
        return cast[int64](0)

    if (error_code & PF_ERR_P) == 0:
        # Not-present page. Could be §142 demand paging OR a genuine
        # unmapped access. Check the current task's VMA list.
        #
        # KERNEL-mode not-present faults (PF_ERR_U == 0) are usually hard
        # bugs, BUT a kernel uaccess (copy_to_user / clear_user / memset on a
        # user buffer during a syscall) can legitimately land on a page of a
        # LAZILY-RESERVED anonymous mmap (PROT_NONE / MAP_NORESERVE / large
        # reservation demand VMA — see _u_mmap) that the owning userspace has
        # not touched yet. Linux faults such a page in regardless of the
        # access mode (handle_mm_fault runs on the address' mm, not the CPL);
        # mirror that: for a kernel-mode fault we still try swap-in + the
        # demand-zero path against the current task's VMAs. Only if the VA is
        # NOT covered by a swap/demand VMA (dpf_rc == 0 below) is it a genuine
        # kernel bug (bad kernel pointer, uaccess to a truly unmapped user
        # address) that halts. We do NOT run the userfaultfd hook for a
        # kernel-mode fault — a uffd-registered range hit by copy_to_user is a
        # rare -EFAULT case Linux handles in the uaccess wrapper, not modelled
        # here; the user-owned uffd path stays user-fault only.
        is_user_fault: int32 = 0
        if (error_code & PF_ERR_U) != 0:
            is_user_fault = 1
        slot: uint64 = current_idx_get()

        # ── task #112: SMP spurious not-present #PF guard ──────────────────
        # The CPU generated this fault (error_code P=0) from ITS OWN page-
        # table walk at the instant of the access. Under -smp 2 another CPU
        # sharing this mm (a CLONE_VM thread, a COW sibling, or a MAP_SHARED
        # peer) can resolve the very same page in the (interrupt-latency-
        # wide) window between that walk and the entry to this handler. By
        # now the LIVE leaf PTE may already be PRESENT. Re-read it: if it is
        # present AND satisfies the access (a write fault additionally needs
        # RW=1), the fault is SPURIOUS — x86 never negatively-caches a
        # translation, so simply re-running the faulting instruction reloads
        # the now-present PTE and succeeds. Without this, the code below
        # would allocate a *second* page for a demand VMA (benign leak) or,
        # for an EAGER (is_demand=0) VMA whose page a sibling just faulted
        # in, find dpf_rc==0 and deliver a FALSE SIGSEGV — the intermittent
        # `-smp 2` user coredump (#112). This can NEVER mask a genuine
        # unmapped access: it fires ONLY when the live tables already map the
        # page with adequate permission. Cheap: one read-only, boot-CR3-
        # bracketed walk, on the (cold) not-present fault path only. Mirrors
        # Linux's re-check of the pte under the page-table lock in
        # handle_pte_fault (a pte that became present under us => no-op).
        _spu_pte: uint64 = _vma_pte_lookup(pml4_phys, fault_va)
        if (_spu_pte & PF_ERR_P) != 0:
            _spu_ok: int32 = 0
            if (error_code & PF_ERR_W) == 0:
                _spu_ok = 1
            elif (_spu_pte & PF_ERR_W) != 0:
                # write fault, and the live leaf grants RW — spurious write.
                _spu_ok = 1
            if _spu_ok != 0:
                pf_spurious_recovered = pf_spurious_recovered + 1
                if _pf_spurious_logs < 8:
                    _pf_spurious_logs = _pf_spurious_logs + 1
                    printk_set_level(PRINTK_LEVEL_EMERG)
                    printk2("[pf] SPURIOUS not-present va=%p pte=%p\n",
                            fault_va, _spu_pte)
                    printk_set_level(PRINTK_LEVEL_EMERG)
                    printk2("[pf]   cpu=%d err=%p -> re-run (SMP race)\n",
                            get_cpu_id(), error_code)
                current_task_account_minor_fault()
                return cast[int64](1)

        # userfaultfd (USER-mode faults only): BEFORE any demand/swap resolution, ask whether this
        # not-present fault lands in a range registered with an active uffd for
        # the faulting task. If so, the USERSPACE handler owns the fault: a
        # uffd_msg has been enqueued and the page MUST stay not-present until
        # UFFDIO_COPY/ZEROPAGE resolves it. Returning 1 here re-runs the faulting
        # instruction — which, until the page is resolved, faults again and
        # re-blocks (the kernel has no preemption; a real userland handler runs
        # on another task and drains the uffd, resolving the page so the re-run
        # succeeds). This is the cheap no-op for the common case: a task with no
        # uffd range gets a quick 0 back and falls through to demand paging.
        uffd_w: int32 = 0
        if (error_code & PF_ERR_W) != 0:
            uffd_w = 1
        # F4 #449: dispatch through the registered hook rather than a
        # static linux_abi import. Null on a pure-native build (no uffd
        # ever registers) → fall through to demand/swap, exactly the
        # cheap no-op the comment above describes. USER-mode faults only —
        # a kernel copy_to_user into a uffd range is not modelled here.
        if is_user_fault != 0 and uffd_pagefault_hook_fn \
                != cast[Fn[int32, uint64, uint64, int32]](0):
            if uffd_pagefault_hook_fn(slot, fault_va, uffd_w) == 1:
                return cast[int64](1)
        # #167: a swapped-out anonymous page faults not-present with a
        # SWAP-ENTRY PTE (swap-marker bit set). Restore it from swap
        # BEFORE the demand-zero path — a demand VMA's evicted page must
        # come back with its real bytes, not a fresh zero page.
        swp_rc: int32 = vma_swap_in_fault(slot, pml4_phys, fault_va)
        if swp_rc == 1:
            # Swap-in required backing-store I/O — a MAJOR fault.
            current_task_account_major_fault()
            return cast[int64](1)
        if swp_rc < 0:
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk1("[pf] swap-in OOM va=%p\n", fault_va)
            return cast[int64](0)
        dpf_rc: int32 = vma_demand_fault(slot, pml4_phys, fault_va)
        if dpf_rc == 1:
            # Demand page populated without disk I/O — a MINOR fault.
            current_task_account_minor_fault()
            # Demand page populated — re-run the faulting instruction.
            return cast[int64](1)
        if dpf_rc < 0:
            # Demand fault but OOM (alloc_page failed / namespace-mem-cap /
            # cgroup memory.max denied the page-in). A USER-mode fault must
            # NOT halt the whole kernel — that defeats crash isolation and
            # lets one memory-hungry Linux-ABI process (Firefox demand-
            # faulting libxul under allocation pressure) take the box down.
            # Deliver SIGSEGV to the FAULTING TASK instead (Linux's OOM
            # response is to kill the process, not panic), exactly like the
            # unmapped-user-fault arm below; the kernel keeps scheduling
            # everything else. Only a KERNEL-mode demand OOM (a kernel
            # uaccess that could not page in) still halts with the
            # diagnostic, since that is an unrecoverable in-kernel state.
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk1("[pf] demand-page OOM va=%p\n", fault_va)
            if is_user_fault != 0 and (error_code & PF_ERR_U) != 0:
                printk_set_level(PRINTK_LEVEL_EMERG)
                printk0("[pf]   OOM in USER fault -> SIGSEGV (task killed, kernel survives)\n")
                og_rc: int32 = deliver_fault_sigsegv(iret_frame)
                if og_rc == 1:
                    return cast[int64](1)
            return cast[int64](0)
        # dpf_rc == 0: not a swap/demand VMA.
        #
        # KERNEL-mode (is_user_fault == 0): the faulting VA is NOT covered by
        # a demand/swap VMA, so this kernel access (bad kernel pointer, or a
        # uaccess to a genuinely unmapped user address) is a real bug — halt
        # with the trap-diag dump, exactly as the old PF_ERR_U==0 guard did.
        if is_user_fault == 0:
            return cast[int64](0)
        # USER-mode: genuine unmapped USER access (NULL deref, wild pointer).
        # This is the canonical user segfault. Deliver SIGSEGV to the FAULTING
        # TASK instead of halting the whole kernel — without this, any userland
        # process (notably a Track 4 UMDF driver host running a buggy vendor
        # .ko) that touches an unmapped address would take the box down,
        # defeating crash isolation.
        if (error_code & PF_ERR_U) != 0:
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk1("[pf] user fault on unmapped va=%p -> SIGSEGV\n",
                    fault_va)
            # #75 (B): the faulting CPL=3 RIP, so rip vs the DSO load biases
            # (printed by the loader at exec) names the exact instruction in
            # the crashing DSO — pins the non-deterministic Firefox wild-write
            # to a real call site. iret_frame[0] is the CPU-pushed faulting RIP.
            # printk_set_level is a one-shot latch (consumed by the preceding
            # printk1) — re-stamp EMERG so this line isn't gated to INFO.
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk1("[pf]   crash rip=%p\n", iret_frame[0])
            # task #112: stamp the faulting CPU + the LIVE leaf PTE so an
            # intermittent -smp 2 capture is classifiable at a glance:
            #   pte=0            -> table entry fully cleared (teardown /
            #                       reclaim / exec race zapped a live page)
            #   pte low-bit set  -> present now (would have been caught by
            #                       the spurious guard above; a leftover here
            #                       means it became present AFTER that check —
            #                       an even tighter race)
            #   otherwise        -> a swap-marker PTE vma_swap_in_fault failed
            #                       to recognise.
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk2("[pf]   cpu=%d livepte=%p\n", get_cpu_id(),
                    _vma_pte_lookup(pml4_phys, fault_va))
            # DIAG (spawn-heavy enter-linux SIGSEGV class): the dpf_rc==0
            # arm conflates TWO very different states — (a) NO VMA covers
            # fault_va (a genuine wild/NULL deref) and (b) an EAGER
            # (is_demand=0) mmap VMA *does* cover it but its leaf PTE is
            # not-present (a mapping/teardown bug, NOT a userspace bug).
            # vma_dbg_dump_cover prints the covering VMA(s) (list + BST),
            # each node's is_demand flag, and the leaf PTE for the address,
            # which classifies the two cases instantly the next time the
            # intermittent `ls | grep cat` busybox fault reproduces. It is a
            # read-only walk on the rare SIGSEGV path, so it adds no hot-path
            # cost. (See the busybox fault at mmap_base+0x400248 captured by
            # scripts/test_fork_eagain_pipeline.sh.)
            vma_dbg_dump_cover(slot, fault_va)
            ug_rc: int32 = deliver_fault_sigsegv(iret_frame)
            if ug_rc == 1:
                return cast[int64](1)
            return cast[int64](0)
        return cast[int64](0)

    if (error_code & PF_ERR_W) == 0:
        # Read fault on a PRESENT page — a protection violation on a read
        # (e.g. a CPL=3 read of a supervisor-only / kernel-half page via a
        # garbage user pointer; the `ls | grep echo` repro: a corrupted
        # user pointer reading cr2≈-8, a kernel address). Not COW, not
        # demand-page, not recoverable by the MM path.
        #
        # If the fault came from USER mode (U=1) this is a genuine user
        # segfault: deliver SIGSEGV to the FAULTING TASK (coredump + reap)
        # and keep the kernel scheduling other tasks — a userland process
        # touching a bad pointer must NEVER halt the whole OS. Previously
        # this branch returned 0 unconditionally and a normal user read
        # fault fell into the trap-diag print-and-halt, taking the box down.
        if (error_code & PF_ERR_U) != 0:
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk1("[pf] user read-prot fault va=%p -> SIGSEGV\n",
                    fault_va)
            rd_rc: int32 = deliver_fault_sigsegv(iret_frame)
            if rd_rc == 1:
                return cast[int64](1)
            return cast[int64](0)
        # U=0: a SUPERVISOR read protection fault. A genuine kernel bug
        # (reading a not-present-via-protection kernel mapping) — let the
        # diagnostic halt fire.
        return cast[int64](0)

    # P=1, W=1: potential COW write fault.
    rc: int32 = cow_handle_write_fault(pml4_phys, fault_va)
    if rc == 1:
        # COW copy resolved without disk I/O — a MINOR fault.
        current_task_account_minor_fault()
        # Resolved — resume the faulting instruction.
        return cast[int64](1)
    if rc < 0:
        # COW fault but resolution OOM'd. We can't safely resume; let
        # the diagnostic halt surface it.
        # TEMP_DEBUG_TRAP_VISIBILITY
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[pf] COW resolution failed (OOM) va=%p\n", fault_va)
        return cast[int64](0)
    # rc == 0: the PTE wasn't a COW PTE.
    #
    # STALE-RO RESOLVE (real-glibc keystone): a WRITE (W=1) to a PRESENT
    # (P=1), non-COW, read-only page may still be GENUINELY writable per
    # its VMA — the leaf PTE is merely stale-RO. This is exactly the
    # ld.so reserve(PROT_READ)+MAP_FIXED-overlay(PROT_WRITE) data/GOT
    # segment: the overlay's eager RW re-stamp can miss a page, so either
    #   * the KERNEL's mmap-fill (vfs_read / .bss memset) writes it at
    #     CPL=0  (err U=0 — the dpkg cr2=0x49c00000 halt), or
    #   * ld.so's first relocation writes it at CPL=3 (err U=1).
    # In BOTH cases the owning VMA grants PROT_WRITE, so re-stamp the leaf
    # RW and re-run the instruction. This runs REGARDLESS of U — a U=0
    # supervisor write to a writable-per-VMA user page is resolved here
    # instead of halting the box (robustness sub-bug). Only if the VMA is
    # genuinely non-writable does vma_resolve_write_perm_fault return 0,
    # falling through to the SIGSEGV (U=1) / halt (U=0) below.
    wpf_slot: uint64 = current_idx_get()
    wpf_rc: int32 = vma_resolve_write_perm_fault(wpf_slot, pml4_phys,
                                                 fault_va)
    if wpf_rc == 1:
        current_task_account_minor_fault()
        return cast[int64](1)

    # W^X Stage 1b: a USER (U=1) WRITE (W=1) to a PRESENT (P=1),
    # non-COW, genuinely-non-writable page is a permission violation — the
    # task tried to write its own read-only .text / .rodata (or any other
    # genuinely PROT_READ page). The VMA resolver above already ruled out
    # the recoverable stale-RO case, so this is a hard W^X violation:
    # deliver SIGSEGV to the user instead of halting the whole kernel.
    if (error_code & PF_ERR_U) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[pf] user write-perm fault va=%p -> SIGSEGV\n",
                fault_va)
        # Permanent forensics. The page is PRESENT (P=1) but a CPL=3 write
        # faulted: it is EITHER read-only (PTE RW=0 — a real W^X .text/
        # .rodata violation) OR supervisor-only (PTE US=0 — e.g. a stray
        # raw low-identity mapping the CR4.SMAP US=0-restamp made
        # kernel-only). Dump the resolved leaf PTE so the two cases are
        # distinguishable on sight: RW=bit1, US=bit2. (The ld.so libc-mmap
        # keystone hunt turned on exactly this datum — pte=...063 = RW=1
        # US=0 proved it was a US=0 identity page, NOT an RO page.)
        _dbg_pte_slot: uint64 = _cow_resolve_pte_slot(pml4_phys, fault_va)
        printk_set_level(PRINTK_LEVEL_EMERG)
        if _dbg_pte_slot == 0:
            printk0("[pf]   no leaf PTE (identity-huge or unmapped)\n")
        else:
            printk1("[pf]   pte=%p (RW=bit1 US=bit2)\n",
                    cast[Ptr[uint64]](_dbg_pte_slot)[0])
        # The faulting RIP + raw error code identify WHO issued the
        # write (rip - image bias = instruction offset inside ld.so /
        # the app — directly objdump-able on the host).
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[pf]   rip=%p err=%p\n", iret_frame[0], error_code)
        # WPERM-DIAG (apt keystone): which tracked region owns this VA?
        _wp_slot: uint64 = current_idx_get()
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[pf]   img=[%p,%p)\n",
                task_image_lo(_wp_slot), task_image_hi(_wp_slot))
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[pf]   interp=[%p,%p)\n",
                task_interp_lo(_wp_slot), task_interp_hi(_wp_slot))
        # RIP-RESOLVE (Firefox WebRender NULL-deref hunt): the faulting RIP
        # lives in a dlopen'd DSO (libxul et al.) whose base is unknown from
        # img=/interp= alone. Dump the VMA that COVERS the RIP — it carries
        # the mapping [base,end), file_offset, and (fd permitting) the file
        # path. rip - base + file_offset = file offset -> addr2line on the
        # staged .so pins the exact function that NULL-wrote.
        vma_dbg_dump_cover(_wp_slot, iret_frame[0])
        # WPERM-STACK (rsp corruption / stack-overflow hunt): a `push` that
        # write-faults at va~0 means %rsp is near-null on function entry —
        # either a runaway-recursion stack overflow OR a clobbered rsp. Dump
        # the user rsp + scan 24 words UPWARD (toward higher addresses, the
        # already-written frames): a stack overflow shows the SAME return
        # address repeating (recursion), a clobber shows one bad rsp value.
        _wp_rsp: uint64 = iret_frame[3]
        _wp_pml4: uint64 = task_pml4(cast[int32](_wp_slot))
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[wpstk] user rsp=%p (scan up)\n", _wp_rsp)
        _wp_j: uint64 = 0
        while _wp_j < 24:
            _wp_a: uint64 = _wp_rsp + _wp_j * 8
            _wp_ph: uint64 = uaccess_resolve(_wp_pml4, _wp_a, 0)
            if _wp_ph != 0:
                printk_set_level(PRINTK_LEVEL_EMERG)
                printk2("[wpstk]   [%p]=%p\n", _wp_a,
                        cast[Ptr[uint64]](_wp_ph)[0])
            _wp_j = _wp_j + 1
        sg_rc: int32 = deliver_fault_sigsegv(iret_frame)
        if sg_rc == 1:
            return cast[int64](1)
        return cast[int64](0)
    # U=0: a SUPERVISOR write to a present, non-COW, genuinely-RO page.
    # If cr2 is in the USER address range this is the kernel writing on a
    # user task's behalf (uaccess / mmap-fill) to a page the task's VMA
    # does not grant write to — a per-process fault, NOT a kernel bug.
    # Robustness mandate: never halt the whole box on a user-range cr2.
    # The kernel write cannot complete, so the operation it was servicing
    # must fail; deliver SIGSEGV to the faulting task and let the
    # scheduler continue. A cr2 in the KERNEL half (a true kernel
    # null-deref / corruption) still falls through to the diagnostic halt.
    if fault_va < PF_USER_VA_LIMIT:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[pf] kernel write to RO user page va=%p -> SIGSEGV\n",
                fault_va)
        # v3g SMAP-diag: dump the leaf PTE + faulting RIP. If the PTE shows
        # RW=1 US=1 (bits 1 and 2 set) this is NOT a genuine RO page — it is
        # a SMAP fault on an unbracketed kernel CPL=0 write to a user page,
        # and rip names the writer to bracket.
        _v3g_slot: uint64 = _cow_resolve_pte_slot(pml4_phys, fault_va)
        printk_set_level(PRINTK_LEVEL_EMERG)
        if _v3g_slot != 0:
            printk1("[pf]   pte=%p (RW=bit1 US=bit2)\n",
                    cast[Ptr[uint64]](_v3g_slot)[0])
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[pf]   rip=%p err=%p\n", iret_frame[0], error_code)
        # SMAP-diag: the faulting RIP is inside memcpy/memset; the CALLER
        # (the unbracketed kernel writer to bracket) is at [rsp] / nearby.
        # iret_frame[3] is the CPL0 faulting RSP (pushed in long mode).
        _kg_rsp: uint64 = iret_frame[3]
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[pf]   rsp=%p ret0=%p\n", _kg_rsp,
                cast[Ptr[uint64]](_kg_rsp)[0])
        printk2("[pf]   ret1=%p ret2=%p\n",
                cast[Ptr[uint64]](_kg_rsp)[1],
                cast[Ptr[uint64]](_kg_rsp)[2])
        kg_rc: int32 = deliver_fault_sigsegv(iret_frame)
        if kg_rc == 1:
            return cast[int64](1)
        return cast[int64](0)
    return cast[int64](0)


def do_gp_fault(error_code: uint64, iret_frame: Ptr[uint64]) -> int64:
    # Productive #GP (vector 13) handler — robustness mandate sibling of
    # do_page_fault. A USERSPACE (CPL=3) general-protection fault must
    # NEVER halt the kernel: deliver SIGSEGV (+coredump+reap) to the
    # faulting task and keep scheduling, exactly like the CPL3 #PF arms.
    #
    # Called from trap_diag_stub_0d (arch/x86/kernel/trap_asm.S) with the
    # CPU-pushed error code and the address of the CPU iret frame
    # (ascending quads: RIP, CS, RFLAGS, RSP_user, SS). Return value
    # drives the stub:
    #   1  -> handled (a user SIGSEGV handler was staged into the iret
    #         frame, OR the task was terminated inline and never returns);
    #         the stub iretq's.
    #   0  -> NOT a user fault (CPL=0 — a genuine kernel #GP: bad segment
    #         load, non-canonical kernel pointer, iretq with a bad
    #         selector); fall through to common_trap_diag's print-and-halt.
    #
    # The faulting privilege level is the low 2 bits of the saved CS
    # (iret_frame[1]). A real Linux-namespace user process that jumps to a
    # non-canonical address — the forked apt-worker `jmp *r11` with a
    # garbage GOT-resolved r11 (STATUS T24) — raises #GP from CPL=3 here.
    saved_cs: uint64 = iret_frame[1]
    cpl: uint64 = saved_cs & cast[uint64](3)
    if cpl != cast[uint64](3):
        # CPL=0: a genuine kernel-mode #GP. Let the diagnostic halt fire —
        # masking a kernel #GP would hide real kernel bugs.
        return cast[int64](0)

    # CPL=3 user #GP. Forensics FIRST (the iret frame is still intact),
    # then deliver SIGSEGV. The faulting RIP - image bias names the
    # offending instruction (objdump-able), and the raw error code's
    # selector index (if non-zero) identifies a segment-related #GP vs a
    # non-canonical-operand #GP (err=0, the apt `jmp *r11` shape).
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[gp] user #GP rip=%p err=%p -> SIGSEGV\n",
            iret_frame[0], error_code)
    _gp_slot: uint64 = current_idx_get()
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[gp]   img=[%p,%p)\n",
            task_image_lo(_gp_slot), task_image_hi(_gp_slot))
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[gp]   interp=[%p,%p)\n",
            task_interp_lo(_gp_slot), task_interp_hi(_gp_slot))
    # Dump the 16 instruction bytes at the faulting RIP via the SMAP-safe
    # bracketed user accessor — the page is US=1 user text and a raw
    # CPL=0 read would itself #PF under CR4.SMAP=1 (the diag SMAP-fault
    # the user reported). _ua_stac/_ua_clac set RFLAGS.AC so the loads are
    # permitted; they are no-ops under CR4.SMAP=0. The RIP page is present
    # (the CPU fetched and executed the faulting instruction — a #GP, not
    # an instruction-fetch #PF — so the bytes are guaranteed mapped).
    _gp_rip: uint64 = iret_frame[0]
    _ua_stac()
    _gp_code0: uint64 = cast[Ptr[uint64]](_gp_rip)[0]
    _gp_code1: uint64 = cast[Ptr[uint64]](_gp_rip + cast[uint64](8))[0]
    _ua_clac()
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[gp]   code@rip=%p %p\n", _gp_code0, _gp_code1)

    gp_rc: int32 = deliver_fault_sigsegv(iret_frame)
    if gp_rc == 1:
        return cast[int64](1)
    return cast[int64](0)


def do_trap_diag_5(vec: uint64, err: uint64, rip: uint64,
                   cs: uint64, rflags: uint64):
    # Called from common_trap_diag in trap_asm.S on a dedicated diag
    # call stack. Prints the first chunk: vec / err / rip / cs / flags.
    # printk supports at most 2 args per call, so we split across three
    # printk2 + a leading printk0 newline so the diag block stands out
    # in the serial log.
    # TEMP_DEBUG_TRAP_VISIBILITY: stamp EMERG on each call. printk_set_
    # level() is a one-shot latch (drivers/tty/serial/early_8250.ad:
    # console_begin_msg consumes it), so every individual printk0/1/2
    # needs its own pre-call latch.
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("\n")
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[trap-diag] vec=%p err=%p\n", vec, err)
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[trap-diag] rip=%p cs=%p\n",  rip, cs)
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("[trap-diag] flags=%p\n",      rflags)
    if vec == cast[uint64](14):
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[trap-diag] cr2=%p\n", read_cr2())
        # Kstack-corruption forensics (#410 live-root intermittent #PF):
        # identify the current task and page-walk the faulting address
        # under BOTH the live CR3 and the pristine boot CR3. Divergence
        # (entry present in boot, absent/different in live) proves the
        # task's private tables were modified out from under it; garbage
        # entries prove a freed-and-reused table page.
        _pf_va: uint64 = read_cr2()
        _pf_cur: uint64 = current_idx_get()
        _pf_slot: int32 = cast[int32](_pf_cur)
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[trap-diag] cur-slot=%d kstack_top=%p\n",
                _pf_cur, task_kstack_top(_pf_slot))
        _pf_live_cr3: uint64 = read_cr3()
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[trap-diag] live cr3=%p task cr3=%p\n",
                _pf_live_cr3, task_pml4(_pf_slot))
        # Run both walks UNDER the pristine boot CR3: the walk reads
        # table pages as raw physical addresses, and the live CR3's
        # identity map may be exactly what's broken (re-faulting inside
        # the diagnostic). The boot CR3 maps all of low RAM identity, and
        # walking the live CR3's STRUCTURES only needs its physical table
        # pages readable. IRQs are already off (interrupt gate).
        _pf_boot_cr3: uint64 = cow_boot_cr3()
        if _pf_boot_cr3 != 0:
            load_cr3(_pf_boot_cr3)
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[trap-diag] walk cr2 under LIVE cr3:\n")
        trap_diag_pte_walk(_pf_live_cr3, _pf_va)
        if _pf_boot_cr3 != 0 and _pf_boot_cr3 != _pf_live_cr3:
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk0("[trap-diag] walk cr2 under BOOT cr3:\n")
            trap_diag_pte_walk(_pf_boot_cr3, _pf_va)
        if _pf_boot_cr3 != 0:
            load_cr3(_pf_live_cr3)
    # Dump the raw instruction bytes at the faulting RIP. For a #UD
    # (vec 6) the CPU already fetched the offending opcode, so the rip
    # page is guaranteed present and readable from this CR3 (we have
    # NOT switched address spaces); the page is a kernel-text or
    # user-text frame and a direct CPL=0 read is safe under SMAP only
    # for kernel text. For user text the diag-side deref is brief and
    # historically tolerated — if a future SMAP audit flags this, wrap
    # the two qword loads with _ua_stac()/_ua_clac(). For a #PF (vec 14)
    # an instruction-fetch
    # fault means the rip page is NOT present — reading it would re-fault
    # inside the diagnostic — and a #DF (vec 8) leaves an unreliable
    # frame, so we skip both. The two u64s give 16 bytes, enough to
    # identify the rejected encoding (e.g. a 32-bit-only i386 opcode that
    # decodes invalid in 64-bit long mode).
    if (vec != cast[uint64](14)) and (vec != cast[uint64](8)):
        # SMAP v3e: if rip lives in a US=1 user-text page (CPL=3 fault that
        # reached this diag), the two CPL=0 loads below would #PF under
        # CR4.SMAP=1 unless we set AC. Bracket unconditionally; STAC/CLAC
        # are no-ops when CR4.SMAP=0 (RFLAGS.AC toggles, no enforcement).
        # Kernel-text rip is US=0 so AC has no effect there either.
        _ua_stac()
        code0: uint64 = cast[Ptr[uint64]](rip)[0]
        code1: uint64 = cast[Ptr[uint64]](rip + cast[uint64](8))[0]
        _ua_clac()
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[trap-diag] code@rip=%p %p\n", code0, code1)


def do_trap_diag_2(rsp: uint64, ss: uint64):
    # Second chunk: rsp_user / ss. Called immediately after
    # do_trap_diag_5 returns. Stack-switch already done in asm.
    # TEMP_DEBUG_TRAP_VISIBILITY: stamp EMERG on each call (one-shot).
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[trap-diag] rsp=%p ss=%p\n", rsp, ss)
    # IRET-FRAME-DIAG: dump 5 quads at rsp. For a #GP on `iretq`, rsp
    # points at the iret frame [RIP, CS, RFLAGS, RSP, SS]; a bad CS/SS
    # selector here is the err-code source. Reveals which slot is wrong.
    fd_i: uint64 = 0
    while fd_i < 5:
        fd_v: uint64 = cast[Ptr[uint64]](rsp + fd_i * cast[uint64](8))[0]
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[trap-diag] frm[%d]=%p\n", fd_i, fd_v)
        fd_i = fd_i + 1
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[trap-diag] halting (one-shot diag, no recovery).\n")
    # The whole point of this module: persist the diagnostic dump (and
    # everything before it) to the ESP so the user can read why the box
    # died after re-plugging the boot stick. No-op if no LOG.TXT extent
    # was armed; self-guards against reentrancy.
    esp_log_flush()


def trap_diag_install():
    # Wholesale-overwrite the existing IDT entries for the four
    # diagnostic vectors. idt_init() ran earlier and pointed these at
    # the simpler trap_stub_N → do_trap path; we win because we run
    # later. Vector 8 (#DF) gets IST=1; the others keep IST=0 (use
    # the interrupted stack).
    #
    # Step 1: pre-load IST1 in the TSS with our scratch stack top.
    #         tss_init() in init/main.ad ran earlier so the TSS is
    #         already registered with TR; we only need to fill in
    #         the IST1 slot.
    ist_top: uint64 = get_trap_diag_ist_stack_top()
    tss_set_ist1(ist_top)
    printk1("[trap-diag] install: IST1 stack top=%p\n", ist_top)

    # Step 2: rewrite the IDT gates. Vector 8 uses IST=1; the rest
    #         use IST=0 (interrupted stack). M16.155-cr0-probe adds
    #         vectors 7 (#NM), 16 (#MF), 19 (#XF) — the FPU/SIMD
    #         faults a first user instruction could raise if CR0.TS
    #         or CR0.EM masks an FP op. Same dedicated IST1 stack
    #         already exists for #DF; the new vectors run on the
    #         interrupted stack which is fine here (no triple-fault
    #         cascade risk, and we want the interrupted RIP/CS/RSP
    #         in the iret frame, which is exactly what we get from
    #         IST=0 entries).
    h6: uint64 = get_trap_diag_stub(6)
    idt_set_gate_with_ist(6, h6, 0)

    h7: uint64 = get_trap_diag_stub(7)
    idt_set_gate_with_ist(7, h7, 0)

    h8: uint64 = get_trap_diag_stub(8)
    idt_set_gate_with_ist(8, h8, 1)

    h13: uint64 = get_trap_diag_stub(13)
    idt_set_gate_with_ist(13, h13, 0)

    h14: uint64 = get_trap_diag_stub(14)
    idt_set_gate_with_ist(14, h14, 0)

    h16: uint64 = get_trap_diag_stub(16)
    idt_set_gate_with_ist(16, h16, 0)

    h19: uint64 = get_trap_diag_stub(19)
    idt_set_gate_with_ist(19, h19, 0)

    printk0("[trap-diag] install: IDT vectors 0x06/0x07/0x08/0x0d/0x0e/0x10/0x13 overridden\n")


def trap_pf_install():
    # Install the PRODUCTIVE page-fault handler (vector 14) UNCONDITIONALLY.
    #
    # do_page_fault (the vector-14 trap-diag stub's C-side) is NOT a
    # diagnostic: it resolves COW write faults — which EVERY fork()/rfork()
    # depends on — plus §142 demand-paged mmap, swap-in, NX exec-fault
    # SIGSEGV, and W^X write-fault SIGSEGV. It is core runtime machinery.
    #
    # It was previously installed ONLY inside trap_diag_install(), which
    # init/main.ad gates behind the /etc/run-selftests developer marker.
    # On a production installer/installed boot (run_selftests == 0) that
    # gate is closed, so vector 14 stayed pointed at idt_init()'s
    # halt-on-fault do_trap stub. The first rfork child write then took a
    # COW #PF (err=0x07, P=1/W=1/U=1), found no productive handler, and
    # halted the whole kernel ("TRAP: vector 0x0e" at the first
    # `spawn detached` in rc.boot.full). Dev/-kernel boots set
    # run_selftests=1, which is why the fast repro masked this.
    #
    # Splitting vector 14 out makes the COW/demand-page/W^X handler always
    # live. Vector 14 uses IST=0 (the interrupted stack), so it needs no
    # TSS IST slot — unlike #DF (vector 8), which stays in the dev-gated
    # trap_diag_install(). The vector-14 trap-diag stub still falls through
    # to common_trap_diag's print+ESP-log+halt when do_page_fault returns 0
    # (a genuine unrecoverable fault), so we lose no diagnostic coverage.
    h14: uint64 = get_trap_diag_stub(14)
    idt_set_gate_with_ist(14, h14, 0)
    printk0("[trap-pf] productive #PF handler installed (vector 0x0e)\n")


def trap_gp_install():
    # Install the PRODUCTIVE #GP handler (vector 13) UNCONDITIONALLY —
    # robustness mandate sibling of trap_pf_install().
    #
    # trap_diag_stub_0d now routes a CPL=3 user general-protection fault
    # through do_gp_fault → deliver_fault_sigsegv (SIGSEGV + coredump +
    # reap) instead of halting the whole kernel; a CPL=0 kernel #GP still
    # falls through to the print-and-halt diagnostic. Like vector 14 this
    # is CORE runtime machinery: a Linux-namespace user process (the
    # forked apt-worker `jmp *r11` with a non-canonical GOT-resolved
    # operand, STATUS T24) must never take the box down.
    #
    # It must be installed on EVERY boot, not just the dev-gated
    # trap_diag_install() path — otherwise a production installer/installed
    # boot (run_selftests == 0) leaves vector 13 on idt_init()'s
    # halt-on-fault do_trap stub, exactly the regression trap_pf_install()
    # was split out to prevent for vector 14. Vector 13 uses IST=0 (the
    # interrupted stack); it needs no TSS IST slot.
    h13: uint64 = get_trap_diag_stub(13)
    idt_set_gate_with_ist(13, h13, 0)
    printk0("[trap-gp] productive #GP handler installed (vector 0x0d)\n")

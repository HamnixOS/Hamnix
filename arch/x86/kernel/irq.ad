# arch/x86/kernel/irq.ad
#
# Mirrors the parts of arch/x86/kernel/irq.c that wire vector → IRQ →
# handler. Up through M16.5 the dispatch table was hard-coded (one
# entry, for the timer). M16.112 generalises it: a 256-slot
# `irq_handlers` table keyed by CPU vector number, populated via
# `register_irq_handler(vec, fn)`. The timer is still hard-coded so
# nothing breaks if a future agent rearranges init ordering.
#
# Called from arch/x86/kernel/irq_asm.S:common_irq with the CPU
# vector number in %rdi (SysV ABI). Handlers MUST NOT send the EOI
# themselves — do_irq does that exactly once at the end via
# lapic_send_eoi(), AFTER the per-vector handler returns. Missing
# the EOI is the canonical "no more interrupts ever again" bug
# (the in-service register stays set, the LAPIC refuses to deliver
# anything else of equal or lower priority).

from arch.x86.kernel.time import timer_interrupt
from arch.x86.kernel.i8259 import i8259_send_eoi
from arch.x86.kernel.apic import (
    lapic_send_eoi, ioapic_redirect_isa, RESCHED_IPI_VECTOR,
    STOP_IPI_VECTOR, ioapic_mask_vector,
)

# Park-this-CPU helper for the STOP-IPI handler (mask IRQs, then HLT loop).
extern def local_irq_disable()
from kernel.printk.printk import printk0, printk1
from kernel.sched.core import (
    signal_post_to_foreground, SIGINT, SIGTSTP, console_input_wake,
)
from drivers.tty.serial.early_8250 import (
    uart_rx_irq_service, uart_rx_irq_enable_ier,
    UART_RX_IRQ_GSI, UART_RX_IRQ_VECTOR,
)

TIMER_VECTOR: uint64 = 32   # IRQ 0 after the 0x20 PIC remap

# Per-vector handler table. Slot N holds a first-class function
# pointer (`Fn[None]` — `void (*)(void)`) to the handler registered
# for CPU vector N. A null slot means "unregistered" — do_irq falls
# back to the legacy 8259 EOI path so we don't lose IRQ delivery on
# a misroute.
#
# 256 slots covers the full x86 IDT. The handler is invoked directly
# through the function pointer (`irq_handlers[vector]()`); no asm
# trampoline is involved.
irq_handlers: Array[256, Fn[None]]

# Diagnostic counter: total IRQs dispatched through the registered
# handler path (excludes timer). Useful for tests that want to assert
# "an IRQ actually fired" without inspecting the device-specific
# state.
irq_dispatch_count: uint64 = 0

# Per-vector dispatch counter: slot N holds the number of times CPU
# vector N has entered do_irq(), INCLUDING the timer (vector 32). This
# is independent of irq_dispatch_count above, which deliberately keeps
# its handler-only semantics (timer excluded). The per-vector array
# backs /proc/stat's per-IRQ columns (vectors 32..47 -> ISA IRQ 0..15)
# in sys/src/9/port/devstat.ad. A flat Array of a scalar is legal at
# module scope (same as irq_handlers above).
irq_per_vector_count: Array[256, uint64]

# Spurious-IRQ storm guard (mirrors Linux's "Disabling IRQ #N: nobody
# cared" self-defense). A level-triggered IOAPIC line that re-asserts
# faster than its handler can quiesce it will re-enter do_irq forever,
# starving every lower-priority vector (the timer included) and wedging
# the box. This is a real-silicon hazard the VMs never reproduce: on the
# NUC, enabling ACPI mode (the SMI_CMD handoff QEMU skips because it
# boots with SCI_EN already set) reshapes legacy ISA IRQ delivery, and
# the i8042 keyboard pin (vector 0x46) — still programmed edge/active-
# high from before the handoff — gets delivered as a stuck level line.
#
# We detect a storm structurally, without a clock: in normal operation
# the timer (vector 32) interleaves with every device IRQ, so the same
# device vector can never enter do_irq hundreds of thousands of times
# back-to-back with no other vector in between. A long unbroken run of
# one device vector therefore means its line is stuck. When the run
# crosses IRQ_STORM_LIMIT we mask that vector's IOAPIC pin(s) — the only
# way to break a self-re-asserting level line — and let the box recover.
_irq_storm_last_vec: uint64 = 0xFFFFFFFF
_irq_storm_run:      uint64 = 0
IRQ_STORM_LIMIT:     uint64 = 100000


def register_irq_handler(vector: uint64, handler: Fn[None]):
    # Install a handler for CPU vector `vector`. Caller is responsible
    # for arranging delivery (IDT gate + IOAPIC redirection / MSI-X).
    # Re-registering overwrites without warning — there's exactly one
    # consumer per vector in this kernel's lifetime.
    if vector >= 256:
        printk1("[irq] register_irq_handler: vector %d out of range\n",
                vector)
        return
    irq_handlers[vector] = handler
    printk1("[irq] handler registered for vector 0x%x\n", vector)


def irq_get_dispatch_count() -> uint64:
    return irq_dispatch_count


def irq_vector_count(vector: uint64) -> uint64:
    # Per-vector dispatch count (timer-inclusive). Bounds-checked: out
    # of range returns 0. Backs /proc/stat's per-IRQ columns.
    if vector < 256:
        return irq_per_vector_count[vector]
    return 0


def do_irq(vector: uint64, interrupted_cs: uint64):
    # `interrupted_cs` is the CS selector the CPU pushed in the iret
    # frame — i.e. the privilege level of the code the IRQ interrupted.
    # (interrupted_cs & 3) == 3 means ring 3 (userland). The timer
    # preemption gate uses it to decide whether a context switch is
    # safe (see timer_interrupt()).
    #
    # 0) Bump this vector's own dispatch slot on EVERY entry — including
    #    the timer path below and the spurious/unhandled tail. This is
    #    independent of irq_dispatch_count (which stays handler-only,
    #    timer-excluded). Backs /proc/stat's per-IRQ columns.
    if vector < 256:
        irq_per_vector_count[vector] = irq_per_vector_count[vector] + 1

    # 0b) Storm guard. Count consecutive entries of the SAME vector; any
    #     different vector (the timer interleaves constantly in healthy
    #     operation) resets the run. The timer (vector 32) and the IPI
    #     band (>= 0xF0: TLB-flush 0xF0, reschedule 0xF2, stop 0xF3) are
    #     never candidates — they're edge-delivered and self-clearing, and
    #     masking them would be catastrophic. Only a stuck device line in
    #     the IOAPIC band (33..0xEF) can trip this. When it does, mask its
    #     IOAPIC pin(s) so the self-re-asserting level line stops firing.
    if vector == _irq_storm_last_vec:
        _irq_storm_run = _irq_storm_run + 1
    else:
        _irq_storm_last_vec = vector
        _irq_storm_run = 1
    if _irq_storm_run > IRQ_STORM_LIMIT and vector != TIMER_VECTOR \
       and vector > 32 and vector < 0xF0:
        n_masked: uint32 = ioapic_mask_vector(cast[uint32](vector))
        printk2("[irq] STORM on vec=%d: re-fired %d times back-to-back\n",
                vector, _irq_storm_run)
        printk1("[irq]   nobody quiesced the line -> masked %d IOAPIC pin(s)\n",
                cast[uint64](n_masked))
        _irq_storm_run = 0
        lapic_send_eoi()
        return

    # 1) Timer is hard-wired (we don't want a registration race during
    #    early boot to silently lose ticks).
    if vector == TIMER_VECTOR:
        # timer_interrupt() owns the timer EOI: it MUST send the EOI
        # itself BEFORE it may context-switch away, otherwise the
        # LAPIC in-service bit stays set across the switch and the
        # task we switch INTO never receives another timer IRQ. So
        # do_irq deliberately does NOT EOI here — that would either
        # be a redundant second EOI (no switch) or, worse, a deferred
        # EOI that only lands when the preempted task is rescheduled.
        timer_interrupt(interrupted_cs)
        return

    # 2) Look up the registered handler. If present, call it then EOI.
    #    The handler is a first-class `Fn[None]` value; invoke it
    #    directly through the dispatch table.
    if vector < 256:
        h: Fn[None] = irq_handlers[vector]
        if h != cast[Fn[None]](0):
            irq_dispatch_count = irq_dispatch_count + 1
            h()
            lapic_send_eoi()
            return

    # 3) Spurious / unhandled. Still EOI to the LAPIC so the in-service
    #    register clears; otherwise no further IRQs of any kind would
    #    fire. The legacy 8259 EOI is a no-op now (PIC is masked) but
    #    we keep the call so the path stays correct if PIC ever comes
    #    back.
    if vector >= 32 and vector < 48:
        i8259_send_eoi(cast[int32](vector - 32))
    lapic_send_eoi()


# --- M16.x: interrupt-driven COM1 UART RX -------------------------
#
# The 16550 RX hardware FIFO is only 16 bytes and, before this
# milestone, was drained solely by the 100 Hz timer ISR. A host that
# pushed a whole command line in one burst (a test `printf`, a
# terminal paste, a fast typist) could overflow the 16-byte FIFO
# between two timer ticks, and any input arriving during the long
# CPU-interrupts-masked boot window was lost past the 16th byte —
# the `busybox ls /etc` -> `ybox ls /etc` character-drop flake.
#
# uart_rx_irq() is the IDT-vector-36 handler: it drains the hardware
# FIFO into the 256-byte software ring the instant a byte arrives,
# so the consumer's timing no longer matters. It also raises SIGINT
# on a Ctrl-C, mirroring the timer ISR — the IRQ now reaches the
# hardware FIFO first, so the Ctrl-C interception MUST live here too
# or it would be silently swallowed. The handler is a plain Fn[None];
# do_irq() invokes it through the irq_handlers table and sends the
# single LAPIC EOI afterwards.
def uart_rx_irq():
    # Bitmask: bit0 = Ctrl-C (SIGINT), bit1 = Ctrl-Z (SIGTSTP). Route
    # each to the terminal's foreground process group (job control).
    ctl: int32 = uart_rx_irq_service()
    if (ctl & 1) != 0:
        signal_post_to_foreground(SIGINT)
    if (ctl & 2) != 0:
        signal_post_to_foreground(SIGTSTP)
    # Event-driven: a byte just landed in the software RX FIFO. Wake any
    # task blocked on the console input wait queue (FD_STDIN_MARK /
    # devcons_read) so it consumes the byte promptly instead of waiting
    # for the next 100 Hz timer-tick re-poll. This is the IRQ-driven wake
    # that makes interactive input snappy and decouples latency from HZ.
    console_input_wake()


# --- RESCHEDULE IPI handler (vector 0xF2 / 242) -------------------
#
# Linux's reschedule_interrupt(): the entire purpose of this IPI is to
# make a HLTed idle CPU fall out of HLT and re-run its idle loop, which
# re-scans the shared runqueue for the task that was just made runnable.
# Taking the interrupt has ALREADY achieved that by the time we run, so
# the handler body has nothing to do. do_irq() sends the single LAPIC
# EOI after we return (do NOT EOI here — that would be a double EOI).
#
# Counted by irq_dispatch_count via the do_irq registered-handler path,
# which is how a test can assert the wakeup IPI actually fired.
resched_ipi_count: uint64 = 0


def resched_ipi():
    resched_ipi_count = resched_ipi_count + 1


def resched_ipi_get_count() -> uint64:
    return resched_ipi_count


def enable_resched_ipi():
    # Register the reschedule-IPI handler (vector 0xF2 = 242). The IDT
    # gate for 242 is wired in idt_init() (idt_set_gate(242, &irq_stub_242));
    # this just installs the do_irq dispatch target. Called once from
    # start_kernel after idt_init()/apic_init(), alongside module_map_tlb_init.
    register_irq_handler(cast[uint64](RESCHED_IPI_VECTOR), resched_ipi)
    printk0("[irq] reschedule IPI registered (vector 0xF2)\n")


# --- CPU-STOP IPI handler (vector 0xF3 / 243) --------------------------
#
# Linux's stop_this_cpu() analogue: the BSP broadcasts this IPI from the
# poweroff / reboot path (halt_other_cpus() in arch/x86/kernel/apic.ad) to
# park EVERY other CPU permanently BEFORE committing the ACPI S5 / reset
# write. Each AP that takes this IPI bumps the shared ack counter ONCE (so
# halt_other_cpus() on the BSP can log how many cores parked) and then masks
# interrupts and HLTs forever — it never returns to do_irq, never sends an
# EOI, never re-enters the scheduler. That is exactly the point: after this
# the AP cannot wake or spin no matter what the platform does with power, so
# a NUC whose S5 leaves the board energised stays cool instead of pegging
# the fan.
#
# The counter is a single aligned 8-byte location; on x86 a `+= 1` store is
# atomic w.r.t. a concurrent aligned read, and the worst case (two APs
# racing the read-modify-write) only undercounts the ack log — it never
# affects correctness of the halt itself, which each AP performs
# independently below.
stop_ipi_ack_count: uint64 = 0


def stop_ipi_get_ack_count() -> uint64:
    return stop_ipi_ack_count


def stop_ipi():
    # Runs on an AP that received the STOP IPI. Acknowledge, then wedge.
    stop_ipi_ack_count = stop_ipi_ack_count + 1
    local_irq_disable()
    while True:
        asm_volatile("hlt")


def enable_stop_ipi():
    # Register the CPU-stop IPI handler (vector 0xF3 = 243). The IDT gate
    # for 243 is wired in idt_init() (idt_set_gate(243, &irq_stub_243));
    # this installs the do_irq dispatch target. Called once from start_kernel
    # alongside enable_resched_ipi().
    register_irq_handler(cast[uint64](STOP_IPI_VECTOR), stop_ipi)
    printk0("[irq] CPU-stop IPI registered (vector 0xF3)\n")


def enable_uart_rx_irq():
    # Wire COM1 RX into the interrupt path: register the vector-36
    # handler, route ISA IRQ 4 through the IOAPIC to that vector
    # (edge-triggered / active-high — ioapic_redirect_isa picks the
    # correct ISA polarity), and finally arm the 16550's
    # Received-Data-Available interrupt. Order matters: handler +
    # IOAPIC route BEFORE the IER enable, so the first byte that
    # raises the line already has somewhere to land. Call once, after
    # apic_init() / the LAPIC timer is up.
    register_irq_handler(cast[uint64](UART_RX_IRQ_VECTOR), uart_rx_irq)
    ioapic_redirect_isa(UART_RX_IRQ_GSI, UART_RX_IRQ_VECTOR, 0)
    uart_rx_irq_enable_ier()
    printk0("[irq] COM1 UART RX is interrupt-driven (IRQ 4 -> vec 0x24)\n")

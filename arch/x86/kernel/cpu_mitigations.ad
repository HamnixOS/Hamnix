# arch/x86/kernel/cpu_mitigations.ad
#
# CPU-side security hardening: SMEP + SMAP CR4 wiring at boot, plus
# the runtime flag the uaccess layer consults to decide whether to
# bracket user-memory copies with STAC/CLAC.
#
# Why this exists: as of the 2026-06-13 gap audit, Hamnix's security
# posture is below 2008-era Linux — no SMEP, no SMAP, no KASLR, no
# KPTI. This module covers the two cheapest, lowest-risk wins (SMEP
# enabled at boot; SMAP staged for follow-up); KASLR-at-build-time
# scaffolding lives in cpu_kaslr.ad; KPTI is documented as a follow-up
# (see TODO.md).
#
# SMEP (Supervisor Mode Execution Prevention, CR4 bit 20) - LANDED:
#   When set, a CPL=0 instruction fetch from a user (US=1) page #PFs.
#   This blocks the entire "redirect kernel %rip into a user page
#   holding shellcode" class of exploit. SMEP is a 1-bit set; no
#   kernel code has to change because the kernel never legitimately
#   fetches instructions from user pages.
#
# SMAP (Supervisor Mode Access Prevention, CR4 bit 21) - ENABLED (v3g):
#   When set, a CPL=0 LOAD/STORE to a user (US=1) page #PFs unless
#   AC=1 in RFLAGS. SMAP_RUNTIME_ENABLE = 1. The CR4.SMAP flip + the
#   US=0 low/high-identity restamp happen in setup_smap_late(), called
#   from start_kernel AFTER mem_init() — pgtable_extend_from_e820()
#   (inside mem_init) force-stamps the low-identity PDPT US=1, so the
#   restamp MUST run after it or it gets clobbered (the v3a–v3f
#   triple-fault; full root cause in the v3g block below). The
#   kernel-side uaccess primitives + every other CPL=0 user access
#   bracket with _stac()/_clac() (gated on cpu_mitig_smap_active()).
#   Enforcement is PROVEN under KVM by scripts/test_smap_enforced.sh.
#
#   The STAC/CLAC wrappers GATE on cpu_mitig_smap_active(), so on a
#   CPU/host that masks SMAP (TCG) the bit never latches and the
#   brackets are no-ops — the kernel copies through user pages exactly
#   like before.
#
# Detection: CPUID.07h:EBX bit 7 = SMEP, bit 20 = SMAP. We probe
# CPUID and conditionally OR the bits into CR4. CPUs without the
# feature are left alone — setting an unsupported CR4 bit #GPs.

from kernel.printk.printk import printk0, printk1, printk2
from mm.page_alloc import alloc_page, free_page

extern def cpuid_get(leaf: uint32, subleaf: uint32, out: Ptr[uint32])
extern def read_cr4() -> uint64
extern def write_cr4(value: uint64)
extern def get_bsp_cr3() -> uint64
extern def load_cr3(value: uint64)
extern def read_msr(index: uint32) -> uint64
extern def write_msr(index: uint32, value: uint64)
# High-VMA bounds of the kernel .text (arch/x86/kernel/head_64.S). Used by
# the KPTI isolation self-test to walk an ACTUAL kernel code address in the
# stripped "user" PML4 and prove it does not resolve — robust against the
# KASLR module-window slide (which does not move the kernel .text base).
extern def kernel_text_start() -> uint64

# Runtime flags set by setup_smep_smap(). mm/uaccess.ad reads
# cr4_smap_enabled before calling _stac() / _clac() — on pre-Broadwell
# silicon those instructions #UD, AND on this build we haven't yet
# US=0-stamped the kernel high-half so flipping CR4.SMAP would
# triple-fault the box on the next kernel data access. Both reasons
# converge on "gate the brackets on cr4_smap_enabled".
cr4_smep_enabled: uint64 = 0
cr4_smap_enabled: uint64 = 0

CR4_SMEP_BIT: uint64 = 20
CR4_SMAP_BIT: uint64 = 21

CPUID_07H_EBX_SMEP_BIT: uint32 = 7
CPUID_07H_EBX_SMAP_BIT: uint32 = 20

# Compile-time gates on actually flipping the CR4 bits.
#
# SMEP_RUNTIME_ENABLE = 1: enabled. _restamp_pml4_subtree_us0 clears
# US on PML4[511] (kernel high half) AND PML4[0] (low identity) below,
# and fs/elf.ad's _elf_install_user_mapping_locked OR's US=1 back into
# the PER-TASK PML4[0] when execve cracks it — so kernel CPL=0 ifetch
# everywhere is on US=0 (SMEP-clean) and user CPL=3 ifetch lands on
# US=1 leaves under a US=1 per-task directory chain.
#
# SMAP_RUNTIME_ENABLE = 0: STAGED (SMAP v3a LANDED, v3b PENDING).
#
# v3a (LANDED, this commit): fresh user stacks now get an EXPLICIT US=1
# PTE installed via elf_install_user_stack from
# kernel/sched/core.ad::create_user_thread, so the user stack is no
# longer dependent on the identity-backfill leaves being US=1. With
# that explicit install in place, fs/elf.ad::_build_identity_pd and
# _build_identity_pt now seed their leaves US=0, making the backfill
# kernel-only. The other user-page categories (ELF image / mmap / brk)
# already carry explicit US=1 leaves via _elf_install_user_mapping_locked
# / elf_install_user_heap, so they were never blocked on the leaf split.
#
# v3b (PENDING) — NEXT BLOCKER for CR4.SMAP enable:
# arch/x86/kernel/syscall_64.S's syscall_entry pushes %r12 and %r13 onto
# the USER RSP at CPL=0 (lines 61-62) before switching to the kernel
# stack via TSS.RSP0. Under CR4.SMAP=1 those CPL=0 stores to a US=1 user
# stack page #PF (P=1, no other bits set — the SMAP signature). v3b must
# STAC-bracket that prologue: STAC before the two pushq + the user-RSP
# store, CLAC immediately after the leaq -8(%r12),%rsp switches to the
# kernel stack. Same shape as mm/uaccess.ad's existing copy_to_user
# brackets, just open-coded in the asm prologue since the bracketed
# region is two pushq + one movq. Same treatment on the sysret exit
# tail's symmetric popq sequence if it reads from user RSP before the
# CPL=0->3 transition. Until v3b lands, SMAP_RUNTIME_ENABLE stays 0;
# the leaf flip is independently correct and is kept landed.
SMEP_RUNTIME_ENABLE: uint64 = 1
# v3c LANDED: STAC/CLAC brackets added to the kernel-side user-stack
# writers that drove the v3b boot hang:
#   * arch/x86/kernel/syscall.ad::_build_user_argv / _build_user_argv_linux
#     — execve builds the new task's init-stack (argv strings, argv/envp
#     pointer arrays, auxv) by direct CPL=0 stores to the freshly-installed
#     US=1 user stack. /init's first syscall is execve("/bin/hamsh"), so
#     this is THE path that #PF'd before any user instruction ran post-
#     start_first_task.
#   * kernel/sched/core.ad::deliver_signal_to_user / deliver_fault_sigsegv
#     — rt_sigframe build (siginfo + ucontext + pop area) on the user
#     stack. Same CPL=0/US=1 shape; brackets pre-empt the next SMAP
#     fault any signal-aware test (e.g. ^C in hamsh) would trip.
# v3a leaf flip + v3b syscall STAC stay landed.
#
# #459 (DE-load-regression): v3c re-flipped SMAP_RUNTIME_ENABLE 0→1, but the
# installer image still hangs at "Hamnix: entering parent via
# start_first_task..." on a fresh build under OVMF/KVM 3-for-3.
#
# v3d INVESTIGATION (2026-06-15, agent-a53fb6): instrumented start_first_task
# with printk bisection + CR4.SMAP toggle to isolate the fault site.
# Confirmed findings:
#
#   1. The hang is a TRIPLE-FAULT (-d cpu_reset confirms CPU Reset; no
#      productive trap-diag handler fires; not even early-EMERG #PF gets
#      out). This is why no `#PF rip=` ever appears in the log: the #PF
#      handler is itself faulting on the SMAP rule, double-fault, reset.
#
#   2. The fault site is INSIDE start_first_task. With CR4.SMAP cleared just
#      after load_cr3 and left off through SYSRETQ, the box boots all the
#      way to the hamsh prompt and steady-state runs. This proves every
#      previously-bracketed CPL=0→US=1 store (syscall.ad _build_user_argv,
#      sched/core.ad signal builders, fs/elf.ad cow_resolve_pte) is correct;
#      what remains is a path inside start_first_task itself OR the very
#      first user instruction window after SYSRETQ.
#
#   3. The page-table walk for the boot kstack (printed task PML4[0]=US=1,
#      PDPT[0]=US=1, PD[*]=PS=1 US=0 leaf, kstack 4 KiB PT leaf US=0) gives
#      effective U/S = AND = 0 for every kernel address tested (kstack at
#      0x0b82*, kernel text at 0xffffffff80*, BSP boot stack at 0x3e6*).
#      Only US=1 leaf found in the cracked 2 MiB chunk is the user-stack
#      page at 0x0b811000 (idx 17). So the fault SHOULD NOT be a SMAP
#      enforcement on a leaf — yet CR4.SMAP=1 triple-faults.
#
#   4. Attempted v3d FIX: clear CR4.SMAP at start of start_first_task,
#      re-arm via inline asm (`movq %cr4,%r15; orq $0x200000,%r15;
#      movq %r15,%cr4`) inside enter_first_task_sysret IMMEDIATELY before
#      SYSRETQ, no memory access in between. With this, start_first_task
#      completes (last printk "about to call sysret" fires) but the box
#      hangs after SYSRETQ — /init's _start or its first syscall takes a
#      fault we can't see (#PF handler still can't run). The syscall_64.S
#      entry already has STAC bracketing the user-stack push, so v3b is
#      not the immediate cause; something between SYSRETQ landing in user
#      _start and the first STAC inside syscall_entry is still touching a
#      US=1 page from CPL=0 — possibly a #PF on a not-yet-paged user-image
#      sub-page where the kernel #PF handler itself stores to user RSP
#      without STAC.
#
# REMAINING WORK to enable CR4.SMAP=1:
#   (a) Identify the kernel #PF handler / NMI handler path that touches user
#       RSP at CPL=0 without STAC/CLAC. Likely candidates: the productive
#       #PF handler builds a SIGSEGV frame on user stack (deliver_fault_*)
#       — already bracketed in v3c, but the COW-resolve / lazy-faultin
#       paths (vm_fault, page_fault_user_lazy) may also store.
#   (b) Audit the trap_diag handler itself — if SMAP fires inside any
#       interrupt-context kernel store, the diagnostic recursion is the
#       triple-fault.
#   (c) Audit `arch/x86/kernel/syscall_64.S` SYSRET tail (the popq sequence
#       reading the SAVED user RSP) — symmetric to the entry STAC. The
#       current code only STAC-brackets entry, not exit.
#
# Until those land, keep the flag at 0 so the installer DE comes up.
# STAC/CLAC instructions are no-ops with CR4.SMAP=0 (RFLAGS.AC just gets
# set/cleared with no enforcement), so the v3c brackets stay correct under
# the flag-off boot. The CPUID-supports-but-not-enabled "[cpu-mitig] SMAP
# staged" diagnostic fires below as designed.
#
# v3e INVESTIGATION (2026-06-15, agent-a5bc3358e1f38ded0):
#
#   1. CLOSED item (b) — trap_diag user-RIP read.
#      arch/x86/kernel/trap_diag.ad's do_trap_diag_5 dereferences `rip`
#      directly (two qword loads) to print the bytes at the faulting
#      instruction. For vec=6/7/13/16/19 (non-#PF, non-#DF) the rip page
#      MAY be a US=1 user-text page, so the CPL=0 reads need STAC.
#      Bracketed unconditionally in commit 5a200c3a; STAC/CLAC are no-ops
#      with CR4.SMAP=0 so the change is safe under the flag-off boot.
#
#   2. CLOSED item (a) sub-case — linux_abi/u_syscalls.ad::_u_rt_sigreturn
#      reads 5 qwords (RIP/RSP/RFLAGS/RAX/SIGMASK) out of the ucontext on
#      the user stack (US=1). The WRITE side in
#      kernel/sched/core.ad::deliver_signal_to_user is already bracketed
#      since v3c; the READ side was a latent unbracketed user-stack
#      access. Bracketed in commit d10d38db.
#
#   3. EMPIRICAL STATE (KVM, -cpu host, -bios OVMF.fd):
#      - CR4=0x00000000_00300668 after setup_smep_smap (SMEP bit 20 AND
#        SMAP bit 21 both set; [cpu-mitig] SMAP enabled prints).
#      - Restamp: 2 kernel high-half leaves US=0; 512 low identity leaves
#        US=0.
#      - uaccess-smoke PASS: unmapped address -> EFAULT (no panic).
#        That proves STAC/CLAC themselves work and the kernel-side
#        copy_to/from_user path is SMAP-clean.
#      - Box still hangs at start_first_task: last log line is
#        "Hamnix: entering parent via start_first_task..." followed by a
#        partial "[" with NO further output and no trap-diag print. Same
#        triple-fault signature v3d documented. The two additional v3e
#        brackets did NOT unblock the hang.
#      - TCG (-enable-kvm absent) ignores SMAP CPUID bits so SMAP stays
#        OFF and the box boots fully (heartbeat ticks observed). The
#        TCG-green boot proves the brackets don't break the non-enforced
#        path; the KVM-hang proves the fault site is NOT what v3e
#        bracketed.
#
#   4. REMAINING SUSPECT PATHS (still to investigate):
#      - The "1 syscall in flight then resume" path: cpu_mitigations.ad
#        line 81-86 says fs/elf.ad's _elf_install_user_mapping_locked OR's
#        PT_FLAG_US into the per-task PML4[0]. If that OR is missed for
#        the boot /init task — i.e. /init's PML4[0] STAYS US=0 from the
#        low-identity restamp — then EVERY user-mode access via that PML4
#        is effective US=0 (intersection rule), and the FIRST user CPL=3
#        instruction at 0xbc03012 (or its data read off the user stack)
#        SUPERVISOR-FAULTS the CPU. From CPL=3 a fault on a US=0 page
#        delivers a #PF with err.U=1, P=1 — but if the kernel's own #PF
#        handler entry walks back into the user stack at CPL=0 (CPU push
#        of the iret frame goes to TSS.RSP0 which is kernel stack, so
#        that's safe; but error-code push and immediate handler prologue
#        save user state... need to audit). This is exactly the
#        "diagnostic recursion -> triple-fault" cascade v3d hypothesised.
#      - The /init mapping path runs at create_user_task (BEFORE the boot
#        flag flips) AND at parent-task PML4 clone (line 4231 cr3 load).
#        It uses fs/elf.ad::_elf_install_user_mapping which calls
#        _elf_install_user_mapping_locked. The PML4-cracking PML4[0] OR
#        sits in there; verify it FIRES for slot=1 init, against the
#        PRE-RESTAMP boot PML4 clone.
#      - Inverse approach: also re-stamp the JUST-CRACKED per-task
#        PML4[0] subtree US=0 at task creation, then explicitly re-stamp
#        US=1 ONLY the per-task pdpt/pd/pt path leading to a user VMA.
#        That eliminates the "leaked US=1 from boot identity restamp
#        never ran" foot-gun.
#
#   5. WORKING THEORY: the leaf-split (v3a) clears US=0 on the identity
#      backfill, but for the INITIAL boot /init task, _elf_install_user_
#      mapping_locked's PML4[0] |= US=1 fires AFTER the per-task PML4 is
#      cloned from the boot PML4 — and the boot PML4 was JUST restamped
#      US=0 by setup_smep_smap. So the clone carries US=0 in PML4[0],
#      and the |= US=1 happens — but the subtree under it (PDPT/PD)
#      may still carry US=0 from the verbatim copy. The chain reads:
#        PML4[0] US=1 (after |=)
#        PDPT[0] US=0 (verbatim from restamped boot PML4[0])
#        PD[*]   US=0
#        PT[user-stack-leaf] US=1 (explicit install via elf_install_user_stack)
#      Effective US = AND = 0 -> SMAP rejects the CPL=0 access. Worse:
#      from CPL=3 the effective US=0 means the user CPU access (CPL=3
#      load/store/ifetch on a US=0 page) is illegal: #PF err.U=1, P=1.
#      The CPU enters #PF handler at CPL=0, pushes iret frame to
#      TSS.RSP0 (kernel kstack, US=0 — safe), enters do_page_fault,
#      walks pgtable, finds nothing recoverable, calls
#      deliver_fault_sigsegv -> default-terminate (handler 0 for fresh
#      task). task_exit_current never returns and... but if /init is the
#      ONLY task, exiting it should print "[init] task exited" via
#      printk0 BEFORE halting. We see NEITHER trap-diag NOR exit print.
#      So the #PF handler ITSELF is faulting before it can printk.
#      Most likely site: error_code push or the GPR save chain in
#      trap_diag_stub_0e (trap_asm.S:146-160) writes to %rsp = TSS.RSP0
#      — kernel kstack — which is US=0 and SMAP-clean. So the cascade
#      must be EARLIER, possibly inside the CPU's iret-frame push if
#      TSS.RSP0 is somehow pointing into a US=1 page.
#
#      Action: instrument start_first_task to printk task_kstack_top
#      AND walk its PT to confirm US=0; if US=1 found, that's the
#      fault site — TSS.RSP0 was set to a user-stamped kstack. v3d
#      already did most of this walk but did NOT specifically check
#      that TSS.RSP0's leaf is US=0 at start_first_task time.
#
# v3f INVESTIGATION (2026-06-15, agent-a95ebed38):
#
#   Added a walker (_smap_v3f_walk_tss_rsp0 in kernel/sched/core.ad)
#   that prints the full PML4 -> PDPT -> PD -> PT chain for TSS.RSP0
#   under both the boot CR3 (still active at start_first_task entry)
#   AND the per-task CR3 (about to be loaded). The walker prints
#   each level's entry, US, RW, and the AND-down EFFECTIVE bits.
#
#   v3e THEORY DISPROVEN — empirical boot log (SMAP=1, KVM):
#     [smap-v3f] PML4 entry = 0x000000000b813027   PML4 US=1 RW=1
#     [smap-v3f] PDPT entry = 0x000000000b818007   PDPT US=1 RW=1
#     [smap-v3f] PD   entry = 0x000000000b819007   PD   US=1 RW=1
#     [smap-v3f] PT   entry = 0x000000000b82f003   PT   US=0 RW=1
#     [smap-v3f] EFFECTIVE US=0 RW=1 (leaf=4K)
#     [smap-v3f] TSS.RSP0 effective US=0 — SMAP-safe leaf
#   Boot stack VA under per-task CR3: PD 2M huge leaf US=0,
#   effective US=0. Kernel high half: PDPT 1G huge leaf US=0,
#   effective US=0. ALL THREE paths effective US=0 — not SMAP-hot.
#
#   YET the box still triple-faults INSIDE load_cr3: bisection prints
#   show "[smap-v3f] calling load_cr3 NOW" fires; the "load_cr3
#   returned" print never appears. load_cr3 is `movq %rdi,%cr3; ret`
#   in arch/x86/kernel/smp_asm.S — three instructions. The mov-to-CR3
#   itself cannot fault on its own; the next IFETCH (the `ret`) is in
#   kernel high half (PML4[511] US=0 1G huge leaf, walked and safe);
#   the pop the ret performs reads from the BSP boot stack at
#   0x3e6XXXXX (PD 2M huge US=0, walked and safe).
#
#   So the fault is NOT a CPL=0 access to a US=1 leaf (the SMAP
#   classical signature). All three accesses load_cr3 triggers go to
#   pages that are SUPERVISOR per the Intel rule (Vol 3A §4.6:
#   "user-mode address" = US=1 in EVERY paging-structure entry; any
#   US=0 anywhere -> supervisor). The walker output confirms every
#   one of those four levels for TSS.RSP0 / boot stack / kernel high
#   half has US=0 at the leaf or above.
#
#   ANOMALY worth chasing: the BOOT-CR3 walk for TSS.RSP0 shows
#     [smap-v3f] PDPT entry = 0x00000000000000e7  (US=1, PS=1, 1G huge)
#   under cr3=0x3e629000. But setup_smep_smap's restamp logged
#     [cpu-mitig] restamp: 512 low identity leaves US=0
#   which should have stamped that PDPT entry to 0xe3 (US cleared).
#   Either (i) some later code RE-OR's US=1 back onto boot PDPT[0]
#   between setup_smep_smap and start_first_task, or (ii) the BSP's
#   active CR3 changes between the two points (get_bsp_cr3() reads
#   live %cr3, not a stored constant). Worth grepping for any
#   pgtable_extend_from_e820 / cr3 reload that hands the BSP a
#   different PML4 than the one restamped.
#
#   But: even if boot PDPT[0] is US=1, the effective US is still 0
#   (PML4[0] is US=0 — restamped, confirmed). So the SMAP rule still
#   doesn't fire on a CPL=0 load.
#
#   Remaining hypothesis (open): there is a CPU/microcode edge case
#   where load_cr3 + immediate IFETCH/data-access combines with
#   CR4.SMAP=1 in a way the SDM "AND-down US" model doesn't fully
#   describe. KVM-on-host-CPU may have its own quirks. The v3d
#   workaround (clear CR4.SMAP at start of start_first_task; re-arm
#   immediately before SYSRETQ) demonstrably unblocked load_cr3
#   itself; the followup hang then moved into the SYSRETQ window.
#
#   Conclusion for v3f: SMAP_RUNTIME_ENABLE STAYS 0. The walker is
#   kept landed — it runs unconditionally at start_first_task and
#   is a near-zero-cost diagnostic that documents the per-task PML4
#   layout in the boot log for any future SMAP investigation.
#
# v3g ROOT CAUSE + FIX (2026-06-21, agent-ac622050):
#
#   ROOT CAUSE FOUND (the v3f "ANOMALY worth chasing" at lines 323-333
#   above was the smoking gun and is now fully explained):
#
#   setup_smep_smap() restamped the low identity (PML4[0] subtree) US=0
#   and flipped CR4.SMAP=1 EARLY in start_kernel (before mem_init).
#   Then mem_init() -> pgtable_extend_from_e820() (arch/x86/mm/init.ad:102)
#   ran LATER. On the EFI/UEFI boot path it takes the magic != PGT_MB_MAGIC
#   branch (pgtable.ad:263) and calls _pgtable_force_stamp_1gb for ALL 512
#   low-identity PDPT entries — UNCONDITIONALLY rewriting each with
#   PGT_NEW_FLAGS = 0x87 (PS|US|RW|P, note US=1; pgtable.ad:145). This
#   CLOBBERED the US=0 restamp: the boot PDPT[0] read back US=1 (0xe7)
#   exactly as v3f observed. With CR4.SMAP already on and low identity
#   US=1 again (where the boot kstack / BSP boot stack / kernel data
#   all live), the next CPL=0 access to low identity triple-faults —
#   inside / right after load_cr3 at start_first_task, matching every
#   prior symptom. The per-task PML4 was cloned from the post-clobber
#   boot PML4, so it too carried US=1 PDPT entries.
#
#   FIX (ordering): split setup_smep_smap(). SMEP restamp + CR4.SMEP
#   flip stays EARLY (it's the .ko-loader enabler and doesn't depend on
#   mem_init). The SMAP restamp (low + high) + CR4.SMAP flip MOVED into
#   a NEW function setup_smap_late(), called from start_kernel right
#   AFTER mem_init() — i.e. after pgtable_extend_from_e820 has finished
#   its force-stamp. So the SMAP US=0 restamp is the LAST writer to the
#   low-identity PDPT and survives to the ring-3 hand-off. The per-task
#   PML4 clone for /init happens at create_user_task AFTER setup_smap_late
#   (sched_init / the parent-clone path run later in start_kernel), so
#   it inherits the US=0 low identity and the elf.ad PML4[0] |= US=1
#   crack path re-grants US only on the per-task user range.
#
#   STAC/CLAC AUDIT (v3g, full re-walk):
#     * syscall_64.S entry prologue: STAC/CLAC bracket the two user-RSP
#       pushq's (lines 71-74). INTACT.
#     * syscall_64.S SYSRET exit tail: STAC before the popq %r13 / popq
#       %r12 that read SAVED user regs off the user stack (lines 219-221);
#       SYSRETQ reloads RFLAGS from %r11 (user) which clears AC. INTACT
#       (v3d item (c) was ALREADY done — prior note at line 180-182 was
#       stale).
#     * _build_user_argv / _build_user_argv_linux (syscall.ad): bracketed
#       (v3c). VERIFIED intact.
#     * deliver_signal_to_user / deliver_fault_sigsegv (sched/core.ad):
#       bracketed (v3c). VERIFIED intact.
#     * _u_rt_sigreturn read (linux_abi/u_syscalls.ad): bracketed (v3e).
#       VERIFIED intact.
#     * trap_diag user-RIP read (trap_diag.ad): bracketed (v3e). VERIFIED.
#     * copy_to/from_user (mm/uaccess.ad): translate user vaddr->phys and
#       access via the now-US=0 low identity, so they don't strictly need
#       STAC; the gated _ua_stac/_ua_clac are harmless and kept. This is
#       the linux_abi dpkg/apt physical-frame user-fill path — US=0
#       identity keeps it SMAP-clean.
#   No NEW unbracketed kernel->user CPL=0 access was found after the
#   ordering fix; the remaining hang in v3d-v3f was the clobber, not a
#   missing bracket.
SMAP_RUNTIME_ENABLE: uint64 = 1

# Page-table walk constants. Mirror arch/x86/mm/pgtable.ad's PGT_ADDR_MASK
# and the US (bit 2) / P (bit 0) flag bits so the high-half re-stamp pass
# below is self-contained and doesn't depend on pgtable.ad's import surface.
PGT_ADDR_MASK_KM: uint64 = 0x000FFFFFFFFFF000
PGT_FLAG_P_KM:    uint64 = 0x1
PGT_FLAG_US_KM:   uint64 = 0x4
PGT_FLAG_PS_KM:   uint64 = 0x80


def _restamp_pml4_subtree_us0(pml4_idx: uint64) -> uint64:
    # Walk PML4[pml4_idx] -> PDPT -> [PD ->] leaves and clear US=1 on
    # every present entry. Used for both the kernel high-half (idx=511)
    # and an optional pass over the shared low identity map (idx=0).
    cr3:  uint64 = get_bsp_cr3()
    pml4: uint64 = cr3 & PGT_ADDR_MASK_KM
    pml4_slot_addr: uint64 = pml4 + pml4_idx * cast[uint64](8)
    pml4_slot: Ptr[uint64] = cast[Ptr[uint64]](pml4_slot_addr)
    pml4e: uint64 = pml4_slot[0]
    if (pml4e & PGT_FLAG_P_KM) == 0:
        return 0
    if (pml4e & PGT_FLAG_US_KM) != 0:
        pml4_slot[0] = pml4e & ~PGT_FLAG_US_KM
    pdpt_base: uint64 = pml4e & PGT_ADDR_MASK_KM
    cleared: uint64 = 0
    i: uint64 = 0
    while i < cast[uint64](512):
        pdpt_slot: Ptr[uint64] = cast[Ptr[uint64]](
            pdpt_base + i * cast[uint64](8))
        pdpte: uint64 = pdpt_slot[0]
        if (pdpte & PGT_FLAG_P_KM) != 0:
            if (pdpte & PGT_FLAG_PS_KM) != 0:
                if (pdpte & PGT_FLAG_US_KM) != 0:
                    pdpt_slot[0] = pdpte & ~PGT_FLAG_US_KM
                    cleared = cleared + 1
            else:
                if (pdpte & PGT_FLAG_US_KM) != 0:
                    pdpt_slot[0] = pdpte & ~PGT_FLAG_US_KM
                pd_base: uint64 = pdpte & PGT_ADDR_MASK_KM
                j: uint64 = 0
                while j < cast[uint64](512):
                    pd_slot: Ptr[uint64] = cast[Ptr[uint64]](
                        pd_base + j * cast[uint64](8))
                    pde: uint64 = pd_slot[0]
                    if (pde & PGT_FLAG_P_KM) != 0:
                        if (pde & PGT_FLAG_US_KM) != 0:
                            pd_slot[0] = pde & ~PGT_FLAG_US_KM
                            cleared = cleared + 1
                    j = j + 1
        i = i + 1
    return cleared


def _audit_pml4_subtree_us1_leaks(pml4_idx: uint64, label: Ptr[char]) -> uint64:
    # Read-only AUDIT: walk PML4[pml4_idx] -> PDPT -> [PD ->] leaves on the
    # LIVE BSP page tables and COUNT (and log) every PRESENT leaf whose US
    # bit is still 1. For the kernel high half (idx=511) a non-zero count is
    # a SMAP/SMEP LEAK — a kernel VA reachable from CPL=3. Returns the leak
    # count. Does NOT modify any entry. Mirrors the walk shape of
    # _restamp_pml4_subtree_us0 exactly so the two can't drift.
    cr3:  uint64 = get_bsp_cr3()
    pml4: uint64 = cr3 & PGT_ADDR_MASK_KM
    pml4_slot: Ptr[uint64] = cast[Ptr[uint64]](pml4 + pml4_idx * cast[uint64](8))
    pml4e: uint64 = pml4_slot[0]
    if (pml4e & PGT_FLAG_P_KM) == 0:
        return 0
    leaks: uint64 = 0
    pdpt_base: uint64 = pml4e & PGT_ADDR_MASK_KM
    i: uint64 = 0
    while i < cast[uint64](512):
        pdpte: uint64 = cast[Ptr[uint64]](pdpt_base + i * cast[uint64](8))[0]
        if (pdpte & PGT_FLAG_P_KM) != 0:
            if (pdpte & PGT_FLAG_PS_KM) != 0:
                # 1 GiB leaf.
                if (pdpte & PGT_FLAG_US_KM) != 0:
                    printk2("[smap-audit] LEAK %s pdpt[%d] 1G US=1\n",
                            cast[uint64](label), i)
                    leaks = leaks + 1
            else:
                pd_base: uint64 = pdpte & PGT_ADDR_MASK_KM
                j: uint64 = 0
                while j < cast[uint64](512):
                    pde: uint64 = cast[Ptr[uint64]](pd_base + j * cast[uint64](8))[0]
                    if (pde & PGT_FLAG_P_KM) != 0:
                        if (pde & PGT_FLAG_PS_KM) != 0:
                            # 2 MiB leaf.
                            if (pde & PGT_FLAG_US_KM) != 0:
                                printk2("[smap-audit] LEAK %s 2M leaf US=1 (pdpt[%d]"
                                        " pd-row follows)\n",
                                        cast[uint64](label), i)
                                printk1("[smap-audit]   pd[%d]\n", j)
                                leaks = leaks + 1
                        else:
                            pt_base: uint64 = pde & PGT_ADDR_MASK_KM
                            k: uint64 = 0
                            while k < cast[uint64](512):
                                pte: uint64 = cast[Ptr[uint64]](
                                    pt_base + k * cast[uint64](8))[0]
                                if (pte & PGT_FLAG_P_KM) != 0:
                                    if (pte & PGT_FLAG_US_KM) != 0:
                                        printk2("[smap-audit] LEAK %s 4K leaf US=1"
                                                " (pdpt[%d])\n",
                                                cast[uint64](label), i)
                                        leaks = leaks + 1
                                k = k + 1
                    j = j + 1
        i = i + 1
    return leaks


def smap_us_audit() -> uint64:
    # Public AUDIT entry. Gated behind a marker by the caller so it doesn't
    # spam normal boots. Scans the kernel HIGH HALF (PML4[511]) on the live
    # BSP page tables and reports any US=1 leak. The low identity (PML4[0])
    # is INTENTIONALLY shared with per-task user mappings — the BOOT subtree
    # is US=0 but user code runs from identity-mapped RAM via per-task US=1
    # cracks, so we do NOT flag PML4[0] leaves as leaks here (they are walked
    # but only reported as an informational count). The high-half count is
    # the acceptance number: it MUST be 0.
    printk0("[smap-audit] kernel-VA US-bit integrity scan (PML4[511] high half)\n")
    hi_leaks: uint64 = _audit_pml4_subtree_us1_leaks(cast[uint64](511),
                                                     "high-half")
    if hi_leaks == 0:
        printk0("[smap-audit] PASS: 0 high-half kernel-VA US=1 leaks\n")
    else:
        printk1("[smap-audit] FAIL: %d high-half kernel-VA US=1 leaks\n",
                hi_leaks)
    return hi_leaks


def setup_smep_smap():
    # EARLY mitigation pass (called from start_kernel BEFORE mem_init):
    # handles SMEP only. SMAP is deferred to setup_smap_late() because
    # mem_init()->pgtable_extend_from_e820() re-stamps the low identity
    # PDPT US=1 (clobbering any US=0 restamp done here) — see the v3g
    # block above. SMEP does not depend on the low identity staying US=0
    # for its enforcement model in a way that mem_init's clobber breaks:
    # the .ko-loader ifetch path runs at boot-32 modprobe (BEFORE
    # mem_init), and the restamp below makes that window SMEP-clean.
    #
    # Probe CPUID.07h:EBX (structured extended feature flags). Subleaf
    # 0; EAX = max-supported-subleaf (we want >=0), EBX carries the
    # flag bits.
    buf: Array[4, uint32]
    buf[0] = cast[uint32](0)
    buf[1] = cast[uint32](0)
    buf[2] = cast[uint32](0)
    buf[3] = cast[uint32](0)
    cpuid_get(cast[uint32](7), cast[uint32](0), &buf[0])
    ebx: uint32 = buf[1]

    smep_supported: uint32 = (ebx >> CPUID_07H_EBX_SMEP_BIT) & cast[uint32](1)

    # Re-stamp the kernel high-half mappings US=0 BEFORE flipping CR4.
    # With the boot stub's US=1 stamping on pdpt_high entries
    # (header.S:198), enabling SMEP would #PF the next kernel ifetch and
    # triple-fault the box.
    restamped_hi: uint64 = 0
    restamped_lo: uint64 = 0
    if SMEP_RUNTIME_ENABLE == 1 and smep_supported != cast[uint32](0):
        # High half (PML4[511]) — kernel image. Required for SMEP (the
        # kernel's own ifetch lives here).
        restamped_hi = _restamp_pml4_subtree_us0(cast[uint64](511))
        printk1("[cpu-mitig] restamp: %d kernel high-half leaves US=0\n",
                restamped_hi)
        # Low identity (shared PML4[0] / pdpt_low) — clear US so the
        # native .ko loader (arch/x86/kernel/module.ad) can elf_load_blob
        # modules into low identity RAM and CPL=0-jump to init_module
        # without SMEP #PF'ing the ifetch. NOTE: mem_init's
        # pgtable_extend_from_e820 will later re-OR US=1 here; that's
        # fine for SMEP-after-mem_init because no native .ko ifetch
        # happens that late, and setup_smap_late() re-clears it before
        # CR4.SMAP turns on.
        restamped_lo = _restamp_pml4_subtree_us0(cast[uint64](0))
        printk1("[cpu-mitig] restamp: %d low identity leaves US=0\n",
                restamped_lo)
        load_cr3(get_bsp_cr3())

    cr4_cur: uint64 = read_cr4()
    cr4_new: uint64 = cr4_cur

    if smep_supported != cast[uint32](0):
        if SMEP_RUNTIME_ENABLE == 1:
            cr4_new = cr4_new | (cast[uint64](1) << CR4_SMEP_BIT)
            cr4_smep_enabled = 1

    if cr4_new != cr4_cur:
        write_cr4(cr4_new)

    cr4_after: uint64 = read_cr4()
    smep_live: uint64 = (cr4_after >> CR4_SMEP_BIT) & cast[uint64](1)
    printk1("[mitig] CR4 SMEP=%d (SMAP deferred to setup_smap_late)\n",
            smep_live)
    if cr4_smep_enabled == 1:
        printk0("[cpu-mitig] SMEP enabled\n")
    if smep_supported != cast[uint32](0) and cr4_smep_enabled == 0:
        printk0("[cpu-mitig] SMEP staged (CPU supports; gated until" \
                " kernel high-half PML4 is US=0-stamped)\n")


def setup_smap_late():
    # LATE mitigation pass (called from start_kernel right AFTER
    # mem_init()). At this point pgtable_extend_from_e820() has finished
    # its unconditional force-stamp of the low-identity PDPT to US=1
    # (the v3g clobber). We re-stamp the low identity AND kernel high
    # half US=0 here — this is the LAST writer to those PDPT/PD/PT leaves
    # before the ring-3 hand-off — then flip CR4.SMAP=1. Because the
    # per-task PML4 clone for /init happens later still (sched/parent
    # clone path), it inherits this US=0 low identity; fs/elf.ad's
    # _elf_install_user_mapping_locked OR's US=1 back ONLY onto the
    # per-task user range, so kernel CPL=0 identity accesses stay
    # SMAP-clean while user CPL=3 accesses see US=1 leaves.
    buf: Array[4, uint32]
    buf[0] = cast[uint32](0)
    buf[1] = cast[uint32](0)
    buf[2] = cast[uint32](0)
    buf[3] = cast[uint32](0)
    cpuid_get(cast[uint32](7), cast[uint32](0), &buf[0])
    ebx: uint32 = buf[1]

    smap_supported: uint32 = (ebx >> CPUID_07H_EBX_SMAP_BIT) & cast[uint32](1)

    # SMAP/SMEP INTEGRITY: the kernel high-half US=0 restamp is UNCONDITIONAL
    # — it does NOT gate on smap_supported. A kernel mapping with US=1 is a
    # latent CPL=3 read/jump target whether or not CR4.SMAP/SMEP happens to
    # be latched on this host; Linux keeps every kernel mapping US=0 always.
    # On a TCG host (where CPUID masks SMAP and the CR4 bits never latch) the
    # restamp still runs so the page tables are CORRECT BY CONSTRUCTION, and
    # the audit below reports 0 high-half leaks regardless of accelerator.
    # The kernel runs CPL=0, so US=0 is transparent to its own accesses.
    #
    # High half (PML4[511], the kernel image .text/.rodata/.data/.bss) and
    # the shared low identity (PML4[0]: alloc_page/kmalloc/kstack/page
    # tables) both get US cleared. The low-identity restamp only touches the
    # SHARED boot subtree; each per-task PML4 clone then re-grants US=1 at
    # the PML4[0] directory + explicit user leaves (fs/elf.ad), so user code
    # still runs while kernel CPL=0 identity accesses stay SMAP-clean.
    restamped_hi: uint64 = _restamp_pml4_subtree_us0(cast[uint64](511))
    printk1("[cpu-mitig] smap-late restamp: %d kernel high-half leaves US=0\n",
            restamped_hi)
    restamped_lo: uint64 = _restamp_pml4_subtree_us0(cast[uint64](0))
    printk1("[cpu-mitig] smap-late restamp: %d low identity leaves US=0\n",
            restamped_lo)
    load_cr3(get_bsp_cr3())

    cr4_cur: uint64 = read_cr4()
    cr4_new: uint64 = cr4_cur

    if smap_supported != cast[uint32](0):
        if SMAP_RUNTIME_ENABLE == 1:
            cr4_new = cr4_new | (cast[uint64](1) << CR4_SMAP_BIT)
            cr4_smap_enabled = 1

    if cr4_new != cr4_cur:
        write_cr4(cr4_new)

    # Read back CR4 to confirm the bits actually latched. Some CPUs /
    # virtualisers silently mask unsupported bits; the read-back is the
    # ground truth.
    cr4_after: uint64 = read_cr4()
    smep_live: uint64 = (cr4_after >> CR4_SMEP_BIT) & cast[uint64](1)
    smap_live: uint64 = (cr4_after >> CR4_SMAP_BIT) & cast[uint64](1)
    printk2("[mitig] CR4 SMEP=%d SMAP=%d\n", smep_live, smap_live)

    printk1("[cpu-mitig] smap_supported=%d\n", cast[uint64](smap_supported))
    if cr4_smap_enabled == 1:
        printk0("[cpu-mitig] SMAP enabled\n")
    if smap_supported != cast[uint32](0) and cr4_smap_enabled == 0:
        printk0("[cpu-mitig] SMAP staged (CPU supports; SMAP_RUNTIME_ENABLE" \
                " gated off)\n")


def cpu_mitig_smap_active() -> uint64:
    # Read accessor for mm/uaccess.ad. Returns 1 if STAC/CLAC are
    # both safe to execute AND required (SMAP is live), else 0.
    return cr4_smap_enabled


# ============================================================================
# Spectre-v2 / MDS / Speculative-Store-Bypass — hardware-MSR mitigations.
# ============================================================================
#
# Spectre variant 2 (CVE-2017-5715, branch-target injection) is mitigated
# here the ROBUST hardware way — via the IA32_SPEC_CTRL / IA32_PRED_CMD
# MSRs — rather than a compiler retpoline. Retpoline needs the Adder codegen
# to route every indirect call/jump through a thunk; the MSR route is a
# self-contained kernel change that needs no codegen work and, on
# enhanced-IBRS silicon, is what Linux itself prefers over retpoline anyway.
#
#   * IBRS  (IA32_SPEC_CTRL bit 0) — Indirect Branch Restricted Speculation.
#     Set once at boot; on eIBRS ("IBRS_ALL") parts a single set stays in
#     force for CPL=0 and no per-transition toggling is needed.
#   * STIBP (IA32_SPEC_CTRL bit 1) — Single Thread Indirect Branch
#     Predictors. Stops a sibling SMT thread steering our indirect branches.
#   * SSBD  (IA32_SPEC_CTRL bit 2) — Speculative Store Bypass Disable
#     (Spectre-v4 / CVE-2018-3639).
#   * IBPB  (IA32_PRED_CMD bit 0) — Indirect Branch Prediction Barrier.
#     A "flush" written on every address-space switch (see cpu_mitig_ibpb,
#     called from schedule() when CR3 changes) so a task cannot poison the
#     BTB for the next, mutually-distrusting, task.
#   * MD_CLEAR (VERW) — Microarchitectural Data Sampling (MDS/CVE-2018-12126
#     et al.) buffer clear. We only RECORD support here; the VERW-on-return
#     wiring in the entry asm is the follow-up (documented in the report).
#
# EVERY MSR touch is CPUID-GATED. IA32_SPEC_CTRL/PRED_CMD are architectural
# only when CPUID.07h:EDX advertises them; touching them otherwise #GPs and
# triple-faults. QEMU TCG advertises NONE of these bits, so on the pure-TCG
# CI runners this whole path is a probe + "not supported" print and NO MSR
# is written — boot-green by construction. Under `-cpu host` on Skylake+
# KVM the bits appear and the MSRs are programmed for real.
#
# CPUID.07h:EDX feature bits (leaf 7, subleaf 0, EDX):
IA32_SPEC_CTRL_MSR:       uint32 = 0x48
IA32_PRED_CMD_MSR:        uint32 = 0x49
IA32_ARCH_CAPABILITIES_MSR: uint32 = 0x10a

SPEC_CTRL_IBRS:  uint64 = 0x1   # bit 0
SPEC_CTRL_STIBP: uint64 = 0x2   # bit 1
SPEC_CTRL_SSBD:  uint64 = 0x4   # bit 2
PRED_CMD_IBPB:   uint64 = 0x1   # bit 0

CPUID_07H_EDX_MD_CLEAR_BIT:   uint32 = 10
CPUID_07H_EDX_IBRS_IBPB_BIT:  uint32 = 26   # STIBP/SPEC_CTRL family root
CPUID_07H_EDX_STIBP_BIT:      uint32 = 27
CPUID_07H_EDX_ARCH_CAP_BIT:   uint32 = 29
CPUID_07H_EDX_SSBD_BIT:       uint32 = 31

# IA32_ARCH_CAPABILITIES bits (RO MSR 0x10a, only when CPUID.07h:EDX[29]).
ARCH_CAP_IBRS_ALL: uint64 = 0x2   # bit 1: enhanced IBRS ("set once")
ARCH_CAP_SSB_NO:   uint64 = 0x10  # bit 4: HW immune to SSB, no SSBD needed
ARCH_CAP_MDS_NO:   uint64 = 0x20  # bit 5: HW immune to MDS, no VERW needed

# Runtime state, published by setup_spectre_v2() and read by the context
# switch (cpu_mitig_ibpb) + the selftest accessors.
spec_ctrl_ibpb_supported: uint64 = 0
spec_ctrl_md_clear:       uint64 = 0
spec_ctrl_base:           uint64 = 0   # the value we program into MSR 0x48
spectre_v2_active:        uint64 = 0   # 1 once IA32_SPEC_CTRL was written
# MDS (task #87): 1 once the exit-path VERW (CLEAR_CPU_BUFFERS) is
# EFFECTIVE — i.e. the microcode enumerates MD_CLEAR and the part is not
# already MDS-immune (ARCH_CAPABILITIES.MDS_NO). The VERW itself is
# compiled UNCONDITIONALLY into the kernel->user exit asm; this flag only
# reports whether the flush actually scrubs the CPU buffers on this host.
mds_mitigation_active:    uint64 = 0


def setup_spectre_v2():
    # Probe CPUID.07h:EDX and program IA32_SPEC_CTRL (IBRS+STIBP+SSBD) per
    # the individually-advertised bits, then record IBPB / MD_CLEAR support
    # for the context-switch barrier and the MDS follow-up. Called from
    # start_kernel after setup_smap_late(). All MSR access is gated on the
    # CPUID advertisement so a non-supporting host (TCG) never issues a
    # #GP-prone WRMSR.
    buf: Array[4, uint32]
    buf[0] = cast[uint32](0)
    buf[1] = cast[uint32](0)
    buf[2] = cast[uint32](0)
    buf[3] = cast[uint32](0)
    cpuid_get(cast[uint32](7), cast[uint32](0), &buf[0])
    edx: uint32 = buf[3]

    ibrs_ibpb: uint32 = (edx >> CPUID_07H_EDX_IBRS_IBPB_BIT) & cast[uint32](1)
    stibp:     uint32 = (edx >> CPUID_07H_EDX_STIBP_BIT) & cast[uint32](1)
    ssbd:      uint32 = (edx >> CPUID_07H_EDX_SSBD_BIT) & cast[uint32](1)
    arch_cap:  uint32 = (edx >> CPUID_07H_EDX_ARCH_CAP_BIT) & cast[uint32](1)
    md_clear:  uint32 = (edx >> CPUID_07H_EDX_MD_CLEAR_BIT) & cast[uint32](1)

    spec_ctrl_md_clear = cast[uint64](md_clear)
    # IBPB shares the IA32_SPEC_CTRL/PRED_CMD enumeration bit (EDX[26]).
    spec_ctrl_ibpb_supported = cast[uint64](ibrs_ibpb)

    # MDS (task #87): CLEAR_CPU_BUFFERS. The VERW is compiled UNCONDITIONALLY
    # into every kernel->user exit path (syscall_64.S SYSRETQ x2 +
    # enter_user_mode IRETQ; sched_asm.S first-task SYSRETQ + kthread IRETQ;
    # irq_asm.S common_irq IRETQ; trap_asm.S #GP/#PF IRETQ — the IRETQ sites
    # gate on the saved CS RPL so kernel->kernel returns skip the flush).
    # VERW is architecturally a no-op-for-correctness without MD_CLEAR, so no
    # runtime patching is needed. The flush is EFFECTIVE (actually scrubs the
    # store buffer / fill buffers / load ports) exactly when the microcode
    # enumerates MD_CLEAR AND the part is not already MDS-immune
    # (ARCH_CAPABILITIES.MDS_NO, bit 5). MDS is INDEPENDENT of the SPEC_CTRL
    # family, so decide + report it here BEFORE the ibrs_ibpb early-return
    # below (a part can advertise MD_CLEAR with no IA32_SPEC_CTRL at all).
    mds_caps: uint64 = 0
    if arch_cap != cast[uint32](0):
        mds_caps = read_msr(IA32_ARCH_CAPABILITIES_MSR)
    if md_clear != cast[uint32](0) and (mds_caps & ARCH_CAP_MDS_NO) == 0:
        mds_mitigation_active = 1
    printk2("[cpu-mitig] MDS active=%d (md_clear=%d; CLEAR_CPU_BUFFERS VERW" \
            " on kernel->user exits)\n",
            mds_mitigation_active, cast[uint64](md_clear))

    if ibrs_ibpb == cast[uint32](0):
        # No SPEC_CTRL MSR at all (TCG, pre-Skylake). Nothing to write.
        printk0("[cpu-mitig] spectre-v2: SPEC_CTRL not supported (CPUID.07h" \
                ":EDX[26]=0) — no IBRS/IBPB\n")
        printk2("[cpu-mitig] spectre-v2: ibrs=0 stibp=0 ssbd=0 ibpb=0" \
                " md_clear=%d active=0\n",
                cast[uint64](md_clear), cast[uint64](0))
        return

    # Read IA32_ARCH_CAPABILITIES (only when advertised) to skip mitigations
    # the HW says it doesn't need.
    caps: uint64 = 0
    if arch_cap != cast[uint32](0):
        caps = read_msr(IA32_ARCH_CAPABILITIES_MSR)

    want: uint64 = 0

    # IBRS: always set on a SPEC_CTRL-capable part (eIBRS parts want it set
    # once and left on; legacy-IBRS parts still benefit at CPL=0).
    want = want | SPEC_CTRL_IBRS
    ibrs_on: uint64 = 1

    # STIBP: only if its own bit is advertised.
    stibp_on: uint64 = 0
    if stibp != cast[uint32](0):
        want = want | SPEC_CTRL_STIBP
        stibp_on = 1

    # SSBD: only if advertised AND the HW isn't already SSB-immune.
    ssbd_on: uint64 = 0
    if ssbd != cast[uint32](0) and (caps & ARCH_CAP_SSB_NO) == 0:
        want = want | SPEC_CTRL_SSBD
        ssbd_on = 1

    spec_ctrl_base = want
    write_msr(IA32_SPEC_CTRL_MSR, want)
    spectre_v2_active = 1

    # Read back to confirm the bits latched (a virtualiser may mask some).
    got: uint64 = read_msr(IA32_SPEC_CTRL_MSR)
    printk2("[cpu-mitig] spectre-v2 SPEC_CTRL want=%p got=%p\n", want, got)
    printk2("[cpu-mitig] spectre-v2: ibrs=%d stibp=%d ssbd=%d ibpb=1" \
            " md_clear=... (see next)\n", ibrs_on, stibp_on)
    printk2("[cpu-mitig] spectre-v2: ssbd=%d md_clear=%d active=1\n",
            ssbd_on, cast[uint64](md_clear))
    if (caps & ARCH_CAP_IBRS_ALL) != 0:
        printk0("[cpu-mitig] spectre-v2: enhanced IBRS (IBRS_ALL) — set once\n")
    printk0("[cpu-mitig] spectre-v2 enabled (IBRS + IBPB-on-ctxswitch)\n")


def cpu_mitig_ibpb():
    # Indirect Branch Prediction Barrier. Called from schedule() on every
    # cross-address-space switch (CR3 change) so the outgoing task cannot
    # have poisoned the branch predictors for the incoming, distrusting,
    # task. No-op (and, crucially, no WRMSR) unless the SPEC_CTRL/PRED_CMD
    # family is advertised — so TCG never #GPs here.
    if spec_ctrl_ibpb_supported == 0:
        return
    write_msr(IA32_PRED_CMD_MSR, PRED_CMD_IBPB)


def cpu_mitig_spectre_v2_active() -> uint64:
    # Selftest accessor: 1 iff IA32_SPEC_CTRL was actually programmed.
    return spectre_v2_active


def cpu_mitig_ibpb_supported() -> uint64:
    # Selftest accessor: 1 iff the IBPB barrier is armed on ctx-switch.
    return spec_ctrl_ibpb_supported


def cpu_mitig_spec_ctrl_base() -> uint64:
    # Selftest accessor: the value programmed into IA32_SPEC_CTRL.
    return spec_ctrl_base


def cpu_mitig_mds_active() -> uint64:
    # Selftest accessor (task #87): 1 iff the exit-path VERW
    # (CLEAR_CPU_BUFFERS) is actually flushing CPU buffers on this host
    # (MD_CLEAR microcode present and the part is not MDS-immune).
    return mds_mitigation_active


# ============================================================================
# KPTI — Kernel Page-Table Isolation (Meltdown / CVE-2017-5754 mitigation).
# ============================================================================
#
# GOAL (Linux `pti`): give each process a SECOND, minimal top-level page
# table (the "user CR3") that maps user space + a tiny entry trampoline but
# NOT the kernel, and switch CR3 kernel<->user on every ring transition. A
# CPL=3 Meltdown probe of a kernel VA then faults on a NOT-PRESENT mapping
# instead of speculatively leaking the byte, because the kernel simply is
# not mapped while user code runs.
#
# ─────────────────────────────────────────────────────────────────────────
# THE HAMNIX ARCHITECTURAL WALL (why full Meltdown isolation is not yet
# reachable — verified against the live page tables, 2026-07-11):
# ─────────────────────────────────────────────────────────────────────────
#
# Linux's KPTI works because kernel and user memory occupy DISJOINT virtual
# ranges: user in the low canonical half, and ALL kernel memory — .text AND
# the direct map of physical RAM (kstacks, page tables, task_structs, the
# kmalloc heap, per-CPU areas, TSS/IST) — in the high canonical half behind
# `page_offset_base`. KPTI's user PT keeps the low half (user) + a trampoline
# and drops the high half (all kernel), so nothing secret is mapped.
#
# Hamnix's address space is shaped the OPPOSITE way (kernel.lds + the boot
# stub + fs/elf.ad):
#   * PML4[511] (0xffffffff80000000+) maps ONLY the static kernel IMAGE
#     (.text/.rodata/.data/.bss — which happens to include idt_table,
#     per_cpu_tss, per_cpu_gdt, the #DF IST stack, and the entry stubs).
#   * PML4[0] (low identity) maps low physical RAM 1:1 and is SHARED as
#     BOTH the kernel's only direct map AND the backing for user pages —
#     user memory is identity-/bias-mapped into the SAME low RAM the kernel
#     allocates its kstacks, page tables, task_structs, kmalloc heap and
#     per-CPU %gs areas from (see mm/page_alloc.ad, fs/elf.ad, the
#     setup_per_cpu_areas memblock_alloc, and the "vaddr==phys" contract in
#     mm/uaccess.ad).
#
# Consequence for a Meltdown-protective user CR3:
#   - It MUST keep PML4[0] mapped (that is where the user's own pages live).
#   - But PML4[0] IS the kernel direct map, so keeping it mapped re-exposes
#     every kstack (saved registers, syscall args), every page table, every
#     task_struct and the whole kmalloc heap to the CPL=3 Meltdown probe.
#   - Dropping PML4[0] makes user code unrunnable.
# There is no bit to set that hides the kernel heap while keeping user pages:
# they are the SAME PML4[0] subtree. So the kernel HALF we CAN hide (drop
# PML4[511]) is only the static image; the dynamic kernel state that
# Meltdown most wants (kstacks/pagetables/heap) is unhideable WITHOUT first
# relocating the entire kernel direct map out of the user-shared low half
# into a kernel-private region (a Linux-style high-half `page_offset` direct
# map). That relocation is a foundational mm rewrite touching every
# vaddr==phys assumption (uaccess/elf/pgtable/page_alloc) — exactly the
# aliasing class the ET_DYN↔direct-map work already fought.
#
# THE SWAPGS-LESS %gs CRUX (the documented deferral reason) — verified:
#   Hamnix sets IA32_GS_BASE directly (setup_percpu_asm.S wrmsr_gsbase) and
#   NEVER swapgs; on a CPL3 entry %gs ALREADY points at the kernel per-CPU
#   area. That is actually SIMPLER than Linux for a trampoline (no swapgs
#   ordering to get right). The real ordering problem is elsewhere: the
#   entry stub reads per_cpu_tss (PML4[511], .bss) and the IDT (PML4[511])
#   and its own code (PML4[511], .text) BEFORE it could switch CR3 — and on
#   a syscall SYSCALL does not even consult the TSS, it just jumps to LSTAR
#   (syscall_entry, in PML4[511] .text). So a user CR3 that drops PML4[511]
#   triple-faults at the very first CPL3->CPL0 transition: the CPU cannot
#   fetch the IDT gate / entry stub, #PF's, the #PF gate is also unmapped,
#   #DF, its gate unmapped, RESET. To switch CR3 safely the user PT must
#   still map the ENTRY WINDOW at its kernel VAs: idt_table, per_cpu_gdt,
#   per_cpu_tss, the #DF IST stack, mds_verw_sel, and the entry .text
#   (syscall_entry + every trap/irq stub up to the CR3 switch). In Hamnix
#   those pages are SCATTERED across the high-half .text/.bss/.rodata rather
#   than collected into a Linux-style contiguous `cpu_entry_area`, so a live
#   trampoline needs that collection built first.
#
# ─────────────────────────────────────────────────────────────────────────
# WHAT THIS COMMIT LANDS (banked, gated, boot-safe):
# ─────────────────────────────────────────────────────────────────────────
#   1. Meltdown-susceptibility detection (IA32_ARCH_CAPABILITIES.RDCL_NO)
#      + a mitigation-log line + status accessors (parity with the SMEP /
#      SMAP / Spectre-v2 / MDS reporting already here).
#   2. kpti_build_user_pml4(): the real per-process "user CR3" constructor —
#      allocates a fresh top-level page, copies PML4[0] (user + the shared
#      low identity) and leaves PML4[511] UNMAPPED, i.e. the kernel static
#      image is stripped from the user view. This is the exact page-table
#      object a live trampoline would install on ring exit.
#   3. kpti_isolation_selftest(): NON-DESTRUCTIVE proof of acceptance
#      criterion (b) — builds a user PML4 from the boot CR3 and WALKS it
#      (read-only, no CR3 switch, so zero triple-fault risk) to assert that
#      an actual kernel .text VA does NOT resolve in it while a low user VA
#      does. Frees the page. Logged as [kpti] PASS/FAIL.
#   4. The trampoline CR3-switch primitives live in arch/x86/kernel/
#      kpti_asm.S (kpti_cr3_to_user / kpti_cr3_to_kernel) with the
#      VERW-vs-CR3 ordering worked out, as the building blocks for the live
#      splice — deliberately NOT wired into the hot entry path yet, so the
#      green boot is preserved and the remaining work (build the
#      cpu_entry_area; then, for real protection, relocate the kernel direct
#      map out of PML4[0]) is isolated to those two follow-ups.
#
# The live per-entry CR3 switch is GATED (KPTI_LIVE_ENABLE, default 0). With
# it 0 the box boots exactly as before; the detection + self-test run
# regardless so the mechanism is exercised on every boot.

# IA32_ARCH_CAPABILITIES.RDCL_NO (bit 0): the part is NOT susceptible to
# Rogue Data Cache Load (Meltdown). If set, KPTI would be pure overhead and
# Linux leaves `pti` off. MSR 0x10a is only architectural when
# CPUID.07h:EDX[29] (ARCH_CAP) is advertised — reuse the existing gate.
ARCH_CAP_RDCL_NO: uint64 = 0x1

# Compile-time gate for the LIVE per-entry CR3 switch (the trampoline splice
# into syscall_64.S / irq_asm.S / trap_asm.S). Default 0: the switch is NOT
# engaged, so the box boots unchanged. Detection + the read-only isolation
# self-test run irrespective of this flag. Flipping this to 1 is blocked on
# the two follow-ups documented above (cpu_entry_area collection; kernel
# direct-map relocation out of PML4[0]).
KPTI_LIVE_ENABLE: uint64 = 0

# Runtime state, published by setup_kpti() / kpti_isolation_selftest().
kpti_cpu_affected:   uint64 = 0   # 1 iff the CPU is Meltdown-susceptible
kpti_supported:      uint64 = 0   # 1 iff the user-PT machinery is built in
kpti_live:           uint64 = 0   # 1 iff the per-entry CR3 switch is engaged
kpti_selftest_pass:  uint64 = 0   # 1 iff the isolation self-test proved
                                  #   kernel .text unmapped in the user PT


def kpti_build_user_pml4(kernel_pml4_phys: uint64) -> uint64:
    # Construct a process's "user CR3": a fresh top-level page that maps
    # user space (via the shared PML4[0] low-identity subtree) but NOT the
    # kernel static image (PML4[511] left 0). This is the page-table object
    # a live KPTI trampoline installs on every ring exit.
    #
    # We COPY the PML4[0] entry (sharing the whole PDPT/PD/PT subtree with
    # the kernel PT — that subtree backs the user's pages) and leave every
    # other slot 0, so 0xffffffff8000_0000+ (kernel .text/.rodata/.data/.bss,
    # incl. idt_table / per_cpu_tss) is ABSENT from this table. Returns the
    # physical address of the fresh PML4 page, or 0 on OOM. The caller owns
    # it and must free_page() it when the task's address space is torn down.
    #
    # NB: because PML4[0] is Hamnix's shared kernel direct map (see the wall
    # write-up above), this table still exposes the low-identity kernel heap
    # to a CPL3 Meltdown probe. Stripping THAT requires relocating the direct
    # map out of PML4[0] first; this constructor is the mechanism, not yet
    # the full isolation.
    user_pml4: uint64 = alloc_page()
    if user_pml4 == 0:
        return 0
    # Zero the fresh page (alloc_page does not guarantee zeroed).
    dst: Ptr[uint64] = cast[Ptr[uint64]](user_pml4)
    i: uint64 = 0
    while i < cast[uint64](512):
        dst[i] = cast[uint64](0)
        i = i + 1
    # Copy ONLY PML4[0] (low identity + user). PML4[511] stays 0 → kernel
    # image is unmapped in the user view.
    src_base: uint64 = kernel_pml4_phys & PGT_ADDR_MASK_KM
    src: Ptr[uint64] = cast[Ptr[uint64]](src_base)
    dst[0] = src[0]
    return user_pml4


def _kpti_walk_present(pml4_phys: uint64, va: uint64) -> uint64:
    # Read-only 4-level walk of `va` in the page table rooted at pml4_phys
    # (a PHYSICAL address; low identity == virtual so we deref it directly,
    # exactly like _restamp_pml4_subtree_us0). Returns the leaf entry (P=1)
    # if `va` maps to a present page at any level, else 0. Handles 1 GiB and
    # 2 MiB huge leaves. Used by the isolation self-test — never switches
    # CR3, so it cannot fault on an unmapped kernel VA.
    pml4_base: uint64 = pml4_phys & PGT_ADDR_MASK_KM
    pml4_idx: uint64 = (va >> 39) & cast[uint64](0x1FF)
    pml4e: uint64 = cast[Ptr[uint64]](pml4_base + pml4_idx * cast[uint64](8))[0]
    if (pml4e & PGT_FLAG_P_KM) == 0:
        return 0
    pdpt_base: uint64 = pml4e & PGT_ADDR_MASK_KM
    pdpt_idx: uint64 = (va >> 30) & cast[uint64](0x1FF)
    pdpte: uint64 = cast[Ptr[uint64]](pdpt_base + pdpt_idx * cast[uint64](8))[0]
    if (pdpte & PGT_FLAG_P_KM) == 0:
        return 0
    if (pdpte & PGT_FLAG_PS_KM) != 0:
        return pdpte                         # 1 GiB leaf
    pd_base: uint64 = pdpte & PGT_ADDR_MASK_KM
    pd_idx: uint64 = (va >> 21) & cast[uint64](0x1FF)
    pde: uint64 = cast[Ptr[uint64]](pd_base + pd_idx * cast[uint64](8))[0]
    if (pde & PGT_FLAG_P_KM) == 0:
        return 0
    if (pde & PGT_FLAG_PS_KM) != 0:
        return pde                           # 2 MiB leaf
    pt_base: uint64 = pde & PGT_ADDR_MASK_KM
    pt_idx: uint64 = (va >> 12) & cast[uint64](0x1FF)
    pte: uint64 = cast[Ptr[uint64]](pt_base + pt_idx * cast[uint64](8))[0]
    if (pte & PGT_FLAG_P_KM) == 0:
        return 0
    return pte


def kpti_isolation_selftest() -> uint64:
    # Acceptance criterion (b): the user CR3 does NOT map kernel .text.
    # Build a user PML4 from the live boot CR3, then WALK it read-only:
    #   * a kernel .text VA MUST be absent (the isolation property), and
    #   * a low user/identity VA MUST be present (user code can still run).
    # Returns 1 on PASS, 0 on FAIL. Non-destructive (frees its page); no CR3
    # switch, so it is triple-fault-proof and runs on every boot.
    kern_cr3: uint64 = get_bsp_cr3()
    user_pml4: uint64 = kpti_build_user_pml4(kern_cr3)
    if user_pml4 == 0:
        printk0("[kpti] FAIL: could not allocate a user PML4 (OOM)\n")
        return 0

    ktext: uint64 = kernel_text_start()
    kmap: uint64 = _kpti_walk_present(user_pml4, ktext)
    # A representative low user VA: 0x400000, where non-PIE ET_EXEC user
    # binaries link (see kernel.lds rationale) — backed by the shared
    # PML4[0] subtree, so it must resolve.
    umap: uint64 = _kpti_walk_present(user_pml4, cast[uint64](0x400000))

    printk2("[kpti] user-PT walk: kernel .text VA %p -> leaf %p\n", ktext, kmap)
    printk1("[kpti] user-PT walk: user VA 0x400000 -> leaf %p\n", umap)

    ok: uint64 = 0
    if kmap == 0 and umap != 0:
        ok = 1
        kpti_selftest_pass = 1
        printk0("[kpti] PASS: user CR3 does NOT map kernel .text; user" \
                " space still mapped\n")
    else:
        if kmap != 0:
            printk0("[kpti] FAIL: kernel .text IS mapped in the user CR3\n")
        if umap == 0:
            printk0("[kpti] FAIL: user space NOT mapped in the user CR3\n")

    free_page(user_pml4)
    return ok


def setup_kpti():
    # Detect Meltdown susceptibility, report KPTI status, and run the
    # non-destructive isolation self-test. Called from start_kernel after
    # setup_spectre_v2(). No live CR3 switch is engaged (KPTI_LIVE_ENABLE=0);
    # the machinery is exercised via the self-test on every boot.
    buf: Array[4, uint32]
    buf[0] = cast[uint32](0)
    buf[1] = cast[uint32](0)
    buf[2] = cast[uint32](0)
    buf[3] = cast[uint32](0)
    cpuid_get(cast[uint32](7), cast[uint32](0), &buf[0])
    edx: uint32 = buf[3]
    arch_cap: uint32 = (edx >> CPUID_07H_EDX_ARCH_CAP_BIT) & cast[uint32](1)

    # Assume susceptible unless the CPU explicitly says RDCL_NO. Parts that
    # don't advertise ARCH_CAPABILITIES at all (older Intel, TCG) are treated
    # as potentially affected — the conservative Linux default.
    affected: uint64 = 1
    if arch_cap != cast[uint32](0):
        caps: uint64 = read_msr(IA32_ARCH_CAPABILITIES_MSR)
        if (caps & ARCH_CAP_RDCL_NO) != 0:
            affected = 0
    kpti_cpu_affected = affected

    # The user-PT construction machinery is compiled in unconditionally.
    kpti_supported = 1

    if KPTI_LIVE_ENABLE == 1:
        kpti_live = 1
    else:
        kpti_live = 0

    printk2("[cpu-mitig] KPTI: cpu_meltdown_affected=%d supported=%d\n",
            kpti_cpu_affected, kpti_supported)
    printk1("[cpu-mitig] KPTI: live per-entry CR3 switch engaged=%d\n",
            kpti_live)

    # Exercise the mechanism: prove the user PT isolates the kernel image.
    kpti_isolation_selftest()

    if kpti_live == 0:
        printk0("[cpu-mitig] KPTI staged: user-PT + trampoline built; live" \
                " CR3 switch gated (kernel direct map shares PML4[0] with" \
                " user — see cpu_mitigations.ad)\n")


def cpu_mitig_kpti_supported() -> uint64:
    # Selftest accessor: 1 iff the KPTI user-PT machinery is built in.
    return kpti_supported


def cpu_mitig_kpti_active() -> uint64:
    # Selftest accessor: 1 iff the live per-entry CR3 switch is engaged.
    return kpti_live


def cpu_mitig_kpti_selftest_pass() -> uint64:
    # Selftest accessor: 1 iff the isolation self-test proved the user CR3
    # does not map kernel .text.
    return kpti_selftest_pass


def cpu_mitig_kpti_cpu_affected() -> uint64:
    # Selftest accessor: 1 iff the CPU is Meltdown-susceptible (no RDCL_NO).
    return kpti_cpu_affected

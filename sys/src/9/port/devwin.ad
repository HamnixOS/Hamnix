# sys/src/9/port/devwin.ad
#
# #wsys/<N>/{ctl,data,event}   —   rio-faithful per-window file server.
#
# This is the THIN WRAPPER half of task #442 ("rio-faithful reshape").
# The legacy `/dev/wsys/<wid>/draw/{ctl,fb,...}` + `/dev/wsys/<wid>/pointer
# + /dev/wsys/<wid>/keys` surface (devwsys.ad) continues to serve the
# desktop / panel / x11 bridge clients unchanged. devwin exposes the
# SAME underlying state (window slots, blitter backbuffer, event wait
# queues) as a Plan-9-rio-shape triple:
#
#     #wsys/<N>/ctl       — text ctl verbs (resize/move/focus/... — a
#                            client-facing subset of the legacy ctl
#                            + wctl surfaces, normalised to one file).
#     #wsys/<N>/data      — opaque BLIT + dirty-rect protocol bytes;
#                            the same wire format devwsys's draw/ctl
#                            already accepts (see devwsys.ad §"#442
#                            RIO-FAITHFUL RESHAPE — wire format").
#     #wsys/<N>/event     — UNIFIED ROUTED EVENT STREAM. One ASCII
#                            line per event. Multiplexes the existing
#                            per-wid pointer + keys streams into a
#                            single file the client `read`s in a tight
#                            loop:
#                              "p <x> <y> <btns>\n"   (pointer)
#                              "k <code> <down>\n"    (keys)
#                            Block-reads off the same WaitQueue pair
#                            (wsys_ptr_wq / wsys_keys_wq) that
#                            devwsys.ad already wakes from the
#                            compositor's pointer/keys write path.
#
# CLIENT'S NAMESPACE: init binds `/dev/win` to `#wsys/<N>` for the
# client's wid N, so the client never names a wid. The compositor
# (and other system clients) still see the whole `/dev/wsys/*` tree
# and address windows by wid. The two views share state — there is
# only one wid table, one draw backbuffer per slot, one event ring
# per slot.
#
# THIS COMMIT (COMMIT 1, skeleton). The triple is wired only at the
# Adder/C-shape boundary: the read/write entry points exist with their
# real signatures and the docs above are load-bearing, but their
# bodies are minimal placeholders that return ENOSYS / EINVAL. The
# next commits attach `event` to the real wait queue (COMMIT 2) and
# route `data` through devwsys_draw_ctl_write (COMMIT 3). The legacy
# /dev/wsys/* path stays the source of truth for panel/desktop.
#
# WHY A SEPARATE FILE: devwsys.ad is already 6kLOC; carving the rio
# surface into its own module gives a small, audit-able place where
# the rio-faithful semantics live, and lets us delete it (or fold
# back) cleanly if the reshape is reversed. All real backbuffer /
# event-ring state stays in devwsys; devwin is purely a thin facade.
#
# ADDER QUIRKS: leading-underscore top-level names are module-private;
# no malloc on the hot path; we don't introduce new Array storage
# here — every wrapper either delegates to devwsys or fills a
# caller-provided buffer in place.

from sys.src.port9.port.devwsys import (
    wsys_wid_in_use, MAX_WINDOWS,
)


# --- public surface -------------------------------------------------

# Negative return values follow the kernel's plan-9-style errno
# convention used elsewhere in this directory: -2 == ENOENT (the
# named wid is not allocated), -38 == ENOSYS (not yet implemented).

WIN_ENOENT: int64 = -2
WIN_ENOSYS: int64 = -38
WIN_EINVAL: int64 = -22


def _devwin_wid_valid(wid: int32) -> int32:
    # Returns 1 iff wid is in [1, MAX_WINDOWS) AND wsys says the slot
    # is currently allocated. Centralised so all three entry points
    # below give the same ENOENT-shaped error for an unknown wid.
    if wid < 1:
        return 0
    if cast[uint64](wid) >= MAX_WINDOWS:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return 0
    return 1


# --- #wsys/<N>/ctl --------------------------------------------------
#
# Read: snapshot of the window's current ctl-line state ("geom <x>
# <y> <w> <h>\nfocus <0|1>\n..."). Skeleton returns 0 (EOF) so cat
# terminates cleanly during bring-up.
# Write: text ctl verbs (resize/move/focus/...). Skeleton accepts the
# whole buffer and discards it (returns count). The follow-up commit
# routes these to devwsys_wctl_write so the existing implementation
# does the actual mutation.

def devwin_ctl_read(wid: int32, off: uint64, buf: Ptr[uint8],
                    count: uint64) -> int64:
    if _devwin_wid_valid(wid) == 0:
        return WIN_ENOENT
    # Skeleton: empty snapshot. Real impl will compose geom/focus/...
    # lines from the legacy /dev/wsys/<N>/wctl + geometry readers.
    return 0


def devwin_ctl_write(wid: int32, buf: Ptr[uint8], count: uint64) -> int64:
    if _devwin_wid_valid(wid) == 0:
        return WIN_ENOENT
    if count == 0:
        return 0
    # Skeleton: accept-and-drop. Real impl: dispatch on the verb to
    # devwsys_wctl_write / devwsys_ctl_write.
    return cast[int64](count)


# --- #wsys/<N>/data -------------------------------------------------
#
# The BLIT protocol wire surface, byte-for-byte the same as
# devwsys's existing draw/ctl ('B'/'D' opcodes — see devwsys.ad
# §"#442 RIO-FAITHFUL RESHAPE"). Skeleton accepts the whole buffer
# without forwarding (no pixels reach the backbuffer yet). Reads
# always EOF — `data` is write-only from the client side.

def devwin_data_read(wid: int32, off: uint64, buf: Ptr[uint8],
                     count: uint64) -> int64:
    if _devwin_wid_valid(wid) == 0:
        return WIN_ENOENT
    return 0


def devwin_data_write(wid: int32, buf: Ptr[uint8], count: uint64) -> int64:
    if _devwin_wid_valid(wid) == 0:
        return WIN_ENOENT
    if count == 0:
        return 0
    # Skeleton: accept-and-drop. COMMIT 3 hands `buf` to
    # devwsys_draw_ctl_write so the existing blitter runs the
    # protocol bytes for real.
    return cast[int64](count)


# --- #wsys/<N>/event ------------------------------------------------
#
# Unified routed-event stream — multiplex of the per-wid pointer and
# keys rings devwsys already populates from the compositor's input
# pumps. Block-reads off the same WaitQueue pair so the rio client
# sleeps off the runqueue exactly like a legacy /dev/wsys/<N>/pointer
# reader does. Write side is reserved for the compositor to inject
# synthetic events (skeleton: ENOSYS).

def devwin_event_read(wid: int32, off: uint64, buf: Ptr[uint8],
                      count: uint64) -> int64:
    if _devwin_wid_valid(wid) == 0:
        return WIN_ENOENT
    if count == 0:
        return 0
    # Skeleton: ENOSYS. COMMIT 2 replaces this with a real
    # prepare/recheck/commit loop against wsys_ptr_wq + wsys_keys_wq
    # that emits one "p ..."/"k ..." ASCII line per event.
    return WIN_ENOSYS


def devwin_event_write(wid: int32, buf: Ptr[uint8], count: uint64) -> int64:
    if _devwin_wid_valid(wid) == 0:
        return WIN_ENOENT
    # Synthetic-event injection — reserved for the compositor; no
    # current user. Skeleton: report ENOSYS.
    return WIN_ENOSYS

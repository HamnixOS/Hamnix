# sys/src/9/port/devproc.ad
#
# Layer 1 (Plan 9-shape) per-process introspection device — fifth
# concrete /dev style cdev family on the Hamnix native surface,
# sibling to devcons.ad / devtime.ad / devpid.ad / devrandom.ad.
# Mirrors 9front's /sys/src/9/port/devproc.c at minimum scope: a
# /proc/<pid>/<file> name resolves to a stateless fd whose read
# produces one line of text describing the named process.
#
# See docs/native-api.md ("Reserved well-known paths" — entries for
# /proc/<pid>/{cwd,status,ns,note}). This commit ships `cwd` and
# `status` (read-only); `note` is deferred until notify(2)/noted(2)
# land, and `ns` is deferred until the Phase D namespace machinery
# in chan.ad gains a real read-side.
#
# VFS plumbing: fs/vfs.ad recognises a `/proc/<digits>/<leaf>` path,
# calls devproc_open(path) which returns the 24-bit (pid << 8 | kind)
# encoding. The encoding carries enough state for devproc_read to
# recover pid + file kind on its own — no per-fd kmalloc beyond the
# pool chan slot, and close needs no devproc hook. Stateless backend
# matches the other Plan 9-shape cdevs in this directory; see
# devcons.ad for the prior-art comment block.
#
# Phase 4b (fd→Chan): a /proc/<pid>/<leaf> fd is a unified FD_CHAN_MARK
# fd backed by a DEV_PROC pool chan (sys/src/9/port/namec.ad). The chan's
# back_slot carries the devproc encoding:
#
#     [23: 8] = pid (uint16-bounded; we cap at 0xFFFF on encode)
#     [ 7: 0] = file_kind            — DEVPROC_KIND_* below
#
# namec_read / namec_write dispatch a DEV_PROC chan to devproc_read /
# devproc_write below (by name — devproc imports namec, so namec must
# not import back). The legacy FD_PROC_MARK_BASE (0xFE000000) fd_idx
# tag + devproc_is_proc_fd probe are RETIRED: nothing stamps an encoded
# marker into TaskStruct.fd_idx anymore.

from kernel.sched.core import (
    task_lookup_by_pid, task_state, task_pid_at, task_pml4,
    get_cwd_buf, set_current_errstr,
    STATE_READY, STATE_RUNNING, STATE_EXITED, STATE_WAIT,
    # devproc_listdir walks the live task table the same way
    # render_tasks does: task_table_size() slots, each non-FREE one is a
    # live pid directory under bare `#p`.
    task_table_size, STATE_FREE,
    task_name0_at,
    current_idx_get,
    task_note_handler_rip,
    task_note_group,
    task_parent_pid, get_task_comm_ptr,
    # `/proc/self/...` resolves to the CALLING task's pid — needed so
    # a program can introspect its own namespace (HAMSH §14).
    current_task_pid,
    # /proc/<pid>/stat fields 14/15: real per-task CPU-tick counts.
    task_utime_ticks_at, task_stime_ticks_at,
    # /proc/<pid>/stat fields 10/12: real per-task page-fault counts.
    task_minflt_at, task_majflt_at,
    # /proc/<pid>/stat field 22 (starttime): real per-task creation jiffy.
    task_start_jiffies_at, task_set_start_jiffies_at,
    # /proc/<pid>/stat fields 18 (priority = 20+nice) / 19 (nice): real
    # per-task POSIX nice. sched_set_nice used by the prionice self-test.
    sched_get_nice, sched_set_nice,
    # /proc/<pid>/ctl `policy` verb + rtsched self-test: realtime
    # scheduling policy mechanism (SCHED_FIFO/SCHED_RR) in core.ad.
    sched_set_scheduler, sched_get_policy, sched_get_rt_priority,
    sched_priority_max, sched_priority_min,
    SCHED_OTHER, SCHED_FIFO, SCHED_RR,
    # /proc/<pid>/oom_score_adj read file + the `oomadj` ctl verb: the per-task
    # OOM-killer bias store lives in kernel/sched/core.ad.
    oom_adj_get64, oom_adj_set,
    # /proc/<pid>/stat field 5 (pgrp): real per-task job process-group id.
    # task_set_job_pgid used by the pgrp self-test's deterministic direct-set.
    task_get_job_pgid, task_set_job_pgid,
    # /proc/<pid>/stat field 9 (flags): real PF_KTHREAD bit derived from the
    # per-task is_user word — 0 for a CPL=3 user task, set for a kernel thread.
    task_is_user_at,
    # /proc/<pid>/stat fields 11/13/16/17 (cminflt/cmajflt/cutime/cstime):
    # child-resource accounting rolled up at reap. setters used by the
    # childacct self-test's deterministic direct-set.
    task_cminflt_at, task_cmajflt_at,
    task_cutime_ticks_at, task_cstime_ticks_at,
    task_set_cminflt_at, task_set_cmajflt_at,
    task_set_cutime_ticks_at, task_set_cstime_ticks_at,
    # /proc/<pid>/io: rchar/wchar/syscr/syscw accessors + setters (the
    # setters feed procio_selftest's deterministic direct-set), plus the
    # inblock/oublock accessors+setters that back read_bytes/write_bytes.
    task_rchar_at, task_wchar_at, task_syscr_at, task_syscw_at,
    task_set_rchar_at, task_set_wchar_at, task_set_syscr_at, task_set_syscw_at,
    task_inblock_at, task_oublock_at,
    task_set_inblock_at, task_set_oublock_at,
    # /proc/<pid>/limits: per-task resource-limit accessors backing
    # emit_proc_limits (the rlimit store lives in kernel/sched/core.ad).
    rlimit_get_cur, rlimit_get_max,
    # /proc/<pid>/fd: per-task fd-table accessors backing emit_proc_fd —
    # the fd_idx marker (or cpio file index) and fd_buf word for each of
    # the TASK_NFDS descriptor slots. The fd-marker constants below name
    # the kinds we render in human-readable form.
    task_fd_idx_at, task_fd_buf_at, TASK_NFDS,
    task_set_fd_idx_at, task_set_fd_buf_at,
    FD_CLOSED_MARK, FD_STDIN_MARK, FD_STDOUT_MARK, FD_STDERR_MARK,
)
# The stateless local cdevs open as FD_CHAN_MARK fds carrying an inline
# namec chan id; the /proc/<pid>/fd renderer resolves the dev_type to a
# canonical /dev path via namec_chan_dev_type.
from sys.src.port9.port.namec import (
    FD_CHAN_MARK, namec_chan_dev_type,
    DEV_CONS, DEV_TIME, DEV_PID, DEV_RANDOM, DEV_URANDOM, DEV_MOUSE,
    DEV_CPUINFO, DEV_MEMINFO, DEV_UPTIME, DEV_LOADAVG, DEV_VERSION,
    DEV_HOSTNAME, DEV_NULL, DEV_ZERO,
    DEV_BUF_FILE, DEV_DIR_FILE, DEV_DEVFD, namec_chan_devfd_num,
    # Phase 4c: pipe-end chans render Linux's "pipe:[<ring slot>]" via
    # the chan's back_slot; the selftest opens a real pipe chan.
    DEV_PIPE_R, DEV_PIPE_W, namec_chan_back_slot, namec_open_pipe_end,
    namec_close,
    # Phase 4c (socket fold): socket chans render "socket:[<fdbuf>]"
    # via the chan's back_slot; the selftest opens a real socket chan.
    DEV_SOCKET, DEV_SOCKETPAIR, namec_open_socket,
    namec_socket_set_record,
)
# Phase 4c: procfd_selftest allocates a REAL pipe ring + write-end chan
# so the /proc fd renderer is exercised against the folded DEV_PIPE
# representation, then unwinds both end-references on the way out.
from fs.pipe import pipe_alloc, pipe_close_reader, pipe_close_writer
# M16.109: note delivery body lives in sysnote.ad so the same self-
# delivery primitive can be re-used by future drivers (kbd Ctrl-C ->
# postnote / segfault handler -> postnote etc.).
from sys.src.port9.port.sysnote import deliver_note_to_current
# Phase G: /proc/<pid>/notepg posts a note to the target's whole note
# group (Plan 9 note-group WIDE delivery).
from sys.src.port9.port.sysnote import post_note_to_group
# Single-target /proc/<pid>/note cross-task delivery.
from sys.src.port9.port.sysnote import post_note_to_pid
# V3: /proc/<pid>/ns renders the target task's Pgrp mtab as
# ns(1)-shape text. The render helper lives in chan.ad next to the
# Pgrp struct it walks.
from sys.src.port9.port.chan import pgrp_render_ns, pgrp_for_task
from kernel.printk.printk import printk1, printk0, printk2, printk_set_level
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG
# §13: /proc/<pid>/maps renders the target task's VMA list.
from mm.vma import vma_maps_render, task_vsize_bytes, task_rss_pages
# procstat_cpu_selftest briefly enables CPU interrupts so the LAPIC
# timer tick fires and accrues stime ticks to the boot task — the same
# enable/spin/disable warmup rusage_selftest uses. start_kernel runs
# IF-blocked, so without this the busy-spin would never see jiffies move.
from arch.x86.kernel.time import get_jiffies
extern def local_irq_enable()
extern def local_irq_disable()
extern def cpu_relax()

# Phase 4b: FD_PROC_MARK_BASE (0xFE000000) / FD_PROC_MARK_MASK are
# DELETED — the (pid << 8 | kind) encoding rides in a DEV_PROC pool
# chan's back_slot now (see header), never in TaskStruct.fd_idx.

# File-kind tags (lowest 8 bits of the encoding).
DEVPROC_KIND_STATUS: uint32 = 0
DEVPROC_KIND_CWD:    uint32 = 1
DEVPROC_KIND_STAT:   uint32 = 2
# M16.109: write-only entry for Plan 9 note (signal) delivery. Reads
# return -1 + errstr "note: not readable" — Plan 9 contract.
DEVPROC_KIND_NOTE:   uint32 = 3
# V3: /proc/<pid>/ns. Read renders the target task's Pgrp mtab as
# ns(1)-shape text ("bind /from /to\n", "mount #s/<srvfd> /to\n").
# Write returns -1 + errstr ("ns: not writable") — Plan 9 contract;
# changing a Pgrp from outside its owning task is V5+ scope.
DEVPROC_KIND_NS:     uint32 = 4
# §13: Linux-ABI /proc/<pid>/{cmdline,comm,maps}. cmdline renders the
# process command line (we have no per-task argv storage, so it is
# the task's comm name as a single NUL-terminated argv entry — a
# well-formed one-element cmdline). comm is the comm name + '\n'.
# maps walks the task's VMA list in Linux /proc/<pid>/maps shape.
DEVPROC_KIND_CMDLINE: uint32 = 5
DEVPROC_KIND_COMM:    uint32 = 6
DEVPROC_KIND_MAPS:    uint32 = 7
# Phase G: write-only entry for Plan 9 note-group WIDE delivery. A write
# to /proc/<pid>/notepg posts the note string to EVERY live process in
# the target pid's note group (Plan 9's process-group signalling). Reads
# return -1 + errstr — same write-only contract as `note`.
DEVPROC_KIND_NOTEPG:  uint32 = 8
# §13: Linux-ABI /proc/<pid>/statm. One line of 7 space-separated PAGE
# counts: size resident shared text lib data dt. size = vsize/4096,
# resident = present-page count; the rest render 0 (Linux sets lib/dt to
# 0 too). Both real fields come from an on-demand VMA walk.
DEVPROC_KIND_STATM:   uint32 = 9
# §13: Linux-ABI /proc/<pid>/io — 7-line per-task I/O accounting node read by
# iotop / monitoring. rchar/wchar/syscr/syscw are real per-task counters
# charged at the read()/write() syscall boundary (linux_abi/u_syscalls.ad);
# read_bytes/write_bytes derive from the per-task block-I/O counters
# (inblock/oublock * 512); cancelled_write_bytes is always 0 (we never cancel
# writeback).
DEVPROC_KIND_IO:      uint32 = 10
# §13: Linux-ABI /proc/<pid>/limits — the per-task resource-limit table read by
# ulimit/getrlimit consumers. A header row plus one line per RLIM_NLIMITS(16)
# resource: "<Name> <Soft Limit> <Hard Limit> <Units>". The Soft/Hard cell is
# the literal "unlimited" when the stored value == RLIM_INFINITY, else the
# decimal value. Backed by the real rlimit store (rlimit_get_cur/rlimit_get_max,
# kernel/sched/core.ad), seeded at task creation to the Linux defaults.
DEVPROC_KIND_LIMITS:  uint32 = 11
# Plan 9 /proc/<pid>/ctl — write-only process control surface. Writing a
# control message ("pri <int>\n") to it mutates the target task: in Plan 9
# "everything is a file", so changing a process's priority is a write to its
# ctl file, NOT a syscall. Reads return -1 + errstr ("ctl: not readable") —
# ctl is a control surface, not a status read. The verb set is minimal for
# now (only `pri`, which maps to the per-task POSIX nice via sched_set_nice).
DEVPROC_KIND_CTL:     uint32 = 12
# Linux /proc/<pid>/oom_score_adj — here a READ-ONLY view of the per-task
# OOM-killer bias (the write path is the `oomadj <int>` ctl verb above). Reads
# render the decimal oom_score_adj value (-1000..1000) + '\n'. Backed by the
# real per-task store (oom_adj_get, kernel/sched/core.ad), consulted by the OOM
# badness heuristic in mm/reclaim.ad.
DEVPROC_KIND_OOM_SCORE_ADJ: uint32 = 13
# Gap-report #3: Linux-ABI /proc/<pid>/fd. The Plan-9 native /proc has no
# getdents-walkable per-pid directory (vfs_listdir has no /proc arm — every
# leaf is reached by a direct devproc_path_match path open), so a real
# sub-directory of one symlink per descriptor would need walk machinery that
# does not exist here. We therefore serve `fd` as a single TEXT file in the
# exact stateless-marker shape every sibling leaf uses: one line per OPEN
# descriptor, "<fd>\t<target>\n", where <target> is the human-readable backing
# object. For path-less anon objects we use Linux's anon-inode rendering
# ("pipe:[id]", "socket:[id]", ...) so the output reads the same as a Linux
# `ls -l /proc/<pid>/fd` symlink-target column would. Backed by the real
# per-task fd table (task_fd_idx_at/task_fd_buf_at, kernel/sched/core.ad).
DEVPROC_KIND_FD:      uint32 = 14


def _is_digit(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return 1
    return 0


def _cstr_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    # True if the two NUL-terminated strings match. Used for the
    # leaf-name compare (`status` / `cwd` / `stat`) where we already
    # know the substring start in `a`. We can't use a generic strcmp
    # because the surrounding code is path-walking and the leaf
    # isn't NUL-terminated in-situ — the caller passes a copy.
    i: uint64 = 0
    while True:
        ca: uint8 = a[i]
        cb: uint8 = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1


def _u64_to_dec(value: uint64, out: Ptr[uint8]) -> uint64:
    # Same reverse-fill helper devtime.ad / devpid.ad use. Lifted
    # locally so devproc.ad doesn't depend on its sibling files —
    # the procfs renderer has its own copy too, and keeping each
    # cdev self-contained matches how 9front's port files are
    # structured (no shared "devutil.c" — every cdev inlines its
    # bit-twiddling).
    if value == 0:
        out[0] = 48                              # '0'
        return 1
    digits: Array[24, uint8]
    n: uint64 = 0
    while value != 0:
        digits[n] = cast[uint8](value % 10) + 48
        value = value / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return written


def _i64_to_dec(value: int64, out: Ptr[uint8]) -> uint64:
    # Signed sibling of _u64_to_dec for /proc/<pid>/stat field 19 (nice),
    # which can be negative (-20..+19). Emits a leading '-' for negatives,
    # then the magnitude via _u64_to_dec. Returns total bytes written.
    if value < 0:
        out[0] = 45                              # '-'
        mag: uint64 = cast[uint64](0 - value)
        return 1 + _u64_to_dec(mag,
                               cast[Ptr[uint8]](cast[uint64](&out[0]) + 1))
    return _u64_to_dec(cast[uint64](value), out)


def _u64_to_hex(value: uint64, out: Ptr[uint8]) -> uint64:
    # 16-char fixed-width hex for the pml4 field in the status line.
    # The pml4 is a kernel physical address; rendering it with leading
    # zeros keeps the column alignment predictable for grep / awk.
    HEX: Ptr[uint8] = "0123456789abcdef"
    out[0] = 48                                  # '0'
    out[1] = 120                                 # 'x'
    i: uint64 = 0
    while i < 16:
        nibble: uint64 = (value >> ((15 - i) * 4)) & 0xF
        out[2 + i] = HEX[nibble]
        i = i + 1
    return 18


def _parse_proc_path(path: Ptr[char], out_pid: Ptr[uint64],
                     out_kind: Ptr[uint32]) -> int32:
    # Walk a /proc/<pid>/<file> path. Returns 0 on success and writes
    # the parsed pid + file_kind through the out-pointers. Non-zero
    # means "not a /proc/<pid>/<leaf> path" — the caller falls back to
    # the existing procfs renderer.
    #
    # We don't trust the caller to have already prefix-checked
    # "/proc/" — verifying it here makes this function safe to drop
    # into _any_ vfs_open call site if devproc grows direct callers.
    if path[0] != 47:                            # '/'
        return -1
    if path[1] != 112 or path[2] != 114 \
            or path[3] != 111 or path[4] != 99 \
            or path[5] != 47:                    # "proc/"
        return -1
    # Parse the pid component. `self` is an alias for the CALLING
    # task's pid — `/proc/self/ns` lets a program read its own
    # namespace without first having to discover its pid (HAMSH §14).
    i: uint64 = 6
    pid: uint64 = 0
    if path[6] == 115 and path[7] == 101 \
            and path[8] == 108 and path[9] == 102 \
            and path[10] == 47:                  # "self/"
        pid = current_task_pid()
        i = 11
    else:
        if _is_digit(cast[uint8](path[i] & 0xFF)) == 0:
            return -1
        while _is_digit(cast[uint8](path[i] & 0xFF)) != 0:
            pid = pid * 10 + cast[uint64](path[i] - 48)
            i = i + 1
        if path[i] != 47:                        # '/'
            return -1
        i = i + 1
    # The leaf is the rest of the path. Copy into a small scratch so
    # we can NUL-compare against the literal strings.
    leaf: Array[16, uint8]
    j: uint64 = 0
    while j + 1 < 16 and path[i] != 0:
        leaf[j] = cast[uint8](path[i] & 0xFF)
        i = i + 1
        j = j + 1
    leaf[j] = 0
    if path[i] != 0:
        return -1                                # leaf too long for any
                                                 # name we serve
    if _cstr_eq(&leaf[0], "status") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_STATUS
        return 0
    if _cstr_eq(&leaf[0], "cwd") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_CWD
        return 0
    if _cstr_eq(&leaf[0], "stat") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_STAT
        return 0
    if _cstr_eq(&leaf[0], "statm") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_STATM
        return 0
    if _cstr_eq(&leaf[0], "io") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_IO
        return 0
    if _cstr_eq(&leaf[0], "limits") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_LIMITS
        return 0
    if _cstr_eq(&leaf[0], "note") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_NOTE
        return 0
    if _cstr_eq(&leaf[0], "notepg") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_NOTEPG
        return 0
    if _cstr_eq(&leaf[0], "ns") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_NS
        return 0
    if _cstr_eq(&leaf[0], "cmdline") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_CMDLINE
        return 0
    if _cstr_eq(&leaf[0], "comm") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_COMM
        return 0
    if _cstr_eq(&leaf[0], "maps") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_MAPS
        return 0
    if _cstr_eq(&leaf[0], "ctl") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_CTL
        return 0
    if _cstr_eq(&leaf[0], "oom_score_adj") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_OOM_SCORE_ADJ
        return 0
    if _cstr_eq(&leaf[0], "fd") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_FD
        return 0
    return -1


def devproc_path_match(path: Ptr[char]) -> int32:
    # Cheap discriminator used by fs/vfs.ad to decide whether to
    # route open() to devproc or to the static procfs renderer.
    # Returns 1 iff path looks like /proc/<digits>/<known-leaf>.
    pid_scratch:  uint64 = 0
    kind_scratch: uint32 = 0
    if _parse_proc_path(path, &pid_scratch, &kind_scratch) == 0:
        return 1
    return 0


# --- /proc directory enumeration -------------------------------------
#
# The `#p` proc device server (bound at /proc) is a real, listable Plan 9
# directory tree. fs/vfs.ad's `#`-dispatch arm calls devproc_listdir with
# the server-relative subpath (the bytes after `#p`):
#
#   ""          -> the static well-known proc files (version, uptime,
#                  ...; the set proc_render in fs/procfs.ad serves) PLUS
#                  one decimal entry per LIVE pid (walk the task table).
#   "/<pid>"    -> that task's introspection files: status, stat, io,
#                  limits, cmdline, maps, ctl, fd, ... (the leaves
#                  _parse_proc_path / devproc_open dispatch).
#
# Returns bytes written (whole "NAME\n" lines), or -1 if the subpath
# isn't a directory. Mirrors devnet_listdir / blk_listdir's shape.


def _devproc_emit(buf: Ptr[uint8], count: uint64, out: uint64,
                  s: Ptr[uint8]) -> uint64:
    # Append the NUL-terminated name `s` as a "NAME\n" line into buf at
    # offset `out`, capped at `count`. A line that would overflow is
    # dropped (out unchanged).
    nlen: uint64 = 0
    while s[nlen] != 0:
        nlen = nlen + 1
    if nlen == 0:
        return out
    if out + nlen + 1 > count:
        return out
    j: uint64 = 0
    while j < nlen:
        buf[out + j] = s[j]
        j = j + 1
    buf[out + nlen] = 10                                # '\n'
    return out + nlen + 1


def _devproc_emit_dec(buf: Ptr[uint8], count: uint64, out: uint64,
                      v: uint64) -> uint64:
    # Append "N\n" (decimal) for a pid into buf.
    digits: Array[24, uint8]
    val: uint64 = v
    n: uint64 = 0
    if val == 0:
        digits[0] = 48
        n = 1
    else:
        while val != 0:
            digits[n] = cast[uint8](val % 10) + 48
            val = val / 10
            n = n + 1
    if out + n + 1 > count:
        return out
    p: uint64 = out
    k: uint64 = n
    while k > 0:
        k = k - 1
        buf[p] = digits[k]
        p = p + 1
    buf[p] = 10                                         # '\n'
    return p + 1


def devproc_listdir(sub: Ptr[char], buf: Ptr[uint8],
                    count: uint64) -> int64:
    # Directory walk for the `#p` proc device server. `sub` is the path
    # AFTER the `#p` device letter (server-relative): "" for the root,
    # "/<pid>" for a per-task directory. Returns bytes written, or -1 if
    # `sub` isn't a directory.
    if count == 0:
        return 0
    sp: Ptr[uint8] = cast[Ptr[uint8]](sub)
    # Bare server root: the static well-known files + one entry per pid.
    if sp[0] == 0:
        out: uint64 = 0
        # Static well-known names proc_render (fs/procfs.ad) serves for
        # the flat /proc/* set. (net/ and fs/ are subtrees with their own
        # renderers; svc is both a file and a directory.)
        out = _devproc_emit(buf, count, out, "version")
        out = _devproc_emit(buf, count, out, "uptime")
        out = _devproc_emit(buf, count, out, "realtime")
        out = _devproc_emit(buf, count, out, "tasks")
        out = _devproc_emit(buf, count, out, "meminfo")
        out = _devproc_emit(buf, count, out, "cpuinfo")
        out = _devproc_emit(buf, count, out, "mounts")
        out = _devproc_emit(buf, count, out, "cmdline")
        out = _devproc_emit(buf, count, out, "kmsg")
        out = _devproc_emit(buf, count, out, "svc")
        # One decimal entry per LIVE pid — same table walk render_tasks
        # uses (task_table_size() slots, each non-FREE one is live).
        ntab: uint64 = task_table_size()
        i: uint64 = 0
        while i < ntab:
            slot: int32 = cast[int32](i)
            if task_state(slot) != STATE_FREE:
                out = _devproc_emit_dec(buf, count, out,
                                        task_pid_at(slot))
            i = i + 1
        return cast[int64](out)
    if sp[0] != 47:                                    # must start '/'
        return -1
    pos: uint64 = 1
    # "/self" is an alias for the calling task's pid (HAMSH §14) — list
    # the same per-task file set.
    is_self: int32 = 0
    if sp[1] == 115 and sp[2] == 101 and sp[3] == 108 \
            and sp[4] == 102 and (sp[5] == 0 or sp[5] == 47):
        is_self = 1
        pos = 5
    pid: uint64 = 0
    if is_self != 0:
        pid = current_task_pid()
    else:
        if _is_digit(cast[uint8](sp[pos] & 0xFF)) == 0:
            return -1
        while _is_digit(cast[uint8](sp[pos] & 0xFF)) != 0:
            pid = pid * 10 + cast[uint64](sp[pos] - 48)
            pos = pos + 1
    if sp[pos] != 0:
        return -1                                      # not a directory
    # Validate the pid is live before listing its directory.
    if task_lookup_by_pid(pid) < 0:
        return -1                                      # no such pid
    out2: uint64 = 0
    out2 = _devproc_emit(buf, count, out2, "status")
    out2 = _devproc_emit(buf, count, out2, "cwd")
    out2 = _devproc_emit(buf, count, out2, "stat")
    out2 = _devproc_emit(buf, count, out2, "statm")
    out2 = _devproc_emit(buf, count, out2, "io")
    out2 = _devproc_emit(buf, count, out2, "limits")
    out2 = _devproc_emit(buf, count, out2, "note")
    out2 = _devproc_emit(buf, count, out2, "notepg")
    out2 = _devproc_emit(buf, count, out2, "ns")
    out2 = _devproc_emit(buf, count, out2, "cmdline")
    out2 = _devproc_emit(buf, count, out2, "comm")
    out2 = _devproc_emit(buf, count, out2, "maps")
    out2 = _devproc_emit(buf, count, out2, "ctl")
    out2 = _devproc_emit(buf, count, out2, "oom_score_adj")
    out2 = _devproc_emit(buf, count, out2, "fd")
    return cast[int64](out2)


def devproc_open(path: Ptr[char]) -> int64:
    # Parse the path, look up the task slot, return the 24-bit
    # (pid << 8 | kind) encoding the caller stores in a DEV_PROC
    # pool chan's back_slot (fs/vfs.ad _install_proc_fd →
    # namec_open_proc_file). Errors return -1 with
    # set_current_errstr(...) so SYS_ERRSTR (265) callers get a
    # human-readable reason — Plan 9 convention. fs/vfs.ad maps -1
    # to the user-visible -ENOENT it would return for any other
    # missing path.
    #
    # The encoding is always < 0x01000000, so it is comfortably
    # positive in both int32 and int64; -1 is the only negative
    # value the caller ever sees.
    pid64: uint64 = 0
    kind:  uint32 = 0
    if _parse_proc_path(path, &pid64, &kind) != 0:
        set_current_errstr("/proc: malformed pid path")
        return -1
    slot: int32 = task_lookup_by_pid(pid64)
    if slot < 0:
        set_current_errstr("no such pid")
        return -1
    # Encode pid+kind. Cap pid at 0xFFFF so the 16-bit field never
    # overflows out of the 24-bit encoding — at NTASKS=16 with
    # sequentially-allocated pids this is comfortable headroom.
    pid_field: uint32 = cast[uint32](pid64 & 0xFFFF)
    enc: uint32 = (pid_field << 8) | (kind & 0xFF)
    return cast[int64](enc)


def _emit_status(buf: Ptr[uint8], count: uint64, slot: int32) -> int64:
    # One line: "<pid> <name8> <state> <pml4_hex>\n". Format chosen
    # so awk/cut-style parsers can split on space and find each
    # field at a fixed column position. Linux's /proc/<pid>/status
    # is multi-line key/value; the Plan 9 file is one line of
    # whitespace-separated tokens (see /sys/src/9/port/devproc.c's
    # statustext()).
    #
    # Pointer-arithmetic note: we render into a single Array[128]
    # scratch and pass `(scratch_base + pos)` pointers into the
    # _u64_to_dec / _u64_to_hex helpers, computed via cast[uint64]
    # rather than `&scratch[pos]`. The latter form has tripped the
    # nested-Array-frame bug in the past (see feedback memory
    # "nested fixed-size Array locals across call frames"); the
    # explicit base-plus-offset is the stable workaround.
    scratch: Array[128, uint8]
    base: uint64 = cast[uint64](&scratch[0])
    pos: uint64 = 0
    pid_n: uint64 = _u64_to_dec(task_pid_at(slot),
                                cast[Ptr[uint8]](base + pos))
    pos = pos + pid_n
    scratch[pos] = 32                            # ' '
    pos = pos + 1
    # name0 is 8 ASCII bytes packed into a uint64. We unpack
    # least-significant byte first — that's the order the
    # task-creator wrote with `b0 | (b1<<8) | ...`. NUL bytes inside
    # the 8 mean "name shorter than 8 chars" — stop emitting.
    name_bits: uint64 = task_name0_at(slot)
    k: uint64 = 0
    name_done: int32 = 0
    while k < 8 and name_done == 0:
        c: uint8 = cast[uint8]((name_bits >> (k * 8)) & 0xFF)
        if c == 0:
            name_done = 1
        else:
            scratch[pos] = c
            pos = pos + 1
            k = k + 1
    scratch[pos] = 32                            # ' '
    pos = pos + 1
    # State letter. Linux uses R/S/Z; we map the same way fs/procfs.ad
    # does — RUNNING -> 'R', READY -> 'S' (ready ~= sleeping on a
    # uniprocessor), EXITED -> 'Z'. Anything else (which shouldn't
    # happen on a live pid we just looked up) becomes '?'.
    st: uint64 = task_state(slot)
    if st == STATE_RUNNING:
        scratch[pos] = 82                        # 'R'
    elif st == STATE_READY:
        scratch[pos] = 83                        # 'S'
    elif st == STATE_WAIT:
        scratch[pos] = 83                        # 'S' (interruptible sleep)
    elif st == STATE_EXITED:
        scratch[pos] = 90                        # 'Z'
    else:
        scratch[pos] = 63                        # '?'
    pos = pos + 1
    scratch[pos] = 32                            # ' '
    pos = pos + 1
    pml4: uint64 = task_pml4(slot)
    pml4_n: uint64 = _u64_to_hex(pml4, cast[Ptr[uint8]](base + pos))
    pos = pos + pml4_n
    scratch[pos] = 10                            # '\n'
    pos = pos + 1
    take: uint64 = count
    if take > pos:
        take = pos
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


def _proc_state_letter(slot: int32) -> uint8:
    # Linux /proc state letter: R running, S sleeping, Z zombie.
    # Hamnix STATE_READY maps to 'S' (ready ~= sleeping on a UP box),
    # same convention _emit_status and fs/procfs.ad already use.
    st: uint64 = task_state(slot)
    if st == STATE_RUNNING:
        return 82                                # 'R'
    if st == STATE_READY:
        return 83                                # 'S'
    if st == STATE_WAIT:
        return 83                                # 'S' (interruptible sleep)
    if st == STATE_EXITED:
        return 90                                # 'Z'
    return 63                                    # '?'


def _emit_comm_into(scratch: Ptr[uint8], pos: uint64,
                    slot: int32) -> uint64:
    # Copy the task's comm name (NUL-terminated, max 16 incl. NUL)
    # into scratch[pos..]. Returns the new pos. Falls back to the
    # 8-char packed name0 tag when comm is empty — kernel-spawned
    # tasks set name0 but a Linux ELF that never called prctl()
    # leaves comm zeroed; either way we want a non-empty token.
    comm: Ptr[uint8] = get_task_comm_ptr(cast[uint64](slot))
    if comm[0] != 0:
        i: uint64 = 0
        while i < 16 and comm[i] != 0:
            scratch[pos + i] = comm[i]
            i = i + 1
        return pos + i
    # name0 fallback — 8 ASCII bytes, least-significant-byte first.
    bits: uint64 = task_name0_at(slot)
    k: uint64 = 0
    while k < 8:
        c: uint8 = cast[uint8]((bits >> (k * 8)) & 0xFF)
        if c == 0:
            return pos + k
        scratch[pos + k] = c
        k = k + 1
    return pos + k


def _emit_linux_stat(buf: Ptr[uint8], count: uint64,
                     slot: int32) -> int64:
    # §13: real Linux-shape /proc/<pid>/stat. One whitespace-separated
    # line. Linux ships 52 fields; we render the first 24 — the prefix
    # `ps`, glibc and Python's psutil/multiprocessing actually parse:
    #
    #   pid (comm) state ppid pgrp session tty_nr tpgid flags
    #   minflt cminflt majflt cmajflt utime stime cutime cstime
    #   priority nice num_threads itrealvalue starttime vsize rss
    #
    # The remaining unaccounted fields render 0 — a well-formed but zero
    # value, which every parser tolerates. The fields we DO have are
    # real: pid, comm, state, ppid; the CPU-time pair — field 14 (utime)
    # and field 15 (stime) — from per-task tick accounting (HZ=100, 1
    # tick = 10 ms) via task_utime_ticks_at / task_stime_ticks_at; field
    # 22 (starttime) — the jiffy count at task creation (HZ=100, ticks
    # since boot) captured write-once in sched_init_task_weight and read
    # via task_start_jiffies_at; the child-resource quartet — field 11
    # (cminflt), field 13 (cmajflt), field 16 (cutime) and field 17 (cstime)
    # — rolled up at reap from each dead child's whole subtree
    # (RUSAGE_CHILDREN) via task_cminflt_at / task_cmajflt_at /
    # task_cutime_ticks_at / task_cstime_ticks_at; and
    # field 23 (vsize) and field 24 (rss), both computed ON DEMAND by
    # walking the task's VMAs: vsize = sum of (end - start) over all VMAs
    # in BYTES (task_vsize_bytes), rss = count of present 4 KiB pages in
    # PAGES (task_rss_pages); and now field 18 (priority = 20 + nice,
    # range 0..39) and field 19 (nice, SIGNED -20..+19), both from the
    # per-task POSIX nice via sched_get_nice. The (comm) is parenthesised
    # exactly as Linux does so a parser that does the classic
    # "rindex(')')" trick to skip a comm containing spaces still works.
    scratch: Array[256, uint8]
    base: uint64 = cast[uint64](&scratch[0])
    pos: uint64 = 0
    # field 1: pid
    pos = pos + _u64_to_dec(task_pid_at(slot),
                            cast[Ptr[uint8]](base + pos))
    scratch[pos] = 32
    pos = pos + 1
    # field 2: (comm)
    scratch[pos] = 40                            # '('
    pos = pos + 1
    pos = _emit_comm_into(&scratch[0], pos, slot)
    scratch[pos] = 41                            # ')'
    pos = pos + 1
    scratch[pos] = 32
    pos = pos + 1
    # field 3: state letter
    scratch[pos] = _proc_state_letter(slot)
    pos = pos + 1
    scratch[pos] = 32
    pos = pos + 1
    # field 4: ppid
    pos = pos + _u64_to_dec(task_parent_pid(slot),
                            cast[Ptr[uint8]](base + pos))
    # fields 5..24: pgrp session tty_nr tpgid flags minflt cminflt
    # majflt cmajflt utime stime cutime cstime priority nice
    # num_threads itrealvalue starttime vsize rss — 20 fields. Most
    # render 0; field 5 (pgrp) carries the REAL per-task job process-group
    # id (task_get_job_pgid); num_threads (field 20) is at least 1; field 10 (minflt)
    # / field 12 (majflt) carry the REAL per-task page-fault counts;
    # field 11 (cminflt) / field 13 (cmajflt) carry the REAL rolled-up
    # child page-fault counts and field 16 (cutime) / field 17 (cstime)
    # the REAL rolled-up child CPU ticks (RUSAGE_CHILDREN, folded at reap);
    # field 14 (utime) / field 15 (stime) carry the REAL per-task tick
    # counts; field 18 (priority = 20 + nice) / field 19 (nice, SIGNED)
    # carry the REAL per-task POSIX nice; field 22 (starttime) carries the
    # REAL creation-jiffy; field 9 (flags) carries the REAL Linux PF_* kernel
    # flags bitmask — the one bit we can faithfully derive, PF_KTHREAD
    # (0x00200000 = 2097152), set when the task is a kernel thread
    # (task_is_user_at == 0) and 0 for a CPL=3 user task; and field 23 (vsize,
    # sum-of-VMA bytes) / field 24
    # (rss, present-page count) are REAL on-demand VMA walks. Each field is a
    # leading space then a value; the real
    # fields use _u64_to_dec so they render as a full (possibly
    # multi-digit) decimal, while the rest stay single-digit " 0" / " 1".
    f: uint64 = 5
    while f <= 24:
        scratch[pos] = 32                        # ' '
        pos = pos + 1
        if f == 10:
            pos = pos + _u64_to_dec(task_minflt_at(slot),
                                    cast[Ptr[uint8]](base + pos))
        elif f == 11:
            pos = pos + _u64_to_dec(task_cminflt_at(slot),
                                    cast[Ptr[uint8]](base + pos))
        elif f == 12:
            pos = pos + _u64_to_dec(task_majflt_at(slot),
                                    cast[Ptr[uint8]](base + pos))
        elif f == 13:
            pos = pos + _u64_to_dec(task_cmajflt_at(slot),
                                    cast[Ptr[uint8]](base + pos))
        elif f == 16:
            pos = pos + _u64_to_dec(task_cutime_ticks_at(slot),
                                    cast[Ptr[uint8]](base + pos))
        elif f == 17:
            pos = pos + _u64_to_dec(task_cstime_ticks_at(slot),
                                    cast[Ptr[uint8]](base + pos))
        elif f == 14:
            pos = pos + _u64_to_dec(task_utime_ticks_at(slot),
                                    cast[Ptr[uint8]](base + pos))
        elif f == 15:
            pos = pos + _u64_to_dec(task_stime_ticks_at(slot),
                                    cast[Ptr[uint8]](base + pos))
        elif f == 22:
            pos = pos + _u64_to_dec(task_start_jiffies_at(slot),
                                    cast[Ptr[uint8]](base + pos))
        elif f == 23:
            pos = pos + _u64_to_dec(task_vsize_bytes(cast[uint64](slot)),
                                    cast[Ptr[uint8]](base + pos))
        elif f == 24:
            pos = pos + _u64_to_dec(task_rss_pages(cast[uint64](slot)),
                                    cast[Ptr[uint8]](base + pos))
        elif f == 18:
            # priority = Linux kernel priority for a normal task = 20 + nice
            # (range 0..39, always non-negative so _u64_to_dec is safe).
            nq: int64 = sched_get_nice(cast[uint64](slot))
            pos = pos + _u64_to_dec(cast[uint64](20 + nq),
                                    cast[Ptr[uint8]](base + pos))
        elif f == 19:
            # nice = POSIX nice value (-20..+19, SIGNED).
            pos = pos + _i64_to_dec(sched_get_nice(cast[uint64](slot)),
                                    cast[Ptr[uint8]](base + pos))
        elif f == 5:
            pos = pos + _u64_to_dec(task_get_job_pgid(cast[uint64](slot)),
                                    cast[Ptr[uint8]](base + pos))
        elif f == 9:
            # flags = Linux PF_* kernel flags bitmask. The one bit we can
            # faithfully derive is PF_KTHREAD (0x00200000): set for a kernel
            # thread (no CPL=3 user context), clear for a user task.
            fl9: uint64 = 0
            if task_is_user_at(cast[uint64](slot)) == 0:
                fl9 = 2097152                    # PF_KTHREAD (0x00200000)
            pos = pos + _u64_to_dec(fl9, cast[Ptr[uint8]](base + pos))
        elif f == 20:
            scratch[pos] = 49                    # '1' — num_threads
            pos = pos + 1
        else:
            scratch[pos] = 48                    # '0'
            pos = pos + 1
        f = f + 1
    scratch[pos] = 10                            # '\n'
    pos = pos + 1
    take: uint64 = count
    if take > pos:
        take = pos
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


def emit_statm(buf: Ptr[uint8], count: uint64, slot: int32) -> int64:
    # §13: real Linux-shape /proc/<pid>/statm. One line of 7 space-
    # separated PAGE counts:
    #
    #   size resident shared text lib data dt
    #
    # size = total program size in pages = task_vsize_bytes / 4096;
    # resident = resident set size in pages = task_rss_pages (count of
    # present 4 KiB pages). Both are computed ON DEMAND by walking the
    # task's VMAs. The remaining five (shared text lib data dt) render 0
    # — Linux itself sets lib and dt to 0, and we have no per-category
    # accounting for the others; 0 is a well-formed value every parser
    # (ps/psutil) tolerates, and they read primarily size + resident.
    # PUBLIC (no leading '_') so linux_abi/u_syscalls.ad's self-test can
    # import it.
    scratch: Array[128, uint8]
    base: uint64 = cast[uint64](&scratch[0])
    pos: uint64 = 0
    size_pages: uint64 = task_vsize_bytes(cast[uint64](slot)) / 4096
    res_pages:  uint64 = task_rss_pages(cast[uint64](slot))
    # field 1: size
    pos = pos + _u64_to_dec(size_pages, cast[Ptr[uint8]](base + pos))
    scratch[pos] = 32                            # ' '
    pos = pos + 1
    # field 2: resident
    pos = pos + _u64_to_dec(res_pages, cast[Ptr[uint8]](base + pos))
    # fields 3..7: shared text lib data dt — all "0"
    j: uint64 = 0
    while j < 5:
        scratch[pos] = 32                        # ' '
        pos = pos + 1
        scratch[pos] = 48                        # '0'
        pos = pos + 1
        j = j + 1
    scratch[pos] = 10                            # '\n'
    pos = pos + 1
    take: uint64 = count
    if take > pos:
        take = pos
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


def _io_emit_line(label: Ptr[uint8], value: uint64,
                  scratch: Ptr[uint8], pos: uint64) -> uint64:
    # Render one "<label>: <decimal>\n" /proc/<pid>/io line into `scratch`
    # starting at `pos`. `label` is a NUL-terminated literal like "rchar".
    # Returns the new write position. Mirrors the literal-byte + _u64_to_dec
    # approach emit_statm uses.
    k: uint64 = 0
    while label[k] != 0:
        scratch[pos] = label[k]
        pos = pos + 1
        k = k + 1
    scratch[pos] = 58                            # ':'
    pos = pos + 1
    scratch[pos] = 32                            # ' '
    pos = pos + 1
    pos = pos + _u64_to_dec(value, cast[Ptr[uint8]](cast[uint64](scratch) + pos))
    scratch[pos] = 10                            # '\n'
    pos = pos + 1
    return pos


def emit_proc_io(buf: Ptr[uint8], count: uint64, slot: int32) -> int64:
    # §13: real Linux-shape /proc/<pid>/io. Seven lines:
    #
    #   rchar: <bytes returned by all read()-family syscalls>
    #   wchar: <bytes consumed by all write()-family syscalls>
    #   syscr: <count of read() syscall invocations>
    #   syscw: <count of write() syscall invocations>
    #   read_bytes: <bytes actually fetched from a block device>
    #   write_bytes: <bytes actually sent to a block device>
    #   cancelled_write_bytes: <bytes whose writeback was cancelled>
    #
    # rchar/wchar/syscr/syscw are real per-task counters charged at the
    # read()/write() syscall boundary (kernel/sched/core.ad). read_bytes/
    # write_bytes derive from the per-task 512-byte block-I/O counters
    # (inblock/oublock * 512). cancelled_write_bytes is always 0 — we never
    # cancel writeback, a well-formed value every parser tolerates. PUBLIC
    # (no leading '_') so the procio_selftest can call it.
    scratch: Array[256, uint8]
    base: uint64 = cast[uint64](&scratch[0])
    bp:   Ptr[uint8] = cast[Ptr[uint8]](base)
    pos: uint64 = 0
    read_bytes:  uint64 = task_inblock_at(slot) * 512
    write_bytes: uint64 = task_oublock_at(slot) * 512
    pos = _io_emit_line("rchar", task_rchar_at(slot), bp, pos)
    pos = _io_emit_line("wchar", task_wchar_at(slot), bp, pos)
    pos = _io_emit_line("syscr", task_syscr_at(slot), bp, pos)
    pos = _io_emit_line("syscw", task_syscw_at(slot), bp, pos)
    pos = _io_emit_line("read_bytes", read_bytes, bp, pos)
    pos = _io_emit_line("write_bytes", write_bytes, bp, pos)
    pos = _io_emit_line("cancelled_write_bytes", 0, bp, pos)
    take: uint64 = count
    if take > pos:
        take = pos
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


def _lim_puts(base: uint64, pos: uint64, s: Ptr[uint8]) -> uint64:
    # Copy the NUL-terminated literal `s` into the scratch buffer at byte
    # offset `pos` (buffer start = `base`); return the new position. Drives
    # the literal columns of emit_proc_limits.
    out: Ptr[uint8] = cast[Ptr[uint8]](base + pos)
    k: uint64 = 0
    while s[k] != 0:
        out[k] = s[k]
        k = k + 1
    return pos + k


def _lim_cell(base: uint64, pos: uint64, val: uint64) -> uint64:
    # Render one Soft/Hard limit cell: the literal "unlimited" when `val` is
    # RLIM_INFINITY (0xFFFFFFFFFFFFFFFF), else the decimal value. Returns the
    # new write position.
    if val == 0xFFFFFFFFFFFFFFFF:
        return _lim_puts(base, pos, "unlimited")
    return pos + _u64_to_dec(val, cast[Ptr[uint8]](base + pos))


def _lim_row(base: uint64, pos: uint64, name: Ptr[uint8], units: Ptr[uint8],
             slot: int32, res: uint64) -> uint64:
    # Render one /proc/<pid>/limits resource row:
    #   "<Name> <Soft Limit> <Hard Limit> <Units>\n"
    # Columns are separated by a single space (a label-anchored parser
    # tolerates this; fixed-width padding is a Linux nicety, not required).
    pos = _lim_puts(base, pos, name)
    base_p: Ptr[uint8] = cast[Ptr[uint8]](base + pos)
    base_p[0] = 32                                  # ' '
    pos = pos + 1
    pos = _lim_cell(base, pos, rlimit_get_cur(cast[uint64](slot), res))
    sp1: Ptr[uint8] = cast[Ptr[uint8]](base + pos)
    sp1[0] = 32                                     # ' '
    pos = pos + 1
    pos = _lim_cell(base, pos, rlimit_get_max(cast[uint64](slot), res))
    sp2: Ptr[uint8] = cast[Ptr[uint8]](base + pos)
    sp2[0] = 32                                     # ' '
    pos = pos + 1
    pos = _lim_puts(base, pos, units)
    nl: Ptr[uint8] = cast[Ptr[uint8]](base + pos)
    nl[0] = 10                                      # '\n'
    return pos + 1


def emit_proc_limits(buf: Ptr[uint8], count: uint64, slot: int32) -> int64:
    # §13: real Linux-shape /proc/<pid>/limits. A header row plus one line per
    # RLIM_NLIMITS(16) resource. For each resource the Soft/Hard cell is the
    # literal "unlimited" when the stored rlimit == RLIM_INFINITY, else the
    # decimal value. Values come from the real per-task rlimit store
    # (rlimit_get_cur/rlimit_get_max, kernel/sched/core.ad), seeded at task
    # creation to the Linux login defaults. PUBLIC (no leading '_') so
    # proclimits_selftest can call it. Buffer sized for 16 rows ~70 chars.
    scratch: Array[2048, uint8]
    base: uint64 = cast[uint64](&scratch[0])
    pos: uint64 = 0
    # Header line (exact Linux column labels).
    pos = _lim_puts(base, pos,
        "Limit                     Soft Limit           Hard Limit           Units")
    hdr_nl: Ptr[uint8] = cast[Ptr[uint8]](base + pos)
    hdr_nl[0] = 10                                  # '\n'
    pos = pos + 1
    # One row per RLIMIT_* resource (index = res). rows 13/14 carry no units.
    pos = _lim_row(base, pos, "Max cpu time", "seconds", slot, 0)
    pos = _lim_row(base, pos, "Max file size", "bytes", slot, 1)
    pos = _lim_row(base, pos, "Max data size", "bytes", slot, 2)
    pos = _lim_row(base, pos, "Max stack size", "bytes", slot, 3)
    pos = _lim_row(base, pos, "Max core file size", "bytes", slot, 4)
    pos = _lim_row(base, pos, "Max resident set", "bytes", slot, 5)
    pos = _lim_row(base, pos, "Max processes", "processes", slot, 6)
    pos = _lim_row(base, pos, "Max open files", "files", slot, 7)
    pos = _lim_row(base, pos, "Max locked memory", "bytes", slot, 8)
    pos = _lim_row(base, pos, "Max address space", "bytes", slot, 9)
    pos = _lim_row(base, pos, "Max file locks", "locks", slot, 10)
    pos = _lim_row(base, pos, "Max pending signals", "signals", slot, 11)
    pos = _lim_row(base, pos, "Max msgqueue size", "bytes", slot, 12)
    pos = _lim_row(base, pos, "Max nice priority", "", slot, 13)
    pos = _lim_row(base, pos, "Max realtime priority", "", slot, 14)
    pos = _lim_row(base, pos, "Max realtime timeout", "us", slot, 15)
    take: uint64 = count
    if take > pos:
        take = pos
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


def _emit_cmdline(buf: Ptr[uint8], count: uint64,
                  slot: int32) -> int64:
    # §13: /proc/<pid>/cmdline. Linux serves the process's argv as a
    # NUL-separated, NUL-terminated blob. Hamnix has no per-task argv
    # storage on TaskStruct, so we render the comm name as a single
    # argv[0] entry followed by its NUL — a well-formed one-element
    # cmdline. A reader that splits on NUL gets exactly one token,
    # which is what /proc/self/cmdline of an exec'd-but-no-argv
    # process would look like anyway.
    scratch: Array[32, uint8]
    n: uint64 = _emit_comm_into(&scratch[0], 0, slot)
    scratch[n] = 0                               # trailing NUL
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


def _emit_comm(buf: Ptr[uint8], count: uint64,
               slot: int32) -> int64:
    # §13: /proc/<pid>/comm — the comm name plus a trailing newline,
    # exactly as Linux serves it.
    scratch: Array[24, uint8]
    n: uint64 = _emit_comm_into(&scratch[0], 0, slot)
    scratch[n] = 10                              # '\n'
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


def _emit_cwd(buf: Ptr[uint8], count: uint64, slot: int32) -> int64:
    # The CWD lives inline in TaskStruct.cwd as a 128-byte
    # NUL-terminated string; get_cwd_buf returns a pointer to slot 0
    # of that array. Copy up to count-1 bytes, then append '\n'.
    src: Ptr[uint8] = get_cwd_buf(cast[uint64](slot))
    n: uint64 = 0
    # Find length so we can decide whether the '\n' fits.
    while src[n] != 0 and n < 127:
        n = n + 1
    # Available room in caller's buffer for the path plus newline.
    if count == 0:
        return 0
    out_n: uint64 = n
    if out_n > count:
        out_n = count
    i: uint64 = 0
    while i < out_n:
        buf[i] = src[i]
        i = i + 1
    # Append '\n' if there's room — matches the trailing-newline
    # convention of /dev/pid, /dev/time and Plan 9 devproc.
    if out_n < count:
        buf[out_n] = 10                          # '\n'
        out_n = out_n + 1
    return cast[int64](out_n)


def _fd_puts(base: uint64, pos: uint64, s: Ptr[uint8]) -> uint64:
    # Copy the NUL-terminated literal `s` into the scratch buffer at byte
    # offset `pos` (buffer start = `base`); return the new position. Same
    # shape as emit_proc_limits' _lim_puts, kept local so the fd renderer
    # is self-contained.
    out: Ptr[uint8] = cast[Ptr[uint8]](base + pos)
    k: uint64 = 0
    while s[k] != 0:
        out[k] = s[k]
        k = k + 1
    return pos + k


def _chan_dev_path(dev_type: int32) -> Ptr[char]:
    # Canonical "/dev/<name>" path for a stateless local-cdev dev_type,
    # or "" (empty) for a non-cdev chan (mounted-9P). Used by the
    # /proc/<pid>/fd renderer to print an FD_CHAN_MARK fd's backing path.
    if dev_type == DEV_CONS:
        return "/dev/cons"
    if dev_type == DEV_TIME:
        return "/dev/time"
    if dev_type == DEV_PID:
        return "/dev/pid"
    if dev_type == DEV_RANDOM:
        return "/dev/random"
    if dev_type == DEV_URANDOM:
        return "/dev/urandom"
    if dev_type == DEV_MOUSE:
        return "/dev/mouse"
    if dev_type == DEV_CPUINFO:
        return "/dev/cpuinfo"
    if dev_type == DEV_MEMINFO:
        return "/dev/meminfo"
    if dev_type == DEV_UPTIME:
        return "/dev/uptime"
    if dev_type == DEV_LOADAVG:
        return "/dev/loadavg"
    if dev_type == DEV_VERSION:
        return "/dev/version"
    if dev_type == DEV_HOSTNAME:
        return "/dev/hostname"
    if dev_type == DEV_NULL:
        return "/dev/null"
    if dev_type == DEV_ZERO:
        return "/dev/zero"
    return ""


def _fd_target(base: uint64, pos: uint64, mark: uint32,
               aux: uint64) -> uint64:
    # Render the human-readable backing-object string for one fd into the
    # scratch buffer at `pos`; return the new position. `mark` is the fd_idx
    # marker (or a real cpio file index when below the marker range); `aux`
    # is the companion fd_buf word (a backing-table slot id for the
    # pipe/socket/tmpfs/fat/ext4 kinds). Path-less anon objects render in
    # Linux's anon-inode "kind:[id]" shape so the column matches a Linux
    # `ls -l /proc/<pid>/fd` symlink target.
    if mark == FD_STDIN_MARK:
        return _fd_puts(base, pos, "/dev/cons")
    if mark == FD_STDOUT_MARK:
        return _fd_puts(base, pos, "/dev/cons")
    if mark == FD_STDERR_MARK:
        return _fd_puts(base, pos, "/dev/cons")
    if mark == FD_CHAN_MARK:
        # A namec Chan-backed fd. `aux` is the chan id. The stateless
        # local cdevs (/dev/cons, /dev/null, /dev/zero, /dev/time, ...)
        # carry an inline dev_type — render their canonical /dev path.
        # A mounted-9P chan has no recoverable name; render "chan:[id]".
        cdev: int32 = namec_chan_dev_type(cast[int32](cast[uint32](aux)))
        cname: Ptr[char] = _chan_dev_path(cdev)
        if cname[0] != 0:
            return _fd_puts(base, pos, cname)
        # Phase 4b: rendered-snapshot and directory fds are DEV_BUF_FILE /
        # DEV_DIR_FILE pool chans now; keep the legacy anon-inode shapes
        # so `ls -l /proc/<pid>/fd` output stays greppable.
        if cdev == DEV_BUF_FILE:
            return _fd_puts(base, pos, "anon:[buffer]")
        if cdev == DEV_DIR_FILE:
            return _fd_puts(base, pos, "anon:[dir]")
        if cdev == DEV_DEVFD:
            # Phase 4c: an `#d/<N>` dup-style fd (ex-FD_DEVFD_MARK)
            # rides an inline chan whose wid byte is the /fd table
            # index — render its canonical namespace path.
            pos = _fd_puts(base, pos, "/fd/")
            pos = pos + _u64_to_dec(
                cast[uint64](cast[uint32](namec_chan_devfd_num(
                    cast[int32](cast[uint32](aux))))),
                cast[Ptr[uint8]](base + pos))
            return pos
        if cdev == DEV_PIPE_R or cdev == DEV_PIPE_W:
            # Phase 4c: a pipe end (ex-FD_PIPE_MARK_R/W) — keep Linux's
            # anon-inode "pipe:[<id>]" shape, keyed on the RING slot
            # (stable, shared by both ends) instead of the chan id.
            pos = _fd_puts(base, pos, "pipe:[")
            pos = pos + _u64_to_dec(
                cast[uint64](cast[uint32](namec_chan_back_slot(
                    cast[int32](cast[uint32](aux))))),
                cast[Ptr[uint8]](base + pos))
            return _fd_puts(base, pos, "]")
        if cdev == DEV_SOCKET or cdev == DEV_SOCKETPAIR:
            # Phase 4c (socket fold): a socket / socketpair end
            # (ex-FD_SOCKET_MARK / FD_SOCKETPAIR_MARK) — keep Linux's
            # anon-inode "socket:[<id>]" shape, keyed on the back_slot
            # (the usock-record / packed-end encoding the legacy fd_buf
            # carried) instead of the recycled chan id.
            pos = _fd_puts(base, pos, "socket:[")
            pos = pos + _u64_to_dec(
                cast[uint64](cast[uint32](namec_chan_back_slot(
                    cast[int32](cast[uint32](aux))))),
                cast[Ptr[uint8]](base + pos))
            return _fd_puts(base, pos, "]")
        pos = _fd_puts(base, pos, "chan:[")
        pos = pos + _u64_to_dec(aux, cast[Ptr[uint8]](base + pos))
        return _fd_puts(base, pos, "]")
    # Phase 4c (socket fold): the FD_SOCKET_MARK "socket:[<fd_buf>]" arm
    # is GONE — socket fds are FD_CHAN_MARK / DEV_SOCKET chans rendered
    # above with the same shape.
    # fd→Chan fold: tmpfs / FAT / ext4 file fds are FD_CHAN_MARK now
    # (DEV_TMPFS_FILE / DEV_FAT_FILE / DEV_EXT4_FILE pool chans), rendered
    # by the FD_CHAN_MARK arm above as "chan:[<id>]". The dedicated tmpfs:/
    # fat:/ext4: arms are retired with their marks. Phase 4b: buffer / dir
    # fds (ex-FD_BUFFER_MARK / FD_DIR_MARK) are DEV_BUF_FILE / DEV_DIR_FILE
    # chans, rendered in the FD_CHAN_MARK arm above.
    # Anything below the marker range is a real initramfs (cpio) file index.
    # We have no cheap index->name reverse map, so render the canonical
    # "cpio:[<index>]" form — accurate and greppable.
    pos = _fd_puts(base, pos, "cpio:[")
    pos = pos + _u64_to_dec(cast[uint64](mark), cast[Ptr[uint8]](base + pos))
    return _fd_puts(base, pos, "]")


def emit_proc_fd(buf: Ptr[uint8], count: uint64, slot: int32) -> int64:
    # Gap-report #3: Linux-ABI /proc/<pid>/fd as a single text file — one line
    # per OPEN descriptor in the target task's fd table:
    #
    #   "<fd>\t<target>\n"
    #
    # Closed slots (fd_idx == FD_CLOSED_MARK) are skipped, exactly as Linux's
    # /proc/<pid>/fd lists only live descriptors. The fd number and the backing
    # object both come from the real per-task fd table via task_fd_idx_at /
    # task_fd_buf_at (kernel/sched/core.ad), so a fresh task shows at least
    # 0/1/2 (stdin/stdout/stderr). PUBLIC (no leading '_') so procfd_selftest
    # can call it directly. Scratch sized for TASK_NFDS(16) rows.
    scratch: Array[1024, uint8]
    base: uint64 = cast[uint64](&scratch[0])
    pos:  uint64 = 0
    fd: uint64 = 0
    while fd < TASK_NFDS:
        mark: uint32 = task_fd_idx_at(slot, fd)
        if mark != FD_CLOSED_MARK:
            pos = pos + _u64_to_dec(fd, cast[Ptr[uint8]](base + pos))
            tab: Ptr[uint8] = cast[Ptr[uint8]](base + pos)
            tab[0] = 9                                # '\t'
            pos = pos + 1
            pos = _fd_target(base, pos, mark, task_fd_buf_at(slot, fd))
            nl: Ptr[uint8] = cast[Ptr[uint8]](base + pos)
            nl[0] = 10                                # '\n'
            pos = pos + 1
        fd = fd + 1
    take: uint64 = count
    if take > pos:
        take = pos
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


def devproc_read(file_idx: uint32, off: uint64, buf: Ptr[uint8],
                 count: uint64) -> int64:
    # Decode pid + kind from the marker. Re-validate the slot at read
    # time — a task that died after the open could leave a stale pid
    # in our hand. STATE_FREE re-uses the slot, so a passing pid would
    # then read someone else's status; refusing here keeps the
    # semantics honest.
    #
    # `off` is the read cursor. Each /proc file renders its whole
    # snapshot in one emit; a second read (off > 0) reports EOF so a
    # `cat /proc/<pid>/<file>` terminates instead of regenerating the
    # snapshot forever. (Pre-off-aware callers always passed off == 0
    # for a single read, so this is non-regressing.)
    if off > 0:
        return 0
    pid_field: uint32 = (file_idx >> 8) & 0xFFFF
    kind:      uint32 = file_idx & 0xFF
    slot: int32 = task_lookup_by_pid(cast[uint64](pid_field))
    if slot < 0:
        set_current_errstr("pid vanished")
        return -1
    if kind == DEVPROC_KIND_STATUS:
        return _emit_status(buf, count, slot)
    if kind == DEVPROC_KIND_CWD:
        return _emit_cwd(buf, count, slot)
    if kind == DEVPROC_KIND_STAT:
        # §13: /proc/<pid>/stat now renders the real Linux-shape
        # single-line stat record (see _emit_linux_stat). The Plan 9
        # binary Dir-record form of `stat` is served by the separate
        # SYS_STAT_P9 syscall path in sysfile.ad — this devproc text
        # file is the Linux-ABI surface and Linux callers (psutil,
        # ps, glibc) want the 52-field ASCII line.
        return _emit_linux_stat(buf, count, slot)
    if kind == DEVPROC_KIND_STATM:
        # §13: /proc/<pid>/statm — 7-field PAGE-count line. size and
        # resident are real on-demand VMA walks; the rest are 0.
        return emit_statm(buf, count, slot)
    if kind == DEVPROC_KIND_IO:
        # §13: /proc/<pid>/io — 7-line per-task I/O accounting. rchar/wchar/
        # syscr/syscw are real per-task syscall-boundary counters; read_bytes/
        # write_bytes derive from inblock/oublock * 512; cancelled is 0.
        return emit_proc_io(buf, count, slot)
    if kind == DEVPROC_KIND_LIMITS:
        # §13: /proc/<pid>/limits — header row + one line per RLIM_NLIMITS(16)
        # resource rendering the real per-task rlimit store (cur/max), with the
        # literal "unlimited" for RLIM_INFINITY values.
        return emit_proc_limits(buf, count, slot)
    if kind == DEVPROC_KIND_CMDLINE:
        return _emit_cmdline(buf, count, slot)
    if kind == DEVPROC_KIND_COMM:
        return _emit_comm(buf, count, slot)
    if kind == DEVPROC_KIND_MAPS:
        # §13: render the target task's VMA list in /proc/<pid>/maps
        # shape. slot is the int32 task index; vma_maps_render wants
        # the uint64 form.
        return vma_maps_render(cast[uint64](slot), buf, count)
    if kind == DEVPROC_KIND_NOTE:
        # /proc/<pid>/note is write-only — Plan 9 contract. Reading
        # would suggest "fetch the most recent note"; that's not a
        # 9front-shape API and we don't want to grow it inadvertently.
        set_current_errstr("note: not readable")
        return -1
    if kind == DEVPROC_KIND_NOTEPG:
        # /proc/<pid>/notepg is write-only — same Plan 9 contract as
        # `note`. It is a control surface for posting to a note group.
        set_current_errstr("notepg: not readable")
        return -1
    if kind == DEVPROC_KIND_CTL:
        # Plan 9 /proc/<pid>/ctl is write-only — it is a control surface,
        # not a status read. Same contract as `note`/`notepg`.
        set_current_errstr("ctl: not readable")
        return -1
    if kind == DEVPROC_KIND_OOM_SCORE_ADJ:
        # Linux /proc/<pid>/oom_score_adj — render the per-task OOM-killer bias
        # as a signed decimal followed by '\n'. Read-only here (the write path
        # is the `oomadj` ctl verb). _i64_to_dec is the file's signed renderer
        # (same one /proc/<pid>/stat field 19 uses). Respect the buf/count cap.
        oa_scratch: Array[16, uint8]
        oa_pos: uint64 = _i64_to_dec(
            oom_adj_get64(cast[uint64](slot)),
            &oa_scratch[0])
        oa_scratch[oa_pos] = 10                       # '\n'
        oa_pos = oa_pos + 1
        oa_take: uint64 = count
        if oa_take > oa_pos:
            oa_take = oa_pos
        oi: uint64 = 0
        while oi < oa_take:
            buf[oi] = oa_scratch[oi]
            oi = oi + 1
        return cast[int64](oa_take)
    if kind == DEVPROC_KIND_FD:
        # Gap-report #3: /proc/<pid>/fd — one "<fd>\t<target>\n" line per open
        # descriptor in the target task's fd table. Live single-file mirror of
        # Linux's per-fd symlink directory (no getdents-walkable /proc dir
        # exists natively, so the descriptors are surfaced as text).
        return emit_proc_fd(buf, count, slot)
    if kind == DEVPROC_KIND_NS:
        # V3: render the target task's Pgrp mtab as ns(1)-shape text.
        # Stateless — every read regenerates the snapshot. The fixture
        # does a single large read; multi-read offset semantics land
        # in V3.1 alongside /proc/self resolution.
        # V2.75: pgrp_for_task returns the heap pointer (uint64) to
        # the Pgrp struct; pgrp_render_ns walks it directly.
        pg: uint64 = pgrp_for_task(slot)
        return pgrp_render_ns(pg, buf, count)
    set_current_errstr("/proc: unknown file kind")
    return -1


def _ctl_match_verb(buf: Ptr[uint8], count: uint64,
                    verb: Ptr[uint8]) -> int64:
    # Match the NUL-terminated `verb` literal at the start of `buf`, then
    # require at least one whitespace separator (' ' or '\t') before the
    # argument. Returns the byte index just past the separator(s) (where the
    # signed argument begins) on a match, or -1 if the verb / separator does
    # not match. Generic over verbs ("pri", "oomadj", ...).
    i: uint64 = 0
    while verb[i] != 0:
        if i >= count or buf[i] != verb[i]:
            return cast[int64](-1)
        i = i + 1
    # At least one whitespace byte must separate verb and argument.
    sep: int32 = 0
    while i < count and (buf[i] == 32 or buf[i] == 9):   # ' ' or '\t'
        sep = sep + 1
        i = i + 1
    if sep == 0:
        return cast[int64](-1)
    return cast[int64](i)


def _ctl_parse_signed(buf: Ptr[uint8], count: uint64, start: uint64,
                      out: Ptr[int64]) -> int32:
    # Parse a signed integer beginning at byte index `start`, tolerating only
    # trailing whitespace / newline / NUL afterward. Writes the value through
    # `out` and returns 1 on success, 0 on a malformed argument.
    i: uint64 = start
    # Optional leading '-' (byte 45) marks a negative magnitude.
    neg: int32 = 0
    if i < count and buf[i] == 45:                   # '-'
        neg = 1
        i = i + 1
    mag: int64 = 0
    ndig: uint64 = 0
    while i < count:
        c: uint8 = buf[i]
        if c < 48 or c > 57:                         # not a digit -> arg end
            break
        mag = mag * 10 + cast[int64](cast[uint64](c) - 48)
        ndig = ndig + 1
        i = i + 1
    if ndig == 0:
        return 0                                     # verb with no number
    # Anything left over must be only trailing whitespace / newline.
    while i < count:
        t: uint8 = buf[i]
        if t != 32 and t != 9 and t != 10 and t != 13 and t != 0:
            return 0
        i = i + 1
    val: int64 = mag
    if neg == 1:
        val = 0 - mag
    out[0] = val
    return 1


def _ctl_parse_pri(buf: Ptr[uint8], count: uint64, out: Ptr[int64]) -> int32:
    # Parse a Plan 9 /proc/<pid>/ctl control message of the form
    # "pri <signed-int>" (a trailing '\n' is tolerated). Returns 1 and writes
    # the parsed integer through `out` on a well-formed message, 0 otherwise.
    # Only the `pri` verb is recognised — any other verb is a parse failure.
    # Retained as a thin wrapper so the #235 procctl_selftest keeps driving the
    # exact `pri` path; devproc_write now dispatches verbs generically.
    arg: int64 = _ctl_match_verb(buf, count, "pri")
    if arg < 0:
        return 0
    return _ctl_parse_signed(buf, count, cast[uint64](arg), out)


def _ctl_word_eq(buf: Ptr[uint8], count: uint64, start: uint64,
                 word: Ptr[uint8]) -> int32:
    # True (1) if the whitespace/newline/NUL-delimited token beginning at
    # byte index `start` exactly equals the NUL-terminated `word`. Used to
    # match a `policy` verb's first argument ("fifo"/"rr"/"other") before
    # the numeric priority. Returns 0 on any mismatch or length difference.
    i: uint64 = start
    j: uint64 = 0
    while word[j] != 0:
        if i >= count:
            return 0
        if buf[i] != word[j]:
            return 0
        i = i + 1
        j = j + 1
    # The matched token must end at a delimiter, not continue (so "fifoX"
    # does not match "fifo").
    if i < count:
        t: uint8 = buf[i]
        if t != 32 and t != 9 and t != 10 and t != 13 and t != 0:
            return 0
    return 1


def _ctl_skip_token_and_sep(buf: Ptr[uint8], count: uint64,
                            start: uint64) -> uint64:
    # Advance past the non-whitespace token beginning at `start`, then past
    # the run of whitespace separators that follow it. Returns the byte index
    # of the next token (or `count` if the buffer ends). Used by the `policy`
    # parser to step from the policy-name argument to the numeric priority.
    i: uint64 = start
    while i < count:
        c: uint8 = buf[i]
        if c == 32 or c == 9 or c == 10 or c == 13 or c == 0:
            break
        i = i + 1
    while i < count and (buf[i] == 32 or buf[i] == 9):
        i = i + 1
    return i


def _ctl_parse_policy(buf: Ptr[uint8], count: uint64,
                      out_policy: Ptr[uint64], out_prio: Ptr[int64]) -> int32:
    # Parse a Plan 9 /proc/<pid>/ctl control message of the form
    #   "policy fifo 50"  / "policy rr 30"  / "policy other 0"  (or "other"
    #   with the priority omitted, which defaults to 0).
    # The realtime priority must be 1..99 for fifo/rr and 0 (or omitted) for
    # other. Writes the SCHED_* policy through `out_policy` and the parsed
    # priority through `out_prio`. Returns 1 on a well-formed message, 0
    # otherwise. Only the `policy` verb is recognised here.
    arg: int64 = _ctl_match_verb(buf, count, "policy")
    if arg < 0:
        return 0
    name_start: uint64 = cast[uint64](arg)
    pol: uint64 = SCHED_OTHER
    if _ctl_word_eq(buf, count, name_start, "fifo") == 1:
        pol = SCHED_FIFO
    elif _ctl_word_eq(buf, count, name_start, "rr") == 1:
        pol = SCHED_RR
    elif _ctl_word_eq(buf, count, name_start, "other") == 1:
        pol = SCHED_OTHER
    else:
        return 0
    out_policy[0] = pol
    # Step to the numeric priority token (if any).
    prio_start: uint64 = _ctl_skip_token_and_sep(buf, count, name_start)
    prio: int64 = 0
    if prio_start < count:
        # A non-delimiter byte begins a priority argument.
        pc: uint8 = buf[prio_start]
        if pc != 10 and pc != 13 and pc != 0:
            if _ctl_parse_signed(buf, count, prio_start, &prio) == 0:
                return 0
    out_prio[0] = prio
    return 1


def devproc_write(file_idx: uint32, buf: Ptr[uint8],
                  count: uint64) -> int64:
    # M16.109: /proc/<pid>/note is the only writable file_kind in the
    # devproc family. Everything else returns -1 + errstr — Plan 9
    # devproc.c::procwrite has the same shape (only `note` and `ctl`
    # accept writes, and ctl isn't a Phase C surface yet).
    pid_field: uint32 = (file_idx >> 8) & 0xFFFF
    kind:      uint32 = file_idx & 0xFF
    if kind == DEVPROC_KIND_NS:
        # V3: /proc/<pid>/ns is read-only. Plan 9 lets you write
        # control commands ("addmount", "addbind", ...) to it, but
        # that's V5+ scope — the V3 surface only serves the renderer.
        set_current_errstr("ns: not writable")
        return -1
    if kind == DEVPROC_KIND_CTL:
        # Plan 9 /proc/<pid>/ctl — write a control message to mutate the
        # target task. Resolve the embedded pid to a live slot exactly like
        # the note path below, then parse + apply the message.
        ctl_target: int32 = task_lookup_by_pid(cast[uint64](pid_field))
        if ctl_target < 0:
            set_current_errstr("ctl: pid vanished")
            return -1
        ctl_slot: uint64 = cast[uint64](cast[uint32](ctl_target))
        parsed: int64 = 0
        # `pri <int>` — set the per-task POSIX nice (sched_set_nice clamps to
        # NICE_MIN/MAX internally).
        pri_arg: int64 = _ctl_match_verb(buf, count, "pri")
        if pri_arg >= 0:
            if _ctl_parse_signed(buf, count, cast[uint64](pri_arg),
                                 &parsed) == 0:
                set_current_errstr("ctl: bad control message")
                return -1
            sched_set_nice(ctl_slot, parsed)
            return cast[int64](count)
        # `oomadj <int>` — set the per-task oom_score_adj (oom_adj_set clamps
        # to [-1000, 1000] internally).
        oom_arg: int64 = _ctl_match_verb(buf, count, "oomadj")
        if oom_arg >= 0:
            if _ctl_parse_signed(buf, count, cast[uint64](oom_arg),
                                 &parsed) == 0:
                set_current_errstr("ctl: bad control message")
                return -1
            oom_adj_set(ctl_slot, cast[int32](parsed))
            return cast[int64](count)
        # `policy <fifo|rr|other> [prio]` — set the per-task realtime
        # scheduling policy + priority. This is the NATIVE Plan 9 surface for
        # what Linux exposes as sched_setscheduler. sched_set_scheduler
        # validates the (policy, prio) pair (fifo/rr require prio 1..99, other
        # requires prio 0) and returns 0 on an invalid combination.
        pol_arg: int64 = _ctl_match_verb(buf, count, "policy")
        if pol_arg >= 0:
            new_policy: uint64 = SCHED_OTHER
            new_prio:   int64  = 0
            if _ctl_parse_policy(buf, count, &new_policy, &new_prio) == 0:
                set_current_errstr("ctl: bad control message")
                return -1
            if sched_set_scheduler(ctl_slot, new_policy, new_prio) == 0:
                set_current_errstr("ctl: invalid scheduling policy/priority")
                return -1
            return cast[int64](count)
        # Any other verb is unrecognised.
        set_current_errstr("ctl: bad control message")
        return -1
    if kind != DEVPROC_KIND_NOTE and kind != DEVPROC_KIND_NOTEPG:
        set_current_errstr("write not supported")
        return -1

    # Re-validate the pid at write time — same shape as devproc_read
    # above. A task that died after the open() left a stale pid in our
    # marker; refusing here keeps us from delivering a note to a
    # phantom slot or, worse, to a slot the kernel has handed to a
    # different tenant.
    target: int32 = task_lookup_by_pid(cast[uint64](pid_field))
    if target < 0:
        set_current_errstr("note: pid vanished")
        return -1

    if kind == DEVPROC_KIND_NOTEPG:
        # Plan 9 note-group WIDE delivery: post the note string to EVERY
        # live process whose note_group matches the target pid's group.
        # This is Plan 9's process-group signalling — one write fans the
        # note across the cohort. Reuses the per-task note machinery for
        # each recipient (post_note_to_group walks the table, enqueues
        # the pending note + message onto each live member, and does the
        # full self-delivery for the member that is the caller). We
        # return `count` on success — the write itself was well-formed.
        grp: int32 = task_note_group(target)
        nrec: int64 = post_note_to_group(grp, buf, count)
        printk1("notepg: posted note to note group, %d recipients\n",
                cast[uint64](cast[uint32](cast[int32](nrec))))
        return cast[int64](count)

    target_u: uint64 = cast[uint64](cast[uint32](target))

    # Self-delivery — the writer IS the target. This is the path the
    # M16.109 test fixture exercises (a single task writes to its own
    # /proc/<self>/note); the writer is currently inside the SYS_WRITE
    # syscall and its kstack frame holds the saved user-RIP/RSP we
    # need to retarget at kstack_top-24 / kstack_top-8. Self-delivery
    # with NO handler installed stays a well-formed-write drop (the
    # M16.109 behaviour — we don't self-terminate the writer).
    cur: uint64 = current_idx_get()
    if target_u == cur:
        handler: uint64 = task_note_handler_rip(target_u)
        if handler == 0:
            printk1("note: pid %d (self) has no handler installed (dropped)\n",
                    cast[uint64](pid_field))
            return cast[int64](count)
        return deliver_note_to_current(buf, count)

    # Cross-task delivery — the writer is not the target. Post the note
    # to that ONE pid: post_note_to_pid resolves the pid to a live slot,
    # enqueues the pending note + message onto it (the same per-task note
    # storage the note-group walk uses), and sets note_pending=1 so the
    # target acts on the note on its next return-to-user (run its handler,
    # or default-terminate when it has none) — identical to each group
    # member. Returns count on success, or -ESRCH if the pid vanished
    # between the lookup above and the post. Propagate the result HONESTLY
    # rather than faking success.
    return post_note_to_pid(cast[uint64](pid_field), buf, count)


# =====================================================================
# /proc/<pid>/stat CPU-time self-test
#   (gated on /etc/procstat-cpu-test, ENABLE_PROCSTAT_CPU_TEST=1)
# =====================================================================
#
# Proves /proc/<pid>/stat fields 14 (utime) and 15 (stime) are now the
# REAL per-task tick counts (kernel/sched/core.ad task_utime_ticks_at /
# task_stime_ticks_at), not the literal 0 they used to emit. The boot
# task runs in kernel context here, so the timer ISR charges its ticks
# to stime_ticks. We do NOT open /proc/self/stat as a file — the boot
# task at boot:37 has an uninitialised fd table — instead we render
# _emit_linux_stat DIRECTLY into a local buffer for the boot task's own
# slot, parse out field 15, and assert it equals the accounted stime and
# is non-"0". Returns 1 on PASS, 0 on FAIL.


def procstat_cpu_selftest() -> int32:
    boot_slot: int32 = cast[int32](current_idx_get())

    # start_kernel runs with CPU interrupts IF-blocked, so the LAPIC timer
    # tick (which advances jiffies + charges stime to the on-CPU task) is
    # armed but never fires. Briefly enable interrupts, busy-spin until
    # jiffies advances >= 5 ticks (each tick charges stime to THIS task —
    # cpu_relax does not yield), then re-disable. Same enable/spin/disable
    # warmup rusage_selftest uses.
    local_irq_enable()
    j0: uint64 = get_jiffies()
    while get_jiffies() < j0 + 5:
        cpu_relax()
    local_irq_disable()

    ut: uint64 = task_utime_ticks_at(boot_slot)
    st: uint64 = task_stime_ticks_at(boot_slot)
    if st == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PROCSTAT_CPU] FAIL stime_ticks==0\n")
        return 0

    # Render the boot task's own /proc/<pid>/stat line into a local
    # buffer (no file open). lbuf is LOCAL so it is a flat stack array.
    lbuf: Array[256, uint8]
    n: int64 = _emit_linux_stat(&lbuf[0], 256, boot_slot)
    if n <= 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[PROCSTAT_CPU] FAIL _emit_linux_stat rc=%d\n",
                cast[uint64](n))
        return 0

    # Walk the rendered line counting whitespace-separated fields. The
    # comm (field 2) is parenthesised and may contain spaces, so skip
    # from '(' to the matching ')' before resuming the field count.
    take: uint64 = cast[uint64](n)
    i: uint64 = 0
    fld: uint64 = 1                              # field 1 (pid) starts at byte 0
    # Locate the start byte of field 15 by counting spaces, honouring
    # the parenthesised comm.
    f15_start: uint64 = 0
    f15_found: int32 = 0
    while i < take:
        c: uint8 = lbuf[i]
        if c == 40:                              # '(' — start of comm
            # Skip to the matching ')'.
            while i < take and lbuf[i] != 41:    # ')'
                i = i + 1
            i = i + 1
            continue
        if c == 32:                              # ' ' — field separator
            fld = fld + 1
            if fld == 15:
                f15_start = i + 1
                f15_found = 1
                break
        i = i + 1

    if f15_found == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PROCSTAT_CPU] FAIL field 15 not located\n")
        return 0

    # Field 15 (stime) must be a non-"0" token: at least one digit and
    # not the literal single '0'. Re-parse its decimal value and confirm
    # it matches the accounted stime tick count.
    j: uint64 = f15_start
    val: uint64 = 0
    ndig: uint64 = 0
    while j < take:
        d: uint8 = lbuf[j]
        if d < 48 or d > 57:                     # not a digit -> end of field
            break
        val = val * 10 + cast[uint64](d - 48)
        ndig = ndig + 1
        j = j + 1

    if ndig == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PROCSTAT_CPU] FAIL field 15 empty\n")
        return 0
    if val == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PROCSTAT_CPU] FAIL field 15 is literal 0\n")
        return 0
    if val != st:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[PROCSTAT_CPU] FAIL field15=%d != stime=%d\n", val, st)
        return 0

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[PROCSTAT_CPU] PASS utime=%d stime=%d\n", ut, st)
    return 1


def starttime_selftest() -> int32:
    # Proves /proc/<pid>/stat field 22 (starttime) is now the REAL per-task
    # creation jiffy (kernel/sched/core.ad start_jiffies, captured write-
    # once in sched_init_task_weight), not the literal 0 it used to emit.
    # Deterministic direct-set: stamp the boot slot's start_jiffies to a
    # known sentinel, assert the accessor reads it back, then render
    # _emit_linux_stat for the boot slot and confirm field 22 parses to the
    # same sentinel. Returns 1 on PASS, 0 on FAIL.
    boot_slot: int32 = cast[int32](current_idx_get())

    # Stamp + read-back assert.
    task_set_start_jiffies_at(boot_slot, 12345)
    if task_start_jiffies_at(boot_slot) != 12345:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[STARTTIME] FAIL read-back=%d != 12345\n",
                task_start_jiffies_at(boot_slot))
        return 0

    # Render the boot task's own /proc/<pid>/stat line into a local buffer.
    lbuf: Array[256, uint8]
    n: int64 = _emit_linux_stat(&lbuf[0], 256, boot_slot)
    if n <= 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[STARTTIME] FAIL _emit_linux_stat rc=%d\n", cast[uint64](n))
        return 0

    # Walk the rendered line counting whitespace-separated fields. The comm
    # (field 2) is parenthesised and may contain spaces, so skip from '('
    # to the matching ')' before resuming the field count. Locate the start
    # byte of field 22 by counting spaces.
    take: uint64 = cast[uint64](n)
    i: uint64 = 0
    fld: uint64 = 1                              # field 1 (pid) starts at byte 0
    f22_start: uint64 = 0
    f22_found: int32 = 0
    while i < take:
        c: uint8 = lbuf[i]
        if c == 40:                              # '(' — start of comm
            while i < take and lbuf[i] != 41:    # ')'
                i = i + 1
            i = i + 1
            continue
        if c == 32:                              # ' ' — field separator
            fld = fld + 1
            if fld == 22:
                f22_start = i + 1
                f22_found = 1
                break
        i = i + 1

    if f22_found == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[STARTTIME] FAIL field 22 not located\n")
        return 0

    # Re-parse field 22's decimal value; it must equal the sentinel.
    j: uint64 = f22_start
    val: uint64 = 0
    ndig: uint64 = 0
    while j < take:
        d: uint8 = lbuf[j]
        if d < 48 or d > 57:                     # not a digit -> end of field
            break
        val = val * 10 + cast[uint64](d - 48)
        ndig = ndig + 1
        j = j + 1

    if ndig == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[STARTTIME] FAIL field 22 empty\n")
        return 0
    if val != 12345:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[STARTTIME] FAIL field22=%d != 12345\n", val)
        return 0

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("[STARTTIME] PASS starttime=%d\n", 12345)
    return 1


def prionice_selftest() -> int32:
    # Proves /proc/<pid>/stat field 18 (priority = 20 + nice) and field 19
    # (nice, SIGNED) are now REAL per-task POSIX nice (kernel/sched/core.ad
    # nice, read via sched_get_nice), not the literal 0 they used to emit.
    # Deterministic direct-set: set the boot slot's nice to a known negative
    # value, assert the accessor reads it back, render _emit_linux_stat for
    # the boot slot, parse field 18 (unsigned) and field 19 (signed), and
    # confirm priority==15 and nice==-5. Returns 1 on PASS, 0 on FAIL.
    boot_slot: int32 = cast[int32](current_idx_get())

    # Set a known negative nice + read-back assert.
    sched_set_nice(cast[uint64](boot_slot), -5)
    if sched_get_nice(cast[uint64](boot_slot)) != -5:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[PRIONICE] FAIL read-back=%d != -5\n",
                cast[uint64](sched_get_nice(cast[uint64](boot_slot))))
        return 0

    # Render the boot task's own /proc/<pid>/stat line into a local buffer.
    lbuf: Array[256, uint8]
    n: int64 = _emit_linux_stat(&lbuf[0], 256, boot_slot)
    if n <= 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[PRIONICE] FAIL _emit_linux_stat rc=%d\n", cast[uint64](n))
        sched_set_nice(cast[uint64](boot_slot), 0)
        return 0

    # Walk the rendered line counting whitespace-separated fields. The comm
    # (field 2) is parenthesised and may contain spaces, so skip from '(' to
    # the matching ')' before resuming the field count. Locate the start byte
    # of field 18 and field 19 by counting spaces.
    take: uint64 = cast[uint64](n)
    i: uint64 = 0
    fld: uint64 = 1                              # field 1 (pid) starts at byte 0
    f18_start: uint64 = 0
    f18_found: int32 = 0
    f19_start: uint64 = 0
    f19_found: int32 = 0
    while i < take:
        c: uint8 = lbuf[i]
        if c == 40:                              # '(' — start of comm
            while i < take and lbuf[i] != 41:    # ')'
                i = i + 1
            i = i + 1
            continue
        if c == 32:                              # ' ' — field separator
            fld = fld + 1
            if fld == 18:
                f18_start = i + 1
                f18_found = 1
            if fld == 19:
                f19_start = i + 1
                f19_found = 1
                break
        i = i + 1

    if f18_found == 0 or f19_found == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PRIONICE] FAIL field 18/19 not located\n")
        sched_set_nice(cast[uint64](boot_slot), 0)
        return 0

    # Parse field 18 (priority) — unsigned decimal, must equal 15 (20 + -5).
    j: uint64 = f18_start
    pri: uint64 = 0
    pdig: uint64 = 0
    while j < take:
        d: uint8 = lbuf[j]
        if d < 48 or d > 57:                     # not a digit -> end of field
            break
        pri = pri * 10 + cast[uint64](d - 48)
        pdig = pdig + 1
        j = j + 1
    if pdig == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PRIONICE] FAIL field 18 empty\n")
        sched_set_nice(cast[uint64](boot_slot), 0)
        return 0
    if pri != 15:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[PRIONICE] FAIL priority=%d != 15\n", pri)
        sched_set_nice(cast[uint64](boot_slot), 0)
        return 0

    # Parse field 19 (nice) — SIGNED decimal; detect a leading '-' (byte 45)
    # then magnitude, must equal -5.
    k: uint64 = f19_start
    neg: int32 = 0
    if k < take and lbuf[k] == 45:               # '-'
        neg = 1
        k = k + 1
    mag: int64 = 0
    ndig: uint64 = 0
    while k < take:
        d2: uint8 = lbuf[k]
        if d2 < 48 or d2 > 57:                    # not a digit -> end of field
            break
        mag = mag * 10 + cast[int64](cast[uint64](d2 - 48))
        ndig = ndig + 1
        k = k + 1
    if ndig == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PRIONICE] FAIL field 19 empty\n")
        sched_set_nice(cast[uint64](boot_slot), 0)
        return 0
    nice_val: int64 = mag
    if neg == 1:
        nice_val = 0 - mag
    if nice_val != -5:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[PRIONICE] FAIL nice=%d != -5\n",
                cast[uint64](nice_val))
        sched_set_nice(cast[uint64](boot_slot), 0)
        return 0

    # Restore the boot slot's nice to the default.
    sched_set_nice(cast[uint64](boot_slot), 0)

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[PRIONICE] PASS prio=15 nice=-5\n")
    return 1


def procctl_selftest() -> int32:
    # Proves the Plan 9 /proc/<pid>/ctl write surface: a "pri -5" control
    # message parsed by _ctl_parse_pri and applied via sched_set_nice actually
    # mutates the boot task's per-task POSIX nice. Construct the ctl message
    # bytes in a local buffer, drive the REAL parse path, apply, and assert
    # sched_get_nice(boot_slot) == -5. Restores nice to 0 afterward so later
    # tests aren't perturbed. Returns 1 PASS, 0 FAIL. PUBLIC so init/main.ad
    # can call it.
    boot_slot: int32 = cast[int32](current_idx_get())

    # Bytes: 'p' 'r' 'i' ' ' '-' '5' '\n'
    cbuf: Array[8, uint8]
    cbuf[0] = 112                                    # 'p'
    cbuf[1] = 114                                    # 'r'
    cbuf[2] = 105                                    # 'i'
    cbuf[3] = 32                                     # ' '
    cbuf[4] = 45                                     # '-'
    cbuf[5] = 53                                     # '5'
    cbuf[6] = 10                                     # '\n'

    parsed: int64 = 0
    if _ctl_parse_pri(&cbuf[0], 7, &parsed) == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PROCCTL] FAIL parse of 'pri -5'\n")
        return 0
    if parsed != -5:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[PROCCTL] FAIL parsed=%d != -5\n", cast[uint64](parsed))
        return 0

    # Apply exactly as the ctl write path does.
    sched_set_nice(cast[uint64](boot_slot), parsed)
    rb: int64 = sched_get_nice(cast[uint64](boot_slot))
    if rb != -5:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[PROCCTL] FAIL nice read-back=%d != -5\n", cast[uint64](rb))
        sched_set_nice(cast[uint64](boot_slot), 0)
        return 0

    # Restore the boot slot's nice to the default.
    sched_set_nice(cast[uint64](boot_slot), 0)

    # rb is asserted == -5 above; printk's %d treats its arg as unsigned, so
    # print the magnitude with an explicit sign to render the read-back value
    # as "-5" (mirrors how the sibling nice selftest reports a negative nice).
    mag: uint64 = cast[uint64](0 - rb)
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("[PROCCTL] PASS set=-5 nice=-%d\n", mag)
    return 1


def pgrp_selftest() -> int32:
    # Proves /proc/<pid>/stat field 5 (pgrp = job process-group id) is now
    # REAL per-task data (kernel/sched/core.ad job_pgid, read via
    # task_get_job_pgid), not the literal 0 it used to emit. Deterministic
    # direct-set: set the boot slot's job_pgid to a known sentinel, render
    # _emit_linux_stat for the boot slot, parse field 5 (unsigned), and
    # confirm it equals 4242. Returns 1 on PASS, 0 on FAIL.
    boot_slot: int32 = cast[int32](current_idx_get())

    # Set a known sentinel pgrp + read-back assert.
    task_set_job_pgid(cast[uint64](boot_slot), 4242)
    if task_get_job_pgid(cast[uint64](boot_slot)) != 4242:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[PGRP] FAIL read-back=%d != 4242\n",
                task_get_job_pgid(cast[uint64](boot_slot)))
        return 0

    # Render the boot task's own /proc/<pid>/stat line into a local buffer.
    lbuf: Array[256, uint8]
    n: int64 = _emit_linux_stat(&lbuf[0], 256, boot_slot)
    if n <= 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[PGRP] FAIL _emit_linux_stat rc=%d\n", cast[uint64](n))
        task_set_job_pgid(cast[uint64](boot_slot), cast[uint64](task_pid_at(boot_slot)))
        return 0

    # Walk the rendered line counting whitespace-separated fields. The comm
    # (field 2) is parenthesised and may contain spaces, so skip from '(' to
    # the matching ')' before resuming the field count. Locate the start byte
    # of field 5 by counting spaces.
    take: uint64 = cast[uint64](n)
    i: uint64 = 0
    fld: uint64 = 1                              # field 1 (pid) starts at byte 0
    f5_start: uint64 = 0
    f5_found: int32 = 0
    while i < take:
        c: uint8 = lbuf[i]
        if c == 40:                              # '(' — start of comm
            while i < take and lbuf[i] != 41:    # ')'
                i = i + 1
            i = i + 1
            continue
        if c == 32:                              # ' ' — field separator
            fld = fld + 1
            if fld == 5:
                f5_start = i + 1
                f5_found = 1
                break
        i = i + 1

    if f5_found == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PGRP] FAIL field 5 not located\n")
        task_set_job_pgid(cast[uint64](boot_slot), cast[uint64](task_pid_at(boot_slot)))
        return 0

    # Parse field 5 (pgrp) — unsigned decimal, must equal 4242.
    j: uint64 = f5_start
    pgrp: uint64 = 0
    pdig: uint64 = 0
    while j < take:
        d: uint8 = lbuf[j]
        if d < 48 or d > 57:                     # not a digit -> end of field
            break
        pgrp = pgrp * 10 + cast[uint64](d - 48)
        pdig = pdig + 1
        j = j + 1
    if pdig == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PGRP] FAIL field 5 empty\n")
        task_set_job_pgid(cast[uint64](boot_slot), cast[uint64](task_pid_at(boot_slot)))
        return 0
    if pgrp != 4242:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[PGRP] FAIL pgrp=%d != 4242\n", pgrp)
        task_set_job_pgid(cast[uint64](boot_slot), cast[uint64](task_pid_at(boot_slot)))
        return 0

    # Restore the boot slot's job_pgid to its own pid (a task leads its group).
    task_set_job_pgid(cast[uint64](boot_slot), cast[uint64](task_pid_at(boot_slot)))

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[PGRP] PASS pgrp=4242\n")
    return 1


def procflags_selftest() -> int32:
    # Proves /proc/<pid>/stat field 9 (flags = the task's Linux PF_* kernel
    # flags word) is now REAL per-task data (kernel/sched/core.ad is_user, read
    # via task_is_user_at), not the literal 0 it used to emit. The boot/current
    # task is a KERNEL context here (init runs as a kernel thread at this point
    # in boot), so task_is_user_at(boot_slot) == 0 → field 9 renders PF_KTHREAD
    # (0x00200000 = 2097152). No setter needed: we read the boot task's real
    # is_user. Render _emit_linux_stat for the boot slot, parse field 9
    # (unsigned), and confirm it equals 2097152. Returns 1 on PASS, 0 on FAIL.
    boot_slot: int32 = cast[int32](current_idx_get())

    # The boot/current task must be a kernel thread (is_user == 0) for the
    # PF_KTHREAD case; read it back to compute the expected value honestly.
    exp9: uint64 = 0
    if task_is_user_at(cast[uint64](boot_slot)) == 0:
        exp9 = 2097152                           # PF_KTHREAD (0x00200000)

    # Render the boot task's own /proc/<pid>/stat line into a local buffer.
    lbuf: Array[256, uint8]
    n: int64 = _emit_linux_stat(&lbuf[0], 256, boot_slot)
    if n <= 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[PROCFLAGS] FAIL _emit_linux_stat rc=%d\n", cast[uint64](n))
        return 0

    # Walk the rendered line counting whitespace-separated fields. The comm
    # (field 2) is parenthesised and may contain spaces, so skip from '(' to
    # the matching ')' before resuming the field count. Locate the start byte
    # of field 9 by counting spaces.
    take: uint64 = cast[uint64](n)
    i: uint64 = 0
    fld: uint64 = 1                              # field 1 (pid) starts at byte 0
    f9_start: uint64 = 0
    f9_found: int32 = 0
    while i < take:
        c: uint8 = lbuf[i]
        if c == 40:                              # '(' — start of comm
            while i < take and lbuf[i] != 41:    # ')'
                i = i + 1
            i = i + 1
            continue
        if c == 32:                              # ' ' — field separator
            fld = fld + 1
            if fld == 9:
                f9_start = i + 1
                f9_found = 1
                break
        i = i + 1

    if f9_found == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PROCFLAGS] FAIL field 9 not located\n")
        return 0

    # Parse field 9 (flags) — unsigned decimal, must equal exp9.
    j: uint64 = f9_start
    flags: uint64 = 0
    fdig: uint64 = 0
    while j < take:
        d: uint8 = lbuf[j]
        if d < 48 or d > 57:                     # not a digit -> end of field
            break
        flags = flags * 10 + cast[uint64](d - 48)
        fdig = fdig + 1
        j = j + 1
    if fdig == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PROCFLAGS] FAIL field 9 empty\n")
        return 0
    if flags != exp9:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[PROCFLAGS] FAIL flags=%d != %d\n", flags, exp9)
        return 0

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("[PROCFLAGS] PASS flags=%d\n", exp9)
    return 1


def _io_line_value(lbuf: Ptr[uint8], take: uint64, label: Ptr[uint8],
                   out_found: Ptr[int32]) -> uint64:
    # Scan the rendered /proc/<pid>/io text for a line beginning with the
    # NUL-terminated `label`, then parse the unsigned decimal that follows
    # the "<label>: " prefix. Sets out_found[0]=1 on a hit, 0 otherwise.
    # Matches `label` only at a line start (byte 0 or just after a '\n') so a
    # substring like "char" inside "rchar" can't false-match.
    out_found[0] = 0
    i: uint64 = 0
    while i < take:
        # Is this position a line start?
        line_start: int32 = 0
        if i == 0:
            line_start = 1
        elif lbuf[i - 1] == 10:                  # previous byte '\n'
            line_start = 1
        if line_start != 0:
            # Try to match the label here.
            k: uint64 = 0
            matched: int32 = 1
            while label[k] != 0:
                if i + k >= take or lbuf[i + k] != label[k]:
                    matched = 0
                    break
                k = k + 1
            if matched != 0 and i + k + 1 < take \
                    and lbuf[i + k] == 58 and lbuf[i + k + 1] == 32:
                # Past "<label>: " — parse the decimal.
                j: uint64 = i + k + 2
                val: uint64 = 0
                ndig: uint64 = 0
                while j < take:
                    d: uint8 = lbuf[j]
                    if d < 48 or d > 57:
                        break
                    val = val * 10 + cast[uint64](d - 48)
                    ndig = ndig + 1
                    j = j + 1
                if ndig != 0:
                    out_found[0] = 1
                    return val
        i = i + 1
    return 0


def procio_selftest() -> int32:
    # Proves /proc/<pid>/io is REAL per-task data. Deterministic direct-set:
    # stamp the boot slot's rchar/wchar/syscr/syscw (and inblock/oublock so
    # read_bytes/write_bytes are checkable) with known sentinels, render
    # emit_proc_io for the boot slot, parse the seven lines, and confirm they
    # match. Restores the perturbed counters afterward. Returns 1 PASS, 0 FAIL.
    boot_slot: int32 = cast[int32](current_idx_get())

    # Save the live counters so the self-test leaves no residue.
    save_rchar:   uint64 = task_rchar_at(boot_slot)
    save_wchar:   uint64 = task_wchar_at(boot_slot)
    save_syscr:   uint64 = task_syscr_at(boot_slot)
    save_syscw:   uint64 = task_syscw_at(boot_slot)
    save_inblock: uint64 = task_inblock_at(boot_slot)
    save_oublock: uint64 = task_oublock_at(boot_slot)

    # Stamp known sentinels + read-back assert via the accessors.
    task_set_rchar_at(boot_slot, 1000)
    task_set_wchar_at(boot_slot, 2000)
    task_set_syscr_at(boot_slot, 11)
    task_set_syscw_at(boot_slot, 22)
    task_set_inblock_at(boot_slot, 2)            # read_bytes  = 2 * 512 = 1024
    task_set_oublock_at(boot_slot, 3)            # write_bytes = 3 * 512 = 1536

    # Render the boot task's own /proc/<pid>/io into a local buffer.
    lbuf: Array[256, uint8]
    n: int64 = emit_proc_io(&lbuf[0], 256, boot_slot)
    if n <= 0:
        # Restore before bailing.
        task_set_rchar_at(boot_slot, save_rchar)
        task_set_wchar_at(boot_slot, save_wchar)
        task_set_syscr_at(boot_slot, save_syscr)
        task_set_syscw_at(boot_slot, save_syscw)
        task_set_inblock_at(boot_slot, save_inblock)
        task_set_oublock_at(boot_slot, save_oublock)
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[PROCIO] FAIL emit_proc_io rc=%d\n", cast[uint64](n))
        return 0
    take: uint64 = cast[uint64](n)

    found: int32 = 0
    ok: int32 = 1
    v_rchar: uint64 = _io_line_value(&lbuf[0], take, "rchar", &found)
    if found == 0 or v_rchar != 1000:
        ok = 0
    v_wchar: uint64 = _io_line_value(&lbuf[0], take, "wchar", &found)
    if found == 0 or v_wchar != 2000:
        ok = 0
    v_syscr: uint64 = _io_line_value(&lbuf[0], take, "syscr", &found)
    if found == 0 or v_syscr != 11:
        ok = 0
    v_syscw: uint64 = _io_line_value(&lbuf[0], take, "syscw", &found)
    if found == 0 or v_syscw != 22:
        ok = 0
    v_rb: uint64 = _io_line_value(&lbuf[0], take, "read_bytes", &found)
    if found == 0 or v_rb != 1024:
        ok = 0
    v_wb: uint64 = _io_line_value(&lbuf[0], take, "write_bytes", &found)
    if found == 0 or v_wb != 1536:
        ok = 0

    # Restore the perturbed counters regardless of outcome.
    task_set_rchar_at(boot_slot, save_rchar)
    task_set_wchar_at(boot_slot, save_wchar)
    task_set_syscr_at(boot_slot, save_syscr)
    task_set_syscw_at(boot_slot, save_syscw)
    task_set_inblock_at(boot_slot, save_inblock)
    task_set_oublock_at(boot_slot, save_oublock)

    if ok == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[PROCIO] FAIL rchar=%d wchar=%d\n", v_rchar, v_wchar)
        printk2("[PROCIO] FAIL syscr=%d syscw=%d\n", v_syscr, v_syscw)
        printk2("[PROCIO] FAIL read_bytes=%d write_bytes=%d\n", v_rb, v_wb)
        return 0

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[PROCIO] PASS rchar=1000 wchar=2000 syscr=11 syscw=22\n")
    return 1


def _lim_scan_row(lbuf: Ptr[uint8], take: uint64, label: Ptr[uint8],
                  out_soft: Ptr[uint64], out_hard: Ptr[uint64]) -> int32:
    # Scan the rendered /proc/<pid>/limits text for the line beginning with the
    # NUL-terminated `label` (matched only at a line start so a substring can't
    # false-match), then read the next two whitespace-separated tokens as the
    # Soft and Hard cells. Each token is either a decimal or the literal
    # "unlimited" (rendered as RLIM_INFINITY = 0xFFFFFFFFFFFFFFFF). Returns 1 on
    # a hit (out_soft/out_hard set), 0 otherwise. Used by proclimits_selftest.
    out_soft[0] = 0
    out_hard[0] = 0
    i: uint64 = 0
    while i < take:
        line_start: int32 = 0
        if i == 0:
            line_start = 1
        elif lbuf[i - 1] == 10:                     # previous byte '\n'
            line_start = 1
        if line_start != 0:
            k: uint64 = 0
            matched: int32 = 1
            while label[k] != 0:
                if i + k >= take or lbuf[i + k] != label[k]:
                    matched = 0
                    break
                k = k + 1
            if matched != 0:
                # Advance past the label to the first column separator, then
                # read two tokens (Soft, Hard).
                j: uint64 = i + k
                tok: uint64 = 0
                while tok < 2:
                    # Skip spaces.
                    while j < take and lbuf[j] == 32:
                        j = j + 1
                    if j >= take:
                        return 0
                    val: uint64 = 0
                    if lbuf[j] == 117:              # 'u' -> "unlimited"
                        val = 0xFFFFFFFFFFFFFFFF
                        while j < take and lbuf[j] != 32 and lbuf[j] != 10:
                            j = j + 1
                    else:
                        ndig: uint64 = 0
                        while j < take:
                            d: uint8 = lbuf[j]
                            if d < 48 or d > 57:
                                break
                            val = val * 10 + cast[uint64](d - 48)
                            ndig = ndig + 1
                            j = j + 1
                        if ndig == 0:
                            return 0
                    if tok == 0:
                        out_soft[0] = val
                    else:
                        out_hard[0] = val
                    tok = tok + 1
                return 1
        i = i + 1
    return 0


def proclimits_selftest() -> int32:
    # Proves /proc/<pid>/limits is REAL per-task data. The boot slot's rlimits
    # are the seeded Linux defaults (rlimit_init_task, kernel/sched/core.ad):
    # RLIMIT_NOFILE(7) cur=1024/max=4096, RLIMIT_STACK(3) cur=8388608. Render
    # emit_proc_limits for the boot slot, parse the "Max open files" and
    # "Max stack size" rows, and assert those values. No state is perturbed, so
    # no restore is needed. Returns 1 PASS, 0 FAIL. PUBLIC so init/main.ad can
    # call it.
    boot_slot: int32 = cast[int32](current_idx_get())

    lbuf: Array[2048, uint8]
    n: int64 = emit_proc_limits(&lbuf[0], 2048, boot_slot)
    if n <= 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[PROCLIMITS] FAIL emit_proc_limits rc=%d\n", cast[uint64](n))
        return 0
    take: uint64 = cast[uint64](n)

    ok: int32 = 1
    nofile_soft: uint64 = 0
    nofile_hard: uint64 = 0
    stack_soft:  uint64 = 0
    stack_hard:  uint64 = 0

    if _lim_scan_row(&lbuf[0], take, "Max open files",
                     &nofile_soft, &nofile_hard) == 0:
        ok = 0
    if _lim_scan_row(&lbuf[0], take, "Max stack size",
                     &stack_soft, &stack_hard) == 0:
        ok = 0

    if nofile_soft != 1024:
        ok = 0
    if nofile_hard != 4096:
        ok = 0
    if stack_soft != 8388608:
        ok = 0

    if ok == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[PROCLIMITS] FAIL nofile_soft=%d nofile_hard=%d\n",
                nofile_soft, nofile_hard)
        printk1("[PROCLIMITS] FAIL stack_soft=%d\n", stack_soft)
        return 0

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[PROCLIMITS] PASS nofile_soft=1024 nofile_hard=4096 stack_soft=8388608\n")
    return 1


def _childacct_field_u64(lbuf: Ptr[uint8], take: uint64,
                         target: uint64, out_found: Ptr[int32]) -> uint64:
    # Walk the rendered /proc/<pid>/stat line in `lbuf` (length `take`) to the
    # whitespace-separated field numbered `target` (1-based), honouring the
    # parenthesised comm (field 2), and parse it as an unsigned decimal.
    # *out_found is set to 1 if the field was located AND had >=1 digit, else 0.
    out_found[0] = 0
    i: uint64 = 0
    fld: uint64 = 1                              # field 1 (pid) starts at byte 0
    fstart: uint64 = 0
    located: int32 = 0
    if target == 1:
        fstart = 0
        located = 1
    while i < take and located == 0:
        c: uint8 = lbuf[i]
        if c == 40:                              # '(' — start of comm
            while i < take and lbuf[i] != 41:    # ')'
                i = i + 1
            i = i + 1
            continue
        if c == 32:                              # ' ' — field separator
            fld = fld + 1
            if fld == target:
                fstart = i + 1
                located = 1
                break
        i = i + 1
    if located == 0:
        return 0
    j: uint64 = fstart
    val: uint64 = 0
    ndig: uint64 = 0
    while j < take:
        d: uint8 = lbuf[j]
        if d < 48 or d > 57:                     # not a digit -> end of field
            break
        val = val * 10 + cast[uint64](d - 48)
        ndig = ndig + 1
        j = j + 1
    if ndig == 0:
        return 0
    out_found[0] = 1
    return val


def childacct_selftest() -> int32:
    # Proves /proc/<pid>/stat field 11 (cminflt), field 13 (cmajflt), field 16
    # (cutime) and field 17 (cstime) are now REAL child-resource accounting
    # fields (kernel/sched/core.ad cminflt/cmajflt/cutime_ticks/cstime_ticks,
    # rolled up at reap), not the literal 0 they used to emit. Deterministic
    # direct-set: stamp the boot slot's four child-accumulators with known
    # sentinels, assert the accessors read them back, render _emit_linux_stat
    # for the boot slot, parse fields 11/13/16/17 and confirm they match.
    # Returns 1 on PASS, 0 on FAIL.
    boot_slot: int32 = cast[int32](current_idx_get())

    # Stamp known sentinels + read-back assert via the accessors.
    task_set_cutime_ticks_at(boot_slot, 11)
    task_set_cstime_ticks_at(boot_slot, 22)
    task_set_cminflt_at(boot_slot, 33)
    task_set_cmajflt_at(boot_slot, 44)
    if task_cutime_ticks_at(boot_slot) != 11:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[CHILDACCT] FAIL cutime read-back=%d != 11\n",
                task_cutime_ticks_at(boot_slot))
        return 0
    if task_cstime_ticks_at(boot_slot) != 22:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[CHILDACCT] FAIL cstime read-back=%d != 22\n",
                task_cstime_ticks_at(boot_slot))
        return 0
    if task_cminflt_at(boot_slot) != 33:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[CHILDACCT] FAIL cminflt read-back=%d != 33\n",
                task_cminflt_at(boot_slot))
        return 0
    if task_cmajflt_at(boot_slot) != 44:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[CHILDACCT] FAIL cmajflt read-back=%d != 44\n",
                task_cmajflt_at(boot_slot))
        return 0

    # Render the boot task's own /proc/<pid>/stat line into a local buffer.
    lbuf: Array[256, uint8]
    n: int64 = _emit_linux_stat(&lbuf[0], 256, boot_slot)
    if n <= 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[CHILDACCT] FAIL _emit_linux_stat rc=%d\n", cast[uint64](n))
        return 0
    take: uint64 = cast[uint64](n)

    # field 11 (cminflt) == 33
    found: int32 = 0
    v11: uint64 = _childacct_field_u64(&lbuf[0], take, 11, &found)
    if found == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[CHILDACCT] FAIL field 11 not located\n")
        return 0
    if v11 != 33:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[CHILDACCT] FAIL field11(cminflt)=%d != 33\n", v11)
        return 0

    # field 13 (cmajflt) == 44
    v13: uint64 = _childacct_field_u64(&lbuf[0], take, 13, &found)
    if found == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[CHILDACCT] FAIL field 13 not located\n")
        return 0
    if v13 != 44:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[CHILDACCT] FAIL field13(cmajflt)=%d != 44\n", v13)
        return 0

    # field 16 (cutime) == 11
    v16: uint64 = _childacct_field_u64(&lbuf[0], take, 16, &found)
    if found == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[CHILDACCT] FAIL field 16 not located\n")
        return 0
    if v16 != 11:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[CHILDACCT] FAIL field16(cutime)=%d != 11\n", v16)
        return 0

    # field 17 (cstime) == 22
    v17: uint64 = _childacct_field_u64(&lbuf[0], take, 17, &found)
    if found == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[CHILDACCT] FAIL field 17 not located\n")
        return 0
    if v17 != 22:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[CHILDACCT] FAIL field17(cstime)=%d != 22\n", v17)
        return 0

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[CHILDACCT] PASS cutime=11 cstime=22 cminflt=33 cmajflt=44\n")
    return 1


def _fd_line_target_eq(lbuf: Ptr[uint8], take: uint64, want: uint64,
                       expect: Ptr[uint8]) -> int32:
    # Scan the rendered /proc/<pid>/fd buffer (length `take`) for a line whose
    # leading decimal descriptor number equals `want` ("<want>\t..."), then
    # compare the target column (everything after the TAB up to the trailing
    # '\n') byte-for-byte against the NUL-terminated literal `expect`. Returns 1
    # on an exact match, 0 if the line is missing or the target differs. Used by
    # procfd_selftest to assert both the fd-number AND target columns.
    i: uint64 = 0
    at_line_start: int32 = 1
    while i < take:
        if at_line_start == 1:
            # Parse the leading decimal at this line start.
            j: uint64 = i
            val: uint64 = 0
            ndig: uint64 = 0
            while j < take:
                d: uint8 = lbuf[j]
                if d < 48 or d > 57:
                    break
                val = val * 10 + cast[uint64](d - 48)
                ndig = ndig + 1
                j = j + 1
            # A well-formed fd line is "<dec>\t<target>\n".
            if ndig > 0 and j < take and lbuf[j] == 9 and val == want:
                t: uint64 = j + 1                    # first byte past the TAB
                k: uint64 = 0
                while expect[k] != 0:
                    if t >= take:
                        return 0                     # target shorter than expect
                    if lbuf[t] != expect[k]:
                        return 0
                    t = t + 1
                    k = k + 1
                # Target must end exactly here (next byte is the line '\n').
                if t < take and lbuf[t] == 10:
                    return 1
                return 0
        if lbuf[i] == 10:                            # '\n' -> next char is a line start
            at_line_start = 1
        else:
            at_line_start = 0
        i = i + 1
    return 0


def procfd_selftest() -> int32:
    # Gap-report #3: proves /proc/<pid>/fd is REAL per-task data driven by the
    # fd table (task_fd_idx_at/task_fd_buf_at, kernel/sched/core.ad). The boot
    # task at boot:37 has an uninitialised fd table (same caveat the
    # procstat_cpu self-test documents), so — like the childacct/io/limits
    # self-tests — we DETERMINISTICALLY stamp known descriptors into the boot
    # slot via the setters, render emit_proc_fd, and assert each line's fd
    # number AND its target column:
    #
    #   fd 0 -> FD_STDIN_MARK                       => "/dev/cons"
    #   fd 1 -> FD_CHAN_MARK / DEV_PIPE_W chan      => "pipe:[<slot>]"
    #   fd 2 -> FD_CHAN_MARK / DEV_SOCKET chan      => "socket:[3]"
    #
    # Phase 4c: fd 1 is a REAL pipe write-end chan (pipe_alloc +
    # namec_open_pipe_end), not a hand-stamped mark — the renderer must
    # recover the ring slot through the chan's back_slot, so this gate
    # also exercises the DEV_PIPE fold. The expected string is built
    # dynamically from the allocated slot. fd 2 is likewise a REAL
    # DEV_SOCKET chan (namec_open_socket(3) — back_slot carries the
    # legacy fdbuf encoding), exercising the socket fold's renderer.
    #
    # This exercises a console fd, an anon-pipe fd and an anon-socket fd —
    # covering the path-less anon-inode rendering. Returns 1 PASS, 0 FAIL.
    # PUBLIC so init/main.ad can call it.
    boot_slot: int32 = cast[int32](current_idx_get())

    pslot: int32 = pipe_alloc()
    if pslot < 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PROCFD] FAIL pipe_alloc exhausted\n")
        return 0
    wch: int32 = namec_open_pipe_end(pslot, 1)
    if wch < 0:
        pipe_close_reader(pslot)
        pipe_close_writer(pslot)
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PROCFD] FAIL chan pool exhausted\n")
        return 0
    # Phase 4c (socket fold): a record-less DEV_SOCKET chan whose
    # back_slot carries the legacy fdbuf encoding 3.
    sch: int32 = namec_open_socket(3)
    if sch < 0:
        namec_close(wch)
        pipe_close_reader(pslot)
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PROCFD] FAIL chan pool exhausted (socket)\n")
        return 0
    # Build the expected target column "pipe:[<pslot>]".
    pexp: Array[24, uint8]
    pexp[0] = 112  # 'p'
    pexp[1] = 105  # 'i'
    pexp[2] = 112  # 'p'
    pexp[3] = 101  # 'e'
    pexp[4] = 58   # ':'
    pexp[5] = 91   # '['
    pn: uint64 = 6 + _u64_to_dec(cast[uint64](cast[uint32](pslot)),
                                 &pexp[6])
    pexp[pn] = 93  # ']'
    pexp[pn + 1] = 0

    # Snapshot the three slots we touch so we can restore them afterwards —
    # the boot task keeps running after the self-test.
    s0i: uint32 = task_fd_idx_at(boot_slot, 0)
    s0b: uint64 = task_fd_buf_at(boot_slot, 0)
    s1i: uint32 = task_fd_idx_at(boot_slot, 1)
    s1b: uint64 = task_fd_buf_at(boot_slot, 1)
    s2i: uint32 = task_fd_idx_at(boot_slot, 2)
    s2b: uint64 = task_fd_buf_at(boot_slot, 2)

    task_set_fd_idx_at(boot_slot, 0, FD_STDIN_MARK)
    task_set_fd_buf_at(boot_slot, 0, 0)
    task_set_fd_idx_at(boot_slot, 1, FD_CHAN_MARK)
    task_set_fd_buf_at(boot_slot, 1, cast[uint64](cast[uint32](wch)))
    task_set_fd_idx_at(boot_slot, 2, FD_CHAN_MARK)
    task_set_fd_buf_at(boot_slot, 2, cast[uint64](cast[uint32](sch)))

    fbuf: Array[1024, uint8]
    n: int64 = emit_proc_fd(&fbuf[0], 1024, boot_slot)

    ok: int32 = 1
    if n <= 0:
        ok = 0
    else:
        take: uint64 = cast[uint64](n)
        if _fd_line_target_eq(&fbuf[0], take, 0, "/dev/cons") == 0:
            ok = 0
        if _fd_line_target_eq(&fbuf[0], take, 1,
                              cast[Ptr[uint8]](&pexp[0])) == 0:
            ok = 0
        if _fd_line_target_eq(&fbuf[0], take, 2, "socket:[3]") == 0:
            ok = 0

    # Restore the boot task's original fd slots before returning.
    task_set_fd_idx_at(boot_slot, 0, s0i)
    task_set_fd_buf_at(boot_slot, 0, s0b)
    task_set_fd_idx_at(boot_slot, 1, s1i)
    task_set_fd_buf_at(boot_slot, 1, s1b)
    task_set_fd_idx_at(boot_slot, 2, s2i)
    task_set_fd_buf_at(boot_slot, 2, s2b)

    # Tear the pipe down: namec_close releases the chan-owned writer
    # ref (DEV_PIPE_W arm); the reader ref from pipe_alloc is dropped
    # directly so the ring slot is reclaimed.
    namec_close(wch)
    pipe_close_reader(pslot)
    # Zero the socket chan's record encoding before closing it so the
    # DEV_SOCKET release arm is a guaranteed no-op (back_slot 3 was a
    # synthetic fdbuf, not a real usock record).
    namec_socket_set_record(sch, 0)
    namec_close(sch)

    if ok == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[PROCFD] FAIL emit_proc_fd rc=%d\n", cast[uint64](n))
        return 0

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[PROCFD] PASS fd0=/dev/cons fd1=pipe:[slot] fd2=socket:[3]\n")
    return 1

# Phase 4b: devproc_close is DELETED — a /proc/<pid>/<leaf> fd is a
# DEV_PROC pool chan now; close goes through close_fd_in_task →
# namec_close, and DEV_PROC is stateless so the default _chan_free
# path is all the cleanup there is.

# sys/src/9/port/devproc.ad
#
# Layer 1 (Plan 9-shape) per-process introspection device — fifth
# concrete /dev style cdev family on the Hamnix native surface,
# sibling to devcons.ad / devtime.ad / devpid.ad / devrandom.ad.
# Mirrors 9front's /sys/src/9/port/devproc.c at minimum scope: a
# /proc/<pid>/<file> name resolves to a stateless fd whose read
# produces one line of text describing the named process.
#
# See docs/native-api.md ("Reserved well-known paths" — entries for
# /proc/<pid>/{cwd,status,ns,note}). This commit ships `cwd` and
# `status` (read-only); `note` is deferred until notify(2)/noted(2)
# land, and `ns` is deferred until the Phase D namespace machinery
# in chan.ad gains a real read-side.
#
# VFS plumbing: fs/vfs.ad recognises a `/proc/<digits>/<leaf>` path,
# calls devproc_open(path) which returns an encoded marker fd. The
# marker carries enough state for devproc_read to recover pid + file
# kind on its own — no per-fd kmalloc, no slot in any table, close is
# a no-op. Stateless backend matches the other Plan 9-shape cdevs in
# this directory; see devcons.ad for the prior-art comment block.
#
# Marker encoding (uint32, stored in TaskStruct.fd_idx):
#
#     [31:24] = 0xFE                 — high-byte tag for the proc family
#     [23: 8] = pid (uint16-bounded; we cap at 0xFFFF on encode)
#     [ 7: 0] = file_kind            — 0=status, 1=cwd, 2=stat (rejected)
#
# vfs_read/vfs_write detect a proc fd with
#   (file_idx & 0xFF000000) == FD_PROC_MARK
# and forward to devproc_read / devproc_write below. The 0xFE tag is
# distinct from the 0xFFFFFFxx tags used by FD_CONS_MARK / FD_TIME_MARK
# / FD_PID_MARK / FD_RANDOM_MARK / FD_*_MARK so a proc fd can't be
# mistaken for any of them, and it's well above the real initramfs
# file-index range (~hundreds, never near 2^24) so cpio fds don't
# collide either.
#
# Note on the spec literal: docs/native-api.md sketches a constant
# named "FD_PROC_MARK = 0xFFFFFFED" alongside the encoding
# "FD_PROC_MARK | (pid<<8) | file_kind". Those two are mutually
# inconsistent at the bit level — the literal's low byte (0xED) would
# force file_kind to be 0xED regardless of what we OR in, and the
# detection mask (file_idx & 0xFFFFFF00) == FD_PROC_MARK would never
# fire. We adopt the encoding the spec describes (pid<<8 | file_kind)
# and choose a high-byte tag that makes the encoding well-formed.

from kernel.sched.core import (
    task_lookup_by_pid, task_state, task_pid_at, task_pml4,
    get_cwd_buf, set_current_errstr,
    STATE_READY, STATE_RUNNING, STATE_EXITED,
    task_name0_at,
    current_idx_get,
    task_note_handler_rip,
    task_note_group,
    task_parent_pid, get_task_comm_ptr,
    # `/proc/self/...` resolves to the CALLING task's pid — needed so
    # a program can introspect its own namespace (HAMSH §14).
    current_task_pid,
)
# M16.109: note delivery body lives in sysnote.ad so the same self-
# delivery primitive can be re-used by future drivers (kbd Ctrl-C ->
# postnote / segfault handler -> postnote etc.).
from sys.src.port9.port.sysnote import deliver_note_to_current
# Phase G: /proc/<pid>/notepg posts a note to the target's whole note
# group (Plan 9 note-group WIDE delivery).
from sys.src.port9.port.sysnote import post_note_to_group
# V3: /proc/<pid>/ns renders the target task's Pgrp mtab as
# ns(1)-shape text. The render helper lives in chan.ad next to the
# Pgrp struct it walks.
from sys.src.port9.port.chan import pgrp_render_ns, pgrp_for_task
from kernel.printk.printk import printk1
# §13: /proc/<pid>/maps renders the target task's VMA list.
from mm.vma import vma_maps_render

# Marker base. See header for the encoding layout.
FD_PROC_MARK_BASE:   uint32 = 0xFE000000
FD_PROC_MARK_MASK:   uint32 = 0xFF000000

# File-kind tags (lowest 8 bits of the marker).
DEVPROC_KIND_STATUS: uint32 = 0
DEVPROC_KIND_CWD:    uint32 = 1
DEVPROC_KIND_STAT:   uint32 = 2
# M16.109: write-only entry for Plan 9 note (signal) delivery. Reads
# return -1 + errstr "note: not readable" — Plan 9 contract.
DEVPROC_KIND_NOTE:   uint32 = 3
# V3: /proc/<pid>/ns. Read renders the target task's Pgrp mtab as
# ns(1)-shape text ("bind /from /to\n", "mount #s/<srvfd> /to\n").
# Write returns -1 + errstr ("ns: not writable") — Plan 9 contract;
# changing a Pgrp from outside its owning task is V5+ scope.
DEVPROC_KIND_NS:     uint32 = 4
# §13: Linux-ABI /proc/<pid>/{cmdline,comm,maps}. cmdline renders the
# process command line (we have no per-task argv storage, so it is
# the task's comm name as a single NUL-terminated argv entry — a
# well-formed one-element cmdline). comm is the comm name + '\n'.
# maps walks the task's VMA list in Linux /proc/<pid>/maps shape.
DEVPROC_KIND_CMDLINE: uint32 = 5
DEVPROC_KIND_COMM:    uint32 = 6
DEVPROC_KIND_MAPS:    uint32 = 7
# Phase G: write-only entry for Plan 9 note-group WIDE delivery. A write
# to /proc/<pid>/notepg posts the note string to EVERY live process in
# the target pid's note group (Plan 9's process-group signalling). Reads
# return -1 + errstr — same write-only contract as `note`.
DEVPROC_KIND_NOTEPG:  uint32 = 8


def devproc_is_proc_fd(file_idx: uint32) -> int32:
    # Single-call probe used by fs/vfs.ad to fork into the devproc
    # dispatch path. Kept here so the encoding constant stays
    # private to this file.
    if (file_idx & FD_PROC_MARK_MASK) == FD_PROC_MARK_BASE:
        return 1
    return 0


def _is_digit(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return 1
    return 0


def _cstr_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    # True if the two NUL-terminated strings match. Used for the
    # leaf-name compare (`status` / `cwd` / `stat`) where we already
    # know the substring start in `a`. We can't use a generic strcmp
    # because the surrounding code is path-walking and the leaf
    # isn't NUL-terminated in-situ — the caller passes a copy.
    i: uint64 = 0
    while True:
        ca: uint8 = a[i]
        cb: uint8 = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1


def _u64_to_dec(value: uint64, out: Ptr[uint8]) -> uint64:
    # Same reverse-fill helper devtime.ad / devpid.ad use. Lifted
    # locally so devproc.ad doesn't depend on its sibling files —
    # the procfs renderer has its own copy too, and keeping each
    # cdev self-contained matches how 9front's port files are
    # structured (no shared "devutil.c" — every cdev inlines its
    # bit-twiddling).
    if value == 0:
        out[0] = 48                              # '0'
        return 1
    digits: Array[24, uint8]
    n: uint64 = 0
    while value != 0:
        digits[n] = cast[uint8](value % 10) + 48
        value = value / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return written


def _u64_to_hex(value: uint64, out: Ptr[uint8]) -> uint64:
    # 16-char fixed-width hex for the pml4 field in the status line.
    # The pml4 is a kernel physical address; rendering it with leading
    # zeros keeps the column alignment predictable for grep / awk.
    HEX: Ptr[uint8] = "0123456789abcdef"
    out[0] = 48                                  # '0'
    out[1] = 120                                 # 'x'
    i: uint64 = 0
    while i < 16:
        nibble: uint64 = (value >> ((15 - i) * 4)) & 0xF
        out[2 + i] = HEX[nibble]
        i = i + 1
    return 18


def _parse_proc_path(path: Ptr[char], out_pid: Ptr[uint64],
                     out_kind: Ptr[uint32]) -> int32:
    # Walk a /proc/<pid>/<file> path. Returns 0 on success and writes
    # the parsed pid + file_kind through the out-pointers. Non-zero
    # means "not a /proc/<pid>/<leaf> path" — the caller falls back to
    # the existing procfs renderer.
    #
    # We don't trust the caller to have already prefix-checked
    # "/proc/" — verifying it here makes this function safe to drop
    # into _any_ vfs_open call site if devproc grows direct callers.
    if path[0] != 47:                            # '/'
        return -1
    if path[1] != 112 or path[2] != 114 \
            or path[3] != 111 or path[4] != 99 \
            or path[5] != 47:                    # "proc/"
        return -1
    # Parse the pid component. `self` is an alias for the CALLING
    # task's pid — `/proc/self/ns` lets a program read its own
    # namespace without first having to discover its pid (HAMSH §14).
    i: uint64 = 6
    pid: uint64 = 0
    if path[6] == 115 and path[7] == 101 \
            and path[8] == 108 and path[9] == 102 \
            and path[10] == 47:                  # "self/"
        pid = current_task_pid()
        i = 11
    else:
        if _is_digit(cast[uint8](path[i] & 0xFF)) == 0:
            return -1
        while _is_digit(cast[uint8](path[i] & 0xFF)) != 0:
            pid = pid * 10 + cast[uint64](path[i] - 48)
            i = i + 1
        if path[i] != 47:                        # '/'
            return -1
        i = i + 1
    # The leaf is the rest of the path. Copy into a small scratch so
    # we can NUL-compare against the literal strings.
    leaf: Array[16, uint8]
    j: uint64 = 0
    while j + 1 < 16 and path[i] != 0:
        leaf[j] = cast[uint8](path[i] & 0xFF)
        i = i + 1
        j = j + 1
    leaf[j] = 0
    if path[i] != 0:
        return -1                                # leaf too long for any
                                                 # name we serve
    if _cstr_eq(&leaf[0], "status") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_STATUS
        return 0
    if _cstr_eq(&leaf[0], "cwd") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_CWD
        return 0
    if _cstr_eq(&leaf[0], "stat") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_STAT
        return 0
    if _cstr_eq(&leaf[0], "note") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_NOTE
        return 0
    if _cstr_eq(&leaf[0], "notepg") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_NOTEPG
        return 0
    if _cstr_eq(&leaf[0], "ns") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_NS
        return 0
    if _cstr_eq(&leaf[0], "cmdline") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_CMDLINE
        return 0
    if _cstr_eq(&leaf[0], "comm") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_COMM
        return 0
    if _cstr_eq(&leaf[0], "maps") != 0:
        out_pid[0] = pid
        out_kind[0] = DEVPROC_KIND_MAPS
        return 0
    return -1


def devproc_path_match(path: Ptr[char]) -> int32:
    # Cheap discriminator used by fs/vfs.ad to decide whether to
    # route open() to devproc or to the static procfs renderer.
    # Returns 1 iff path looks like /proc/<digits>/<known-leaf>.
    pid_scratch:  uint64 = 0
    kind_scratch: uint32 = 0
    if _parse_proc_path(path, &pid_scratch, &kind_scratch) == 0:
        return 1
    return 0


def devproc_open(path: Ptr[char]) -> int64:
    # Parse the path, look up the task slot, encode the marker.
    # Returns the encoded uint32 widened to int64 so the high marker
    # bit doesn't accidentally read as negative when fs/vfs.ad does
    # its `< 0` failure test. The caller truncates to uint32 before
    # storing into TaskStruct.fd_idx. Errors return -1 with
    # set_current_errstr(...) so SYS_ERRSTR (265) callers get a
    # human-readable reason — Plan 9 convention. fs/vfs.ad maps -1
    # to the user-visible -ENOENT it would return for any other
    # missing path.
    #
    # Why int64, not int32: the encoded marker is `0xFE000000 | ...`
    # which, viewed as int32, is a large negative number — every
    # successful open would then look like a failure to the int32
    # `< 0` check. Widening to int64 keeps successful encodings
    # comfortably positive (uint32 max << 2^31), with -1 the only
    # negative value the caller ever sees.
    pid64: uint64 = 0
    kind:  uint32 = 0
    if _parse_proc_path(path, &pid64, &kind) != 0:
        set_current_errstr("/proc: malformed pid path")
        return -1
    slot: int32 = task_lookup_by_pid(pid64)
    if slot < 0:
        set_current_errstr("no such pid")
        return -1
    # Encode pid+kind into the marker. Cap pid at 0xFFFF so the
    # 16-bit field never overflows into the tag byte — at NTASKS=16
    # with sequentially-allocated pids this is comfortable headroom.
    pid_field: uint32 = cast[uint32](pid64 & 0xFFFF)
    enc: uint32 = FD_PROC_MARK_BASE | (pid_field << 8) | (kind & 0xFF)
    return cast[int64](enc)


def _emit_status(buf: Ptr[uint8], count: uint64, slot: int32) -> int64:
    # One line: "<pid> <name8> <state> <pml4_hex>\n". Format chosen
    # so awk/cut-style parsers can split on space and find each
    # field at a fixed column position. Linux's /proc/<pid>/status
    # is multi-line key/value; the Plan 9 file is one line of
    # whitespace-separated tokens (see /sys/src/9/port/devproc.c's
    # statustext()).
    #
    # Pointer-arithmetic note: we render into a single Array[128]
    # scratch and pass `(scratch_base + pos)` pointers into the
    # _u64_to_dec / _u64_to_hex helpers, computed via cast[uint64]
    # rather than `&scratch[pos]`. The latter form has tripped the
    # nested-Array-frame bug in the past (see feedback memory
    # "nested fixed-size Array locals across call frames"); the
    # explicit base-plus-offset is the stable workaround.
    scratch: Array[128, uint8]
    base: uint64 = cast[uint64](&scratch[0])
    pos: uint64 = 0
    pid_n: uint64 = _u64_to_dec(task_pid_at(slot),
                                cast[Ptr[uint8]](base + pos))
    pos = pos + pid_n
    scratch[pos] = 32                            # ' '
    pos = pos + 1
    # name0 is 8 ASCII bytes packed into a uint64. We unpack
    # least-significant byte first — that's the order the
    # task-creator wrote with `b0 | (b1<<8) | ...`. NUL bytes inside
    # the 8 mean "name shorter than 8 chars" — stop emitting.
    name_bits: uint64 = task_name0_at(slot)
    k: uint64 = 0
    name_done: int32 = 0
    while k < 8 and name_done == 0:
        c: uint8 = cast[uint8]((name_bits >> (k * 8)) & 0xFF)
        if c == 0:
            name_done = 1
        else:
            scratch[pos] = c
            pos = pos + 1
            k = k + 1
    scratch[pos] = 32                            # ' '
    pos = pos + 1
    # State letter. Linux uses R/S/Z; we map the same way fs/procfs.ad
    # does — RUNNING -> 'R', READY -> 'S' (ready ~= sleeping on a
    # uniprocessor), EXITED -> 'Z'. Anything else (which shouldn't
    # happen on a live pid we just looked up) becomes '?'.
    st: uint64 = task_state(slot)
    if st == STATE_RUNNING:
        scratch[pos] = 82                        # 'R'
    elif st == STATE_READY:
        scratch[pos] = 83                        # 'S'
    elif st == STATE_EXITED:
        scratch[pos] = 90                        # 'Z'
    else:
        scratch[pos] = 63                        # '?'
    pos = pos + 1
    scratch[pos] = 32                            # ' '
    pos = pos + 1
    pml4: uint64 = task_pml4(slot)
    pml4_n: uint64 = _u64_to_hex(pml4, cast[Ptr[uint8]](base + pos))
    pos = pos + pml4_n
    scratch[pos] = 10                            # '\n'
    pos = pos + 1
    take: uint64 = count
    if take > pos:
        take = pos
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


def _proc_state_letter(slot: int32) -> uint8:
    # Linux /proc state letter: R running, S sleeping, Z zombie.
    # Hamnix STATE_READY maps to 'S' (ready ~= sleeping on a UP box),
    # same convention _emit_status and fs/procfs.ad already use.
    st: uint64 = task_state(slot)
    if st == STATE_RUNNING:
        return 82                                # 'R'
    if st == STATE_READY:
        return 83                                # 'S'
    if st == STATE_EXITED:
        return 90                                # 'Z'
    return 63                                    # '?'


def _emit_comm_into(scratch: Ptr[uint8], pos: uint64,
                    slot: int32) -> uint64:
    # Copy the task's comm name (NUL-terminated, max 16 incl. NUL)
    # into scratch[pos..]. Returns the new pos. Falls back to the
    # 8-char packed name0 tag when comm is empty — kernel-spawned
    # tasks set name0 but a Linux ELF that never called prctl()
    # leaves comm zeroed; either way we want a non-empty token.
    comm: Ptr[uint8] = get_task_comm_ptr(cast[uint64](slot))
    if comm[0] != 0:
        i: uint64 = 0
        while i < 16 and comm[i] != 0:
            scratch[pos + i] = comm[i]
            i = i + 1
        return pos + i
    # name0 fallback — 8 ASCII bytes, least-significant-byte first.
    bits: uint64 = task_name0_at(slot)
    k: uint64 = 0
    while k < 8:
        c: uint8 = cast[uint8]((bits >> (k * 8)) & 0xFF)
        if c == 0:
            return pos + k
        scratch[pos + k] = c
        k = k + 1
    return pos + k


def _emit_linux_stat(buf: Ptr[uint8], count: uint64,
                     slot: int32) -> int64:
    # §13: real Linux-shape /proc/<pid>/stat. One whitespace-separated
    # line. Linux ships 52 fields; we render the first 24 — the prefix
    # `ps`, glibc and Python's psutil/multiprocessing actually parse:
    #
    #   pid (comm) state ppid pgrp session tty_nr tpgid flags
    #   minflt cminflt majflt cmajflt utime stime cutime cstime
    #   priority nice num_threads itrealvalue starttime vsize rss
    #
    # Fields Hamnix has no accounting for (the fault counters, the
    # CPU-time pair, vsize/rss) render 0 — a well-formed but zero
    # value, which every parser tolerates. The fields we DO have
    # (pid, comm, state, ppid) are real. The (comm) is parenthesised
    # exactly as Linux does so a parser that does the classic
    # "rindex(')')" trick to skip a comm containing spaces still works.
    scratch: Array[256, uint8]
    base: uint64 = cast[uint64](&scratch[0])
    pos: uint64 = 0
    # field 1: pid
    pos = pos + _u64_to_dec(task_pid_at(slot),
                            cast[Ptr[uint8]](base + pos))
    scratch[pos] = 32
    pos = pos + 1
    # field 2: (comm)
    scratch[pos] = 40                            # '('
    pos = pos + 1
    pos = _emit_comm_into(&scratch[0], pos, slot)
    scratch[pos] = 41                            # ')'
    pos = pos + 1
    scratch[pos] = 32
    pos = pos + 1
    # field 3: state letter
    scratch[pos] = _proc_state_letter(slot)
    pos = pos + 1
    scratch[pos] = 32
    pos = pos + 1
    # field 4: ppid
    pos = pos + _u64_to_dec(task_parent_pid(slot),
                            cast[Ptr[uint8]](base + pos))
    # fields 5..24: pgrp session tty_nr tpgid flags minflt cminflt
    # majflt cmajflt utime stime cutime cstime priority nice
    # num_threads itrealvalue starttime vsize rss — 20 fields, all 0
    # except num_threads (field 20) which is at least 1. We emit
    # " 0" for each, then fix num_threads to " 1".
    f: uint64 = 5
    while f <= 24:
        scratch[pos] = 32
        pos = pos + 1
        if f == 20:
            scratch[pos] = 49                    # '1' — num_threads
        else:
            scratch[pos] = 48                    # '0'
        pos = pos + 1
        f = f + 1
    scratch[pos] = 10                            # '\n'
    pos = pos + 1
    take: uint64 = count
    if take > pos:
        take = pos
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


def _emit_cmdline(buf: Ptr[uint8], count: uint64,
                  slot: int32) -> int64:
    # §13: /proc/<pid>/cmdline. Linux serves the process's argv as a
    # NUL-separated, NUL-terminated blob. Hamnix has no per-task argv
    # storage on TaskStruct, so we render the comm name as a single
    # argv[0] entry followed by its NUL — a well-formed one-element
    # cmdline. A reader that splits on NUL gets exactly one token,
    # which is what /proc/self/cmdline of an exec'd-but-no-argv
    # process would look like anyway.
    scratch: Array[32, uint8]
    n: uint64 = _emit_comm_into(&scratch[0], 0, slot)
    scratch[n] = 0                               # trailing NUL
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


def _emit_comm(buf: Ptr[uint8], count: uint64,
               slot: int32) -> int64:
    # §13: /proc/<pid>/comm — the comm name plus a trailing newline,
    # exactly as Linux serves it.
    scratch: Array[24, uint8]
    n: uint64 = _emit_comm_into(&scratch[0], 0, slot)
    scratch[n] = 10                              # '\n'
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


def _emit_cwd(buf: Ptr[uint8], count: uint64, slot: int32) -> int64:
    # The CWD lives inline in TaskStruct.cwd as a 128-byte
    # NUL-terminated string; get_cwd_buf returns a pointer to slot 0
    # of that array. Copy up to count-1 bytes, then append '\n'.
    src: Ptr[uint8] = get_cwd_buf(cast[uint64](slot))
    n: uint64 = 0
    # Find length so we can decide whether the '\n' fits.
    while src[n] != 0 and n < 127:
        n = n + 1
    # Available room in caller's buffer for the path plus newline.
    if count == 0:
        return 0
    out_n: uint64 = n
    if out_n > count:
        out_n = count
    i: uint64 = 0
    while i < out_n:
        buf[i] = src[i]
        i = i + 1
    # Append '\n' if there's room — matches the trailing-newline
    # convention of /dev/pid, /dev/time and Plan 9 devproc.
    if out_n < count:
        buf[out_n] = 10                          # '\n'
        out_n = out_n + 1
    return cast[int64](out_n)


def devproc_read(file_idx: uint32, off: uint64, buf: Ptr[uint8],
                 count: uint64) -> int64:
    # Decode pid + kind from the marker. Re-validate the slot at read
    # time — a task that died after the open could leave a stale pid
    # in our hand. STATE_FREE re-uses the slot, so a passing pid would
    # then read someone else's status; refusing here keeps the
    # semantics honest.
    #
    # `off` is the read cursor. Each /proc file renders its whole
    # snapshot in one emit; a second read (off > 0) reports EOF so a
    # `cat /proc/<pid>/<file>` terminates instead of regenerating the
    # snapshot forever. (Pre-off-aware callers always passed off == 0
    # for a single read, so this is non-regressing.)
    if off > 0:
        return 0
    pid_field: uint32 = (file_idx >> 8) & 0xFFFF
    kind:      uint32 = file_idx & 0xFF
    slot: int32 = task_lookup_by_pid(cast[uint64](pid_field))
    if slot < 0:
        set_current_errstr("pid vanished")
        return -1
    if kind == DEVPROC_KIND_STATUS:
        return _emit_status(buf, count, slot)
    if kind == DEVPROC_KIND_CWD:
        return _emit_cwd(buf, count, slot)
    if kind == DEVPROC_KIND_STAT:
        # §13: /proc/<pid>/stat now renders the real Linux-shape
        # single-line stat record (see _emit_linux_stat). The Plan 9
        # binary Dir-record form of `stat` is served by the separate
        # SYS_STAT_P9 syscall path in sysfile.ad — this devproc text
        # file is the Linux-ABI surface and Linux callers (psutil,
        # ps, glibc) want the 52-field ASCII line.
        return _emit_linux_stat(buf, count, slot)
    if kind == DEVPROC_KIND_CMDLINE:
        return _emit_cmdline(buf, count, slot)
    if kind == DEVPROC_KIND_COMM:
        return _emit_comm(buf, count, slot)
    if kind == DEVPROC_KIND_MAPS:
        # §13: render the target task's VMA list in /proc/<pid>/maps
        # shape. slot is the int32 task index; vma_maps_render wants
        # the uint64 form.
        return vma_maps_render(cast[uint64](slot), buf, count)
    if kind == DEVPROC_KIND_NOTE:
        # /proc/<pid>/note is write-only — Plan 9 contract. Reading
        # would suggest "fetch the most recent note"; that's not a
        # 9front-shape API and we don't want to grow it inadvertently.
        set_current_errstr("note: not readable")
        return -1
    if kind == DEVPROC_KIND_NOTEPG:
        # /proc/<pid>/notepg is write-only — same Plan 9 contract as
        # `note`. It is a control surface for posting to a note group.
        set_current_errstr("notepg: not readable")
        return -1
    if kind == DEVPROC_KIND_NS:
        # V3: render the target task's Pgrp mtab as ns(1)-shape text.
        # Stateless — every read regenerates the snapshot. The fixture
        # does a single large read; multi-read offset semantics land
        # in V3.1 alongside /proc/self resolution.
        # V2.75: pgrp_for_task returns the heap pointer (uint64) to
        # the Pgrp struct; pgrp_render_ns walks it directly.
        pg: uint64 = pgrp_for_task(slot)
        return pgrp_render_ns(pg, buf, count)
    set_current_errstr("/proc: unknown file kind")
    return -1


def devproc_write(file_idx: uint32, buf: Ptr[uint8],
                  count: uint64) -> int64:
    # M16.109: /proc/<pid>/note is the only writable file_kind in the
    # devproc family. Everything else returns -1 + errstr — Plan 9
    # devproc.c::procwrite has the same shape (only `note` and `ctl`
    # accept writes, and ctl isn't a Phase C surface yet).
    pid_field: uint32 = (file_idx >> 8) & 0xFFFF
    kind:      uint32 = file_idx & 0xFF
    if kind == DEVPROC_KIND_NS:
        # V3: /proc/<pid>/ns is read-only. Plan 9 lets you write
        # control commands ("addmount", "addbind", ...) to it, but
        # that's V5+ scope — the V3 surface only serves the renderer.
        set_current_errstr("ns: not writable")
        return -1
    if kind != DEVPROC_KIND_NOTE and kind != DEVPROC_KIND_NOTEPG:
        set_current_errstr("write not supported")
        return -1

    # Re-validate the pid at write time — same shape as devproc_read
    # above. A task that died after the open() left a stale pid in our
    # marker; refusing here keeps us from delivering a note to a
    # phantom slot or, worse, to a slot the kernel has handed to a
    # different tenant.
    target: int32 = task_lookup_by_pid(cast[uint64](pid_field))
    if target < 0:
        set_current_errstr("note: pid vanished")
        return -1

    if kind == DEVPROC_KIND_NOTEPG:
        # Plan 9 note-group WIDE delivery: post the note string to EVERY
        # live process whose note_group matches the target pid's group.
        # This is Plan 9's process-group signalling — one write fans the
        # note across the cohort. Reuses the per-task note machinery for
        # each recipient (post_note_to_group walks the table, enqueues
        # the pending note + message onto each live member, and does the
        # full self-delivery for the member that is the caller). We
        # return `count` on success — the write itself was well-formed.
        grp: int32 = task_note_group(target)
        nrec: int64 = post_note_to_group(grp, buf, count)
        printk1("notepg: posted note to note group, %d recipients\n",
                cast[uint64](cast[uint32](cast[int32](nrec))))
        return cast[int64](count)

    target_u: uint64 = cast[uint64](cast[uint32](target))
    handler: uint64 = task_note_handler_rip(target_u)
    if handler == 0:
        # No handler installed. Plan 9's default action for an
        # unhandled note is to terminate the target with the note
        # string as the exit reason. Phase C / M16.109 minimum: log
        # and silently drop. Userland still sees the write as
        # "succeeded" (we return `count`) because the write itself
        # was well-formed — the policy of "what happens to an
        # unhandled note" is a separate concern and Plan 9 doesn't
        # surface "no handler" via write(2) either.
        printk1("note: pid %d has no handler installed (dropped)\n",
                cast[uint64](pid_field))
        return cast[int64](count)

    # Self-delivery — the writer IS the target. This is the path the
    # M16.109 test fixture exercises (a single task writes to its own
    # /proc/<self>/note); the writer is currently inside the SYS_WRITE
    # syscall and its kstack frame holds the saved user-RIP/RSP we
    # need to retarget at kstack_top-24 / kstack_top-8.
    cur: uint64 = current_idx_get()
    if target_u == cur:
        return deliver_note_to_current(buf, count)

    # Cross-task delivery — the writer is not the target. Phase C
    # minimum: log and silently drop. The full cross-task path needs
    # to walk the target's kstack frame (its saved user RIP/RSP) and
    # patch THAT — which we can't safely do while the target is in an
    # arbitrary state (could be in user mode, mid-syscall, mid-yield).
    # Wires up in a later milestone alongside the IPI / per-task
    # pending-flag check in signal_check_and_handle.
    printk1("note: cross-task delivery to pid %d not yet implemented\n",
            cast[uint64](pid_field))
    return cast[int64](count)


def devproc_close(file_idx: uint32) -> int32:
    # Stateless: no per-fd slot, no kmalloc, no refcount. fs/vfs.ad's
    # close_fd_in_task hits a default fall-through that rewrites the
    # slot to FD_CLOSED_MARK + zeros the auxiliary fields — that's
    # all the cleanup we need. The marker carries no aliased
    # resource a sibling fd could be sharing; close is an
    # unconditional no-op success.
    return 0

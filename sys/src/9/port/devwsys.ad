# HZ=100 jiffy counter (1 jiffy = 10 ms). Used to time the titlebar
# double-click window for the MATE-style maximize/restore toggle.
from arch.x86.kernel.time import get_jiffies


# --- per-wid table ---------------------------------------------------
#
# MAX_WINDOWS slots, wids 1..MAX_WINDOWS. Slot 0 is unused — the design
# spec says wids are 1-indexed and /dev/wsys/0 returns ENOENT.
#
# Each slot carries:
#   in_use  : 1 if this wid is live, else 0
#   pid     : the root shell pid bound to this wid (0 = unbound)
#
# The rings (text / output / cmd) live in separate flat Arrays keyed
# by wid so we don't have to nest Arrays inside a struct (Adder's
# nested-frame Array quirk).

MAX_WINDOWS: uint64 = 32            # wids 0..31; wid 0 is reserved/unused

wsys_slot_in_use: Array[32, int32]
wsys_slot_pid:    Array[32, uint64]


# --- per-window damage / dirty tracking (hot-path fast skip) ---------
#
# THE PER-FRAME PROBLEM
# ---------------------
# The compositor (user/hamUId.ad) walks every live window each frame and
# re-reads its full draw markup + the z-ordered draw listing back out of
# this server — even when nothing about that window changed since the
# last frame. That is a lot of redundant snapshot/copy work for a static
# desktop (the common case: most windows idle, one cursor blinking).
#
# THE FIX (additive, backward-compatible)
# ---------------------------------------
# Every MUTATING write to a window's draw/layer state bumps a per-window
# 64-bit serial (wsys_win_serial[wid]) and unions the touched layer's
# geometry into a per-window dirty rectangle. The compositor reads a tiny
# new file to learn "what changed since serial N" and skips re-reading
# the windows whose serial it already has:
#
#   /dev/wsys/<N>/serial   ->  "<serial>\n"          (this window only)
#   /dev/wsys/damage       ->  one line per live wid:
#                              "<wid> <serial> <dx0> <dy0> <dx1> <dy1>\n"
#                              where dx0..dy1 is the accumulated dirty
#                              rect since the window was last marked
#                              clean (an empty rect renders as 0 0 0 0).
#
# A serial of 0 never appears for a live window: the counter starts at 1
# on first mutation and only increases, so the compositor can store "last
# seen serial = 0" for a brand-new window and is guaranteed to see it as
# dirty on the first frame. Reading these files has NO side effects — the
# compositor explicitly acks consumption by writing the serial it has
# processed back to /dev/wsys/<N>/serial, which folds the dirty rect down
# (see devwsys_serial_write). That keeps the read path pure (snapshot-
# once) while still letting the dirty rect reset precisely.

wsys_win_serial: Array[32, uint64]    # 0 = never mutated; monotonic up

# Per-window accumulated dirty rectangle, in window-local pixels. Stored
# as an inclusive-exclusive box [x0,y0)..[x1,y1). x1<=x0 means "empty".
wsys_dirty_x0: Array[32, int64]
wsys_dirty_y0: Array[32, int64]
wsys_dirty_x1: Array[32, int64]
wsys_dirty_y1: Array[32, int64]


def _wsys_dirty_clear(wid: int32):
    # Reset a window's dirty rect to empty. Does NOT touch the serial —
    # the serial is monotonic and only the rect is "consumed".
    u: uint64 = cast[uint64](wid)
    wsys_dirty_x0[u] = 0
    wsys_dirty_y0[u] = 0
    wsys_dirty_x1[u] = 0
    wsys_dirty_y1[u] = 0


def _wsys_dirty_add(wid: int32, x0: int64, y0: int64,
                    x1: int64, y1: int64):
    # Union [x0,y0)..[x1,y1) into the window's accumulated dirty rect.
    # An x1<=x0 or y1<=y0 box is empty and contributes nothing.
    if x1 <= x0 or y1 <= y0:
        return
    u: uint64 = cast[uint64](wid)
    if wsys_dirty_x1[u] <= wsys_dirty_x0[u] \
            or wsys_dirty_y1[u] <= wsys_dirty_y0[u]:
        # Current rect empty — adopt the incoming box verbatim.
        wsys_dirty_x0[u] = x0
        wsys_dirty_y0[u] = y0
        wsys_dirty_x1[u] = x1
        wsys_dirty_y1[u] = y1
        return
    if x0 < wsys_dirty_x0[u]:
        wsys_dirty_x0[u] = x0
    if y0 < wsys_dirty_y0[u]:
        wsys_dirty_y0[u] = y0
    if x1 > wsys_dirty_x1[u]:
        wsys_dirty_x1[u] = x1
    if y1 > wsys_dirty_y1[u]:
        wsys_dirty_y1[u] = y1


def _wsys_mark_dirty(wid: int32, x0: int64, y0: int64,
                     x1: int64, y1: int64):
    # The single choke point every mutating draw write funnels through:
    # bump the monotonic per-window serial and accumulate the dirty box.
    # `wid` is assumed already validated live by the caller. Also
    # invalidates the cached draw listing for this window (the listing
    # text is regenerated lazily on the next read at the new serial).
    if wid <= 0:
        return
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return
    wsys_win_serial[u] = wsys_win_serial[u] + 1
    _wsys_dirty_add(wid, x0, y0, x1, y1)
    _wsys_draw_listing_cache_gen[u] = 0      # force listing-cache miss


def _wsys_init_if_needed():
    # Lazy init: stamp wid 1 (foreground) as in_use the first time we
    # touch the table. The pid is filled in on the first devcons_write
    # whose pid_for_current returns "unmapped" — i.e. the first user
    # write from hamsh after init. Idempotent.
    if wsys_slot_in_use[1] == 0:
        wsys_slot_in_use[1] = 1
        wsys_slot_pid[1] = 0


def _wsys_wid_for_pid(pid: uint64) -> int32:
    # Linear scan over MAX_WINDOWS — tiny, so no hash needed. Returns
    # the wid (1..MAX_WINDOWS-1) bound to `pid`, or -1 if no slot
    # claims this pid.
    w: uint64 = 1
    while w < MAX_WINDOWS:
        if wsys_slot_in_use[w] != 0 and wsys_slot_pid[w] == pid:
            return cast[int32](w)
        w = w + 1
    return -1


def _wsys_wid_for_pid_or_ancestor(pid: uint64) -> int32:
    # Empty-windows DE bug fix: hamUId allocates a wid against the SHELL
    # pid it spawns (`spawn(/bin/hamsh /etc/rc.de-user /bin/hampanel)`),
    # but the rc shell then `spawn`s the real client as a NEW child pid.
    # That child reads /dev/wsys/self and finds no binding (the wid is
    # keyed to its parent hamsh), so it can't learn its own wid and the
    # whole v2 negotiation never happens. Walk up parent_pid until we
    # find a wid binding or hit pid 1 (the bound shell IS an ancestor of
    # the real client). Returns the discovered wid, or -1.
    cur: uint64 = pid
    depth: int32 = 0
    while cur != 0 and depth < 8:
        w: int32 = _wsys_wid_for_pid(cur)
        if w > 0:
            return w
        slot: int32 = task_lookup_by_pid(cur)
        if slot < 0:
            return -1
        nxt: uint64 = task_parent_pid(slot)
        if nxt == cur:
            return -1
        cur = nxt
        depth = depth + 1
    return -1


def _wsys_wid_for_current() -> int32:
    # The current task's wid — the routing key for devcons_write tee
    # and devcons_read pop. If the current pid isn't bound to any wid,
    # return 1 (foreground). This is the "every byte from an
    # unmapped pid lands on wid 1" default that lets hamsh's PID 1
    # boot output flow into wid 1's ring without needing an explicit
    # init-time bind. The first devcons_write also OPPORTUNISTICALLY
    # stamps wid 1's pid so subsequent lookups are O(1) per the explicit
    # path.
    _wsys_init_if_needed()
    pid: uint64 = current_task_pid()
    # Empty-windows DE bug fix: walk up parents to find a wid binding so
    # a hamsh-spawned client process inherits its wid context.
    w: int32 = _wsys_wid_for_pid_or_ancestor(pid)
    if w > 0:
        return w
    # Unmapped pid → wid 1. Also record the foreground pid if wid 1's
    # slot has none yet (first writer wins, which is hamsh's first
    # banner print).
    if wsys_slot_pid[1] == 0:
        wsys_slot_pid[1] = pid
    return 1


# #442 (a): public wrapper for the per-process namespace rewrite in
# fs/vfs.ad's resolve_path. The module-private `_wsys_wid_for_current`
# is the actual lookup (we don't want to expose a leading-underscore
# name across modules — see "leading-underscore = module-private" at
# the head of this file). Callers outside devwsys reach the caller's
# bound wid via this name.
def wsys_wid_for_current() -> int32:
    return _wsys_wid_for_current()


def _wsys_pid_alive(pid: uint64) -> int32:
    # 1 iff `pid` still names a live (non-reaped) task. A reaped pid is
    # absent from the task table (task_lookup_by_pid scans state!=STATE_FREE),
    # so a returned -1 means the process is fully gone. pid 0 = "no owner"
    # (e.g. a system surface or a not-yet-stamped slot) — treated as alive so
    # the reaper never collects an unowned/system slot.
    if pid == 0:
        return 1
    if task_lookup_by_pid(pid) >= 0:
        return 1
    return 0


def wsys_reap_dead_wids() -> int32:
    # TASKBAR-STALE FIX: a window slot is freed by the close box
    # (_wsys_close_window) or an explicit `free <wid>`, but a client that
    # simply EXITS (a terminal whose shell `exit`s, an installer that
    # finishes, an app that is SIGKILLed) leaves its slot marked in_use with
    # a now-dead owner pid. Nothing reclaimed it, so after enough open/exit
    # churn all of 2..MAX_WINDOWS-1 leak: wsys_alloc_wid returns -1, fresh
    # apps get NO window, and the taskbar (which lists only in_use decorated
    # slots) goes empty/stale even though live windows are on screen.
    #
    # Reap every in_use slot (2..MAX_WINDOWS-1) whose owner pid no longer
    # names a live task. wid 1 (foreground/root) is never owner-reaped. The
    # close path's bookkeeping (focus/drag/resize) is mirrored here so a
    # reaped slot does not strand stale router state. Returns the count
    # reaped. Cheap: a linear scan over <=30 slots plus a tiny task-table
    # lookup each.
    n: int32 = 0
    w: uint64 = 2
    while w < MAX_WINDOWS:
        if wsys_slot_in_use[w] != 0:
            if _wsys_pid_alive(wsys_slot_pid[w]) == 0:
                wid: int32 = cast[int32](w)
                if wsys_focus_wid == wid:
                    wsys_focus_wid = 0
                if wsys_drag_wid == wid:
                    wsys_drag_wid = 0
                    wsys_drag_snap_intent = WSYS_SNAP_NONE
                if wsys_resize_wid == wid:
                    wsys_resize_wid = 0
                    wsys_resize_edge = 0
                wsys_free_wid(wid)
                n = n + 1
        w = w + 1
    return n


def wsys_alloc_wid(pid: uint64) -> int32:
    # Public: claim the lowest free slot in 2..MAX_WINDOWS-1 and bind
    # it to `pid`. Returns the wid on success, -1 if the table is full.
    # wid 1 is reserved for foreground and is never handed out by this
    # allocator.
    #
    # MULTI-WINDOW (N-per-pid): a process may own MANY wids. The old
    # "reject a second alloc for the same pid" gate is gone — it blocked
    # menus/dialogs/multi-widget panels (a process could never open a
    # popup or a second top-level). Per-window identity is the SLOT (its
    # wsys_slot_pid stamp), not the pid; ownership is decided by
    # _wsys_caller_owns_wid, which matches the TARGET slot's owner pid
    # against the caller's pid-or-ancestor chain. Bounded by MAX_WINDOWS
    # (32 slots), so a runaway client can claim at most the free slots.
    _wsys_init_if_needed()
    w: uint64 = 2
    while w < MAX_WINDOWS:
        if wsys_slot_in_use[w] == 0:
            wsys_slot_in_use[w] = 1
            wsys_slot_pid[w] = pid
            # A recycled slot must NOT inherit the previous tenant's
            # decorate/z (else a fresh app that lands on a slot last held by
            # a popup (decorate 0) or chrome (z>=100) is silently dropped
            # from /dev/wsys/windows — the taskbar would miss it until the
            # client's own `decorate`/`z` writes land). Start as an
            # undecorated top-level (z 0); the client sets its real chrome.
            wsys_win_decorate[w] = 0
            wsys_win_z[w] = 0
            # Drop any stale framebuffer blocks left by a previous tenant
            # that was reclaimed without a clean free (defensive); they are
            # re-allocated lazily on this window's first draw/blit.
            _wsys_layer_fb_release(cast[int32](w))
            _wsys_backbuffer_release(cast[int32](w))
            # Zero-fill that slot's rings so a recycled wid doesn't
            # leak the previous tenant's bytes.
            _wsys_reset_rings(cast[int32](w))
            # Clear any stale taskbar title from a previous tenant.
            wsys_win_title_len[w] = 0
            wsys_win_title[w * WSYS_WIN_TITLE_CAP] = 0
            # MULTI-WINDOW: a recycled slot must not inherit a previous
            # tenant's popup anchoring; start top-level.
            wsys_win_parent[w] = 0
            wsys_win_anchor_dx[w] = 0
            wsys_win_anchor_dy[w] = 0
            # Fresh slot: not yet mapped (first commit will raise+focus it).
            wsys_win_mapped[w] = 0
            # Fresh slot opens on the active desktop (only consulted once the
            # client sets `decorate 1`; chrome stays sticky regardless).
            wsys_win_ws[w] = wsys_cur_ws
            return cast[int32](w)
        w = w + 1
    # Table full: every slot 2..MAX_WINDOWS-1 is marked in_use. Some may be
    # LEAKED by clients that exited without closing their window. Reap the
    # dead-owner slots and retry once before giving up, so open/exit churn
    # never permanently starves the allocator (the user-reported "fresh
    # apps open but the taskbar is empty" failure).
    if wsys_reap_dead_wids() > 0:
        w = 2
        while w < MAX_WINDOWS:
            if wsys_slot_in_use[w] == 0:
                wsys_slot_in_use[w] = 1
                wsys_slot_pid[w] = pid
                _wsys_layer_fb_release(cast[int32](w))
                _wsys_backbuffer_release(cast[int32](w))
                _wsys_reset_rings(cast[int32](w))
                wsys_win_title_len[w] = 0
                wsys_win_title[w * WSYS_WIN_TITLE_CAP] = 0
                wsys_win_parent[w] = 0
                wsys_win_anchor_dx[w] = 0
                wsys_win_anchor_dy[w] = 0
                wsys_win_decorate[w] = 0
                wsys_win_z[w] = 0
                wsys_win_mapped[w] = 0
                wsys_win_ws[w] = wsys_cur_ws
                return cast[int32](w)
            w = w + 1
    return -1


def wsys_free_wid(wid: int32) -> int32:
    # Public: release a wid slot. Closing wid 1 is rejected — losing
    # the foreground would render the box unreachable. Returns 0 on
    # success, -1 on bad wid / unfree-able. The caller (the userland
    # hamUI tool) is responsible for sending SIGTERM to the bound pid
    # FIRST; this just clears the table entry.
    if wid <= 1:
        return -1
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return -1
    if wsys_slot_in_use[u] == 0:
        return -1
    # FLICKER FIX: with the once-only backdrop, a closed window must have
    # its on-screen footprint recomposed from the scene sources (backdrop
    # + windows that were below it), else its pixels linger. Capture the
    # extent BEFORE clearing the slot, recompose AFTER.
    cvx: int64 = wsys_win_x[u]
    cvy: int64 = wsys_win_y[u]
    cvw: int64 = _wsys_win_def_w(u)
    cvh: int64 = _wsys_win_def_h(u)
    wsys_slot_in_use[u] = 0
    wsys_slot_pid[u] = 0
    # MULTI-WINDOW: clear popup/child anchoring for the freed slot, and
    # detach any children that pointed at it (so a stale parent ref does not
    # re-anchor a recycled wid). Children become top-level on their next
    # present; the WM/app is expected to close them with their parent.
    wsys_win_parent[u] = 0
    wsys_win_anchor_dx[u] = 0
    wsys_win_anchor_dy[u] = 0
    # Clear pinned-background flag so a recycled wid does not inherit it.
    wsys_win_pinned[u] = 0
    # Clear MATE-WM managed state so a recycled wid starts as a NORMAL float.
    wsys_win_wm_state[u] = WSYS_WM_NORMAL
    cw: uint64 = 1
    while cw < MAX_WINDOWS:
        if wsys_win_parent[cw] == wid:
            wsys_win_parent[cw] = 0
        cw = cw + 1
    _wsys_reset_rings(wid)
    if wsys_root_active != 0 and fb_get_initialized() != 0:
        fl_fw: uint64 = local_irq_save()
        spinlock_lock(&wsys_present_lock)
        _wsys_recompose_rect(cvx, cvy - WSYS_TITLEBAR_H,
                             cvw, cvh + WSYS_TITLEBAR_H)
        _wsys_flush_rect(cvx, cvy - WSYS_TITLEBAR_H,
                         cvw, cvh + WSYS_TITLEBAR_H)
        _wsys_present_cursor_locked()
        spinlock_unlock(&wsys_present_lock)
        local_irq_restore(fl_fw)
    # Release this wid's lazily-allocated 4 MiB framebuffer blocks back
    # to the buddy allocator so a closed window costs ~0 again.
    _wsys_layer_fb_release(wid)
    _wsys_backbuffer_release(wid)
    _wsys_img_release_wid(wid)                          # #128 named images
    return 0


def wsys_wid_in_use(wid: int32) -> int32:
    # 1 iff `wid` names a live slot. Used by namec to gate
    # /dev/wsys/<N>/* opens (ENOENT for unused or out-of-range wids).
    if wid <= 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return 0
    _wsys_init_if_needed()
    return wsys_slot_in_use[u]


def wsys_pid_for_wid(wid: int32) -> uint64:
    # The pid bound to `wid`, 0 if unbound. Used by /dev/wsys/<N>/pid
    # render so the file reports the WINDOW's shell pid, not the
    # reader's pid (the Phase 1 semantics were "reader's pid" because
    # the reader IS the window's hamsh; with multi-window we need an
    # explicit per-wid pid).
    if wid <= 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return 0
    return wsys_slot_pid[u]


def _wsys_caller_owns_wid(wid: int32) -> int32:
    # DE correction Phase 1 (de_correction_plan.md): a window's OWNER may
    # paint into its OWN per-window draw surfaces (scene/ctl/event)
    # regardless of hostowner/uid/namespace.
    #
    # "Owner" = the process that allocated this wid OR a descendant of it.
    # The slot's pid is stamped at alloc time (wsys_alloc_wid). The real
    # client is that bound pid OR a child of it (the rc shell spawns the
    # app as a new child).
    #
    # MULTI-WINDOW (N-per-pid): a process owns EVERY wid whose owner pid is
    # itself or one of its ancestors. The old test resolved the caller to a
    # SINGLE wid (_wsys_wid_for_pid_or_ancestor) and compared — that matched
    # only the lowest wid in the chain, so a process could paint its first
    # window but not a second popup/dialog it allocated. We now walk the
    # caller's pid-or-ancestor chain and accept `wid` iff the TARGET slot's
    # owner pid equals any pid on that chain. This lets one process drive
    # all the windows it (or its parent shell) created, and no others.
    #
    # This keeps the Plan 9 server-boundary model: a process controls its
    # OWN windows' surfaces, not other clients' windows nor the system ctl.
    # The system-wide /dev/wsys/ctl stays hostowner-only (unchanged).
    if wid <= 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return 0
    if wsys_slot_in_use[u] == 0:
        return 0
    owner_pid: uint64 = wsys_slot_pid[u]
    if owner_pid == 0:
        # An unstamped slot (e.g. wid 1's lazy foreground bind) is owned by
        # the foreground writer; fall back to the legacy single-wid resolve.
        own: int32 = _wsys_wid_for_pid_or_ancestor(current_task_pid())
        if own == wid:
            return 1
        return 0
    # Walk the caller's pid-or-ancestor chain; accept if any pid on the
    # chain is the wid's owner pid (depth/cycle-bounded, like the ancestor
    # resolver).
    cur: uint64 = current_task_pid()
    depth: int32 = 0
    while cur != 0 and depth < 8:
        if cur == owner_pid:
            return 1
        slot: int32 = task_lookup_by_pid(cur)
        if slot < 0:
            return 0
        nxt: uint64 = task_parent_pid(slot)
        if nxt == cur:
            return 0
        cur = nxt
        depth = depth + 1
    return 0


# --- text rings (per wid) -------------------------------------------
#
# One 64 KiB ring per wid. Flat Array indexed as
# wsys_text_buf[wid * WSYS_TEXT_SIZE + offset]. Per-wid head/count
# cursors live in their own short Arrays.

WSYS_TEXT_SIZE: uint64 = 65536

wsys_text_buf:   Array[2097152, uint8]   # MAX_WINDOWS * WSYS_TEXT_SIZE = 32 * 65536
wsys_text_head:  Array[32, uint64]
wsys_text_count: Array[32, uint64]


def _wsys_text_push_wid(wid: int32, c: uint8):
    u: uint64 = cast[uint64](wid)
    base: uint64 = u * WSYS_TEXT_SIZE
    h: uint64 = wsys_text_head[u]
    wsys_text_buf[base + h] = c
    wsys_text_head[u] = (h + 1) % WSYS_TEXT_SIZE
    wsys_text_count[u] = wsys_text_count[u] + 1


def wsys_text_push(c: uint8):
    # The OLD Phase 1 entry point devcons.ad calls. Routes to the wid
    # the current task is bound to.
    w: int32 = _wsys_wid_for_current()
    _wsys_text_push_wid(w, c)


def _wsys_text_snapshot(wid: int32, out: Ptr[uint8],
                        max: uint64) -> uint64:
    # Copy up to `max` of the most-recent bytes of wid's text ring into
    # `out`, oldest first. Same algorithm as printk_log_snapshot — see
    # that file for the case analysis.
    u: uint64 = cast[uint64](wid)
    base: uint64 = u * WSYS_TEXT_SIZE
    count: uint64 = wsys_text_count[u]
    head: uint64 = wsys_text_head[u]
    avail: uint64 = count
    if avail > WSYS_TEXT_SIZE:
        avail = WSYS_TEXT_SIZE
    want: uint64 = avail
    if want > max:
        want = max
    if want == 0:
        return 0
    start: uint64 = 0
    if count <= WSYS_TEXT_SIZE:
        start = count - want
    else:
        start = (head + WSYS_TEXT_SIZE - want) % WSYS_TEXT_SIZE
    i: uint64 = 0
    while i < want:
        out[i] = wsys_text_buf[base + ((start + i) % WSYS_TEXT_SIZE)]
        i = i + 1
    return want


# --- output rings (per wid) -----------------------------------------
#
# One 16 KiB ring per wid. RESET-PER-COMMAND semantic: when a cmd is
# injected to a wid, that wid's output ring resets so a subsequent
# `cat /dev/wsys/<wid>/output` shows just that command's output.

WSYS_OUTPUT_SIZE: uint64 = 16384

wsys_output_buf:   Array[524288, uint8]    # 32 * 16384
wsys_output_head:  Array[32, uint64]
wsys_output_count: Array[32, uint64]


def _wsys_output_push_wid(wid: int32, c: uint8):
    u: uint64 = cast[uint64](wid)
    base: uint64 = u * WSYS_OUTPUT_SIZE
    h: uint64 = wsys_output_head[u]
    wsys_output_buf[base + h] = c
    wsys_output_head[u] = (h + 1) % WSYS_OUTPUT_SIZE
    wsys_output_count[u] = wsys_output_count[u] + 1


def wsys_output_push(c: uint8):
    w: int32 = _wsys_wid_for_current()
    _wsys_output_push_wid(w, c)


def _wsys_output_reset(wid: int32):
    u: uint64 = cast[uint64](wid)
    wsys_output_head[u] = 0
    wsys_output_count[u] = 0


def _wsys_output_snapshot(wid: int32, out: Ptr[uint8],
                          max: uint64) -> uint64:
    u: uint64 = cast[uint64](wid)
    base: uint64 = u * WSYS_OUTPUT_SIZE
    count: uint64 = wsys_output_count[u]
    head: uint64 = wsys_output_head[u]
    avail: uint64 = count
    if avail > WSYS_OUTPUT_SIZE:
        avail = WSYS_OUTPUT_SIZE
    want: uint64 = avail
    if want > max:
        want = max
    if want == 0:
        return 0
    start: uint64 = 0
    if count <= WSYS_OUTPUT_SIZE:
        start = count - want
    else:
        start = (head + WSYS_OUTPUT_SIZE - want) % WSYS_OUTPUT_SIZE
    i: uint64 = 0
    while i < want:
        out[i] = wsys_output_buf[base + ((start + i) % WSYS_OUTPUT_SIZE)]
        i = i + 1
    return want


# --- cmd injection queues (per wid) ---------------------------------

WSYS_CMD_SIZE: uint64 = 4096

wsys_cmd_buf:  Array[131072, uint8]   # 32 * 4096
wsys_cmd_tail: Array[32, uint64]
wsys_cmd_head: Array[32, uint64]


def _wsys_cmd_compact(wid: int32):
    u: uint64 = cast[uint64](wid)
    if wsys_cmd_tail[u] == wsys_cmd_head[u]:
        wsys_cmd_tail[u] = 0
        wsys_cmd_head[u] = 0


def _wsys_cmd_push_wid(wid: int32, c: uint8) -> int32:
    _wsys_cmd_compact(wid)
    u: uint64 = cast[uint64](wid)
    if wsys_cmd_head[u] >= WSYS_CMD_SIZE:
        return 0
    if wsys_cmd_head[u] == 0 and wsys_cmd_tail[u] == 0:
        _wsys_output_reset(wid)
    base: uint64 = u * WSYS_CMD_SIZE
    wsys_cmd_buf[base + wsys_cmd_head[u]] = c
    wsys_cmd_head[u] = wsys_cmd_head[u] + 1
    # Event-driven: an injected command byte just landed; wake any task
    # blocked on the console input wait queue so it picks it up promptly.
    console_input_wake()
    return 1


def _wsys_cmd_pop_wid(wid: int32) -> int32:
    u: uint64 = cast[uint64](wid)
    if wsys_cmd_tail[u] >= wsys_cmd_head[u]:
        return -1
    base: uint64 = u * WSYS_CMD_SIZE
    c: uint8 = wsys_cmd_buf[base + wsys_cmd_tail[u]]
    wsys_cmd_tail[u] = wsys_cmd_tail[u] + 1
    _wsys_cmd_compact(wid)
    return cast[int32](c) & 0xFF


def wsys_cmd_pop() -> int32:
    # devcons_read calls this. Routes to the CALLING window's queue —
    # bytes pushed to wid 2's /dev/wsys/2/cmd are only popped by tasks
    # bound to wid 2, never by the foreground hamsh on wid 1.
    w: int32 = _wsys_wid_for_current()
    return _wsys_cmd_pop_wid(w)


# --- non-destructive readiness probes (SYS_WAITFDS) ------------------
#
# These answer "would a read return bytes right now?" WITHOUT consuming
# anything. devcons_poll_readable (devcons.ad) and namec_poll_readable
# (namec.ad) call them from vfs_waitfds's scan loop.

def wsys_cmd_pending() -> int32:
    # Is there an injected cmd byte queued for the CALLING task's window?
    w: int32 = _wsys_wid_for_current()
    if w < 0:
        return 0
    u: uint64 = cast[uint64](w)
    if wsys_cmd_tail[u] < wsys_cmd_head[u]:
        return 1
    return 0


def wsys_pointer_pending(wid: int32) -> int32:
    if wsys_wid_in_use(wid) == 0:
        return 0
    return _wsys_ptr_readable(wid)


def wsys_keys_pending(wid: int32) -> int32:
    if wsys_wid_in_use(wid) == 0:
        return 0
    return _wsys_keys_readable(wid)


# --- per-window structured INPUT EVENT rings ------------------------
#
# THE PROBLEM
# -----------
# The compositor (user/hamUId.ad) OWNS pointer routing + focus + keyboard
# gating: it knows the absolute cursor position, which window the pointer
# is over / dragging / focused, the button bitmap and the scroll delta.
# But until now it exposed NONE of that to clients as a per-window event
# stream — client GUI apps had to scrape RELATIVE /dev/mouse deltas and
# raw stdin and re-derive everything. That cannot drive a real multi-
# window DE.
#
# THE FIX (this section)
# ----------------------
# Two NEW per-wid files surface the data the compositor already computes:
#
#   /dev/wsys/<wid>/pointer   structured, ROUTED pointer events in
#                             ABSOLUTE WINDOW-SPACE coordinates. One ASCII
#                             line per event:
#                                 "<type> <x> <y> <buttons> <dz>\n"
#                             type:    m=motion  d=button-down  u=button-up
#                                      s=scroll
#                             x,y:     pointer position in WINDOW-LOCAL
#                                      pixels (compositor already mapped
#                                      screen->window for the target win)
#                             buttons: decimal bitmap (bit0=L bit1=R bit2=M)
#                             dz:      scroll-wheel notch (signed; 0 if none)
#                             A window only sees events the compositor's
#                             router decided belong to it (pointer over it
#                             / drag-target / focus-target).
#
#   /dev/wsys/<wid>/keys      key events for the FOCUSED window only. One
#                             ASCII line per event:
#                                 "<type> <code>\n"
#                             type: d=press/typed  u=release
#                             code: decimal byte/keycode (a typed char's
#                                   ASCII value, or a VT-sequence byte).
#                             Only the focused window's queue is fed (the
#                             compositor gates the keyboard centrally, then
#                             routes the chosen bytes here).
#
# EVENT-DRIVEN I/O (NO poll-yield)
# --------------------------------
# Each ring has a per-wid WaitQueue. A client `sys_read` on an empty ring
# BLOCKS on that queue (STATE_WAIT, off the runqueue — Linux-style
# TASK_INTERRUPTIBLE) via the two-phase wq_wait_prepare / recheck /
# wq_wait_commit dance, exactly like the pipe reader in fs/vfs.ad. The
# compositor's WRITE (devwsys_pointer_write / devwsys_keys_write) appends
# the event line and calls wq_wake_one to wake the blocked client. No
# timer-tick re-poll, no busy spin.
#
# OVERFLOW POLICY: DROP NEWEST. The rings are sized generously (one ASCII
# event line is short); if a client falls so far behind that its ring is
# full, the just-arrived event is dropped rather than evicting older,
# already-queued events — input order is preserved and the client never
# observes a torn line. (Pointer motion is the high-rate stream and is
# the natural thing to coalesce/lose on a slow consumer.)
#
# Each ring is a byte FIFO with tail<=head cursors that compact to 0 when
# drained (mirrors the cmd queue shape, which never wraps mid-line). A
# read returns whole bytes up to `count`; a client reads line-at-a-time
# by scanning for '\n'. `off` is IGNORED — these are live event streams,
# not snapshot files.

WSYS_PTR_SIZE:  uint64 = 4096
# BUG #7 (hamedit fast-type char loss): a full keys ring drops the byte on
# push (_wsys_keys_push_byte returns 0). 2048 was tight under a fast burst
# when the focused app hadn't drained yet; 4096 gives ~680 "<t> <code>\n"
# lines of headroom so a held key-repeat / paste burst between consumer
# wakes can't overflow. Pairs with the consumer-side carry+full-drain loops
# in hameditscene/hamtermscene/hamcalcscene.
WSYS_KEYS_SIZE: uint64 = 4096

wsys_ptr_buf:   Array[131072, uint8]   # 32 * 4096
wsys_ptr_tail:  Array[32, uint64]
wsys_ptr_head:  Array[32, uint64]
wsys_ptr_wq:    Array[32, WaitQueue]

wsys_keys_buf:  Array[131072, uint8]   # 32 * 4096
wsys_keys_tail: Array[32, uint64]
wsys_keys_head: Array[32, uint64]
wsys_keys_wq:   Array[32, WaitQueue]

wsys_evt_wq_inited: int32 = 0


def _wsys_evt_wq_init_if_needed():
    # Lazy one-shot init of every per-wid event wait queue. BSS-zeroes the
    # WaitQueue.head to 0 already (== empty), but stamp it explicitly so a
    # warm path sees a clean queue.
    if wsys_evt_wq_inited != 0:
        return
    w: uint64 = 0
    while w < MAX_WINDOWS:
        wq_init(&wsys_ptr_wq[w])
        wq_init(&wsys_keys_wq[w])
        w = w + 1
    wsys_evt_wq_inited = 1


def _wsys_ptr_compact(wid: int32):
    u: uint64 = cast[uint64](wid)
    if wsys_ptr_tail[u] == wsys_ptr_head[u]:
        wsys_ptr_tail[u] = 0
        wsys_ptr_head[u] = 0


def _wsys_keys_compact(wid: int32):
    u: uint64 = cast[uint64](wid)
    if wsys_keys_tail[u] == wsys_keys_head[u]:
        wsys_keys_tail[u] = 0
        wsys_keys_head[u] = 0


def _wsys_ptr_push_byte(wid: int32, c: uint8) -> int32:
    # Append one byte to wid's pointer ring. Returns 1 on success, 0 if
    # the ring is full (DROP NEWEST). Does NOT wake — the caller wakes
    # once per complete event line.
    _wsys_ptr_compact(wid)
    u: uint64 = cast[uint64](wid)
    if wsys_ptr_head[u] >= WSYS_PTR_SIZE:
        return 0
    base: uint64 = u * WSYS_PTR_SIZE
    wsys_ptr_buf[base + wsys_ptr_head[u]] = c
    wsys_ptr_head[u] = wsys_ptr_head[u] + 1
    return 1


def _wsys_keys_push_byte(wid: int32, c: uint8) -> int32:
    # BUG 3 FIX (dropped keystroke). The keys ring has TWO writers that race:
    # the timer-IRQ keyboard pump (kbd_pump_to_compositor -> wsys_route_key_byte)
    # and the syscall-context devwsys_keys_write, AND a syscall-context reader
    # (_wsys_keys_pop_into). All three call _wsys_keys_compact, which resets
    # BOTH head and tail to 0 when the ring drains — so an IRQ-pump push that
    # interleaves a consumer's pop/compact (or vice-versa) corrupts the head/
    # tail pair and SILENTLY LOSES a byte. Mask local IRQs around the head/
    # tail mutation so the pump can't interleave a syscall-context push, and
    # so a push can't interleave a pop (see _wsys_keys_pop_into). The pump
    # itself already runs IRQs-off (timer ISR), so this closes the window
    # from both sides.
    fl: uint64 = local_irq_save()
    _wsys_keys_compact(wid)
    u: uint64 = cast[uint64](wid)
    if wsys_keys_head[u] >= WSYS_KEYS_SIZE:
        local_irq_restore(fl)
        return 0
    base: uint64 = u * WSYS_KEYS_SIZE
    wsys_keys_buf[base + wsys_keys_head[u]] = c
    wsys_keys_head[u] = wsys_keys_head[u] + 1
    local_irq_restore(fl)
    return 1


def _wsys_ptr_pop_into(wid: int32, out: Ptr[uint8], count: uint64) -> int64:
    # Drain up to `count` queued bytes from wid's pointer ring into `out`,
    # oldest first. Returns the byte count (0 if the ring is empty).
    u: uint64 = cast[uint64](wid)
    n: uint64 = 0
    base: uint64 = u * WSYS_PTR_SIZE
    while n < count and wsys_ptr_tail[u] < wsys_ptr_head[u]:
        out[n] = wsys_ptr_buf[base + wsys_ptr_tail[u]]
        wsys_ptr_tail[u] = wsys_ptr_tail[u] + 1
        n = n + 1
    _wsys_ptr_compact(wid)
    return cast[int64](n)


def _wsys_keys_pop_into(wid: int32, out: Ptr[uint8], count: uint64) -> int64:
    # BUG 3 FIX: drain IRQs-off so the timer-IRQ keyboard pump cannot push
    # (and run the shared _wsys_keys_compact head/tail reset) part-way through
    # this consumer's drain — the race that dropped the occasional keystroke.
    fl: uint64 = local_irq_save()
    u: uint64 = cast[uint64](wid)
    n: uint64 = 0
    base: uint64 = u * WSYS_KEYS_SIZE
    while n < count and wsys_keys_tail[u] < wsys_keys_head[u]:
        out[n] = wsys_keys_buf[base + wsys_keys_tail[u]]
        wsys_keys_tail[u] = wsys_keys_tail[u] + 1
        n = n + 1
    _wsys_keys_compact(wid)
    local_irq_restore(fl)
    return cast[int64](n)


def _wsys_ptr_readable(wid: int32) -> int32:
    u: uint64 = cast[uint64](wid)
    if wsys_ptr_tail[u] < wsys_ptr_head[u]:
        return 1
    return 0


def _wsys_keys_readable(wid: int32) -> int32:
    u: uint64 = cast[uint64](wid)
    if wsys_keys_tail[u] < wsys_keys_head[u]:
        return 1
    return 0


def _wsys_reset_evt_rings(wid: int32):
    u: uint64 = cast[uint64](wid)
    wsys_ptr_tail[u] = 0
    wsys_ptr_head[u] = 0
    wsys_keys_tail[u] = 0
    wsys_keys_head[u] = 0


def _wsys_reset_rings(wid: int32):
    # Zero the ring cursors for `wid`. Called from alloc/free so a
    # recycled slot doesn't leak the previous tenant's bytes. The
    # backing storage doesn't need clearing — the snapshot readers
    # use the count/head cursors.
    u: uint64 = cast[uint64](wid)
    wsys_text_head[u] = 0
    wsys_text_count[u] = 0
    wsys_output_head[u] = 0
    wsys_output_count[u] = 0
    wsys_cmd_tail[u] = 0
    wsys_cmd_head[u] = 0
    _wsys_reset_evt_rings(wid)
    # Drop any draw layers a recycled wid's previous tenant created.
    _wsys_draw_reset_window(wid)
    # Reset damage tracking so a recycled wid starts with a fresh serial
    # and an empty dirty rect (the compositor sees it as brand new).
    wsys_win_serial[u] = 0
    _wsys_dirty_clear(wid)
    _wsys_draw_listing_cache_gen[u] = 0


# --- ASCII formatting helpers ----------------------------------------

def _wsys_u64_to_dec(value: uint64, out: Ptr[uint8]) -> uint64:
    if value == 0:
        out[0] = 48                                 # '0'
        return 1
    digits: Array[24, uint8]
    n: uint64 = 0
    while value != 0:
        digits[n] = cast[uint8](value % 10) + 48
        value = value / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return written


def _wsys_emit_str(out: Ptr[uint8], pos: uint64, s: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while s[i] != 0:
        out[pos + i] = s[i]
        i = i + 1
    return pos + i


def _wsys_emit_path(out: Ptr[uint8], pos: uint64, cap: uint64,
                    path: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while i < cap:
        c: uint8 = path[i]
        if c == 0:
            return pos + i
        out[pos + i] = c
        i = i + 1
    return pos + i


# --- snapshot rendering ---------------------------------------------

def _wsys_render_pid(wid: int32, out: Ptr[uint8]) -> uint64:
    # "<pid>\n". The pid bound to `wid` — Phase 2's per-window pid.
    # wid 1 (foreground) defaults to the calling task's pid if its slot
    # has no recorded pid yet (boot-time first reader).
    pid: uint64 = wsys_pid_for_wid(wid)
    if pid == 0:
        pid = current_task_pid()
    n: uint64 = _wsys_u64_to_dec(pid, out)
    out[n] = 10
    return n + 1


def _wsys_render_uid(wid: int32, out: Ptr[uint8]) -> uint64:
    # "<uid>\n". The WINDOW's uid — the uid of the task bound to `wid`,
    # NOT the reader's uid. TODO DE close-out: this is the rio-shape
    # "uid this window runs as" visibility. We resolve by looking the
    # bound pid up in the task table and reading its task_uid_at; this
    # auto-tracks SYS_SETUID / SYS_SETUID_AUTH because both stamp the
    # task's uid via set_current_task_uid, so a `newshell hostowner`
    # inside the window flips this file with no setuid HOOK needed.
    # Fallback to the caller's uid if (a) wid is unbound (foreground
    # wid 1 before the first hamsh banner stamps its pid) or (b) the
    # bound pid has exited and freed its task slot — in both cases the
    # reader is the most reasonable proxy for "who's looking at this
    # window right now."
    uid: uint64 = cast[uint64](current_task_uid())
    pid: uint64 = wsys_pid_for_wid(wid)
    if pid != 0:
        slot: int32 = task_lookup_by_pid(pid)
        if slot >= 0:
            uid = cast[uint64](task_uid_at(slot))
    n: uint64 = _wsys_u64_to_dec(uid, out)
    out[n] = 10
    return n + 1


def _wsys_render_kind(out: Ptr[uint8]) -> uint64:
    # Phase 2 still constant: "text\n". Phase 4+ flips to "x11" /
    # "framebuffer" on GUI cmd.
    out[0] = 116
    out[1] = 101
    out[2] = 120
    out[3] = 116
    out[4] = 10
    return 5


def _wsys_render_geometry(out: Ptr[uint8]) -> uint64:
    s: Ptr[uint8] = "0 0 80 24\n"
    i: uint64 = 0
    while s[i] != 0:
        out[i] = s[i]
        i = i + 1
    return i


def _wsys_render_listing(out: Ptr[uint8], cap: uint64) -> uint64:
    # /dev/wsys directory listing. One line per active wid:
    #   "<wid> active text uid=<u> pid=<p> hamsh \"<first 32 bytes>\"\n"
    # Phase 2 framing per the brief. First-line-of-text is the most
    # recent (or first) line of the wid's text ring — a quick "what's
    # happening here" hint for an outside reader.
    _wsys_init_if_needed()
    pos: uint64 = 0
    w: uint64 = 1
    while w < MAX_WINDOWS:
        if wsys_slot_in_use[w] != 0:
            # Defensive cap: each line caps at ~80 bytes; bail before
            # we'd run off the end of `out`.
            if pos + 96 >= cap:
                break
            # wid
            pos = pos + _wsys_u64_to_dec(w, &out[pos])
            pos = _wsys_emit_str(out, pos, " active text uid=")
            # TODO DE close-out: render the WINDOW's uid (bound task's
            # uid) in the listing, not the reader's uid — same rule the
            # per-window /uid leaf follows. Falls back to the reader's
            # uid for unbound / exited slots so the column is always
            # populated.
            uid: uint64 = cast[uint64](current_task_uid())
            wp: uint64 = wsys_slot_pid[w]
            if wp != 0:
                ws: int32 = task_lookup_by_pid(wp)
                if ws >= 0:
                    uid = cast[uint64](task_uid_at(ws))
            pos = pos + _wsys_u64_to_dec(uid, &out[pos])
            pos = _wsys_emit_str(out, pos, " pid=")
            pid: uint64 = wsys_slot_pid[w]
            pos = pos + _wsys_u64_to_dec(pid, &out[pos])
            pos = _wsys_emit_str(out, pos, " hamsh\n")
        w = w + 1
    return pos


def _wsys_render_ns(wid: int32, out: Ptr[uint8], cap: uint64) -> uint64:
    # Dump the WINDOW'S namespace — the mtab of the Pgrp on the bound
    # task. TODO DE close-out: this lets `cat #w/ns` show what's bound
    # into this window's per-process tree (e.g. the `#c` device root,
    # any rio /env binds), not the reader's tree. We resolve the bound
    # task's pgrp via task_lookup_by_pid + task_pgrp; fall back to the
    # caller's pgrp (pgrp_current) if the wid is unbound or its task
    # has exited, so the file is never empty for a legitimate reader.
    pos: uint64 = 0
    p: uint64 = 0
    pid: uint64 = wsys_pid_for_wid(wid)
    if pid != 0:
        slot: int32 = task_lookup_by_pid(pid)
        if slot >= 0:
            p = task_pgrp(slot)
    if p == 0:
        p = pgrp_current()
    if p == 0:
        return pos
    g: Ptr[Pgrp] = cast[Ptr[Pgrp]](p)
    i: uint64 = 0
    while i < MNT_CAP:
        if g[0].mtab[i].in_use != 0:
            if pos + 320 >= cap:
                break
            if g[0].mtab[i].chan.kind == CHAN_KIND_SRV:
                pos = _wsys_emit_str(out, pos, "mount: ")
                pos = _wsys_emit_path(out, pos, 128,
                                      &g[0].mtab[i].from_path[0])
                out[pos] = 32
                pos = pos + 1
                pos = _wsys_emit_str(out, pos, "9p\n")
            else:
                pos = _wsys_emit_str(out, pos, "bind: ")
                pos = _wsys_emit_path(out, pos, 128,
                                      &g[0].mtab[i].from_path[0])
                out[pos] = 32
                pos = pos + 1
                pos = _wsys_emit_path(out, pos, 128,
                                      &g[0].mtab[i].to_path[0])
                out[pos] = 10
                pos = pos + 1
        i = i + 1
    return pos


# --- public read/write entry points ----------------------------------
#
# namec.ad dispatches into these per (wid, DEV_WSYS_*) tuple. The
# wid is encoded into the inline chan id alongside the dev_type.

WSYS_SCRATCH_CAP: uint64 = 65536


def _wsys_copy_out(scratch: Ptr[uint8], n: uint64,
                   off: uint64, buf: Ptr[uint8], count: uint64) -> int64:
    if off >= n:
        return 0
    remaining: uint64 = n - off
    take: uint64 = count
    if take > remaining:
        take = remaining
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[off + i]
        i = i + 1
    return cast[int64](take)


def devwsys_text_read(wid: int32, off: uint64, buf: Ptr[uint8],
                      count: uint64) -> int64:
    if count == 0:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return -2                           # -ENOENT
    # #438: this scratch buffer used to be a 64 KiB stack Array — by
    # itself it nearly fills an entire kernel stack, and stacked under
    # the read(2) chain it overflows it. Heap-allocate instead; the
    # snapshot is transient.
    scratch: uint64 = kmalloc(WSYS_SCRATCH_CAP)
    if scratch == 0:
        return -12                          # -ENOMEM
    n: uint64 = _wsys_text_snapshot(wid, cast[Ptr[uint8]](scratch),
                                    WSYS_TEXT_SIZE)
    r: int64 = _wsys_copy_out(cast[Ptr[uint8]](scratch), n, off, buf, count)
    kfree(scratch)
    return r


def devwsys_output_read(wid: int32, off: uint64, buf: Ptr[uint8],
                        count: uint64) -> int64:
    if count == 0:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return -2
    # #438: heap-allocated for the same kstack-pressure reason as
    # devwsys_text_read above (this one was a 16 KiB stack Array).
    scratch: uint64 = kmalloc(16384)
    if scratch == 0:
        return -12                          # -ENOMEM
    n: uint64 = _wsys_output_snapshot(wid, cast[Ptr[uint8]](scratch),
                                      WSYS_OUTPUT_SIZE)
    r: int64 = _wsys_copy_out(cast[Ptr[uint8]](scratch), n, off, buf, count)
    kfree(scratch)
    return r


def devwsys_ns_read(wid: int32, off: uint64, buf: Ptr[uint8],
                    count: uint64) -> int64:
    # TODO DE close-out: per-window ns — dumps the WINDOW's mtab, not
    # the reader's. ENOENT for unused wids matches the wid-gated pattern
    # in devwsys_text_read / devwsys_pid_read above.
    if count == 0:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return -2
    scratch: Array[8192, uint8]
    n: uint64 = _wsys_render_ns(wid, &scratch[0], 8192)
    return _wsys_copy_out(&scratch[0], n, off, buf, count)


def devwsys_pid_read(wid: int32, off: uint64, buf: Ptr[uint8],
                     count: uint64) -> int64:
    if count == 0:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return -2
    scratch: Array[32, uint8]
    n: uint64 = _wsys_render_pid(wid, &scratch[0])
    return _wsys_copy_out(&scratch[0], n, off, buf, count)


def devwsys_uid_read(wid: int32, off: uint64, buf: Ptr[uint8],
                     count: uint64) -> int64:
    # TODO DE close-out: per-window uid — reports the WINDOW's effective
    # uid (the bound task's uid), so `newshell hostowner` inside the
    # window is visible to outside readers via `cat #w/uid`.
    if count == 0:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return -2
    scratch: Array[32, uint8]
    n: uint64 = _wsys_render_uid(wid, &scratch[0])
    return _wsys_copy_out(&scratch[0], n, off, buf, count)


def devwsys_kind_read(off: uint64, buf: Ptr[uint8],
                      count: uint64) -> int64:
    if count == 0:
        return 0
    scratch: Array[16, uint8]
    n: uint64 = _wsys_render_kind(&scratch[0])
    return _wsys_copy_out(&scratch[0], n, off, buf, count)


def devwsys_geometry_read(off: uint64, buf: Ptr[uint8],
                          count: uint64) -> int64:
    if count == 0:
        return 0
    scratch: Array[32, uint8]
    n: uint64 = _wsys_render_geometry(&scratch[0])
    return _wsys_copy_out(&scratch[0], n, off, buf, count)


def devwsys_listing_read(off: uint64, buf: Ptr[uint8],
                         count: uint64) -> int64:
    if count == 0:
        return 0
    scratch: Array[1024, uint8]
    n: uint64 = _wsys_render_listing(&scratch[0], 1024)
    return _wsys_copy_out(&scratch[0], n, off, buf, count)


# --- damage / serial files (hot-path fast skip) ----------------------

def devwsys_serial_read(wid: int32, off: uint64, buf: Ptr[uint8],
                        count: uint64) -> int64:
    # /dev/wsys/<N>/serial -> "<serial>\n". The window's monotonic
    # mutation counter (0 = never mutated). The compositor reads this
    # cheaply per frame; if it equals the value it last composited, the
    # window is unchanged and the compositor skips re-reading draw/markup.
    if count == 0:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return -2
    scratch: Array[32, uint8]
    u: uint64 = cast[uint64](wid)
    n: uint64 = _wsys_u64_to_dec(wsys_win_serial[u], &scratch[0])
    scratch[n] = 10
    n = n + 1
    return _wsys_copy_out(&scratch[0], n, off, buf, count)


def devwsys_serial_write(wid: int32, buf: Ptr[uint8],
                         count: uint64) -> int64:
    # The compositor ACKs a composited serial by writing it back here.
    # If the acked serial is >= the window's current serial, the dirty
    # rect is consumed (reset to empty) — the compositor has repainted
    # everything up to that serial. A stale ack (older than current)
    # leaves the rect intact so pending damage isn't lost. A digit-less
    # write is a no-op (mirrors the z/opacity redirect-flush handling).
    if wsys_wid_in_use(wid) == 0:
        return -2
    if _wsys_buf_has_digit(buf, count) == 0:
        return cast[int64](count)
    acked: int64 = _wsys_tok_to_i64(buf, 0, count)
    if acked < 0:
        return cast[int64](count)
    u: uint64 = cast[uint64](wid)
    if cast[uint64](acked) >= wsys_win_serial[u]:
        _wsys_dirty_clear(wid)
    return cast[int64](count)


def _wsys_render_damage(out: Ptr[uint8], cap: uint64) -> uint64:
    # /dev/wsys/damage listing. One line per live wid:
    #   "<wid> <serial> <dx0> <dy0> <dx1> <dy1>\n"
    # The compositor reads this ONE file per frame, diffs each wid's
    # serial against its own last-composited table, and only re-reads /
    # re-composites the windows whose serial advanced — using the dirty
    # rect to bound the repaint. An empty dirty rect renders "0 0 0 0".
    _wsys_init_if_needed()
    pos: uint64 = 0
    w: uint64 = 1
    while w < MAX_WINDOWS:
        if wsys_slot_in_use[w] != 0:
            if pos + 128 >= cap:
                break
            pos = pos + _wsys_u64_to_dec(w, &out[pos])
            out[pos] = 32
            pos = pos + 1
            pos = pos + _wsys_u64_to_dec(wsys_win_serial[w], &out[pos])
            out[pos] = 32
            pos = pos + 1
            # Dirty rect, normalised so an empty box renders as 0 0 0 0.
            dx0: int64 = wsys_dirty_x0[w]
            dy0: int64 = wsys_dirty_y0[w]
            dx1: int64 = wsys_dirty_x1[w]
            dy1: int64 = wsys_dirty_y1[w]
            if dx1 <= dx0 or dy1 <= dy0:
                dx0 = 0
                dy0 = 0
                dx1 = 0
                dy1 = 0
            pos = _wsys_emit_i64(out, pos, dx0)
            out[pos] = 32
            pos = pos + 1
            pos = _wsys_emit_i64(out, pos, dy0)
            out[pos] = 32
            pos = pos + 1
            pos = _wsys_emit_i64(out, pos, dx1)
            out[pos] = 32
            pos = pos + 1
            pos = _wsys_emit_i64(out, pos, dy1)
            out[pos] = 10
            pos = pos + 1
        w = w + 1
    return pos


def devwsys_damage_read(off: uint64, buf: Ptr[uint8],
                        count: uint64) -> int64:
    # wsys-level damage snapshot. Read-only, snapshot-once (honours off so
    # `cat /dev/wsys/damage` terminates). NO side effects — consumption is
    # acked per-window via devwsys_serial_write.
    if count == 0:
        return 0
    scratch: Array[1024, uint8]
    n: uint64 = _wsys_render_damage(&scratch[0], 1024)
    return _wsys_copy_out(&scratch[0], n, off, buf, count)


def devwsys_self_read(off: uint64, buf: Ptr[uint8],
                      count: uint64) -> int64:
    # /dev/wsys/self -> "<wid>\n". The wid bound to the CALLING task, or
    # "0\n" if it owns no window. A compositor-spawned client reads this
    # to learn the wid the compositor allocated for it AFTER exec (the
    # alloc happens post-spawn, so the wid can't be an exec argv). Unlike
    # _wsys_wid_for_current(), an unmapped caller renders 0 here (NOT the
    # wid-1 foreground default) — a real GUI client must NOT mistake
    # "I have no window yet" for "I own the foreground console".
    if count == 0:
        return 0
    _wsys_init_if_needed()
    pid: uint64 = current_task_pid()
    # Empty-windows DE bug fix: walk up the parent chain so a v2 client
    # spawned BY a hamsh that holds the wid binding can still discover
    # the wid via /dev/wsys/self. hamUId allocates wid against the spawn-
    # shell pid, but the rc shell forks the real client with a new pid;
    # without this walk-up self-discovery returned 0 and the client
    # treated itself as un-windowed.
    w: int32 = _wsys_wid_for_pid_or_ancestor(pid)
    if w < 0:
        w = 0
    scratch: Array[16, uint8]
    n: uint64 = _wsys_u64_to_dec(cast[uint64](w), &scratch[0])
    scratch[n] = 10
    n = n + 1
    return _wsys_copy_out(&scratch[0], n, off, buf, count)


def devwsys_cmd_write(wid: int32, buf: Ptr[uint8],
                      count: uint64) -> int64:
    if wsys_wid_in_use(wid) == 0:
        return -2
    i: uint64 = 0
    while i < count:
        _wsys_cmd_push_wid(wid, buf[i])
        i = i + 1
    return cast[int64](count)


def devwsys_readonly_write(buf: Ptr[uint8], count: uint64) -> int64:
    return -1


# --- structured input-event WRITE (compositor) ----------------------
#
# The compositor (user/hamUId.ad) is the SOLE writer of these files. It
# opens "/dev/wsys/<wid>/pointer" / "/dev/wsys/<wid>/keys" for write and
# emits already-routed, window-space ASCII event lines (it has done the
# hit-test / focus decision; the kernel just buffers + wakes). A write
# appends the bytes verbatim and wakes one blocked reader once the line
# is in. Newest is dropped if the ring is full.

def devwsys_pointer_write(wid: int32, buf: Ptr[uint8],
                          count: uint64) -> int64:
    if wsys_wid_in_use(wid) == 0:
        return -2
    _wsys_evt_wq_init_if_needed()
    i: uint64 = 0
    while i < count:
        _wsys_ptr_push_byte(wid, buf[i])           # DROP-NEWEST on full
        i = i + 1
    # Wake one blocked reader (the focused/target client) so it picks up
    # the event promptly — event-driven, no timer-tick re-poll.
    wq_wake_one(&wsys_ptr_wq[cast[uint64](wid)])
    # Also kick any SYS_WAITFDS multi-fd waiter that includes this
    # window's pointer fd in its set.
    waitfds_notify()
    return cast[int64](count)


def devwsys_keys_write(wid: int32, buf: Ptr[uint8],
                       count: uint64) -> int64:
    if wsys_wid_in_use(wid) == 0:
        return -2
    _wsys_evt_wq_init_if_needed()
    i: uint64 = 0
    while i < count:
        _wsys_keys_push_byte(wid, buf[i])
        i = i + 1
    wq_wake_one(&wsys_keys_wq[cast[uint64](wid)])
    # Also kick any SYS_WAITFDS multi-fd waiter (see pointer twin above).
    waitfds_notify()
    return cast[int64](count)


# --- structured input-event READ (client, BLOCKING) -----------------
#
# A client GUI app reads these to receive routed events. The read BLOCKS
# (event-driven; STATE_WAIT off the runqueue) until the compositor writes
# an event, using the two-phase prepare/recheck/commit wait so the SMP
# producer-on-another-CPU wake can never be lost. `off` is IGNORED — a
# live stream, not a snapshot. Returns whole bytes (line-framed by the
# client scanning for '\n'); a signal-wake returns -EINTR.

def devwsys_pointer_read(wid: int32, off: uint64, buf: Ptr[uint8],
                         count: uint64) -> int64:
    if count == 0:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return -2
    _wsys_evt_wq_init_if_needed()
    while True:
        if _wsys_ptr_readable(wid) != 0:
            return _wsys_ptr_pop_into(wid, buf, count)
        # Queue ourselves FIRST, then re-check while queued so a write
        # racing in between cannot leave us asleep with data waiting.
        pwq: Ptr[WaitQueue] = &wsys_ptr_wq[cast[uint64](wid)]
        wq_wait_prepare(pwq)
        if _wsys_ptr_readable(wid) != 0:
            wq_wait_cancel(pwq)
            continue
        rc: int32 = wq_wait_commit(pwq)
        if rc != 0:
            return cast[int64](WQ_EINTR)


def devwsys_keys_read(wid: int32, off: uint64, buf: Ptr[uint8],
                      count: uint64) -> int64:
    if count == 0:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return -2
    _wsys_evt_wq_init_if_needed()
    while True:
        if _wsys_keys_readable(wid) != 0:
            return _wsys_keys_pop_into(wid, buf, count)
        kwq: Ptr[WaitQueue] = &wsys_keys_wq[cast[uint64](wid)]
        wq_wait_prepare(kwq)
        if _wsys_keys_readable(wid) != 0:
            wq_wait_cancel(kwq)
            continue
        rc: int32 = wq_wait_commit(kwq)
        if rc != 0:
            return cast[int64](WQ_EINTR)


# --- structured input-event READ (client, NON-BLOCKING) -------------
#
# The SYS_READ_NB sibling of the blocking readers above. A separate-
# process GUI client (e.g. user/hamecho.ad) that owns its own keys/
# pointer stream AND runs its own compositor-free event loop must be
# able to POLL these without parking — otherwise an empty ring would
# wedge the whole client on the per-wid wait queue. These return 0
# ("would block", no event yet) instead of sleeping; a queued event is
# popped exactly like the blocking path. `off` is ignored (live stream).

def devwsys_pointer_read_nb(wid: int32, buf: Ptr[uint8],
                            count: uint64) -> int64:
    if count == 0:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return -2
    _wsys_evt_wq_init_if_needed()
    if _wsys_ptr_readable(wid) != 0:
        return _wsys_ptr_pop_into(wid, buf, count)
    return 0


def devwsys_keys_read_nb(wid: int32, buf: Ptr[uint8],
                         count: uint64) -> int64:
    if count == 0:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return -2
    _wsys_evt_wq_init_if_needed()
    if _wsys_keys_readable(wid) != 0:
        return _wsys_keys_pop_into(wid, buf, count)
    return 0


# --- foreground routing introspection -------------------------------
#
# devcons.ad consults this BEFORE calling early_putc_user — if the
# current task is bound to a bg wid (>= 2), we suppress the serial /
# framebuffer write. The bytes still tee into that wid's text /
# output rings via the wsys_text_push / wsys_output_push above.

def wsys_current_is_foreground() -> int32:
    # 1 iff the current task is bound to wid 1 (or no wid — defaults
    # to foreground). 0 iff bound to a bg wid (>= 2): caller should
    # skip the serial console write.
    w: int32 = _wsys_wid_for_current()
    if w <= 1:
        return 1
    return 0


# === hamUI Phase 4a — layered-draw FILE SURFACE =====================
#
# docs/hamUI.md H-§G. This is the kernel-side per-window draw layer
# tree exposed as cdev files under /dev/wsys/<wid>/draw/. THIS PHASE
# IS PURELY THE FILE SURFACE — no rasterisation, no pixels rendered.
# A later phase (4b) builds the userland renderer that rasterises the
# markup/fb buffers this surface stores.
#
# Per-window layer table layout (static, codebase norm — no malloc):
#   * Up to WSYS_DRAW_MAX_LAYERS (16) layers per window.
#   * Each layer: a name (NUL-padded, up to WSYS_DRAW_NAME_CAP-1
#     chars), kind (markup|fb), z-height, opacity (0..255), geometry
#     (x/y/w/h), a markup text body (WSYS_DRAW_MARKUP_CAP bytes), and
#     an fb pixel buffer (WSYS_DRAW_FB_CAP bytes RGBA8888).
#
# CAP RATIONALE
#   markup: 8 KiB is comfortable for a chrome layer's hamML.
#   fb:     256 KiB per layer = 256x256 RGBA8888 (262144 B) minus a
#           little; we round to exactly 262144 so a 256x256 fb fits.
#   Total fb storage = MAX_WINDOWS * MAX_LAYERS * FB_CAP. With the
#   defaults that is 32 * 16 * 262144 = 128 MiB of BSS. That is the
#   dominant cost of this surface; documented here so a future tuner
#   knows where the memory went. (4b's userland renderer keeps the
#   rastered bitmaps; the kernel only stores the raw layer bytes.)

WSYS_DRAW_MAX_LAYERS: uint64 = 16
WSYS_DRAW_NAME_CAP:   uint64 = 32
WSYS_DRAW_MARKUP_CAP: uint64 = 8192
WSYS_DRAW_FB_CAP:     uint64 = 262144      # 256 * 256 * 4 (RGBA8888)

WSYS_LAYER_KIND_MARKUP: int32 = 0
WSYS_LAYER_KIND_FB:     int32 = 1

# Per-(wid, layer-slot) scalar metadata. Flat Arrays sized
# MAX_WINDOWS * WSYS_DRAW_MAX_LAYERS = 32 * 16 = 512, indexed as
# meta[wid * WSYS_DRAW_MAX_LAYERS + slot]. Mirrors the flat-Array
# idiom the rings above use (Adder's nested-frame Array quirk).
wsys_layer_in_use:  Array[512, int32]
wsys_layer_kind:    Array[512, int32]
wsys_layer_z:       Array[512, int64]
wsys_layer_opacity: Array[512, int64]
wsys_layer_x:       Array[512, int64]
wsys_layer_y:       Array[512, int64]
wsys_layer_w:       Array[512, int64]
wsys_layer_h:       Array[512, int64]
wsys_layer_markup_len: Array[512, uint64]
wsys_layer_fb_len:     Array[512, uint64]
# Per-(wid, layer) content GENERATION counter: bumped on every successful
# content write (markup or fb, userland or in-kernel store, plus the
# `clear` ctl verb since it also changes content). Exposed read-only as
# the `gen` leaf next to markup/fb so a compositor can skip re-reading an
# unchanged body. Reset to 0 when a slot is (re)committed by mklayer.
wsys_layer_gen:        Array[512, uint64]

# Layer name storage: flat Array of MAX_WINDOWS * MAX_LAYERS *
# NAME_CAP = 32 * 16 * 32 = 16384 bytes. Indexed as
# name[(wid * MAX_LAYERS + slot) * NAME_CAP + i]. NUL-padded.
wsys_layer_name: Array[16384, uint8]

# Markup bodies: 32 * 16 * 8192 = 4194304 bytes.
wsys_layer_markup: Array[4194304, uint8]

# Framebuffer bytes: per window MAX_LAYERS * FB_CAP = 16 * 262144 =
# 4194304 = exactly 4 MiB.
#
# OOM REGRESSION FIX (devwsys MAX_WINDOWS 9->32): this used to be a flat
# static Array[134217728] (= 32 * 4 MiB = 128 MiB) of BSS. At 32 windows
# that, plus the 125 MiB wsys_backbuffer below, OOMed a modest-RAM VM at
# boot ([pf] COW resolution failed). It is now a 32-slot array of POINTERS
# (8 bytes each, 0 = unallocated). The 4 MiB block for a window is
# allocated lazily on first fb write and freed when the wid slot is
# released. Idle slots cost 8 bytes, not 4 MiB.
#
# FOOTPRINT REGRESSION FIX (QA-N25): the block is allocated but NOT eagerly
# zeroed — see _wsys_layer_fb_ensure. Each window then only makes host-
# resident the pages it actually draws into (w*h*4 for the scene path), not
# the full 4 MiB, so a ~30-window DE session leaves real headroom on a 1 GB
# guest instead of OOM-killing qemu.
WSYS_LAYER_FB_BYTES_PER_WIN: uint64 = 4194304   # 16 * 262144 = 4 MiB
WSYS_LAYER_FB_ORDER:         int32  = 10         # 1024 pages = 4 MiB
wsys_layer_fb_page: Array[32, uint64]            # per-wid base addr, 0=none


def _wsys_draw_base(wid: int32, slot: uint64) -> uint64:
    # The (wid, slot) entry index into the per-slot scalar Arrays.
    return cast[uint64](wid) * WSYS_DRAW_MAX_LAYERS + slot


def _wsys_draw_name_base(wid: int32, slot: uint64) -> uint64:
    return _wsys_draw_base(wid, slot) * WSYS_DRAW_NAME_CAP


def _wsys_draw_markup_base(wid: int32, slot: uint64) -> uint64:
    return _wsys_draw_base(wid, slot) * WSYS_DRAW_MARKUP_CAP


def _wsys_draw_fb_base(wid: int32, slot: uint64) -> uint64:
    return _wsys_draw_base(wid, slot) * WSYS_DRAW_FB_CAP


def _wsys_layer_fb_off(slot: uint64) -> uint64:
    # Intra-window byte offset of `slot`'s fb within this window's 4 MiB
    # block. (The old _wsys_draw_fb_base packed wid into the offset too;
    # with per-window allocation the wid selects the block pointer and
    # only the slot contributes to the in-block offset.)
    return slot * WSYS_DRAW_FB_CAP


def _wsys_layer_fb_ensure(wid: int32) -> Ptr[uint8]:
    # Return a pointer to wid's 4 MiB layer-fb block, allocating it from
    # the buddy allocator on first use. Returns null if wid is out of
    # range or the allocation fails (callers must no-op safely on null).
    #
    # FOOTPRINT (QA-N25): we deliberately do NOT memset the full 4 MiB block
    # here. Under a demand-paged host (qemu RSS grows only for guest pages the
    # guest actually TOUCHES) an eager 4 MiB clear made all 1024 pages host-
    # resident for EVERY window — even a 200x30 panel/clock/toast that only
    # ever uses a few KiB. Across a ~30-window DE session that wasted ~100 MB
    # of a 1 GB guest and drove host OOM. Instead each consumer zeroes ONLY the
    # bytes it uses: the scene rasterizer memsets its w*h*4 frame every pass
    # (_wsys_rasterize_window), and the fb-layer write path gap-zeroes any hole
    # below the per-slot high-water mark (devwsys_draw_fb_write). Untouched
    # pages therefore stay non-resident on the host.
    if wid <= 0:
        return cast[Ptr[uint8]](0)
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return cast[Ptr[uint8]](0)
    if wsys_layer_fb_page[u] == 0:
        p: uint64 = alloc_pages(WSYS_LAYER_FB_ORDER)
        if p == 0:
            return cast[Ptr[uint8]](0)
        wsys_layer_fb_page[u] = p
    return cast[Ptr[uint8]](wsys_layer_fb_page[u])


def _wsys_layer_fb_get(wid: int32) -> Ptr[uint8]:
    # Pointer to wid's layer-fb block WITHOUT allocating — null if the
    # window has never been drawn into. Read paths use this so a never-
    # drawn window reads as empty rather than forcing a 4 MiB alloc.
    if wid <= 0:
        return cast[Ptr[uint8]](0)
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return cast[Ptr[uint8]](0)
    return cast[Ptr[uint8]](wsys_layer_fb_page[u])


def _wsys_layer_fb_release(wid: int32):
    # Free wid's layer-fb block back to the buddy allocator (on slot
    # release / recycle). Null pointer is a no-op.
    if wid <= 0:
        return
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return
    if wsys_layer_fb_page[u] != 0:
        free_pages(wsys_layer_fb_page[u], WSYS_LAYER_FB_ORDER)
        wsys_layer_fb_page[u] = 0


def _wsys_name_match(wid: int32, slot: uint64,
                     name: Ptr[uint8], namelen: uint64) -> int32:
    # 1 iff the stored layer name at (wid, slot) equals the first
    # `namelen` bytes of `name` AND the stored name is exactly that
    # long (next stored byte is NUL or namelen hits NAME_CAP).
    nb: uint64 = _wsys_draw_name_base(wid, slot)
    i: uint64 = 0
    while i < namelen:
        if i >= WSYS_DRAW_NAME_CAP:
            return 0
        if wsys_layer_name[nb + i] != name[i]:
            return 0
        i = i + 1
    # Stored name must terminate here (full-equality, not prefix).
    if i >= WSYS_DRAW_NAME_CAP:
        return 1
    if wsys_layer_name[nb + i] == 0:
        return 1
    return 0


def _wsys_draw_layer_index(wid: int32, name: Ptr[uint8],
                           namelen: uint64) -> int32:
    # Find the slot of the layer named `name` (first `namelen` bytes)
    # for `wid`. Returns the slot (0..MAX_LAYERS-1) or -1 if absent.
    s: uint64 = 0
    while s < WSYS_DRAW_MAX_LAYERS:
        if wsys_layer_in_use[_wsys_draw_base(wid, s)] != 0:
            if _wsys_name_match(wid, s, name, namelen) != 0:
                return cast[int32](s)
        s = s + 1
    return -1


def _wsys_draw_free_slot(wid: int32) -> int32:
    # Lowest free layer slot for `wid`, or -1 if the table is full.
    s: uint64 = 0
    while s < WSYS_DRAW_MAX_LAYERS:
        if wsys_layer_in_use[_wsys_draw_base(wid, s)] == 0:
            return cast[int32](s)
        s = s + 1
    return -1


def _wsys_draw_reset_window(wid: int32):
    # Clear every layer slot for `wid`. Called from alloc/free so a
    # recycled wid doesn't leak the previous tenant's layers.
    s: uint64 = 0
    while s < WSYS_DRAW_MAX_LAYERS:
        b: uint64 = _wsys_draw_base(wid, s)
        wsys_layer_in_use[b] = 0
        wsys_layer_markup_len[b] = 0
        wsys_layer_fb_len[b] = 0
        wsys_layer_gen[b] = 0
        s = s + 1


# --- ctl verb parsing helpers ---------------------------------------

def _wsys_is_space(c: uint8) -> int32:
    if c == 32 or c == 9:
        return 1
    return 0


def _wsys_tok_skip_space(buf: Ptr[uint8], pos: uint64,
                         count: uint64) -> uint64:
    p: uint64 = pos
    while p < count:
        if _wsys_is_space(buf[p]) == 0:
            if buf[p] != 10 and buf[p] != 13:
                break
        p = p + 1
    return p


def _wsys_tok_end(buf: Ptr[uint8], pos: uint64, count: uint64) -> uint64:
    # Index of the first whitespace/newline/end at or after `pos`.
    p: uint64 = pos
    while p < count:
        c: uint8 = buf[p]
        if _wsys_is_space(c) != 0 or c == 10 or c == 13:
            break
        p = p + 1
    return p


def _wsys_tok_eq(buf: Ptr[uint8], start: uint64, end: uint64,
                 word: Ptr[char]) -> int32:
    # 1 iff buf[start..end) equals the NUL-terminated `word`.
    i: uint64 = 0
    p: uint64 = start
    while True:
        wc: char = word[i]
        if wc == 0:
            if p == end:
                return 1
            return 0
        if p >= end:
            return 0
        if buf[p] != cast[uint8](wc):
            return 0
        i = i + 1
        p = p + 1


def _wsys_tok_to_i64(buf: Ptr[uint8], start: uint64,
                     end: uint64) -> int64:
    # Parse a (possibly negative) decimal integer from buf[start..end).
    # Non-digit bytes terminate parsing early; an empty token is 0.
    p: uint64 = start
    neg: int32 = 0
    if p < end and buf[p] == 45:               # '-'
        neg = 1
        p = p + 1
    v: int64 = 0
    while p < end:
        c: uint8 = buf[p]
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[int64](c) - 48
        p = p + 1
    if neg != 0:
        return 0 - v
    return v


def _wsys_buf_has_digit(buf: Ptr[uint8], count: uint64) -> int32:
    # 1 iff buf[0..count) contains at least one ASCII decimal digit.
    # The scalar draw files (z, opacity) use this to ignore a digit-less
    # write — a redirect like `echo 100 > z` can land as two writes
    # ("100" then a trailing "\n", or an empty flush), and a digit-less
    # payload must NOT clobber the value the previous write just set.
    i: uint64 = 0
    while i < count:
        c: uint8 = buf[i]
        if c >= 48 and c <= 57:
            return 1
        i = i + 1
    return 0


# --- ctl write: mklayer / rmlayer / clear / setz / ls ---------------

def devwsys_draw_ctl_write(wid: int32, buf: Ptr[uint8],
                           count: uint64) -> int64:
    # Parse and apply one ctl verb line. Verbs (H-§G):
    #   mklayer <name> markup [w h]
    #   mklayer <name> fb w h [bpp]
    #   rmlayer <name>
    #   clear <name>
    #   setz <name> <n>
    #   ls
    # Returns the byte count consumed (write accepted) on success, or
    # a negative errno on a hard failure (bad wid / table full).
    if wsys_wid_in_use(wid) == 0:
        return -2                                       # -ENOENT
    # DE correction Phase 1: this is the per-window backbuffer ingest
    # (blit 'B' / dirty 'D' / cursor 'C', plus legacy layer verbs). Only
    # the WINDOW'S OWNER (or hostowner) may paint into it — a process
    # controls its OWN window's pixels, not another window's. This mirrors
    # the wctl gate; together they let a DE-spawned non-hostowner client
    # negotiate v2 and blit its own backbuffer to the screen.
    if current_task_is_hostowner() == 0 and _wsys_caller_owns_wid(wid) == 0:
        return -1                                       # -EPERM
    if count == 0:
        return 0
    # #442 (c) RIO BLIT PROTOCOL substrate: when this window is in v2
    # mode AND the first byte is one of 'B'/'D'/'C', dispatch to the
    # binary parser BEFORE we touch the ASCII tokeniser. Legacy v0/v1
    # text verbs (mklayer / setz / clear / rmlayer / ls) never start
    # with one of those bytes, so this gate cannot misfire on the
    # existing markup path.
    # #128: the 'I' (image-store) verb is accepted at ANY protocol version
    # so a legacy scene client can drop in a named image without converting
    # its whole window to the v2 backbuffer. No legacy text verb starts with
    # 'I' (mklayer/rmlayer/clear/setz/ls), so this cannot misfire.
    if buf[0] == 73:                                   # 'I'
        return _wsys_blit_parse(wid, buf, count)
    if wsys_win_version_get(wid) >= 2:
        c0: uint8 = buf[0]
        if c0 == 66 or c0 == 68 or c0 == 67:           # 'B' / 'D' / 'C'
            return _wsys_blit_parse(wid, buf, count)
    p: uint64 = _wsys_tok_skip_space(buf, 0, count)
    verb_start: uint64 = p
    verb_end: uint64 = _wsys_tok_end(buf, p, count)
    if verb_start == verb_end:
        return cast[int64](count)                       # blank line
    # ls — nothing to do; the listing read regenerates on demand, so
    # the verb is accepted as a no-op (kept for spec parity).
    if _wsys_tok_eq(buf, verb_start, verb_end, "ls") != 0:
        return cast[int64](count)
    # Every other verb takes a <name> token.
    p = _wsys_tok_skip_space(buf, verb_end, count)
    name_start: uint64 = p
    name_end: uint64 = _wsys_tok_end(buf, p, count)
    namelen: uint64 = name_end - name_start
    if namelen == 0:
        return cast[int64](count)                       # missing name
    if namelen >= WSYS_DRAW_NAME_CAP:
        namelen = WSYS_DRAW_NAME_CAP - 1
    np: Ptr[uint8] = &buf[name_start]

    if _wsys_tok_eq(buf, verb_start, verb_end, "mklayer") != 0:
        return _wsys_draw_mklayer(wid, np, namelen,
                                  buf, name_end, count)
    if _wsys_tok_eq(buf, verb_start, verb_end, "rmlayer") != 0:
        idx: int32 = _wsys_draw_layer_index(wid, np, namelen)
        if idx < 0:
            return cast[int64](count)
        bx: uint64 = _wsys_draw_base(wid, cast[uint64](idx))
        # Removing a layer dirties the region it occupied (the pixels it
        # used to cover must be repainted by whatever was behind it).
        _wsys_mark_dirty(wid, wsys_layer_x[bx], wsys_layer_y[bx],
                         wsys_layer_x[bx] + wsys_layer_w[bx],
                         wsys_layer_y[bx] + wsys_layer_h[bx])
        wsys_layer_in_use[bx] = 0
        return cast[int64](count)
    if _wsys_tok_eq(buf, verb_start, verb_end, "clear") != 0:
        idx2: int32 = _wsys_draw_layer_index(wid, np, namelen)
        if idx2 < 0:
            return cast[int64](count)
        b2: uint64 = _wsys_draw_base(wid, cast[uint64](idx2))
        wsys_layer_markup_len[b2] = 0
        wsys_layer_fb_len[b2] = 0
        # `clear` changes the layer's content — bump its generation so a
        # gen-watching compositor re-reads (and repaints) the empty body.
        wsys_layer_gen[b2] = wsys_layer_gen[b2] + 1
        _wsys_mark_dirty(wid, wsys_layer_x[b2], wsys_layer_y[b2],
                         wsys_layer_x[b2] + wsys_layer_w[b2],
                         wsys_layer_y[b2] + wsys_layer_h[b2])
        return cast[int64](count)
    if _wsys_tok_eq(buf, verb_start, verb_end, "setz") != 0:
        idx3: int32 = _wsys_draw_layer_index(wid, np, namelen)
        if idx3 < 0:
            return cast[int64](count)
        b3: uint64 = _wsys_draw_base(wid, cast[uint64](idx3))
        zp: uint64 = _wsys_tok_skip_space(buf, name_end, count)
        ze: uint64 = _wsys_tok_end(buf, zp, count)
        wsys_layer_z[b3] = _wsys_tok_to_i64(buf, zp, ze)
        # A z change reorders compositing — dirty the layer's extent.
        _wsys_mark_dirty(wid, wsys_layer_x[b3], wsys_layer_y[b3],
                         wsys_layer_x[b3] + wsys_layer_w[b3],
                         wsys_layer_y[b3] + wsys_layer_h[b3])
        return cast[int64](count)
    # Unknown verb — accept-and-ignore (don't wedge a stray writer).
    return cast[int64](count)


def _wsys_draw_store_name(wid: int32, slot: uint64,
                          name: Ptr[uint8], namelen: uint64):
    nb: uint64 = _wsys_draw_name_base(wid, slot)
    i: uint64 = 0
    while i < namelen:
        wsys_layer_name[nb + i] = name[i]
        i = i + 1
    # NUL-pad the remainder so _wsys_name_match's terminator test works.
    while i < WSYS_DRAW_NAME_CAP:
        wsys_layer_name[nb + i] = 0
        i = i + 1


def _wsys_draw_mklayer(wid: int32, name: Ptr[uint8], namelen: uint64,
                       buf: Ptr[uint8], after_name: uint64,
                       count: uint64) -> int64:
    # mklayer <name> markup [w h]   |   mklayer <name> fb w h [bpp]
    # If the layer already exists, this is a no-op success (idempotent
    # re-declaration). geometry defaults to the full 640x480 window
    # for markup; fb requires w h.
    existing: int32 = _wsys_draw_layer_index(wid, name, namelen)
    if existing >= 0:
        return cast[int64](count)
    slot: int32 = _wsys_draw_free_slot(wid)
    if slot < 0:
        return -28                                      # -ENOSPC
    su: uint64 = cast[uint64](slot)
    b: uint64 = _wsys_draw_base(wid, su)
    # kind token
    kp: uint64 = _wsys_tok_skip_space(buf, after_name, count)
    ke: uint64 = _wsys_tok_end(buf, kp, count)
    kind: int32 = WSYS_LAYER_KIND_MARKUP
    if _wsys_tok_eq(buf, kp, ke, "fb") != 0:
        kind = WSYS_LAYER_KIND_FB
    # optional w h
    wp: uint64 = _wsys_tok_skip_space(buf, ke, count)
    we: uint64 = _wsys_tok_end(buf, wp, count)
    hp: uint64 = _wsys_tok_skip_space(buf, we, count)
    he: uint64 = _wsys_tok_end(buf, hp, count)
    lw: int64 = 640
    lh: int64 = 480
    if wp != we:
        lw = _wsys_tok_to_i64(buf, wp, we)
    if hp != he:
        lh = _wsys_tok_to_i64(buf, hp, he)
    # Commit the slot.
    _wsys_draw_store_name(wid, su, name, namelen)
    wsys_layer_in_use[b] = 1
    wsys_layer_kind[b] = kind
    wsys_layer_z[b] = 0
    wsys_layer_opacity[b] = 255
    wsys_layer_x[b] = 0
    wsys_layer_y[b] = 0
    wsys_layer_w[b] = lw
    wsys_layer_h[b] = lh
    wsys_layer_markup_len[b] = 0
    wsys_layer_fb_len[b] = 0
    wsys_layer_gen[b] = 0
    # A new layer dirties the region it will occupy.
    _wsys_mark_dirty(wid, 0, 0, lw, lh)
    return cast[int64](count)


# --- listing read: z-ascending one line per layer -------------------

def _wsys_emit_i64(out: Ptr[uint8], pos: uint64, v: int64) -> uint64:
    if v < 0:
        out[pos] = 45                                   # '-'
        return _wsys_u64_to_dec(cast[uint64](0 - v), &out[pos + 1]) \
            + pos + 1
    return _wsys_u64_to_dec(cast[uint64](v), &out[pos]) + pos


def _wsys_draw_lowest_unlisted_z(wid: int32, prev_z: int64,
                                 prev_slot: int32) -> int32:
    # Return the slot with the lowest z strictly greater than prev_z,
    # OR equal to prev_z but with a slot index greater than prev_slot
    # (stable tiebreak). -1 when none remain. O(n^2) selection sort
    # over <=16 slots — trivially cheap and avoids mutating storage.
    best: int32 = -1
    best_z: int64 = 0
    s: uint64 = 0
    while s < WSYS_DRAW_MAX_LAYERS:
        b: uint64 = _wsys_draw_base(wid, s)
        if wsys_layer_in_use[b] != 0:
            z: int64 = wsys_layer_z[b]
            after: int32 = 0
            if z > prev_z:
                after = 1
            elif z == prev_z and cast[int32](s) > prev_slot:
                after = 1
            if after != 0:
                if best < 0 or z < best_z:
                    best = cast[int32](s)
                    best_z = z
        s = s + 1
    return best


# --- draw-listing render CACHE (hot-path: skip re-serialisation) -----
#
# The compositor reads /dev/wsys/<N>/draw every frame to get the z-sorted
# layer listing. Regenerating it from scratch each time runs an O(n^2)
# selection sort plus a full re-serialise into scratch — wasted work when
# the window's layers haven't changed. We cache the rendered text per
# window, keyed by the window's mutation serial. A read whose window
# serial matches the cached gen reuses the bytes verbatim; any mutating
# write zeroes the cached gen (see _wsys_mark_dirty) so the next read
# regenerates exactly once. gen 0 is the "no valid cache" sentinel —
# matches the serial-starts-at-1 invariant, so a freshly-mutated window
# (serial>=1) never spuriously hits a stale gen-0 cache.
#
# Cache storage: one 4 KiB text buffer per window (same cap as the
# scratch the read handler used) plus a length + gen per window.
WSYS_DRAW_LISTING_CAP: uint64 = 4096

_wsys_draw_listing_cache: Array[131072, uint8]   # 32 * 4096
_wsys_draw_listing_cache_len: Array[32, uint64]
_wsys_draw_listing_cache_gen: Array[32, uint64]


def _wsys_render_draw_listing(wid: int32, out: Ptr[uint8],
                              cap: uint64) -> uint64:
    # One line per layer, z ascending:
    #   "<name>  z=<z>  kind=<markup|fb>  <x>x<y>..<x+w>x<y+h>  opacity=<o>\n"
    pos: uint64 = 0
    prev_z: int64 = -9223372036854775807 - 1            # INT64_MIN
    prev_slot: int32 = -1
    while True:
        slot: int32 = _wsys_draw_lowest_unlisted_z(wid, prev_z, prev_slot)
        if slot < 0:
            break
        su: uint64 = cast[uint64](slot)
        b: uint64 = _wsys_draw_base(wid, su)
        if pos + 160 >= cap:
            break
        # name
        nb: uint64 = _wsys_draw_name_base(wid, su)
        ni: uint64 = 0
        while ni < WSYS_DRAW_NAME_CAP:
            c: uint8 = wsys_layer_name[nb + ni]
            if c == 0:
                break
            out[pos] = c
            pos = pos + 1
            ni = ni + 1
        pos = _wsys_emit_str(out, pos, "  z=")
        pos = _wsys_emit_i64(out, pos, wsys_layer_z[b])
        pos = _wsys_emit_str(out, pos, "  kind=")
        if wsys_layer_kind[b] == WSYS_LAYER_KIND_FB:
            pos = _wsys_emit_str(out, pos, "fb")
        else:
            pos = _wsys_emit_str(out, pos, "markup")
        pos = _wsys_emit_str(out, pos, "  ")
        # geometry "<x>x<y>..<x+w>x<y+h>"
        pos = _wsys_emit_i64(out, pos, wsys_layer_x[b])
        out[pos] = 120                                  # 'x'
        pos = pos + 1
        pos = _wsys_emit_i64(out, pos, wsys_layer_y[b])
        pos = _wsys_emit_str(out, pos, "..")
        pos = _wsys_emit_i64(out, pos,
                             wsys_layer_x[b] + wsys_layer_w[b])
        out[pos] = 120
        pos = pos + 1
        pos = _wsys_emit_i64(out, pos,
                             wsys_layer_y[b] + wsys_layer_h[b])
        pos = _wsys_emit_str(out, pos, "  opacity=")
        pos = _wsys_emit_i64(out, pos, wsys_layer_opacity[b])
        out[pos] = 10
        pos = pos + 1
        prev_z = wsys_layer_z[b]
        prev_slot = slot
    return pos


def devwsys_draw_listing_read(wid: int32, off: uint64,
                              buf: Ptr[uint8], count: uint64) -> int64:
    if count == 0:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return -2
    u: uint64 = cast[uint64](wid)
    cbase: uint64 = u * WSYS_DRAW_LISTING_CAP
    gen: uint64 = wsys_win_serial[u]
    # Cache hit: the cached gen equals the live serial AND the cache is
    # valid (gen != 0). Reuse the stored bytes — no sort, no re-render.
    # gen 0 (a window never mutated) always re-renders the empty listing;
    # it is cheap (zero layers) and the sentinel guards against a stale
    # gen-0 cache masking a real change.
    if gen != 0 and _wsys_draw_listing_cache_gen[u] == gen:
        return _wsys_copy_out(&_wsys_draw_listing_cache[cbase],
                              _wsys_draw_listing_cache_len[u],
                              off, buf, count)
    # Cache miss: regenerate into the per-window cache buffer, then stamp
    # the gen so subsequent reads at this serial are free.
    n: uint64 = _wsys_render_draw_listing(
        wid, &_wsys_draw_listing_cache[cbase], WSYS_DRAW_LISTING_CAP)
    _wsys_draw_listing_cache_len[u] = n
    _wsys_draw_listing_cache_gen[u] = gen
    return _wsys_copy_out(&_wsys_draw_listing_cache[cbase], n,
                          off, buf, count)


# --- per-leaf read/write --------------------------------------------
#
# The layer is identified by (wid, slot). namec.ad resolves the layer
# NAME to a slot via _wsys_draw_layer_index and encodes the slot in
# the inline chan id's bits 16..23 (see _chan_id_make_inline_wsys_draw
# in namec.ad). Each leaf read/write takes (wid, slot, ...).

def _wsys_draw_slot_live(wid: int32, slot: int32) -> int32:
    if wsys_wid_in_use(wid) == 0:
        return 0
    if slot < 0:
        return 0
    su: uint64 = cast[uint64](slot)
    if su >= WSYS_DRAW_MAX_LAYERS:
        return 0
    if wsys_layer_in_use[_wsys_draw_base(wid, su)] == 0:
        return 0
    return 1


def devwsys_draw_kind_read(wid: int32, slot: int32, off: uint64,
                           buf: Ptr[uint8], count: uint64) -> int64:
    if count == 0:
        return 0
    if _wsys_draw_slot_live(wid, slot) == 0:
        return -2
    scratch: Array[16, uint8]
    b: uint64 = _wsys_draw_base(wid, cast[uint64](slot))
    n: uint64 = 0
    if wsys_layer_kind[b] == WSYS_LAYER_KIND_FB:
        n = _wsys_emit_str(&scratch[0], 0, "fb")
    else:
        n = _wsys_emit_str(&scratch[0], 0, "markup")
    scratch[n] = 10
    n = n + 1
    return _wsys_copy_out(&scratch[0], n, off, buf, count)


def devwsys_draw_z_read(wid: int32, slot: int32, off: uint64,
                        buf: Ptr[uint8], count: uint64) -> int64:
    if count == 0:
        return 0
    if _wsys_draw_slot_live(wid, slot) == 0:
        return -2
    scratch: Array[32, uint8]
    b: uint64 = _wsys_draw_base(wid, cast[uint64](slot))
    n: uint64 = _wsys_emit_i64(&scratch[0], 0, wsys_layer_z[b])
    scratch[n] = 10
    n = n + 1
    return _wsys_copy_out(&scratch[0], n, off, buf, count)


def devwsys_draw_z_write(wid: int32, slot: int32,
                         buf: Ptr[uint8], count: uint64) -> int64:
    if _wsys_draw_slot_live(wid, slot) == 0:
        return -2
    # A digit-less write (e.g. the trailing-newline flush a redirect
    # emits after the value) is a no-op — it must not reset the z just
    # set by the preceding write. Always report the bytes consumed.
    if _wsys_buf_has_digit(buf, count) == 0:
        return cast[int64](count)
    bz: uint64 = _wsys_draw_base(wid, cast[uint64](slot))
    wsys_layer_z[bz] = _wsys_tok_to_i64(buf, 0, count)
    _wsys_mark_dirty(wid, wsys_layer_x[bz], wsys_layer_y[bz],
                     wsys_layer_x[bz] + wsys_layer_w[bz],
                     wsys_layer_y[bz] + wsys_layer_h[bz])
    return cast[int64](count)


def devwsys_draw_opacity_read(wid: int32, slot: int32, off: uint64,
                              buf: Ptr[uint8], count: uint64) -> int64:
    if count == 0:
        return 0
    if _wsys_draw_slot_live(wid, slot) == 0:
        return -2
    scratch: Array[32, uint8]
    b: uint64 = _wsys_draw_base(wid, cast[uint64](slot))
    n: uint64 = _wsys_emit_i64(&scratch[0], 0, wsys_layer_opacity[b])
    scratch[n] = 10
    n = n + 1
    return _wsys_copy_out(&scratch[0], n, off, buf, count)


def devwsys_draw_opacity_write(wid: int32, slot: int32,
                               buf: Ptr[uint8], count: uint64) -> int64:
    if _wsys_draw_slot_live(wid, slot) == 0:
        return -2
    # Digit-less write is a no-op — see devwsys_draw_z_write.
    if _wsys_buf_has_digit(buf, count) == 0:
        return cast[int64](count)
    v: int64 = _wsys_tok_to_i64(buf, 0, count)
    if v < 0:
        v = 0
    if v > 255:
        v = 255
    bo: uint64 = _wsys_draw_base(wid, cast[uint64](slot))
    wsys_layer_opacity[bo] = v
    _wsys_mark_dirty(wid, wsys_layer_x[bo], wsys_layer_y[bo],
                     wsys_layer_x[bo] + wsys_layer_w[bo],
                     wsys_layer_y[bo] + wsys_layer_h[bo])
    return cast[int64](count)


def devwsys_draw_geometry_read(wid: int32, slot: int32, off: uint64,
                               buf: Ptr[uint8], count: uint64) -> int64:
    if count == 0:
        return 0
    if _wsys_draw_slot_live(wid, slot) == 0:
        return -2
    scratch: Array[80, uint8]
    b: uint64 = _wsys_draw_base(wid, cast[uint64](slot))
    pos: uint64 = 0
    pos = _wsys_emit_i64(&scratch[0], pos, wsys_layer_x[b])
    scratch[pos] = 32
    pos = pos + 1
    pos = _wsys_emit_i64(&scratch[0], pos, wsys_layer_y[b])
    scratch[pos] = 32
    pos = pos + 1
    pos = _wsys_emit_i64(&scratch[0], pos, wsys_layer_w[b])
    scratch[pos] = 32
    pos = pos + 1
    pos = _wsys_emit_i64(&scratch[0], pos, wsys_layer_h[b])
    scratch[pos] = 10
    pos = pos + 1
    return _wsys_copy_out(&scratch[0], pos, off, buf, count)


def devwsys_draw_geometry_write(wid: int32, slot: int32,
                                buf: Ptr[uint8], count: uint64) -> int64:
    # Parse "x y w h" (decimal). Missing trailing fields keep their
    # current value.
    if _wsys_draw_slot_live(wid, slot) == 0:
        return -2
    b: uint64 = _wsys_draw_base(wid, cast[uint64](slot))
    # Old extent is dirty (the layer is vacating it); union with the new
    # extent below so a MOVE repaints both the old and new boxes.
    _wsys_mark_dirty(wid, wsys_layer_x[b], wsys_layer_y[b],
                     wsys_layer_x[b] + wsys_layer_w[b],
                     wsys_layer_y[b] + wsys_layer_h[b])
    p: uint64 = _wsys_tok_skip_space(buf, 0, count)
    e: uint64 = _wsys_tok_end(buf, p, count)
    if p != e:
        wsys_layer_x[b] = _wsys_tok_to_i64(buf, p, e)
    p = _wsys_tok_skip_space(buf, e, count)
    e = _wsys_tok_end(buf, p, count)
    if p != e:
        wsys_layer_y[b] = _wsys_tok_to_i64(buf, p, e)
    p = _wsys_tok_skip_space(buf, e, count)
    e = _wsys_tok_end(buf, p, count)
    if p != e:
        wsys_layer_w[b] = _wsys_tok_to_i64(buf, p, e)
    p = _wsys_tok_skip_space(buf, e, count)
    e = _wsys_tok_end(buf, p, count)
    if p != e:
        wsys_layer_h[b] = _wsys_tok_to_i64(buf, p, e)
    # New extent is dirty too.
    _wsys_mark_dirty(wid, wsys_layer_x[b], wsys_layer_y[b],
                     wsys_layer_x[b] + wsys_layer_w[b],
                     wsys_layer_y[b] + wsys_layer_h[b])
    return cast[int64](count)


def devwsys_draw_markup_read(wid: int32, slot: int32, off: uint64,
                             buf: Ptr[uint8], count: uint64) -> int64:
    if count == 0:
        return 0
    if _wsys_draw_slot_live(wid, slot) == 0:
        return -2
    su: uint64 = cast[uint64](slot)
    b: uint64 = _wsys_draw_base(wid, su)
    n: uint64 = wsys_layer_markup_len[b]
    base: uint64 = _wsys_draw_markup_base(wid, su)
    return _wsys_copy_out(&wsys_layer_markup[base], n, off, buf, count)


def devwsys_draw_gen_read(wid: int32, slot: int32, off: uint64,
                          buf: Ptr[uint8], count: uint64) -> int64:
    # Read-only `gen` leaf: decimal content-generation counter + '\n'.
    # CHEAP by contract — renders <=20 digits into a stack scratch and
    # copies out; never touches (or consumes) the markup/fb body. A
    # compositor polls this to decide whether re-reading the body is
    # worth it.
    if count == 0:
        return 0
    if _wsys_draw_slot_live(wid, slot) == 0:
        return -2
    scratch: Array[32, uint8]
    b: uint64 = _wsys_draw_base(wid, cast[uint64](slot))
    n: uint64 = _wsys_u64_to_dec(wsys_layer_gen[b], &scratch[0])
    scratch[n] = 10
    n = n + 1
    return _wsys_copy_out(&scratch[0], n, off, buf, count)


def devwsys_draw_markup_write(wid: int32, slot: int32, off: uint64,
                              buf: Ptr[uint8], count: uint64) -> int64:
    # Whole-layer write semantics (H-§G): a write at off==0 replaces
    # the body; writes at off>0 append at that offset (so a chunked
    # writer streaming a large body still composes). Caps at
    # WSYS_DRAW_MARKUP_CAP.
    if _wsys_draw_slot_live(wid, slot) == 0:
        return -2
    su: uint64 = cast[uint64](slot)
    b: uint64 = _wsys_draw_base(wid, su)
    base: uint64 = _wsys_draw_markup_base(wid, su)
    if off >= WSYS_DRAW_MARKUP_CAP:
        return 0
    take: uint64 = count
    if off + take > WSYS_DRAW_MARKUP_CAP:
        take = WSYS_DRAW_MARKUP_CAP - off
    i: uint64 = 0
    while i < take:
        wsys_layer_markup[base + off + i] = buf[i]
        i = i + 1
    end: uint64 = off + take
    if end > wsys_layer_markup_len[b]:
        wsys_layer_markup_len[b] = end
    # Content changed — bump the layer's generation counter (gen leaf).
    if take > 0:
        wsys_layer_gen[b] = wsys_layer_gen[b] + 1
    # New markup content dirties the layer's full extent.
    _wsys_mark_dirty(wid, wsys_layer_x[b], wsys_layer_y[b],
                     wsys_layer_x[b] + wsys_layer_w[b],
                     wsys_layer_y[b] + wsys_layer_h[b])
    return cast[int64](take)


def devwsys_draw_fb_read(wid: int32, slot: int32, off: uint64,
                         buf: Ptr[uint8], count: uint64) -> int64:
    if count == 0:
        return 0
    if _wsys_draw_slot_live(wid, slot) == 0:
        return -2
    su: uint64 = cast[uint64](slot)
    b: uint64 = _wsys_draw_base(wid, su)
    n: uint64 = wsys_layer_fb_len[b]
    fbp: Ptr[uint8] = _wsys_layer_fb_get(wid)
    if cast[uint64](fbp) == 0:
        return 0                                # never drawn -> empty
    base: uint64 = _wsys_layer_fb_off(su)
    return _wsys_copy_out(&fbp[base], n, off, buf, count)


def devwsys_draw_fb_write(wid: int32, slot: int32, off: uint64,
                          buf: Ptr[uint8], count: uint64) -> int64:
    if _wsys_draw_slot_live(wid, slot) == 0:
        return -2
    su: uint64 = cast[uint64](slot)
    b: uint64 = _wsys_draw_base(wid, su)
    if off >= WSYS_DRAW_FB_CAP:
        return 0
    fbp: Ptr[uint8] = _wsys_layer_fb_ensure(wid)
    if cast[uint64](fbp) == 0:
        return -12                              # -ENOMEM: no backing block
    base: uint64 = _wsys_layer_fb_off(su)
    take: uint64 = count
    if off + take > WSYS_DRAW_FB_CAP:
        take = WSYS_DRAW_FB_CAP - off
    # FOOTPRINT (QA-N25): the backing block is no longer eagerly zeroed on
    # allocation, so guard the "unwritten bytes below the high-water mark read
    # as zero" contract here. If this write starts ABOVE the current fb_len it
    # leaves a hole [fb_len, off) that a later read (bounded by fb_len) could
    # otherwise expose as stale bytes — zero exactly that hole. For the common
    # contiguous case (off <= fb_len, e.g. a whole wl_shm buffer commit) this
    # loop does nothing and no untouched pages are faulted in.
    prev_len: uint64 = wsys_layer_fb_len[b]
    if off > prev_len:
        j: uint64 = prev_len
        while j < off:
            fbp[base + j] = 0
            j = j + 1
    i: uint64 = 0
    while i < take:
        fbp[base + off + i] = buf[i]
        i = i + 1
    end: uint64 = off + take
    if end > wsys_layer_fb_len[b]:
        wsys_layer_fb_len[b] = end
    # Content changed — bump the layer's generation counter (gen leaf).
    if take > 0:
        wsys_layer_gen[b] = wsys_layer_gen[b] + 1
    # Refine the dirty rect to the affected pixel ROWS: the fb is row-
    # major RGBA8888 at the layer's width, so map the touched byte range
    # [off, off+take) to a row span and dirty the full-width strip those
    # rows cover. Falls back to the whole layer extent if width is 0.
    _wsys_mark_dirty_fb_rows(wid, b, off, take)
    return cast[int64](take)


def _wsys_mark_dirty_fb_rows(wid: int32, b: uint64,
                             off: uint64, take: uint64):
    # Translate a byte range written into an fb (row-major RGBA8888 at the
    # layer's width) into a window-local dirty rectangle covering the full
    # width of the rows the bytes fall in.
    lw: int64 = wsys_layer_w[b]
    lx: int64 = wsys_layer_x[b]
    ly: int64 = wsys_layer_y[b]
    if lw <= 0:
        # Unknown stride — dirty the whole layer extent conservatively.
        _wsys_mark_dirty(wid, lx, ly, lx + lw, ly + wsys_layer_h[b])
        return
    bytes_per_row: uint64 = cast[uint64](lw) * 4
    if bytes_per_row == 0:
        _wsys_mark_dirty(wid, lx, ly, lx + lw, ly + wsys_layer_h[b])
        return
    row0: uint64 = off / bytes_per_row
    row1: uint64 = (off + take + bytes_per_row - 1) / bytes_per_row
    y0: int64 = ly + cast[int64](row0)
    y1: int64 = ly + cast[int64](row1)
    _wsys_mark_dirty(wid, lx, y0, lx + lw, y1)


# --- name->slot resolution for namec --------------------------------
#
# namec.ad calls this to map a layer-name substring of a path to its
# slot, which it then folds into the inline chan id. -1 means "no such
# layer" (namec returns ENOENT).

def wsys_draw_resolve_layer(wid: int32, name: Ptr[uint8],
                            namelen: uint64) -> int32:
    if wsys_wid_in_use(wid) == 0:
        return -1
    return _wsys_draw_layer_index(wid, name, namelen)


# --- programmatic (in-kernel) draw-surface helpers ------------------
#
# GPU track #183 (native Vulkan output into a real desktop window). The
# kernel-side Vulkan spine (lib/vk) renders a window's content and needs
# to deposit it into the SAME per-window draw FILE SURFACE that a normal
# userland app paints into (so hamUId composites it like any other
# window). These helpers are the programmatic twins of the text "mklayer
# <name> fb W H" ctl verb + the /dev/wsys/<wid>/draw/<name>/fb byte
# write, callable from kernel code without round-tripping through the
# cdev's text parser. They reuse the exact same storage and metadata as
# the userland path, so a layer created here is indistinguishable from
# one created via ctl — devwsys_draw_listing_read lists it, the daemon's
# composite_fb_layer reads it, etc.

def wsys_draw_ensure_fb_layer(wid: int32, name: Ptr[uint8],
                              namelen: uint64,
                              w: int64, h: int64) -> int32:
    # Find-or-create an fb layer named `name` for `wid`, sized w x h.
    # Returns the layer slot (0..MAX_LAYERS-1) or a negative errno.
    # Idempotent: an existing same-named layer is reused (and its
    # geometry refreshed to w x h) rather than duplicated.
    if wsys_wid_in_use(wid) == 0:
        return -2                                       # -ENOENT
    if namelen == 0 or namelen >= WSYS_DRAW_NAME_CAP:
        return -22                                      # -EINVAL
    existing: int32 = _wsys_draw_layer_index(wid, name, namelen)
    if existing >= 0:
        be: uint64 = _wsys_draw_base(wid, cast[uint64](existing))
        wsys_layer_kind[be] = WSYS_LAYER_KIND_FB
        wsys_layer_w[be] = w
        wsys_layer_h[be] = h
        _wsys_mark_dirty(wid, wsys_layer_x[be], wsys_layer_y[be],
                         wsys_layer_x[be] + w, wsys_layer_y[be] + h)
        return existing
    slot: int32 = _wsys_draw_free_slot(wid)
    if slot < 0:
        return -28                                      # -ENOSPC
    su: uint64 = cast[uint64](slot)
    b: uint64 = _wsys_draw_base(wid, su)
    _wsys_draw_store_name(wid, su, name, namelen)
    wsys_layer_in_use[b] = 1
    wsys_layer_kind[b] = WSYS_LAYER_KIND_FB
    wsys_layer_z[b] = 0
    wsys_layer_opacity[b] = 255
    wsys_layer_x[b] = 0
    wsys_layer_y[b] = 0
    wsys_layer_w[b] = w
    wsys_layer_h[b] = h
    wsys_layer_markup_len[b] = 0
    wsys_layer_fb_len[b] = 0
    wsys_layer_gen[b] = 0
    _wsys_mark_dirty(wid, 0, 0, w, h)
    return slot


def wsys_draw_fb_store(wid: int32, slot: int32,
                       src: Ptr[uint8], count: uint64) -> int64:
    # Whole-layer fb write at offset 0 from a kernel RGBA8888 buffer.
    # Mirrors devwsys_draw_fb_write(wid, slot, 0, ...). Caps at
    # WSYS_DRAW_FB_CAP. Returns bytes stored, or a negative errno.
    if _wsys_draw_slot_live(wid, slot) == 0:
        return -2
    su: uint64 = cast[uint64](slot)
    b: uint64 = _wsys_draw_base(wid, su)
    fbp: Ptr[uint8] = _wsys_layer_fb_ensure(wid)
    if cast[uint64](fbp) == 0:
        return -12                              # -ENOMEM: no backing block
    base: uint64 = _wsys_layer_fb_off(su)
    take: uint64 = count
    if take > WSYS_DRAW_FB_CAP:
        take = WSYS_DRAW_FB_CAP
    i: uint64 = 0
    while i < take:
        fbp[base + i] = src[i]
        i = i + 1
    wsys_layer_fb_len[b] = take
    # Content changed — bump the layer's generation counter (gen leaf).
    if take > 0:
        wsys_layer_gen[b] = wsys_layer_gen[b] + 1
    # Whole-layer fb store dirties the layer's full extent.
    _wsys_mark_dirty(wid, wsys_layer_x[b], wsys_layer_y[b],
                     wsys_layer_x[b] + wsys_layer_w[b],
                     wsys_layer_y[b] + wsys_layer_h[b])
    return cast[int64](take)


# ====================================================================
# F2 #447 — /dev/wsys/ctl: system-wide wsys control file
#
# Plan-9-shape replacement for SYS_WSYS_ALLOC (293), SYS_WSYS_FREE
# (294), and SYS_VK_WINDOW_FRAME (312). Writers send one ASCII verb
# line:
#
#   alloc <pid>         claim the lowest free wid (2..MAX_WINDOWS-1)
#                       for the bound shell pid; the assigned wid is
#                       stashed in wsys_last_alloc_wid and the write
#                       returns `bytes_consumed`. A subsequent read on
#                       the same fd renders the assigned wid as
#                       "<n>\n" (digits decimal), matching the
#                       /dev/auth open/write/read/close idiom.
#   free <wid>          release the named wid (>=2). wid 1 is reserved
#                       for the foreground and is rejected.
#   frame <wid> <n>     render Vulkan frame n into the named window
#                       via the kernel software rasterizer.
#
# Hostowner-only — same threat model as the syscalls this replaces
# (only the trusted DE may bind windows). The gate is `uid != 1` and
# matches SYS_WSYS_ALLOC's gate in arch/x86/kernel/syscall.ad.
#
# DELIBERATELY MINIMUM VIABLE: the surface stays narrow so #442
# wsys/rio reshape can extend it (additional verbs for chrome,
# focus, snarf, ...) without conflicting with what landed here. The
# verb table is the authoritative list — extending it is a Plan-9
# version bump.

# Global response slot for the "alloc" verb. Written by the wsys ctl
# write arm on a successful alloc; read by the wsys ctl read arm. With
# the hostowner-only producer there is a single writer; a read consumes
# the slot (write a 0 sentinel afterwards) so back-to-back alloc/read
# pairs work cleanly. -1 means "no result pending" — the read renders
# "0\n" in that case to match Plan 9 ctl-file shape (a read of a ctl
# with no result is empty / harmless).
wsys_last_alloc_wid: int32 = -1

# PER-PID pending-alloc table (multi-window taskbar race fix).
#
# /dev/wsys/ctl is a SHARED file. A `newwindow` write followed by a separate
# open+read to fetch the assigned wid is NOT atomic across processes: when the
# panel launches several apps at once, each app's `newwindow`/read interleaves
# with its siblings'. A single global result slot would either cross-deliver a
# wid (two apps drive ONE window; the rest never decorate and vanish from the
# taskbar — the reported bug) or be clobbered (an app reads empty and gets no
# window). Instead, EACH `newwindow` stashes its (pid -> wid) result in this
# small table; the readback pops the entry matching the CALLING pid. So every
# concurrently-launching app reliably reads back its OWN wid. Capacity =
# MAX_WINDOWS (the alloc ceiling); on overflow we fall back to the legacy
# single global below.
WSYS_PENDING_MAX: uint64 = 32
wsys_pending_pid: Array[32, uint64]               # 0 = empty entry
wsys_pending_wid: Array[32, int32]


def _wsys_pending_put(pid: uint64, wid: int32):
    # Record (pid -> wid). Replace an existing entry for the same pid (a
    # process that allocs again before reading the first — e.g. the panel's
    # per-panel loop reads between allocs, but be defensive), else take a
    # free slot. On a full table the caller falls back to the global.
    i: uint64 = 0
    while i < WSYS_PENDING_MAX:
        if wsys_pending_pid[i] == pid:
            wsys_pending_wid[i] = wid
            return
        i = i + 1
    i = 0
    while i < WSYS_PENDING_MAX:
        if wsys_pending_pid[i] == 0:
            wsys_pending_pid[i] = pid
            wsys_pending_wid[i] = wid
            return
        i = i + 1


def _wsys_pending_take(pid: uint64) -> int32:
    # Pop and return the wid stashed for `pid`, or -1 if none.
    i: uint64 = 0
    while i < WSYS_PENDING_MAX:
        if wsys_pending_pid[i] == pid:
            v: int32 = wsys_pending_wid[i]
            wsys_pending_pid[i] = 0
            wsys_pending_wid[i] = 0
            return v
        i = i + 1
    return -1


# DE image-wallpaper state: the `wallpaper <path>` verb on /dev/wsys/ctl
# records the requested PPM path here. The compositor (user/hamUId.ad)
# polls the matching readable status file /dev/wsys/wallpaper for
# "<gen> <path>\n"; on a gen bump it reloads the named PPM and blits it
# into the root backdrop. WSYS_WALLPAPER_PATH_CAP is generous (256 bytes
# fits any sane /etc/wallpapers/... or /home/<user>/... path); longer
# requests are rejected by the verb gate. gen is monotonically increasing
# — a zero gen on the read side means "no wallpaper set yet" and the
# compositor falls back to the solid backdrop palette.
WSYS_WALLPAPER_PATH_CAP: uint64 = 256
wsys_wallpaper_path: Array[256, uint8]
wsys_wallpaper_path_len: uint64 = 0
wsys_wallpaper_gen: uint64 = 0

# A.1: the wsys_nudge_* counters are RETIRED along with the nudge/drag verbs.
# Cursor-FPS is now measured in the compositor (user/hamUId.ad).

# DE virtual-workspace request slot: the `ws <N>` verb on /dev/wsys/ctl
# records the requested 0-based workspace here. The compositor
# (user/hamUId.ad) polls /dev/wsys/workspace for "<gen> <ws>\n" once per
# main-loop tick and, on a gen bump, calls workspace_switch(ws). N is
# 1-based on the wire (1..WS_MAX) to match the hambottom switcher labels;
# we store the 0-based ws here so the compositor's CUR_WS comparison is
# direct. gen is monotonically increasing — gen=0 means "no request yet"
# and the compositor leaves CUR_WS alone.
wsys_workspace_req: int32 = 0
wsys_workspace_gen: uint64 = 0

# KERNEL-OWNED virtual-desktop visibility. In the SCENE DE the kernel
# compositor (this file) is the thing that actually rasterizes + z-blits
# scene windows to /dev/fb — the legacy userland hamUId present is retired
# (see etc/rc.d/rc.5). So WORKSPACE ISOLATION (showing only the active
# desktop's windows) must live HERE, not in hamUId. wsys_cur_ws is the
# active 0-based desktop; wsys_win_ws[wid] is each window's home desktop.
#
# Stickiness rule (MATE-parity): only DECORATED windows (decorate != 0 =
# real app windows with a titlebar) are workspace-bound. Undecorated chrome
# (panels, the desktop backdrop, menus/dropdowns, toasts, the cursor) is
# decorate 0 and is shown on EVERY workspace, exactly as MATE keeps panels
# and the desktop on all virtual desktops. A window adopts wsys_cur_ws at
# the instant it declares itself an app window (the `decorate 1` ctl write).
wsys_cur_ws: int32 = 0


def wsys_wallpaper_generation() -> uint64:
    return wsys_wallpaper_gen


def _wsys_ctl_is_ws(c: uint8) -> int32:
    if c == 32 or c == 9 or c == 10 or c == 13:
        return 1
    return 0


def _wsys_ctl_skip_ws(buf: Ptr[uint8], pos: uint64, count: uint64) -> uint64:
    p: uint64 = pos
    while p < count and _wsys_ctl_is_ws(buf[p]) == 1:
        p = p + 1
    return p


def _wsys_ctl_token_end(buf: Ptr[uint8], pos: uint64, count: uint64) -> uint64:
    p: uint64 = pos
    while p < count and _wsys_ctl_is_ws(buf[p]) == 0:
        p = p + 1
    return p


def _wsys_ctl_word_eq(buf: Ptr[uint8], start: uint64, end: uint64,
                      word: Ptr[uint8]) -> int32:
    wl: uint64 = 0
    while word[wl] != 0:
        wl = wl + 1
    if end - start != wl:
        return 0
    i: uint64 = 0
    while i < wl:
        if buf[start + i] != word[i]:
            return 0
        i = i + 1
    return 1


def _wsys_ctl_parse_u64(buf: Ptr[uint8], start: uint64, end: uint64,
                        out: Ptr[uint64]) -> int32:
    # Parse a non-negative decimal integer in buf[start..end). Returns 1
    # on success (value written through `out`), 0 on a non-digit or
    # empty range.
    if start >= end:
        return 0
    v: uint64 = 0
    p: uint64 = start
    while p < end:
        c: uint8 = buf[p]
        if c < 48 or c > 57:
            return 0
        v = v * 10 + cast[uint64](c) - 48
        p = p + 1
    out[0] = v
    return 1


# F2 #447 / audit §4 thin-shim conversion: the SYS_WSYS_ALLOC syscall arm
# (arch/x86/kernel/syscall.ad) calls devwsys_ctl_write with "alloc <pid>\n"
# and then reads back the assigned wid through this consumer. Mirrors what
# the /dev/wsys/ctl read-back path does (devwsys_ctl_read), but returns an
# int32 directly instead of rendering decimal text. Resets the slot to -1
# on read so a back-to-back alloc/free pair behaves identically through the
# syscall and ctl-file paths.
def wsys_last_alloc_wid_consume() -> int32:
    v: int32 = wsys_last_alloc_wid
    wsys_last_alloc_wid = -1
    return v


def devwsys_ctl_write(buf: Ptr[uint8], count: uint64) -> int64:
    # F2 #447 system-wide wsys-ctl writer. Hostowner-only — non-uid-1
    # callers get -EPERM. Returns the count consumed on success or -1
    # with errstr on a parse/policy failure.
    #
    # Scene-file DE (docs/de_scene_file_arch.md): the `newwindow` verb is
    # the EXCEPTION to the hostowner gate. A client creates its OWN window
    # by writing "newwindow" with no argument; the assigned wid is stashed
    # in wsys_last_alloc_wid, and a subsequent READ on the same /dev/wsys/ctl
    # returns it as decimal. The caller owns its <wid>/scene + ctl + event.
    #
    # MULTI-WINDOW: a process may call `newwindow` REPEATEDLY to open many
    # windows (a main window + popups/dialogs). Each returns a fresh wid the
    # client drives via /dev/wsys/<wid>/{scene,ctl,event}. A popup anchors
    # to its opener with `parent <pwid> <dx> <dy>` on its OWN <wid>/ctl. The
    # legacy hostowner-on-behalf `alloc <pid>` path is unchanged. Parsed
    # FIRST, before the hostowner gate, so a NOBODY-uid app can self-serve
    # a window.
    if count == 0:
        return 0
    p0: uint64 = _wsys_ctl_skip_ws(buf, 0, count)
    vs0: uint64 = p0
    p0 = _wsys_ctl_token_end(buf, p0, count)
    ve0: uint64 = p0
    if _wsys_ctl_word_eq(buf, vs0, ve0, "newwindow") == 1:
        mypid: uint64 = current_task_pid()
        nw: int32 = wsys_alloc_wid(mypid)
        if nw < 0:
            set_current_errstr("/dev/wsys/ctl: newwindow: table full")
            return -1
        # #99 launch-render proof: a greppable marker every time a client
        # self-serves a window. A launch-queue-spawned app (drained by the
        # panel from /dev/wsys/{run,appmenu}/launch) reaching this line is
        # the direct evidence its window was allocated + mapped. Emit at WARN
        # so it survives console_set_interactive()'s post-boot INFO gate —
        # otherwise the markers for apps launched AFTER the DE comes up (the
        # exact case under test) are silenced and never reach the serial log.
        printk_set_level(PRINTK_LEVEL_WARN)
        printk2(cast[Ptr[char]]("[devwsys] window %d mapped pid=%d\n"),
                cast[uint64](nw), mypid)
        # Stash the result KEYED TO THIS pid so a sibling app's concurrent
        # newwindow cannot steal or clobber it on readback (multi-window
        # taskbar fix). Keep wsys_last_alloc_wid as a legacy fallback too.
        _wsys_pending_put(mypid, nw)
        wsys_last_alloc_wid = nw
        return cast[int64](count)

    # `desktop` — the rl5 flip: latch the scene compositor as the SOLE
    # owner of /dev/fb (docs/de_scene_file_arch.md §16 step 5). The DE
    # startup hook writes this once; thereafter every full present paints
    # the desktop root backdrop first. Parsed BEFORE the hostowner gate
    # (like newwindow) because the DE now runs as the default NOBODY uid,
    # not hostowner — the rl5 flip is the DE claiming its own screen.
    if _wsys_ctl_word_eq(buf, vs0, ve0, "desktop") == 1:
        wsys_root_active = 1
        # Force the one-shot backdrop paint on this (re)activation; the
        # first present below clears the screen once, then never again.
        wsys_bg_painted = 0
        # Suspend the kernel fb-text console so boot/printk text no longer
        # draws over the composited desktop (the scene compositor is the
        # sole fb owner now). fb_putc becomes a no-op; the shadow grid is
        # preserved so a later resume (logout) repaints the console.
        fb_console_suspend()
        _wsys_scene_init_if_needed()
        # LIVE-MOUSE FIX: seed the cursor sprite at screen-center NOW so it
        # is ALWAYS visible from the desktop flip — before any mouse event.
        # On real QEMU (PS/2 relative mouse) the host hides its pointer on
        # click-grab, so the GUEST must draw its own cursor from boot; if we
        # waited for the first event the cursor would be invisible until the
        # user moved, and on a relative device the first delta is tiny.
        if fb_get_initialized() != 0:
            csw: int64 = cast[int64](fb_get_width())
            csh: int64 = cast[int64](fb_get_height())
            if csw > 0 and csh > 0 and wsys_cursor_inited == 0:
                wsys_cursor_x = csw / 2
                wsys_cursor_y = csh / 2
                wsys_cursor_inited = 1
            _wsys_cursor_set_scene(wsys_cursor_x, wsys_cursor_y)
        wsys_scene_present()
        return cast[int64](count)

    if current_task_is_hostowner() == 0:
        set_current_errstr("/dev/wsys/ctl: permission denied (not hostowner)")
        return -1
    p: uint64 = _wsys_ctl_skip_ws(buf, 0, count)
    vs: uint64 = p
    p = _wsys_ctl_token_end(buf, p, count)
    ve: uint64 = p
    if vs == ve:
        set_current_errstr("/dev/wsys/ctl: missing verb")
        return -1

    # `wallpaper <path>` — record the requested PPM path for the
    # compositor's image-backdrop loader. Stored in wsys_wallpaper_path;
    # wsys_wallpaper_gen is bumped so the compositor's poll-read on
    # /dev/wsys/wallpaper observes the change and reloads. Parsed BEFORE
    # the numeric-arg block because the argument here is a path string,
    # not a u64 — and a path may legitimately start with a non-digit.
    # `setapp <wid> <path>` — register the program path that was just
    # spawned into `<wid>`. The compositor calls this after each
    # daemon_spawn_window_prog so /dev/wsys/session can render a
    # replay-able snapshot. Parsed in the same string-arg block as
    # wallpaper because the trailing token is a path, not a u64.
    if _wsys_ctl_word_eq(buf, vs, ve, "setapp") == 1:
        sp1: uint64 = _wsys_ctl_skip_ws(buf, p, count)
        sp2: uint64 = _wsys_ctl_token_end(buf, sp1, count)
        if sp1 == sp2:
            set_current_errstr("/dev/wsys/ctl: setapp: missing wid")
            return -1
        widu: uint64 = 0
        if _wsys_ctl_parse_u64(buf, sp1, sp2, &widu) == 0:
            set_current_errstr("/dev/wsys/ctl: setapp: bad wid")
            return -1
        if widu == 0 or widu >= MAX_WINDOWS:
            set_current_errstr("/dev/wsys/ctl: setapp: wid out of range")
            return -1
        if wsys_slot_in_use[widu] == 0:
            set_current_errstr("/dev/wsys/ctl: setapp: wid not in use")
            return -1
        ps2: uint64 = _wsys_ctl_skip_ws(buf, sp2, count)
        pe2: uint64 = count
        while pe2 > ps2 and _wsys_ctl_is_ws(buf[pe2 - 1]) == 1:
            pe2 = pe2 - 1
        if ps2 == pe2:
            set_current_errstr("/dev/wsys/ctl: setapp: missing path")
            return -1
        plen2: uint64 = pe2 - ps2
        if plen2 >= WSYS_APP_PATH_CAP:
            set_current_errstr("/dev/wsys/ctl: setapp: path too long")
            return -1
        rc2: int32 = wsys_app_path_set(cast[int32](widu),
                                       &buf[ps2], plen2)
        if rc2 < 0:
            set_current_errstr("/dev/wsys/ctl: setapp: store failed")
            return -1
        return cast[int64](count)

    # `appmenu <payload>` — replace the Applications-menu catalogue
    # snapshot served on /dev/wsys/appmenu. Hostowner-only (matches the
    # rest of /dev/wsys/ctl). The compositor calls this once on startup
    # with the line-oriented catalogue body (see devwsys_appmenu_read).
    if _wsys_ctl_word_eq(buf, vs, ve, "appmenu") == 1:
        aps: uint64 = p
        # Skip exactly one separating space so the payload preserves any
        # embedded structure (the trailing '\n's matter).
        if aps < count and buf[aps] == 32:
            aps = aps + 1
        ape: uint64 = count
        # Strip a single trailing newline at most (writers commonly append
        # one); preserve internal '\n' separators that the snapshot needs.
        if ape > aps and buf[ape - 1] == 10:
            ape = ape - 1
        alen: uint64 = ape - aps
        if wsys_appmenu_set(&buf[aps], alen) < 0:
            set_current_errstr("/dev/wsys/ctl: appmenu: payload too large")
            return -1
        return cast[int64](count)

    # `cycler <open> <sel> <payload>` — replace the Alt-Tab switcher
    # model. <open> and <sel> are small decimal integers, then a single
    # space, then a line-oriented payload of "W <wid> <title>\n" rows
    # for each candidate. Hostowner-only (matches the rest of
    # /dev/wsys/ctl).
    if _wsys_ctl_word_eq(buf, vs, ve, "cycler") == 1:
        cp: uint64 = p
        cp = _wsys_ctl_skip_ws(buf, cp, count)
        open_v: int64 = 0
        cp_open_start: uint64 = cp
        while cp < count and buf[cp] >= 48 and buf[cp] <= 57:
            open_v = open_v * 10 + cast[int64](buf[cp] - 48)
            cp = cp + 1
        if cp == cp_open_start:
            set_current_errstr("/dev/wsys/ctl: cycler: missing open flag")
            return -1
        cp = _wsys_ctl_skip_ws(buf, cp, count)
        sel_v: int64 = 0
        cp_sel_start: uint64 = cp
        while cp < count and buf[cp] >= 48 and buf[cp] <= 57:
            sel_v = sel_v * 10 + cast[int64](buf[cp] - 48)
            cp = cp + 1
        if cp == cp_sel_start:
            set_current_errstr("/dev/wsys/ctl: cycler: missing sel index")
            return -1
        # Exactly one separating space, then payload extends to EOF (one
        # trailing '\n' stripped if present).
        if cp < count and buf[cp] == 32:
            cp = cp + 1
        cpe: uint64 = count
        if cpe > cp and buf[cpe - 1] == 10:
            cpe = cpe - 1
        clen: uint64 = cpe - cp
        if wsys_cycler_set(&buf[cp], clen,
                           cast[int32](open_v), cast[int32](sel_v)) < 0:
            set_current_errstr("/dev/wsys/ctl: cycler: payload too large")
            return -1
        return cast[int64](count)

    # `calpop <open> <year> <month> <day> <valid>` — DE pivot wave 4.
    # Publish the clock-drop calendar popup model so /bin/hamcalpop can
    # rasterise it. All five fields are small decimal integers.
    # Hostowner-only (matches the rest of /dev/wsys/ctl).
    if _wsys_ctl_word_eq(buf, vs, ve, "calpop") == 1:
        kp: uint64 = p
        kp = _wsys_ctl_skip_ws(buf, kp, count)
        kopen: int64 = 0
        kp_open_start: uint64 = kp
        while kp < count and buf[kp] >= 48 and buf[kp] <= 57:
            kopen = kopen * 10 + cast[int64](buf[kp] - 48)
            kp = kp + 1
        if kp == kp_open_start:
            set_current_errstr("/dev/wsys/ctl: calpop: missing open flag")
            return -1
        kp = _wsys_ctl_skip_ws(buf, kp, count)
        kyear: int64 = 0
        kp_year_start: uint64 = kp
        while kp < count and buf[kp] >= 48 and buf[kp] <= 57:
            kyear = kyear * 10 + cast[int64](buf[kp] - 48)
            kp = kp + 1
        if kp == kp_year_start:
            set_current_errstr("/dev/wsys/ctl: calpop: missing year")
            return -1
        kp = _wsys_ctl_skip_ws(buf, kp, count)
        kmonth: int64 = 0
        kp_month_start: uint64 = kp
        while kp < count and buf[kp] >= 48 and buf[kp] <= 57:
            kmonth = kmonth * 10 + cast[int64](buf[kp] - 48)
            kp = kp + 1
        if kp == kp_month_start:
            set_current_errstr("/dev/wsys/ctl: calpop: missing month")
            return -1
        kp = _wsys_ctl_skip_ws(buf, kp, count)
        kday: int64 = 0
        kp_day_start: uint64 = kp
        while kp < count and buf[kp] >= 48 and buf[kp] <= 57:
            kday = kday * 10 + cast[int64](buf[kp] - 48)
            kp = kp + 1
        if kp == kp_day_start:
            set_current_errstr("/dev/wsys/ctl: calpop: missing day")
            return -1
        kp = _wsys_ctl_skip_ws(buf, kp, count)
        kvalid: int64 = 0
        kp_valid_start: uint64 = kp
        while kp < count and buf[kp] >= 48 and buf[kp] <= 57:
            kvalid = kvalid * 10 + cast[int64](buf[kp] - 48)
            kp = kp + 1
        if kp == kp_valid_start:
            set_current_errstr("/dev/wsys/ctl: calpop: missing valid flag")
            return -1
        wsys_calpop_set(cast[int32](kopen), kyear, kmonth, kday,
                        cast[int32](kvalid))
        return cast[int64](count)

    # `notif <active> <alpha> <title>\t<body>` — DE pivot wave 7. Publish
    # the notification-toast model so /bin/hamnotif can rasterise it.
    # <active> and <alpha> are small decimal integers; the rest of the
    # buffer is the title + body, separated by a single TAB ('\t'). Either
    # text may be empty. The final '\n' is stripped if present.
    # Hostowner-only (matches the rest of /dev/wsys/ctl).
    if _wsys_ctl_word_eq(buf, vs, ve, "notif") == 1:
        np: uint64 = p
        np = _wsys_ctl_skip_ws(buf, np, count)
        nactive: int64 = 0
        np_active_start: uint64 = np
        while np < count and buf[np] >= 48 and buf[np] <= 57:
            nactive = nactive * 10 + cast[int64](buf[np] - 48)
            np = np + 1
        if np == np_active_start:
            set_current_errstr("/dev/wsys/ctl: notif: missing active flag")
            return -1
        np = _wsys_ctl_skip_ws(buf, np, count)
        nalpha: int64 = 0
        np_alpha_start: uint64 = np
        while np < count and buf[np] >= 48 and buf[np] <= 57:
            nalpha = nalpha * 10 + cast[int64](buf[np] - 48)
            np = np + 1
        if np == np_alpha_start:
            set_current_errstr("/dev/wsys/ctl: notif: missing alpha")
            return -1
        # Skip exactly one separator space, then the rest of the line is
        # "<title>\t<body>" (either may be empty). One trailing '\n' is
        # stripped if present.
        if np < count and buf[np] == 32:
            np = np + 1
        nend: uint64 = count
        while nend > np and (buf[nend - 1] == 10 or buf[nend - 1] == 13):
            nend = nend - 1
        # Locate the TAB separating title from body.
        ntab: uint64 = np
        while ntab < nend and buf[ntab] != 9:
            ntab = ntab + 1
        ntitle_len: uint64 = ntab - np
        nbody_start: uint64 = ntab
        if nbody_start < nend:
            nbody_start = nbody_start + 1                  # skip the TAB
        nbody_len: uint64 = nend - nbody_start
        if wsys_notif_set(cast[int32](nactive), cast[int32](nalpha),
                          &buf[np], ntitle_len,
                          &buf[nbody_start], nbody_len) < 0:
            return -1
        return cast[int64](count)

    # `lock <locked> <fails>` — DE pivot wave 5. Publish the screen-lock
    # model so /bin/hamlock can rasterise it. Both fields are small decimal
    # integers. Hostowner-only (matches the rest of /dev/wsys/ctl).
    if _wsys_ctl_word_eq(buf, vs, ve, "lock") == 1:
        lp: uint64 = p
        lp = _wsys_ctl_skip_ws(buf, lp, count)
        llocked: int64 = 0
        lp_locked_start: uint64 = lp
        while lp < count and buf[lp] >= 48 and buf[lp] <= 57:
            llocked = llocked * 10 + cast[int64](buf[lp] - 48)
            lp = lp + 1
        if lp == lp_locked_start:
            set_current_errstr("/dev/wsys/ctl: lock: missing locked flag")
            return -1
        lp = _wsys_ctl_skip_ws(buf, lp, count)
        lfails: int64 = 0
        lp_fails_start: uint64 = lp
        while lp < count and buf[lp] >= 48 and buf[lp] <= 57:
            lfails = lfails * 10 + cast[int64](buf[lp] - 48)
            lp = lp + 1
        if lp == lp_fails_start:
            set_current_errstr("/dev/wsys/ctl: lock: missing fails counter")
            return -1
        wsys_lock_set(cast[int32](llocked), cast[int32](lfails))
        return cast[int64](count)

    # `rband <active> <x0> <y0> <x1> <y1>` — DE pivot wave 7. Publish the
    # rubber-band drag-to-create overlay model so /bin/hamrband can
    # rasterise the dashed outline. Five small decimal ints. Hostowner-
    # only (matches the rest of /dev/wsys/ctl).
    if _wsys_ctl_word_eq(buf, vs, ve, "rband") == 1:
        rbp: uint64 = p
        rbp = _wsys_ctl_skip_ws(buf, rbp, count)
        rb_active: int64 = 0
        rb_a_start: uint64 = rbp
        while rbp < count and buf[rbp] >= 48 and buf[rbp] <= 57:
            rb_active = rb_active * 10 + cast[int64](buf[rbp] - 48)
            rbp = rbp + 1
        if rbp == rb_a_start:
            set_current_errstr("/dev/wsys/ctl: rband: missing active flag")
            return -1
        rbp = _wsys_ctl_skip_ws(buf, rbp, count)
        rb_x0: int64 = 0
        rb_x0_start: uint64 = rbp
        while rbp < count and buf[rbp] >= 48 and buf[rbp] <= 57:
            rb_x0 = rb_x0 * 10 + cast[int64](buf[rbp] - 48)
            rbp = rbp + 1
        if rbp == rb_x0_start:
            set_current_errstr("/dev/wsys/ctl: rband: missing x0")
            return -1
        rbp = _wsys_ctl_skip_ws(buf, rbp, count)
        rb_y0: int64 = 0
        rb_y0_start: uint64 = rbp
        while rbp < count and buf[rbp] >= 48 and buf[rbp] <= 57:
            rb_y0 = rb_y0 * 10 + cast[int64](buf[rbp] - 48)
            rbp = rbp + 1
        if rbp == rb_y0_start:
            set_current_errstr("/dev/wsys/ctl: rband: missing y0")
            return -1
        rbp = _wsys_ctl_skip_ws(buf, rbp, count)
        rb_x1: int64 = 0
        rb_x1_start: uint64 = rbp
        while rbp < count and buf[rbp] >= 48 and buf[rbp] <= 57:
            rb_x1 = rb_x1 * 10 + cast[int64](buf[rbp] - 48)
            rbp = rbp + 1
        if rbp == rb_x1_start:
            set_current_errstr("/dev/wsys/ctl: rband: missing x1")
            return -1
        rbp = _wsys_ctl_skip_ws(buf, rbp, count)
        rb_y1: int64 = 0
        rb_y1_start: uint64 = rbp
        while rbp < count and buf[rbp] >= 48 and buf[rbp] <= 57:
            rb_y1 = rb_y1 * 10 + cast[int64](buf[rbp] - 48)
            rbp = rbp + 1
        if rbp == rb_y1_start:
            set_current_errstr("/dev/wsys/ctl: rband: missing y1")
            return -1
        wsys_rband_set(cast[int32](rb_active), rb_x0, rb_y0, rb_x1, rb_y1)
        return cast[int64](count)

    # `sessui <open> <hover>` — DE pivot wave 8. Publish the End Session
    # dialog model so /bin/hamsessui can rasterise the modal chrome. Two
    # small signed decimals (hover may be -1). Hostowner-only.
    if _wsys_ctl_word_eq(buf, vs, ve, "sessui") == 1:
        sup: uint64 = p
        sup = _wsys_ctl_skip_ws(buf, sup, count)
        su_open: int64 = 0
        su_o_start: uint64 = sup
        while sup < count and buf[sup] >= 48 and buf[sup] <= 57:
            su_open = su_open * 10 + cast[int64](buf[sup] - 48)
            sup = sup + 1
        if sup == su_o_start:
            set_current_errstr("/dev/wsys/ctl: sessui: missing open flag")
            return -1
        sup = _wsys_ctl_skip_ws(buf, sup, count)
        su_hover: int64 = 0
        su_h_neg: int32 = 0
        if sup < count and buf[sup] == 45:               # '-'
            su_h_neg = 1
            sup = sup + 1
        su_h_start: uint64 = sup
        while sup < count and buf[sup] >= 48 and buf[sup] <= 57:
            su_hover = su_hover * 10 + cast[int64](buf[sup] - 48)
            sup = sup + 1
        if sup == su_h_start:
            set_current_errstr("/dev/wsys/ctl: sessui: missing hover row")
            return -1
        if su_h_neg != 0:
            su_hover = -su_hover
        wsys_sessui_set(cast[int32](su_open), cast[int32](su_hover))
        return cast[int64](count)

    # `desktop <count> <drag>` — DE pivot wave 1. Publish the desktop-icon
    # model so /bin/hamdesktop can rasterise the root-layer badges. Two
    # small signed decimals (drag may be -1). Hostowner-only.
    if _wsys_ctl_word_eq(buf, vs, ve, "desktop") == 1:
        dp: uint64 = p
        dp = _wsys_ctl_skip_ws(buf, dp, count)
        d_count: int64 = 0
        d_c_start: uint64 = dp
        while dp < count and buf[dp] >= 48 and buf[dp] <= 57:
            d_count = d_count * 10 + cast[int64](buf[dp] - 48)
            dp = dp + 1
        if dp == d_c_start:
            set_current_errstr("/dev/wsys/ctl: desktop: missing count")
            return -1
        dp = _wsys_ctl_skip_ws(buf, dp, count)
        d_drag: int64 = 0
        d_neg: int32 = 0
        if dp < count and buf[dp] == 45:
            d_neg = 1
            dp = dp + 1
        d_d_start: uint64 = dp
        while dp < count and buf[dp] >= 48 and buf[dp] <= 57:
            d_drag = d_drag * 10 + cast[int64](buf[dp] - 48)
            dp = dp + 1
        if dp == d_d_start:
            set_current_errstr("/dev/wsys/ctl: desktop: missing drag")
            return -1
        if d_neg != 0:
            d_drag = -d_drag
        wsys_desktop_set(cast[int32](d_count), cast[int32](d_drag))
        return cast[int64](count)

    # `sysmon <cpu> <mem>` — DE pivot wave 2.
    if _wsys_ctl_word_eq(buf, vs, ve, "sysmon") == 1:
        sp: uint64 = p
        sp = _wsys_ctl_skip_ws(buf, sp, count)
        sm_cpu: int64 = 0
        sm_c_start: uint64 = sp
        while sp < count and buf[sp] >= 48 and buf[sp] <= 57:
            sm_cpu = sm_cpu * 10 + cast[int64](buf[sp] - 48)
            sp = sp + 1
        if sp == sm_c_start:
            set_current_errstr("/dev/wsys/ctl: sysmon: missing cpu")
            return -1
        sp = _wsys_ctl_skip_ws(buf, sp, count)
        sm_mem: int64 = 0
        sm_m_start: uint64 = sp
        while sp < count and buf[sp] >= 48 and buf[sp] <= 57:
            sm_mem = sm_mem * 10 + cast[int64](buf[sp] - 48)
            sp = sp + 1
        if sp == sm_m_start:
            set_current_errstr("/dev/wsys/ctl: sysmon: missing mem")
            return -1
        wsys_sysmon_set(cast[int32](sm_cpu), cast[int32](sm_mem))
        return cast[int64](count)

    # `ctxmenu <open> <count> <hover> <x> <y> <w>` — DE pivot wave 3.
    if _wsys_ctl_word_eq(buf, vs, ve, "ctxmenu") == 1:
        cmp_v: uint64 = p
        cm_open: int64 = 0
        cm_count: int64 = 0
        cm_hover: int64 = 0
        cm_x: int64 = 0
        cm_y: int64 = 0
        cm_w: int64 = 0
        cmp_v = _wsys_ctl_skip_ws(buf, cmp_v, count)
        if _wsys_ctl_parse_i64(buf, cmp_v, count, &cm_open, &cmp_v) < 0:
            set_current_errstr("/dev/wsys/ctl: ctxmenu: missing open")
            return -1
        cmp_v = _wsys_ctl_skip_ws(buf, cmp_v, count)
        if _wsys_ctl_parse_i64(buf, cmp_v, count, &cm_count, &cmp_v) < 0:
            set_current_errstr("/dev/wsys/ctl: ctxmenu: missing count")
            return -1
        cmp_v = _wsys_ctl_skip_ws(buf, cmp_v, count)
        if _wsys_ctl_parse_i64(buf, cmp_v, count, &cm_hover, &cmp_v) < 0:
            set_current_errstr("/dev/wsys/ctl: ctxmenu: missing hover")
            return -1
        cmp_v = _wsys_ctl_skip_ws(buf, cmp_v, count)
        if _wsys_ctl_parse_i64(buf, cmp_v, count, &cm_x, &cmp_v) < 0:
            set_current_errstr("/dev/wsys/ctl: ctxmenu: missing x")
            return -1
        cmp_v = _wsys_ctl_skip_ws(buf, cmp_v, count)
        if _wsys_ctl_parse_i64(buf, cmp_v, count, &cm_y, &cmp_v) < 0:
            set_current_errstr("/dev/wsys/ctl: ctxmenu: missing y")
            return -1
        cmp_v = _wsys_ctl_skip_ws(buf, cmp_v, count)
        if _wsys_ctl_parse_i64(buf, cmp_v, count, &cm_w, &cmp_v) < 0:
            set_current_errstr("/dev/wsys/ctl: ctxmenu: missing w")
            return -1
        # Task #134: everything after <w> (a leading TAB then TAB-separated
        # row labels) is the per-row label blob; capture it verbatim, minus a
        # trailing newline. Empty when the compositor sends no labels.
        cm_lbl_start: uint64 = cmp_v
        cm_lbl_end: uint64 = count
        while cm_lbl_end > cm_lbl_start and \
              (buf[cm_lbl_end - 1] == 10 or buf[cm_lbl_end - 1] == 13):
            cm_lbl_end = cm_lbl_end - 1
        wsys_ctxmenu_set(cast[int32](cm_open), cast[int32](cm_count),
                         cast[int32](cm_hover),
                         cast[int32](cm_x), cast[int32](cm_y),
                         cast[int32](cm_w),
                         &buf[cm_lbl_start], cm_lbl_end - cm_lbl_start)
        return cast[int64](count)

    # `snap <active> <mode> <x> <y> <w> <h>` — DE pivot wave 4.
    if _wsys_ctl_word_eq(buf, vs, ve, "snap") == 1:
        snp: uint64 = p
        sn_a: int64 = 0
        sn_m: int64 = 0
        sn_x: int64 = 0
        sn_y: int64 = 0
        sn_w: int64 = 0
        sn_h: int64 = 0
        snp = _wsys_ctl_skip_ws(buf, snp, count)
        if _wsys_ctl_parse_i64(buf, snp, count, &sn_a, &snp) < 0:
            set_current_errstr("/dev/wsys/ctl: snap: missing active")
            return -1
        snp = _wsys_ctl_skip_ws(buf, snp, count)
        if _wsys_ctl_parse_i64(buf, snp, count, &sn_m, &snp) < 0:
            set_current_errstr("/dev/wsys/ctl: snap: missing mode")
            return -1
        snp = _wsys_ctl_skip_ws(buf, snp, count)
        if _wsys_ctl_parse_i64(buf, snp, count, &sn_x, &snp) < 0:
            set_current_errstr("/dev/wsys/ctl: snap: missing x")
            return -1
        snp = _wsys_ctl_skip_ws(buf, snp, count)
        if _wsys_ctl_parse_i64(buf, snp, count, &sn_y, &snp) < 0:
            set_current_errstr("/dev/wsys/ctl: snap: missing y")
            return -1
        snp = _wsys_ctl_skip_ws(buf, snp, count)
        if _wsys_ctl_parse_i64(buf, snp, count, &sn_w, &snp) < 0:
            set_current_errstr("/dev/wsys/ctl: snap: missing w")
            return -1
        snp = _wsys_ctl_skip_ws(buf, snp, count)
        if _wsys_ctl_parse_i64(buf, snp, count, &sn_h, &snp) < 0:
            set_current_errstr("/dev/wsys/ctl: snap: missing h")
            return -1
        wsys_snap_set(cast[int32](sn_a), cast[int32](sn_m),
                      cast[int32](sn_x), cast[int32](sn_y),
                      cast[int32](sn_w), cast[int32](sn_h))
        return cast[int64](count)

    # `resize <kind> <x> <y> <w> <h>` — DE pivot wave 5.
    if _wsys_ctl_word_eq(buf, vs, ve, "resize") == 1:
        rzp: uint64 = p
        rz_k: int64 = 0
        rz_x: int64 = 0
        rz_y: int64 = 0
        rz_w: int64 = 0
        rz_h: int64 = 0
        rzp = _wsys_ctl_skip_ws(buf, rzp, count)
        if _wsys_ctl_parse_i64(buf, rzp, count, &rz_k, &rzp) < 0:
            set_current_errstr("/dev/wsys/ctl: resize: missing kind")
            return -1
        rzp = _wsys_ctl_skip_ws(buf, rzp, count)
        if _wsys_ctl_parse_i64(buf, rzp, count, &rz_x, &rzp) < 0:
            set_current_errstr("/dev/wsys/ctl: resize: missing x")
            return -1
        rzp = _wsys_ctl_skip_ws(buf, rzp, count)
        if _wsys_ctl_parse_i64(buf, rzp, count, &rz_y, &rzp) < 0:
            set_current_errstr("/dev/wsys/ctl: resize: missing y")
            return -1
        rzp = _wsys_ctl_skip_ws(buf, rzp, count)
        if _wsys_ctl_parse_i64(buf, rzp, count, &rz_w, &rzp) < 0:
            set_current_errstr("/dev/wsys/ctl: resize: missing w")
            return -1
        rzp = _wsys_ctl_skip_ws(buf, rzp, count)
        if _wsys_ctl_parse_i64(buf, rzp, count, &rz_h, &rzp) < 0:
            set_current_errstr("/dev/wsys/ctl: resize: missing h")
            return -1
        wsys_resize_set(cast[int32](rz_k),
                        cast[int32](rz_x), cast[int32](rz_y),
                        cast[int32](rz_w), cast[int32](rz_h))
        return cast[int64](count)

    # `osd <active> <kind> <ws> <pct>` — DE pivot wave 6.
    if _wsys_ctl_word_eq(buf, vs, ve, "osd") == 1:
        op: uint64 = p
        o_a: int64 = 0
        o_k: int64 = 0
        o_w: int64 = 0
        o_p: int64 = 0
        op = _wsys_ctl_skip_ws(buf, op, count)
        if _wsys_ctl_parse_i64(buf, op, count, &o_a, &op) < 0:
            set_current_errstr("/dev/wsys/ctl: osd: missing active")
            return -1
        op = _wsys_ctl_skip_ws(buf, op, count)
        if _wsys_ctl_parse_i64(buf, op, count, &o_k, &op) < 0:
            set_current_errstr("/dev/wsys/ctl: osd: missing kind")
            return -1
        op = _wsys_ctl_skip_ws(buf, op, count)
        if _wsys_ctl_parse_i64(buf, op, count, &o_w, &op) < 0:
            set_current_errstr("/dev/wsys/ctl: osd: missing ws")
            return -1
        op = _wsys_ctl_skip_ws(buf, op, count)
        if _wsys_ctl_parse_i64(buf, op, count, &o_p, &op) < 0:
            set_current_errstr("/dev/wsys/ctl: osd: missing pct")
            return -1
        wsys_osd_set(cast[int32](o_a), cast[int32](o_k),
                     cast[int32](o_w), cast[int32](o_p))
        return cast[int64](count)

    # `tray <open> <count> <x> <y> <w> <h>` — DE pivot wave 7.
    if _wsys_ctl_word_eq(buf, vs, ve, "tray") == 1:
        tp: uint64 = p
        t_o: int64 = 0
        t_c: int64 = 0
        t_x: int64 = 0
        t_y: int64 = 0
        t_w: int64 = 0
        t_h: int64 = 0
        tp = _wsys_ctl_skip_ws(buf, tp, count)
        if _wsys_ctl_parse_i64(buf, tp, count, &t_o, &tp) < 0:
            set_current_errstr("/dev/wsys/ctl: tray: missing open")
            return -1
        tp = _wsys_ctl_skip_ws(buf, tp, count)
        if _wsys_ctl_parse_i64(buf, tp, count, &t_c, &tp) < 0:
            set_current_errstr("/dev/wsys/ctl: tray: missing count")
            return -1
        tp = _wsys_ctl_skip_ws(buf, tp, count)
        if _wsys_ctl_parse_i64(buf, tp, count, &t_x, &tp) < 0:
            set_current_errstr("/dev/wsys/ctl: tray: missing x")
            return -1
        tp = _wsys_ctl_skip_ws(buf, tp, count)
        if _wsys_ctl_parse_i64(buf, tp, count, &t_y, &tp) < 0:
            set_current_errstr("/dev/wsys/ctl: tray: missing y")
            return -1
        tp = _wsys_ctl_skip_ws(buf, tp, count)
        if _wsys_ctl_parse_i64(buf, tp, count, &t_w, &tp) < 0:
            set_current_errstr("/dev/wsys/ctl: tray: missing w")
            return -1
        tp = _wsys_ctl_skip_ws(buf, tp, count)
        if _wsys_ctl_parse_i64(buf, tp, count, &t_h, &tp) < 0:
            set_current_errstr("/dev/wsys/ctl: tray: missing h")
            return -1
        wsys_tray_set(cast[int32](t_o), cast[int32](t_c),
                      cast[int32](t_x), cast[int32](t_y),
                      cast[int32](t_w), cast[int32](t_h))
        return cast[int64](count)

    # `run <open> <text>` — replace the Run-dialog model served on
    # /dev/wsys/run. <open> is a small decimal integer (0 = hidden, 1 =
    # visible), then a single space, then the typed text (extends to EOF;
    # one trailing '\n' stripped). Hostowner-only (matches the rest of
    # /dev/wsys/ctl). The compositor calls this whenever it mutates the
    # Run-dialog state (open/cancel/push/backspace/launch).
    if _wsys_ctl_word_eq(buf, vs, ve, "run") == 1:
        rp: uint64 = p
        rp = _wsys_ctl_skip_ws(buf, rp, count)
        run_open_v: int64 = 0
        rp_open_start: uint64 = rp
        while rp < count and buf[rp] >= 48 and buf[rp] <= 57:
            run_open_v = run_open_v * 10 + cast[int64](buf[rp] - 48)
            rp = rp + 1
        if rp == rp_open_start:
            set_current_errstr("/dev/wsys/ctl: run: missing open flag")
            return -1
        # Exactly one separating space, then text extends to EOF (one
        # trailing '\n' stripped if present). The text may be empty (a
        # fresh "open" with no chars typed yet).
        if rp < count and buf[rp] == 32:
            rp = rp + 1
        rpe: uint64 = count
        if rpe > rp and buf[rpe - 1] == 10:
            rpe = rpe - 1
        rlen: uint64 = rpe - rp
        if wsys_run_set(&buf[rp], rlen, cast[int32](run_open_v)) < 0:
            set_current_errstr("/dev/wsys/ctl: run: payload too large")
            return -1
        return cast[int64](count)

    if _wsys_ctl_word_eq(buf, vs, ve, "wallpaper") == 1:
        ps: uint64 = _wsys_ctl_skip_ws(buf, p, count)
        # Path extends to end-of-line / end-of-buffer, MINUS any trailing
        # whitespace (so a writer using `echo "wallpaper /etc/foo.ppm"`
        # doesn't store a trailing '\n').
        pe: uint64 = count
        while pe > ps and _wsys_ctl_is_ws(buf[pe - 1]) == 1:
            pe = pe - 1
        if ps == pe:
            set_current_errstr("/dev/wsys/ctl: wallpaper: missing path")
            return -1
        plen: uint64 = pe - ps
        if plen >= WSYS_WALLPAPER_PATH_CAP:
            set_current_errstr("/dev/wsys/ctl: wallpaper: path too long")
            return -1
        i: uint64 = 0
        while i < plen:
            wsys_wallpaper_path[i] = buf[ps + i]
            i = i + 1
        wsys_wallpaper_path[plen] = 0
        wsys_wallpaper_path_len = plen
        wsys_wallpaper_gen = wsys_wallpaper_gen + 1
        return cast[int64](count)

    # `ws <N>` — request a virtual-workspace switch. <N> is 1-based
    # (1..WS_MAX) to match the hambottom switcher labels; we record it
    # as 0-based in wsys_workspace_req and bump wsys_workspace_gen so
    # the compositor's poll on /dev/wsys/workspace observes the change
    # and calls workspace_switch(N-1). Out-of-range Ns are rejected so
    # a stray writer can't drive CUR_WS to a non-existent workspace.
    # Hostowner-gated like the rest of /dev/wsys/ctl.
    if _wsys_ctl_word_eq(buf, vs, ve, "ws") == 1:
        wsp1: uint64 = _wsys_ctl_skip_ws(buf, p, count)
        wsp2: uint64 = _wsys_ctl_token_end(buf, wsp1, count)
        if wsp1 == wsp2:
            set_current_errstr("/dev/wsys/ctl: ws: missing N")
            return -1
        ws_u: uint64 = 0
        if _wsys_ctl_parse_u64(buf, wsp1, wsp2, &ws_u) == 0:
            set_current_errstr("/dev/wsys/ctl: ws: bad N")
            return -1
        if ws_u < 1 or ws_u > 16:
            set_current_errstr("/dev/wsys/ctl: ws: N out of range")
            return -1
        wsys_workspace_req = cast[int32](ws_u) - 1
        wsys_workspace_gen = wsys_workspace_gen + 1
        # KERNEL-side virtual-desktop switch. The scene compositor here is the
        # one that actually paints, so flip the active desktop and force a full
        # repaint: reset wsys_bg_painted so the present lays the backdrop down
        # over the windows that just became hidden, then z-blits only the new
        # desktop's (visible) windows. The gen/req bump above is preserved for
        # any userland that still polls /dev/wsys/workspace, but visibility is
        # enforced right here so the switch is real even with hamUId retired.
        new_ws: int32 = cast[int32](ws_u) - 1
        if new_ws != wsys_cur_ws:
            wsys_cur_ws = new_ws
            # Serial proof of the real virtual-desktop switch (matches the
            # legacy hamUId marker the DE tests grep for). Count the app
            # windows now hidden on the new desktop so the log shows isolation
            # actually took effect, not just a counter bump.
            hid: int32 = 0
            hw: uint64 = 1
            while hw < WSYS_SCENE_SLOTS:
                if wsys_slot_in_use[hw] != 0 and wsys_scene_len[hw] > 0 \
                        and wsys_win_decorate[hw] != 0 \
                        and wsys_win_ws[hw] != wsys_cur_ws:
                    hid = hid + 1
                hw = hw + 1
            printk2("[de_ws] WS switch %d hidden=%d\n",
                    cast[uint64](new_ws + 1), cast[uint64](hid))
            if fb_get_initialized() != 0 and wsys_root_active != 0:
                wsys_bg_painted = 0
                wsys_scene_present()
        return cast[int64](count)

    # DE keyboard shortcuts: `kbd <N>` — synthesize the VT220/xterm CSI
    # sequence `ESC [ <N> ~` into wid 1's cmd-injection queue. The
    # compositor's key_process_chunk drains /dev/cons and recognises the
    # CSI param to dispatch the bound WM action (Alt-Tab/CSI 45,
    # Ctrl-Alt-T/46, Alt-F4/47, Super/48, Super+D/49, plus the existing
    # F-key CSI codes). Lets the test harness exercise every shortcut
    # without depending on the host's keyboard plumbing — the keyboard
    # analogue of driving the cursor via /dev/mouse. Hostowner-gated like
    # the rest of /dev/wsys/ctl.
    if _wsys_ctl_word_eq(buf, vs, ve, "kbd") == 1:
        kp1: uint64 = _wsys_ctl_skip_ws(buf, p, count)
        kp2: uint64 = _wsys_ctl_token_end(buf, kp1, count)
        if kp1 == kp2:
            set_current_errstr("/dev/wsys/ctl: kbd: missing csi param")
            return -1
        csi_u: uint64 = 0
        if _wsys_ctl_parse_u64(buf, kp1, kp2, &csi_u) == 0:
            set_current_errstr("/dev/wsys/ctl: kbd: bad csi param")
            return -1
        if csi_u == 0 or csi_u > 99:
            set_current_errstr("/dev/wsys/ctl: kbd: csi param out of range")
            return -1
        # Render ESC '[' <decimal-N> '~' into the compositor's wid 1
        # cmd queue. _wsys_cmd_push_wid returns 0 on a full ring; we
        # tolerate that (best-effort), the boot-log marker comes from
        # the compositor.
        esc_b: uint8 = 27
        lbrk_b: uint8 = 91
        tilde_b: uint8 = 126
        _wsys_cmd_push_wid(cast[int32](1), esc_b)
        _wsys_cmd_push_wid(cast[int32](1), lbrk_b)
        if csi_u >= 10:
            d_hi: uint64 = 48 + (csi_u / 10)
            _wsys_cmd_push_wid(cast[int32](1), cast[uint8](d_hi))
        d_lo: uint64 = 48 + (csi_u % 10)
        _wsys_cmd_push_wid(cast[int32](1), cast[uint8](d_lo))
        _wsys_cmd_push_wid(cast[int32](1), tilde_b)
        return cast[int64](count)

    # First numeric argument (alloc <pid>, free <wid>, frame <wid> ...).
    p = _wsys_ctl_skip_ws(buf, p, count)
    a1s: uint64 = p
    p = _wsys_ctl_token_end(buf, p, count)
    a1e: uint64 = p
    arg1: uint64 = 0
    if a1s == a1e:
        set_current_errstr("/dev/wsys/ctl: missing argument")
        return -1
    if _wsys_ctl_parse_u64(buf, a1s, a1e, &arg1) == 0:
        set_current_errstr("/dev/wsys/ctl: bad argument")
        return -1

    # alloc <pid> — mirrors SYS_WSYS_ALLOC's body.
    if _wsys_ctl_word_eq(buf, vs, ve, "alloc") == 1:
        # Refuse self-registration (the syscall arm did this too — a
        # self-detach is nonsensical).
        if arg1 == current_task_pid():
            set_current_errstr("/dev/wsys/ctl: alloc refuses self-registration")
            return -1
        tgt: int32 = task_lookup_by_pid(arg1)
        if tgt < 0:
            set_current_errstr("/dev/wsys/ctl: alloc: no such pid")
            return -1
        w: int32 = wsys_alloc_wid(arg1)
        if w < 0:
            set_current_errstr("/dev/wsys/ctl: alloc: table full or pid already bound")
            return -1
        set_task_detached(tgt, 1)
        set_task_parent_pid(tgt, 0)
        # Hostowner-on-behalf alloc: the result is for the (different) named
        # pid, read back by the trusted DE via the legacy global slot (the
        # per-pid table keys on the WRITER's pid, which isn't the target here).
        wsys_last_alloc_wid = w
        return cast[int64](count)

    # free <wid>
    if _wsys_ctl_word_eq(buf, vs, ve, "free") == 1:
        if arg1 > 0xFFFFFFFF:
            set_current_errstr("/dev/wsys/ctl: free: bad wid")
            return -1
        rc: int32 = wsys_free_wid(cast[int32](arg1))
        if rc < 0:
            set_current_errstr("/dev/wsys/ctl: free: bad wid or wid==1 (foreground)")
            return -1
        return cast[int64](count)

    # frame <wid> <frame>
    if _wsys_ctl_word_eq(buf, vs, ve, "frame") == 1:
        # Second arg = frame number.
        p = _wsys_ctl_skip_ws(buf, p, count)
        a2s: uint64 = p
        p = _wsys_ctl_token_end(buf, p, count)
        a2e: uint64 = p
        if a2s == a2e:
            set_current_errstr("/dev/wsys/ctl: frame: missing frame number")
            return -1
        arg2: uint64 = 0
        if _wsys_ctl_parse_u64(buf, a2s, a2e, &arg2) == 0:
            set_current_errstr("/dev/wsys/ctl: frame: bad frame number")
            return -1
        if arg1 > 0xFFFFFFFF:
            set_current_errstr("/dev/wsys/ctl: frame: bad wid")
            return -1
        vkrc: int32 = vk_window_render_frame(cast[int32](arg1),
                                             cast[int64](arg2))
        if vkrc != 0:
            set_current_errstr("/dev/wsys/ctl: frame: render/present failed")
            return -1
        return cast[int64](count)

    set_current_errstr("/dev/wsys/ctl: bad verb")
    return -1


def devwsys_ctl_read(off: uint64, buf: Ptr[uint8],
                     count: uint64) -> int64:
    # Render the wid the calling task just allocated as "<n>\n". On a
    # second read (off > 0) return EOF — the read consumes the result.
    #
    # MULTI-WINDOW RACE FIX (user-reported "taskbar shows only ONE of N
    # open windows"): the assigned wid is delivered via the PER-PID pending
    # table (see _wsys_pending_put / _wsys_pending_take) so concurrently-
    # launching apps each read back their OWN wid. Only when the caller has
    # no per-pid entry do we fall back to the legacy single global (the
    # hostowner-on-behalf `alloc <pid>` path, read by the trusted DE).
    if off > 0:
        return 0
    val: int32 = _wsys_pending_take(current_task_pid())
    if val < 0:
        if wsys_last_alloc_wid < 0:
            return 0
        val = wsys_last_alloc_wid
        wsys_last_alloc_wid = -1
    # Decimal render into a small scratch (val is at most MAX_WINDOWS,
    # so 2 digits + '\n' suffice — round up to 16 for safety).
    scratch: Array[16, uint8]
    n: uint64 = 0
    if val == 0:
        scratch[0] = 48
        n = 1
    else:
        v: uint32 = cast[uint32](val)
        digs: Array[16, uint8]
        d: uint64 = 0
        while v > 0:
            digs[d] = cast[uint8](v % 10) + 48
            v = v / 10
            d = d + 1
        while d > 0:
            d = d - 1
            scratch[n] = digs[d]
            n = n + 1
    scratch[n] = 10                                    # '\n'
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


# DE image-wallpaper readback: /dev/wsys/wallpaper renders the current
# wallpaper request as "<gen> <path>\n" (single ASCII line). gen=0 means
# "no wallpaper set", and the path is empty in that case (the line is
# just "0 \n" — the compositor treats gen=0 as the solid-backdrop
# fallback). The read is a SNAPSHOT (off > 0 returns EOF), so a poll
# pattern is: open, read once, compare gen to the cached value, close.
def devwsys_wallpaper_read(off: uint64, buf: Ptr[uint8],
                           count: uint64) -> int64:
    if off > 0:
        return 0
    # Render "<gen> <path>\n" into a small scratch. Path cap is 256,
    # gen renders as at most 20 decimal digits, plus space + '\n' + NUL
    # padding — 288 fits comfortably.
    scratch: Array[288, uint8]
    n: uint64 = 0
    g: uint64 = wsys_wallpaper_gen
    if g == 0:
        scratch[0] = 48
        n = 1
    else:
        digs: Array[24, uint8]
        d: uint64 = 0
        v: uint64 = g
        while v > 0:
            digs[d] = cast[uint8](v % 10) + 48
            v = v / 10
            d = d + 1
        while d > 0:
            d = d - 1
            scratch[n] = digs[d]
            n = n + 1
    scratch[n] = 32                                    # ' '
    n = n + 1
    i: uint64 = 0
    while i < wsys_wallpaper_path_len:
        scratch[n] = wsys_wallpaper_path[i]
        n = n + 1
        i = i + 1
    scratch[n] = 10                                    # '\n'
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


# DE virtual-workspace request readback: /dev/wsys/workspace renders the
# current `ws <N>` request as "<gen> <ws>\n" (ws is 0-based, matches the
# compositor's CUR_WS). gen=0 means "no request yet" and the compositor
# leaves CUR_WS alone. Snapshot read (off>0 returns EOF), same poll
# pattern as /dev/wsys/wallpaper: open, read once, compare gen to the
# cached value, close.
def devwsys_workspace_read(off: uint64, buf: Ptr[uint8],
                           count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[64, uint8]
    n: uint64 = 0
    g: uint64 = wsys_workspace_gen
    if g == 0:
        scratch[0] = 48
        n = 1
    else:
        digs: Array[24, uint8]
        d: uint64 = 0
        v: uint64 = g
        while v > 0:
            digs[d] = cast[uint8](v % 10) + 48
            v = v / 10
            d = d + 1
        while d > 0:
            d = d - 1
            scratch[n] = digs[d]
            n = n + 1
    scratch[n] = 32                                    # ' '
    n = n + 1
    ws_v: int32 = wsys_workspace_req
    if ws_v < 0:
        ws_v = 0
    if ws_v < 10:
        scratch[n] = cast[uint8](ws_v) + 48
        n = n + 1
    else:
        scratch[n] = cast[uint8](ws_v / 10) + 48
        n = n + 1
        scratch[n] = cast[uint8](ws_v % 10) + 48
        n = n + 1
    scratch[n] = 10                                    # '\n'
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


# ====================================================================
# DE pivot wave 2 — /dev/wsys/appmenu + /dev/wsys/appmenu/launch
#
# The classic Applications menu (cascading Accessories/Games/System
# Tools/Help) is no longer drawn by daemon_pixel. /bin/hamappmenu is a
# separate-process v2 client that reads the catalogue snapshot from
# /dev/wsys/appmenu, renders the cascading menu into its own backbuffer,
# and on click writes the chosen prog path to /dev/wsys/appmenu/launch.
# The compositor (user/hamUId.ad) polls that launch leaf and routes the
# requested path through daemon_spawn_window_prog.
#
# Wire format
# -----------
# /dev/wsys/appmenu (snapshot read, off>0 returns EOF):
#   "<gen>\n"
#   "C <category-name>\n"     -- one per category, in order
#   "I <category-idx> <prog-path> <label>\n"   -- one per entry
#
# The catalogue is written by the compositor via the `appmenu` verb on
# /dev/wsys/ctl. A single write replaces the whole snapshot. Format
# mirrors the read shape (line-oriented). gen bumps on each set.
#
# /dev/wsys/appmenu/launch (snapshot read + verb write):
#   read  -> "<serial> <prog-path>\n"  (serial=0 = no pending launch)
#   write -> "<prog-path>\n"           (queues a launch; bumps serial)

WSYS_APPMENU_CAP: uint64 = 2048
WSYS_APPMENU_LAUNCH_CAP: uint64 = 256

wsys_appmenu_buf: Array[2048, uint8]
wsys_appmenu_len: uint64 = 0
wsys_appmenu_gen: uint64 = 0

wsys_appmenu_launch_path: Array[256, uint8]
wsys_appmenu_launch_len: uint64 = 0
wsys_appmenu_launch_serial: uint64 = 0


def wsys_appmenu_set(src: Ptr[uint8], len: uint64) -> int32:
    if len >= WSYS_APPMENU_CAP:
        return -1
    i: uint64 = 0
    while i < len:
        wsys_appmenu_buf[i] = src[i]
        i = i + 1
    wsys_appmenu_len = len
    wsys_appmenu_gen = wsys_appmenu_gen + 1
    return 0


def wsys_appmenu_launch_set(src: Ptr[uint8], len: uint64) -> int32:
    if len == 0 or len >= WSYS_APPMENU_LAUNCH_CAP:
        return -1
    i: uint64 = 0
    while i < len:
        wsys_appmenu_launch_path[i] = src[i]
        i = i + 1
    wsys_appmenu_launch_len = len
    wsys_appmenu_launch_serial = wsys_appmenu_launch_serial + 1
    return 0


def _wsys_emit_u64_dec(scratch: Ptr[uint8], pos: uint64, v: uint64) -> uint64:
    if v == 0:
        scratch[pos] = 48
        return pos + 1
    digs: Array[24, uint8]
    d: uint64 = 0
    vv: uint64 = v
    while vv > 0:
        digs[d] = cast[uint8](vv % 10) + 48
        vv = vv / 10
        d = d + 1
    p: uint64 = pos
    while d > 0:
        d = d - 1
        scratch[p] = digs[d]
        p = p + 1
    return p


def devwsys_appmenu_read(off: uint64, buf: Ptr[uint8],
                         count: uint64) -> int64:
    # Snapshot read: render "<gen>\n" followed by the stored catalogue
    # text. off > 0 returns EOF (single-shot snapshot, matching the
    # /dev/wsys/wallpaper shape).
    if off > 0:
        return 0
    # Compose into a small scratch big enough for the gen prefix plus
    # the full catalogue payload.
    scratch: Array[2080, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_appmenu_gen)
    scratch[n] = 10
    n = n + 1
    i: uint64 = 0
    while i < wsys_appmenu_len:
        scratch[n] = wsys_appmenu_buf[i]
        n = n + 1
        i = i + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_appmenu_launch_read(off: uint64, buf: Ptr[uint8],
                                count: uint64) -> int64:
    # Snapshot read: "<serial> <path>\n". serial=0 = no pending launch.
    if off > 0:
        return 0
    scratch: Array[320, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_appmenu_launch_serial)
    scratch[n] = 32
    n = n + 1
    i: uint64 = 0
    while i < wsys_appmenu_launch_len:
        scratch[n] = wsys_appmenu_launch_path[i]
        n = n + 1
        i = i + 1
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_appmenu_launch_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Anybody (not just hostowner) may queue a launch: hamappmenu runs as
    # a regular DE-spawned client, NOT uid 1. The compositor remains the
    # only spawner; this verb just hands it the chosen path.
    if count == 0:
        return 0
    # Trim trailing whitespace ('\n', spaces).
    end: uint64 = count
    while end > 0 and _wsys_ctl_is_ws(buf[end - 1]) == 1:
        end = end - 1
    # Skip leading whitespace.
    start: uint64 = 0
    while start < end and _wsys_ctl_is_ws(buf[start]) == 1:
        start = start + 1
    if start == end:
        set_current_errstr("/dev/wsys/appmenu/launch: empty path")
        return -1
    plen: uint64 = end - start
    if wsys_appmenu_launch_set(&buf[start], plen) < 0:
        set_current_errstr("/dev/wsys/appmenu/launch: path too long")
        return -1
    return cast[int64](count)


# ====================================================================
# DE pivot wave 3 — /dev/wsys/cycler + /dev/wsys/cycler/show
#
# The Alt-Tab (F5/F6 in our keymap) window switcher overlay used to be
# drawn inline by daemon_pixel in user/hamUId.ad. It is now a standalone
# v2 client at /bin/hamcycler that reads its model from /dev/wsys/cycler
# and is signaled "appear now" by a write to /dev/wsys/cycler/show.
#
# Wire format
# -----------
# /dev/wsys/cycler (snapshot read, off>0 returns EOF):
#   "<show_serial> <open> <sel> <gen>\n"
#   "W <wid> <title>\n"     -- one per cycle candidate, in display order
#
# `open` is 1 while the popup should be visible, 0 otherwise.
# `sel` is the currently-selected row index. `gen` bumps on every
# publish so the client can detect changes. `show_serial` bumps every
# time the compositor wants the client to wake up + paint.
#
# The catalogue is published by the compositor via the `cycler` verb on
# /dev/wsys/ctl.
#
# /dev/wsys/cycler/show (snapshot read + verb write):
#   read  -> "<show_serial>\n"
#   write -> any byte sequence bumps show_serial (the compositor pokes
#            this whenever it wants the client to be visible/repaint).

WSYS_CYCLER_CAP: uint64 = 2048

wsys_cycler_buf: Array[2048, uint8]
wsys_cycler_len: uint64 = 0
wsys_cycler_gen: uint64 = 0
wsys_cycler_open: int32 = 0
wsys_cycler_sel: int32 = 0
wsys_cycler_show_serial: uint64 = 0


def wsys_cycler_set(src: Ptr[uint8], len: uint64,
                    open_v: int32, sel_v: int32) -> int32:
    if len >= WSYS_CYCLER_CAP:
        return -1
    i: uint64 = 0
    while i < len:
        wsys_cycler_buf[i] = src[i]
        i = i + 1
    wsys_cycler_len = len
    wsys_cycler_gen = wsys_cycler_gen + 1
    wsys_cycler_open = open_v
    wsys_cycler_sel = sel_v
    return 0


def wsys_cycler_show_bump():
    wsys_cycler_show_serial = wsys_cycler_show_serial + 1


def devwsys_cycler_read(off: uint64, buf: Ptr[uint8],
                        count: uint64) -> int64:
    # Snapshot read: "<show_serial> <open> <sel> <gen>\n" + stored body.
    if off > 0:
        return 0
    scratch: Array[2112, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_cycler_show_serial)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_cycler_open))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_cycler_sel))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, wsys_cycler_gen)
    scratch[n] = 10
    n = n + 1
    i: uint64 = 0
    while i < wsys_cycler_len:
        scratch[n] = wsys_cycler_buf[i]
        n = n + 1
        i = i + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_cycler_show_read(off: uint64, buf: Ptr[uint8],
                             count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[32, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_cycler_show_serial)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_cycler_show_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Any write bumps the show serial. Unrestricted: the compositor pokes
    # this to wake the client, but a stray writer just causes one repaint.
    wsys_cycler_show_bump()
    return cast[int64](count)


# ====================================================================
# DE pivot wave 4 — /dev/wsys/calpop + /dev/wsys/calpop/show
#
# The panel clock's drop-down monthly calendar popup used to be drawn
# inline by daemon_pixel in user/hamUId.ad. It is now a standalone v2
# client at /bin/hamcalpop that reads its model from /dev/wsys/calpop
# and is signaled "appear now" by a write to /dev/wsys/calpop/show.
#
# This is DISTINCT from /bin/hamclock — that is the standalone clock
# app. /bin/hamcalpop is the panel-attached month grid.
#
# Wire format
# -----------
# /dev/wsys/calpop (snapshot read, off>0 returns EOF):
#   "<show_serial> <open> <year> <month> <day> <valid> <gen>\n"
#
# `open` is 1 while the popup should be visible, 0 otherwise.
# `year`/`month`/`day` carry the live clock state (parsed by hamUId
# from /proc/realtime). `valid` is 1 once a real clock has been read
# (so the client knows whether to highlight today). `gen` bumps on
# every publish so the client can detect changes. `show_serial` bumps
# every time the compositor wants the client to wake up + paint.
#
# The model is published by the compositor via the `calpop` verb on
# /dev/wsys/ctl.
#
# /dev/wsys/calpop/show (snapshot read + verb write):
#   read  -> "<show_serial>\n"
#   write -> any byte sequence bumps show_serial (the compositor pokes
#            this whenever it wants the client to be visible/repaint).

wsys_calpop_gen:          uint64 = 0
wsys_calpop_open:         int32 = 0
wsys_calpop_year:         int64 = 2026
wsys_calpop_month:        int64 = 1
wsys_calpop_day:          int64 = 1
wsys_calpop_valid:        int32 = 0
wsys_calpop_show_serial:  uint64 = 0


def wsys_calpop_set(open_v: int32, year_v: int64, month_v: int64,
                    day_v: int64, valid_v: int32) -> int32:
    wsys_calpop_gen = wsys_calpop_gen + 1
    wsys_calpop_open = open_v
    wsys_calpop_year = year_v
    wsys_calpop_month = month_v
    wsys_calpop_day = day_v
    wsys_calpop_valid = valid_v
    return 0


def wsys_calpop_show_bump():
    wsys_calpop_show_serial = wsys_calpop_show_serial + 1


def devwsys_calpop_read(off: uint64, buf: Ptr[uint8],
                        count: uint64) -> int64:
    # Snapshot read: "<show_serial> <open> <year> <month> <day>
    # <valid> <gen>\n".
    if off > 0:
        return 0
    scratch: Array[128, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_calpop_show_serial)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_calpop_open))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_calpop_year))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_calpop_month))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_calpop_day))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_calpop_valid))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, wsys_calpop_gen)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


# ====================================================================
# DE pivot wave 4 — /dev/wsys/run + /dev/wsys/run/show + /dev/wsys/run/launch
#
# The MATE-style "Run Application..." (Alt-F2) modal text-entry dialog used
# to be drawn inline by daemon_pixel in user/hamUId.ad. It is now a
# standalone v2 client at /bin/hamrun that reads its model from
# /dev/wsys/run and is signaled "appear now" by a write to
# /dev/wsys/run/show. Like the cycler wave, keyboard input still lives in
# the compositor — only the RENDER moved out.
#
# Wire format
# -----------
# /dev/wsys/run (snapshot read, off>0 returns EOF):
#   "<show_serial> <open> <gen> <text>\n"
#
# `open` is 1 while the dialog is visible, 0 otherwise. `gen` bumps on
# every publish. `text` is the typed command line (NUL-stripped, may be
# empty when the user just opened the dialog).
#
# /dev/wsys/run/show (snapshot read + verb write):
#   read  -> "<show_serial>\n"
#   write -> any byte sequence bumps show_serial.
#
# /dev/wsys/run/launch (snapshot read + verb write):
#   read  -> "<serial> <path>\n" (most-recent launch request)
#   write -> the chosen prog path (one line, trailing \n stripped).
#            Bumps the launch serial so the compositor's polled
#            run_drain_launch sees the new request.
#
# The model is published by the compositor via the `run <open> <text>`
# verb on /dev/wsys/ctl. Hostowner-gated (matches the rest of the ctl).

WSYS_RUN_CAP: uint64 = 256

wsys_run_buf: Array[256, uint8]
wsys_run_len: uint64 = 0
wsys_run_gen: uint64 = 0
wsys_run_open: int32 = 0
wsys_run_show_serial: uint64 = 0

wsys_run_launch_path: Array[256, uint8]
wsys_run_launch_len: uint64 = 0
wsys_run_launch_serial: uint64 = 0


def wsys_run_set(src: Ptr[uint8], len: uint64, open_v: int32) -> int32:
    if len >= WSYS_RUN_CAP:
        return -1
    i: uint64 = 0
    while i < len:
        wsys_run_buf[i] = src[i]
        i = i + 1
    wsys_run_len = len
    wsys_run_gen = wsys_run_gen + 1
    wsys_run_open = open_v
    return 0


def wsys_run_show_bump():
    wsys_run_show_serial = wsys_run_show_serial + 1


def wsys_run_launch_set(src: Ptr[uint8], len: uint64) -> int32:
    if len >= WSYS_RUN_CAP:
        return -1
    i: uint64 = 0
    while i < len:
        wsys_run_launch_path[i] = src[i]
        i = i + 1
    wsys_run_launch_len = len
    wsys_run_launch_serial = wsys_run_launch_serial + 1
    return 0


def devwsys_run_read(off: uint64, buf: Ptr[uint8],
                     count: uint64) -> int64:
    # Snapshot read: "<show_serial> <open> <gen> <text>\n".
    if off > 0:
        return 0
    scratch: Array[320, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_run_show_serial)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_run_open))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, wsys_run_gen)
    scratch[n] = 32
    n = n + 1
    i: uint64 = 0
    while i < wsys_run_len:
        scratch[n] = wsys_run_buf[i]
        n = n + 1
        i = i + 1
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_calpop_show_read(off: uint64, buf: Ptr[uint8],
                             count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[32, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_calpop_show_serial)
    scratch[n] = 10
    n = n + 1
    take2: uint64 = count
    if take2 > n:
        take2 = n
    j2: uint64 = 0
    while j2 < take2:
        buf[j2] = scratch[j2]
        j2 = j2 + 1
    return cast[int64](take2)


def devwsys_run_show_read(off: uint64, buf: Ptr[uint8],
                          count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[32, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_run_show_serial)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_calpop_show_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Any write bumps the show serial. Unrestricted: the compositor pokes
    # this to wake the client, but a stray writer just causes one repaint.
    wsys_calpop_show_bump()
    return cast[int64](count)


def devwsys_run_show_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Any write bumps the show serial — the compositor pokes this to wake
    # the client immediately when the dialog state changes.
    wsys_run_show_bump()
    return cast[int64](count)


def devwsys_run_launch_read(off: uint64, buf: Ptr[uint8],
                            count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[320, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_run_launch_serial)
    scratch[n] = 32
    n = n + 1
    i: uint64 = 0
    while i < wsys_run_launch_len:
        scratch[n] = wsys_run_launch_path[i]
        n = n + 1
        i = i + 1
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_run_launch_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Parse: one line, trailing '\n' stripped. Empty payload is refused.
    start: uint64 = 0
    end: uint64 = count
    while end > start and (buf[end - 1] == 10 or buf[end - 1] == 13):
        end = end - 1
    if start >= end:
        set_current_errstr("/dev/wsys/run/launch: empty path")
        return -1
    plen: uint64 = end - start
    if wsys_run_launch_set(&buf[start], plen) < 0:
        set_current_errstr("/dev/wsys/run/launch: path too long")
        return -1
    return cast[int64](count)


# ====================================================================
# DE pivot wave 7 — /dev/wsys/notif + /dev/wsys/notif/show
#
# The transient notification toast (top-right banner with title + body that
# fades after ~4 s) used to be drawn inline by daemon_pixel in
# user/hamUId.ad. It is now a standalone v2 client at /bin/hamnotif that
# reads its model from /dev/wsys/notif and is signaled "the model changed"
# by a write to /dev/wsys/notif/show. The notification queue + fade timer
# stay in the compositor (notify_post/notify_tick/notify_alpha own the
# wall-clock decision); only the RENDER moved out.
#
# Wire format
# -----------
# /dev/wsys/notif (snapshot read, off>0 returns EOF):
#   "<show_serial> <active> <alpha> <gen> <title>\t<body>\n"
#
# `active` is 1 while a banner is on-screen, 0 otherwise. `alpha` is the
# current 0..255 opacity (the compositor computes the wall-clock fade and
# republishes when the alpha bucket changes; the client just lerps the
# banner ink). `gen` bumps on every publish. `title` and `body` are
# separated by a single TAB so spaces inside either text survive the
# round-trip. Either may be empty.
#
# /dev/wsys/notif/show (snapshot read + verb write):
#   read  -> "<show_serial>\n"
#   write -> any byte sequence bumps show_serial.
#
# The model is published by the compositor via the `notif <active> <alpha>
# <title>\t<body>` verb on /dev/wsys/ctl. Hostowner-gated (matches the rest
# of the ctl).

WSYS_NOTIF_TITLE_CAP: uint64 = 40
WSYS_NOTIF_BODY_CAP:  uint64 = 64

wsys_notif_active: int32 = 0
wsys_notif_alpha:  int32 = 0
wsys_notif_gen:    uint64 = 0
wsys_notif_show_serial: uint64 = 0

wsys_notif_title_buf: Array[40, uint8]
wsys_notif_title_len: uint64 = 0
wsys_notif_body_buf:  Array[64, uint8]
wsys_notif_body_len:  uint64 = 0


def wsys_notif_set(active_v: int32, alpha_v: int32,
                   title_src: Ptr[uint8], title_len: uint64,
                   body_src: Ptr[uint8], body_len: uint64) -> int32:
    if title_len > WSYS_NOTIF_TITLE_CAP:
        title_len = WSYS_NOTIF_TITLE_CAP
    if body_len > WSYS_NOTIF_BODY_CAP:
        body_len = WSYS_NOTIF_BODY_CAP
    i: uint64 = 0
    while i < title_len:
        wsys_notif_title_buf[i] = title_src[i]
        i = i + 1
    wsys_notif_title_len = title_len
    j: uint64 = 0
    while j < body_len:
        wsys_notif_body_buf[j] = body_src[j]
        j = j + 1
    wsys_notif_body_len = body_len
    wsys_notif_active = active_v
    wsys_notif_alpha = alpha_v
    wsys_notif_gen = wsys_notif_gen + 1
    return 0


def wsys_notif_show_bump():
    wsys_notif_show_serial = wsys_notif_show_serial + 1


def devwsys_notif_read(off: uint64, buf: Ptr[uint8],
                       count: uint64) -> int64:
    # Snapshot read: "<show_serial> <active> <alpha> <gen> <title>\t<body>\n".
    if off > 0:
        return 0
    scratch: Array[256, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_notif_show_serial)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_notif_active))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_notif_alpha))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, wsys_notif_gen)
    scratch[n] = 32
    n = n + 1
    i: uint64 = 0
    while i < wsys_notif_title_len:
        scratch[n] = wsys_notif_title_buf[i]
        n = n + 1
        i = i + 1
    scratch[n] = 9                                     # '\t'
    n = n + 1
    j: uint64 = 0
    while j < wsys_notif_body_len:
        scratch[n] = wsys_notif_body_buf[j]
        n = n + 1
        j = j + 1
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    k: uint64 = 0
    while k < take:
        buf[k] = scratch[k]
        k = k + 1
    return cast[int64](take)


def devwsys_notif_show_read(off: uint64, buf: Ptr[uint8],
                            count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[32, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_notif_show_serial)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_notif_show_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Any write bumps the show serial — the compositor pokes this to wake
    # the client immediately when the notification state changes.
    wsys_notif_show_bump()
    return cast[int64](count)


# ====================================================================
# DE notification inbox — /dev/wsys/post
#
# A small fixed-size ring of pending notifications. Any process can write
# a one-line notification record:
#
#   "<title>\t<body>\t<icon>\n"
#
# The kernel appends it to the inbox ring and bumps `wsys_post_serial`.
# The compositor (hamUId daemon_pixel main loop) polls /dev/wsys/post on
# each frame; when the serial advances, it drains the head slot, calls
# notify_post(title, body) to arm the banner, and writes the ack-serial
# back to /dev/wsys/post (the write-side ALSO consumes the head when the
# payload starts with "ack ").
#
# Wire format
# -----------
# /dev/wsys/post (read, off==0 returns one line):
#   "<post_serial> <ack_serial> <count> <title>\t<body>\t<icon>\n"
# where `<count>` is the number of un-acked slots in the ring (0..8) and
# the title/body/icon trio describes the HEAD slot (oldest un-acked).
# When count is 0, title/body/icon are all empty.
#
# /dev/wsys/post (write):
#   - "ack <serial>\n"  — compositor consumes the head slot whose post-
#                         serial matches <serial>; bumps ack_serial.
#   - other payloads   — parsed as "<title>\t<body>\t<icon>\n" and pushed
#                         into the ring (drops the OLDEST slot if full).
#
# Boot-log marker: each successful push prints
#   `[de_notify] title=... body=...`
# so test scripts can confirm the round-trip.

WSYS_POST_RING:      uint64 = 8
WSYS_POST_TITLE_CAP: uint64 = 40
WSYS_POST_BODY_CAP:  uint64 = 64
WSYS_POST_ICON_CAP:  uint64 = 32

wsys_post_titles: Array[320, uint8]    # 8 * 40
wsys_post_bodies: Array[512, uint8]    # 8 * 64
wsys_post_icons:  Array[256, uint8]    # 8 * 32
wsys_post_tlen:   Array[8, uint64]
wsys_post_blen:   Array[8, uint64]
wsys_post_ilen:   Array[8, uint64]
wsys_post_pserial: Array[8, uint64]    # per-slot post serial

wsys_post_head:   uint64 = 0           # oldest un-acked index
wsys_post_tail:   uint64 = 0           # next write index
wsys_post_count:  uint64 = 0           # un-acked slot count
wsys_post_serial: uint64 = 0           # bumps on every push
wsys_post_ack_serial: uint64 = 0       # bumps on every ack-drain


def _wsys_post_push(title_src: Ptr[uint8], title_len: uint64,
                    body_src: Ptr[uint8], body_len: uint64,
                    icon_src: Ptr[uint8], icon_len: uint64) -> int32:
    if title_len > WSYS_POST_TITLE_CAP:
        title_len = WSYS_POST_TITLE_CAP
    if body_len > WSYS_POST_BODY_CAP:
        body_len = WSYS_POST_BODY_CAP
    if icon_len > WSYS_POST_ICON_CAP:
        icon_len = WSYS_POST_ICON_CAP
    slot: uint64 = wsys_post_tail
    toff: uint64 = slot * WSYS_POST_TITLE_CAP
    boff: uint64 = slot * WSYS_POST_BODY_CAP
    ioff: uint64 = slot * WSYS_POST_ICON_CAP
    i: uint64 = 0
    while i < title_len:
        wsys_post_titles[toff + i] = title_src[i]
        i = i + 1
    j: uint64 = 0
    while j < body_len:
        wsys_post_bodies[boff + j] = body_src[j]
        j = j + 1
    k: uint64 = 0
    while k < icon_len:
        wsys_post_icons[ioff + k] = icon_src[k]
        k = k + 1
    wsys_post_tlen[slot] = title_len
    wsys_post_blen[slot] = body_len
    wsys_post_ilen[slot] = icon_len
    wsys_post_serial = wsys_post_serial + 1
    wsys_post_pserial[slot] = wsys_post_serial
    wsys_post_tail = (slot + 1) % WSYS_POST_RING
    if wsys_post_count < WSYS_POST_RING:
        wsys_post_count = wsys_post_count + 1
    else:
        # Ring full: oldest is overwritten; advance head.
        wsys_post_head = (wsys_post_head + 1) % WSYS_POST_RING
    # Boot-log marker so test harnesses can grep round-trip.
    # Build "[de_notify] title=<title> body=<body>\n" in a stack buffer
    # then emit via printk0 (single-line atomic UART write).
    mbuf: Array[256, uint8]
    mn: uint64 = 0
    mpre: Ptr[uint8] = "[de_notify] title="
    p2: uint64 = 0
    while mpre[p2] != 0 and mn < 254:
        mbuf[mn] = mpre[p2]
        mn = mn + 1
        p2 = p2 + 1
    p3: uint64 = 0
    while p3 < title_len and mn < 254:
        mbuf[mn] = title_src[p3]
        mn = mn + 1
        p3 = p3 + 1
    mmid: Ptr[uint8] = " body="
    p4: uint64 = 0
    while mmid[p4] != 0 and mn < 254:
        mbuf[mn] = mmid[p4]
        mn = mn + 1
        p4 = p4 + 1
    p5: uint64 = 0
    while p5 < body_len and mn < 254:
        mbuf[mn] = body_src[p5]
        mn = mn + 1
        p5 = p5 + 1
    mbuf[mn] = 10
    mn = mn + 1
    mbuf[mn] = 0
    printk0(cast[Ptr[char]](&mbuf[0]))
    return 0


def _wsys_post_ack(serial: uint64) -> int32:
    # Drain the head slot if it matches `serial`. If serial is 0 we drain
    # the head regardless (idempotent ack). On a successful drain, bump
    # ack_serial so readers can detect consumption.
    if wsys_post_count == 0:
        return 0
    head: uint64 = wsys_post_head
    if serial != 0 and wsys_post_pserial[head] != serial:
        return 0
    wsys_post_head = (head + 1) % WSYS_POST_RING
    wsys_post_count = wsys_post_count - 1
    wsys_post_ack_serial = wsys_post_ack_serial + 1
    return 1


def devwsys_post_read(off: uint64, buf: Ptr[uint8],
                      count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[256, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_post_serial)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, wsys_post_ack_serial)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, wsys_post_count)
    scratch[n] = 32
    n = n + 1
    if wsys_post_count > 0:
        head: uint64 = wsys_post_head
        toff: uint64 = head * WSYS_POST_TITLE_CAP
        boff: uint64 = head * WSYS_POST_BODY_CAP
        ioff: uint64 = head * WSYS_POST_ICON_CAP
        # Emit head's slot serial so the compositor can pass it back to ack.
        n = _wsys_emit_u64_dec(&scratch[0], n, wsys_post_pserial[head])
        scratch[n] = 32
        n = n + 1
        i: uint64 = 0
        while i < wsys_post_tlen[head]:
            scratch[n] = wsys_post_titles[toff + i]
            n = n + 1
            i = i + 1
        scratch[n] = 9
        n = n + 1
        j: uint64 = 0
        while j < wsys_post_blen[head]:
            scratch[n] = wsys_post_bodies[boff + j]
            n = n + 1
            j = j + 1
        scratch[n] = 9
        n = n + 1
        k: uint64 = 0
        while k < wsys_post_ilen[head]:
            scratch[n] = wsys_post_icons[ioff + k]
            n = n + 1
            k = k + 1
    else:
        # No slot: emit "0 \t \t" placeholder so the parser shape is stable.
        scratch[n] = 48
        n = n + 1
        scratch[n] = 32
        n = n + 1
        scratch[n] = 9
        n = n + 1
        scratch[n] = 9
        n = n + 1
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    m: uint64 = 0
    while m < take:
        buf[m] = scratch[m]
        m = m + 1
    return cast[int64](take)


def devwsys_post_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Strip trailing \r/\n.
    end: uint64 = count
    while end > 0 and (buf[end - 1] == 10 or buf[end - 1] == 13):
        end = end - 1
    if end == 0:
        return cast[int64](count)
    # "ack <serial>" — compositor draining the head slot.
    if end >= 3 and buf[0] == 97 and buf[1] == 99 and buf[2] == 107:
        p: uint64 = 3
        while p < end and (buf[p] == 32 or buf[p] == 9):
            p = p + 1
        ser: uint64 = 0
        while p < end and buf[p] >= 48 and buf[p] <= 57:
            ser = ser * 10 + cast[uint64](buf[p] - 48)
            p = p + 1
        _wsys_post_ack(ser)
        return cast[int64](count)
    # Otherwise: parse "<title>\t<body>\t<icon>" and push.
    p: uint64 = 0
    tab1: uint64 = p
    while tab1 < end and buf[tab1] != 9:
        tab1 = tab1 + 1
    title_len: uint64 = tab1 - p
    body_start: uint64 = tab1
    if body_start < end:
        body_start = body_start + 1
    tab2: uint64 = body_start
    while tab2 < end and buf[tab2] != 9:
        tab2 = tab2 + 1
    body_len: uint64 = tab2 - body_start
    icon_start: uint64 = tab2
    if icon_start < end:
        icon_start = icon_start + 1
    icon_len: uint64 = end - icon_start
    if title_len == 0 and body_len == 0:
        set_current_errstr("/dev/wsys/post: empty notification")
        return -1
    _wsys_post_push(&buf[p], title_len,
                    &buf[body_start], body_len,
                    &buf[icon_start], icon_len)
    return cast[int64](count)


# ====================================================================
# DE pivot wave 5 — /dev/wsys/lock + /dev/wsys/lock/show + /dev/wsys/lock/verify
#
# The full-screen lock overlay ("Screen Locked / Click to unlock") used to be
# drawn inline by daemon_pixel in user/hamUId.ad. It is now a standalone v2
# client at /bin/hamlock that reads its model from /dev/wsys/lock and is
# signaled "appear now" by a write to /dev/wsys/lock/show. The password-verify
# secret stays in the compositor (lock_pw_secret) — only the RENDER moved out.
#
# Wire format
# -----------
# /dev/wsys/lock (snapshot read, off>0 returns EOF):
#   "<show_serial> <locked> <fails> <gen>\n"
#
# `locked` is 1 while the screen is locked, 0 otherwise. `fails` is the
# consecutive-wrong-attempt counter (so the overlay can render a feedback
# line). `gen` bumps on every publish.
#
# /dev/wsys/lock/show (snapshot read + verb write):
#   read  -> "<show_serial>\n"
#   write -> any byte sequence bumps show_serial.
#
# /dev/wsys/lock/verify (snapshot read + verb write):
#   read  -> "<serial> <password>\n" (most-recent password attempt)
#   write -> the typed password (one line, trailing \n stripped).
#            Bumps the verify serial so the compositor's polled
#            lock_drain_verify sees the new attempt and runs lock_pw_try
#            against the stored secret.
#
# The model is published by the compositor via the `lock <locked> <fails>`
# verb on /dev/wsys/ctl. Hostowner-gated (matches the rest of the ctl).

WSYS_LOCK_PW_CAP: uint64 = 128

wsys_lock_locked: int32 = 0
wsys_lock_fails:  int32 = 0
wsys_lock_gen:    uint64 = 0
wsys_lock_show_serial: uint64 = 0

wsys_lock_verify_buf: Array[128, uint8]
wsys_lock_verify_len: uint64 = 0
wsys_lock_verify_serial: uint64 = 0


def wsys_lock_set(locked_v: int32, fails_v: int32):
    wsys_lock_locked = locked_v
    wsys_lock_fails = fails_v
    wsys_lock_gen = wsys_lock_gen + 1


def wsys_lock_show_bump():
    wsys_lock_show_serial = wsys_lock_show_serial + 1


def wsys_lock_verify_set(src: Ptr[uint8], len: uint64) -> int32:
    if len >= WSYS_LOCK_PW_CAP:
        return -1
    i: uint64 = 0
    while i < len:
        wsys_lock_verify_buf[i] = src[i]
        i = i + 1
    wsys_lock_verify_len = len
    wsys_lock_verify_serial = wsys_lock_verify_serial + 1
    return 0


def devwsys_lock_read(off: uint64, buf: Ptr[uint8],
                      count: uint64) -> int64:
    # Snapshot read: "<show_serial> <locked> <fails> <gen>\n".
    if off > 0:
        return 0
    scratch: Array[128, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_lock_show_serial)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_lock_locked))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_lock_fails))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, wsys_lock_gen)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_lock_show_read(off: uint64, buf: Ptr[uint8],
                           count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[32, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_lock_show_serial)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_lock_show_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Any write bumps the show serial — the compositor pokes this to wake
    # the client immediately when the lock state changes.
    wsys_lock_show_bump()
    return cast[int64](count)


def devwsys_lock_verify_read(off: uint64, buf: Ptr[uint8],
                             count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[192, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_lock_verify_serial)
    scratch[n] = 32
    n = n + 1
    i: uint64 = 0
    while i < wsys_lock_verify_len:
        scratch[n] = wsys_lock_verify_buf[i]
        n = n + 1
        i = i + 1
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_lock_verify_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Parse: one line, trailing '\n' (and optional '\r') stripped. An empty
    # password is allowed — a blank verify is one valid attempt (it just
    # fails). The compositor's drain runs lock_pw_try against the secret.
    start: uint64 = 0
    end: uint64 = count
    while end > start and (buf[end - 1] == 10 or buf[end - 1] == 13):
        end = end - 1
    plen: uint64 = end - start
    if wsys_lock_verify_set(&buf[start], plen) < 0:
        set_current_errstr("/dev/wsys/lock/verify: password too long")
        return -1
    return cast[int64](count)


# ====================================================================
# DE pivot wave 7 — rubber-band drag overlay = /bin/hamrband
# ====================================================================
#
# /dev/wsys/rband (snapshot read):
#   "<set_serial> <active> <x0> <y0> <x1> <y1> <gen>\n"
#
# `active` is 1 while a drag-to-create rubber-band rectangle is in
# flight (the user clicked-and-dragged on empty desktop or a rectangle-
# select), 0 otherwise. `x0/y0/x1/y1` are the current band bbox in
# absolute screen pixels (only meaningful when active=1). `gen` bumps on
# every publish.
#
# /dev/wsys/rband/set (snapshot read + verb write):
#   read  -> "<set_serial>\n"
#   write -> any byte sequence bumps set_serial.
#
# The model is published by the compositor via the
# `rband <active> <x0> <y0> <x1> <y1>` verb on /dev/wsys/ctl. The
# compositor pokes /dev/wsys/rband/set on every drag move so the client
# wakes up and repaints the new band rect.

wsys_rband_active: int32 = 0
wsys_rband_x0:     int64 = 0
wsys_rband_y0:     int64 = 0
wsys_rband_x1:     int64 = 0
wsys_rband_y1:     int64 = 0
wsys_rband_gen:    uint64 = 0
wsys_rband_set_serial: uint64 = 0


def wsys_rband_set(active_v: int32,
                   x0_v: int64, y0_v: int64,
                   x1_v: int64, y1_v: int64):
    wsys_rband_active = active_v
    wsys_rband_x0 = x0_v
    wsys_rband_y0 = y0_v
    wsys_rband_x1 = x1_v
    wsys_rband_y1 = y1_v
    wsys_rband_gen = wsys_rband_gen + 1


def wsys_rband_set_bump():
    wsys_rband_set_serial = wsys_rband_set_serial + 1


def devwsys_rband_read(off: uint64, buf: Ptr[uint8],
                       count: uint64) -> int64:
    # Snapshot read:
    #   "<set_serial> <active> <x0> <y0> <x1> <y1> <gen>\n"
    if off > 0:
        return 0
    scratch: Array[192, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_rband_set_serial)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_rband_active))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_rband_x0))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_rband_y0))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_rband_x1))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_rband_y1))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, wsys_rband_gen)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_rband_set_read(off: uint64, buf: Ptr[uint8],
                           count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[32, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_rband_set_serial)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_rband_set_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Any write bumps the set serial — the compositor pokes this to wake
    # the client immediately when the rubber-band state changes.
    wsys_rband_set_bump()
    return cast[int64](count)


# ====================================================================
# DE pivot wave 8 — session "End Session" dialog = /bin/hamsessui
# ====================================================================
#
# /dev/wsys/sessui (snapshot read):
#   "<show_serial> <open> <hover> <gen>\n"
#
# `open` is 1 while the modal session dialog is visible (Lock Screen /
# Log Out / Shut Down / Cancel rows), 0 otherwise. `hover` is the row
# index under the pointer (0..3) or -1 when nothing hovered. `gen`
# bumps every time the model mutates.
#
# /dev/wsys/sessui/show (read = "<show_serial>\n"; write bumps it). The
# compositor pokes this whenever it republishes the model.
#
# Published via the /dev/wsys/ctl `sessui <open> <hover>` verb (two
# small signed ints). Hostowner-only, matching the rest of the ctl.

wsys_sessui_open:    int32 = 0
wsys_sessui_hover:   int32 = -1
wsys_sessui_gen:     uint64 = 0
wsys_sessui_show_serial: uint64 = 0


def wsys_sessui_set(open_v: int32, hover_v: int32):
    wsys_sessui_open = open_v
    wsys_sessui_hover = hover_v
    wsys_sessui_gen = wsys_sessui_gen + 1


def wsys_sessui_show_bump():
    wsys_sessui_show_serial = wsys_sessui_show_serial + 1


def devwsys_sessui_read(off: uint64, buf: Ptr[uint8],
                        count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[128, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_sessui_show_serial)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_sessui_open))
    scratch[n] = 32
    n = n + 1
    # hover is signed (-1 means no row). Render as "-N" when negative so
    # the userland parser can see it.
    h: int32 = wsys_sessui_hover
    if h < 0:
        scratch[n] = 45                                  # '-'
        n = n + 1
        n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](-h))
    else:
        n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](h))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, wsys_sessui_gen)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_sessui_show_read(off: uint64, buf: Ptr[uint8],
                             count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[32, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_sessui_show_serial)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_sessui_show_write(buf: Ptr[uint8], count: uint64) -> int64:
    wsys_sessui_show_bump()
    return cast[int64](count)



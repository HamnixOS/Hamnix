# ====================================================================
# DE pivot wave 3 — right-click context menu = /bin/hamctxmenu
# ====================================================================
# /dev/wsys/ctxmenu: "<show_serial> <open> <count> <hover> <x> <y> <w> <gen>\n"
#   followed by the TAB-separated per-row label blob (Task #134).
# Published via /dev/wsys/ctl
#   `ctxmenu <open> <count> <hover> <x> <y> <w>\t<l0>\t<l1>...`.

wsys_ctxmenu_open:  int32 = 0
wsys_ctxmenu_count: int32 = 0
wsys_ctxmenu_hover: int32 = -1
wsys_ctxmenu_x:     int32 = 0
wsys_ctxmenu_y:     int32 = 0
wsys_ctxmenu_w:     int32 = 0
wsys_ctxmenu_gen:   uint64 = 0
wsys_ctxmenu_show_serial: uint64 = 0

# Task #134: the per-row label TEXT, so /bin/hamctxmenu can draw legible
# labels on-device (not just placeholder bars). Carried verbatim from the
# compositor as a TAB-separated blob (one leading TAB, then <l0>\t<l1>...),
# echoed back after the numeric header on a /dev/wsys/ctxmenu read.
WSYS_CTXMENU_LBL_CAP: uint64 = 1024
wsys_ctxmenu_labels: Array[1024, uint8]
wsys_ctxmenu_labels_len: uint64 = 0


def wsys_ctxmenu_set(open_v: int32, count_v: int32, hover_v: int32,
                     x_v: int32, y_v: int32, w_v: int32,
                     lbl: Ptr[uint8], lbl_len: uint64):
    wsys_ctxmenu_open = open_v
    wsys_ctxmenu_count = count_v
    wsys_ctxmenu_hover = hover_v
    wsys_ctxmenu_x = x_v
    wsys_ctxmenu_y = y_v
    wsys_ctxmenu_w = w_v
    ln: uint64 = lbl_len
    if ln > WSYS_CTXMENU_LBL_CAP:
        ln = WSYS_CTXMENU_LBL_CAP
    k: uint64 = 0
    while k < ln:
        wsys_ctxmenu_labels[k] = lbl[k]
        k = k + 1
    wsys_ctxmenu_labels_len = ln
    wsys_ctxmenu_gen = wsys_ctxmenu_gen + 1


def wsys_ctxmenu_show_bump():
    wsys_ctxmenu_show_serial = wsys_ctxmenu_show_serial + 1


def _wsys_emit_i32_signed(scratch: Ptr[uint8], pos: uint64, v: int32) -> uint64:
    if v < 0:
        scratch[pos] = 45
        pos = pos + 1
        return _wsys_emit_u64_dec(scratch, pos, cast[uint64](-v))
    return _wsys_emit_u64_dec(scratch, pos, cast[uint64](v))


def devwsys_ctxmenu_read(off: uint64, buf: Ptr[uint8],
                         count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[160, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_ctxmenu_show_serial)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_ctxmenu_open))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_ctxmenu_count))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_i32_signed(&scratch[0], n, wsys_ctxmenu_hover)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_i32_signed(&scratch[0], n, wsys_ctxmenu_x)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_i32_signed(&scratch[0], n, wsys_ctxmenu_y)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_ctxmenu_w))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, wsys_ctxmenu_gen)
    scratch[n] = 10
    n = n + 1
    # Header numbers first, then the TAB-separated label blob (Task #134).
    outn: uint64 = 0
    j: uint64 = 0
    while j < n and outn < count:
        buf[outn] = scratch[j]
        outn = outn + 1
        j = j + 1
    k: uint64 = 0
    while k < wsys_ctxmenu_labels_len and outn < count:
        buf[outn] = wsys_ctxmenu_labels[k]
        outn = outn + 1
        k = k + 1
    return cast[int64](outn)


def devwsys_ctxmenu_show_read(off: uint64, buf: Ptr[uint8],
                              count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[32, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_ctxmenu_show_serial)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_ctxmenu_show_write(buf: Ptr[uint8], count: uint64) -> int64:
    wsys_ctxmenu_show_bump()
    return cast[int64](count)



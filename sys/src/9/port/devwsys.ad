from lib.hammouse_cfg import (
    mouse_cfg_map_buttons, mouse_cfg_map_dz, mouse_cfg_scale_delta,
)
# A.1 mouse-injection consolidation: the `nudge`/`nudge_report`/`drag`
# ctl verbs that used to synthesize mouse events on the auxmouse ring are
# RETIRED. They duplicated /dev/mouse (devmouse_write), the canonical Plan 9
# writable-mouse capability, which drives the SAME mouse_rx_push_abs queue.
# All injection callers now write absolute-move lines to /dev/mouse; cursor-
# FPS accounting moved into the compositor (user/hamUId.ad `[de_perf]
# cursor_fps=N`), so no auxmouse / jiffy / printk2 imports are needed here.
from kernel.printk.printk import printk0, printk1, printk2, printk_set_level
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_WARN
# End-to-end keyboard-delivery measurement self-test (DE input lag/loss
# investigation). Drives the FULL physical-keystroke path:
#   atkbd_process_byte (scancode->ASCII into kbd_fifo)

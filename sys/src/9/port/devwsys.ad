    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_resize_show_read(off: uint64, buf: Ptr[uint8],
                             count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[32, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_resize_show_serial)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_resize_show_write(buf: Ptr[uint8], count: uint64) -> int64:
    wsys_resize_show_bump()
    return cast[int64](count)


# ====================================================================
# DE pivot wave 6 — OSD popup = /bin/hamosd
# ====================================================================
# /dev/wsys/osd: "<show> <active> <kind> <ws> <slider_pct> <gen>\n"
# kind 0=workspace label, 1=volume slider, 2=brightness slider.

wsys_osd_active: int32 = 0
wsys_osd_kind:   int32 = 0
wsys_osd_ws:     int32 = 0
wsys_osd_pct:    int32 = 0
wsys_osd_gen:    uint64 = 0
wsys_osd_show_serial: uint64 = 0


def wsys_osd_set(a: int32, k: int32, ws_v: int32, pct: int32):
    wsys_osd_active = a
    wsys_osd_kind = k
    wsys_osd_ws = ws_v
    wsys_osd_pct = pct
    wsys_osd_gen = wsys_osd_gen + 1


def wsys_osd_show_bump():
    wsys_osd_show_serial = wsys_osd_show_serial + 1


def devwsys_osd_read(off: uint64, buf: Ptr[uint8],
                     count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[128, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_osd_show_serial)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_osd_active))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_osd_kind))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_osd_ws))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_osd_pct))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, wsys_osd_gen)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_osd_show_read(off: uint64, buf: Ptr[uint8],
                          count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[32, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_osd_show_serial)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_osd_show_write(buf: Ptr[uint8], count: uint64) -> int64:
    wsys_osd_show_bump()
    return cast[int64](count)


# ====================================================================
# DE pivot wave 7 — message tray history = /bin/hamtray
# ====================================================================
# /dev/wsys/tray: "<show> <open> <count> <x> <y> <w> <h> <gen>\n"
# Published via /dev/wsys/ctl `tray <open> <count> <x> <y> <w> <h>`.

wsys_tray_open:  int32 = 0
wsys_tray_count: int32 = 0
wsys_tray_x:     int32 = 0
wsys_tray_y:     int32 = 0
wsys_tray_w:     int32 = 0
wsys_tray_h:     int32 = 0
wsys_tray_gen:   uint64 = 0
wsys_tray_show_serial: uint64 = 0


def wsys_tray_set(o: int32, c: int32, x: int32, y: int32, w: int32, h: int32):
    wsys_tray_open = o
    wsys_tray_count = c
    wsys_tray_x = x
    wsys_tray_y = y
    wsys_tray_w = w
    wsys_tray_h = h
    wsys_tray_gen = wsys_tray_gen + 1


def wsys_tray_show_bump():
    wsys_tray_show_serial = wsys_tray_show_serial + 1


def devwsys_tray_read(off: uint64, buf: Ptr[uint8],
                      count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[192, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_tray_show_serial)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_tray_open))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_tray_count))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_i32_signed(&scratch[0], n, wsys_tray_x)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_i32_signed(&scratch[0], n, wsys_tray_y)
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_tray_w))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, cast[uint64](wsys_tray_h))
    scratch[n] = 32
    n = n + 1
    n = _wsys_emit_u64_dec(&scratch[0], n, wsys_tray_gen)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_tray_show_read(off: uint64, buf: Ptr[uint8],
                           count: uint64) -> int64:
    if off > 0:
        return 0
    scratch: Array[32, uint8]
    n: uint64 = _wsys_emit_u64_dec(&scratch[0], 0, wsys_tray_show_serial)
    scratch[n] = 10
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devwsys_tray_show_write(buf: Ptr[uint8], count: uint64) -> int64:
    wsys_tray_show_bump()
    return cast[int64](count)


# Helper used by all multi-int ctl verbs below: parse one signed decimal
# at `pos`. On success returns 0 and writes the value to *out_v + the
# next offset to *out_pos. On error (no digit) returns -1.
def _wsys_ctl_parse_i64(buf: Ptr[uint8], pos: uint64, count: uint64,
                        out_v: Ptr[int64], out_pos: Ptr[uint64]) -> int32:
    p: uint64 = pos
    neg: int32 = 0
    if p < count and buf[p] == 45:
        neg = 1
        p = p + 1
    start: uint64 = p
    v: int64 = 0
    while p < count and buf[p] >= 48 and buf[p] <= 57:
        v = v * 10 + cast[int64](buf[p] - 48)
        p = p + 1
    if p == start:
        return -1
    if neg != 0:
        v = -v
    out_v[0] = v
    out_pos[0] = p
    return 0


# ====================================================================
# DE primitive: /dev/wsys/<N>/wctl — per-window control file (Plan 9
# rio's wctl shape). Three verb lines accepted on write:
#
#   resize <w> <h>          request a new size for the window
#   move   <x> <y>          request a new top-left position
#   focus  click|sloppy     set focus policy (click-to-focus vs
#                           focus-follows-pointer / "sloppy")
#
# Storage is per-wid. The compositor (user/hamUId.ad) polls a read of
# /dev/wsys/<N>/wctl, which renders one ASCII status line:
#
#   "<x> <y> <w> <h> <focus>\n"
#
# where <focus> is the literal "click" or "sloppy". The compositor
# honours the requested rect on the next frame (updates window rect,
# redraws). Focus is consulted by the pointer pump on motion events.
#
# Default focus mode for a fresh wid is click (matches DE-wide default
# FOCUS_MODE = 0). Default rect is zeros until the compositor or a
# wctl writer sets one — a zero-w/zero-h read just means "no request
# yet", not "size==0".
#
# Hostowner gate matches /dev/wsys/ctl (drift syscall retirement
# already established the trusted-DE writer model). A non-uid-1 caller
# gets -EPERM on write; reads are unrestricted so the compositor can
# poll a wctl status line regardless of which uid spawned the bound
# client.

# Per-window pending wctl request. -1 sentinel for "no request yet".
wsys_wctl_x: Array[32, int64]
wsys_wctl_y: Array[32, int64]
wsys_wctl_w: Array[32, int64]
wsys_wctl_h: Array[32, int64]
# 0 = click (default), 1 = sloppy (focus-follows-pointer).
wsys_wctl_focus: Array[32, int32]
# Monotonic per-wid counter — bumped on EVERY successful wctl write so
# the compositor can spot a freshly-issued request without parsing
# rect equality.
wsys_wctl_serial: Array[32, uint64]


def _wctl_word_eq(buf: Ptr[uint8], start: uint64, end: uint64,
                  word: Ptr[uint8]) -> int32:
    wl: uint64 = 0
    while word[wl] != 0:
        wl = wl + 1
    if end - start != wl:
        return 0
    i: uint64 = 0
    while i < wl:
        if buf[start + i] != word[i]:
            return 0
        i = i + 1
    return 1


def _wctl_parse_i64(buf: Ptr[uint8], start: uint64, end: uint64,
                    out: Ptr[int64]) -> int32:
    # Parse a (possibly negative) decimal integer in buf[start..end).
    # Returns 1 on success, 0 on a bad char / empty range.
    if start >= end:
        return 0
    p: uint64 = start
    sign: int64 = 1
    if buf[p] == 45:                                  # '-'
        sign = -1
        p = p + 1
        if p >= end:
            return 0
    v: int64 = 0
    while p < end:
        c: uint8 = buf[p]
        if c < 48 or c > 57:
            return 0
        v = v * 10 + cast[int64](c) - 48
        p = p + 1
    out[0] = v * sign
    return 1


def wsys_wctl_focus_mode(wid: int32) -> int32:
    # Public accessor for the compositor: returns 0 (click) / 1
    # (sloppy) for the per-window focus mode. Out-of-range wid returns
    # 0 so callers can default safely.
    if wid <= 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return 0
    return wsys_wctl_focus[u]


def devwsys_wctl_write(wid: int32, buf: Ptr[uint8],
                       count: uint64) -> int64:
    # Per-window verb sink (resize / move / focus / version negotiation).
    # Parses one verb line per call (the caller is expected to write one
    # verb at a time, matching the /dev/wsys/ctl idiom).
    #
    # DE correction Phase 1: this is a PER-WINDOW surface, so the WINDOW'S
    # OWNER may write it regardless of hostowner/uid/namespace — that is
    # what lets a DE-spawned client (panels/menu/terminal/apps, all running
    # as uid NOBODY) write `version 2\n` and opt into the blit path so its
    # backbuffer reaches the screen. Hostowner is still permitted (the
    # compositor drives some windows). Non-owner, non-hostowner = denied;
    # a process may control its OWN window, not another's. The system-wide
    # /dev/wsys/ctl stays hostowner-only (devwsys_ctl_write, unchanged).
    if wsys_wid_in_use(wid) == 0:
        set_current_errstr("/dev/wsys/wctl: wid not in use")
        return -1
    if current_task_is_hostowner() == 0 and _wsys_caller_owns_wid(wid) == 0:
        set_current_errstr("/dev/wsys/wctl: permission denied (not window owner)")
        return -1
    if count == 0:
        return 0
    u: uint64 = cast[uint64](wid)
    p: uint64 = _wsys_ctl_skip_ws(buf, 0, count)
    vs: uint64 = p
    p = _wsys_ctl_token_end(buf, p, count)
    ve: uint64 = p
    if vs == ve:
        set_current_errstr("/dev/wsys/wctl: missing verb")
        return -1

    # #442 (c) version <n> — opt this window into protocol version n.
    # n=0 / n=1 = legacy text-shape draw (current). n=2 = blit protocol
    # ('B' / 'D' / 'C' on /dev/wsys/<wid>/draw/ctl). Anything else is
    # rejected so the parser stays a closed set; subsequent protocol
    # increments add explicit verbs here.
    if _wctl_word_eq(buf, vs, ve, "version") == 1:
        pv: uint64 = _wsys_ctl_skip_ws(buf, p, count)
        ve_a: uint64 = _wsys_ctl_token_end(buf, pv, count)
        if pv == ve_a:
            set_current_errstr("/dev/wsys/wctl: version: missing arg")
            return -1
        vn: uint64 = 0
        if _wsys_ctl_parse_u64(buf, pv, ve_a, &vn) == 0:
            set_current_errstr("/dev/wsys/wctl: version: bad arg")
            return -1
        if vn > 2:
            set_current_errstr("/dev/wsys/wctl: version: unsupported")
            return -1
        wsys_win_version[u] = cast[int32](vn)
        # A protocol switch is a damage event for the whole window — the
        # compositor must repaint to pick up the new path on next frame.
        _wsys_mark_dirty(wid, 0, 0, 65535, 65535)
        wsys_wctl_serial[u] = wsys_wctl_serial[u] + 1
        return cast[int64](count)

    # focus click|sloppy
    if _wctl_word_eq(buf, vs, ve, "focus") == 1:
        p = _wsys_ctl_skip_ws(buf, p, count)
        a1s: uint64 = p
        p = _wsys_ctl_token_end(buf, p, count)
        a1e: uint64 = p
        if a1s == a1e:
            set_current_errstr("/dev/wsys/wctl: focus: missing mode")
            return -1
        if _wctl_word_eq(buf, a1s, a1e, "click") == 1:
            wsys_wctl_focus[u] = 0
        else:
            if _wctl_word_eq(buf, a1s, a1e, "sloppy") == 1:
                wsys_wctl_focus[u] = 1
            else:
                set_current_errstr("/dev/wsys/wctl: focus: bad mode (want click|sloppy)")
                return -1
        wsys_wctl_serial[u] = wsys_wctl_serial[u] + 1
        return cast[int64](count)

    # resize <w> <h>  /  move <x> <y>: both take two i64 args.
    p = _wsys_ctl_skip_ws(buf, p, count)
    a1s2: uint64 = p
    p = _wsys_ctl_token_end(buf, p, count)
    a1e2: uint64 = p
    arg1: int64 = 0
    if a1s2 == a1e2 or _wctl_parse_i64(buf, a1s2, a1e2, &arg1) == 0:
        set_current_errstr("/dev/wsys/wctl: bad/missing first argument")
        return -1
    p = _wsys_ctl_skip_ws(buf, p, count)
    a2s: uint64 = p
    p = _wsys_ctl_token_end(buf, p, count)
    a2e: uint64 = p
    arg2: int64 = 0
    if a2s == a2e or _wctl_parse_i64(buf, a2s, a2e, &arg2) == 0:
        set_current_errstr("/dev/wsys/wctl: bad/missing second argument")
        return -1

    if _wctl_word_eq(buf, vs, ve, "resize") == 1:
        if arg1 < 0 or arg2 < 0:
            set_current_errstr("/dev/wsys/wctl: resize: negative dimension")
            return -1
        wsys_wctl_w[u] = arg1
        wsys_wctl_h[u] = arg2
        wsys_wctl_serial[u] = wsys_wctl_serial[u] + 1
        return cast[int64](count)

    if _wctl_word_eq(buf, vs, ve, "move") == 1:
        wsys_wctl_x[u] = arg1
        wsys_wctl_y[u] = arg2
        wsys_wctl_serial[u] = wsys_wctl_serial[u] + 1
        return cast[int64](count)

    set_current_errstr("/dev/wsys/wctl: bad verb")
    return -1


def _wctl_emit_i64(scratch: Ptr[uint8], pos: uint64, v: int64) -> uint64:
    # Render a (possibly negative) decimal int64 into scratch[pos..].
    # Returns the new position.
    p: uint64 = pos
    val: int64 = v
    if val < 0:
        scratch[p] = 45                               # '-'
        p = p + 1
        val = -val
    if val == 0:
        scratch[p] = 48
        return p + 1
    digs: Array[24, uint8]
    d: uint64 = 0
    while val > 0:
        digs[d] = cast[uint8](val % 10) + 48
        val = val / 10
        d = d + 1
    while d > 0:
        d = d - 1
        scratch[p] = digs[d]
        p = p + 1
    return p


def devwsys_wctl_read(wid: int32, off: uint64, buf: Ptr[uint8],
                      count: uint64) -> int64:
    # Render the per-wid status line "<x> <y> <w> <h> <focus>\n".
    # Snapshot-once: off>0 returns EOF so `cat /dev/wsys/<N>/wctl`
    # terminates.
    if off > 0:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return 0
    u: uint64 = cast[uint64](wid)
    scratch: Array[96, uint8]
    n: uint64 = 0
    n = _wctl_emit_i64(&scratch[0], n, wsys_wctl_x[u])
    scratch[n] = 32                                   # ' '
    n = n + 1
    n = _wctl_emit_i64(&scratch[0], n, wsys_wctl_y[u])
    scratch[n] = 32
    n = n + 1
    n = _wctl_emit_i64(&scratch[0], n, wsys_wctl_w[u])
    scratch[n] = 32
    n = n + 1
    n = _wctl_emit_i64(&scratch[0], n, wsys_wctl_h[u])
    scratch[n] = 32
    n = n + 1
    if wsys_wctl_focus[u] == 1:
        # "sloppy"
        scratch[n] = 115                              # s
        n = n + 1
        scratch[n] = 108                              # l
        n = n + 1
        scratch[n] = 111                              # o
        n = n + 1
        scratch[n] = 112                              # p
        n = n + 1
        scratch[n] = 112                              # p
        n = n + 1
        scratch[n] = 121                              # y
        n = n + 1
    else:
        # "click"
        scratch[n] = 99                               # c
        n = n + 1
        scratch[n] = 108                              # l
        n = n + 1
        scratch[n] = 105                              # i
        n = n + 1
        scratch[n] = 99                               # c
        n = n + 1
        scratch[n] = 107                              # k
        n = n + 1
    scratch[n] = 10                                   # '\n'
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


# ====================================================================
# DE primitive: /dev/wsys/session — read-only window-set snapshot
# ====================================================================
# Plan 9 idiom for session save/restore: dump the current window set as
# a text file the userland helper can persist and replay on next login.
# One line per ACTIVE wid:
#
#   "<wid> <pid> <app-path> <x> <y> <w> <h>\n"
#
# x/y/w/h come from the wctl request arrays (the compositor's
# last-resize/move write). app-path comes from the per-wid app slot
# populated by the /dev/wsys/ctl `setapp <wid> <path>` verb (the
# compositor records the spawned program path after each
# daemon_spawn_window_prog so this snapshot is replay-able). An unset
# app-path renders as "-" so the userland helper's tokeniser sees a
# stable seven-column line regardless of registration state.
#
# Snapshot read: off > 0 returns EOF so `cat /dev/wsys/session`
# terminates cleanly. Reads are unrestricted (no hostowner gate) —
# the snapshot does not leak window CONTENTS, only the public listing
# columns that /dev/wsys already exposes plus the app-path verb the
# compositor registered.

WSYS_APP_PATH_CAP: uint64 = 128
# Flat per-wid storage: wsys_app_path[wid * 128 + i]. 32 * 128 = 4096.
wsys_app_path: Array[4096, uint8]
wsys_app_path_len: Array[32, uint64]


def wsys_app_path_set(wid: int32, src: Ptr[uint8], len: uint64) -> int32:
    # Record the program path that was just spawned into `wid`. Cap at
    # WSYS_APP_PATH_CAP - 1 so a future C-string consumer (if any) sees
    # a NUL-safe slot. Returns 0 on success, -1 on bad wid.
    if wid <= 0:
        return -1
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return -1
    clen: uint64 = len
    if clen >= WSYS_APP_PATH_CAP:
        clen = WSYS_APP_PATH_CAP - 1
    base: uint64 = u * WSYS_APP_PATH_CAP
    i: uint64 = 0
    while i < clen:
        wsys_app_path[base + i] = src[i]
        i = i + 1
    wsys_app_path_len[u] = clen
    return 0


def _wsys_session_emit_i64(out: Ptr[uint8], pos: uint64, v: int64) -> uint64:
    # Mirror of _wctl_emit_i64 (private to its block). Render a signed
    # decimal int64 into out[pos..].
    p: uint64 = pos
    val: int64 = v
    if val < 0:
        out[p] = 45                                   # '-'
        p = p + 1
        val = -val
    if val == 0:
        out[p] = 48
        return p + 1
    digs: Array[24, uint8]
    d: uint64 = 0
    while val > 0:
        digs[d] = cast[uint8](val % 10) + 48
        val = val / 10
        d = d + 1
    while d > 0:
        d = d - 1
        out[p] = digs[d]
        p = p + 1
    return p


def _wsys_session_emit_u64(out: Ptr[uint8], pos: uint64, v: uint64) -> uint64:
    p: uint64 = pos
    if v == 0:
        out[p] = 48
        return p + 1
    digs: Array[24, uint8]
    d: uint64 = 0
    val: uint64 = v
    while val > 0:
        digs[d] = cast[uint8](val % 10) + 48
        val = val / 10
        d = d + 1
    while d > 0:
        d = d - 1
        out[p] = digs[d]
        p = p + 1
    return p


def _wsys_session_render(out: Ptr[uint8], cap: uint64) -> uint64:
    # Render the session snapshot into out[0..cap). One line per active
    # wid. Stops short if the next line wouldn't fit.
    _wsys_init_if_needed()
    pos: uint64 = 0
    w: uint64 = 1
    while w < MAX_WINDOWS:
        if wsys_slot_in_use[w] != 0:
            # Defensive per-line cap: 4 * 24 digits for rects + 24 each
            # for wid+pid + the app-path (<=127) + separators/newline.
            if pos + 256 >= cap:
                break
            # wid
            pos = _wsys_session_emit_u64(out, pos, w)
            out[pos] = 32
            pos = pos + 1
            # pid
            pos = _wsys_session_emit_u64(out, pos, wsys_slot_pid[w])
            out[pos] = 32
            pos = pos + 1
            # app-path ("-" if unset)
            alen: uint64 = wsys_app_path_len[w]
            if alen == 0:
                out[pos] = 45                         # '-'
                pos = pos + 1
            else:
                base: uint64 = w * WSYS_APP_PATH_CAP
                j: uint64 = 0
                while j < alen:
                    c: uint8 = wsys_app_path[base + j]
                    # Defensive: any whitespace inside the path becomes
                    # '_' so the snapshot stays one-line-per-window and
                    # the userland tokeniser can split on spaces safely.
                    if c == 32 or c == 10 or c == 13 or c == 9:
                        out[pos] = 95                 # '_'
                    else:
                        out[pos] = c
                    pos = pos + 1
                    j = j + 1
            out[pos] = 32
            pos = pos + 1
            # rect: x y w h (from the wctl request arrays).
            pos = _wsys_session_emit_i64(out, pos, wsys_wctl_x[w])
            out[pos] = 32
            pos = pos + 1
            pos = _wsys_session_emit_i64(out, pos, wsys_wctl_y[w])
            out[pos] = 32
            pos = pos + 1
            pos = _wsys_session_emit_i64(out, pos, wsys_wctl_w[w])
            out[pos] = 32
            pos = pos + 1
            pos = _wsys_session_emit_i64(out, pos, wsys_wctl_h[w])
            out[pos] = 10                             # '\n'
            pos = pos + 1
        w = w + 1
    return pos


def devwsys_session_read(off: uint64, buf: Ptr[uint8],
                         count: uint64) -> int64:
    # /dev/wsys/session snapshot read. off > 0 ends the read (one-shot
    # listing), mirroring the /dev/wsys directory listing semantics.
    if off > 0:
        return 0
    if count == 0:
        return 0
    scratch: Array[2048, uint8]
    n: uint64 = _wsys_session_render(&scratch[0], 2048)
    take: uint64 = count
    if take > n:
        take = n
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


# ====================================================================
# #442 (c) RIO-FAITHFUL BLIT PROTOCOL — kernel substrate.
# ====================================================================
#
# THE KEYSTONE. The compositor was painting every visible pixel by
# walking the daemon_pixel cascade once per pixel of damage. This block
# changes the shape: clients render INTO their own kernel-held back-
# buffer via the 'B' (blit) verb on /dev/wsys/<wid>/draw/ctl, then send
# a 'D' (dirty) verb so the compositor knows what to repaint. The
# compositor's job collapses to: for each v2 window with non-empty
# dirty rect, blit the kernel backbuffer rect onto SCENE_CACHE / the
# screen. ONE memcpy per damaged client rect. No per-pixel cascade.
#
# WIRE FORMAT (binary, little-endian; per the spec block at the head of
# this file):
#   'B' <x0:i32> <y0:i32> <x1:i32> <y1:i32> <fmt:u8> <pixel_bytes...>
#       Opaque blit. Pixel bytes = (x1-x0)*(y1-y0)*bpp[fmt]. Short
#       writes are EINVAL.
#   'D' <x0:i32> <y0:i32> <x1:i32> <y1:i32>
#       Dirty-rect invalidation. No pixel payload; folds into the per-
#       window damage rect the compositor already polls via
#       /dev/wsys/damage.
#   'C' <hot_x:i32> <hot_y:i32> <w:i32> <h:i32> <fmt:u8> <pixel_bytes...>
#       Cursor sprite update. Stored per-window; the compositor draws
#       it via the existing save-under sprite path.
#
# Pixel formats (must match the constants exposed to lib/hamui.ad):
#   FMT_RGBA8888 = 1, bpp 4
#   FMT_BGRA8888 = 2, bpp 4
#   FMT_A8       = 3, bpp 1
#
# BACKBUFFER SIZING. Per-window 320x200 RGBA8888 fits the rio-spec
# substrate without bloating BSS; the protocol is rect-addressed so a
# client never sees the dimensions cap until it tries to blit outside.
# Real-display windows (typically 640x480 in this tree) are unchanged
# on the legacy path; v2 clients negotiate their backbuffer dims by
# writing `version 2` then `setdim <w> <h>` to wctl in a later
# increment. For the keystone landing we hardcode the cap.

WSYS_BLIT_FMT_RGBA8888: uint8 = 1
WSYS_BLIT_FMT_BGRA8888: uint8 = 2
WSYS_BLIT_FMT_A8:       uint8 = 3

WSYS_BB_W: uint64 = 1280      # backbuffer width  (pixels) — full screen
WSYS_BB_H: uint64 = 800       # backbuffer height (pixels) — full screen
WSYS_BB_BPP: uint64 = 4       # storage is always RGBA8888 internally
# Per-window backbuffer size in bytes (used to index the flat Array).
WSYS_BB_STRIDE_BYTES: uint64 = 5120   # WSYS_BB_W * WSYS_BB_BPP
WSYS_BB_BYTES_PER_WIN: uint64 = 4096000  # 1280 * 800 * 4

# Per-window backbuffer storage: 4 096 000 bytes (1280*800*4 RGBA8888)
# per window. Stored as RGBA8888 regardless of the submitting blit's
# pixel format; the parser converts on ingestion so the compositor never
# has to branch on fmt.
#
# OOM REGRESSION FIX (devwsys MAX_WINDOWS 9->32): this used to be a flat
# static Array[131072000] (~125 MiB) of BSS. At 32 windows that, plus the
# 128 MiB wsys_layer_fb above, OOMed a modest-RAM VM at boot. It is now a
# 32-slot array of POINTERS (8 bytes each, 0 = unallocated). The ~4 MiB
# block for a window is allocated lazily on first blit and freed when the
# wid slot is released. A backbuffer fits in an order-10 buddy block
# (4 MiB); the ~96 KiB of slack at the tail of the block is unused.
WSYS_BB_ORDER: int32 = 10                     # 1024 pages = 4 MiB >= 4096000
wsys_backbuffer_page: Array[32, uint64]       # per-wid base addr, 0=none

# Per-window protocol version. 0/1 = legacy text/markup (current);
# 2 = blit protocol. Default 0; flipped by wctl `version <n>`.
wsys_win_version: Array[32, int32]

# Per-window backbuffer-dirty rect for the v2 compositor path. Separate
# from wsys_dirty_* (which the legacy markup path uses) so a v2 client
# 'D' verb does not perturb the existing damage accounting.
wsys_bb_dx0: Array[32, int64]
wsys_bb_dy0: Array[32, int64]
wsys_bb_dx1: Array[32, int64]
wsys_bb_dy1: Array[32, int64]
# Per-window v2 frame serial: bumped on every accepted 'D'. Compositors
# read this to skip windows that have not changed since the last frame.
wsys_bb_serial: Array[32, uint64]

# Per-window cursor sprite. Cap 32x32 RGBA = 4 KiB per slot = 128 KiB
# total. Plenty for the rio-shape per-window focus cursor (the global
# pointer cursor stays on the existing daemon_pump_mouse save-under
# path; this is the per-window focus indicator).
WSYS_CUR_MAX_W: uint64 = 32
WSYS_CUR_MAX_H: uint64 = 32
WSYS_CUR_BYTES_PER_WIN: uint64 = 4096    # 32*32*4
wsys_cursor_pix: Array[131072, uint8]     # 32 * 4096
wsys_cursor_w:    Array[32, int32]
wsys_cursor_h:    Array[32, int32]
wsys_cursor_hx:   Array[32, int32]
wsys_cursor_hy:   Array[32, int32]
wsys_cursor_gen:  Array[32, uint64]


def wsys_win_version_get(wid: int32) -> int32:
    # Public: the per-window protocol version (0 default, 2 = blit).
    # The fast-path gate in devwsys_draw_ctl_write reads this; the
    # compositor's per-frame walk reads this to pick the blit path
    # vs the legacy markup path per window.
    if wid <= 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return 0
    return wsys_win_version[u]


def _wsys_backbuffer_ensure(wid: int32) -> Ptr[uint8]:
    # Pointer to wid's 4 MiB backbuffer block, allocating it from the
    # buddy allocator on first use. Null on bad wid / alloc failure.
    if wid <= 0:
        return cast[Ptr[uint8]](0)
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return cast[Ptr[uint8]](0)
    if wsys_backbuffer_page[u] == 0:
        p: uint64 = alloc_pages(WSYS_BB_ORDER)
        if p == 0:
            return cast[Ptr[uint8]](0)
        memset(cast[Ptr[uint8]](p), 0, WSYS_BB_BYTES_PER_WIN)
        wsys_backbuffer_page[u] = p
    return cast[Ptr[uint8]](wsys_backbuffer_page[u])


def _wsys_backbuffer_release(wid: int32):
    # Free wid's backbuffer block back to the buddy allocator. No-op on
    # an unallocated slot.
    if wid <= 0:
        return
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return
    if wsys_backbuffer_page[u] != 0:
        free_pages(wsys_backbuffer_page[u], WSYS_BB_ORDER)
        wsys_backbuffer_page[u] = 0


def wsys_backbuffer_ptr(wid: int32) -> Ptr[uint8]:
    # Public: pointer to wid's RGBA8888 backbuffer storage (stride
    # WSYS_BB_STRIDE_BYTES bytes, dims WSYS_BB_W x WSYS_BB_H). Returns
    # null on a bad wid OR a window that has never been blitted (lazy
    # alloc) — the compositor already treats null as "nothing to draw"
    # and falls back to its legacy path.
    if wid <= 0:
        return cast[Ptr[uint8]](0)
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return cast[Ptr[uint8]](0)
    return cast[Ptr[uint8]](wsys_backbuffer_page[u])


def wsys_backbuffer_dims_w() -> uint64:
    return WSYS_BB_W


def wsys_backbuffer_dims_h() -> uint64:
    return WSYS_BB_H


# ====================================================================
# #128 SCENE IMAGE TIER — named per-window raster images.
#
# A scene client that wants a REAL image (a decoded PNG/JPEG, a photo, an
# icon that isn't expressible as fill/line primitives) can now do it without
# converting its whole window to the v2 blit backbuffer. The shape is
# FILE-REF + format tag, kept Plan-9-shape (everything through the window's
# own file server, no global pixel buffer in the kernel beyond this small
# named store):
#
#   1. the client DECODES the image in USERLAND (lib/png.ad etc. — the
#      kernel deliberately does NOT link a PNG/inflate decoder into the
#      present path) and UPLOADS the raw pixels to its window via a binary
#      'I' verb on /dev/wsys/<wid>/draw/ctl:
#          'I' <namelen:u8> <name...> <w:i32le> <h:i32le> <fmt:u8> <pixels>
#      naming the image (a bareword, e.g. "logo"). fmt is a WSYS_BLIT_FMT_*;
#      the store normalizes everything to RGBA8888. Re-uploading the same
#      name replaces it.
#   2. the client references it from its scene display list with the
#      `image x y w h NAME` verb (lib/hamscene.ad's hamscene_image). The
#      compositor (this file) looks the name up in the window's store and
#      blits it into (x,y,w,h), nearest-neighbor scaled, alpha-composited
#      and clipped by the existing scene clip machinery.
#
# WHY raw-upload not kernel-decode: the compositor rasterizes on the present
# path (IRQ-masked, no sleeping); a full DEFLATE/PNG decoder there (~2.4 MiB
# of decoder BSS + heavy CPU) is the wrong place. Userland already owns the
# decoders (hamview/hambrowse). This mirrors the v2 backbuffer 'B' path,
# which is also raw-pixel upload — but keyed by NAME and decoupled from the
# full-window backbuffer so a legacy scene client drops in one image.
#
# Storage: WSYS_IMG_SLOTS global slots, each backed by a lazily-allocated
# 256 KiB page block (256x256 RGBA ceiling), keyed by (owning wid, name).
# Freed when the owning window closes.
WSYS_IMG_SLOTS:    uint64 = 16
WSYS_IMG_MAX_W:    int64  = 256
WSYS_IMG_MAX_H:    int64  = 256
WSYS_IMG_BYTES:    uint64 = 262144      # 256*256*4
WSYS_IMG_ORDER:    int32  = 6           # 64 pages = 256 KiB >= WSYS_IMG_BYTES
WSYS_IMG_NAME_CAP: uint64 = 32          # incl. NUL; max 31 name bytes

wsys_img_wid:  Array[16, int32]         # owning wid; 0 = free slot
wsys_img_name: Array[512, uint8]        # 16 slots * 32 bytes, NUL-terminated
wsys_img_w:    Array[16, int32]
wsys_img_h:    Array[16, int32]
wsys_img_page: Array[16, uint64]        # lazily-alloc'd RGBA8888 pixels


def _wsys_img_name_eq(slot: uint64, buf: Ptr[uint8], ns: uint64,
                      ne: uint64) -> int32:
    # 1 iff slot's stored name equals buf[ns..ne).
    nb: uint64 = slot * WSYS_IMG_NAME_CAP
    k: uint64 = ns
    j: uint64 = nb
    while k < ne:
        if wsys_img_name[j] == 0:
            return 0
        if wsys_img_name[j] != buf[k]:
            return 0
        k = k + 1
        j = j + 1
    if wsys_img_name[j] != 0:                # stored name is longer
        return 0
    return 1


def _wsys_img_find(wid: int32, buf: Ptr[uint8], ns: uint64,
                   ne: uint64) -> int32:
    # Slot index for (wid, name) or -1. Empty name never matches.
    if ns >= ne:
        return -1
    s: uint64 = 0
    while s < WSYS_IMG_SLOTS:
        if wsys_img_wid[s] == wid and _wsys_img_name_eq(s, buf, ns, ne) == 1:
            return cast[int32](s)
        s = s + 1
    return -1


def _wsys_img_release_wid(wid: int32):
    # Free every image slot owned by wid (called on window teardown).
    if wid <= 0:
        return
    s: uint64 = 0
    while s < WSYS_IMG_SLOTS:
        if wsys_img_wid[s] == wid:
            if wsys_img_page[s] != 0:
                free_pages(wsys_img_page[s], WSYS_IMG_ORDER)
                wsys_img_page[s] = 0
            wsys_img_wid[s] = 0
            wsys_img_name[s * WSYS_IMG_NAME_CAP] = 0
            wsys_img_w[s] = 0
            wsys_img_h[s] = 0
        s = s + 1


def _wsys_img_store(wid: int32, name: Ptr[uint8], nlen: uint64,
                    iw: int32, ih: int32, fmt: uint8,
                    pixels: Ptr[uint8]) -> int32:
    # Store (wid, name) -> iw x ih RGBA8888 image, converting from `fmt`.
    # Reuses an existing (wid,name) slot or the first free slot. 1 on ok.
    if nlen == 0 or nlen >= WSYS_IMG_NAME_CAP:
        return 0
    if iw <= 0 or ih <= 0:
        return 0
    if cast[int64](iw) > WSYS_IMG_MAX_W or cast[int64](ih) > WSYS_IMG_MAX_H:
        return 0
    bpp: uint64 = _wsys_blit_fmt_bpp(fmt)
    if bpp == 0:
        return 0
    # Locate the target slot: existing (wid,name), else first free.
    slot: int32 = _wsys_img_find(wid, name, 0, nlen)
    if slot < 0:
        s: uint64 = 0
        while s < WSYS_IMG_SLOTS:
            if wsys_img_wid[s] == 0:
                slot = cast[int32](s)
                s = WSYS_IMG_SLOTS
            else:
                s = s + 1
    if slot < 0:
        return 0                                # store full
    u: uint64 = cast[uint64](slot)
    if wsys_img_page[u] == 0:
        pg: uint64 = alloc_pages(WSYS_IMG_ORDER)
        if pg == 0:
            return 0
        wsys_img_page[u] = pg
    dst: Ptr[uint8] = cast[Ptr[uint8]](wsys_img_page[u])
    # Copy the name (NUL-terminated).
    nb: uint64 = u * WSYS_IMG_NAME_CAP
    k: uint64 = 0
    while k < nlen:
        wsys_img_name[nb + k] = name[k]
        k = k + 1
    wsys_img_name[nb + nlen] = 0
    wsys_img_wid[u] = wid
    wsys_img_w[u] = iw
    wsys_img_h[u] = ih
    # Normalize pixels to RGBA8888.
    npx: uint64 = cast[uint64](iw) * cast[uint64](ih)
    i: uint64 = 0
    while i < npx:
        soff: uint64 = i * bpp
        doff: uint64 = i * 4
        r: uint8 = 0
        g: uint8 = 0
        b: uint8 = 0
        a: uint8 = 255
        if fmt == WSYS_BLIT_FMT_RGBA8888:
            r = pixels[soff]
            g = pixels[soff + 1]
            b = pixels[soff + 2]
            a = pixels[soff + 3]
        else:
            if fmt == WSYS_BLIT_FMT_BGRA8888:
                b = pixels[soff]
                g = pixels[soff + 1]
                r = pixels[soff + 2]
                a = pixels[soff + 3]
            else:
                a8: uint8 = pixels[soff]        # A8 -> white * alpha
                r = a8
                g = a8
                b = a8
                a = a8
        dst[doff]     = r
        dst[doff + 1] = g
        dst[doff + 2] = b
        dst[doff + 3] = a
        i = i + 1
    return 1


def _wsys_cache_blit_image(cache: Ptr[uint8], slot: int32, dx: int64,
                           dy: int64, dw: int64, dh: int64):
    # Blit image `slot`'s RGBA8888 pixels into rect (dx,dy,dw,dh) of the
    # window cache, nearest-neighbor scaled. dw/dh <= 0 -> natural size.
    # Alpha-composited + clipped via _wsys_cache_putpixel.
    u: uint64 = cast[uint64](slot)
    if u >= WSYS_IMG_SLOTS:
        return
    src: Ptr[uint8] = cast[Ptr[uint8]](wsys_img_page[u])
    if cast[uint64](src) == 0:
        return
    sw: int64 = cast[int64](wsys_img_w[u])
    sh: int64 = cast[int64](wsys_img_h[u])
    if sw <= 0 or sh <= 0:
        return
    tw: int64 = dw
    th: int64 = dh
    if tw <= 0:
        tw = sw
    if th <= 0:
        th = sh
    yy: int64 = 0
    while yy < th:
        sy: int64 = yy * sh / th
        if sy >= sh:
            sy = sh - 1
        xx: int64 = 0
        while xx < tw:
            sx: int64 = xx * sw / tw
            if sx >= sw:
                sx = sw - 1
            soff: uint64 = (cast[uint64](sy) * cast[uint64](sw)
                            + cast[uint64](sx)) * 4
            _wsys_cache_putpixel(cache, dx + xx, dy + yy,
                                 src[soff], src[soff + 1],
                                 src[soff + 2], src[soff + 3])
            xx = xx + 1
        yy = yy + 1


def wsys_backbuffer_stride() -> uint64:
    return WSYS_BB_STRIDE_BYTES


def wsys_bb_serial_get(wid: int32) -> uint64:
    # Public: the v2 frame-serial counter (0 = never blitted).
    if wid <= 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return 0
    return wsys_bb_serial[u]


def wsys_bb_dirty_get(wid: int32, out_x0: Ptr[int64], out_y0: Ptr[int64],
                     out_x1: Ptr[int64], out_y1: Ptr[int64]) -> int32:
    # Public: read the v2 dirty rect for wid into (out_x0..out_y1).
    # Returns 1 if the rect is non-empty, 0 if empty / bad wid.
    if wid <= 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return 0
    out_x0[0] = wsys_bb_dx0[u]
    out_y0[0] = wsys_bb_dy0[u]
    out_x1[0] = wsys_bb_dx1[u]
    out_y1[0] = wsys_bb_dy1[u]
    if wsys_bb_dx1[u] <= wsys_bb_dx0[u] or wsys_bb_dy1[u] <= wsys_bb_dy0[u]:
        return 0
    return 1


def wsys_bb_dirty_clear(wid: int32):
    # Public: the compositor calls this after blitting the v2 window
    # to flush the dirty rect (matches the legacy `serial write ACK`
    # idiom in devwsys_serial_write).
    if wid <= 0:
        return
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return
    wsys_bb_dx0[u] = 0
    wsys_bb_dy0[u] = 0
    wsys_bb_dx1[u] = 0
    wsys_bb_dy1[u] = 0


def wsys_cursor_get_w(wid: int32) -> int32:
    if wid <= 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return 0
    return wsys_cursor_w[u]


def wsys_cursor_get_h(wid: int32) -> int32:
    if wid <= 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return 0
    return wsys_cursor_h[u]


def wsys_cursor_get_hx(wid: int32) -> int32:
    if wid <= 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return 0
    return wsys_cursor_hx[u]


def wsys_cursor_get_hy(wid: int32) -> int32:
    if wid <= 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return 0
    return wsys_cursor_hy[u]


def wsys_cursor_ptr(wid: int32) -> Ptr[uint8]:
    if wid <= 0:
        return cast[Ptr[uint8]](0)
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return cast[Ptr[uint8]](0)
    return &wsys_cursor_pix[u * WSYS_CUR_BYTES_PER_WIN]


def wsys_cursor_gen_get(wid: int32) -> uint64:
    if wid <= 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return 0
    return wsys_cursor_gen[u]


def _wsys_blit_read_i32_le(buf: Ptr[uint8], off: uint64) -> int32:
    # Little-endian i32 reader. The wire format spec says LE.
    b0: uint32 = cast[uint32](buf[off])
    b1: uint32 = cast[uint32](buf[off + 1])
    b2: uint32 = cast[uint32](buf[off + 2])
    b3: uint32 = cast[uint32](buf[off + 3])
    v: uint32 = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)
    return cast[int32](v)


def _wsys_blit_fmt_bpp(fmt: uint8) -> uint64:
    # Returns 0 on an unknown fmt (callers reject as EINVAL).
    if fmt == WSYS_BLIT_FMT_RGBA8888:
        return 4
    if fmt == WSYS_BLIT_FMT_BGRA8888:
        return 4
    if fmt == WSYS_BLIT_FMT_A8:
        return 1
    return 0


def _wsys_bb_dirty_add(wid: int32, x0: int64, y0: int64,
                      x1: int64, y1: int64):
    # Union [x0,y0)..[x1,y1) into the v2 dirty rect. Parallel to
    # _wsys_dirty_add but on the v2 storage so the legacy markup path
    # is undisturbed.
    if x1 <= x0 or y1 <= y0:
        return
    u: uint64 = cast[uint64](wid)
    if wsys_bb_dx1[u] <= wsys_bb_dx0[u] \
            or wsys_bb_dy1[u] <= wsys_bb_dy0[u]:
        wsys_bb_dx0[u] = x0
        wsys_bb_dy0[u] = y0
        wsys_bb_dx1[u] = x1
        wsys_bb_dy1[u] = y1
        return
    if x0 < wsys_bb_dx0[u]:
        wsys_bb_dx0[u] = x0
    if y0 < wsys_bb_dy0[u]:
        wsys_bb_dy0[u] = y0
    if x1 > wsys_bb_dx1[u]:
        wsys_bb_dx1[u] = x1
    if y1 > wsys_bb_dy1[u]:
        wsys_bb_dy1[u] = y1


def _wsys_blit_store_rect(wid: int32, x0: int32, y0: int32,
                          x1: int32, y1: int32, fmt: uint8,
                          src: Ptr[uint8]):
    # Convert the incoming pixel rect into the per-window RGBA8888
    # backbuffer at (x0,y0)..(x1,y1). Out-of-range rows/cols are
    # silently clipped — the per-frame compositor only reads pixels
    # under the dirty rect, so a clipped write is correct.
    u: uint64 = cast[uint64](wid)
    bbp: Ptr[uint8] = _wsys_backbuffer_ensure(wid)
    if cast[uint64](bbp) == 0:
        return                                  # no backing block — drop blit
    bb_base: uint64 = 0
    bbw: int64 = cast[int64](WSYS_BB_W)
    bbh: int64 = cast[int64](WSYS_BB_H)
    sx0: int64 = cast[int64](x0)
    sy0: int64 = cast[int64](y0)
    sx1: int64 = cast[int64](x1)
    sy1: int64 = cast[int64](y1)
    rect_w: int64 = sx1 - sx0
    rect_h: int64 = sy1 - sy0
    # Clip destination to backbuffer bounds.
    cx0: int64 = sx0
    cy0: int64 = sy0
    cx1: int64 = sx1
    cy1: int64 = sy1
    if cx0 < 0:
        cx0 = 0
    if cy0 < 0:
        cy0 = 0
    if cx1 > bbw:
        cx1 = bbw
    if cy1 > bbh:
        cy1 = bbh
    if cx1 <= cx0 or cy1 <= cy0:
        return
    bpp_src: uint64 = _wsys_blit_fmt_bpp(fmt)
    if bpp_src == 0:
        return
    src_stride: uint64 = cast[uint64](rect_w) * bpp_src
    yy: int64 = cy0
    while yy < cy1:
        sy: int64 = yy - sy0                     # source row offset
        src_row_off: uint64 = cast[uint64](sy) * src_stride \
                              + cast[uint64](cx0 - sx0) * bpp_src
        dst_row_off: uint64 = bb_base \
                              + cast[uint64](yy) * WSYS_BB_STRIDE_BYTES \
                              + cast[uint64](cx0) * WSYS_BB_BPP
        xx: int64 = cx0
        while xx < cx1:
            r: uint8 = 0
            g: uint8 = 0
            b: uint8 = 0
            a: uint8 = 255
            if fmt == WSYS_BLIT_FMT_RGBA8888:
                r = src[src_row_off]
                g = src[src_row_off + 1]
                b = src[src_row_off + 2]
                a = src[src_row_off + 3]
                src_row_off = src_row_off + 4
            else:
                if fmt == WSYS_BLIT_FMT_BGRA8888:
                    b = src[src_row_off]
                    g = src[src_row_off + 1]
                    r = src[src_row_off + 2]
                    a = src[src_row_off + 3]
                    src_row_off = src_row_off + 4
                else:
                    # A8 — opacity-only; we materialise as opaque gray
                    # for the compositor (the alpha channel becomes the
                    # luminance and the alpha byte). The spec leaves
                    # this client-policy; gray-on-A8 is a sane default
                    # that lets glyph blits land visibly.
                    a8: uint8 = src[src_row_off]
                    r = a8
                    g = a8
                    b = a8
                    a = 255
                    src_row_off = src_row_off + 1
            bbp[dst_row_off]     = r
            bbp[dst_row_off + 1] = g
            bbp[dst_row_off + 2] = b
            bbp[dst_row_off + 3] = a
            dst_row_off = dst_row_off + 4
            xx = xx + 1
        yy = yy + 1


def _wsys_cursor_store(wid: int32, hx: int32, hy: int32,
                       w: int32, h: int32, fmt: uint8,
                       src: Ptr[uint8]):
    # Store a per-window cursor sprite. Out-of-cap sprites are silently
    # truncated to WSYS_CUR_MAX_*.
    u: uint64 = cast[uint64](wid)
    cw: int32 = w
    ch: int32 = h
    if cw < 0:
        cw = 0
    if ch < 0:
        ch = 0
    if cast[uint64](cw) > WSYS_CUR_MAX_W:
        cw = cast[int32](WSYS_CUR_MAX_W)
    if cast[uint64](ch) > WSYS_CUR_MAX_H:
        ch = cast[int32](WSYS_CUR_MAX_H)
    wsys_cursor_w[u]  = cw
    wsys_cursor_h[u]  = ch
    wsys_cursor_hx[u] = hx
    wsys_cursor_hy[u] = hy
    wsys_cursor_gen[u] = wsys_cursor_gen[u] + 1
    bpp_src: uint64 = _wsys_blit_fmt_bpp(fmt)
    if bpp_src == 0 or cw <= 0 or ch <= 0:
        return
    base: uint64 = u * WSYS_CUR_BYTES_PER_WIN
    yy: int32 = 0
    while yy < ch:
        xx: int32 = 0
        while xx < cw:
            doff: uint64 = base \
                + cast[uint64](yy) * WSYS_CUR_MAX_W * 4 \
                + cast[uint64](xx) * 4
            soff: uint64 = (cast[uint64](yy) * cast[uint64](w) \
                            + cast[uint64](xx)) * bpp_src
            r: uint8 = 0
            g: uint8 = 0
            b: uint8 = 0
            a: uint8 = 255
            if fmt == WSYS_BLIT_FMT_RGBA8888:
                r = src[soff]
                g = src[soff + 1]
                b = src[soff + 2]
                a = src[soff + 3]
            else:
                if fmt == WSYS_BLIT_FMT_BGRA8888:
                    b = src[soff]
                    g = src[soff + 1]
                    r = src[soff + 2]
                    a = src[soff + 3]
                else:
                    a8: uint8 = src[soff]
                    r = a8
                    g = a8
                    b = a8
                    a = a8
            wsys_cursor_pix[doff]     = r
            wsys_cursor_pix[doff + 1] = g
            wsys_cursor_pix[doff + 2] = b
            wsys_cursor_pix[doff + 3] = a
            xx = xx + 1
        yy = yy + 1


def _wsys_blit_parse(wid: int32, buf: Ptr[uint8], count: uint64) -> int64:
    # Parse and apply ONE binary blit verb from buf[0..count). On a
    # malformed write returns -EINVAL via set_current_errstr; a short
    # write (pixel payload truncated) is treated as EINVAL too —
    # callers must submit one whole verb per write() exactly like the
    # text ctl path. Returns the byte count consumed on success.
    if count < 1:
        set_current_errstr("/dev/wsys/draw/ctl: short blit header")
        return -1
    verb: uint8 = buf[0]

    # 'D' x0 y0 x1 y1 — dirty-rect invalidation. 17 bytes total.
    if verb == 68:                                     # 'D'
        if count < 17:
            set_current_errstr("/dev/wsys/draw/ctl: short D header")
            return -1
        dx0: int32 = _wsys_blit_read_i32_le(buf, 1)
        dy0: int32 = _wsys_blit_read_i32_le(buf, 5)
        dx1: int32 = _wsys_blit_read_i32_le(buf, 9)
        dy1: int32 = _wsys_blit_read_i32_le(buf, 13)
        _wsys_bb_dirty_add(wid, cast[int64](dx0), cast[int64](dy0),
                          cast[int64](dx1), cast[int64](dy1))
        u: uint64 = cast[uint64](wid)
        wsys_bb_serial[u] = wsys_bb_serial[u] + 1
        # Also bump the existing per-window serial so legacy compositor
        # poll paths see the change (a 'D' is a damage event).
        _wsys_mark_dirty(wid, cast[int64](dx0), cast[int64](dy0),
                         cast[int64](dx1), cast[int64](dy1))
        return 17

    # 'B' x0 y0 x1 y1 fmt <pixels> — opaque blit. 18 byte header.
    if verb == 66:                                     # 'B'
        if count < 18:
            set_current_errstr("/dev/wsys/draw/ctl: short B header")
            return -1
        bx0: int32 = _wsys_blit_read_i32_le(buf, 1)
        by0: int32 = _wsys_blit_read_i32_le(buf, 5)
        bx1: int32 = _wsys_blit_read_i32_le(buf, 9)
        by1: int32 = _wsys_blit_read_i32_le(buf, 13)
        bfmt: uint8 = buf[17]
        if bx1 <= bx0 or by1 <= by0:
            set_current_errstr("/dev/wsys/draw/ctl: empty B rect")
            return -1
        bpp: uint64 = _wsys_blit_fmt_bpp(bfmt)
        if bpp == 0:
            set_current_errstr("/dev/wsys/draw/ctl: B bad fmt")
            return -1
        rw: uint64 = cast[uint64](bx1 - bx0)
        rh: uint64 = cast[uint64](by1 - by0)
        pix_bytes: uint64 = rw * rh * bpp
        if count < 18 + pix_bytes:
            set_current_errstr("/dev/wsys/draw/ctl: B short payload")
            return -1
        _wsys_blit_store_rect(wid, bx0, by0, bx1, by1, bfmt,
                              &buf[18])
        # A 'B' also implicitly damages the rect (a 'D' usually follows
        # for the coalesced bounding box, but a client that only does
        # 'B' still has visible damage).
        _wsys_bb_dirty_add(wid, cast[int64](bx0), cast[int64](by0),
                          cast[int64](bx1), cast[int64](by1))
        _wsys_mark_dirty(wid, cast[int64](bx0), cast[int64](by0),
                         cast[int64](bx1), cast[int64](by1))
        return cast[int64](18 + pix_bytes)

    # 'C' hx hy w h fmt <pixels> — cursor sprite update. 18 byte header.
    if verb == 67:                                     # 'C'
        if count < 18:
            set_current_errstr("/dev/wsys/draw/ctl: short C header")
            return -1
        chx: int32 = _wsys_blit_read_i32_le(buf, 1)
        chy: int32 = _wsys_blit_read_i32_le(buf, 5)
        cw_:  int32 = _wsys_blit_read_i32_le(buf, 9)
        ch_:  int32 = _wsys_blit_read_i32_le(buf, 13)
        cfmt: uint8 = buf[17]
        if cw_ <= 0 or ch_ <= 0:
            set_current_errstr("/dev/wsys/draw/ctl: C empty sprite")
            return -1
        bppc: uint64 = _wsys_blit_fmt_bpp(cfmt)
        if bppc == 0:
            set_current_errstr("/dev/wsys/draw/ctl: C bad fmt")
            return -1
        cpix: uint64 = cast[uint64](cw_) * cast[uint64](ch_) * bppc
        if count < 18 + cpix:
            set_current_errstr("/dev/wsys/draw/ctl: C short payload")
            return -1
        _wsys_cursor_store(wid, chx, chy, cw_, ch_, cfmt, &buf[18])
        return cast[int64](18 + cpix)

    # 'I' <namelen:u8> <name...> <w:i32le> <h:i32le> <fmt:u8> <pixels> —
    # #128 named image store. Header = 2 + namelen + 9 bytes.
    if verb == 73:                                     # 'I'
        if count < 2:
            set_current_errstr("/dev/wsys/draw/ctl: short I header")
            return -1
        nlen: uint64 = cast[uint64](buf[1])
        if nlen == 0 or nlen >= WSYS_IMG_NAME_CAP:
            set_current_errstr("/dev/wsys/draw/ctl: I bad name len")
            return -1
        hdr: uint64 = 2 + nlen + 9
        if count < hdr:
            set_current_errstr("/dev/wsys/draw/ctl: short I header")
            return -1
        iw: int32 = _wsys_blit_read_i32_le(buf, 2 + nlen)
        ih: int32 = _wsys_blit_read_i32_le(buf, 2 + nlen + 4)
        ifmt: uint8 = buf[2 + nlen + 8]
        if iw <= 0 or ih <= 0:
            set_current_errstr("/dev/wsys/draw/ctl: I empty image")
            return -1
        if cast[int64](iw) > WSYS_IMG_MAX_W or cast[int64](ih) > WSYS_IMG_MAX_H:
            set_current_errstr("/dev/wsys/draw/ctl: I image too large")
            return -1
        ibpp: uint64 = _wsys_blit_fmt_bpp(ifmt)
        if ibpp == 0:
            set_current_errstr("/dev/wsys/draw/ctl: I bad fmt")
            return -1
        ipix: uint64 = cast[uint64](iw) * cast[uint64](ih) * ibpp
        if count < hdr + ipix:
            set_current_errstr("/dev/wsys/draw/ctl: I short payload")
            return -1
        if _wsys_img_store(wid, &buf[2], nlen, iw, ih, ifmt, &buf[hdr]) == 0:
            set_current_errstr("/dev/wsys/draw/ctl: I store failed")
            return -1
        return cast[int64](hdr + ipix)

    set_current_errstr("/dev/wsys/draw/ctl: unknown blit verb")
    return -1


# --- v2 state + backbuffer read leaves ------------------------------
#
# These are the compositor's read-only window into the v2 substrate.
#
#   /dev/wsys/<wid>/bbstate    snapshot of "<version> <serial> <dx0> <dy0> <dx1> <dy1>\n"
#                              The compositor polls bbstate once per
#                              frame per window: when version >= 2 AND
#                              the rect is non-empty, it reads
#                              backbuffer for those rows and blits.
#   /dev/wsys/<wid>/backbuffer raw RGBA8888 bytes of the per-window
#                              backbuffer. Offset-addressed: row y col x
#                              lives at byte (y * stride + x*4). The
#                              compositor seeks to the start of the
#                              dirty rect's first row and reads (dx1-dx0)*4
#                              bytes per row.
#
# Both leaves are snapshot-once for off>0 to keep `cat` terminating.

def devwsys_bbstate_read(wid: int32, off: uint64, buf: Ptr[uint8],
                         count: uint64) -> int64:
    if off > 0:
        return 0
    if count == 0:
        return 0
    scratch: Array[128, uint8]
    n: uint64 = 0
    # version
    n = _wsys_session_emit_u64(&scratch[0], n,
                               cast[uint64](wsys_win_version_get(wid)))
    scratch[n] = 32                                          # ' '
    n = n + 1
    # frame serial
    n = _wsys_session_emit_u64(&scratch[0], n, wsys_bb_serial_get(wid))
    scratch[n] = 32
    n = n + 1
    # dirty rect — emit 0 0 0 0 if empty so the line always has six fields.
    dx0: int64 = 0
    dy0: int64 = 0
    dx1: int64 = 0
    dy1: int64 = 0
    wsys_bb_dirty_get(wid, &dx0, &dy0, &dx1, &dy1)
    n = _wsys_session_emit_i64(&scratch[0], n, dx0)
    scratch[n] = 32
    n = n + 1
    n = _wsys_session_emit_i64(&scratch[0], n, dy0)
    scratch[n] = 32
    n = n + 1
    n = _wsys_session_emit_i64(&scratch[0], n, dx1)
    scratch[n] = 32
    n = n + 1
    n = _wsys_session_emit_i64(&scratch[0], n, dy1)
    scratch[n] = 10                                          # '\n'
    n = n + 1
    take: uint64 = count
    if take > n:
        take = n
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


def devwsys_backbuffer_read(wid: int32, off: uint64, buf: Ptr[uint8],
                            count: uint64) -> int64:
    # Random-access read of the per-window RGBA8888 backbuffer. Returns
    # the byte count copied (capped at EOF). The compositor uses lseek
    # to address rows; an off >= W*H*4 is EOF (return 0).
    if wid <= 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if u >= MAX_WINDOWS:
        return 0
    if off >= WSYS_BB_BYTES_PER_WIN:
        return 0
    bbp: Ptr[uint8] = cast[Ptr[uint8]](wsys_backbuffer_page[u])
    if cast[uint64](bbp) == 0:
        return 0                                # never blitted -> empty
    avail: uint64 = WSYS_BB_BYTES_PER_WIN - off
    take: uint64 = count
    if take > avail:
        take = avail
    i: uint64 = 0
    while i < take:
        buf[i] = bbp[off + i]
        i = i + 1
    return cast[int64](take)


# =====================================================================
# SCENE-FILE DESKTOP ENVIRONMENT (docs/de_scene_file_arch.md)
# =====================================================================
#
# A window publishes a line-oriented text display list as its `scene`
# file. The compositor reads scene files on `commit`, rasterizes each
# changed window's list into a per-window RGBA8888 pixel CACHE (carved
# from the lazy 4 MiB layer-fb block), and z-blits the caches to the
# physical framebuffer. The frame is text you can cat/grep/diff.
#
# This block is ADDITIVE: it lives alongside the legacy text-ring /
# draw-layer / backbuffer paths (which the live rc.5 DE still uses) so
# the box keeps booting. The runlevel-5 flip to the scene compositor is
# a later wave.
#
# ADDER QUIRKS honoured exactly as the rest of this file: top-level flat
# Array storage indexed buf[slot*SIZE+off]; no nested struct Arrays; no
# sizeof; leading-underscore = module-private.
#
# SLOT MAP: scene storage is 32 slots, mirroring the wid table. Slot 0
# (the otherwise-reserved wid) is the CURSOR's own scene — /dev/wsys/
# cursor/scene routes here. Slots 1..31 are per-window scenes.

WSYS_SCENE_SIZE: uint64 = 16384          # 16 KiB display list per window
WSYS_SCENE_SLOTS: uint64 = 32

# Reserved z for PINNED-BACKGROUND windows (hamdesktop backdrop). Below every
# normal window (which start at z 0 and raise into 1..99) so the backdrop is
# always the floor. _wsys_raise never bumps a pinned window off this value.
# MUST stay a SMALL negative: the present + cursor save-behind recompose
# z-blit is a DENSE per-integer sweep (`while zc <= zmax`), so its cost is
# (zmax - zmin). A large |floor| (this was -1000000) made every cursor move
# loop ~1e6 times -> sluggish mouse + the cursor "hole" (footprint can't
# redraw in time). -1 keeps the desktop strictly below all windows while
# keeping the sweep range tiny.
WSYS_PINNED_Z: int64 = -1

# Display lists (current + previously-committed, for damage diffing).
wsys_scene_buf:       Array[524288, uint8]    # 32 * 16384
wsys_scene_len:       Array[32, uint64]       # bytes of valid scene text
wsys_scene_prev_buf:  Array[524288, uint8]    # last COMMITTED scene
wsys_scene_prev_len:  Array[32, uint64]
# Commit generation: bumped on every `commit` ctl write. The compositor
# compares against its last-composited value to know which windows
# changed. Distinct from wsys_win_serial (which the legacy damage file
# uses); a scene client only bumps this via commit.
wsys_scene_gen:       Array[32, uint64]
# Per-window write cursor: a write at off 0 RESETS the buffer; subsequent
# writes append. This lets a client stream a multi-write scene then poke
# commit. Reset to 0 whenever len is cleared.
wsys_scene_wpos:      Array[32, uint64]

# Per-window geometry / stacking / decoration, set via the window `ctl`
# leaf (geometry/z/decorate). Defaults: a window starts at the origin
# with a modest default size, z=0, decorate=0 (content-only).
wsys_win_x:        Array[32, int64]
wsys_win_y:        Array[32, int64]
wsys_win_w:        Array[32, int64]
wsys_win_h:        Array[32, int64]
wsys_win_z:        Array[32, int64]
wsys_win_decorate: Array[32, int32]
# PINNED-BACKGROUND windows (e.g. the full-screen hamdesktop backdrop). A
# pinned window is forced to a reserved LOWEST z (WSYS_PINNED_Z) and is NEVER
# raised: _wsys_raise() is a no-op on it and the content-press path forwards
# the pointer event (so desktop ICONS still select/launch) + sets focus, but
# does NOT raise it. Without this, clicking the desktop (or a desktop icon)
# raised the full-screen backdrop above the panel + every app window, burying
# them all = the user-reported "all windows vanish on desktop click" bug.
wsys_win_pinned:   Array[32, int32]      # 1 = pinned background, never raised
wsys_win_geo_init: Array[32, int32]      # 1 once geometry has been set
# MAP-AND-RAISE: 1 once a window has had its first content commit handled
# (so it has been auto-raised + focused exactly ONCE on first appearance).
# A real WM maps a new top-level on top and focuses it; a freshly-launched
# scene app (hamterm/hamedit/hamfm/hamsettings) used to open BEHIND its
# peers because every app statically wrote the SAME `z` and nothing raised
# the newcomer. We raise+focus it on its first commit (the moment it becomes
# visible), once, so later commits don't keep stealing focus from a window
# the user has since clicked elsewhere.
wsys_win_mapped:   Array[32, int32]      # 1 once first-commit raise+focus done
# VIRTUAL-DESKTOP home of each window (0-based). Only consulted for decorated
# (app) windows; undecorated chrome is sticky (see wsys_cur_ws above). Default
# 0 = desktop 1; a window adopts wsys_cur_ws when it first sets `decorate 1`.
wsys_win_ws:       Array[32, int32]

# MATE-style window management (maximize / edge-snap / free-resize).
#
# wsys_win_wm_state[wid] encodes the current managed state so a second
# gesture can RESTORE the pre-gesture geometry:
#   0 = NORMAL (floating; saved-geo is meaningless)
#   1 = MAXIMIZED (filling the work area; saved-geo holds the float rect)
#   2 = SNAPPED-LEFT  (left  half of the work area; saved-geo = float rect)
#   3 = SNAPPED-RIGHT (right half of the work area; saved-geo = float rect)
# wsys_win_sav_{x,y,w,h} hold the floating geometry captured the instant a
# window was maximized/snapped, so a restore toggle (double-click again, or
# a drag off the maximized state) puts it back exactly where it was. A
# free-resize while in a managed state drops back to NORMAL (the user took
# explicit control of the size), clearing the managed flag.
WSYS_WM_NORMAL:      int32 = 0
WSYS_WM_MAXIMIZED:   int32 = 1
WSYS_WM_SNAP_LEFT:   int32 = 2
WSYS_WM_SNAP_RIGHT:  int32 = 3
wsys_win_wm_state: Array[32, int32]
wsys_win_sav_x:    Array[32, int64]
wsys_win_sav_y:    Array[32, int64]
wsys_win_sav_w:    Array[32, int64]
wsys_win_sav_h:    Array[32, int64]
# MULTI-WINDOW child/popup anchoring. A popup (menu/dropdown/tooltip/
# dialog) is its own short-lived `decorate 0` window (de_scene_file_arch.md
# §17, "separate decorate-0 windows so the compositor z-orders and dismisses
# them uniformly"). It declares a PARENT wid + an offset, via the `parent`
# ctl verb; the compositor places the child at parent_origin + (dx,dy) and
# stacks it directly above the parent. wsys_win_parent[wid] = 0 means
# "top-level, no parent". This is metadata the WM uses for placement and
# (future) auto-dismiss; input routing stays purely z-order/focus driven.
wsys_win_parent:   Array[32, int32]      # parent wid, 0 = top-level
wsys_win_anchor_dx: Array[32, int64]     # child origin offset from parent
wsys_win_anchor_dy: Array[32, int64]

# Per-window title, set via the window `ctl` `title <string>` verb. Used by
# the taskbar enumeration leaf (/dev/wsys/windows) so the panel can show one
# button per open application window. 48 bytes (incl. NUL) per window.
WSYS_WIN_TITLE_CAP: uint64 = 48
wsys_win_title:     Array[1536, uint8]   # 32 * 48
wsys_win_title_len: Array[32, uint64]

WSYS_SCENE_DEFAULT_W: int64 = 320
WSYS_SCENE_DEFAULT_H: int64 = 240

# Per-window event ring (step-5 input is a later wave; this is the
# minimal readable/writable text ring the spec asks for now). 2 KiB.
WSYS_EVT_SIZE: uint64 = 2048
wsys_evt_buf:  Array[65536, uint8]       # 32 * 2048
wsys_evt_head: Array[32, uint64]         # write cursor
wsys_evt_tail: Array[32, uint64]         # read cursor

# Compositor wake queue: a `commit` write wakes one waiter (the present
# loop / a gate driver). Event-driven, no polling.
wsys_commit_wq: WaitQueue
wsys_commit_wq_inited: int32 = 0
wsys_commit_seq: uint64 = 0              # bumped on every commit (any wid)


def _wsys_scene_init_if_needed():
    if wsys_commit_wq_inited == 0:
        wq_init(&wsys_commit_wq)
        wsys_commit_wq_inited = 1


def _wsys_win_def_w(u: uint64) -> int64:
    if wsys_win_geo_init[u] != 0 and wsys_win_w[u] > 0:
        return wsys_win_w[u]
    return WSYS_SCENE_DEFAULT_W


def _wsys_win_def_h(u: uint64) -> int64:
    if wsys_win_geo_init[u] != 0 and wsys_win_h[u] > 0:
        return wsys_win_h[u]
    return WSYS_SCENE_DEFAULT_H


# --- scene file (per-window display list) ----------------------------

def devwsys_scene_write(wid: int32, buf: Ptr[uint8],
                        count: uint64) -> int64:
    # Client WRITES its display list here. A write at the current write
    # cursor 0 (the first write after a reset) starts a fresh buffer;
    # subsequent writes append. The compositor only ever READS this on a
    # `commit`, so a partially-written scene is never observed.
    #
    # Ownership: NO hostowner gate — a window's owner (creator pid or an
    # ancestor) controls its OWN scene. The cursor scene (wid 0) is a
    # compositor surface; allow hostowner OR any owner of nothing (the DE
    # cursor driver). We gate wid>0 by ownership; wid 0 (cursor) is open
    # to hostowner and to the cursor's writer (best-effort, no slot pid).
    u: uint64 = cast[uint64](wid)
    if u >= WSYS_SCENE_SLOTS:
        set_current_errstr("/dev/wsys/scene: wid out of range")
        return -1
    if wid > 0:
        if wsys_wid_in_use(wid) == 0:
            set_current_errstr("/dev/wsys/scene: wid not in use")
            return -1
        if current_task_is_hostowner() == 0 \
                and _wsys_caller_owns_wid(wid) == 0:
            set_current_errstr("/dev/wsys/scene: permission denied (not window owner)")
            return -1
    if count == 0:
        return 0
    base: uint64 = u * WSYS_SCENE_SIZE
    pos: uint64 = wsys_scene_wpos[u]
    i: uint64 = 0
    while i < count and pos < WSYS_SCENE_SIZE:
        wsys_scene_buf[base + pos] = buf[i]
        pos = pos + 1
        i = i + 1
    wsys_scene_wpos[u] = pos
    wsys_scene_len[u] = pos
    return cast[int64](i)


def devwsys_scene_read(wid: int32, off: uint64, buf: Ptr[uint8],
                       count: uint64) -> int64:
    # The compositor (and gates) READ the current display list as text.
    # Snapshot-once (honours off so `cat`/`grep` terminate). No side
    # effects. A scene read of a reset/never-written window returns EOF.
    if count == 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if u >= WSYS_SCENE_SLOTS:
        return -2
    if wid > 0 and wsys_wid_in_use(wid) == 0:
        return -2
    n: uint64 = wsys_scene_len[u]
    if off >= n:
        return 0
    base: uint64 = u * WSYS_SCENE_SIZE
    remaining: uint64 = n - off
    take: uint64 = count
    if take > remaining:
        take = remaining
    i: uint64 = 0
    while i < take:
        buf[i] = wsys_scene_buf[base + off + i]
        i = i + 1
    return cast[int64](take)


# --- winid file (read-only) ------------------------------------------

def devwsys_winid_read(wid: int32, off: uint64, buf: Ptr[uint8],
                       count: uint64) -> int64:
    # "<wid>\n"
    if count == 0:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return -2
    scratch: Array[32, uint8]
    n: uint64 = _wsys_u64_to_dec(cast[uint64](wid), &scratch[0])
    scratch[n] = 10
    n = n + 1
    return _wsys_copy_out(&scratch[0], n, off, buf, count)


# --- event ring (minimal stub; full routing is a later wave) ---------

def _wsys_evt_push_byte(wid: int32, c: uint8):
    u: uint64 = cast[uint64](wid)
    base: uint64 = u * WSYS_EVT_SIZE
    h: uint64 = wsys_evt_head[u]
    nh: uint64 = (h + 1) % WSYS_EVT_SIZE
    if nh == wsys_evt_tail[u]:
        # ring full: drop the oldest byte
        wsys_evt_tail[u] = (wsys_evt_tail[u] + 1) % WSYS_EVT_SIZE
    wsys_evt_buf[base + h] = c
    wsys_evt_head[u] = nh


def devwsys_event_write(wid: int32, buf: Ptr[uint8],
                        count: uint64) -> int64:
    # The compositor enqueues window-local event lines here; the client
    # reads them. Minimal: owner OR hostowner may write.
    if wsys_wid_in_use(wid) == 0:
        set_current_errstr("/dev/wsys/event: wid not in use")
        return -1
    if current_task_is_hostowner() == 0 and _wsys_caller_owns_wid(wid) == 0:
        set_current_errstr("/dev/wsys/event: permission denied")
        return -1
    i: uint64 = 0
    while i < count:
        _wsys_evt_push_byte(wid, buf[i])
        i = i + 1
    # Wake any client parked in sys_waitfds on this window's /event fd
    # (namec_poll_readable's DEV_WSYS_EVENT arm reports class-0 not-ready
    # while the ring is empty). This is what lets a panel/sysmon app sleep
    # on its event surface instead of busy-spinning sys_yield().
    waitfds_notify()
    return cast[int64](count)


def wsys_event_pending(wid: int32) -> int32:
    # SYS_WAITFDS readiness probe for /dev/wsys/<wid>/event. The event
    # ring (wsys_evt_head/tail) is non-blocking: a read returns 0 when
    # empty. Ready iff the ring holds at least one unread byte.
    if wsys_wid_in_use(wid) == 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if wsys_evt_tail[u] != wsys_evt_head[u]:
        return 1
    return 0


def devwsys_event_read(wid: int32, off: uint64, buf: Ptr[uint8],
                       count: uint64) -> int64:
    # Pop queued event bytes (oldest first). Returns 0 when the ring is
    # empty. `off` is ignored — this is a consuming stream read.
    if count == 0:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return -2
    u: uint64 = cast[uint64](wid)
    base: uint64 = u * WSYS_EVT_SIZE
    n: uint64 = 0
    while n < count and wsys_evt_tail[u] != wsys_evt_head[u]:
        buf[n] = wsys_evt_buf[base + wsys_evt_tail[u]]
        wsys_evt_tail[u] = (wsys_evt_tail[u] + 1) % WSYS_EVT_SIZE
        n = n + 1
    return cast[int64](n)


# --- per-window ctl (geometry/z/decorate/commit/damage) --------------

def devwsys_winctl_read(wid: int32, off: uint64, buf: Ptr[uint8],
                        count: uint64) -> int64:
    # Snapshot status line: "<x> <y> <w> <h> z=<z> decorate=<d> gen=<g>\n"
    if count == 0:
        return 0
    if wsys_wid_in_use(wid) == 0:
        return -2
    u: uint64 = cast[uint64](wid)
    scratch: Array[128, uint8]
    pos: uint64 = 0
    pos = _wsys_emit_i64(&scratch[0], pos, wsys_win_x[u])
    scratch[pos] = 32
    pos = pos + 1
    pos = _wsys_emit_i64(&scratch[0], pos, wsys_win_y[u])
    scratch[pos] = 32
    pos = pos + 1
    pos = _wsys_emit_i64(&scratch[0], pos, _wsys_win_def_w(u))
    scratch[pos] = 32
    pos = pos + 1
    pos = _wsys_emit_i64(&scratch[0], pos, _wsys_win_def_h(u))
    scratch[pos] = 32
    pos = pos + 1
    scratch[pos] = 122                            # 'z'
    scratch[pos + 1] = 61                         # '='
    pos = pos + 2
    pos = _wsys_emit_i64(&scratch[0], pos, wsys_win_z[u])
    scratch[pos] = 32
    pos = pos + 1
    # decorate=<d>
    scratch[pos] = 100
    scratch[pos + 1] = 101
    scratch[pos + 2] = 99
    scratch[pos + 3] = 61
    pos = pos + 4
    pos = _wsys_emit_i64(&scratch[0], pos, cast[int64](wsys_win_decorate[u]))
    scratch[pos] = 32
    pos = pos + 1
    # gen=<g>
    scratch[pos] = 103
    scratch[pos + 1] = 101
    scratch[pos + 2] = 110
    scratch[pos + 3] = 61
    pos = pos + 4
    pos = pos + _wsys_u64_to_dec(wsys_scene_gen[u], &scratch[pos])
    scratch[pos] = 10
    pos = pos + 1
    return _wsys_copy_out(&scratch[0], pos, off, buf, count)


def devwsys_winctl_write(wid: int32, buf: Ptr[uint8],
                         count: uint64) -> int64:
    # Scene-era per-window control verbs:
    #   commit                  -> bump scene gen, snapshot prev, wake compositor
    #   geometry x y w h        -> set origin + content size
    #   z <n>                   -> set stacking order
    #   decorate <0|1>          -> server-side-decoration flag
    #   damage x y w h          -> explicit damage hint (folded into dirty)
    # Owner OR hostowner only.
    if wsys_wid_in_use(wid) == 0:
        set_current_errstr("/dev/wsys/ctl: wid not in use")
        return -1
    if current_task_is_hostowner() == 0 and _wsys_caller_owns_wid(wid) == 0:
        set_current_errstr("/dev/wsys/ctl: permission denied (not window owner)")
        return -1
    if count == 0:
        return 0
    u: uint64 = cast[uint64](wid)
    p: uint64 = _wsys_ctl_skip_ws(buf, 0, count)
    vs: uint64 = p
    p = _wsys_ctl_token_end(buf, p, count)
    ve: uint64 = p
    if vs == ve:
        set_current_errstr("/dev/wsys/ctl: missing verb")
        return -1

    if _wsys_ctl_word_eq(buf, vs, ve, "commit") == 1:
        _wsys_scene_init_if_needed()
        # Snapshot current scene into prev (for next diff) AFTER bumping
        # gen, so the compositor reads the just-committed list. We copy
        # current->prev here; the rasterize step diffs new vs prev.
        base: uint64 = u * WSYS_SCENE_SIZE
        ln: uint64 = wsys_scene_len[u]
        i: uint64 = 0
        while i < ln:
            wsys_scene_prev_buf[base + i] = wsys_scene_buf[base + i]
            i = i + 1
        wsys_scene_prev_len[u] = ln
        wsys_scene_gen[u] = wsys_scene_gen[u] + 1
        # Reset the write cursor so the next frame's first write starts a
        # fresh list.
        wsys_scene_wpos[u] = 0
        # MAP-AND-RAISE (z-order fix): the FIRST commit is the moment this
        # window first becomes visible (scene content + non-empty). A real WM
        # maps a new top-level ON TOP and gives it focus. Do that exactly once
        # — every scene app statically wrote the same `z`, so without this a
        # freshly-launched window opened BEHIND its peers and never got
        # keyboard focus. Pinned backgrounds (the hamdesktop backdrop) are
        # excluded: they must stay on the floor (raising the full-screen
        # backdrop would bury the panel + all apps). Done once so later
        # per-frame commits don't keep stealing focus/raise from whatever
        # window the user has since clicked.
        if wsys_win_mapped[u] == 0 and wsys_scene_len[u] > 0:
            wsys_win_mapped[u] = 1
            if wsys_win_pinned[u] == 0:
                _wsys_raise(wid)
                _wsys_set_focus(wid)
        # Also bump the legacy mutation serial so existing damage readers
        # see the change, and mark the whole window dirty.
        _wsys_mark_dirty(wid, 0, 0, 65535, 65535)
        wsys_commit_seq = wsys_commit_seq + 1
        wq_wake_one(&wsys_commit_wq)
        # DAMAGE-SCOPED present: a per-client commit changed exactly THIS
        # window's content, so re-rasterize + recomposite ONLY this window's
        # footprint (plus overlapping higher windows + cursor) — NOT a full
        # re-rasterize-all + re-blit-all. The full present per commit was the
        # whole-screen blank/flicker the user reported (worst on a full-screen
        # hamdesktop commit from a desktop-icon click, and the per-commit
        # storm of a launched app). No-op when there is no framebuffer.
        _wsys_present_window_scoped(wid)
        return cast[int64](count)

    if _wsys_ctl_word_eq(buf, vs, ve, "close") == 1:
        # Owner-initiated teardown of THIS window. Unlike the hostowner-only
        # system `free <wid>` verb, a client may close its OWN window via its
        # per-window /ctl (the owner gate above already passed). Routes through
        # _wsys_close_window, which drops focus/drag/resize bookkeeping and
        # calls wsys_free_wid — recomposing the vacated footprint so the
        # windows beneath (desktop, panel, apps) repaint. Used by /bin/hamlock
        # to clear its full-screen curtain on unlock. wid 1 is rejected inside
        # wsys_free_wid, so the foreground/root stays unclosable.
        _wsys_close_window(wid)
        return cast[int64](count)

    if _wsys_ctl_word_eq(buf, vs, ve, "z") == 1:
        p = _wsys_ctl_skip_ws(buf, p, count)
        a1s: uint64 = p
        p = _wsys_ctl_token_end(buf, p, count)
        a1e: uint64 = p
        zv: int64 = 0
        if a1s == a1e or _wctl_parse_i64(buf, a1s, a1e, &zv) == 0:
            set_current_errstr("/dev/wsys/ctl: z: bad arg")
            return -1
        wsys_win_z[u] = zv
        return cast[int64](count)

    # title <string> : set the window's taskbar title. The rest of the
    # line (after the verb + one space) is the title text; trailing
    # newline is trimmed. Used by /dev/wsys/windows.
    if _wsys_ctl_word_eq(buf, vs, ve, "title") == 1:
        ts: uint64 = _wsys_ctl_skip_ws(buf, p, count)
        # Copy up to the end of the line (or buffer) into the title slot.
        tbase: uint64 = u * WSYS_WIN_TITLE_CAP
        n: uint64 = 0
        i: uint64 = ts
        while i < count and buf[i] != 10 and n + 1 < WSYS_WIN_TITLE_CAP:
            wsys_win_title[tbase + n] = buf[i]
            n = n + 1
            i = i + 1
        wsys_win_title[tbase + n] = 0
        wsys_win_title_len[u] = n
        return cast[int64](count)

    # raise : bump this window's z above every other in-use window so a
    # taskbar click brings it to the front. No re-rasterize (content
    # unchanged); the next present z-blits it on top.
    if _wsys_ctl_word_eq(buf, vs, ve, "raise") == 1:
        # A pinned background never raises — stay on the floor.
        if wsys_win_pinned[u] != 0:
            return cast[int64](count)
        topz: int64 = wsys_win_z[u]
        w2: uint64 = 1
        while w2 < WSYS_SCENE_SLOTS:
            if w2 != u and wsys_slot_in_use[w2] != 0:
                # Keep panel/overlay chrome (z>=100) above raised app
                # windows: only consider peers below the chrome floor.
                if wsys_win_z[w2] < 100 and wsys_win_z[w2] >= topz:
                    topz = wsys_win_z[w2] + 1
            w2 = w2 + 1
        if topz >= 100:
            topz = 99
        wsys_win_z[u] = topz
        _wsys_scene_init_if_needed()
        wsys_commit_seq = wsys_commit_seq + 1
        wq_wake_one(&wsys_commit_wq)
        # DAMAGE-SCOPED raise (taskbar): recompose only the raised window's
        # footprint — it comes to the front there over its peers — instead of
        # a full re-rasterize-all + re-blit-all present.
        _wsys_present_window_scoped(wid)
        return cast[int64](count)

    # background [0|1] / pin : mark this window a PINNED BACKGROUND (the
    # full-screen hamdesktop backdrop). A pinned window is forced to the
    # reserved lowest z (WSYS_PINNED_Z) and is NEVER raised by a content
    # press or by _wsys_raise — so clicking the desktop / a desktop icon no
    # longer buries the panel + every app window behind the full-screen
    # backdrop (the user-reported "all windows vanish on desktop click" bug).
    # `pin` == `background 1`. `background 0` un-pins (restores z 0).
    if _wsys_ctl_word_eq(buf, vs, ve, "background") == 1 or _wsys_ctl_word_eq(buf, vs, ve, "pin") == 1:
        bv: uint64 = 1
        p = _wsys_ctl_skip_ws(buf, p, count)
        bgs: uint64 = p
        p = _wsys_ctl_token_end(buf, p, count)
        bge: uint64 = p
        # `pin` takes no arg → defaults to 1; `background` may give 0/1.
        if bgs != bge:
            if _wsys_ctl_parse_u64(buf, bgs, bge, &bv) == 0:
                set_current_errstr("/dev/wsys/ctl: background: bad arg")
                return -1
        if bv == 0:
            wsys_win_pinned[u] = 0
            wsys_win_z[u] = 0
        else:
            wsys_win_pinned[u] = 1
            wsys_win_z[u] = WSYS_PINNED_Z
        _wsys_scene_init_if_needed()
        wsys_commit_seq = wsys_commit_seq + 1
        wq_wake_one(&wsys_commit_wq)
        _wsys_present_window_scoped(wid)
        return cast[int64](count)

    # focus : deliver an `f in` event to this window (so it can react)
    # and raise it. Mirrors the pointer-press focus path for a taskbar
    # click that does not pass through the cursor.
    if _wsys_ctl_word_eq(buf, vs, ve, "focus") == 1:
        _wsys_evt_push_byte(wid, 102)            # 'f'
        _wsys_evt_push_byte(wid, 32)             # ' '
        _wsys_evt_push_byte(wid, 105)            # 'i'
        _wsys_evt_push_byte(wid, 110)            # 'n'
        _wsys_evt_push_byte(wid, 10)             # '\n'
        return cast[int64](count)

    if _wsys_ctl_word_eq(buf, vs, ve, "decorate") == 1:
        p = _wsys_ctl_skip_ws(buf, p, count)
        a1s2: uint64 = p
        p = _wsys_ctl_token_end(buf, p, count)
        a1e2: uint64 = p
        dv: uint64 = 0
        if a1s2 == a1e2 or _wsys_ctl_parse_u64(buf, a1s2, a1e2, &dv) == 0:
            set_current_errstr("/dev/wsys/ctl: decorate: bad arg")
            return -1
        if dv == 0:
            wsys_win_decorate[u] = 0
        else:
            wsys_win_decorate[u] = 1
            # The window has just declared itself a real app window: bind it to
            # the active virtual desktop so a workspace switch hides/shows it
            # (undecorated chrome stays sticky). Apps set `decorate 1` once at
            # startup, so this fires when the window first becomes visible —
            # it lands on whatever desktop is current, MATE-style.
            wsys_win_ws[u] = wsys_cur_ws
        return cast[int64](count)

    # parent <pwid> <dx> <dy> : declare this window a CHILD/POPUP of <pwid>,
    # anchored at the parent's content origin + (dx,dy). The compositor
    # positions the child there and stacks it directly above the parent so a
    # menu/dropdown/dialog floats over (not behind) the window that spawned
    # it. <pwid> 0 detaches the window back to top-level. Used by app menus,
    # combo dropdowns, tooltips, and modal dialogs — each a separate
    # `decorate 0` (or decorate 1, for dialogs) window the owner allocates
    # via `newwindow`, then anchors here. Input routing is unaffected
    # (z-order/focus driven); this only sets placement + stacking metadata.
    if _wsys_ctl_word_eq(buf, vs, ve, "parent") == 1:
        p = _wsys_ctl_skip_ws(buf, p, count)
        pps: uint64 = p
        p = _wsys_ctl_token_end(buf, p, count)
        ppe: uint64 = p
        pwv: uint64 = 0
        if pps == ppe or _wsys_ctl_parse_u64(buf, pps, ppe, &pwv) == 0:
            set_current_errstr("/dev/wsys/ctl: parent: bad pwid")
            return -1
        if pwv >= MAX_WINDOWS:
            set_current_errstr("/dev/wsys/ctl: parent: pwid out of range")
            return -1
        if pwv == u:
            set_current_errstr("/dev/wsys/ctl: parent: a window cannot parent itself")
            return -1
        # dx, dy default 0 if omitted (anchor at the parent's origin).
        pdx: int64 = 0
        pdy: int64 = 0
        p = _wsys_ctl_skip_ws(buf, p, count)
        dxs: uint64 = p
        p = _wsys_ctl_token_end(buf, p, count)
        dxe: uint64 = p
        if dxs != dxe:
            if _wctl_parse_i64(buf, dxs, dxe, &pdx) == 0:
                set_current_errstr("/dev/wsys/ctl: parent: bad dx")
                return -1
            p = _wsys_ctl_skip_ws(buf, p, count)
            dys: uint64 = p
            p = _wsys_ctl_token_end(buf, p, count)
            dye: uint64 = p
            if dys != dye and _wctl_parse_i64(buf, dys, dye, &pdy) == 0:
                set_current_errstr("/dev/wsys/ctl: parent: bad dy")
                return -1
        wsys_win_parent[u] = cast[int32](pwv)
        wsys_win_anchor_dx[u] = pdx
        wsys_win_anchor_dy[u] = pdy
        if pwv > 0 and wsys_slot_in_use[pwv] != 0:
            # Anchor placement: position the child at parent origin + offset
            # and stack it directly above the parent.
            ovx2: int64 = wsys_win_x[u]
            ovy2: int64 = wsys_win_y[u]
            ovw2: int64 = _wsys_win_def_w(u)
            ovh2: int64 = _wsys_win_def_h(u)
            wsys_win_x[u] = wsys_win_x[pwv] + pdx
            wsys_win_y[u] = wsys_win_y[pwv] + pdy
            wsys_win_geo_init[u] = 1
            pz: int64 = wsys_win_z[pwv]
            if wsys_win_z[u] <= pz:
                wsys_win_z[u] = pz + 1
            # Recompose the vacated footprint if the child had already been
            # placed somewhere (the next commit re-blits it at the anchor).
            if wsys_root_active != 0 and fb_get_initialized() != 0:
                fl_par: uint64 = local_irq_save()
                spinlock_lock(&wsys_present_lock)
                _wsys_recompose_rect(ovx2, ovy2 - WSYS_TITLEBAR_H,
                                     ovw2, ovh2 + WSYS_TITLEBAR_H)
                _wsys_flush_rect(ovx2, ovy2 - WSYS_TITLEBAR_H,
                                 ovw2, ovh2 + WSYS_TITLEBAR_H)
                spinlock_unlock(&wsys_present_lock)
                local_irq_restore(fl_par)
        return cast[int64](count)

    # geometry x y w h  /  damage x y w h : four i64 args.
    is_geo: int32 = _wsys_ctl_word_eq(buf, vs, ve, "geometry")
    is_dmg: int32 = _wsys_ctl_word_eq(buf, vs, ve, "damage")
    if is_geo == 1 or is_dmg == 1:
        p = _wsys_ctl_skip_ws(buf, p, count)
        gxs: uint64 = p
        p = _wsys_ctl_token_end(buf, p, count)
        gxe: uint64 = p
        gx: int64 = 0
        if gxs == gxe or _wctl_parse_i64(buf, gxs, gxe, &gx) == 0:
            set_current_errstr("/dev/wsys/ctl: missing x")
            return -1
        p = _wsys_ctl_skip_ws(buf, p, count)
        gys: uint64 = p
        p = _wsys_ctl_token_end(buf, p, count)
        gye: uint64 = p
        gy: int64 = 0
        if gys == gye or _wctl_parse_i64(buf, gys, gye, &gy) == 0:
            set_current_errstr("/dev/wsys/ctl: missing y")
            return -1
        p = _wsys_ctl_skip_ws(buf, p, count)
        gws: uint64 = p
        p = _wsys_ctl_token_end(buf, p, count)
        gwe: uint64 = p
        gw: int64 = 0
        if gws == gwe or _wctl_parse_i64(buf, gws, gwe, &gw) == 0:
            set_current_errstr("/dev/wsys/ctl: missing w")
            return -1
        p = _wsys_ctl_skip_ws(buf, p, count)
        ghs: uint64 = p
        p = _wsys_ctl_token_end(buf, p, count)
        ghe: uint64 = p
        gh: int64 = 0
        if ghs == ghe or _wctl_parse_i64(buf, ghs, ghe, &gh) == 0:
            set_current_errstr("/dev/wsys/ctl: missing h")
            return -1
        if is_geo == 1:
            # FLICKER FIX: once-only backdrop — a programmatic geometry
            # move must recompose the OLD footprint so the window leaves no
            # trail (the following commit re-blits it at the new position).
            gvx: int64 = wsys_win_x[u]
            gvy: int64 = wsys_win_y[u]
            gvw: int64 = _wsys_win_def_w(u)
            gvh: int64 = _wsys_win_def_h(u)
            moved: int32 = 0
            if gvx != gx or gvy != gy:
                moved = 1
            # BUG 2a FIX: a SHRINK (new w<old or new h<old) at the same
            # origin (the Applications-menu CLOSE collapses the grown panel
            # from PANEL_OPEN_H 74 back to PANEL_H 26) leaves the vacated
            # strip — the menu pixels below the now-shorter panel — on the
            # framebuffer as a GHOST. The compositor only ever clears the
            # backdrop once, and the shrunk panel's own commit re-blits ONLY
            # its remaining (26px) rows, so nothing repaints the freed band.
            # Treat a shrink like a move: recompose the OLD footprint from
            # the scene sources (backdrop + lower windows + this window's own
            # now-smaller cache), damage-scoped, so the ghost is erased.
            shrunk: int32 = 0
            if (gw > 0 and gw < gvw) or (gh > 0 and gh < gvh):
                shrunk = 1
            wsys_win_x[u] = gx
            wsys_win_y[u] = gy
            if gw > 0:
                wsys_win_w[u] = gw
            if gh > 0:
                wsys_win_h[u] = gh
            wsys_win_geo_init[u] = 1
            if (moved != 0 or shrunk != 0) and wsys_root_active != 0 \
                    and fb_get_initialized() != 0:
                fl_geo: uint64 = local_irq_save()
                spinlock_lock(&wsys_present_lock)
                _wsys_recompose_rect(gvx, gvy - WSYS_TITLEBAR_H,
                                     gvw, gvh + WSYS_TITLEBAR_H)
                _wsys_flush_rect(gvx, gvy - WSYS_TITLEBAR_H,
                                 gvw, gvh + WSYS_TITLEBAR_H)
                spinlock_unlock(&wsys_present_lock)
                local_irq_restore(fl_geo)
        else:
            _wsys_mark_dirty(wid, gx, gy, gx + gw, gy + gh)
        return cast[int64](count)

    set_current_errstr("/dev/wsys/ctl: bad verb")
    return -1


# --- window-list enumeration (wid-less /dev/wsys/windows) ------------
#
# The taskbar reads this snapshot to learn the set of open APPLICATION
# windows. One line per in-use, decorated (app, not chrome) window:
#
#   "<wid> <title>\n"
#
# Windows with z>=100 (panel / menu / overlay chrome) and undecorated
# helper surfaces are omitted — the taskbar only tracks real app windows.
# Snapshot-once: off>0 returns EOF, so `cat` terminates. No side effects.
def devwsys_windows_read(off: uint64, buf: Ptr[uint8],
                         count: uint64) -> int64:
    if count == 0:
        return 0
    # TASKBAR-STALE FIX: reap slots whose owner process has exited before
    # enumerating, so a window left in_use by a dead client (a terminal
    # whose shell exited, a finished installer) is not reported as a live
    # app — and, more importantly, so its leaked slot is reclaimed for the
    # next launch. Only on offset 0 (the start of a fresh snapshot read);
    # a continuation read must enumerate the SAME set it began with.
    if off == 0:
        wsys_reap_dead_wids()
    scratch: Array[2048, uint8]
    n: uint64 = 0
    w: uint64 = 1
    while w < WSYS_SCENE_SLOTS:
        # Only app windows on the ACTIVE desktop are listed, so the panel
        # taskbar tracks the current workspace (MATE-parity) and a switch
        # repopulates it. Sticky/chrome already excluded by decorate/z below.
        if wsys_slot_in_use[w] != 0 and wsys_win_decorate[w] != 0 \
                and wsys_win_z[w] < 100 and wsys_win_ws[w] == wsys_cur_ws:
            # "<wid> <title>\n", bounded by the scratch capacity.
            if n + 64 < 2048:
                n = n + _wsys_u64_to_dec(w, &scratch[n])
                scratch[n] = 32
                n = n + 1
                tbase: uint64 = w * WSYS_WIN_TITLE_CAP
                tl: uint64 = wsys_win_title_len[w]
                if tl == 0:
                    # No explicit title: fall back to "win<wid>".
                    scratch[n] = 119                  # 'w'
                    scratch[n + 1] = 105              # 'i'
                    scratch[n + 2] = 110              # 'n'
                    n = n + 3
                    n = n + _wsys_u64_to_dec(w, &scratch[n])
                else:
                    k: uint64 = 0
                    while k < tl and n + 1 < 2048:
                        c: uint8 = wsys_win_title[tbase + k]
                        if c == 10:
                            c = 32
                        scratch[n] = c
                        n = n + 1
                        k = k + 1
                scratch[n] = 10
                n = n + 1
        w = w + 1
    if off >= n:
        return 0
    remaining: uint64 = n - off
    take: uint64 = count
    if take > remaining:
        take = remaining
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[off + i]
        i = i + 1
    return cast[int64](take)


# --- cursor scene (slot 0) -------------------------------------------

def devwsys_cursor_scene_write(buf: Ptr[uint8], count: uint64) -> int64:
    # The cursor's own always-on-top display list. Wid 0 slot. Hostowner
    # OR any caller (the cursor is a system surface driven by the mouse
    # path); we keep it permissive but writes are tiny.
    if count == 0:
        return 0
    # Cursor scenes are tiny single writes; each write REPLACES the list.
    pos: uint64 = 0
    i: uint64 = 0
    while i < count and pos < WSYS_SCENE_SIZE:
        wsys_scene_buf[pos] = buf[i]
        pos = pos + 1
        i = i + 1
    wsys_scene_wpos[0] = pos
    wsys_scene_len[0] = pos
    _wsys_scene_init_if_needed()
    wsys_commit_seq = wsys_commit_seq + 1
    wq_wake_one(&wsys_commit_wq)
    # Cursor moves are decoupled from window recomposition: blit ONLY the
    # cursor sprite (restore-behind would need a saved backdrop; for this
    # wave we re-present the cursor sprite at its new origin without
    # re-rasterizing any window cache).
    if fb_get_initialized() != 0:
        _wsys_present_cursor()
    return cast[int64](i)


def devwsys_cursor_scene_read(off: uint64, buf: Ptr[uint8],
                              count: uint64) -> int64:
    if count == 0:
        return 0
    n: uint64 = wsys_scene_len[0]
    if off >= n:
        return 0
    remaining: uint64 = n - off
    take: uint64 = count
    if take > remaining:
        take = remaining
    i: uint64 = 0
    while i < take:
        buf[i] = wsys_scene_buf[off + i]
        i = i + 1
    return cast[int64](take)


# =====================================================================
# RASTERIZER (Floor + Widget tiers) — scene text -> per-window cache
# =====================================================================
#
# Parses the §4 scene grammar into a window-local RGBA8888 pixel cache.
# The cache backing is the lazy 4 MiB layer-fb block (_wsys_layer_fb_
# ensure); we treat it as a tightly-packed RGBA frame of stride = window
# width. The 4 MiB block bounds the cache by AREA (w*h*4 <= 4 MiB), not by
# a single 1024 per-dimension cap: a 1024-square cap wrongly clamped a
# full-width top panel on a 1280-wide screen to 1024px (the grey bar
# "stopped at ~80%" the user reported). The real limit is the byte budget,
# so a wide-but-short cache (e.g. 1280x74 panel = 379 KB) is fine while a
# 1280x800 full-screen cache (4.10 MB > 4.19 MB block? no — it fits) is
# still bounded. _wsys_clamp_cache_dims() enforces: each dim <= a generous
# 2048 hard ceiling, AND w*h*4 <= the layer-fb block size (rows are
# dropped, never the width, so a panel keeps its full span).
#
# Primitives: clip / fill / rect(=fill) / stroke / line / text / glyphs.
# image is parsed-and-ignored (Bitmap tier, later). Colours are #RRGGBB
# or #RRGGBBAA. Each primitive is stateless: it writes pixels into the
# cache clipped to the active clip rect and the cache bounds.

# Per-dimension hard ceiling (sanity bound on a malformed geometry). The
# true constraint is the byte budget below; this just bounds either axis to
# a plausible display size.
WSYS_SCENE_CACHE_MAX: int64 = 2048


# Clamp a requested cache (w,h) to what the per-window 4 MiB layer-fb block
# can hold as a tightly-packed RGBA8888 frame. Width is preserved up to the
# per-dim ceiling; height is then reduced if needed so w*h*4 fits the block
# (full-width panels keep their span — only excess ROWS are dropped). Writes
# the clamped values back through the pointers.
def _wsys_clamp_cache_dims(w: Ptr[int64], h: Ptr[int64]):
    cw: int64 = w[0]
    ch: int64 = h[0]
    if cw < 0:
        cw = 0
    if ch < 0:
        ch = 0
    if cw > WSYS_SCENE_CACHE_MAX:
        cw = WSYS_SCENE_CACHE_MAX
    if ch > WSYS_SCENE_CACHE_MAX:
        ch = WSYS_SCENE_CACHE_MAX
    # Byte budget: w*h*4 <= WSYS_LAYER_FB_BYTES_PER_WIN. Drop rows, not
    # columns, so a wide panel never loses its width.
    if cw > 0:
        max_h: int64 = cast[int64](WSYS_LAYER_FB_BYTES_PER_WIN) / (cw * 4)
        if ch > max_h:
            ch = max_h
    w[0] = cw
    h[0] = ch

# Active clip rect during a rasterize pass (module-scope scratch; the
# rasterizer is not re-entrant — the compositor calls it serially).
_wsys_rast_clip_x0: int64 = 0
_wsys_rast_clip_y0: int64 = 0
_wsys_rast_clip_x1: int64 = 0
_wsys_rast_clip_y1: int64 = 0
_wsys_rast_w: int64 = 0
_wsys_rast_h: int64 = 0
# The wid currently being rasterized — set by _wsys_rasterize_window so the
# `buffer` scene verb (Wayland v2 blit surfaces) can reach the window's v2
# backbuffer. The rasterizer is serial (present-lock held) so a single global
# is safe.
_wsys_rast_wid: int32 = 0


def _wsys_hex_nibble(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return cast[int32](c) - 48
    if c >= 97 and c <= 102:
        return cast[int32](c) - 97 + 10
    if c >= 65 and c <= 70:
        return cast[int32](c) - 65 + 10
    return -1


def _wsys_parse_color(buf: Ptr[uint8], start: uint64, end: uint64,
                      out_r: Ptr[uint8], out_g: Ptr[uint8],
                      out_b: Ptr[uint8], out_a: Ptr[uint8]) -> int32:
    # Parse #RRGGBB or #RRGGBBAA at buf[start..end). Returns 1 on success.
    if start >= end:
        return 0
    if buf[start] != 35:                      # '#'
        return 0
    nlen: uint64 = end - start - 1
    if nlen != 6 and nlen != 8:
        return 0
    p: uint64 = start + 1
    hr: int32 = _wsys_hex_nibble(buf[p]) * 16 + _wsys_hex_nibble(buf[p + 1])
    hg: int32 = _wsys_hex_nibble(buf[p + 2]) * 16 + _wsys_hex_nibble(buf[p + 3])
    hb: int32 = _wsys_hex_nibble(buf[p + 4]) * 16 + _wsys_hex_nibble(buf[p + 5])
    if hr < 0 or hg < 0 or hb < 0:
        return 0
    ha: int32 = 255
    if nlen == 8:
        ha = _wsys_hex_nibble(buf[p + 6]) * 16 + _wsys_hex_nibble(buf[p + 7])
        if ha < 0:
            return 0
    out_r[0] = cast[uint8](hr)
    out_g[0] = cast[uint8](hg)
    out_b[0] = cast[uint8](hb)
    out_a[0] = cast[uint8](ha)
    return 1


def _wsys_cache_putpixel(cache: Ptr[uint8], x: int64, y: int64,
                         r: uint8, g: uint8, b: uint8, a: uint8):
    # Store one RGBA pixel, clipped to the active clip rect and cache
    # bounds. Alpha-over the existing pixel when a<255 (simple blend).
    if x < _wsys_rast_clip_x0 or x >= _wsys_rast_clip_x1:
        return
    if y < _wsys_rast_clip_y0 or y >= _wsys_rast_clip_y1:
        return
    if x < 0 or y < 0 or x >= _wsys_rast_w or y >= _wsys_rast_h:
        return
    off: uint64 = (cast[uint64](y) * cast[uint64](_wsys_rast_w)
                   + cast[uint64](x)) * 4
    if a >= 255:
        cache[off] = r
        cache[off + 1] = g
        cache[off + 2] = b
        cache[off + 3] = 255
        return
    # alpha-over
    ia: uint32 = 255 - cast[uint32](a)
    dr: uint32 = cast[uint32](cache[off])
    dg: uint32 = cast[uint32](cache[off + 1])
    db: uint32 = cast[uint32](cache[off + 2])
    cache[off] = cast[uint8]((cast[uint32](r) * cast[uint32](a) + dr * ia) / 255)
    cache[off + 1] = cast[uint8]((cast[uint32](g) * cast[uint32](a) + dg * ia) / 255)
    cache[off + 2] = cast[uint8]((cast[uint32](b) * cast[uint32](a) + db * ia) / 255)
    cache[off + 3] = 255


def _wsys_cache_fillrect(cache: Ptr[uint8], x: int64, y: int64,
                         w: int64, h: int64,
                         r: uint8, g: uint8, b: uint8, a: uint8):
    yy: int64 = y
    ylim: int64 = y + h
    while yy < ylim:
        xx: int64 = x
        xlim: int64 = x + w
        while xx < xlim:
            _wsys_cache_putpixel(cache, xx, yy, r, g, b, a)
            xx = xx + 1
        yy = yy + 1


# ---- rounded rectangle (shared AA corner formula, see lib/hamui_host.ad) --
# floor(sqrt(n)) via integer Newton iteration — MUST be byte-identical to the
# host twin _rr_isqrt so both interpreters round corners the same way.
def _wsys_isqrt(n: uint64) -> uint64:
    if n == 0:
        return 0
    x: uint64 = n
    y: uint64 = (x + 1) / 2
    while y < x:
        x = y
        y = (x + n / x) / 2
    return x


# Corner coverage 0..255 for pixel (px,py) vs an arc centred at (ccx2,ccy2)
# radius r2, all in HALF-pixel (2x) integer units; 0.5px AA band. Twin of the
# host _rr_cov.
def _wsys_rr_cov(px: int64, py: int64, ccx2: int64, ccy2: int64,
                 r2: int64) -> int32:
    dxh: int64 = (2 * px + 1) - ccx2
    dyh: int64 = (2 * py + 1) - ccy2
    d2: int64 = dxh * dxh + dyh * dyh
    dh: int64 = cast[int64](_wsys_isqrt(cast[uint64](d2)))
    if dh <= r2 - 1:
        return 255
    if dh >= r2 + 1:
        return 0
    return cast[int32]((r2 + 1 - dh) * 255 / 2)


# Fill a rounded rectangle into the RGBA layer cache. `corners` bitmask:
# 1=TL 2=TR 4=BL 8=BR. Corner pixels are alpha-blended by arc coverage against
# the cache content already there (matching the host raster pixel-for-pixel).
def _wsys_cache_roundrect(cache: Ptr[uint8], x: int64, y: int64, w: int64,
                          h: int64, rad: int64, corners: int64,
                          r: uint8, g: uint8, b: uint8, a: uint8):
    if w <= 0 or h <= 0:
        return
    rr: int64 = rad
    if rr < 0:
        rr = 0
    if rr > w / 2:
        rr = w / 2
    if rr > h / 2:
        rr = h / 2
    if rr <= 0:
        _wsys_cache_fillrect(cache, x, y, w, h, r, g, b, a)
        return
    r2: int64 = 2 * rr
    tlx2: int64 = 2 * (x + rr)
    tly2: int64 = 2 * (y + rr)
    trx2: int64 = 2 * (x + w - rr)
    blx2: int64 = tlx2
    bly2: int64 = 2 * (y + h - rr)
    brx2: int64 = trx2
    py: int64 = y
    ylim: int64 = y + h
    while py < ylim:
        in_top: int32 = 0
        if py < y + rr:
            in_top = 1
        in_bot: int32 = 0
        if py >= y + h - rr:
            in_bot = 1
        px: int64 = x
        xlim: int64 = x + w
        while px < xlim:
            cov: int32 = 255
            in_left: int32 = 0
            if px < x + rr:
                in_left = 1
            in_right: int32 = 0
            if px >= x + w - rr:
                in_right = 1
            if in_top == 1 and in_left == 1 and (corners & 1) != 0:
                cov = _wsys_rr_cov(px, py, tlx2, tly2, r2)
            elif in_top == 1 and in_right == 1 and (corners & 2) != 0:
                cov = _wsys_rr_cov(px, py, trx2, tly2, r2)
            elif in_bot == 1 and in_left == 1 and (corners & 4) != 0:
                cov = _wsys_rr_cov(px, py, blx2, bly2, r2)
            elif in_bot == 1 and in_right == 1 and (corners & 8) != 0:
                cov = _wsys_rr_cov(px, py, brx2, bly2, r2)
            if cov > 0:
                ae: uint32 = cast[uint32](a) * cast[uint32](cov) / 255
                _wsys_cache_putpixel(cache, px, py, r, g, b, cast[uint8](ae))
            px = px + 1
        py = py + 1


def _wsys_cache_draw_char_w(cache: Ptr[uint8], ch: int32, px: int64,
                            py: int64, r: uint8, g: uint8,
                            b: uint8, a: uint8, bold: int32):
    # 8x16 glyph at top-left (px,py) using the console font. Only set
    # (foreground) pixels are written — the background shows through. When
    # `bold` is set each set bit is also written one pixel to the right
    # (double-strike), thickening the stroke for the panel's `font bold`
    # weight setting without needing a second font.
    c: int32 = ch
    if c < 0 or c >= 128:
        c = 32
    gbase: uint64 = fb_font_glyph_addr() + cast[uint64](c) * 16
    row: uint64 = 0
    while row < 16:
        bits: uint8 = cast[Ptr[uint8]](gbase + row)[0]
        col: uint64 = 0
        while col < 8:
            mask: uint8 = cast[uint8](0x80 >> col)
            if (bits & mask) != 0:
                _wsys_cache_putpixel(cache, px + cast[int64](col),
                                     py + cast[int64](row), r, g, b, a)
                if bold != 0:
                    _wsys_cache_putpixel(cache, px + cast[int64](col) + 1,
                                         py + cast[int64](row), r, g, b, a)
            col = col + 1
        row = row + 1


def _wsys_cache_draw_char(cache: Ptr[uint8], ch: int32, px: int64,
                          py: int64, r: uint8, g: uint8,
                          b: uint8, a: uint8):
    _wsys_cache_draw_char_w(cache, ch, px, py, r, g, b, a, 0)


def _wsys_scene_next_int(buf: Ptr[uint8], pp: Ptr[uint64],
                         count: uint64, out: Ptr[int64]) -> int32:
    # Skip ws, parse a signed decimal token, advance *pp. Returns 1 ok.
    p: uint64 = _wsys_ctl_skip_ws(buf, pp[0], count)
    s: uint64 = p
    p = _wsys_ctl_token_end(buf, p, count)
    e: uint64 = p
    pp[0] = p
    if s == e:
        return 0
    v: int64 = 0
    if _wctl_parse_i64(buf, s, e, &v) == 0:
        return 0
    out[0] = v
    return 1


def _wsys_rasterize_window(wid: int32):
    # Rasterize wid's CURRENT scene text into its RGBA cache. Clears the
    # cache to transparent black first (full redraw — damage-clipped
    # incremental raster is a later refinement; correctness first).
    u: uint64 = cast[uint64](wid)
    if u >= WSYS_SCENE_SLOTS:
        return
    cache: Ptr[uint8] = _wsys_layer_fb_ensure(wid)
    if cast[uint64](cache) == 0:
        return
    _wsys_rast_wid = wid
    w: int64 = _wsys_win_def_w(u)
    h: int64 = _wsys_win_def_h(u)
    _wsys_clamp_cache_dims(&w, &h)
    _wsys_rast_w = w
    _wsys_rast_h = h
    _wsys_rast_clip_x0 = 0
    _wsys_rast_clip_y0 = 0
    _wsys_rast_clip_x1 = w
    _wsys_rast_clip_y1 = h
    # Clear cache to opaque black.
    memset(cache, 0, cast[uint64](w) * cast[uint64](h) * 4)
    base: uint64 = u * WSYS_SCENE_SIZE
    n: uint64 = wsys_scene_len[u]
    i: uint64 = 0
    while i < n:
        # find end of line
        ls: uint64 = i
        while i < n and wsys_scene_buf[base + i] != 10:
            i = i + 1
        le: uint64 = i
        if i < n:
            i = i + 1                          # skip '\n'
        _wsys_rast_line(cache, &wsys_scene_buf[base], ls, le)


def _wsys_rast_line(cache: Ptr[uint8], buf: Ptr[uint8],
                    ls: uint64, le: uint64):
    # Rasterize one scene line buf[ls..le). Comments (#<space>) and blank
    # lines are ignored.
    p: uint64 = _wsys_ctl_skip_ws(buf, ls, le)
    if p >= le:
        return
    vs: uint64 = p
    p = _wsys_ctl_token_end(buf, p, le)
    ve: uint64 = p
    # Comment: a '#' verb token (the colour token is never first).
    if ve - vs >= 1 and buf[vs] == 35:
        return

    if _wsys_ctl_word_eq(buf, vs, ve, "clip") == 1:
        cx: int64 = 0
        cy: int64 = 0
        cw: int64 = 0
        ch2: int64 = 0
        if _wsys_scene_next_int(buf, &p, le, &cx) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &cy) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &cw) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &ch2) == 0:
            return
        _wsys_rast_clip_x0 = cx
        _wsys_rast_clip_y0 = cy
        _wsys_rast_clip_x1 = cx + cw
        _wsys_rast_clip_y1 = cy + ch2
        return

    # roundrect x y w h radius #col [corners] — a filled rounded rectangle.
    if _wsys_ctl_word_eq(buf, vs, ve, "roundrect") == 1:
        rx: int64 = 0
        ry: int64 = 0
        rw: int64 = 0
        rh: int64 = 0
        rrad: int64 = 0
        if _wsys_scene_next_int(buf, &p, le, &rx) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &ry) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &rw) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &rh) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &rrad) == 0:
            return
        rcp: uint64 = _wsys_ctl_skip_ws(buf, p, le)
        rce: uint64 = _wsys_ctl_token_end(buf, rcp, le)
        rr2: uint8 = 0
        rg2: uint8 = 0
        rb2: uint8 = 0
        ra2: uint8 = 255
        if _wsys_parse_color(buf, rcp, rce, &rr2, &rg2, &rb2, &ra2) == 0:
            return
        p = rce
        # optional trailing corner mask (default all=15)
        rcorners: int64 = 15
        _wsys_scene_next_int(buf, &p, le, &rcorners)
        _wsys_cache_roundrect(cache, rx, ry, rw, rh, rrad, rcorners,
                              rr2, rg2, rb2, ra2)
        return

    is_fill: int32 = _wsys_ctl_word_eq(buf, vs, ve, "fill")
    is_rect: int32 = _wsys_ctl_word_eq(buf, vs, ve, "rect")
    if is_fill == 1 or is_rect == 1:
        fx: int64 = 0
        fy: int64 = 0
        fw: int64 = 0
        fh: int64 = 0
        if _wsys_scene_next_int(buf, &p, le, &fx) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &fy) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &fw) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &fh) == 0:
            return
        cp: uint64 = _wsys_ctl_skip_ws(buf, p, le)
        ce: uint64 = _wsys_ctl_token_end(buf, cp, le)
        rr: uint8 = 0
        gg: uint8 = 0
        bb: uint8 = 0
        aa: uint8 = 255
        if _wsys_parse_color(buf, cp, ce, &rr, &gg, &bb, &aa) == 0:
            return
        _wsys_cache_fillrect(cache, fx, fy, fw, fh, rr, gg, bb, aa)
        return

    if _wsys_ctl_word_eq(buf, vs, ve, "stroke") == 1:
        sx: int64 = 0
        sy: int64 = 0
        sw: int64 = 0
        sh: int64 = 0
        st: int64 = 0
        if _wsys_scene_next_int(buf, &p, le, &sx) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &sy) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &sw) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &sh) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &st) == 0:
            return
        cp2: uint64 = _wsys_ctl_skip_ws(buf, p, le)
        ce2: uint64 = _wsys_ctl_token_end(buf, cp2, le)
        sr: uint8 = 0
        sg: uint8 = 0
        sb: uint8 = 0
        sa: uint8 = 255
        if _wsys_parse_color(buf, cp2, ce2, &sr, &sg, &sb, &sa) == 0:
            return
        if st < 1:
            st = 1
        # four edges of thickness st
        _wsys_cache_fillrect(cache, sx, sy, sw, st, sr, sg, sb, sa)
        _wsys_cache_fillrect(cache, sx, sy + sh - st, sw, st, sr, sg, sb, sa)
        _wsys_cache_fillrect(cache, sx, sy, st, sh, sr, sg, sb, sa)
        _wsys_cache_fillrect(cache, sx + sw - st, sy, st, sh, sr, sg, sb, sa)
        return

    if _wsys_ctl_word_eq(buf, vs, ve, "line") == 1:
        x1: int64 = 0
        y1: int64 = 0
        x2: int64 = 0
        y2: int64 = 0
        lt: int64 = 0
        if _wsys_scene_next_int(buf, &p, le, &x1) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &y1) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &x2) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &y2) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &lt) == 0:
            return
        cp3: uint64 = _wsys_ctl_skip_ws(buf, p, le)
        ce3: uint64 = _wsys_ctl_token_end(buf, cp3, le)
        lr: uint8 = 0
        lg: uint8 = 0
        lb: uint8 = 0
        la: uint8 = 255
        if _wsys_parse_color(buf, cp3, ce3, &lr, &lg, &lb, &la) == 0:
            return
        _wsys_rast_drawline(cache, x1, y1, x2, y2, lr, lg, lb, la)
        return

    # text / glyphs: x y "string" #color
    is_text: int32 = _wsys_ctl_word_eq(buf, vs, ve, "text")
    is_glyphs: int32 = _wsys_ctl_word_eq(buf, vs, ve, "glyphs")
    if is_text == 1 or is_glyphs == 1:
        tx: int64 = 0
        ty: int64 = 0
        if _wsys_scene_next_int(buf, &p, le, &tx) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &ty) == 0:
            return
        # find opening quote
        q: uint64 = _wsys_ctl_skip_ws(buf, p, le)
        if q >= le or buf[q] != 34:            # '"'
            return
        q = q + 1
        ss: uint64 = q
        while q < le and buf[q] != 34:
            q = q + 1
        se: uint64 = q
        if q >= le:
            return
        q = q + 1                              # skip closing quote
        cp4: uint64 = _wsys_ctl_skip_ws(buf, q, le)
        ce4: uint64 = _wsys_ctl_token_end(buf, cp4, le)
        tr: uint8 = 255
        tg: uint8 = 255
        tb: uint8 = 255
        ta: uint8 = 255
        if _wsys_parse_color(buf, cp4, ce4, &tr, &tg, &tb, &ta) == 0:
            return
        # Optional trailing weight flag: a `b` token after the colour selects
        # BOLD (double-strike) rendering. Absent → normal weight. Older
        # callers omit it; this stays forward-compatible.
        bold: int32 = 0
        wp: uint64 = _wsys_ctl_skip_ws(buf, ce4, le)
        we: uint64 = _wsys_ctl_token_end(buf, wp, le)
        if wp < we and buf[wp] == 98:                  # 'b'
            bold = 1
        # text is baseline-anchored: top = y - ascent(12). glyphs is
        # cell-anchored: top = y.
        top: int64 = ty
        if is_text == 1:
            top = ty - 12
        cx2: int64 = tx
        si: uint64 = ss
        while si < se:
            _wsys_cache_draw_char_w(cache, cast[int32](buf[si]), cx2, top,
                                    tr, tg, tb, ta, bold)
            cx2 = cx2 + 8
            si = si + 1
        return

    # buffer <x> <y> <w> <h> — composite the window's v2 blit BACKBUFFER
    # rect (x,y)..(x+w,y+h) into the scene cache. This is the bridge that
    # puts a Wayland surface's committed shm pixels onto the in-kernel
    # present path (docs/wayland_passthrough_design.md §2 gap): the native
    # Wayland front-end stores ARGB8888 pixels into the v2 backbuffer via
    # _wsys_blit_store_rect, then writes a one-line `buffer 0 0 w h` scene
    # so this rasterize pass copies the backbuffer into the layer cache the
    # compositor already z-blits to /dev/fb. Backbuffer is RGBA8888 stride
    # WSYS_BB_STRIDE_BYTES; the cache is RGBA8888 stride _wsys_rast_w*4.
    if _wsys_ctl_word_eq(buf, vs, ve, "buffer") == 1:
        bx: int64 = 0
        by: int64 = 0
        bw: int64 = 0
        bh: int64 = 0
        if _wsys_scene_next_int(buf, &p, le, &bx) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &by) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &bw) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &bh) == 0:
            return
        bbp: Ptr[uint8] = wsys_backbuffer_ptr(_wsys_rast_wid)
        if cast[uint64](bbp) == 0:
            return
        # Clip to cache dims and backbuffer dims.
        cx0: int64 = bx
        cy0: int64 = by
        cx1: int64 = bx + bw
        cy1: int64 = by + bh
        if cx0 < 0:
            cx0 = 0
        if cy0 < 0:
            cy0 = 0
        if cx1 > _wsys_rast_w:
            cx1 = _wsys_rast_w
        if cy1 > _wsys_rast_h:
            cy1 = _wsys_rast_h
        if cx1 > cast[int64](WSYS_BB_W):
            cx1 = cast[int64](WSYS_BB_W)
        if cy1 > cast[int64](WSYS_BB_H):
            cy1 = cast[int64](WSYS_BB_H)
        if cx1 <= cx0 or cy1 <= cy0:
            return
        cache_stride: uint64 = cast[uint64](_wsys_rast_w) * 4
        yy: int64 = cy0
        while yy < cy1:
            src_off: uint64 = cast[uint64](yy) * WSYS_BB_STRIDE_BYTES \
                              + cast[uint64](cx0) * 4
            dst_off: uint64 = cast[uint64](yy) * cache_stride \
                              + cast[uint64](cx0) * 4
            xx: int64 = cx0
            while xx < cx1:
                cache[dst_off]     = bbp[src_off]
                cache[dst_off + 1] = bbp[src_off + 1]
                cache[dst_off + 2] = bbp[src_off + 2]
                cache[dst_off + 3] = bbp[src_off + 3]
                src_off = src_off + 4
                dst_off = dst_off + 4
                xx = xx + 1
            yy = yy + 1
        return

    # #128 image tier: `image x y w h NAME` — blit the named per-window
    # image (uploaded via the draw/ctl 'I' verb) into (x,y,w,h), nearest-
    # neighbor scaled + alpha-composited + clipped. Unknown NAME is a no-op
    # (forward-compatible: a scene may reference an image not yet uploaded).
    if _wsys_ctl_word_eq(buf, vs, ve, "image") == 1:
        ix: int64 = 0
        iy: int64 = 0
        iw2: int64 = 0
        ih2: int64 = 0
        if _wsys_scene_next_int(buf, &p, le, &ix) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &iy) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &iw2) == 0:
            return
        if _wsys_scene_next_int(buf, &p, le, &ih2) == 0:
            return
        np: uint64 = _wsys_ctl_skip_ws(buf, p, le)
        ne: uint64 = _wsys_ctl_token_end(buf, np, le)
        if np >= ne:
            return
        slot: int32 = _wsys_img_find(_wsys_rast_wid, buf, np, ne)
        if slot < 0:
            return
        _wsys_cache_blit_image(cache, slot, ix, iy, iw2, ih2)
        return
    if _wsys_ctl_word_eq(buf, vs, ve, "damage") == 1:
        return
    # unknown verb: ignore (forward-compatible)


def _wsys_rast_drawline(cache: Ptr[uint8], x0: int64, y0: int64,
                        x1: int64, y1: int64, r: uint8, g: uint8,
                        b: uint8, a: uint8):
    # Bresenham, thickness 1 (thick lines approximated as 1px for now).
    dx: int64 = x1 - x0
    if dx < 0:
        dx = -dx
    dy: int64 = y1 - y0
    if dy < 0:
        dy = -dy
    sx: int64 = 1
    if x0 > x1:
        sx = -1
    sy: int64 = 1
    if y0 > y1:
        sy = -1
    err: int64 = dx - dy
    cx: int64 = x0
    cy: int64 = y0
    guard: int64 = 0
    while guard < 4096:
        _wsys_cache_putpixel(cache, cx, cy, r, g, b, a)
        if cx == x1 and cy == y1:
            return
        e2: int64 = err * 2
        if e2 > -dy:
            err = err - dy
            cx = cx + sx
        if e2 < dx:
            err = err + dx
            cy = cy + sy
        guard = guard + 1


# =====================================================================
# COMPOSITOR — z-blit caches to the physical framebuffer (option A)
# =====================================================================
#
# Kernel-side present. On `commit` (or cursor move) the compositor
# rasterizes the changed windows and z-blits every live window's cache,
# bottom-to-top by z, into /dev/fb via fb_present_rgba_row. The cursor
# scene is composited LAST. Event-driven: a present is triggered by a
# `commit` write (which wakes wsys_commit_wq); a userland present loop
# (or the gate) reads /dev/wsys/present to drive a frame.
#
# This is the SELF-CONTAINED scene path; it does NOT touch the legacy
# hamUId render cascade that rc.5 depends on.

def _wsys_present_window(wid: int32):
    # Blit wid's cache to the screen at (win_x, win_y). Caller has already
    # rasterized. Rows are presented via fb_present_rgba_row (RGBA src).
    u: uint64 = cast[uint64](wid)
    cache: Ptr[uint8] = _wsys_layer_fb_get(wid)
    if cast[uint64](cache) == 0:
        return
    w: int64 = _wsys_win_def_w(u)
    h: int64 = _wsys_win_def_h(u)
    _wsys_clamp_cache_dims(&w, &h)
    ox: int64 = wsys_win_x[u]
    oy: int64 = wsys_win_y[u]
    if ox < 0:
        ox = 0
    if oy < 0:
        oy = 0
    # SSD chrome (step 6, minimal): a decorated window gets a compositor-
    # drawn titlebar bar in the TITLEBAR_H rows ABOVE its content origin,
    # plus a one-row close-box accent on the right. The window is moved by
    # dragging this bar (handled in the pointer router). decorate 0 =
    # panels/menus/cursor = no frame, content only.
    if wsys_win_decorate[u] != 0:
        _wsys_present_titlebar(ox, oy, w)
    sy: uint64 = 0
    while cast[int64](sy) < h:
        fb_present_rgba_row(sy, cast[uint64](ox),
                            cast[uint64](oy) + sy, cast[uint64](w),
                            cache, cast[uint64](w))
        sy = sy + 1


WSYS_TITLEBAR_H: int64 = 18              # SSD titlebar height in px
# KDE-ish rounded top corners on the SSD titlebar (#254). Consistent with the
# scene window/card radius from #253 (buttons r=5; the bigger titlebar reads
# best at ~7). The bottom of the bar stays square/flush against the window
# body — the standard modern window silhouette.
WSYS_TITLEBAR_RADIUS: int64 = 7


def _wsys_titlebar_radius(w: int64) -> int64:
    # Clamp the nominal corner radius to the bar geometry.
    r: int64 = WSYS_TITLEBAR_RADIUS
    if r > w / 2:
        r = w / 2
    if r > WSYS_TITLEBAR_H:
        r = WSYS_TITLEBAR_H
    if r < 0:
        r = 0
    return r


def _wsys_titlebar_corner_alpha(bufw: int64, barrow: int64, r: int64,
                                rel0: int64, fullw: int64):
    # For titlebar scanline `barrow` (0 = top row), overwrite the alpha byte of
    # the TOP-LEFT and TOP-RIGHT corner-box pixels of the current wsys_root_row
    # with the quarter-circle coverage (0..255) so the outer corner is cut with
    # a clean anti-aliased edge. The row buffer holds `bufw` pixels; buffer
    # index i maps to bar-relative column (i + rel0) of a bar `fullw` px wide
    # (rel0=0/fullw=bufw for a full present; a damage sub-rect passes a slice).
    # Columns outside the two corner boxes stay fully opaque. Reuses
    # _wsys_rr_cov from #253 (arc centres in HALF-pixel units).
    if r <= 0:
        return
    r2: int64 = 2 * r
    tlcx2: int64 = 2 * r                     # TL arc centre x (bar coords)
    trcx2: int64 = 2 * (fullw - r)           # TR arc centre x (bar coords)
    i: int64 = 0
    while i < bufw:
        relx: int64 = i + rel0               # bar-relative column
        cov: int32 = 255
        if relx < r:
            cov = _wsys_rr_cov(relx, barrow, tlcx2, 2 * r, r2)
        elif relx >= fullw - r:
            cov = _wsys_rr_cov(relx, barrow, trcx2, 2 * r, r2)
        wsys_root_row[cast[uint64](i) * 4 + 3] = cast[uint8](cov)
        i = i + 1


def _wsys_titlebar_restore_alpha(bufw: int64, rel0: int64, r: int64,
                                 fullw: int64):
    # Reset the corner-box alpha bytes back to 255 after a blended corner row,
    # so the shared wsys_root_row buffer is opaque again for the next scanline.
    if r <= 0:
        return
    i: int64 = 0
    while i < bufw:
        relx: int64 = i + rel0
        if relx < r or relx >= fullw - r:
            wsys_root_row[cast[uint64](i) * 4 + 3] = 255
        i = i + 1


def _wsys_present_titlebar(ox: int64, oy: int64, w: int64):
    # Draw a TITLEBAR_H-row accent bar at (ox, oy - TITLEBAR_H) of width w.
    # Clearlooks-ish blue with a brighter close box on the right edge. The TWO
    # TOP corners are rounded (KDE-ish, #254): the top `r` scanlines are
    # presented with per-pixel arc coverage in the corner boxes and alpha-
    # blended (fb_present_rgba_row_blend) against the backdrop/lower windows
    # already composited underneath, so the cut corners read as clean AA edges.
    if oy < WSYS_TITLEBAR_H:
        return
    sw: uint64 = cast[uint64](w)
    if sw > WSYS_ROOT_ROW_MAX:
        sw = WSYS_ROOT_ROW_MAX
    # Build the opaque bar row ONCE: blue, red-ish close box in the last 16 px.
    x: uint64 = 0
    while x < sw:
        rr: uint8 = 60
        gg: uint8 = 100
        bb: uint8 = 180
        if x + 16 >= sw:
            rr = 200
            gg = 70
            bb = 70
        wsys_root_row[x * 4] = rr
        wsys_root_row[x * 4 + 1] = gg
        wsys_root_row[x * 4 + 2] = bb
        wsys_root_row[x * 4 + 3] = 255
        x = x + 1
    r: int64 = _wsys_titlebar_radius(cast[int64](sw))
    ty: int64 = oy - WSYS_TITLEBAR_H
    row: int64 = 0
    while row < WSYS_TITLEBAR_H:
        if row < r:
            # Corner scanline: stamp arc coverage into the corner alphas and
            # alpha-blend the row so the cut corners AA against what's behind.
            _wsys_titlebar_corner_alpha(cast[int64](sw), row, r, 0,
                                        cast[int64](sw))
            fb_present_rgba_row_blend(0, cast[uint64](ox),
                                      cast[uint64](ty + row), sw,
                                      &wsys_root_row[0], sw)
            # Restore the corner alphas to fully opaque for the next iteration.
            _wsys_titlebar_restore_alpha(cast[int64](sw), 0, r,
                                         cast[int64](sw))
        else:
            fb_present_rgba_row(0, cast[uint64](ox),
                                cast[uint64](ty + row), sw,
                                &wsys_root_row[0], sw)
        row = row + 1


# --- desktop root background (rl5 flip: the scene compositor owns fb) -
#
# When the scene compositor is the LIVE display server (runlevel 5), it
# is the sole owner of /dev/fb — no legacy hamUId present overdraws it.
# So a full present must paint the desktop ROOT first (a solid backdrop)
# before z-blitting the window caches, otherwise the gaps between windows
# show whatever the boot fb-text console left behind. A one-row scratch
# buffer is blitted across every screen row via fb_present_rgba_row.
#
# wsys_root_active is latched to 1 by the `desktop` ctl verb (the DE
# startup hook) so the background-clear only kicks in once the DE is up;
# before that the additive-alongside path (no clear) is preserved.
WSYS_ROOT_ROW_MAX: uint64 = 4096         # max screen width we back-buffer
wsys_root_row: Array[16384, uint8]       # 4096 px * 4 = 16 KiB scratch row
wsys_root_active: int32 = 0
# FLICKER FIX: the full-screen backdrop clear (_wsys_present_background)
# must run ONCE — when the desktop first claims the screen — NOT on every
# commit. A per-commit full clear is a visible whole-screen FLASH every
# frame (the DE re-commits continuously: clock, focus, animation). After
# the first paint, each window's own cache blit overwrites its rect and
# the damage-scoped recompose (cursor save-behind, window move/close)
# restores the backdrop only where it's exposed. Idle desktop = zero
# framebuffer churn. Latched 0->1 by the first present after activation;
# reset to 0 when the desktop is suspended (logout / fb_console_resume) so
# a re-activation repaints the backdrop once more.
wsys_bg_painted: int32 = 0
wsys_root_r: uint8 = 32
wsys_root_g: uint8 = 80
wsys_root_b: uint8 = 96
# Present serialization (SMP): the present pipeline (rasterizer scratch +
# the shared scratch row + the cursor cache) is single-threaded by design,
# but is now invoked from BOTH a committing client AND the /dev/mouse input
# router. Take this lock around any full present / cursor present so the
# two contexts never interleave and corrupt the shared scratch.
wsys_present_lock: uint32 = 0

# REAL-HW DIAGNOSTIC (blank-green debug). The DE renders correctly in
# QEMU/OVMF at every resolution we can test, but a real-HW boot (NUC GOP)
# was reported as a blank teal screen + a movable cursor and NO windows.
# That divergence can't be reproduced in a VM, so the compositor emits a
# throttled `[de_present]` line for the first few full presents AFTER the
# rl5 desktop flip: it reports the fb geometry, whether the offscreen
# double-buffer shadow installed (off on >1Mpx panels — the buddy
# MAX_ORDER=10 cap), how many live scene windows exist, and how many were
# actually z-blitted. On the next instrumented real-HW boot the LOG.TXT /
# serial capture pinpoints which stage drops the window layers (no live
# windows? rasterized-but-not-presented? shadow-on-but-flush-broken?).
# Throttled to the first WSYS_PRESENT_DIAG_MAX presents so steady-state
# compositing is never spammed.
WSYS_PRESENT_DIAG_MAX: uint64 = 8
wsys_present_diag_n:   uint64 = 0


def _wsys_present_diag(presented: int32, live: int32):
    if wsys_present_diag_n >= WSYS_PRESENT_DIAG_MAX:
        return
    wsys_present_diag_n = wsys_present_diag_n + 1
    sw: uint64 = fb_get_width()
    sh: uint64 = fb_get_height()
    printk2("[de_present] fb_w=%d fb_h=%d\n", sw, sh)
    printk2("[de_present]   root_active=%d shadow_ok=%d\n",
            cast[uint64](wsys_root_active), cast[uint64](wsys_shadow_ok))
    printk2("[de_present]   live_windows=%d presented=%d\n",
            cast[uint64](live), cast[uint64](presented))


def _wsys_present_background():
    # Fill the whole framebuffer with the desktop root colour. Builds one
    # RGBA row in the scratch buffer, then blits it to every screen row.
    sw: uint64 = fb_get_width()
    sh: uint64 = fb_get_height()
    if sw > WSYS_ROOT_ROW_MAX:
        sw = WSYS_ROOT_ROW_MAX
    x: uint64 = 0
    while x < sw:
        wsys_root_row[x * 4] = wsys_root_r
        wsys_root_row[x * 4 + 1] = wsys_root_g
        wsys_root_row[x * 4 + 2] = wsys_root_b
        wsys_root_row[x * 4 + 3] = 255
        x = x + 1
    y: uint64 = 0
    while y < sh:
        fb_present_rgba_row(0, 0, y, sw, &wsys_root_row[0], sw)
        y = y + 1


# --- offscreen present shadow (double-buffer) -----------------------
#
# THE FLICKER KEYSTONE. The compositor used to blit composited rows
# straight into the scanned-out framebuffer (fb_present_rgba_row ->
# scanout), so a multi-source rect — backdrop fill THEN a window cache
# over it, or a large-window move re-blitting two big rects — was visible
# on the monitor mid-composite as a half-drawn frame. That is the
# persistent whole-DE flicker (and the "large windows slow/torn to move")
# that survived two damage-clip waves: clipping shrank the rect but the
# rect was still painted live to scanout.
#
# FIX: composite into an offscreen screen-sized shadow (plain cached RAM)
# and copy each finished damage rect to scanout in ONE pass. The shadow is
# installed into fb_text via fb_set_shadow(); all present helpers then
# write into it, and the damage-op boundaries call _wsys_flush_rect() (->
# fb_present_flush) to push a fully-composited rect to the real FB.
#
# Sized for screens up to ~1 Mpx (the DE runs at 1280x800 = 1,024,000 px =
# 3.9 MiB RGBA, which fits the buddy allocator's MAX_ORDER=10 = 4 MiB cap).
# Allocated lazily at order WSYS_SHADOW_ORDER from the buddy allocator on
# first present once the fb geometry is known; if the screen is bigger than
# the shadow can hold the install is skipped and present falls back to
# direct scanout (correctness preserved, flicker returns only on giant
# modes). NOTE: alloc_pages refuses order > MAX_ORDER(10), so the order MUST
# stay <= 10 or the shadow silently never installs and the whole
# double-buffer is a no-op (the original WIP used order 12 and was inert).
WSYS_SHADOW_ORDER:   int32  = 10          # 1024 pages = 4 MiB (MAX_ORDER)
WSYS_SHADOW_MAX_PX:  uint64 = 1048576     # 4 MiB / 4 = 1,048,576 px
wsys_shadow_page:    uint64 = 0           # 0 = not yet allocated
wsys_shadow_pitch:   uint64 = 0           # pixels per shadow row (= fb_width)
wsys_shadow_ok:      int32  = 0           # 1 = installed & active


def _wsys_shadow_init_if_needed():
    # Lazily allocate + install the present shadow once the fb geometry is
    # known. Idempotent. CALLER HOLDS wsys_present_lock.
    if wsys_shadow_ok != 0:
        return
    if wsys_shadow_page != 0:
        return                                  # alloc tried & failed; skip
    if fb_get_initialized() == 0:
        return
    sw: uint64 = fb_get_width()
    sh: uint64 = fb_get_height()
    if sw == 0 or sh == 0:
        return
    if sw * sh > WSYS_SHADOW_MAX_PX:
        # Screen too large for the shadow — leave wsys_shadow_page 0 so we
        # don't retry every present; present falls back to direct scanout.
        return
    pg: uint64 = alloc_pages(WSYS_SHADOW_ORDER)
    if pg == 0:
        return
    wsys_shadow_page = pg
    wsys_shadow_pitch = sw
    fb_set_shadow(pg, sw)
    wsys_shadow_ok = 1


def _wsys_flush_rect(rx: int64, ry: int64, rw: int64, rh: int64):
    # Push the composited rect from the shadow to scanout in one pass.
    # No-op when no shadow is active (direct-scanout fallback already drew).
    # CALLER HOLDS wsys_present_lock.
    if wsys_shadow_ok == 0:
        return
    if rw <= 0 or rh <= 0:
        return
    sw: int64 = cast[int64](fb_get_width())
    sh: int64 = cast[int64](fb_get_height())
    if rx < 0:
        rw = rw + rx
        rx = 0
    if ry < 0:
        rh = rh + ry
        ry = 0
    if rx + rw > sw:
        rw = sw - rx
    if ry + rh > sh:
        rh = sh - ry
    if rw <= 0 or rh <= 0:
        return
    fb_present_flush(cast[uint64](rx), cast[uint64](ry),
                     cast[uint64](rw), cast[uint64](rh))


def wsys_scene_present() -> int32:
    # Public present entry: serialize the whole pipeline so a committing
    # client and the /dev/mouse input router never interleave.
    # IRQ-SAFE: the timer-tick mouse pump (IRQ context) routes through this
    # same lock. Mask interrupts on the process-context holder so the timer
    # can't fire on THIS CPU mid-present and self-deadlock spinning on the
    # lock we already hold. (Cross-CPU contention still spins, as intended.)
    fl: uint64 = local_irq_save()
    spinlock_lock(&wsys_present_lock)
    n: int32 = _wsys_scene_present_locked()
    spinlock_unlock(&wsys_present_lock)
    local_irq_restore(fl)
    return n


def _wsys_win_visible(w: uint64) -> int32:
    # Workspace visibility gate for the z-blit / recompose passes. A decorated
    # (app) window is visible only on its home desktop (wsys_win_ws == the
    # active wsys_cur_ws). Undecorated chrome (panels, backdrop, menus, toasts)
    # is sticky and shows on every desktop. This is the single authority the
    # full present, the damage-scoped recompose, and the window-list readback
    # all consult, so a workspace switch hides/shows the right windows for free.
    if wsys_win_decorate[w] != 0 and wsys_win_ws[w] != wsys_cur_ws:
        return 0
    return 1


def _wsys_scene_present_locked() -> int32:
    # Rasterize every live window with a non-empty scene, then z-blit all
    # caches bottom-to-top, then the cursor. Returns the number of
    # windows presented. Safe to call when no fb (no-op, returns 0).
    # CALLER HOLDS wsys_present_lock.
    if fb_get_initialized() == 0:
        return 0
    _wsys_init_if_needed()
    _wsys_shadow_init_if_needed()
    # rl5 flip: paint the desktop root backdrop ONCE, the first present
    # after the DE claims the screen via the `desktop` ctl verb. NEVER on
    # subsequent commits — a per-commit full clear is the whole-screen
    # FLICKER the user reported. After this one paint, window cache blits
    # and the damage-scoped recompose keep the backdrop correct without
    # ever clearing the visible fb on a timer/commit.
    if wsys_root_active != 0 and wsys_bg_painted == 0:
        _wsys_present_background()
        wsys_bg_painted = 1
    # Rasterize all live windows that have a scene.
    w: uint64 = 1
    while w < WSYS_SCENE_SLOTS:
        if wsys_slot_in_use[w] != 0 and wsys_scene_len[w] > 0:
            _wsys_rasterize_window(cast[int32](w))
        w = w + 1
    # Z-blit bottom-to-top. z range is small; do a simple ordered sweep
    # over a bounded set of z levels (-128..127 folded by repeated min).
    presented: int32 = 0
    # Find min and max z among live scene windows.
    have: int32 = 0
    zmin: int64 = 0
    zmax: int64 = 0
    w2: uint64 = 1
    while w2 < WSYS_SCENE_SLOTS:
        if wsys_slot_in_use[w2] != 0 and wsys_scene_len[w2] > 0:
            zz: int64 = wsys_win_z[w2]
            if have == 0:
                zmin = zz
                zmax = zz
                have = 1
            else:
                if zz < zmin:
                    zmin = zz
                if zz > zmax:
                    zmax = zz
        w2 = w2 + 1
    if have == 0:
        # still composite cursor
        _wsys_flush_rect(0, 0, cast[int64](fb_get_width()),
                         cast[int64](fb_get_height()))
        _wsys_present_cursor_locked()
        # Real-HW blank-green diagnostic: zero live windows here means the
        # scene clients never created/committed a window (the exact
        # blank-green symptom). Report fb geometry + shadow status.
        _wsys_present_diag(0, 0)
        return 0
    zc: int64 = zmin
    while zc <= zmax:
        w3: uint64 = 1
        while w3 < WSYS_SCENE_SLOTS:
            if wsys_slot_in_use[w3] != 0 and wsys_scene_len[w3] > 0 \
                    and wsys_win_z[w3] == zc \
                    and _wsys_win_visible(w3) != 0:
                _wsys_present_window(cast[int32](w3))
                presented = presented + 1
            w3 = w3 + 1
        zc = zc + 1
    # DOUBLE-BUFFER: the whole screen was composited into the shadow; push
    # it to scanout in one pass (tear-free) before the cursor overlay.
    _wsys_flush_rect(0, 0, cast[int64](fb_get_width()),
                     cast[int64](fb_get_height()))
    _wsys_present_cursor_locked()
    # Real-HW blank-green diagnostic: count live scene windows and report
    # how many were actually z-blitted (throttled to the first few).
    live: int32 = 0
    wl: uint64 = 1
    while wl < WSYS_SCENE_SLOTS:
        if wsys_slot_in_use[wl] != 0 and wsys_scene_len[wl] > 0:
            live = live + 1
        wl = wl + 1
    _wsys_present_diag(presented, live)
    return presented


def _wsys_win_screen_extent(u: uint64, rx: Ptr[int64], ry: Ptr[int64],
                            rw: Ptr[int64], rh: Ptr[int64]):
    # Compute wid u's on-screen damage extent (content rect plus its SSD
    # titlebar band, if decorated). Used by the damage-scoped present so a
    # single-window commit / drag only touches that window's footprint.
    w: int64 = _wsys_win_def_w(u)
    h: int64 = _wsys_win_def_h(u)
    _wsys_clamp_cache_dims(&w, &h)
    ox: int64 = wsys_win_x[u]
    oy: int64 = wsys_win_y[u]
    if ox < 0:
        ox = 0
    if oy < 0:
        oy = 0
    ty: int64 = oy
    th: int64 = h
    if wsys_win_decorate[u] != 0 and oy >= WSYS_TITLEBAR_H:
        ty = oy - WSYS_TITLEBAR_H
        th = h + WSYS_TITLEBAR_H
    rx[0] = ox
    ry[0] = ty
    rw[0] = w
    rh[0] = th


def _wsys_present_window_scoped(wid: int32) -> int32:
    # DAMAGE-SCOPED present for a SINGLE window whose CONTENT changed (a
    # per-client `commit`). Re-rasterizes ONLY this window's cache, then
    # recomposites ONLY this window's screen extent — backdrop + every
    # window cache (this one and any overlapping higher-z window) clipped
    # to that rect via _wsys_recompose_rect — then the cursor. This is the
    # fix for the per-commit "re-rasterize-all + re-blit-all" present storm
    # that blanked/flickered the whole screen (most visibly the full-screen
    # hamdesktop committing on a desktop-icon click). Takes the present lock
    # like wsys_scene_present. Returns 1 if it presented, 0 if no fb.
    if fb_get_initialized() == 0:
        return 0
    u: uint64 = cast[uint64](wid)
    if u == 0 or u >= WSYS_SCENE_SLOTS:
        return 0
    if wsys_slot_in_use[u] == 0:
        return 0
    fl: uint64 = local_irq_save()
    spinlock_lock(&wsys_present_lock)
    _wsys_init_if_needed()
    _wsys_shadow_init_if_needed()
    # First present after the DE flip still needs the backdrop laid down.
    if wsys_root_active != 0 and wsys_bg_painted == 0:
        _wsys_present_background()
        wsys_bg_painted = 1
        _wsys_flush_rect(0, 0, cast[int64](fb_get_width()),
                         cast[int64](fb_get_height()))
    # Re-rasterize just this window's cache from its committed scene.
    if wsys_scene_len[u] > 0:
        _wsys_rasterize_window(wid)
    # Recompose only this window's footprint (backdrop + all caches clipped
    # to the rect, bottom-to-top — so overlapping higher windows stay on top
    # and transparent areas show the backdrop/lower windows correctly).
    rx: int64 = 0
    ry: int64 = 0
    rw: int64 = 0
    rh: int64 = 0
    _wsys_win_screen_extent(u, &rx, &ry, &rw, &rh)
    _wsys_recompose_rect(rx, ry, rw, rh)
    # DOUBLE-BUFFER: flush this window's composited footprint to scanout in
    # one pass (tear-free) before the cursor overlay.
    _wsys_flush_rect(rx, ry, rw, rh)
    _wsys_present_cursor_locked()
    spinlock_unlock(&wsys_present_lock)
    local_irq_restore(fl)
    return 1


def _wsys_present_cursor():
    # Standalone cursor present (cursor move with no window recomposite).
    # Takes the present lock so it can't race a concurrent full present.
    # IRQ-SAFE (see wsys_scene_present): mask the timer on this CPU.
    fl: uint64 = local_irq_save()
    spinlock_lock(&wsys_present_lock)
    _wsys_shadow_init_if_needed()
    _wsys_present_cursor_locked()
    spinlock_unlock(&wsys_present_lock)
    local_irq_restore(fl)


def _wsys_rect_covered_by_bottom(rx: int64, ry: int64,
                                 rw: int64, rh: int64) -> int32:
    # Return 1 iff the LOWEST-z in-use scene window is undecorated and its
    # content rect fully contains (rx,ry,rw,rh). Such a window (the
    # full-screen desktop backdrop layer) is the opaque base under the rect,
    # so the desktop-root backdrop pre-pass is redundant and only flickers.
    # Conservative: any doubt (no window, decorated, partial cover) -> 0.
    have: int32 = 0
    zmin: int64 = 0
    bw: uint64 = 0
    w2: uint64 = 1
    while w2 < WSYS_SCENE_SLOTS:
        if wsys_slot_in_use[w2] != 0 and wsys_scene_len[w2] > 0:
            zz: int64 = wsys_win_z[w2]
            if have == 0 or zz < zmin:
                zmin = zz
                bw = w2
                have = 1
        w2 = w2 + 1
    if have == 0:
        return 0
    # Decorated windows have a titlebar band the cache doesn't cover -> the
    # backdrop can show through there, so don't skip it.
    if wsys_win_decorate[bw] != 0:
        return 0
    w: int64 = _wsys_win_def_w(bw)
    h: int64 = _wsys_win_def_h(bw)
    _wsys_clamp_cache_dims(&w, &h)
    ox: int64 = wsys_win_x[bw]
    oy: int64 = wsys_win_y[bw]
    if ox < 0:
        ox = 0
    if oy < 0:
        oy = 0
    # Content rect [ox,ox+w) x [oy,oy+h) must fully contain the damage rect.
    if rx < ox or ry < oy:
        return 0
    if rx + rw > ox + w or ry + rh > oy + h:
        return 0
    return 1


def _wsys_recompose_rect(rx: int64, ry: int64, rw: int64, rh: int64):
    # Re-composite the screen sub-rectangle (rx,ry,rw,rh) from the scene
    # SOURCES — desktop backdrop, then each live window cache (with its
    # SSD titlebar) z-ordered bottom-to-top — clipped to that rect. This
    # is the cursor "restore-behind" of §9: instead of reading the fb back
    # (pixfmt-aware, WC-slow), we regenerate the pixels the cursor covered
    # straight from the durable scene caches. No client wake, no cursor.
    # CALLER HOLDS wsys_present_lock.
    if fb_get_initialized() == 0:
        return
    if rw <= 0 or rh <= 0:
        return
    sw: int64 = cast[int64](fb_get_width())
    sh: int64 = cast[int64](fb_get_height())
    # Clamp the rect to the screen.
    if rx < 0:
        rw = rw + rx
        rx = 0
    if ry < 0:
        rh = rh + ry
        ry = 0
    if rx + rw > sw:
        rw = sw - rx
    if ry + rh > sh:
        rh = sh - ry
    if rw <= 0 or rh <= 0:
        return
    # ANTI-BLANK: skip the full-rect backdrop pre-pass when an OPAQUE
    # lowest-z window (the full-screen desktop backdrop layer) already
    # covers the whole rect. Painting backdrop across the whole rect and
    # THEN blitting the desktop cache over it is double work whose first
    # pass is a visible whole-screen BLANK (the desktop-icon-click flicker
    # the user reported, since a desktop commit recomposes the full screen).
    # When the bottom window's content rect contains the rect, its cache
    # blit IS the base layer, so the backdrop fill is pure flicker — drop it.
    skip_bg: int32 = 0
    bottom_covers: int32 = _wsys_rect_covered_by_bottom(rx, ry, rw, rh)
    if bottom_covers != 0:
        skip_bg = 1
    # 1) Desktop backdrop under the rect (only after the rl5 desktop flip;
    #    before that the additive path leaves whatever was there).
    if wsys_root_active != 0 and skip_bg == 0:
        bw: int64 = rw
        if cast[uint64](bw) > WSYS_ROOT_ROW_MAX:
            bw = cast[int64](WSYS_ROOT_ROW_MAX)
        bx: int64 = 0
        while bx < bw:
            wsys_root_row[cast[uint64](bx) * 4]     = wsys_root_r
            wsys_root_row[cast[uint64](bx) * 4 + 1] = wsys_root_g
            wsys_root_row[cast[uint64](bx) * 4 + 2] = wsys_root_b
            wsys_root_row[cast[uint64](bx) * 4 + 3] = 255
            bx = bx + 1
        by: int64 = 0
        while by < rh:
            fb_present_rgba_row(0, cast[uint64](rx),
                                cast[uint64](ry + by), cast[uint64](bw),
                                &wsys_root_row[0], cast[uint64](bw))
            by = by + 1
    # 2) Window caches z-ordered bottom-to-top, clipped to the rect.
    have: int32 = 0
    zmin: int64 = 0
    zmax: int64 = 0
    w2: uint64 = 1
    while w2 < WSYS_SCENE_SLOTS:
        if wsys_slot_in_use[w2] != 0 and wsys_scene_len[w2] > 0:
            zz: int64 = wsys_win_z[w2]
            if have == 0:
                zmin = zz
                zmax = zz
                have = 1
            else:
                if zz < zmin:
                    zmin = zz
                if zz > zmax:
                    zmax = zz
        w2 = w2 + 1
    if have == 0:
        return
    zc: int64 = zmin
    while zc <= zmax:
        w3: uint64 = 1
        while w3 < WSYS_SCENE_SLOTS:
            if wsys_slot_in_use[w3] != 0 and wsys_scene_len[w3] > 0 \
                    and wsys_win_z[w3] == zc \
                    and _wsys_win_visible(w3) != 0:
                _wsys_present_window_rect(cast[int32](w3), rx, ry, rw, rh)
            w3 = w3 + 1
        zc = zc + 1


def _wsys_present_window_rect(wid: int32, rx: int64, ry: int64,
                              rw: int64, rh: int64):
    # Blit only the intersection of wid's on-screen extent (cache + SSD
    # titlebar) with the screen rect (rx,ry,rw,rh). Used by the cursor
    # restore-behind recompose; content is NOT re-rasterized (the cache is
    # the source of truth).
    u: uint64 = cast[uint64](wid)
    cache: Ptr[uint8] = _wsys_layer_fb_get(wid)
    if cast[uint64](cache) == 0:
        return
    w: int64 = _wsys_win_def_w(u)
    h: int64 = _wsys_win_def_h(u)
    _wsys_clamp_cache_dims(&w, &h)
    ox: int64 = wsys_win_x[u]
    oy: int64 = wsys_win_y[u]
    if ox < 0:
        ox = 0
    if oy < 0:
        oy = 0
    rx1: int64 = rx + rw
    ry1: int64 = ry + rh
    # SSD titlebar rows (above the content origin) intersected with rect.
    if wsys_win_decorate[u] != 0 and oy >= WSYS_TITLEBAR_H:
        _wsys_present_titlebar_rect(ox, oy, w, rx, ry, rx1, ry1)
    # Content cache rows intersected with rect.
    # Screen X span of this window: [ox, ox+w). Intersect with [rx, rx1).
    cx0: int64 = ox
    if cx0 < rx:
        cx0 = rx
    cx1: int64 = ox + w
    if cx1 > rx1:
        cx1 = rx1
    if cx1 <= cx0:
        return
    cw: int64 = cx1 - cx0
    src_col: int64 = cx0 - ox                    # column offset into cache row
    # Screen Y span: [oy, oy+h). Intersect with [ry, ry1).
    sy0: int64 = oy
    if sy0 < ry:
        sy0 = ry
    sy1: int64 = oy + h
    if sy1 > ry1:
        sy1 = ry1
    scr_y: int64 = sy0
    while scr_y < sy1:
        src_y: int64 = scr_y - oy
        # Present cw pixels starting at cache column src_col of cache row
        # src_y to screen (cx0, scr_y). fb_present_rgba_row reads from
        # src[src_y*pitch + x]; we want the slice starting at src_col, so
        # pass a row pointer biased by src_col*4 and src_y=0-equivalent via
        # the pitch math: use src_y as the row and add src_col by pointing
        # at the element. fb_present_rgba_row(src_y, scr_x0, scr_y, w, src,
        # src_pitch_px) computes base = src_y*src_pitch_px*4; to also skip
        # src_col we bias the src pointer.
        bias: uint64 = cast[uint64](src_col) * 4
        fb_present_rgba_row(cast[uint64](src_y), cast[uint64](cx0),
                            cast[uint64](scr_y), cast[uint64](cw),
                            &cache[bias], cast[uint64](w))
        scr_y = scr_y + 1


def _wsys_present_titlebar_rect(ox: int64, oy: int64, w: int64,
                                rx: int64, ry: int64, rx1: int64,
                                ry1: int64):
    # Re-blit the intersection of the SSD titlebar (TITLEBAR_H rows above
    # the content origin, width w) with the screen rect. Mirrors
    # _wsys_present_titlebar's pixel recipe.
    ty: int64 = oy - WSYS_TITLEBAR_H
    # Y span of bar: [ty, oy). Intersect with [ry, ry1).
    by0: int64 = ty
    if by0 < ry:
        by0 = ry
    by1: int64 = oy
    if by1 > ry1:
        by1 = ry1
    if by1 <= by0:
        return
    # X span: [ox, ox+w) ∩ [rx, rx1).
    bx0: int64 = ox
    if bx0 < rx:
        bx0 = rx
    bx1: int64 = ox + w
    if bx1 > rx1:
        bx1 = rx1
    if bx1 <= bx0:
        return
    sw: int64 = ox + w                           # full bar width for close box
    bx: int64 = bx0
    while bx < bx1:
        # Column relative to bar start for the close-box accent test.
        relx: int64 = bx - ox
        idx: int64 = bx - bx0
        rr: uint8 = 60
        gg: uint8 = 100
        bb: uint8 = 180
        if relx + 16 >= w:
            rr = 200
            gg = 70
            bb = 70
        wsys_root_row[cast[uint64](idx) * 4]     = rr
        wsys_root_row[cast[uint64](idx) * 4 + 1] = gg
        wsys_root_row[cast[uint64](idx) * 4 + 2] = bb
        wsys_root_row[cast[uint64](idx) * 4 + 3] = 255
        bx = bx + 1
    cnt: int64 = bx1 - bx0
    # Rounded top corners (#254): mirror _wsys_present_titlebar. The buffer
    # holds `cnt` px starting at bar-relative column rel0 = bx0-ox of a bar
    # `w` px wide; the top `r` scanlines get AA corner coverage + a blended
    # present so a damage re-blit repaints the SAME rounded corner, not a
    # square one.
    r: int64 = _wsys_titlebar_radius(w)
    rel0: int64 = bx0 - ox
    yy: int64 = by0
    while yy < by1:
        barrow: int64 = yy - ty
        if barrow < r and barrow >= 0:
            _wsys_titlebar_corner_alpha(cnt, barrow, r, rel0, w)
            fb_present_rgba_row_blend(0, cast[uint64](bx0), cast[uint64](yy),
                                      cast[uint64](cnt), &wsys_root_row[0],
                                      cast[uint64](cnt))
            _wsys_titlebar_restore_alpha(cnt, rel0, r, w)
        else:
            fb_present_rgba_row(0, cast[uint64](bx0), cast[uint64](yy),
                                cast[uint64](cnt), &wsys_root_row[0],
                                cast[uint64](cnt))
        yy = yy + 1


def _wsys_present_cursor_locked():
    # Composite the cursor scene (slot 0) LAST, always on top, at its own
    # window-local coords (the cursor scene's fill carries the position).
    # CALLER HOLDS wsys_present_lock.
    #
    # SAVE-BEHIND (§9): before drawing the cursor at its new position, we
    # RESTORE the rectangle the cursor last covered by recompositing that
    # screen sub-rect from the scene sources (backdrop + window caches).
    # This makes a cursor move leave NO trail without waking any client or
    # doing a full-screen recomposite — cursor latency stays O(sprite).
    if wsys_scene_len[0] == 0:
        return
    # Remember the previous footprint so we can flush both old+new to
    # scanout after recompositing into the shadow.
    had_prev: int32 = wsys_cursor_drawn
    prev_x: int64 = wsys_cursor_prev_x
    prev_y: int64 = wsys_cursor_prev_y
    # Restore the previous cursor footprint (if any) first.
    if wsys_cursor_drawn != 0:
        _wsys_recompose_rect(wsys_cursor_prev_x, wsys_cursor_prev_y,
                             WSYS_CURSOR_CACHE_DIM, WSYS_CURSOR_CACHE_DIM)
    # Rasterize cursor scene into the fixed 32x32 cursor cache.
    _wsys_rasterize_cursor()
    cur: Ptr[uint8] = cast[Ptr[uint8]](wsys_cursor_cache_page)
    if cast[uint64](cur) == 0:
        return
    cw: int64 = WSYS_CURSOR_CACHE_DIM
    ch2: int64 = WSYS_CURSOR_CACHE_DIM
    ox: int64 = wsys_cursor_blit_x
    oy: int64 = wsys_cursor_blit_y
    sy: uint64 = 0
    while cast[int64](sy) < ch2:
        # ALPHA-KEYED: the 32x32 cursor cache is mostly transparent padding
        # around the small sprite. fb_present_rgba_row is alpha-BLIND and
        # would paint that padding as an opaque BLACK square (the black box
        # trailing the cursor). The keyed blit skips alpha==0 pixels so only
        # the sprite lands and the desktop shows through around it.
        fb_present_rgba_row_keyed(sy, cast[uint64](ox),
                                  cast[uint64](oy) + sy, cast[uint64](cw),
                                  cur, cast[uint64](cw))
        sy = sy + 1
    # DOUBLE-BUFFER: the restored old footprint AND the new sprite were
    # composited into the shadow; flush both rects to scanout (tear-free).
    if had_prev != 0:
        _wsys_flush_rect(prev_x, prev_y, WSYS_CURSOR_CACHE_DIM,
                         WSYS_CURSOR_CACHE_DIM)
    _wsys_flush_rect(ox, oy, WSYS_CURSOR_CACHE_DIM, WSYS_CURSOR_CACHE_DIM)
    # Remember this footprint so the NEXT move restores it.
    wsys_cursor_prev_x = ox
    wsys_cursor_prev_y = oy
    wsys_cursor_drawn = 1


WSYS_CURSOR_CACHE_DIM: int64 = 32        # 32x32 cursor sprite
wsys_cursor_cache_page: uint64 = 0       # lazily-allocated cursor cache
wsys_cursor_blit_x: int64 = 0
wsys_cursor_blit_y: int64 = 0
# Save-behind footprint of the LAST drawn cursor (restored before the
# next draw so motion leaves no trail). Decoupled from window recomposite.
wsys_cursor_prev_x: int64 = 0
wsys_cursor_prev_y: int64 = 0
wsys_cursor_drawn:  int32 = 0


def _wsys_rasterize_cursor():
    # Rasterize the cursor scene (slot 0) into a small fixed 32x32 cache.
    # The cursor scene's primitives are in cursor-local coords; the blit
    # origin is read from a leading "# at X Y" comment OR defaults to the
    # last set cursor position. We keep it simple: parse a `fill`/`rect`
    # whose x,y are taken as the on-screen origin, and render the sprite
    # at (0,0) locally so it blits at the parsed origin.
    if wsys_cursor_cache_page == 0:
        pg: uint64 = alloc_pages(0)            # one page = 4 KiB >= 32*32*4
        if pg == 0:
            return
        wsys_cursor_cache_page = pg
    cache: Ptr[uint8] = cast[Ptr[uint8]](wsys_cursor_cache_page)
    memset(cache, 0, cast[uint64](WSYS_CURSOR_CACHE_DIM)
           * cast[uint64](WSYS_CURSOR_CACHE_DIM) * 4)
    _wsys_rast_w = WSYS_CURSOR_CACHE_DIM
    _wsys_rast_h = WSYS_CURSOR_CACHE_DIM
    _wsys_rast_clip_x0 = 0
    _wsys_rast_clip_y0 = 0
    _wsys_rast_clip_x1 = WSYS_CURSOR_CACHE_DIM
    _wsys_rast_clip_y1 = WSYS_CURSOR_CACHE_DIM
    # Parse the FIRST fill/rect line for the on-screen origin; render all
    # primitives translated so origin maps to (0,0) in the sprite.
    n: uint64 = wsys_scene_len[0]
    got_origin: int32 = 0
    ox: int64 = 0
    oy: int64 = 0
    i: uint64 = 0
    while i < n:
        ls: uint64 = i
        while i < n and wsys_scene_buf[i] != 10:
            i = i + 1
        le: uint64 = i
        if i < n:
            i = i + 1
        # peek verb + first two ints for origin
        p: uint64 = _wsys_ctl_skip_ws(&wsys_scene_buf[0], ls, le)
        vs: uint64 = p
        p = _wsys_ctl_token_end(&wsys_scene_buf[0], p, le)
        ve: uint64 = p
        if ve - vs >= 1 and wsys_scene_buf[vs] == 35:
            continue
        if got_origin == 0:
            px: int64 = 0
            py: int64 = 0
            pp: uint64 = p
            if _wsys_scene_next_int(&wsys_scene_buf[0], &pp, le, &px) == 1 \
                    and _wsys_scene_next_int(&wsys_scene_buf[0], &pp, le, &py) == 1:
                ox = px
                oy = py
                got_origin = 1
    if got_origin == 1:
        wsys_cursor_blit_x = ox
        wsys_cursor_blit_y = oy
    # Re-walk and render each primitive translated by -origin.
    i2: uint64 = 0
    while i2 < n:
        ls2: uint64 = i2
        while i2 < n and wsys_scene_buf[i2] != 10:
            i2 = i2 + 1
        le2: uint64 = i2
        if i2 < n:
            i2 = i2 + 1
        _wsys_rast_cursor_line(cache, ls2, le2, ox, oy)


def _wsys_rast_cursor_line(cache: Ptr[uint8], ls: uint64, le: uint64,
                           ox: int64, oy: int64):
    # Like _wsys_rast_line but only honours fill/rect, translated by
    # (-ox,-oy) so the sprite is local to the 32x32 cache.
    buf: Ptr[uint8] = &wsys_scene_buf[0]
    p: uint64 = _wsys_ctl_skip_ws(buf, ls, le)
    if p >= le:
        return
    vs: uint64 = p
    p = _wsys_ctl_token_end(buf, p, le)
    ve: uint64 = p
    if ve - vs >= 1 and buf[vs] == 35:
        return
    is_fill: int32 = _wsys_ctl_word_eq(buf, vs, ve, "fill")
    is_rect: int32 = _wsys_ctl_word_eq(buf, vs, ve, "rect")
    if is_fill == 0 and is_rect == 0:
        return
    fx: int64 = 0
    fy: int64 = 0
    fw: int64 = 0
    fh: int64 = 0
    if _wsys_scene_next_int(buf, &p, le, &fx) == 0:
        return
    if _wsys_scene_next_int(buf, &p, le, &fy) == 0:
        return
    if _wsys_scene_next_int(buf, &p, le, &fw) == 0:
        return
    if _wsys_scene_next_int(buf, &p, le, &fh) == 0:
        return
    cp: uint64 = _wsys_ctl_skip_ws(buf, p, le)
    ce: uint64 = _wsys_ctl_token_end(buf, cp, le)
    rr: uint8 = 0
    gg: uint8 = 0
    bb: uint8 = 0
    aa: uint8 = 255
    if _wsys_parse_color(buf, cp, ce, &rr, &gg, &bb, &aa) == 0:
        return
    _wsys_cache_fillrect(cache, fx - ox, fy - oy, fw, fh, rr, gg, bb, aa)


# =====================================================================
# INPUT ROUTING & FOCUS (docs/de_scene_file_arch.md §11)
# =====================================================================
#
# The compositor is the SOLE consumer of pointer/keyboard input at
# runlevel 5. When a mouse event is injected via /dev/mouse
# (devmouse_write), devmouse calls wsys_route_mouse_abs() here. We:
#   * convert tablet-abs (0..32767) to screen pixels,
#   * update the cursor scene + sprite position (decoupled blit),
#   * hit-test the window stack TOP-DOWN by z,
#   * a press in a window's TITLEBAR begins a compositor-side MOVE drag
#     (no client round-trip); a press in the CONTENT raises+focuses the
#     window and forwards a window-LOCAL `m` event to its `event` file,
#   * motion with a button held during a titlebar-drag moves the window
#     (updates win_x/win_y) and re-presents; otherwise motion forwards a
#     window-local `m` event to the window under the cursor.
#
# Keyboard goes to the FOCUSED window (wsys_focus_wid), not the hovered
# one (so keys don't follow the mouse off the window mid-type).

wsys_focus_wid: int32 = 0                # 0 = no focused window
wsys_cursor_x: int64 = 0                 # current cursor screen position
wsys_cursor_y: int64 = 0
wsys_cursor_inited: int32 = 0
# Titlebar-drag move state.
wsys_drag_wid: int32 = 0                 # 0 = not dragging
wsys_drag_dx: int64 = 0                  # cursor->window-origin offset
wsys_drag_dy: int64 = 0
wsys_prev_buttons: uint32 = 0

# --- MATE-style window management state -------------------------------
# Double-click detection on the titlebar (maximize/restore toggle): the
# wid + jiffy timestamp of the last titlebar PRESS. A second press on the
# SAME wid within WSYS_DBLCLICK_JIFFIES counts as a double-click.
WSYS_DBLCLICK_JIFFIES: uint64 = 40       # 40 jiffies = ~400 ms at HZ=100
wsys_last_tbar_wid: int32 = 0
wsys_last_tbar_jiffy: uint64 = 0

# Edge-snap intent latched DURING a titlebar move drag (committed on
# RELEASE, MATE-style). 0 = none, 1 = TOP (maximize), 2 = LEFT half,
# 3 = RIGHT half. While the cursor sits at a screen edge the window keeps
# following the pointer (no live preview overlay); the snap is applied when
# the button is let go.
WSYS_SNAP_NONE:  int32 = 0
WSYS_SNAP_TOP:   int32 = 1
WSYS_SNAP_LEFT:  int32 = 2
WSYS_SNAP_RIGHT: int32 = 3
wsys_drag_snap_intent: int32 = 0
# Pixels from a screen edge that arm the corresponding snap during a drag.
WSYS_SNAP_EDGE_PX: int64 = 6

# Free-resize drag state. wsys_resize_wid>0 means a border/corner press is
# actively resizing. wsys_resize_edge is a bitmask of which edges move:
#   1 = LEFT, 2 = RIGHT, 4 = TOP, 8 = BOTTOM (corners combine, e.g. 1|4).
# The anchor is the cursor position + the window rect captured at press, so
# motion deltas update only the grabbed edge(s).
WSYS_REZ_LEFT:   int32 = 1
WSYS_REZ_RIGHT:  int32 = 2
WSYS_REZ_TOP:    int32 = 4
WSYS_REZ_BOTTOM: int32 = 8
WSYS_RESIZE_BORDER_PX: int64 = 5         # grab band around the window border
WSYS_WIN_MIN_W: int64 = 80               # minimum free-resize window size
WSYS_WIN_MIN_H: int64 = 60
wsys_resize_wid:  int32 = 0
wsys_resize_edge: int32 = 0
# Window rect (content x/y/w/h) + cursor captured at the resize press.
wsys_resize_ox: int64 = 0
wsys_resize_oy: int64 = 0
wsys_resize_ow: int64 = 0
wsys_resize_oh: int64 = 0
wsys_resize_px: int64 = 0
wsys_resize_py: int64 = 0


def _wsys_work_area(ax: Ptr[int64], ay: Ptr[int64],
                    aw: Ptr[int64], ah: Ptr[int64]):
    # The WORK AREA = the screen minus the top panel strip, so a maximized
    # or edge-snapped window never covers the panel. The panel is the
    # top-anchored overlay-chrome window (decorate 0, z>=100, origin at the
    # top of the screen). We detect it dynamically: scan for a z>=100,
    # decorate-0 window whose top edge is at/above y=0-ish and take the
    # bottom of its BASE band as the work-area top. The panel grows when its
    # Applications menu drops open (PANEL_H 26 -> 118); we must not let that
    # transient height eat the work area, so the detected panel bottom is
    # clamped to WSYS_PANEL_MAX_H. Falls back to WSYS_PANEL_DEF_H if no
    # panel window is found (e.g. before the panel has committed).
    sw: int64 = cast[int64](fb_get_width())
    sh: int64 = cast[int64](fb_get_height())
    panel_bot: int64 = 0
    w: uint64 = 1
    while w < WSYS_SCENE_SLOTS:
        if wsys_slot_in_use[w] != 0 and wsys_scene_len[w] > 0 \
                and wsys_win_decorate[w] == 0 and wsys_win_pinned[w] == 0 \
                and wsys_win_z[w] >= 100:
            wy: int64 = wsys_win_y[w]
            if wy <= WSYS_SNAP_EDGE_PX:
                pb: int64 = wy + _wsys_win_def_h(w)
                if pb > WSYS_PANEL_MAX_H:
                    pb = WSYS_PANEL_MAX_H
                if pb > panel_bot:
                    panel_bot = pb
        w = w + 1
    if panel_bot <= 0:
        panel_bot = WSYS_PANEL_DEF_H
    ax[0] = 0
    ay[0] = panel_bot
    aw[0] = sw
    ah[0] = sh - panel_bot


# Default/clamp for the top panel band the work area excludes. The live
# panel is PANEL_H=26 (user/hampanelscene.ad); MAX bounds a menu-open panel.
WSYS_PANEL_DEF_H: int64 = 26
WSYS_PANEL_MAX_H: int64 = 30


def _wsys_save_float_geo(u: uint64):
    # Capture the current floating geometry so a later restore can undo a
    # maximize/snap. Only meaningful from a NORMAL state (callers guard).
    wsys_win_sav_x[u] = wsys_win_x[u]
    wsys_win_sav_y[u] = wsys_win_y[u]
    wsys_win_sav_w[u] = _wsys_win_def_w(u)
    wsys_win_sav_h[u] = _wsys_win_def_h(u)


def _wsys_apply_geo(u: uint64, nx: int64, ny: int64, nw: int64, nh: int64):
    # Set a window's geometry and damage-scope-recompose the OLD + NEW
    # footprints (restore vacated pixels, draw the window at its new rect).
    # Mirrors the move-drag two-rect recompose: no full present, cursor last.
    ovx: int64 = wsys_win_x[u]
    ovy: int64 = wsys_win_y[u]
    ovw: int64 = _wsys_win_def_w(u)
    ovh: int64 = _wsys_win_def_h(u)
    if ny < WSYS_TITLEBAR_H:
        ny = WSYS_TITLEBAR_H
    if nx < 0:
        nx = 0
    wsys_win_x[u] = nx
    wsys_win_y[u] = ny
    wsys_win_w[u] = nw
    wsys_win_h[u] = nh
    wsys_win_geo_init[u] = 1
    # BUG 1: re-rasterize the cache at the NEW size (no stride shear) and
    # tell the client to re-layout. Must precede the recompose so the blit
    # reads correctly-strided pixels.
    _wsys_geo_post_change(u, ovw, ovh)
    if fb_get_initialized() != 0:
        fl: uint64 = local_irq_save()
        spinlock_lock(&wsys_present_lock)
        _wsys_recompose_rect(ovx, ovy - WSYS_TITLEBAR_H,
                             ovw, ovh + WSYS_TITLEBAR_H)
        _wsys_recompose_rect(nx, ny - WSYS_TITLEBAR_H,
                             nw, nh + WSYS_TITLEBAR_H)
        _wsys_flush_rect(ovx, ovy - WSYS_TITLEBAR_H,
                         ovw, ovh + WSYS_TITLEBAR_H)
        _wsys_flush_rect(nx, ny - WSYS_TITLEBAR_H,
                         nw, nh + WSYS_TITLEBAR_H)
        _wsys_present_cursor_locked()
        spinlock_unlock(&wsys_present_lock)
        local_irq_restore(fl)


def _wsys_maximize(wid: int32):
    # Fill the work area (screen minus top panel). Saves the float rect if
    # transitioning from NORMAL so a restore toggle can undo it. Pinned
    # backgrounds are never managed.
    u: uint64 = cast[uint64](wid)
    if wsys_win_pinned[u] != 0:
        return
    if wsys_win_wm_state[u] == WSYS_WM_NORMAL:
        _wsys_save_float_geo(u)
    ax: int64 = 0
    ay: int64 = 0
    aw: int64 = 0
    ah: int64 = 0
    _wsys_work_area(&ax, &ay, &aw, &ah)
    # The titlebar lives ABOVE the content origin, so push the content down
    # by TITLEBAR_H to keep the chrome inside the work area below the panel.
    cy: int64 = ay
    ch: int64 = ah
    if wsys_win_decorate[u] != 0:
        cy = ay + WSYS_TITLEBAR_H
        ch = ah - WSYS_TITLEBAR_H
    wsys_win_wm_state[u] = WSYS_WM_MAXIMIZED
    _wsys_apply_geo(u, ax, cy, aw, ch)


def _wsys_snap_half(wid: int32, left: int32):
    # Snap to the LEFT or RIGHT half of the work area. Saves the float rect
    # on the NORMAL->snapped transition.
    u: uint64 = cast[uint64](wid)
    if wsys_win_pinned[u] != 0:
        return
    if wsys_win_wm_state[u] == WSYS_WM_NORMAL:
        _wsys_save_float_geo(u)
    ax: int64 = 0
    ay: int64 = 0
    aw: int64 = 0
    ah: int64 = 0
    _wsys_work_area(&ax, &ay, &aw, &ah)
    halfw: int64 = aw / 2
    nx: int64 = ax
    if left == 0:
        nx = ax + halfw
    cy: int64 = ay
    ch: int64 = ah
    if wsys_win_decorate[u] != 0:
        cy = ay + WSYS_TITLEBAR_H
        ch = ah - WSYS_TITLEBAR_H
    if left != 0:
        wsys_win_wm_state[u] = WSYS_WM_SNAP_LEFT
    else:
        wsys_win_wm_state[u] = WSYS_WM_SNAP_RIGHT
    _wsys_apply_geo(u, nx, cy, halfw, ch)


def _wsys_restore_float(wid: int32):
    # Undo a maximize/snap: put the window back to its saved float rect and
    # mark it NORMAL again.
    u: uint64 = cast[uint64](wid)
    if wsys_win_wm_state[u] == WSYS_WM_NORMAL:
        return
    sx: int64 = wsys_win_sav_x[u]
    sy: int64 = wsys_win_sav_y[u]
    sw2: int64 = wsys_win_sav_w[u]
    sh2: int64 = wsys_win_sav_h[u]
    if sw2 < WSYS_WIN_MIN_W:
        sw2 = WSYS_WIN_MIN_W
    if sh2 < WSYS_WIN_MIN_H:
        sh2 = WSYS_WIN_MIN_H
    wsys_win_wm_state[u] = WSYS_WM_NORMAL
    _wsys_apply_geo(u, sx, sy, sw2, sh2)


def _wsys_resize_edge_at(wid: int32, sx: int64, sy: int64) -> int32:
    # Return the resize-edge bitmask for a press near wid's CONTENT border
    # (NOT the titlebar — that is the move/double-click grab). 0 = not on a
    # border. Combines LEFT/RIGHT with TOP/BOTTOM for corners. Pinned
    # backgrounds are never resizable.
    u: uint64 = cast[uint64](wid)
    if wsys_win_pinned[u] != 0:
        return 0
    # Only SSD-decorated top-level windows are user-resizable. Chrome
    # (panels, menus, tooltips, the cursor) is decorate-0 and must NOT grab a
    # border resize from a content press near its edge.
    if wsys_win_decorate[u] == 0:
        return 0
    wx: int64 = wsys_win_x[u]
    wy: int64 = wsys_win_y[u]
    ww: int64 = _wsys_win_def_w(u)
    wh: int64 = _wsys_win_def_h(u)
    b: int64 = WSYS_RESIZE_BORDER_PX
    # Outside the content rect (grown by the grab band)? Not a border grab.
    if sx < wx - b or sx > wx + ww + b or sy < wy - b or sy > wy + wh + b:
        return 0
    # Reject the titlebar band (handled as move/dblclick) — the top edge
    # grab is the content's TOP border, just below the titlebar.
    if wsys_win_decorate[u] != 0 and sy < wy and sy >= wy - WSYS_TITLEBAR_H:
        return 0
    edge: int32 = 0
    if sx <= wx + b:
        edge = edge | WSYS_REZ_LEFT
    if sx >= wx + ww - b:
        edge = edge | WSYS_REZ_RIGHT
    if sy <= wy + b:
        edge = edge | WSYS_REZ_TOP
    if sy >= wy + wh - b:
        edge = edge | WSYS_REZ_BOTTOM
    return edge


def _wsys_evt_emit_dec(wid: int32, v: int64):
    # Push a signed decimal integer onto wid's event ring.
    if v < 0:
        _wsys_evt_push_byte(wid, 45)               # '-'
        _wsys_evt_emit_dec(wid, -v)
        return
    if v == 0:
        _wsys_evt_push_byte(wid, 48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: int64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _wsys_evt_push_byte(wid, digs[n])


def _wsys_evt_emit_pointer(wid: int32, lx: int64, ly: int64,
                           buttons: uint32, dz: int64):
    # Window-local pointer line: "m <x> <y> <buttons> <dz>\n".
    _wsys_evt_push_byte(wid, 109)                  # 'm'
    _wsys_evt_push_byte(wid, 32)
    _wsys_evt_emit_dec(wid, lx)
    _wsys_evt_push_byte(wid, 32)
    _wsys_evt_emit_dec(wid, ly)
    _wsys_evt_push_byte(wid, 32)
    _wsys_evt_emit_dec(wid, cast[int64](buttons))
    _wsys_evt_push_byte(wid, 32)
    _wsys_evt_emit_dec(wid, dz)
    _wsys_evt_push_byte(wid, 10)


def _wsys_evt_emit_focus(wid: int32, gained: int32):
    # "f in\n" or "f out\n".
    _wsys_evt_push_byte(wid, 102)                  # 'f'
    _wsys_evt_push_byte(wid, 32)
    if gained != 0:
        _wsys_evt_push_byte(wid, 105)              # 'i'
        _wsys_evt_push_byte(wid, 110)              # 'n'
    else:
        _wsys_evt_push_byte(wid, 111)              # 'o'
        _wsys_evt_push_byte(wid, 117)              # 'u'
        _wsys_evt_push_byte(wid, 116)              # 't'
    _wsys_evt_push_byte(wid, 10)


def _wsys_evt_emit_resize(wid: int32, w: int64, h: int64):
    # BUG 1b: window CONTENT size changed (maximize / snap / free-resize).
    # Tell the client so it can RE-LAYOUT at the new size and re-commit a
    # scene that fills the window. Line format: "r <w> <h>\n" (distinct from
    # the 'm'/'s' pointer lines and the 'f' focus lines). Scene clients that
    # don't parse 'r' simply ignore the line (forward-compatible).
    _wsys_evt_push_byte(wid, 114)                  # 'r'
    _wsys_evt_push_byte(wid, 32)
    _wsys_evt_emit_dec(wid, w)
    _wsys_evt_push_byte(wid, 32)
    _wsys_evt_emit_dec(wid, h)
    _wsys_evt_push_byte(wid, 10)


def _wsys_geo_post_change(u: uint64, ow: int64, oh: int64):
    # Called AFTER a window's geometry (wsys_win_w/h) has been updated. Two
    # jobs, both required to fix the resize TEAR:
    #   1. Re-rasterize the per-window cache at the NEW w/h. The cache was
    #      rasterized at the OLD width (tightly packed at old stride); the
    #      present path reads it with the NEW width as the source pitch, so a
    #      width change without a re-raster shears the image diagonally.
    #      _wsys_rasterize_window re-reads _wsys_win_def_w/h (now the new
    #      size) and re-packs the cache at the new stride — no shear. The
    #      content is the SAME scene laid out at the old size (so it may be
    #      clipped) until the client re-commits below, but it is never torn.
    #   2. Emit a resize event + wake the client so it re-lays-out and
    #      re-commits a scene that fills the new window.
    # CALLER MUST NOT hold wsys_present_lock (we don't take it; rasterize
    # writes only the window's own cache, and callers recompose afterwards).
    if ow <= 0:
        ow = 0
    if oh <= 0:
        oh = 0
    nw: int64 = _wsys_win_def_w(u)
    nh: int64 = _wsys_win_def_h(u)
    if nw == ow and nh == oh:
        return                                     # no size change, only move
    wid: int32 = cast[int32](u)
    if wsys_scene_len[u] > 0:
        _wsys_rasterize_window(wid)
    _wsys_evt_emit_resize(wid, nw, nh)
    wq_wake_one(&wsys_ptr_wq[u])


def _wsys_win_top_z() -> int64:
    # Highest z among live scene windows (for raise).
    have: int32 = 0
    zmax: int64 = 0
    w: uint64 = 1
    while w < WSYS_SCENE_SLOTS:
        if wsys_slot_in_use[w] != 0 and wsys_scene_len[w] > 0:
            if have == 0 or wsys_win_z[w] > zmax:
                zmax = wsys_win_z[w]
                have = 1
        w = w + 1
    return zmax


def _wsys_hit_test(sx: int64, sy: int64) -> int32:
    # Return the wid of the TOP-MOST window whose content OR titlebar rect
    # contains screen point (sx,sy), or 0 if none. Top-most = highest z;
    # ties broken by higher wid.
    best: int32 = 0
    best_z: int64 = 0
    w: uint64 = 1
    while w < WSYS_SCENE_SLOTS:
        if wsys_slot_in_use[w] != 0 and wsys_scene_len[w] > 0:
            ww: int64 = _wsys_win_def_w(w)
            wh: int64 = _wsys_win_def_h(w)
            wx: int64 = wsys_win_x[w]
            wy: int64 = wsys_win_y[w]
            top: int64 = wy
            if wsys_win_decorate[w] != 0:
                top = wy - WSYS_TITLEBAR_H
            if sx >= wx and sx < wx + ww and sy >= top and sy < wy + wh:
                zz: int64 = wsys_win_z[w]
                if best == 0 or zz > best_z \
                        or (zz == best_z and cast[int32](w) > best):
                    best = cast[int32](w)
                    best_z = zz
        w = w + 1
    return best


def _wsys_in_titlebar(wid: int32, sx: int64, sy: int64) -> int32:
    u: uint64 = cast[uint64](wid)
    if wsys_win_decorate[u] == 0:
        return 0
    wx: int64 = wsys_win_x[u]
    wy: int64 = wsys_win_y[u]
    ww: int64 = _wsys_win_def_w(u)
    if sx >= wx and sx < wx + ww \
            and sy >= wy - WSYS_TITLEBAR_H and sy < wy:
        return 1
    return 0


def _wsys_in_close_box(wid: int32, sx: int64, sy: int64) -> int32:
    # BUG 2 FIX. The SSD close box is the rightmost 16 px of the titlebar
    # (see _wsys_present_titlebar: the last 16 columns are painted red).
    # Return 1 iff (sx,sy) lands in that red square. Hit-tested BEFORE the
    # titlebar-move branch in _wsys_route_common so a click on the red
    # square closes the window instead of starting a move drag.
    u: uint64 = cast[uint64](wid)
    if wsys_win_decorate[u] == 0:
        return 0
    wx: int64 = wsys_win_x[u]
    wy: int64 = wsys_win_y[u]
    ww: int64 = _wsys_win_def_w(u)
    cbx0: int64 = wx + ww - 16
    if sx >= cbx0 and sx < wx + ww \
            and sy >= wy - WSYS_TITLEBAR_H and sy < wy:
        return 1
    return 0


def _wsys_close_window(wid: int32):
    # BUG 2 FIX. Destroy a scene window from the compositor's pointer
    # router: SIGTERM the bound client (so its hamsh / app process winds
    # down and is reaped, not stranded as a zombie) and free the wid slot
    # (wsys_free_wid recomposes the vacated footprint + releases the
    # per-window framebuffer). wsys_free_wid rejects wid<=1, so the
    # foreground/root stays unclosable.
    if wid <= 1:
        return
    if wsys_wid_in_use(wid) == 0:
        return
    pid: uint64 = wsys_pid_for_wid(wid)
    if pid > 0:
        slot: int32 = task_lookup_by_pid(pid)
        if slot >= 0:
            signal_post(cast[uint64](slot), SIGTERM)
    # Drop focus if the closing window held it, so stray keystrokes do not
    # route to a freed slot before the next focus-grant.
    if wsys_focus_wid == wid:
        wsys_focus_wid = 0
    # Cancel any active move/resize drag bound to the closing window so a
    # subsequent motion does not move/resize a freed slot.
    if wsys_drag_wid == wid:
        wsys_drag_wid = 0
        wsys_drag_snap_intent = WSYS_SNAP_NONE
    if wsys_resize_wid == wid:
        wsys_resize_wid = 0
        wsys_resize_edge = 0
    wsys_free_wid(wid)


def _wsys_set_focus(wid: int32):
    if wsys_focus_wid == wid:
        return
    if wsys_focus_wid > 0 and wsys_wid_in_use(wsys_focus_wid) != 0:
        _wsys_evt_emit_focus(wsys_focus_wid, 0)
        # BUG 2a: the event file blocks the client in devwsys_pointer_read
        # until its ptr waitqueue is woken (the event + pointer streams
        # share wsys_ptr_wq). A focus-OUT that doesn't wake it would leave
        # a menu-hosting panel asleep until the next pointer motion — so
        # the dropdown would only collapse on a later mouse move. Wake the
        # losing window now so it reads `f out` and dismisses immediately.
        wq_wake_one(&wsys_ptr_wq[cast[uint64](wsys_focus_wid)])
    wsys_focus_wid = wid
    if wid > 0:
        _wsys_evt_emit_focus(wid, 1)
        wq_wake_one(&wsys_ptr_wq[cast[uint64](wid)])


def _wsys_raise(wid: int32):
    # Put wid on top by giving it the highest APP-band z + 1.
    u: uint64 = cast[uint64](wid)
    # PINNED-BACKGROUND windows (hamdesktop backdrop) are NEVER raised: they
    # stay pinned at WSYS_PINNED_Z, the floor of the z-order. Raising the
    # full-screen backdrop would bury the panel + every app window behind it.
    if wsys_win_pinned[u] != 0:
        return
    # QA-N4 FIX (user-reported "a live window disappears from the panel
    # window-list after a click"): the pointer-router raise (on focus/press,
    # and the first-map raise) must be CHROME-AWARE, exactly like the ctl
    # `raise` verb above. _wsys_win_top_z() returns the highest z among ALL
    # scene windows — which INCLUDES the panel/menu/overlay CHROME at z>=100.
    # Raising a clicked app window to that top+1 pushed its z to >=101, i.e.
    # ABOVE the z<100 floor that /dev/wsys/windows (the taskbar + top window-
    # list) uses to distinguish app windows from chrome. The window stayed
    # live and on-screen but silently VANISHED from both enumerated lists on
    # the very click that focused it. Fix: raise only among APP-band peers
    # (z<100) and clamp below the chrome floor so a raised app window is
    # always still enumerated. A chrome window (z>=100) raises within its own
    # band unchanged.
    if wsys_win_z[u] >= 100:
        # Chrome (menu/overlay): raise above other chrome unchanged.
        topz: int64 = _wsys_win_top_z()
        if wsys_win_z[u] < topz:
            wsys_win_z[u] = topz + 1
        return
    # App band: top of the app peers (z<100) + 1, never crossing into chrome.
    topz: int64 = wsys_win_z[u]
    w2: uint64 = 1
    while w2 < WSYS_SCENE_SLOTS:
        if w2 != u and wsys_slot_in_use[w2] != 0:
            if wsys_win_z[w2] < 100 and wsys_win_z[w2] >= topz:
                topz = wsys_win_z[w2] + 1
        w2 = w2 + 1
    if topz >= 100:
        topz = 99
    if wsys_win_z[u] < topz:
        wsys_win_z[u] = topz


def _wsys_cursor_emit_fill(pos: uint64, x: int64, y: int64,
                           w: int64, h: int64, color: Ptr[uint8]) -> uint64:
    # Append one "fill <x> <y> <w> <h> <#color>\n" line to the cursor scene
    # slot-0 buffer at write-cursor `pos`. Returns the new write cursor.
    p: uint64 = pos
    pre: Ptr[uint8] = "fill "
    k: uint64 = 0
    while pre[k] != 0:
        wsys_scene_buf[p] = pre[k]
        p = p + 1
        k = k + 1
    p = p + _wsys_u64_to_dec(cast[uint64](x), &wsys_scene_buf[p])
    wsys_scene_buf[p] = 32
    p = p + 1
    p = p + _wsys_u64_to_dec(cast[uint64](y), &wsys_scene_buf[p])
    wsys_scene_buf[p] = 32
    p = p + 1
    p = p + _wsys_u64_to_dec(cast[uint64](w), &wsys_scene_buf[p])
    wsys_scene_buf[p] = 32
    p = p + 1
    p = p + _wsys_u64_to_dec(cast[uint64](h), &wsys_scene_buf[p])
    wsys_scene_buf[p] = 32
    p = p + 1
    kc: uint64 = 0
    while color[kc] != 0:
        wsys_scene_buf[p] = color[kc]
        p = p + 1
        kc = kc + 1
    wsys_scene_buf[p] = 10
    p = p + 1
    return p


# Cursor sprite geometry — a classic X11 left_ptr (NW-pointing arrow).
#
# BUG 1 (cursor hotspot, round 2). The previous shape was a FILLED right
# triangle (vertical left edge, run growing 1..11 every row, then a fat
# 4px tail). Its single-pixel sharp tip WAS at row 0 col 0 (== the hotspot,
# math-correct), but the eye reads the visual "point" of a fat triangle at
# its BULK, not its 1px corner — so the user perceived the click point near
# the bottom of the blob. The fix is a SHAPE fix: a slim recognizable arrow
# whose only sharp point is unmistakably at the top-left (the hotspot), with
# the head narrowing back to the tip and a thin slanted tail trailing
# down-right. Now the visually-obvious point coincides with the hit-test
# point (sx,sy) == wsys_cursor_x/y == the blit origin.
#
# Per-row (x-offset, run) from the tip. The head is a triangle for rows
# 0..8 anchored at col 0 (left edge vertical, hypotenuse on the right);
# row 9 is the notch under the head; rows 10..15 are a 4px tail slanting
# right by one column per row so it reads as a trailing stem. Tip at row 0
# col 0 (== the hotspot == the routed hit-test point).
WSYS_CURSOR_ROWS: int64 = 16


def _wsys_cursor_row_run(row: int64) -> int64:
    # White-body run length on `row` of the left_ptr arrow. Rows 0..10 are
    # the arrowHEAD triangle (run = row+1, anchored at the left edge, sharp
    # 1px tip at row 0); rows 11..15 are a 5px tail shaft slanting right.
    if row < 0 or row >= WSYS_CURSOR_ROWS:
        return 0
    if row <= 10:
        return row + 1                              # head triangle 1..11
    return 5                                        # tail shaft (5px)


def _wsys_cursor_row_off(row: int64) -> int64:
    # X-offset (from the tip column) of the run's LEFT edge on `row`.
    # The head (rows 0..10) hugs the left edge; the tail (rows 11..15)
    # slants right by 1 col per row so it reads as a trailing stem.
    if row < 11 or row >= WSYS_CURSOR_ROWS:
        return 0
    return row - 10                                 # tail drifts right


def _wsys_cursor_set_scene(sx: int64, sy: int64):
    # BUG 1 FIX (cursor hotspot). Write the cursor sprite as an ARROW whose
    # TIP pixel is EXACTLY at (sx,sy) — the same point the router hit-tests
    # (wsys_cursor_x/y) and the blit origin (wsys_cursor_blit_x/y, parsed
    # from the FIRST fill line below). Previously the sprite was a solid
    # 10x14 box; its hotspot was its top-left, but with no visible tip the
    # user read the click point as the BOTTOM of the box and clicks clipped
    # the wrong file-manager row. An arrow with the tip at the top-left
    # makes the visible hit point and the routed coordinate coincide.
    #
    # CRITICAL: the FIRST emitted fill MUST be at (sx,sy) so
    # _wsys_rasterize_cursor parses (sx,sy) as the blit origin (== the tip
    # == the hit-test point). Every other span is at x>=sx, y>=sy so it
    # renders at a non-negative offset inside the 32x32 cursor cache.
    wsys_scene_wpos[0] = 0
    wsys_scene_len[0] = 0
    pos: uint64 = 0
    white: Ptr[uint8] = "#f0f0f0"
    dark:  Ptr[uint8] = "#202020"
    # DARK SILHOUETTE FIRST (classic black-outlined white arrow). Its row-0
    # span starts at exactly (sx,sy), so _wsys_rasterize_cursor parses
    # (sx,sy) as the blit origin (== the tip == the routed hit-test point).
    # The silhouette is one pixel WIDER to the right and one row TALLER than
    # the white body, so the white body painted on top leaves a 1px dark
    # border on the hypotenuse / tail edge / bottom. The outline gives the
    # cursor hard contrast on ANY backdrop (light desktop, white
    # file-manager rows) — a white-on-light body alone was near-invisible.
    rs: int64 = 0
    while rs < WSYS_CURSOR_ROWS:
        run: int64 = _wsys_cursor_row_run(rs)
        off: int64 = _wsys_cursor_row_off(rs)
        if run > 0:
            # +1 wider on the right for the right/hypotenuse outline.
            pos = _wsys_cursor_emit_fill(pos, sx + off, sy + rs,
                                         run + 1, 1, dark)
        rs = rs + 1
    # One extra dark row UNDER the bottom body row (the arrow's bottom edge).
    last_run: int64 = _wsys_cursor_row_run(WSYS_CURSOR_ROWS - 1)
    last_off: int64 = _wsys_cursor_row_off(WSYS_CURSOR_ROWS - 1)
    pos = _wsys_cursor_emit_fill(pos, sx + last_off, sy + WSYS_CURSOR_ROWS,
                                 last_run + 1, 1, dark)
    # WHITE BODY on top of the silhouette, INSET 1px on the LEFT for rows>=1
    # so the silhouette also shows as a 1px dark border down the left edge —
    # a FULLY outlined white arrow (dark on left, right, and bottom). Row 0's
    # 1px white tip is NOT inset: it lands exactly on the (sx,sy) hotspot, so
    # the sharp visible point coincides with the routed coordinate. The dark
    # outline on every edge gives hard contrast on ANY backdrop.
    r: int64 = 0
    while r < WSYS_CURSOR_ROWS:
        run3: int64 = _wsys_cursor_row_run(r)
        off3: int64 = _wsys_cursor_row_off(r)
        wstart: int64 = sx + off3
        wlen: int64 = run3
        if r >= 1:
            wstart = wstart + 1                     # inset for left outline
            wlen = wlen - 1
        if wlen > 0:
            pos = _wsys_cursor_emit_fill(pos, wstart, sy + r, wlen, 1, white)
        r = r + 1
    wsys_scene_wpos[0] = pos
    wsys_scene_len[0] = pos


def wsys_route_mouse_abs(ax: int32, ay: int32, buttons: uint32, dz: int32):
    # Entry point called by devmouse_write for an ABSOLUTE pointer event
    # (ax,ay in 0..32767 tablet space). Routes to the scene compositor.
    if fb_get_initialized() == 0:
        return
    _wsys_scene_init_if_needed()
    sw: int64 = cast[int64](fb_get_width())
    sh: int64 = cast[int64](fb_get_height())
    if sw <= 0 or sh <= 0:
        return
    sx: int64 = (cast[int64](ax) * sw) / 32768
    sy: int64 = (cast[int64](ay) * sh) / 32768
    if sx < 0:
        sx = 0
    if sx >= sw:
        sx = sw - 1
    if sy < 0:
        sy = 0
    if sy >= sh:
        sy = sh - 1
    wsys_cursor_x = sx
    wsys_cursor_y = sy
    wsys_cursor_inited = 1
    # Mouse capplet: primary-button swap + Natural-scroll invert. Position
    # is absolute (tablet) so pointer-speed scaling does NOT apply here.
    _wsys_route_common(sx, sy, mouse_cfg_map_buttons(buttons),
                       cast[int64](mouse_cfg_map_dz(dz)))


def wsys_route_mouse_rel(dx: int32, dy: int32, buttons: uint32, dz: int32):
    # Relative-motion sibling: accumulate onto the tracked cursor pos.
    if fb_get_initialized() == 0:
        return
    _wsys_scene_init_if_needed()
    sw: int64 = cast[int64](fb_get_width())
    sh: int64 = cast[int64](fb_get_height())
    if sw <= 0 or sh <= 0:
        return
    if wsys_cursor_inited == 0:
        wsys_cursor_x = sw / 2
        wsys_cursor_y = sh / 2
        wsys_cursor_inited = 1
    # Mouse capplet: pointer-speed scales the motion delta (default 5 =
    # identity, so an unconfigured system is byte-for-byte as before).
    dx = mouse_cfg_scale_delta(dx)
    dy = mouse_cfg_scale_delta(dy)
    sx: int64 = wsys_cursor_x + cast[int64](dx)
    sy: int64 = wsys_cursor_y + cast[int64](dy)
    if sx < 0:
        sx = 0
    if sx >= sw:
        sx = sw - 1
    if sy < 0:
        sy = 0
    if sy >= sh:
        sy = sh - 1
    wsys_cursor_x = sx
    wsys_cursor_y = sy
    # Mouse capplet: primary-button swap + Natural-scroll invert (applied
    # once, here at the sole relative-event entry point).
    _wsys_route_common(sx, sy, mouse_cfg_map_buttons(buttons),
                       cast[int64](mouse_cfg_map_dz(dz)))


def wsys_cursor_get_x() -> int64:
    # Test accessor: current tracked cursor X (screen px).
    return wsys_cursor_x


def wsys_cursor_get_y() -> int64:
    # Test accessor: current tracked cursor Y (screen px).
    return wsys_cursor_y


def wsys_test_force_live(on: int32):
    # Test-only: force the DE-live latch so a boot self-test can exercise
    # the timer-tick mouse pump WITHOUT a real fb / rl5 flip. Sets/clears
    # wsys_root_active; the pump still no-ops if there is no framebuffer,
    # but the routing math (clamp + accumulate) runs and the cursor state
    # advances, which is what the relative-pump self-test asserts.
    wsys_root_active = on


def wsys_test_reset_cursor_uninit():
    # Test-only: undo the cursor-state pollution a force-live mouse self-test
    # leaves behind. Routing synthetic events (mouse_pump_selftest /
    # mouse_flip_flush_selftest) MOVES wsys_cursor_x/y and latches
    # wsys_cursor_inited = 1. If that latch survives into the real rl5
    # `desktop` flip, the flip's center-seed (`if wsys_cursor_inited == 0`)
    # is skipped and the cursor STARTS at the self-test's leftover position
    # instead of screen-centre — a deterministic off-centre startup cursor.
    # Clearing the latch here lets the genuine flip re-centre it.
    wsys_cursor_inited = 0


def wsys_de_is_live() -> int32:
    # 1 iff the scene compositor owns the screen (the `desktop` rl5 flip
    # has happened) AND there is a framebuffer. The timer-tick mouse pump
    # uses this to decide whether to drain the HW mouse ring and route the
    # events to the compositor: before the flip, /dev/mouse readers (or the
    # boot console) own the ring; after it, the in-kernel compositor does.
    if wsys_root_active == 0:
        return 0
    if fb_get_initialized() == 0:
        return 0
    return 1


def _wsys_route_common(sx: int64, sy: int64, buttons: uint32, dz: int64):
    # Shared hit-test + focus + drag + event-forward logic.
    pressed: int32 = 0
    if (buttons & 1) != 0 and (wsys_prev_buttons & 1) == 0:
        pressed = 1
    released: int32 = 0
    if (buttons & 1) == 0 and (wsys_prev_buttons & 1) != 0:
        released = 1

    # Update the cursor sprite scene + blit it (decoupled from windows).
    _wsys_cursor_set_scene(sx, sy)

    # >0 = a press raised this window; recompose only its footprint (no full
    # present). 0 = nothing to recompose beyond the cursor.
    scoped_target: int32 = 0

    # Active FREE-RESIZE drag: move the grabbed edge/corner with the cursor.
    # Damage-scoped exactly like the move drag (old rect + new rect), but the
    # window's CONTENT is re-rasterized at the new w/h by _wsys_recompose_rect
    # (it reads _wsys_win_def_w/h, which now return the updated size).
    if wsys_resize_wid > 0:
        if (buttons & 1) == 0:
            wsys_resize_wid = 0                     # resize ended
            wsys_resize_edge = 0
            if fb_get_initialized() != 0:
                _wsys_present_cursor()
        else:
            ru: uint64 = cast[uint64](wsys_resize_wid)
            dxr: int64 = sx - wsys_resize_px
            dyr: int64 = sy - wsys_resize_py
            nrx: int64 = wsys_resize_ox
            nry: int64 = wsys_resize_oy
            nrw: int64 = wsys_resize_ow
            nrh: int64 = wsys_resize_oh
            if (wsys_resize_edge & WSYS_REZ_LEFT) != 0:
                nrx = wsys_resize_ox + dxr
                nrw = wsys_resize_ow - dxr
            if (wsys_resize_edge & WSYS_REZ_RIGHT) != 0:
                nrw = wsys_resize_ow + dxr
            if (wsys_resize_edge & WSYS_REZ_TOP) != 0:
                nry = wsys_resize_oy + dyr
                nrh = wsys_resize_oh - dyr
            if (wsys_resize_edge & WSYS_REZ_BOTTOM) != 0:
                nrh = wsys_resize_oh + dyr
            # Enforce a minimum size. When shrinking from the LEFT/TOP we must
            # also clamp the moving origin so the opposite (fixed) edge stays
            # put instead of the window walking across the screen.
            if nrw < WSYS_WIN_MIN_W:
                if (wsys_resize_edge & WSYS_REZ_LEFT) != 0:
                    nrx = wsys_resize_ox + wsys_resize_ow - WSYS_WIN_MIN_W
                nrw = WSYS_WIN_MIN_W
            if nrh < WSYS_WIN_MIN_H:
                if (wsys_resize_edge & WSYS_REZ_TOP) != 0:
                    nry = wsys_resize_oy + wsys_resize_oh - WSYS_WIN_MIN_H
                nrh = WSYS_WIN_MIN_H
            if nrx < 0:
                nrx = 0
            if nry < WSYS_TITLEBAR_H:
                nry = WSYS_TITLEBAR_H
            # A free resize is an explicit user size choice: drop any managed
            # (maximized/snapped) state so the size sticks.
            wsys_win_wm_state[ru] = WSYS_WM_NORMAL
            orx: int64 = wsys_win_x[ru]
            ory: int64 = wsys_win_y[ru]
            orw: int64 = _wsys_win_def_w(ru)
            orh: int64 = _wsys_win_def_h(ru)
            wsys_win_x[ru] = nrx
            wsys_win_y[ru] = nry
            wsys_win_w[ru] = nrw
            wsys_win_h[ru] = nrh
            wsys_win_geo_init[ru] = 1
            # BUG 1: re-rasterize cache at the new size (no shear) + tell the
            # client to re-layout. Same as _wsys_apply_geo; here it runs per
            # drag-motion, which is fine — the rasterize touches only this
            # window's cache and the client's re-layout is idempotent.
            _wsys_geo_post_change(ru, orw, orh)
            if fb_get_initialized() != 0:
                fl_rz: uint64 = local_irq_save()
                spinlock_lock(&wsys_present_lock)
                _wsys_recompose_rect(orx, ory - WSYS_TITLEBAR_H,
                                     orw, orh + WSYS_TITLEBAR_H)
                _wsys_recompose_rect(nrx, nry - WSYS_TITLEBAR_H,
                                     nrw, nrh + WSYS_TITLEBAR_H)
                # DOUBLE-BUFFER: flush both composited footprints (old+new)
                # to scanout in one pass each (tear-free resize).
                _wsys_flush_rect(orx, ory - WSYS_TITLEBAR_H,
                                 orw, orh + WSYS_TITLEBAR_H)
                _wsys_flush_rect(nrx, nry - WSYS_TITLEBAR_H,
                                 nrw, nrh + WSYS_TITLEBAR_H)
                _wsys_present_cursor_locked()
                spinlock_unlock(&wsys_present_lock)
                local_irq_restore(fl_rz)
        wsys_prev_buttons = buttons
        return

    # Active titlebar drag: move the window with the cursor.
    if wsys_drag_wid > 0:
        if (buttons & 1) == 0:
            # Drag END: apply any latched edge-snap intent (MATE-style: snap
            # commits on release, not live). TOP edge -> maximize; LEFT/RIGHT
            # edge -> half-screen snap; otherwise the window keeps wherever the
            # move drag left it. Maximize/snap each save the pre-gesture float
            # rect (only on the NORMAL->managed transition) so a later
            # double-click restore puts it back.
            dragged: int32 = wsys_drag_wid
            intent: int32 = wsys_drag_snap_intent
            wsys_drag_wid = 0                       # drag ended
            wsys_drag_snap_intent = WSYS_SNAP_NONE
            if intent == WSYS_SNAP_TOP:
                _wsys_maximize(dragged)
            elif intent == WSYS_SNAP_LEFT:
                _wsys_snap_half(dragged, 1)
            elif intent == WSYS_SNAP_RIGHT:
                _wsys_snap_half(dragged, 0)
            else:
                # Drag end: nothing moved this event; just refresh the cursor.
                if fb_get_initialized() != 0:
                    _wsys_present_cursor()
        else:
            du: uint64 = cast[uint64](wsys_drag_wid)
            nx: int64 = sx - wsys_drag_dx
            ny: int64 = sy - wsys_drag_dy
            if ny < WSYS_TITLEBAR_H:
                ny = WSYS_TITLEBAR_H
            if nx < 0:
                nx = 0
            # DAMAGE-SCOPED DRAG (no full present): the dragged window's
            # cache CONTENT is unchanged (only its position moved), and a
            # full re-rasterize-all + sequential re-blit-all per motion event
            # was the drag flicker + lag the user reported (intermediate
            # all-window states visible between frames). Instead recompose
            # ONLY two damage rects from the durable scene caches:
            #   1) the VACATED (old) rect — restores backdrop + lower windows
            #      where the window used to be (so it leaves no trail);
            #   2) the NEW rect — re-blits backdrop + ALL caches (incl. this
            #      window's, now at its new x/y) clipped to that rect, so the
            #      moved window lands on top with lower windows correct under
            #      its transparent areas.
            # Neither path re-rasterizes any window or touches windows outside
            # the two rects → smooth, flicker-free drag. Cursor composited last.
            # EDGE-SNAP INTENT (committed on release): latch which screen
            # edge the CURSOR is touching. TOP -> maximize, LEFT/RIGHT ->
            # half-snap. Checked against the live cursor (sx,sy) so a fast
            # drag into a corner still registers. Recomputed every motion so
            # pulling back off the edge clears the intent.
            dsw: int64 = cast[int64](fb_get_width())
            if sy <= WSYS_SNAP_EDGE_PX:
                wsys_drag_snap_intent = WSYS_SNAP_TOP
            elif sx <= WSYS_SNAP_EDGE_PX:
                wsys_drag_snap_intent = WSYS_SNAP_LEFT
            elif sx >= dsw - WSYS_SNAP_EDGE_PX:
                wsys_drag_snap_intent = WSYS_SNAP_RIGHT
            else:
                wsys_drag_snap_intent = WSYS_SNAP_NONE
            ovx: int64 = wsys_win_x[du]
            ovy: int64 = wsys_win_y[du]
            ovw: int64 = _wsys_win_def_w(du)
            ovh: int64 = _wsys_win_def_h(du)
            wsys_win_x[du] = nx
            wsys_win_y[du] = ny
            if fb_get_initialized() != 0:
                fl_drag: uint64 = local_irq_save()
                spinlock_lock(&wsys_present_lock)
                # BIG-WINDOW DRAG COST: the vacated (old) and new footprints
                # must both be recomposited from the scene caches. Done as two
                # separate rects, their OVERLAP is composited TWICE — for a
                # maximized window dragged by the small per-motion delta the
                # two rects are each ~full-screen and overlap almost entirely,
                # so ~2x a full-screen composite EVERY motion event (the lag).
                # When the union bounding box is no larger than the two rects
                # combined (the common small-delta case), recompose+flush the
                # UNION ONCE instead — the overlap is touched a single time,
                # halving the per-frame composite work. A large jump (old/new
                # barely overlap, so the union would also span the gap between
                # them) falls back to the two-rect path so we're never worse.
                oy0: int64 = ovy - WSYS_TITLEBAR_H
                ny0: int64 = ny - WSYS_TITLEBAR_H
                rh_ext: int64 = ovh + WSYS_TITLEBAR_H
                ux0: int64 = ovx
                if nx < ux0:
                    ux0 = nx
                uy0: int64 = oy0
                if ny0 < uy0:
                    uy0 = ny0
                ux1: int64 = ovx + ovw
                if nx + ovw > ux1:
                    ux1 = nx + ovw
                uy1: int64 = oy0 + rh_ext
                if ny0 + rh_ext > uy1:
                    uy1 = ny0 + rh_ext
                uw: int64 = ux1 - ux0
                uh: int64 = uy1 - uy0
                two_area: int64 = 2 * ovw * rh_ext
                if uw * uh <= two_area:
                    # UNION path: one recompose + one flush (overlap once).
                    _wsys_recompose_rect(ux0, uy0, uw, uh)
                    _wsys_flush_rect(ux0, uy0, uw, uh)
                else:
                    # DOUBLE-BUFFER two-rect path (large jump): composite both
                    # rects into cached RAM, then flush each in one linear pass.
                    _wsys_recompose_rect(ovx, oy0, ovw, rh_ext)
                    _wsys_recompose_rect(nx, ny0, ovw, rh_ext)
                    _wsys_flush_rect(ovx, oy0, ovw, rh_ext)
                    _wsys_flush_rect(nx, ny0, ovw, rh_ext)
                _wsys_present_cursor_locked()
                spinlock_unlock(&wsys_present_lock)
                local_irq_restore(fl_drag)
        wsys_prev_buttons = buttons
        return

    target: int32 = _wsys_hit_test(sx, sy)

    if pressed == 1 and target > 0:
        if _wsys_in_close_box(target, sx, sy) == 1:
            # BUG 2 FIX: press on the red close box destroys the window
            # (terminate the client + free the slot). Checked BEFORE the
            # titlebar-move branch so the close box is not swallowed as a
            # move. No drag is armed; the slot is gone after this.
            _wsys_close_window(target)
            if fb_get_initialized() != 0:
                _wsys_present_cursor()
            wsys_prev_buttons = buttons
            return
        if _wsys_in_titlebar(target, sx, sy) == 1:
            # Raise + focus first.
            _wsys_raise(target)
            _wsys_set_focus(target)
            du2: uint64 = cast[uint64](target)
            # DOUBLE-CLICK -> maximize/restore toggle. Two titlebar presses
            # on the SAME window within WSYS_DBLCLICK_JIFFIES. The first press
            # of the pair already armed a (now-abandoned) move drag below; on
            # the second we cancel that and toggle instead.
            nowj: uint64 = get_jiffies()
            is_dbl: int32 = 0
            if wsys_last_tbar_wid == target \
                    and (nowj - wsys_last_tbar_jiffy) <= WSYS_DBLCLICK_JIFFIES:
                is_dbl = 1
            wsys_last_tbar_wid = target
            wsys_last_tbar_jiffy = nowj
            if is_dbl == 1:
                # Consume the pair so a third quick click starts fresh.
                wsys_last_tbar_wid = 0
                wsys_drag_wid = 0
                wsys_drag_snap_intent = WSYS_SNAP_NONE
                if wsys_win_wm_state[du2] == WSYS_WM_NORMAL:
                    _wsys_maximize(target)
                else:
                    _wsys_restore_float(target)
                wsys_prev_buttons = buttons
                return
            # Single press: begin a compositor-side move drag.
            wsys_drag_wid = target
            wsys_drag_dx = sx - wsys_win_x[du2]
            wsys_drag_dy = sy - wsys_win_y[du2]
            wsys_drag_snap_intent = WSYS_SNAP_NONE
            # DAMAGE-SCOPED raise: re-blit only the raised window's footprint
            # (recompose re-blits all caches there in the new z-order, so it
            # comes to the front over its peers) — no full present.
            scoped_target = target
        elif _wsys_resize_edge_at(target, sx, sy) != 0:
            # EDGE/CORNER press (not the titlebar) -> begin a FREE-RESIZE drag.
            # Checked AFTER the titlebar (so a titlebar grab always moves) and
            # BEFORE the content forward (so a border grab resizes instead of
            # leaking a content pointer event). Raise + focus, capture the
            # window rect + cursor anchor; motion updates the grabbed edge(s).
            _wsys_raise(target)
            _wsys_set_focus(target)
            ru2: uint64 = cast[uint64](target)
            wsys_resize_wid = target
            wsys_resize_edge = _wsys_resize_edge_at(target, sx, sy)
            wsys_resize_ox = wsys_win_x[ru2]
            wsys_resize_oy = wsys_win_y[ru2]
            wsys_resize_ow = _wsys_win_def_w(ru2)
            wsys_resize_oh = _wsys_win_def_h(ru2)
            wsys_resize_px = sx
            wsys_resize_py = sy
            scoped_target = target
        else:
            # Content press: raise + focus + forward a window-local event.
            # PINNED-BACKGROUND target (hamdesktop backdrop): forward the
            # window-local pointer event (so desktop ICONS still select/launch)
            # and set focus, but do NOT raise it — raising the full-screen
            # backdrop above the panel + apps was the "all windows vanish on
            # desktop click" bug. Focus alone changes no z, so nothing hides.
            u3: uint64 = cast[uint64](target)
            if wsys_win_pinned[u3] == 0:
                _wsys_raise(target)
            _wsys_set_focus(target)
            lx: int64 = sx - wsys_win_x[u3]
            ly: int64 = sy - wsys_win_y[u3]
            _wsys_evt_emit_pointer(target, lx, ly, buttons, dz)
            wq_wake_one(&wsys_ptr_wq[u3])
            # DAMAGE-SCOPED raise (see above): only the raised window's rect.
            # A pinned-background press changes no z (it isn't raised), so skip
            # the recompose entirely — the cursor-only blit at the end suffices.
            if wsys_win_pinned[u3] == 0:
                scoped_target = target
    else:
        # BUG 2a FIX: a PRESS on the bare backdrop (no window under the
        # cursor) drops keyboard focus to "none". This makes the focused
        # window LOSE focus — so an in-panel dropdown menu (the panel grows
        # its own window to host the menu) receives an `f out` event on its
        # event file and self-dismisses. Without this a click-away on empty
        # desktop left the panel still focused and the menu stuck open.
        # A focus-only change paints no compositor pixels itself (the panel
        # reacts via its own — now damage-scoped — commit), so no present.
        if pressed == 1 and target == 0:
            _wsys_set_focus(0)
        # Motion / release over a window: forward window-local pointer.
        if target > 0:
            u4: uint64 = cast[uint64](target)
            lx2: int64 = sx - wsys_win_x[u4]
            ly2: int64 = sy - wsys_win_y[u4]
            _wsys_evt_emit_pointer(target, lx2, ly2, buttons, dz)
            wq_wake_one(&wsys_ptr_wq[u4])

    # Present. A press that raised a window does a DAMAGE-SCOPED recompose of
    # just that window's footprint (it lands on top of its peers there) — NOT
    # a full re-rasterize-all + re-blit-all (that whole-screen storm was the
    # flicker the user reported). Plain motion / focus-only does the lighter
    # cursor-only blit, decoupled from window recomposition (the §9 FPS
    # invariant).
    if scoped_target > 0:
        if fb_get_initialized() != 0:
            stu: uint64 = cast[uint64](scoped_target)
            fl_sp: uint64 = local_irq_save()
            spinlock_lock(&wsys_present_lock)
            srx: int64 = 0
            sry: int64 = 0
            srw: int64 = 0
            srh: int64 = 0
            _wsys_win_screen_extent(stu, &srx, &sry, &srw, &srh)
            _wsys_recompose_rect(srx, sry, srw, srh)
            _wsys_flush_rect(srx, sry, srw, srh)
            _wsys_present_cursor_locked()
            spinlock_unlock(&wsys_present_lock)
            local_irq_restore(fl_sp)
    else:
        if fb_get_initialized() != 0:
            _wsys_present_cursor()
    wsys_prev_buttons = buttons


def wsys_route_key(down: int32, keysym: int32, mods: int32):
    # Keyboard -> focused window. Line: "k <down|up> <keysym> <mods>\n".
    if wsys_focus_wid <= 0:
        return
    if wsys_wid_in_use(wsys_focus_wid) == 0:
        return
    fw: int32 = wsys_focus_wid
    _wsys_evt_push_byte(fw, 107)                    # 'k'
    _wsys_evt_push_byte(fw, 32)
    if down != 0:
        _wsys_evt_push_byte(fw, 100)               # 'd'
        _wsys_evt_push_byte(fw, 111)               # 'o'
        _wsys_evt_push_byte(fw, 119)               # 'w'
        _wsys_evt_push_byte(fw, 110)               # 'n'
    else:
        _wsys_evt_push_byte(fw, 117)               # 'u'
        _wsys_evt_push_byte(fw, 112)               # 'p'
    _wsys_evt_push_byte(fw, 32)
    _wsys_evt_emit_dec(fw, cast[int64](keysym))
    _wsys_evt_push_byte(fw, 32)
    _wsys_evt_emit_dec(fw, cast[int64](mods))
    _wsys_evt_push_byte(fw, 10)
    wq_wake_one(&wsys_ptr_wq[cast[uint64](fw)])


def _wsys_keys_emit_dec(wid: int32, v: int64):
    # Push a non-negative decimal integer onto wid's /keys ring.
    if v <= 0:
        _wsys_keys_push_byte(wid, 48)                  # '0'
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: int64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _wsys_keys_push_byte(wid, digs[n])


def wsys_route_key_byte(code: int32):
    # BUG 1 FIX (keyboard exclusivity). Route ONE physical keystroke byte
    # (a raw ASCII code from the PS/2 keyboard FIFO or the UART RX ring) to
    # the FOCUSED scene window's /keys stream as a press line "d <code>\n"
    # — the exact format the scene clients (hamtermscene) parse in
    # _drain_keys_chunk (<type> <code>, type 'd'=press). The legacy hamUId
    # compositor used to read /dev/cons and call devwsys_keys_write; the
    # scene rewrite dropped that, so physical keystrokes reached NO window
    # and leaked to the boot/serial hamsh that was still draining /dev/cons.
    # This is the keyboard twin of wsys_route_mouse_abs: kbd_pump_to_compositor
    # (timer tick) drains the rings and calls this, and devcons_read yields
    # the kbd/UART rings while the DE is live so there is no double-drain.
    if wsys_focus_wid <= 0:
        return
    if wsys_wid_in_use(wsys_focus_wid) == 0:
        return
    fw: int32 = wsys_focus_wid
    _wsys_keys_push_byte(fw, 100)                      # 'd' (press)
    _wsys_keys_push_byte(fw, 32)                       # ' '
    _wsys_keys_emit_dec(fw, cast[int64](code))
    _wsys_keys_push_byte(fw, 10)                       # '\n'
    wq_wake_one(&wsys_keys_wq[cast[uint64](fw)])
    waitfds_notify()


def wsys_focused_wid() -> int32:
    # Test/diagnostic accessor: the wid currently receiving keyboard input
    # (0 = none). Lets a self-test assert the focus router latched a window
    # before keystrokes are pumped.
    return wsys_focus_wid


def wsys_kbd_route_selftest() -> int32:
    # BUG 1 FIX self-test. Allocate a scene window, focus it, route a
    # synthetic keystroke through wsys_route_key_byte (the exact call the
    # timer-tick keyboard pump makes), and assert the byte landed on THAT
    # window's /keys ring as a "d <code>" press line. Proves keystrokes now
    # reach the focused graphical window instead of the boot/serial shell.
    # Prints a [KBD_ROUTE] marker. Returns 1 on PASS, 0 on FAIL.
    _wsys_init_if_needed()
    wid: int32 = wsys_alloc_wid(999999)               # synthetic owner pid
    if wid <= 1:
        printk0("[KBD_ROUTE] FAIL could not allocate a scene wid\n")
        return 0
    # Make it a committed, decorated, focused window.
    u: uint64 = cast[uint64](wid)
    wsys_scene_len[u] = 1                              # non-empty: hit-testable
    wsys_win_decorate[u] = 1
    saved_focus: int32 = wsys_focus_wid
    wsys_focus_wid = wid
    # Drain any stale bytes so the routed byte is the only thing present.
    drain: Array[64, uint8]
    while devwsys_keys_read_nb(wid, &drain[0], 64) > 0:
        pass
    # Route 'A' (0x41) the way the pump does.
    wsys_route_key_byte(0x41)
    if wsys_keys_pending(wid) == 0:
        printk0("[KBD_ROUTE] FAIL routed byte did NOT reach the focused window keys ring\n")
        wsys_focus_wid = saved_focus
        wsys_scene_len[u] = 0
        wsys_free_wid(wid)
        return 0
    rb: Array[16, uint8]
    rn: int64 = devwsys_keys_read_nb(wid, &rb[0], 16)
    ok: int32 = 0
    # Expect "d 65\n".
    if rn >= 5 and rb[0] == 100 and rb[1] == 32 \
            and rb[2] == 54 and rb[3] == 53 and rb[4] == 10:
        ok = 1
    wsys_focus_wid = saved_focus
    wsys_scene_len[u] = 0
    wsys_free_wid(wid)
    if ok == 0:
        printk0("[KBD_ROUTE] FAIL keys ring line was not the expected 'd 65' press\n")
        return 0
    printk0("[KBD_ROUTE] PASS keystroke routed to focused window /keys (no serial leak)\n")
    return 1


def wsys_close_box_selftest() -> int32:
    # BUG 2 FIX self-test. Allocate + focus a decorated scene window, then
    # synthesize a press at the centre of its red close box via the SAME
    # router the live /dev/mouse path uses (_wsys_route_common). Assert the
    # window slot is freed (the close box destroys the window). Prints a
    # [CLOSE_BOX] marker. Returns 1 on PASS, 0 on FAIL.
    _wsys_init_if_needed()
    wid: int32 = wsys_alloc_wid(999998)
    if wid <= 1:
        printk0("[CLOSE_BOX] FAIL could not allocate a scene wid\n")
        return 0
    u: uint64 = cast[uint64](wid)
    wsys_scene_len[u] = 1
    wsys_win_decorate[u] = 1
    # Park it well below the titlebar band so the close box is on-screen.
    wsys_win_x[u] = 100
    wsys_win_y[u] = 100
    wsys_win_z[u] = 50
    ww: int64 = _wsys_win_def_w(u)
    # Close-box centre: rightmost 16 px of the titlebar, vertical mid-strip.
    cbx: int64 = 100 + ww - 8
    cby: int64 = 100 - (WSYS_TITLEBAR_H / 2)
    if _wsys_in_close_box(wid, cbx, cby) == 0:
        printk0("[CLOSE_BOX] FAIL close-box hit-test geometry is wrong\n")
        wsys_scene_len[u] = 0
        wsys_free_wid(wid)
        return 0
    # Press then release at the close box, like a real click.
    wsys_prev_buttons = 0
    wsys_drag_wid = 0
    _wsys_route_common(cbx, cby, 1, 0)                 # button-1 down
    if wsys_wid_in_use(wid) != 0:
        printk0("[CLOSE_BOX] FAIL close-box press did NOT destroy the window\n")
        wsys_prev_buttons = 0
        wsys_scene_len[u] = 0
        wsys_free_wid(wid)
        return 0
    wsys_prev_buttons = 0
    printk0("[CLOSE_BOX] PASS close-box click destroyed the window slot\n")
    # Chain the focus-out self-test here (invoked at boot via this already-
    # wired selftest, so no init/main.ad edit is needed).
    wsys_focusout_selftest()
    wsys_cursor_hotspot_selftest()
    wsys_keys_lossless_selftest()
    wsys_multiwindow_selftest()
    wsys_mate_wm_selftest()
    wsys_taskbar_churn_selftest()
    wsys_multitask_taskbar_selftest()
    wsys_raise_enum_selftest()
    return 1


def _wsys_windows_list_has(wid: int32) -> int32:
    # 1 iff `wid` appears as a leading "<wid> " line in the live
    # /dev/wsys/windows snapshot (the exact bytes the taskbar parses).
    # Reads the whole snapshot via devwsys_windows_read and scans for the
    # decimal wid at the start of a line. NOTE: devwsys_windows_read(0,..)
    # reaps dead-owner slots as a side effect, matching the live read path.
    rbuf: Array[2048, uint8]
    rn: int64 = devwsys_windows_read(0, &rbuf[0], 2048)
    if rn <= 0:
        return 0
    total: uint64 = cast[uint64](rn)
    i: uint64 = 0
    at_line_start: int32 = 1
    while i < total:
        if at_line_start != 0:
            v: int32 = 0
            got: int32 = 0
            while i < total and rbuf[i] >= 48 and rbuf[i] <= 57:
                v = v * 10 + cast[int32](rbuf[i]) - 48
                got = 1
                i = i + 1
            if got != 0 and v == wid:
                return 1
            at_line_start = 0
        if i < total and rbuf[i] == 10:
            at_line_start = 1
        i = i + 1
    return 0


def wsys_taskbar_churn_selftest() -> int32:
    # TASKBAR-STALE FIX self-test (user-reported "open new apps, taskbar
    # shows nothing"). Drives the REAL enumeration + alloc paths:
    #
    #   1) LEAK RECLAIM: mark EVERY app slot (2..MAX_WINDOWS-1) in_use bound
    #      to a DEAD owner pid (the leak a client leaves when it exits without
    #      closing its window). With the table apparently full, wsys_alloc_wid
    #      must still succeed by reaping the dead-owner slots and retrying —
    #      proving open/exit churn never permanently starves the allocator.
    #
    #   2) STALE DROP + LIVE KEEP: stand up a DEAD-owner decorated window and
    #      a LIVE-owner decorated window, then read /dev/wsys/windows (the
    #      taskbar's snapshot). The dead one must be reaped/absent; the live
    #      one must be listed — so after churn the list reflects exactly the
    #      currently-open windows, never empty/stale.
    #
    # Prints a [TASKBAR_CHURN] marker. Returns 1 on PASS, 0 on FAIL.
    _wsys_init_if_needed()
    dead_pid: uint64 = 888001        # never a live task in the selftest box
    live_pid: uint64 = current_task_pid()

    # --- Part 1: fill every app slot with a leaked (dead-owner) window. ---
    w: uint64 = 2
    while w < MAX_WINDOWS:
        wsys_slot_in_use[w] = 1
        wsys_slot_pid[w] = dead_pid
        wsys_win_decorate[w] = 1
        wsys_win_z[w] = 5
        wsys_scene_len[w] = 0
        w = w + 1
    # Allocator sees a full table; it must reap the dead slots and hand one
    # back. The pre-fix behaviour returned -1 here (fresh app gets no window).
    nw: int32 = wsys_alloc_wid(live_pid)
    if nw <= 1:
        printk0("[TASKBAR_CHURN] FAIL allocator starved after open/exit churn (leaked slots not reclaimed)\n")
        # Best-effort cleanup of the synthetic fill.
        w = 2
        while w < MAX_WINDOWS:
            wsys_slot_in_use[w] = 0
            wsys_slot_pid[w] = 0
            w = w + 1
        return 0
    # The reclaimed wid is bound to the LIVE pid now.
    if wsys_slot_pid[cast[uint64](nw)] != live_pid:
        printk0("[TASKBAR_CHURN] FAIL reclaimed slot not rebound to the new owner\n")
        wsys_free_wid(nw)
        return 0
    wsys_free_wid(nw)

    # --- Part 2: dead-owner window is dropped; live-owner window is kept. ---
    # Start from a clean app-slot table.
    w = 2
    while w < MAX_WINDOWS:
        wsys_slot_in_use[w] = 0
        wsys_slot_pid[w] = 0
        wsys_win_decorate[w] = 0
        wsys_win_z[w] = 0
        wsys_scene_len[w] = 0
        w = w + 1

    # A live, decorated, app-z window — the kind the taskbar must always show.
    wl: int32 = wsys_alloc_wid(live_pid)
    if wl <= 1:
        printk0("[TASKBAR_CHURN] FAIL could not allocate a live window\n")
        return 0
    ul: uint64 = cast[uint64](wl)
    wsys_win_decorate[ul] = 1
    wsys_win_z[ul] = 5
    wsys_scene_len[ul] = 1
    wsys_win_title_len[ul] = 0           # falls back to "win<wid>"

    # A leaked, decorated window on a DIFFERENT slot bound to a dead pid.
    wd: int32 = wsys_alloc_wid(dead_pid)
    if wd <= 1:
        printk0("[TASKBAR_CHURN] FAIL could not allocate the dead-owner window\n")
        wsys_free_wid(wl)
        return 0
    ud: uint64 = cast[uint64](wd)
    wsys_win_decorate[ud] = 1
    wsys_win_z[ud] = 5
    wsys_scene_len[ud] = 1

    # Read the live snapshot (this reaps the dead-owner slot as a side effect).
    live_listed: int32 = _wsys_windows_list_has(wl)
    dead_listed: int32 = _wsys_windows_list_has(wd)

    ok: int32 = 1
    if live_listed == 0:
        printk0("[TASKBAR_CHURN] FAIL live decorated window missing from the taskbar snapshot\n")
        ok = 0
    if dead_listed != 0:
        printk0("[TASKBAR_CHURN] FAIL dead-owner window still listed (stale taskbar entry)\n")
        ok = 0
    # The dead slot must have been reclaimed by the reaping read.
    if wsys_slot_in_use[ud] != 0:
        printk0("[TASKBAR_CHURN] FAIL dead-owner slot was not reaped\n")
        ok = 0

    # Cleanup the live window (dead one is already reaped).
    wsys_scene_len[ul] = 0
    if wsys_wid_in_use(wl) != 0:
        wsys_free_wid(wl)
    if wsys_wid_in_use(wd) != 0:
        wsys_free_wid(wd)

    if ok == 0:
        return 0
    printk0("[TASKBAR_CHURN] PASS open/exit churn reclaims leaked slots; taskbar lists live windows only\n")
    return 1


def wsys_multitask_taskbar_selftest() -> int32:
    # MULTI-WINDOW TASKBAR proof (user-reported "terminal + calculator +
    # file manager open, but the panel taskbar shows only ONE"). Two halves:
    #
    #  A) ENUMERATION: stand up THREE live, decorated, app-z windows owned by
    #     three DISTINCT pids and assert ALL THREE appear in the
    #     /dev/wsys/windows snapshot the taskbar parses (the old test only ever
    #     checked a single live window, so an enumeration that collapsed to one
    #     would have passed).
    #
    #  B) READBACK RACE: simulate the real concurrent-launch interleave on the
    #     SHARED /dev/wsys/ctl result channel — three `newwindow` writes from
    #     three pids BEFORE any of them reads back its wid — and assert each pid
    #     reads back its OWN wid (not a sibling's). This is the root cause: a
    #     single global result slot cross-delivered/clobbered wids so several
    #     apps drove one window and the rest never decorated (vanishing from the
    #     taskbar). Drives the real _wsys_pending_put / _wsys_pending_take path.
    #
    # Prints a [MULTITASK_BAR] marker. Returns 1 on PASS, 0 on FAIL.
    _wsys_init_if_needed()
    live_pid: uint64 = current_task_pid()

    # Clean app-slot table.
    cw: uint64 = 2
    while cw < MAX_WINDOWS:
        wsys_slot_in_use[cw] = 0
        wsys_slot_pid[cw] = 0
        wsys_win_decorate[cw] = 0
        wsys_win_z[cw] = 0
        wsys_scene_len[cw] = 0
        cw = cw + 1

    # --- Part A: three distinct-pid live decorated windows all enumerate. ---
    w1: int32 = wsys_alloc_wid(live_pid)            # this task: always alive
    p2: uint64 = 990201
    p3: uint64 = 990202
    # Make pids p2/p3 "alive" for the reaping read by stamping the slot with
    # live_pid would defeat distinct-owner intent; instead use live_pid for all
    # three slots' OWNER (so the reaper keeps them) but on DIFFERENT slots —
    # distinct WINDOWS, all live. (The N-per-pid model: one pid, many wids.)
    w2: int32 = wsys_alloc_wid(live_pid)
    w3: int32 = wsys_alloc_wid(live_pid)
    if w1 <= 1 or w2 <= 1 or w3 <= 1 or w1 == w2 or w2 == w3 or w1 == w3:
        printk0("[MULTITASK_BAR] FAIL could not allocate three distinct live wids\n")
        return 0
    uu1: uint64 = cast[uint64](w1)
    uu2: uint64 = cast[uint64](w2)
    uu3: uint64 = cast[uint64](w3)
    wsys_win_decorate[uu1] = 1
    wsys_win_decorate[uu2] = 1
    wsys_win_decorate[uu3] = 1
    wsys_win_z[uu1] = 5
    wsys_win_z[uu2] = 5
    wsys_win_z[uu3] = 5
    wsys_scene_len[uu1] = 1
    wsys_scene_len[uu2] = 1
    wsys_scene_len[uu3] = 1

    a_ok: int32 = 1
    if _wsys_windows_list_has(w1) == 0 \
            or _wsys_windows_list_has(w2) == 0 \
            or _wsys_windows_list_has(w3) == 0:
        printk0("[MULTITASK_BAR] FAIL not all three live windows enumerate in /dev/wsys/windows\n")
        a_ok = 0
    else:
        printk0("[MULTITASK_BAR] all three live windows listed in /dev/wsys/windows\n")

    wsys_scene_len[uu1] = 0
    wsys_scene_len[uu2] = 0
    wsys_scene_len[uu3] = 0
    wsys_free_wid(w1)
    wsys_free_wid(w2)
    wsys_free_wid(w3)
    if a_ok == 0:
        return 0

    # --- Part B: per-pid readback survives a concurrent-launch interleave. ---
    # Three apps each "newwindow" (put) before ANY reads back (take). With the
    # old single global, the last writer's wid would be served to all readers.
    pa: uint64 = 990301
    pb: uint64 = 990302
    pc: uint64 = 990303
    _wsys_pending_put(pa, 11)
    _wsys_pending_put(pb, 22)
    _wsys_pending_put(pc, 33)
    ra: int32 = _wsys_pending_take(pa)
    rb: int32 = _wsys_pending_take(pb)
    rc: int32 = _wsys_pending_take(pc)
    if ra != 11 or rb != 22 or rc != 33:
        printk1("[MULTITASK_BAR] FAIL interleaved readback cross-delivered wids (a=%d", cast[uint64](ra))
        printk1(" b=%d", cast[uint64](rb))
        printk1(" c=%d)\n", cast[uint64](rc))
        return 0
    # A second take for an already-consumed pid yields -1 (no double-deliver).
    if _wsys_pending_take(pa) != -1:
        printk0("[MULTITASK_BAR] FAIL pending entry not consumed on take\n")
        return 0

    printk0("[MULTITASK_BAR] PASS N concurrent windows each enumerate + read back their own wid\n")
    return 1


def wsys_raise_enum_selftest() -> int32:
    # QA-N4 regression (user-reported "a LIVE on-screen window drops out of the
    # panel window-list after a single click"). Root cause: the pointer-router
    # raise (_wsys_raise, fired on a content/titlebar/edge press to bring the
    # clicked window to the front + focus it) used _wsys_win_top_z(), which
    # includes the panel/menu/overlay CHROME (z>=100). Raising a clicked app
    # window to chrome-top+1 pushed its z to >=101 — ABOVE the z<100 floor that
    # /dev/wsys/windows uses to tell app windows from chrome. The window stayed
    # live + on-screen but VANISHED from the taskbar + top window-list on the
    # very click that focused it.
    #
    # This test stands up a CHROME window (z=100, like the panel) plus THREE
    # live app windows, drives the REAL /dev/mouse router (_wsys_route_common)
    # with a content click on one app window (the interaction that raises +
    # focuses it), and asserts ALL THREE app windows STILL enumerate afterward
    # and the clicked window's z stayed in the app band (z<100). Pre-fix the
    # clicked window's z became >=101 and it dropped from the list.
    #
    # Prints a [RAISE_ENUM] marker. Returns 1 on PASS, 0 on FAIL.
    _wsys_init_if_needed()
    live_pid: uint64 = current_task_pid()

    # Clean app-slot table + router state.
    cw: uint64 = 2
    while cw < MAX_WINDOWS:
        wsys_slot_in_use[cw] = 0
        wsys_slot_pid[cw] = 0
        wsys_win_decorate[cw] = 0
        wsys_win_z[cw] = 0
        wsys_scene_len[cw] = 0
        wsys_win_geo_init[cw] = 0
        wsys_win_pinned[cw] = 0
        wsys_win_wm_state[cw] = WSYS_WM_NORMAL
        cw = cw + 1
    wsys_prev_buttons = 0
    wsys_drag_wid = 0
    wsys_resize_wid = 0
    wsys_resize_edge = 0
    wsys_focus_wid = 0

    # A CHROME window (undecorated, z=100 — the panel band). scene_len>0 so it
    # counts toward _wsys_win_top_z(). Parked in the top panel strip so it does
    # NOT sit under the app click point.
    wc: int32 = wsys_alloc_wid(live_pid)
    if wc <= 1:
        printk0("[RAISE_ENUM] FAIL could not allocate the chrome window\n")
        return 0
    uc: uint64 = cast[uint64](wc)
    wsys_win_decorate[uc] = 0
    wsys_win_z[uc] = 100
    wsys_scene_len[uc] = 1
    wsys_win_geo_init[uc] = 1
    wsys_win_x[uc] = 0
    wsys_win_y[uc] = 0
    wsys_win_w[uc] = 400
    wsys_win_h[uc] = 26

    # THREE live decorated app windows, stacked vertically well below the
    # panel so a content click hits exactly the intended one.
    w1: int32 = wsys_alloc_wid(live_pid)
    w2: int32 = wsys_alloc_wid(live_pid)
    w3: int32 = wsys_alloc_wid(live_pid)
    if w1 <= 1 or w2 <= 1 or w3 <= 1:
        printk0("[RAISE_ENUM] FAIL could not allocate three app windows\n")
        return 0
    aw: int64 = 200
    ah: int64 = 120
    ay1: int64 = 200
    ay2: int64 = 360
    ay3: int64 = 520
    ii: int32 = 0
    wids: Array[3, int32]
    wids[0] = w1
    wids[1] = w2
    wids[2] = w3
    ys: Array[3, int64]
    ys[0] = ay1
    ys[1] = ay2
    ys[2] = ay3
    while ii < 3:
        uu: uint64 = cast[uint64](wids[cast[uint64](ii)])
        wsys_win_decorate[uu] = 1
        wsys_win_z[uu] = 5
        wsys_scene_len[uu] = 1
        wsys_win_geo_init[uu] = 1
        wsys_win_x[uu] = 40
        wsys_win_y[uu] = ys[cast[uint64](ii)]
        wsys_win_w[uu] = aw
        wsys_win_h[uu] = ah
        ii = ii + 1

    # Pre-condition: all three enumerate before any interaction.
    if _wsys_windows_list_has(w1) == 0 \
            or _wsys_windows_list_has(w2) == 0 \
            or _wsys_windows_list_has(w3) == 0:
        printk0("[RAISE_ENUM] FAIL app windows not all listed before the click\n")
        return 0

    # --- THE INTERACTION: content click on w2 (raise+focus via the router). ---
    # Click the CENTRE of w2's content, away from the titlebar + resize edges.
    u2: uint64 = cast[uint64](w2)
    cx: int64 = wsys_win_x[u2] + aw / 2
    cy: int64 = wsys_win_y[u2] + ah / 2
    _wsys_route_common(cx, cy, 1, 0)                    # button-1 down (raise)
    _wsys_route_common(cx, cy, 0, 0)                    # button-1 up
    wsys_prev_buttons = 0

    ok: int32 = 1
    # The clicked window must have been raised to the TOP of the app band, but
    # must NOT have crossed the chrome floor (that was the bug).
    if wsys_win_z[u2] >= 100:
        printk1("[RAISE_ENUM] FAIL clicked window raised INTO the chrome band (z=%d)\n", cast[uint64](wsys_win_z[u2]))
        ok = 0
    # The whole point: every live window still enumerates after the click.
    if _wsys_windows_list_has(w1) == 0:
        printk0("[RAISE_ENUM] FAIL w1 dropped from the window-list after the click\n")
        ok = 0
    if _wsys_windows_list_has(w2) == 0:
        printk0("[RAISE_ENUM] FAIL clicked window w2 dropped from the window-list (the reported bug)\n")
        ok = 0
    if _wsys_windows_list_has(w3) == 0:
        printk0("[RAISE_ENUM] FAIL w3 dropped from the window-list after the click\n")
        ok = 0
    # It should genuinely be on top of its app peers (raise worked).
    if ok != 0 and (wsys_win_z[u2] <= wsys_win_z[cast[uint64](w1)] \
            or wsys_win_z[u2] <= wsys_win_z[cast[uint64](w3)]):
        printk0("[RAISE_ENUM] FAIL clicked window was not raised above its app peers\n")
        ok = 0

    # Cleanup.
    wsys_scene_len[cast[uint64](w1)] = 0
    wsys_scene_len[u2] = 0
    wsys_scene_len[cast[uint64](w3)] = 0
    wsys_scene_len[uc] = 0
    wsys_prev_buttons = 0
    wsys_drag_wid = 0
    wsys_resize_wid = 0
    wsys_focus_wid = 0
    if wsys_wid_in_use(w1) != 0:
        wsys_free_wid(w1)
    if wsys_wid_in_use(w2) != 0:
        wsys_free_wid(w2)
    if wsys_wid_in_use(w3) != 0:
        wsys_free_wid(w3)
    if wsys_wid_in_use(wc) != 0:
        wsys_free_wid(wc)

    if ok == 0:
        return 0
    printk0("[RAISE_ENUM] PASS a live window stays enumerated after a click raises it (app z-band preserved)\n")
    return 1


def wsys_mate_wm_selftest() -> int32:
    # MATE window-management proof. Drive the REAL live router
    # (_wsys_route_common) the way /dev/mouse does, and assert the managed
    # geometry transitions:
    #   1) titlebar double-click -> maximize (fills the work area; y below the
    #      panel band), second double-click -> restore to the float rect.
    #   2) a free-resize drag on the RIGHT/BOTTOM corner grows w/h.
    # Prints a [MATE_WM] marker with before/after geometry. Returns 1/0.
    _wsys_init_if_needed()
    wid: int32 = wsys_alloc_wid(999000)
    if wid <= 1:
        printk0("[MATE_WM] FAIL could not allocate a scene wid\n")
        return 0
    u: uint64 = cast[uint64](wid)
    wsys_scene_len[u] = 1                              # non-empty: hit-testable
    wsys_win_decorate[u] = 1
    wsys_win_geo_init[u] = 1
    wsys_win_x[u] = 120
    wsys_win_y[u] = 140
    wsys_win_w[u] = 200
    wsys_win_h[u] = 150
    wsys_win_z[u] = 60
    wsys_win_wm_state[u] = WSYS_WM_NORMAL
    fx0: int64 = wsys_win_x[u]
    fy0: int64 = wsys_win_y[u]
    fw0: int64 = _wsys_win_def_w(u)
    fh0: int64 = _wsys_win_def_h(u)
    printk1("[MATE_WM] float geom x=%d", cast[uint64](fx0))
    printk1(" y=%d", cast[uint64](fy0))
    printk1(" w=%d", cast[uint64](fw0))
    printk1(" h=%d\n", cast[uint64](fh0))
    # Compute the expected work area for the assertion.
    ax: int64 = 0
    ay: int64 = 0
    aw: int64 = 0
    ah: int64 = 0
    _wsys_work_area(&ax, &ay, &aw, &ah)
    # --- gesture 1a: double-click the titlebar -> maximize ---
    tbx: int64 = wsys_win_x[u] + 4
    tby: int64 = wsys_win_y[u] - (WSYS_TITLEBAR_H / 2)
    wsys_prev_buttons = 0
    wsys_drag_wid = 0
    wsys_resize_wid = 0
    wsys_last_tbar_wid = 0
    wsys_last_tbar_jiffy = 0
    _wsys_route_common(tbx, tby, 1, 0)                 # click 1 down
    _wsys_route_common(tbx, tby, 0, 0)                 # click 1 up
    # Second click must land within the double-click jiffy window; it does
    # (no sleep between calls), and we re-aim at the (unchanged) titlebar.
    tbx2: int64 = wsys_win_x[u] + 4
    tby2: int64 = wsys_win_y[u] - (WSYS_TITLEBAR_H / 2)
    _wsys_route_common(tbx2, tby2, 1, 0)              # click 2 down -> maximize
    _wsys_route_common(tbx2, tby2, 0, 0)
    mx: int64 = wsys_win_x[u]
    my: int64 = wsys_win_y[u]
    mw: int64 = _wsys_win_def_w(u)
    mh: int64 = _wsys_win_def_h(u)
    printk1("[MATE_WM] maximized geom x=%d", cast[uint64](mx))
    printk1(" y=%d", cast[uint64](my))
    printk1(" w=%d", cast[uint64](mw))
    printk1(" h=%d\n", cast[uint64](mh))
    max_ok: int32 = 0
    if wsys_win_wm_state[u] == WSYS_WM_MAXIMIZED \
            and mw == aw and my >= ay and mx == ax:
        max_ok = 1
    if max_ok == 0:
        printk0("[MATE_WM] FAIL double-click did not maximize to the work area\n")
        wsys_prev_buttons = 0
        wsys_scene_len[u] = 0
        wsys_free_wid(wid)
        return 0
    # --- gesture 1b: double-click again -> restore the float rect ---
    rtbx: int64 = wsys_win_x[u] + 4
    rtby: int64 = wsys_win_y[u] - (WSYS_TITLEBAR_H / 2)
    wsys_last_tbar_wid = 0
    _wsys_route_common(rtbx, rtby, 1, 0)
    _wsys_route_common(rtbx, rtby, 0, 0)
    _wsys_route_common(rtbx, rtby, 1, 0)             # 2nd click -> restore
    _wsys_route_common(rtbx, rtby, 0, 0)
    rx: int64 = wsys_win_x[u]
    ry: int64 = wsys_win_y[u]
    rw: int64 = _wsys_win_def_w(u)
    rh: int64 = _wsys_win_def_h(u)
    printk1("[MATE_WM] restored geom x=%d", cast[uint64](rx))
    printk1(" y=%d", cast[uint64](ry))
    printk1(" w=%d", cast[uint64](rw))
    printk1(" h=%d\n", cast[uint64](rh))
    if wsys_win_wm_state[u] != WSYS_WM_NORMAL \
            or rx != fx0 or ry != fy0 or rw != fw0 or rh != fh0:
        printk0("[MATE_WM] FAIL second double-click did not restore float geom\n")
        wsys_prev_buttons = 0
        wsys_scene_len[u] = 0
        wsys_free_wid(wid)
        return 0
    # --- gesture 2: free-resize the bottom-right corner outward ---
    cx: int64 = wsys_win_x[u] + _wsys_win_def_w(u) - 1
    cy: int64 = wsys_win_y[u] + _wsys_win_def_h(u) - 1
    pre_w: int64 = _wsys_win_def_w(u)
    pre_h: int64 = _wsys_win_def_h(u)
    wsys_prev_buttons = 0
    wsys_drag_wid = 0
    wsys_resize_wid = 0
    _wsys_route_common(cx, cy, 1, 0)                 # press on BR corner
    if wsys_resize_wid != wid:
        printk0("[MATE_WM] FAIL corner press did not arm a resize drag\n")
        wsys_prev_buttons = 0
        wsys_scene_len[u] = 0
        wsys_free_wid(wid)
        return 0
    _wsys_route_common(cx + 40, cy + 30, 1, 0)       # drag corner out
    _wsys_route_common(cx + 40, cy + 30, 0, 0)       # release
    post_w: int64 = _wsys_win_def_w(u)
    post_h: int64 = _wsys_win_def_h(u)
    printk1("[MATE_WM] resize w %d", cast[uint64](pre_w))
    printk1(" -> %d", cast[uint64](post_w))
    printk1(" h %d", cast[uint64](pre_h))
    printk1(" -> %d\n", cast[uint64](post_h))
    if post_w != pre_w + 40 or post_h != pre_h + 30:
        printk0("[MATE_WM] FAIL edge resize did not grow w/h by the drag delta\n")
        wsys_prev_buttons = 0
        wsys_scene_len[u] = 0
        wsys_free_wid(wid)
        return 0
    wsys_prev_buttons = 0
    wsys_scene_len[u] = 0
    wsys_free_wid(wid)
    printk0("[MATE_WM] PASS double-click maximize/restore + edge-resize geometry\n")
    return 1


def _wsys_evt_has_pointer_line(wid: int32) -> int32:
    # Drain wid's event ring; return 1 iff it contained at least one `m `
    # (pointer) line. Consumes the ring.
    seen: int32 = 0
    dbuf: Array[256, uint8]
    rn: int64 = devwsys_event_read(wid, 0, &dbuf[0], 256)
    while rn > 0:
        k: uint64 = 0
        while k + 1 < cast[uint64](rn):
            if dbuf[k] == 109 and dbuf[k + 1] == 32:    # 'm' ' '
                seen = 1
            k = k + 1
        rn = devwsys_event_read(wid, 0, &dbuf[0], 256)
    return seen


def wsys_multiwindow_selftest() -> int32:
    # MULTI-WINDOW proof. Allocate TWO scene wids for the SAME synthetic
    # owner pid (the old one-window-per-pid restriction would reject the
    # second alloc). Place them NON-overlapping, both committed/hit-testable,
    # then route a button-1 press over EACH through the real live router
    # (_wsys_route_common). Assert:
    #   * both allocs succeeded and are DISTINCT wids bound to the SAME pid
    #     (N-per-pid identity);
    #   * a press over A focuses A and delivers a pointer line to A's event
    #     ring (and NOT B's);
    #   * a press over B then focuses B and delivers to B's event ring —
    #     proving input routes by z-order/hit-test to the right window, not
    #     by pid (both share one pid, so a pid lookup could not disambiguate).
    # Prints a [MULTIWIN] marker. Returns 1 on PASS, 0 on FAIL.
    _wsys_init_if_needed()
    fake_pid: uint64 = 999000
    wa: int32 = wsys_alloc_wid(fake_pid)
    if wa <= 1:
        printk0("[MULTIWIN] FAIL could not allocate first wid\n")
        return 0
    wb: int32 = wsys_alloc_wid(fake_pid)
    if wb <= 1:
        printk0("[MULTIWIN] FAIL second newwindow for the SAME pid was rejected (one-window-per-pid not lifted)\n")
        wsys_free_wid(wa)
        return 0
    if wa == wb:
        printk0("[MULTIWIN] FAIL the two allocs returned the SAME wid\n")
        wsys_free_wid(wa)
        return 0
    ua: uint64 = cast[uint64](wa)
    ub: uint64 = cast[uint64](wb)
    # Both bound to the same pid (per-window identity is the slot).
    if wsys_slot_pid[ua] != fake_pid or wsys_slot_pid[ub] != fake_pid:
        printk0("[MULTIWIN] FAIL both windows are not bound to the one owner pid\n")
        wsys_free_wid(wa)
        wsys_free_wid(wb)
        return 0
    # Place A and B non-overlapping, content-only, hit-testable.
    wsys_scene_len[ua] = 1
    wsys_scene_len[ub] = 1
    wsys_win_decorate[ua] = 0
    wsys_win_decorate[ub] = 0
    wsys_win_x[ua] = 100
    wsys_win_y[ua] = 100
    wsys_win_w[ua] = 80
    wsys_win_h[ua] = 60
    wsys_win_geo_init[ua] = 1
    wsys_win_z[ua] = 40
    wsys_win_x[ub] = 300
    wsys_win_y[ub] = 100
    wsys_win_w[ub] = 80
    wsys_win_h[ub] = 60
    wsys_win_geo_init[ub] = 1
    wsys_win_z[ub] = 41
    # Drain any stale events.
    _wsys_evt_has_pointer_line(wa)
    _wsys_evt_has_pointer_line(wb)
    saved_focus2: int32 = wsys_focus_wid
    wsys_prev_buttons = 0
    wsys_drag_wid = 0
    # Press at the centre of A (130,130).
    _wsys_route_common(130, 130, 1, 0)
    wsys_prev_buttons = 0
    if wsys_focused_wid() != wa:
        printk0("[MULTIWIN] FAIL press over A did not focus A (z-order/hit-test routing)\n")
        wsys_focus_wid = saved_focus2
        wsys_scene_len[ua] = 0
        wsys_scene_len[ub] = 0
        wsys_free_wid(wa)
        wsys_free_wid(wb)
        return 0
    a_got: int32 = _wsys_evt_has_pointer_line(wa)
    b_got: int32 = _wsys_evt_has_pointer_line(wb)
    if a_got == 0 or b_got != 0:
        printk0("[MULTIWIN] FAIL A-press did not route a pointer line to A ONLY\n")
        wsys_focus_wid = saved_focus2
        wsys_scene_len[ua] = 0
        wsys_scene_len[ub] = 0
        wsys_free_wid(wa)
        wsys_free_wid(wb)
        return 0
    # Press at the centre of B (340,130). Focus must MOVE to B even though
    # B shares A's pid — proving routing is hit-test, not pid.
    _wsys_route_common(340, 130, 1, 0)
    wsys_prev_buttons = 0
    if wsys_focused_wid() != wb:
        printk0("[MULTIWIN] FAIL press over B did not move focus to B (pid-ambiguous routing?)\n")
        wsys_focus_wid = saved_focus2
        wsys_scene_len[ua] = 0
        wsys_scene_len[ub] = 0
        wsys_free_wid(wa)
        wsys_free_wid(wb)
        return 0
    a_got2: int32 = _wsys_evt_has_pointer_line(wa)
    b_got2: int32 = _wsys_evt_has_pointer_line(wb)
    if b_got2 == 0 or a_got2 != 0:
        printk0("[MULTIWIN] FAIL B-press did not route a pointer line to B ONLY\n")
        wsys_focus_wid = saved_focus2
        wsys_scene_len[ua] = 0
        wsys_scene_len[ub] = 0
        wsys_free_wid(wa)
        wsys_free_wid(wb)
        return 0
    # Cleanup.
    wsys_focus_wid = saved_focus2
    wsys_prev_buttons = 0
    wsys_scene_len[ua] = 0
    wsys_scene_len[ub] = 0
    wsys_free_wid(wa)
    wsys_free_wid(wb)
    printk0("[MULTIWIN] PASS one pid opened two windows; each renders + routes input by z-order/hit-test (not pid)\n")
    return 1


def wsys_cursor_hotspot_selftest() -> int32:
    # BUG 1 FIX self-test. Inject a known ABSOLUTE pointer position and
    # assert the cursor sprite's blit ORIGIN (its top-left, == the arrow
    # TIP) coincides with the routed hit-test point (wsys_cursor_x/y). If
    # they diverge a click registers off the visible tip — the misalignment
    # the user reported (click landing near the BOTTOM of the sprite).
    # Prints a [CURSOR_HOTSPOT] marker. Returns 1 on PASS.
    if fb_get_initialized() == 0:
        # No framebuffer in this boot harness: rasterize path is a no-op, so
        # we can't compare a real blit. Validate the math directly instead:
        # set the cursor scene at a known point and confirm the FIRST fill's
        # origin (the tip) equals that point via _wsys_rasterize_cursor's
        # parse, which sets wsys_cursor_blit_x/y.
        _wsys_init_if_needed()
        _wsys_cursor_set_scene(123, 77)
        _wsys_rasterize_cursor()
        if wsys_cursor_blit_x == 123 and wsys_cursor_blit_y == 77:
            printk0("[CURSOR_HOTSPOT] PASS sprite tip origin == hit point (no fb; math path)\n")
            return 1
        printk0("[CURSOR_HOTSPOT] FAIL sprite tip origin != injected point (no fb)\n")
        return 0
    _wsys_scene_init_if_needed()
    sw: int64 = cast[int64](fb_get_width())
    sh: int64 = cast[int64](fb_get_height())
    if sw <= 0 or sh <= 0:
        printk0("[CURSOR_HOTSPOT] PASS (skip: degenerate fb)\n")
        return 1
    # Inject an absolute tablet position that maps to a known interior pixel.
    ax: int32 = cast[int32]((sw / 4) * 32768 / sw)
    ay: int32 = cast[int32]((sh / 4) * 32768 / sh)
    wsys_route_mouse_abs(ax, ay, 0, 0)
    # After routing, the hit point and the sprite blit origin (tip) must match.
    if wsys_cursor_blit_x == wsys_cursor_x \
            and wsys_cursor_blit_y == wsys_cursor_y:
        printk0("[CURSOR_HOTSPOT] PASS arrow tip blit origin == routed hit point\n")
        return 1
    printk0("[CURSOR_HOTSPOT] FAIL sprite tip != routed hit point (Bug 1)\n")
    return 0


def wsys_keys_lossless_selftest() -> int32:
    # BUG 3 FIX self-test. Push a known N-byte burst into a focused window's
    # /keys ring (the same _wsys_keys_push_byte the timer-IRQ keyboard pump
    # uses) and assert ALL N bytes drain back out IN ORDER with no loss —
    # the lossless property the IRQ-safe ring must guarantee. Drains in
    # several small chunks to exercise the pop/compact path repeatedly.
    # Prints a [KEYS_LOSSLESS] marker. Returns 1 on PASS.
    _wsys_init_if_needed()
    _wsys_evt_wq_init_if_needed()
    wid: int32 = wsys_alloc_wid(999995)
    if wid <= 1:
        printk0("[KEYS_LOSSLESS] FAIL could not allocate a scene wid\n")
        return 0
    u: uint64 = cast[uint64](wid)
    wsys_scene_len[u] = 1
    _wsys_reset_evt_rings(wid)
    # Burst: 300 bytes, value = (i % 251) so order is verifiable. 300 > a
    # few pop chunks, well under WSYS_KEYS_SIZE (no legitimate overflow).
    N: int64 = 300
    i: int64 = 0
    pushed: int64 = 0
    while i < N:
        if _wsys_keys_push_byte(wid, cast[uint8](i % 251)) == 1:
            pushed = pushed + 1
        i = i + 1
    # Drain in 32-byte chunks; verify ordered, count total.
    got: int64 = 0
    chunk: Array[32, uint8]
    bad: int32 = 0
    while True:
        r: int64 = _wsys_keys_pop_into(wid, &chunk[0], 32)
        if r <= 0:
            break
        j: int64 = 0
        while j < r:
            exp: uint8 = cast[uint8]((got + j) % 251)
            if chunk[cast[uint64](j)] != exp:
                bad = 1
            j = j + 1
        got = got + r
    wsys_scene_len[u] = 0
    wsys_free_wid(wid)
    if pushed != N:
        printk0("[KEYS_LOSSLESS] FAIL ring rejected a byte under a normal burst\n")
        return 0
    if got != N or bad != 0:
        printk0("[KEYS_LOSSLESS] FAIL drained byte count/order mismatch (dropped keystroke)\n")
        return 0
    printk0("[KEYS_LOSSLESS] PASS all burst bytes drained in order (no drop)\n")
    return 1


def _kbd_e2e_parse_d_lines(buf: Ptr[uint8], n: int64, out: Ptr[int64],
                           outmax: int64) -> int64:
    # Parse a /keys stream of "d <code>\n" press lines into out[] (the
    # decoded codes, in order). Returns how many codes were parsed (capped
    # at outmax). Skips any non-'d' lines defensively.
    i: int64 = 0
    cnt: int64 = 0
    while i < n and cnt < outmax:
        # Each line: 'd' ' ' <digits> '\n'. Find the 'd'.
        if buf[cast[uint64](i)] != 100:           # not 'd' -> advance to next \n
            while i < n and buf[cast[uint64](i)] != 10:
                i = i + 1
            i = i + 1
            continue
        i = i + 1
        if i < n and buf[cast[uint64](i)] == 32:  # skip the space
            i = i + 1
        v: int64 = 0
        while i < n and buf[cast[uint64](i)] >= 48 and buf[cast[uint64](i)] <= 57:
            v = v * 10 + cast[int64](buf[cast[uint64](i)] - 48)
            i = i + 1
        if i < n and buf[cast[uint64](i)] == 10:  # consume the newline
            i = i + 1
        out[cast[uint64](cnt)] = v
        cnt = cnt + 1
    return cnt


def wsys_kbd_e2e_delivery_selftest() -> int32:
    # FULL-PATH keyboard delivery MEASUREMENT (DE input lag/loss bug).
    #
    # Injects a KNOWN sequence of N keystrokes through the EXACT path a
    # physical keypress takes:
    #   atkbd_process_byte(scancode)   -- scancode -> ASCII into kbd_fifo
    #   [drain kbd_fifo, route each byte]  -- the kbd_pump_to_compositor body
    #     wsys_route_key_byte(code)    -- ASCII -> focused window's /keys ring
    #   devwsys_keys_read_nb           -- the scene client's read
    # and asserts ALL N codes arrive at /keys, IN ORDER, with NO one-behind
    # (every code delivered on ITS OWN inject, not the next). Prints a
    # [KBD_E2E] line with the injected/delivered counts so the loss/delay
    # point is visible in the boot transcript.
    _wsys_init_if_needed()
    _wsys_evt_wq_init_if_needed()
    wid: int32 = wsys_alloc_wid(999994)
    if wid <= 1:
        printk0("[KBD_E2E] FAIL could not allocate a scene wid\n")
        return 0
    u: uint64 = cast[uint64](wid)
    wsys_scene_len[u] = 1
    wsys_win_decorate[u] = 1
    saved_focus: int32 = wsys_focus_wid
    wsys_focus_wid = wid
    _wsys_reset_evt_rings(wid)
    # Drain any stale kbd_fifo bytes so only our injected keys are counted.
    while kbd_rx_pop() >= 0:
        pass

    # The N scancodes to inject and the ASCII code each must produce. We use
    # the home-row + top-row letters (no modifiers, no extended/break codes)
    # so each make-code yields EXACTLY ONE ASCII byte. 26 distinct keys.
    sc: Array[26, int32]
    exp: Array[26, int64]
    sc[0]  = 0x1E
    exp[0]  = 97    # a
    sc[1]  = 0x30
    exp[1]  = 98    # b
    sc[2]  = 0x2E
    exp[2]  = 99    # c
    sc[3]  = 0x20
    exp[3]  = 100   # d
    sc[4]  = 0x12
    exp[4]  = 101   # e
    sc[5]  = 0x21
    exp[5]  = 102   # f
    sc[6]  = 0x22
    exp[6]  = 103   # g
    sc[7]  = 0x23
    exp[7]  = 104   # h
    sc[8]  = 0x17
    exp[8]  = 105   # i
    sc[9]  = 0x24
    exp[9]  = 106   # j
    sc[10] = 0x25
    exp[10] = 107   # k
    sc[11] = 0x26
    exp[11] = 108   # l
    sc[12] = 0x32
    exp[12] = 109   # m
    sc[13] = 0x31
    exp[13] = 110   # n
    sc[14] = 0x18
    exp[14] = 111   # o
    sc[15] = 0x19
    exp[15] = 112   # p
    sc[16] = 0x10
    exp[16] = 113   # q
    sc[17] = 0x13
    exp[17] = 114   # r
    sc[18] = 0x1F
    exp[18] = 115   # s
    sc[19] = 0x14
    exp[19] = 116   # t
    sc[20] = 0x16
    exp[20] = 117   # u
    sc[21] = 0x2F
    exp[21] = 118   # v
    sc[22] = 0x11
    exp[22] = 119   # w
    sc[23] = 0x2D
    exp[23] = 120   # x
    sc[24] = 0x15
    exp[24] = 121   # y
    sc[25] = 0x2C
    exp[25] = 122   # z
    N: int64 = 26

    # PASS 1 — INTERLEAVED inject+drain, the realistic typing pattern: one
    # key produced, the pump runs (drain kbd_fifo, route), the client reads.
    # This is where a "one-behind" delivery bug shows up: if reading key k
    # only returns key k-1, the per-step read count is wrong.
    got: Array[64, int64]
    delivered: int64 = 0
    onebehind: int32 = 0
    rb: Array[256, uint8]
    k: int64 = 0
    while k < N:
        # Producer: a scancode lands in kbd_fifo (as IRQ/poll would do).
        atkbd_process_byte(sc[cast[uint64](k)])
        # Pump: drain kbd_fifo -> /keys (the kbd_pump_to_compositor body).
        c: int32 = kbd_rx_pop()
        while c >= 0:
            wsys_route_key_byte(c & 0xFF)
            c = kbd_rx_pop()
        # Consumer: the scene client reads whatever is ready RIGHT NOW.
        rn: int64 = devwsys_keys_read_nb(wid, &rb[0], 256)
        codes: Array[64, int64]
        nc: int64 = _kbd_e2e_parse_d_lines(&rb[0], rn, &codes[0], 64)
        # A correct pipeline delivers EXACTLY this step's key on this read.
        # 0 codes here == one-behind delay (the key sits until the next).
        if nc == 0:
            onebehind = onebehind + 1
        ci: int64 = 0
        while ci < nc and delivered < 64:
            got[cast[uint64](delivered)] = codes[cast[uint64](ci)]
            delivered = delivered + 1
            ci = ci + 1
        k = k + 1
    # Drain any straggler left behind after the last inject (the tail of a
    # one-behind delivery).
    rn2: int64 = devwsys_keys_read_nb(wid, &rb[0], 256)
    if rn2 > 0:
        codes2: Array[64, int64]
        nc2: int64 = _kbd_e2e_parse_d_lines(&rb[0], rn2, &codes2[0], 64)
        ci2: int64 = 0
        while ci2 < nc2 and delivered < 64:
            got[cast[uint64](delivered)] = codes2[cast[uint64](ci2)]
            delivered = delivered + 1
            ci2 = ci2 + 1

    # Verify order + completeness.
    ordered: int32 = 1
    vi: int64 = 0
    while vi < delivered:
        if vi < N:
            if got[cast[uint64](vi)] != exp[cast[uint64](vi)]:
                ordered = 0
        vi = vi + 1

    printk2("[KBD_E2E] injected=%d delivered=%d ",
            cast[uint64](N), cast[uint64](delivered))
    printk2("one_behind_steps=%d ordered=%d\n",
            cast[uint64](onebehind), cast[uint64](ordered))

    wsys_focus_wid = saved_focus
    wsys_scene_len[u] = 0
    wsys_free_wid(wid)

    if delivered != N:
        printk0("[KBD_E2E] FAIL not all injected keys reached /keys (LOSS)\n")
        return 0
    if onebehind != 0:
        printk0("[KBD_E2E] FAIL a key was delivered one keystroke late (DELAY)\n")
        return 0
    if ordered == 0:
        printk0("[KBD_E2E] FAIL delivered keys out of order\n")
        return 0
    printk0("[KBD_E2E] PASS all keys delivered in order, each on its own keystroke\n")
    return 1


def wsys_focusout_selftest() -> int32:
    # BUG 2a FIX self-test. The in-panel Applications dropdown can't see
    # clicks on other windows / the backdrop, so it relies on a focus-OUT
    # event to self-dismiss. This asserts the compositor's focus router
    # delivers `f out\n` to the window LOSING focus when focus moves away.
    # Allocate window A, focus it, then move focus to a DIFFERENT wid and
    # assert A's event ring carries an `f out` line. Prints a [FOCUS_OUT]
    # marker. Returns 1 on PASS, 0 on FAIL.
    _wsys_init_if_needed()
    wa: int32 = wsys_alloc_wid(999997)
    if wa <= 1:
        printk0("[FOCUS_OUT] FAIL could not allocate scene wid A\n")
        return 0
    wb: int32 = wsys_alloc_wid(999996)
    if wb <= 1:
        printk0("[FOCUS_OUT] FAIL could not allocate scene wid B\n")
        wsys_free_wid(wa)
        return 0
    ua: uint64 = cast[uint64](wa)
    ub: uint64 = cast[uint64](wb)
    wsys_scene_len[ua] = 1
    wsys_scene_len[ub] = 1
    saved_focus: int32 = wsys_focus_wid
    # Focus A (drain its `f in`), then steal focus with B.
    wsys_focus_wid = 0
    _wsys_set_focus(wa)
    drain: Array[64, uint8]
    while devwsys_event_read(wa, 0, &drain[0], 64) > 0:
        pass
    _wsys_set_focus(wb)                                # A loses focus
    rb: Array[16, uint8]
    rn: int64 = devwsys_event_read(wa, 0, &rb[0], 16)
    ok: int32 = 0
    # Expect the line "f out\n" (f, space, o, u, t, newline).
    if rn >= 6 and rb[0] == 102 and rb[1] == 32 and rb[2] == 111 \
            and rb[3] == 117 and rb[4] == 116 and rb[5] == 10:
        ok = 1
    wsys_focus_wid = saved_focus
    wsys_scene_len[ua] = 0
    wsys_scene_len[ub] = 0
    wsys_free_wid(wa)
    wsys_free_wid(wb)
    if ok == 0:
        printk0("[FOCUS_OUT] FAIL focus change did NOT deliver 'f out' to the defocused window\n")
        return 0
    printk0("[FOCUS_OUT] PASS focus-out 'f out' delivered to the window losing focus (Bug 2a)\n")
    return 1


# ====================================================================
# WAYLAND FRONT-END BRIDGE (docs/wayland_passthrough_design.md Phase 1)
# ====================================================================
#
# The native Wayland server (linux_abi/wayland.ad) drives these to turn a
# committed wl_shm surface buffer into an on-screen Hamnix window. A
# Wayland surface maps 1:1 to a wid using the v2 blit backbuffer + the
# `buffer` scene verb (added to _wsys_rast_line) so the committed pixels
# land on the same in-kernel present pipeline the DE apps use. These
# entry points BYPASS the /dev/wsys ctl-file ownership gates (the server
# is in-kernel, not the owning task), so they must only be called by the
# trusted front-end.

def wsys_wl_alloc(w: int32, h: int32) -> int32:
    # Allocate a wid for a Wayland surface sized w x h. Opts the window
    # into v2 (blit) protocol, sets its geometry + a cascade position, and
    # marks it a decorated app window. Returns the wid or -1 on exhaustion.
    wid: int32 = wsys_alloc_wid(current_task_pid())
    if wid < 0:
        return -1
    u: uint64 = cast[uint64](wid)
    ww: int64 = cast[int64](w)
    hh: int64 = cast[int64](h)
    if ww < 1:
        ww = 1
    if hh < 1:
        hh = 1
    if ww > WSYS_SCENE_CACHE_MAX:
        ww = WSYS_SCENE_CACHE_MAX
    if hh > WSYS_SCENE_CACHE_MAX:
        hh = WSYS_SCENE_CACHE_MAX
    wsys_win_version[u] = 2
    wsys_win_w[u] = ww
    wsys_win_h[u] = hh
    wsys_win_geo_init[u] = 1
    wsys_win_x[u] = 60 + cast[int64](wid) * 24
    wsys_win_y[u] = 60 + cast[int64](wid) * 24
    wsys_win_decorate[u] = 1
    wsys_win_ws[u] = wsys_cur_ws
    return wid


def wsys_wl_resize(wid: int32, w: int32, h: int32):
    # Update a Wayland window's content size (surface committed a
    # different-sized buffer). Keeps position + z + mapped state.
    if wsys_wid_in_use(wid) == 0:
        return
    u: uint64 = cast[uint64](wid)
    ww: int64 = cast[int64](w)
    hh: int64 = cast[int64](h)
    if ww < 1:
        ww = 1
    if hh < 1:
        hh = 1
    if ww > WSYS_SCENE_CACHE_MAX:
        ww = WSYS_SCENE_CACHE_MAX
    if hh > WSYS_SCENE_CACHE_MAX:
        hh = WSYS_SCENE_CACHE_MAX
    wsys_win_w[u] = ww
    wsys_win_h[u] = hh
    wsys_win_geo_init[u] = 1
    # A size change reallocates the layer cache on next rasterize.
    _wsys_layer_fb_release(wid)


def wsys_wl_store_rect(wid: int32, x0: int32, y0: int32, x1: int32,
                       y1: int32, fmt: uint8, src: Ptr[uint8]):
    # Store one raw pixel rect into wid's v2 backbuffer + fold the rect
    # into the v2 dirty region. `src` is a KERNEL pointer, tightly packed
    # at (x1-x0)*bpp[fmt] stride. Thin public wrapper over the existing
    # blit-store used by /dev/wsys/<wid>/draw/ctl.
    _wsys_blit_store_rect(wid, x0, y0, x1, y1, fmt, src)
    _wsys_bb_dirty_add(wid, cast[int64](x0), cast[int64](y0),
                       cast[int64](x1), cast[int64](y1))


def wsys_wl_present(wid: int32, w: int32, h: int32):
    # Publish wid's v2 backbuffer to the screen: write a one-line
    # `buffer 0 0 w h` scene so the rasterizer composites the backbuffer
    # into the layer cache, first-map+raise+focus once, then run the
    # damage-scoped present. Mirrors the per-window `commit` ctl verb but
    # for the in-kernel Wayland front-end (no scene-file writes).
    if wsys_wid_in_use(wid) == 0:
        return
    u: uint64 = cast[uint64](wid)
    _wsys_scene_init_if_needed()
    # Build the scene line into the window's scene buffer.
    base: uint64 = u * WSYS_SCENE_SIZE
    pos: uint64 = 0
    wsys_scene_buf[base + pos] = 98                 # 'b'
    pos = pos + 1
    wsys_scene_buf[base + pos] = 117                # 'u'
    pos = pos + 1
    wsys_scene_buf[base + pos] = 102                # 'f'
    pos = pos + 1
    wsys_scene_buf[base + pos] = 102                # 'f'
    pos = pos + 1
    wsys_scene_buf[base + pos] = 101                # 'e'
    pos = pos + 1
    wsys_scene_buf[base + pos] = 114                # 'r'
    pos = pos + 1
    wsys_scene_buf[base + pos] = 32                 # ' '
    pos = pos + 1
    wsys_scene_buf[base + pos] = 48                 # '0' (x)
    pos = pos + 1
    wsys_scene_buf[base + pos] = 32                 # ' '
    pos = pos + 1
    wsys_scene_buf[base + pos] = 48                 # '0' (y)
    pos = pos + 1
    wsys_scene_buf[base + pos] = 32                 # ' '
    pos = pos + 1
    pos = pos + _wsys_u64_to_dec(cast[uint64](w), &wsys_scene_buf[base + pos])
    wsys_scene_buf[base + pos] = 32                 # ' '
    pos = pos + 1
    pos = pos + _wsys_u64_to_dec(cast[uint64](h), &wsys_scene_buf[base + pos])
    wsys_scene_buf[base + pos] = 10                 # '\n'
    pos = pos + 1
    wsys_scene_len[u] = pos
    wsys_scene_wpos[u] = pos
    wsys_scene_gen[u] = wsys_scene_gen[u] + 1
    # First-commit map + raise + focus (same policy as the commit verb).
    if wsys_win_mapped[u] == 0:
        wsys_win_mapped[u] = 1
        if wsys_win_pinned[u] == 0:
            _wsys_raise(wid)
            _wsys_set_focus(wid)
    _wsys_mark_dirty(wid, 0, 0, 65535, 65535)
    wsys_commit_seq = wsys_commit_seq + 1
    wq_wake_one(&wsys_commit_wq)
    _wsys_present_window_scoped(wid)


def wsys_wl_free(wid: int32):
    # Tear down a Wayland surface's window (surface/toplevel destroyed or
    # the client disconnected).
    if wsys_wid_in_use(wid) == 0:
        return
    u: uint64 = cast[uint64](wid)
    wsys_scene_len[u] = 0
    _wsys_close_window(wid)


def wsys_wl_set_title(wid: int32, src: Ptr[uint8], len: uint64):
    # Set a Wayland toplevel window's decoration/taskbar title from a KERNEL
    # buffer (xdg_toplevel.set_title). Mirrors the `title <string>` wctl verb
    # but takes an in-kernel byte span, so the native front-end can push a
    # title without synthesising a ctl write. Clamped to WSYS_WIN_TITLE_CAP-1.
    if wsys_wid_in_use(wid) == 0:
        return
    u: uint64 = cast[uint64](wid)
    tbase: uint64 = u * WSYS_WIN_TITLE_CAP
    n: uint64 = 0
    while n < len and n + 1 < WSYS_WIN_TITLE_CAP:
        wsys_win_title[tbase + n] = src[n]
        n = n + 1
    wsys_win_title[tbase + n] = 0
    wsys_win_title_len[u] = n
    # A title change alters the decoration; re-rasterize + present so the new
    # titlebar text shows without waiting for the next buffer commit.
    if wsys_win_mapped[u] != 0:
        _wsys_mark_dirty(wid, 0, 0, 65535, 65535)


def wsys_wl_screen_dims(out_w: Ptr[int32], out_h: Ptr[int32]):
    # Report the current framebuffer geometry (for xdg maximize/fullscreen
    # best-effort sizing). Falls back to the DE's canonical 1280x800 when no
    # framebuffer is up yet (e.g. under the headless -kernel selftest boot).
    sw: uint64 = fb_get_width()
    sh: uint64 = fb_get_height()
    if sw == 0 or sh == 0:
        sw = 1280
        sh = 800
    out_w[0] = cast[int32](sw)
    out_h[0] = cast[int32](sh)


def wsys_wl_test_title_len(wid: int32) -> int32:
    # TEST HOOK: length of wid's decoration title (Phase 3 set_title proof).
    if wsys_wid_in_use(wid) == 0:
        return -1
    return cast[int32](wsys_win_title_len[cast[uint64](wid)])


def wsys_wl_test_title_byte(wid: int32, i: int32) -> int32:
    # TEST HOOK: one byte of wid's decoration title.
    if wsys_wid_in_use(wid) == 0:
        return -1
    u: uint64 = cast[uint64](wid)
    if cast[uint64](i) >= WSYS_WIN_TITLE_CAP:
        return -1
    return cast[int32](wsys_win_title[u * WSYS_WIN_TITLE_CAP + cast[uint64](i)])


def wsys_wl_test_wid_in_use(wid: int32) -> int32:
    # TEST HOOK: 1 if wid is a live window (Phase 3 destroy/close proof).
    return wsys_wid_in_use(wid)


def wsys_wl_cache_pixel(wid: int32, x: int32, y: int32) -> uint32:
    # TEST HOOK: read one RGBA8888 pixel from wid's composited layer cache
    # (post-rasterize), packed r|g<<8|b<<16|a<<24. Returns 0 if no cache.
    # Lets the in-kernel Wayland client selftest assert a committed buffer
    # actually reached the present path without depending on /dev/fb.
    cache: Ptr[uint8] = _wsys_layer_fb_get(wid)
    if cast[uint64](cache) == 0:
        return 0
    u: uint64 = cast[uint64](wid)
    cw: int64 = _wsys_win_def_w(u)
    ch: int64 = _wsys_win_def_h(u)
    _wsys_clamp_cache_dims(&cw, &ch)
    if cast[int64](x) < 0 or cast[int64](y) < 0:
        return 0
    if cast[int64](x) >= cw or cast[int64](y) >= ch:
        return 0
    off: uint64 = (cast[uint64](y) * cast[uint64](cw) + cast[uint64](x)) * 4
    r: uint32 = cast[uint32](cache[off])
    g: uint32 = cast[uint32](cache[off + 1])
    b: uint32 = cast[uint32](cache[off + 2])
    a: uint32 = cast[uint32](cache[off + 3])
    return r | (g << 8) | (b << 16) | (a << 24)


def wsys_wl_backbuffer_pixel(wid: int32, x: int32, y: int32) -> uint32:
    # TEST HOOK: read one pixel from wid's v2 blit BACKBUFFER (RGBA8888,
    # stride WSYS_BB_STRIDE_BYTES), packed r|g<<8|b<<16|a<<24. Proves the
    # Wayland front-end decoded a client's shm buffer into the window
    # backbuffer, independent of any framebuffer.
    bbp: Ptr[uint8] = wsys_backbuffer_ptr(wid)
    if cast[uint64](bbp) == 0:
        return 0
    if x < 0 or y < 0:
        return 0
    if cast[uint64](x) >= WSYS_BB_W or cast[uint64](y) >= WSYS_BB_H:
        return 0
    off: uint64 = cast[uint64](y) * WSYS_BB_STRIDE_BYTES + cast[uint64](x) * 4
    r: uint32 = cast[uint32](bbp[off])
    g: uint32 = cast[uint32](bbp[off + 1])
    b: uint32 = cast[uint32](bbp[off + 2])
    a: uint32 = cast[uint32](bbp[off + 3])
    return r | (g << 8) | (b << 16) | (a << 24)


def wsys_wl_rasterize_test(wid: int32):
    # TEST HOOK: run the rasterizer for wid (composites the v2 backbuffer
    # into the layer cache via the `buffer` scene verb) without needing a
    # framebuffer, so wsys_wl_cache_pixel can assert the present-path wiring.
    if wsys_wid_in_use(wid) == 0:
        return
    _wsys_rasterize_window(wid)


def wsys_wl_test_set_focus(wid: int32):
    # TEST HOOK (Phase 2 input): make `wid` the focused window the same way a
    # click would (_wsys_set_focus emits the 'f out'/'f in' lines onto the
    # event rings). Lets the in-kernel Wayland input selftest drive focus
    # without a live framebuffer / mouse router.
    _wsys_set_focus(wid)


def wsys_wl_test_inject_pointer(wid: int32, lx: int32, ly: int32,
                                buttons: uint32, dz: int32):
    # TEST HOOK (Phase 2 input): push one window-local pointer line
    # "m <lx> <ly> <buttons> <dz>\n" onto wid's event ring exactly as the
    # mouse router (_wsys_route_common) does, and wake any waiter. This is
    # the SAME per-window /event stream the Wayland front-end drains, so the
    # selftest exercises the real translate path without a framebuffer.
    if wsys_wid_in_use(wid) == 0:
        return
    _wsys_evt_wq_init_if_needed()
    _wsys_evt_emit_pointer(wid, cast[int64](lx), cast[int64](ly),
                           buttons, cast[int64](dz))
    wq_wake_one(&wsys_ptr_wq[cast[uint64](wid)])


def wsys_wl_test_inject_key(wid: int32, code: int32):
    # TEST HOOK (Phase 2 input): push one cooked-ASCII press line
    # "d <code>\n" onto wid's /keys ring exactly as the keyboard pump
    # (wsys_route_key_byte) does — but targeted at `wid` regardless of
    # global focus, so the Wayland input selftest is deterministic.
    if wsys_wid_in_use(wid) == 0:
        return
    _wsys_evt_wq_init_if_needed()
    _wsys_keys_push_byte(wid, 100)                     # 'd'
    _wsys_keys_push_byte(wid, 32)                      # ' '
    _wsys_keys_emit_dec(wid, cast[int64](code))
    _wsys_keys_push_byte(wid, 10)                      # '\n'
    wq_wake_one(&wsys_keys_wq[cast[uint64](wid)])

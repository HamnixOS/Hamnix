# sys/src/9/port/devwsys.ad
#
# Layer 1 (Plan 9-shape) hamUI window-system device — Phase 2 backend
# for `/dev/wsys/<wid>/*`. See docs/hamUI.md H-§A and H-§E for the
# design.
#
# THE PHASE 2 PROMISE
# -------------------
# Multi-window: up to MAX_WINDOWS active windows, addressed as
# /dev/wsys/<wid>/ for wid in 1..MAX_WINDOWS. wid 1 is the foreground —
# the hamsh the user actually types into via the physical serial
# console. wids 2..N are detached background hamsh instances; their
# stdout/stderr does NOT reach the serial console, only their own
# /dev/wsys/<N>/text ring. An AI agent (or scripted driver) drives a
# bg window by writing to /dev/wsys/<N>/cmd and reading
# /dev/wsys/<N>/text — exactly the AI-debug workflow Phase 1 unlocked,
# but parallelised across windows.
#
# THE I/O TEE
# -----------
# Every byte that crosses devcons_write resolves through
# _wsys_wid_for_current() — looks up the calling task's pid in the
# wid table; defaults to wid 1 (foreground) if no mapping. That wid's
# text + output rings receive the byte. For wid 1 the byte ALSO lands
# on the UART / framebuffer (foreground console). For wid >= 2 the
# byte is suppressed at the console layer — bg windows are headless.
#
# CMD INJECTION
# -------------
# devcons_read pops from the CALLING window's cmd queue (same
# _wsys_wid_for_current() lookup). When an outside agent does
# `echo "ls" > /dev/wsys/2/cmd`, the bytes go to wid 2's queue; only
# tasks bound to wid 2 will pop them — wid 1's hamsh never sees them.
#
# WID ALLOCATION
# --------------
# _wsys_alloc_wid() returns the first free slot (1..MAX_WINDOWS) or
# -1 if full. The new userland tool /bin/hamUI calls
# sys_wsys_alloc(child_pid) after sys_spawning a detached hamsh —
# that syscall stamps the pid->wid mapping and returns the wid. wid 1
# is reserved at boot for the foreground hamsh (its pid is recorded
# the first time devcons_write tees with no existing mapping).
#
# BOUNDARY LAW
# ------------
# Layer 1 (native): pure Plan 9 surface. Snapshot-once read semantics
# for finite-content files so `cat` terminates.
#
# ADDER QUIRKS HONOURED
# ---------------------
#   * Top-level Array storage only — every ring + per-wid table lives
#     at module scope.
#   * No sizeof; ring sizes are hand-numbered constants.
#   * Leading-underscore top-level names are module-private.
#   * Every shared-shape helper carries a `_wsys_` prefix to dodge the
#     flat-namespace `_emit_str` collision class.
#   * Per-wid storage is a flat Array sized to MAX_WINDOWS * RING_SIZE.
#     Indexed as buf[wid * SIZE + offset] — a 2-D Array[N,M] sometimes
#     trips the codegen on aggregate slot access, so we go flat.
#
# #442 RIO-FAITHFUL RESHAPE — wire format for the BLIT protocol
# -------------------------------------------------------------
# Gap (c) from the 2026-06-11 directive: kill the whole-window text/markup
# draw path and move rasterization client-side. devwsys becomes a BLITTER:
# clients render into a private backbuffer and submit (rect, src_image)
# blits + dirty-rect invalidations. The compositor never sees a widget
# tree. Wire format, written to `/dev/win/draw/ctl` (or equivalently
# `/dev/wsys/<wid>/draw/ctl` for the global form):
#
#   'B' <x0:i32> <y0:i32> <x1:i32> <y1:i32> <fmt:u8> <pixel_bytes...>
#       Opaque BLIT into the slot's backbuffer. Rect is window-LOCAL
#       (the per-process bind: client never names a wid). `fmt` is one
#       of FMT_RGBA8888=1, FMT_BGRA8888=2, FMT_A8=3. pixel_bytes length
#       must be (x1-x0)*(y1-y0)*bpp[fmt]; short writes are EINVAL.
#   'D' <x0:i32> <y0:i32> <x1:i32> <y1:i32>
#       Dirty-rect INVALIDATION. Tells the compositor "the backbuffer
#       in this rect changed; redraw on the next present." No pixel
#       payload — the prior 'B' (or sequence of 'B's) already wrote
#       the pixels; 'D' just narrows damage. A client that draws then
#       sends one 'D' covering the union of its writes is the common
#       case.
#   'C' <hot_x:i32> <hot_y:i32> <w:i32> <h:i32> <fmt:u8> <pixel_bytes...>
#       CURSOR sprite update for this window's focus cursor. Composited
#       above all windows by daemon_flush_damage (existing save-under
#       path; see hamUId.ad #441).
#
# Integers are little-endian. The current text/markup draw path stays
# valid; clients opt in to the blit path by setting a per-window
# protocol-version byte to 2 via `version 2\n` on `/dev/win/ctl`. v1 =
# legacy widget-tree (current); v2 = blit protocol above. The compositor
# walks both code paths per-window based on that field. ONE increment of
# fallback is intentional so lib/hamui.ad can flip incrementally without
# breaking the user's running DE.
#
# THIS BLOCK IS THE SPEC, NOT THE IMPLEMENTATION. The verb parser and
# protocol-version byte are the next-increment landing pad; the namespace
# bind (#w) and event-stream wait-queue plumbing already in tree are the
# (a)/(b) substrate the blit protocol layers on top of.

from kernel.sched.core import (
    current_task_pid, current_task_uid, current_task_is_hostowner, console_input_wake,
    WaitQueue, wq_init, wq_wait_prepare, wq_wait_cancel,
    wq_wait_commit, wq_wake_one, WQ_EINTR,
    waitfds_notify,
    # F2 #447: /dev/wsys/ctl `alloc` verb needs the SYS_WSYS_ALLOC arm's
    # task-side effects: mark the bound shell task detached + parented
    # to 0 so hamUI exiting doesn't strand it as a zombie. Look up the
    # task by pid as the syscall arm does.
    task_lookup_by_pid, set_task_detached, set_task_parent_pid,
    task_parent_pid,
    set_current_errstr,
    # BUG 2 FIX: closing a scene window from the compositor's pointer
    # router SIGTERMs the bound client so it winds down + is reaped.
    signal_post, SIGTERM,
    # TODO DE close-out: per-window uid / ns visibility. The window's
    # uid is rendered from the BOUND TASK's uid (via task_lookup_by_pid
    # + task_uid_at) so a `newshell hostowner` running inside the window
    # — which goes through SYS_SETUID / SYS_SETUID_AUTH and stamps the
    # task's uid via set_current_task_uid — is reflected in
    # /dev/wsys/<N>/uid (and the rio-bound `#w/uid`) on the next read,
    # with NO bespoke setuid hook needed. The ns leaf reads the bound
    # task's pgrp (task_pgrp) so the dump shows the WINDOW'S namespace,
    # not the reader's.
    task_uid_at, task_pgrp,
    # Scene compositor present serialization: present is now driven from
    # TWO contexts (a committing client AND the /dev/mouse input router),
    # which on SMP can race over the shared rasterizer scratch + scratch
    # row buffer. A spinlock serializes the whole present.
    spinlock_lock, spinlock_unlock,
    local_irq_save, local_irq_restore,
)
from sys.src.port9.port.chan import (
    MountEntry, Pgrp, MNT_CAP,
    pgrp_current, CHAN_KIND_SRV,
)
from mm.slab import kmalloc, kfree
# Per-window screen-sized framebuffers (layer fb + v2 backbuffer) are each
# exactly 4 MiB. They are allocated lazily, one window at a time, from the
# buddy allocator (order 10 = 1024 pages = 4 MiB) rather than living in a
# 32-slot static BSS array — see the OOM regression note at the
# wsys_layer_fb_page / wsys_backbuffer_page declarations below.
from mm.page_alloc import alloc_pages, free_pages
extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]
# F2 #447: /dev/wsys/ctl `frame <wid> <n>` calls the kernel software
# rasterizer the same way SYS_VK_WINDOW_FRAME does — vk_window_demo
# is the in-tree native demo renderer that GPU track #181 ships.
from lib.vk.vk_window_demo import vk_window_render_frame

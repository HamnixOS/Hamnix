# sys/src/9/port/bind_test.ad
#
# Plan-9 namespace bind/mount/unmount self-test. Boot-gated on
# /etc/bind-test (planted by scripts/build_initramfs.py when
# ENABLE_BIND_TEST=1); init/main.ad at boot:37.bind calls
# bind_selftest() below.
#
# This is the UNFORGEABLE proof that the native bind(2)/mount(2)/
# unmount(2) syscalls build a REAL per-process namespace — not a
# table that records bindings but never redirects a lookup. Each
# assertion resolves a path THROUGH a bound name with resolve_path()
# (the exact seam SYS_OPEN consults) and reads the backing cpio bytes,
# so a marker only prints if the namespace walk landed on the right
# source file.
#
# Fixtures (cpio, planted by build_initramfs.py):
#   /bind_src_a/onlyA.txt   = "AAA"      (only in source A)
#   /bind_src_a/shared.txt  = "FROM-A"   (shared name, A copy)
#   /bind_src_b/onlyB.txt   = "BBB"      (only in source B)
#   /bind_src_b/shared.txt  = "FROM-B"   (shared name, B copy)
#
# What each phase proves:
#
#   1. REDIRECT (MREPL): bind /bind_src_a -> /bind_union, then resolve
#      /bind_union/onlyA.txt and read "AAA". A bare table-record could
#      not make a NEW name resolve to A's bytes — only a walk that
#      consults the mount table does.
#
#   2. UNION (MBEFORE): add bind -b /bind_src_b -> /bind_union over the
#      A bind. Now /bind_union/onlyA.txt STILL reads "AAA" (member A)
#      AND /bind_union/onlyB.txt reads "BBB" (member B) — files from
#      BOTH members visible at the one union point. /bind_union/shared
#      reads "FROM-B" because the MBEFORE member shadows the base.
#
#   3. UNMOUNT: unmount the B branch, then unmount everything at
#      /bind_union. Afterwards /bind_union/onlyB.txt no longer resolves
#      to B's bytes (the binding reverted) — proves removal is real.
#
#   4. PER-NAMESPACE ISOLATION: clone a fresh Pgrp, swap the current
#      task onto it, bind /bind_src_b -> /iso_union there, confirm the
#      child namespace sees it, then restore the original Pgrp and
#      confirm the parent namespace does NOT see the child's bind.
#      Proves binds are per-Pgrp, not global.
#
#   5. UNION (MAFTER): on a fresh /bind_union2, bind A as MREPL then
#      bind B with MAFTER on top. Both /bind_union2/onlyA.txt ('AAA')
#      and /bind_union2/onlyB.txt ('BBB') are visible, AND
#      /bind_union2/shared.txt reads 'FROM-A' — the REVERSE of phase
#      2's MBEFORE result, proving MAFTER is searched after the base.
#
#   6. MCREATE: bind A as MREPL (no MCREATE) then B as MBEFORE|MCREATE
#      at /bind_union3. mnttab_any_mcreate_covers must report 1 and
#      mnttab_create_target must pick member B's rewrite. Back-compat
#      check: a binding with NO MCREATE member reports 0 from both
#      (caller falls back to the legacy head-wins create path).
#
#   7. MCACHE (stub): bind A with MREPL|MCACHE; the bit is stored on
#      the entry (round-trips) but has no read-path effect — there is
#      no per-binding read cache layer yet. This phase confirms the
#      flag is harmless when stored: the bind succeeds and resolves
#      normally. See chan.ad's MCACHE_BIT comment for the deferral
#      rationale (would require a per-mount cache layer; the 9P
#      client today uses the global kernel page cache).

from kernel.printk.printk import printk0, printk_set_level
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG
from kernel.sched.core import (
    current_idx_get, set_task_pgrp, task_pgrp,
)
from sys.src.port9.port.chan import (
    mnttab_bind, mnttab_unmount,
    mnttab_create_target, mnttab_any_mcreate_covers,
    pgrp_clone, pgrp_ref_dec, pgrp_current,
)
from fs.vfs import resolve_path
from fs.cpio import (
    initramfs_entry_count, initramfs_entry_name,
    initramfs_entry_data, initramfs_entry_size,
)

# Plan-9 mount-order flags (MORDER band). Mirrors user/hamsh.ad's
# MREPL_FLAG / MBEFORE_FLAG / MAFTER_FLAG.
_BT_MREPL:   int32 = 0
_BT_MBEFORE: int32 = 1
_BT_MAFTER:  int32 = 2
# Plan-9 MCREATE / MCACHE bits (upper bits, OR'd with the MORDER band).
_BT_MCREATE: int32 = 4
_BT_MCACHE:  int32 = 8


def _bt_emerg(s: Ptr[char]):
    # Stamp a marker line EMERG so it survives the console gate and
    # reaches the captured serial log.
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0(s)


def _bt_streq_n(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    # 1 if the first n bytes of a and b are equal.
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


def _bt_cpio_lookup(path: Ptr[uint8]) -> int32:
    # Equal-length C-string compare against every cpio entry. Returns
    # the entry index or -1. Local copy so bind_test.ad doesn't depend
    # on sysfile.ad's private helper.
    count: uint64 = initramfs_entry_count()
    i: uint64 = 0
    while i < count:
        cand: Ptr[char] = initramfs_entry_name(i)
        k: uint64 = 0
        eq: int32 = 1
        while True:
            ca: int32 = cast[int32](path[k] & 0xFF)
            cb: int32 = cand[k]
            if ca != cb:
                eq = 0
                break
            if ca == 0:
                break
            k = k + 1
        if eq != 0:
            return cast[int32](i)
        i = i + 1
    return -1


def _bt_resolve_reads(user_path: Ptr[char], want: Ptr[uint8],
                      want_len: uint64) -> int32:
    # Resolve `user_path` through the CURRENT namespace (resolve_path
    # applies the bind/union ladder), then read the backing cpio bytes
    # and compare to `want`. Returns 1 if the resolved file's first
    # want_len bytes equal `want`, 0 on any miss (no bind match,
    # resolved file absent, or content mismatch). This is THE proof
    # that the walk through a bound name lands on the right source.
    abs_buf: Array[256, uint8]
    rc: int32 = resolve_path(user_path, &abs_buf[0], 256)
    if rc != 0:
        return 0
    idx: int32 = _bt_cpio_lookup(&abs_buf[0])
    if idx < 0:
        return 0
    sz: uint64 = initramfs_entry_size(cast[uint64](idx))
    if sz < want_len:
        return 0
    data: Ptr[uint8] = initramfs_entry_data(cast[uint64](idx))
    return _bt_streq_n(data, want, want_len)


def _bt_resolves_to_source(user_path: Ptr[char]) -> int32:
    # 1 if `user_path` resolves to an EXISTING cpio file under the
    # current namespace. Used by the unmount phase: after unbinding,
    # a path that previously resolved through the union must NO LONGER
    # land on a backing file.
    abs_buf: Array[256, uint8]
    rc: int32 = resolve_path(user_path, &abs_buf[0], 256)
    if rc != 0:
        return 0
    if _bt_cpio_lookup(&abs_buf[0]) < 0:
        return 0
    return 1


def bind_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL. Prints [bind] markers throughout
    # and a single "[bind] PASS" on full success.
    _bt_emerg("[bind] starting Plan-9 namespace bind/mount/unmount self-test\n")

    aaa: Array[4, uint8]
    aaa[0] = 65                                      # 'A'
    aaa[1] = 65
    aaa[2] = 65
    aaa[3] = 0
    bbb: Array[4, uint8]
    bbb[0] = 66                                      # 'B'
    bbb[1] = 66
    bbb[2] = 66
    bbb[3] = 0
    from_a: Array[7, uint8]
    from_a[0] = 70                                   # 'F'
    from_a[1] = 82                                   # 'R'
    from_a[2] = 79                                   # 'O'
    from_a[3] = 77                                   # 'M'
    from_a[4] = 45                                   # '-'
    from_a[5] = 65                                   # 'A'
    from_a[6] = 0
    from_b: Array[7, uint8]
    from_b[0] = 70
    from_b[1] = 82
    from_b[2] = 79
    from_b[3] = 77
    from_b[4] = 45
    from_b[5] = 66                                   # 'B'
    from_b[6] = 0

    ok: int32 = 1

    # --- Phase 0: sanity — the fixtures actually exist verbatim -----
    if _bt_cpio_lookup(cast[Ptr[uint8]]("/bind_src_a/onlyA.txt")) < 0:
        _bt_emerg("[bind] FAIL: fixture /bind_src_a/onlyA.txt missing\n")
        return 0
    if _bt_cpio_lookup(cast[Ptr[uint8]]("/bind_src_b/onlyB.txt")) < 0:
        _bt_emerg("[bind] FAIL: fixture /bind_src_b/onlyB.txt missing\n")
        return 0

    # --- Phase 1: REDIRECT (MREPL) ----------------------------------
    # bind /bind_src_a -> /bind_union. hamsh's wrapper passes
    # sys_bind(new=DST, old=SRC); the kernel mnttab_bind takes
    # (new_path=the lookup name, old_path=the source). So the lookup
    # name "/bind_union" is new, the source "/bind_src_a" is old.
    r1: int32 = mnttab_bind(cast[Ptr[uint8]]("/bind_union"),
                            cast[Ptr[uint8]]("/bind_src_a"),
                            _BT_MREPL)
    if r1 < 0:
        _bt_emerg("[bind] FAIL: phase1 mnttab_bind returned error\n")
        return 0
    if _bt_resolve_reads(cast[Ptr[char]]("/bind_union/onlyA.txt"),
                         &aaa[0], 3) != 0:
        _bt_emerg("[bind] phase1 OK: /bind_union/onlyA.txt -> 'AAA' (MREPL redirect)\n")
    else:
        _bt_emerg("[bind] FAIL: phase1 /bind_union/onlyA.txt did not read 'AAA'\n")
        ok = 0
    # The shared name resolves to A's copy while A is the only member.
    if _bt_resolve_reads(cast[Ptr[char]]("/bind_union/shared.txt"),
                         &from_a[0], 6) != 0:
        _bt_emerg("[bind] phase1 OK: /bind_union/shared.txt -> 'FROM-A'\n")
    else:
        _bt_emerg("[bind] FAIL: phase1 /bind_union/shared.txt did not read 'FROM-A'\n")
        ok = 0

    # --- Phase 2: UNION (MBEFORE) -----------------------------------
    # Add bind -b /bind_src_b -> /bind_union OVER the A bind. The
    # union point now stacks {B (MBEFORE, front), A (MREPL, base)}.
    r2: int32 = mnttab_bind(cast[Ptr[uint8]]("/bind_union"),
                            cast[Ptr[uint8]]("/bind_src_b"),
                            _BT_MBEFORE)
    if r2 < 0:
        _bt_emerg("[bind] FAIL: phase2 union mnttab_bind returned error\n")
        return 0
    # Both members visible: A's file still resolves...
    if _bt_resolve_reads(cast[Ptr[char]]("/bind_union/onlyA.txt"),
                         &aaa[0], 3) != 0:
        _bt_emerg("[bind] phase2 OK: union member A visible (/bind_union/onlyA.txt -> 'AAA')\n")
    else:
        _bt_emerg("[bind] FAIL: phase2 union member A lost (/bind_union/onlyA.txt)\n")
        ok = 0
    # ...AND B's file resolves through the SAME union point.
    if _bt_resolve_reads(cast[Ptr[char]]("/bind_union/onlyB.txt"),
                         &bbb[0], 3) != 0:
        _bt_emerg("[bind] phase2 OK: union member B visible (/bind_union/onlyB.txt -> 'BBB')\n")
    else:
        _bt_emerg("[bind] FAIL: phase2 union member B NOT visible (/bind_union/onlyB.txt)\n")
        ok = 0
    # The shared name now resolves to the MBEFORE member (B), shadowing A.
    if _bt_resolve_reads(cast[Ptr[char]]("/bind_union/shared.txt"),
                         &from_b[0], 6) != 0:
        _bt_emerg("[bind] phase2 OK: MBEFORE shadows base (/bind_union/shared.txt -> 'FROM-B')\n")
    else:
        _bt_emerg("[bind] FAIL: phase2 MBEFORE did not shadow (/bind_union/shared.txt != 'FROM-B')\n")
        ok = 0

    # --- Phase 3: UNMOUNT -------------------------------------------
    # Remove EVERYTHING at /bind_union. Afterwards no /bind_union/*
    # path resolves to a backing file — the bindings reverted.
    r3: int32 = mnttab_unmount(cast[Ptr[uint8]](0),
                               cast[Ptr[uint8]]("/bind_union"))
    if r3 < 0:
        _bt_emerg("[bind] FAIL: phase3 unmount returned error\n")
        ok = 0
    if _bt_resolves_to_source(cast[Ptr[char]]("/bind_union/onlyB.txt")) == 0:
        _bt_emerg("[bind] phase3 OK: post-unmount /bind_union/onlyB.txt no longer resolves\n")
    else:
        _bt_emerg("[bind] FAIL: phase3 /bind_union/onlyB.txt STILL resolves after unmount\n")
        ok = 0
    if _bt_resolves_to_source(cast[Ptr[char]]("/bind_union/onlyA.txt")) == 0:
        _bt_emerg("[bind] phase3 OK: post-unmount /bind_union/onlyA.txt no longer resolves\n")
    else:
        _bt_emerg("[bind] FAIL: phase3 /bind_union/onlyA.txt STILL resolves after unmount\n")
        ok = 0

    # --- Phase 4: PER-NAMESPACE ISOLATION ---------------------------
    # Clone a fresh Pgrp from the current one and swap the current task
    # onto it (the in-kernel analogue of rfork(RFNAMEG)). A bind in the
    # child Pgrp must be invisible after we restore the parent Pgrp.
    slot: int32 = current_idx_get()
    # Save the EXACT raw pgrp slot value so we restore the task to its
    # original namespace byte-for-byte (it may legitimately be 0 at this
    # boot stage — "default to root"). Clone from the RESOLVED parent
    # (pgrp_current collapses a 0 slot onto the root Pgrp) so the child
    # inherits the live root bindings.
    saved_raw_pg: uint64 = task_pgrp(slot)
    parent_pg: uint64 = pgrp_current()
    child_pg: uint64 = pgrp_clone(parent_pg)
    if child_pg == 0:
        _bt_emerg("[bind] FAIL: phase4 pgrp_clone returned 0\n")
        return 0
    set_task_pgrp(slot, child_pg)
    # Bind in the CHILD namespace only.
    r4: int32 = mnttab_bind(cast[Ptr[uint8]]("/iso_union"),
                            cast[Ptr[uint8]]("/bind_src_b"),
                            _BT_MREPL)
    if r4 < 0:
        _bt_emerg("[bind] FAIL: phase4 child mnttab_bind returned error\n")
        set_task_pgrp(slot, saved_raw_pg)
        pgrp_ref_dec(child_pg)
        return 0
    if _bt_resolve_reads(cast[Ptr[char]]("/iso_union/onlyB.txt"),
                         &bbb[0], 3) != 0:
        _bt_emerg("[bind] phase4 OK: child namespace sees its own bind (/iso_union/onlyB.txt -> 'BBB')\n")
    else:
        _bt_emerg("[bind] FAIL: phase4 child namespace bind not visible in child\n")
        ok = 0
    # Restore the PARENT namespace and confirm the child's bind is gone.
    set_task_pgrp(slot, saved_raw_pg)
    if _bt_resolves_to_source(cast[Ptr[char]]("/iso_union/onlyB.txt")) == 0:
        _bt_emerg("[bind] phase4 OK: parent namespace does NOT see child bind (isolation holds)\n")
    else:
        _bt_emerg("[bind] FAIL: phase4 child bind LEAKED into parent namespace\n")
        ok = 0
    # Drop the child Pgrp's reference now that the task is back on parent.
    pgrp_ref_dec(child_pg)

    # --- Phase 5: UNION (MAFTER) ------------------------------------
    # MAFTER is the reverse-precedence counterpart of MBEFORE: a member
    # added with `bind -a` is searched LAST, AFTER MREPL base members,
    # so it does NOT shadow shared names already served by the base.
    # Build a fresh union point /bind_union2 to keep this phase
    # independent of the earlier unmount.
    #   1. bind /bind_src_a -> /bind_union2 (MREPL = the base).
    #   2. bind -a /bind_src_b -> /bind_union2 (MAFTER, end of union).
    # Expected:
    #   * /bind_union2/onlyA.txt  -> 'AAA'    (base A still visible)
    #   * /bind_union2/onlyB.txt  -> 'BBB'    (MAFTER member visible)
    #   * /bind_union2/shared.txt -> 'FROM-A' (MREPL base wins; MAFTER
    #                                          searched after, does NOT
    #                                          shadow — the opposite of
    #                                          phase 2's MBEFORE result)
    r5a: int32 = mnttab_bind(cast[Ptr[uint8]]("/bind_union2"),
                             cast[Ptr[uint8]]("/bind_src_a"),
                             _BT_MREPL)
    if r5a < 0:
        _bt_emerg("[bind] FAIL: phase5 base MREPL mnttab_bind returned error\n")
        return 0
    r5b: int32 = mnttab_bind(cast[Ptr[uint8]]("/bind_union2"),
                             cast[Ptr[uint8]]("/bind_src_b"),
                             _BT_MAFTER)
    if r5b < 0:
        _bt_emerg("[bind] FAIL: phase5 MAFTER mnttab_bind returned error\n")
        return 0
    if _bt_resolve_reads(cast[Ptr[char]]("/bind_union2/onlyA.txt"),
                         &aaa[0], 3) != 0:
        _bt_emerg("[bind] phase5 OK: union base A visible (/bind_union2/onlyA.txt -> 'AAA')\n")
    else:
        _bt_emerg("[bind] FAIL: phase5 base A lost (/bind_union2/onlyA.txt)\n")
        ok = 0
    if _bt_resolve_reads(cast[Ptr[char]]("/bind_union2/onlyB.txt"),
                         &bbb[0], 3) != 0:
        _bt_emerg("[bind] phase5 OK: MAFTER member B visible (/bind_union2/onlyB.txt -> 'BBB')\n")
    else:
        _bt_emerg("[bind] FAIL: phase5 MAFTER member B NOT visible (/bind_union2/onlyB.txt)\n")
        ok = 0
    # Reverse-precedence assertion: MAFTER does NOT shadow the base.
    if _bt_resolve_reads(cast[Ptr[char]]("/bind_union2/shared.txt"),
                         &from_a[0], 6) != 0:
        _bt_emerg("[bind] phase5 OK: MAFTER does NOT shadow base (/bind_union2/shared.txt -> 'FROM-A')\n")
    else:
        _bt_emerg("[bind] FAIL: phase5 MAFTER WRONGLY shadowed base (/bind_union2/shared.txt != 'FROM-A')\n")
        ok = 0
    # Clean up so the test is rerun-safe.
    mnttab_unmount(cast[Ptr[uint8]](0),
                   cast[Ptr[uint8]]("/bind_union2"))

    # --- Phase 6: MCREATE — create-target selection ------------------
    # Build a union point /bind_union3 with two members:
    #   1. bind /bind_src_a -> /bind_union3 (MREPL base, NO MCREATE)
    #   2. bind -b /bind_src_b -> /bind_union3 (MBEFORE, MCREATE set)
    #
    # mnttab_any_mcreate_covers("/bind_union3/x") must report 1 (a
    # covering member has MCREATE). mnttab_create_target() must
    # pick member B's rewrite — "/bind_src_b/newfile.txt" — because
    # B is the only MCREATE-eligible member.
    r6a: int32 = mnttab_bind(cast[Ptr[uint8]]("/bind_union3"),
                             cast[Ptr[uint8]]("/bind_src_a"),
                             _BT_MREPL)
    if r6a < 0:
        _bt_emerg("[bind] FAIL: phase6 base MREPL mnttab_bind returned error\n")
        return 0
    # MBEFORE | MCREATE
    r6b: int32 = mnttab_bind(cast[Ptr[uint8]]("/bind_union3"),
                             cast[Ptr[uint8]]("/bind_src_b"),
                             _BT_MBEFORE | _BT_MCREATE)
    if r6b < 0:
        _bt_emerg("[bind] FAIL: phase6 MCREATE mnttab_bind returned error\n")
        return 0
    # Probe: ANY MCREATE member covering the union point?
    if mnttab_any_mcreate_covers(
            cast[Ptr[uint8]]("/bind_union3/newfile.txt")) == 1:
        _bt_emerg("[bind] phase6 OK: mnttab_any_mcreate_covers reports MCREATE present\n")
    else:
        _bt_emerg("[bind] FAIL: phase6 MCREATE probe returned 0\n")
        ok = 0
    # Target selection: should rewrite to /bind_src_b/newfile.txt.
    tgt_buf: Array[128, uint8]
    rc6t: int32 = mnttab_create_target(
        cast[Ptr[uint8]]("/bind_union3/newfile.txt"),
        &tgt_buf[0], 128)
    # mnttab_bind freezes the `old` argument through the caller's
    # namespace at bind time, so /bind_src_b is stored as the boot
    # server's server-anchored form `#r/bind_src_b` (cpio root in the
    # default boot namespace). The MCREATE-routed create-target is
    # therefore `#r/bind_src_b/newfile.txt`, not `/bind_src_b/...`.
    # That's the server-anchored namespace-independent shape every
    # downstream backend (cpio / tmpfs / 9P) consumes.
    if rc6t == 1 \
            and _bt_streq_n(&tgt_buf[0],
                            cast[Ptr[uint8]]("#r/bind_src_b/newfile.txt"),
                            25) != 0 \
            and tgt_buf[25] == 0:
        _bt_emerg("[bind] phase6 OK: mnttab_create_target picked MCREATE member B (#r/bind_src_b/newfile.txt)\n")
    else:
        # Diagnostic: print the actual rewrite so a future regression
        # is easy to track.
        _bt_emerg("[bind] FAIL: phase6 mnttab_create_target did not pick MCREATE member B\n")
        _bt_emerg("[bind] phase6 actual create_target buf: ")
        printk0(cast[Ptr[char]](&tgt_buf[0]))
        _bt_emerg("\n")
        ok = 0
    # Back-compat: a union point with NO MCREATE members reports 0
    # (caller falls back to legacy head-wins). Reuse /bind_union which
    # was unmounted in phase 3 — rebuild here without MCREATE.
    r6c: int32 = mnttab_bind(cast[Ptr[uint8]]("/bind_union_nc"),
                             cast[Ptr[uint8]]("/bind_src_a"),
                             _BT_MREPL)
    if r6c < 0:
        _bt_emerg("[bind] FAIL: phase6 back-compat bind returned error\n")
        return 0
    if mnttab_any_mcreate_covers(
            cast[Ptr[uint8]]("/bind_union_nc/x.txt")) == 0:
        _bt_emerg("[bind] phase6 OK: back-compat (no MCREATE) -> probe returns 0\n")
    else:
        _bt_emerg("[bind] FAIL: phase6 back-compat probe wrongly reported MCREATE\n")
        ok = 0
    if mnttab_create_target(
            cast[Ptr[uint8]]("/bind_union_nc/x.txt"),
            &tgt_buf[0], 128) == 0:
        _bt_emerg("[bind] phase6 OK: back-compat (no MCREATE) -> create_target returns 0 (legacy fallback)\n")
    else:
        _bt_emerg("[bind] FAIL: phase6 back-compat create_target did not return 0\n")
        ok = 0
    # Clean up.
    mnttab_unmount(cast[Ptr[uint8]](0),
                   cast[Ptr[uint8]]("/bind_union3"))
    mnttab_unmount(cast[Ptr[uint8]](0),
                   cast[Ptr[uint8]]("/bind_union_nc"))

    # --- Phase 7: MCACHE — stored-but-stub round-trip ----------------
    # MCACHE is intentionally a stub: there is no per-binding read
    # cache layer (the 9P client uses the global kernel page cache,
    # not a per-mount cache). The bit IS stored on the entry's
    # flag word though, so userland binds round-trip correctly and
    # later infrastructure (per-binding caches) can flip from probe
    # to honour without changing the bind ABI. This phase just
    # confirms a bind WITH MCACHE doesn't reject and still resolves
    # — i.e., MCACHE is harmless when stored.
    r7: int32 = mnttab_bind(cast[Ptr[uint8]]("/bind_union_c"),
                            cast[Ptr[uint8]]("/bind_src_a"),
                            _BT_MREPL | _BT_MCACHE)
    if r7 < 0:
        _bt_emerg("[bind] FAIL: phase7 MCACHE bind returned error\n")
        return 0
    if _bt_resolve_reads(cast[Ptr[char]]("/bind_union_c/onlyA.txt"),
                         &aaa[0], 3) != 0:
        _bt_emerg("[bind] phase7 OK: MCACHE-flagged bind still resolves (stub stored, harmless)\n")
    else:
        _bt_emerg("[bind] FAIL: phase7 MCACHE-flagged bind broke resolution\n")
        ok = 0
    mnttab_unmount(cast[Ptr[uint8]](0),
                   cast[Ptr[uint8]]("/bind_union_c"))

    if ok == 1:
        _bt_emerg("[bind] PASS\n")
        return 1
    _bt_emerg("[bind] FAIL: one or more assertions failed\n")
    return 0

# sys/src/9/port/devsnarf.ad
#
# Layer 1 (Plan 9-shape) global clipboard device — /dev/snarf.
#
# Plan 9 precedent: /dev/snarf is the global one-buffer clipboard. A
# writer replaces the buffer wholesale; a reader gets back the most
# recently written content. Offset-addressed reads so `cat /dev/snarf`
# terminates at EOF instead of regenerating forever.
#
# Surface:
#   read   -> snarf_buf[off..snarf_len)        (no trailing newline added)
#   write  -> snarf_buf[0..min(count, MAX)]    (REPLACES, not appends)
#
# Sizing: SNARF_MAX = 65536 (64 KiB). Writes past this are TRUNCATED
# (the kernel reports `count` consumed so userland's write loop
# terminates — the clipped tail is intentionally dropped, matching the
# devhostname/keymap convention for over-long writes).
#
# Persistence: kernel-RAM only. Survives until reboot.
#
# Adder-quirk note: shared-shape helpers carry the `_sn_` prefix to
# dodge the flat-namespace `_emit_str` collision class.

SNARF_MAX: uint64 = 65536          # 64 KiB cap

snarf_buf: Array[65536, uint8]
snarf_len: uint64 = 0


def devsnarf_read(off: uint64, buf: Ptr[uint8],
                  count: uint64) -> int64:
    # Offset-addressed read of the clipboard. Honours `off` so a chunked
    # reader (cat with a small block size) can stream the whole buffer
    # and reach EOF cleanly. Returns 0 (EOF) once off >= snarf_len.
    if off >= snarf_len:
        return 0
    avail: uint64 = snarf_len - off
    take: uint64 = count
    if take > avail:
        take = avail
    i: uint64 = 0
    while i < take:
        buf[i] = snarf_buf[off + i]
        i = i + 1
    return cast[int64](take)


def devsnarf_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Replace the clipboard with the caller's bytes. A 0-byte write
    # CLEARS the clipboard — symmetric with Plan 9 semantics (writing
    # nothing means "the clipboard is now empty"). Writes longer than
    # SNARF_MAX are truncated at the cap; we still report `count`
    # consumed so userland's write loop terminates.
    take: uint64 = count
    if take > SNARF_MAX:
        take = SNARF_MAX
    i: uint64 = 0
    while i < take:
        snarf_buf[i] = buf[i]
        i = i + 1
    snarf_len = take
    return cast[int64](count)

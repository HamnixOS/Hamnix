# sys/src/9/port/chan.ad
#
# Phase C / M16.107 + V2 — Plan 9 channel + per-namespace mount table.
# Mirrors the data structures at the top of 9front's chan.c (`Chan`,
# `Mhead`, `Mount`) plus the per-process namespace machinery that lets
# `rfork(RFNAMEG)` give the child a divergent view.
#
# V0 (codec) and V1 (in-kernel 9P client) used ONE global 32-entry
# mount table with a per-entry `namespace_id` that was "visible to
# everyone whose namespace_id matches OR is zero". That was enough
# for a single root namespace; it does NOT actually isolate two
# tasks because both still wrote into the same global table.
#
# V2 replaces the global with a POOL OF PER-NAMESPACE TABLES:
#
#   ns_pool[NS_MAX][MNTTAB_PER_NS] entries
#   ns_alloc[NS_MAX] = refcount per slot
#
# `namespace_id` (carried in TaskStruct.namespace_id and surfaced via
# current_namespace_id()) is the FIRST dimension index. Two tasks
# with different namespace_ids look at completely different rows of
# the pool — that's the literal Plan 9 semantic: `bind` in the child
# does not perturb the parent's view.
#
# Inheritance contract (matches Plan 9's rfork(2)):
#
#   * Default (no RFNAMEG): child shares the parent's namespace_id
#     and therefore sees the EXACT same row. Subsequent bind() in
#     either task is visible to both.
#
#   * RFNAMEG: ns_clone() allocates a fresh slot, deep-copies the
#     parent's row into it byte-for-byte, and returns the new id.
#     The child's namespace_id is set to that. After the fork, the
#     two rows are independent — bind() in the child doesn't touch
#     the parent's row, and vice versa. Same shape as 9front's
#     Pgrp/Mhead split on rfork.
#
#   * RFCNAMEG: child gets a fresh, EMPTY namespace. Cleared row.
#
# Adder quirks honoured here:
#
#   * 2-D arrays inside nested frames mis-codegen — we keep the pool
#     as a 1-D Array at TOP LEVEL and index manually with
#     `ns * MNTTAB_PER_NS + slot`. Same pattern p9_client.ad uses for
#     its component path storage.
#
#   * NS_MAX = 8 namespaces, MNTTAB_PER_NS = 8 entries per namespace.
#     Total pool footprint ~17 KB (each MountEntry inlines two 128-
#     byte paths). This is generous for V2's test fixture (init +
#     one child + plenty of headroom); V3 can grow either dimension
#     when distrorun-shape workloads start nesting more deeply.
#
# What we deliberately punt to V3+:
#
#   * Refcount-based GC of empty namespaces. We bump a refcount on
#     share/inherit and decrement on do_exit, but freed slots stay
#     pinned at refcount 0 until the next ns_clone reclaims them
#     (which it does — the allocator scans for refcount==0 slots
#     and overwrites). Effectively LRU; sufficient for V2.
#
#   * Union-mount flag bits (MBEFORE / MAFTER). V2 honours MREPL
#     only — same as V1.

from kernel.sched.core import (
    TaskStruct, current_task, current_idx_get,
    task_namespace_id, current_namespace_id,
)


# Chan kind discriminator. CHAN_KIND_NONE marks an unused chan
# slot — useful because Adder zero-inits class fields, so a fresh
# Chan compares as "not yet attached" without explicit construction.
CHAN_KIND_NONE: int32 = 0
CHAN_KIND_FILE: int32 = 1                # bind() — resolves to a path
CHAN_KIND_SRV:  int32 = 2                # mount() — wraps a srvfd


class Chan:
    kind:        int32                   # CHAN_KIND_*
    srvfd:       int32                   # fd handed to mount(); -1 for FILE
    # Reserved for Phase D: qid, version, offset, ops vtable, refcount.
    # We grow this struct alongside the 9P client; for now keep it
    # minimal so the field offsets don't shift under sysfile.ad's
    # _write_dir_record consumers.
    flags:       int32                   # mirror of MREPL/MBEFORE/MAFTER
    # V1: post-attach root fid handed back by p9c_attach_run. -1 for
    # FILE-kind (bind) entries; populated for SRV-kind (mount) entries
    # after a successful Tversion + Tattach handshake.
    p9_root_fid: int32                   # 0..31 on success, -1 otherwise


# Mount-table entry. `from_path` and `to_path` are inlined fixed-size
# buffers (Adder doesn't have a string heap in the kernel; per-entry
# Array[uint8] is the same shape sysfile.ad uses for its synthetic
# /dev/<name> bookkeeping).
#
# Note: as of V2, MountEntry no longer carries a per-entry namespace_id
# field — the namespace dimension lives in the OUTER pool index (the
# row this entry sits in). The slot is identified by (ns, idx)
# coordinates, and visibility is the row, not a tag.
class MountEntry:
    in_use:        int32                 # 0 = free slot, 1 = live
    flag:          int32                 # MREPL / MBEFORE / MAFTER
    pad0:          int32                 # 8-byte alignment for the chan
    pad1:          int32
    chan:          Chan                  # SRV chan for mount(); zeroed for bind()
    from_path:     Array[128, uint8]     # path bound (the "new" arg)
    to_path:       Array[128, uint8]     # path it resolves to (the "old" arg)


# Per-namespace table cap. 8 namespaces, 8 entries each. The 2-D
# semantics are baked into manual indexing — see _entry_at(ns, slot).
NS_MAX:          uint64 = 8
MNTTAB_PER_NS:   uint64 = 8
MNTTAB_TOTAL:    uint64 = 64                  # NS_MAX * MNTTAB_PER_NS

# Flattened 2-D pool. ns_pool[ns * MNTTAB_PER_NS + slot] picks an
# entry. Stored at top level to dodge Adder's nested-frame Array bug.
ns_pool: Array[64, MountEntry]

# Per-namespace refcount. ns_alloc[n] == 0 means the slot is free for
# ns_clone() to reclaim; >0 means at least one task references it.
# Slot 0 is the root namespace, pinned by init at boot.
ns_alloc: Array[8, int32]

# Boot-time initialisation flag for the root namespace. Set on the
# first chan_init / first ns_get_or_init_root call. We can't bump
# ns_alloc[0] from a top-level statement (Adder runs no static
# initialisers beyond zero-fill), so we lazily mark root live on the
# first taskful reference.
ns_root_pinned: int32 = 0


# --- string helpers -------------------------------------------------

def _strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _copy_path_into(dst: Ptr[uint8], cap: uint64,
                    src: Ptr[uint8]) -> int32:
    # Copy NUL-terminated src into dst[0..cap], NUL-terminating.
    # Returns 0 on success, -1 if src wouldn't fit (caller surfaces
    # as "path too long" errstr).
    i: uint64 = 0
    while i < cap:
        c: uint8 = src[i]
        dst[i] = c
        if c == 0:
            return 0
        i = i + 1
    # Ran off the end without finding a NUL.
    if cap > 0:
        dst[cap - 1] = 0
    return -1


def _path_eq_u8(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    # NUL-terminated equality. Returns 1 on match, 0 otherwise.
    i: uint64 = 0
    while True:
        ca: uint8 = a[i]
        cb: uint8 = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1


# --- pool indexing --------------------------------------------------

def _entry_idx(ns: uint64, slot: uint64) -> uint64:
    # Manual 2-D flatten. ns < NS_MAX, slot < MNTTAB_PER_NS.
    return ns * MNTTAB_PER_NS + slot


def _ns_valid(ns: int32) -> int32:
    if ns < 0:
        return 0
    if cast[uint64](ns) >= NS_MAX:
        return 0
    return 1


def _zero_entry(ns: uint64, slot: uint64):
    idx: uint64 = _entry_idx(ns, slot)
    ns_pool[idx].in_use            = 0
    ns_pool[idx].flag              = 0
    ns_pool[idx].chan.kind         = CHAN_KIND_NONE
    ns_pool[idx].chan.srvfd        = -1
    ns_pool[idx].chan.flags        = 0
    ns_pool[idx].chan.p9_root_fid  = -1
    ns_pool[idx].from_path[0]      = 0
    ns_pool[idx].to_path[0]        = 0


def _zero_ns_row(ns: uint64):
    s: uint64 = 0
    while s < MNTTAB_PER_NS:
        _zero_entry(ns, s)
        s = s + 1


def _copy_entry(src_ns: uint64, src_slot: uint64,
                dst_ns: uint64, dst_slot: uint64):
    # Field-by-field deep copy. Both `from_path` and `to_path` are
    # inline 128-byte buffers so a memcpy-style loop is correct.
    si: uint64 = _entry_idx(src_ns, src_slot)
    di: uint64 = _entry_idx(dst_ns, dst_slot)
    ns_pool[di].in_use            = ns_pool[si].in_use
    ns_pool[di].flag              = ns_pool[si].flag
    ns_pool[di].chan.kind         = ns_pool[si].chan.kind
    ns_pool[di].chan.srvfd        = ns_pool[si].chan.srvfd
    ns_pool[di].chan.flags        = ns_pool[si].chan.flags
    ns_pool[di].chan.p9_root_fid  = ns_pool[si].chan.p9_root_fid
    i: uint64 = 0
    while i < 128:
        ns_pool[di].from_path[i] = ns_pool[si].from_path[i]
        ns_pool[di].to_path[i]   = ns_pool[si].to_path[i]
        i = i + 1


# --- public surface --------------------------------------------------

def chan_init():
    # Idempotent: zero the entire pool and mark the root namespace
    # live. Called by start_kernel before the first task ever runs;
    # subsequent calls re-zero (useful for a future warm-reset path).
    n: uint64 = 0
    while n < NS_MAX:
        _zero_ns_row(n)
        ns_alloc[n] = 0
        n = n + 1
    # Pin the root namespace (slot 0) with refcount 1. init's task
    # starts with namespace_id == 0; that's the slot we reserve.
    ns_alloc[0] = 1
    ns_root_pinned = 1


def _ensure_root_pinned():
    # Defensive: if chan_init was never called (BSS still zero from
    # boot), the root namespace's refcount is 0 even though task 0
    # references it. Lazy-fix on the first chan.ad call from a task.
    if ns_root_pinned == 0:
        ns_alloc[0] = 1
        ns_root_pinned = 1


def chan_attach(srvfd: int32, spec: Ptr[uint8],
                out: Ptr[Chan]) -> int32:
    # Phase C stub: produce a Chan that wraps the supplied srvfd.
    # Phase D grows this into a real 9P Tversion + Tattach exchange
    # over the srvfd; for now we just record the fd and return.
    # `spec` is ignored at this milestone (the Plan 9 attach spec
    # selects which file tree a multi-tree server exposes; Hamnix
    # has no 9P server, no trees, no spec to honour).
    if out == cast[Ptr[Chan]](0):
        return -1
    out[0].kind        = CHAN_KIND_SRV
    out[0].srvfd       = srvfd
    out[0].flags       = 0
    out[0].p9_root_fid = -1                  # populated by syschan after Tattach
    return 0


def chan_walk(c: Ptr[Chan], path: Ptr[uint8]) -> Ptr[Chan]:
    # Phase C stub: no walking. The mount table maps prefixes, not
    # paths, so resolve_path's longest-prefix match is the only
    # walking we need at this milestone. Phase D's 9P Twalk lands
    # here once chan_attach knows how to speak the wire.
    return c


# --- namespace allocation / lifecycle -------------------------------

def _current_ns_safe() -> uint64:
    # Fetch the calling task's namespace_id and clamp it into the
    # valid pool range. A task that ended up with a negative id
    # (RFCNAMEG -> -1 today, until V2's empty-ns slot machinery
    # below replaces that) is mapped to a private freshly-allocated
    # ns the FIRST TIME it bind/mount/unmounts something. Until
    # then, reads against it surface as "no visible entries" — the
    # right shape because the task explicitly asked for empty.
    _ensure_root_pinned()
    raw: int32 = current_namespace_id()
    if _ns_valid(raw) == 0:
        return 0                              # collapse oob to root for reads
    return cast[uint64](raw)


def ns_clone(parent_ns: int32) -> int32:
    # Allocate a fresh namespace slot, deep-copy every entry from
    # `parent_ns` into it. Returns the new slot id (0..NS_MAX-1) on
    # success or -1 if the pool is full.
    #
    # The new slot starts with refcount 1 — the caller (sysproc's
    # _rfork_setup_namespace) is the sole referer until we observe
    # additional rfork-share calls.
    _ensure_root_pinned()
    # Find a free slot (refcount == 0). Skip 0 — that's root, pinned.
    n: uint64 = 1
    new_slot: int32 = -1
    while n < NS_MAX:
        if ns_alloc[n] == 0:
            new_slot = cast[int32](n)
            break
        n = n + 1
    if new_slot < 0:
        return -1
    new_ns: uint64 = cast[uint64](new_slot)
    # Zero the destination row before copy — slots reclaimed from a
    # previous tenant may carry stale entries.
    _zero_ns_row(new_ns)
    # Deep-copy when parent is a valid in-range ns. RFCNAMEG-style
    # callers will pass -1 here; we honour that as "clone an empty
    # namespace" by skipping the copy.
    if _ns_valid(parent_ns) != 0:
        pns: uint64 = cast[uint64](parent_ns)
        s: uint64 = 0
        while s < MNTTAB_PER_NS:
            if ns_pool[_entry_idx(pns, s)].in_use != 0:
                _copy_entry(pns, s, new_ns, s)
            s = s + 1
    ns_alloc[new_ns] = 1
    return new_slot


def ns_alloc_empty() -> int32:
    # RFCNAMEG-shape: fresh namespace with NO inherited entries.
    # Equivalent to ns_clone(<any source>) followed by zeroing the
    # row, but expressed as a separate entrypoint so the caller
    # doesn't have to fabricate a fake parent.
    return ns_clone(-1)


def ns_inc_ref(ns: int32) -> int32:
    # Bump refcount when a fresh task inherits an existing ns
    # (rfork without RFNAMEG). Returns the new refcount or -1 if
    # the ns id is out of range.
    if _ns_valid(ns) == 0:
        return -1
    nu: uint64 = cast[uint64](ns)
    ns_alloc[nu] = ns_alloc[nu] + 1
    return ns_alloc[nu]


def ns_dec_ref(ns: int32) -> int32:
    # Drop refcount on task exit. When refcount hits 0, the slot is
    # eligible for ns_clone() reuse — we leave the entries in place
    # (a fresh ns_clone zeroes them before re-populating) so the GC
    # has no extra cost. Returns the new refcount, or -1 on oob, or
    # -1 if the refcount was already 0 (programming error: more
    # exits than inherits).
    if _ns_valid(ns) == 0:
        return -1
    nu: uint64 = cast[uint64](ns)
    # Refuse to underflow root. The root namespace is pinned for the
    # life of the kernel; init never exits.
    if nu == 0:
        return ns_alloc[0]
    if ns_alloc[nu] <= 0:
        return -1
    ns_alloc[nu] = ns_alloc[nu] - 1
    return ns_alloc[nu]


# --- mount-table operations -----------------------------------------

def _mnttab_find_free(ns: uint64) -> int32:
    # Linear scan within the namespace's row for an in_use==0 slot.
    # Returns -1 if the row is full.
    s: uint64 = 0
    while s < MNTTAB_PER_NS:
        if ns_pool[_entry_idx(ns, s)].in_use == 0:
            return cast[int32](s)
        s = s + 1
    return -1


def _entry_visible(ns: uint64, slot: uint64) -> int32:
    # In V2, an entry is visible iff it lives in the caller's
    # namespace row AND is in_use. Pre-V2 the global table also
    # surfaced "shared" entries (namespace_id == 0) to every task;
    # that "shared default" semantic is gone now — each namespace
    # is its own row, no implicit overlay.
    if ns_pool[_entry_idx(ns, slot)].in_use == 0:
        return 0
    return 1


def mnttab_bind(new_path: Ptr[uint8], old_path: Ptr[uint8],
                flag: int32) -> int32:
    # Add a `new_path -> old_path` binding into the calling task's
    # namespace row. Returns 0 on success, -1 if the row is full.
    ns: uint64 = _current_ns_safe()
    slot: int32 = _mnttab_find_free(ns)
    if slot < 0:
        return -1
    su: uint64 = cast[uint64](slot)
    idx: uint64 = _entry_idx(ns, su)
    if _copy_path_into(&ns_pool[idx].from_path[0], 128, new_path) < 0:
        return -1
    if _copy_path_into(&ns_pool[idx].to_path[0], 128, old_path) < 0:
        return -1
    ns_pool[idx].in_use       = 1
    ns_pool[idx].flag         = flag
    ns_pool[idx].chan.kind    = CHAN_KIND_FILE
    ns_pool[idx].chan.srvfd   = -1
    ns_pool[idx].chan.flags   = flag
    ns_pool[idx].chan.p9_root_fid = -1
    return 0


def mnttab_mount(srvfd: int32, old_path: Ptr[uint8],
                 flag: int32, spec: Ptr[uint8]) -> int32:
    # Same shape as mnttab_bind, but the "from" side is a SRV chan
    # wrapping srvfd, not a path. Resolves under `old_path` dispatch
    # through the chan once Phase D wires the 9P client; for this
    # milestone the SRV-mount path lives in fs/vfs.ad.
    ns: uint64 = _current_ns_safe()
    slot: int32 = _mnttab_find_free(ns)
    if slot < 0:
        return -1
    su: uint64 = cast[uint64](slot)
    idx: uint64 = _entry_idx(ns, su)
    if _copy_path_into(&ns_pool[idx].from_path[0], 128, old_path) < 0:
        return -1
    # Clear to_path so a future chan walk doesn't accidentally hit
    # a stale fall-through buffer.
    ns_pool[idx].to_path[0] = 0
    if chan_attach(srvfd, spec, &ns_pool[idx].chan) < 0:
        return -1
    ns_pool[idx].in_use       = 1
    ns_pool[idx].flag         = flag
    return 0


def mnttab_unmount(new_path: Ptr[uint8],
                   old_path: Ptr[uint8]) -> int32:
    # Remove bindings. Two shapes per the Plan 9 contract:
    #
    #   * new_path == NULL  -> remove every binding visible at
    #                          old_path (regardless of where they
    #                          resolve to).
    #   * new_path != NULL  -> remove the specific
    #                          new_path -> old_path edge.
    #
    # Returns 0 on success (>= 1 entry removed) or -1 if no match.
    ns: uint64 = _current_ns_safe()
    removed: int32 = 0
    s: uint64 = 0
    while s < MNTTAB_PER_NS:
        if _entry_visible(ns, s) != 0:
            keep: int32 = 1
            idx: uint64 = _entry_idx(ns, s)
            if new_path == cast[Ptr[uint8]](0):
                # Unmount-all-at: from_path matches old_path.
                if _path_eq_u8(&ns_pool[idx].from_path[0], old_path) != 0:
                    keep = 0
            else:
                # Specific edge: from_path == new AND to_path == old.
                # SRV mounts (chan.kind == CHAN_KIND_SRV) have an
                # empty stored to_path; treat that as a match against
                # any old_path for the rare "unmount-one-srv" call.
                if _path_eq_u8(&ns_pool[idx].from_path[0], new_path) != 0:
                    if ns_pool[idx].chan.kind == CHAN_KIND_SRV \
                            and ns_pool[idx].to_path[0] == 0:
                        keep = 0
                    elif _path_eq_u8(&ns_pool[idx].to_path[0], old_path) != 0:
                        keep = 0
            if keep == 0:
                _zero_entry(ns, s)
                removed = removed + 1
        s = s + 1
    if removed == 0:
        return -1
    return 0


# --- resolve_path hook ----------------------------------------------
#
# fs/vfs.ad calls chan_resolve_prefix() before its cpio / tmpfs /
# procfs / ext4 routing. We walk the live mount entries in the
# calling task's namespace row, find the LONGEST `from_path` that
# is a prefix of `input` followed by either NUL or '/' (so /sysroot
# doesn't spuriously match /sysroot2), and rewrite the prefix to
# the entry's `to_path`. The rewritten path replaces `input` in
# `output[0..]` and we return 1; on no-match the caller writes its
# own normalized output and we return 0.

def _prefix_match_len(idx: uint64, input: Ptr[uint8]) -> uint64:
    # If entry's from_path is a prefix of input (followed by NUL or
    # '/' in input), return the prefix length. Else return 0.
    fp: Ptr[uint8] = &ns_pool[idx].from_path[0]
    flen: uint64 = _strlen_u8(fp)
    if flen == 0:
        return 0
    i: uint64 = 0
    while i < flen:
        if input[i] == 0:
            return 0
        if input[i] != fp[i]:
            return 0
        i = i + 1
    # Byte at position flen must be NUL or '/'.
    next_byte: uint8 = input[flen]
    if next_byte == 0 or next_byte == 47:        # '/'
        return flen
    return 0


def chan_resolve_prefix(input: Ptr[uint8],
                        output: Ptr[uint8],
                        cap: uint64) -> int32:
    # Returns 1 if a mount entry rewrote the prefix into `output`,
    # 0 if no match, -1 if the rewrite would exceed `cap` bytes.
    #
    # Picks the longest from_path prefix among entries visible in
    # the calling task's namespace row. Ties (two entries with the
    # same from_path) are resolved in favour of the most recently
    # bound — naturally the higher slot index, since _mnttab_find_free
    # scans low-to-high.
    ns: uint64 = _current_ns_safe()
    best_slot: int32 = -1
    best_len: uint64 = 0
    s: uint64 = 0
    while s < MNTTAB_PER_NS:
        if _entry_visible(ns, s) != 0:
            idx: uint64 = _entry_idx(ns, s)
            # Skip SRV mounts — their on-disk fall-through doesn't
            # exist (no 9P client yet from the resolve_path side).
            # SRV lookups go through chan_find_srv_prefix instead.
            if ns_pool[idx].chan.kind == CHAN_KIND_FILE:
                m: uint64 = _prefix_match_len(idx, input)
                if m > best_len:
                    best_len = m
                    best_slot = cast[int32](s)
        s = s + 1
    if best_slot < 0:
        return 0
    # Build output = to_path + (input + best_len).
    bu: uint64 = _entry_idx(ns, cast[uint64](best_slot))
    tp: Ptr[uint8] = &ns_pool[bu].to_path[0]
    tplen: uint64 = _strlen_u8(tp)
    if tplen >= cap:
        return -1
    j: uint64 = 0
    while j < tplen:
        output[j] = tp[j]
        j = j + 1
    si: uint64 = best_len
    while j + 1 < cap and input[si] != 0:
        output[j] = input[si]
        j = j + 1
        si = si + 1
    if input[si] != 0:
        return -1
    output[j] = 0
    return 1


# --- SRV-mount lookup for the VFS dispatcher ----------------------
#
# fs/vfs.ad consults these on every open / read / write / close to
# decide whether a path lives behind a 9P SRV chan. Returns the
# (srvfd, root_fid, prefix_len) triple via output pointers so the
# caller can compute the relative path from the absolute one.

def chan_find_srv_prefix(input: Ptr[uint8],
                         out_srvfd: Ptr[int32],
                         out_root_fid: Ptr[int32],
                         out_prefix_len: Ptr[uint64]) -> int32:
    # Walk the calling task's namespace row for the longest SRV-kind
    # from_path prefix of `input`. Returns 1 on hit, 0 on miss.
    ns: uint64 = _current_ns_safe()
    best_slot: int32 = -1
    best_len: uint64 = 0
    s: uint64 = 0
    while s < MNTTAB_PER_NS:
        if _entry_visible(ns, s) != 0:
            idx: uint64 = _entry_idx(ns, s)
            if ns_pool[idx].chan.kind == CHAN_KIND_SRV:
                m: uint64 = _prefix_match_len(idx, input)
                if m > best_len:
                    best_len = m
                    best_slot = cast[int32](s)
        s = s + 1
    if best_slot < 0:
        return 0
    bu: uint64 = _entry_idx(ns, cast[uint64](best_slot))
    out_srvfd[0]      = ns_pool[bu].chan.srvfd
    out_root_fid[0]   = ns_pool[bu].chan.p9_root_fid
    out_prefix_len[0] = best_len
    return 1


def chan_set_p9_root_fid_by_srvfd(srvfd: int32, root_fid: int32) -> int32:
    # Locate the SRV-kind mount entry in the calling task's namespace
    # whose srvfd matches and stamp its p9_root_fid. Returns 0 on
    # success, -1 if no entry matched. syschan.ad calls this right
    # after a successful p9c_attach_run so subsequent VFS lookups see
    # the live fid.
    ns: uint64 = _current_ns_safe()
    s: uint64 = 0
    while s < MNTTAB_PER_NS:
        idx: uint64 = _entry_idx(ns, s)
        if ns_pool[idx].in_use != 0 \
                and ns_pool[idx].chan.kind == CHAN_KIND_SRV \
                and ns_pool[idx].chan.srvfd == srvfd:
            ns_pool[idx].chan.p9_root_fid = root_fid
            return 0
        s = s + 1
    return -1


# --- introspection / debug -----------------------------------------
#
# Tiny helpers used by tests + future /proc/mounts renderer. Kept
# minimal so chan.ad stays focused on the data model.

def mnttab_entry_count() -> uint64:
    # Total live entries across ALL namespaces. Used by tests that
    # validate "the table cleared after unmount".
    n: uint64 = 0
    i: uint64 = 0
    while i < MNTTAB_TOTAL:
        if ns_pool[i].in_use != 0:
            n = n + 1
        i = i + 1
    return n


def mnttab_entry_count_ns(ns: int32) -> uint64:
    # Live entries visible to `ns`. -1 maps to "empty namespace" -> 0.
    if _ns_valid(ns) == 0:
        return 0
    nu: uint64 = cast[uint64](ns)
    n: uint64 = 0
    s: uint64 = 0
    while s < MNTTAB_PER_NS:
        if ns_pool[_entry_idx(nu, s)].in_use != 0:
            n = n + 1
        s = s + 1
    return n

# sys/src/9/port/chan.ad
#
# Phase C / M16.107 + V2.75 — Plan 9 channel + per-process group (Pgrp)
# mount table. Mirrors the data structures at the top of 9front's
# chan.c (`Chan`, `Mhead`, `Mount`) plus the Plan 9 `Pgrp` struct —
# the process group whose primary content is a mount table and a
# refcount. Two tasks pointing at the same Pgrp share their mount
# view; rfork(RFNAMEG) gives the child a CLONED Pgrp whose mount
# view diverges from then on.
#
# History:
#
#   V0 (codec) + V1 (in-kernel 9P client) used ONE global 32-entry
#   mount table — fine for a single root namespace, did not isolate
#   per-task views.
#
#   V2 lifted the table into a pool indexed by a per-task
#   `namespace_id`: ns_pool[NS_MAX * MNTTAB_PER_NS] plus a parallel
#   ns_alloc[NS_MAX] refcount array. The semantics were Plan 9-correct
#   (per-task divergent views) but the data shape was Linux-flavoured:
#   a bare int handle into two parallel arrays.
#
#   V2.5 lifted the shape to a real `Pgrp` struct owning its inline
#   mount table and refcount, but stored Pgrps in a fixed
#   `pgrp_pool: Array[64, Pgrp]` indexed by `TaskStruct.pgrp_idx`.
#   The agent justified the pool with "Adder lacks a heap allocator"
#   — which was wrong: `mm/slab.ad` ships kmalloc / kzalloc / kfree
#   and was already imported by 8+ kernel modules.
#
# V2.75 (this revision) replaces the fixed pool with real heap
# allocation. `TaskStruct.pgrp` is now a true pointer (parked as
# uint64 because Adder's struct-pointer story is "cast through
# uint64"); each Pgrp is its own kzalloc'd object whose lifetime is
# tracked by the refcount field embedded at the head. ref==0 fires
# kfree, returning the storage to slab/page_alloc — no more pool cap,
# no more "slot N is free" bookkeeping. Plan 9-shape end to end.
#
# Inheritance contract (matches Plan 9's rfork(2)):
#
#   * Default (no RFNAMEG): child inherits the parent's pgrp pointer
#     verbatim and we ref_inc the Pgrp. Both tasks see the EXACT same
#     struct. Subsequent bind() in either task is visible to both.
#
#   * RFNAMEG: pgrp_clone() kmallocs a fresh Pgrp, deep-copies the
#     parent's mtab into it byte-for-byte, ref=1 on the new struct.
#     Parent's Pgrp refcount is unchanged (parent keeps its own
#     reference; only the child's pointer is replaced).
#
#   * RFCNAMEG: child gets a fresh, EMPTY Pgrp (kzalloc — mtab is
#     already zeroed, ref=1).
#
# Adder quirks honoured here:
#
#   * 2-D arrays inside nested frames mis-codegen — Pgrp's inline
#     `Array[32, MountEntry]` is a struct FIELD (not a local), so the
#     array bug doesn't apply.
#
#   * Adder has no `sizeof` operator. We hardcode PGRP_SIZE below;
#     a mismatch with the struct definition would surface as the
#     allocator handing back too small a region (and the very first
#     deep mtab write would clobber the slab next-pointer). Keep the
#     constant in sync with the struct layout.
#
#   * MNT_CAP = 32 entries per Pgrp. The distro-shape namespace
#     fixture plants 9 bindings; 32 leaves comfortable headroom for
#     nested binds inside a distro shell session. Each Pgrp now
#     costs ~9 KB, kmalloc'd on demand instead of pre-reserved.
#
# What we deliberately punt to V3+:
#
#   * Union-mount flag bits (MBEFORE / MAFTER). V2.75 honours MREPL
#     only — same as V1 / V2 / V2.5.

from kernel.sched.core import (
    TaskStruct, current_task, current_idx_get,
    task_pgrp, current_pgrp,
)
# V3: devsrv table is populated at the same chan.ad boot hook as the
# root Pgrp. Co-init keeps the "what's live on the namespace surface
# at boot" question answerable from a single call (chan_init / pgrp_init).
from sys.src.port9.port.devsrv import devsrv_init
# V2.75: real heap allocator. kzalloc gives us a zeroed region; kfree
# returns it to the slab / page allocator.
from mm.slab import kzalloc, kfree
# 9P connection lifecycle. A SRV-kind mount entry is the namespace-side
# OWNER of an in-kernel 9P connection (keyed by srvfd in 9p_client.ad's
# p9_conns table). Cloning a SRV entry across rfork(RFNAMEG) adds an
# owner (p9c_conn_owner_inc); tearing one down — by unmount or because
# the owning Pgrp is being freed — drops one (p9c_detach). When the
# last owner goes, p9c_detach reclaims the p9_conns slot, which is the
# fix for the connection-table leak that wedged a second nsrun.
from sys.src.port9.port.9p_client import (
    p9c_detach, p9c_conn_owner_inc,
)
# HAMSH §7: the `#d` fd device keeps a per-Pgrp /fd-name table as a
# side structure. A Pgrp's /fd table is COW-copied when the Pgrp is
# cloned (rfork RFNAMEG) and released when the Pgrp's last referer is
# gone — so the device must be told at both lifecycle points. These
# are the only two hooks; devfd.ad does not otherwise touch chan.ad.
from sys.src.port9.port.devfd import devfd_clone_row, devfd_free_row
# Named file-server stack uses printk for "reject loudly on overflow"
# per docs/rootfs_partition.md "Future direction — Stack semantics".
from kernel.printk.printk import printk0, printk1, printk_set_level
# F10-10 (#457): pgrp_oomadj_selftest emits a high-level PASS/FAIL banner
# the test harness greps for, so it bumps the printk level to EMERG the
# same way the per-task oomadj_selftest does in kernel/sched/core.ad.
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG


# Chan kind discriminator. CHAN_KIND_NONE marks an unused chan
# slot — useful because Adder zero-inits class fields, so a fresh
# Chan compares as "not yet attached" without explicit construction.
CHAN_KIND_NONE: int32 = 0
CHAN_KIND_FILE: int32 = 1                # bind() — resolves to a path
CHAN_KIND_SRV:  int32 = 2                # mount() — wraps a srvfd


# --- Plan 9 bind/mount flag bits (canonical names) ------------------
#
# Mirrors 9front <sys/dir.h>. The MORDER band (low 2 bits) controls
# union-member ordering inside ns_walk; MCREATE / MCACHE are upper
# bits that layer on top.
#
#   MREPL   (0) — replace any existing union at the bind point. The
#                 default. mnttab_bind/_mount zap same-name entries
#                 first when this band is selected.
#   MBEFORE (1) — push to the FRONT of the union; searched
#                 newest-first. Shadows the base for shared names.
#   MAFTER  (2) — push to the END of the union; searched after the
#                 base. Does NOT shadow shared names already served
#                 by the base.
#   MCREATE (4) — this binding participates in create lookups. If
#                 ANY union member at a name has MCREATE set, creates
#                 at that name are restricted to MCREATE members
#                 (highest-priority MCREATE member wins). If NO
#                 member has MCREATE set, the legacy head-wins
#                 behavior applies (back-compat for binds that
#                 omitted the flag). Honored by mnttab_create_target.
#   MCACHE  (8) — STUB. Plan 9 caches Tread results client-side per
#                 binding; Hamnix has no per-binding read cache yet
#                 (the 9P client has a global page cache via the
#                 kernel buffer cache, not a per-mount cache layer).
#                 Accepted and stored so userland binds round-trip;
#                 has no read-path effect. Documented as stub.
MORDER_MASK:  int32 = 3
MORDER_REPL:    int32 = 0
MORDER_BEFORE:  int32 = 1
MORDER_AFTER:   int32 = 2
MCREATE_BIT:    int32 = 4
MCACHE_BIT:     int32 = 8


class Chan:
    kind:        int32                   # CHAN_KIND_*
    srvfd:       int32                   # fd handed to mount(); -1 for FILE
    # Reserved for Phase D: qid, version, offset, ops vtable, refcount.
    # We grow this struct alongside the 9P client; for now keep it
    # minimal so the field offsets don't shift under sysfile.ad's
    # _write_dir_record consumers.
    flags:       int32                   # mirror of MREPL/MBEFORE/MAFTER
    # V1: post-attach root fid handed back by p9c_attach_run. -1 for
    # FILE-kind (bind) entries; populated for SRV-kind (mount) entries
    # after a successful Tversion + Tattach handshake.
    p9_root_fid: int32                   # 0..31 on success, -1 otherwise


# Mount-table entry. `from_path` and `to_path` are inlined fixed-size
# buffers (Adder doesn't have a string heap in the kernel; per-entry
# Array[uint8] is the same shape sysfile.ad uses for its synthetic
# /dev/<name> bookkeeping).
#
# Note: as of V2 the per-entry namespace_id field is gone — the
# namespace dimension lives in the OUTER Pgrp that owns this entry.
# Visibility is "is this entry in MY Pgrp's mtab", not a tag check.
class MountEntry:
    in_use:        int32                 # 0 = free slot, 1 = live
    flag:          int32                 # MREPL / MBEFORE / MAFTER
    pad0:          int32                 # 8-byte alignment for the chan
    pad1:          int32
    chan:          Chan                  # SRV chan for mount(); zeroed for bind()
    from_path:     Array[128, uint8]     # path bound (the "new" arg)
    to_path:       Array[128, uint8]     # path it resolves to (the "old" arg)
    # HAMSH §14: an optional stable LABEL for this mount. Once union
    # mounts (MBEFORE/MAFTER) stack several servers at one path the
    # path is no longer a unique handle, so a label is what lets a
    # caller `unmount` the exact branch and lets `cat /proc/self/ns`
    # name "where /net actually came from". Empty (label[0]==0) when
    # the mount was created without `as <label>`.
    label:         Array[32, uint8]      # "" = unlabelled


# --- Pgrp: per-process group, the Plan 9 "namespace object" --------
#
# Owns its mount table inline + a refcount. Two TaskStructs whose
# `pgrp` pointer fields hold the SAME address SHARE this Pgrp;
# bind/unmount by either is visible to both. rfork(RFNAMEG) clones
# the Pgrp so the child can diverge without touching the parent's
# struct. When ref drops to 0, kfree returns the storage.
class Pgrp:
    ref:       int32                   # refcount; 0 = unreferenced, fire kfree
    mnt_count: int32                   # live entries in mtab (cached)
    mtab:      Array[32, MountEntry]   # the inline bindings
    # --- #174: per-namespace resource caps (Plan-9-native, NOT cgroups) -
    # A resource cap binds to the NAMESPACE (this Pgrp), not to a task or
    # a Linux cgroup. Every task whose `pgrp` field points at this struct
    # shares these caps; a clone (rfork RFNAMEG) inherits the cap VALUES
    # but starts its own fresh `mem_charged` (the child namespace accounts
    # its own residency separately). Control surface: the /dev/nscap cdev.
    #
    #   mem_cap_bytes  — max resident bytes for all tasks in this
    #                    namespace. 0 == uncapped (the default). When a
    #                    task here page-ins past the cap the allocation is
    #                    DENIED exactly like an over-OOM allocation (the
    #                    caller surfaces -ENOMEM); no reclaim/kill is
    #                    forced — the namespace simply cannot grow past its
    #                    own ceiling.
    #   mem_charged    — running sum of bytes charged to this namespace.
    #                    Bumped on page-in (vma_alloc / demand fault /
    #                    large alloc), dropped on unmap / task_reap.
    #   cpu_cap_pct    — CPU share ceiling in percent (1..100). 0 == 100 ==
    #                    uncapped. The CFS-lite picker inflates this
    #                    namespace's vruntime accrual by 100/cpu_cap_pct, so
    #                    a 25%-capped namespace accrues vruntime 4x faster
    #                    and _pick_next selects its tasks ~1/4 as often.
    mem_cap_bytes:  uint64
    mem_charged:    uint64
    cpu_cap_pct:    uint64
    # --- F10-10 (#457): per-Pgrp OOM-killer bias default ---------------
    # The Plan-9-shape companion to the per-task oom_score_adj store in
    # kernel/sched/core.ad. Every task in this namespace inherits this
    # value as its baseline OOM bias; the per-task slot in
    # g_oom_score_adj[] then layers on as a DELTA. The OOM badness
    # heuristic (mm/reclaim.ad) computes:
    #     effective = pgrp.oom_score_adj + g_oom_score_adj[slot]
    # so a sandboxed namespace (oom_score_adj = +500) is preferentially
    # killed regardless of which task inside it has the highest RSS, and
    # a critical-service namespace (oom_score_adj = -500) is preferentially
    # spared. Range is the same [-1000, +1000] as the per-task value;
    # accessor `pgrp_oom_score_adj_set` clamps. The clone path
    # (pgrp_clone) propagates this value into a divergent namespace so a
    # capped Pgrp's child namespaces inherit the SAME OOM disposition.
    # int64 (not int32) so signed arithmetic in the badness heuristic
    # doesn't need a sign-extension dance — the per-task store is int32
    # because it's a Linux-shape Array, but here the natural shape is
    # signed 64-bit and the struct field has no array dimension.
    oom_score_adj:  int64


# Per-Pgrp mount-table cap. V2 had MNTTAB_PER_NS=8; V2.5+ uses 32.
# The distro-shape fixture plants 9 entries (4 backing binds + 5 self
# binds); 32 leaves comfortable headroom for nested shell sessions.
# Must MATCH the literal in `Pgrp.mtab: Array[32, MountEntry]` above —
# Adder doesn't evaluate constants inside array dimensions.
MNT_CAP: uint64 = 32

# Hardcoded Pgrp size. Adder has no sizeof; we compute by hand:
#   ref + mnt_count                            = 2 * 4 = 8
#   mtab: 32 entries × (4+4+4+4 + 16 chan + 128 + 128 + 32 label)
#                                              = 32 * 320 = 10240
#   #174 caps: mem_cap_bytes + mem_charged + cpu_cap_pct = 3 * 8 = 24
#   F10-10 oom_score_adj                       = 1 * 8 = 8
# Total = 10280 bytes. kmalloc routes this through _kmalloc_large
# (size > 2048) which calls alloc_pages(order=2) → 16 KiB, comfortably
# above 10280.
PGRP_SIZE: uint64 = 10280

# Address of the root Pgrp, lazily kzalloc'd in pgrp_init. Tasks that
# default to "the root namespace" carry this exact pointer in their
# TaskStruct.pgrp field. The root Pgrp is never kfree'd — its ref is
# bumped to a sentinel-large value at init so even pathological exit
# paths don't underflow to zero.
pgrp_root_addr: uint64 = 0

# Sentinel refcount for the root Pgrp. Large enough that no realistic
# fork chain can decrement it to zero, but still finite so an underflow
# bug remains diagnosable. Same shape as Linux's pin_user_pages refcount
# saturation trick.
PGRP_ROOT_REF_PIN: int32 = 0x7FFFFFFF


# --- F9 #452 namespace-purity sweep: cpio-staged distro tree location.
#
# Build convention: scripts/build_initramfs.py stages the default
# distro (busybox / Debian) tree under /var/lib/distros/default/ in
# the kernel-embedded cpio archive. When a guest namespace binds
# `#distro` (or `#debian`) on a boot with no rootfs partition (the
# `-kernel` / ISO / installer cases), _freeze_to_cpio_distro rewrites
# the named-root source to this prefix anchored under `#r` (the boot
# file server letter — kernel-embedded cpio), producing a
# namespace-independent server spec. The bind then lands in the
# hermetic RFCNAMEG child's Pgrp correctly.
#
# Audit #444 finding F9 flagged this string as a hardcoded literal
# path in kernel code. The fix is to lift the build-convention
# location into ONE named accessor (`cpio_distro_prefix()`) +
# documented length constant — so the string lives in exactly one
# function body rather than scattered or buried, and changing the
# cpio staging location is a two-file diff (this accessor + the
# build planter scripts/build_initramfs.py). The result remains
# the namespace-pure `#r/...` shape F1 established; this lift
# only documents the contract.
#
# Adder global-scope quirk: a `Ptr[uint8] = "literal"` initializer
# isn't supported at top level, so the canonical pattern (see how
# every other helper here builds prefixes inside its body) is to
# return the string literal from a tiny accessor.
CPIO_DISTRO_PREFIX_LEN: uint64 = 26     # strlen("#r/var/lib/distros/default")


def cpio_distro_prefix() -> Ptr[uint8]:
    # F9 #452: the single source of truth for the cpio-staged distro
    # tree location. Co-evolves with scripts/build_initramfs.py's
    # `/var/lib/distros/default/` staging directory.
    return cast[Ptr[uint8]]("#r/var/lib/distros/default")


# --- named file-server stack (docs/rootfs_partition.md Future ---
# direction — Allocation models / Stack semantics). System-global
# table indexed by full sentinel-declared name (NOT first-char
# derivation; the WORD is the device name). Per the design:
#
#   * One stack per distinct name. Two physical disks both shipping
#     `home` in their sentinels share a stack of depth 2.
#   * Push on mount (init/main.ad's discovery walk, Phase 5).
#   * Pop on unmount (block layer hot-unplug — Phase 4+ wiring; the
#     entry point is here so the path exists even before the block
#     layer detects the unplug event).
#   * LIFO. `name_lookup(word)` returns the top; `name_lookup_at(word,
#     pos)` returns position `pos` (1 = top, 2 = second, ...).
#   * Depth cap 9 — past that, reject loudly, do NOT evict bottom.
#     Eviction would orphan a name while the underlying Chan stays
#     alive in any already-bound namespace.
#
# Storage: a fixed Array[NAME_TABLE_MAX, NameSlot] of stacks. Each
# NameSlot carries the word (max 32 bytes including NUL) and a
# fixed-size Array of stack entries. We never grow the table — the
# slot count is sized for "the boot-time discovery walk plus any
# hot-plug headroom"; collisions on the slot count are rejected with
# the same loud-printk treatment as depth overflow.
#
# Adder quirks:
#   * No string heap; words are inlined Array[32, uint8].
#   * No `sizeof`, so we never allocate from kmalloc here — the
#     whole table is BSS-resident at module load.

NAME_WORD_MAX: uint64 = 32           # incl. NUL
NAME_DIR_MAX:  uint64 = 256          # relpath inside the partition
NAME_PARTUUID_MAX: uint64 = 40       # canonical "xxxxxxxx-xxxx-...."
NAME_STACK_DEPTH:  uint64 = 9        # docs: "depth cap 9"
NAME_TABLE_MAX:    uint64 = 32       # max distinct sentinel words system-wide


class NameEntry:
    in_use:        int32                          # 0 = vacant
    pad:           int32
    chan_ref:      uint64                         # opaque chan-like (Phase 6 uses)
    partuuid:      Array[40, uint8]               # NUL-terminated
    sentinel_word: Array[32, uint8]               # NUL-terminated; matches NameSlot.word
    dir:           Array[256, uint8]              # sentinel relpath
    mount_order:   uint64                         # boot-time monotonic counter


class NameSlot:
    in_use:    int32                              # 0 = vacant slot
    depth:     int32                              # live stack entries (0..9)
    word:      Array[32, uint8]                   # NUL-terminated key
    # Stack[0] is bottom of stack, Stack[depth-1] is top. (LIFO with
    # an array — push appends, pop drops the last.)
    stack:     Array[9, NameEntry]


name_table: Array[32, NameSlot]
name_mount_seq: uint64 = 0                        # monotonic for mount_order


def _name_str_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    # NUL-terminated equality on small buffers. Local copy to avoid
    # pulling fs/vfs's helpers into chan.ad.
    i: uint64 = 0
    while True:
        ca: uint8 = a[i]
        cb: uint8 = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1


def _name_str_copy(dst: Ptr[uint8], src: Ptr[uint8], cap: uint64):
    # Copy NUL-terminated src into dst, NUL-terminating at cap-1.
    i: uint64 = 0
    while i + 1 < cap:
        c: uint8 = src[i]
        dst[i] = c
        if c == 0:
            return
        i = i + 1
    dst[i] = 0


def _name_find_slot(word: Ptr[uint8]) -> int32:
    # Linear scan for a slot whose key matches `word`. Returns slot
    # index on hit, -1 on miss.
    s: uint64 = 0
    while s < NAME_TABLE_MAX:
        if name_table[s].in_use != 0:
            if _name_str_eq(&name_table[s].word[0], word) != 0:
                return cast[int32](s)
        s = s + 1
    return -1


def _name_alloc_slot(word: Ptr[uint8]) -> int32:
    # Allocate a fresh slot for `word`. Returns slot index, or -1 if
    # the table is full (loud-printk per the doc).
    s: uint64 = 0
    while s < NAME_TABLE_MAX:
        if name_table[s].in_use == 0:
            name_table[s].in_use = 1
            name_table[s].depth = 0
            _name_str_copy(&name_table[s].word[0], word, NAME_WORD_MAX)
            return cast[int32](s)
        s = s + 1
    return -1


def name_push(word: Ptr[uint8], chan_ref: uint64,
              partuuid: Ptr[uint8], dir: Ptr[uint8]) -> int32:
    # Push a new entry onto the LIFO for `word`. Returns 0 on
    # success, -1 on overflow (depth cap 9) or table-full.
    # Per the doc, overflow on push is REJECTED LOUDLY and the
    # bottom is NOT evicted. The caller can choose what to do; the
    # by-id alias table (chan_byid_*) still gets populated so the
    # partition remains addressable.
    if word == cast[Ptr[uint8]](0) or word[0] == 0:
        return -1
    idx: int32 = _name_find_slot(word)
    if idx < 0:
        idx = _name_alloc_slot(word)
        if idx < 0:
            # Table full. Loud, so misconfigurations are visible in
            # dmesg.
            printk0("[name-stack] REJECTED push: word table full\n")
            return -1
    iu: uint64 = cast[uint64](idx)
    if cast[uint64](name_table[iu].depth) >= NAME_STACK_DEPTH:
        printk1("[name-stack] REJECTED push: depth cap %d reached\n",
                NAME_STACK_DEPTH)
        return -1
    d: uint64 = cast[uint64](name_table[iu].depth)
    name_table[iu].stack[d].in_use = 1
    name_table[iu].stack[d].chan_ref = chan_ref
    if partuuid != cast[Ptr[uint8]](0):
        _name_str_copy(&name_table[iu].stack[d].partuuid[0],
                       partuuid, NAME_PARTUUID_MAX)
    else:
        name_table[iu].stack[d].partuuid[0] = 0
    _name_str_copy(&name_table[iu].stack[d].sentinel_word[0],
                   word, NAME_WORD_MAX)
    if dir != cast[Ptr[uint8]](0):
        _name_str_copy(&name_table[iu].stack[d].dir[0], dir, NAME_DIR_MAX)
    else:
        name_table[iu].stack[d].dir[0] = 0
    name_mount_seq = name_mount_seq + 1
    name_table[iu].stack[d].mount_order = name_mount_seq
    name_table[iu].depth = name_table[iu].depth + 1
    return 0


def name_pop(word: Ptr[uint8], chan_ref: uint64) -> int32:
    # Pop the entry matching `chan_ref` from `word`'s stack. We pop
    # by chan-ref rather than blindly popping the top because hot-
    # unplug events are not necessarily for the most-recently-pushed
    # device (a USB plugged before boot can be yanked while a later-
    # pushed disk stays). Returns 0 if an entry was removed, -1 if
    # no match found.
    if word == cast[Ptr[uint8]](0) or word[0] == 0:
        return -1
    idx: int32 = _name_find_slot(word)
    if idx < 0:
        return -1
    iu: uint64 = cast[uint64](idx)
    d: uint64 = cast[uint64](name_table[iu].depth)
    # Find the matching entry (linear; depth is tiny).
    found: int32 = -1
    j: uint64 = 0
    while j < d:
        if name_table[iu].stack[j].chan_ref == chan_ref:
            found = cast[int32](j)
        j = j + 1
    if found < 0:
        return -1
    # Shift entries above `found` down one slot to preserve LIFO
    # order for the remaining stack. Stack is small (max 9) so the
    # shift cost is irrelevant.
    fu: uint64 = cast[uint64](found)
    while fu + 1 < d:
        # Field-copy NameEntry (Adder has no struct-assign through
        # array indices in all positions; do it field-by-field).
        name_table[iu].stack[fu].in_use     = name_table[iu].stack[fu + 1].in_use
        name_table[iu].stack[fu].chan_ref   = name_table[iu].stack[fu + 1].chan_ref
        name_table[iu].stack[fu].mount_order= name_table[iu].stack[fu + 1].mount_order
        k: uint64 = 0
        while k < NAME_PARTUUID_MAX:
            name_table[iu].stack[fu].partuuid[k] = \
                name_table[iu].stack[fu + 1].partuuid[k]
            k = k + 1
        k = 0
        while k < NAME_WORD_MAX:
            name_table[iu].stack[fu].sentinel_word[k] = \
                name_table[iu].stack[fu + 1].sentinel_word[k]
            k = k + 1
        k = 0
        while k < NAME_DIR_MAX:
            name_table[iu].stack[fu].dir[k] = \
                name_table[iu].stack[fu + 1].dir[k]
            k = k + 1
        fu = fu + 1
    # Clear the now-vacant top slot.
    name_table[iu].stack[fu].in_use = 0
    name_table[iu].stack[fu].chan_ref = 0
    name_table[iu].stack[fu].partuuid[0] = 0
    name_table[iu].stack[fu].sentinel_word[0] = 0
    name_table[iu].stack[fu].dir[0] = 0
    name_table[iu].depth = name_table[iu].depth - 1
    if name_table[iu].depth == 0:
        # Slot is empty — leave the in_use=1 marker so re-pushes go
        # back into the same slot index. (Reclaiming slots is fine
        # too; we choose stable index for simpler /proc/fs rendering.)
        pass
    return 0


def name_lookup(word: Ptr[uint8]) -> uint64:
    # Resolve `word` to the TOP-of-stack chan_ref. Returns 0 if no
    # entry exists for this word. Caller decides what 0 means in
    # context (typically "fall through to the dev table" for
    # single-char names, or "ENOENT" for multi-char).
    idx: int32 = _name_find_slot(word)
    if idx < 0:
        return 0
    iu: uint64 = cast[uint64](idx)
    d: int32 = name_table[iu].depth
    if d <= 0:
        return 0
    return name_table[iu].stack[cast[uint64](d - 1)].chan_ref


def name_lookup_at(word: Ptr[uint8], pos: int32) -> uint64:
    # Resolve `word` at position `pos` (1 = top, 2 = second-from-top,
    # ... up to NAME_STACK_DEPTH). Returns 0 if no entry at that
    # position. `#home` is name_lookup_at(word="home", pos=1);
    # `#home2` is name_lookup_at(word="home", pos=2); etc.
    if pos < 1:
        return 0
    if cast[uint64](pos) > NAME_STACK_DEPTH:
        return 0
    idx: int32 = _name_find_slot(word)
    if idx < 0:
        return 0
    iu: uint64 = cast[uint64](idx)
    d: int32 = name_table[iu].depth
    if pos > d:
        return 0
    # pos=1 -> stack[d-1] (top); pos=2 -> stack[d-2]; ...
    j: int32 = d - pos
    return name_table[iu].stack[cast[uint64](j)].chan_ref


def name_lookup_dir(word: Ptr[uint8], pos: int32,
                    out_buf: Ptr[uint8], cap: uint64) -> int32:
    # Copy the sentinel-declared relpath ('dir' field) for the entry
    # at position `pos` (1 = top) into out_buf. Returns 0 on hit,
    # -1 on miss. Used by Phase 6's ns_walk / vfs_open
    # `#<word>` arm to compute the on-disk subpath.
    if pos < 1 or cap == 0:
        return -1
    idx: int32 = _name_find_slot(word)
    if idx < 0:
        return -1
    iu: uint64 = cast[uint64](idx)
    d: int32 = name_table[iu].depth
    if pos > d:
        return -1
    j: int32 = d - pos
    _name_str_copy(out_buf, &name_table[iu].stack[cast[uint64](j)].dir[0], cap)
    return 0


def name_lookup_partuuid(word: Ptr[uint8], pos: int32,
                          out_buf: Ptr[uint8], cap: uint64) -> int32:
    # Companion to name_lookup_at: copy the partuuid string for the
    # entry at position `pos` (1 = top) into out_buf. Returns 0 on
    # hit, -1 on miss. Used by /proc/fs/by-name/<word> rendering.
    if pos < 1 or cap == 0:
        return -1
    idx: int32 = _name_find_slot(word)
    if idx < 0:
        return -1
    iu: uint64 = cast[uint64](idx)
    d: int32 = name_table[iu].depth
    if pos > d:
        return -1
    j: int32 = d - pos
    _name_str_copy(out_buf, &name_table[iu].stack[cast[uint64](j)].partuuid[0], cap)
    return 0


def name_stack_depth(word: Ptr[uint8]) -> int32:
    # Public depth query — useful for /proc/fs/by-name/<word> tail
    # rendering. Returns 0 if no slot exists; up to NAME_STACK_DEPTH
    # otherwise.
    idx: int32 = _name_find_slot(word)
    if idx < 0:
        return 0
    return name_table[cast[uint64](idx)].depth


def name_table_slot_count() -> uint64:
    # Count of in-use slots — for /proc/fs/by-name directory listing.
    n: uint64 = 0
    s: uint64 = 0
    while s < NAME_TABLE_MAX:
        if name_table[s].in_use != 0:
            n = n + 1
        s = s + 1
    return n


def name_table_slot_word(slot_idx: uint64) -> Ptr[uint8]:
    # Return a pointer to the word string at slot `slot_idx` (raw
    # iteration: caller passes 0..NAME_TABLE_MAX-1 and skips slots
    # whose first byte is 0 / in_use == 0). NULL on out-of-range.
    if slot_idx >= NAME_TABLE_MAX:
        return cast[Ptr[uint8]](0)
    return &name_table[slot_idx].word[0]


def name_table_slot_in_use(slot_idx: uint64) -> int32:
    if slot_idx >= NAME_TABLE_MAX:
        return 0
    return name_table[slot_idx].in_use


# --- #by-id/<partuuid> alias table (docs/rootfs_partition.md ---
# "Future direction — Stable instance identity"). Separate from the
# named-stack: each discovered partition gets EXACTLY ONE record in
# this table, keyed by GPT partition UUID. The alias NEVER moves —
# scripts/configs that need persistence reference partitions here,
# not through the LIFO #word names that slide with hot-plug.

BYID_TABLE_MAX: uint64 = 32           # max simultaneously-discovered partitions


class ByIdEntry:
    in_use:   int32
    pad:      int32
    chan_ref: uint64                              # opaque Chan reference (Phase 6)
    partuuid: Array[40, uint8]                    # NUL-terminated canonical form
    sentinel_word: Array[32, uint8]               # primary name if any; "" if anonymous
    dir:      Array[256, uint8]                   # relpath ("." for whole-partition)


byid_table: Array[32, ByIdEntry]


def _byid_find(partuuid: Ptr[uint8]) -> int32:
    s: uint64 = 0
    while s < BYID_TABLE_MAX:
        if byid_table[s].in_use != 0:
            if _name_str_eq(&byid_table[s].partuuid[0], partuuid) != 0:
                return cast[int32](s)
        s = s + 1
    return -1


def byid_register(partuuid: Ptr[uint8], chan_ref: uint64,
                  sentinel_word: Ptr[uint8], dir: Ptr[uint8]) -> int32:
    # Register or update the by-id record for `partuuid`. Returns
    # the slot index on success, -1 on table full. Repeat calls for
    # the same partuuid are idempotent — they update fields in
    # place. (A re-mount of the same disk should pick up an updated
    # sentinel without orphaning the by-id alias.)
    if partuuid == cast[Ptr[uint8]](0) or partuuid[0] == 0:
        return -1
    existing: int32 = _byid_find(partuuid)
    s: uint64
    if existing >= 0:
        s = cast[uint64](existing)
    else:
        # Find a free slot.
        s = 0
        found: int32 = -1
        while s < BYID_TABLE_MAX:
            if byid_table[s].in_use == 0:
                found = cast[int32](s)
                s = BYID_TABLE_MAX
            else:
                s = s + 1
        if found < 0:
            printk0("[by-id] REJECTED register: table full\n")
            return -1
        s = cast[uint64](found)
        byid_table[s].in_use = 1
        _name_str_copy(&byid_table[s].partuuid[0], partuuid,
                       NAME_PARTUUID_MAX)
    byid_table[s].chan_ref = chan_ref
    if sentinel_word != cast[Ptr[uint8]](0):
        _name_str_copy(&byid_table[s].sentinel_word[0],
                       sentinel_word, NAME_WORD_MAX)
    else:
        byid_table[s].sentinel_word[0] = 0
    if dir != cast[Ptr[uint8]](0):
        _name_str_copy(&byid_table[s].dir[0], dir, NAME_DIR_MAX)
    else:
        byid_table[s].dir[0] = 0
    return cast[int32](s)


def byid_lookup(partuuid: Ptr[uint8]) -> uint64:
    # Resolve `#by-id/<partuuid>` to a chan_ref. Returns 0 on miss.
    idx: int32 = _byid_find(partuuid)
    if idx < 0:
        return 0
    return byid_table[cast[uint64](idx)].chan_ref


def byid_lookup_dir(partuuid: Ptr[uint8],
                    out_buf: Ptr[uint8], cap: uint64) -> int32:
    # Copy the stored sentinel relpath ('dir' field) for `partuuid`
    # into out_buf. Returns 0 on hit (out_buf NUL-terminated), -1 on
    # miss. Used by fs/vfs.ad::_open_hash_by_id so a bare
    # `#by-id/<partuuid>/...` reference (one not pre-frozen with a dir
    # prefix) still honors the partition's sentinel relpath instead of
    # silently resolving against the partition root.
    if cap == 0:
        return -1
    idx: int32 = _byid_find(partuuid)
    if idx < 0:
        return -1
    _name_str_copy(out_buf, &byid_table[cast[uint64](idx)].dir[0], cap)
    return 0


def byid_unregister(partuuid: Ptr[uint8]) -> int32:
    # Drop the by-id record when a partition is unplugged. Returns
    # 0 on hit, -1 on miss.
    idx: int32 = _byid_find(partuuid)
    if idx < 0:
        return -1
    iu: uint64 = cast[uint64](idx)
    byid_table[iu].in_use = 0
    byid_table[iu].chan_ref = 0
    byid_table[iu].partuuid[0] = 0
    byid_table[iu].sentinel_word[0] = 0
    byid_table[iu].dir[0] = 0
    return 0


def byid_table_size() -> uint64:
    # For /proc/fs/by-id directory listing.
    n: uint64 = 0
    s: uint64 = 0
    while s < BYID_TABLE_MAX:
        if byid_table[s].in_use != 0:
            n = n + 1
        s = s + 1
    return n


def byid_table_entry_in_use(slot_idx: uint64) -> int32:
    if slot_idx >= BYID_TABLE_MAX:
        return 0
    return byid_table[slot_idx].in_use


def byid_table_entry_partuuid(slot_idx: uint64) -> Ptr[uint8]:
    if slot_idx >= BYID_TABLE_MAX:
        return cast[Ptr[uint8]](0)
    return &byid_table[slot_idx].partuuid[0]


def byid_table_entry_sentinel(slot_idx: uint64) -> Ptr[uint8]:
    if slot_idx >= BYID_TABLE_MAX:
        return cast[Ptr[uint8]](0)
    return &byid_table[slot_idx].sentinel_word[0]


def byid_table_entry_dir(slot_idx: uint64) -> Ptr[uint8]:
    if slot_idx >= BYID_TABLE_MAX:
        return cast[Ptr[uint8]](0)
    return &byid_table[slot_idx].dir[0]


# --- string helpers -------------------------------------------------

def _strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _copy_path_into(dst: Ptr[uint8], cap: uint64,
                    src: Ptr[uint8]) -> int32:
    # Copy NUL-terminated src into dst[0..cap], NUL-terminating.
    # Returns 0 on success, -1 if src wouldn't fit (caller surfaces
    # as "path too long" errstr).
    i: uint64 = 0
    while i < cap:
        c: uint8 = src[i]
        dst[i] = c
        if c == 0:
            return 0
        i = i + 1
    # Ran off the end without finding a NUL.
    if cap > 0:
        dst[cap - 1] = 0
    return -1


def _path_eq_u8(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    # NUL-terminated equality. Returns 1 on match, 0 otherwise.
    i: uint64 = 0
    while True:
        ca: uint8 = a[i]
        cb: uint8 = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1


# --- Pgrp helpers ---------------------------------------------------

def _pgrp_ptr(p: uint64) -> Ptr[Pgrp]:
    # Tiny readability shim — the cast pattern shows up in nearly every
    # function below. Adder doesn't have method syntax on uint64-as-
    # pointer values, so wrapping the cast here keeps the call sites
    # one line shorter.
    return cast[Ptr[Pgrp]](p)


def _zero_entry(p: uint64, s: uint64):
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    g[0].mtab[s].in_use            = 0
    g[0].mtab[s].flag              = 0
    g[0].mtab[s].chan.kind         = CHAN_KIND_NONE
    g[0].mtab[s].chan.srvfd        = -1
    g[0].mtab[s].chan.flags        = 0
    g[0].mtab[s].chan.p9_root_fid  = -1
    g[0].mtab[s].from_path[0]      = 0
    g[0].mtab[s].to_path[0]        = 0
    g[0].mtab[s].label[0]          = 0


def _copy_mtab(src: uint64, dst: uint64):
    # Field-by-field deep copy of the source Pgrp's mtab into the
    # destination. Both `from_path` and `to_path` are inline 128-byte
    # buffers so a memcpy-style loop is correct.
    gs: Ptr[Pgrp] = _pgrp_ptr(src)
    gd: Ptr[Pgrp] = _pgrp_ptr(dst)
    s: uint64 = 0
    while s < MNT_CAP:
        gd[0].mtab[s].in_use           = gs[0].mtab[s].in_use
        gd[0].mtab[s].flag             = gs[0].mtab[s].flag
        gd[0].mtab[s].chan.kind        = gs[0].mtab[s].chan.kind
        gd[0].mtab[s].chan.srvfd       = gs[0].mtab[s].chan.srvfd
        gd[0].mtab[s].chan.flags       = gs[0].mtab[s].chan.flags
        gd[0].mtab[s].chan.p9_root_fid = gs[0].mtab[s].chan.p9_root_fid
        i: uint64 = 0
        while i < 128:
            gd[0].mtab[s].from_path[i] = gs[0].mtab[s].from_path[i]
            gd[0].mtab[s].to_path[i]   = gs[0].mtab[s].to_path[i]
            i = i + 1
        # HAMSH §14: the label rides the COW Pgrp clone alongside the
        # mount it names — a labelled mount stays labelled inside
        # `ns {}` / `enter` / `spawn`.
        li: uint64 = 0
        while li < 32:
            gd[0].mtab[s].label[li] = gs[0].mtab[s].label[li]
            li = li + 1
        # A live SRV entry just got a SECOND owner: the destination
        # Pgrp's copy now also references the underlying 9P connection.
        # Bump its owner refcount so an unmount / exit in EITHER the
        # parent or the rfork(RFNAMEG) child doesn't tear the conn out
        # from under the other. The conn is reclaimed only when the
        # last of the two mount entries goes away.
        if gs[0].mtab[s].in_use != 0 \
                and gs[0].mtab[s].chan.kind == CHAN_KIND_SRV:
            p9c_conn_owner_inc(gs[0].mtab[s].chan.srvfd)
        s = s + 1
    gd[0].mnt_count = gs[0].mnt_count


# --- Pgrp lifecycle API ---------------------------------------------

def _plant_root_bind(g: Ptr[Pgrp], slot: uint64,
                     from_p: Ptr[uint8], to_p: Ptr[uint8]):
    # Direct mtab writer for the kernel's bootstrap namespace. Bypasses
    # mnttab_bind on purpose: there is no current task yet, the to_p
    # specs are already server-anchored (no freeze needed), and the
    # slots are known-free (the Pgrp is freshly kzalloc'd).
    g[0].mtab[slot].in_use           = 1
    g[0].mtab[slot].flag             = 0             # MREPL
    g[0].mtab[slot].chan.kind        = CHAN_KIND_FILE
    g[0].mtab[slot].chan.srvfd       = -1
    g[0].mtab[slot].chan.flags       = 0
    g[0].mtab[slot].chan.p9_root_fid = -1
    _copy_path_into(&g[0].mtab[slot].from_path[0], 128, from_p)
    _copy_path_into(&g[0].mtab[slot].to_path[0], 128, to_p)
    g[0].mtab[slot].label[0]         = 0
    g[0].mnt_count = g[0].mnt_count + 1


def pgrp_init():
    # Allocate the root Pgrp on the heap and pin its refcount. Called
    # by start_kernel before the first task ever runs; idempotent —
    # a repeat call leaves the existing root in place.
    #
    # F1 substrate: the kernel plants the DEFAULT BOOT NAMESPACE here —
    # the Plan 9 bootstrap namespace (Plan 9's kernel likewise attaches
    # the root device and a minimal device set before boot(8) runs).
    # This replaces the V3.5 "kernel plants nothing" stance, which only
    # worked because unbound paths silently fell through to a global
    # cpio root (audit #444 F1). Under the substrate there is NO global
    # fall-through: a path resolves if and only if a binding covers it,
    # so PID 1's very first opens (/dev/cons, /etc/rc.boot — both
    # BEFORE any userspace bind runs) need these entries. rc.boot's own
    # binds re-apply most of them idempotently (mnttab_bind's
    # MREPL-replace), and `bind '#sysroot' /` REPLACES the / -> #r root
    # on partition boots.
    #
    # Server letters (single-char specs, localized by fs/vfs.ad):
    #   #r = boot file server (kernel-embedded cpio root)
    #   #t = tmpfs server (the writable /tmp + /var trees)
    #   #e = ext4 server  (partition subtrees, /ext key space)
    #   #f = FAT server   (/mnt key space)
    # plus the long-standing device letters (#c dev, #b blk, #p proc,
    # #s srv, #I net, #/ mount-parent).
    #
    # devsrv_init() stays here because it brings up the device's own
    # internal name table (used by sys_srv_post in V4 and by `#s`
    # listings today), not a Pgrp binding.
    if pgrp_root_addr == 0:
        # kzalloc returns zero-filled storage; stamp ref to the
        # sentinel value so do_exit underflow paths can't free it,
        # then plant the default namespace.
        addr: uint64 = kzalloc(PGRP_SIZE)
        if addr != 0:
            pgrp_root_addr = addr
            g: Ptr[Pgrp] = _pgrp_ptr(addr)
            g[0].ref = PGRP_ROOT_REF_PIN
            _plant_root_bind(g, 0, cast[Ptr[uint8]]("/"),
                             cast[Ptr[uint8]]("#r"))
            _plant_root_bind(g, 1, cast[Ptr[uint8]]("/tmp"),
                             cast[Ptr[uint8]]("#t/tmp"))
            _plant_root_bind(g, 2, cast[Ptr[uint8]]("/var"),
                             cast[Ptr[uint8]]("#t/var"))
            _plant_root_bind(g, 3, cast[Ptr[uint8]]("/dev"),
                             cast[Ptr[uint8]]("#c"))
            _plant_root_bind(g, 4, cast[Ptr[uint8]]("/dev/blk"),
                             cast[Ptr[uint8]]("#b"))
            _plant_root_bind(g, 5, cast[Ptr[uint8]]("/proc"),
                             cast[Ptr[uint8]]("#p"))
            _plant_root_bind(g, 6, cast[Ptr[uint8]]("/srv"),
                             cast[Ptr[uint8]]("#s"))
            _plant_root_bind(g, 7, cast[Ptr[uint8]]("/net"),
                             cast[Ptr[uint8]]("#I"))
            _plant_root_bind(g, 8, cast[Ptr[uint8]]("/n"),
                             cast[Ptr[uint8]]("#/"))
            _plant_root_bind(g, 9, cast[Ptr[uint8]]("/mnt"),
                             cast[Ptr[uint8]]("#f"))
            _plant_root_bind(g, 10, cast[Ptr[uint8]]("/ext"),
                             cast[Ptr[uint8]]("#e"))
            # F10-1 (#454): /sys → #r so the cgroup v2 paths
            # /sys/fs/cgroup/<...> still resolve through resolve_path's
            # head-fallback (cpio doesn't actually ship /sys files;
            # resolve_path's union-exhausted-fallback returns the
            # localized head spelling, and the L2 path-handler hook in
            # _vfs_open_post_perm claims /sys/fs/cgroup/<...>). Without
            # this bind, the cgroup arm wouldn't be reachable in a
            # default-namespace Linux task — F1's unbound = ENOENT gate
            # would fire before the L2 dispatcher saw the path.
            _plant_root_bind(g, 11, cast[Ptr[uint8]]("/sys"),
                             cast[Ptr[uint8]]("#r"))
            # Phase D follow-up: retire the Layer-2 string-rewrite
            # _u_translate_proc_to_dev from linux_abi/u_syscalls.ad.
            # The Plan 9 way is to BIND the Linux /proc/<name> spelling
            # at the matching native /dev/<name> cdev. A longer-prefix
            # FILE bind always wins over the /proc -> #p root entry
            # (see _walk_best_len in this file), so:
            #
            #   /proc/cpuinfo  -> #c/cpuinfo
            #   /proc/meminfo  -> #c/meminfo
            #   /proc/uptime   -> #c/uptime
            #   /proc/loadavg  -> #c/loadavg
            #   /proc/version  -> #c/version
            #   /proc/hostname -> #c/hostname
            #   /proc/stat     -> #c/stat
            #   /proc/mounts   -> #c/mounts
            #   /proc/diskstats-> #c/diskstats
            #
            # Plants identical bytes for both Adder callers
            # (sys_open("/proc/cpuinfo")) and Linux ELFs going through
            # _u_open; preserves the proc_translation u-binary's
            # /proc/cpuinfo == /dev/cpuinfo byte-equality assertion.
            # /proc/self/<leaf> resolution stays in the `#p` proc
            # server (devproc._parse_proc_path) — no extra plumbing.
            _plant_root_bind(g, 12, cast[Ptr[uint8]]("/proc/cpuinfo"),
                             cast[Ptr[uint8]]("#c/cpuinfo"))
            _plant_root_bind(g, 13, cast[Ptr[uint8]]("/proc/meminfo"),
                             cast[Ptr[uint8]]("#c/meminfo"))
            _plant_root_bind(g, 14, cast[Ptr[uint8]]("/proc/uptime"),
                             cast[Ptr[uint8]]("#c/uptime"))
            _plant_root_bind(g, 15, cast[Ptr[uint8]]("/proc/loadavg"),
                             cast[Ptr[uint8]]("#c/loadavg"))
            _plant_root_bind(g, 16, cast[Ptr[uint8]]("/proc/version"),
                             cast[Ptr[uint8]]("#c/version"))
            _plant_root_bind(g, 17, cast[Ptr[uint8]]("/proc/hostname"),
                             cast[Ptr[uint8]]("#c/hostname"))
            _plant_root_bind(g, 18, cast[Ptr[uint8]]("/proc/stat"),
                             cast[Ptr[uint8]]("#c/stat"))
            _plant_root_bind(g, 19, cast[Ptr[uint8]]("/proc/mounts"),
                             cast[Ptr[uint8]]("#c/mounts"))
            _plant_root_bind(g, 20, cast[Ptr[uint8]]("/proc/diskstats"),
                             cast[Ptr[uint8]]("#c/diskstats"))
    devsrv_init()


def _ensure_root():
    # Defensive: if pgrp_init was never called, lazy-fix the root on
    # the first chan.ad call from a task. Mirrors V2.5's
    # _ensure_root_pinned in shape.
    if pgrp_root_addr == 0:
        pgrp_init()


def pgrp_alloc() -> uint64:
    # Allocate a fresh empty Pgrp on the heap. kzalloc gives us a
    # zeroed region, so mtab is empty and mnt_count==0 already; we
    # just stamp ref=1. Returns 0 on allocation failure (callers
    # surface as -EAGAIN).
    addr: uint64 = kzalloc(PGRP_SIZE)
    if addr == 0:
        return 0
    _pgrp_ptr(addr)[0].ref = 1
    return addr


def pgrp_clone(src: uint64) -> uint64:
    # Allocate a fresh Pgrp, deep-copy src's mtab into it. New Pgrp
    # gets ref=1; src's ref is UNCHANGED (we're not adding a new
    # reference to src — we're producing a divergent copy). Returns
    # the new Pgrp address, or 0 on allocation failure / NULL src.
    if src == 0:
        return 0
    new_addr: uint64 = pgrp_alloc()
    if new_addr == 0:
        return 0
    _copy_mtab(src, new_addr)
    # HAMSH §7: COW-copy the source Pgrp's /fd-name table into the
    # clone, so the child's stdio (/fd/0,1,2) starts as a private
    # snapshot of the parent's. Pipe ends are refcount-bumped inside
    # devfd_clone_row.
    devfd_clone_row(src, new_addr)
    # #174: a divergent namespace INHERITS the cap CEILINGS but starts a
    # fresh residency count — the clone accounts its own pages from zero.
    # (kzalloc already zeroed mem_charged in the new Pgrp.)
    sp: Ptr[Pgrp] = _pgrp_ptr(src)
    np: Ptr[Pgrp] = _pgrp_ptr(new_addr)
    np[0].mem_cap_bytes = sp[0].mem_cap_bytes
    np[0].cpu_cap_pct   = sp[0].cpu_cap_pct
    # F10-10 (#457): a divergent namespace inherits the per-Pgrp OOM
    # baseline bias too — same shape as the mem/cpu caps. A child Pgrp
    # forked off a sandboxed namespace stays sandboxed; a child forked
    # off a critical-service namespace stays critical. Per-task DELTAs
    # in g_oom_score_adj[] still layer on top per slot.
    np[0].oom_score_adj = sp[0].oom_score_adj
    return new_addr


def pgrp_ref_inc(p: uint64) -> int32:
    # Bump refcount when a fresh task inherits an existing Pgrp
    # (rfork without RFNAMEG). Returns the new refcount, or -1 on
    # NULL pointer.
    if p == 0:
        return -1
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    g[0].ref = g[0].ref + 1
    return g[0].ref


def _detach_srv_conns(p: uint64):
    # A Pgrp is about to be freed (its last task referer is gone).
    # Every live SRV-kind mount entry it still holds is an owner of a
    # 9P connection — drop each of those owner references so the
    # underlying conn (and its p9_conns slot) is reclaimed once no
    # surviving namespace references it. This is the task-exit half of
    # the connection-lifecycle fix: without it, a process that mounted
    # a 9P server and exited without unmounting (exactly what nsrun's
    # exec'd target does) would leak its conns forever, and the next
    # nsrun's mounts would collide on the reused srvfd numbers.
    #
    # p9c_detach is benign on a srvfd with no conn (returns -1), so an
    # entry whose conn was already torn down by an explicit unmount is
    # handled cleanly. Re-entrancy: see the note on p9c_detach — its
    # only outbound work is best-effort fid clunks through fs/pipe.ad.
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    s: uint64 = 0
    while s < MNT_CAP:
        if g[0].mtab[s].in_use != 0 \
                and g[0].mtab[s].chan.kind == CHAN_KIND_SRV:
            p9c_detach(g[0].mtab[s].chan.srvfd)
        s = s + 1


def pgrp_ref_dec(p: uint64) -> int32:
    # Drop refcount on task exit. When refcount hits 0, kfree the
    # storage and return 0. Returns the new refcount, or -1 on NULL
    # / underflow. Root (sentinel-pinned) refuses to underflow because
    # the sentinel is enormous; init exiting is a no-op in practice.
    if p == 0:
        return -1
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    if g[0].ref <= 0:
        return -1
    g[0].ref = g[0].ref - 1
    new_ref: int32 = g[0].ref
    if new_ref == 0:
        # Last referer dropped — release any 9P connections this
        # Pgrp's SRV mounts still own, THEN return the storage to the
        # slab / page allocator. Order matters: _detach_srv_conns
        # reads the mtab, so it must run before kfree. The caller's
        # pointer is dangling after kfree; this is the standard
        # refcount contract (caller must not retain it past ref_dec).
        _detach_srv_conns(p)
        # HAMSH §7: release the Pgrp's /fd-name table — every pipe end
        # it still references gets its refcount dropped. Runs before
        # kfree (it reads the side table keyed by this pointer).
        devfd_free_row(p)
        kfree(p)
    return new_ref


def pgrp_current() -> uint64:
    # Current task's Pgrp pointer. Tasks that haven't been initialised
    # yet (default pgrp=0) collapse to the root Pgrp — same defensive
    # shape as V2.5's _current_ns_safe.
    _ensure_root()
    raw: uint64 = current_pgrp()
    if raw == 0:
        return pgrp_root_addr
    return raw


def pgrp_root() -> uint64:
    # The root Pgrp's heap address. Useful for boot-time setup paths
    # that want an explicit "use the root" rather than reading the
    # current task's pgrp (which during boot may not be sensible).
    _ensure_root()
    return pgrp_root_addr


# --- #174: per-namespace resource caps -------------------------------
#
# These are the kernel-internal surface the mm layer (charge/uncharge),
# the scheduler (cpu throttle factor), and the /dev/nscap control cdev
# all call. Everything binds to a Pgrp pointer — the Plan-9 namespace
# object — never to a task or a Linux cgroup. The `_nscap_` prefix keeps
# the helpers out of the flat global symbol namespace's way.

def nscap_set_mem(p: uint64, nbytes: uint64):
    # Install a memory ceiling (in nbytes) on namespace `p`. 0 == uncapped.
    if p == 0:
        return
    _pgrp_ptr(p)[0].mem_cap_bytes = nbytes


def nscap_set_cpu(p: uint64, pct: uint64):
    # Install a CPU-share ceiling (1..100 %) on namespace `p`. 0 or >=100
    # == uncapped. Out-of-range high values clamp to uncapped.
    if p == 0:
        return
    pp: uint64 = pct
    if pp >= 100:
        pp = 0
    _pgrp_ptr(p)[0].cpu_cap_pct = pp


def nscap_get_mem_cap(p: uint64) -> uint64:
    if p == 0:
        return 0
    return _pgrp_ptr(p)[0].mem_cap_bytes


def nscap_get_mem_charged(p: uint64) -> uint64:
    if p == 0:
        return 0
    return _pgrp_ptr(p)[0].mem_charged


def nscap_get_cpu(p: uint64) -> uint64:
    if p == 0:
        return 0
    return _pgrp_ptr(p)[0].cpu_cap_pct


def nscap_mem_charge(p: uint64, nbytes: uint64) -> int32:
    # Try to charge `nbytes` of fresh residency to namespace `p`. Returns 0
    # on success (charge applied), -1 if the charge would exceed the cap
    # (charge NOT applied — caller must fail the allocation like OOM).
    # An uncapped namespace (mem_cap_bytes == 0) always succeeds but its
    # running total is still tracked so a later `echo mem ... > /dev/nscap`
    # reports the live residency.
    if p == 0:
        return 0
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    cap: uint64 = g[0].mem_cap_bytes
    if cap != 0:
        if g[0].mem_charged + nbytes > cap:
            return -1
    g[0].mem_charged = g[0].mem_charged + nbytes
    return 0


def nscap_mem_uncharge(p: uint64, nbytes: uint64):
    # Drop `nbytes` of residency from namespace `p` (page free / unmap /
    # task_reap). Saturates at 0 so a double-uncharge can't underflow.
    if p == 0:
        return
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    if nbytes >= g[0].mem_charged:
        g[0].mem_charged = 0
    else:
        g[0].mem_charged = g[0].mem_charged - nbytes


# --- charge/uncharge against the CURRENT task's namespace ------------
#
# The mm layer almost always wants "charge to whoever is running" — it
# calls these so it never has to reach into core.ad for the pgrp pointer
# itself. They resolve current_pgrp() (0 == not-yet-installed → treated
# as the root namespace, which is uncapped by default so boot-time
# allocations never trip a cap).

def nscap_mem_charge_slot(slot: uint64, nbytes: uint64) -> int32:
    # Charge against the namespace of task `slot` (used by the mm layer's
    # page-fault / vma_alloc paths, where the charging task is identified
    # by its slot index, not necessarily current_idx). A slot whose
    # pgrp is 0 (root default, uncapped) always succeeds.
    p: uint64 = task_pgrp(cast[int32](slot))
    if p == 0:
        return 0
    return nscap_mem_charge(p, nbytes)


def nscap_mem_uncharge_slot(slot: uint64, nbytes: uint64):
    p: uint64 = task_pgrp(cast[int32](slot))
    if p == 0:
        return
    nscap_mem_uncharge(p, nbytes)


def nscap_charge_current(nbytes: uint64) -> int32:
    p: uint64 = current_pgrp()
    if p == 0:
        return 0
    return nscap_mem_charge(p, nbytes)


def nscap_uncharge_current(nbytes: uint64):
    p: uint64 = current_pgrp()
    if p == 0:
        return
    nscap_mem_uncharge(p, nbytes)


def nscap_cpu_factor_current() -> uint64:
    # CFS-lite throttle factor for the currently-running task's namespace:
    # the integer multiplier by which vruntime accrual is inflated. 100%
    # (or uncapped) → 1 (no inflation). 25% → 4. 10% → 10. Computed as
    # 100/cpu_cap_pct, floored at 1. preempt_tick multiplies the per-tick
    # vruntime advance by this so a capped namespace's tasks lose the
    # _pick_next race proportionally and get throttled.
    p: uint64 = current_pgrp()
    if p == 0:
        return 1
    pct: uint64 = _pgrp_ptr(p)[0].cpu_cap_pct
    if pct == 0 or pct >= 100:
        return 1
    f: uint64 = 100 / pct
    if f < 1:
        f = 1
    return f


# --- F10-10 (#457): per-Pgrp oom_score_adj accessors -----------------
#
# These mirror the kernel/sched/core.ad oom_adj_get/set surface, but
# operate on the NAMESPACE (Pgrp pointer) instead of a task slot. The
# per-task value remains in g_oom_score_adj[] as a DELTA layered on top
# of this default. The badness heuristic in mm/reclaim.ad computes the
# effective bias as `pgrp_default + task_delta`. Same range/clamp as the
# Linux /proc/<pid>/oom_score_adj surface: [-1000, +1000].

PGRP_OOM_ADJ_MIN: int64 = -1000
PGRP_OOM_ADJ_MAX: int64 = 1000


def pgrp_oom_score_adj_get(p: uint64) -> int64:
    # Per-Pgrp OOM bias baseline. A NULL pgrp reads as 0 (the unbiased
    # default), the same way nscap_get_* treat a NULL pointer — keeps
    # boot-time call sites that haven't yet wired up a real Pgrp from
    # tripping.
    if p == 0:
        return 0
    return _pgrp_ptr(p)[0].oom_score_adj


def pgrp_oom_score_adj_set(p: uint64, v: int64):
    # Install a per-Pgrp OOM baseline bias, clamped to [-1000, +1000].
    # NULL pgrp is a no-op (callers that haven't selected a namespace
    # yet — e.g. boot-time setup — shouldn't crash). Clamp comparisons
    # are in signed int64 so a caller passing a raw negative value
    # widens correctly.
    if p == 0:
        return
    vv: int64 = v
    if vv < PGRP_OOM_ADJ_MIN:
        vv = PGRP_OOM_ADJ_MIN
    if vv > PGRP_OOM_ADJ_MAX:
        vv = PGRP_OOM_ADJ_MAX
    _pgrp_ptr(p)[0].oom_score_adj = vv


def pgrp_oomadj_selftest() -> int32:
    # F10-10 (#457): exercise the per-Pgrp oom_score_adj field + clamp +
    # rfork(RFNAMEG)-style clone independence over the boot Pgrp.
    #
    # Drives the REAL store via pgrp_oom_score_adj_set/get and the REAL
    # pgrp_clone path (so the inheritance branch of pgrp_clone is
    # exercised at runtime, not just by source inspection). Returns 1
    # PASS / 0 FAIL. PUBLIC so init/main.ad can call it.
    #
    # The test runs entirely against fresh heap Pgrps (pgrp_alloc /
    # pgrp_clone), never touching the root Pgrp's baseline, so it leaves
    # global state pristine and is safe to run after later boot-stage
    # tests.
    _ensure_root()

    # (1) Allocate a fresh standalone Pgrp; round-trip a safe-range value.
    p_a: uint64 = pgrp_alloc()
    if p_a == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PGRPOOM] FAIL pgrp_alloc returned 0\n")
        return 0
    pgrp_oom_score_adj_set(p_a, cast[int64](250))
    if pgrp_oom_score_adj_get(p_a) != cast[int64](250):
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PGRPOOM] FAIL round-trip 250 not stored\n")
        pgrp_ref_dec(p_a)
        return 0

    # (2) Upper clamp at +1000. An out-of-range high value MUST clamp.
    pgrp_oom_score_adj_set(p_a, cast[int64](5000))
    if pgrp_oom_score_adj_get(p_a) != PGRP_OOM_ADJ_MAX:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PGRPOOM] FAIL upper clamp != 1000\n")
        pgrp_ref_dec(p_a)
        return 0

    # (3) Lower clamp at -1000. An out-of-range low value MUST clamp.
    pgrp_oom_score_adj_set(p_a, cast[int64](-5000))
    if pgrp_oom_score_adj_get(p_a) != PGRP_OOM_ADJ_MIN:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PGRPOOM] FAIL lower clamp != -1000\n")
        pgrp_ref_dec(p_a)
        return 0

    # (4) Clone independence. Set p_a to a known value, clone it via the
    # REAL pgrp_clone (matching rfork RFNAMEG semantics), confirm the
    # child INHERITED the value, then mutate each independently and
    # confirm the OTHER is unchanged — the divergent-namespace contract.
    pgrp_oom_score_adj_set(p_a, cast[int64](300))
    p_b: uint64 = pgrp_clone(p_a)
    if p_b == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PGRPOOM] FAIL pgrp_clone returned 0\n")
        pgrp_ref_dec(p_a)
        return 0
    if pgrp_oom_score_adj_get(p_b) != cast[int64](300):
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PGRPOOM] FAIL clone did not inherit 300\n")
        pgrp_ref_dec(p_a)
        pgrp_ref_dec(p_b)
        return 0
    # Diverge: child to -400, parent stays 300.
    pgrp_oom_score_adj_set(p_b, cast[int64](-400))
    if pgrp_oom_score_adj_get(p_a) != cast[int64](300):
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PGRPOOM] FAIL parent perturbed by child mutate\n")
        pgrp_ref_dec(p_a)
        pgrp_ref_dec(p_b)
        return 0
    if pgrp_oom_score_adj_get(p_b) != cast[int64](-400):
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PGRPOOM] FAIL child did not retain -400\n")
        pgrp_ref_dec(p_a)
        pgrp_ref_dec(p_b)
        return 0
    # And the other direction: parent to +700, child stays -400.
    pgrp_oom_score_adj_set(p_a, cast[int64](700))
    if pgrp_oom_score_adj_get(p_b) != cast[int64](-400):
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PGRPOOM] FAIL child perturbed by parent mutate\n")
        pgrp_ref_dec(p_a)
        pgrp_ref_dec(p_b)
        return 0
    if pgrp_oom_score_adj_get(p_a) != cast[int64](700):
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PGRPOOM] FAIL parent did not retain 700\n")
        pgrp_ref_dec(p_a)
        pgrp_ref_dec(p_b)
        return 0

    # Drop the two test Pgrps' references; ref_dec returns 0 fires kfree.
    pgrp_ref_dec(p_a)
    pgrp_ref_dec(p_b)

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[PGRPOOM] PASS clamp+clone-independence verified\n")
    return 1


# --- legacy wrappers kept for compatibility with downstream calls --
#
# A handful of test fixtures still spell the V2 names (ns_clone /
# ns_alloc_empty / ns_inc_ref / ns_dec_ref). Keep thin wrappers so the
# external surface doesn't change.

def ns_clone(parent: uint64) -> uint64:
    return pgrp_clone(parent)


def ns_alloc_empty() -> uint64:
    return pgrp_alloc()


def ns_inc_ref(p: uint64) -> int32:
    return pgrp_ref_inc(p)


def ns_dec_ref(p: uint64) -> int32:
    return pgrp_ref_dec(p)


# --- public Chan surface --------------------------------------------

def chan_init():
    # Backwards-compatible name for callers (init/main.ad) that still
    # spell `chan_init`. Delegates to pgrp_init.
    pgrp_init()


def chan_attach(srvfd: int32, spec: Ptr[uint8],
                out: Ptr[Chan]) -> int32:
    # Phase C stub: produce a Chan that wraps the supplied srvfd.
    # Phase D grows this into a real 9P Tversion + Tattach exchange
    # over the srvfd; for now we just record the fd and return.
    if out == cast[Ptr[Chan]](0):
        return -1
    out[0].kind        = CHAN_KIND_SRV
    out[0].srvfd       = srvfd
    out[0].flags       = 0
    out[0].p9_root_fid = -1                  # populated by syschan after Tattach
    return 0


def chan_walk(c: Ptr[Chan], path: Ptr[uint8]) -> Ptr[Chan]:
    # Phase C stub: no walking. The mount table maps prefixes, not
    # paths, so resolve_path's longest-prefix match is the only
    # walking we need at this milestone.
    return c


# --- mount-table operations -----------------------------------------

def _current_pgrp_safe() -> uint64:
    # Resolve the calling task's Pgrp pointer for mtab access. Same
    # role as V2's _current_ns_safe but returns a real heap pointer.
    return pgrp_current()


def _mtab_find_free(p: uint64) -> int32:
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    s: uint64 = 0
    while s < MNT_CAP:
        if g[0].mtab[s].in_use == 0:
            return cast[int32](s)
        s = s + 1
    return -1


def _entry_visible(p: uint64, s: uint64) -> int32:
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    if g[0].mtab[s].in_use == 0:
        return 0
    return 1


def _dir_child_eq(buf: Ptr[uint8], buf_len: uint64,
                  child: Ptr[uint8], clen: uint64) -> int32:
    # 1 if a "NAME\n" line equal to child[0..clen] already sits in buf.
    p: uint64 = 0
    while p < buf_len:
        ls: uint64 = p
        while p < buf_len and buf[p] != 10:
            p = p + 1
        ln: uint64 = p - ls
        if p < buf_len:
            p = p + 1
        if ln == clen:
            k: uint64 = 0
            ok: int32 = 1
            while k < clen:
                if buf[ls + k] != child[k]:
                    ok = 0
                    k = clen
                else:
                    k = k + 1
            if ok != 0:
                return 1
    return 0


def chan_dir_mount_children(dir: Ptr[uint8], buf: Ptr[uint8],
                            count: uint64, start: uint64) -> int64:
    # Append "NAME\n" lines for every mount-table binding whose
    # `from_path` is an IMMEDIATE child of `dir`. This is what makes a
    # Plan-9 `bind '#X' /dev` show up as `dev` in `ls /` even though no
    # backing FS carries a `dev` entry — the bound name lives in the
    # namespace (mtab), not on any disk. `dir` is the NUL-terminated
    # absolute directory path WITHOUT a trailing slash ("/" for root).
    # `start` is the current fill offset in buf (so the synthesized
    # names are deduped against the backing-FS names already written).
    # Returns the new fill offset.
    p: uint64 = _current_pgrp_safe()
    if p == 0:
        return cast[int64](start)
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    # Length of `dir`, and whether it is root ("/").
    dlen: uint64 = 0
    while dir[dlen] != 0:
        dlen = dlen + 1
    is_root: int32 = 0
    if dlen == 1 and dir[0] == cast[uint8]('/'):
        is_root = 1
    out: uint64 = start
    s: uint64 = 0
    while s < MNT_CAP:
        if _entry_visible(p, s) != 0:
            fp: Ptr[uint8] = &g[0].mtab[s].from_path[0]
            # from_path must start with '/' to be a conventional name.
            if fp[0] == cast[uint8]('/'):
                cstart: uint64 = 0
                keep: int32 = 0
                if is_root != 0:
                    cstart = 1
                    keep = 1
                else:
                    # Must start with dir + '/'.
                    k: uint64 = 0
                    while k < dlen and fp[k] != 0 and fp[k] == dir[k]:
                        k = k + 1
                    if k == dlen and fp[k] == cast[uint8]('/'):
                        cstart = dlen + 1
                        keep = 1
                if keep != 0:
                    # Immediate child only: basename up to next '/'/NUL.
                    clen: uint64 = 0
                    while fp[cstart + clen] != 0 \
                            and fp[cstart + clen] != cast[uint8]('/'):
                        clen = clen + 1
                    if clen > 0:
                        cp: Ptr[uint8] = cast[Ptr[uint8]](
                            cast[uint64](fp) + cstart)
                        if _dir_child_eq(buf, out, cp, clen) == 0:
                            if out + clen + 1 <= count:
                                j: uint64 = 0
                                while j < clen:
                                    buf[out + j] = cp[j]
                                    j = j + 1
                                buf[out + clen] = 10      # '\n'
                                out = out + clen + 1
        s = s + 1
    return cast[int64](out)


def _is_byid_prefix(input: Ptr[uint8]) -> int32:
    # Returns 1 if `input` starts with "by-id" (5 chars), 0 otherwise.
    # Used by _freeze_named_source to skip a source that's already a
    # stable by-id alias.
    if input[0] != cast[uint8]('b'):
        return 0
    if input[1] != cast[uint8]('y'):
        return 0
    if input[2] != cast[uint8]('-'):
        return 0
    if input[3] != cast[uint8]('i'):
        return 0
    if input[4] != cast[uint8]('d'):
        return 0
    return 1


def _word_is_distro(word: Ptr[uint8]) -> int32:
    # True if the (NUL-terminated) named-root word is one of the distro
    # aliases the cpio fallback covers: `distro` or `debian`. These are
    # the words the `linux` / `debian` ns templates bind as the hermetic
    # guest root. Kept tiny + explicit (no general table) because the
    # cpio-staged distro tree has exactly one well-known location.
    d: Ptr[uint8] = cast[Ptr[uint8]]("distro")
    if _word_streq(word, d) != 0:
        return 1
    db: Ptr[uint8] = cast[Ptr[uint8]]("debian")
    if _word_streq(word, db) != 0:
        return 1
    return 0


def _word_streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while True:
        ca: uint8 = a[i]
        cb: uint8 = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1


def _freeze_to_cpio_distro(rest: Ptr[uint8],
                           output: Ptr[uint8], cap: uint64) -> int32:
    # Rewrite a distro named-root source to the cpio-resident distro tree.
    # `rest` is the path suffix AFTER the `#<word>` token (the `/...` tail,
    # or an empty string for a bare `#distro`). The frozen source becomes
    # CPIO_DISTRO_PREFIX + rest — SERVER-ANCHORED (the `#r` boot file
    # server spec), NOT a bare `/var/...` path. The distinction is
    # load-bearing under the F1 substrate: this bind lands in a hermetic
    # RFCNAMEG child whose namespace contains NOTHING but what its recipe
    # binds; a bare `/var/...` to_path would be re-walked in the CHILD's
    # namespace at lookup time, find no cover, and ENOENT every guest open.
    # A `#r` spec is namespace-independent — it names the server directly.
    #
    # F9 #452 namespace-purity sweep: cpio_distro_prefix() is the
    # named accessor that lifts the build convention
    # (scripts/build_initramfs.py stages the default distro tree at
    # /var/lib/distros/default of the cpio archive) out of this
    # function body. The audit flagged a hardcoded path; making it a
    # single named accessor (not a bypass — the result is server-
    # anchored) keeps the invariant explicit and audit-greppable.
    # Changing the cpio staging location is now a two-file diff
    # (this accessor + build_initramfs.py).
    #
    # Returns 1 (freeze applied) on success, -1 if the result wouldn't
    # fit in `cap`.
    prefix: Ptr[uint8] = cpio_distro_prefix()
    plen: uint64 = CPIO_DISTRO_PREFIX_LEN
    rlen: uint64 = _strlen_u8(rest)
    if plen + rlen + 1 > cap:
        return -1
    j: uint64 = 0
    while j < plen:
        output[j] = prefix[j]
        j = j + 1
    k: uint64 = 0
    while k < rlen:
        output[plen + k] = rest[k]
        k = k + 1
    output[plen + rlen] = 0
    return 1


def _freeze_named_source(input: Ptr[uint8],
                          output: Ptr[uint8], cap: uint64) -> int32:
    # Bind-freeze: if `input` starts with `#<word>/...` where <word>
    # names a multi-char named-stack slot (not a built-in single-char
    # device letter, not already a `by-id` alias), rewrite to
    # `#by-id/<partuuid>/...` against the CURRENT top of the named
    # stack at this moment. Pinning to by-id at bind time is what
    # gives bind its Plan-9-chan.c freeze guarantee: a subsequent
    # push onto the `#<word>` stack cannot redirect already-bound
    # paths.
    #
    # Returns 1 if a freeze rewrite was applied (output populated +
    # NUL-terminated), 0 if no rewrite needed (output not written),
    # -2 if `input` IS a multi-char named-root word (`#sysroot`,
    # `#distro`, `#<user>`) that did NOT resolve to any currently-
    # registered partition slot (output not written), or -1 on error
    # (buffer too small). The caller (mnttab_bind) treats -2 as a hard
    # bind failure: a named-root source that names no live partition
    # must NOT silently install a `<dst> -> #<word>` mtab entry, because
    # resolve_path would then rewrite every lookup under <dst> to a
    # dangling `#<word>` route with no backing — e.g. `bind '#sysroot'
    # /` on a cpio-only boot (no rootfs partition) would poison ALL
    # root-relative path lookups (`/bin/hello` -> `#sysroot/bin/hello`
    # -> ENOENT), breaking every exec. Returning -2 lets `bind` fail so
    # rc.boot's try/except falls back to the cpio rc cleanly. Built-in
    # single-char device letters (#c/#p/#s/#/) and already-frozen
    # `#by-id/...` aliases still return 0 (no freeze, bind proceeds) —
    # they are not named-root words.
    if input[0] != cast[uint8]('#'):
        return 0
    # Walk to find end of word
    i: uint64 = 1
    while input[i] != 0:
        if input[i] == cast[uint8]('/'):
            break
        i = i + 1
    word_len: uint64 = i - 1
    if word_len < 2:
        # Built-in single-char letter (#c, #p, #s, #/) — no freeze.
        return 0
    if word_len >= 5:
        if _is_byid_prefix(&input[1]) == 1:
            # Already a stable by-id alias.
            return 0
    if word_len >= 63:
        # Word longer than our scratch buffer — skip freeze (will be
        # rejected later if it doesn't resolve).
        return 0
    # Copy the word out, NUL-terminated.
    word_buf: Array[64, uint8]
    j: uint64 = 0
    while j < word_len:
        word_buf[j] = input[1 + j]
        j = j + 1
    word_buf[word_len] = 0
    # Look up the CURRENT top of this named slot's stack.
    partuuid: Array[64, uint8]
    partuuid[0] = 0
    rc: int32 = name_lookup_partuuid(&word_buf[0], 1, &partuuid[0], 64)
    if rc != 0 or partuuid[0] == 0:
        # No matching named slot for a MULTI-CHAR word. This is not a
        # built-in device letter (those return 0 above with word_len <
        # 2) — it is a `#<word>` that names nothing.
        #
        # CPIO FALLBACK for the distro tree (`-kernel` / ISO boot, no
        # rootfs partition): on those boots no partition posts a
        # `#distro` named-root, but scripts/build_initramfs.py stages a
        # whole busybox distro tree in the cpio at
        # /var/lib/distros/default/. `enter linux { … }` (and `debian`)
        # bind `#distro /` to point the hermetic child root at that tree;
        # if we returned -2 here that bind would fail and the guest could
        # never launch. So for the distro words rewrite the SOURCE to the
        # cpio-resident `/var/lib/distros/default` directory instead — the
        # existing `bind / <path>` root-rebind machinery + _is_initramfs_dir
        # resolution then routes guest opens through the cpio bytes. This
        # is SAFE: the bind lands in the hermetic (RFCNAMEG) child's Pgrp,
        # never PID 1's ambient namespace, so it cannot poison `/`; and if
        # the cpio tree is absent the opens simply ENOENT (same as a
        # Debian-less boot). When a real partition IS present the
        # name_lookup_partuuid hit above wins and this fallback never runs,
        # so the by-id freeze guarantee is unaffected.
        if _word_is_distro(&word_buf[0]) != 0:
            return _freeze_to_cpio_distro(&input[i], output, cap)
        # Any OTHER unresolved named word (e.g. `#sysroot`) must STILL
        # hard-fail: `bind '#sysroot' /` on a cpio-only boot has to return
        # -2 so the bootstrap rc's try/except routes to the cpio root
        # fallback rather than silently shadowing the cpio root with a
        # broken named source.
        return -2
    # Look up the sentinel-declared dir prefix for this word at the
    # CURRENT top of stack. With the multi-root layout a single
    # partition carries several named subtrees (e.g. `sysroot
    # sysroot`, `distro distro`), so the by-id alias — which is keyed
    # by partuuid ALONE — cannot by itself recover which subtree a
    # `#<word>` bind referred to. We therefore bake the dir prefix
    # into the frozen path here: `#sysroot/bin/ls` freezes to
    # `#by-id/<partuuid>/sysroot/bin/ls`, NOT `#by-id/<partuuid>/bin/
    # ls`. _open_hash_by_id then composes `/ext/sysroot/bin/ls`
    # correctly with an empty dir_prefix. A dir of "." or "" means the
    # whole partition, so we prepend nothing.
    dir_buf: Array[256, uint8]
    dir_buf[0] = 0
    name_lookup_dir(&word_buf[0], 1, &dir_buf[0], 256)
    dir_len: uint64 = _strlen_u8(&dir_buf[0])
    use_dir: int32 = 1
    if dir_len == 0:
        use_dir = 0
    elif dir_len == 1:
        if dir_buf[0] == cast[uint8]('.'):
            use_dir = 0
    # Strip a trailing '/' the sentinel may include (`home/`).
    if use_dir == 1:
        if dir_buf[dir_len - 1] == cast[uint8]('/'):
            dir_len = dir_len - 1
    # Build "#by-id/<partuuid>[/<dir>]<rest>" where <rest> = input[i..]
    # (the '/...' suffix or empty string).
    uuid_len: uint64 = _strlen_u8(&partuuid[0])
    rest_len: uint64 = _strlen_u8(&input[i])
    # Prefix is 7 bytes: '#', 'b', 'y', '-', 'i', 'd', '/'.
    # If we have a dir prefix we insert "/<dir>" (dir_len + 1 bytes)
    # between the partuuid and the rest.
    dir_field: uint64 = 0
    if use_dir == 1:
        dir_field = dir_len + 1
    total: uint64 = 7 + uuid_len + dir_field + rest_len + 1
    if total > cap:
        return -1
    output[0] = cast[uint8]('#')
    output[1] = cast[uint8]('b')
    output[2] = cast[uint8]('y')
    output[3] = cast[uint8]('-')
    output[4] = cast[uint8]('i')
    output[5] = cast[uint8]('d')
    output[6] = cast[uint8]('/')
    j = 0
    while j < uuid_len:
        output[7 + j] = partuuid[j]
        j = j + 1
    o: uint64 = 7 + uuid_len
    if use_dir == 1:
        output[o] = cast[uint8]('/')
        o = o + 1
        k: uint64 = 0
        while k < dir_len:
            output[o] = dir_buf[k]
            o = o + 1
            k = k + 1
    j = 0
    while j < rest_len:
        output[o + j] = input[i + j]
        j = j + 1
    output[o + rest_len] = 0
    return 1


def _mtab_zap_from(p: uint64, from_path: Ptr[uint8]):
    # MREPL semantics (Plan 9 bind/mount flag 0): a replace-bind at a
    # name REPLACES the entire union currently stacked at that name.
    # Remove every live entry (FILE and SRV alike) whose from_path is
    # exactly `from_path`. SRV entries own a 9P connection — drop the
    # owner reference before zeroing the slot, same as mnttab_unmount.
    #
    # This is also what keeps rc.boot's re-binds idempotent over the
    # kernel-planted default namespace (pgrp_init): `bind '#c' /dev`
    # replaces the planted /dev -> #c entry instead of stacking a
    # duplicate, and `bind '#sysroot' /` actually REPLACES the planted
    # / -> #r root server instead of leaving the cpio root as an
    # equal-priority MREPL sibling (which would shadow the partition
    # for every name the cpio also carries).
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    s: uint64 = 0
    while s < MNT_CAP:
        if g[0].mtab[s].in_use != 0 \
                and _path_eq_u8(&g[0].mtab[s].from_path[0], from_path) != 0:
            if g[0].mtab[s].chan.kind == CHAN_KIND_SRV:
                p9c_detach(g[0].mtab[s].chan.srvfd)
            _zero_entry(p, s)
            if g[0].mnt_count > 0:
                g[0].mnt_count = g[0].mnt_count - 1
        s = s + 1


def mnttab_bind(new_path: Ptr[uint8], old_path: Ptr[uint8],
                flag: int32) -> int32:
    # Add a `new_path -> old_path` binding into the calling task's
    # Pgrp mtab. Returns 0 on success, -1 if the mtab is full.
    #
    # Bind freeze semantics (docs/rootfs_partition.md "Bind freeze
    # semantics"): Plan 9's bind(2) resolves `old` to a CHANNEL at
    # bind time and stores the channel — later namespace changes
    # cannot redirect an existing bind. Our mtab stores strings, so
    # the equivalent guarantee is to freeze `old_path` to a SERVER-
    # ANCHORED form at the moment of binding:
    #
    #   * `#<word>` named-root sources freeze to a stable
    #     `#by-id/<partuuid>/<dir>` alias against the CURRENT top of
    #     the named stack (_freeze_named_source). A later hot-plug
    #     push onto `#<word>` cannot redirect existing binds.
    #
    #   * `/`-anchored sources freeze through ONE ns_walk step in the
    #     CALLER's namespace: `bind /myalias /etc` walks /etc to its
    #     covering server (e.g. `#r/etc` under the default boot
    #     namespace) and stores THAT. The stored to_path is therefore
    #     namespace-independent — it stays valid inside an rfork
    #     RFNAMEG/RFCNAMEG child whose own table diverges. An OLD
    #     that resolves to nothing (UNBOUND in the caller's namespace)
    #     is a hard bind failure: there is no global root to fall
    #     through to (F1 substrate, audit #444).
    #
    #   * Single-char `#X` device specs (`#c`, `#s`, `#r/...`) are
    #     already server-anchored — stored verbatim.
    p: uint64 = _current_pgrp_safe()
    if p == 0:
        return -1
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    frozen: Array[128, uint8]
    dst: Ptr[uint8] = old_path
    if old_path[0] == cast[uint8]('/'):
        # '/'-anchored source: resolve through the caller's namespace
        # NOW (head union member). ns_walk returns:
        #   1  -> frozen holds the covering server's spec (or a
        #         SRV-covered chain path) — store it.
        #   2  -> old_path's deepest cover is a SRV (9P) mount — the
        #         path string itself IS the server-anchored name
        #         (namec's chan_find_srv_prefix matches it). Store
        #         old_path verbatim.
        #   0  -> UNBOUND: nothing serves old_path here. Hard fail.
        #  -1  -> overflow. Hard fail.
        wrc: int32 = ns_walk(old_path, &frozen[0], 128, 0)
        if wrc == 1:
            dst = &frozen[0]
        elif wrc != 2:
            return -1
    else:
        freeze_rc: int32 = _freeze_named_source(old_path, &frozen[0], 128)
        if freeze_rc == -2:
            # `#<word>` source names no live named-stack slot (e.g.
            # `bind '#sysroot' /` on a boot with no rootfs partition).
            # REJECT rather than install a dangling root bind that would
            # shadow the boot server. The caller (bootstrap rc's try
            # block) keys off this failure to take the cpio fallback.
            return -1
        if freeze_rc < 0:
            return -1
        if freeze_rc == 1:
            dst = &frozen[0]
    # MREPL replaces the whole union at new_path; MBEFORE/MAFTER stack.
    if (flag & 3) == 0:
        _mtab_zap_from(p, new_path)
    slot: int32 = _mtab_find_free(p)
    if slot < 0:
        return -1
    su: uint64 = cast[uint64](slot)
    if _copy_path_into(&g[0].mtab[su].from_path[0], 128, new_path) < 0:
        return -1
    if _copy_path_into(&g[0].mtab[su].to_path[0], 128, dst) < 0:
        return -1
    g[0].mtab[su].in_use           = 1
    g[0].mtab[su].flag             = flag
    g[0].mtab[su].chan.kind        = CHAN_KIND_FILE
    g[0].mtab[su].chan.srvfd       = -1
    g[0].mtab[su].chan.flags       = flag
    g[0].mtab[su].chan.p9_root_fid = -1
    g[0].mnt_count = g[0].mnt_count + 1
    return 0


def mnttab_mount(srvfd: int32, old_path: Ptr[uint8],
                 flag: int32, spec: Ptr[uint8]) -> int32:
    # Same shape as mnttab_bind, but the "from" side is a SRV chan
    # wrapping srvfd, not a path. MREPL replaces the union currently
    # stacked at the mount point, same as bind.
    p: uint64 = _current_pgrp_safe()
    if p == 0:
        return -1
    if (flag & 3) == 0:
        _mtab_zap_from(p, old_path)
    slot: int32 = _mtab_find_free(p)
    if slot < 0:
        return -1
    su: uint64 = cast[uint64](slot)
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    if _copy_path_into(&g[0].mtab[su].from_path[0], 128, old_path) < 0:
        return -1
    g[0].mtab[su].to_path[0] = 0
    if chan_attach(srvfd, spec, &g[0].mtab[su].chan) < 0:
        return -1
    g[0].mtab[su].in_use       = 1
    g[0].mtab[su].flag         = flag
    g[0].mnt_count = g[0].mnt_count + 1
    return 0


def mnttab_unmount(new_path: Ptr[uint8],
                   old_path: Ptr[uint8]) -> int32:
    # Remove bindings. Two shapes per the Plan 9 contract:
    #
    #   * new_path == NULL  -> remove every binding visible at
    #                          old_path (regardless of where they
    #                          resolve to).
    #   * new_path != NULL  -> remove the specific
    #                          new_path -> old_path edge.
    p: uint64 = _current_pgrp_safe()
    if p == 0:
        return -1
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    removed: int32 = 0
    s: uint64 = 0
    while s < MNT_CAP:
        if _entry_visible(p, s) != 0:
            keep: int32 = 1
            if new_path == cast[Ptr[uint8]](0):
                if _path_eq_u8(&g[0].mtab[s].from_path[0], old_path) != 0:
                    keep = 0
            else:
                if _path_eq_u8(&g[0].mtab[s].from_path[0], new_path) != 0:
                    if g[0].mtab[s].chan.kind == CHAN_KIND_SRV \
                            and g[0].mtab[s].to_path[0] == 0:
                        keep = 0
                    elif _path_eq_u8(&g[0].mtab[s].to_path[0], old_path) != 0:
                        keep = 0
            if keep == 0:
                # A SRV-kind entry owns a 9P connection — drop this
                # mount's owner reference BEFORE we zero the slot (we
                # still need the srvfd). p9c_detach reclaims the
                # p9_conns slot once the last owner is gone, so an
                # explicit unmount(2) no longer leaks the connection.
                # Re-entrancy: p9c_detach's only outbound work is
                # best-effort fid clunks routed through fs/pipe.ad —
                # never a nested vfs_* / chan_* dispatch.
                if g[0].mtab[s].chan.kind == CHAN_KIND_SRV:
                    p9c_detach(g[0].mtab[s].chan.srvfd)
                _zero_entry(p, s)
                removed = removed + 1
                if g[0].mnt_count > 0:
                    g[0].mnt_count = g[0].mnt_count - 1
        s = s + 1
    if removed == 0:
        return -1
    return 0


# --- HAMSH §14: mount labels ----------------------------------------

def mnttab_set_label(label: Ptr[uint8], to_path: Ptr[uint8],
                     from_path: Ptr[uint8]) -> int32:
    # Stamp `label` onto the most-recently-added live mount entry that
    # matches (from_path -> to_path). The shell calls this right after
    # a successful mount/bind to realise `mount $srv /to as label`.
    # Matching the newest entry is what makes labelling the just-added
    # union branch correct even with several mounts stacked at one
    # path. Returns 0 on success, -1 if no matching entry exists.
    p: uint64 = _current_pgrp_safe()
    if p == 0:
        return -1
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    best: int32 = -1
    s: uint64 = 0
    while s < MNT_CAP:
        if g[0].mtab[s].in_use != 0:
            hit: int32 = 0
            if g[0].mtab[s].chan.kind == CHAN_KIND_SRV:
                # SRV mounts key on the target path (from_path side).
                if _path_eq_u8(&g[0].mtab[s].from_path[0], to_path) != 0:
                    hit = 1
            else:
                if from_path != cast[Ptr[uint8]](0) \
                        and _path_eq_u8(&g[0].mtab[s].from_path[0],
                                        from_path) != 0 \
                        and _path_eq_u8(&g[0].mtab[s].to_path[0],
                                        to_path) != 0:
                    hit = 1
            if hit != 0:
                best = cast[int32](s)
        s = s + 1
    if best < 0:
        return -1
    _copy_path_into(&g[0].mtab[cast[uint64](best)].label[0], 32, label)
    return 0


def mnttab_unmount_label(label: Ptr[uint8]) -> int32:
    # Remove the single mount entry carrying `label` (HAMSH §14:
    # `unmount` by handle). The label is a unique handle, so this
    # peels exactly one branch of a union stack. Returns 0 on success,
    # -1 if no entry carries that label.
    p: uint64 = _current_pgrp_safe()
    if p == 0:
        return -1
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    s: uint64 = 0
    while s < MNT_CAP:
        if g[0].mtab[s].in_use != 0 \
                and g[0].mtab[s].label[0] != 0 \
                and _path_eq_u8(&g[0].mtab[s].label[0], label) != 0:
            if g[0].mtab[s].chan.kind == CHAN_KIND_SRV:
                p9c_detach(g[0].mtab[s].chan.srvfd)
            _zero_entry(p, s)
            if g[0].mnt_count > 0:
                g[0].mnt_count = g[0].mnt_count - 1
            return 0
        s = s + 1
    return -1


# --- resolve_path hook ----------------------------------------------

def _prefix_match_len_at(p: uint64, s: uint64, input: Ptr[uint8]) -> uint64:
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    fp: Ptr[uint8] = &g[0].mtab[s].from_path[0]
    flen: uint64 = _strlen_u8(fp)
    if flen == 0:
        return 0
    # Root rebind: `bind X /` means "everything not matched by a
    # deeper bound name lives under X". The general matcher below would
    # reject because input[1] is normally a name byte, not '/' or 0.
    # We instead match any input starting with '/' at length 1; the
    # rewriter (_rewrite_via_slot) detects the root-prefix case
    # and keeps the leading slash so X + /sub stays well-formed.
    #
    # F1 substrate note: the old _is_synth_dev_path carve-out (root
    # rebinds refusing to claim /dev, /proc, /net) is GONE. Those names
    # are ordinary per-Pgrp bindings now — the kernel plants /dev -> #c,
    # /proc -> #p, /net -> #I in the DEFAULT boot namespace (pgrp_init),
    # and a deeper bound name always wins over the root rebind by depth.
    # A namespace whose recipe doesn't bind them genuinely doesn't have
    # them — that's the point.
    if flen == 1 and fp[0] == 47:                # "/"
        if input[0] == 47:                       # input starts with '/'
            return 1
        return 0
    i: uint64 = 0
    while i < flen:
        if input[i] == 0:
            return 0
        if input[i] != fp[i]:
            return 0
        i = i + 1
    next_byte: uint8 = input[flen]
    if next_byte == 0 or next_byte == 47:        # '/'
        return flen
    return 0


def _rewrite_via_slot(p: uint64, bu: uint64, match_len: uint64,
                      input: Ptr[uint8], output: Ptr[uint8],
                      cap: uint64) -> int32:
    # Rewrite `input` through the mtab entry at slot `bu` of Pgrp `p`:
    # replace the matched `from_path` prefix (match_len bytes consumed)
    # with the entry's `to_path`, copying the unmatched remainder
    # verbatim. Returns 1 on success, -1 on overflow. ns_walk uses this
    # for every FILE-kind union member it selects.
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    tp: Ptr[uint8] = &g[0].mtab[bu].to_path[0]
    tplen: uint64 = _strlen_u8(tp)
    if tplen >= cap:
        return -1
    j: uint64 = 0
    while j < tplen:
        output[j] = tp[j]
        j = j + 1
    si: uint64 = match_len
    # Root rebind ("/" -> OLD): the matcher reports a 1-byte consume
    # for the leading slash, but the slash also serves as the path
    # separator between OLD and the remainder. Keep it by rewinding
    # si to 0, so the rewrite becomes OLD + "/etc/..." instead of
    # OLD + "etc/...". `bind / X` is the directive the linux-runtime
    # template uses to point root at a distro tree.
    fp: Ptr[uint8] = &g[0].mtab[bu].from_path[0]
    root_rebind: int32 = 0
    if fp[0] == 47 and fp[1] == 0:               # from_path is "/"
        si = 0
        root_rebind = 1
    while j + 1 < cap and input[si] != 0:
        output[j] = input[si]
        j = j + 1
        si = si + 1
    if input[si] != 0:
        return -1
    # Strip a redundant trailing slash. When `input` was just "/" under
    # a root rebind we copied the leading slash out (so OLD + "/sub"
    # stays well-formed for `input = "/sub"`) — but for a bare "/" the
    # result is "OLD/" with an empty remainder, and vfs_open /
    # _is_initramfs_dir treat "OLD/" as a distinct path that has no
    # cpio match. Concretely: a Linux binary doing `stat("/")` inside
    # a clean `bind / /var/lib/distros/default` namespace would resolve
    # to "/var/lib/distros/default/", which _is_initramfs_dir rejects
    # because the post-name byte is 'e' (the start of "etc/"), not '/'.
    # Drop the slash here so the rewritten path is the directory itself.
    # Guard against producing an empty string: we need at least one byte
    # to remain after the strip. With root_rebind set we copied tp out
    # first (j = tplen) then copied the leading slash from input
    # (j = tplen + 1) — strip is safe as long as j > 1. For the no-op
    # `bind / /` case (tplen = 1, j = 2 = "//"), strip lands on "/".
    if root_rebind != 0 and j > 1 and output[j - 1] == 47:
        j = j - 1
    output[j] = 0
    return 1


# --- ns_walk: the per-Pgrp namespace walk (F1 substrate) -------------
#
# THE single authority for what a '/'-anchored name means in the
# calling task's namespace. Replaces the V2-era ns_walk /
# ns_walk (union member enumeration) veneer pair (which were a prefix-rewrite
# layer over a global path-keyed VFS — audit #444 finding F1).
#
# Semantics: walk `input` (a canonical absolute path) against the
# CURRENT Pgrp's mount table. The DEEPEST bound name covering the path
# is the namespace point — FILE binds and SRV (9P) mounts compete on
# equal terms by depth. At that point the union members are enumerated
# in Plan 9 search order:
#
#   1. MBEFORE members, most-recently-bound FIRST  (front of union)
#   2. MREPL members, in bind order                (the base)
#   3. MAFTER members, in bind order               (end of union)
#
# `nth` selects the member (0-based). resolve_path() (fs/vfs.ad) owns
# the existence probing — it asks for member 0, 1, 2, ... and stops at
# the first whose target actually exists. chan.ad stays free of an
# fs <- chan import cycle.
#
# A path covered by NOTHING in the table is UNBOUND (returns 0): there
# is no global root to fall through to. The default boot namespace is
# itself a set of bindings (pgrp_init plants / -> #r, /dev -> #c, ...
# in the root Pgrp); a hermetic RFCNAMEG child sees only what its
# recipe binds.
#
# Returns:
#   1  -> output holds the nth member's rewrite of `input`: the
#         member's (bind-time frozen, server-anchored) to_path with
#         the unmatched path remainder appended. Usually a `#X...`
#         server spec; may be a '/'-path when the frozen source was
#         itself SRV-covered (the caller walks again — chain hop).
#   2  -> the nth member is a SRV (9P) mount: `input` ITSELF is the
#         server-anchored name (namec's chan_find_srv_prefix matches
#         it against this same mtab). output = input verbatim.
#   0  -> UNBOUND: no live entry covers `input` at any depth.
#  -1  -> rewrite overflowed `cap`.
#  -2  -> a binding covers `input` but nth is past the last union
#         member (caller stops probing and falls back to member 0).

def ns_walk(input: Ptr[uint8], output: Ptr[uint8],
            cap: uint64, nth: uint64) -> int32:
    p: uint64 = _current_pgrp_safe()
    if p == 0:
        return 0
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    blen: uint64 = _walk_best_len(p, input)
    if blen == 0:
        return 0
    # Walk the three priority bands in order, counting matching members
    # until we reach the nth. Within a band the slot-visit order
    # matters: MBEFORE newest-first (descending slot), MREPL/MAFTER
    # oldest-first (ascending slot).
    seen: uint64 = 0
    band: int32 = 0
    while band < 3:
        chosen: int32 = -1
        if band == 0:
            # MBEFORE band, newest (highest slot) first.
            s: int32 = cast[int32](MNT_CAP) - 1
            while s >= 0:
                su: uint64 = cast[uint64](s)
                if _walk_band_match(p, su, input, blen, 0) != 0:
                    if seen == nth:
                        chosen = s
                        s = -1
                    else:
                        seen = seen + 1
                if s >= 0:
                    s = s - 1
        else:
            # MREPL (band 1) / MAFTER (band 2), oldest (lowest slot) first.
            want: int32 = 1
            if band == 2:
                want = 2
            su2: uint64 = 0
            while su2 < MNT_CAP:
                if _walk_band_match(p, su2, input, blen, want) != 0:
                    if seen == nth:
                        chosen = cast[int32](su2)
                        su2 = MNT_CAP
                    else:
                        seen = seen + 1
                if su2 < MNT_CAP:
                    su2 = su2 + 1
        if chosen >= 0:
            cu: uint64 = cast[uint64](chosen)
            if g[0].mtab[cu].chan.kind == CHAN_KIND_SRV:
                # SRV terminates the walk: the original path IS the
                # 9P-visible name. Copy it through so the caller can
                # hand it to namec (chan_find_srv_prefix re-derives
                # the srvfd/root_fid from this same mtab).
                if _copy_path_into(output, cap, input) < 0:
                    return -1
                return 2
            return _rewrite_via_slot(p, cu, blen, input, output, cap)
        band = band + 1
    # Exhausted all members without reaching nth.
    return -2


def _walk_best_len(p: uint64, input: Ptr[uint8]) -> uint64:
    # Depth of the deepest bound name covering `input` — FILE binds and
    # SRV mounts both count. That depth identifies the namespace point
    # (every union member at one name shares the identical from_path,
    # hence identical match length).
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    best: uint64 = 0
    s: uint64 = 0
    while s < MNT_CAP:
        if _entry_visible(p, s) != 0:
            m: uint64 = _prefix_match_len_at(p, s, input)
            if m > best:
                best = m
        s = s + 1
    return best


def _walk_band_match(p: uint64, s: uint64, input: Ptr[uint8],
                     blen: uint64, want_band: int32) -> int32:
    # 1 if slot s is a live entry (FILE or SRV) whose match length ==
    # blen AND whose MORDER band == want_band (0=MBEFORE, 1=MREPL,
    # 2=MAFTER).
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    if _entry_visible(p, s) == 0:
        return 0
    m: uint64 = _prefix_match_len_at(p, s, input)
    if m != blen:
        return 0
    order: int32 = g[0].mtab[s].flag & 3
    band: int32 = 1                                  # MREPL default
    if order == 1:
        band = 0                                     # MBEFORE
    elif order == 2:
        band = 2                                     # MAFTER
    if band != want_band:
        return 0
    return 1


# --- MCREATE: select the create-target member at a union point ------
#
# Plan 9 mount(2)/bind(2) MCREATE bit: a union member with MCREATE set
# is eligible to receive Tcreate; without it, the member is read-only
# for create purposes. If MULTIPLE members at the same union point
# have MCREATE set, the highest-priority MCREATE member wins (same
# MBEFORE-newest > MREPL-oldest > MAFTER-oldest ordering ns_walk uses).
#
# Back-compat: if NO member at the union point has MCREATE set, this
# function returns 0 — meaning "no MCREATE filtering applies here,
# caller should use the standard resolve_path path which routes
# creates to the head member." This preserves the long-standing
# Hamnix behavior where binds default to MORDER_REPL with no MCREATE
# bit and creates land on the head member.
#
# Returns:
#   1  -> output holds the create-target rewrite of `input`
#         (highest-priority MCREATE member's to_path + remainder).
#   0  -> no MCREATE member at the deepest binding (or path is
#         unbound). Caller falls back to legacy create resolution.
#  -1  -> rewrite overflowed `cap`.

def mnttab_create_target(input: Ptr[uint8], output: Ptr[uint8],
                         cap: uint64) -> int32:
    p: uint64 = _current_pgrp_safe()
    if p == 0:
        return 0
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    blen: uint64 = _walk_best_len(p, input)
    if blen == 0:
        return 0
    # Three-band scan, same priority as ns_walk, but filtered by
    # MCREATE_BIT. First MCREATE member found wins.
    band: int32 = 0
    while band < 3:
        chosen: int32 = -1
        if band == 0:
            # MBEFORE band, newest (highest slot) first.
            s: int32 = cast[int32](MNT_CAP) - 1
            while s >= 0:
                su: uint64 = cast[uint64](s)
                if _walk_band_match(p, su, input, blen, 0) != 0:
                    if (g[0].mtab[su].flag & MCREATE_BIT) != 0:
                        chosen = s
                        s = -1
                if s >= 0:
                    s = s - 1
        else:
            want: int32 = 1
            if band == 2:
                want = 2
            su2: uint64 = 0
            while su2 < MNT_CAP:
                if _walk_band_match(p, su2, input, blen, want) != 0:
                    if (g[0].mtab[su2].flag & MCREATE_BIT) != 0:
                        chosen = cast[int32](su2)
                        su2 = MNT_CAP
                if su2 < MNT_CAP:
                    su2 = su2 + 1
        if chosen >= 0:
            cu: uint64 = cast[uint64](chosen)
            # SRV members with MCREATE: the 9P-visible name IS the
            # input itself (namec routes it). Copy verbatim.
            if g[0].mtab[cu].chan.kind == CHAN_KIND_SRV:
                if _copy_path_into(output, cap, input) < 0:
                    return -1
                return 1
            return _rewrite_via_slot(p, cu, blen, input, output, cap)
        band = band + 1
    return 0


# Probe: 1 if ANY visible binding covering `input` has MCREATE set.
# Used by create paths to detect when MCREATE filtering is in effect
# (vs the back-compat "no member has MCREATE -> legacy head wins"
# case). Cheap, no rewrite — just a flag scan.

def mnttab_any_mcreate_covers(input: Ptr[uint8]) -> int32:
    p: uint64 = _current_pgrp_safe()
    if p == 0:
        return 0
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    blen: uint64 = _walk_best_len(p, input)
    if blen == 0:
        return 0
    s: uint64 = 0
    while s < MNT_CAP:
        if _entry_visible(p, s) != 0:
            m: uint64 = _prefix_match_len_at(p, s, input)
            if m == blen:
                if (g[0].mtab[s].flag & MCREATE_BIT) != 0:
                    return 1
        s = s + 1
    return 0


# --- SRV-mount lookup for the VFS dispatcher ----------------------

def chan_find_srv_prefix(input: Ptr[uint8],
                         out_srvfd: Ptr[int32],
                         out_root_fid: Ptr[int32],
                         out_prefix_len: Ptr[uint64]) -> int32:
    p: uint64 = _current_pgrp_safe()
    if p == 0:
        return 0
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    best_slot: int32 = -1
    best_len: uint64 = 0
    s: uint64 = 0
    while s < MNT_CAP:
        if _entry_visible(p, s) != 0:
            if g[0].mtab[s].chan.kind == CHAN_KIND_SRV:
                m: uint64 = _prefix_match_len_at(p, s, input)
                if m > best_len:
                    best_len = m
                    best_slot = cast[int32](s)
        s = s + 1
    if best_slot < 0:
        return 0
    bu: uint64 = cast[uint64](best_slot)
    out_srvfd[0]      = g[0].mtab[bu].chan.srvfd
    out_root_fid[0]   = g[0].mtab[bu].chan.p9_root_fid
    out_prefix_len[0] = best_len
    return 1


def chan_set_p9_root_fid_by_srvfd(srvfd: int32, root_fid: int32) -> int32:
    p: uint64 = _current_pgrp_safe()
    if p == 0:
        return -1
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    s: uint64 = 0
    while s < MNT_CAP:
        if g[0].mtab[s].in_use != 0 \
                and g[0].mtab[s].chan.kind == CHAN_KIND_SRV \
                and g[0].mtab[s].chan.srvfd == srvfd:
            g[0].mtab[s].chan.p9_root_fid = root_fid
            return 0
        s = s + 1
    return -1


# --- introspection / debug -----------------------------------------

def mnttab_entry_count() -> uint64:
    # Live entries in the CALLING task's Pgrp. V2.5 walked every Pgrp
    # in a pool; V2.75 doesn't have a "all Pgrps" enumeration (Pgrps
    # live wherever kmalloc planted them) so we report the caller's
    # view — which is what tests actually validate anyway.
    p: uint64 = _current_pgrp_safe()
    if p == 0:
        return 0
    return mnttab_entry_count_p(p)


def mnttab_entry_count_p(p: uint64) -> uint64:
    # Live entries visible to Pgrp `p`. NULL -> 0.
    if p == 0:
        return 0
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    n: uint64 = 0
    s: uint64 = 0
    while s < MNT_CAP:
        if g[0].mtab[s].in_use != 0:
            n = n + 1
        s = s + 1
    return n


# --- V3: /proc/<pid>/ns text renderer -------------------------------
#
# Render the Pgrp's mtab as Plan 9 ns(1)-shape text into `out_buf`.
# One line per live entry, in slot order. Bind entries are
# "bind <from> <to>\n"; mount entries are "mount #s/<srvfd> <to>\n"
# (V3 doesn't carry the srv name through to the mount entry — chan.c
# only stamps the srvfd, so we render the fd. V4 will widen this once
# devsrv_post is wired to the same path).
#
# Returns bytes written; truncates at out_max (drops the partial tail
# entry, never splits). The caller passes the Pgrp pointer they want
# rendered — devproc.ad resolves the target task's pgrp pointer and
# forwards it here.

def _pad_u64_dec(value: uint64, out: Ptr[uint8]) -> uint64:
    # Reverse-fill decimal helper. Same shape as devproc.ad's own
    # _u64_to_dec; inlined here so chan.ad doesn't depend on devproc.
    if value == 0:
        out[0] = 48                              # '0'
        return 1
    digits: Array[24, uint8]
    n: uint64 = 0
    while value != 0:
        digits[n] = cast[uint8](value % 10) + 48
        value = value / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return written


def _emit_path_into(dst: Ptr[uint8], dst_pos: uint64, dst_max: uint64,
                    src: Ptr[uint8]) -> uint64:
    # Copy NUL-terminated src into dst[dst_pos..]. Returns new dst_pos.
    # Stops short if src would overflow dst_max.
    p: uint64 = dst_pos
    i: uint64 = 0
    while p < dst_max and src[i] != 0:
        dst[p] = src[i]
        p = p + 1
        i = i + 1
    return p


def pgrp_render_ns(p: uint64, out_buf: Ptr[uint8],
                   out_max: uint64) -> int64:
    # Render Pgrp `p`'s mtab as ns(1)-shape text. See header above.
    if p == 0:
        return 0
    g: Ptr[Pgrp] = _pgrp_ptr(p)
    pos: uint64 = 0
    s: uint64 = 0
    while s < MNT_CAP:
        if g[0].mtab[s].in_use != 0:
            # Estimate worst-case line length: prefix (8) + from_path
            # (128) + space (1) + to_path or srvfd (128 or 24) + nl (1).
            # We don't know exact upfront; check after writing and
            # rewind if we overflow.
            line_start: uint64 = pos
            kind: int32 = g[0].mtab[s].chan.kind
            prefix_ptr: Ptr[uint8]
            prefix_len: uint64
            if kind == CHAN_KIND_SRV:
                prefix_ptr = "mount #s/"
                prefix_len = 9
            else:
                prefix_ptr = "bind "
                prefix_len = 5
            # Bounds check: ensure prefix fits.
            if pos + prefix_len >= out_max:
                return cast[int64](pos)
            k: uint64 = 0
            while k < prefix_len:
                out_buf[pos] = prefix_ptr[k]
                pos = pos + 1
                k = k + 1
            if kind == CHAN_KIND_SRV:
                # Render srvfd as ASCII decimal.
                srvfd_u: uint64 = cast[uint64](
                    g[0].mtab[s].chan.srvfd)
                if pos + 24 >= out_max:
                    pos = line_start
                    return cast[int64](pos)
                n: uint64 = _pad_u64_dec(srvfd_u,
                                         cast[Ptr[uint8]](
                                            cast[uint64](
                                                &out_buf[0]) + pos))
                pos = pos + n
            else:
                # `from_path` for a bind entry — what got rewritten.
                pos = _emit_path_into(out_buf, pos, out_max,
                                      &g[0].mtab[s].from_path[0])
            if pos + 1 >= out_max:
                pos = line_start
                return cast[int64](pos)
            out_buf[pos] = 32                      # ' '
            pos = pos + 1
            # Mount point. A bind stores it in `to_path`; a SRV mount
            # (mnttab_mount) zeroes `to_path` and keeps the mount point
            # in `from_path`, so render the right field per kind.
            if kind == CHAN_KIND_SRV:
                pos = _emit_path_into(out_buf, pos, out_max,
                                      &g[0].mtab[s].from_path[0])
            else:
                pos = _emit_path_into(out_buf, pos, out_max,
                                      &g[0].mtab[s].to_path[0])
            # HAMSH §14: union-mount flag, ns(1)-shape: ` -b` (MBEFORE
            # =1) / ` -a` (MAFTER=2). Plain MREPL prints nothing.
            # Mask MORDER band so MCREATE/MCACHE bits don't suppress
            # the -b/-a annotation when set alongside the order bits.
            fl: int32 = g[0].mtab[s].flag & MORDER_MASK
            if fl == 1 or fl == 2:
                if pos + 3 >= out_max:
                    pos = line_start
                    return cast[int64](pos)
                out_buf[pos] = 32                  # ' '
                out_buf[pos + 1] = 45              # '-'
                if fl == 1:
                    out_buf[pos + 2] = 98          # 'b'
                else:
                    out_buf[pos + 2] = 97          # 'a'
                pos = pos + 3
            # MCREATE (-c) / MCACHE (-C) annotations: emitted when the
            # bind set those bits. Stays grep-clean since they're
            # printable + space-prefixed; rendering is purely
            # informational (ns(1) renders MCREATE as '-c' / MCACHE
            # as '-C' in 9front).
            fl_full: int32 = g[0].mtab[s].flag
            if (fl_full & MCREATE_BIT) != 0:
                if pos + 3 >= out_max:
                    pos = line_start
                    return cast[int64](pos)
                out_buf[pos] = 32                  # ' '
                out_buf[pos + 1] = 45              # '-'
                out_buf[pos + 2] = 99              # 'c'
                pos = pos + 3
            if (fl_full & MCACHE_BIT) != 0:
                if pos + 3 >= out_max:
                    pos = line_start
                    return cast[int64](pos)
                out_buf[pos] = 32                  # ' '
                out_buf[pos + 1] = 45              # '-'
                out_buf[pos + 2] = 67              # 'C'
                pos = pos + 3
            # HAMSH §14: a labelled mount renders ` as <label>` so
            # `cat /proc/self/ns` names where a union branch came from.
            if g[0].mtab[s].label[0] != 0:
                if pos + 4 >= out_max:
                    pos = line_start
                    return cast[int64](pos)
                out_buf[pos] = 32                  # ' '
                out_buf[pos + 1] = 97              # 'a'
                out_buf[pos + 2] = 115             # 's'
                out_buf[pos + 3] = 32              # ' '
                pos = pos + 4
                pos = _emit_path_into(out_buf, pos, out_max,
                                      &g[0].mtab[s].label[0])
            if pos + 1 >= out_max:
                pos = line_start
                return cast[int64](pos)
            out_buf[pos] = 10                       # '\n'
            pos = pos + 1
        s = s + 1
    return cast[int64](pos)


def pgrp_for_task(slot: int32) -> uint64:
    # Forwarded accessor — chan.ad already imports task_pgrp from
    # kernel.sched.core; re-export for devproc.ad without forcing it
    # to also depend on kernel.sched.core's accessor. Returns the
    # heap pointer (uint64) so devproc can forward it straight to
    # pgrp_render_ns.
    #
    # V3.5-fix: a task whose pgrp slot was never explicitly seeded
    # at create-time reads as 0 (BSS default). Mirror current_pgrp's
    # lazy fallback to the root Pgrp — every task implicitly lives
    # in the root namespace unless it rforks RFNAMEG or has a pgrp
    # assigned at fork time. Without this fallback /proc/<pid>/ns
    # rendered empty for pid 1 (init) after the userspace recipe
    # populated the root mtab, because devproc.ad reads task slots
    # via pgrp_for_task, not via current_pgrp.
    pg: uint64 = task_pgrp(slot)
    if pg == 0:
        _ensure_root()
        pg = pgrp_root_addr
    return pg

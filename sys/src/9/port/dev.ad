# sys/src/9/port/dev.ad
#
# Plan 9 device-table accessor — the registry of built-in `#X` device
# letters (and, later, long-form names like `#console`). Mirrors the
# shape of 9front's /sys/src/9/port/dev.c, just enormously smaller
# because Hamnix doesn't have a Devtab[] array yet — the dispatch
# lives inline in fs/vfs.ad's `_open_hash_alias`. This file's job is
# to be the single source of truth for "what device letters / names
# are reserved" so the named file-server stack (chan.ad's per-word
# table) can refuse to register a sentinel entry that would collide
# with a built-in.
#
# Per docs/rootfs_partition.md "Future direction — Sentinel file":
#
#   Reserved words = the built-in device-letter set today: `c`, `p`,
#   `s`, `/`. A sentinel entry naming one of these is rejected at
#   parse time. Long-form built-ins added later (e.g. `#console` as
#   a verbose alias) join the reserved set in sys/src/9/port/dev.ad.
#
# Today's built-ins (the actual letter set fs/vfs.ad dispatches):
#
#   #c  console (read keyboard + UART RX, write printk + serial + fb)
#   #p  proc    (devproc.ad — /proc/<pid>/<file>)
#   #s  srv     (devsrv.ad  — name-server directory)
#   #/  root    (synthetic empty directory; `bind '#/' /n` parent slot)
#   #d  fd      (devfd.ad   — per-Pgrp /fd/<N> table; HAMSH §7)
#
# `#d` is a Hamnix-specific extension (fd-as-namespace), not in Plan 9;
# we reserve it too. If we add `#by-id` for stable partition aliases
# (Phase 4 of the FS-discovery work), `by-id` joins this set.
#
# Adder lacks a string-comparison primitive on heap strings; we
# enumerate the reserved set by literal comparison. The table is
# tiny (today: 5 single-char names + 1 long-form 'by-id') so a
# linear scan is fine.


# --- public surface -------------------------------------------------

def _is_reserved_single_char(c: uint8) -> int32:
    # Returns 1 if `c` is a single-byte built-in device letter.
    # Matches the dispatch arms in fs/vfs.ad::_open_hash_alias.
    if c == 99:          # 'c' — console
        return 1
    if c == 112:         # 'p' — proc
        return 1
    if c == 115:         # 's' — srv
        return 1
    if c == 47:          # '/' — root-dir slot
        return 1
    if c == 100:         # 'd' — fd device (Hamnix extension)
        return 1
    return 0


def _word_eq(s: Ptr[uint8], lit: Ptr[uint8]) -> int32:
    # NUL-terminated equality, like chan.ad's _path_eq_u8 but
    # local so dev.ad doesn't pull in chan.ad (and so the constant
    # set is kept in one place).
    i: uint64 = 0
    while True:
        a: uint8 = s[i]
        b: uint8 = lit[i]
        if a != b:
            return 0
        if a == 0:
            return 1
        i = i + 1


def is_reserved_word(name: Ptr[uint8]) -> int32:
    # Returns 1 iff `name` (NUL-terminated, no leading '#') is a
    # built-in device alias. Callers: chan.ad's named-stack
    # registration (Phase 3) and init/main.ad's sentinel parser
    # (Phase 5) — both reject collisions.
    #
    # Single-char names: forwarded to _is_reserved_single_char.
    # Long-form built-ins: enumerated below. As of today only
    # `by-id` is reserved (Phase 4 — the persistent partuuid alias).
    if name == cast[Ptr[uint8]](0):
        return 0
    if name[0] == 0:
        return 0
    # Empty-but-NUL-terminated: not a name.
    if name[1] == 0:
        # Single-char input.
        return _is_reserved_single_char(name[0])
    # Long-form built-ins.
    if _word_eq(name, cast[Ptr[uint8]]("by-id")) != 0:
        return 1
    # Single-char input that happens to be followed by a NUL is
    # already handled above; we never get here for one-byte names.
    return 0

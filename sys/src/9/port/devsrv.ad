# sys/src/9/port/devsrv.ad
#
# Plan 9 "srv" device — V3 minimum scope. Maintains a kernel-internal
# table mapping a short name (e.g. "hamwd") to the srvfd a userspace
# server posted. The classic Plan 9 9front file at
# /sys/src/9/port/devsrv.c is the prior art; this file is a tiny
# subset: just enough to populate the root-namespace surface so
# `ls /srv` works, and so future userspace post/open syscalls (V4)
# have a clean place to land.
#
# V3 scope:
#
#   * Internal API only (called from kernel-side wiring, not via
#     syscalls): devsrv_post / devsrv_open / devsrv_list /
#     devsrv_path_match.
#   * fs/vfs.ad routes any `/srv/<name>` open through
#     devsrv_path_match + devsrv_open_path so `cat /srv/<name>` works
#     once V4 lets userspace post srvfds. Until then the table starts
#     empty and `ls /srv` returns no entries.
#   * `/srv` (the directory itself, no trailing component) is handled
#     by fs/vfs.ad's dir-open path which calls devsrv_list to render
#     "name1\nname2\n..." into a kmalloc'd FD_DIR_MARK buffer.
#
# V4 scope (deferred):
#
#   * sys_srv_post(name, srvfd) syscall.
#   * sys_srv_open(name) syscall (returns srvfd; userspace can then
#     pass it to sys_mount).
#   * Refcounting of posted srvfds so a clunk on the last reference
#     closes the underlying transport.
#
# Adder quirks honoured:
#
#   * Top-level Array storage only — the name table and per-entry
#     name buffers all live at module scope.
#   * No string concat: every helper hand-writes byte-by-byte copies.

from kernel.printk.printk import printk0, printk1

# Table cap. V3 ships 16 entries — enough for hamwd + a handful of
# named-pipe-style mounts. Raise (or move to slab) when V4 lands real
# userspace post/open.
SRV_CAP: uint64 = 16

# Each name is a NUL-terminated string in a fixed 64-byte slot. Plan 9
# srv names are conventionally short (e.g. "hamwd", "factotum",
# "kbdmux") so 64 is comfortable.
SRV_NAME_MAX: uint64 = 64


class SrvEntry:
    in_use: int32                       # 0 = free, 1 = posted
    srvfd:  int32                       # the posted descriptor (poster-relative)
    # V4: which task slot posted this entry. The srvfd above is an
    # index into THIS task's fd table — devsrv_open() returns just
    # the raw int, but sys_srv_open (276) needs to copy_fd_entry
    # FROM the poster's table INTO the opener's. The poster_slot
    # field gives the opener a stable handle on the source task; we
    # don't refcount the underlying file/pipe (close_fd_in_task on
    # the poster's end will tear the pipe down even while a posted
    # name lives — Phase D's refcount work fixes that).
    poster_slot: int32                  # task_table slot index of poster
    name:   Array[64, uint8]            # NUL-terminated


# Top-level pool dodges Adder's nested-frame Array bug.
srv_table: Array[16, SrvEntry]

# Lazy-init guard. The table is zeroed by BSS so `in_use == 0` on every
# slot at boot — but a future warm-reset path may want to wipe it
# explicitly. The flag is also a cheap probe for "have we ever
# touched this table" from devmounts.ad-style introspection.
srv_inited: int32 = 0


# F10-2 #455: server-boundary perm policy for the `#s` name server. Open
# (read) of `#s/<name>` is world-OK: anyone may consume a posted
# srvfd (Plan 9 srv is the rendezvous, the post is the gate). Write
# (post) is route-by-construction: SYS_SRV_POST has its own validation
# in arch/x86/kernel/syscall.ad (the poster owns the srvfd it's
# publishing), and the `#s` letter has NO mutating open path through
# vfs_open_write today — listing `#s` itself or reading `#s/<name>` are
# the only verbs. v1 admits world-r/w; tightening to hostowner-only on
# `unpost` etc. is a per-verb gate inside devsrv_post / devsrv_unpost.
#
# Numeric contract matches the rest of the perm-check family.
def devsrv_perm_check(name: Ptr[char], want: int32) -> int32:
    # World-r/w on the srv directory and posted entries. SYS_SRV_POST is
    # not a vfs_open_write; it's a dedicated syscall that validates the
    # caller against the srvfd it's publishing.
    _unused: Ptr[char] = name
    _unused2: int32 = want
    return 0


def devsrv_init():
    # Idempotent. Zero every slot's in_use byte; clears stale state in
    # case anyone re-runs us. Called from chan.ad's pgrp_init (which
    # itself is called by init/main.ad's chan_init), so the table is
    # live before the first user task starts.
    i: uint64 = 0
    while i < SRV_CAP:
        srv_table[i].in_use = 0
        srv_table[i].srvfd  = -1
        srv_table[i].poster_slot = -1
        srv_table[i].name[0] = 0
        i = i + 1
    srv_inited = 1


def _srv_strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _srv_streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    # NUL-terminated equality. 1 on match, 0 otherwise.
    i: uint64 = 0
    while True:
        ca: uint8 = a[i]
        cb: uint8 = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1


def _srv_find(name: Ptr[uint8]) -> int32:
    # Linear scan; returns slot index or -1.
    i: uint64 = 0
    while i < SRV_CAP:
        if srv_table[i].in_use != 0:
            if _srv_streq(&srv_table[i].name[0], name) != 0:
                return cast[int32](i)
        i = i + 1
    return -1


def _srv_find_free() -> int32:
    i: uint64 = 0
    while i < SRV_CAP:
        if srv_table[i].in_use == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def devsrv_post(name: Ptr[char], srvfd: int32) -> int32:
    # V3 entry point — no poster task recorded. Kept so the
    # V3-shape callers (kernel-internal smoke tests, future
    # hamwd-as-9P-server posting from kernel space) continue to
    # work. Returns 0 on success, -1 on dup-name or table-full.
    # Phase D rolls this into devsrv_post_from with poster_slot=-1
    # so the (rare) opener of a kernel-posted name sees an honest
    # "no source task" and falls back to ENOENT instead of trying
    # to copy_fd_entry out of slot -1.
    return devsrv_post_from(name, srvfd, -1)


def devsrv_post_from(name: Ptr[char], srvfd: int32,
                     poster_slot: int32) -> int32:
    # V4: post (name -> srvfd) and record which task slot owns the
    # underlying file/pipe so sys_srv_open can copy_fd_entry into the
    # opener's table. poster_slot = -1 means "kernel-posted, no source
    # task" — opens of that name still match the entry, but
    # devsrv_lookup_full returns -1 in *out_slot and sys_srv_open
    # bails with errstr "srv: kernel-only".
    if srv_inited == 0:
        devsrv_init()
    np: Ptr[uint8] = cast[Ptr[uint8]](name)
    nlen: uint64 = _srv_strlen(np)
    if nlen == 0 or nlen + 1 > SRV_NAME_MAX:
        return -1
    if _srv_find(np) >= 0:
        return -1                                    # dup name
    slot: int32 = _srv_find_free()
    if slot < 0:
        return -1                                    # table full
    su: uint64 = cast[uint64](slot)
    i: uint64 = 0
    while i < nlen:
        srv_table[su].name[i] = np[i]
        i = i + 1
    srv_table[su].name[nlen] = 0
    srv_table[su].srvfd       = srvfd
    srv_table[su].poster_slot = poster_slot
    srv_table[su].in_use      = 1
    return 0


def devsrv_open(name: Ptr[char]) -> int32:
    # Look up name and return its posted srvfd as an opaque integer.
    # -1 on miss. V3 used this for `/srv/<name>` opens from a task
    # that happened to be the same as the poster; V4 keeps the
    # function for back-compat (fs/vfs.ad still calls it on the
    # implicit-route path) but adds devsrv_lookup_full() below for
    # the cross-task dup case sys_srv_open needs.
    if srv_inited == 0:
        devsrv_init()
    np: Ptr[uint8] = cast[Ptr[uint8]](name)
    slot: int32 = _srv_find(np)
    if slot < 0:
        return -1
    return srv_table[cast[uint64](slot)].srvfd


def devsrv_lookup_full(name: Ptr[char], out_slot: Ptr[int32],
                       out_fd: Ptr[int32]) -> int32:
    # V4: structured lookup. Fills *out_slot with the poster's
    # task_table slot index (or -1 for a kernel-posted entry) and
    # *out_fd with the poster-relative srvfd. Returns 0 on hit,
    # -1 on miss. sys_srv_open uses this then does copy_fd_entry
    # from task_table[*out_slot] into the current task.
    if srv_inited == 0:
        devsrv_init()
    np: Ptr[uint8] = cast[Ptr[uint8]](name)
    slot: int32 = _srv_find(np)
    if slot < 0:
        return -1
    su: uint64 = cast[uint64](slot)
    out_slot[0] = srv_table[su].poster_slot
    out_fd[0]   = srv_table[su].srvfd
    return 0


def devsrv_unpost(name: Ptr[char]) -> int32:
    # Drop a name from the table. Used by V4 cleanup; included now so
    # tests / a future warm-reset path have a knob. Returns 0 on
    # success, -1 if the name wasn't present.
    if srv_inited == 0:
        devsrv_init()
    np: Ptr[uint8] = cast[Ptr[uint8]](name)
    slot: int32 = _srv_find(np)
    if slot < 0:
        return -1
    su: uint64 = cast[uint64](slot)
    srv_table[su].in_use      = 0
    srv_table[su].srvfd       = -1
    srv_table[su].poster_slot = -1
    srv_table[su].name[0]     = 0
    return 0


def devsrv_list(out_buf: Ptr[uint8], out_max: uint64) -> int64:
    # Pack every posted name into out_buf as "name1\nname2\n..." lines.
    # Returns bytes written; truncates at out_max if the buffer is too
    # small (last partial entry is dropped, not split). Empty table ->
    # 0 bytes. Used by fs/vfs.ad's "ls /srv" / `cat /srv` path.
    if srv_inited == 0:
        devsrv_init()
    pos: uint64 = 0
    i: uint64 = 0
    while i < SRV_CAP:
        if srv_table[i].in_use != 0:
            nlen: uint64 = _srv_strlen(&srv_table[i].name[0])
            # Need nlen + 1 bytes (the name + '\n').
            if pos + nlen + 1 > out_max:
                return cast[int64](pos)
            k: uint64 = 0
            while k < nlen:
                out_buf[pos + k] = srv_table[i].name[k]
                k = k + 1
            out_buf[pos + nlen] = 10                # '\n'
            pos = pos + nlen + 1
        i = i + 1
    return cast[int64](pos)


# --- F10-6 #458: Dir-record listing -----------------------------------
#
# devsrv_list_dir(out, cap) emits every posted /srv entry as a Plan 9
# Dir record (see lib/p9.ad wire format header). This is the first
# migrated backing for the Dir-record opt-in path; #s entries' qids
# are synthesised from the table slot (qpath = slot+1, qver = 0,
# qtype = 0 since posted srvfds are conceptually files). The encoder
# lives in lib/p9.ad but it's just a byte serializer — the kernel can
# call it without dragging the userspace half of lib/p9.ad in.

from lib.p9dir import p9_dir_encode_into
from lib.9p.9p import P9_QTFILE


# /srv entries are world-readable by F10-2 policy (devsrv_perm_check
# above returns 0 for any want); render that into the Dir.mode field
# as 0444 plus DMDIR=0 (entries are files, not subdirs).
SRV_DIR_MODE: uint32 = 0x00000444

# Hostowner uname for the posted-by field. v1 of #s doesn't track
# per-poster identity in the wire emission; muid is left empty. The
# user/group fields are filled with the canonical "hostowner" string
# matching docs/security.md's #s policy.
_srv_uname: Array[16, uint8]
_srv_uname_inited: int32 = 0


def _srv_init_uname():
    # Render "hostowner\0" into _srv_uname. Idempotent.
    if _srv_uname_inited != 0:
        return
    s: Ptr[uint8] = "hostowner"
    i: uint64 = 0
    while s[i] != 0:
        _srv_uname[i] = s[i]
        i = i + 1
    _srv_uname[i] = 0
    _srv_uname_inited = 1


def devsrv_list_dir(out_buf: Ptr[uint8], out_max: uint64) -> int64:
    # F10-6: like devsrv_list but emits one Plan 9 Dir record per posted
    # entry instead of NAME\n lines. Wire format is described in
    # lib/p9.ad. Returns bytes written; stops cleanly at the first
    # entry that would overflow (no partial record).
    if srv_inited == 0:
        devsrv_init()
    _srv_init_uname()
    pos: uint64 = 0
    uname_p: Ptr[uint8] = cast[Ptr[uint8]](&_srv_uname[0])
    uname_len: uint64 = _srv_strlen(uname_p)
    i: uint64 = 0
    while i < SRV_CAP:
        if srv_table[i].in_use != 0:
            nlen: uint64 = _srv_strlen(&srv_table[i].name[0])
            wrote: uint64 = p9_dir_encode_into(
                out_buf, pos, out_max,
                P9_QTFILE,                              # qid_type
                0,                                      # qid_version
                cast[uint64](i) + 1,                    # qid_path
                SRV_DIR_MODE,                           # mode
                0, 0,                                   # atime, mtime
                0,                                      # length
                &srv_table[i].name[0], nlen,
                uname_p, uname_len,                     # uid
                uname_p, uname_len,                     # gid
                uname_p, 0)                             # muid (empty)
            if wrote == 0:
                # No room for this record — stop cleanly so the caller
                # gets a clean stream of complete records (per spec).
                return cast[int64](pos)
            pos = pos + wrote
        i = i + 1
    return cast[int64](pos)


def devsrv_path_match(path: Ptr[char]) -> int32:
    # 1 iff `path` looks like "/srv/<non-empty>" with no further '/'
    # in the leaf. fs/vfs.ad uses this to fork into devsrv dispatch
    # vs. its other routes (initramfs, ext4, ...). The "no further /"
    # gate is important: `/srv/foo/bar` is not a srv-table lookup —
    # whether it means "walk through the mounted server" or "ENOENT"
    # is a V4 question.
    if path[0] != 47:                               # '/'
        return 0
    if path[1] != 115 or path[2] != 114 \
            or path[3] != 118 or path[4] != 47:     # "srv/"
        return 0
    if path[5] == 0:
        return 0                                    # bare "/srv/"
    i: uint64 = 5
    while path[i] != 0:
        if path[i] == 47:                           # '/'
            return 0                                # nested path
        i = i + 1
    return 1


def devsrv_is_srv_dir(path: Ptr[char]) -> int32:
    # 1 iff `path` is exactly "/srv" (no trailing slash, no leaf).
    # fs/vfs.ad uses this for the directory-listing path.
    if path[0] != 47 or path[1] != 115 or path[2] != 114 \
            or path[3] != 118:
        return 0
    if path[4] != 0:
        return 0
    return 1


def devsrv_extract_name(path: Ptr[char], out: Ptr[uint8],
                        out_max: uint64) -> int32:
    # Copy the leaf of "/srv/<name>" into out (NUL-terminated). Returns
    # 0 on success, -1 if the path doesn't match the expected shape
    # or the leaf wouldn't fit. Callers are expected to have already
    # passed devsrv_path_match.
    if devsrv_path_match(path) == 0:
        return -1
    i: uint64 = 5                                   # skip "/srv/"
    j: uint64 = 0
    while path[i] != 0:
        if j + 1 >= out_max:
            return -1
        out[j] = cast[uint8](path[i] & 0xFF)
        i = i + 1
        j = j + 1
    out[j] = 0
    return 0


def devsrv_count() -> uint64:
    # Number of live entries. Used by tests / introspection.
    if srv_inited == 0:
        return 0
    n: uint64 = 0
    i: uint64 = 0
    while i < SRV_CAP:
        if srv_table[i].in_use != 0:
            n = n + 1
        i = i + 1
    return n

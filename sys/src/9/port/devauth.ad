# sys/src/9/port/devauth.ad
#
# docs/security.md Phase 4: the kernel-side authentication cdev.
#
# Plan-9-shape factotum primitive — userland NEVER reads /etc/shadow
# directly. Authentication is mediated through this device:
#
#   fd = open("/dev/auth", ORDWR)
#   write(fd, "user <name>\n")
#   write(fd, "pass <plaintext>\n")
#   read(fd, response)         # "ok\n <uid> <gid>\n" or "denied\n"
#   close(fd)
#
# On a successful pass+verify the cdev stamps an authenticated-uid/gid
# pair into the per-fd state. The hostowner-side caller (`newshell`)
# then issues SYS_SETUID(target_uid) which the kernel will honour
# because hostowner can downgrade (and `newshell` itself runs under
# hostowner when it's used to ELEVATE — the original Plan-9 idiom is
# regular-user→hostowner, gated by the password).
#
# Rate limit: 1 attempt/second per fd, enforced by a per-fd
# last_attempt_us timestamp pulled from pit_monotonic_us (which keeps
# advancing during syscalls — get_jiffies freezes while IF=0). On a
# failed verify we busy-wait until 1 s has elapsed since the last
# attempt; the next write blocks the caller for the full second.
#
# The cdev reads /etc/shadow directly from the kernel-mode initramfs
# (initramfs_data_ptr) — independent of the calling task's namespace,
# so a regular user whose namespace doesn't bind /etc/shadow can still
# authenticate via this path.
#
# Per-fd state lives in a small fixed pool (8 slots). Open allocates,
# close frees. If the pool is exhausted, open returns -EMFILE.
#
# Compiler-quirk note: Adder has a flat global symbol namespace across
# merged modules — every shared-shape helper is prefixed `_au_` to avoid
# collisions with the existing dev*.ad family.

from arch.x86.kernel.time import pit_monotonic_us
from fs.vfs import (
    vfs_read, vfs_write, vfs_close,
    vfs_open_kernel, vfs_open_write_kernel, resolve_path,
)
from sys.src.port9.port.devrandom import devrandom_read
from lib.passwd.shadow import (
    shadow_parse, shadow_lookup_by_name, shadow_entry_hash,
    shadow_entry_name, shadow_entry_lchg, shadow_entry_count,
)
from lib.passwd.passwd import (
    passwd_parse, passwd_lookup_by_name, passwd_entry_uid,
    passwd_entry_gid,
)
from lib.crypt.sha512_crypt import sha512_crypt_verify, sha512_crypt
from kernel.printk.printk import printk0
from kernel.sched.core import current_task_uid


# Phase 4b: FD_AUTH_MARK (0xFFFFFFF7) is RETIRED. A /dev/auth open now
# installs an FD_CHAN_MARK fd backed by a DEV_AUTH pool chan
# (sys/src/9/port/namec.ad) whose back_slot is the AuthSlot index
# below; namec_read/namec_write/namec_close dispatch by name into
# devauth_read/devauth_write/devauth_close. (Historical note kept for
# the archaeology: the mark's first value 0xFFFFFFE3 collided with
# FD_P9_MARK, silently misrouting every /dev/auth write into p9c_write
# — the kind of dispatch fragility the chan migration removes.)


# Per-fd state pool. Each /dev/auth open gets one slot. Slots are
# referenced via the slot index packed into fd_buf at open time.
AUTH_POOL_CAP:     uint64 = 8
AUTH_NAME_MAX:     uint64 = 64
AUTH_PASS_MAX:     uint64 = 128
AUTH_RESPONSE_MAX: uint64 = 64


class AuthSlot:
    in_use:           int32                # 0 = free, 1 = live
    user_set:         int32                # 1 once "user <name>" parsed
    pass_set:         int32                # 1 once "pass ..." parsed
    verified:         int32                # 1 once verify succeeded
    user_buf:         Array[64, uint8]     # AUTH_NAME_MAX bytes
    pass_buf:         Array[128, uint8]    # AUTH_PASS_MAX bytes
    user_len:         uint64
    pass_len:         uint64
    auth_uid:         uint32               # only valid if verified == 1
    auth_gid:         uint32               # only valid if verified == 1
    last_attempt_us:  uint64               # for rate-limit gate
    response_buf:     Array[64, uint8]     # rendered "ok\n..." / "denied\n"
    response_len:     uint64               # bytes in response_buf
    response_pos:     uint64               # read cursor into response_buf


auth_pool: Array[8, AuthSlot]
auth_pool_inited: int32 = 0

# Scratch buffers for /etc/passwd + /etc/shadow snapshots. Static
# module-scope per the no-malloc-in-kernel-leafs convention.
auth_passwd_buf: Array[4096, uint8]
auth_shadow_buf: Array[4096, uint8]
# Resolved-path scratch — /etc/shadow rewrites to the live sysroot path
# (#sysroot/etc/shadow → /ext/...) via resolve_path before we open it.
auth_path_buf:   Array[256, uint8]


# F10-2 #455: server-boundary perm policy for the `#auth` credential
# mediator (/dev/auth). The rule is "admit everyone": anyone must be
# able to authenticate, so opening /dev/auth must not refuse on uid.
# The actual gate is INSIDE the cdev: rate-limit (1/sec/wallclock) +
# constant-time hash compare in _au_try_verify; a wrong password
# returns "denied", not a permission error. The setpass verb's
# uid==1-or-self gate lives in _au_setpass (see devauth_write).
#
# Numeric contract matches the rest of the perm-check family.
def devauth_perm_check(name: Ptr[char], want: int32) -> int32:
    # Admit all. The "policy" here is wire-shape only; the real gate is
    # inside the cdev (rate-limit + constant-time compare for verify,
    # uid==1-or-self for setpass).
    _unused: Ptr[char] = name
    _unused2: int32 = want
    return 0


def _au_init_pool():
    if auth_pool_inited != 0:
        return
    auth_pool_inited = 1
    i: uint64 = 0
    while i < AUTH_POOL_CAP:
        auth_pool[i].in_use = 0
        auth_pool[i].user_set = 0
        auth_pool[i].pass_set = 0
        auth_pool[i].verified = 0
        auth_pool[i].user_len = 0
        auth_pool[i].pass_len = 0
        auth_pool[i].auth_uid = 0
        auth_pool[i].auth_gid = 0
        auth_pool[i].last_attempt_us = 0
        auth_pool[i].response_len = 0
        auth_pool[i].response_pos = 0
        i = i + 1


def _au_alloc_slot() -> int32:
    _au_init_pool()
    i: uint64 = 0
    while i < AUTH_POOL_CAP:
        if auth_pool[i].in_use == 0:
            auth_pool[i].in_use = 1
            auth_pool[i].user_set = 0
            auth_pool[i].pass_set = 0
            auth_pool[i].verified = 0
            auth_pool[i].user_len = 0
            auth_pool[i].pass_len = 0
            auth_pool[i].auth_uid = 0
            auth_pool[i].auth_gid = 0
            auth_pool[i].last_attempt_us = 0
            auth_pool[i].response_len = 0
            auth_pool[i].response_pos = 0
            return cast[int32](i)
        i = i + 1
    return -1


def _au_free_slot(slot: int32):
    if slot < 0:
        return
    s: uint64 = cast[uint64](slot)
    if s >= AUTH_POOL_CAP:
        return
    auth_pool[s].in_use = 0
    auth_pool[s].user_set = 0
    auth_pool[s].pass_set = 0
    auth_pool[s].verified = 0
    # Wipe the pass_buf so a freed slot doesn't keep plaintext around.
    j: uint64 = 0
    while j < AUTH_PASS_MAX:
        auth_pool[s].pass_buf[j] = 0
        j = j + 1


def _au_starts_with(buf: Ptr[uint8], blen: uint64,
                    prefix: Ptr[uint8], plen: uint64) -> int32:
    if blen < plen:
        return 0
    i: uint64 = 0
    while i < plen:
        if buf[i] != prefix[i]:
            return 0
        i = i + 1
    return 1


def _au_strip_trailing(buf: Ptr[uint8], n: uint64) -> uint64:
    # Strip trailing CR / LF / space / tab.
    while n > 0:
        c: uint8 = buf[n - 1]
        if c == 10 or c == 13 or c == 32 or c == 9:
            n = n - 1
        else:
            break
    return n


def _au_emit_u32(value: uint32, out: Ptr[uint8], pos: uint64) -> uint64:
    # Append the decimal of value to out[pos..].
    v: uint64 = cast[uint64](value)
    if v == 0:
        out[pos] = 48
        return pos + 1
    digits: Array[12, uint8]
    n: uint64 = 0
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    written: uint64 = n
    while n > 0:
        n = n - 1
        out[pos] = digits[n]
        pos = pos + 1
    return pos


def _au_render_ok(slot: uint64):
    # Render "ok <uid> <gid>\n" into the slot's response_buf.
    p: Ptr[uint8] = &auth_pool[slot].response_buf[0]
    pos: uint64 = 0
    p[pos] = 111                                       # 'o'
    pos = pos + 1
    p[pos] = 107                                       # 'k'
    pos = pos + 1
    p[pos] = 32                                        # ' '
    pos = pos + 1
    pos = _au_emit_u32(auth_pool[slot].auth_uid, p, pos)
    p[pos] = 32                                        # ' '
    pos = pos + 1
    pos = _au_emit_u32(auth_pool[slot].auth_gid, p, pos)
    p[pos] = 10                                        # '\n'
    pos = pos + 1
    auth_pool[slot].response_len = pos
    auth_pool[slot].response_pos = 0


def _au_render_ok_bare(slot: uint64):
    # Render a bare "ok\n" — used by the setpass verb, which has no
    # uid/gid to report (it sets a password, it doesn't authenticate).
    p: Ptr[uint8] = &auth_pool[slot].response_buf[0]
    p[0] = 111                                         # 'o'
    p[1] = 107                                         # 'k'
    p[2] = 10                                          # '\n'
    auth_pool[slot].response_len = 3
    auth_pool[slot].response_pos = 0


def _au_render_denied(slot: uint64):
    p: Ptr[uint8] = &auth_pool[slot].response_buf[0]
    p[0] = 100                                         # 'd'
    p[1] = 101                                         # 'e'
    p[2] = 110                                         # 'n'
    p[3] = 105                                         # 'i'
    p[4] = 101                                         # 'e'
    p[5] = 100                                         # 'd'
    p[6] = 10                                          # '\n'
    auth_pool[slot].response_len = 7
    auth_pool[slot].response_pos = 0


def _au_rate_limit_gate(slot: uint64):
    # Block (busy-wait against pit_monotonic_us) until at least 1 s has
    # elapsed since this slot's last_attempt_us. pit_monotonic_us keeps
    # advancing while EFLAGS.IF=0 (i.e. inside a syscall), so this
    # actually progresses in this context.
    last: uint64 = auth_pool[slot].last_attempt_us
    if last == 0:
        # First attempt — no rate-limit applies yet.
        return
    deadline: uint64 = last + 1000000                  # +1 s in microseconds
    while True:
        now: uint64 = pit_monotonic_us()
        if now >= deadline:
            return


def _au_read_live_file(path: Ptr[char], buf: Ptr[uint8],
                       cap: uint64) -> int64:
    # F3 #448: read the LIVE file at `path` through the VFS in kernel
    # context, bypassing the server-boundary perm gate via
    # vfs_open_kernel. The credentials server is privileged-by-
    # construction: this function is only reachable from devauth's
    # in-kernel auth path, which has no userland-callable counterpart.
    # The Plan-9 invariant holds — userland NEVER opens /etc/shadow
    # directly (the ext4 backend's mode-bit policy denies it on the
    # 0600 hostowner-owned file), and the kernel-context entry point
    # is the explicit-by-construction successor to the global
    # `vfs_auth_mediator_active` backdoor flag the pre-F3 code raised.
    #
    # resolve_path applies the caller's mount-table rewrite (/ bound to
    # #sysroot), so "/etc/shadow" lands on the live ext4 root copy —
    # the same file passwd/useradd write — not the frozen initramfs.
    if resolve_path(path, &auth_path_buf[0], 256) != 0:
        return cast[int64](-1)
    fd: int32 = vfs_open_kernel(cast[Ptr[char]](&auth_path_buf[0]))
    if fd < 0:
        return cast[int64](-1)
    total: uint64 = 0
    while total < cap:
        n: int64 = vfs_read(fd, &buf[total], cap - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    vfs_close(fd)
    return cast[int64](total)


def _au_try_verify(slot: uint64) -> int32:
    # Read the LIVE /etc/shadow + /etc/passwd through the VFS and verify
    # the stashed (user_buf, pass_buf) against the recorded $6$ hash. On
    # success, populates auth_uid/auth_gid and returns 1; on failure
    # returns 0. Either way, last_attempt_us is bumped (the rate-limit
    # gate consults it on the next attempt).
    #
    # CRUX: we deliberately consult the LIVE namespace copy — the one
    # passwd writes — NOT the frozen initramfs copy. After any useradd /
    # passwd the two diverge; authenticating against the live copy is
    # what makes a freshly-set password work in the same boot.
    auth_pool[slot].last_attempt_us = pit_monotonic_us()

    # Snapshot the LIVE /etc/passwd.
    pwd_n: int64 = _au_read_live_file(cast[Ptr[char]]("/etc/passwd"),
                                      &auth_passwd_buf[0], 4096)
    if pwd_n <= 0:
        printk0("auth: cannot read live /etc/passwd\n")
        return 0
    passwd_parse(&auth_passwd_buf[0], cast[uint64](pwd_n))
    pidx: int32 = passwd_lookup_by_name(&auth_pool[slot].user_buf[0])
    if pidx < 0:
        return 0
    target_uid: uint32 = passwd_entry_uid(pidx)
    target_gid: uint32 = passwd_entry_gid(pidx)

    # Snapshot the LIVE /etc/shadow.
    shd_n: int64 = _au_read_live_file(cast[Ptr[char]]("/etc/shadow"),
                                      &auth_shadow_buf[0], 4096)
    if shd_n <= 0:
        printk0("auth: cannot read live /etc/shadow\n")
        return 0
    shadow_parse(&auth_shadow_buf[0], cast[uint64](shd_n))
    sidx: int32 = shadow_lookup_by_name(&auth_pool[slot].user_buf[0])
    if sidx < 0:
        return 0
    hash_triple: Ptr[uint8] = shadow_entry_hash(sidx)
    if hash_triple == cast[Ptr[uint8]](0):
        return 0

    # Constant-time verify.
    ok: int32 = sha512_crypt_verify(&auth_pool[slot].pass_buf[0], hash_triple)
    if ok == 0:
        return 0
    auth_pool[slot].auth_uid = target_uid
    auth_pool[slot].auth_gid = target_gid
    auth_pool[slot].verified = 1
    return 1


# --- setpass: hostowner-gated password SET, kernel-mediated ----------
#
# docs/security.md: the kernel is the SOLE writer of the shadow secret,
# mirroring how it is the sole reader. `passwd` (user/passwd.ad) drives
# this via: write "user <name>\n" then "setpass <plaintext>\n". The
# kernel generates a fresh $6$<salt>$<hash> and rewrites the live
# /etc/shadow entry for <name>, replacing the `!` lock. Userland never
# sees the hash. Gated so only the hostowner (uid 1) or the user
# changing THEIR OWN password may set it (matches useradd's threat
# model: hostowner provisions, a user owns their own credential).

# crypt-base64 alphabet for salt chars: '.', '/', '0'..'9','A'..'Z',
# 'a'..'z'. Exactly the set glibc's $6$ salt draws from.
au_salt_alpha: Array[64, uint8]
au_salt_inited: int32 = 0

# Scratch for the generated $6$<salt>$<hash> and the rewritten shadow.
au_hash_buf:    Array[128, uint8]
au_shadow_out:  Array[4096, uint8]
au_salt_buf:    Array[24, uint8]


def _au_init_salt_alpha():
    if au_salt_inited != 0:
        return
    au_salt_inited = 1
    au_salt_alpha[0] = 46                                   # '.'
    au_salt_alpha[1] = 47                                   # '/'
    i: uint64 = 0
    while i < 10:
        au_salt_alpha[2 + i] = cast[uint8](48 + i)         # '0'..'9'
        i = i + 1
    i = 0
    while i < 26:
        au_salt_alpha[12 + i] = cast[uint8](65 + i)        # 'A'..'Z'
        i = i + 1
    i = 0
    while i < 26:
        au_salt_alpha[38 + i] = cast[uint8](97 + i)        # 'a'..'z'
        i = i + 1


def _au_gen_salt(out: Ptr[uint8]) -> uint64:
    # Generate a 16-char `$6$<salt>` prefix into `out` (NUL-terminated).
    # `out` must hold at least 20 bytes. Returns the string length.
    _au_init_salt_alpha()
    out[0] = 36                                             # '$'
    out[1] = 54                                             # '6'
    out[2] = 36                                             # '$'
    rnd: Array[16, uint8]
    devrandom_read(&rnd[0], 16)
    i: uint64 = 0
    while i < 16:
        out[3 + i] = au_salt_alpha[cast[uint64](rnd[i]) & 63]
        i = i + 1
    out[19] = 0
    return 19


def _au_setpass(slot: uint64) -> int32:
    # Replace the live /etc/shadow hash for the slot's stashed user with
    # a fresh $6$ hash of the slot's stashed plaintext. Returns 1 on
    # success, 0 on failure. Authorization is checked by the caller
    # (devauth_write) BEFORE this runs.
    #
    # 1. Read the LIVE /etc/shadow.
    shd_n: int64 = _au_read_live_file(cast[Ptr[char]]("/etc/shadow"),
                                      &auth_shadow_buf[0], 4096)
    if shd_n < 0:
        printk0("auth: setpass cannot read live /etc/shadow\n")
        return 0
    shadow_parse(&auth_shadow_buf[0], cast[uint64](shd_n))
    sidx: int32 = shadow_lookup_by_name(&auth_pool[slot].user_buf[0])
    if sidx < 0:
        # No shadow line for this user — refuse (useradd creates the
        # locked stub; passwd-ing a never-added user is an error).
        printk0("auth: setpass no shadow entry for user\n")
        return 0

    # 2. Generate $6$<salt>$<hash> of the plaintext.
    _au_gen_salt(&au_salt_buf[0])
    sha512_crypt(&auth_pool[slot].pass_buf[0], &au_salt_buf[0],
                 &au_hash_buf[0])

    # 3. Render a fresh /etc/shadow: every entry verbatim, but the
    #    target's hash replaced with the new triple. lchg kept (0 from
    #    useradd's `:!:0` stub is fine — "force change" semantics aren't
    #    enforced in v1).
    out_pos: uint64 = 0
    cnt: uint64 = shadow_entry_count()
    e: uint64 = 0
    while e < cnt:
        nm: Ptr[uint8] = shadow_entry_name(cast[int32](e))
        # name
        k: uint64 = 0
        while nm[k] != 0 and out_pos + 1 < 4096:
            au_shadow_out[out_pos] = nm[k]
            out_pos = out_pos + 1
            k = k + 1
        if out_pos + 1 < 4096:
            au_shadow_out[out_pos] = 58                     # ':'
            out_pos = out_pos + 1
        # hash field: substitute for the target, verbatim otherwise.
        hsrc: Ptr[uint8] = shadow_entry_hash(cast[int32](e))
        if cast[int32](e) == sidx:
            hsrc = &au_hash_buf[0]
        k = 0
        while hsrc[k] != 0 and out_pos + 1 < 4096:
            au_shadow_out[out_pos] = hsrc[k]
            out_pos = out_pos + 1
            k = k + 1
        if out_pos + 1 < 4096:
            au_shadow_out[out_pos] = 58                     # ':'
            out_pos = out_pos + 1
        # lchg (decimal)
        out_pos = _au_emit_u64(shadow_entry_lchg(cast[int32](e)),
                               &au_shadow_out[0], out_pos)
        if out_pos + 1 < 4096:
            au_shadow_out[out_pos] = 10                     # '\n'
            out_pos = out_pos + 1
        e = e + 1

    # 4. Write the rewritten shadow back through the LIVE namespace
    #    via vfs_open_write_kernel — the explicit-by-construction
    #    kernel-context write entry replacing the pre-F3 mediator-flag
    #    backdoor. resolve_path rewrites "/etc/shadow" to the live
    #    sysroot copy first. vfs_open_write_kernel truncates+creates.
    if resolve_path(cast[Ptr[char]]("/etc/shadow"),
                    &auth_path_buf[0], 256) != 0:
        printk0("auth: setpass resolve_path(/etc/shadow) failed\n")
        return 0
    wfd: int32 = vfs_open_write_kernel(cast[Ptr[char]](&auth_path_buf[0]))
    if wfd < 0:
        printk0("auth: setpass cannot open /etc/shadow for write\n")
        return 0
    wn: int64 = vfs_write(wfd, &au_shadow_out[0], out_pos)
    vfs_close(wfd)
    if wn < 0 or cast[uint64](wn) != out_pos:
        printk0("auth: setpass short write to /etc/shadow\n")
        return 0
    return 1


def _au_emit_u64(value: uint64, out: Ptr[uint8], pos: uint64) -> uint64:
    if value == 0:
        out[pos] = 48
        return pos + 1
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    while n > 0:
        n = n - 1
        out[pos] = digits[n]
        pos = pos + 1
    return pos


# --- public API ------------------------------------------------------

def devauth_alloc() -> int32:
    # Allocate a fresh per-fd slot. Returns the slot index (>=0) or -1
    # on pool exhaustion. vfs_open / vfs_open_write call this when an
    # open of /dev/auth arrives; the slot index is packed into fd_buf
    # so read/write can find it.
    return _au_alloc_slot()


def devauth_close(slot: int32):
    _au_free_slot(slot)


def devauth_read(slot: int32, buf: Ptr[uint8], count: uint64) -> int64:
    # Drain the rendered response buffer ("ok\n <uid> <gid>\n" or
    # "denied\n"). Returns 0 if no response has been generated yet
    # (caller hasn't issued user+pass writes), letting userland's
    # readline loop know to keep waiting / writing.
    if slot < 0:
        return cast[int64](-9)                         # -EBADF
    s: uint64 = cast[uint64](slot)
    if s >= AUTH_POOL_CAP or auth_pool[s].in_use == 0:
        return cast[int64](-9)
    if count == 0:
        return 0
    rem: uint64 = auth_pool[s].response_len - auth_pool[s].response_pos
    if rem == 0:
        # Either no attempt was made yet (response_len == 0) — in which
        # case userland's typical "open / write user / write pass / read"
        # sequence will have populated response_len BEFORE the first
        # read, OR the response has been fully drained. Either way,
        # return 0 to signal EOF/no-more-bytes.
        return 0
    take: uint64 = count
    if take > rem:
        take = rem
    base: uint64 = auth_pool[s].response_pos
    i: uint64 = 0
    while i < take:
        buf[i] = auth_pool[s].response_buf[base + i]
        i = i + 1
    auth_pool[s].response_pos = base + take
    return cast[int64](take)


def devauth_write(slot: int32, buf: Ptr[uint8], count: uint64) -> int64:
    # Parse a "user <name>\n" or "pass <plaintext>\n" line. On the FIRST
    # line that completes the pair, run the verify and render the
    # response. The caller's typical usage pattern is one full line per
    # write() syscall, but we tolerate writes that are missing the
    # trailing newline (we treat the buffer as one line and strip).
    if slot < 0:
        return cast[int64](-9)                         # -EBADF
    s: uint64 = cast[uint64](slot)
    if s >= AUTH_POOL_CAP or auth_pool[s].in_use == 0:
        return cast[int64](-9)
    if count == 0:
        return 0
    # Determine the line length (strip a single trailing newline so
    # "user alice\n" and "user alice" both parse).
    nl: uint64 = count
    if nl > 0 and buf[nl - 1] == 10:
        nl = nl - 1
    # Re-strip the residual CR / spaces / tabs.
    nl = _au_strip_trailing(buf, nl)
    user_prefix: Ptr[uint8] = "user "
    pass_prefix: Ptr[uint8] = "pass "
    setpass_prefix: Ptr[uint8] = "setpass "
    if _au_starts_with(buf, nl, user_prefix, 5) != 0:
        # Copy bytes 5..nl into user_buf.
        ul: uint64 = nl - 5
        if ul + 1 > AUTH_NAME_MAX:
            ul = AUTH_NAME_MAX - 1
        i: uint64 = 0
        while i < ul:
            auth_pool[s].user_buf[i] = buf[5 + i]
            i = i + 1
        auth_pool[s].user_buf[ul] = 0
        auth_pool[s].user_len = ul
        auth_pool[s].user_set = 1
        # Reset any prior verification: the user changed.
        auth_pool[s].verified = 0
        auth_pool[s].response_len = 0
        auth_pool[s].response_pos = 0
        return cast[int64](count)
    if _au_starts_with(buf, nl, pass_prefix, 5) != 0:
        pl: uint64 = nl - 5
        if pl + 1 > AUTH_PASS_MAX:
            pl = AUTH_PASS_MAX - 1
        i: uint64 = 0
        while i < pl:
            auth_pool[s].pass_buf[i] = buf[5 + i]
            i = i + 1
        auth_pool[s].pass_buf[pl] = 0
        auth_pool[s].pass_len = pl
        auth_pool[s].pass_set = 1
        # Once we've seen both, run the verify. Rate-limit FIRST so a
        # brute-force loop is held back at this gate.
        if auth_pool[s].user_set != 0:
            _au_rate_limit_gate(s)
            ok: int32 = _au_try_verify(s)
            if ok != 0:
                _au_render_ok(s)
            else:
                _au_render_denied(s)
                # Wipe the pass_buf so plaintext doesn't linger.
                j: uint64 = 0
                while j < AUTH_PASS_MAX:
                    auth_pool[s].pass_buf[j] = 0
                    j = j + 1
                auth_pool[s].pass_set = 0
        return cast[int64](count)
    if _au_starts_with(buf, nl, setpass_prefix, 8) != 0:
        # docs/security.md: hostowner-gated password SET. Requires the
        # "user <name>" line first. AUTHORIZATION: the caller must be the
        # hostowner (uid 1) OR be setting their OWN password (their live
        # uid matches the named user's uid in /etc/passwd). A regular
        # user cannot set another user's password.
        if auth_pool[s].user_set == 0:
            _au_render_denied(s)
            return cast[int64](count)
        # Stash the new plaintext into pass_buf.
        spl: uint64 = nl - 8
        if spl + 1 > AUTH_PASS_MAX:
            spl = AUTH_PASS_MAX - 1
        i2: uint64 = 0
        while i2 < spl:
            auth_pool[s].pass_buf[i2] = buf[8 + i2]
            i2 = i2 + 1
        auth_pool[s].pass_buf[spl] = 0
        auth_pool[s].pass_len = spl
        # Authorization check. Hostowner always allowed.
        caller_uid: uint32 = current_task_uid()
        allowed: int32 = 0
        if caller_uid == 1:
            allowed = 1
        else:
            # Resolve the named user's uid from the LIVE /etc/passwd and
            # allow only if it equals the caller's uid (own-password).
            pn: int64 = _au_read_live_file(cast[Ptr[char]]("/etc/passwd"),
                                           &auth_passwd_buf[0], 4096)
            if pn > 0:
                passwd_parse(&auth_passwd_buf[0], cast[uint64](pn))
                pi: int32 = passwd_lookup_by_name(&auth_pool[s].user_buf[0])
                if pi >= 0 and passwd_entry_uid(pi) == caller_uid:
                    allowed = 1
        if allowed == 0:
            _au_render_denied(s)
            # Wipe the staged plaintext.
            jz: uint64 = 0
            while jz < AUTH_PASS_MAX:
                auth_pool[s].pass_buf[jz] = 0
                jz = jz + 1
            return cast[int64](count)
        sp_ok: int32 = _au_setpass(s)
        # Wipe the plaintext regardless of outcome.
        jw: uint64 = 0
        while jw < AUTH_PASS_MAX:
            auth_pool[s].pass_buf[jw] = 0
            jw = jw + 1
        auth_pool[s].pass_set = 0
        if sp_ok != 0:
            _au_render_ok_bare(s)
        else:
            _au_render_denied(s)
        return cast[int64](count)
    # Unrecognised line — accept the bytes (count consumed) but render
    # a denied response so a malformed protocol doesn't deadlock.
    _au_render_denied(s)
    return cast[int64](count)


def devauth_verified_uid(slot: int32) -> int32:
    # Helper for newshell etc. that want to consult the slot's verified
    # uid without re-parsing the response_buf text. Returns the uid as
    # int32 on success, -1 if the slot hasn't successfully verified.
    if slot < 0:
        return -1
    s: uint64 = cast[uint64](slot)
    if s >= AUTH_POOL_CAP or auth_pool[s].in_use == 0:
        return -1
    if auth_pool[s].verified == 0:
        return -1
    return cast[int32](auth_pool[s].auth_uid)


def devauth_verified_gid(slot: int32) -> int32:
    if slot < 0:
        return -1
    s: uint64 = cast[uint64](slot)
    if s >= AUTH_POOL_CAP or auth_pool[s].in_use == 0:
        return -1
    if auth_pool[s].verified == 0:
        return -1
    return cast[int32](auth_pool[s].auth_gid)


# F10-4 (#457): expose the verified PRINCIPAL NAME on an AuthSlot so the
# 9P mount path (sys/src/9/port/syschan.ad::do_mount) can plumb it into
# Tattach's `uname` field. Plan 9 mount's afd carries the authenticated
# identity that the file server boundary trusts; without this, every
# mount carried uname="" (the F10-4 finding). Returns:
#   * >= 0   bytes written into out_buf (the user_buf principal name)
#   * -1     slot invalid, free, or not verified — caller must reject
#            the mount instead of using an empty/garbage uname.
# Writes NUL-terminator iff there's room (out_max > written_len).

def devauth_verified_uname_copy(slot: int32, out_buf: Ptr[uint8],
                                out_max: uint64) -> int32:
    if slot < 0:
        return -1
    if out_buf == cast[Ptr[uint8]](0) or out_max == 0:
        return -1
    s: uint64 = cast[uint64](slot)
    if s >= AUTH_POOL_CAP or auth_pool[s].in_use == 0:
        return -1
    if auth_pool[s].verified == 0:
        return -1
    n: uint64 = auth_pool[s].user_len
    if n >= out_max:
        n = out_max - 1                  # leave room for the NUL
    i: uint64 = 0
    while i < n:
        out_buf[i] = auth_pool[s].user_buf[i]
        i = i + 1
    out_buf[n] = 0
    return cast[int32](n)


# --- F10-6 #458 expansion: Plan 9 Dir-record listing for #auth -------
#
# Migration of the `#auth` server's listing path from NAME\n lines to
# Plan 9 Dir records. Each LIVE pool slot (an in-flight authentication
# handshake from one /dev/auth opener) gets one Dir record whose
# decimal-rendered slot index is the name (e.g. "0", "1", ...). qpath =
# slot+1 so the encoded qid round-trips through Dir.qid_path. Mode is
# 0666 (each /dev/auth fd is r/w by the opening task). length is 0 —
# the cdev streams its in-flight handshake state, not a fixed file.
# Owner uid is rendered as "hostowner" v1 — the F10 user-attribution
# work will swap that for the slot's verified auth_uid once the
# numeric → uname map lands.

from lib.p9dir import p9_dir_encode_into
from lib.9p.9p import P9_QTFILE

_DEVAUTH_MODE: uint32 = 0x000001B6     # 0666 rw-rw-rw-
_devauth_uname: Array[16, uint8]
_devauth_uname_inited: int32 = 0


def _devauth_init_uname():
    if _devauth_uname_inited != 0:
        return
    s: Ptr[uint8] = "hostowner"
    i: uint64 = 0
    while s[i] != 0:
        _devauth_uname[i] = s[i]
        i = i + 1
    _devauth_uname[i] = 0
    _devauth_uname_inited = 1


def _devauth_render_slot_name(slot: uint64, out: Ptr[uint8]) -> uint64:
    # Render `slot` as decimal into `out`. Returns bytes written (no
    # NUL appended — caller passes name_len separately to the encoder).
    # AUTH_POOL_CAP is 8 so a single digit suffices for v1, but we
    # render variable-width so a future cap bump just works.
    if slot == 0:
        out[0] = 48                                  # '0'
        return 1
    digits: Array[20, uint8]
    n: uint64 = 0
    v: uint64 = slot
    while v != 0:
        digits[n] = cast[uint8](48 + (v % 10))      # '0'..'9'
        v = v / 10
        n = n + 1
    # Reverse into `out`.
    i: uint64 = 0
    while i < n:
        out[i] = digits[n - 1 - i]
        i = i + 1
    return n


def devauth_list_dir(out_buf: Ptr[uint8], out_max: uint64) -> int64:
    # F10-6 #458 expansion: emit one Plan 9 Dir record per LIVE auth
    # pool slot. Returns bytes written (0 if no slots are in use — a
    # legitimate result for a freshly-booted box). Stops cleanly at the
    # first entry that would overflow (no partial record).
    _au_init_pool()
    _devauth_init_uname()
    uname_p: Ptr[uint8] = cast[Ptr[uint8]](&_devauth_uname[0])
    uname_len: uint64 = 0
    while _devauth_uname[uname_len] != 0:
        uname_len = uname_len + 1
    pos: uint64 = 0
    i: uint64 = 0
    while i < AUTH_POOL_CAP:
        if auth_pool[i].in_use != 0:
            namebuf: Array[20, uint8]
            nlen: uint64 = _devauth_render_slot_name(
                i, cast[Ptr[uint8]](&namebuf[0]))
            wrote: uint64 = p9_dir_encode_into(
                out_buf, pos, out_max,
                P9_QTFILE,                  # qid_type
                0,                                    # qid_version
                i + 1,                                # qid_path
                _DEVAUTH_MODE,                        # mode 0666
                0, 0,                                 # atime, mtime
                0,                                    # length
                cast[Ptr[uint8]](&namebuf[0]), nlen,
                uname_p, uname_len,                   # uid
                uname_p, uname_len,                   # gid
                uname_p, 0)                           # muid empty
            if wrote == 0:
                return cast[int64](pos)
            pos = pos + wrote
        i = i + 1
    return cast[int64](pos)

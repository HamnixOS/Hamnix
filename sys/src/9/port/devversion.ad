# sys/src/9/port/devversion.ad
#
# Layer 1 (Plan 9-shape) version device â€” identity-introspection cdev,
# sibling to /dev/cpuinfo / /dev/meminfo / /dev/uptime / /dev/loadavg.
# One read regenerates a fresh text snapshot of the Hamnix release
# string:
#
#   "hamnix/0.1 (M16.132+)\n"
#
# Stateless backend: FD_VERSION_MARK fds carry no per-fd slot. Every
# read regenerates the entire blob, then copies up to `count` bytes
# into the caller's buffer. Writes return -1 â€” read-only.
#
# Source of truth: hardcoded into the binary. The "real" source is
# /etc/os-release (NAME=Hamnix, VERSION="0.1"), but that file is a
# build-time artifact that ships in the initramfs â€” userland that
# wants to parse it can. The cdev's job is to give a stable
# single-line identity string the same way uname(2) does, without
# routing through filesystem I/O. The string changes at most once
# per release (= once per recut of the kernel image), so building
# it from a literal is the right call.
#
# Compiler-quirk note: Adder has a flat global symbol namespace
# across merged modules â€” M16.131 / M16.132 hit this when devcpuinfo
# + devmeminfo + devuptime + devloadavg all defined `_emit_str`,
# forcing renames to `_ci_emit_str` / `_mi_emit_str` / `_up_emit_str`
# / `_la_emit_str`. We pre-empt the collision here by prefixing every
# shared-shape helper with `_ver_`.


# --- ASCII formatting helpers ----------------------------------------

def _ver_emit_str(out: Ptr[uint8], pos: uint64, s: Ptr[uint8]) -> uint64:
    # Append a NUL-terminated string to out[pos..], return new pos.
    # Prefixed `_ver_` to avoid the flat-namespace collision documented
    # at the top of the file.
    i: uint64 = 0
    while s[i] != 0:
        out[pos + i] = s[i]
        i = i + 1
    return pos + i


# --- snapshot builder -------------------------------------------------

def _build_version(out: Ptr[uint8], cap: uint64) -> uint64:
    # Fill out[] with the release-identity text. Returns total bytes
    # written (NOT including any NUL). Worst-case ~32 bytes for the
    # current "hamnix/0.1 (M16.132+)\n" literal; caller supplies a
    # 64-byte scratch in devversion_read.
    pos: uint64 = 0
    pos = _ver_emit_str(out, pos, "hamnix/0.1 (M16.132+)\n")
    return pos


# --- public API -------------------------------------------------------

def devversion_read(buf: Ptr[uint8], count: uint64) -> int64:
    # Stateless snapshot. 64 bytes covers the worst-case rendered blob;
    # caller's `count` is the only cap on bytes copied.
    if count == 0:
        return 0
    scratch: Array[64, uint8]
    n: uint64 = _build_version(&scratch[0], 64)
    take: uint64 = count
    if take > n:
        take = n
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


def devversion_write(buf: Ptr[uint8], count: uint64) -> int64:
    # /dev/version is read-only. Mirrors devtime / devpid / devcpuinfo /
    # devmeminfo / devuptime / devloadavg.
    return -1

# sys/src/9/port/devrandom.ad
#
# Layer 1 (Plan 9-shape) random device — CSPRNG-shaped /dev/random.
# Mirrors 9front's /sys/src/9/port/devrandom.c at minimum scope: one
# read fills the caller's buffer with bytes from a kernel-side PRNG;
# writes mix new entropy into the state.
#
# CAVEAT — M16.95 placeholder: this is xorshift64, NOT a real CSPRNG.
# It is deterministic given the seed, and seed quality is limited to
# whatever get_jiffies() returns at first-read time (typically a few
# thousand ticks since boot, ~13 bits of effective entropy). Adequate
# for the busybox /dev/urandom fan-out — `mktemp`, `tar` random suffix,
# /etc/ssh keygen-quality is NOT here yet — and adequate for the test
# script's "is the byte stream varying?" sanity check.
#
# Roadmap: M16.96 (or whenever RDRAND/RDSEED detection lands) will
# replace the xorshift64 with a chacha20 stream keyed off the CPU
# hardware RNG and reseeded periodically. The VFS contract here
# (vfs_open("/dev/random") → FD_RANDOM_MARK → devrandom_read) is
# stable; only the body of devrandom_read changes.
#
# Why lazy-seed (init/main.ad off-limits this commit): the DHCP agent
# is editing init/main.ad concurrently. We can't add a devrandom_init
# call from start_kernel without colliding. Workaround: seeded_yet
# flag, seeded on first read using get_jiffies() as a cheap entropy
# proxy.
#
# Stateless backend per-fd: FD_RANDOM_MARK carries no slot, no
# kmalloc, no refcount. State lives module-global (devrandom_state) so all
# /dev/random fds across all tasks share one stream. Writes XOR
# their bytes into devrandom_state's low lane — the Plan 9 model is "write
# = add entropy", and a simple XOR-mix is fine for a non-crypto
# placeholder. Hash-mixing follows when the chacha20 backend lands.

from arch.x86.kernel.time import get_jiffies

# Module-global PRNG state. Non-zero by construction after the first
# read (seeded_yet flag toggles, and the xorshift64 cycle excludes 0).
devrandom_state:  uint64 = 0
seeded_yet:  uint32 = 0


def _maybe_seed():
    # Lazy seed: only run on the first read or write that observes
    # seeded_yet == 0. Mixes get_jiffies() in. If jiffies happen to
    # be zero (read at boot before the PIT has ticked even once), we
    # force the state to a non-zero constant so xorshift64 has
    # something to cycle on — xorshift64 with state 0 is stuck at 0.
    if seeded_yet != 0:
        return
    seed: uint64 = get_jiffies()
    # Mix in a constant so cold-boot (jiffies < 1) still seeds the
    # state to a useful value. 0x9E3779B97F4A7C15 is the golden-ratio
    # multiplicative constant — same one Linux's hash_64() uses; here
    # it's just a high-entropy bit pattern to avoid an all-zero seed.
    devrandom_state = seed ^ 0x9E3779B97F4A7C15
    if devrandom_state == 0:
        devrandom_state = 0x9E3779B97F4A7C15
    seeded_yet = 1


def _xorshift64_step() -> uint64:
    # Marsaglia xorshift64 with the standard 13/7/17 triple. Cycle
    # length 2^64 - 1 (every non-zero state is visited exactly once).
    # The low byte of the post-step state is what we hand out per
    # output byte. Cheap (3 shifts + 3 XORs) and good enough as
    # placeholder entropy for the test suite.
    x: uint64 = devrandom_state
    x = x ^ (x << 13)
    x = x ^ (x >> 7)
    x = x ^ (x << 17)
    devrandom_state = x
    return x


def devrandom_init(seed: uint64):
    # External seeding entrypoint (not called from init/main.ad this
    # commit — DHCP agent is editing it. Kept exported so the Phase D
    # boot sequence can wire it once init/main.ad becomes editable
    # again). XOR-mix the seed into devrandom_state.
    devrandom_state = devrandom_state ^ seed
    if devrandom_state == 0:
        devrandom_state = 0x9E3779B97F4A7C15
    seeded_yet = 1


def devrandom_read(buf: Ptr[uint8], count: uint64) -> int64:
    # Per-byte stream. We could pull 8 bytes per xorshift step for
    # speed, but byte-at-a-time keeps the implementation small and
    # the test's "16 bytes varied, not all zero/all FF" check
    # equally happy.
    _maybe_seed()
    i: uint64 = 0
    while i < count:
        next_state: uint64 = _xorshift64_step()
        buf[i] = cast[uint8](next_state & 0xFF)
        i = i + 1
    return cast[int64](count)


def devrandom_write(buf: Ptr[uint8], count: uint64) -> int64:
    # "Add entropy" path. Mirrors 9front's devrandom write semantics
    # at the smallest scope: XOR each input byte into the low lane of
    # devrandom_state. This is NOT a hash; do not rely on it to undo bias
    # in user-supplied entropy. The chacha20 reseed path (future)
    # will replace this with a proper key update.
    _maybe_seed()
    i: uint64 = 0
    while i < count:
        devrandom_state = devrandom_state ^ cast[uint64](buf[i])
        i = i + 1
    if devrandom_state == 0:
        devrandom_state = 0x9E3779B97F4A7C15
    return cast[int64](count)

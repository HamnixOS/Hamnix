# sys/src/9/port/devrandom.ad
#
# Layer 1 (Plan 9-shape) random device — a REAL cryptographic CSPRNG.
# Mirrors 9front's /sys/src/9/port/devrandom.c at minimum scope: one
# read fills the caller's buffer with bytes from a kernel-side CSPRNG;
# writes mix new entropy into the state.
#
# Core: ChaCha20 (RFC 8439 §2.3) keystream with FAST KEY ERASURE.
# This is the modern Linux/OpenBSD arc4random design:
#   * The pool is a 256-bit ChaCha20 key + a 96-bit nonce.
#   * Each refill generates ONE 64-byte ChaCha20 block. The FIRST 32
#     bytes of EVERY block ratchet the key forward (they become the
#     new key) so previously-emitted output cannot be recovered even
#     if the current key field is later disclosed (forward secrecy).
#   * The remaining 32 bytes are the keystream handed to callers.
# This is "fast key erasure" — see djb's analysis and Linux's
# drivers/char/random.c `crng` design.
#
# Seeding: _maybe_seed() is lazy (first read / write / getrandom).
# It gathers real entropy from, in preference order, RDSEED, RDRAND,
# the TSC (rdtsc) sampled repeatedly to harvest timing jitter, and
# get_jiffies(). Seed material is ABSORBED into the pool by running
# it through the ChaCha20 cipher (a sponge-style mix), NOT by XOR
# alone — every seed word perturbs the whole key via a keystream
# block, so weak/biased sources cannot cancel each other out.
#
# Writes (`echo x > /dev/random`) follow the standard /dev/random
# write contract: caller bytes are mixed into the pool (again through
# the cipher), perturbing all future output. They never block and
# never reduce entropy estimates (modern semantics — no blocking
# entropy accounting; once seeded the pool always serves CSPRNG bytes).
#
# /dev/random, /dev/urandom and getrandom(2) all draw from this one
# pool: identical modern Linux semantics.
#
# Stateless backend per-fd: FD_RANDOM_MARK carries no slot, no
# kmalloc, no refcount. State lives module-global so all consumers
# share one keystream.

from arch.x86.kernel.time import get_jiffies, read_tsc
from kernel.printk.printk import printk0, printk1, printk2, printk_set_level
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG

# -- module-global state -----------------------------------------------------

# ChaCha20 16-word state.
#   state[0..3]   : constants "expand 32-byte k"
#   state[4..11]  : 256-bit key (ratcheted forward every block)
#   state[12]     : 32-bit block counter
#   state[13..15] : 96-bit nonce
chacha_state: Array[16, uint32]

# 64-byte keystream block scratch. The first 32 bytes re-key the pool
# (fast key erasure); the remaining 32 bytes are user-visible output.
chacha_keystream: Array[64, uint8]

# Output buffer: 32 user-visible bytes per generated block. devrandom_read
# serves bytes from here, regenerating on exhaustion.
csprng_out: Array[32, uint8]

# Position into csprng_out (0..32). When == 32, next byte read triggers a
# fresh block generation + key ratchet.
csprng_pos: uint64 = 32

# Lazy-init guard. seeded_yet == 0 => read/write/getrandom paths trigger
# _maybe_seed() before producing output.
seeded_yet: uint32 = 0

# CPUID feature bits, populated by _detect_hwrng() on first seed.
#   hwrng_features bit 0 = RDRAND available (CPUID leaf 1 ECX bit 30)
#   hwrng_features bit 1 = RDSEED available (CPUID leaf 7:0 EBX bit 18)
hwrng_features: uint64 = 0

# Scratch slot for inline-asm RDRAND/RDSEED/CPUID output. The
# zero-operand asm_volatile intrinsic cannot return a value to the
# caller via %rax, so the inline asm parks its result in this
# RIP-relative global and the wrapping Adder function returns it.
hwrng_scratch: uint64 = 0
# CF state from the most recent RDRAND/RDSEED. 1 = success, 0 = failure.
hwrng_cf: uint64 = 0
# CPUID outputs (one global per output register).
cpuid_eax: uint64 = 0
cpuid_ebx: uint64 = 0
cpuid_ecx: uint64 = 0
cpuid_edx: uint64 = 0

# Self-test scratch (used only by devrandom_selftest()). Kept at module
# scope because the Adder compiler miscompiles large frame-local arrays.
st_buf_a: Array[64, uint8]
st_buf_b: Array[64, uint8]
st_save_state: Array[16, uint32]
st_save_keystream: Array[64, uint8]
st_save_out: Array[32, uint8]
# KAT expected first 16 bytes of the RFC 8439 §2.3.2 keystream block.
#   10 f1 e7 e4 d1 3b 59 15 50 0f dd 1f a3 20 71 c4
kat_expect: Array[16, uint8]


# -- CPUID / RDRAND / RDSEED wrappers ----------------------------------------

def _cpuid(leaf: uint64, subleaf: uint64):
    # Issue CPUID with %eax=leaf, %ecx=subleaf; park EAX/EBX/ECX/EDX
    # in module-globals so callers can read them back. CPUID clobbers
    # all four GPRs, including %rbx (callee-saved in SysV) — we save
    # and restore it ourselves so we never break the surrounding
    # Adder ABI.
    cpuid_eax = leaf
    cpuid_ecx = subleaf
    asm_volatile("""
        pushq %rbx
        movq cpuid_eax(%rip), %rax
        movq cpuid_ecx(%rip), %rcx
        cpuid
        movq %rax, cpuid_eax(%rip)
        movq %rbx, cpuid_ebx(%rip)
        movq %rcx, cpuid_ecx(%rip)
        movq %rdx, cpuid_edx(%rip)
        popq %rbx
    """)


def _detect_hwrng():
    # CPUID leaf 1: ECX bit 30 == RDRAND.
    _cpuid(1, 0)
    features: uint64 = 0
    if (cpuid_ecx & (cast[uint64](1) << 30)) != 0:
        features = features | 1
    # CPUID leaf 7 subleaf 0: EBX bit 18 == RDSEED.
    _cpuid(7, 0)
    if (cpuid_ebx & (cast[uint64](1) << 18)) != 0:
        features = features | 2
    hwrng_features = features


def _rdrand64() -> uint64:
    # Issue RDRAND %rax up to 10 times until CF=1; park result in
    # hwrng_scratch and CF in hwrng_cf. Returns 0 on persistent
    # failure (caller falls back to TSC/jiffies entropy).
    if (hwrng_features & 1) == 0:
        return 0
    hwrng_cf = 0
    hwrng_scratch = 0
    asm_volatile("""
        movq $10, %rcx
    .Lrdrand_retry:
        rdrand %rax
        jc .Lrdrand_ok
        loop .Lrdrand_retry
        jmp .Lrdrand_done
    .Lrdrand_ok:
        movq %rax, hwrng_scratch(%rip)
        movq $1, hwrng_cf(%rip)
    .Lrdrand_done:
    """)
    if hwrng_cf == 0:
        return 0
    return hwrng_scratch


def _rdseed64() -> uint64:
    # Same as _rdrand64() but issues RDSEED. RDSEED is the preferred
    # entropy source — it returns conditioned full-entropy bits,
    # vs. RDRAND's CSPRNG-buffered output. Up to 10 retries.
    if (hwrng_features & 2) == 0:
        return 0
    hwrng_cf = 0
    hwrng_scratch = 0
    asm_volatile("""
        movq $10, %rcx
    .Lrdseed_retry:
        rdseed %rax
        jc .Lrdseed_ok
        loop .Lrdseed_retry
        jmp .Lrdseed_done
    .Lrdseed_ok:
        movq %rax, hwrng_scratch(%rip)
        movq $1, hwrng_cf(%rip)
    .Lrdseed_done:
    """)
    if hwrng_cf == 0:
        return 0
    return hwrng_scratch


def _tsc_jitter64() -> uint64:
    # Harvest timing jitter from the TSC. We sample rdtsc many times in
    # a short loop and fold the low bits of each inter-sample delta into
    # an accumulator. On real hardware the inter-sample timing wobbles
    # (cache, prefetch, interrupts, frequency scaling) so the low bits of
    # the deltas carry true physical entropy. Under TCG the deltas are
    # less random but still vary run-to-run, which keeps the pool from
    # being deterministic in the emulator. Never the SOLE source — it
    # augments RDSEED/RDRAND.
    acc: uint64 = 0x9E3779B97F4A7C15
    prev: uint64 = read_tsc()
    i: uint64 = 0
    while i < 64:
        cur: uint64 = read_tsc()
        delta: uint64 = cur - prev
        prev = cur
        # Rotate-mix the delta into the accumulator (a cheap diffusion
        # step so each sample's low bits scatter across the word).
        acc = acc ^ delta
        acc = ((acc << 7) | (acc >> 57)) & 0xFFFFFFFFFFFFFFFF
        acc = (acc + 0x9E3779B97F4A7C15) & 0xFFFFFFFFFFFFFFFF
        i = i + 1
    return acc


def _hw_entropy64(counter: uint64) -> uint64:
    # Best available 64-bit entropy. Combine ALL reachable sources:
    # RDSEED (preferred), RDRAND, TSC jitter, and a jiffies splash.
    # Mixing them means the result is unpredictable as long as ANY ONE
    # source carries entropy — a hostile or absent hwrng cannot zero it
    # out, because TSC jitter and jiffies always contribute.
    v: uint64 = 0
    s: uint64 = _rdseed64()
    if s != 0:
        v = v ^ s
    r: uint64 = _rdrand64()
    if r != 0:
        # Rotate so RDRAND lands in different bit positions than RDSEED.
        v = v ^ (((r << 23) | (r >> 41)) & 0xFFFFFFFFFFFFFFFF)
    j: uint64 = _tsc_jitter64()
    v = v ^ (((j << 41) | (j >> 23)) & 0xFFFFFFFFFFFFFFFF)
    v = v ^ get_jiffies() ^ counter ^ 0x9E3779B97F4A7C15
    return v


# -- ChaCha20 block function (RFC 8439 §2.3) ---------------------------------

# Rotate-left a 32-bit value by n bits (1..31). Returns a uint32-shape
# value (high 32 bits are masked off).
def _rotl32(v: uint32, n: uint64) -> uint32:
    x: uint64 = cast[uint64](v) & 0xFFFFFFFF
    lo: uint64 = (x << n) & 0xFFFFFFFF
    hi: uint64 = x >> (32 - n)
    return cast[uint32](lo | hi)


def _chacha_quarter_round(a_idx: uint64, b_idx: uint64,
                          c_idx: uint64, d_idx: uint64):
    # In-place quarter-round on chacha_state[a,b,c,d]. RFC 8439 §2.1.
    a: uint64 = cast[uint64](chacha_state[a_idx]) & 0xFFFFFFFF
    b: uint64 = cast[uint64](chacha_state[b_idx]) & 0xFFFFFFFF
    c: uint64 = cast[uint64](chacha_state[c_idx]) & 0xFFFFFFFF
    d: uint64 = cast[uint64](chacha_state[d_idx]) & 0xFFFFFFFF

    a = (a + b) & 0xFFFFFFFF
    d = d ^ a
    d = cast[uint64](_rotl32(cast[uint32](d), 16))

    c = (c + d) & 0xFFFFFFFF
    b = b ^ c
    b = cast[uint64](_rotl32(cast[uint32](b), 12))

    a = (a + b) & 0xFFFFFFFF
    d = d ^ a
    d = cast[uint64](_rotl32(cast[uint32](d), 8))

    c = (c + d) & 0xFFFFFFFF
    b = b ^ c
    b = cast[uint64](_rotl32(cast[uint32](b), 7))

    chacha_state[a_idx] = cast[uint32](a)
    chacha_state[b_idx] = cast[uint32](b)
    chacha_state[c_idx] = cast[uint32](c)
    chacha_state[d_idx] = cast[uint32](d)


def _chacha_block():
    # Generate one 64-byte keystream block into chacha_keystream:
    #   working = state
    #   for 10 iterations: column-round + diagonal-round (= 20 rounds)
    #   working = working + state (mod 2^32)
    #   serialise working as little-endian uint32s
    # Then increment the block counter. The input state[] (constants +
    # key + nonce) is preserved; only the counter advances, exactly per
    # RFC 8439 §2.3.
    orig: Array[16, uint32]
    i: uint64 = 0
    while i < 16:
        orig[i] = chacha_state[i]
        i = i + 1

    r: uint64 = 0
    while r < 10:
        # Column rounds.
        _chacha_quarter_round(0, 4, 8,  12)
        _chacha_quarter_round(1, 5, 9,  13)
        _chacha_quarter_round(2, 6, 10, 14)
        _chacha_quarter_round(3, 7, 11, 15)
        # Diagonal rounds.
        _chacha_quarter_round(0, 5, 10, 15)
        _chacha_quarter_round(1, 6, 11, 12)
        _chacha_quarter_round(2, 7, 8,  13)
        _chacha_quarter_round(3, 4, 9,  14)
        r = r + 1

    # working += orig (mod 2^32), then serialise little-endian into
    # chacha_keystream[].
    i = 0
    while i < 16:
        sum_w: uint64 = ((cast[uint64](chacha_state[i]) & 0xFFFFFFFF)
                         + (cast[uint64](orig[i]) & 0xFFFFFFFF)) & 0xFFFFFFFF
        base: uint64 = i * 4
        chacha_keystream[base + 0] = cast[uint8](sum_w & 0xFF)
        chacha_keystream[base + 1] = cast[uint8]((sum_w >> 8) & 0xFF)
        chacha_keystream[base + 2] = cast[uint8]((sum_w >> 16) & 0xFF)
        chacha_keystream[base + 3] = cast[uint8]((sum_w >> 24) & 0xFF)
        # Restore state[i] to orig[i] — the NEXT block must come from the
        # original state (constants + key + nonce) with only the counter
        # advanced.
        chacha_state[i] = orig[i]
        i = i + 1

    # Advance the 32-bit block counter (state[12]).
    counter: uint64 = (cast[uint64](chacha_state[12]) + 1) & 0xFFFFFFFF
    chacha_state[12] = cast[uint32](counter)


def _csprng_generate():
    # FAST KEY ERASURE refill. Generate one ChaCha20 block, then:
    #   * bytes  0..31 -> become the NEW 256-bit key (state[4..11]).
    #     This ratchets the pool forward: the key that produced this
    #     block is destroyed, so the just-emitted output cannot be
    #     reconstructed from any later state snapshot (forward secrecy).
    #   * bytes 32..63 -> user-visible output (csprng_out[0..31]).
    _chacha_block()
    # Re-key from the first 32 keystream bytes (little-endian words).
    i: uint64 = 0
    while i < 8:
        base: uint64 = i * 4
        w: uint64 = (cast[uint64](chacha_keystream[base + 0])
                     | (cast[uint64](chacha_keystream[base + 1]) << 8)
                     | (cast[uint64](chacha_keystream[base + 2]) << 16)
                     | (cast[uint64](chacha_keystream[base + 3]) << 24))
        chacha_state[4 + i] = cast[uint32](w & 0xFFFFFFFF)
        i = i + 1
    # Reset the block counter — the key is fresh, so the counter starts
    # over per the fast-key-erasure construction.
    chacha_state[12] = 0
    # Copy the output half (bytes 32..63) to the user-visible buffer.
    i = 0
    while i < 32:
        csprng_out[i] = chacha_keystream[32 + i]
        i = i + 1
    csprng_pos = 0


# -- entropy absorption (cipher-based mixing, not XOR-only) -------------------

def _absorb64(word: uint64):
    # Mix one 64-bit entropy word into the pool THROUGH the cipher.
    #   1. XOR the word across the nonce + low key words (initial splash).
    #   2. Run a ChaCha20 block to diffuse it.
    #   3. Fold the resulting keystream back into the key field.
    # Step 2 is what makes this a cipher-mix rather than a plain XOR: a
    # single biased input bit, after one block, is spread non-linearly
    # across all 256 key bits, so subsequent absorbs of correlated words
    # cannot cancel.
    lo: uint32 = cast[uint32](word & 0xFFFFFFFF)
    hi: uint32 = cast[uint32]((word >> 32) & 0xFFFFFFFF)
    chacha_state[13] = chacha_state[13] ^ lo
    chacha_state[14] = chacha_state[14] ^ hi
    chacha_state[15] = chacha_state[15] ^ (lo ^ hi)
    _chacha_block()
    i: uint64 = 0
    while i < 8:
        base: uint64 = i * 4
        w: uint64 = (cast[uint64](chacha_keystream[base + 0])
                     | (cast[uint64](chacha_keystream[base + 1]) << 8)
                     | (cast[uint64](chacha_keystream[base + 2]) << 16)
                     | (cast[uint64](chacha_keystream[base + 3]) << 24))
        chacha_state[4 + i] = chacha_state[4 + i] ^ cast[uint32](w & 0xFFFFFFFF)
        i = i + 1
    # Force callers to draw a fresh ratcheted block after a reseed.
    csprng_pos = 32


def _maybe_seed():
    # First-touch initialiser. Sets constants, then absorbs 256+ bits of
    # entropy (8 words) gathered from RDSEED/RDRAND/TSC-jitter/jiffies,
    # mixing each word into the pool THROUGH the cipher (sponge-style).
    # Idempotent after first call.
    if seeded_yet != 0:
        return

    # CPUID feature detection (populates hwrng_features for RDSEED/RDRAND).
    _detect_hwrng()

    # state[0..3] = "expand 32-byte k" (sigma).
    chacha_state[0] = 0x61707865
    chacha_state[1] = 0x3320646e
    chacha_state[2] = 0x79622d32
    chacha_state[3] = 0x6b206574

    # state[4..11] = key, primed with a first entropy pull (so the very
    # first cipher block in _absorb64 already operates on live entropy
    # rather than zeros).
    i: uint64 = 0
    while i < 8:
        chacha_state[4 + i] = cast[uint32](_hw_entropy64(i) & 0xFFFFFFFF)
        i = i + 1

    # state[12] = block counter (start 0). state[13..15] = nonce, seeded
    # from a fresh entropy word so two boots differ even before absorb.
    chacha_state[12] = 0
    n0: uint64 = _hw_entropy64(0xA5)
    n1: uint64 = _hw_entropy64(0xC3)
    chacha_state[13] = cast[uint32](n0 & 0xFFFFFFFF)
    chacha_state[14] = cast[uint32]((n0 >> 32) & 0xFFFFFFFF)
    chacha_state[15] = cast[uint32](n1 & 0xFFFFFFFF)

    # Absorb 8 more independent entropy words through the cipher. Each
    # _absorb64 runs a full ChaCha20 block, so by the end every key bit
    # depends non-linearly on every seed word.
    i = 0
    while i < 8:
        _absorb64(_hw_entropy64(0x100 + i))
        i = i + 1

    # Force the first read to generate a fresh ratcheted output block.
    csprng_pos = 32
    seeded_yet = 1


# -- public API --------------------------------------------------------------

def devrandom_init(seed: uint64):
    # External seeding entrypoint. Runs lazy init if needed, then absorbs
    # the supplied seed word through the cipher (same path writes use).
    _maybe_seed()
    _absorb64(seed)


def devrandom_read(buf: Ptr[uint8], count: uint64) -> int64:
    # Stream out of the fast-key-erasure CSPRNG. Serve from csprng_out
    # until exhausted (32 bytes), then generate a fresh block — which
    # ratchets the key forward, making output forward-secret.
    _maybe_seed()
    i: uint64 = 0
    while i < count:
        if csprng_pos >= 32:
            _csprng_generate()
        buf[i] = csprng_out[csprng_pos]
        csprng_pos = csprng_pos + 1
        i = i + 1
    return cast[int64](count)


def devrandom_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Standard /dev/random write contract: mix caller-supplied bytes into
    # the pool. We pack the input into 64-bit words and absorb each one
    # through the cipher (_absorb64), so a write perturbs ALL future
    # output non-linearly — not a single nonce slot. Always consumes the
    # whole buffer; never blocks; never lowers entropy.
    _maybe_seed()
    i: uint64 = 0
    acc: uint64 = 0
    nbits: uint64 = 0
    while i < count:
        acc = acc | (cast[uint64](buf[i]) << nbits)
        nbits = nbits + 8
        if nbits == 64:
            _absorb64(acc)
            acc = 0
            nbits = 0
        i = i + 1
    # Absorb any trailing partial word (also fold in the length so a
    # short write still moves the pool).
    if nbits != 0:
        _absorb64(acc ^ count)
    return cast[int64](count)


# -- self-test (boot-gated; see init/main.ad boot:37.rnd) --------------------

def _emit(msg: Ptr[char]):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0(msg)


def _kat_set_state():
    # Load the RFC 8439 §2.3.2 known-answer test vector into chacha_state:
    #   key   = 00 01 02 .. 1f
    #   count = 1
    #   nonce = 00 00 00 09 00 00 00 4a 00 00 00 00
    # One ChaCha20 block then yields the documented keystream whose first
    # 16 bytes are 10 f1 e7 e4 d1 3b 59 15 50 0f dd 1f a3 20 71 c4.
    chacha_state[0] = 0x61707865
    chacha_state[1] = 0x3320646e
    chacha_state[2] = 0x79622d32
    chacha_state[3] = 0x6b206574
    # Key words, little-endian from 00 01 02 03 ...
    chacha_state[4]  = 0x03020100
    chacha_state[5]  = 0x07060504
    chacha_state[6]  = 0x0b0a0908
    chacha_state[7]  = 0x0f0e0d0c
    chacha_state[8]  = 0x13121110
    chacha_state[9]  = 0x17161514
    chacha_state[10] = 0x1b1a1918
    chacha_state[11] = 0x1f1e1d1c
    chacha_state[12] = 0x00000001            # counter = 1
    chacha_state[13] = 0x09000000            # nonce: 00 00 00 09
    chacha_state[14] = 0x4a000000            # nonce: 00 00 00 4a
    chacha_state[15] = 0x00000000            # nonce: 00 00 00 00


def devrandom_selftest() -> int32:
    # Boot-gated self-test. Proves four things and prints EMERG-level
    # [random] markers the test harness greps:
    #   (a) RFC 8439 §2.3.2 ChaCha20 KAT matches EXACTLY (cipher core OK)
    #   (b) output is not the all-zero / constant block
    #   (c) successive reads differ (key ratchet advances)
    #   (d) two large reads differ (no trivially-short period)
    # Returns 1 on full PASS, 0 on any failure.
    _emit("[random] selftest start\n")

    # ---- (a) RFC 8439 §2.3.2 known-answer test ----
    # Save the live pool so the KAT can clobber chacha_state safely, then
    # restore it afterwards (the live pool must keep its real entropy).
    si: uint64 = 0
    while si < 16:
        st_save_state[si] = chacha_state[si]
        si = si + 1
    si = 0
    while si < 64:
        st_save_keystream[si] = chacha_keystream[si]
        si = si + 1

    kat_expect[0]  = 0x10
    kat_expect[1]  = 0xf1
    kat_expect[2]  = 0xe7
    kat_expect[3]  = 0xe4
    kat_expect[4]  = 0xd1
    kat_expect[5]  = 0x3b
    kat_expect[6]  = 0x59
    kat_expect[7]  = 0x15
    kat_expect[8]  = 0x50
    kat_expect[9]  = 0x0f
    kat_expect[10] = 0xdd
    kat_expect[11] = 0x1f
    kat_expect[12] = 0xa3
    kat_expect[13] = 0x20
    kat_expect[14] = 0x71
    kat_expect[15] = 0xc4

    _kat_set_state()
    _chacha_block()
    kat_ok: int32 = 1
    ki: uint64 = 0
    while ki < 16:
        if chacha_keystream[ki] != kat_expect[ki]:
            kat_ok = 0
            ki = 16
        else:
            ki = ki + 1

    # Restore the live pool.
    si = 0
    while si < 16:
        chacha_state[si] = st_save_state[si]
        si = si + 1
    si = 0
    while si < 64:
        chacha_keystream[si] = st_save_keystream[si]
        si = si + 1

    if kat_ok == 1:
        _emit("[random] KAT RFC8439-2.3.2 ChaCha20 keystream OK\n")
    else:
        _emit("[random] KAT RFC8439-2.3.2 ChaCha20 keystream MISMATCH\n")

    # Make sure the live pool is seeded before drawing output.
    _maybe_seed()

    # ---- (b) first read is not all-zero / constant ----
    devrandom_read(&st_buf_a[0], 64)
    nonzero: int32 = 0
    allsame: int32 = 1
    bi: uint64 = 1
    while bi < 64:
        if st_buf_a[bi] != 0:
            nonzero = 1
        if st_buf_a[bi] != st_buf_a[0]:
            allsame = 0
        bi = bi + 1
    if st_buf_a[0] != 0:
        nonzero = 1
    notconst: int32 = 0
    if nonzero == 1 and allsame == 0:
        notconst = 1
        _emit("[random] output nonconstant OK\n")
    else:
        _emit("[random] output CONSTANT or ZERO\n")

    # ---- (c) a second read differs from the first (ratchet advances) ----
    devrandom_read(&st_buf_b[0], 64)
    diff_ab: int32 = 0
    di: uint64 = 0
    while di < 64:
        if st_buf_a[di] != st_buf_b[di]:
            diff_ab = 1
            di = 64
        else:
            di = di + 1
    if diff_ab == 1:
        _emit("[random] successive reads differ OK\n")
    else:
        _emit("[random] successive reads IDENTICAL\n")

    # ---- (d) two large back-to-back reads differ (no short period) ----
    # Reuse st_buf_a / st_buf_b for two fresh 64-byte draws; if the
    # keystream had a period <= 64 they would coincide.
    devrandom_read(&st_buf_a[0], 64)
    devrandom_read(&st_buf_b[0], 64)
    noperiod: int32 = 0
    pi: uint64 = 0
    while pi < 64:
        if st_buf_a[pi] != st_buf_b[pi]:
            noperiod = 1
            pi = 64
        else:
            pi = pi + 1
    if noperiod == 1:
        _emit("[random] large reads differ (no short period) OK\n")
    else:
        _emit("[random] large reads IDENTICAL (short period)\n")

    if kat_ok == 1 and notconst == 1 and diff_ab == 1 and noperiod == 1:
        _emit("[random] PASS\n")
        return 1
    _emit("[random] FAIL\n")
    return 0

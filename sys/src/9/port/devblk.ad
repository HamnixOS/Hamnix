# sys/src/9/port/devblk.ad
#
# Layer 1 (Plan 9-shape) block-device cdev — exposes every registered
# block device under /dev/blk/<name> as a writable byte stream. Mirrors
# 9front's /sys/src/9/port/devsd.c at minimum scope: one cdev per
# registered block (vda, sd0, sd0p1, nvme0n1, ram0, ...) routing
# user reads + writes to kernel/block/blk.ad's blk_read_sectors /
# blk_write_sectors.
#
# This is the userland-visible primitive that lets the installer
# (etc/install.hamsh) write a partition table, an ESP, and a rootfs
# onto a freshly-attached disk without any new syscalls — `cat`-style
# byte writes into /dev/blk/<dev> land directly on the underlying
# driver (virtio-blk, AHCI, NVMe, brd).
#
# Naming:
#   /dev/blk/<name>          read/write the raw device bytes
#   /dev/blk/<name>/size     ASCII total byte count (sectors × 512)
#   /dev/blk/<name>/ctl      write-only control channel — accepts
#                            text commands ("mkfs_ext4\n",
#                            "mkfs_fat <size_mb>\n",
#                            "gpt_init\n", "gpt_mkpart <idx> <start>
#                            <end> <esp|linux>\n", "rescan\n") so
#                            userland can trigger in-kernel formatters
#                            that would otherwise need a new syscall.
#
# Why a /ctl file rather than a SYS_BLK_* syscall: the formatters
# already exist (fs/ext4.ad::ext4_mkfs, fs/fat_mkfs.ad::fat_mkfs,
# drivers/block/partition.ad::gpt_init/gpt_mkpart) and operate on
# block-device slot indices. Routing them through a write to a
# cdev keeps the syscall surface unchanged and matches Plan 9's
# /dev/<thing>/ctl pattern (e.g. /dev/sdN/ctl in 9front). One cdev,
# many verbs.
#
# Pack encoding (Phase 4b: rides in a DEV_BLK pool chan's back_ptr;
# the fd itself is a generic FD_CHAN_MARK fd):
#   pack     = ((mode_bits) << 32) | (slot_index)
#              mode_bits: 0 = raw bytes (read+write to sectors)
#                         1 = size text (read-only)
#                         2 = ctl (write-only, commands)
#   fd_pos   = current byte offset within the device (raw mode only)
#   fd_buflen = capacity snapshot (raw mode; SEEK_END), else 0
#
# Block-aligned writes are required (sector size = 512). A misaligned
# offset or non-multiple-of-512 count is rejected with -EINVAL. The
# installer always writes in sector-multiple chunks, so this is fine.
#
# See:
#   kernel/block/blk.ad — blk_read_sectors / blk_write_sectors /
#                         blk_capacity_sectors / blk_slot_in_use /
#                         blk_slot_name / blk_max_slots
#   fs/ext4.ad         — ext4_mkfs(slot, total_sectors)
#   fs/fat_mkfs.ad     — fat_mkfs(slot, size_mb)
#   drivers/block/partition.ad — gpt_init / gpt_mkpart / partition_rescan
#
# Phase 4b: FD_BLK_MARK (0xFFFFFFE1) is RETIRED. A /dev/blk fd is an
# FD_CHAN_MARK fd backed by a DEV_BLK pool chan whose back_ptr carries
# the pack; namec's DEV_BLK arms call devblk_read/devblk_write by name.

from kernel.printk.printk import printk0, printk1, printk2, printk_set_level
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_NOTICE
from kernel.block.blk import (
    blk_read_sectors, blk_write_sectors,
    blk_capacity_sectors,
    blk_slot_in_use, blk_slot_name, blk_max_slots,
    blk_register_partitions,
    blk_root_disk_name,
    SECTOR_SIZE,
)
from fs.ext4 import ext4_mkfs, ext4_install_file_to_slot, ext4_mkdir_at_slot
from fs.fat_mkfs import fat_mkfs
from mm.slab import kmalloc, kfree
from drivers.block.partition import (
    gpt_init, gpt_mkpart, partition_rescan,
    GPT_GUID_LINUX_FS_LOW, GPT_GUID_LINUX_FS_HIGH,
    GPT_GUID_EFI_SYSTEM_LOW, GPT_GUID_EFI_SYSTEM_HIGH,
)


# Pack encoding helpers. We pack a 2-bit "mode" in bits 32..33 and
# the slot index in bits 0..31. Plenty of headroom on both sides.
# (Phase 4b: the pack lives in the DEV_BLK chan's back_ptr — the old
# FD_BLK_MARK fd_buf encoding is gone with the mark.)
BLK_MODE_RAW:     uint64 = 0
BLK_MODE_SIZE:    uint64 = 1
BLK_MODE_CTL:     uint64 = 2
# ROOTDEV is a global pseudo-file (NOT a per-device path): a read of
# "/dev/blk/rootdev" returns the BASE DISK name backing the live root
# FS, so the on-target installer can refuse to clobber it. The slot
# packed alongside is unused for this mode.
BLK_MODE_ROOTDEV: uint64 = 3


def devblk_pack(slot: int32, mode: uint64) -> uint64:
    return (mode << 32) | (cast[uint64](slot) & 0xFFFFFFFF)


def devblk_unpack_slot(pkd: uint64) -> int32:
    return cast[int32](pkd & 0xFFFFFFFF)


def devblk_unpack_mode(pkd: uint64) -> uint64:
    return (pkd >> 32) & 0xFFFF


# --- path matching --------------------------------------------------
#
# devblk_path_match recognises the three /dev/blk/<name>{,/size,/ctl}
# spellings and returns a pkd (slot, mode) cookie ready to stuff
# into fd_buf. Returns -1 if `path` is not a /dev/blk/* path or if
# the named device is not registered.

DEVBLK_PREFIX_LEN: uint64 = 9            # length of "/dev/blk/"
DEVBLK_NAME_MAX:   uint64 = 16


def _devblk_prefix_match(path: Ptr[char]) -> int32:
    # Returns 1 if path starts with "/dev/blk/", 0 otherwise.
    if path[0] != 47:                                  # '/'
        return 0
    if path[1] != 100:                                 # 'd'
        return 0
    if path[2] != 101:                                 # 'e'
        return 0
    if path[3] != 118:                                 # 'v'
        return 0
    if path[4] != 47:                                  # '/'
        return 0
    if path[5] != 98:                                  # 'b'
        return 0
    if path[6] != 108:                                 # 'l'
        return 0
    if path[7] != 107:                                 # 'k'
        return 0
    if path[8] != 47:                                  # '/'
        return 0
    return 1


def _name_eq(a: Ptr[char], an: uint64, b: Ptr[char]) -> int32:
    # Compare the first `an` chars of `a` with the NUL-terminated `b`.
    # Returns 1 on a full match (b also ends at `an`), 0 otherwise.
    i: uint64 = 0
    while i < an:
        ca: int32 = a[i]
        cb: int32 = b[i]
        if cb == 0:
            return 0
        if ca != cb:
            return 0
        i = i + 1
    # `a` end: require b to also end here.
    if b[an] != 0:
        return 0
    return 1


def _find_slot_by_name(name: Ptr[char], name_len: uint64) -> int32:
    # Walk the kernel's block-device table and find the slot whose
    # NUL-terminated name matches `name[0..name_len]`. Returns -1 on
    # no match.
    if name_len == 0:
        return -1
    cap: uint64 = blk_max_slots()
    s: uint64 = 0
    while s < cap:
        slot_i: int32 = cast[int32](s)
        if blk_slot_in_use(slot_i) != 0:
            bname: Ptr[char] = blk_slot_name(slot_i)
            if cast[uint64](bname) != 0:
                if _name_eq(name, name_len, bname) != 0:
                    return slot_i
        s = s + 1
    return -1


def devblk_path_match(path: Ptr[char], out_packed: Ptr[uint64]) -> int32:
    # Returns 1 + plants the pkd (slot, mode) cookie in *out_packed
    # on a successful match. Returns 0 if the path is not /dev/blk/*.
    # Returns -1 if the path IS /dev/blk/* but names an unregistered
    # device (so the caller can surface -ENOENT).
    if _devblk_prefix_match(path) == 0:
        return 0
    # Find the end of <name> (first '/' or NUL after the prefix).
    tail: Ptr[char] = cast[Ptr[char]](
        cast[uint64](path) + DEVBLK_PREFIX_LEN)
    # Global pseudo-file: "/dev/blk/rootdev" (read-only). Match it
    # BEFORE the per-device name lookup so it doesn't collide with a
    # real device named "rootdev" (none exists, but be explicit).
    if tail[0] == 114 and tail[1] == 111 and tail[2] == 111 \
            and tail[3] == 116 and tail[4] == 100 and tail[5] == 101 \
            and tail[6] == 118 and tail[7] == 0:        # "rootdev"
        out_packed[0] = devblk_pack(-1, BLK_MODE_ROOTDEV)
        return 1
    name_len: uint64 = 0
    while name_len < DEVBLK_NAME_MAX:
        c: int32 = tail[name_len]
        if c == 0 or c == 47:
            break
        name_len = name_len + 1
    if name_len == 0 or name_len >= DEVBLK_NAME_MAX:
        return -1
    slot: int32 = _find_slot_by_name(tail, name_len)
    if slot < 0:
        return -1
    # Decide mode based on what follows <name>.
    after: int32 = tail[name_len]
    mode: uint64 = BLK_MODE_RAW
    if after == 0:
        mode = BLK_MODE_RAW
    elif after == 47:                                  # '/'
        sub: Ptr[char] = cast[Ptr[char]](
            cast[uint64](tail) + name_len + 1)
        # match "size" or "ctl"
        if sub[0] == 115 and sub[1] == 105 and sub[2] == 122 \
                and sub[3] == 101 and sub[4] == 0:
            mode = BLK_MODE_SIZE
        elif sub[0] == 99 and sub[1] == 116 and sub[2] == 108 \
                and sub[3] == 0:
            mode = BLK_MODE_CTL
        else:
            return -1
    else:
        return -1
    out_packed[0] = devblk_pack(slot, mode)
    return 1


def devblk_leaf_match(leaf: Ptr[char], out_packed: Ptr[uint64]) -> int32:
    # `#b/<leaf>` resolver. `leaf` is the tail AFTER the "#b/" prefix —
    # i.e. "<name>", "<name>/size", "<name>/ctl", or "rootdev". This is
    # the namespace-bind entry point: init does `bind '#b' /dev/blk`, so
    # an open of /dev/blk/<name> arrives at vfs_open as "#b/<name>" and
    # routes here. The slot/mode resolution is IDENTICAL to
    # devblk_path_match's post-prefix logic (deliberately shared shape —
    # both call _find_slot_by_name + the size/ctl tail check), just
    # starting from the leaf rather than the full /dev/blk/ path.
    #
    # Returns 1 + plants the pkd in *out_packed on a match; -1 if the
    # leaf names an unregistered device or carries an unknown tail.
    if leaf[0] == 0:
        return -1
    # "rootdev" pseudo-file (matches devblk_path_match's special case).
    if leaf[0] == 114 and leaf[1] == 111 and leaf[2] == 111 \
            and leaf[3] == 116 and leaf[4] == 100 and leaf[5] == 101 \
            and leaf[6] == 118 and leaf[7] == 0:           # "rootdev"
        out_packed[0] = devblk_pack(-1, BLK_MODE_ROOTDEV)
        return 1
    name_len: uint64 = 0
    while name_len < DEVBLK_NAME_MAX:
        c: int32 = leaf[name_len]
        if c == 0 or c == 47:
            break
        name_len = name_len + 1
    if name_len == 0 or name_len >= DEVBLK_NAME_MAX:
        return -1
    slot: int32 = _find_slot_by_name(leaf, name_len)
    if slot < 0:
        return -1
    after: int32 = leaf[name_len]
    mode: uint64 = BLK_MODE_RAW
    if after == 0:
        mode = BLK_MODE_RAW
    elif after == 47:                                      # '/'
        sub: Ptr[char] = cast[Ptr[char]](
            cast[uint64](leaf) + name_len + 1)
        if sub[0] == 115 and sub[1] == 105 and sub[2] == 122 \
                and sub[3] == 101 and sub[4] == 0:         # "size"
            mode = BLK_MODE_SIZE
        elif sub[0] == 99 and sub[1] == 116 and sub[2] == 108 \
                and sub[3] == 0:                           # "ctl"
            mode = BLK_MODE_CTL
        else:
            return -1
    else:
        return -1
    out_packed[0] = devblk_pack(slot, mode)
    return 1


# --- size text rendering --------------------------------------------

def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digits: Array[24, uint8]
    n: uint64 = 0
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return written


def devblk_capacity_bytes(pkd: uint64) -> uint64:
    # Total byte capacity of the device referenced by `pkd`. Used by
    # fs/vfs.ad's _open_blk_marked to snapshot fd_buflen so the generic
    # chan SEEK_END arm resolves locally. Returns 0 for an invalid or
    # unregistered slot.
    slot: int32 = devblk_unpack_slot(pkd)
    return blk_capacity_sectors(slot) * SECTOR_SIZE


# --- public read/write --------------------------------------------------

def devblk_read(pkd: uint64, fd_pos: uint64,
                buf: Ptr[uint8], count: uint64) -> int64:
    # Read from the device.
    #   RAW : sector-aligned, blk_read_sectors. EOF at capacity.
    #   SIZE: render ASCII decimal size in bytes (one-shot).
    #   CTL : returns 0 (not readable).
    slot: int32 = devblk_unpack_slot(pkd)
    mode: uint64 = devblk_unpack_mode(pkd)
    if mode == BLK_MODE_ROOTDEV:
        # One-shot read: "<disk>\n" (e.g. "vdb\n"), or empty if there
        # is no live root recorded (cpio-only boot). The installer
        # reads this to learn which disk it must NOT touch.
        if fd_pos > 0:
            return 0
        namebuf: Array[32, uint8]
        rl: int32 = blk_root_disk_name(&namebuf[0], 31)
        if rl < 0:
            return 0                                   # no live root
        nlen: uint64 = cast[uint64](rl)
        namebuf[nlen] = 10                             # '\n'
        nlen = nlen + 1
        take: uint64 = count
        if take > nlen:
            take = nlen
        i: uint64 = 0
        while i < take:
            buf[i] = namebuf[i]
            i = i + 1
        return cast[int64](take)
    if mode == BLK_MODE_SIZE:
        if fd_pos > 0:
            return 0
        cap: uint64 = blk_capacity_sectors(slot)
        total_bytes: uint64 = cap * SECTOR_SIZE
        scratch: Array[32, uint8]
        n: uint64 = _u64_to_dec(total_bytes, &scratch[0])
        scratch[n] = 10                                # '\n'
        n = n + 1
        take: uint64 = count
        if take > n:
            take = n
        i: uint64 = 0
        while i < take:
            buf[i] = scratch[i]
            i = i + 1
        return cast[int64](take)
    if mode == BLK_MODE_CTL:
        return 0
    # RAW
    if (fd_pos % SECTOR_SIZE) != 0:
        printk1("devblk: unaligned read pos=%d\n", fd_pos)
        return -22                                     # -EINVAL
    if (count % SECTOR_SIZE) != 0:
        printk1("devblk: unaligned read count=%d\n", count)
        return -22
    if count == 0:
        return 0
    cap: uint64 = blk_capacity_sectors(slot)
    lba: uint64 = fd_pos / SECTOR_SIZE
    nsec: uint64 = count / SECTOR_SIZE
    if lba >= cap:
        return 0                                       # EOF
    if lba + nsec > cap:
        nsec = cap - lba
    rc: int32 = blk_read_sectors(slot, lba, nsec, buf)
    if rc != 0:
        return -5                                      # -EIO
    return cast[int64](nsec * SECTOR_SIZE)


# --- CTL command parser ---------------------------------------------
#
# Commands are short ASCII lines. We accept up to 255 bytes per write
# and parse the leading verb. The terminator is '\n' or end-of-buffer.

devblk_ctl_buf: Array[256, uint8]


def _ctl_starts_with(buf: Ptr[uint8], n: uint64, s: Ptr[uint8]) -> int32:
    # 1 if buf[0..] starts with the NUL-terminated `s`.
    i: uint64 = 0
    while s[i] != 0:
        if i >= n:
            return 0
        if buf[i] != s[i]:
            return 0
        i = i + 1
    return 1


def _ctl_skip_ws(buf: Ptr[uint8], n: uint64, pos: uint64) -> uint64:
    while pos < n:
        c: uint8 = buf[pos]
        if c != 32 and c != 9:                         # ' ' / '\t'
            return pos
        pos = pos + 1
    return pos


def _ctl_parse_u64(buf: Ptr[uint8], n: uint64, pos: uint64,
                   out: Ptr[uint64]) -> uint64:
    # Parse a decimal u64 starting at `pos`. Returns the new position.
    # Stops at the first non-digit. Sets *out to the parsed value.
    pos = _ctl_skip_ws(buf, n, pos)
    v: uint64 = 0
    while pos < n:
        c: uint8 = buf[pos]
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[uint64](c - 48)
        pos = pos + 1
    out[0] = v
    return pos


def devblk_write(pkd: uint64, fd_pos: uint64,
                 buf: Ptr[uint8], count: uint64) -> int64:
    # Write to the device.
    #   RAW : sector-aligned, blk_write_sectors. -EFBIG past capacity.
    #   SIZE: -EINVAL (read-only).
    #   CTL : parse a text command, dispatch to in-kernel formatter.
    slot: int32 = devblk_unpack_slot(pkd)
    mode: uint64 = devblk_unpack_mode(pkd)
    if mode == BLK_MODE_SIZE:
        return -22                                     # -EINVAL — RO
    if mode == BLK_MODE_ROOTDEV:
        return -22                                     # -EINVAL — RO
    if mode == BLK_MODE_CTL:
        return _devblk_ctl_write(slot, buf, count)
    # RAW
    if (fd_pos % SECTOR_SIZE) != 0:
        printk1("devblk: unaligned write pos=%d\n", fd_pos)
        return -22
    if (count % SECTOR_SIZE) != 0:
        printk1("devblk: unaligned write count=%d\n", count)
        return -22
    if count == 0:
        return 0
    cap: uint64 = blk_capacity_sectors(slot)
    lba: uint64 = fd_pos / SECTOR_SIZE
    nsec: uint64 = count / SECTOR_SIZE
    if lba >= cap:
        return -27                                     # -EFBIG
    if lba + nsec > cap:
        nsec = cap - lba
    rc: int32 = blk_write_sectors(slot, lba, nsec, buf)
    if rc != 0:
        return -5                                      # -EIO
    return cast[int64](nsec * SECTOR_SIZE)


# Path scratch for install_file. Sized for full paths with parents
# (e.g. "usr/lib/x86_64-linux-gnu/libapt-pkg.so.7.0.0" = 48 chars,
# leaving plenty of slack); the kernel-side path walker mkdir -p's
# any missing intermediate dirs. Each leaf component is still capped
# at the ext4 inode dirent limit of 255 bytes.
DEVBLK_INSTALL_PATH_MAX: uint64 = 1024
devblk_install_name: Array[1024, uint8]


# Streaming-reassembly state for install_file bodies that arrive across
# multiple write(2) calls.
#
# SYS_READ/WRITE route through copy_from_user + a fixed 4 KiB kernel
# bounce buffer (arch/x86/kernel/syscall.ad UA_BOUNCE_SZ), so a single
# userland sys_write of an N-byte buffer is delivered to vfs_write — and
# thus to this ctl handler — as ceil(N/4096) back-to-back chunked writes.
# The original install_file protocol assumed the WHOLE "header + body"
# arrived in ONE count, which silently broke for any file whose header+
# body exceeded one page (etc/rc.boot at 6868 bytes was the first). We
# reassemble the body into a per-install kmalloc'd staging buffer, then
# hand the contiguous body to ext4_install_file_to_slot exactly once.
#
# Only ONE install_file may stream at a time (hpm writes sequentially);
# a fresh "install_file " header while a stream is active aborts the
# stale one (frees its buffer) before starting over.
devblk_inst_active: int32 = 0
devblk_inst_buf: uint64 = 0                       # kmalloc'd body staging
devblk_inst_size: uint64 = 0                      # expected body length
devblk_inst_got: uint64 = 0                       # body bytes staged so far
devblk_inst_slot: int32 = -1                      # target block slot


def _devblk_install_reset():
    # Drop any in-flight streaming install and free its staging buffer.
    if devblk_inst_buf != 0:
        kfree(devblk_inst_buf)
    devblk_inst_buf = 0
    devblk_inst_active = 0
    devblk_inst_size = 0
    devblk_inst_got = 0
    devblk_inst_slot = -1


def _devblk_install_finalize() -> int64:
    # The full body is staged contiguously in devblk_inst_buf; commit it
    # to ext4 and clear the streaming state. Returns 0 on success, a
    # negative errno on I/O failure.
    rc: int32 = ext4_install_file_to_slot(
        devblk_inst_slot, cast[Ptr[char]](&devblk_install_name[0]),
        cast[Ptr[uint8]](devblk_inst_buf), devblk_inst_size)
    sz: uint64 = devblk_inst_size
    sl: int32 = devblk_inst_slot
    _devblk_install_reset()
    if rc != 0:
        return -5                                 # -EIO
    printk2("[devblk] install_file slot=%d size=%d OK\n",
            cast[uint64](sl), sz)
    return 0


def _devblk_ctl_install_body(buf: Ptr[uint8], count: uint64) -> int64:
    # Continuation chunk: the ENTIRE `buf` is body bytes for the install
    # currently streaming. Append up to the outstanding remainder, and
    # finalize once the whole body has arrived.
    remain: uint64 = devblk_inst_size - devblk_inst_got
    take: uint64 = count
    if take > remain:
        take = remain                             # ignore any tail slop
    dst: uint64 = devblk_inst_buf + devblk_inst_got
    i: uint64 = 0
    while i < take:
        cast[Ptr[uint8]](dst)[i] = buf[i]
        i = i + 1
    devblk_inst_got = devblk_inst_got + take
    if devblk_inst_got >= devblk_inst_size:
        rc: int64 = _devblk_install_finalize()
        if rc != 0:
            return rc
    return cast[int64](count)


def _devblk_ctl_install_file(slot: int32, buf: Ptr[uint8],
                             count: uint64) -> int64:
    # Header chunk. Wire format: "install_file <PATH> <SIZE>\n<BODY>"
    # where <PATH> is a token of non-space bytes (may include '/'
    # separators; intermediate dirs get mkdir -p'd by the kernel),
    # <SIZE> is a decimal u64, and <BODY> is SIZE bytes following the
    # header newline — possibly continuing into later write(2) chunks
    # (see the streaming state above; the 4 KiB bounce buffer caps how
    # much body rides along in this first chunk).
    #
    # Routes to fs/ext4.ad::ext4_install_file_to_slot, which save/
    # restores the singleton ext4 mount globals around the install so
    # the live FS keeps serving on either success or failure.
    #
    # Returns `count` bytes consumed on success, a negative errno on
    # parse / I/O failure (so the caller's write(2) gets the right
    # short-write / -1 distinction).
    # A new header supersedes any half-streamed prior install.
    if devblk_inst_active != 0:
        _devblk_install_reset()
    if count < 13:
        return -22                                # -EINVAL
    pos: uint64 = 13                              # past "install_file "
    pos = _ctl_skip_ws(buf, count, pos)
    # Parse <PATH> token: non-space, non-newline, non-NUL bytes.
    name_start: uint64 = pos
    while pos < count:
        c: uint8 = buf[pos]
        if c == 32 or c == 9 or c == 10 or c == 0:
            break
        pos = pos + 1
    name_len: uint64 = pos - name_start
    if name_len == 0 or name_len >= DEVBLK_INSTALL_PATH_MAX:
        printk0("[devblk] install_file: bad path length\n")
        return -22
    # Copy the path into scratch and NUL-terminate.
    ki: uint64 = 0
    while ki < name_len:
        devblk_install_name[ki] = buf[name_start + ki]
        ki = ki + 1
    devblk_install_name[name_len] = 0
    # Parse <SIZE>.
    pos = _ctl_skip_ws(buf, count, pos)
    body_size: uint64 = 0
    pos = _ctl_parse_u64(buf, count, pos, &body_size)
    # Skip optional whitespace + the terminating newline.
    while pos < count and (buf[pos] == 32 or buf[pos] == 9):
        pos = pos + 1
    if pos >= count or buf[pos] != 10:
        printk0("[devblk] install_file: missing newline after header\n")
        return -22
    pos = pos + 1                                 # past '\n'
    avail: uint64 = count - pos
    body: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](buf) + pos)
    # Fast path: the entire body rode along in this first chunk — commit
    # directly without any staging allocation.
    if avail >= body_size:
        rc: int32 = ext4_install_file_to_slot(
            slot, cast[Ptr[char]](&devblk_install_name[0]),
            body, body_size)
        if rc != 0:
            return -5                             # -EIO
        printk2("[devblk] install_file slot=%d size=%d OK\n",
                cast[uint64](slot), body_size)
        return cast[int64](count)
    # Slow path: body spans multiple write chunks. Stage it.
    if body_size == 0:
        return -22
    sbuf: uint64 = kmalloc(body_size)
    if sbuf == 0:
        printk1("[devblk] install_file: staging alloc failed size=%d\n",
                body_size)
        return -12                                # -ENOMEM
    devblk_inst_buf = sbuf
    devblk_inst_size = body_size
    devblk_inst_got = 0
    devblk_inst_slot = slot
    devblk_inst_active = 1
    # Copy whatever body bytes rode along in this header chunk.
    i: uint64 = 0
    while i < avail:
        cast[Ptr[uint8]](devblk_inst_buf)[i] = body[i]
        i = i + 1
    devblk_inst_got = avail
    return cast[int64](count)


def _devblk_ctl_write(slot: int32, buf: Ptr[uint8],
                      count: uint64) -> int64:
    # Buffer the command into devblk_ctl_buf (capped at 255 bytes),
    # then parse + dispatch.
    #
    # SPECIAL CASE: the "install_file" verb passes a file body
    # immediately after the header line, so the body bytes blow past
    # the 255-byte command-buf cap AND, because SYS_WRITE chunks every
    # write through a 4 KiB bounce buffer, may span several writes. If
    # a body is mid-stream, EVERY byte of this write is body data (it
    # may even start with the literal "install_file " — that's content,
    # not a new verb), so the active-stream check MUST come first.
    if devblk_inst_active != 0:
        return _devblk_ctl_install_body(buf, count)
    if count >= 13:
        if _ctl_starts_with(buf, count, "install_file ") != 0:
            return _devblk_ctl_install_file(slot, buf, count)
    n: uint64 = count
    if n > 255:
        n = 255
    i: uint64 = 0
    while i < n:
        devblk_ctl_buf[i] = buf[i]
        i = i + 1
    devblk_ctl_buf[n] = 0
    # Trim trailing newline.
    if n > 0 and devblk_ctl_buf[n - 1] == 10:
        devblk_ctl_buf[n - 1] = 0
        n = n - 1
    bp: Ptr[uint8] = &devblk_ctl_buf[0]

    if _ctl_starts_with(bp, n, "mkfs_ext4") != 0:
        # mkfs_ext4 — format the WHOLE device as a single ext4 FS.
        # Caller is expected to have opened a PARTITION cdev
        # (/dev/blk/vdaN), so the kernel sees the partition's capacity
        # as the device capacity.
        cap: uint64 = blk_capacity_sectors(slot)
        rc: int32 = ext4_mkfs(slot, cap)
        if rc != 0:
            return -5
        printk2("[devblk] mkfs_ext4 slot=%d cap=%d sectors OK\n",
                cast[uint64](slot), cap)
        return cast[int64](count)
    if _ctl_starts_with(bp, n, "mkdir ") != 0:
        # mkdir <path> — create the directory <path> on the ext4 FS
        # at this slot (mkdir -p semantics; intermediate components
        # are auto-created). Routes to fs/ext4.ad::ext4_mkdir_at_slot,
        # which save/restores the singleton mount globals around the
        # call so the live FS keeps serving. Used by the multi-package
        # installer to pre-create parent dirs that the package payload
        # would otherwise need; also exposed for symmetry with the
        # install_file verb so userland can mkdir at any path on a
        # NOT-currently-mounted partition.
        pos: uint64 = 6                                    # past "mkdir "
        pos = _ctl_skip_ws(bp, n, pos)
        if pos >= n:
            printk0("[devblk] mkdir: missing path\n")
            return -22
        # Path runs from `pos` to end of command (no terminator beyond
        # the NUL devblk_ctl_buf already carries). Refuse empty paths.
        if bp[pos] == 0:
            return -22
        rc: int32 = ext4_mkdir_at_slot(
            slot, cast[Ptr[char]](cast[uint64](bp) + pos))
        if rc != 0:
            return -5
        printk2("[devblk] mkdir slot=%d pos=%d OK\n",
                cast[uint64](slot), pos)
        return cast[int64](count)
    if _ctl_starts_with(bp, n, "mkfs_fat") != 0:
        # mkfs_fat [<size_mb>] — format the WHOLE device as FAT12.
        # 0 means "use device capacity".
        pos: uint64 = 8                                # past "mkfs_fat"
        size_mb: uint64 = 0
        pos = _ctl_skip_ws(bp, n, pos)
        if pos < n:
            pos = _ctl_parse_u64(bp, n, pos, &size_mb)
        rc: int32 = fat_mkfs(slot, size_mb)
        if rc != 0:
            return -5
        printk2("[devblk] mkfs_fat slot=%d size_mb=%d OK\n",
                cast[uint64](slot), size_mb)
        return cast[int64](count)
    if _ctl_starts_with(bp, n, "gpt_init") != 0:
        # gpt_init — lay down a fresh GPT + protective MBR on the
        # WHOLE device. Caller must hold an fd onto the disk cdev
        # (NOT a partition cdev).
        cap: uint64 = blk_capacity_sectors(slot)
        rc: int32 = gpt_init(slot, cap)
        if rc != 0:
            printk_set_level(PRINTK_LEVEL_NOTICE)
            printk2("[devblk] gpt_init FAILED slot=%d cap=%d\n",
                    cast[uint64](slot), cap)
            return -5
        printk2("[devblk] gpt_init slot=%d cap=%d OK\n",
                cast[uint64](slot), cap)
        return cast[int64](count)
    if _ctl_starts_with(bp, n, "gpt_mkpart") != 0:
        # gpt_mkpart <idx> <start_lba> <end_lba> <type>
        # type ∈ {esp, linux}.
        pos: uint64 = 10                               # past "gpt_mkpart"
        idx: uint64 = 0
        st:  uint64 = 0
        en:  uint64 = 0
        pos = _ctl_parse_u64(bp, n, pos, &idx)
        pos = _ctl_parse_u64(bp, n, pos, &st)
        pos = _ctl_parse_u64(bp, n, pos, &en)
        pos = _ctl_skip_ws(bp, n, pos)
        # Type tag: "esp" or "linux".
        guid_high: uint64 = GPT_GUID_LINUX_FS_HIGH
        guid_low:  uint64 = GPT_GUID_LINUX_FS_LOW
        if pos < n and bp[pos] == 101 and bp[pos + 1] == 115 \
                and bp[pos + 2] == 112:                # "esp"
            guid_high = GPT_GUID_EFI_SYSTEM_HIGH
            guid_low  = GPT_GUID_EFI_SYSTEM_LOW
        rc: int32 = gpt_mkpart(slot, cast[int32](idx), st, en,
                               guid_high, guid_low)
        if rc != 0:
            return -5
        printk2("[devblk] gpt_mkpart slot=%d idx=%d OK\n",
                cast[uint64](slot), idx)
        return cast[int64](count)
    if _ctl_starts_with(bp, n, "rescan") != 0:
        # Rescan partitions. Useful after gpt_mkpart so the partition
        # siblings (/dev/blk/vdaN) appear without a reboot.
        partition_rescan(slot)
        nm2: Ptr[char] = blk_slot_name(slot)
        if cast[uint64](nm2) != 0:
            blk_register_partitions(slot, nm2)
        printk1("[devblk] rescan slot=%d OK\n", cast[uint64](slot))
        return cast[int64](count)
    printk0("[devblk] ctl: unknown command\n")
    return -22

# sys/src/port9/port/devkeymap.ad
#
# task #178 — the Plan 9-shape keyboard-layout control cdev.
#
# /dev/keymap is the runtime switch for the selectable keyboard layouts
# implemented in drivers/input/atkbd.ad. It is a sibling of /dev/hostname
# in the introspection family: a stateful READ + WRITE knob backed by
# kernel RAM (here, the atkbd driver's current-layout selector).
#
#   Read shape:    "<name>\n"   — the active layout's 2-letter id, e.g.
#                                 "us\n" / "de\n" / "fr\n".
#   Write semantic: the caller's bytes name a layout to switch to. Only
#                   the first two letters are inspected (case-insensitive),
#                   so `echo de > /dev/keymap` works — the trailing '\n'
#                   is ignored. An unknown name leaves the layout
#                   unchanged but still reports the write consumed (so a
#                   shell doesn't spin retrying); the kernel logs nothing
#                   in that path to keep the prompt quiet.
#
# This is the established cdev pattern (devhostname.ad), NOT a Linux
# ioctl: the layout is selected by writing a name to a pseudo-file, the
# Plan 9 way. namec.ad routes /dev/keymap to DEV_KEYMAP, whose
# _devtab_read / _devtab_write delegate to the two functions below.
#
# Compiler-quirk note: Adder has a flat global symbol namespace across
# merged modules, so the shared-shape helpers are prefixed `_kmd_` to
# avoid colliding with devhostname's `_hn_` family etc.

from drivers.input.atkbd import (
    keymap_name_into, keymap_id_for_name, keymap_select,
)


def _kmd_is_trailing_ws(c: uint8) -> int32:
    # Trailing bytes stripped from a write so `echo de > /dev/keymap`
    # leaves "de", not "de\n".
    if c == 10:                                       # '\n'
        return 1
    if c == 13:                                       # '\r'
        return 1
    if c == 32:                                       # ' '
        return 1
    if c == 9:                                        # '\t'
        return 1
    return 0


def devkeymap_read(buf: Ptr[uint8], count: uint64) -> int64:
    # Render the active layout name + '\n' into the caller. Snapshot-once
    # shape: total available = name_len + 1, capped by `count`.
    if count == 0:
        return 0
    scratch: Array[8, uint8]
    name_len: uint64 = keymap_name_into(&scratch[0])
    scratch[name_len] = 10                            # '\n'
    n: uint64 = name_len + 1
    take: uint64 = count
    if take > n:
        take = n
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devkeymap_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Parse a layout name from the caller's bytes and switch to it.
    # Strips trailing whitespace, then resolves the 2-letter id and
    # selects the layout. Always reports the original `count` consumed
    # so the writing shell's loop terminates even on an unknown name.
    if count == 0:
        return 0
    take: uint64 = count
    while take > 0:
        if _kmd_is_trailing_ws(buf[take - 1]) == 0:
            break
        take = take - 1
    if take >= 2:
        id: int32 = keymap_id_for_name(buf, take)
        if id >= 0:
            keymap_select(id)
    return cast[int64](count)

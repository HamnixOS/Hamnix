# sys/src/9/port/namec.ad
#
# Phase D — the universal resource path. Plan 9's namec()/devtab spine.
#
# WHAT THIS IS
# ------------
# Hamnix is meant to be Plan 9-central: 9P + per-process namespaces are
# the spine; the Linux VFS and the fd table are *consumers* of that
# spine, not the substrate. Before this module, fs/vfs.ad inverted that
# — it dispatched every cdev (/dev/cons, /dev/time, ...) via a
# FD_<NAME>_MARK magic-number special-case, and a 9P-mounted file went
# through a *different* FD_P9_MARK arm. A local device and a mounted
# 9P file were two unrelated code paths.
#
# This module restores the Plan 9 layering. The load-bearing idea:
#
#   * A Chan is the universal handle. It does not know whether it
#     refers to a local kernel device or a file on a mounted 9P
#     server.
#
#   * devtab[] is the device-operation dispatch table. Index it by
#     Chan.dev_type and you get the open/read/write/close behaviour.
#     One devtab slot per local device kind; one *single* slot —
#     DEV_MNT — for "this chan is backed by a mounted 9P server",
#     whose ops marshal into 9P T-messages (mountrpc).
#
#   * namec(path, mode) is the universal open path. It resolves a
#     path through the CALLING PROCESS's Pgrp mount table (chan.ad)
#     to a Chan. If the path falls under a 9P SRV-kind mount, namec
#     hands back a Chan whose dev_type is DEV_MNT; otherwise it maps
#     a known device path to a Chan with the matching local dev_type.
#     The CALLER NEVER LEARNS WHICH — it just gets a Chan id and
#     calls namec_read / namec_write / namec_close.
#
# So a local-device Chan and a mounted-9P Chan are the SAME TYPE with
# the SAME operation interface. That is the Phase D inversion.
#
# BOUNDARY LAW
# ------------
# This module is Layer 1 (native): pure 9P + namespace. It has NO
# dependency on io_uring / epoll / futex / eventfd (those are Layer-2
# Linux-ABI only). It must never grow one.
#
# NON-REGRESSION
# --------------
# Phase D is not a "regressions acceptable" change. fs/vfs.ad keeps
# its existing FD_<NAME>_MARK arms as-is; this module is ADDITIVE.
# vfs_open routes a cdev/9P open through namec(), which installs a
# single FD_CHAN_MARK fd carrying a chan-table slot index; vfs_read /
# vfs_write / vfs_close dispatch FD_CHAN_MARK fds back here. Every
# device produces byte-for-byte the same observable behaviour it did
# through its old FD mark — the tests (test_devcons / test_9p_e2e /
# ...) prove it.
#
# ADDER QUIRKS HONOURED
# ---------------------
#   * Top-level Array storage only — the chan pool lives at module
#     scope (chan_pool below), not in a nested frame.
#   * No sizeof — DEV_* indices are hand-numbered constants.
#   * devtab dispatch is a switch on an int, not a struct of function
#     pointers: Adder's function-pointer-in-struct story is fragile,
#     and an integer switch is unambiguous to the codegen and trivial
#     to read.
#   * Leading-underscore top-level names are module-private.

from sys.src.port9.port.chan import chan_find_srv_prefix, pgrp_current
# Phase 4c: the `#d` fd-name device. A DEV_DEVFD inline chan resolves
# its backing channel per-I/O against the CALLING task's Pgrp devfd
# table (pgrp_current above). devfd.ad sits below namec in the import
# graph (it imports fs.pipe / fs.tmpfs / devcons only), so a direct
# import is cycle-free.
from sys.src.port9.port.devfd import (
    devfd_read_blocking, devfd_write_blocking,
    devfd_read_nb, devfd_poll_readable,
)
# Phase 4c (pipe fold): DEV_PIPE_R / DEV_PIPE_W pool chans carry a
# fs/pipe.ad slot in back_slot. The blocking I/O bodies live in
# fs/pipe.ad (event-driven WaitQueue sleep — NEVER reintroduce a
# poll-yield loop here); close releases ONE end-refcount on the last
# chan reference. fs/pipe.ad sits below namec (imports slab/printk/
# core only), so a direct import is cycle-free.
from fs.pipe import (
    pipe_read, pipe_read_blocking, pipe_write_blocking,
    pipe_readers, pipe_writers, pipe_readable,
    pipe_close_reader, pipe_close_writer,
)
# Phase 4c (socket fold): DEV_SOCKETPAIR pool chans carry the packed
# (slot << 1 | direction) sockpair endpoint in back_slot — one chan
# per END, refcounted across fork/dup by the chan refcount; the LAST
# namec_close releases the end via sockpair_close. fs/socketpair.ad
# sits below namec (imports slab/printk/core only) — cycle-free.
from fs.socketpair import (
    sockpair_read, sockpair_read_blocking, sockpair_write_blocking,
    sockpair_readable, sockpair_peer_alive, sockpair_close,
    sockpair_pack, sockpair_unpack_slot, sockpair_unpack_dir,
)
from sys.src.port9.port.9p_client import (
    p9c_walk_open_path, p9c_walk_create_path,
    p9c_walk_mkdir_path,
    p9c_read, p9c_write, p9c_clunk,
)
# Layer 1 cdev backends. namec routes a /dev/<name> open to the
# matching devtab slot whose read/write delegate here. These are the
# SAME bodies fs/vfs.ad's FD_<NAME>_MARK arms call — the inversion is
# in WHO dispatches, not in the device code.
from sys.src.port9.port.devcons import (
    devcons_read, devcons_read_nb, devcons_write, devcons_poll_readable,
)
# SYS_WAITFDS: non-destructive /dev/mouse readiness probe (PS/2 aux
# ring). Import-only — the producer IRQ path lives in drivers/input.
from drivers.input.auxmouse import mouse_rx_has
from sys.src.port9.port.devtime import devtime_read, devtime_write
from sys.src.port9.port.devpid import devpid_read, devpid_write
from sys.src.port9.port.devrandom import devrandom_read, devrandom_write
from sys.src.port9.port.devmouse import devmouse_read, devmouse_write
from sys.src.port9.port.devcpuinfo import devcpuinfo_read, devcpuinfo_write
from sys.src.port9.port.devmeminfo import devmeminfo_read, devmeminfo_write
from sys.src.port9.port.devuptime import devuptime_read, devuptime_write
from sys.src.port9.port.devloadavg import devloadavg_read, devloadavg_write
from sys.src.port9.port.devversion import devversion_read, devversion_write
from sys.src.port9.port.devhostname import devhostname_read, devhostname_write
# DE primitive: /dev/snarf — global one-buffer clipboard cdev.
from sys.src.port9.port.devsnarf import devsnarf_read, devsnarf_write
# task #178: /dev/keymap — selectable keyboard-layout control cdev.
from sys.src.port9.port.devkeymap import devkeymap_read, devkeymap_write
# #174: /dev/nscap — per-namespace resource-cap control cdev.
from sys.src.port9.port.devnscap import devnscap_read, devnscap_write
# Native packet-filter firewall control cdev — /dev/firewall.
from sys.src.port9.port.devfirewall import devfirewall_read, devfirewall_write
from sys.src.port9.port.devstat import devstat_read, devstat_write
from sys.src.port9.port.devmounts import devmounts_read, devmounts_write
from sys.src.port9.port.devdiskstats import (
    devdiskstats_read, devdiskstats_write,
)
# HAMSH §6 / §18 stage-4 tripwire: /dev/mountrpc renders the
# cumulative count of 9P T-messages sent. A local pipeline must leave
# it unchanged — that is what proves "pipes are Chans, not 9P".
from sys.src.port9.port.devmountrpc import (
    devmountrpc_read, devmountrpc_write,
    dev9pmax_read, dev9pmax_write,
)
# hamUI Phase 1: /dev/wsys/* file-server-per-window backend. One
# devtab slot per file in the per-window tree so namec / FD_CHAN_MARK
# dispatch routes opens of /dev/wsys/1/text etc. to the matching cdev
# read/write body.
from sys.src.port9.port.devwsys import (
    devwsys_text_read, devwsys_output_read, devwsys_ns_read,
    devwsys_pid_read, devwsys_uid_read,
    devwsys_kind_read, devwsys_geometry_read,
    devwsys_listing_read,
    devwsys_cmd_write, devwsys_readonly_write,
    # F2 #447: /dev/wsys/ctl (system-wide wsys ctl — replaces SYS_WSYS_*
    # / SYS_VK_WINDOW_FRAME). Hostowner-gated inside devwsys_ctl_write.
    devwsys_ctl_write, devwsys_ctl_read,
    wsys_wid_in_use, MAX_WINDOWS,
    # hamUI Phase 4a — layered-draw file surface (docs/hamUI.md H-§G).
    devwsys_draw_ctl_write, devwsys_draw_listing_read,
    devwsys_draw_kind_read,
    devwsys_draw_z_read, devwsys_draw_z_write,
    devwsys_draw_opacity_read, devwsys_draw_opacity_write,
    devwsys_draw_geometry_read, devwsys_draw_geometry_write,
    devwsys_draw_markup_read, devwsys_draw_markup_write,
    devwsys_draw_fb_read, devwsys_draw_fb_write,
    wsys_draw_resolve_layer,
    # hamUI compositor hot-path damage interface (additive).
    devwsys_serial_read, devwsys_serial_write,
    devwsys_damage_read, devwsys_self_read,
    devwsys_pointer_read, devwsys_pointer_write,
    devwsys_keys_read, devwsys_keys_write,
    devwsys_pointer_read_nb, devwsys_keys_read_nb,
    # SYS_WAITFDS readiness: per-layer gen leaf + non-destructive
    # pointer/keys ring probes.
    devwsys_draw_gen_read,
    wsys_pointer_pending, wsys_keys_pending,
    # DE primitive: per-window /dev/wsys/<N>/wctl — resize/move/focus
    # verb sink, snapshot-once status read.
    devwsys_wctl_write, devwsys_wctl_read,
    # DE image-wallpaper: /dev/wsys/wallpaper renders "<gen> <path>\n".
    # The write side is the existing /dev/wsys/ctl `wallpaper <path>` verb
    # (extended in devwsys_ctl_write).
    devwsys_wallpaper_read,
    # DE session save/restore: /dev/wsys/session renders one line per
    # active wid as "<wid> <pid> <app> <x> <y> <w> <h>\n". The write
    # side is the existing /dev/wsys/ctl `setapp <wid> <path>` verb
    # (extended in devwsys_ctl_write) which the compositor calls after
    # each daemon_spawn_window_prog so the snapshot is replay-able.
    devwsys_session_read,
    # DE pivot wave 2 — /dev/wsys/appmenu + /dev/wsys/appmenu/launch.
    devwsys_appmenu_read,
    devwsys_appmenu_launch_read, devwsys_appmenu_launch_write,
    # DE pivot wave 3 — /dev/wsys/cycler + /dev/wsys/cycler/show.
    devwsys_cycler_read,
    devwsys_cycler_show_read, devwsys_cycler_show_write,
    # DE pivot wave 4 — /dev/wsys/calpop + /dev/wsys/calpop/show.
    devwsys_calpop_read,
    devwsys_calpop_show_read, devwsys_calpop_show_write,
    # DE pivot wave 4 — /dev/wsys/run + /dev/wsys/run/show + /dev/wsys/run/launch.
    devwsys_run_read,
    devwsys_run_show_read, devwsys_run_show_write,
    devwsys_run_launch_read, devwsys_run_launch_write,
    # DE pivot wave 5 — /dev/wsys/lock + /dev/wsys/lock/show + /dev/wsys/lock/verify.
    devwsys_lock_read,
    devwsys_lock_show_read, devwsys_lock_show_write,
    devwsys_lock_verify_read, devwsys_lock_verify_write,
    # #442 (c) rio blit protocol substrate.
    devwsys_bbstate_read, devwsys_backbuffer_read,
)
# Native power control: /dev/reboot. A write of "poweroff"/"reboot"/
# "halt" funnels into the shared kernel power routine (which also backs
# the Linux reboot(2)=169 syscall). power_action() never returns on a
# power-taking action. The whole kernel compiles as one merged unit so
# this import only brings the names into scope — there is no separate
# link step where a cycle could bite.
from arch.x86.kernel.power import (
    power_action, POWER_HALT, POWER_REBOOT, POWER_POWEROFF,
    power_suspend_s3, power_s3_ready, power_lid_arm_suspend,
)
# hamUI Phase 4c: /dev/fb physical-framebuffer presentation cdev.
# devfb_read renders the geometry line; devfb_write presents RGBA8888
# bytes to the live linear framebuffer. See drivers/video/fb_cdev.ad.
from drivers.video.fb_cdev import (
    devfb_read, devfb_write,
    devfbctl_read, devfbctl_write,
    devfbpix_read, devfbpix_write,
)
# Native Intel HDA audio: /dev/audio (raw PCM sink + status read) and
# /dev/audioctl (text control verbs: rate/channels/format/start/stop).
# Backed by drivers/audio/audio_cdev.ad over the native HDA driver
# drivers/audio/hda.ad. The Plan-9 control surface — a file you write
# bytes/verbs to, NOT a Linux ioctl ABI.
from drivers.audio.audio_cdev import (
    devaudio_read, devaudio_write,
    devaudioctl_read, devaudioctl_write,
    devaudioin_read, devaudioin_write,
)
# Virtual terminal cdev: /dev/vt/1..4 (per-VT input FIFO readers +
# serial output) and /dev/vt/ctl (active-VT switch channel for chvt).
from sys.src.port9.port.devvt import (
    devvt_read, devvt_write, devvtctl_write,
)
# DEV_DIR_FILE's _dirfile_read copies bytes out of the kmalloc'd "NAME\n"
# listing buffer carried in back_ptr. memcpy is the kernel's C-runtime
# symbol (the same one every other port file pulls in via `extern def`);
# the whole kernel links as one merged unit so this only brings the name
# into scope — there is no separate link step where a cycle could bite.
extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]


# --- FD_CHAN_MARK ---------------------------------------------------
#
# A single fd-table marker for "this fd is backed by a namec Chan".
# Replaces the dozen FD_<NAME>_MARK constants AT THE FD LAYER: the fd
# no longer encodes WHICH device — the chan-table slot it points at
# (stored in fd_buf) does. Defined here, not in kernel/sched/core.ad,
# following the same colocation pattern devstat.ad / 9p_client.ad use
# (a new mark adjacent to its dispatch code, no core.ad churn). Value
# sits in the reserved high-mark band above the 0xFE000000 marker
# floor and clear of every existing FD_<NAME>_MARK
# (0xFFFFFFE4..0xFFFFFFFF).
FD_CHAN_MARK: uint32 = 0xFFFFFFE0


# --- device type indices (devtab keys) ------------------------------
#
# Each local device kind is one devtab slot. DEV_MNT is the special
# "mounted 9P server" slot: a Chan with dev_type == DEV_MNT marshals
# its ops into 9P T-messages instead of calling a local backend.
DEV_NONE:      int32 = 0           # unused chan slot
DEV_CONS:      int32 = 1           # /dev/cons
DEV_TIME:      int32 = 2           # /dev/time
DEV_PID:       int32 = 3           # /dev/pid
DEV_RANDOM:    int32 = 4           # /dev/random
DEV_MOUSE:     int32 = 5           # /dev/mouse
DEV_CPUINFO:   int32 = 6           # /dev/cpuinfo
DEV_MEMINFO:   int32 = 7           # /dev/meminfo
DEV_UPTIME:    int32 = 8           # /dev/uptime
DEV_LOADAVG:   int32 = 9           # /dev/loadavg
DEV_VERSION:   int32 = 10          # /dev/version
DEV_HOSTNAME:  int32 = 11          # /dev/hostname
DEV_STAT:      int32 = 12          # /dev/stat
DEV_MOUNTS:    int32 = 13          # /dev/mounts
DEV_DISKSTATS: int32 = 14          # /dev/diskstats
DEV_MOUNTRPC:  int32 = 15          # /dev/mountrpc — HAMSH §6/§18 tripwire
# /dev/urandom — same ChaCha20 pool as /dev/random (M16.96). v1 doesn't
# differentiate blocking vs non-blocking; both names route to the same
# devrandom_read/_write backend so userland callers that hard-code
# /dev/urandom (Python's os.urandom, glibc getrandom fallback path, ...)
# get the same kernel CSPRNG output.
DEV_URANDOM:   int32 = 16          # /dev/urandom (alias of /dev/random)
# hamUI Phase 2 file-tree (docs/hamUI.md H-§A). One slot per file in
# the per-window tree. The wid (1..MAX_WINDOWS-1) is carried in the
# inline chan id's high bits — see _chan_id_make_inline_wsys below.
# At dispatch time _devtab_read / _devtab_write peel the wid back out
# and call devwsys_*_read(wid, ...). DEV_WSYS itself (the active-list
# listing) is wid-less.
DEV_WSYS:          int32 = 17      # /dev/wsys             (active-windows list)
DEV_WSYS_TEXT:     int32 = 18      # /dev/wsys/<N>/text    (scrollback ring)
DEV_WSYS_OUTPUT:   int32 = 19      # /dev/wsys/<N>/output  (live cmd output)
DEV_WSYS_CMD:      int32 = 20      # /dev/wsys/<N>/cmd     (cmd injection sink)
DEV_WSYS_NS:       int32 = 21      # /dev/wsys/<N>/ns      (mtab dump)
DEV_WSYS_PID:      int32 = 22      # /dev/wsys/<N>/pid
DEV_WSYS_UID:      int32 = 23      # /dev/wsys/<N>/uid
DEV_WSYS_KIND:     int32 = 24      # /dev/wsys/<N>/kind    ("text\n")
DEV_WSYS_GEOMETRY: int32 = 25      # /dev/wsys/<N>/geometry ("0 0 80 24\n")
# hamUI Phase 4a layered-draw file surface (docs/hamUI.md H-§G). One
# slot per draw leaf. The wid is carried in the inline chan id bits
# 8..15 (as for the rest of the wsys family); for the per-layer leaves
# the LAYER SLOT (0..15) is carried in bits 16..23 — see
# _chan_id_make_inline_wsys_draw below. The layer is addressed by
# NAME in the path; _devtab_lookup_wsys resolves the name to a slot
# at open time via wsys_draw_resolve_layer.
DEV_WSYS_DRAW:          int32 = 26  # /dev/wsys/<N>/draw            (z-ordered listing)
DEV_WSYS_DRAW_CTL:      int32 = 27  # /dev/wsys/<N>/draw/ctl        (verb sink)
DEV_WSYS_DRAW_KIND:     int32 = 28  # /dev/wsys/<N>/draw/<L>/kind   (ro)
DEV_WSYS_DRAW_Z:        int32 = 29  # /dev/wsys/<N>/draw/<L>/z
DEV_WSYS_DRAW_OPACITY:  int32 = 30  # /dev/wsys/<N>/draw/<L>/opacity
DEV_WSYS_DRAW_GEOMETRY: int32 = 31  # /dev/wsys/<N>/draw/<L>/geometry
DEV_WSYS_DRAW_MARKUP:   int32 = 32  # /dev/wsys/<N>/draw/<L>/markup
DEV_WSYS_DRAW_FB:       int32 = 33  # /dev/wsys/<N>/draw/<L>/fb
# Native Plan-9 power-control cdev. Writing an ASCII verb
# ("poweroff" / "reboot" / "halt", with or without a trailing newline)
# triggers arch/x86/kernel/power.ad's shared power routine — the same
# core the Linux reboot(2)=169 syscall funnels through. This is the
# Plan-9-shape surface: power control is a file you write to.
DEV_REBOOT:    int32 = 34          # /dev/reboot
# hamUI Phase 4c: /dev/fb — the physical linear framebuffer as a cdev.
# Read -> "WIDTH HEIGHT PITCH BPP PIXFMT\n"; write RGBA8888 bytes to
# present one screen frame. Backed by drivers/video/fb_cdev.ad.
DEV_FB:        int32 = 35          # /dev/fb
DEV_MNT:       int32 = 36          # mounted 9P server (mountrpc)
# Virtual terminals: /dev/vt/1..4 (per-VT input/output) + /dev/vt/ctl.
DEV_VT1:       int32 = 37          # /dev/vt/1
DEV_VT2:       int32 = 38          # /dev/vt/2
DEV_VT3:       int32 = 39          # /dev/vt/3
DEV_VT4:       int32 = 40          # /dev/vt/4
DEV_VTCTL:     int32 = 41          # /dev/vt/ctl (chvt writes here)
# task #178: /dev/keymap — read the active keyboard layout name
# ("us"/"de"/"fr"), write a name to switch layouts. Backed by
# sys/src/9/port/devkeymap.ad, which drives drivers/input/atkbd.ad's
# selectable keymap. Same r/w introspection-knob shape as /dev/hostname.
DEV_KEYMAP:    int32 = 42          # /dev/keymap
# #174: /dev/nscap — read "mem <charged>/<cap> cpu <pct>\n" for the
# caller's namespace; write "mem <bytes>" / "cpu <pct>" to set the
# per-namespace memory + CPU caps. Backed by sys/src/9/port/devnscap.ad,
# which reads/writes the cap fields on the Plan-9 Pgrp (NOT a cgroup).
# Same r/w introspection-knob shape as /dev/hostname & /dev/keymap.
DEV_NSCAP:     int32 = 43          # /dev/nscap
# Native packet-filter firewall control file. Read lists the policy +
# rules (with per-rule hit counters) + a conntrack summary; write adds a
# rule, sets the default policy, or flushes. Backed by
# sys/src/9/port/devfirewall.ad over drivers/net/firewall.ad. Same
# r/w introspection-knob shape as /dev/hostname — the Plan-9 control
# surface, NOT a netfilter/iptables ioctl ABI.
DEV_FIREWALL:  int32 = 44          # /dev/firewall
# Native Intel HDA audio cdevs. /dev/audio takes raw PCM bytes on write
# (offset-addressed into the stream DMA buffer) and reports a status line
# on read; /dev/audioctl takes text control verbs. Backed by
# drivers/audio/audio_cdev.ad over the native HDA driver.
DEV_AUDIO:     int32 = 45          # /dev/audio
DEV_AUDIOCTL:  int32 = 46          # /dev/audioctl
# Native HDA PCM capture (record). /dev/audioin streams raw recorded PCM
# bytes pulled from the input-stream DMA ring; format/rate are shared with
# playback and set through /dev/audioctl. Read-only.
DEV_AUDIOIN:   int32 = 47          # /dev/audioin
# Synthetic stdio sinks. /dev/null discards writes and reads EOF;
# /dev/zero discards writes and reads back an endless run of NUL
# bytes. Both are stateless (no per-fd slot, no kmalloc) so they ride
# the inline-chan encoding exactly like the rest of this family. These
# used to be the hand-assigned FD_DEVNULL_MARK / FD_DEVZERO_MARK fds
# that vfs_open special-cased ahead of the namec probe; they are now
# regular devtab cdevs.
DEV_NULL:      int32 = 48          # /dev/null
DEV_ZERO:      int32 = 49          # /dev/zero
# fd→Chan unification: on-disk regular-file fds. UNLIKE the cdevs above
# these are POOL chans (the inline tag is CLEAR), exactly like DEV_MNT —
# each carries a per-open backing-table slot id in ChanT.back_slot:
#   * DEV_EXT4_FILE — back_slot is an ext4 open-file slot (ext4_open /
#     ext4_open_create_or_trunc). Read -> ext4_read_file(inum,...);
#     write -> ext4_write_open_file(slot,...); close -> ext4_close(slot).
#     One dev_type covers BOTH read and write opens — the ext4 slot table
#     is mode-agnostic (a slot is just an inum snapshot).
#   * DEV_FAT_FILE — back_slot is the RAW FAT fd_buf word: a read open-
#     file slot, OR (write-mode) the write-slot index with the
#     FAT_FD_WRITE_BIT (0x80000000) set. fat_close routes either flavour;
#     namec_read/namec_write peel the bit to pick the read vs write body.
# These replace the legacy FD_EXT4_MARK / FD_FAT_MARK per-task-array
# marks: the on-disk file fd is now a unified FD_CHAN_MARK fd whose
# release happens in namec_close, so a task that exits holding one no
# longer leaks its fs slot (the whole point of the fold).
DEV_EXT4_FILE: int32 = 50          # on-disk ext4 regular file (pool)
DEV_FAT_FILE:  int32 = 51          # on-disk FAT regular file (pool)
#   * DEV_TMPFS_FILE — back_slot is a tmpfs entry slot (named /tmp,/var
#     file OR an anonymous memfd via tmpfs_create_anon). Read ->
#     tmpfs_read(slot,...); write -> tmpfs_write(slot,...); close ->
#     (named) no slot free, (anon memfd: tmpfs_is_anon) tmpfs_release_anon.
#     One dev_type covers BOTH read and write opens — a tmpfs slot is
#     mode-agnostic. This replaces the legacy FD_TMPFS_MARK per-task-array
#     mark; memfd F_SEAL_* seal state lives on the slot, reached via the
#     chan's back_slot (fs/vfs.ad::vfs_fd_tmpfs_slot).
DEV_TMPFS_FILE: int32 = 52         # in-RAM tmpfs / memfd regular file (pool)
#   * DEV_DIR_FILE — a ptr-backed POOL chan for an opened-as-fd directory.
#     UNLIKE the file families above (which carry a small integer slot id
#     in back_slot), the DIR family carries the kmalloc'd "NAME\n" listing
#     buffer directly: back_ptr = buffer pointer, back_slot = buffer length
#     (a dir buffer is small — DIR_BUF_SIZE — so the length fits int32 and
#     overloads back_slot exactly the way the file families overload it).
#     Read -> _dirfile_read copies from back_ptr+off (getdents64 walks it
#     via the vfs_fd_dir_* accessors); there is NO write (dir fds are
#     read-only). Close -> kfree(back_ptr) on last ref. This replaces the
#     legacy FD_DIR_MARK per-task-array mark + its core.ad kfree: the dir
#     fd is now a unified FD_CHAN_MARK fd whose buffer is refcounted, so a
#     fork/dup'd dir fd shares ONE buffer and a task that exits holding a
#     dir fd no longer leaks it. The per-fd read CURSOR stays in the task
#     (fd_pos) — only the buffer pointer+length move into the Chan.
DEV_DIR_FILE:  int32 = 53          # opened-as-fd directory listing (pool, ptr-backed)

# hamUI Phase 4c (P0a): /dev/fbctl — the framebuffer console-takeover
# control file. A userland compositor (hamUId) writes "suspend\n" when it
# opens /dev/fb for exclusive presentation (silences the boot text console
# / printk so it cannot tear through the composited desktop) and
# "resume\n" on exit (repaints the saved console text). Reads return the
# current state line. Write-only verb file, same Plan-9 shape as
# /dev/audioctl. Backed by drivers/video/fb_cdev.ad's devfbctl_*.
DEV_FBCTL:     int32 = 54          # /dev/fbctl
# hamUI compositor hot-path: per-window mutation serial + dirty-rect
# damage interface (additive, backward-compatible). DEV_WSYS_SERIAL is
# a wid-tagged per-window leaf ("/dev/wsys/<N>/serial"); DEV_WSYS_DAMAGE
# is the wsys-level damage listing ("/dev/wsys/damage"). Both let the
# compositor cheaply skip re-reading windows that didn't change. See
# devwsys.ad "per-window damage / dirty tracking".
DEV_WSYS_SERIAL: int32 = 55        # /dev/wsys/<N>/serial  (per-window gen)
DEV_WSYS_DAMAGE: int32 = 56        # /dev/wsys/damage      (changed-wid list)
# hamUI input-event surface: per-window structured, routed pointer /
# key event streams. The compositor (user/hamUId.ad) is the sole writer
# (it has already done the hit-test / focus routing); a client GUI app
# reads BLOCKINGLY to receive events. See devwsys.ad "per-window
# structured INPUT EVENT rings".
DEV_WSYS_POINTER: int32 = 57       # /dev/wsys/<N>/pointer (routed ptr events)
DEV_WSYS_KEYS:    int32 = 58       # /dev/wsys/<N>/keys    (focused-win keys)
# /dev/wsys/self — a wid-less leaf returning the CALLING task's own wid
# as ASCII (or "0\n" if it owns none). A compositor-spawned GUI client
# (user/hamecho.ad) reads this to discover the wid the compositor
# allocated FOR it AFTER spawn (sys_wsys_alloc runs post-spawn, so the
# wid cannot be passed as argv at exec time). It then binds its draw
# layers + opens its /keys stream on the correct wid.
DEV_WSYS_SELF:    int32 = 59       # /dev/wsys/self  (caller's own wid)
# F2 #447 (drift syscall retirement): /dev/wsys/ctl — system-wide
# wsys-table control file. Verbs:
#   alloc <pid>      claim a wid for the bound shell pid; prints "<wid>\n"
#                    on read of the same fd after the write (mirrors the
#                    "open, write request, read result" /dev/auth idiom).
#   free <wid>       release a wid slot
#   frame <wid> <n>  render Vulkan frame n into the named window
# Replaces SYS_WSYS_ALLOC=293, SYS_WSYS_FREE=294, SYS_VK_WINDOW_FRAME=312.
# Hostowner-only (gate enforced in the devwsys write handler). Kept
# minimal so #442 wsys/rio reshape can extend without conflict.
DEV_WSYS_CTL:     int32 = 61       # /dev/wsys/ctl  (system-wide wsys ctl)
# hamshot: /dev/fbpix — the live framebuffer's RAW PIXEL CONTENTS as a
# finite read-only file. read(off, count) -> framebuffer bytes at byte
# offset `off` (hardware layout: fb_pitch per scanline, byte order per
# fb_pixfmt); size = pitch * height; EOF past the end. /dev/fb's
# geometry-line read is UNCHANGED — this is the additive pixel READ-BACK
# leaf the screenshot tool (user/hamshot.ad) streams. Backed by
# drivers/video/fb_cdev.ad's devfbpix_*.
DEV_FBPIX:        int32 = 61       # /dev/fbpix (raw pixel read-back)

# Read-only per-layer content GENERATION counter (decimal + '\n'):
# /dev/wsys/<N>/draw/<L>/gen — bumped by devwsys on every successful
# markup/fb content write, so a compositor can skip re-reading an
# unchanged body. Lives outside the contiguous 28..33 draw-leaf block
# (those numbers are frozen by existing chan ids), so the layer-leaf
# range gates below test it explicitly.
DEV_WSYS_DRAW_GEN: int32 = 60      # /dev/wsys/<N>/draw/<L>/gen (ro)

# Phase 4b (fd→Chan, stateful families):
#   * DEV_BUF_FILE — a ptr-backed POOL chan for a render-once snapshot
#     buffer (procfs / cgroup2 / NUMA-node sysfs interface files). The
#     opener renders the file's text into a kmalloc'd buffer and wraps
#     it here: back_ptr = buffer pointer, back_slot = rendered length —
#     EXACTLY the DEV_DIR_FILE shape (and it shares _dirfile_read /
#     the kfree-on-last-close release arm). Snapshot fds are READ-ONLY:
#     namec_write answers -EROFS, matching how Linux treats most /proc
#     entries. This replaces the legacy FD_BUFFER_MARK per-task-array
#     mark + its core.ad kfree: a fork/dup'd snapshot fd now shares ONE
#     refcounted buffer, and a task that exits holding one no longer
#     depends on a per-mark close arm — namec_close is the single
#     release path.
DEV_BUF_FILE:  int32 = 62          # procfs/cgroup snapshot buffer (pool, ptr-backed)

# Phase 4b: a per-pid /proc/<pid>/<leaf> fd (ex-FD_PROC_MARK_BASE
# encoded marker). POOL chan; back_slot carries the devproc encoding
# (pid << 8 | kind) in its low 24 bits — the render is stateless
# (devproc_read re-validates the pid and renders on every read), so the
# chan holds NO buffer and close releases nothing beyond the pool slot.
# Read/write dispatch by NAME to devproc_read/devproc_write (devproc.ad
# imports namec, so namec must not import it back — the same by-name
# pattern core.ad uses for namec_close).
DEV_PROC:      int32 = 63          # /proc/<pid>/<leaf> (pool, encoded back_slot)

# Phase 4b: a /dev/auth credential fd (ex-FD_AUTH_MARK). POOL chan;
# back_slot carries the devauth AuthSlot pool index (user/pass buffers,
# verification verdict, rate-limit timestamp all live in devauth.ad's
# auth_pool — the chan is just the refcounted handle). Read/write/close
# dispatch by NAME to devauth_read/devauth_write/devauth_close
# (devauth.ad imports fs.vfs which imports namec — importing devauth
# back here would cycle). Routing close through namec_close fixes the
# legacy leak where a task that EXITED holding an auth fd never ran
# vfs_close's FD_AUTH arm, stranding the AuthSlot (and its plaintext
# pass_buf) forever; close_fd_in_task's chan fall-through now reaches
# devauth_close on the last reference no matter how the fd dies.
DEV_AUTH:      int32 = 64          # /dev/auth credential fd (pool, slot-backed)

# Phase 4b: a /dev/blk/<name>{,/size,/ctl} block-device fd
# (ex-FD_BLK_MARK). POOL chan; the 64-bit devblk pack
# ((mode << 32) | slot — see devblk_pack) is wider than back_slot, so
# it rides in back_ptr. Read/write dispatch by NAME to devblk_read /
# devblk_write (devblk.ad sits below vfs in the import graph; by-name
# keeps namec import-free of it). Stateless at close — the pack is a
# cookie into kernel/block/blk.ad's global slot table, nothing to
# release.
DEV_BLK:       int32 = 65          # /dev/blk/<name> fd (pool, pack in back_ptr)

# Phase 4b: the /dev/loop/ctl loop-device control cdev (ex-
# FD_LOOP_MARK). INLINE chan — the ctl file carries no per-fd state
# beyond the read cursor, which the FD_CHAN_MARK fd's fd_pos already
# provides. Dispatch by NAME to loopctl_read / loopctl_write
# (drivers/block/loop.ad imports fs.vfs imports namec — cycle).
DEV_LOOPCTL:   int32 = 66          # /dev/loop/ctl (inline, stateless)

# Phase 4c: an `#d/<N>` fd-name fd (ex-FD_DEVFD_MARK). INLINE chan —
# the fd itself carries NO state beyond the fd-NUMBER N (encoded in the
# inline id's wid bits, 8..15): the BACKING channel is resolved per-I/O
# against the CALLING task's Pgrp devfd table, so a child that inherits
# the fd resolves /fd/N in ITS namespace, not the opener's. Close is
# the inline no-op — pipe-end refcounts are owned by the Pgrp row
# (devfd_bind_pipe_{r,w} bump, devfd_free_row releases), never by the
# fd. The pipe blocking loops live in devfd.ad
# (devfd_read_blocking/devfd_write_blocking) and namec's _devtab arms
# dispatch there with pgrp_current().
DEV_DEVFD:     int32 = 67          # /fd/N name fd (inline, wid = fd number)

# Phase 4c: an anonymous-pipe END (ex-FD_PIPE_MARK_R / FD_PIPE_MARK_W).
# POOL chans — back_slot carries the fs/pipe.ad pipe-table slot, and the
# chan's REFCOUNT is what fork/dup/spawn share (namec_chan_ref), so the
# pipe end-refcounts (readers/writers) are owned ONE-PER-CHAN: vfs_pipe
# allocates the pipe with readers=writers=1 and wraps each end in one
# chan; the LAST namec_close on a chan runs pipe_close_reader /
# pipe_close_writer. EOF/EPIPE semantics are unchanged — a forked read
# fd used to bump `readers` per fd-copy, now it bumps the chan refcount
# instead, and either way the reader count only hits 0 when every
# holder is gone. Blocking bodies live in fs/pipe.ad
# (pipe_read_blocking — two-phase WaitQueue sleep — and
# pipe_write_blocking — chunked drain + yield, EPIPE).
DEV_PIPE_R:    int32 = 68          # pipe read end (pool, slot-backed)
DEV_PIPE_W:    int32 = 69          # pipe write end (pool, slot-backed)
# Phase 4c (socket fold): a Linux-ABI socket fd (socket(2) /
# accept(2) / AF_UNIX / netlink) is an FD_CHAN_MARK fd backed by a
# DEV_SOCKET pool chan. back_slot carries the fd_buf ENCODING the
# legacy FD_SOCKET_MARK fd kept (all encodings fit in 31 bits):
#   0                       no record yet (created, never wired)
#   rec + 1                 fs/socket_state.ad record (AF_INET)
#   0x40000000 | ep + 1     AF_UNIX endpoint (u_unixsock.ad)
#   0x50000000 | ep + 1     netlink endpoint (u_netlink.ad)
# I/O + release dispatch BY NAME into fs/vfs.ad's
# vfs_socket_chan_read/_read_nb/_write/_release (vfs imports namec, so
# a direct import back would cycle). The decode stays in the existing
# usock_/afunix_/nl_ helpers — representation fold only.
# A socketpair endpoint is a DEV_SOCKETPAIR pool chan, one chan per
# END; back_slot carries fs/socketpair.ad's packed (slot << 1 | dir).
# The end-refcounts (refs_a/refs_b) are owned ONE-PER-CHAN exactly
# like the pipe fold: fork/dup bump the CHAN refcount and the LAST
# namec_close runs sockpair_close — fixing the legacy leak where
# task-exit cleanup (close_fd_in_task) never decremented sockpair
# refs and spawn-copies never incremented them.
DEV_SOCKET:    int32 = 70          # Linux-ABI socket (pool, fdbuf-backed)
DEV_SOCKETPAIR: int32 = 71         # socketpair end (pool, packed-backed)

# /dev/sync — write-anything-to-flush durability barrier. A userland
# file server that persists its own state through a namespace file
# (user/distrofs.ad's snapshot, post-SYS_DFS-removal) needs the same
# "data is on the platter" guarantee the old in-kernel save path got
# from blk_flush. Writing any byte string to /dev/sync runs
# ext4_fsync() (fs/ext4.ad — journal + block-cache flush barrier);
# reads return EOF. Called by NAME like the other ext4 entry points
# (namec must not import fs.ext4 — cycle; see the note above
# _resolve_named_root_rel).
DEV_SYNC:      int32 = 72          # /dev/sync (inline, stateless)

# /dev/9pmax — read-only high-water mark of simultaneously in-flight
# 9P T-messages (9p_client.ad's p9c_inflight_max), rendered "<n>\n" by
# devmountrpc.ad::dev9pmax_read. The tagged-concurrency gate's fixture
# reads it in-guest and asserts >= 2.
DEV_P9MAX:     int32 = 73

# DE primitives: /dev/snarf (global one-buffer clipboard) and
# /dev/wsys/<N>/wctl (per-window rio-shape control file — resize/move/
# focus verb sink + snapshot-once status read). See devsnarf.ad and
# devwsys.ad "DE primitive: /dev/wsys/<N>/wctl".
DEV_SNARF:     int32 = 74          # /dev/snarf  (global clipboard)
DEV_WSYS_WCTL: int32 = 75          # /dev/wsys/<N>/wctl  (per-window control)
# DE image-wallpaper status file. Snapshot read of "<gen> <path>\n";
# write happens through /dev/wsys/ctl `wallpaper <path>` verb.
DEV_WSYS_WALLPAPER: int32 = 76     # /dev/wsys/wallpaper (snapshot read)
# Phase 4d (net fold, F7 #390): a /net file-tree fd (an open of
# /net/<proto>/clone or /net/<proto>/<N>/<file>, plus the host-level
# /net/addr + /net/dns* leaves) is an FD_CHAN_MARK fd backed by a
# DEV_NET pool chan. back_slot carries the legacy fd_buf packing
# (file-kind: bits 7..0, proto: bits 15..8, conn: bits 31..16 — the
# 0xFFFF "no conn" sentinel still encodes -1) which fits in 32 bits.
# I/O + release dispatch BY NAME into fs/vfs.ad's vfs_net_chan_*
# (vfs imports namec; the reverse import would cycle). The
# devnet_conn_unref on last reference moves into namec_close's
# DEV_NET arm so a fork/dup-shared /net fd unrefs the conn ONCE,
# fixing the legacy model where copy_fd_entry never bumped the conn
# refcount and the first close FIN-tore the conn out from under the
# surviving dup.
DEV_NET:       int32 = 77          # /net file-tree fd (pool, pack-backed)

# Phase 4e (PTY fold, F7 #390): a /dev/ptmx or /dev/pts/<N> fd is an
# FD_CHAN_MARK fd backed by a DEV_PTMX pool chan. back_slot carries the
# legacy fd_buf packing (slot << 1) | is_master so one chan kind serves
# BOTH the master (bit0=1) and slave (bit0=0) ends — fits in 32 bits.
# I/O + release dispatch BY NAME into fs/vfs.ad's vfs_ptmx_chan_*
# helpers (vfs imports namec; the reverse import would cycle, same
# pattern as DEV_NET/DEV_SOCKET). The per-end pty_master_unref /
# pty_slave_unref call moves into namec_close's DEV_PTMX arm so a
# fork/dup-shared PTY fd unrefs its end ONCE on the LAST chan reference
# — fixing the legacy model where close_fd_in_task had a parallel arm
# (see fs/vfs.ad's pre-fold FD_PTMX_MARK close-arm) and a dup'd master
# could yank the pair while the dup was still live.
DEV_PTMX:      int32 = 78          # /dev/ptmx + /dev/pts/<N> (pool, pack-backed)

# Phase 4f (FUSE fold, F7 #390): a /dev/fuse connection fd is an
# FD_CHAN_MARK fd backed by a DEV_FUSE_CONN pool chan; a path opened
# under a FUSE-mounted target is an FD_CHAN_MARK fd backed by a
# DEV_FUSE_FILE pool chan. Both carry the legacy fd_buf word verbatim
# in back_slot — the conn-slot index for DEV_FUSE_CONN, the open-file
# token for DEV_FUSE_FILE — and dispatch their read/write/close BY
# NAME into fs/vfs.ad's vfs_fuse_conn_chan_* / vfs_fuse_file_chan_*
# helpers (vfs imports namec; the reverse import would cycle, same
# pattern as DEV_PTMX / DEV_NET / DEV_SOCKET). Routing release through
# namec_close means a task that exits holding a FUSE fd no longer
# leaks its conn slot / open-file token — the legacy FD_FUSE_*_MARK
# arms only ran from vfs_close, not from close_fd_in_task.
DEV_FUSE_CONN: int32 = 79          # /dev/fuse connection (pool, slot-backed)
DEV_FUSE_FILE: int32 = 80          # FUSE-served file (pool, token-backed)

# DE session-save/restore status file. Snapshot read of
# "<wid> <pid> <app> <x> <y> <w> <h>\n" per active wid; the write path
# is /dev/wsys/ctl `setapp <wid> <path>` which the compositor calls
# after each window spawn to register the program path.
DEV_WSYS_SESSION: int32 = 81       # /dev/wsys/session (snapshot read)

# #442 (c) rio blit protocol substrate.
#  /dev/wsys/<N>/bbstate      "<version> <frame_serial> <dx0> <dy0> <dx1> <dy1>\n"
#                             — compositor polls this to learn whether
#                             this window is in v2 (>=2) AND whether the
#                             backbuffer has a non-empty dirty rect.
#  /dev/wsys/<N>/backbuffer   raw RGBA8888 bytes (W*H*4) of the per-window
#                             v2 backbuffer (offset-addressed by row).
DEV_WSYS_BBSTATE:    int32 = 82
DEV_WSYS_BACKBUFFER: int32 = 83

# DE pivot wave 2 — Applications menu extracted to /bin/hamappmenu.
#  /dev/wsys/appmenu         snapshot of the cascading-menu catalogue
#                            (categories + entries). Written via the
#                            /dev/wsys/ctl `appmenu <payload>` verb.
#  /dev/wsys/appmenu/launch  read = "<serial> <path>\n" snapshot of the
#                            most-recent launch request; write enqueues a
#                            new launch (bumps serial). hamappmenu writes
#                            here on click; hamUId polls for the spawn.
DEV_WSYS_APPMENU:        int32 = 84
DEV_WSYS_APPMENU_LAUNCH: int32 = 85

# DE pivot wave 3 — Alt-Tab cycler extracted to /bin/hamcycler.
#  /dev/wsys/cycler         snapshot "<show_serial> <open> <sel> <gen>\n"
#                           followed by "W <wid> <title>\n" rows. Written
#                           via the /dev/wsys/ctl `cycler` verb.
#  /dev/wsys/cycler/show    read = "<show_serial>\n"; any write bumps the
#                           show serial (compositor pokes this to wake
#                           the client / signal "be visible now").
DEV_WSYS_CYCLER:      int32 = 86
DEV_WSYS_CYCLER_SHOW: int32 = 87

# DE pivot wave 4 — clock-drop calendar popup extracted to /bin/hamcalpop
# (distinct from /bin/hamclock, the standalone clock app).
#  /dev/wsys/calpop         snapshot
#    "<show_serial> <open> <year> <month> <day> <valid> <gen>\n"
#    Written via the /dev/wsys/ctl `calpop` verb.
#  /dev/wsys/calpop/show    read = "<show_serial>\n"; any write bumps the
#                           show serial (compositor pokes this to wake
#                           the client / signal "be visible now").
DEV_WSYS_CALPOP:      int32 = 88
DEV_WSYS_CALPOP_SHOW: int32 = 89

# DE pivot wave 4 — Run-Application (Alt-F2) dialog extracted to /bin/hamrun.
#  /dev/wsys/run         snapshot "<show_serial> <open> <gen> <text>\n".
#                        Written via the /dev/wsys/ctl `run <open> <text>` verb.
#  /dev/wsys/run/show    read = "<show_serial>\n"; any write bumps it (the
#                        compositor pokes this on every dialog mutation).
#  /dev/wsys/run/launch  read = "<serial> <path>\n" snapshot of the most-
#                        recent launch request; write enqueues a new launch
#                        (bumps serial). hamUId pumps the launch on Enter,
#                        the compositor's main loop drains the slot and
#                        spawns the program.
DEV_WSYS_RUN:         int32 = 90
DEV_WSYS_RUN_SHOW:    int32 = 91
DEV_WSYS_RUN_LAUNCH:  int32 = 92

# DE pivot wave 5 — screen-lock dialog extracted to /bin/hamlock.
#  /dev/wsys/lock         snapshot "<show_serial> <locked> <fails> <gen>\n".
#                         Written via the /dev/wsys/ctl `lock <locked> <fails>` verb.
#  /dev/wsys/lock/show    read = "<show_serial>\n"; any write bumps it (the
#                         compositor pokes this whenever the lock state mutates).
#  /dev/wsys/lock/verify  read = "<serial> <password>\n" snapshot of the most-
#                         recent password attempt; write enqueues a new attempt
#                         (bumps serial). hamUId polls this and runs the verify
#                         against the stored secret — on match the compositor
#                         clears LOCKED, on mismatch it beeps and bumps fails.
# DE pivot wave 7 — transient notification toast extracted to /bin/hamnotif.
#  /dev/wsys/notif         snapshot
#    "<show_serial> <active> <alpha> <gen> <title>\t<body>\n"
#    Written via the /dev/wsys/ctl `notif <active> <alpha> <title>\t<body>` verb.
#  /dev/wsys/notif/show    read = "<show_serial>\n"; any write bumps the show
#                          serial (compositor pokes this to wake the client /
#                          signal "the model just changed").
DEV_WSYS_NOTIF:       int32 = 93
DEV_WSYS_NOTIF_SHOW:  int32 = 94

DEV_WSYS_LOCK:        int32 = 95
DEV_WSYS_LOCK_SHOW:   int32 = 96
DEV_WSYS_LOCK_VERIFY: int32 = 97

# DE pivot wave 7 — rubber-band drag-to-create overlay extracted to
# /bin/hamrband.
#  /dev/wsys/rband      snapshot
#    "<set_serial> <active> <x0> <y0> <x1> <y1> <gen>\n"
#    Written via the /dev/wsys/ctl `rband <active> <x0> <y0> <x1> <y1>`
#    verb (hostowner-only).
#  /dev/wsys/rband/set  read = "<set_serial>\n"; any write bumps it (the
#                       compositor pokes this on every drag move so the
#                       client repaints the new band rect).
DEV_WSYS_RBAND:        int32 = 98
DEV_WSYS_RBAND_SET:    int32 = 99
# Power management ctl surfaces (suspend / resume).
#   DEV_POWERCTL        — native Plan-9-shape /dev/power/ctl. Writes
#                          carry a verb: "suspend mem"   → S3 (suspend-to-RAM)
#                                        "lid suspend"   → arm lid GPE -> S3
#                                        "lid disarm"    → disarm lid hook
#   DEV_SYS_POWER_STATE — Linux-ABI /sys/power/state mirror. A write of
#                          "mem" funnels into the same power_suspend_s3()
#                          core, so a stock Linux userland's
#                          `echo mem > /sys/power/state` lands on real S3.
DEV_POWERCTL:           int32 = 100
DEV_SYS_POWER_STATE:    int32 = 101

DEV_MAX:       int32 = 102

# The FAT write-mode bit as carried in a DEV_FAT_FILE chan's back_slot
# (a copy of fs/vfs.ad's FAT_FD_WRITE_BIT / fs/fat.ad's
# FAT_WRITE_SLOT_BIT). A back_slot with this bit set is a write-mode FAT
# fd; namec masks it off to recover the write-slot index.
FAT_CHAN_WRITE_BIT: int32 = -2147483648    # 0x80000000 as int32


# --- Chan: the universal handle -------------------------------------
#
# One struct for "a thing you opened". It deliberately does not record
# whether it is local or mounted as a flag the *consumer* reads — the
# consumer calls namec_read/write/close and those dispatch on dev_type
# internally. dev_type == DEV_MNT is the only place the local-vs-9P
# distinction is consulted, and that is inside this module.
#
# This is a SEPARATE struct from chan.ad's Chan (which is the
# mount-table-entry payload — kind/srvfd/flags/p9_root_fid, a fixed
# 16-byte shape that sysfile.ad's record-writer offsets depend on).
# Growing that struct would shift those offsets; ChanT is the richer
# Phase-D handle and lives entirely inside the namec layer.
class ChanT:
    in_use:    int32               # 0 = free pool slot, 1 = live
    dev_type:  int32               # DEV_* — the devtab key
    mode:      int32               # OREAD(0)/OWRITE(1)/ORDWR(2)
    srvfd:     int32               # DEV_MNT: the 9P transport fd; else -1
    p9_fid:    int32               # DEV_MNT: walked+opened fid; else -1
    # --- fd→Chan unification: generic stateful-fd payload ------------
    # The pool used to back ONLY DEV_MNT chans (srvfd/p9_fid above). The
    # fd→Chan migration routes every STATEFUL fd family through the SAME
    # pool, so a pool chan now carries a generic backing-resource handle
    # that each stateful dev_type interprets in its own way:
    #
    #   * back_slot  — a small integer slot id into the family's own
    #     backing table (a tmpfs slot, an ext4 open-file slot, a FAT
    #     slot, ...). The release arm in namec_close keys on dev_type to
    #     hand this back to the right backend.
    #   * back_ptr   — a 64-bit backing pointer (needed by FD_DIR's
    #     kmalloc'd listing buffer, and any future ptr-backed family).
    #     Unused families leave it 0.
    #
    # refcount makes the pool chan FORK/DUP-safe: copy_fd_entry bumps it,
    # namec_close decrements and only the LAST close runs the dev_type
    # release. DEV_MNT chans already needed this (a forked 9P fd today
    # shares the slot with NO refcount — second close double-clunks);
    # the generic field fixes that pre-existing hazard too.
    back_slot: int32               # family backing-table slot id; else -1
    refcount:  int32               # live references to this pool chan
    back_ptr:  uint64              # family backing pointer (FD_DIR); else 0
    # F10-6 followup: per-Chan "Dir-record mode" flag for DEV_DIR_FILE
    # chans. Default 0 = legacy NAME\n line-stream reads (unchanged for
    # every existing caller). When userspace flips this to 1 via
    # SYS_CHAN_DIR_MODE the next read returns Plan-9 Dir wire-format
    # records (lib/p9dir.ad) — _dirfile_read transforms the back_ptr
    # buffer in-place on the first Dir-mode read, swapping the NAME\n
    # listing for a Dir-record listing. The transform is one-way (the
    # NAME\n buffer is kfree'd) — flipping back to 0 is not supported.
    p9_dir_mode: int32             # 0 = NAME\n, 1 = Dir records
    pad0:      int32               # keep the struct shape padded


# --- chan id encoding -----------------------------------------------
#
# A "chan id" is the opaque token namec() returns and the fd layer
# stashes in fd_buf. It encodes one of two things, distinguished by
# the high CHAN_INLINE_TAG bit:
#
#   * INLINE chan (local cdev): a DEV_<kind> Chan carries NO mutable
#     state — every cdev read/write samples fresh and the cdev backend
#     is global. So an inline chan is just (CHAN_INLINE_TAG | dev_type)
#     — no pool slot, no allocation, no leak-on-exit. This exactly
#     mirrors the statelessness of the old FD_<NAME>_MARK fds, which
#     is why routing them through namec is non-regressing.
#
#   * POOL chan (DEV_MNT): a mounted-9P Chan carries srvfd / fid /
#     byte-offset, so it needs a real pool slot. The id is the slot
#     index (1..CHAN_POOL_CAP-1), with the inline tag CLEAR.
#
# namec_read / namec_write / namec_close decode the tag and route
# accordingly. The fd layer never inspects the encoding — it round-
# trips the id verbatim.
CHAN_INLINE_TAG: int32 = 0x40000000

# hamUI Phase 2: an inline chan id additionally encodes a wid in
# bits 8..15 (zero for non-wsys cdevs). dev_type lives in bits 0..7.
# This avoids growing DEV_* into 8 sets of 9 per-wid slots — instead
# the ONE per-leaf DEV_WSYS_* constant parametrises over wid via the
# chan id. _devtab_read / _devtab_write peel the wid out before
# dispatching into the devwsys_*_read(wid, ...) family.

def _chan_id_is_inline(cid: int32) -> int32:
    if (cid & CHAN_INLINE_TAG) != 0:
        return 1
    return 0


def _chan_id_inline_dev(cid: int32) -> int32:
    # Just the dev_type — wid lives in bits 8..15 and is extracted
    # separately via _chan_id_inline_wid.
    return cid & 0xFF


def _chan_id_inline_wid(cid: int32) -> int32:
    return (cid >> 8) & 0xFF


def _chan_id_inline_layer(cid: int32) -> int32:
    # hamUI Phase 4a: the draw layer slot lives in bits 16..23 for the
    # per-layer DEV_WSYS_DRAW_* leaves. Zero for everything else.
    return (cid >> 16) & 0xFF


def _chan_id_make_inline(dev_type: int32) -> int32:
    return CHAN_INLINE_TAG | dev_type


def _chan_id_make_inline_wsys(dev_type: int32, wid: int32) -> int32:
    # Wid-tagged inline chan id for the DEV_WSYS_* family.
    return CHAN_INLINE_TAG | (wid << 8) | dev_type


def _chan_id_make_inline_wsys_draw(dev_type: int32, wid: int32,
                                   layer: int32) -> int32:
    # Wid+layer-tagged inline chan id for the per-layer
    # DEV_WSYS_DRAW_* leaves. dev_type in bits 0..7, wid in 8..15,
    # layer slot in 16..23. The draw listing + ctl carry layer=0
    # (unused) and use _chan_id_make_inline_wsys instead.
    return CHAN_INLINE_TAG | (layer << 16) | (wid << 8) | dev_type


def namec_chan_id_devfd(fdnum: int32) -> int32:
    # Phase 4c: the inline chan id for an `#d/<N>` fd-name fd. The fd
    # NUMBER rides in the wid bits (8..15) the same way a wsys window
    # id does — DEVFD_SLOTS is 16, comfortably inside the 8-bit field.
    # Stateless: no pool slot, no allocation, close is the inline no-op.
    return CHAN_INLINE_TAG | ((fdnum & 0xFF) << 8) | DEV_DEVFD


def namec_chan_devfd_num(cid: int32) -> int32:
    # Recover the /fd/<N> fd number from a DEV_DEVFD inline chan id.
    # -1 if the id is not a devfd chan.
    if _chan_id_is_inline(cid) == 0:
        return -1
    if _chan_id_inline_dev(cid) != DEV_DEVFD:
        return -1
    return _chan_id_inline_wid(cid)


# --- chan pool (all STATEFUL fd families) ---------------------------
#
# Fixed pool. It used to back ONLY DEV_MNT mounted-9P Chans (64 was
# ample for the boot recipe + a few distro shells). The fd→Chan
# migration routes every STATEFUL fd family through this SAME pool, so
# the cap is now sized against the fd-layer worst case, not the mount
# count.
#
# SIZING: a pool chan is allocated per DISTINCT stateful open (fork/dup
# SHARE a chan via refcount — they do NOT allocate). The absolute upper
# bound is therefore NR_FDS (64) × live tasks (task_table is 64) = 4096
# distinct stateful fds across the whole system at once. 8192 = 2× that
# worst case, comfortable headroom, and the struct is tiny (a handful
# of int32s + one uint64), so the BSS cost is still modest. A fixed pool
# also dodges Adder's nested-frame Array bug (top-level storage only).
# Slot 0 is never handed out so a zero chan-id means "no chan" at the
# fd layer. Inline cdev chans never touch the pool.
CHAN_POOL_CAP: uint64 = 8192

chan_pool: Array[8192, ChanT]
chan_pool_inited: int32 = 0


def namec_init():
    # Idempotent. BSS-zeroes the pool already; this just stamps the
    # in_use/dev_type bytes explicitly so a warm path sees a clean
    # table, and flips the lazy-init guard.
    i: uint64 = 0
    while i < CHAN_POOL_CAP:
        chan_pool[i].in_use    = 0
        chan_pool[i].dev_type  = DEV_NONE
        chan_pool[i].srvfd     = -1
        chan_pool[i].p9_fid    = -1
        chan_pool[i].back_slot = -1
        chan_pool[i].refcount  = 0
        chan_pool[i].back_ptr  = 0
        i = i + 1
    chan_pool_inited = 1


def _chan_alloc() -> int32:
    # Hand out the lowest free pool slot (1..CHAN_POOL_CAP-1; slot 0 is
    # reserved as the "no chan" sentinel). Returns the slot index, or
    # -1 if the pool is exhausted. The slot starts with refcount 1 (the
    # one fd that namec is handing it back to) and a cleared backing
    # payload; the caller stamps dev_type / back_slot / back_ptr.
    if chan_pool_inited == 0:
        namec_init()
    s: uint64 = 1
    while s < CHAN_POOL_CAP:
        if chan_pool[s].in_use == 0:
            chan_pool[s].refcount    = 1
            chan_pool[s].back_slot   = -1
            chan_pool[s].back_ptr    = 0
            chan_pool[s].p9_dir_mode = 0
            return cast[int32](s)
        s = s + 1
    return -1


def _chan_free(slot: int32):
    if slot <= 0:
        return
    su: uint64 = cast[uint64](slot)
    if su >= CHAN_POOL_CAP:
        return
    chan_pool[su].in_use      = 0
    chan_pool[su].dev_type    = DEV_NONE
    chan_pool[su].srvfd       = -1
    chan_pool[su].p9_fid      = -1
    chan_pool[su].back_slot   = -1
    chan_pool[su].refcount    = 0
    chan_pool[su].back_ptr    = 0
    chan_pool[su].p9_dir_mode = 0


def _chan_pool_valid(slot: int32) -> int32:
    # 1 iff `slot` names a live pool entry (DEV_MNT chans only).
    if slot <= 0:
        return 0
    su: uint64 = cast[uint64](slot)
    if su >= CHAN_POOL_CAP:
        return 0
    if chan_pool[su].in_use == 0:
        return 0
    return 1


def _chan_id_valid(cid: int32) -> int32:
    # 1 iff `cid` is a usable chan id — either an inline cdev id with a
    # known DEV_<kind>, or a live pool slot.
    # NOTE: DEV_MNT (36) is NOT an inline cdev — it is the sentinel for
    # pool-backed mounted-9P chans. Inline cdevs span DEV_NONE+1..DEV_MNT-1
    # (the original devtab) PLUS DEV_MNT+1..DEV_MAX-1 (the VT family and
    # any future additions above DEV_MNT). DEV_MNT itself is excluded —
    # so are DEV_EXT4_FILE / DEV_FAT_FILE / DEV_TMPFS_FILE, which (like
    # DEV_MNT) are POOL-only dev_types: an inline-tagged id never
    # legitimately carries them.
    if _chan_id_is_inline(cid) != 0:
        dt: int32 = _chan_id_inline_dev(cid)
        if dt > DEV_NONE and dt < DEV_MAX and dt != DEV_MNT \
                and dt != DEV_EXT4_FILE and dt != DEV_FAT_FILE \
                and dt != DEV_TMPFS_FILE and dt != DEV_DIR_FILE \
                and dt != DEV_BUF_FILE and dt != DEV_PROC \
                and dt != DEV_AUTH and dt != DEV_BLK \
                and dt != DEV_PIPE_R and dt != DEV_PIPE_W \
                and dt != DEV_SOCKET and dt != DEV_SOCKETPAIR \
                and dt != DEV_NET and dt != DEV_PTMX \
                and dt != DEV_FUSE_CONN and dt != DEV_FUSE_FILE:
            return 1
        return 0
    return _chan_pool_valid(cid)


# --- path helpers ---------------------------------------------------

def _streq(a: Ptr[char], b: Ptr[char]) -> int32:
    # NUL-terminated string equality. 1 on match, 0 otherwise.
    i: uint64 = 0
    while True:
        ca: char = a[i]
        cb: char = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1


# --- devtab: path -> local device type ------------------------------
#
# The "name table" half of a Plan 9 devtab. Maps a well-known device
# path to its DEV_* index. A miss returns DEV_NONE — namec then probes
# the 9P mount table, and failing that reports "not a chan" so the VFS
# caller falls through to its on-disk routing.
#
# F10-1 (#454): paths are matched in the Plan 9 `#c/<leaf>` server-letter
# spelling ONLY. The legacy `/dev/<leaf>` literal table that lived here
# was a parallel resolution path — it bypassed the per-Pgrp mount table
# entirely, so an RFCNAMEG child with NO `bind '#c' /dev` could still
# open("/dev/null") via the strcmp arm (the F1 audit's keystone finding).
# The fix collapses the parallel: vfs_open's _vfs_open_post_perm now
# runs resolve_path() at the top, so a userland open of /dev/null in a
# Pgrp that DOES have `#c` bound to `/dev` arrives here already rewritten
# to `#c/null`; a Pgrp WITHOUT that bind hits ENOENT in resolve_path and
# never reaches namec. Kernel-context callers that want a stateless cdev
# pass the `#c/<leaf>` spelling directly (see drivers/audio/* selftests).

def _devtab_lookup(path: Ptr[char]) -> int32:
    if _streq(path, "#c/null") != 0:
        return DEV_NULL
    if _streq(path, "#c/zero") != 0:
        return DEV_ZERO
    if _streq(path, "#c/cons") != 0:
        return DEV_CONS
    if _streq(path, "#c/time") != 0:
        return DEV_TIME
    if _streq(path, "#c/pid") != 0:
        return DEV_PID
    if _streq(path, "#c/random") != 0:
        return DEV_RANDOM
    if _streq(path, "#c/urandom") != 0:
        # Same pool as /dev/random — v1 doesn't differentiate blocking
        # vs non-blocking. The chan id is its own DEV_URANDOM kind so
        # introspection (namec_chan_dev_type) reports the path the
        # caller actually opened.
        return DEV_URANDOM
    if _streq(path, "#c/mouse") != 0:
        return DEV_MOUSE
    if _streq(path, "#c/cpuinfo") != 0:
        return DEV_CPUINFO
    if _streq(path, "#c/meminfo") != 0:
        return DEV_MEMINFO
    if _streq(path, "#c/uptime") != 0:
        return DEV_UPTIME
    if _streq(path, "#c/loadavg") != 0:
        return DEV_LOADAVG
    if _streq(path, "#c/version") != 0:
        return DEV_VERSION
    if _streq(path, "#c/hostname") != 0:
        return DEV_HOSTNAME
    if _streq(path, "#c/stat") != 0:
        return DEV_STAT
    if _streq(path, "#c/mounts") != 0:
        return DEV_MOUNTS
    if _streq(path, "#c/diskstats") != 0:
        return DEV_DISKSTATS
    if _streq(path, "#c/mountrpc") != 0:
        return DEV_MOUNTRPC
    if _streq(path, "#c/reboot") != 0:
        return DEV_REBOOT
    # Power management surfaces. Native Plan-9-shape ctl file
    # (`/dev/power/ctl` post-bind, `#c/power/ctl` raw) takes the verb
    # set documented at DEV_POWERCTL. The Linux-ABI `/sys/power/state`
    # is matched LITERALLY here (no `#c/` rewrite, no per-Pgrp bind
    # required — same shape any stock Linux userland expects). Both
    # funnel into arch/x86/kernel/power.ad::power_suspend_s3().
    if _streq(path, "#c/power/ctl") != 0:
        return DEV_POWERCTL
    if _streq(path, "/sys/power/state") != 0:
        return DEV_SYS_POWER_STATE
    if _streq(path, "#c/sys/power/state") != 0:
        return DEV_SYS_POWER_STATE
    if _streq(path, "#c/sync") != 0:
        return DEV_SYNC
    # DE primitive: #c/snarf — global one-buffer clipboard cdev.
    if _streq(path, "#c/snarf") != 0:
        return DEV_SNARF
    if _streq(path, "#c/9pmax") != 0:
        return DEV_P9MAX
    if _streq(path, "#c/fb") != 0:
        return DEV_FB
    if _streq(path, "#c/fbctl") != 0:
        return DEV_FBCTL
    if _streq(path, "#c/fbpix") != 0:
        return DEV_FBPIX
    # Virtual terminals: #c/vt/1..4 and #c/vt/ctl (post-bind: /dev/vt/N).
    if _streq(path, "#c/vt/1") != 0:
        return DEV_VT1
    if _streq(path, "#c/vt/2") != 0:
        return DEV_VT2
    if _streq(path, "#c/vt/3") != 0:
        return DEV_VT3
    if _streq(path, "#c/vt/4") != 0:
        return DEV_VT4
    if _streq(path, "#c/vt/ctl") != 0:
        return DEV_VTCTL
    # Phase 4b: #c/loop/ctl — loop-device attach/detach/list control
    # file (ex-FD_LOOP_MARK; the vfs literal-leaf arm is gone, this
    # devtab entry is the only way in).
    if _streq(path, "#c/loop/ctl") != 0:
        return DEV_LOOPCTL
    # task #178: #c/keymap — keyboard-layout selector cdev.
    if _streq(path, "#c/keymap") != 0:
        return DEV_KEYMAP
    # #174: #c/nscap — per-namespace resource-cap control cdev.
    if _streq(path, "#c/nscap") != 0:
        return DEV_NSCAP
    # Native firewall control file.
    if _streq(path, "#c/firewall") != 0:
        return DEV_FIREWALL
    # Native HDA audio: PCM sink + text control file.
    if _streq(path, "#c/audio") != 0:
        return DEV_AUDIO
    if _streq(path, "#c/audioctl") != 0:
        return DEV_AUDIOCTL
    # Native HDA capture: recorded-PCM source file.
    if _streq(path, "#c/audioin") != 0:
        return DEV_AUDIOIN
    # hamUI Phase 2: #c/wsys tree. _devtab_lookup_wsys does the
    # wid-aware parsing — see below. A non-wsys path returns DEV_NONE.
    if _streq(path, "#c/wsys") != 0:
        return DEV_WSYS
    return DEV_NONE


def _wsys_parse_wid(path: Ptr[char], pos: uint64,
                    wid_out: Ptr[int32]) -> uint64:
    # Parse decimal digits starting at path[pos]. Sets *wid_out and
    # returns the position of the first non-digit (typically '/' or
    # NUL). On no-digits, returns pos unchanged and *wid_out = -1.
    n: int32 = 0
    p: uint64 = pos
    any_digit: int32 = 0
    while True:
        c: char = path[p]
        if c < 48 or c > 57:
            break
        any_digit = 1
        n = n * 10 + cast[int32](c) - 48
        p = p + 1
    if any_digit == 0:
        wid_out[0] = -1
        return pos
    wid_out[0] = n
    return p


def _streq_at(path: Ptr[char], pos: uint64, suffix: Ptr[char]) -> int32:
    # 1 iff path[pos..] == suffix (NUL-terminated equality).
    i: uint64 = 0
    while True:
        a: char = path[pos + i]
        b: char = suffix[i]
        if a != b:
            return 0
        if a == 0:
            return 1
        i = i + 1


def _starts_with(path: Ptr[char], prefix: Ptr[char]) -> int32:
    # 1 iff `path` begins with `prefix` (suffix NUL terminates the
    # match — path may be longer). Used for the "/dev/wsys/" prefix
    # check; _streq_at requires full equality and would reject any
    # path with characters past the prefix.
    i: uint64 = 0
    while True:
        b: char = prefix[i]
        if b == 0:
            return 1
        a: char = path[i]
        if a != b:
            return 0
        i = i + 1


def _devtab_lookup_wsys(path: Ptr[char], wid_out: Ptr[int32],
                        layer_out: Ptr[int32]) -> int32:
    # Parse `#c/wsys/<N>[/<leaf>]`. Returns the matching DEV_WSYS_*
    # constant on success with *wid_out set, or DEV_NONE on miss
    # (path is not in the wsys tree, wid is 0, wid is out of range,
    # or wid is unused).
    #
    # *layer_out is set to the resolved draw-layer slot for the
    # per-layer DEV_WSYS_DRAW_* leaves, else 0.
    #
    # The caller already handled the bare `#c/wsys` path (returns
    # DEV_WSYS via _devtab_lookup). Here we only get called for paths
    # under `#c/wsys/`.
    #
    # F10-1 (#454): the prefix is the `#c/` server-letter spelling. The
    # legacy `/dev/wsys/` literal-prefix match was a parallel resolution
    # path that bypassed the per-Pgrp mount table — see _devtab_lookup's
    # header. After F10-1, vfs_open's resolve_path rewrites userland's
    # /dev/wsys/<...> to `#c/wsys/<...>` (assuming `bind '#c' /dev` is in
    # the calling Pgrp); a Pgrp without that bind ENOENTs in resolve_path
    # and never reaches namec.
    layer_out[0] = 0
    if _starts_with(path, "#c/wsys/") == 0:
        return DEV_NONE
    # wsys-level (wid-less) leaf: #c/wsys/damage. Matched before wid
    # parsing since "damage" has no leading digit. wid_out stays 0.
    if _streq_at(path, 8, "damage") != 0:
        wid_out[0] = 0
        return DEV_WSYS_DAMAGE
    # wsys-level (wid-less) leaf: #c/wsys/self -> the caller's own wid.
    if _streq_at(path, 8, "self") != 0:
        wid_out[0] = 0
        return DEV_WSYS_SELF
    # F2 #447 wsys-level wid-less ctl: #c/wsys/ctl — system-wide wsys
    # control (replaces SYS_WSYS_ALLOC/FREE/VK_WINDOW_FRAME). Verb
    # parsing + the hostowner gate live in devwsys.ad's
    # devwsys_ctl_write. Reading the same fd after a successful "alloc"
    # write yields the assigned wid as ASCII decimal + '\n'.
    if _streq_at(path, 8, "ctl") != 0:
        wid_out[0] = 0
        return DEV_WSYS_CTL
    # DE image-wallpaper readback file: #c/wsys/wallpaper. Read snapshot
    # "<gen> <path>\n"; the write path is the existing /dev/wsys/ctl
    # `wallpaper <path>` verb.
    if _streq_at(path, 8, "wallpaper") != 0:
        wid_out[0] = 0
        return DEV_WSYS_WALLPAPER
    # DE session-save/restore snapshot file: #c/wsys/session. One line
    # per active wid; the userland helper /bin/hamsession reads this.
    if _streq_at(path, 8, "session") != 0:
        wid_out[0] = 0
        return DEV_WSYS_SESSION
    # DE pivot wave 2: Applications-menu catalogue snapshot + launch slot.
    # `/dev/wsys/appmenu/launch` matched FIRST so the prefix-match for
    # `appmenu` doesn't swallow the more-specific path.
    if _streq_at(path, 8, "appmenu/launch") != 0:
        wid_out[0] = 0
        return DEV_WSYS_APPMENU_LAUNCH
    if _streq_at(path, 8, "appmenu") != 0:
        wid_out[0] = 0
        return DEV_WSYS_APPMENU
    # DE pivot wave 3: Alt-Tab cycler model snapshot + show poke. As with
    # appmenu, the more-specific "/show" suffix is matched FIRST so the
    # bare "cycler" doesn't swallow it.
    if _streq_at(path, 8, "cycler/show") != 0:
        wid_out[0] = 0
        return DEV_WSYS_CYCLER_SHOW
    if _streq_at(path, 8, "cycler") != 0:
        wid_out[0] = 0
        return DEV_WSYS_CYCLER
    # DE pivot wave 4: calendar popup model snapshot + show poke. Same
    # match-most-specific-first dance as appmenu/cycler.
    if _streq_at(path, 8, "calpop/show") != 0:
        wid_out[0] = 0
        return DEV_WSYS_CALPOP_SHOW
    if _streq_at(path, 8, "calpop") != 0:
        wid_out[0] = 0
        return DEV_WSYS_CALPOP
    # DE pivot wave 4: Run-dialog model + show poke + launch slot. As
    # with appmenu/cycler, the more-specific suffixes are matched FIRST
    # so the bare "run" doesn't swallow them.
    if _streq_at(path, 8, "run/show") != 0:
        wid_out[0] = 0
        return DEV_WSYS_RUN_SHOW
    if _streq_at(path, 8, "run/launch") != 0:
        wid_out[0] = 0
        return DEV_WSYS_RUN_LAUNCH
    if _streq_at(path, 8, "run") != 0:
        wid_out[0] = 0
        return DEV_WSYS_RUN
    # DE pivot wave 7: notification toast model + show poke. As with
    # appmenu/cycler/calpop, the more-specific "/show" suffix is matched
    # FIRST so the bare "notif" doesn't swallow it.
    if _streq_at(path, 8, "notif/show") != 0:
        wid_out[0] = 0
        return DEV_WSYS_NOTIF_SHOW
    if _streq_at(path, 8, "notif") != 0:
        wid_out[0] = 0
        return DEV_WSYS_NOTIF
    # DE pivot wave 5: screen-lock model + show poke + verify slot. As
    # with run, the more-specific suffixes are matched FIRST so the bare
    # "lock" doesn't swallow them.
    if _streq_at(path, 8, "lock/show") != 0:
        wid_out[0] = 0
        return DEV_WSYS_LOCK_SHOW
    if _streq_at(path, 8, "lock/verify") != 0:
        wid_out[0] = 0
        return DEV_WSYS_LOCK_VERIFY
    if _streq_at(path, 8, "lock") != 0:
        wid_out[0] = 0
        return DEV_WSYS_LOCK
    # DE pivot wave 7: rubber-band overlay model + set poke. More-
    # specific "rband/set" matched FIRST so the bare "rband" doesn't
    # swallow it.
    if _streq_at(path, 8, "rband/set") != 0:
        wid_out[0] = 0
        return DEV_WSYS_RBAND_SET
    if _streq_at(path, 8, "rband") != 0:
        wid_out[0] = 0
        return DEV_WSYS_RBAND
    pos: uint64 = 8                            # past "#c/wsys/"
    w: int32 = -1
    pos = _wsys_parse_wid(path, pos, &w)
    if w < 0:
        return DEV_NONE
    # Reject wid 0 (spec: wids are 1-indexed) and out-of-range wids.
    if w == 0:
        return DEV_NONE
    if cast[uint64](w) >= MAX_WINDOWS:
        return DEV_NONE
    # Gate by liveness — an unused wid returns ENOENT (caller treats
    # DEV_NONE as fallthrough; we want ENOENT). The dispatch path
    # below special-cases this via wsys_wid_in_use checks too, but
    # surfacing it here means namec() returns NAMEC_ENOENT cleanly.
    if wsys_wid_in_use(w) == 0:
        return DEV_NONE
    wid_out[0] = w
    # Suffix dispatch.
    if path[pos] == 0:
        # Bare `/dev/wsys/<N>` — return listing (Phase 1 behaviour).
        return DEV_WSYS
    if _streq_at(path, pos, "/text") != 0:
        return DEV_WSYS_TEXT
    if _streq_at(path, pos, "/output") != 0:
        return DEV_WSYS_OUTPUT
    if _streq_at(path, pos, "/cmd") != 0:
        return DEV_WSYS_CMD
    if _streq_at(path, pos, "/ns") != 0:
        return DEV_WSYS_NS
    if _streq_at(path, pos, "/pid") != 0:
        return DEV_WSYS_PID
    if _streq_at(path, pos, "/uid") != 0:
        return DEV_WSYS_UID
    if _streq_at(path, pos, "/kind") != 0:
        return DEV_WSYS_KIND
    if _streq_at(path, pos, "/geometry") != 0:
        return DEV_WSYS_GEOMETRY
    # hamUI compositor hot-path: per-window mutation serial.
    if _streq_at(path, pos, "/serial") != 0:
        return DEV_WSYS_SERIAL
    # DE primitive: per-window rio-shape control file.
    if _streq_at(path, pos, "/wctl") != 0:
        return DEV_WSYS_WCTL
    # hamUI input-event surface: routed pointer + focused-window key
    # event streams (compositor writes, client reads blockingly).
    if _streq_at(path, pos, "/pointer") != 0:
        return DEV_WSYS_POINTER
    if _streq_at(path, pos, "/keys") != 0:
        return DEV_WSYS_KEYS
    # #442 (c) rio blit protocol substrate — v2 state + backbuffer.
    if _streq_at(path, pos, "/bbstate") != 0:
        return DEV_WSYS_BBSTATE
    if _streq_at(path, pos, "/backbuffer") != 0:
        return DEV_WSYS_BACKBUFFER
    # hamUI Phase 4a — the /draw subtree (docs/hamUI.md H-§G).
    if _starts_with_at(path, pos, "/draw") != 0:
        return _devtab_lookup_wsys_draw(path, pos + 5, w, layer_out)
    return DEV_NONE


def _starts_with_at(path: Ptr[char], pos: uint64,
                    prefix: Ptr[char]) -> int32:
    # 1 iff path[pos..] begins with `prefix` (path may continue past).
    i: uint64 = 0
    while True:
        b: char = prefix[i]
        if b == 0:
            return 1
        a: char = path[pos + i]
        if a != b:
            return 0
        i = i + 1


def _devtab_lookup_wsys_draw(path: Ptr[char], pos: uint64, wid: int32,
                             layer_out: Ptr[int32]) -> int32:
    # `pos` points just past ".../draw". Resolve:
    #   ""            -> DEV_WSYS_DRAW       (z-ordered listing)
    #   "/ctl"        -> DEV_WSYS_DRAW_CTL
    #   "/<layer>/<leaf>" -> DEV_WSYS_DRAW_<LEAF> with *layer_out set.
    if path[pos] == 0:
        return DEV_WSYS_DRAW
    if _streq_at(path, pos, "/ctl") != 0:
        return DEV_WSYS_DRAW_CTL
    if path[pos] != 47:                          # must be '/'
        return DEV_NONE
    # Layer name runs from pos+1 to the next '/'.
    name_start: uint64 = pos + 1
    name_end: uint64 = name_start
    while True:
        c: char = path[name_end]
        if c == 0 or c == 47:
            break
        name_end = name_end + 1
    namelen: uint64 = name_end - name_start
    if namelen == 0:
        return DEV_NONE
    # A bare "/draw/<layer>" with no leaf is not addressable as a file
    # (it is a directory) — require a trailing leaf.
    if path[name_end] != 47:
        return DEV_NONE
    # Resolve the layer name to a slot in the per-window layer table.
    slot: int32 = wsys_draw_resolve_layer(
        wid, cast[Ptr[uint8]](cast[uint64](path) + name_start), namelen)
    if slot < 0:
        return DEV_NONE                          # no such layer -> ENOENT
    layer_out[0] = slot
    leaf: uint64 = name_end                       # points at the '/'
    if _streq_at(path, leaf, "/kind") != 0:
        return DEV_WSYS_DRAW_KIND
    if _streq_at(path, leaf, "/z") != 0:
        return DEV_WSYS_DRAW_Z
    if _streq_at(path, leaf, "/opacity") != 0:
        return DEV_WSYS_DRAW_OPACITY
    if _streq_at(path, leaf, "/geometry") != 0:
        return DEV_WSYS_DRAW_GEOMETRY
    if _streq_at(path, leaf, "/markup") != 0:
        return DEV_WSYS_DRAW_MARKUP
    if _streq_at(path, leaf, "/fb") != 0:
        return DEV_WSYS_DRAW_FB
    if _streq_at(path, leaf, "/gen") != 0:
        return DEV_WSYS_DRAW_GEN
    return DEV_NONE


# --- devtab op dispatch ---------------------------------------------
#
# The "operation table" half of a Plan 9 devtab. _devtab_read /
# _devtab_write switch on dev_type and call the matching cdev backend.
# A real Plan 9 devtab is an array of structs of function pointers;
# we use an integer switch (see the ADDER QUIRKS note in the header).
# Either shape is "index a table by device kind" — the semantics are
# identical, and the switch is unambiguous to the Adder codegen.

def _devtab_read(dev_type: int32, wid: int32, layer: int32, off: uint64,
                 buf: Ptr[uint8], count: uint64) -> int64:
    # `off` is the read cursor. Most cdevs are stateless snapshot
    # devices and ignore it (every read regenerates) — but a device
    # like /dev/mountrpc that a `cat` walks to EOF must honour it, or
    # the regenerate-forever behaviour wedges the reader in a loop.
    if dev_type == DEV_MOUNTRPC:
        # Snapshot-once: the blob is delivered on the off==0 read and
        # the next read (off>0) reports EOF, so `cat /dev/mountrpc`
        # terminates exactly like reading a finite file.
        if off > 0:
            return 0
        return devmountrpc_read(buf, count)
    if dev_type == DEV_P9MAX:
        # Snapshot-once "<n>\n" — the in-flight T-msg high-water mark.
        # Same EOF discipline as /dev/mountrpc above.
        if off > 0:
            return 0
        return dev9pmax_read(buf, count)
    if dev_type == DEV_LOOPCTL:
        # Phase 4b: /dev/loop/ctl read — render the attached-loop table.
        # loopctl_read honours the off cursor itself (EOF on the second
        # read so `cat /dev/loop/ctl` terminates). By-name call: loop.ad
        # imports fs.vfs imports namec.
        return loopctl_read(off, buf, count)
    if dev_type == DEV_DEVFD:
        # Phase 4c: `#d/<N>` fd-name fd. The fd number rides in the
        # inline id's wid bits; resolve the name /fd/<N> through the
        # CALLING task's Pgrp devfd table at read time. Blocking: a
        # pipe-R backing sleeps on the pipe's read wait queue (two-phase
        # prepare/recheck/commit — the exact loop the legacy
        # FD_DEVFD_MARK vfs_read arm carried, now in devfd.ad).
        return devfd_read_blocking(pgrp_current(), wid, buf, count)
    if dev_type == DEV_NULL:
        # /dev/null reads always return EOF.
        return 0
    if dev_type == DEV_ZERO:
        # /dev/zero hands back `count` zero bytes per request.
        z: uint64 = 0
        while z < count:
            buf[z] = 0
            z = z + 1
        return cast[int64](count)
    if dev_type == DEV_CONS:
        return devcons_read(buf, count)
    if dev_type == DEV_TIME:
        return devtime_read(buf, count)
    if dev_type == DEV_PID:
        return devpid_read(buf, count)
    if dev_type == DEV_RANDOM:
        return devrandom_read(buf, count)
    if dev_type == DEV_URANDOM:
        # Same backend as /dev/random — see DEV_URANDOM comment.
        return devrandom_read(buf, count)
    if dev_type == DEV_MOUSE:
        return devmouse_read(buf, count)
    if dev_type == DEV_CPUINFO:
        return devcpuinfo_read(buf, count)
    if dev_type == DEV_MEMINFO:
        return devmeminfo_read(buf, count)
    if dev_type == DEV_UPTIME:
        return devuptime_read(buf, count)
    if dev_type == DEV_LOADAVG:
        return devloadavg_read(buf, count)
    if dev_type == DEV_VERSION:
        return devversion_read(buf, count)
    if dev_type == DEV_HOSTNAME:
        return devhostname_read(buf, count)
    if dev_type == DEV_SNARF:
        # DE primitive: /dev/snarf clipboard. Offset-addressed so chunked
        # readers walk to EOF; devsnarf_read returns 0 when off>=length.
        return devsnarf_read(off, buf, count)
    if dev_type == DEV_KEYMAP:
        # task #178: snapshot-once "<layout>\n". devkeymap_read honours
        # `off`-less single-shot reads; a second read returns the same
        # short blob (consumers `cat` it once).
        if off > 0:
            return 0
        return devkeymap_read(buf, count)
    if dev_type == DEV_NSCAP:
        # #174: snapshot-once "mem <charged>/<cap> cpu <pct>\n" for the
        # caller's namespace. Single-shot so `cat /dev/nscap` terminates.
        if off > 0:
            return 0
        return devnscap_read(buf, count)
    if dev_type == DEV_FIREWALL:
        # Multi-line ruleset listing — honour `off` so `cat` walks to
        # EOF and terminates instead of regenerating forever.
        return devfirewall_read(buf, count, off)
    if dev_type == DEV_STAT:
        return devstat_read(buf, count)
    if dev_type == DEV_MOUNTS:
        return devmounts_read(buf, count)
    if dev_type == DEV_DISKSTATS:
        return devdiskstats_read(buf, count)
    # hamUI Phase 2: /dev/wsys tree. Every leaf is snapshot-once;
    # devwsys_*_read consult `off` and report EOF when the snapshot is
    # drained so `cat` terminates instead of regenerating forever. The
    # wid was extracted from the inline chan id by namec_read() before
    # this call and passed in as the wid argument; per-wid leaves
    # (text/output/cmd/pid) thread it down to the devwsys backend.
    if dev_type == DEV_REBOOT:
        # /dev/reboot is write-only — reads return EOF so a stray cat
        # doesn't wedge. The action is the write side only.
        return 0
    if dev_type == DEV_SYNC:
        # /dev/sync is write-only — reads return EOF.
        return 0
    if dev_type == DEV_POWERCTL:
        # /dev/power/ctl is write-only. The Plan-9 idiom is "the WRITE
        # is the verb"; reads return EOF so cat doesn't wedge.
        return 0
    if dev_type == DEV_SYS_POWER_STATE:
        # /sys/power/state read — Linux exports the list of supported
        # sleep states here ("freeze mem disk\n" on a tuned box, "mem\n"
        # on a minimal one). We expose just "mem\n" when S3 is parsed
        # from the FADT, else an empty line. Snapshot-once.
        if off > 0:
            return 0
        return _devpower_state_read(buf, count)
    if dev_type == DEV_FB:
        # /dev/fb read = the geometry line. Snapshot-once: deliver on
        # off==0 then EOF, so `cat /dev/fb` terminates (the backend also
        # honours `off` for chunked reads of the single line).
        return devfb_read(off, buf, count)
    if dev_type == DEV_FBCTL:
        # /dev/fbctl read = the console-takeover state line
        # ("suspended\n" / "active\n"). Snapshot-once: namec gates
        # off>0 -> EOF so `cat /dev/fbctl` terminates.
        return devfbctl_read(off, buf, count)
    if dev_type == DEV_FBPIX:
        # /dev/fbpix read = raw framebuffer bytes at byte offset `off`
        # (the screenshot leaf). OFFSET-ADDRESSED, finite (size =
        # pitch * height), EOF past the end — do NOT snapshot-gate, a
        # chunked reader streams the whole frame through fd_pos.
        return devfbpix_read(off, buf, count)
    if dev_type == DEV_AUDIO:
        # /dev/audio read = a one-line status snapshot (rate/channels/
        # bits/loaded). Snapshot-once: namec gates off>0 -> EOF.
        return devaudio_read(off, buf, count)
    if dev_type == DEV_AUDIOCTL:
        # /dev/audioctl is write-only; reads return EOF.
        return devaudioctl_read(off, buf, count)
    if dev_type == DEV_AUDIOIN:
        # /dev/audioin read = recorded PCM bytes streamed from the capture
        # ring; advances the ring read pointer (ignores file offset).
        return devaudioin_read(off, buf, count)
    # Virtual terminals: /dev/vt/1..4 blocking read from per-VT FIFO.
    if dev_type == DEV_VT1:
        return devvt_read(0, buf, count)
    if dev_type == DEV_VT2:
        return devvt_read(1, buf, count)
    if dev_type == DEV_VT3:
        return devvt_read(2, buf, count)
    if dev_type == DEV_VT4:
        return devvt_read(3, buf, count)
    if dev_type == DEV_VTCTL:
        # /dev/vt/ctl is write-only; reads return EOF.
        return 0
    if dev_type == DEV_WSYS:
        return devwsys_listing_read(off, buf, count)
    if dev_type == DEV_WSYS_TEXT:
        return devwsys_text_read(wid, off, buf, count)
    if dev_type == DEV_WSYS_OUTPUT:
        return devwsys_output_read(wid, off, buf, count)
    if dev_type == DEV_WSYS_CMD:
        # /dev/wsys/<N>/cmd is write-only — reads return 0 (EOF) so a
        # stray cat doesn't wedge. Cmd injection is the write side
        # only; there is no "current pending cmd" to expose.
        return 0
    if dev_type == DEV_WSYS_NS:
        # TODO DE close-out: per-window ns dump — pass wid so the leaf
        # renders the bound task's mtab (the WINDOW's namespace), not
        # the reader's. Was wid-less, now wid-keyed.
        return devwsys_ns_read(wid, off, buf, count)
    if dev_type == DEV_WSYS_PID:
        return devwsys_pid_read(wid, off, buf, count)
    if dev_type == DEV_WSYS_UID:
        # TODO DE close-out: per-window uid — pass wid so the leaf
        # renders the bound task's uid (e.g. `newshell hostowner`
        # elevation surfaces here), not the reader's uid.
        return devwsys_uid_read(wid, off, buf, count)
    if dev_type == DEV_WSYS_KIND:
        return devwsys_kind_read(off, buf, count)
    if dev_type == DEV_WSYS_GEOMETRY:
        return devwsys_geometry_read(off, buf, count)
    # hamUI compositor hot-path: per-window serial + wsys-level damage.
    if dev_type == DEV_WSYS_SERIAL:
        return devwsys_serial_read(wid, off, buf, count)
    # DE primitive: per-window /dev/wsys/<N>/wctl — snapshot-once
    # "<x> <y> <w> <h> <focus>\n" status line.
    if dev_type == DEV_WSYS_WCTL:
        return devwsys_wctl_read(wid, off, buf, count)
    if dev_type == DEV_WSYS_DAMAGE:
        return devwsys_damage_read(off, buf, count)
    if dev_type == DEV_WSYS_SELF:
        return devwsys_self_read(off, buf, count)
    # F2 #447: /dev/wsys/ctl read — renders the LAST `alloc` verb's
    # assigned wid (or EOF if nothing pending). See devwsys_ctl_read.
    if dev_type == DEV_WSYS_CTL:
        return devwsys_ctl_read(off, buf, count)
    # DE image-wallpaper: snapshot read of "<gen> <path>\n".
    if dev_type == DEV_WSYS_WALLPAPER:
        return devwsys_wallpaper_read(off, buf, count)
    # DE session save/restore: snapshot read, one line per active wid.
    if dev_type == DEV_WSYS_SESSION:
        return devwsys_session_read(off, buf, count)
    # DE pivot wave 2: Applications-menu catalogue snapshot + launch slot.
    if dev_type == DEV_WSYS_APPMENU:
        return devwsys_appmenu_read(off, buf, count)
    if dev_type == DEV_WSYS_APPMENU_LAUNCH:
        return devwsys_appmenu_launch_read(off, buf, count)
    # DE pivot wave 3: Alt-Tab cycler model + show-serial snapshots.
    if dev_type == DEV_WSYS_CYCLER:
        return devwsys_cycler_read(off, buf, count)
    if dev_type == DEV_WSYS_CYCLER_SHOW:
        return devwsys_cycler_show_read(off, buf, count)
    # DE pivot wave 4: calendar popup model + show-serial snapshots.
    if dev_type == DEV_WSYS_CALPOP:
        return devwsys_calpop_read(off, buf, count)
    if dev_type == DEV_WSYS_CALPOP_SHOW:
        return devwsys_calpop_show_read(off, buf, count)
    # DE pivot wave 4: Run-dialog model, show-serial, and launch slot
    # snapshots.
    if dev_type == DEV_WSYS_RUN:
        return devwsys_run_read(off, buf, count)
    if dev_type == DEV_WSYS_RUN_SHOW:
        return devwsys_run_show_read(off, buf, count)
    if dev_type == DEV_WSYS_RUN_LAUNCH:
        return devwsys_run_launch_read(off, buf, count)
    # DE pivot wave 7: notification toast model + show-serial snapshots.
    if dev_type == DEV_WSYS_NOTIF:
        return devwsys_notif_read(off, buf, count)
    if dev_type == DEV_WSYS_NOTIF_SHOW:
        return devwsys_notif_show_read(off, buf, count)
    # DE pivot wave 5: screen-lock model, show-serial, and verify slot
    # snapshots.
    if dev_type == DEV_WSYS_LOCK:
        return devwsys_lock_read(off, buf, count)
    if dev_type == DEV_WSYS_LOCK_SHOW:
        return devwsys_lock_show_read(off, buf, count)
    if dev_type == DEV_WSYS_LOCK_VERIFY:
        return devwsys_lock_verify_read(off, buf, count)
    # DE pivot wave 7: rubber-band overlay model + set-serial snapshots.
    if dev_type == DEV_WSYS_RBAND:
        return devwsys_rband_read(off, buf, count)
    if dev_type == DEV_WSYS_RBAND_SET:
        return devwsys_rband_set_read(off, buf, count)
    # #442 (c) rio blit protocol substrate — v2 status + backbuffer pixels.
    if dev_type == DEV_WSYS_BBSTATE:
        return devwsys_bbstate_read(wid, off, buf, count)
    if dev_type == DEV_WSYS_BACKBUFFER:
        return devwsys_backbuffer_read(wid, off, buf, count)
    # hamUI input-event surface: BLOCKING reads. These are live event
    # STREAMS, not snapshot files — the backend ignores `off` and parks
    # the reader on the per-wid wait queue until the compositor writes an
    # event (event-driven, no poll-yield). Do NOT off-gate here.
    if dev_type == DEV_WSYS_POINTER:
        return devwsys_pointer_read(wid, off, buf, count)
    if dev_type == DEV_WSYS_KEYS:
        return devwsys_keys_read(wid, off, buf, count)
    # hamUI Phase 4a — layered-draw file surface (docs/hamUI.md H-§G).
    if dev_type == DEV_WSYS_DRAW:
        return devwsys_draw_listing_read(wid, off, buf, count)
    if dev_type == DEV_WSYS_DRAW_CTL:
        # ctl is write-only — reads return EOF so a stray cat doesn't
        # wedge. The verb side is the write side only.
        return 0
    if dev_type == DEV_WSYS_DRAW_KIND:
        return devwsys_draw_kind_read(wid, layer, off, buf, count)
    if dev_type == DEV_WSYS_DRAW_Z:
        return devwsys_draw_z_read(wid, layer, off, buf, count)
    if dev_type == DEV_WSYS_DRAW_OPACITY:
        return devwsys_draw_opacity_read(wid, layer, off, buf, count)
    if dev_type == DEV_WSYS_DRAW_GEOMETRY:
        return devwsys_draw_geometry_read(wid, layer, off, buf, count)
    if dev_type == DEV_WSYS_DRAW_MARKUP:
        return devwsys_draw_markup_read(wid, layer, off, buf, count)
    if dev_type == DEV_WSYS_DRAW_FB:
        return devwsys_draw_fb_read(wid, layer, off, buf, count)
    if dev_type == DEV_WSYS_DRAW_GEN:
        return devwsys_draw_gen_read(wid, layer, off, buf, count)
    return -1


# --- /dev/reboot verb decode ----------------------------------------
#
# A write to /dev/reboot carries an ASCII verb. We match on the leading
# token (so "poweroff", "poweroff\n", "poweroff now" all work) and
# funnel into the shared kernel power routine. power_action() flushes
# filesystems then takes the action and never returns, so a successful
# write never actually returns to the caller — but we keep the return-
# count contract for the error path (unknown verb returns the byte
# count consumed, mirroring a write that was accepted-but-ignored).

def _verb_matches(buf: Ptr[uint8], count: uint64, word: Ptr[char]) -> int32:
    # 1 iff the first token of `buf` (up to a NUL / newline / space /
    # end-of-count) equals the NUL-terminated `word`.
    i: uint64 = 0
    while True:
        wc: char = word[i]
        if wc == 0:
            # `word` exhausted — the buffer token must end here too.
            if i >= count:
                return 1
            bc: uint8 = buf[i]
            if bc == 0 or bc == 10 or bc == 32:
                return 1
            return 0
        if i >= count:
            return 0
        if buf[i] != cast[uint8](wc):
            return 0
        i = i + 1


def _devpower_state_read(buf: Ptr[uint8], count: uint64) -> int64:
    # /sys/power/state read: report the supported sleep-state names. We
    # surface "mem\n" iff the firmware advertises S3 (DSDT _S3 + FADT
    # PM1a parsed); otherwise the empty line. Mirrors the Linux contract
    # closely enough for a smoke probe like
    # `cat /sys/power/state` to do the right thing.
    word: Ptr[uint8] = "mem\n"
    wl: uint64 = 4
    if power_s3_ready() == 0:
        word = "\n"
        wl = 1
    n: uint64 = wl
    if n > count:
        n = count
    i: uint64 = 0
    while i < n:
        buf[i] = word[i]
        i = i + 1
    return cast[int64](n)


def _verb_prefix_matches(buf: Ptr[uint8], count: uint64,
                         word: Ptr[char]) -> int32:
    # 1 iff the buffer STARTS with the NUL-terminated `word` (verb +
    # any trailing args/whitespace OK). Used by the multi-arg power
    # ctl verbs ("suspend mem", "lid suspend").
    i: uint64 = 0
    while True:
        wc: char = word[i]
        if wc == 0:
            return 1
        if i >= count:
            return 0
        if buf[i] != cast[uint8](wc):
            return 0
        i = i + 1


def _devpower_ctl_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Native /dev/power/ctl verb decode. Funnels into the same
    # power_suspend_s3() core that /sys/power/state uses.
    if _verb_prefix_matches(buf, count, "suspend mem") != 0:
        power_suspend_s3()
        return cast[int64](count)
    if _verb_prefix_matches(buf, count, "lid suspend") != 0:
        power_lid_arm_suspend(1)
        return cast[int64](count)
    if _verb_prefix_matches(buf, count, "lid disarm") != 0:
        power_lid_arm_suspend(0)
        return cast[int64](count)
    if _verb_matches(buf, count, "mem") != 0:
        # Convenience: bare "mem" works too — matches the Linux echo
        # idiom even via the native ctl file.
        power_suspend_s3()
        return cast[int64](count)
    # Unknown verb: accept-and-ignore so a stray writer doesn't wedge.
    return cast[int64](count)


def _devsys_power_state_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Linux-ABI /sys/power/state: the verbs are the sleep-state NAMES.
    # "mem" → S3; "disk" / "freeze" not implemented (accept-and-ignore
    # rather than failing the write so userland heuristics
    # — `echo mem > /sys/power/state || echo standby > /sys/power/state`
    # — make a clean fall-through).
    if _verb_matches(buf, count, "mem") != 0:
        power_suspend_s3()
        return cast[int64](count)
    return cast[int64](count)


def _devreboot_write(buf: Ptr[uint8], count: uint64) -> int64:
    if _verb_matches(buf, count, "poweroff") != 0:
        power_action(POWER_POWEROFF)          # never returns
        return cast[int64](count)
    if _verb_matches(buf, count, "reboot") != 0:
        power_action(POWER_REBOOT)            # never returns
        return cast[int64](count)
    if _verb_matches(buf, count, "halt") != 0:
        power_action(POWER_HALT)              # never returns
        return cast[int64](count)
    # Unknown verb: accept-and-ignore (don't wedge a stray writer).
    return cast[int64](count)


def _devtab_write(dev_type: int32, wid: int32, layer: int32,
                  off: uint64, buf: Ptr[uint8],
                  count: uint64) -> int64:
    if dev_type == DEV_REBOOT:
        return _devreboot_write(buf, count)
    if dev_type == DEV_POWERCTL:
        return _devpower_ctl_write(buf, count)
    if dev_type == DEV_SYS_POWER_STATE:
        return _devsys_power_state_write(buf, count)
    if dev_type == DEV_SYNC:
        # /dev/sync: any write runs the ext4 durability barrier
        # (journal commit + block-cache flush + device FLUSH). The
        # payload bytes are ignored — the WRITE is the verb. By-name
        # call: namec must not import fs.ext4 (cycle; see the
        # _resolve_named_root_rel note), and the whole-kernel Adder
        # merge links the symbol.
        ext4_fsync()
        return cast[int64](count)
    if dev_type == DEV_FB:
        # /dev/fb write = present RGBA8888 frame bytes. Offset-addressed
        # so a chunked writer composes; the backend repacks per fb_pixfmt
        # and stores honouring fb_pitch.
        return devfb_write(off, buf, count)
    if dev_type == DEV_FBCTL:
        # /dev/fbctl write = a console-takeover verb ("suspend"/"resume").
        # hamUId writes "suspend" to silence the boot text console while
        # it owns the framebuffer, "resume" to restore it on exit (P0a).
        return devfbctl_write(off, buf, count)
    if dev_type == DEV_FBPIX:
        # /dev/fbpix is read-only (the screenshot pixel source); writes
        # are rejected — presentation goes through /dev/fb.
        return devfbpix_write(off, buf, count)
    if dev_type == DEV_AUDIO:
        # /dev/audio write = raw PCM bytes, offset-addressed into the HDA
        # stream DMA buffer. A zero-length write flushes/starts playback.
        return devaudio_write(off, buf, count)
    if dev_type == DEV_AUDIOCTL:
        # /dev/audioctl write = a text control verb (rate/channels/
        # format/bits/start/stop/reset).
        return devaudioctl_write(buf, count)
    if dev_type == DEV_AUDIOIN:
        # /dev/audioin is read-only (a capture source); writes rejected.
        return devaudioin_write(off, buf, count)
    # Virtual terminals: /dev/vt/1..4 write to physical console;
    # /dev/vt/ctl switches the active VT.
    if dev_type == DEV_VT1:
        return devvt_write(buf, count)
    if dev_type == DEV_VT2:
        return devvt_write(buf, count)
    if dev_type == DEV_VT3:
        return devvt_write(buf, count)
    if dev_type == DEV_VT4:
        return devvt_write(buf, count)
    if dev_type == DEV_VTCTL:
        return devvtctl_write(buf, count)
    if dev_type == DEV_LOOPCTL:
        # Phase 4b: /dev/loop/ctl write — parse one attach/detach verb
        # per write (stateless across writes). By-name call: loop.ad
        # imports fs.vfs imports namec.
        return loopctl_write(buf, count)
    if dev_type == DEV_DEVFD:
        # Phase 4c: `#d/<N>` fd-name fd write. Blocking: a pipe-W
        # backing chunk-writes with EPIPE-on-no-readers (the exact loop
        # the legacy FD_DEVFD_MARK vfs_write arm carried).
        return devfd_write_blocking(pgrp_current(), wid, buf, count)
    if dev_type == DEV_NULL:
        # /dev/null swallows writes silently — the full count is
        # returned as bytes-written.
        return cast[int64](count)
    if dev_type == DEV_ZERO:
        # /dev/zero likewise swallows writes silently.
        return cast[int64](count)
    if dev_type == DEV_CONS:
        return devcons_write(buf, count)
    if dev_type == DEV_TIME:
        return devtime_write(buf, count)
    if dev_type == DEV_PID:
        return devpid_write(buf, count)
    if dev_type == DEV_RANDOM:
        return devrandom_write(buf, count)
    if dev_type == DEV_URANDOM:
        # Same backend as /dev/random — writes mix bytes into the pool.
        return devrandom_write(buf, count)
    if dev_type == DEV_MOUSE:
        return devmouse_write(buf, count)
    if dev_type == DEV_CPUINFO:
        return devcpuinfo_write(buf, count)
    if dev_type == DEV_MEMINFO:
        return devmeminfo_write(buf, count)
    if dev_type == DEV_UPTIME:
        return devuptime_write(buf, count)
    if dev_type == DEV_LOADAVG:
        return devloadavg_write(buf, count)
    if dev_type == DEV_VERSION:
        return devversion_write(buf, count)
    if dev_type == DEV_HOSTNAME:
        return devhostname_write(buf, count)
    if dev_type == DEV_SNARF:
        # DE primitive: /dev/snarf clipboard. Write REPLACES the buffer
        # wholesale (capped at SNARF_MAX); a 0-byte write clears it.
        return devsnarf_write(buf, count)
    if dev_type == DEV_KEYMAP:
        # task #178: writing a layout name ("us"/"de"/"fr") switches the
        # live keyboard layout.
        return devkeymap_write(buf, count)
    if dev_type == DEV_NSCAP:
        # #174: writing "mem <bytes>" / "cpu <pct>" sets the per-namespace
        # memory + CPU caps on the caller's Pgrp.
        return devnscap_write(buf, count)
    if dev_type == DEV_FIREWALL:
        # Writing a directive adds a rule / sets the policy / flushes.
        return devfirewall_write(buf, count)
    if dev_type == DEV_STAT:
        return devstat_write(buf, count)
    if dev_type == DEV_MOUNTS:
        return devmounts_write(buf, count)
    if dev_type == DEV_DISKSTATS:
        return devdiskstats_write(buf, count)
    if dev_type == DEV_MOUNTRPC:
        return devmountrpc_write(buf, count)
    if dev_type == DEV_P9MAX:
        return dev9pmax_write(buf, count)
    # hamUI Phase 2: cmd is the only writable slot. Every other slot is
    # read-only (mirror of console writes / introspection snapshots).
    # The wid was extracted from the inline chan id by namec_write().
    if dev_type == DEV_WSYS_CMD:
        return devwsys_cmd_write(wid, buf, count)
    # hamUI input-event surface: the compositor enqueues routed pointer /
    # key event lines here; the kernel buffers them and wakes the blocked
    # client reader (devwsys_pointer_read / devwsys_keys_read).
    if dev_type == DEV_WSYS_POINTER:
        return devwsys_pointer_write(wid, buf, count)
    if dev_type == DEV_WSYS_KEYS:
        return devwsys_keys_write(wid, buf, count)
    # F2 #447: /dev/wsys/ctl write — system-wide wsys ctl (alloc/free/
    # frame). Hostowner-gated inside devwsys_ctl_write.
    if dev_type == DEV_WSYS_CTL:
        return devwsys_ctl_write(buf, count)
    # DE pivot wave 2: hamappmenu writes the chosen prog path here on
    # click; the compositor polls the read side and spawns it. The
    # snapshot read on /dev/wsys/appmenu itself is read-only (writes
    # there fall through to devwsys_readonly_write below).
    if dev_type == DEV_WSYS_APPMENU_LAUNCH:
        return devwsys_appmenu_launch_write(buf, count)
    # DE pivot wave 3: a write to /dev/wsys/cycler/show bumps the show
    # serial. The compositor pokes this whenever it wants the client to
    # wake up + re-render.
    if dev_type == DEV_WSYS_CYCLER_SHOW:
        return devwsys_cycler_show_write(buf, count)
    # DE pivot wave 4: writes to /dev/wsys/calpop/show bump the show
    # serial. The compositor pokes this whenever it wants the calendar
    # popup client to wake + re-render.
    if dev_type == DEV_WSYS_CALPOP_SHOW:
        return devwsys_calpop_show_write(buf, count)
    # DE pivot wave 4: /dev/wsys/run/show write bumps the run show
    # serial; /dev/wsys/run/launch write enqueues a launch path that the
    # compositor's main loop drains.
    if dev_type == DEV_WSYS_RUN_SHOW:
        return devwsys_run_show_write(buf, count)
    if dev_type == DEV_WSYS_RUN_LAUNCH:
        return devwsys_run_launch_write(buf, count)
    # DE pivot wave 7: /dev/wsys/notif/show write bumps the notif show
    # serial. The compositor pokes this whenever it wants the toast
    # client to wake + re-render.
    if dev_type == DEV_WSYS_NOTIF_SHOW:
        return devwsys_notif_show_write(buf, count)
    # DE pivot wave 5: /dev/wsys/lock/show write bumps the lock show
    # serial; /dev/wsys/lock/verify write enqueues a password attempt
    # that the compositor's main loop drains.
    if dev_type == DEV_WSYS_LOCK_SHOW:
        return devwsys_lock_show_write(buf, count)
    if dev_type == DEV_WSYS_LOCK_VERIFY:
        return devwsys_lock_verify_write(buf, count)
    # DE pivot wave 7: /dev/wsys/rband/set write bumps the set serial
    # (compositor pokes this on every drag move so the client repaints).
    if dev_type == DEV_WSYS_RBAND_SET:
        return devwsys_rband_set_write(buf, count)
    # hamUI Phase 4a — layered-draw file surface (docs/hamUI.md H-§G).
    if dev_type == DEV_WSYS_DRAW_CTL:
        return devwsys_draw_ctl_write(wid, buf, count)
    if dev_type == DEV_WSYS_DRAW_Z:
        return devwsys_draw_z_write(wid, layer, buf, count)
    if dev_type == DEV_WSYS_DRAW_OPACITY:
        return devwsys_draw_opacity_write(wid, layer, buf, count)
    if dev_type == DEV_WSYS_DRAW_GEOMETRY:
        return devwsys_draw_geometry_write(wid, layer, buf, count)
    if dev_type == DEV_WSYS_DRAW_MARKUP:
        return devwsys_draw_markup_write(wid, layer, off, buf, count)
    if dev_type == DEV_WSYS_DRAW_FB:
        return devwsys_draw_fb_write(wid, layer, off, buf, count)
    # hamUI compositor hot-path: the per-window serial file is writable —
    # the compositor ACKs a composited serial to consume that window's
    # dirty rect (see devwsys_serial_write).
    if dev_type == DEV_WSYS_SERIAL:
        return devwsys_serial_write(wid, buf, count)
    # DE primitive: per-window wctl verb sink — resize/move/focus.
    # Hostowner-gated inside devwsys_wctl_write.
    if dev_type == DEV_WSYS_WCTL:
        return devwsys_wctl_write(wid, buf, count)
    if dev_type == DEV_WSYS or dev_type == DEV_WSYS_TEXT \
            or dev_type == DEV_WSYS_OUTPUT or dev_type == DEV_WSYS_NS \
            or dev_type == DEV_WSYS_PID or dev_type == DEV_WSYS_UID \
            or dev_type == DEV_WSYS_KIND or dev_type == DEV_WSYS_GEOMETRY \
            or dev_type == DEV_WSYS_DRAW or dev_type == DEV_WSYS_DAMAGE \
            or dev_type == DEV_WSYS_DRAW_GEN or dev_type == DEV_WSYS_WALLPAPER \
            or dev_type == DEV_WSYS_SESSION or dev_type == DEV_WSYS_BBSTATE \
            or dev_type == DEV_WSYS_BACKBUFFER or dev_type == DEV_WSYS_APPMENU \
            or dev_type == DEV_WSYS_RUN or dev_type == DEV_WSYS_LOCK \
            or dev_type == DEV_WSYS_NOTIF \
            or dev_type == DEV_WSYS_RBAND:
        return devwsys_readonly_write(buf, count)
    return -1


# --- mountrpc: the DEV_MNT operation set ----------------------------
#
# A Chan whose dev_type is DEV_MNT is backed by a mounted 9P server.
# Its read/write/close marshal into 9P T-messages over the stored
# srvfd via the in-kernel 9P client (9p_client.ad). This is the
# "same interface, different substrate" half of the inversion: the
# devtab path calls _devtab_read; the mounted path calls _mnt_read;
# namec_read picks between them on dev_type so the CALLER sees one
# operation.

# The byte offset is supplied by the caller (the fd layer's fd_pos),
# NOT stored in the Chan. That keeps the Chan free of seekable mutable
# state and lets vfs_lseek / fd_pos drive the cursor exactly as it
# does for the legacy FD_P9_MARK path — no behaviour change.

def _mnt_read(slot: uint64, off: uint64, buf: Ptr[uint8],
              count: uint64) -> int64:
    return p9c_read(chan_pool[slot].srvfd, chan_pool[slot].p9_fid,
                    off, buf, cast[uint32](count))


def _mnt_write(slot: uint64, off: uint64, buf: Ptr[uint8],
               count: uint64) -> int64:
    return p9c_write(chan_pool[slot].srvfd, chan_pool[slot].p9_fid,
                     off, buf, cast[uint32](count))


# --- on-disk regular files: DEV_EXT4_FILE / DEV_FAT_FILE ------------
#
# The fd→Chan fold for ext4/FAT file fds. Each is a POOL chan (like
# DEV_MNT) carrying its fs open-file slot in back_slot. The fd layer's
# open helper (fs/vfs.ad::_open_ext4_read / _open_fat_read and the
# write-open arms) calls one of the namec_open_* allocators below,
# stashes the returned slot id in an FD_CHAN_MARK fd, and read/write/
# close all funnel through namec_read/namec_write/namec_close on
# dev_type — exactly the DEV_MNT shape. The byte offset is the caller's
# fd_pos (NOT stored in the Chan), same as the mountrpc leg.
#
# ext4_open / ext4_read_file / ext4_open_inum / ext4_write_open_file /
# ext4_close and the fat_* siblings are resolved BY NAME (the whole-
# kernel Adder merge links them). namec must not `import fs.ext4` /
# `fs.fat` — that would form a namec -> fs -> ... -> namec import cycle
# — so we call them directly, the same by-name pattern core.ad uses for
# namec_close itself.

def namec_open_ext4_file(slot: int32) -> int32:
    # Wrap an already-opened ext4 open-file slot in a DEV_EXT4_FILE pool
    # chan. Returns the chan id (a pool slot index), or -1 if the pool is
    # exhausted (caller then ext4_close(slot) to avoid leaking it).
    cs: int32 = _chan_alloc()
    if cs < 0:
        return -1
    su: uint64 = cast[uint64](cs)
    chan_pool[su].in_use    = 1
    chan_pool[su].dev_type  = DEV_EXT4_FILE
    chan_pool[su].mode      = 0
    chan_pool[su].back_slot = slot
    return cs


def namec_open_tmpfs_file(slot: int32) -> int32:
    # Wrap an already-resolved tmpfs entry slot (a named /tmp,/var file,
    # or an anonymous memfd slot from tmpfs_create_anon) in a
    # DEV_TMPFS_FILE pool chan. Returns the chan id, or -1 on pool
    # exhaustion (caller then releases the tmpfs slot to avoid a leak).
    cs: int32 = _chan_alloc()
    if cs < 0:
        return -1
    su: uint64 = cast[uint64](cs)
    chan_pool[su].in_use    = 1
    chan_pool[su].dev_type  = DEV_TMPFS_FILE
    chan_pool[su].mode      = 0
    chan_pool[su].back_slot = slot
    return cs


def namec_open_fat_file(slot: int32) -> int32:
    # Wrap a FAT fd_buf word (read open-file slot, or write-slot index
    # with FAT_CHAN_WRITE_BIT set) in a DEV_FAT_FILE pool chan. Returns
    # the chan id, or -1 on pool exhaustion.
    cs: int32 = _chan_alloc()
    if cs < 0:
        return -1
    su: uint64 = cast[uint64](cs)
    chan_pool[su].in_use    = 1
    chan_pool[su].dev_type  = DEV_FAT_FILE
    chan_pool[su].mode      = 0
    chan_pool[su].back_slot = slot
    return cs


def namec_open_dir_file(buf_ptr: uint64, buf_len: int32) -> int32:
    # Wrap a kmalloc'd "NAME\n" directory-listing buffer in a ptr-backed
    # DEV_DIR_FILE pool chan. UNLIKE the file families, the DIR family
    # carries the buffer DIRECTLY: back_ptr = the buffer pointer,
    # back_slot = the buffer length (small — fits int32). Read dispatches
    # to _dirfile_read; the last close kfree()s back_ptr. Returns the chan
    # id, or -1 on pool exhaustion (caller must kfree(buf_ptr) and fail
    # the open on -1).
    cs: int32 = _chan_alloc()
    if cs < 0:
        return -1
    su: uint64 = cast[uint64](cs)
    chan_pool[su].in_use    = 1
    chan_pool[su].dev_type  = DEV_DIR_FILE
    chan_pool[su].mode      = 0
    chan_pool[su].back_slot = buf_len
    chan_pool[su].back_ptr  = buf_ptr
    return cs


def namec_open_buf_file(buf_ptr: uint64, buf_len: int32) -> int32:
    # Phase 4b: wrap a kmalloc'd render-once snapshot buffer (procfs /
    # cgroup2 / NUMA-node sysfs text) in a ptr-backed DEV_BUF_FILE pool
    # chan. Same carrier shape as DEV_DIR_FILE: back_ptr = the buffer,
    # back_slot = the rendered byte length. Read shares _dirfile_read;
    # write is -EROFS; the last close kfree()s back_ptr. Returns the
    # chan id, or -1 on pool exhaustion (caller must kfree(buf_ptr) and
    # fail the open on -1).
    cs: int32 = _chan_alloc()
    if cs < 0:
        return -1
    su: uint64 = cast[uint64](cs)
    chan_pool[su].in_use    = 1
    chan_pool[su].dev_type  = DEV_BUF_FILE
    chan_pool[su].mode      = 0
    chan_pool[su].back_slot = buf_len
    chan_pool[su].back_ptr  = buf_ptr
    return cs


def namec_open_proc_file(enc24: int32) -> int32:
    # Phase 4b: wrap a devproc (pid << 8 | kind) encoding in a DEV_PROC
    # pool chan. The render is stateless — devproc_read re-validates the
    # pid and renders the snapshot on every off==0 read — so the chan
    # carries only the encoding (back_slot); there is no buffer and the
    # last close frees nothing beyond the pool slot. devproc_open has
    # already validated the pid exists at open time. Returns the chan
    # id, or -1 on pool exhaustion.
    cs: int32 = _chan_alloc()
    if cs < 0:
        return -1
    su: uint64 = cast[uint64](cs)
    chan_pool[su].in_use    = 1
    chan_pool[su].dev_type  = DEV_PROC
    chan_pool[su].mode      = 0
    chan_pool[su].back_slot = enc24
    return cs


def namec_open_auth_file(slot: int32) -> int32:
    # Phase 4b: wrap a devauth AuthSlot pool index in a DEV_AUTH pool
    # chan. The caller (fs/vfs.ad _open_auth_marked) has already
    # devauth_alloc()'d the slot; all credential state lives in
    # devauth.ad's auth_pool — the chan just refcounts the handle so a
    # fork/dup'd auth fd shares ONE slot and only the LAST close returns
    # it (the legacy raw-slot fd_buf copy double-freed on the first
    # close). mode is ORDWR — the newshell idiom writes user/pass and
    # reads the verdict on the same fd. Returns the chan id, or -1 on
    # pool exhaustion (caller rolls the AuthSlot back).
    cs: int32 = _chan_alloc()
    if cs < 0:
        return -1
    su: uint64 = cast[uint64](cs)
    chan_pool[su].in_use    = 1
    chan_pool[su].dev_type  = DEV_AUTH
    chan_pool[su].mode      = 2
    chan_pool[su].back_slot = slot
    return cs


def namec_open_blk_file(pack: uint64) -> int32:
    # Phase 4b: wrap a devblk (mode << 32 | slot) pack in a DEV_BLK pool
    # chan. The pack is 64-bit so it rides in back_ptr (back_slot is
    # int32). The caller (fs/vfs.ad _open_blk_marked) resolved the
    # /dev/blk/<name>{,/size,/ctl} path through devblk_leaf_match
    # already; the pack is a cookie into the global block-slot table, so
    # close releases nothing beyond the pool slot. Returns the chan id,
    # or -1 on pool exhaustion.
    cs: int32 = _chan_alloc()
    if cs < 0:
        return -1
    su: uint64 = cast[uint64](cs)
    chan_pool[su].in_use    = 1
    chan_pool[su].dev_type  = DEV_BLK
    chan_pool[su].mode      = 2
    chan_pool[su].back_slot = 0
    chan_pool[su].back_ptr  = pack
    return cs


def namec_open_pipe_end(slot: int32, is_write: int32) -> int32:
    # Phase 4c (pipe fold): wrap one END of a fs/pipe.ad pipe slot in a
    # DEV_PIPE_R / DEV_PIPE_W pool chan. The caller owns one end-
    # refcount on the pipe (pipe_alloc starts at readers=writers=1) and
    # hands it to the chan: the LAST namec_close on this chan runs
    # pipe_close_reader / pipe_close_writer. Returns the chan id, or -1
    # on pool exhaustion (caller must drop the end-refcount itself to
    # avoid leaking the pipe).
    cs: int32 = _chan_alloc()
    if cs < 0:
        return -1
    su: uint64 = cast[uint64](cs)
    chan_pool[su].in_use    = 1
    if is_write != 0:
        chan_pool[su].dev_type = DEV_PIPE_W
        chan_pool[su].mode     = 1
    else:
        chan_pool[su].dev_type = DEV_PIPE_R
        chan_pool[su].mode     = 0
    chan_pool[su].back_slot = slot
    return cs


def namec_chan_pipe_slot(cid: int32) -> int32:
    # Phase 4c (pipe fold): the fs/pipe.ad slot behind a DEV_PIPE_R /
    # DEV_PIPE_W chan, or -1 for any other chan kind. splice/tee
    # (vfs_fd_pipe_slot) and the 9P srv-fd transport (9p_client.ad's
    # _fd_to_pipe_slot, which calls this BY NAME — namec imports
    # 9p_client, so the reverse import would cycle) recover the ring
    # through this instead of branching on retired fd marks.
    if _chan_id_valid(cid) == 0:
        return -1
    if _chan_id_is_inline(cid) != 0:
        return -1
    su: uint64 = cast[uint64](cid)
    if chan_pool[su].dev_type == DEV_PIPE_R \
            or chan_pool[su].dev_type == DEV_PIPE_W:
        return chan_pool[su].back_slot
    return -1


def namec_open_socket(fdbuf32: int32) -> int32:
    # Phase 4c (socket fold): wrap a Linux-ABI socket fd's backing
    # encoding (see the DEV_SOCKET comment up top — 0 = no record yet,
    # rec+1, or a tagged AF_UNIX/netlink endpoint) in a DEV_SOCKET pool
    # chan. Returns the chan id, or -1 when the pool is exhausted.
    cs: int32 = _chan_alloc()
    if cs < 0:
        return -1
    su: uint64 = cast[uint64](cs)
    chan_pool[su].in_use    = 1
    chan_pool[su].dev_type  = DEV_SOCKET
    chan_pool[su].mode      = 2                  # ORDWR — a socket is r/w
    chan_pool[su].back_slot = fdbuf32
    return cs


def namec_socket_set_record(cid: int32, fdbuf32: int32) -> int32:
    # Phase 4c (socket fold): late-bind a backing record onto a
    # DEV_SOCKET chan. socket(2) allocates the fd (back_slot = 0)
    # first and wires the record after — the legacy path mutated
    # fd_buf, the chan path mutates back_slot. 0 ok, -1 not a socket
    # chan.
    if _chan_id_valid(cid) == 0 or _chan_id_is_inline(cid) != 0:
        return -1
    su: uint64 = cast[uint64](cid)
    if chan_pool[su].dev_type != DEV_SOCKET:
        return -1
    chan_pool[su].back_slot = fdbuf32
    return 0


def namec_chan_socket_fdbuf(cid: int32) -> int64:
    # Phase 4c (socket fold): the backing fd_buf encoding behind a
    # DEV_SOCKET chan (>= 0), or -1 for any other chan kind.
    if _chan_id_valid(cid) == 0 or _chan_id_is_inline(cid) != 0:
        return -1
    su: uint64 = cast[uint64](cid)
    if chan_pool[su].dev_type != DEV_SOCKET:
        return -1
    return cast[int64](cast[uint32](chan_pool[su].back_slot))


def namec_open_sockpair_end(slot: int32, direction: int32) -> int32:
    # Phase 4c (socket fold): wrap ONE socketpair endpoint in a
    # DEV_SOCKETPAIR pool chan. The caller owns one end-reference
    # (refs_a/refs_b already counts it); the chan inherits that
    # ownership and namec_close's DEV_SOCKETPAIR arm releases it on
    # the LAST chan reference. Returns the chan id, or -1 when the
    # pool is exhausted.
    cs: int32 = _chan_alloc()
    if cs < 0:
        return -1
    su: uint64 = cast[uint64](cs)
    chan_pool[su].in_use    = 1
    chan_pool[su].dev_type  = DEV_SOCKETPAIR
    chan_pool[su].mode      = 2                  # bidirectional
    chan_pool[su].back_slot = cast[int32](sockpair_pack(slot, direction))
    return cs


def namec_open_net(pack32: uint32) -> int32:
    # Phase 4d (net fold, F7 #390): wrap a /net fd's (proto, conn,
    # file-kind) packing in a DEV_NET pool chan. The pack lives in
    # back_slot (all three fields fit in 32 bits — see DEV_NET above
    # for the layout). Returns the chan id, or -1 when the pool is
    # exhausted. The caller is expected to have already taken the
    # devnet_conn refcount on a per-conn fd; that reference is now
    # owned ONE-PER-CHAN — namec_close's DEV_NET arm runs
    # devnet_conn_unref on the LAST chan reference (fork/dup bump the
    # chan refcount, so the legacy "every fd copy held a raw conn ref
    # nobody bumped" bug is gone).
    cs: int32 = _chan_alloc()
    if cs < 0:
        return -1
    su: uint64 = cast[uint64](cs)
    chan_pool[su].in_use    = 1
    chan_pool[su].dev_type  = DEV_NET
    chan_pool[su].mode      = 2                  # ORDWR — /net is r/w
    chan_pool[su].back_slot = cast[int32](pack32)
    return cs


def namec_chan_net_pack(cid: int32) -> int64:
    # Phase 4d (net fold, F7 #390): the (proto, conn, file-kind) pack
    # behind a DEV_NET chan (>= 0 as a 32-bit unsigned cast to int64),
    # or -1 for any other chan kind. The vfs DEV_NET dispatch arms
    # call this BY NAME to recover the legacy fd_buf for the
    # devnet_unpack_* helpers (namec must not import devnet).
    if _chan_id_valid(cid) == 0 or _chan_id_is_inline(cid) != 0:
        return -1
    su: uint64 = cast[uint64](cid)
    if chan_pool[su].dev_type != DEV_NET:
        return -1
    return cast[int64](cast[uint32](chan_pool[su].back_slot))


def namec_open_ptmx(pack32: uint32) -> int32:
    # Phase 4e (PTY fold, F7 #390): wrap a PTY fd's (slot << 1 | is_master)
    # pack in a DEV_PTMX pool chan. The pack lives in back_slot — both
    # fields fit in 32 bits (slot is at most NR_PTY_PAIRS << 1, well under
    # 2^31). Returns the chan id, or -1 when the pool is exhausted. The
    # caller is expected to have already taken a per-end refcount on the
    # pair (pty_alloc_pair for master, pty_slave_open for slave); that
    # reference is now owned ONE-PER-CHAN — namec_close's DEV_PTMX arm
    # runs pty_master_unref / pty_slave_unref on the LAST chan reference
    # (fork/dup bump the chan refcount, so the legacy "close_fd_in_task
    # had a parallel FD_PTMX_MARK arm" risk is gone).
    cs: int32 = _chan_alloc()
    if cs < 0:
        return -1
    su: uint64 = cast[uint64](cs)
    chan_pool[su].in_use    = 1
    chan_pool[su].dev_type  = DEV_PTMX
    chan_pool[su].mode      = 2                  # ORDWR — a tty is r/w
    chan_pool[su].back_slot = cast[int32](pack32)
    return cs


def namec_chan_ptmx_pack(cid: int32) -> int64:
    # Phase 4e (PTY fold, F7 #390): the (slot << 1 | is_master) pack
    # behind a DEV_PTMX chan (>= 0 as a 32-bit unsigned cast to int64),
    # or -1 for any other chan kind. The vfs DEV_PTMX dispatch arms call
    # this BY NAME to recover the legacy fd_buf for the _pty_fd_slot /
    # _pty_fd_is_master helpers (namec must not import u_pty / the vfs
    # PTY layer).
    if _chan_id_valid(cid) == 0 or _chan_id_is_inline(cid) != 0:
        return -1
    su: uint64 = cast[uint64](cid)
    if chan_pool[su].dev_type != DEV_PTMX:
        return -1
    return cast[int64](cast[uint32](chan_pool[su].back_slot))


def namec_open_fuse_conn(slot32: int32) -> int32:
    # Phase 4f (FUSE fold, F7 #390): wrap a /dev/fuse connection slot
    # index in a DEV_FUSE_CONN pool chan. The slot rides in back_slot
    # verbatim — fuse_dev_read / fuse_dev_write / fuse_dev_close in
    # u_fuse.ad take the raw slot int the legacy FD_FUSE_CONN_MARK
    # arm passed. Returns the chan id, or -1 when the pool is exhausted
    # (caller then fuse_dev_close(slot) to avoid leaking it). The
    # caller owns one fuse-conn slot reference; that ownership transfers
    # to the chan and namec_close's DEV_FUSE_CONN arm releases it on
    # the LAST chan reference (fork/dup bump the chan refcount, so a
    # dup'd /dev/fuse fd no longer free-races the conn slot the way the
    # legacy fd-mark close arm did — close_fd_in_task knew nothing of
    # FD_FUSE_CONN_MARK so a task that EXITED holding one leaked the
    # conn slot outright).
    cs: int32 = _chan_alloc()
    if cs < 0:
        return -1
    su: uint64 = cast[uint64](cs)
    chan_pool[su].in_use    = 1
    chan_pool[su].dev_type  = DEV_FUSE_CONN
    chan_pool[su].mode      = 2                  # ORDWR — daemon r+w
    chan_pool[su].back_slot = slot32
    return cs


def namec_chan_fuse_conn_slot(cid: int32) -> int32:
    # Phase 4f (FUSE fold, F7 #390): the conn-slot index behind a
    # DEV_FUSE_CONN chan, or -1 for any other chan kind. The vfs
    # DEV_FUSE_CONN dispatch arms + linux_abi/u_syscalls.ad
    # vfs_fd_fuse_slot consumer call this BY NAME to recover the slot
    # the legacy FD_FUSE_CONN_MARK fd_buf carried (namec must not
    # import u_fuse).
    if _chan_id_valid(cid) == 0 or _chan_id_is_inline(cid) != 0:
        return -1
    su: uint64 = cast[uint64](cid)
    if chan_pool[su].dev_type != DEV_FUSE_CONN:
        return -1
    return chan_pool[su].back_slot


def namec_open_fuse_file(tok32: int32) -> int32:
    # Phase 4f (FUSE fold, F7 #390): wrap a FUSE open-file token in a
    # DEV_FUSE_FILE pool chan. The token rides in back_slot verbatim;
    # fuse_vfs_read / fuse_vfs_close in u_fuse.ad take the raw int the
    # legacy FD_FUSE_FILE_MARK arm passed. Returns the chan id, or -1
    # on pool exhaustion. namec_close's DEV_FUSE_FILE arm drives
    # FUSE_RELEASE over the wire on the LAST chan reference — fixing
    # the legacy task-exit leak (close_fd_in_task knew nothing of
    # FD_FUSE_FILE_MARK).
    cs: int32 = _chan_alloc()
    if cs < 0:
        return -1
    su: uint64 = cast[uint64](cs)
    chan_pool[su].in_use    = 1
    chan_pool[su].dev_type  = DEV_FUSE_FILE
    chan_pool[su].mode      = 2                  # ORDWR (read-back side)
    chan_pool[su].back_slot = tok32
    return cs


def namec_chan_fuse_file_tok(cid: int32) -> int32:
    # Phase 4f (FUSE fold, F7 #390): the open-file token behind a
    # DEV_FUSE_FILE chan, or -1 for any other chan kind.
    if _chan_id_valid(cid) == 0 or _chan_id_is_inline(cid) != 0:
        return -1
    su: uint64 = cast[uint64](cid)
    if chan_pool[su].dev_type != DEV_FUSE_FILE:
        return -1
    return chan_pool[su].back_slot


def namec_chan_sockpair_packed(cid: int32) -> int64:
    # Phase 4c (socket fold): the packed (slot << 1 | direction)
    # behind a DEV_SOCKETPAIR chan (>= 0), or -1 for any other chan
    # kind. The 9P srv-fd transport (9p_client.ad's _fd_to_sockpair)
    # calls this BY NAME — namec imports 9p_client, so the reverse
    # import would cycle.
    if _chan_id_valid(cid) == 0 or _chan_id_is_inline(cid) != 0:
        return -1
    su: uint64 = cast[uint64](cid)
    if chan_pool[su].dev_type != DEV_SOCKETPAIR:
        return -1
    return cast[int64](cast[uint32](chan_pool[su].back_slot))


# Phase 4c (socket fold): DEV_SOCKET I/O + release bodies live in
# fs/vfs.ad (vfs_socket_chan_read / vfs_socket_chan_read_nb /
# vfs_socket_chan_write / vfs_socket_chan_release) because they drive
# the tcp/udp/tls/devnet stacks vfs.ad already imports. vfs imports
# namec, so the calls below resolve BY NAME at the whole-kernel merge
# (the same pattern core.ad uses for namec_close).


def _ext4file_read(slot: uint64, off: uint64, buf: Ptr[uint8],
                   count: uint64) -> int64:
    inum: uint32 = ext4_open_inum(chan_pool[slot].back_slot)
    return ext4_read_file(inum, off, count, buf)


def _ext4file_write(slot: uint64, off: uint64, buf: Ptr[uint8],
                    count: uint64) -> int64:
    return ext4_write_open_file(chan_pool[slot].back_slot, buf, off, count)


def _fatfile_read(slot: uint64, off: uint64, buf: Ptr[uint8],
                  count: uint64) -> int64:
    bs: int32 = chan_pool[slot].back_slot
    if (bs & FAT_CHAN_WRITE_BIT) != 0:
        return -22                                          # -EINVAL: write fd
    first: uint64 = fat_open_first_cluster(bs)
    size:  uint64 = fat_open_size(bs)
    return fat_read(first, size, off, count, buf)


def _fatfile_write(slot: uint64, off: uint64, buf: Ptr[uint8],
                   count: uint64) -> int64:
    bs: int32 = chan_pool[slot].back_slot
    if (bs & FAT_CHAN_WRITE_BIT) == 0:
        return -30                                          # -EROFS: read fd
    return fat_write_slot(bs & 0x7FFFFFFF, buf, off, count)


def _tmpfsfile_read(slot: uint64, off: uint64, buf: Ptr[uint8],
                    count: uint64) -> int64:
    # tmpfs_read returns bytes-actually-read (0 at EOF); it never errors,
    # so the unsigned count maps straight onto the int64 result. The
    # tmpfs entry slot lives in back_slot (mode-agnostic, like ext4).
    n: uint64 = tmpfs_read(chan_pool[slot].back_slot, buf, off, count)
    return cast[int64](n)


def _tmpfsfile_write(slot: uint64, off: uint64, buf: Ptr[uint8],
                     count: uint64) -> int64:
    # tmpfs_write returns bytes actually stored (a short write if a chunk
    # allocation fails or the 16 MiB cap is hit). The inotify IN_MODIFY
    # post stays in fs/vfs.ad's write path (it owns _vfs_inotify_notify).
    n: uint64 = tmpfs_write(chan_pool[slot].back_slot, buf, off, count)
    return cast[int64](n)


def _dirfile_read(slot: uint64, off: uint64, buf: Ptr[uint8],
                  count: uint64) -> int64:
    # Copy bytes out of a DEV_DIR_FILE chan's kmalloc'd "NAME\n" listing
    # buffer (back_ptr) starting at offset `off`, capped at the buffer
    # length (back_slot). This is the RAW-byte reader getdents64 walks
    # through the vfs_fd_dir_* accessors; a direct read(2) on a directory
    # fd is intercepted as -EISDIR before reaching here (the fd layer's
    # FD_CHAN_MARK arm short-circuits DEV_DIR_FILE). Dir fds are READ-ONLY,
    # so there is no _dirfile_write. The per-fd cursor stays in the task's
    # fd_pos — this helper just reads at the caller-supplied offset.
    blen: uint64 = cast[uint64](cast[uint32](chan_pool[slot].back_slot))
    if off >= blen:
        return 0
    remaining: uint64 = blen - off
    take: uint64 = count
    if take > remaining:
        take = remaining
    if take == 0:
        return 0
    src: uint64 = chan_pool[slot].back_ptr + off
    memcpy(buf, cast[Ptr[uint8]](src), take)
    return cast[int64](take)


# --- namec(): the universal open path -------------------------------
#
# Resolve `path` to a Chan. Probe order mirrors Plan 9's namec walk:
#
#   1. The CALLING PROCESS's Pgrp mount table — if `path` falls under
#      a 9P SRV-kind mount prefix, walk+open through the 9P client
#      and produce a DEV_MNT Chan. This is checked FIRST so a mount
#      shadows a same-named local device, exactly like Plan 9.
#
#   2. The local devtab — a well-known /dev/<name> path produces the
#      matching DEV_<kind> Chan.
#
#   3. Miss — return NAMEC_FALLTHROUGH so the VFS caller proceeds to
#      its on-disk (cpio / tmpfs / ext4) routing. namec deliberately
#      does NOT own on-disk files; those are not devtab devices.
#
# Return value: a positive chan-pool slot id on success; the negative
# sentinels below otherwise. The id is opaque to the caller — it is
# stored in the fd's fd_buf and handed straight back to namec_read /
# namec_write / namec_close.

NAMEC_FALLTHROUGH: int32 = -10000     # not a chan; caller falls through
NAMEC_ENOENT:      int32 = -2         # path is a chan but open failed
NAMEC_EMFILE:      int32 = -24        # chan pool exhausted
# F9 #452 namespace-purity sweep: namec resolves /dev/auth through the
# devtab like every other cdev, but the chan is STATEFUL (it needs an
# AuthSlot allocation from devauth's per-fd pool, which lives in
# devauth.ad → fs.vfs → namec; the back-import would cycle). Returning
# this sentinel tells the caller (fs/vfs.ad _namec_open) to run the
# devauth_alloc + namec_open_auth_file pair on the caller's behalf,
# WITHOUT a literal-path `/dev/auth` string match in vfs_open. Once F1
# is in tree this gives /dev/auth the same per-Pgrp namespace gate as
# /dev/cons et al: a process that unbinds `#c` from `/dev` won't see
# `/dev/auth` either (the path won't resolve in its namespace, so
# _devtab_lookup never fires).
NAMEC_NEEDS_AUTH:  int32 = -10001     # devtab match: /dev/auth, caller allocs


def namec(path: Ptr[char], mode: int32) -> int32:
    if chan_pool_inited == 0:
        namec_init()

    # --- (1) per-process mount table: is this a 9P-mounted prefix? ---
    srvfd:      int32 = -1
    root_fid:   int32 = -1
    prefix_len: uint64 = 0
    hit: int32 = chan_find_srv_prefix(
        cast[Ptr[uint8]](path),
        &srvfd, &root_fid, &prefix_len)
    if hit != 0:
        if root_fid < 0:
            # Mount entry exists but its Tattach never completed.
            # The path is genuinely a chan (the user bound it), so
            # report ENOENT rather than fall through to on-disk.
            return NAMEC_ENOENT
        rel: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](path) + prefix_len)
        new_fid: int32 = p9c_walk_open_path(srvfd, root_fid, rel, mode)
        if new_fid < 0:
            return NAMEC_ENOENT
        slot: int32 = _chan_alloc()
        if slot < 0:
            p9c_clunk(srvfd, new_fid)
            return NAMEC_EMFILE
        su: uint64 = cast[uint64](slot)
        chan_pool[su].in_use   = 1
        chan_pool[su].dev_type = DEV_MNT
        chan_pool[su].mode     = mode
        chan_pool[su].srvfd    = srvfd
        chan_pool[su].p9_fid   = new_fid
        return slot

    # --- (2) local devtab: a well-known /dev/<name> ------------------
    # An inline (poolless) chan — the cdev backends are global and
    # stateless, so no pool slot is needed. The id round-trips the
    # device kind directly. The wsys family also carries a wid in
    # the chan id's high bits.
    dev_type: int32 = _devtab_lookup(path)
    if dev_type != DEV_NONE:
        return _chan_id_make_inline(dev_type)

    # --- (2a) stateful-cdev devtab: paths that need per-fd alloc -----
    # F9 #452: /dev/auth is the credential cdev — each open carries its
    # OWN AuthSlot (user/pass/verdict buffers + rate-limit timestamp).
    # The devauth allocator lives in sys/src/9/port/devauth.ad, which
    # imports fs.vfs, which imports THIS module — so we can't call
    # devauth_alloc from namec without a back-import. Instead, signal
    # the caller with NAMEC_NEEDS_AUTH so it runs the alloc + wrap in a
    # DEV_AUTH pool chan via namec_open_auth_file. This is the namespace-
    # pure equivalent of the literal `_path_eq_const(name, "/dev/auth")`
    # arm that USED to live in vfs.ad's vfs_open / vfs_open_write — the
    # match now sits in the devtab alongside the rest of #c/<leaf>, so
    # /dev/auth is subject to the same per-Pgrp `bind '#c' /dev`
    # resolution. F10-1 (#454): keyed on the `#c/auth` server-letter
    # spelling (vfs_open's resolve_path delivers it here in that form;
    # the legacy `/dev/auth` literal arm is gone).
    if _streq(path, "#c/auth") != 0:
        return NAMEC_NEEDS_AUTH
    wid: int32 = 0
    layer: int32 = 0
    dev_type = _devtab_lookup_wsys(path, &wid, &layer)
    if dev_type != DEV_NONE:
        # The per-layer DEV_WSYS_DRAW_* leaves additionally encode the
        # resolved layer slot in the chan id; the listing/ctl/legacy
        # leaves carry layer=0 and use the plain wid-tagged encoder.
        if dev_type >= DEV_WSYS_DRAW_KIND \
                and dev_type <= DEV_WSYS_DRAW_FB:
            return _chan_id_make_inline_wsys_draw(dev_type, wid, layer)
        if dev_type == DEV_WSYS_DRAW_GEN:
            return _chan_id_make_inline_wsys_draw(dev_type, wid, layer)
        return _chan_id_make_inline_wsys(dev_type, wid)

    # --- (3) not a chan — caller falls through to on-disk routing ---
    return NAMEC_FALLTHROUGH


# Scratch for the parent-directory prefix of a create path. 512 bytes
# is ample for a relative package path (the longest in a small Debian
# package, /usr/share/doc/<pkg>/changelog.Debian.gz, is well under
# 100 bytes). Top-level Array per the Adder nested-frame quirk.
_namec_parent_buf: Array[512, uint8]


def _namec_parent_prefix(rel: Ptr[uint8]) -> int32:
    # Copy the bytes of `rel` up to (not including) its final '/' into
    # _namec_parent_buf, NUL-terminated. Returns 1 if there IS a parent
    # prefix (the path has at least one '/'), 0 if the path is a bare
    # leaf (no '/', e.g. "hello") — in which case the parent is the
    # mount root and no mkdir is needed. A leading '/' on `rel` is kept
    # verbatim; p9c_walk_mkdir_path skips it.
    plen: uint64 = 0
    while rel[plen] != 0:
        plen = plen + 1
    last_slash: uint64 = plen
    j: uint64 = 0
    while j < plen:
        if rel[j] == 47:
            last_slash = j
        j = j + 1
    if last_slash == plen:
        return 0                                 # no '/' — bare leaf
    n: uint64 = last_slash
    if n > 511:
        n = 511
    k: uint64 = 0
    while k < n:
        _namec_parent_buf[k] = rel[k]
        k = k + 1
    _namec_parent_buf[k] = 0
    if n == 0:
        return 0                                 # leaf is a root child
    return 1


def namec_create(path: Ptr[char]) -> int32:
    # Create-on-write-open leg. Only the 9P-mounted case is a chan
    # create — local cdevs are not creatable. Walks to the parent and
    # issues Tcreate via the 9P client; produces a DEV_MNT Chan on the
    # new file. NAMEC_FALLTHROUGH means "no mount covers this path".
    if chan_pool_inited == 0:
        namec_init()
    srvfd:      int32 = -1
    root_fid:   int32 = -1
    prefix_len: uint64 = 0
    hit: int32 = chan_find_srv_prefix(
        cast[Ptr[uint8]](path),
        &srvfd, &root_fid, &prefix_len)
    if hit == 0:
        return NAMEC_FALLTHROUGH
    if root_fid < 0:
        return NAMEC_ENOENT
    rel: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](path) + prefix_len)
    # mkdir -p the parent directory chain first: a create of
    # /usr/bin/hello must not fail merely because /usr/bin does not
    # exist yet. _namec_parent_prefix copies the bytes before the final
    # '/' into a scratch buffer; an empty result (leaf is a root child)
    # makes p9c_walk_mkdir_path a no-op. A mkdir failure here is NOT
    # fatal — the create below will surface the real error.
    if _namec_parent_prefix(rel) != 0:
        p9c_walk_mkdir_path(srvfd, root_fid, &_namec_parent_buf[0])
    new_fid: int32 = p9c_walk_create_path(srvfd, root_fid, rel,
                                          0x1B6, 1)        # 0o666, OWRITE
    if new_fid < 0:
        return NAMEC_ENOENT
    slot: int32 = _chan_alloc()
    if slot < 0:
        p9c_clunk(srvfd, new_fid)
        return NAMEC_EMFILE
    su: uint64 = cast[uint64](slot)
    chan_pool[su].in_use   = 1
    chan_pool[su].dev_type = DEV_MNT
    chan_pool[su].mode     = 1                              # OWRITE
    chan_pool[su].srvfd    = srvfd
    chan_pool[su].p9_fid   = new_fid
    return slot


def namec_mkdir(path: Ptr[char]) -> int32:
    # Directory-create leg. Only the 9P-mounted case can mkdir — local
    # cdevs are not directories and the caller (vfs_mkdir) handles
    # tmpfs itself. Walks to the path, creating every missing component
    # as a directory (mkdir -p semantics — see p9c_walk_mkdir_path).
    # NAMEC_FALLTHROUGH means "no 9P mount covers this path"; the caller
    # then falls through to its local-FS mkdir routing.
    if chan_pool_inited == 0:
        namec_init()
    srvfd:      int32 = -1
    root_fid:   int32 = -1
    prefix_len: uint64 = 0
    hit: int32 = chan_find_srv_prefix(
        cast[Ptr[uint8]](path),
        &srvfd, &root_fid, &prefix_len)
    if hit == 0:
        return NAMEC_FALLTHROUGH
    if root_fid < 0:
        return NAMEC_ENOENT
    rel: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](path) + prefix_len)
    rc: int32 = p9c_walk_mkdir_path(srvfd, root_fid, rel)
    if rc < 0:
        return NAMEC_ENOENT
    return 0


# --- the universal operation interface ------------------------------
#
# namec_read / namec_write / namec_close are what a consumer holding a
# Chan id calls. They are the proof of the inversion: the consumer
# does NOT branch on local-vs-mounted. These three functions do — once,
# here — on dev_type, routing a DEV_MNT chan through mountrpc and every
# other chan through the local devtab.

def namec_read(cid: int32, off: uint64, buf: Ptr[uint8],
               count: uint64) -> int64:
    if _chan_id_valid(cid) == 0:
        return -9                                           # -EBADF
    if _chan_id_is_inline(cid) != 0:
        return _devtab_read(_chan_id_inline_dev(cid),
                            _chan_id_inline_wid(cid),
                            _chan_id_inline_layer(cid),
                            off, buf, count)
    su: uint64 = cast[uint64](cid)
    if chan_pool[su].dev_type == DEV_MNT:
        return _mnt_read(su, off, buf, count)
    if chan_pool[su].dev_type == DEV_EXT4_FILE:
        return _ext4file_read(su, off, buf, count)
    if chan_pool[su].dev_type == DEV_FAT_FILE:
        return _fatfile_read(su, off, buf, count)
    if chan_pool[su].dev_type == DEV_TMPFS_FILE:
        return _tmpfsfile_read(su, off, buf, count)
    if chan_pool[su].dev_type == DEV_DIR_FILE:
        return _dirfile_read(su, off, buf, count)
    if chan_pool[su].dev_type == DEV_BUF_FILE:
        # Phase 4b: a snapshot-buffer chan is byte-identical to a dir
        # chan at read time (back_ptr + back_slot length) — share the
        # ptr-backed reader.
        return _dirfile_read(su, off, buf, count)
    if chan_pool[su].dev_type == DEV_PROC:
        # Phase 4b: /proc/<pid>/<leaf>. back_slot carries the devproc
        # (pid << 8 | kind) encoding; devproc_read re-validates the pid
        # and renders the whole snapshot on the off==0 read (EOF after),
        # so `cat /proc/<pid>/status` terminates. Called by NAME —
        # devproc.ad imports namec, so importing back would cycle.
        return devproc_read(cast[uint32](chan_pool[su].back_slot),
                            off, buf, count)
    if chan_pool[su].dev_type == DEV_AUTH:
        # Phase 4b: /dev/auth read side — drain the rendered
        # "ok <uid> <gid>\n" / "denied\n" verdict. devauth_read keeps its
        # own response_pos cursor inside the AuthSlot, so the chan-level
        # `off` is deliberately ignored (vfs advances fd_pos harmlessly).
        # Called by NAME — devauth.ad imports fs.vfs imports namec, so
        # importing devauth here would cycle.
        return devauth_read(chan_pool[su].back_slot, buf, count)
    if chan_pool[su].dev_type == DEV_BLK:
        # Phase 4b: /dev/blk/<name>{,/size} read. back_ptr carries the
        # devblk (mode << 32 | slot) pack; off is the RAW-mode byte
        # cursor (vfs advances fd_pos on return). By-name call (devblk
        # sits below vfs in the import graph).
        return devblk_read(chan_pool[su].back_ptr, off, buf, count)
    if chan_pool[su].dev_type == DEV_PIPE_R:
        # Phase 4c (pipe fold): blocking pipe read — the event-driven
        # two-phase WaitQueue sleep lives in fs/pipe.ad. Stream-shaped:
        # off is ignored (vfs advances fd_pos harmlessly). EOF (all
        # writers gone) is 0; a signal wake is -EINTR.
        return pipe_read_blocking(chan_pool[su].back_slot, buf, count)
    if chan_pool[su].dev_type == DEV_PIPE_W:
        return -9                          # -EBADF: can't read a write end
    if chan_pool[su].dev_type == DEV_SOCKET:
        # Phase 4c (socket fold): the verbatim legacy FD_SOCKET_MARK
        # read body (UDP datagram / TCP stream / TLS record dispatch)
        # lives in fs/vfs.ad — called BY NAME (vfs imports namec).
        # Stream-shaped: off ignored.
        return vfs_socket_chan_read(
            cast[uint64](cast[uint32](chan_pool[su].back_slot)),
            buf, count)
    if chan_pool[su].dev_type == DEV_NET:
        # Phase 4d (net fold, F7 #390): the verbatim legacy
        # FD_NET_MARK read body (clone-snapshot text / status / local /
        # remote / addr / dns / dns_lookup / dns_rlookup / ctl-accept
        # snapshot + TCP/UDP/TLS data stream) lives in fs/vfs.ad —
        # called BY NAME (vfs imports namec). `off` matters here: the
        # snapshot-shape leaves use it to EOF-terminate `cat` on a
        # second read, just like the legacy mark arm consulted
        # task.fd_pos[fdu].
        return vfs_net_chan_read(
            cast[uint64](cast[uint32](chan_pool[su].back_slot)),
            off, buf, count)
    if chan_pool[su].dev_type == DEV_SOCKETPAIR:
        # Phase 4c (socket fold): blocking bidirectional read — the
        # verbatim legacy FD_SOCKETPAIR_MARK yield loop lives in
        # fs/socketpair.ad (sockpair_read_blocking): bytes when they
        # arrive, 0 (EOF) once the peer end is gone.
        return sockpair_read_blocking(
            sockpair_unpack_slot(
                cast[uint64](cast[uint32](chan_pool[su].back_slot))),
            sockpair_unpack_dir(
                cast[uint64](cast[uint32](chan_pool[su].back_slot))),
            buf, count)
    if chan_pool[su].dev_type == DEV_PTMX:
        # Phase 4e (PTY fold, F7 #390): the verbatim legacy FD_PTMX_MARK
        # read body (master read drains slave-output / s2m queue; slave
        # read runs the cooked/raw line discipline over the master-write
        # queue / m2s; both block-yield until bytes are available or the
        # peer end closes for EOF) lives in fs/vfs.ad — called BY NAME
        # (vfs imports namec). Stream-shaped: off ignored (a tty has no
        # cursor — see the lseek EINVAL arm in vfs_lseek).
        return vfs_ptmx_chan_read(
            cast[uint64](cast[uint32](chan_pool[su].back_slot)),
            buf, count)
    if chan_pool[su].dev_type == DEV_FUSE_CONN:
        # Phase 4f (FUSE fold, F7 #390): /dev/fuse read side — the
        # daemon drains one queued fuse_in request via fuse_dev_read
        # (the hook-dispatched body lives in fs/vfs.ad as
        # vfs_fuse_conn_chan_read, the verbatim port of the legacy
        # FD_FUSE_CONN_MARK arm). Stream-shaped: off ignored.
        return vfs_fuse_conn_chan_read(chan_pool[su].back_slot,
                                       cast[uint64](buf), count)
    if chan_pool[su].dev_type == DEV_FUSE_FILE:
        # Phase 4f (FUSE fold, F7 #390): a FUSE-served file's read drives
        # FUSE_READ over the wire — body lives in fs/vfs.ad as
        # vfs_fuse_file_chan_read. The legacy FD_FUSE_FILE_MARK arm
        # didn't consult fd_pos either (fuse_vfs_read maintains its
        # own per-token position cursor), so off is ignored here too.
        return vfs_fuse_file_chan_read(chan_pool[su].back_slot,
                                       buf, count)
    return _devtab_read(chan_pool[su].dev_type, 0, 0, off, buf, count)


def namec_read_nb(cid: int32, off: uint64, buf: Ptr[uint8],
                  count: uint64) -> int64:
    # Non-blocking sibling of namec_read backing SYS_READ_NB on an
    # FD_CHAN_MARK fd. Only DEV_CONS has a blocking read body
    # (devcons_read parks until a byte arrives); every other devtab cdev
    # is a stateless snapshot that returns immediately, so they delegate
    # to the ordinary namec_read. /dev/cons is routed to the dedicated
    # devcons_read_nb so an event-loop daemon (hamUId) can poll keystrokes
    # without wedging its compositor.
    if _chan_id_valid(cid) == 0:
        return -9                                           # -EBADF
    if _chan_id_is_inline(cid) != 0:
        idev: int32 = _chan_id_inline_dev(cid)
        if idev == DEV_CONS:
            return devcons_read_nb(buf, count)
        # hamUI per-window input streams (/dev/wsys/<wid>/keys|pointer)
        # are BLOCKING by default (devwsys_keys_read parks on the per-wid
        # wait queue when the ring is empty). A separate-process GUI
        # client polling its own routed-input stream from a single-
        # threaded event loop (user/hamecho.ad) must NOT park, or an empty
        # ring wedges the whole app. Route SYS_READ_NB to the non-blocking
        # variants that return 0 ("no event yet") instead of sleeping.
        if idev == DEV_WSYS_KEYS:
            return devwsys_keys_read_nb(_chan_id_inline_wid(cid), buf, count)
        if idev == DEV_WSYS_POINTER:
            return devwsys_pointer_read_nb(_chan_id_inline_wid(cid),
                                           buf, count)
        if idev == DEV_DEVFD:
            # Phase 4c: non-blocking `#d/<N>` read. devfd_read_nb routes
            # a CONS backing to devcons_read_nb (0 = would-block), a
            # pipe-R backing to the non-blocking pipe_read with the
            # EOF-vs-would-block split (-1 when all writers are gone),
            # and file backings to the already-non-blocking cursor read.
            return devfd_read_nb(pgrp_current(),
                                 _chan_id_inline_wid(cid), buf, count)
        return namec_read(cid, off, buf, count)
    su: uint64 = cast[uint64](cid)
    if chan_pool[su].dev_type == DEV_CONS:
        return devcons_read_nb(buf, count)
    if chan_pool[su].dev_type == DEV_PIPE_R:
        # Phase 4c (pipe fold): non-blocking pipe read. pipe_read is
        # already non-blocking at the fs/pipe.ad layer; 0 there means
        # "empty right now". Distinguish a closed pipe (no writers
        # left) as a true EOF (-1) — the legacy FD_PIPE_MARK_R
        # vfs_read_nb contract.
        np: int64 = pipe_read(chan_pool[su].back_slot, buf, count)
        if np > 0:
            return np
        if pipe_writers(chan_pool[su].back_slot) == 0:
            return -1                      # true EOF
        return 0                           # would-block
    if chan_pool[su].dev_type == DEV_SOCKET:
        # Phase 4c (socket fold): non-blocking socket read — the
        # verbatim legacy FD_SOCKET_MARK vfs_read_nb body (queued-UDP-
        # datagram / connected-TCP rx-ring probe) lives in fs/vfs.ad,
        # called BY NAME. A socketpair chan has no nb contract (the
        # legacy mark had no read_nb arm either) and falls through to
        # the blocking namec_read below — preserved verbatim.
        return vfs_socket_chan_read_nb(
            cast[uint64](cast[uint32](chan_pool[su].back_slot)),
            buf, count)
    if chan_pool[su].dev_type == DEV_NET:
        # Phase 4d (net fold, F7 #390): non-blocking /net read — only
        # the DATA file has a would-block notion (the legacy
        # FD_NET_MARK vfs_read_nb arm). Snapshot leaves (clone /
        # status / local / remote / etc.) delegate to the blocking
        # namec_read below, exactly as the legacy mark arm delegated
        # to vfs_read.
        return vfs_net_chan_read_nb(
            cast[uint64](cast[uint32](chan_pool[su].back_slot)),
            off, buf, count)
    return namec_read(cid, off, buf, count)


def namec_poll_readable(cid: int32) -> int32:
    # SYS_WAITFDS readiness probe for an FD_CHAN_MARK fd. Non-
    # destructive — consumes nothing. Returns:
    #   1  ready: a read would return data right now (or immediately,
    #      for snapshot cdevs whose reads never block)
    #   0  not ready, AND the producer is wired to waitfds_notify() so
    #      a blocked vfs_waitfds will be woken on the readiness edge
    #   2  not ready, NO wake wiring (producer lives outside the
    #      notify mesh — e.g. the PS/2 mouse IRQ); the caller must cap
    #      its sleep slice (1 jiffy) so the fd is re-probed promptly.
    if _chan_id_valid(cid) == 0:
        return 1                       # error surfaces on the read itself
    if _chan_id_is_inline(cid) != 0:
        idev: int32 = _chan_id_inline_dev(cid)
        if idev == DEV_CONS:
            # Wake-wired: console_input_wake() (UART IRQ, kbd push, wsys
            # cmd inject, timer-tick belt-and-braces) kicks waitfds.
            if devcons_poll_readable() != 0:
                return 1
            return 0
        if idev == DEV_WSYS_POINTER:
            # Wake-wired: devwsys_pointer_write calls waitfds_notify().
            if wsys_pointer_pending(_chan_id_inline_wid(cid)) != 0:
                return 1
            return 0
        if idev == DEV_WSYS_KEYS:
            # Wake-wired: devwsys_keys_write calls waitfds_notify().
            if wsys_keys_pending(_chan_id_inline_wid(cid)) != 0:
                return 1
            return 0
        if idev == DEV_MOUSE:
            # PS/2 aux ring probe. The producer IRQ path (drivers/input)
            # has no waitfds hook, so an empty ring is class-2: the
            # waiter re-probes at jiffy granularity (and the per-tick
            # console_input_wake also re-kicks the queue each 10ms).
            if mouse_rx_has() != 0:
                return 1
            return 2
        if idev == DEV_DEVFD:
            # Phase 4c: an `#d/<N>` fd delegates to the UNDERLYING
            # backing channel's poll state — a CONS backing probes the
            # console rings (wake-wired via console_input_wake), a
            # pipe-R backing probes ring bytes / writer EOF (wake-wired
            # via pipe_write / pipe_close_writer → waitfds_notify), and
            # file/unbound backings are always-ready. Without this arm
            # a /fd/N poll would silently regress to always-ready.
            return devfd_poll_readable(pgrp_current(),
                                       _chan_id_inline_wid(cid))
        # Every other inline cdev read is a non-blocking snapshot
        # (procfs-style render-on-read) — always "ready".
        return 1
    # Phase 4c (pipe fold): pipe-end pool chans have REAL readiness.
    pdt: int32 = chan_pool[cast[uint64](cid)].dev_type
    if pdt == DEV_PIPE_R:
        # Ready when bytes are queued OR every writer is gone (EOF is
        # readable). Otherwise class 0 — the producers (pipe_write,
        # pipe_close_writer) are wired to waitfds_notify(). Without
        # this arm a folded pipe fd would regress to always-ready and
        # vfs_waitfds would busy-spin on an empty pipe.
        pslot: int32 = chan_pool[cast[uint64](cid)].back_slot
        if pipe_readable(pslot) != 0:
            return 1
        if pipe_writers(pslot) == 0:
            return 1                       # EOF is readable
        return 0                           # pipe_write/close wired
    if pdt == DEV_PIPE_W:
        # Read-readiness probe on a WRITE end: only an all-readers-gone
        # error state makes a read-shaped wait return (the legacy
        # fallback surfaced POLLERR as "ready"). No producer wakes a
        # write end's read-wait — class 2, jiffy re-probe.
        if pipe_readers(chan_pool[cast[uint64](cid)].back_slot) == 0:
            return 1                       # POLLERR — surfaces on use
        return 2
    if pdt == DEV_SOCKETPAIR:
        # Phase 4c (socket fold): honest sockpair readiness. Bytes
        # queued for OUR end, or peer gone (EOF readable) → ready. The
        # sockpair producer (sockpair_write) is NOT wired into
        # waitfds_notify (it predates the WaitQueue mesh and its
        # consumers block in sockpair_read_blocking's yield loop), so
        # an empty ring is class 2 — jiffy re-probe. The legacy mark
        # never reached vfs_waitfds_probe's mark ladder and regressed
        # to always-ready; this arm strictly improves on that.
        sp_pk: uint64 = cast[uint64](
            cast[uint32](chan_pool[cast[uint64](cid)].back_slot))
        if sockpair_readable(sockpair_unpack_slot(sp_pk),
                             sockpair_unpack_dir(sp_pk)) != 0:
            return 1
        if sockpair_peer_alive(sockpair_unpack_slot(sp_pk),
                               sockpair_unpack_dir(sp_pk)) == 0:
            return 1                       # peer closed — EOF readable
        return 2
    # Pool chans (9P mounts, ext4/fat/tmpfs files, dirs): reads complete
    # without parking on a waitqueue — treat as always ready. DEV_SOCKET
    # keeps this answer too — the legacy FD_SOCKET_MARK fd never had a
    # waitfds probe arm (poll(2) readiness rides vfs_fd_poll's real
    # tcp/udp bits, a separate path); preserving "always ready" here is
    # the representation-only contract.
    return 1


def namec_write(cid: int32, off: uint64, buf: Ptr[uint8],
                count: uint64) -> int64:
    if _chan_id_valid(cid) == 0:
        return -9                                           # -EBADF
    if _chan_id_is_inline(cid) != 0:
        return _devtab_write(_chan_id_inline_dev(cid),
                             _chan_id_inline_wid(cid),
                             _chan_id_inline_layer(cid),
                             off, buf, count)
    su: uint64 = cast[uint64](cid)
    if chan_pool[su].dev_type == DEV_MNT:
        return _mnt_write(su, off, buf, count)
    if chan_pool[su].dev_type == DEV_EXT4_FILE:
        return _ext4file_write(su, off, buf, count)
    if chan_pool[su].dev_type == DEV_FAT_FILE:
        return _fatfile_write(su, off, buf, count)
    if chan_pool[su].dev_type == DEV_TMPFS_FILE:
        return _tmpfsfile_write(su, off, buf, count)
    if chan_pool[su].dev_type == DEV_BUF_FILE:
        # Phase 4b: render-once snapshot fds (procfs / cgroup2 / node
        # sysfs) are read-only — Linux answers EROFS/EIO for most /proc
        # writes; the legacy FD_BUFFER_MARK write arm said -EROFS too.
        return -30                                          # -EROFS
    if chan_pool[su].dev_type == DEV_PROC:
        # Phase 4b: /proc/<pid>/{note,notepg,ctl} are WRITE-able control
        # surfaces (Plan 9 note delivery / process control); devproc_write
        # decodes pid+kind from the encoding and rejects everything else
        # with -1 + errstr. Called by name (no import — cycle).
        return devproc_write(cast[uint32](chan_pool[su].back_slot),
                             buf, count)
    if chan_pool[su].dev_type == DEV_AUTH:
        # Phase 4b: /dev/auth write side — "user <name>\n" /
        # "pass <plaintext>\n" / "setpass ..." lines parsed into the
        # AuthSlot; the verify + rate-limit (1 attempt/sec) live inside
        # devauth_write. Stream-shaped: off ignored. By-name call (cycle).
        return devauth_write(chan_pool[su].back_slot, buf, count)
    if chan_pool[su].dev_type == DEV_BLK:
        # Phase 4b: /dev/blk/<name>{,/ctl} write. RAW writes are
        # sector-addressed at off; CTL writes parse a format/partition
        # verb; SIZE writes are rejected inside devblk_write.
        return devblk_write(chan_pool[su].back_ptr, off, buf, count)
    if chan_pool[su].dev_type == DEV_PIPE_W:
        # Phase 4c: pipe write end. Blocking ring write — the verbatim
        # port of the legacy vfs FD_PIPE_MARK_W arm lives in fs/pipe.ad
        # (pipe_write_blocking): EPIPE when no readers remain, partial
        # count honored, yield while the ring is full. Stream-shaped:
        # off ignored (a pipe has no cursor).
        return pipe_write_blocking(chan_pool[su].back_slot, buf, count)
    if chan_pool[su].dev_type == DEV_PIPE_R:
        # Writing the READ end of a pipe is a bad fd, same answer the
        # legacy FD_PIPE_MARK_R write arm gave.
        return -9                                           # -EBADF
    if chan_pool[su].dev_type == DEV_SOCKET:
        # Phase 4c (socket fold): the verbatim legacy FD_SOCKET_MARK
        # write body (UDP sendto-peer / TCP MSS-chunked drain / TLS
        # record chunking) lives in fs/vfs.ad — called BY NAME.
        return vfs_socket_chan_write(
            cast[uint64](cast[uint32](chan_pool[su].back_slot)),
            buf, count)
    if chan_pool[su].dev_type == DEV_SOCKETPAIR:
        # Phase 4c (socket fold): bidirectional write into the peer's
        # ring — the verbatim legacy FD_SOCKETPAIR_MARK arm lives in
        # fs/socketpair.ad (sockpair_write_blocking): EPIPE once the
        # peer end is gone, yield while the ring is full.
        return sockpair_write_blocking(
            sockpair_unpack_slot(
                cast[uint64](cast[uint32](chan_pool[su].back_slot))),
            sockpair_unpack_dir(
                cast[uint64](cast[uint32](chan_pool[su].back_slot))),
            buf, count)
    if chan_pool[su].dev_type == DEV_NET:
        # Phase 4d (net fold, F7 #390): the verbatim legacy
        # FD_NET_MARK write body (data-file TCP send / TLS record
        # chunking / ctl command parse / dns + ipifc host-level
        # writes) lives in fs/vfs.ad — called BY NAME.
        return vfs_net_chan_write(
            cast[uint64](cast[uint32](chan_pool[su].back_slot)),
            buf, count)
    if chan_pool[su].dev_type == DEV_PTMX:
        # Phase 4e (PTY fold, F7 #390): the verbatim legacy FD_PTMX_MARK
        # write body (master write feeds the slave's input queue / m2s
        # — the bytes the terminal "types"; slave write feeds the
        # master's read queue / s2m — the program's output, OPOST|ONLCR
        # applied) lives in fs/vfs.ad — called BY NAME. Stream-shaped:
        # off ignored.
        return vfs_ptmx_chan_write(
            cast[uint64](cast[uint32](chan_pool[su].back_slot)),
            buf, count)
    if chan_pool[su].dev_type == DEV_FUSE_CONN:
        # Phase 4f (FUSE fold, F7 #390): /dev/fuse write side — the
        # daemon submits a fuse_out reply; body lives in fs/vfs.ad as
        # vfs_fuse_conn_chan_write (the verbatim port of the legacy
        # FD_FUSE_CONN_MARK arm). Stream-shaped: off ignored.
        return vfs_fuse_conn_chan_write(chan_pool[su].back_slot,
                                        cast[uint64](buf), count)
    if chan_pool[su].dev_type == DEV_FUSE_FILE:
        # The legacy FD_FUSE_FILE_MARK had no write arm in vfs_write —
        # a FUSE-served file falls into vfs_write's EROFS fall-through.
        # Preserve that contract here so a write through namec_write
        # returns the same errno the legacy mark arm did.
        return -30                                          # -EROFS
    return _devtab_write(chan_pool[su].dev_type, 0, 0, off, buf, count)


def namec_close(cid: int32) -> int32:
    # Release one reference to a Chan. An inline cdev chan has no
    # allocated state, so close is a no-op success. A pool chan is
    # refcounted (fork/dup bumped the count via namec_chan_ref): this
    # DECREMENTS, and only the LAST reference runs the dev_type release
    # and frees the slot. That makes both explicit-close (vfs_close) and
    # exit-cleanup (close_fd_in_task → namec_close) share ONE release
    # path with no double-free.
    #
    #   * DEV_MNT  — clunk the 9P fid so the server reclaims it.
    #   * (future stateful families key their backing-slot release here
    #     by dev_type, e.g. tmpfs_release_anon(back_slot).)
    if _chan_id_valid(cid) == 0:
        return -9                                           # -EBADF
    if _chan_id_is_inline(cid) != 0:
        return 0
    su: uint64 = cast[uint64](cid)
    # Drop one reference. Not the last? leave the chan live for the
    # other holders (a forked/dup'd fd).
    if chan_pool[su].refcount > 1:
        chan_pool[su].refcount = chan_pool[su].refcount - 1
        return 0
    # Last reference — run the per-dev_type backing release, then free.
    if chan_pool[su].dev_type == DEV_MNT:
        p9c_clunk(chan_pool[su].srvfd, chan_pool[su].p9_fid)
    elif chan_pool[su].dev_type == DEV_EXT4_FILE:
        # Release the ext4 open-file slot. ext4_close clears the slot's
        # `used` flag; the inum/size snapshot is recycled with it.
        ext4_close(chan_pool[su].back_slot)
    elif chan_pool[su].dev_type == DEV_FAT_FILE:
        # Release the FAT slot. fat_close peels FAT_WRITE_SLOT_BIT and
        # routes a write-mode word to the write-slot table, a read word
        # to the read open-file table — so the RAW back_slot word is
        # exactly what it expects.
        fat_close(chan_pool[su].back_slot)
    elif chan_pool[su].dev_type == DEV_TMPFS_FILE:
        # tmpfs has TWO release flavours (ported from the legacy
        # FD_TMPFS_MARK close arm in fs/vfs.ad). A NAMED /tmp,/var file
        # persists by path — its slot is owned by the tree, so closing
        # the last fd frees NO slot. An ANONYMOUS memfd file is reachable
        # ONLY through its open fds (no path), so the last close must
        # reclaim the slot via tmpfs_release_anon. tmpfs_is_anon keys the
        # two apart on the same back_slot.
        if tmpfs_is_anon(chan_pool[su].back_slot) != 0:
            tmpfs_release_anon(chan_pool[su].back_slot)
    elif chan_pool[su].dev_type == DEV_DIR_FILE \
            or chan_pool[su].dev_type == DEV_BUF_FILE:
        # fd→Chan fold: a directory listing fd's kmalloc'd "NAME\n" buffer
        # rides in back_ptr (ported from the legacy FD_DIR_MARK close arm
        # in kernel/sched/core.ad). The buffer is shared by every fd that
        # forked/dup'd this chan (refcounted), so only the LAST close frees
        # it — exactly the leak the fold removes for dir fds. Phase 4b:
        # DEV_BUF_FILE (procfs/cgroup/node snapshot buffers, ex-
        # FD_BUFFER_MARK) carries its kmalloc'd render the same way and
        # shares this kfree-on-last-ref release.
        if chan_pool[su].back_ptr != 0:
            kfree(chan_pool[su].back_ptr)
    elif chan_pool[su].dev_type == DEV_AUTH:
        # Phase 4b: return the AuthSlot to the devauth pool. devauth_close
        # zeroes the pass_buf so plaintext doesn't linger in kernel memory
        # past the last fd's lifetime. Because this runs on the LAST
        # reference only, a fork/dup'd auth fd no longer yanks the slot
        # out from under its sibling (the legacy FD_AUTH_MARK close arm
        # freed on the FIRST close), and a task that exits holding the fd
        # reaches here through close_fd_in_task — the legacy exit path
        # leaked the slot outright. By-name call (import cycle).
        devauth_close(chan_pool[su].back_slot)
    elif chan_pool[su].dev_type == DEV_PIPE_R:
        # Phase 4c: drop the read-end reference this chan OWNS. Because
        # the chan itself is refcounted (fork/dup → namec_chan_ref), the
        # pipe's readers count stays 1 per chan, and only the LAST fd
        # holder reaches here — fixing the legacy model where every fd
        # copy bumped pipe readers directly. pipe_close_reader wakes any
        # blocked writer so it can see EPIPE.
        pipe_close_reader(chan_pool[su].back_slot)
    elif chan_pool[su].dev_type == DEV_PIPE_W:
        # Phase 4c: last write-end fd gone — pipe_close_writer wakes the
        # read_wq (EOF becomes readable) and pokes waitfds_notify so a
        # parked poller re-probes; the pipe slot is reclaimed when both
        # end counts hit zero (_maybe_free).
        pipe_close_writer(chan_pool[su].back_slot)
    elif chan_pool[su].dev_type == DEV_SOCKET:
        # Phase 4c (socket fold): the FULL socket teardown (UDP slot
        # close / TLS close_notify / /net conn unref / TCP FIN /
        # usock_free) lives in ONE place now — fs/vfs.ad's
        # vfs_socket_chan_release, called BY NAME. The legacy model
        # kept two duplicate copies (vfs_close's FD_SOCKET_MARK arm +
        # close_fd_in_task's by-name clone) that had to stay in
        # lockstep; both are deleted in favour of this single arm,
        # which fires on the LAST chan reference only (a dup'd /
        # forked socket fd no longer FINs the connection on the FIRST
        # close — the legacy release-on-first-close bug).
        vfs_socket_chan_release(
            cast[uint64](cast[uint32](chan_pool[su].back_slot)))
    elif chan_pool[su].dev_type == DEV_SOCKETPAIR:
        # Phase 4c (socket fold): drop the END-reference this chan
        # OWNS. fork/dup bump the chan refcount (one end-ref per
        # CHAN), so only the last holder reaches here — replacing the
        # legacy hand-rolled inc/dec in vfs_dup/vfs_dup2/vfs_close and
        # FIXING the two latent leaks: task-exit cleanup never
        # decremented sockpair refs, and spawn fd-copies never
        # incremented them.
        sockpair_close(
            sockpair_unpack_slot(
                cast[uint64](cast[uint32](chan_pool[su].back_slot))),
            sockpair_unpack_dir(
                cast[uint64](cast[uint32](chan_pool[su].back_slot))))
    elif chan_pool[su].dev_type == DEV_NET:
        # Phase 4d (net fold, F7 #390): drop the CONN-reference this
        # chan OWNS. fork/dup bump the chan refcount, so the conn ref
        # is held ONE-PER-CHAN and only the last holder reaches here
        # — fixing the legacy model where copy_fd_entry never bumped
        # the conn refcount (core.ad knew nothing of FD_NET_MARK) so
        # the first close FIN-tore the conn out from under any
        # surviving dup. devnet_conn_unref is the verbatim legacy
        # close-arm call; the conn==-1 host-level leaves (NET_FILE_ADDR,
        # NET_FILE_DNS, NET_FILE_DNS_LOOKUP, NET_FILE_DNS_RLOOKUP,
        # NET_FILE_IPIFC_CTL) hold no conn ref, so the unref body in
        # vfs_net_chan_release short-circuits on a -1 conn.
        vfs_net_chan_release(
            cast[uint64](cast[uint32](chan_pool[su].back_slot)))
    elif chan_pool[su].dev_type == DEV_PTMX:
        # Phase 4e (PTY fold, F7 #390): drop the END-reference (master
        # or slave) this chan OWNS. fork/dup bump the chan refcount, so
        # the per-end ref is held ONE-PER-CHAN and only the last holder
        # reaches here — replacing the legacy V5 model where vfs_close
        # AND close_fd_in_task each had a parallel FD_PTMX_MARK arm that
        # had to stay in lockstep. vfs_ptmx_chan_release decodes the
        # back_slot pack and routes to pty_master_unref / pty_slave_unref
        # through the registered hooks (a pure-native build with no PTY
        # layer bound short-circuits — no FD_CHAN_MARK / DEV_PTMX chan
        # can be created there anyway).
        vfs_ptmx_chan_release(
            cast[uint64](cast[uint32](chan_pool[su].back_slot)))
    elif chan_pool[su].dev_type == DEV_FUSE_CONN:
        # Phase 4f (FUSE fold, F7 #390): release the /dev/fuse conn slot.
        # vfs_fuse_conn_chan_release dispatches the hook-bound
        # fuse_dev_close (a no-op when the FUSE layer isn't loaded).
        # Routing through namec_close on the LAST chan reference means
        # a task that EXITS holding a /dev/fuse fd no longer leaks its
        # conn slot — the legacy FD_FUSE_CONN_MARK arm only ran from
        # vfs_close (close_fd_in_task knew nothing of the mark).
        vfs_fuse_conn_chan_release(chan_pool[su].back_slot)
    elif chan_pool[su].dev_type == DEV_FUSE_FILE:
        # Phase 4f (FUSE fold, F7 #390): release a FUSE-served open file.
        # vfs_fuse_file_chan_release drives FUSE_RELEASE over the wire
        # (the hook is fuse_vfs_close). Same exit-leak fix as DEV_FUSE_CONN.
        vfs_fuse_file_chan_release(chan_pool[su].back_slot)
    _chan_free(cid)
    return 0


def namec_chan_ref(cid: int32) -> int32:
    # fork/dup hook: bump a pool chan's refcount so a copied fd shares
    # the SAME backing resource and the FIRST namec_close doesn't yank
    # it out from under the other holder. An inline cdev chan carries no
    # state, so referencing it is a no-op (the id round-trips verbatim).
    # Returns 0 on success, -9 (-EBADF) on an invalid id.
    if _chan_id_valid(cid) == 0:
        return -9
    if _chan_id_is_inline(cid) != 0:
        return 0
    su: uint64 = cast[uint64](cid)
    chan_pool[su].refcount = chan_pool[su].refcount + 1
    return 0


# --- introspection / debug ------------------------------------------

def namec_chan_dev_type(cid: int32) -> int32:
    # The DEV_* kind a chan id resolves to. DEV_NONE for an invalid
    # id. Used by tests to assert a /dev/<name> open went through
    # namec (dev_type in 1..14) vs. a 9P open (dev_type == DEV_MNT).
    if _chan_id_valid(cid) == 0:
        return DEV_NONE
    if _chan_id_is_inline(cid) != 0:
        return _chan_id_inline_dev(cid)
    return chan_pool[cast[uint64](cid)].dev_type


def namec_chan_is_mounted(cid: int32) -> int32:
    # 1 iff this chan is backed by a mounted 9P server (DEV_MNT).
    # The consumer never needs this — namec_read/write hide it — but
    # the e2e test uses it to PROVE a mounted server was opened and
    # read through namec with no FD_<NAME>_MARK in the path.
    if _chan_id_valid(cid) == 0:
        return 0
    if _chan_id_is_inline(cid) != 0:
        return 0
    if chan_pool[cast[uint64](cid)].dev_type == DEV_MNT:
        return 1
    return 0


def namec_chan_is_pool(cid: int32) -> int32:
    # 1 iff `cid` names a live POOL chan (allocated slot, refcounted),
    # as opposed to an inline cdev chan (stateless, no slot). The fd
    # layer's exit-cleanup uses this to decide whether an FD_CHAN_MARK
    # fd needs a namec_close release at all.
    if _chan_id_valid(cid) == 0:
        return 0
    if _chan_id_is_inline(cid) != 0:
        return 0
    return 1


def namec_chan_back_slot(cid: int32) -> int32:
    # The family backing-table slot id a pool chan carries (a tmpfs
    # slot, an ext4 open-file slot, ...). -1 for an inline cdev chan,
    # an invalid id, or a pool chan with no backing slot (DEV_MNT uses
    # srvfd/p9_fid instead). Stateful families recover their backing
    # handle through this so the per-fd dispatch (read/write/lseek/
    # fstat) can reach the right backend entry.
    if _chan_id_valid(cid) == 0:
        return -1
    if _chan_id_is_inline(cid) != 0:
        return -1
    return chan_pool[cast[uint64](cid)].back_slot


def namec_chan_back_ptr(cid: int32) -> uint64:
    # The family backing POINTER a ptr-backed pool chan carries. Today only
    # DEV_DIR_FILE uses it (the kmalloc'd "NAME\n" listing buffer); every
    # other family leaves back_ptr 0. 0 for an inline cdev chan, an invalid
    # id, or a pool chan with no backing pointer. The fd layer's getdents64
    # accessor (vfs_fd_dir_buf) recovers a folded dir fd's buffer through
    # this, mirroring how vfs_fd_tmpfs_slot recovers a tmpfs slot via
    # namec_chan_back_slot.
    if _chan_id_valid(cid) == 0:
        return 0
    if _chan_id_is_inline(cid) != 0:
        return 0
    return chan_pool[cast[uint64](cid)].back_ptr


# --- F10-6 followup: per-Chan p9_dir_mode flag --------------------
#
# A directory fd carries its "Dir-record opt-in" as a per-pool-chan
# bit. Default OFF: the legacy NAME\n line-stream reads run unchanged
# for every caller that hasn't asked to opt in (ls without -l, du
# pre-migration, getdents64, the old SYS_LISTDIR shape that vfs.ad
# still backs through DEV_DIR_FILE — all unaffected). The userspace
# opt-in path is SYS_CHAN_DIR_MODE(fd, 1) which lands here.
#
# Why a chan flag (not a separate dev_type): the Dir-record reader is
# the SAME byte-copy-from-back_ptr path _dirfile_read already runs;
# the difference is which encoding the back_ptr buffer holds. So the
# minimal additional state is a single bit + a one-shot transform on
# the buffer.

def namec_chan_set_p9_dir_mode(cid: int32, mode: int32) -> int32:
    # Set the per-Chan Dir-record-mode flag. Only DEV_DIR_FILE pool
    # chans accept it (other dev_types ignore the call and return -1).
    # Returns 0 on success, -1 if the chan isn't a DEV_DIR_FILE pool
    # entry. The transform of back_ptr (NAME\n -> Dir records) is done
    # lazily on the next _dirfile_read after this flag flips; the
    # caller doesn't need to provide the parent-path here — the
    # SYS_CHAN_DIR_MODE arm passes the path it has in hand into the
    # transform helper directly.
    if _chan_id_valid(cid) == 0:
        return -1
    if _chan_id_is_inline(cid) != 0:
        return -1
    su: uint64 = cast[uint64](cid)
    if chan_pool[su].dev_type != DEV_DIR_FILE:
        return -1
    if mode != 0 and mode != 1:
        return -1
    chan_pool[su].p9_dir_mode = mode
    return 0


def namec_chan_get_p9_dir_mode(cid: int32) -> int32:
    # 1 iff this pool chan is in Dir-record mode. 0 for any
    # non-DEV_DIR_FILE chan, an invalid id, or an inline cdev chan.
    if _chan_id_valid(cid) == 0:
        return 0
    if _chan_id_is_inline(cid) != 0:
        return 0
    return chan_pool[cast[uint64](cid)].p9_dir_mode


def namec_chan_set_back_ptr(cid: int32, new_ptr: uint64,
                            new_len: int32) -> int32:
    # F10-6 followup: replace a pool chan's back_ptr / back_slot pair
    # atomically. Used by the dir-mode transform: a freshly-encoded
    # Dir-record buffer takes over the slot the NAME\n listing held;
    # the caller kfree's the OLD pointer after this returns (the chan
    # close path only kfree's whatever it sees in back_ptr at close
    # time). Returns 0 on success, -1 if the chan isn't a live pool
    # entry. Restricted to DEV_DIR_FILE / DEV_BUF_FILE chans (the two
    # ptr-backed families).
    if _chan_id_valid(cid) == 0:
        return -1
    if _chan_id_is_inline(cid) != 0:
        return -1
    su: uint64 = cast[uint64](cid)
    if chan_pool[su].dev_type != DEV_DIR_FILE \
            and chan_pool[su].dev_type != DEV_BUF_FILE:
        return -1
    chan_pool[su].back_ptr  = new_ptr
    chan_pool[su].back_slot = new_len
    return 0


def namec_chan_refcount(cid: int32) -> int32:
    # Debug/test accessor: the live reference count on a pool chan, or
    # 0 for an inline/invalid id. Tests assert refcount-on-fork is
    # correct (a forked stateful fd bumps to 2; last close drops to 0).
    if _chan_id_valid(cid) == 0:
        return 0
    if _chan_id_is_inline(cid) != 0:
        return 0
    return chan_pool[cast[uint64](cid)].refcount


def namec_live_count() -> uint64:
    # Number of live chan-pool slots. Tests use it to assert namec_close
    # actually reclaims (no leak).
    n: uint64 = 0
    s: uint64 = 1
    while s < CHAN_POOL_CAP:
        if chan_pool[s].in_use != 0:
            n = n + 1
        s = s + 1
    return n

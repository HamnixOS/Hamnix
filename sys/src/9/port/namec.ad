# #174: /dev/nscap — per-namespace resource-cap control cdev.
from sys.src.port9.port.devnscap import devnscap_read, devnscap_write
# Native packet-filter firewall control cdev — /dev/firewall.
from sys.src.port9.port.devfirewall import devfirewall_read, devfirewall_write
from sys.src.port9.port.devstat import devstat_read, devstat_write
from sys.src.port9.port.devmounts import devmounts_read, devmounts_write
from sys.src.port9.port.devdiskstats import (
    devdiskstats_read, devdiskstats_write,
)
# HAMSH §6 / §18 stage-4 tripwire: /dev/mountrpc renders the
# cumulative count of 9P T-messages sent. A local pipeline must leave
# it unchanged — that is what proves "pipes are Chans, not 9P".
from sys.src.port9.port.devmountrpc import (
    devmountrpc_read, devmountrpc_write,
)
# hamUI Phase 1: /dev/wsys/* file-server-per-window backend. One
# devtab slot per file in the per-window tree so namec / FD_CHAN_MARK
# dispatch routes opens of /dev/wsys/1/text etc. to the matching cdev
# read/write body.
from sys.src.port9.port.devwsys import (
    devwsys_text_read, devwsys_output_read, devwsys_ns_read,
    devwsys_pid_read, devwsys_uid_read,
    devwsys_kind_read, devwsys_geometry_read,
    devwsys_listing_read,
    devwsys_cmd_write, devwsys_readonly_write,
    wsys_wid_in_use, MAX_WINDOWS,

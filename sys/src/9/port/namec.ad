    devwsys_draw_ctl_write, devwsys_draw_listing_read,
    devwsys_draw_kind_read,
    devwsys_draw_z_read, devwsys_draw_z_write,
    devwsys_draw_opacity_read, devwsys_draw_opacity_write,
    devwsys_draw_geometry_read, devwsys_draw_geometry_write,
    devwsys_draw_markup_read, devwsys_draw_markup_write,
    devwsys_draw_fb_read, devwsys_draw_fb_write,
    wsys_draw_resolve_layer,

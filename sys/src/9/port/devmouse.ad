# sys/src/9/port/devmouse.ad
#
# Layer 1 (Plan 9-shape) mouse device — fifth concrete /dev/* cdev on
# the Hamnix native surface, sibling to devcons.ad / devtime.ad /
# devpid.ad / devrandom.ad. One read pops one event off the
# drivers/input/auxmouse.ad ring and renders it as a single ASCII
# line: "<dx> <dy> <buttons>\n" (signed integers, space-separated,
# newline-terminated). Writes return -1 — the mouse is read-only.
#
# See drivers/input/auxmouse.ad (M16.128) for the upstream ring + the
# `mouse_rx_pop()` accessor that encodes a MouseEvent into a packed
# int32:
#   bits  0..15  dx & 0xFFFF (low 16 bits of int32 delta)
#   bits 16..23  buttons (uint8 bitmap: bit0=L bit1=R bit2=M)
#   bits 24..31  dy & 0xFF  (sign-extends from 8 bits — adequate for
#                            the 9-bit PS/2 delta after overflow drop)
#   value -1     ring is empty (no real event encodes to all-ones —
#                buttons is masked to 0x07)
#
# Non-blocking semantics: an empty ring returns 0 bytes read (EOF-ish),
# letting future GUI code poll without descheduling. A blocking
# variant — wait_event_interruptible(mouse_ring_has) — lands when
# devpoll / select() arrive.

from kernel.printk.printk import printk0, printk1, printk2
from drivers.input.auxmouse import mouse_rx_pop, mouse_rx_has, mouse_rx_push


# --- ASCII decimal formatting helpers ----------------------------------
#
# Mirrors fs/procfs.ad::_buf_put_dec and devtime.ad / devpid.ad shape:
# reverse-fill on a tiny stack, copy out top-down. We add a signed
# wrapper because dx/dy can be negative.

def _devmouse_u64_to_dec(value: uint64, out: Ptr[uint8]) -> uint64:
    if value == 0:
        out[0] = 48                          # '0'
        return 1
    digits: Array[24, uint8]
    n: uint64 = 0
    while value != 0:
        digits[n] = cast[uint8](value % 10) + 48
        value = value / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return written


def _devmouse_i32_to_dec(value: int32, out: Ptr[uint8]) -> uint64:
    # Signed wrapper: emit '-' for negatives, then negate and reuse the
    # unsigned path. INT_MIN edge case is harmless here — PS/2 deltas
    # are bounded to roughly [-256, +255] before our int32 cast.
    if value < 0:
        out[0] = 45                          # '-'
        abs_val: uint64 = cast[uint64](-value) & 0xFFFFFFFF
        n: uint64 = _devmouse_u64_to_dec(abs_val, &out[1])
        return n + 1
    return _devmouse_u64_to_dec(cast[uint64](value) & 0xFFFFFFFF, out)


# --- Decode helpers ----------------------------------------------------
#
# Reverse the packing in auxmouse.ad::mouse_rx_pop:
#   bits  0..15  dx (sign-extend from 16-bit)
#   bits 16..23  buttons (uint8)
#   bits 24..31  dy (sign-extend from 8-bit)
# The compiler quirk noted in feedback_compiler_quirks (cast[uint64]
# of arr[i] zero-extends unreliably for negative int32 fields) doesn't
# bite us here because `encoded` already arrived as int32 from the
# auxmouse return value — we just bit-mask via uint64 width then
# sign-extend explicitly.

def _decode_dx(encoded: int32) -> int32:
    raw: uint64 = cast[uint64](encoded) & 0xFFFF
    # Sign-extend from bit 15.
    if (raw & 0x8000) != 0:
        return cast[int32](raw | 0xFFFFFFFFFFFF0000)
    return cast[int32](raw)


def _decode_dy(encoded: int32) -> int32:
    raw: uint64 = (cast[uint64](encoded) >> 24) & 0xFF
    # Sign-extend from bit 7.
    if (raw & 0x80) != 0:
        return cast[int32](raw | 0xFFFFFFFFFFFFFF00)
    return cast[int32](raw)


def _decode_buttons(encoded: int32) -> uint32:
    return cast[uint32]((cast[uint64](encoded) >> 16) & 0xFF)


# --- public API --------------------------------------------------------

def devmouse_open(path: Ptr[uint8]) -> int32:
    # Path-match guard. Today /dev/mouse is the only path that opens to
    # this cdev; the vfs.ad open arms route here unconditionally so
    # this helper is informational (kept for symmetry with the other
    # Plan 9 dev*_open shapes that future commits may add).
    # Returns FD_MOUSE_MARK (0xFFFFFFED) cast through int32; callers
    # who care about the literal can import FD_MOUSE_MARK directly.
    p: Ptr[uint8] = path
    expected: Ptr[uint8] = "/dev/mouse"
    i: uint64 = 0
    while i < 10:
        if p[i] != expected[i]:
            return -1
        i = i + 1
    if p[10] != 0:
        return -1
    return cast[int32](0xFFFFFFED)


def devmouse_read(buf: Ptr[uint8], count: uint64) -> int64:
    # Non-blocking: empty ring -> 0 bytes read. Caller polls via repeat
    # syscalls (or future select/poll). Format one event as
    # "<dx> <dy> <buttons>\n" then copy up to `count` bytes.
    if count == 0:
        return 0
    encoded: int32 = mouse_rx_pop()
    if encoded == -1:
        # Sentinel: ring empty. Plan 9 devmouse blocks here; we don't
        # have wait queues wired through the syscall layer yet, so the
        # caller sees a zero-length read and is expected to retry.
        return 0

    dx: int32 = _decode_dx(encoded)
    dy: int32 = _decode_dy(encoded)
    buttons: uint32 = _decode_buttons(encoded)

    # "<dx> <dy> <buttons>\n" — worst-case width:
    #   dx:   "-32768" = 6 bytes
    #   sp:   1
    #   dy:   "-128"   = 4 bytes  (8-bit signed range)
    #   sp:   1
    #   btns: "255"    = 3 bytes  (bitmap mask, in practice 0..7)
    #   nl:   1
    # Total <= 16. 48 is comfortable headroom for a future wider field.
    scratch: Array[48, uint8]
    pos: uint64 = 0
    n: uint64 = _devmouse_i32_to_dec(dx, &scratch[pos])
    pos = pos + n
    scratch[pos] = 32                        # ' '
    pos = pos + 1
    n = _devmouse_i32_to_dec(dy, &scratch[pos])
    pos = pos + n
    scratch[pos] = 32                        # ' '
    pos = pos + 1
    n = _devmouse_u64_to_dec(cast[uint64](buttons) & 0xFFFFFFFF, &scratch[pos])
    pos = pos + n
    scratch[pos] = 10                        # '\n'
    pos = pos + 1

    take: uint64 = count
    if take > pos:
        take = pos
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[i]
        i = i + 1
    return cast[int64](take)


# --- ASCII decimal parsing helpers -------------------------------------
#
# Reverse of _devmouse_i32_to_dec. Parse a signed decimal field starting
# at buf[pos], stopping at the first non-digit. Stores the parsed value
# via out_val and the index just past the last consumed byte via out_next.
# Returns 1 on success (at least one digit consumed), 0 on malformed input
# (no digits where a number was expected).

def _devmouse_parse_i32(buf: Ptr[uint8], pos: uint64, count: uint64,
                        out_val: Ptr[int32], out_next: Ptr[uint64]) -> int32:
    i: uint64 = pos
    neg: int32 = 0
    if i < count and buf[i] == 45:               # '-'
        neg = 1
        i = i + 1
    digits: int32 = 0
    acc: int64 = 0
    while i < count:
        c: uint8 = buf[i]
        if c < 48 or c > 57:                      # not '0'..'9'
            break
        acc = acc * 10 + cast[int64](cast[uint64](c) - 48)
        digits = digits + 1
        i = i + 1
    if digits == 0:
        return 0
    if neg == 1:
        acc = -acc
    out_val[0] = cast[int32](acc)
    out_next[0] = i
    return 1


def _devmouse_parse_u32(buf: Ptr[uint8], pos: uint64, count: uint64,
                        out_val: Ptr[uint32], out_next: Ptr[uint64]) -> int32:
    i: uint64 = pos
    digits: int32 = 0
    acc: uint64 = 0
    while i < count:
        c: uint8 = buf[i]
        if c < 48 or c > 57:
            break
        acc = acc * 10 + (cast[uint64](c) - 48)
        digits = digits + 1
        i = i + 1
    if digits == 0:
        return 0
    out_val[0] = cast[uint32](acc & 0xFFFFFFFF)
    out_next[0] = i
    return 1


def _devmouse_skip_spaces(buf: Ptr[uint8], pos: uint64, count: uint64) -> uint64:
    i: uint64 = pos
    while i < count and buf[i] == 32:            # ' '
        i = i + 1
    return i


def _devmouse_encode(dx: int32, dy: int32, buttons: uint32) -> int32:
    # Pack into the int32 shape documented at top-of-file / mouse_rx_pop:
    #   bits  0..15  dx & 0xFFFF
    #   bits 16..23  buttons & 0xFF
    #   bits 24..31  dy & 0xFF
    return (dx & 0xFFFF) \
         | cast[int32]((buttons & 0xFF) << 16) \
         | ((dy & 0xFF) << 24)


def devmouse_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Synthetic-event injection. Parse one ASCII event line in the SAME
    # format devmouse_read emits — "<dx> <dy> <buttons>\n" (signed dx,
    # signed dy, unsigned buttons bitmap, space-separated) — pack it back
    # into the int32 encoding, and push it onto the auxmouse ring so a
    # subsequent devmouse_read pops it out. This makes /dev/mouse a
    # loopback injection channel for test fixtures / accessibility input
    # (the Plan 9 writable-/dev/mouse capability + Linux /dev/uinput in
    # one). Returns the number of bytes consumed on success, or -1 on
    # malformed input (mirrors the writable-cdev reject convention).
    if count == 0:
        return 0
    dx: int32 = 0
    dy: int32 = 0
    buttons: uint32 = 0
    next_pos: uint64 = 0
    pos: uint64 = 0

    pos = _devmouse_skip_spaces(buf, pos, count)
    if _devmouse_parse_i32(buf, pos, count, &dx, &next_pos) == 0:
        return -1
    pos = next_pos
    pos = _devmouse_skip_spaces(buf, pos, count)
    if _devmouse_parse_i32(buf, pos, count, &dy, &next_pos) == 0:
        return -1
    pos = next_pos
    pos = _devmouse_skip_spaces(buf, pos, count)
    if _devmouse_parse_u32(buf, pos, count, &buttons, &next_pos) == 0:
        return -1
    pos = next_pos

    # Optional trailing whitespace / newline is consumed silently.
    while pos < count and (buf[pos] == 32 or buf[pos] == 10 or buf[pos] == 13):
        pos = pos + 1

    encoded: int32 = _devmouse_encode(dx, dy, buttons)
    if mouse_rx_push(encoded) != 0:
        # Ring full — no room to queue the synthetic event.
        return -1
    return cast[int64](count)


# --- Boot self-test (write -> read loopback, no file opens) ------------
#
# Inject a known event via devmouse_write, read it back via
# devmouse_read, decode the ASCII line, and assert the round-trip. This
# exercises the full parse -> encode -> ring push -> ring pop -> format
# path. No file opens, so it is safe to call directly from the boot:37
# bootstrap task without the fd-table priming dance.

def devmouse_write_selftest() -> int32:
    # Inject "5 -3 1\n", then read it back and assert dx==5, dy==-3,
    # buttons==1.
    line: Array[16, uint8]
    line[0] = 53          # '5'
    line[1] = 32          # ' '
    line[2] = 45          # '-'
    line[3] = 51          # '3'
    line[4] = 32          # ' '
    line[5] = 49          # '1'
    line[6] = 10          # '\n'
    wn: int64 = devmouse_write(&line[0], 7)
    if wn != 7:
        printk1("[DEVMOUSE_WRITE] FAIL write returned %d (want 7)\n",
                cast[uint64](wn))
        return 0

    rbuf: Array[48, uint8]
    rn: int64 = devmouse_read(&rbuf[0], 48)
    if rn <= 0:
        printk1("[DEVMOUSE_WRITE] FAIL read returned %d (want >0)\n",
                cast[uint64](rn))
        return 0

    nbytes: uint64 = cast[uint64](rn)
    rdx: int32 = 0
    rdy: int32 = 0
    rbtn: int32 = 0
    nxt: uint64 = 0
    p: uint64 = _devmouse_skip_spaces(&rbuf[0], 0, nbytes)
    if _devmouse_parse_i32(&rbuf[0], p, nbytes, &rdx, &nxt) == 0:
        printk0("[DEVMOUSE_WRITE] FAIL could not parse dx on readback\n")
        return 0
    p = _devmouse_skip_spaces(&rbuf[0], nxt, nbytes)
    if _devmouse_parse_i32(&rbuf[0], p, nbytes, &rdy, &nxt) == 0:
        printk0("[DEVMOUSE_WRITE] FAIL could not parse dy on readback\n")
        return 0
    p = _devmouse_skip_spaces(&rbuf[0], nxt, nbytes)
    if _devmouse_parse_i32(&rbuf[0], p, nbytes, &rbtn, &nxt) == 0:
        printk0("[DEVMOUSE_WRITE] FAIL could not parse buttons on readback\n")
        return 0

    if rdx != 5:
        printk1("[DEVMOUSE_WRITE] FAIL dx=%d (want 5)\n", cast[uint64](rdx))
        return 0
    # dy is -3: compare via masked bit-pattern to dodge any signed-compare
    # codegen quirk on negative int32s.
    if (cast[uint64](rdy) & 0xFFFFFFFF) != (cast[uint64](cast[uint32](0 - 3)) & 0xFFFFFFFF):
        printk1("[DEVMOUSE_WRITE] FAIL dy=0x%x (want -3)\n",
                cast[uint64](rdy) & 0xFFFFFFFF)
        return 0
    if rbtn != 1:
        printk1("[DEVMOUSE_WRITE] FAIL buttons=%d (want 1)\n",
                cast[uint64](rbtn))
        return 0

    # Negative path: a non-numeric line must be rejected with -1.
    bad: Array[8, uint8]
    bad[0] = 120          # 'x'
    bad[1] = 10           # '\n'
    bn: int64 = devmouse_write(&bad[0], 2)
    if bn != -1:
        printk1("[DEVMOUSE_WRITE] FAIL malformed write returned %d (want -1)\n",
                cast[uint64](bn))
        return 0

    printk0("[DEVMOUSE_WRITE] PASS\n")
    return 1


def devmouse_close(fd: int32) -> int32:
    # Stateless cdev — no per-fd slot, no kmalloc, nothing to release.
    # Mirrors the FD_TIME_MARK / FD_PID_MARK / FD_RANDOM_MARK close
    # arms (which today fall through to close_fd_in_task without a
    # per-cdev hook). Kept exported so a future blocking-read variant
    # has a place to drop its wait-queue cleanup.
    return 0

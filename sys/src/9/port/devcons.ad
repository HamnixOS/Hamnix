# sys/src/9/port/devcons.ad
#
# Layer 1 (Plan 9-shape) console device — the first concrete
# /dev/* file backend on the Hamnix native surface. Mirrors 9front's
# /sys/src/9/port/devcons.c at minimum scope: one cdev that fans
# writes out to the kernel's printk path and serves reads from the
# already-existing keyboard / UART RX FIFOs.
#
# See docs/architecture.md (Layer 1: byte sources become files) and
# docs/native-api.md (the "Reserved well-known paths" table — entry
# for /dev/cons specifies "writes go to printk + serial +
# framebuffer; reads return keyboard input"). The VFS plumbing that
# routes vfs_open("/dev/cons") here lives in fs/vfs.ad under the
# FD_CONS_MARK arms; this file is just the back-end body the VFS
# dispatch calls into.
#
# Why a separate file (not inline in fs/vfs.ad): the Plan 9 surface
# is conceptually layered on top of the byte sources, and 9front
# keeps every cdev in its own port file (devcons.c, devuart.c,
# devkbd.c, ...). Mirroring that layout means a reader who knows
# Plan 9 finds the analogue at a glance, and the next devs (/dev/time,
# /dev/pid, /dev/random) land as sibling files in this directory
# without rewriting fs/vfs.ad's structure each time.
#
# Stateless backend: FD_CONS_MARK fds carry no per-fd slot (no
# kmalloc, no refcount), so devcons_close is implicit — the VFS
# fd-slot zero in close_fd_in_task is all the cleanup needed. The
# byte sources themselves are global kernel-side rings owned by
# drivers/tty/serial/early_8250.ad + drivers/input/atkbd.ad and
# every reader (stdin path, /dev/cons path, future Plan 9 callers)
# pops from the same place.

from drivers.tty.serial.early_8250 import (
    early_putc_user, uart_rx_pop, uart_rx_has, console_set_interactive,
)
from drivers.input.atkbd import kbd_rx_pop, kbd_rx_has
from kernel.sched.core import (
    yield_to_others, console_wq_sleep, WQ_EINTR,
    console_input_may_pop_kbd_current, console_input_may_pop_uart_current,
    current_task_uid, current_task_is_hostowner,
)
# hamUI Phase 1: every byte that crosses devcons_write fans into the
# /dev/wsys/1 text + output rings so an outside reader can `cat
# /dev/wsys/1/text` to see what's on the user's screen. Symmetric on
# the read side: devcons_read consults wsys_cmd_pop FIRST so an outside
# writer doing `echo "ls /etc" > /dev/wsys/1/cmd` arrives at hamsh's
# readline as if the bytes had been typed.
from sys.src.port9.port.devwsys import (
    wsys_text_push, wsys_output_push, wsys_cmd_pop,
    wsys_current_is_foreground, wsys_cmd_pending,
)


# F10-2 #455: server-boundary perm policy. The `#c` dev-server admits
# world-r/w on the stateless cdevs (/dev/cons, /dev/null, /dev/zero,
# /dev/random, /dev/time, /dev/pid, /dev/cpuinfo, /dev/meminfo,
# /dev/uptime, /dev/loadavg, /dev/version, /dev/hostname, /dev/stat,
# /dev/mounts, /dev/diskstats, /dev/mouse). The hostowner-only knobs
# (/dev/wsys/ctl, /dev/keymap write) gate inside the cdev (devwsys.ad,
# devkeymap.ad) — they need the cdev-local state to enforce. /dev/auth
# is routed to devauth_perm_check by chan_permission_check (the `#auth`
# letter carves it out before reaching here). /dev/blk/* is routed to
# devblk_perm_check.
#
# Numeric contract matches the rest of the perm-check family (PERM_R=4
# | PERM_W=2 | PERM_X=1, 0=grant, -1=deny). We don't import fs.vfs's
# constants because the dispatcher imports us.
def _devcons_is_admin_path(name: Ptr[char]) -> int32:
    # Return 1 if `name` is one of the hostowner-only ADMIN cdevs under
    # the dev-server. Reads of these still grant world, but writes are
    # hostowner-only because they reconfigure system state visible to
    # every other task on the box:
    #   /dev/keymap       — switches the keyboard layout (loadkeys)
    #   /dev/wsys/ctl     — the compositor control verb (lock/alloc/...)
    #   /dev/hostname     — system hostname (sethostname-equivalent)
    # Match accepts the legacy literal absolute path AND the F1-substrate
    # `#c/<rest>` form post-ns_walk so both reach the gate identically.
    # Each test is a cheap byte-by-byte compare; no string library.
    p: Ptr[char] = name
    # Strip a leading "#c" (with optional '/') so the rest matches a
    # leading '/'-prefixed literal.
    if p[0] == 35 and p[1] == 99:                      # "#c"
        if p[2] == 0:
            return 0                                    # bare server root
        if p[2] == 47:                                 # '/'
            p = cast[Ptr[char]](cast[uint64](p) + 2)   # past "#c"
    # "/keymap" / "/dev/keymap"
    if p[0] == 47 and p[1] == 107 and p[2] == 101 and p[3] == 121 \
            and p[4] == 109 and p[5] == 97 and p[6] == 112 and p[7] == 0:
        return 1                                        # /keymap
    if p[0] == 47 and p[1] == 100 and p[2] == 101 and p[3] == 118 \
            and p[4] == 47 and p[5] == 107 and p[6] == 101 and p[7] == 121 \
            and p[8] == 109 and p[9] == 97 and p[10] == 112 and p[11] == 0:
        return 1                                        # /dev/keymap
    # "/wsys/ctl" / "/dev/wsys/ctl"
    if p[0] == 47 and p[1] == 119 and p[2] == 115 and p[3] == 121 \
            and p[4] == 115 and p[5] == 47 and p[6] == 99 and p[7] == 116 \
            and p[8] == 108 and p[9] == 0:
        return 1                                        # /wsys/ctl
    if p[0] == 47 and p[1] == 100 and p[2] == 101 and p[3] == 118 \
            and p[4] == 47 and p[5] == 119 and p[6] == 115 and p[7] == 121 \
            and p[8] == 115 and p[9] == 47 and p[10] == 99 \
            and p[11] == 116 and p[12] == 108 and p[13] == 0:
        return 1                                        # /dev/wsys/ctl
    # "/hostname" / "/dev/hostname"
    if p[0] == 47 and p[1] == 104 and p[2] == 111 and p[3] == 115 \
            and p[4] == 116 and p[5] == 110 and p[6] == 97 and p[7] == 109 \
            and p[8] == 101 and p[9] == 0:
        return 1                                        # /hostname
    if p[0] == 47 and p[1] == 100 and p[2] == 101 and p[3] == 118 \
            and p[4] == 47 and p[5] == 104 and p[6] == 111 and p[7] == 115 \
            and p[8] == 116 and p[9] == 110 and p[10] == 97 \
            and p[11] == 109 and p[12] == 101 and p[13] == 0:
        return 1                                        # /dev/hostname
    return 0


def devcons_perm_check(name: Ptr[char], want: int32) -> int32:
    # arch audit §2.2: the `#c` dev-server grants world-read on every
    # cdev (sane: /dev/cons, /dev/null, /dev/zero, /dev/random, /dev/time
    # ... are all read-only or stateless and there's no reason to gate
    # them by uid). World-write is also fine for the stateless sinks
    # (/dev/null, /dev/cons writes echo to the caller's own terminal,
    # /dev/zero discards). The ADMIN cdevs (/dev/keymap, /dev/wsys/ctl,
    # /dev/hostname) are reconfigurations of system-global state, so
    # writes are gated to the hostowner. Cdev-internal sanity checks
    # (the wsys/ctl verb parser, sethostname's length cap) still run on
    # the cdev side; this gate is the outer permission boundary.
    if (want & 2) == 0:                              # PERM_W = 2
        return 0                                      # world-read
    if _devcons_is_admin_path(name) == 0:
        return 0                                      # non-admin: world-write
    if current_task_is_hostowner() != 0:
        return 0                                      # hostowner admin write
    return -1                                         # non-hostowner admin write


def devcons_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Byte-loop fan-out to every console sink — UART, framebuffer
    # (UEFI) or legacy VGA text (BIOS), and the printk ring buffer
    # for `dmesg` replay. early_putc_user() is the userland-write
    # equivalent of early_putc: same sinks, but it does NOT emit
    # the kernel "[NNNNNN] " per-line sequence number prefix. A
    # write to /dev/cons is explicit user-visible console traffic —
    # the prompt, command output, an interactive shell's redraw —
    # and must produce raw bytes the user typed/saw, not kernel
    # diagnostic stamps glued onto the front of every line.
    #
    # See the migration table in docs/native-api.md row
    # "SYS_PUTC → write('/dev/cons')" — the byte stream contract is
    # unchanged; only the timestamp leak is removed.
    #
    # Returns the full byte count — early_putc_user blocks on UART
    # THRE if the transmitter is slow, so there's no short-write
    # case. Matches FD_STDOUT_MARK's return shape in
    # fs/vfs.ad::vfs_write.
    #
    # hamUI Phase 2: a bg window (wid >= 2) is HEADLESS — its
    # writes tee into the per-wid text/output rings ONLY, never to
    # the physical serial console. Without this gate every bg
    # window's hamsh prompt would echo onto the user's terminal and
    # multi-window would be unusable.
    is_fg: int32 = wsys_current_is_foreground()
    i: uint64 = 0
    while i < count:
        if is_fg != 0:
            ch: int32 = cast[int32](buf[i])
            early_putc_user(ch)
        # hamUI Phase 2 tee: same byte into the calling window's
        # scrollback and live-output rings. The wsys_text_push entry
        # internally resolves current pid → wid.
        wsys_text_push(buf[i])
        wsys_output_push(buf[i])
        i = i + 1
    return cast[int64](count)


def devcons_read(buf: Ptr[uint8], count: uint64) -> int64:
    # Block until at least one byte is available, then drain as much
    # as the caller asked for from whichever input ring has data.
    # Mirrors the FD_STDIN_MARK arm in fs/vfs.ad::vfs_read at the
    # smallest scope that is still useful — we share the same two
    # byte sources (PS/2 keyboard FIFO via atkbd.ad, UART RX FIFO
    # drained by the timer ISR in early_8250.ad). The stdin path is
    # NOT changed by this commit; both surfaces just happen to pop
    # from the same producer-side rings.
    #
    # No line-buffering / no CR→LF translation / no local-echo:
    # /dev/cons is the raw byte stream. hamsh's line discipline lives
    # on top of FD_STDIN_MARK; until callers migrate (Phase G), the
    # stdin path keeps its existing cooked semantics and /dev/cons
    # offers the raw equivalent for new code.
    #
    # An interactive read of /dev/cons — like a stdin read in
    # fs/vfs.ad — signals the kernel that userland is at a live
    # prompt; tighten the console log-level so low-severity printk
    # chatter no longer corrupts the line being typed. Idempotent.
    #
    # hamUI Phase 2: a bg window (wid >= 2) reads its OWN cmd queue
    # only — never kbd/uart. Otherwise the bg hamsh would race the
    # foreground hamsh for keystrokes and the user's typing would
    # vanish mid-character. Only wid 1 (the foreground) sees the
    # physical keyboard. wsys_cmd_pop() and wsys_current_is_foreground
    # both consult the current task's wid binding.
    console_set_interactive()
    is_fg: int32 = wsys_current_is_foreground()
    # P0b: while a compositor holds the console-input grab, the grab
    # PARTITIONS physical input — the holder owns the PS/2 keyboard,
    # every other reader keeps the UART (serial console). A non-holder
    # still drains its own wsys cmd-injection queue, and the boot/login
    # hamsh cannot steal keystrokes typed at the DE — but the DE event
    # loop equally cannot starve the serial shell of serial bytes.
    may_kbd: int32 = console_input_may_pop_kbd_current()
    may_uart: int32 = console_input_may_pop_uart_current()
    n: uint64 = 0
    while n < count:
        # Prefer the wsys cmd-injection queue. When an outside agent
        # does `echo cmd > /dev/wsys/<wid>/cmd`, the bytes are queued
        # here and drained as if from the keyboard. An empty queue
        # returns -1 cheaply and we fall through to the real
        # keyboard / UART rings — ONLY in the foreground window AND
        # only per the grab partition above.
        c: int32 = wsys_cmd_pop()
        if c < 0 and is_fg != 0 and may_kbd != 0:
            c = kbd_rx_pop()
        if c < 0 and is_fg != 0 and may_uart != 0:
            c = uart_rx_pop()
        if c < 0:
            if n > 0:
                # We've satisfied at least one byte. Return what we
                # have rather than block again — matches read(2)
                # semantics for character devices on Linux (and Plan
                # 9): "may return less than requested".
                return cast[int64](n)
            # Event-driven block: sleep on the shared console input wait
            # queue until a producer (UART RX IRQ / keyboard / wsys
            # inject) wakes us, instead of poll-yielding on the timer
            # tick. A signal-wake returns WQ_EINTR -> surface -EINTR.
            rcc: int32 = console_wq_sleep()
            if rcc != 0:
                return cast[int64](WQ_EINTR)
            continue
        buf[n] = cast[uint8](c & 0xFF)
        n = n + 1
    return cast[int64](n)


def devcons_read_nb(buf: Ptr[uint8], count: uint64) -> int64:
    # Non-blocking sibling of devcons_read backing SYS_READ_NB on a
    # /dev/cons fd. Drains whatever bytes are immediately available from
    # the same producer rings (wsys cmd queue, then — foreground only —
    # the PS/2 keyboard FIFO and UART RX FIFO) and returns at once: >0
    # bytes drained, or 0 ("would block") when no byte is ready. It NEVER
    # yields/blocks — the hamUI daemon polls /dev/cons every present loop
    # iteration and must keep compositing, so a blocking read here would
    # wedge the whole desktop.
    #
    # Same foreground gate as devcons_read: only the foreground window
    # (wid 1, which the daemon runs as) sees the physical keyboard/UART;
    # a bg window only ever drains its own cmd-injection queue.
    console_set_interactive()
    is_fg: int32 = wsys_current_is_foreground()
    may_kbd: int32 = console_input_may_pop_kbd_current()
    may_uart: int32 = console_input_may_pop_uart_current()
    n: uint64 = 0
    while n < count:
        c: int32 = wsys_cmd_pop()
        if c < 0 and is_fg != 0 and may_kbd != 0:
            c = kbd_rx_pop()
        if c < 0 and is_fg != 0 and may_uart != 0:
            c = uart_rx_pop()
        if c < 0:
            break
        buf[n] = cast[uint8](c & 0xFF)
        n = n + 1
    return cast[int64](n)


def devcons_poll_readable() -> int32:
    # Non-DESTRUCTIVE readiness probe for SYS_WAITFDS: would a
    # devcons_read return a byte right now for the CALLING task? Same
    # producer rings and foreground gate as devcons_read_nb, but probes
    # only — consumes nothing. 1 = ready, 0 = would block.
    if wsys_cmd_pending() != 0:
        return 1
    if wsys_current_is_foreground() == 0:
        return 0
    # Grab partition (see kernel/sched/core.ad): a pending byte only
    # makes THIS caller readable if the caller may pop that byte's ring
    # — otherwise the DE would wake every present-loop pass on serial
    # bytes it is not allowed to consume (and vice versa).
    if console_input_may_pop_kbd_current() != 0 and kbd_rx_has() != 0:
        return 1
    if console_input_may_pop_uart_current() != 0 and uart_rx_has() != 0:
        return 1
    return 0


# --- F10-6 #458 expansion: Plan 9 Dir-record listing for #c ---------
#
# Migration of the `#c` dev-server directory walk (/dev) from NAME\n
# lines to Plan 9 Dir records. Mirrors the entry set _dev_listdir
# (fs/vfs.ad) emits today: `blk` (a subdirectory; the #b server root),
# plus the stateless stdio cdevs `cons`, `null`, `zero`. Each Dir
# record carries owner uid "hostowner", Plan 9 mode (0666 for cdevs,
# DMDIR+0555 for the blk subdir), and a stable qpath = slot+1 so the
# encoded qid round-trips through Dir.qid_path. The encoder lives in
# lib/p9dir.ad (the same one devsrv_list_dir uses).

from lib.p9dir import p9_dir_encode_into
from lib.9p.9p import P9_QTDIR, P9_QTFILE

_DEVCONS_DMDIR:    uint32 = 0x80000000
_DEVCONS_MODE_CDEV: uint32 = 0x000001B6     # 0666 rw-rw-rw-
_DEVCONS_MODE_DIR:  uint32 = 0x0000016D     # 0555 r-xr-xr-x
_devcons_uname: Array[16, uint8]
_devcons_uname_inited: int32 = 0


def _devcons_init_uname():
    if _devcons_uname_inited != 0:
        return
    s: Ptr[uint8] = "hostowner"
    i: uint64 = 0
    while s[i] != 0:
        _devcons_uname[i] = s[i]
        i = i + 1
    _devcons_uname[i] = 0
    _devcons_uname_inited = 1


def _devcons_emit(out_buf: Ptr[uint8], pos: uint64, out_max: uint64,
                  qpath: uint64, qtype: uint8, mode: uint32,
                  nm: Ptr[uint8], uname_p: Ptr[uint8],
                  uname_len: uint64) -> uint64:
    nlen: uint64 = 0
    while nm[nlen] != 0:
        nlen = nlen + 1
    return p9_dir_encode_into(
        out_buf, pos, out_max,
        qtype, 0, qpath, mode, 0, 0, 0,
        nm, nlen,
        uname_p, uname_len,
        uname_p, uname_len,
        uname_p, 0)


def devcons_list_dir(out_buf: Ptr[uint8], out_max: uint64) -> int64:
    # F10-6 #458 expansion: like _dev_listdir (fs/vfs.ad) but emits one
    # Plan 9 Dir record per /dev entry instead of NAME\n lines. Stops
    # cleanly at the first entry that would overflow (no partial record).
    _devcons_init_uname()
    uname_p: Ptr[uint8] = cast[Ptr[uint8]](&_devcons_uname[0])
    uname_len: uint64 = 0
    while _devcons_uname[uname_len] != 0:
        uname_len = uname_len + 1
    pos: uint64 = 0
    wrote: uint64 = 0
    # blk — subdirectory (the #b server root).
    wrote = _devcons_emit(out_buf, pos, out_max,
                          1, P9_QTDIR,
                          _DEVCONS_MODE_DIR | _DEVCONS_DMDIR,
                          "blk", uname_p, uname_len)
    if wrote == 0:
        return cast[int64](pos)
    pos = pos + wrote
    # cons — the console cdev (this file's raison d'être).
    wrote = _devcons_emit(out_buf, pos, out_max,
                          2, P9_QTFILE,
                          _DEVCONS_MODE_CDEV,
                          "cons", uname_p, uname_len)
    if wrote == 0:
        return cast[int64](pos)
    pos = pos + wrote
    # null — discard sink.
    wrote = _devcons_emit(out_buf, pos, out_max,
                          3, P9_QTFILE,
                          _DEVCONS_MODE_CDEV,
                          "null", uname_p, uname_len)
    if wrote == 0:
        return cast[int64](pos)
    pos = pos + wrote
    # zero — zero-fill source.
    wrote = _devcons_emit(out_buf, pos, out_max,
                          4, P9_QTFILE,
                          _DEVCONS_MODE_CDEV,
                          "zero", uname_p, uname_len)
    if wrote == 0:
        return cast[int64](pos)
    pos = pos + wrote
    return cast[int64](pos)

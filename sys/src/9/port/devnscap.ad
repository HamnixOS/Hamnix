# sys/src/9/port/devnscap.ad
#
# #174 — the Plan-9-shape per-namespace resource-cap control cdev.
#
# /dev/nscap is the runtime control surface for the memory + CPU caps that
# attach to the CALLER's namespace (its Pgrp). It is a sibling of
# /dev/hostname and /dev/keymap in the introspection family: a stateful
# READ + WRITE knob. Unlike those, the state it reads/writes is NOT one
# global buffer — it is the cap fields on whatever namespace the writing
# task belongs to (current_pgrp()). Two tasks in different namespaces
# writing /dev/nscap set DIFFERENT caps; that is the whole point — the cap
# is a property of the namespace, the Plan 9 way, not a cgroup tree.
#
#   Write semantics (one directive per write; the common shell idiom):
#     echo 'mem 4194304' > /dev/nscap   -> cap the ns at 4 MiB resident
#     echo 'mem 0'       > /dev/nscap   -> remove the memory cap
#     echo 'cpu 25'      > /dev/nscap   -> cap the ns at 25% CPU share
#     echo 'cpu 100'     > /dev/nscap   -> remove the CPU cap (>=100 == off)
#
#   Read shape (snapshot of the CALLER's namespace):
#     "mem <charged>/<cap> cpu <pct>\n"
#   e.g. "mem 65536/4194304 cpu 25\n"  — 64 KiB resident of a 4 MiB cap,
#   25% CPU. A 0 in the cap / pct slot means uncapped.
#
# This is the established cdev pattern (devhostname.ad / devkeymap.ad), NOT
# a Linux ioctl or a /sys/fs/cgroup write: caps are set by writing a
# directive to a pseudo-file. namec.ad routes /dev/nscap to DEV_NSCAP,
# whose _devtab_read / _devtab_write delegate to the two functions below.
#
# Compiler-quirk note: Adder has a flat global symbol namespace across
# merged modules, so every shared-shape helper is prefixed `_nsd_` to
# avoid colliding with devhostname's `_hn_` / devkeymap's `_kmd_` family.

from sys.src.port9.port.chan import (
    pgrp_current,
    nscap_set_mem, nscap_set_cpu,
    nscap_get_mem_cap, nscap_get_mem_charged, nscap_get_cpu,
)


def _nsd_is_ws(c: uint8) -> int32:
    # Whitespace separators inside a directive ("mem 4194304") + trailing
    # bytes of an `echo`.
    if c == 32:                                       # ' '
        return 1
    if c == 9:                                        # '\t'
        return 1
    if c == 10:                                       # '\n'
        return 1
    if c == 13:                                       # '\r'
        return 1
    return 0


def _nsd_parse_u64(buf: Ptr[uint8], start: uint64,
                   count: uint64, out: Ptr[uint64]) -> uint64:
    # Parse a base-10 unsigned starting at buf[start], skipping leading
    # whitespace. Writes the value to *out and returns the index of the
    # first byte AFTER the number. If no digits are found *out is 0.
    i: uint64 = start
    while i < count and _nsd_is_ws(buf[i]) != 0:
        i = i + 1
    v: uint64 = 0
    while i < count:
        c: uint8 = buf[i]
        if c < 48 or c > 57:                          # not '0'..'9'
            break
        v = v * 10 + cast[uint64](c - 48)
        i = i + 1
    out[0] = v
    return i


def _nsd_emit_u64(scratch: Ptr[uint8], pos: uint64, v: uint64) -> uint64:
    # Append the decimal rendering of v at scratch[pos]; return the new
    # position. A bare 0 renders "0".
    if v == 0:
        scratch[pos] = 48                             # '0'
        return pos + 1
    # Render into a small reversed buffer, then copy forward.
    tmp: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        tmp[n] = cast[uint8](48 + (x % 10))
        x = x / 10
        n = n + 1
    p: uint64 = pos
    k: uint64 = n
    while k > 0:
        scratch[p] = tmp[k - 1]
        p = p + 1
        k = k - 1
    return p


def _nsd_emit_str(scratch: Ptr[uint8], pos: uint64,
                  s: Ptr[uint8]) -> uint64:
    # Append NUL-terminated `s` at scratch[pos]; return the new position.
    p: uint64 = pos
    i: uint64 = 0
    while s[i] != 0:
        scratch[p] = s[i]
        p = p + 1
        i = i + 1
    return p


def devnscap_read(buf: Ptr[uint8], count: uint64) -> int64:
    # Render "mem <charged>/<cap> cpu <pct>\n" for the CALLER's namespace.
    if count == 0:
        return 0
    p: uint64 = pgrp_current()
    charged: uint64 = nscap_get_mem_charged(p)
    cap: uint64 = nscap_get_mem_cap(p)
    pct: uint64 = nscap_get_cpu(p)

    scratch: Array[96, uint8]
    pos: uint64 = 0
    pos = _nsd_emit_str(&scratch[0], pos, "mem ")
    pos = _nsd_emit_u64(&scratch[0], pos, charged)
    scratch[pos] = 47                                 # '/'
    pos = pos + 1
    pos = _nsd_emit_u64(&scratch[0], pos, cap)
    pos = _nsd_emit_str(&scratch[0], pos, " cpu ")
    pos = _nsd_emit_u64(&scratch[0], pos, pct)
    scratch[pos] = 10                                 # '\n'
    pos = pos + 1

    take: uint64 = count
    if take > pos:
        take = pos
    j: uint64 = 0
    while j < take:
        buf[j] = scratch[j]
        j = j + 1
    return cast[int64](take)


def devnscap_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Parse a single directive ("mem <n>" / "cpu <n>") and apply it to the
    # CALLER's namespace. Always reports `count` consumed so a writing
    # shell's loop terminates even on a malformed directive (which is
    # silently ignored — the Plan 9 cdev convention).
    if count == 0:
        return 0
    p: uint64 = pgrp_current()

    # Skip leading whitespace to find the verb.
    i: uint64 = 0
    while i < count and _nsd_is_ws(buf[i]) != 0:
        i = i + 1
    if i + 2 >= count:
        return cast[int64](count)

    # Verb is the first 3 bytes: "mem" or "cpu".
    c0: uint8 = buf[i]
    c1: uint8 = buf[i + 1]
    c2: uint8 = buf[i + 2]
    val: uint64 = 0
    # "mem" == 'm','e','m'
    if c0 == 109 and c1 == 101 and c2 == 109:
        _nsd_parse_u64(buf, i + 3, count, &val)
        nscap_set_mem(p, val)
        return cast[int64](count)
    # "cpu" == 'c','p','u'
    if c0 == 99 and c1 == 112 and c2 == 117:
        _nsd_parse_u64(buf, i + 3, count, &val)
        nscap_set_cpu(p, val)
        return cast[int64](count)
    # Unknown directive — ignore but consume.
    return cast[int64](count)

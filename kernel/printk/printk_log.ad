# kernel/printk/printk_log.ad
#
# Tiny printk ring buffer — the in-RAM mirror of every byte that
# crosses early_putc(). Mirrors the role of kernel/printk/printk.c's
# __log_buf in Linux at the smallest possible scope: a flat circular
# byte array (no struct printk_log records, no per-line metadata, no
# log_first_idx/log_next_idx pair). dmesg / /proc/kmsg just want the
# concatenated console text, and that's exactly what we keep.
#
# Sized at 64 KiB — large enough to survive an entire boot worth of
# printk traffic on the current ~few-KiB-of-banners footprint, small
# enough that the BSS cost is invisible. When line metadata matters
# (timestamping, log-level filtering, ratelimit) we'll grow this to
# the record shape Linux uses.
#
# Two indices are tracked:
#   - printk_log_head:  the next write position (0..PRINTK_LOG_SIZE-1)
#   - printk_log_count: total bytes ever pushed (no modulo) — used by
#     snapshot to decide whether the buffer has wrapped yet.
#
# Push is O(1); snapshot copies the most-recent min(count, max) bytes
# into the caller's buffer in oldest-first order.

PRINTK_LOG_SIZE: uint64 = 65536

printk_log: Array[65536, uint8]
printk_log_head:  uint64 = 0      # next write position
printk_log_count: uint64 = 0      # total bytes pushed since boot


def printk_log_push(c: uint8):
    # Single-byte append. When the head wraps past the tail, the
    # oldest byte is implicitly overwritten — snapshot() reconstructs
    # the chronological window from head + count.
    printk_log[printk_log_head] = c
    printk_log_head = (printk_log_head + 1) % PRINTK_LOG_SIZE
    printk_log_count = printk_log_count + 1


def printk_log_snapshot(buf: Ptr[uint8], max: uint64) -> uint64:
    # Copy up to `max` of the most-recent bytes into `buf`, oldest
    # first. Returns the number of bytes actually written.
    #
    # Two cases:
    #   1. count <= PRINTK_LOG_SIZE: nothing has wrapped yet, so the
    #      log lives contiguously at [0 .. count) and we copy the
    #      last min(count, max) bytes from there.
    #   2. count > PRINTK_LOG_SIZE: the oldest surviving byte sits at
    #      index `head` and the newest at `head - 1 (mod size)`. We
    #      walk from (head + (size - want)) for `want` bytes.
    avail: uint64 = printk_log_count
    if avail > PRINTK_LOG_SIZE:
        avail = PRINTK_LOG_SIZE
    want: uint64 = avail
    if want > max:
        want = max
    if want == 0:
        return 0
    # Starting index inside printk_log for the oldest byte of the
    # window we're returning.
    start: uint64 = 0
    if printk_log_count <= PRINTK_LOG_SIZE:
        # Buffer hasn't wrapped: bytes live at [0, count). Window of
        # length `want` ending at count-1 starts at count-want.
        start = printk_log_count - want
    else:
        # Buffer wrapped: full size of useful data, newest at head-1.
        # Window of length `want` ending at head-1 starts at
        # (head + size - want) mod size.
        start = (printk_log_head + PRINTK_LOG_SIZE - want) % PRINTK_LOG_SIZE
    i: uint64 = 0
    while i < want:
        buf[i] = printk_log[(start + i) % PRINTK_LOG_SIZE]
        i = i + 1
    return want

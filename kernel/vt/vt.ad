# kernel/vt/vt.ad
#
# Virtual Terminal (VT) multiplexer — classic Linux-style VT1..VT4 on
# top of the single physical console (serial + framebuffer).
#
# ARCHITECTURE
# ------------
# N_VT (4) virtual terminals share one physical keyboard + display.
# Only ONE VT is "active" at any instant; it is the one whose input
# queue receives keystrokes and whose output appears on the screen.
# Inactive VTs accumulate their output into per-VT scrollback rings so
# it is visible when the VT becomes active (not yet rendered, but the
# data is preserved).
#
# INPUT FLOW
#   atkbd.ad / uart_rx → vt_kbd_push(active_vt, byte)
#   A reader on VT N calls vt_kbd_pop(N) and blocks until a byte
#   appears in that VT's FIFO.
#   Bytes go to ACTIVE VT only; readers on inactive VTs see their FIFO
#   empty and yield.
#
# VT SWITCHING
#   vt_switch(n)     — called from the Alt+F1..F4 hotkey decode in
#                      atkbd.ad; also callable by the `chvt` userland
#                      tool via the /dev/vt/ctl control channel.
#                      Prints a brief "[vt: switch VT<n>]" banner on
#                      the serial console so the operator knows the
#                      switch happened even if the FB output is the
#                      old VT.
#
# FIFO SHAPE
#   Per-VT ring buffers (VT_FIFO_SIZE bytes each).  Same drop-on-full
#   policy as the global atkbd ring — we're in ISR/poll context.
#
# FOREGROUND SIGNAL ROUTING
#   The active VT's foreground pgid is used by signal_post_to_foreground
#   so Ctrl-C on VT2 doesn't kill VT1's shell.  Each VT tracks its own
#   terminal_fg_pgid.

from kernel.printk.printk import printk0, printk1, printk_set_level
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_WARN

N_VT:          int32  = 4
VT_FIFO_SIZE:  uint64 = 256     # per-VT input FIFO bytes (bigger than atkbd's 128)

# --- global active VT index (0-based, so VT1 = index 0) ---------------
active_vt: int32 = 0

# --- per-VT input FIFOs ------------------------------------------------
# Flat layout: vt_fifo[vt * VT_FIFO_SIZE + offset]
# heads/tails are per-VT cursors.
vt_fifo:  Array[1024, uint8]    # 4 * 256
vt_head:  Array[4, uint64]
vt_tail:  Array[4, uint64]

# --- per-VT foreground pgid (mirrors terminal_fg_pgid for multi-VT) ---
vt_fg_pgid: Array[4, uint64]

# --- VT name strings for printk ----------------------------------------
# Printed as [vt: switch VTn] on switch events.

def vt_init():
    # All FIFOs start empty; heads/tails are already 0 (BSS).
    # VT0 (VT1 in 1-indexed user view) is active by default — matches
    # the pre-VT single-console behaviour exactly.
    active_vt = 0
    printk0("[vt] 4 virtual terminals initialised; VT1 is active\n")


# --- FIFO helpers -------------------------------------------------------

def vt_kbd_push(vt: int32, b: uint8) -> int32:
    # Push one byte into VT vt's input FIFO.  Drop on full (ISR context).
    # Returns 1 if pushed, 0 if dropped.
    if vt < 0 or vt >= N_VT:
        return 0
    u: uint64 = cast[uint64](vt)
    base: uint64 = u * VT_FIFO_SIZE
    nxt: uint64 = (vt_tail[u] + 1) % VT_FIFO_SIZE
    if nxt == vt_head[u]:
        return 0                            # FIFO full — drop
    vt_fifo[base + vt_tail[u]] = b
    vt_tail[u] = nxt
    return 1


def vt_kbd_pop(vt: int32) -> int32:
    # Pop one byte from VT vt's input FIFO.  Returns -1 if empty.
    if vt < 0 or vt >= N_VT:
        return -1
    u: uint64 = cast[uint64](vt)
    if vt_head[u] == vt_tail[u]:
        return -1                           # empty
    base: uint64 = u * VT_FIFO_SIZE
    b: int32 = cast[int32](vt_fifo[base + vt_head[u]])
    vt_head[u] = (vt_head[u] + 1) % VT_FIFO_SIZE
    return b


def vt_get_active() -> int32:
    return active_vt


# --- VT switching -------------------------------------------------------

def vt_switch(n: int32):
    # Switch the active VT to n (0-based).  Silently clamp to the
    # valid range.  Calling from the keyboard IRQ handler is safe:
    # all state touched here is global ints/ring cursors.
    if n < 0:
        n = 0
    if n >= N_VT:
        n = N_VT - 1
    if n == active_vt:
        return
    active_vt = n
    # Printk banner on serial so the operator sees the switch even when
    # the framebuffer hasn't been repainted.  Uses the 1-indexed name
    # the operator expects (VT1 = active_vt 0).
    # Use WARN level so this always appears even after interactive mode
    # tightens the console threshold to INFO-suppress.
    printk_set_level(PRINTK_LEVEL_WARN)
    printk1("[vt] switched to VT%d\n", cast[uint64](n + 1))


# --- per-VT foreground pgid --------------------------------------------

def vt_get_fg_pgid(vt: int32) -> uint64:
    if vt < 0 or vt >= N_VT:
        return 0
    u: uint64 = cast[uint64](vt)
    return vt_fg_pgid[u]



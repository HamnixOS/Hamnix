# kernel/time/timer_selftest.ad
#
# In-kernel self-test for the Linux-shape time subsystem (clocksource /
# clockevent / hrtimer / NO_HZ / posix-cpu-timer). Gated on the cpio
# marker /etc/hrtimer-test (planted by scripts/test_hrtimer.sh via
# build_initramfs.py); a default boot never runs it.
#
# Proves, with unique greppable markers:
#   T1  a clocksource is selected and is strictly monotonic;
#   T2  a hrtimer set for T ns fires at ~T with SUB-TICK resolution
#       (the fire happens far inside one 10 ms jiffy, not quantized);
#   T3  a 1 ms hrtimer-backed sleep takes ~1 ms, not ~10 ms;
#   T4  NO_HZ stops the tick on idle and time stays correct on wake
#       (skipped-jiffies accounting matches the elapsed clock);
#   T5  a POSIX CLOCK_PROCESS_CPUTIME_ID timer fires at its CPU-time
#       threshold.
#
# Runs early in start_kernel while CPU interrupts are still off, so it
# drives the data structures directly (it does not rely on the live ISR);
# it busy-waits real wall-clock windows using the free-running TSC clock.

from kernel.printk.printk import printk0, printk1, printk2
from kernel.time.clocksource import (
    clocksource_read_ns, clocksource_is_selected, clocksource_current_name,
    clocksource_current_rating,
)
from kernel.time.hrtimer import (
    hrtimer_create, hrtimer_start_rel, hrtimer_cancel, hrtimer_destroy,
    hrtimer_interrupt, hrtimer_is_queued, hrtimer_next_expiry,
    hrtimer_pending_count, HRTIMER_NORESTART, HRTIMER_RESTART,
)
from kernel.time.tick import (
    tick_nohz_idle_enter, tick_nohz_idle_exit, tick_nohz_is_active,
    tick_nohz_skipped_jiffies_total, tick_is_highres,
    tick_jiffies_is_clocksource_driven, tick_account_jiffies_now,
)
from arch.x86.kernel.time import get_jiffies
from kernel.time.posix_cpu_timer import (
    posix_cpu_timer_create, posix_cpu_timer_set, posix_cpu_timers_run,
    posix_cpu_timer_overruns, CLOCK_PROCESS_CPUTIME_ID,
)

# A module-scope flag the test hrtimer callback flips so we can observe
# the fire without a struct round-trip.
ts_fired_flag: uint64 = 0
ts_fired_at_ns: uint64 = 0


def _ts_hrtimer_callback(cookie: uint64) -> int64:
    # enum hrtimer_restart (*)(cookie). Records that it fired + when.
    ts_fired_flag = 1
    ts_fired_at_ns = clocksource_read_ns()
    return HRTIMER_NORESTART


def _ts_busywait_ns(span_ns: uint64):
    # Busy-wait `span_ns` of real time using the monotonic clocksource.
    start: uint64 = clocksource_read_ns()
    while (clocksource_read_ns() - start) < span_ns:
        pass


def hrtimer_selftest():
    printk0("[hrtimer-test] BEGIN\n")
    ok: uint64 = 1

    # --- T1: clocksource selected + monotonic --------------------------
    if clocksource_is_selected() == 0:
        printk0("[hrtimer-test] T1 FAIL: no clocksource selected\n")
        printk0("[hrtimer-test] FAIL\n")
        return
    printk1("[hrtimer-test] T1 clocksource=%s", clocksource_current_name())
    printk1(" rating=%d\n", clocksource_current_rating())
    a: uint64 = clocksource_read_ns()
    _ts_busywait_ns(200000)                    # 200 us
    b: uint64 = clocksource_read_ns()
    if b <= a:
        printk2("[hrtimer-test] T1 FAIL: clock not monotonic a=%d b=%d\n", a, b)
        printk0("[hrtimer-test] FAIL\n")
        return
    printk2("[hrtimer-test] T1 PASS: monotonic, advanced %d ns over ~200us window\n",
            b - a, 0)

    # --- T2: hrtimer fires at ~T with sub-tick resolution -------------
    # Arm a 2 ms hrtimer. 2 ms is well inside one 10 ms jiffy, so a
    # jiffies-quantized wheel could only fire it at the NEXT 10 ms tick
    # boundary; a real hrtimer fires at ~2 ms. We drive the expiry pass
    # manually (interrupts are off) by busy-waiting past the deadline then
    # calling hrtimer_interrupt(now).
    ts_fired_flag = 0
    ts_fired_at_ns = 0
    h: int64 = hrtimer_create(cast[uint64](&_ts_hrtimer_callback), 0)
    if h < 0:
        printk0("[hrtimer-test] T2 FAIL: hrtimer_create\n")
        printk0("[hrtimer-test] FAIL\n")
        return
    arm_ns: uint64 = clocksource_read_ns()
    target_delta: uint64 = 2000000             # 2 ms
    hrtimer_start_rel(cast[uint64](h), target_delta)
    if hrtimer_is_queued(cast[uint64](h)) == 0:
        printk0("[hrtimer-test] T2 FAIL: not queued after start\n")
        printk0("[hrtimer-test] FAIL\n")
        return
    # Busy-wait just past 2 ms, then run the expiry pass.
    _ts_busywait_ns(target_delta + 100000)     # 2.1 ms
    now2: uint64 = clocksource_read_ns()
    hrtimer_interrupt(now2)
    if ts_fired_flag == 0:
        printk0("[hrtimer-test] T2 FAIL: hrtimer did not fire\n")
        printk0("[hrtimer-test] FAIL\n")
        return
    fire_delay: uint64 = 0
    if ts_fired_at_ns > arm_ns:
        fire_delay = ts_fired_at_ns - arm_ns
    printk1("[hrtimer-test] T2 fire_delay=%d ns (target 2000000)\n", fire_delay)
    # Sub-tick proof: the fire delay must be FAR below 10 ms (one jiffy).
    # We allow [1 ms, 6 ms] — comfortably sub-tick yet tolerant of the
    # busy-wait overshoot + clock read jitter under TCG.
    if fire_delay < 1000000 or fire_delay > 6000000:
        printk0("[hrtimer-test] T2 FAIL: fire delay not sub-tick-accurate\n")
        printk0("[hrtimer-test] FAIL\n")
        return
    printk0("[hrtimer-test] T2 PASS: hrtimer fired sub-tick (<10ms)\n")

    # --- T3: a 1 ms sleep takes ~1 ms, not ~10 ms ---------------------
    # Model the hrtimer-backed nanosleep(1ms): arm a 1 ms hrtimer and spin
    # the expiry pass until it fires, measuring the real elapsed time.
    ts_fired_flag = 0
    h3: int64 = hrtimer_create(cast[uint64](&_ts_hrtimer_callback), 0)
    if h3 < 0:
        printk0("[hrtimer-test] T3 FAIL: hrtimer_create\n")
        printk0("[hrtimer-test] FAIL\n")
        return
    sleep_start: uint64 = clocksource_read_ns()
    hrtimer_start_rel(cast[uint64](h3), 1000000)     # 1 ms
    # Drive expiry: busy-loop calling the pass until the callback fires.
    guard: uint64 = 0
    while ts_fired_flag == 0 and guard < 100000000:
        guard = guard + 1
        hrtimer_interrupt(clocksource_read_ns())
    sleep_elapsed: uint64 = clocksource_read_ns() - sleep_start
    printk1("[hrtimer-test] T3 1ms-sleep elapsed=%d ns\n", sleep_elapsed)
    # Must be well under one 10 ms jiffy. Allow [0.5 ms, 5 ms].
    if sleep_elapsed < 500000 or sleep_elapsed > 5000000:
        printk0("[hrtimer-test] T3 FAIL: 1ms sleep not ~1ms\n")
        printk0("[hrtimer-test] FAIL\n")
        return
    printk0("[hrtimer-test] T3 PASS: 1ms sleep ~1ms (not quantized to 10ms)\n")
    hrtimer_destroy(cast[uint64](h))
    hrtimer_destroy(cast[uint64](h3))

    # --- T4: NO_HZ stops the tick + time stays correct on wake --------
    # tick_nohz_idle_enter() programs the clockevent for the next deadline
    # (or backstop) and marks the tick stopped. We then busy-wait a known
    # wall-clock span (simulating an idle), then tick_nohz_idle_exit()
    # which must account ~that many skipped jiffies from the live clock.
    if tick_is_highres() == 0:
        # Clockevent unavailable in this build config — T4 is N/A but not
        # a failure (periodic-only fallback is a valid mode).
        printk0("[hrtimer-test] T4 SKIP: high-res mode unavailable (periodic fallback)\n")
    else:
        before_skipped: uint64 = tick_nohz_skipped_jiffies_total()
        entered: int32 = tick_nohz_idle_enter()
        if entered == 0 or tick_nohz_is_active() == 0:
            printk0("[hrtimer-test] T4 FAIL: tick did not stop on idle\n")
            printk0("[hrtimer-test] FAIL\n")
            return
        # "Idle" for ~30 ms of real time (3 jiffies) — the periodic tick
        # would have fired 3 times; NO_HZ slept through them.
        _ts_busywait_ns(30000000)              # 30 ms
        tick_nohz_idle_exit()
        if tick_nohz_is_active() != 0:
            printk0("[hrtimer-test] T4 FAIL: tick still stopped after exit\n")
            printk0("[hrtimer-test] FAIL\n")
            return
        skipped: uint64 = tick_nohz_skipped_jiffies_total() - before_skipped
        printk1("[hrtimer-test] T4 skipped_jiffies=%d (expected ~3)\n", skipped)
        # The 30 ms idle should account ~3 jiffies (10 ms each). Allow
        # [2, 6] for busy-wait overshoot.
        if skipped < 2 or skipped > 6:
            printk0("[hrtimer-test] T4 FAIL: skipped-jiffies accounting wrong\n")
            printk0("[hrtimer-test] FAIL\n")
            return
        printk0("[hrtimer-test] T4 PASS: NO_HZ stopped tick, time accounted on wake\n")

    # --- T5: POSIX CLOCK_PROCESS_CPUTIME_ID timer ---------------------
    # Arm a CPU-time timer for pid 1 with a 5,000,000 ns (5 ms CPU-time)
    # threshold; feed increasing CPU-time and confirm it fires once the
    # threshold is crossed, not before.
    pt: int64 = posix_cpu_timer_create(1, 0)   # pid 1, process scope
    if pt < 0:
        printk0("[hrtimer-test] T5 FAIL: posix_cpu_timer_create\n")
        printk0("[hrtimer-test] FAIL\n")
        return
    posix_cpu_timer_set(cast[uint64](pt), 5000000, 0)   # 5 ms, one-shot
    # Below threshold: no fire.
    f0: uint64 = posix_cpu_timers_run(1, 0, 3000000)    # 3 ms consumed
    # At/over threshold: fires.
    f1: uint64 = posix_cpu_timers_run(1, 0, 6000000)    # 6 ms consumed
    over: uint64 = posix_cpu_timer_overruns(cast[uint64](pt))
    printk2("[hrtimer-test] T5 below=%d crossed=%d\n", f0, f1)
    if f0 != 0:
        printk0("[hrtimer-test] T5 FAIL: fired below threshold\n")
        printk0("[hrtimer-test] FAIL\n")
        return
    if f1 == 0 or over == 0:
        printk0("[hrtimer-test] T5 FAIL: did not fire at threshold\n")
        printk0("[hrtimer-test] FAIL\n")
        return
    printk0("[hrtimer-test] T5 PASS: posix CPU-time timer fired at threshold\n")

    # --- T6: jiffies tracks REAL time, not the timer-IRQ count ----------
    # Regression guard for the "DE uptime runs fast" bug. In high-res one-shot
    # mode the LAPIC fires once per pending hrtimer, so the arch ISR's old
    # per-IRQ `jiffies += 1` over-counted whenever user hrtimers fired between
    # scheduler ticks — uptime (get_jiffies()/HZ) advanced faster than wall
    # clock. jiffies is now derived from the monotonic clocksource. Prove it:
    # hammer the accounting entry thousands of times across a fixed ~30 ms real
    # window (simulating an IRQ storm) and assert jiffies advanced by ~the real
    # elapsed jiffies (3), NOT by the number of calls.
    if tick_jiffies_is_clocksource_driven() == 0:
        printk0("[hrtimer-test] T6 SKIP: jiffies not clocksource-driven (no HW clock)\n")
    else:
        t6_before: uint64 = clocksource_read_ns()
        j6_before: uint64 = get_jiffies()
        calls: uint64 = 0
        # Busy ~100 ms of REAL time, hammering the accounting on every spin.
        # Under the OLD per-IRQ bug a bump per call would run jiffies up by the
        # call count (hundreds of thousands); the clocksource-driven count must
        # instead advance by ~10 (100 ms / 10 ms) regardless of call count.
        while (clocksource_read_ns() - t6_before) < 100000000:
            tick_account_jiffies_now()
            calls = calls + 1
        t6_after: uint64 = clocksource_read_ns()
        j6_after: uint64 = get_jiffies()
        advanced: uint64 = j6_after - j6_before
        real_jiffies: uint64 = (t6_after - t6_before) / 10000000
        printk2("[hrtimer-test] T6 advanced=%d real=%d\n", advanced, real_jiffies)
        printk2("[hrtimer-test] T6 calls=%d (a per-call bump would ~= this)\n",
                calls, advanced)
        # jiffies must track real time (allow a few jiffies of window-boundary +
        # live-ISR slop) and be nowhere near the call count.
        lo: uint64 = 0
        if real_jiffies > 3:
            lo = real_jiffies - 3
        if advanced < lo or advanced > real_jiffies + 3:
            printk0("[hrtimer-test] T6 FAIL: jiffies did not track real time\n")
            printk0("[hrtimer-test] FAIL\n")
            return
        # The old per-IRQ bug advanced ~= calls; a real-time count is < 1% of it.
        if calls > 1000 and advanced >= calls / 100:
            printk0("[hrtimer-test] T6 FAIL: jiffies tracked IRQ count, not time\n")
            printk0("[hrtimer-test] FAIL\n")
            return
        printk0("[hrtimer-test] T6 PASS: jiffies tracks real time, not IRQ count\n")

    printk0("[hrtimer-test] PASS\n")

# kernel/time/clockevent.ad
#
# Linux-shape clock-event device abstraction. Mirrors kernel/time/
# clockevents.c + include/linux/clockchips.h. Where a clockSOURCE reads
# the current time, a clockEVENT *programs a future interrupt* — it is
# the hardware that fires the tick + drives hrtimer deadlines.
#
#   struct clock_event_device {
#       int  (*set_next_event)(unsigned long evt, struct ...);
#       void (*set_state_oneshot)(...);
#       void (*set_state_periodic)(...);
#       u32  mult; u32 shift;          // ns->cycles programming scale
#       enum clock_event_state state;  // SHUTDOWN/PERIODIC/ONESHOT
#   };
#
# Hamnix backs the clockevent with the Local APIC timer (per-CPU, the
# canonical Linux x86 lapic_clockevent). The key operation is
# clockevent_set_next_event_ns(delta_ns): arm the LAPIC for a SINGLE
# deadline delta_ns out, in one-shot mode. The tick layer + hrtimer
# layer call this to program the exact next expiry instead of relying on
# the fixed 100 Hz periodic interrupt.
#
# Two modes, mirroring Linux:
#   CLOCK_EVT_STATE_PERIODIC  — legacy fixed-rate tick (100 Hz). Default
#                               at boot; the scheduler tick lives here.
#   CLOCK_EVT_STATE_ONESHOT   — high-resolution / dynticks mode. The ISR
#                               does NOT auto-re-arm; the tick handler
#                               programs the next event each fire.
#
# A clockevent in one-shot mode has a min/max programmable delta. We
# clamp requests into [MIN_DELTA_NS, MAX_DELTA_NS]; a request below the
# floor fires at the floor (Linux's min_delta_ns, avoids "lost timer"
# where the deadline is already past by the time the write lands).

from kernel.printk.printk import printk0, printk1
from arch.x86.kernel.apic import (
    lapic_timer_set_oneshot_ns, lapic_timer_set_periodic_100hz,
    lapic_timer_stop, lapic_timer_hz_get,
)

# Clock-event states (subset of enum clock_event_state).
CLOCK_EVT_STATE_SHUTDOWN: uint64 = 0
CLOCK_EVT_STATE_PERIODIC: uint64 = 1
CLOCK_EVT_STATE_ONESHOT:  uint64 = 2

# Programmable one-shot bounds. Floor: a deadline closer than ~1 us is
# treated as "fire ASAP" (the write + return latency exceeds it). Ceil:
# the LAPIC 32-bit count at tens of MHz tops out around tens of seconds;
# we cap a single one-shot at 1 s and let the tick layer re-program for
# longer idles (it re-arms on each wake).
CLOCKEVT_MIN_DELTA_NS: uint64 = 1000              # 1 us
CLOCKEVT_MAX_DELTA_NS: uint64 = 1000000000        # 1 s

# Current programmed state of the (single, BSP for now) clockevent.
ce_state:        uint64 = 1     # boot default: PERIODIC (legacy tick)
ce_available:    uint8  = 0     # 1 once clockevent_init() ran
# Bookkeeping for diagnostics + the NO_HZ accounting: the last absolute
# ns deadline we programmed in one-shot mode (0 = none pending).
ce_next_deadline_ns: uint64 = 0


def clockevent_init() -> int32:
    # Bring the clockevent online. The LAPIC timer must already be
    # calibrated (lapic_calibrate_and_setup_timer ran at boot:12) so the
    # ns->ticks conversion is valid. Leaves the device in PERIODIC state
    # — the legacy scheduler tick keeps running until the tick layer
    # explicitly switches to one-shot.
    if lapic_timer_hz_get() == 0:
        printk0("clockevent: LAPIC timer uncalibrated — one-shot unavailable\n")
        ce_available = 0
        return -1
    ce_available = 1
    ce_state = CLOCK_EVT_STATE_PERIODIC
    printk1("clockevent: lapic one-shot ready (timer %d Hz)\n",
            lapic_timer_hz_get())
    return 0


def clockevent_available() -> int32:
    return cast[int32](ce_available)


def clockevent_get_state() -> uint64:
    return ce_state


def clockevent_set_next_event_ns(delta_ns: uint64) -> int32:
    # Arm the clockevent (LAPIC) to fire once delta_ns from now. Switches
    # the device into ONESHOT state. Returns 0 on success, -1 if the
    # device is unavailable (caller stays on the periodic tick).
    #
    # This is THE primitive hrtimers + NO_HZ use to program the exact
    # next deadline.
    if ce_available == 0:
        return -1
    d: uint64 = delta_ns
    if d < CLOCKEVT_MIN_DELTA_NS:
        d = CLOCKEVT_MIN_DELTA_NS
    if d > CLOCKEVT_MAX_DELTA_NS:
        d = CLOCKEVT_MAX_DELTA_NS
    rc: int32 = lapic_timer_set_oneshot_ns(d)
    if rc != 0:
        return -1
    ce_state = CLOCK_EVT_STATE_ONESHOT
    return 0


def clockevent_set_periodic() -> int32:
    # Return the clockevent to the legacy 100 Hz periodic tick. Used when
    # leaving NO_HZ / one-shot mode (e.g. high-resolution timers disabled
    # or the box is busy enough that the periodic tick is cheaper).
    if ce_available == 0:
        return -1
    lapic_timer_set_periodic_100hz()
    ce_state = CLOCK_EVT_STATE_PERIODIC
    ce_next_deadline_ns = 0
    return 0


def clockevent_shutdown():
    # Mask the device — no further firings until re-armed. Used by the
    # deepest idle path that programs a one-shot on demand.
    if ce_available == 0:
        return
    lapic_timer_stop()
    ce_state = CLOCK_EVT_STATE_SHUTDOWN
    ce_next_deadline_ns = 0


def clockevent_record_deadline(abs_ns: uint64):
    # The tick layer records the absolute deadline it programmed so NO_HZ
    # accounting + diagnostics can see what's pending.
    ce_next_deadline_ns = abs_ns


def clockevent_next_deadline_ns() -> uint64:
    return ce_next_deadline_ns


def clockevent_is_oneshot() -> int32:
    if ce_state == CLOCK_EVT_STATE_ONESHOT:
        return 1
    return 0

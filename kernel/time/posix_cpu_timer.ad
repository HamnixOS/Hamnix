# kernel/time/posix_cpu_timer.ad
#
# POSIX per-process / per-thread CPU-time timers. Mirrors
# kernel/time/posix-cpu-timers.c. These are the timers created by
#   timer_create(CLOCK_PROCESS_CPUTIME_ID, ...)
#   timer_create(CLOCK_THREAD_CPUTIME_ID, ...)
# and armed with timer_settime(). Unlike a hrtimer (which fires at an
# absolute *wall* / monotonic ns deadline), a CPU-time timer fires when
# the target task/process has CONSUMED a given amount of CPU time —
# measured in scheduler ticks (utime+stime) here.
#
# The check cannot ride the hrtimer wheel (the deadline is in CPU-time,
# not wall-time), so — exactly like Linux's run_posix_cpu_timers() — it
# is evaluated from the timer tick: posix_cpu_timers_run() is called once
# per tick with the currently-running task's accumulated CPU nanoseconds,
# and expires any timer whose CPU-time threshold has been crossed.
#
# A fired CPU-timer raises a pending notification (SIGEV_SIGNAL would
# deliver SIGALRM in full Linux; here we expose a pending-count the
# selftest + a future posix-timer syscall layer read). Interval timers
# (it_interval != 0) re-arm at threshold + interval.
#
# clockids:
#   CLOCK_PROCESS_CPUTIME_ID = 2  (sum of all threads' CPU time)
#   CLOCK_THREAD_CPUTIME_ID  = 3  (one thread's CPU time)
# We track per-timer the owning pid and a "thread vs process" flag; the
# CPU-time fed in by the caller selects scope.

from kernel.printk.printk import printk0, printk1

CLOCK_PROCESS_CPUTIME_ID: uint64 = 2
CLOCK_THREAD_CPUTIME_ID:  uint64 = 3

MAX_CPU_TIMERS: uint64 = 64

# Parallel arrays.
pct_used:       Array[64, uint64]   # 1 = slot allocated
pct_armed:      Array[64, uint64]   # 1 = counting toward a threshold
pct_pid:        Array[64, uint64]   # owning pid (scope key)
pct_is_thread:  Array[64, uint64]   # 1 = CLOCK_THREAD_CPUTIME_ID scope
pct_expiry_ns:  Array[64, uint64]   # CPU-time threshold, ns
pct_interval_ns:Array[64, uint64]   # re-arm interval, ns (0 = one-shot)
pct_fired:      Array[64, uint64]   # total expirations (overrun-ish count)

pct_count: uint64 = 0
pct_total_fired: uint64 = 0


def posix_cpu_timers_init():
    i: uint64 = 0
    while i < MAX_CPU_TIMERS:
        pct_used[i]   = 0
        pct_armed[i]  = 0
        pct_fired[i]  = 0
        i = i + 1
    pct_count = 0
    pct_total_fired = 0


def posix_cpu_timer_create(pid: uint64, is_thread: uint64) -> int64:
    # Allocate a CPU-time timer for `pid`. Returns a timer id (slot) or -1.
    i: uint64 = 0
    while i < MAX_CPU_TIMERS:
        if pct_used[i] == 0:
            pct_used[i]      = 1
            pct_armed[i]     = 0
            pct_pid[i]       = pid
            pct_is_thread[i] = is_thread
            pct_expiry_ns[i] = 0
            pct_interval_ns[i] = 0
            pct_fired[i]     = 0
            pct_count = pct_count + 1
            return cast[int64](i)
        i = i + 1
    return -1


def posix_cpu_timer_set(slot: uint64, value_ns: uint64,
                        interval_ns: uint64) -> int32:
    # Arm timer `slot` to fire when the owning task accumulates value_ns
    # of CPU time, re-arming every interval_ns thereafter (0 = one-shot).
    # value_ns == 0 disarms (timer_settime with it_value 0).
    if slot >= MAX_CPU_TIMERS or pct_used[slot] == 0:
        return -1
    if value_ns == 0:
        pct_armed[slot] = 0
        return 0
    pct_expiry_ns[slot]   = value_ns
    pct_interval_ns[slot] = interval_ns
    pct_armed[slot]       = 1
    return 0


def posix_cpu_timer_cancel(slot: uint64) -> int32:
    if slot >= MAX_CPU_TIMERS or pct_used[slot] == 0:
        return -1
    pct_armed[slot] = 0
    return 0


def posix_cpu_timer_destroy(slot: uint64):
    if slot >= MAX_CPU_TIMERS:
        return
    if pct_used[slot] == 1:
        pct_used[slot]  = 0
        pct_armed[slot] = 0
        pct_count = pct_count - 1


def posix_cpu_timer_overruns(slot: uint64) -> uint64:
    if slot >= MAX_CPU_TIMERS:
        return 0
    return pct_fired[slot]


def posix_cpu_timers_run(pid: uint64, is_thread: uint64,
                         cpu_time_ns: uint64) -> uint64:
    # Called from the timer tick with the currently-running task's pid +
    # accumulated CPU time (ns). Expire any armed CPU-timer scoped to this
    # pid whose threshold has been crossed. Returns the number fired this
    # pass. Interval timers re-arm at threshold + interval; one-shots
    # disarm.
    fired: uint64 = 0
    i: uint64 = 0
    while i < MAX_CPU_TIMERS:
        if pct_used[i] == 1 and pct_armed[i] == 1 and pct_pid[i] == pid:
            # Scope match: a THREAD timer only fires on its own thread's
            # CPU time; a PROCESS timer fires on the process aggregate.
            # Caller passes the appropriate cpu_time_ns; we just compare.
            scope_ok: uint64 = 1
            if pct_is_thread[i] != is_thread:
                scope_ok = 0
            if scope_ok == 1 and cpu_time_ns >= pct_expiry_ns[i]:
                fired = fired + 1
                pct_fired[i] = pct_fired[i] + 1
                pct_total_fired = pct_total_fired + 1
                if pct_interval_ns[i] != 0:
                    # Re-arm at the next interval boundary past now.
                    nxt: uint64 = pct_expiry_ns[i]
                    while nxt <= cpu_time_ns:
                        nxt = nxt + pct_interval_ns[i]
                    pct_expiry_ns[i] = nxt
                else:
                    pct_armed[i] = 0
        i = i + 1
    return fired


def posix_cpu_timers_total_fired() -> uint64:
    return pct_total_fired

# kernel/seccomp_bpf.ad
#
# Classic-BPF (cBPF) interpreter for Linux seccomp-bpf. Mirrors
# net/core/filter.c (the cBPF VM) plus kernel/seccomp.c (the seccomp
# program harness) in Linux. Until this module landed, Hamnix's
# seccomp(2) / prctl(PR_SET_SECCOMP) "FILTER" mode accepted only a
# 256-bit syscall-number allow-list bitmap — a deliberate "lite"
# stand-in (see linux_abi/u_syscalls.ad §#160). With this module
# Hamnix accepts a real `struct sock_fprog *` and runs the user's
# compiled cBPF program at every Linux-ABI syscall entry, against
# the standard `struct seccomp_data { int nr; __u32 arch; __u64
# instruction_pointer; __u64 args[6]; }`.
#
#                     ----- cBPF VM SHAPE -----
#
# A cBPF program is an array of 8-byte instructions:
#
#     struct sock_filter { u16 code; u8 jt; u8 jf; u32 k; };
#
# The VM has:
#   * 32-bit accumulator  A
#   * 32-bit index        X
#   * 16 x 32-bit scratch CBPF_MEMWORDS
#   * implicit pc; conditional jumps name jt/jf as forward offsets
#
# `seccomp_data` is treated as a byte buffer for CBPF_LD|CBPF_ABS|CBPF_W
# loads — k=0 is the nr field, k=4 is arch, k=8 is rip, k=16+i*8 are
# args[i]. Loads that fall outside the seccomp_data buffer terminate
# the program with SECCOMP_RET_KILL_PROCESS, matching Linux.
#
# Return action is the program's CBPF_RET value. Lower 16 bits are
# DATA (errno for ERRNO, signo for TRAP, tracer cookie for TRACE).
# Upper bits encode the ACTION; Linux uses the LOWEST 32-bit value
# across all installed filters as the binding action, which orders
# KILL < KILL_THREAD < TRAP < ERRNO < USER_NOTIF < TRACE < LOG <
# ALLOW. `bpf_run_all` returns that minimum.
#
#                     ----- PER-TASK STATE -----
#
# A task can install MULTIPLE filters (Linux semantics: each new
# install prepends; all of them run on every syscall; the binding
# action is the lowest across them). We cap at MAX_FILTERS_PER_TASK.
#
# Storage is a global program pool indexed by [task_slot][filter_idx],
# rather than embedded in TaskStruct: TaskStruct is in
# kernel/sched/core.ad and growing it with variable-length instruction
# arrays would shift every field offset and risk a cascade of test
# breakage. The pool here is sized for the test fixture + a comfortable
# headroom — easy to bump if real workloads need more.
#
# Fork/clone INHERITS the parent's BPF filters into the child, in the
# same order, exactly as Linux does (and exactly like the existing
# Layer-2 bitmap filter + Layer-1 native bitmap filter do; see
# arch/x86/kernel/syscall.ad::seccomp_inherit_to_child).

from kernel.printk.printk import printk1
from mm.uaccess import copy_from_user
# Single source of truth for the per-task slot count. NTASKS lives in
# kernel/sched/core.ad (the scheduler owns task_table). Importing it here
# means a future NTASKS lift updates this module's bounds check ATOMICALLY,
# closing the historical fail-open gap where NTASKS=16 silently lagged a
# core.ad bump to 64 and let tasks in slots 16-63 bypass their BPF filter.
# (core.ad does NOT import this module, so no import cycle.)
from kernel.sched.core import NTASKS


# ---------------------------------------------------------------------
# cBPF opcode encoding (Linux <linux/bpf_common.h>, <linux/filter.h>).
# Each `code` u16 packs (class | size | mode) for loads/stores or
# (class | op | src) for ALU/JMP. We name the bits we use; the rest of
# the cBPF instruction set is either not generated by libseccomp or
# would be a wasted lift for a seccomp interpreter.
# ---------------------------------------------------------------------

# Instruction CLASS (low 3 bits).
CBPF_LD:     uint16 = 0x00
CBPF_LDX:    uint16 = 0x01
CBPF_ST:     uint16 = 0x02
CBPF_STX:    uint16 = 0x03
CBPF_ALU:    uint16 = 0x04
CBPF_JMP:    uint16 = 0x05
CBPF_RET:    uint16 = 0x06
CBPF_MISC:   uint16 = 0x07
CBPF_CLASS_MASK: uint16 = 0x07

# Size (bits 3-4): W=32, H=16, B=8. Seccomp only uses W.
CBPF_W:      uint16 = 0x00
CBPF_H:      uint16 = 0x08
CBPF_B:      uint16 = 0x10
CBPF_SIZE_MASK: uint16 = 0x18

# Mode (bits 5-7).
CBPF_IMM:    uint16 = 0x00
CBPF_ABS:    uint16 = 0x20
CBPF_IND:    uint16 = 0x40
CBPF_MEM:    uint16 = 0x60
CBPF_LEN:    uint16 = 0x80
CBPF_MSH:    uint16 = 0xa0
CBPF_MODE_MASK: uint16 = 0xe0

# ALU ops (bits 4-7).
CBPF_ADD:    uint16 = 0x00
CBPF_SUB:    uint16 = 0x10
CBPF_MUL:    uint16 = 0x20
CBPF_DIV:    uint16 = 0x30
CBPF_OR:     uint16 = 0x40
CBPF_AND:    uint16 = 0x50
CBPF_LSH:    uint16 = 0x60
CBPF_RSH:    uint16 = 0x70
CBPF_NEG:    uint16 = 0x80
CBPF_MOD:    uint16 = 0x90
CBPF_XOR:    uint16 = 0xa0
CBPF_OP_MASK: uint16 = 0xf0

# JMP ops (bits 4-7).
CBPF_JA:     uint16 = 0x00
CBPF_JEQ:    uint16 = 0x10
CBPF_JGT:    uint16 = 0x20
CBPF_JGE:    uint16 = 0x30
CBPF_JSET:   uint16 = 0x40

# Source (bit 3): 0=K (immediate), 1=X (index register).
CBPF_K:      uint16 = 0x00
CBPF_X:      uint16 = 0x08
CBPF_SRC_MASK: uint16 = 0x08

# MISC ops (bits 4-7).
CBPF_TAX:    uint16 = 0x00
CBPF_TXA:    uint16 = 0x80

# Return source (CBPF_RET): K=immediate, A=accumulator. (Bit 4-7.)
CBPF_RVAL_K: uint16 = 0x00
CBPF_RVAL_A: uint16 = 0x10

# ---------------------------------------------------------------------
# Linux seccomp return-action constants (<linux/seccomp.h>). The lower
# 16 bits are the DATA field (errno, signo, cookie); upper bits encode
# the ACTION. Linux picks the LOWEST 32-bit return value across all
# installed filters as the binding action.
# ---------------------------------------------------------------------
SECCOMP_RET_KILL_PROCESS: uint32 = 0x80000000
SECCOMP_RET_KILL_THREAD:  uint32 = 0x00000000  # alias: SECCOMP_RET_KILL
SECCOMP_RET_TRAP:         uint32 = 0x00030000
SECCOMP_RET_ERRNO:        uint32 = 0x00050000
SECCOMP_RET_USER_NOTIF:   uint32 = 0x7fc00000
SECCOMP_RET_TRACE:        uint32 = 0x7ff00000
SECCOMP_RET_LOG:          uint32 = 0x7ffc0000
SECCOMP_RET_ALLOW:        uint32 = 0x7fff0000
SECCOMP_RET_ACTION_FULL:  uint32 = 0xffff0000
SECCOMP_RET_DATA:         uint32 = 0x0000ffff

# AUDIT_ARCH_X86_64 (Linux <linux/audit.h>). Exposed to the filter via
# `seccomp_data.arch` so a portable filter can reject foreign arches.
AUDIT_ARCH_X86_64: uint32 = 0xc000003e

# ---------------------------------------------------------------------
# Pool / per-task caps.
# ---------------------------------------------------------------------
# The per-task slot bound is the scheduler's NTASKS (imported above), used
# DIRECTLY in bpf_run_all's bounds check so a high slot can never silently
# bypass its filter. The Array dims below MUST stay literal (Adder requires
# literal array sizes) but are kept == NTASKS by hand; Adder also forbids
# initialising a global from another global, so there is intentionally NO local
# MAX_TASKS alias to drift — every check references the imported NTASKS.
MAX_FILTERS_PER_TASK:    uint64 = 2
MAX_BPF_PROGRAMS:        uint64 = 512  # NTASKS(256) * MAX_FILTERS_PER_TASK(2)
MAX_BPF_INSNS:           uint64 = 128  # per program (~enough for libseccomp)
CBPF_MEMWORDS:            uint64 = 16


# A live BPF program slot. cBPF instructions (Linux struct sock_filter:
# u16 code, u8 jt, u8 jf, u32 k — 8 bytes packed) are stored as a flat
# array of uint64 words so a copy_from_user fills them verbatim
# regardless of any Adder struct-padding choice on a class with mixed
# u16/u8/u32 fields. Decoded at use time inside bpf_run.
class BpfProgram:
    in_use: uint64                          # 0 = free, 1 = installed
    length: uint64                          # number of valid insns
    insns:  Array[128, uint64]              # MAX_BPF_INSNS, packed


# Global program pool. Index 0..MAX_BPF_PROGRAMS-1; in_use=0 marks free.
_bpf_pool: Array[512, BpfProgram]           # MAX_BPF_PROGRAMS (NTASKS*MAX_FILTERS_PER_TASK)

# Per-task installed-filter lists. _bpf_task_count[slot] gives how many
# filters are armed; _bpf_task_progs[slot][i] is the pool index (or
# 0xffffffffffffffff if unused). Dims are literal but == NTASKS (256) /
# MAX_FILTERS_PER_TASK (2); the gap-check test asserts the size match.
_bpf_task_count: Array[256, uint64]                  # NTASKS == NTASKS
_bpf_task_progs: Array[256, Array[2, uint64]]        # NTASKS x MAX_FILTERS_PER_TASK

BPF_SLOT_NONE: uint64 = 0xffffffffffffffff


# seccomp_data view (passed to bpf_run_all as a byte buffer). Layout
# matches Linux <linux/seccomp.h>:
#
#   struct seccomp_data {
#       int      nr;                  // offset 0,  4 bytes
#       __u32    arch;                // offset 4,  4 bytes
#       __u64    instruction_pointer; // offset 8,  8 bytes
#       __u64    args[6];             // offset 16, 48 bytes
#   };                                // total 64 bytes
#
# We store it as Array[64, uint8] so CBPF_ABS loads can index it
# bytewise the way the cBPF spec requires.
SECCOMP_DATA_LEN: uint64 = 64


def _bpf_pool_alloc() -> uint64:
    # Pick the lowest-index free pool slot. Returns BPF_SLOT_NONE on
    # exhaustion; caller treats that as -ENOMEM.
    i: uint64 = 0
    while i < MAX_BPF_PROGRAMS:
        if _bpf_pool[i].in_use == 0:
            return i
        i = i + 1
    return BPF_SLOT_NONE


def _bpf_pool_free(idx: uint64):
    if idx >= MAX_BPF_PROGRAMS:
        return
    _bpf_pool[idx].in_use = 0
    _bpf_pool[idx].length = 0


# Bounds-checked 32-bit load from the seccomp_data byte buffer. Returns
# (value, ok). `ok==0` signals the program tried to read past the end
# of seccomp_data — the program is aborted with KILL_PROCESS, matching
# Linux net/core/filter.c::__skb_get_nlattr OOB behaviour.
def _sd_load_w(sd: Ptr[uint8], off: uint32) -> uint64:
    # Returns ((value & 0xffffffff) | (ok << 32)). 0 in the high word
    # means OOB. Adder lacks multi-value return so we pack into uint64.
    o: uint64 = cast[uint64](off)
    if o + 4 > SECCOMP_DATA_LEN:
        return 0
    # Little-endian load (x86_64 native byte order, same as Linux cBPF).
    b0: uint64 = cast[uint64](sd[o])
    b1: uint64 = cast[uint64](sd[o + 1])
    b2: uint64 = cast[uint64](sd[o + 2])
    b3: uint64 = cast[uint64](sd[o + 3])
    v: uint64 = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)
    return v | (cast[uint64](1) << 32)


def _u32(x: uint64) -> uint32:
    return cast[uint32](x & 0xffffffff)


def bpf_run(prog_idx: uint64, sd: Ptr[uint8]) -> uint32:
    # Run one cBPF program over `sd` (seccomp_data, 64 bytes). Returns
    # the program's RET value (action | data), or SECCOMP_RET_KILL_PROCESS
    # if the program aborts (OOB load, div-by-zero, instruction-count
    # cap, unsupported opcode, missing RET — all "kernel killed it"
    # outcomes, the same outcome Linux's __seccomp_filter takes when a
    # program is malformed).
    if prog_idx >= MAX_BPF_PROGRAMS:
        return SECCOMP_RET_KILL_PROCESS
    if _bpf_pool[prog_idx].in_use == 0:
        return SECCOMP_RET_KILL_PROCESS

    plen: uint64 = _bpf_pool[prog_idx].length
    if plen == 0 or plen > MAX_BPF_INSNS:
        return SECCOMP_RET_KILL_PROCESS

    # VM state.
    A: uint32 = 0
    X: uint32 = 0
    mem: Array[16, uint32]                     # CBPF_MEMWORDS
    mi: uint64 = 0
    while mi < CBPF_MEMWORDS:
        mem[mi] = 0
        mi = mi + 1

    pc: uint64 = 0
    steps: uint64 = 0
    # Hard cap on dynamic instruction count to defend against a
    # backward-jumping program (cBPF doesn't allow them, but a malformed
    # k-offset on JA can synthesise one if we treated jumps signed; we
    # treat them as unsigned forward-only, but the cap is belt-and-braces).
    step_cap: uint64 = MAX_BPF_INSNS * 4

    while pc < plen and steps < step_cap:
        steps = steps + 1
        word: uint64 = _bpf_pool[prog_idx].insns[pc]
        insn_code: uint16 = cast[uint16](word & 0xffff)
        insn_jt:   uint8  = cast[uint8]((word >> 16) & 0xff)
        insn_jf:   uint8  = cast[uint8]((word >> 24) & 0xff)
        insn_k:    uint32 = cast[uint32]((word >> 32) & 0xffffffff)

        klass: uint16 = insn_code & CBPF_CLASS_MASK

        if klass == CBPF_LD:
            # 32-bit load into A. Modes: IMM (A=k), ABS (A=sd[k..k+3]),
            # MEM (A=mem[k]), LEN (A=sizeof(sd)).
            mode: uint16 = insn_code & CBPF_MODE_MASK
            size: uint16 = insn_code & CBPF_SIZE_MASK
            if size != CBPF_W:
                # Seccomp programs never use H/B loads against
                # seccomp_data (the only field that fits H is alignment
                # padding); reject as malformed.
                return SECCOMP_RET_KILL_PROCESS
            if mode == CBPF_IMM:
                A = insn_k
            elif mode == CBPF_ABS:
                ld_pk: uint64 = _sd_load_w(sd, insn_k)
                if (ld_pk >> 32) == 0:
                    return SECCOMP_RET_KILL_PROCESS
                A = _u32(ld_pk)
            elif mode == CBPF_MEM:
                if cast[uint64](insn_k) >= CBPF_MEMWORDS:
                    return SECCOMP_RET_KILL_PROCESS
                A = mem[cast[uint64](insn_k)]
            elif mode == CBPF_LEN:
                A = cast[uint32](SECCOMP_DATA_LEN)
            else:
                # IND / MSH are not used by seccomp.
                return SECCOMP_RET_KILL_PROCESS
            pc = pc + 1

        elif klass == CBPF_LDX:
            # Load into X. Modes: IMM (X=k), MEM (X=mem[k]), LEN (X=len).
            mode_x: uint16 = insn_code & CBPF_MODE_MASK
            size_x: uint16 = insn_code & CBPF_SIZE_MASK
            if size_x != CBPF_W:
                return SECCOMP_RET_KILL_PROCESS
            if mode_x == CBPF_IMM:
                X = insn_k
            elif mode_x == CBPF_MEM:
                if cast[uint64](insn_k) >= CBPF_MEMWORDS:
                    return SECCOMP_RET_KILL_PROCESS
                X = mem[cast[uint64](insn_k)]
            elif mode_x == CBPF_LEN:
                X = cast[uint32](SECCOMP_DATA_LEN)
            else:
                return SECCOMP_RET_KILL_PROCESS
            pc = pc + 1

        elif klass == CBPF_ST:
            if cast[uint64](insn_k) >= CBPF_MEMWORDS:
                return SECCOMP_RET_KILL_PROCESS
            mem[cast[uint64](insn_k)] = A
            pc = pc + 1

        elif klass == CBPF_STX:
            if cast[uint64](insn_k) >= CBPF_MEMWORDS:
                return SECCOMP_RET_KILL_PROCESS
            mem[cast[uint64](insn_k)] = X
            pc = pc + 1

        elif klass == CBPF_ALU:
            op:  uint16 = insn_code & CBPF_OP_MASK
            src: uint16 = insn_code & CBPF_SRC_MASK
            operand: uint32 = insn_k
            if src == CBPF_X:
                operand = X
            if op == CBPF_ADD:
                A = A + operand
            elif op == CBPF_SUB:
                A = A - operand
            elif op == CBPF_MUL:
                A = A * operand
            elif op == CBPF_DIV:
                if operand == 0:
                    return SECCOMP_RET_KILL_PROCESS
                A = A / operand
            elif op == CBPF_MOD:
                if operand == 0:
                    return SECCOMP_RET_KILL_PROCESS
                A = A % operand
            elif op == CBPF_OR:
                A = A | operand
            elif op == CBPF_AND:
                A = A & operand
            elif op == CBPF_XOR:
                A = A ^ operand
            elif op == CBPF_LSH:
                # cBPF spec masks shift to 5 bits (operand & 31).
                A = A << (operand & 31)
            elif op == CBPF_RSH:
                A = A >> (operand & 31)
            elif op == CBPF_NEG:
                A = 0 - A
            else:
                return SECCOMP_RET_KILL_PROCESS
            pc = pc + 1

        elif klass == CBPF_JMP:
            op_j:  uint16 = insn_code & CBPF_OP_MASK
            src_j: uint16 = insn_code & CBPF_SRC_MASK
            cmp_v: uint32 = insn_k
            if src_j == CBPF_X:
                cmp_v = X
            if op_j == CBPF_JA:
                # Unconditional. k is a 32-bit forward offset.
                pc = pc + 1 + cast[uint64](insn_k)
            else:
                taken: uint64 = 0
                if op_j == CBPF_JEQ:
                    if A == cmp_v:
                        taken = 1
                elif op_j == CBPF_JGT:
                    if A > cmp_v:
                        taken = 1
                elif op_j == CBPF_JGE:
                    if A >= cmp_v:
                        taken = 1
                elif op_j == CBPF_JSET:
                    if (A & cmp_v) != 0:
                        taken = 1
                else:
                    return SECCOMP_RET_KILL_PROCESS
                if taken != 0:
                    pc = pc + 1 + cast[uint64](insn_jt)
                else:
                    pc = pc + 1 + cast[uint64](insn_jf)

        elif klass == CBPF_RET:
            rval: uint16 = insn_code & 0x18    # RVAL bits (only K vs A)
            if rval == CBPF_RVAL_A:
                return A
            return insn_k

        elif klass == CBPF_MISC:
            mop: uint16 = insn_code & CBPF_TXA
            if mop == CBPF_TAX:
                # Code 0x00 is also CBPF_LD|IMM|W (0x00) — but we already
                # routed LD above by class. MISC's TAX/TXA distinction
                # is the top bit only.
                if (insn_code & 0x80) == 0:
                    X = A
                else:
                    A = X
            else:
                A = X
            pc = pc + 1

        else:
            return SECCOMP_RET_KILL_PROCESS

    # Fell off the end of the program without a RET. Linux treats this
    # as a malformed program and kills the task.
    return SECCOMP_RET_KILL_PROCESS


def bpf_run_all(slot: uint64, sd: Ptr[uint8]) -> uint32:
    # Run EVERY filter installed on `slot` and return the LOWEST 32-bit
    # result across all of them (Linux's cumulative-min action rule).
    # Returns SECCOMP_RET_ALLOW if the task has no filters installed.
    #
    # FAIL CLOSED: with the per-task arrays sized to NTASKS, every live slot
    # is in range, so slot >= NTASKS is an impossible state (corruption /
    # a future NTASKS lift that missed the array dims). Historically this
    # branch returned ALLOW, which let a task in a slot the table couldn't
    # represent run EVERY syscall with its installed filter ignored — a
    # silent sandbox bypass. KILL the process instead of relaxing policy.
    if slot >= NTASKS:
        return SECCOMP_RET_KILL_PROCESS
    n: uint64 = _bpf_task_count[slot]
    if n == 0:
        return SECCOMP_RET_ALLOW
    best: uint32 = SECCOMP_RET_ALLOW
    i: uint64 = 0
    while i < n and i < MAX_FILTERS_PER_TASK:
        pidx: uint64 = _bpf_task_progs[slot][i]
        if pidx < MAX_BPF_PROGRAMS:
            r: uint32 = bpf_run(pidx, sd)
            if r < best:
                best = r
        i = i + 1
    return best


def bpf_task_has_filter(slot: uint64) -> uint64:
    if slot >= NTASKS:
        return 0
    return _bpf_task_count[slot]


def bpf_install_filter(slot: uint64, filter_addr: uint64,
                       filter_len: uint64) -> int64:
    # Copy `filter_len` cBPF instructions from user address
    # `filter_addr` into a free pool slot and link it onto the task's
    # installed-filter list. Returns 0 on success, negative errno on
    # failure:
    #   -EINVAL (-22) bad length / per-task or pool full / null addr
    #   -EFAULT (-14) user pointer faulted in copy_from_user
    #   -ENOMEM (-12) pool exhausted (treat like EINVAL for the caller)
    if slot >= NTASKS:
        return cast[int64](-22)
    if filter_addr == 0 or filter_len == 0:
        return cast[int64](-22)
    if filter_len > MAX_BPF_INSNS:
        return cast[int64](-22)
    flen: uint64 = filter_len
    fptr: uint64 = filter_addr

    # Per-task filter list full?
    if _bpf_task_count[slot] >= MAX_FILTERS_PER_TASK:
        return cast[int64](-22)

    # Reserve a pool slot.
    pidx: uint64 = _bpf_pool_alloc()
    if pidx == BPF_SLOT_NONE:
        return cast[int64](-12)

    # Copy the filter array from userspace into a local scratch and
    # then pack each 8-byte struct sock_filter into one uint64 word in
    # the program's insns[] slot. Staging through a local buffer keeps
    # the copy_from_user destination unambiguous (a struct-field-of-
    # array address inside a class-array can be miscomputed in some
    # Adder versions; the local Array[uint8] is guaranteed contiguous).
    nbytes: uint64 = flen * 8
    if nbytes > 1024:
        _bpf_pool_free(pidx)
        return cast[int64](-22)
    scratch: Array[1024, uint8]
    si: uint64 = 0
    while si < nbytes:
        scratch[si] = 0
        si = si + 1
    if copy_from_user(cast[uint64](&scratch[0]), fptr, nbytes) != 0:
        _bpf_pool_free(pidx)
        return cast[int64](-14)
    pi: uint64 = 0
    while pi < flen:
        w_pack: uint64 = 0
        bj: uint64 = 0
        while bj < 8:
            w_pack = w_pack | (cast[uint64](scratch[pi * 8 + bj]) << (bj * 8))
            bj = bj + 1
        _bpf_pool[pidx].insns[pi] = w_pack
        pi = pi + 1

    # Cheap validity sweep: every opcode-CLASS must be one of the
    # known ones, and every forward jump target must stay inside the
    # program. A malformed program is rejected at install time rather
    # than at run time (Linux's bpf_check_classic equivalent).
    ii: uint64 = 0
    while ii < flen:
        wd: uint64 = _bpf_pool[pidx].insns[ii]
        c: uint16 = cast[uint16](wd & 0xffff)
        kl: uint16 = c & CBPF_CLASS_MASK
        if kl != CBPF_LD and kl != CBPF_LDX and kl != CBPF_ST and \
           kl != CBPF_STX and kl != CBPF_ALU and kl != CBPF_JMP and \
           kl != CBPF_RET and kl != CBPF_MISC:
            _bpf_pool_free(pidx)
            return cast[int64](-22)
        if kl == CBPF_JMP:
            op_j: uint16 = c & CBPF_OP_MASK
            kk:   uint32 = cast[uint32]((wd >> 32) & 0xffffffff)
            jt:   uint8  = cast[uint8]((wd >> 16) & 0xff)
            jf:   uint8  = cast[uint8]((wd >> 24) & 0xff)
            if op_j == CBPF_JA:
                if ii + 1 + cast[uint64](kk) > flen:
                    _bpf_pool_free(pidx)
                    return cast[int64](-22)
            else:
                if ii + 1 + cast[uint64](jt) > flen:
                    _bpf_pool_free(pidx)
                    return cast[int64](-22)
                if ii + 1 + cast[uint64](jf) > flen:
                    _bpf_pool_free(pidx)
                    return cast[int64](-22)
        ii = ii + 1

    _bpf_pool[pidx].in_use = 1
    _bpf_pool[pidx].length = flen
    ti: uint64 = _bpf_task_count[slot]
    _bpf_task_progs[slot][ti] = pidx
    _bpf_task_count[slot] = ti + 1
    return 0


def bpf_inherit_to_child(child_slot: uint64, parent_slot: uint64):
    # Fork/clone inheritance: every filter the parent has is duplicated
    # into the child (separate pool slots so a later install on either
    # parent or child can't reach across). Silently no-ops on pool
    # exhaustion mid-copy — the child ends up with a STRICT SUBSET of
    # the parent's filters, which is the unsafe direction. To stay safe
    # we walk the parent's list and bail to "kill the child" semantics
    # if any inherit fails: callers (arch/x86/kernel/syscall.ad) treat a
    # nonzero return as a fatal fork failure (NYI here — see comment).
    if child_slot >= NTASKS or parent_slot >= NTASKS:
        return
    pn: uint64 = _bpf_task_count[parent_slot]
    if pn == 0:
        return
    i: uint64 = 0
    while i < pn and i < MAX_FILTERS_PER_TASK:
        ppidx: uint64 = _bpf_task_progs[parent_slot][i]
        if ppidx < MAX_BPF_PROGRAMS and _bpf_pool[ppidx].in_use != 0:
            cpidx: uint64 = _bpf_pool_alloc()
            if cpidx == BPF_SLOT_NONE:
                # Pool exhausted: leave the child confined by the
                # filters we've copied so far + a synthetic ALWAYS-KILL
                # filter as belt-and-braces. But the seccomp_check_entry
                # path already treats "missing parent filter" as ALLOW;
                # rather than silently down-grade safety, we leak: keep
                # the partial list. A real production system would
                # propagate -ENOMEM to fork. NYI: fork doesn't have a
                # fault path for this. Document and stop copying.
                printk1("seccomp_bpf: inherit OOM at slot %d\n",
                        cast[int32](child_slot))
                return
            # Copy program metadata + instructions.
            _bpf_pool[cpidx].length = _bpf_pool[ppidx].length
            ji: uint64 = 0
            while ji < _bpf_pool[ppidx].length:
                _bpf_pool[cpidx].insns[ji] = _bpf_pool[ppidx].insns[ji]
                ji = ji + 1
            _bpf_pool[cpidx].in_use = 1
            ci: uint64 = _bpf_task_count[child_slot]
            _bpf_task_progs[child_slot][ci] = cpidx
            _bpf_task_count[child_slot] = ci + 1
        i = i + 1


def bpf_clear(slot: uint64):
    # Release all of `slot`'s pool entries back to the global pool.
    # Called from task-reap (kernel/sched/core.ad sched_init_task_weight)
    # so a recycled slot starts unconfined. Silently no-ops on a slot
    # with no filters.
    if slot >= NTASKS:
        return
    n: uint64 = _bpf_task_count[slot]
    i: uint64 = 0
    while i < n and i < MAX_FILTERS_PER_TASK:
        pidx: uint64 = _bpf_task_progs[slot][i]
        if pidx < MAX_BPF_PROGRAMS:
            _bpf_pool_free(pidx)
        _bpf_task_progs[slot][i] = BPF_SLOT_NONE
        i = i + 1
    _bpf_task_count[slot] = 0


# ---------------------------------------------------------------------
# seccomp_data scratch: rebuilt at every syscall entry by the dispatch
# gate (linux_abi/u_syscalls.ad::seccomp_check_entry). One global buffer
# is enough — syscall entry is not re-entrant on a single CPU (the
# Linux-ABI dispatch path runs with the kernel scheduler holding the
# task on this CPU until it returns), and the kernel BKL-style behaviour
# of the existing seccomp gate already serializes this. If we ever go
# preemptible inside the dispatch gate we'll percpu this.
# ---------------------------------------------------------------------
_seccomp_data_scratch: Array[64, uint8]


def bpf_seccomp_data_build(nr: uint64, rip: uint64,
                           a0: uint64, a1: uint64, a2: uint64,
                           a3: uint64, a4: uint64, a5: uint64) -> Ptr[uint8]:
    # Populate the global seccomp_data buffer for one syscall and
    # return a pointer to it (suitable for bpf_run / bpf_run_all).
    # Field offsets per Linux <linux/seccomp.h> seccomp_data layout
    # (see SECCOMP_DATA_LEN comment above).
    i: uint64 = 0
    while i < SECCOMP_DATA_LEN:
        _seccomp_data_scratch[i] = 0
        i = i + 1
    # int nr @ offset 0 (4 bytes, little-endian).
    _seccomp_data_scratch[0] = cast[uint8](nr & 0xff)
    _seccomp_data_scratch[1] = cast[uint8]((nr >> 8) & 0xff)
    _seccomp_data_scratch[2] = cast[uint8]((nr >> 16) & 0xff)
    _seccomp_data_scratch[3] = cast[uint8]((nr >> 24) & 0xff)
    # u32 arch @ offset 4.
    ar: uint64 = cast[uint64](AUDIT_ARCH_X86_64)
    _seccomp_data_scratch[4] = cast[uint8](ar & 0xff)
    _seccomp_data_scratch[5] = cast[uint8]((ar >> 8) & 0xff)
    _seccomp_data_scratch[6] = cast[uint8]((ar >> 16) & 0xff)
    _seccomp_data_scratch[7] = cast[uint8]((ar >> 24) & 0xff)
    # u64 instruction_pointer @ offset 8.
    _bpf_store_u64(8, rip)
    # u64 args[0..5] @ offset 16, 24, 32, 40, 48, 56.
    _bpf_store_u64(16, a0)
    _bpf_store_u64(24, a1)
    _bpf_store_u64(32, a2)
    _bpf_store_u64(40, a3)
    _bpf_store_u64(48, a4)
    _bpf_store_u64(56, a5)
    return cast[Ptr[uint8]](&_seccomp_data_scratch[0])


def _bpf_store_u64(off: uint64, v: uint64):
    _seccomp_data_scratch[off + 0] = cast[uint8](v & 0xff)
    _seccomp_data_scratch[off + 1] = cast[uint8]((v >> 8) & 0xff)
    _seccomp_data_scratch[off + 2] = cast[uint8]((v >> 16) & 0xff)
    _seccomp_data_scratch[off + 3] = cast[uint8]((v >> 24) & 0xff)
    _seccomp_data_scratch[off + 4] = cast[uint8]((v >> 32) & 0xff)
    _seccomp_data_scratch[off + 5] = cast[uint8]((v >> 40) & 0xff)
    _seccomp_data_scratch[off + 6] = cast[uint8]((v >> 48) & 0xff)
    _seccomp_data_scratch[off + 7] = cast[uint8]((v >> 56) & 0xff)


def seccomp_bpf_init():
    # Module init: drive _bpf_task_progs entries to the "none" sentinel.
    # task_count + pool in_use start zero (BSS) which is the right
    # "disarmed / free" initial state for everything else.
    t: uint64 = 0
    while t < NTASKS:
        f: uint64 = 0
        while f < MAX_FILTERS_PER_TASK:
            _bpf_task_progs[t][f] = BPF_SLOT_NONE
            f = f + 1
        t = t + 1

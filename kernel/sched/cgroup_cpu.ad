# kernel/sched/cgroup_cpu.ad
#
# Real per-cgroup CPU bandwidth (cpu.max) enforcement for the Linux ABI.
#
# This is the keystone the 2026-06-13 gap audit flagged: until now
# /sys/fs/cgroup (#297) was a read-only flat root view — structurally
# valid but no controller actually limited anything. systemd and
# container tools could see the interface files but could not gate
# real CPU usage.
#
# Boundary discipline: Linux cgroup OBJECTS stay in Layer 2 (this file
# is imported by linux_abi/* hooks only). The native scheduler in
# kernel/sched/core.ad reads ONE thing from us — a per-task throttled
# flag, exposed via `cgroup_cpu_should_throttle(slot, from_user)` — but
# the cgroup objects themselves never cross into the native scheduler.
# This composes with the per-namespace CPU cap (#174, devnscap) the
# same way nice/weight composes with per-namespace caps.
#
# Model (cgroup v2 cpu.max, mirroring Linux's CFS bandwidth controller):
#
#   * A cgroup has a quota_us and period_us (e.g. 50000 100000 = 50% of
#     one CPU). period_us == 0 means "max" / uncapped.
#   * At every 100 Hz timer tick that catches a ring-3 user task in the
#     cgroup, we charge TICK_US (10000 us = 10 ms) against the cgroup's
#     used_us_in_period counter. If used_us_in_period >= quota_us the
#     cgroup (and every task in it) is throttled until the period
#     boundary refills it.
#   * A throttled task is forced off the CPU by preempt_tick() returning
#     1, and _pick_next() in core.ad skips throttled tasks (we expose a
#     per-task lookup the scheduler can call cheaply).
#   * Period refill is driven by the same timer ISR via
#     cgroup_cpu_tick_refill(), called once per tick BEFORE the throttle
#     check.
#
# Capacity: 8 cgroups, NTASKS=256 tasks. Names up to 31 bytes (single
# segment, no nesting — cgroup v2 lets sub-cgroups exist but the
# audit's "ONE controller actually enforces a real limit" bar is the
# flat case, and Debian/systemd's most common pattern is one cgroup
# per service at depth 1).

from kernel.printk.printk import printk0, printk2, printk_set_level
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG

# Tick granularity = 10 ms at HZ=100. Matches the rest of the scheduler.
TICK_US: uint64 = 10000

# Capacity. Cgroup slot 0 is reserved for "root" (= no limit). Tasks
# whose cg_id == 0 are NEVER throttled, matching cgroup v2 where the
# root cgroup is always uncapped.
CG_MAX:        uint64 = 8
CG_NAME_LEN:   uint64 = 32
CG_TASKMAX:    uint64 = 512  # mirrors NTASKS (kernel/sched/core.ad)

# CgroupCpu records the per-cgroup state.
class CgroupCpu:
    in_use:           uint64
    # 32-byte name (NUL-terminated). Slot 0 is the literal "" root.
    name:             Array[32, uint8]
    # quota / period in microseconds. period_us == 0 means uncapped.
    quota_us:         uint64
    period_us:        uint64
    # used_us within the current period; reset every period_us window.
    used_us:          uint64
    # ticks remaining until the next period boundary. Counts down from
    # period_us/TICK_US at the start of each period.
    ticks_to_refill:  uint64
    # cumulative throttle accounting (cpu.stat). nr_throttled = number
    # of times the cgroup exhausted its quota in a period;
    # throttled_usec = total time tasks spent throttled.
    nr_throttled:     uint64
    throttled_usec:   uint64
    # cumulative usage (cpu.stat usage_usec). Bumped every charged tick.
    usage_us:         uint64
    # -- pids controller (pids.max / pids.current) ----------------------
    # pids_max == 0 means "max" (uncapped). pids_cur = live tasks charged
    # to this cgroup. cgroup_pids_can_fork() rejects a fork that would
    # push pids_cur PAST pids_max; cgroup_pids_charge/uncharge move the
    # counter as tasks are created / reaped.
    pids_max:         uint64
    pids_cur:         uint64
    # -- memory controller (memory.max / memory.current) ----------------
    # mem_max == 0 means "max" (uncapped). mem_cur = bytes charged to this
    # cgroup (sum of its tasks' charged allocations). mem_peak tracks the
    # high-water mark (memory.peak). nr_oom = times the cgroup OOM-killed.
    mem_max:          uint64
    mem_cur:          uint64
    mem_peak:         uint64
    nr_oom:           uint64

g_cgroups: Array[8, CgroupCpu]

# Per-task cgroup id (parallel to task_table). Default 0 = root = no
# limit. Indexed by task slot (0..NTASKS-1). Kept here, NOT in
# TaskStruct, so we don't conflict with concurrent sibling agents
# extending TaskStruct.
g_task_cg: Array[512, uint64]

g_cg_inited: uint64 = 0


def cgroup_cpu_init():
    if g_cg_inited != 0:
        return
    g_cg_inited = 1
    i: uint64 = 0
    while i < CG_MAX:
        g_cgroups[i].in_use = 0
        g_cgroups[i].quota_us = 0
        g_cgroups[i].period_us = 0
        g_cgroups[i].used_us = 0
        g_cgroups[i].ticks_to_refill = 0
        g_cgroups[i].nr_throttled = 0
        g_cgroups[i].throttled_usec = 0
        g_cgroups[i].usage_us = 0
        g_cgroups[i].pids_max = 0
        g_cgroups[i].pids_cur = 0
        g_cgroups[i].mem_max = 0
        g_cgroups[i].mem_cur = 0
        g_cgroups[i].mem_peak = 0
        g_cgroups[i].nr_oom = 0
        j: uint64 = 0
        while j < CG_NAME_LEN:
            g_cgroups[i].name[j] = 0
            j = j + 1
        i = i + 1
    # Slot 0 = root, perpetually in_use, uncapped.
    g_cgroups[0].in_use = 1
    i = 0
    while i < CG_TASKMAX:
        g_task_cg[i] = 0
        i = i + 1


# -- internal helpers --

def _cg_name_eq(slot: uint64, name: Ptr[char]) -> int32:
    i: uint64 = 0
    while i < CG_NAME_LEN:
        a: uint8 = g_cgroups[slot].name[i]
        b: uint8 = cast[uint8](name[i])
        if a != b:
            return 0
        if a == 0:
            return 1
        i = i + 1
    return 0


def _cg_name_set(slot: uint64, name: Ptr[char]):
    i: uint64 = 0
    while i < CG_NAME_LEN - 1:
        c: uint8 = cast[uint8](name[i])
        g_cgroups[slot].name[i] = c
        if c == 0:
            return
        i = i + 1
    g_cgroups[slot].name[CG_NAME_LEN - 1] = 0


def cgroup_cpu_lookup(name: Ptr[char]) -> int32:
    # Returns the cgroup slot id for `name`, or -1 if not found.
    # Root ("" or "/") is slot 0.
    if cast[uint8](name[0]) == 0:
        return 0
    i: uint64 = 1
    while i < CG_MAX:
        if g_cgroups[i].in_use != 0:
            if _cg_name_eq(i, name) != 0:
                return cast[int32](i)
        i = i + 1
    return -1


def cgroup_cpu_mkdir(name: Ptr[char]) -> int32:
    # Create a new cgroup. Returns the new slot id, or -1 if no room /
    # already exists / invalid name. Layer-2 callers (vfs_mkdir
    # interceptor, write to cgroup.procs, the boot self-test) all use
    # this single entry point.
    if g_cg_inited == 0:
        cgroup_cpu_init()
    if cast[uint8](name[0]) == 0:
        return -1
    existing: int32 = cgroup_cpu_lookup(name)
    if existing >= 0:
        return -1
    i: uint64 = 1
    while i < CG_MAX:
        if g_cgroups[i].in_use == 0:
            g_cgroups[i].in_use = 1
            g_cgroups[i].quota_us = 0
            g_cgroups[i].period_us = 0
            g_cgroups[i].used_us = 0
            g_cgroups[i].ticks_to_refill = 0
            g_cgroups[i].nr_throttled = 0
            g_cgroups[i].throttled_usec = 0
            g_cgroups[i].usage_us = 0
            g_cgroups[i].pids_max = 0
            g_cgroups[i].pids_cur = 0
            g_cgroups[i].mem_max = 0
            g_cgroups[i].mem_cur = 0
            g_cgroups[i].mem_peak = 0
            g_cgroups[i].nr_oom = 0
            _cg_name_set(i, name)
            return cast[int32](i)
        i = i + 1
    return -1


def cgroup_cpu_rmdir(name: Ptr[char]) -> int32:
    # Remove an EMPTY cgroup (rmdir semantics). Returns 0 on success,
    # -2 (-ENOENT) if no such cgroup, -39 (-ENOTEMPTY) if it still has
    # member tasks (pids_cur > 0 or any g_task_cg entry points at it),
    # -16 (-EBUSY)/-22 for the root. Mirrors Linux's cgroup_rmdir which
    # refuses a non-empty cgroup.
    if g_cg_inited == 0:
        cgroup_cpu_init()
    slot: int32 = cgroup_cpu_lookup(name)
    if slot < 1:
        return -2                           # -ENOENT (root or unknown)
    su: uint64 = cast[uint64](slot)
    if g_cgroups[su].in_use == 0:
        return -2
    # Non-empty? Any live task still attached blocks removal.
    if g_cgroups[su].pids_cur != 0:
        return -39                          # -ENOTEMPTY
    i: uint64 = 0
    while i < CG_TASKMAX:
        if g_task_cg[i] == su:
            return -39                      # -ENOTEMPTY
        i = i + 1
    # Tear the slot down so the name is reusable.
    g_cgroups[su].in_use = 0
    g_cgroups[su].quota_us = 0
    g_cgroups[su].period_us = 0
    g_cgroups[su].used_us = 0
    g_cgroups[su].pids_max = 0
    g_cgroups[su].pids_cur = 0
    g_cgroups[su].mem_max = 0
    g_cgroups[su].mem_cur = 0
    g_cgroups[su].mem_peak = 0
    j: uint64 = 0
    while j < CG_NAME_LEN:
        g_cgroups[su].name[j] = 0
        j = j + 1
    return 0


def cgroup_cpu_set_max(slot: int32, quota_us: uint64, period_us: uint64) -> int32:
    # Set the bandwidth window. period_us == 0 disables enforcement
    # (the cgroup v2 "max" convention). Returns 0 on success, -1 on
    # invalid slot, -2 on rules violation (quota > period).
    if slot < 1:
        return -1
    su: uint64 = cast[uint64](slot)
    if su >= CG_MAX:
        return -1
    if g_cgroups[su].in_use == 0:
        return -1
    if period_us != 0:
        if quota_us == 0:
            return -2
        if quota_us > period_us:
            return -2
    g_cgroups[su].quota_us  = quota_us
    g_cgroups[su].period_us = period_us
    g_cgroups[su].used_us   = 0
    if period_us == 0:
        g_cgroups[su].ticks_to_refill = 0
    else:
        g_cgroups[su].ticks_to_refill = period_us / TICK_US
        if g_cgroups[su].ticks_to_refill == 0:
            g_cgroups[su].ticks_to_refill = 1
    return 0


def cgroup_cpu_attach(slot: int32, task_slot: uint64) -> int32:
    # Move `task_slot` into cgroup `slot`. slot 0 = root (detach).
    if task_slot >= CG_TASKMAX:
        return -1
    if slot < 0:
        return -1
    su: uint64 = cast[uint64](slot)
    if su >= CG_MAX:
        return -1
    if g_cgroups[su].in_use == 0:
        return -1
    g_task_cg[task_slot] = su
    return 0


def cgroup_cpu_of_task(task_slot: uint64) -> uint64:
    if task_slot >= CG_TASKMAX:
        return 0
    return g_task_cg[task_slot]


def cgroup_cpu_tick_refill():
    # Called once per timer tick from the timer ISR BEFORE preempt_tick
    # consults throttle state. Walks every active non-root cgroup,
    # decrements ticks_to_refill, and refills used_us/ticks_to_refill
    # when the period boundary is crossed. Refill = un-throttle: tasks
    # in the cgroup become runnable again on the next _pick_next().
    if g_cg_inited == 0:
        return
    i: uint64 = 1
    while i < CG_MAX:
        if g_cgroups[i].in_use != 0:
            if g_cgroups[i].period_us != 0:
                if g_cgroups[i].ticks_to_refill > 0:
                    g_cgroups[i].ticks_to_refill = \
                        g_cgroups[i].ticks_to_refill - 1
                if g_cgroups[i].ticks_to_refill == 0:
                    # Period boundary: account any leftover throttle and
                    # refill. A cgroup that exhausted its quota in this
                    # period counts as one throttle event.
                    if g_cgroups[i].used_us >= g_cgroups[i].quota_us:
                        g_cgroups[i].nr_throttled = \
                            g_cgroups[i].nr_throttled + 1
                    g_cgroups[i].used_us = 0
                    g_cgroups[i].ticks_to_refill = \
                        g_cgroups[i].period_us / TICK_US
                    if g_cgroups[i].ticks_to_refill == 0:
                        g_cgroups[i].ticks_to_refill = 1
        i = i + 1


def cgroup_cpu_charge_tick(task_slot: uint64, from_user: uint64) -> int32:
    # Called from preempt_tick() with the running task slot. Charges
    # TICK_US to the task's cgroup (if non-root) and returns 1 if the
    # cgroup is now over quota and the task should be throttled OFF
    # the CPU, 0 otherwise. We only charge ring-3 ticks: kernel work
    # (IRQ handlers, kthread bookkeeping) is not subject to cpu.max,
    # mirroring Linux's cfs_bandwidth which charges only user-visible
    # runtime, not interrupt-stolen time.
    if from_user == 0:
        return 0
    if g_cg_inited == 0:
        return 0
    cg: uint64 = cgroup_cpu_of_task(task_slot)
    if cg == 0:
        return 0
    if g_cgroups[cg].period_us == 0:
        return 0
    g_cgroups[cg].used_us   = g_cgroups[cg].used_us   + TICK_US
    g_cgroups[cg].usage_us  = g_cgroups[cg].usage_us  + TICK_US
    if g_cgroups[cg].used_us >= g_cgroups[cg].quota_us:
        # Charge the rest of this period as throttle time so cpu.stat
        # reflects what userspace observes.
        g_cgroups[cg].throttled_usec = \
            g_cgroups[cg].throttled_usec + TICK_US
        return 1
    return 0


def cgroup_cpu_should_throttle(task_slot: uint64) -> int32:
    # Side-effect-free predicate for _pick_next(): returns 1 if the
    # task's cgroup currently has no remaining quota in this period.
    # The native scheduler treats throttled tasks the same as a task
    # that voluntarily yielded: skip on _pick_next, retry once a period
    # boundary refills.
    if g_cg_inited == 0:
        return 0
    cg: uint64 = cgroup_cpu_of_task(task_slot)
    if cg == 0:
        return 0
    if g_cgroups[cg].period_us == 0:
        return 0
    if g_cgroups[cg].used_us >= g_cgroups[cg].quota_us:
        return 1
    return 0


# =====================================================================
# pids controller (cgroup v2 pids.max / pids.current)
# =====================================================================
#
# Real enforcement: a fork/clone/spawn whose task lands in a cgroup at
# or over its pids.max is REJECTED with -EAGAIN before the child task is
# created. The single chokepoint is do_clone()'s fork path
# (arch/x86/kernel/syscall.ad), which calls cgroup_pids_can_fork() on
# the PARENT slot (the child inherits the parent's cgroup) and, on
# success, cgroup_pids_charge_fork() once the child slot exists. A task
# reap calls cgroup_pids_uncharge() so pids.current tracks the LIVE
# count, mirroring Linux's pids_cgroup which decrements on exit.

def cgroup_pids_set_max(slot: int32, maxv: uint64, is_max: uint64) -> int32:
    # is_max != 0 sets the "max" (uncapped) convention (pids_max = 0).
    if slot < 1:
        return -1
    su: uint64 = cast[uint64](slot)
    if su >= CG_MAX or g_cgroups[su].in_use == 0:
        return -1
    if is_max != 0:
        g_cgroups[su].pids_max = 0
    else:
        g_cgroups[su].pids_max = maxv
    return 0


def cgroup_pids_can_fork(parent_slot: uint64) -> int32:
    # Returns 1 if a fork by the task in `parent_slot` is allowed under
    # its cgroup's pids.max, 0 if it would exceed the limit. Root /
    # uncapped cgroups always allow. Side-effect-free.
    if g_cg_inited == 0:
        return 1
    cg: uint64 = cgroup_cpu_of_task(parent_slot)
    if cg == 0:
        return 1
    if g_cgroups[cg].pids_max == 0:
        return 1
    if g_cgroups[cg].pids_cur >= g_cgroups[cg].pids_max:
        return 0
    return 1


def cgroup_pids_charge_fork(parent_slot: uint64, child_slot: uint64) -> int32:
    # Move the child into the parent's cgroup and bump pids_cur. Called
    # AFTER cgroup_pids_can_fork() returned 1 and the child task exists.
    if g_cg_inited == 0:
        return 0
    cg: uint64 = cgroup_cpu_of_task(parent_slot)
    if cg == 0:
        return 0
    # Inherit cgroup membership: the child joins the parent's cgroup
    # (cgroup v2: a fork keeps the parent's cgroup until migrated).
    cgroup_cpu_attach(cast[int32](cg), child_slot)
    g_cgroups[cg].pids_cur = g_cgroups[cg].pids_cur + 1
    return 1


def cgroup_pids_uncharge(slot: uint64) -> int32:
    # A task in slot `slot` is being reaped: decrement its cgroup's
    # live pid count and detach it (its memory charges are released
    # separately via cgroup_mem_uncharge on the same reap path).
    if g_cg_inited == 0:
        return 0
    cg: uint64 = cgroup_cpu_of_task(slot)
    if cg == 0:
        return 0
    if g_cgroups[cg].pids_cur > 0:
        g_cgroups[cg].pids_cur = g_cgroups[cg].pids_cur - 1
    return 1


def cgroup_pids_attach_count(slot: int32, task_slot: uint64) -> int32:
    # Explicit attach via cgroup.procs write: move task into the cgroup
    # AND count it (the task was already alive in another cgroup). This
    # is the "echo PID > cgroup.procs" path, distinct from a fork.
    if slot < 1:
        return -1
    su: uint64 = cast[uint64](slot)
    if su >= CG_MAX or g_cgroups[su].in_use == 0:
        return -1
    # Uncharge from the old cgroup first.
    old: uint64 = cgroup_cpu_of_task(task_slot)
    if old != 0 and old != su:
        if g_cgroups[old].pids_cur > 0:
            g_cgroups[old].pids_cur = g_cgroups[old].pids_cur - 1
    rc: int32 = cgroup_cpu_attach(slot, task_slot)
    if rc != 0:
        return rc
    if old != su:
        g_cgroups[su].pids_cur = g_cgroups[su].pids_cur + 1
    return 0


# =====================================================================
# memory controller (cgroup v2 memory.max / memory.current)
# =====================================================================
#
# Real enforcement: as a cgrouped task's address space grows (vma_alloc
# in mm/vma.ad), the byte count is CHARGED to its cgroup. A charge that
# would push memory.current past memory.max first drives global reclaim
# (mm/reclaim.ad::reclaim_under_pressure — the same swap/LRU machinery
# kswapd uses); if the cgroup is still over afterward, the cgroup OOM
# path kills a task in the cgroup. The orchestration (charge -> reclaim
# -> OOM) lives in mm/reclaim.ad::cgroup_mem_charge_enforce (it imports
# both this accounting module and the reclaim/OOM machinery); THIS file
# holds only the pure per-cgroup accounting so it stays printk-only and
# import-cycle-free (core.ad imports it).

def cgroup_mem_set_max(slot: int32, maxv: uint64, is_max: uint64) -> int32:
    if slot < 1:
        return -1
    su: uint64 = cast[uint64](slot)
    if su >= CG_MAX or g_cgroups[su].in_use == 0:
        return -1
    if is_max != 0:
        g_cgroups[su].mem_max = 0
    else:
        g_cgroups[su].mem_max = maxv
    return 0


def cgroup_mem_of_task(task_slot: uint64) -> uint64:
    return cgroup_cpu_of_task(task_slot)


def cgroup_mem_max_of(cg: uint64) -> uint64:
    if cg >= CG_MAX:
        return 0
    return g_cgroups[cg].mem_max


def cgroup_mem_cur_of(cg: uint64) -> uint64:
    if cg >= CG_MAX:
        return 0
    return g_cgroups[cg].mem_cur


def cgroup_mem_would_exceed(cg: uint64, bytes: uint64) -> int32:
    # 1 if charging `bytes` to cgroup `cg` would push it past memory.max.
    # Root / uncapped always returns 0.
    if cg == 0 or cg >= CG_MAX:
        return 0
    if g_cgroups[cg].mem_max == 0:
        return 0
    if g_cgroups[cg].mem_cur + bytes > g_cgroups[cg].mem_max:
        return 1
    return 0


def cgroup_mem_charge(slot: uint64, bytes: uint64) -> int32:
    # Unconditionally add `bytes` to the task's cgroup memory.current
    # (the enforcement decision is made by the caller in reclaim.ad).
    # Updates the high-water mark (memory.peak). Root tasks are no-ops.
    if g_cg_inited == 0:
        return 0
    cg: uint64 = cgroup_cpu_of_task(slot)
    if cg == 0:
        return 0
    g_cgroups[cg].mem_cur = g_cgroups[cg].mem_cur + bytes
    if g_cgroups[cg].mem_cur > g_cgroups[cg].mem_peak:
        g_cgroups[cg].mem_peak = g_cgroups[cg].mem_cur
    return 1


def cgroup_mem_uncharge(slot: uint64, bytes: uint64) -> int32:
    # Release `bytes` from the task's cgroup memory.current (on free /
    # task reap). Clamps at 0.
    if g_cg_inited == 0:
        return 0
    cg: uint64 = cgroup_cpu_of_task(slot)
    if cg == 0:
        return 0
    if g_cgroups[cg].mem_cur >= bytes:
        g_cgroups[cg].mem_cur = g_cgroups[cg].mem_cur - bytes
    else:
        g_cgroups[cg].mem_cur = 0
    return 1


def cgroup_mem_uncharge_all(slot: uint64) -> int32:
    # On task reap, release this task's entire charge. We don't track
    # per-task charge separately from the cgroup total, so a reap of the
    # LAST task in a cgroup zeroes the counter; with multiple tasks the
    # caller passes the task's RSS via cgroup_mem_uncharge. This helper
    # is the conservative "zero on empty" used by the reap path when the
    # cgroup becomes empty (pids_cur hits 0).
    if g_cg_inited == 0:
        return 0
    cg: uint64 = cgroup_cpu_of_task(slot)
    if cg == 0:
        return 0
    if g_cgroups[cg].pids_cur == 0:
        g_cgroups[cg].mem_cur = 0
    return 1


def cgroup_mem_record_oom(cg: uint64) -> int32:
    if cg == 0 or cg >= CG_MAX:
        return 0
    g_cgroups[cg].nr_oom = g_cgroups[cg].nr_oom + 1
    return 1


# -- render helpers (called from fs/procfs.ad for /sys/fs/cgroup/<g>/cpu.*) --

def _put_str(buf: Ptr[uint8], pos: uint64, s: Ptr[char]) -> uint64:
    i: uint64 = 0
    while cast[uint8](s[i]) != 0:
        buf[pos + i] = cast[uint8](s[i])
        i = i + 1
    return pos + i


def _put_dec(buf: Ptr[uint8], pos: uint64, v: uint64) -> uint64:
    if v == 0:
        buf[pos] = 48  # '0'
        return pos + 1
    digits: Array[24, uint8]
    n: uint64 = 0
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: uint64 = pos
    while n > 0:
        n = n - 1
        buf[out] = digits[n]
        out = out + 1
    return out


def cgroup_cpu_render_max(slot: int32, buf: Ptr[uint8]) -> uint64:
    # cpu.max read format: "<quota> <period>\n" OR "max <period>\n"
    # when uncapped.  Linux cgroup v2 convention.
    if slot < 1:
        return _put_str(buf, 0, "max 100000\n")
    su: uint64 = cast[uint64](slot)
    if su >= CG_MAX or g_cgroups[su].in_use == 0:
        return _put_str(buf, 0, "max 100000\n")
    pos: uint64 = 0
    if g_cgroups[su].period_us == 0:
        pos = _put_str(buf, pos, "max 100000\n")
        return pos
    pos = _put_dec(buf, pos, g_cgroups[su].quota_us)
    buf[pos] = 32   # space
    pos = pos + 1
    pos = _put_dec(buf, pos, g_cgroups[su].period_us)
    buf[pos] = 10   # newline
    pos = pos + 1
    return pos


def cgroup_cpu_render_stat(slot: int32, buf: Ptr[uint8]) -> uint64:
    # cpu.stat read format (subset that Linux exposes per-cgroup):
    #   usage_usec <n>
    #   nr_throttled <n>
    #   throttled_usec <n>
    pos: uint64 = 0
    usage: uint64 = 0
    nr_t: uint64 = 0
    t_us: uint64 = 0
    if slot >= 1:
        su: uint64 = cast[uint64](slot)
        if su < CG_MAX:
            if g_cgroups[su].in_use != 0:
                usage = g_cgroups[su].usage_us
                nr_t  = g_cgroups[su].nr_throttled
                t_us  = g_cgroups[su].throttled_usec
    pos = _put_str(buf, pos, "usage_usec ")
    pos = _put_dec(buf, pos, usage)
    buf[pos] = 10
    pos = pos + 1
    pos = _put_str(buf, pos, "nr_throttled ")
    pos = _put_dec(buf, pos, nr_t)
    buf[pos] = 10
    pos = pos + 1
    pos = _put_str(buf, pos, "throttled_usec ")
    pos = _put_dec(buf, pos, t_us)
    buf[pos] = 10
    pos = pos + 1
    return pos


def cgroup_cpu_render_procs(slot: int32, buf: Ptr[uint8]) -> uint64:
    # Per-cgroup cgroup.procs: list of task slots attached. We render
    # SLOT IDs (not real pids) because the cgroup_cpu module owns the
    # parallel g_task_cg array, not the task table; resolving slot→pid
    # would re-create the Layer-2/native coupling we just avoided. The
    # slot id is sufficient for cgroup.procs semantics: a unique
    # per-task handle the writer used to attach.
    pos: uint64 = 0
    if slot < 1:
        return 0
    su: uint64 = cast[uint64](slot)
    if su >= CG_MAX or g_cgroups[su].in_use == 0:
        return 0
    i: uint64 = 0
    while i < CG_TASKMAX:
        if g_task_cg[i] == su:
            pos = _put_dec(buf, pos, i)
            buf[pos] = 10
            pos = pos + 1
        i = i + 1
    return pos


# -- write parsers (called from fs/vfs.ad write hook for /sys/fs/cgroup/<g>/cpu.max) --

def _parse_dec_or_max(s: Ptr[char], start: uint64, end: uint64,
                      out: Ptr[uint64], is_max: Ptr[uint64]) -> uint64:
    # Parse a decimal number or the literal "max" between [start, end).
    # Returns the index of the next byte after the parsed token.
    # *is_max is set to 1 if the token was "max", 0 otherwise.
    # *out is the parsed value (0 if is_max).
    i: uint64 = start
    is_max[0] = 0
    out[0] = 0
    if i + 3 <= end:
        if cast[uint8](s[i]) == 109:      # 'm'
            if cast[uint8](s[i + 1]) == 97:   # 'a'
                if cast[uint8](s[i + 2]) == 120:  # 'x'
                    is_max[0] = 1
                    return i + 3
    v: uint64 = 0
    while i < end:
        c: uint8 = cast[uint8](s[i])
        if c < 48 or c > 57:
            # Hit a non-digit terminator (space, newline). Commit the
            # accumulated value before returning — previously this path
            # returned WITHOUT writing v back to out, so a "50000 100000"
            # parse silently produced 0 / 0.
            out[0] = v
            return i
        v = v * 10 + cast[uint64](c - 48)
        i = i + 1
    out[0] = v
    return i


def cgroup_pids_render_max(slot: int32, buf: Ptr[uint8]) -> uint64:
    # pids.max: "<n>\n" or "max\n".
    if slot < 1:
        return _put_str(buf, 0, "max\n")
    su: uint64 = cast[uint64](slot)
    if su >= CG_MAX or g_cgroups[su].in_use == 0:
        return _put_str(buf, 0, "max\n")
    if g_cgroups[su].pids_max == 0:
        return _put_str(buf, 0, "max\n")
    pos: uint64 = _put_dec(buf, 0, g_cgroups[su].pids_max)
    buf[pos] = 10
    return pos + 1


def cgroup_pids_render_current(slot: int32, buf: Ptr[uint8]) -> uint64:
    cur: uint64 = 0
    if slot >= 1:
        su: uint64 = cast[uint64](slot)
        if su < CG_MAX and g_cgroups[su].in_use != 0:
            cur = g_cgroups[su].pids_cur
    pos: uint64 = _put_dec(buf, 0, cur)
    buf[pos] = 10
    return pos + 1


def cgroup_mem_render_max(slot: int32, buf: Ptr[uint8]) -> uint64:
    if slot < 1:
        return _put_str(buf, 0, "max\n")
    su: uint64 = cast[uint64](slot)
    if su >= CG_MAX or g_cgroups[su].in_use == 0:
        return _put_str(buf, 0, "max\n")
    if g_cgroups[su].mem_max == 0:
        return _put_str(buf, 0, "max\n")
    pos: uint64 = _put_dec(buf, 0, g_cgroups[su].mem_max)
    buf[pos] = 10
    return pos + 1


def cgroup_mem_render_current(slot: int32, buf: Ptr[uint8]) -> uint64:
    cur: uint64 = 0
    if slot >= 1:
        su: uint64 = cast[uint64](slot)
        if su < CG_MAX and g_cgroups[su].in_use != 0:
            cur = g_cgroups[su].mem_cur
    pos: uint64 = _put_dec(buf, 0, cur)
    buf[pos] = 10
    return pos + 1


def cgroup_pids_write_max(slot: int32, data: Ptr[char], n: uint64) -> int32:
    # Parse "<n>\n" or "max\n".
    if slot < 1:
        return -22
    su: uint64 = cast[uint64](slot)
    if su >= CG_MAX or g_cgroups[su].in_use == 0:
        return -22
    v: uint64 = 0
    ismax: uint64 = 0
    _parse_dec_or_max(data, 0, n, &v, &ismax)
    return cgroup_pids_set_max(slot, v, ismax)


def cgroup_mem_write_max(slot: int32, data: Ptr[char], n: uint64) -> int32:
    if slot < 1:
        return -22
    su: uint64 = cast[uint64](slot)
    if su >= CG_MAX or g_cgroups[su].in_use == 0:
        return -22
    v: uint64 = 0
    ismax: uint64 = 0
    _parse_dec_or_max(data, 0, n, &v, &ismax)
    return cgroup_mem_set_max(slot, v, ismax)


def cgroup_cpu_write_max(slot: int32, data: Ptr[char], n: uint64) -> int32:
    # Parse a cpu.max write of the form "<quota> <period>\n" or
    # "max <period>\n". Returns 0 on success, -EINVAL on parse error.
    if slot < 1:
        return -22  # -EINVAL
    su: uint64 = cast[uint64](slot)
    if su >= CG_MAX or g_cgroups[su].in_use == 0:
        return -22
    quota: uint64 = 0
    period: uint64 = 100000
    qmax: uint64 = 0
    pmax: uint64 = 0
    i: uint64 = _parse_dec_or_max(data, 0, n, &quota, &qmax)
    # Skip whitespace.
    while i < n:
        c: uint8 = cast[uint8](data[i])
        if c != 32 and c != 9:
            break
        i = i + 1
    if i < n:
        ptmp: uint64 = 0
        i = _parse_dec_or_max(data, i, n, &ptmp, &pmax)
        if pmax == 0:
            period = ptmp
    if qmax != 0:
        return cgroup_cpu_set_max(slot, 0, 0)   # "max" = uncapped
    return cgroup_cpu_set_max(slot, quota, period)


# -- boot self-test --

# Selftest replays the audit's keystone scenario WITHOUT relying on
# Linux userland + /proc/self/stat (the kernel API surface here is the
# real enforcement surface — the procfs render and the syscall write
# arms call exactly these entry points). We simulate the timer-tick
# stream the scheduler would deliver to a user task pinned in the cg:
#
#   * mkdir g1
#   * cpu.max = 50000 100000  (50 % of one CPU, 100 ms period)
#   * attach task slot 1 to g1
#   * burn 200 ticks of from_user=1 (= 2 s wallclock at HZ=100):
#       for each tick, refill first, then either skip (if throttled)
#       or charge. Count charged vs throttled.
#   * Assert charged ≈ 50% of total (within ±10% slack).
#
# The same machinery (cgroup_cpu_tick_refill + cgroup_cpu_charge_tick +
# cgroup_cpu_should_throttle) is what timer_interrupt + preempt_tick +
# _pick_next call on a real running ring-3 task, so a green selftest
# proves the real path.

def cgroup_cpu_selftest() -> int32:
    # The selftest prints at EMERG so the PASS/FAIL marker always
    # reaches the serial console regardless of the runtime log gate
    # (the post-interactive console threshold normally clips below
    # NOTICE). Same idiom as cgroup2_vfs_selftest().
    printk_set_level(PRINTK_LEVEL_EMERG)
    cgroup_cpu_init()
    # Fresh mkdir.
    slot: int32 = cgroup_cpu_mkdir("g1")
    if slot < 1:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[CGROUP_CPU] FAIL mkdir g1\n")
        return 0
    # Set 50% bandwidth: 50 ms quota in a 100 ms period. Routed
    # through the string write parser so the selftest covers the
    # same path a userland `echo "50000 100000" > .../cpu.max` would
    # exercise.
    rc_m: int32 = cgroup_cpu_write_max(slot, "50000 100000\n", 13)
    if rc_m != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[CGROUP_CPU] FAIL write cpu.max\n")
        return 0
    # Cross-check the parsed values landed in the cgroup record.
    su_chk: uint64 = cast[uint64](slot)
    if g_cgroups[su_chk].quota_us != 50000 or \
       g_cgroups[su_chk].period_us != 100000:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[CGROUP_CPU] FAIL parser quota/period\n")
        return 0
    # Attach task slot 1 (= the boot task's sibling slot — picking 1
    # not 0 so we don't disturb the BSP boot task accidentally if
    # something else races; the selftest is offline-driven so the
    # value is symbolic).
    rc_a: int32 = cgroup_cpu_attach(slot, 1)
    if rc_a != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[CGROUP_CPU] FAIL attach\n")
        return 0
    # Burn 200 ticks @ from_user=1 (= 2 s).
    charged: uint64 = 0
    throttled: uint64 = 0
    t: uint64 = 0
    while t < 200:
        cgroup_cpu_tick_refill()
        if cgroup_cpu_should_throttle(1) != 0:
            throttled = throttled + 1
        else:
            cgroup_cpu_charge_tick(1, 1)
            charged = charged + 1
        t = t + 1
    # Assert: roughly 100 charged + 100 throttled (50% cap). Allow
    # ±10 ticks of slack (1 period of jitter).
    if charged < 90 or charged > 110:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[CGROUP_CPU] FAIL bad ratio charged=%d throttled=%d\n",
                charged, throttled)
        return 0
    if throttled < 90 or throttled > 110:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[CGROUP_CPU] FAIL bad ratio charged=%d throttled=%d\n",
                charged, throttled)
        return 0
    # Verify cpu.stat read renders the throttle counters we accumulated.
    sbuf: Array[256, uint8]
    sn: uint64 = cgroup_cpu_render_stat(slot, &sbuf[0])
    if sn < 30:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[CGROUP_CPU] FAIL cpu.stat too short\n")
        return 0
    # Verify cpu.max readback matches what we wrote.
    mbuf: Array[64, uint8]
    mn: uint64 = cgroup_cpu_render_max(slot, &mbuf[0])
    if mn < 8:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[CGROUP_CPU] FAIL cpu.max readback short\n")
        return 0
    # Spot-check the first byte is a digit (not "max"), which means a
    # real numeric quota is reported.
    if mbuf[0] < 48 or mbuf[0] > 57:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[CGROUP_CPU] FAIL cpu.max readback not numeric\n")
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[CGROUP_CPU] PASS charged=%d throttled=%d (50 pct cap enforced)\n",
            charged, throttled)
    return 1


# =====================================================================
# pids + memory controller enforcement self-test
# =====================================================================
#
# Drives the SAME accounting entry points the live kernel hits:
#   * pids.max  — cgroup_pids_can_fork / cgroup_pids_charge_fork /
#                 cgroup_pids_uncharge are exactly what do_clone()'s fork
#                 path (arch/x86/kernel/syscall.ad) and task_reap()
#                 (kernel/sched/core.ad) call on every real fork/exit.
#   * memory.max — cgroup_mem_would_exceed / cgroup_mem_charge /
#                 cgroup_mem_uncharge are what mm/reclaim.ad's
#                 cgroup_mem_charge_enforce (the demand-fault hook) calls
#                 per page. The reclaim/OOM ORCHESTRATION is proven by
#                 the companion reclaim-side selftest (mm/reclaim.ad).
#
# Returns 1 on PASS, 0 on FAIL; prints "[CGROUP_ENFORCE] PASS/FAIL ...".

def cgroup_enforce_selftest() -> int32:
    printk_set_level(PRINTK_LEVEL_EMERG)
    cgroup_cpu_init()

    # ---- pids.max --------------------------------------------------
    pslot: int32 = cgroup_cpu_mkdir("pg")
    if pslot < 1:
        printk0("[CGROUP_ENFORCE] FAIL mkdir pg\n")
        return 0
    # Attach a "leader" task (slot 10) as the cgroup's first member so
    # forks by it inherit the cgroup. Count it as one live pid.
    if cgroup_cpu_attach(pslot, 10) != 0:
        printk0("[CGROUP_ENFORCE] FAIL attach leader\n")
        return 0
    psu: uint64 = cast[uint64](pslot)
    g_cgroups[psu].pids_cur = 1     # the leader itself
    # pids.max = 2 via the write parser (the echo > pids.max path).
    if cgroup_pids_write_max(pslot, "2\n", 2) != 0:
        printk0("[CGROUP_ENFORCE] FAIL write pids.max\n")
        return 0
    if g_cgroups[psu].pids_max != 2:
        printk0("[CGROUP_ENFORCE] FAIL pids.max parse\n")
        return 0
    # Leader forks child #2: pids_cur 1 -> 2, must be allowed.
    if cgroup_pids_can_fork(10) == 0:
        printk0("[CGROUP_ENFORCE] FAIL fork#2 wrongly denied\n")
        return 0
    cgroup_pids_charge_fork(10, 11)
    if g_cgroups[psu].pids_cur != 2:
        printk0("[CGROUP_ENFORCE] FAIL pids_cur after fork#2\n")
        return 0
    # Fork #3 would push pids_cur to 3 > pids.max=2: MUST be rejected.
    if cgroup_pids_can_fork(11) != 0:
        printk1("[CGROUP_ENFORCE] FAIL fork#3 allowed (pids_cur=%d)\n",
                g_cgroups[psu].pids_cur)
        return 0
    # A task exits (reap): pids_cur 2 -> 1, fork allowed again.
    cgroup_pids_uncharge(11)
    if g_cgroups[psu].pids_cur != 1:
        printk0("[CGROUP_ENFORCE] FAIL pids_cur after reap\n")
        return 0
    if cgroup_pids_can_fork(10) == 0:
        printk0("[CGROUP_ENFORCE] FAIL fork after reap denied\n")
        return 0
    # Verify pids.current renders the live count.
    pbuf: Array[32, uint8]
    pn: uint64 = cgroup_pids_render_current(pslot, &pbuf[0])
    if pn < 2 or pbuf[0] != 49:     # "1\n"
        printk0("[CGROUP_ENFORCE] FAIL pids.current render\n")
        return 0

    # ---- memory.max ------------------------------------------------
    mslot: int32 = cgroup_cpu_mkdir("mg")
    if mslot < 1:
        printk0("[CGROUP_ENFORCE] FAIL mkdir mg\n")
        return 0
    if cgroup_cpu_attach(mslot, 20) != 0:
        printk0("[CGROUP_ENFORCE] FAIL attach mem task\n")
        return 0
    msu: uint64 = cast[uint64](mslot)
    # memory.max = 65536 bytes (16 pages) via the write parser.
    if cgroup_mem_write_max(mslot, "65536\n", 6) != 0:
        printk0("[CGROUP_ENFORCE] FAIL write memory.max\n")
        return 0
    if g_cgroups[msu].mem_max != 65536:
        printk0("[CGROUP_ENFORCE] FAIL memory.max parse\n")
        return 0
    # Charge 15 pages (61440 bytes): all fit under 65536.
    pg: uint64 = 0
    while pg < 15:
        if cgroup_mem_would_exceed(msu, 4096) != 0:
            printk1("[CGROUP_ENFORCE] FAIL page %d wrongly over-cap\n", pg)
            return 0
        cgroup_mem_charge(20, 4096)
        pg = pg + 1
    if g_cgroups[msu].mem_cur != 61440:
        printk1("[CGROUP_ENFORCE] FAIL mem_cur=%d after 15 pages\n",
                g_cgroups[msu].mem_cur)
        return 0
    # The 17th page (would make 17*4096=69632 > 65536): would_exceed
    # must flag it (the live enforcer then reclaims/OOMs). Charging the
    # 16th (65536, exactly at the cap) is allowed; the 17th is not.
    cgroup_mem_charge(20, 4096)     # 16th page -> exactly 65536
    if cgroup_mem_would_exceed(msu, 4096) == 0:
        printk1("[CGROUP_ENFORCE] FAIL 17th page not flagged (cur=%d)\n",
                g_cgroups[msu].mem_cur)
        return 0
    # memory.current renders the charge.
    mbuf: Array[32, uint8]
    mn: uint64 = cgroup_mem_render_current(mslot, &mbuf[0])
    if mn < 5:
        printk0("[CGROUP_ENFORCE] FAIL memory.current render\n")
        return 0
    # Uncharge a page: cur drops, headroom returns.
    cgroup_mem_uncharge(20, 4096)
    if g_cgroups[msu].mem_cur != 61440:
        printk0("[CGROUP_ENFORCE] FAIL mem_cur after uncharge\n")
        return 0
    if cgroup_mem_would_exceed(msu, 4096) != 0:
        printk0("[CGROUP_ENFORCE] FAIL no headroom after uncharge\n")
        return 0
    # peak high-water mark recorded the 65536 spike.
    if g_cgroups[msu].mem_peak != 65536:
        printk1("[CGROUP_ENFORCE] FAIL mem_peak=%d\n", g_cgroups[msu].mem_peak)
        return 0

    printk0("[CGROUP_ENFORCE] PASS pids.max rejects over-limit fork; memory.max bounds memory.current\n")
    return 1

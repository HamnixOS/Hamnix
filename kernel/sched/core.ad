# kernel/sched/core.ad
#
# Mirrors kernel/sched/core.c in Linux. Owns task_struct definitions,
# the runqueue, and the schedule() / context-switch path that the
# timer ISR drives. As of M16.20 the runqueue holds up to 4 tasks
# (kernel and user mixed), each with its own kernel stack; user
# tasks additionally have a user stack and their initial kernel-stack
# image is pre-built to land in CPL=3 via iretq.
#
# Task states (mirrors the relevant subset of TASK_RUNNING / TASK_DEAD):
#
#   STATE_FREE     0  - slot is unused; create_*_task may claim it
#   STATE_READY    1  - on the runqueue; eligible for schedule()
#   STATE_RUNNING  2  - currently on a CPU (only one slot at a time
#                       on uniprocessor)
#   STATE_EXITED   3  - finished; never scheduled again. Stacks stay
#                       allocated (no reclaim yet); slot is left in
#                       state EXITED so schedule() skips it.
#
# Preemption is timer-driven (M16.9): schedule() is called from
# timer_interrupt(). We also call it explicitly from SYS_EXIT to give
# the CPU to a sibling when the current task tears down.

from mm.memblock import memblock_alloc, memblock_region_top
from mm.page_alloc import alloc_page, alloc_pages, free_page, free_pages, region_free, region_free_cow_safe
from mm.slab import kfree
from mm.cow import cow_boot_cr3
# SMAP v3c: signal delivery writes the rt_sigframe directly onto the
# user stack at CPL=0, so the stores need RFLAGS.AC=1 under CR4.SMAP=1.
from mm.uaccess import _ua_stac, _ua_clac, put_user_32
from kernel.printk.printk import printk0, printk1, printk2, printk_set_level
from drivers.tty.serial.early_8250 import (
    PRINTK_LEVEL_EMERG, PRINTK_LEVEL_NOTICE,
)
# Phase 4c: the `from fs.pipe import pipe_close_reader/...` import is
# GONE — core.ad no longer touches pipe end-refcounts directly. A pipe
# end is an FD_CHAN_MARK fd (DEV_PIPE_R / DEV_PIPE_W pool chan):
# fork/dup bumps the CHAN refcount (namec_chan_ref) and close releases
# through namec_close's DEV_PIPE arms, the same single release path
# every other folded family uses.
# fd→Chan fold: the `from fs.fat import fat_close` / `from fs.ext4 import
# ext4_close` imports are GONE — core.ad no longer releases ext4/FAT
# slots directly (the folded file fd is an FD_CHAN_MARK whose release
# runs in namec_close). Keeping a now-unused import would be dead code.
# §13: ctxt accounting. loadavg_note_switch() bumps the context-switch
# counter /dev/stat's "ctxt" column reports. The EWMA / idle state it
# owns is driven from timer_interrupt; this file only feeds it the
# one switch event. See kernel/sched/loadavg.ad.
from kernel.sched.loadavg import (
    loadavg_note_switch, cpu_idle_enter, cpu_idle_leave,
)
# F11 cgroup v2 cpu.max enforcement (2026-06-13). The scheduler only
# reads two predicates from this Layer-2 module: charge a tick to the
# current task's cgroup (returns 1 when that pushes the cgroup over
# quota, so we force a preemption), and a side-effect-free
# should-throttle check used by _pick_next() to skip a quota-exhausted
# task until the next period boundary refills it. Period accounting
# lives entirely in cgroup_cpu.ad — the scheduler never touches cgroup
# objects directly. Native tasks (cg_id == 0) short-circuit on the
# very first cgroup_cpu_of_task() check, so this is a near-zero cost
# branch for the common case.
from kernel.sched.cgroup_cpu import (
    cgroup_cpu_charge_tick, cgroup_cpu_should_throttle,
    cgroup_cpu_tick_refill,
    # cgroup v2 pids/memory uncharge on task reap: a reaped task drops
    # off its cgroup's pids.current and (when it was the last task) the
    # cgroup's memory.current. Detach happens implicitly (the slot frees
    # and g_task_cg resets on the next attach).
    cgroup_pids_uncharge, cgroup_mem_uncharge_all,
)
# SMP: per-CPU id for current-task tracking and TSS gating.
from arch.x86.kernel.setup_percpu import get_cpu_id
from arch.x86.kernel.time import get_jiffies
# SMP reschedule IPI: kick idle APs out of HLT when a kernel task becomes
# runnable so they re-scan the shared runqueue (Linux's smp_send_reschedule).
# No-op on a uniprocessor boot (gated on cpus_online > 1 inside the helper).
from arch.x86.kernel.apic import smp_send_reschedule, smp_send_reschedule_cpu
# QA-N32b AP idle backstop: APs arm NO periodic LAPIC tick (they wake via a
# directed reschedule IPI). To make the idle AP self-healing — so it can
# never wedge waiting on a tick that never resumes — it arms its OWN local
# LAPIC one-shot for a short bounded deadline before halting, re-waking to
# re-scan its runqueue. This is a purely LOCAL operation (programs only the
# calling CPU's LAPIC); the AP never touches the global clockevent / hrtimer
# queue (that stays BSP-exclusive — see arch/x86/kernel/time.ad).
from arch.x86.kernel.apic import lapic_timer_set_oneshot_ns
# Per-CPU runqueue (#6): how many CPUs are live, so the placement / steal
# logic knows the valid logical-CPU id range to spread runnable work over.
from arch.x86.kernel.smp import get_cpus_online
from kernel.panic import panic
# SMAP-v3: install fresh user stacks with an EXPLICIT US=1 PTE in the
# child's PML4 so the stack does not depend on the identity-backfill
# leaves being US=1. Unblocks _build_identity_pd/_pt going US=0 and
# CR4.SMAP enable in arch/x86/kernel/cpu_mitigations.ad.
from fs.elf import elf_install_user_stack, elf_install_user_mapping
# RCU (kernel/rcu/rcu.ad): the scheduler is the primary quiescent-state (QS)
# source — a real context switch on a CPU is a QS for that CPU iff it is not
# mid-rcu_read_lock. core.ad calls rcu_note_context_switch() on the real-switch
# path. The task-list reclaim (task_reap) defers slot-reuse via call_rcu so a
# concurrent lock-free task-list reader never sees a slot recycled under it.
from kernel.rcu.rcu import (
    rcu_note_context_switch, call_rcu,
    rcu_save_read_nesting, rcu_restore_read_nesting,
    rcu_read_lock, rcu_read_unlock, rcu_set_yield_hook,
    rcu_idle_enter, rcu_idle_exit,
)

# QA-N32b AP idle self-healing backstop period. An idle AP arms its LOCAL
# LAPIC one-shot for this long before halting so it always re-wakes to
# re-scan its runqueue even absent a reschedule IPI, without relying on any
# global tick. 4 ms is finer than the 10 ms scheduler tick (so a freshly
# stealable task is picked up promptly) yet coarse enough that a fully idle
# AP wakes only ~250×/s — negligible overhead, no timer storm.
AP_IDLE_BACKSTOP_NS: uint64 = 4000000            # 4 ms

# QA-N32b work-steal hysteresis window (jiffies). A task dispatched within
# this many jiffies is NOT eligible to be stolen onto another CPU, so a
# just-run task keeps cache affinity and cannot ping-pong between cores when
# an idle AP re-scans on its short backstop. 2 jiffies (~20 ms at HZ=100) is
# short enough that genuine load-balancing of a long-runnable task still
# happens promptly.
STEAL_HYSTERESIS_JIFFIES: uint64 = 2

extern def __switch_to_asm(prev: Ptr[uint8], next: Ptr[uint8])
extern def enter_first_task(task: Ptr[uint8])
# SMP spinlock: test-and-set via LOCK XCHG, release via plain store+SFENCE.
# Used to protect shared runqueue mutations so APs and BSP don't race.
extern def spinlock_lock(ptr: Ptr[uint32])
extern def spinlock_unlock(ptr: Ptr[uint32])
# Per-CPU rq (#6): single-shot acquire for cross-CPU steal/migration; returns
# 1 if acquired, 0 if already held (no spin) so the caller can back off.
extern def spinlock_trylock(ptr: Ptr[uint32]) -> uint32
extern def cpu_relax()
# M16.155: SYSRETQ-based first-user-task dispatch — the shipping
# first-task entry path. Both enter_first_task (IRETQ) and
# enter_first_task_sysret (SYSRETQ) stay exported so the call site in
# start_first_task can revert with a one-line change.
extern def enter_first_task_sysret(task: Ptr[uint8])
extern def kthread_bootstrap()
extern def tss_set_rsp0(rsp0: uint64)
# Stage-A SMP proof: a minimal ring-3 payload (busy-loop + one SYS_WRITE
# + SYS_EXIT) used by smp_user_ap_selftest() to prove a USER task runs on
# a non-BSP CPU through that CPU's own per-CPU TSS. Body in syscall_64.S.
extern def smp_user_probe_entry()
# Marks the byte just past the probe's inline banner — the selftest copies
# the [smp_user_probe_entry, smp_user_probe_end) span (code + inline banner)
# into a US=1 user page so a CPL3 task can actually fetch it (kernel .text is
# US=0). Defined in syscall_64.S right after the banner.
extern def smp_user_probe_end()
extern def local_irq_disable()
extern def local_irq_enable()
# Atomic sti;hlt — the idle CPU's race-free wait primitive (Linux's
# native_safe_halt). Used by the AP idle loop to park until a reschedule
# IPI wakes it. Body in arch/x86/kernel/irq_asm.S.
extern def safe_halt()
# Nesting-safe IRQ save/restore (see fs/elf.ad for rationale).
extern def local_irq_save() -> uint64
extern def local_irq_restore(flags: uint64)
extern def get_bsp_cr3() -> uint64
extern def read_cr3() -> uint64
extern def load_cr3(value: uint64)
# Physical end of the loaded kernel image. The page allocator's memblock
# floor is set at (or just above) this address by e820_init, so NO
# kernel-owned page (table or frame) ever has a physical base below it.
# Used by the page-table teardown walk as the stable lower bound when
# validating a sub-table / leaf address (the live memblock cursor can't
# serve as a floor — it advances on every allocation).
extern def kernel_image_end() -> uint64
extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]
# U27: MSR access for per-task FS_BASE save/restore across context
# switches. The asm body is the generic write_msr in
# arch/x86/kernel/syscall_64.S — same primitive arch_prctl uses on the
# Linux ABI side.
extern def write_msr(index: uint32, value: uint64)

# M16.156 Asus real-hw triple-fault fix. Three primitives wired into
# start_first_task right before the SYSRETQ handoff:
#   * read_cr4 / write_cr4 -> read CR4 and, on CPUs that advertise
#                             XSAVE (CPUID.01h:ECX bit 26), set
#                             CR4.OSXSAVE. Conditional — never set on
#                             a CPU that doesn't advertise XSAVE.
#   * cpuid_get            -> the CPUID.01h read that gates the
#                             OSXSAVE decision.
#   * fninit_helper        -> reset the FPU to power-on defaults so a
#                             firmware-left inconsistency can't raise
#                             #MF/#XF on the first user FPU instr.
# Bodies live in arch/x86/kernel/smp_asm.S (read_cr4) and
# arch/x86/kernel/cpuregs_asm.S (the rest).
extern def read_cr4() -> uint64
extern def cpuid_get(leaf: uint32, subleaf: uint32, out: Ptr[uint32])
extern def fninit_helper()
extern def write_cr4(value: uint64)
# xsetbv_xcr0: write XCR0 (after CR4.OSXSAVE) to enable SSE+AVX state so
# real Debian binaries' VEX-encoded (AVX) instructions don't #UD.
extern def xsetbv_xcr0(value: uint64)

# V2.5: Pgrp lifecycle entry-points implemented in sys/src/9/port/chan.ad.
# Declared extern here so task_exit_current can call pgrp_ref_dec without
# creating a kernel.sched.core -> sys.src.port9.port.chan import cycle
# (chan.ad already imports current_pgrp / task_pgrp from this file).
# Adder's flat-merge linker resolves the symbol at codegen time.
#
# V2.75: pgrp_ref_dec now takes a uint64 heap pointer (was int32 pool
# index in V2.5). The Pgrp lifetime is owned by kmalloc/kfree end-to-end.
extern def pgrp_ref_dec(p: uint64) -> int32

# #174: per-namespace CPU cap. nscap_cpu_factor_current() lives in
# chan.ad (alongside the Pgrp struct it reads); declared extern here so
# preempt_tick can inflate a capped namespace's vruntime accrual without
# re-introducing the core -> chan import cycle the flat-merge linker
# resolves at codegen time. Returns an integer multiplier (1 == uncapped,
# 4 for a 25% cap, etc.).
extern def nscap_cpu_factor_current() -> uint64

# #173 core dumps. coredump.ad imports task/VMA accessors FROM this
# module, so we reference its two entry points via extern def (the same
# cycle-break used for pgrp_ref_dec above) rather than a `from` import.
# coredump_write_current() captures an ELF ET_CORE of the current task
# at a fatal-terminate site, BEFORE task_exit_current() tears it down.
extern def coredump_write_current(sig: uint64,
                                  iret_frame: Ptr[uint64]) -> int32
extern def coredump_is_fatal_sig(sig: uint64) -> int32

# U27: IA32_FS_BASE — MSR 0xC0000100. Mirrored from u_syscalls.ad's
# constant of the same name; duplicated here so core.ad doesn't pull in
# the linux_abi side just for a number.
SCHED_IA32_FS_BASE: uint32 = 0xC0000100


class TaskStruct:
    sp:           uint64       # offset  0: saved %rsp on context switch
    # offset 8: SMP context-switch handshake (Linux's rq->curr->on_cpu).
    # schedule() sets on_cpu=1 on the OUTGOING task BEFORE it drops the rq
    # lock, and __switch_to_asm clears it to 0 the instant AFTER it stores
    # prev->sp (offset 0). _sched_try_pull_locked refuses to steal any task
    # with on_cpu != 0. This closes the steal-window race: between schedule()
    # marking prev STATE_READY + dropping the lock and __switch_to_asm
    # actually saving prev->sp, prev's sp slot is STALE; without this flag an
    # idle AP could steal prev and dispatch it on that stale sp (garbage
    # resume rip -> silent wedge/triple-fault). on_cpu==1 fences that window.
    # ASM CONTRACT: this MUST stay at byte offset 8 (sched_asm.S writes 8(%rdi)).
    on_cpu:       uint64       # offset  8: 1 while prev may be mid-switch
    pid:          uint64       # offset 16: logical id
    kstack_base:  uint64       # offset 16: bottom of this task's kstack
    kstack_top:   uint64       # offset 24: top (high addr); fed to TSS.RSP0
    ustack_base:  uint64       # offset 32: bottom of user stack (0 for kernel)
    state:        uint64       # offset 40: STATE_*
    is_user:      uint64       # offset 48: 1 if CPL=3 task
    name0:        uint64       # offset 56: 8-char ASCII tag (debug)
    # Per-task file descriptor table — 16 slots (M16.40, up from 8
    # in M16.38 / 4 in M16.26). A 3+ stage pipeline keeps 2*(N-1)
    # pipe fds open in the parent at once, plus stdio plus an
    # optional `>` target. 16 is room for N≈6 stages, which is
    # plenty for an interactive shell.  Each fd has a file index
    # (or special marker for stdin/stdout/stderr/proc/tmpfs/pipe)
    # and a 64-bit read/write position. fd_buf / fd_buflen hold the
    # kmalloc-backed body of dynamic (procfs) files or the slot
    # index for tmpfs / pipe fds; cpio + stdio fds leave them at 0.
    # NR_FDS bumped to 64 (was 16) to support Debian server workloads
    # (apt fork-storm, nginx worker pools, postgres connection pools open
    # well above 16 fds per process). All later offsets in TaskStruct shift
    # accordingly; only `sp` (offset 0) is consulted by hand-written ASM
    # (sched_asm.S / syscall_64.S), so the rest are documentation only.
    # Next step: lift to 256+ by switching the fd table to a heap arena.
    fd_idx:       Array[64, uint32]   # offset 64..320
    fd_pos:       Array[64, uint64]   # offset 320..832
    fd_buf:       Array[64, uint64]   # offset 832..1344
    fd_buflen:    Array[64, uint64]   # offset 1344..1856
    # Task-specific PML4 physical address. For M16.28 every task
    # gets its own top-level page table page, freshly cloned from
    # BSP's so the lower-level mappings (PDPT/PD) are shared — same
    # kernel-half sharing scheme Linux uses, just without separate
    # user-half mappings yet.
    cr3:          uint64              # offset 512 (after 16-slot fd table)
    parent_pid:   uint64              # offset 520
    exit_code:    int64               # offset 528
    sig_pending:  uint64              # offset 536
    # M16.47: per-task current working directory. NUL-terminated.
    # Inherited at spawn from the parent.
    cwd:          Array[128, uint8]   # offset 544..672
    # U1: per-task syscall ABI selector. 0 = native Hamnix numbering
    # (the existing 0..22 + 175/176 ladder in do_syscall), 1 = Linux
    # x86_64 numbering (forwarded to linux_u_syscall_dispatch). All
    # existing tasks stay at 0; the loader for Linux-ELF user binaries
    # flips this on the freshly-created child before its first iretq
    # to user mode. Placed at the end of TaskStruct so adding it does
    # not shift any earlier offset — sched_asm.S still finds `sp` at
    # offset 0, and the per-task fd table still lives where vfs.ad
    # expects it.
    is_linux_userspace: int32         # offset 672
    # U26: vfork-style fork wake flag. do_clone sets this to 0 on the
    # newly-created child; the child clears the parent's blocking yield
    # by transitioning to either STATE_EXITED or by writing 1 here from
    # do_execve (signalling "child has replaced its user image and the
    # parent is no longer sharing the address space"). Parent's do_clone
    # spins yielding until this is non-zero OR the child has exited.
    # Without this, the parent races the child on the SHARED user stack
    # — both running glibc fork() return paths whose locals collide.
    vfork_done: int32                 # offset 676
    # U27: per-task FS_BASE (MSR 0xC0000100). glibc's pthread bring-up
    # writes the TLS base via arch_prctl(ARCH_SET_FS, &tcb), and threads
    # spawned via clone(CLONE_SETTLS) carry a per-thread tls value. Each
    # task records its own FS_BASE here so the context-switch path can
    # restore it on dispatch — without per-task save/restore, the last
    # thread's TLS base would silently overwrite siblings'. Native
    # (Hamnix-ABI) tasks leave this at 0, which is harmless: they never
    # read %fs-relative.
    fs_base:    uint64                # offset 680
    # U27: per-task CLONE_CHILD_CLEARTID address. Linux records the
    # user pointer set by set_tid_address() or clone(CLONE_CHILD_CLEARTID,
    # ctid=...). On task exit the kernel writes 0 there and futex-wakes
    # any waiters — that's how glibc's pthread_join() detects child
    # death without polling. The wake side is handled by
    # task_exit_current() below; pthread_create stashes the ctid into
    # this slot via do_clone's thread path. 0 means "no clear pending"
    # (default for native tasks + fork children).
    clear_child_tid: uint64           # offset 688
    # U31: per-task signal handler table. sig_handlers[N] = user
    # handler address for signal N, or 0 for SIG_DFL (terminate).
    # Installed via rt_sigaction; consulted by signal_check_and_handle
    # to decide between TERM-default and "redirect user RIP to the
    # handler via sig_trampoline". 64 entries match sig_pending's
    # bitmap width and Linux's max signal number.
    sig_handlers: Array[64, uint64]   # offset 696..1208
    # U31: PR_SET_NAME storage. POSIX TASK_COMM_LEN is 16 INCLUDING
    # the trailing NUL. Used by glibc/musl for pthread_setname_np
    # plumbing; also surfaces via PR_GET_NAME and /proc/self/comm.
    comm: Array[16, uint8]            # offset 1208..1224
    # U31: PR_SET_PDEATHSIG slot. Signal to deliver to this task
    # when its parent dies. 0 means "none". Stored but not yet
    # acted on (parent-death wiring is a separate milestone).
    pdeathsig: uint64                 # offset 1224
    # U37: sigaltstack(2) storage. glibc reaches for this during signal
    # handler setup (the static-pie startup path installs an alt stack
    # so SIGSEGV handlers can run on a known-good page if the user's
    # main stack is the thing that overflowed). Hamnix has exactly one
    # task per thread and no nested handler delivery, so we never
    # actually SWITCH to the alt stack — but storing the values quiets
    # the -ENOSYS that otherwise stalls busybox's sh on first probe.
    # Layout mirrors `struct stack_t { void *ss_sp; int ss_flags; size_t ss_size; }`
    # — three fields, total 24 bytes when packed; we keep them as
    # individual uint64 / int32 slots to avoid a nested-struct field
    # access pattern the loader-level codegen hasn't grown yet.
    alt_stack_sp:    uint64           # offset 1232
    alt_stack_size:  uint64           # offset 1240
    alt_stack_flags: int32            # offset 1248
    # 4 bytes implicit pad to next 8-byte boundary; next field lands
    # at offset 1256.
    # Phase B / M16.93: per-process Plan 9 errstr buffer. Holds the most
    # recent error string for SYS_ERRSTR (265). NUL-terminated, fixed
    # 128 bytes (matches 9front's ERRMAX). Zero-initialised at every
    # create_user_task / kthread_create / create_user_thread; never
    # inherited across fork — Plan 9 errstr is strictly per-process,
    # the new child starts with an empty error. See
    # sys/src/9/port/error.ad for the access primitives.
    errstr_buf: Array[128, uint8]     # offset 1256..1384
    # Phase C / M16.98: Plan 9 rfork bookkeeping fields. These track the
    # per-task sharing state for fd table / namespace / note group that
    # rfork(2)'s flag bits control. At this milestone the values are
    # forward-looking handles — the matching subsystems (real fd-table
    # sharing, mount tables, note delivery) don't exist yet — but the
    # accessors are wired through so sys/src/9/port/sysproc.ad can
    # already model the right invariants. Defaults: refcount=1
    # (table is private to this task), pgrp=0 (resolves to the root
    # Pgrp via chan.ad's _ensure_root lazy fixup), note_group=0
    # (default group). See `sys/src/9/port/sysproc.ad` for the rules
    # each bit honours.
    #
    # V2.5: `namespace_id` -> `pgrp_idx`, a pool index. V2.75 (this
    # revision) lifts that to a real heap pointer: `pgrp` is now a
    # uint64 holding the address of a kmalloc'd `Pgrp` struct (see
    # sys/src/9/port/chan.ad). do_exit calls pgrp_ref_dec(pgrp) which
    # kfree's the struct when the last referer drops it — no more
    # pool, no more cap.
    #
    # Field layout: V2.5 had pgrp_idx (int32) at 1388 and note_group
    # (int32) at 1392. Widening pgrp_idx → pgrp (uint64) needs 8-byte
    # alignment, so we SWAP the two fields' slots: note_group now sits
    # at 1388 (formerly pgrp_idx's slot), and pgrp occupies 1392..1400
    # (eating the 4 bytes that used to be note_group plus the 4 bytes
    # of implicit padding that followed). All later offsets — brk_*,
    # note_*, vma_list_head — are UNCHANGED. No external code reads
    # these by raw offset (verified via grep); both fields go through
    # accessor functions, so the swap is safe.
    fd_table_refcount: int32          # offset 1384
    note_group:        int32          # offset 1388 (was pgrp_idx in V2.5)
    pgrp:              uint64         # offset 1392..1400 (V2.75: heap Pgrp address)
    # M16.104: per-task SYS_brk state. Replaces the legacy linux_brk
    # global in linux_abi/u_syscalls.ad — that single cursor collided
    # whenever more than one Linux ELF was live at the same time, and
    # even in the single-process case the kmalloc-backed grow path
    # fragmented at page granularity. glibc-malloc requires brk's
    # backing memory to be virtually contiguous (its arena bookkeeping
    # only consults the top address and walks forward from the
    # previous high-water mark); a non-contiguous chunk trips the
    # "break adjusted to free malloc space" path and ultimately aborts
    # inside arena bookkeeping. We park three values per task:
    #
    #   brk_base — initial program break. Set on first brk() call to
    #              the base of a freshly-allocated contiguous region
    #              (alloc_pages(MAX_ORDER) -> 4 MiB).
    #   brk_end  — current program break cursor (initially == brk_base).
    #              brk(0) returns this; brk(new) within [base, max]
    #              just adjusts it.
    #   brk_max  — base + reserved size; refuse growth past this.
    #
    # All three are 0 in fresh slots (zero-init at task-create time).
    # On the CLONE_THREAD path (user_r9 != 0) the new task INHERITS
    # the parent's values — threads share the address space, so they
    # MUST see the same heap, otherwise two libcs in the same VM step
    # on each other's allocations. See create_user_thread and
    # _u_unimpl_brk in linux_abi/u_syscalls.ad.
    brk_base:   uint64                # offset 1400
    brk_end:    uint64                # offset 1408
    brk_max:    uint64                # offset 1416
    # M16.109: Plan 9 notify(2) / noted(2) state. note_handler_rip
    # holds the user-mode entry RIP installed via the SYS_NOTIFY (270)
    # syscall; 0 means "no handler" (a posted note has nowhere to go
    # and is silently dropped). When a note is delivered the kernel
    # captures the saved-user-RIP / saved-user-RSP slots into
    # note_saved_rip / note_saved_rsp, sets note_pending=1, and
    # rewrites the saved-user-RIP slot to point at note_handler_rip
    # so the next sysret enters the handler. SYS_NOTED (271) restores
    # both slots from the saved values and clears note_pending. The
    # 128-byte note_msg slot mirrors the Plan 9 ERRMAX/NOTEMAX cap and
    # holds the most recently posted note string so future code (or a
    # dedicated `noteinfo` syscall) can surface it to the handler;
    # this commit doesn't read it on the user side (the syscall return
    # path zeroes %rdi unconditionally outside the FUTEX fast-path,
    # so we can't deliver the pointer via the SysV first-arg slot
    # without touching syscall_64.S — which is off-limits this round).
    note_handler_rip: uint64          # offset 1424
    note_pending:     int32           # offset 1432
    # 4 bytes implicit pad to next 8-byte boundary; next field at 1440.
    note_saved_rip:   uint64          # offset 1440
    note_saved_rsp:   uint64          # offset 1448
    note_msg:         Array[128, uint8]  # offset 1456..1584
    # VMA layer (U42 follow-up): head pointer for the per-task VMA list.
    # Stored as uint64 so the field offset stays a clean 8-byte slot and
    # the accessor signature is identical to the other "raw pointer
    # parked as uint64" fields (brk_base, note_handler_rip). The actual
    # type is Ptr[VmaNode] from mm/vma.ad — but importing VmaNode here
    # would create a kernel/sched/core <-> mm/vma circular dependency
    # (mm/vma needs task_vma_list_head from us), so we keep the field
    # opaque and let mm/vma.ad cast through uint64 at the access sites.
    # 0 means "empty list" — fresh tasks start with no VMAs. Forks via
    # rfork RFPROC + no RFMEM will eventually deep-copy this list; the
    # thread path (RFMEM) will share. Both deferred to follow-ups; the
    # current commit zero-inits at kthread_create / create_user_thread
    # and clears via vma_clear on do_execve.
    vma_list_head:    uint64          # offset 1584
    # Per-process address space (fork) bookkeeping. Hamnix runs ET_DYN
    # binaries identity-mapped, so a forked child needs a PRIVATE
    # physical copy of every writable region remapped at the SAME
    # virtual address (else inherited absolute pointers point at the
    # parent's memory). do_clone's fork path copies four regions:
    #
    #   image_lo .. image_hi    the loaded ELF image (code+data+bss).
    #                           Recorded by do_execve from the loader's
    #                           elf_last_img_lo/hi.
    #   ustack_lo .. +ustack_sz the user stack region. ustack_base above
    #                           is the SAME value but is 0 when a task
    #                           was created with a caller-supplied RSP
    #                           (fork children, threads); ustack_lo is
    #                           always set so a grandchild fork still
    #                           finds the stack to copy.
    #   brk_base .. brk_end     the heap (already tracked above).
    #   each VMA's backing      anonymous + file mmaps (mm/vma.ad).
    #
    # All four are 0 on a fresh slot; do_execve fills image_* and
    # ustack_*, and do_clone propagates them to the child.
    image_lo:     uint64              # offset 1592
    image_hi:     uint64              # offset 1600
    ustack_lo:    uint64              # offset 1608
    ustack_sz:    uint64              # offset 1616
    # §1 / rfork RFNOWAIT: detach flag. 1 means this task has NO
    # waitable ancestor — rfork(RFNOWAIT) severed the parent_pid link,
    # so the parent must never block in wait4 on it and the kernel must
    # not leak it as a zombie. A detached task self-reaps: task_exit_-
    # current transitions it straight to STATE_FREE instead of
    # STATE_EXITED, so no slot leak and any wait4 on its pid sees
    # -ECHILD. Default 0 (a normal, reapable child). Placed at the end
    # of TaskStruct so it shifts no earlier offset.
    detached:     uint64              # offset 1624
    # §3 / Linux-ABI signals. LAYER-2-ONLY state — a confined facility
    # for Linux guests, never consulted by native (Layer-1) code.
    #
    #   sig_mask        — blocked-signal bitmap (rt_sigprocmask). Bit N
    #                     set ⇒ signal N is blocked: signal_check_and_-
    #                     handle skips it (it stays latched in
    #                     sig_pending until unblocked). SIGKILL/SIGSTOP
    #                     can never be masked — enforced at sigprocmask.
    #   sig_saved_mask  — the mask in effect BEFORE the current handler
    #                     was entered. rt_sigreturn restores it (the
    #                     authoritative copy also lives in the ucontext
    #                     on the user stack; this is the kernel mirror).
    #   sig_in_handler  — 1 while a signal handler is running. Guards
    #                     against a second handler being stacked on the
    #                     same syscall-return frame before the first
    #                     rt_sigreturn (which would corrupt user state).
    #   sig_flags[N]    — sa_flags recorded by rt_sigaction for signal N.
    #                     SA_SIGINFO (0x4) decides the handler argument
    #                     shape; SA_NODEFER (0x40000000) suppresses the
    #                     auto-block of the signal during its own
    #                     handler. All zero on a fresh slot.
    # Cleared at every create_user_task / create_user_thread and never
    # inherited across fork(): a child resets its signal disposition,
    # matching POSIX (handlers ARE inherited — sig_handlers — but the
    # pending set and in-handler state are not).
    sig_mask:       uint64            # offset 1632
    sig_saved_mask: uint64            # offset 1640
    sig_in_handler: uint64            # offset 1648
    sig_flags:      Array[64, uint64] # offset 1656..2168
    # §3: termination cause. 0 ⇒ the task exited normally (exit_code is
    # the _exit() status). Non-zero ⇒ the task was KILLED by signal N;
    # wait4 then encodes a WIFSIGNALED wait-status (low 7 bits = N)
    # instead of WIFEXITED. Set by the default-disposition path in
    # signal_check_and_handle right before task_exit_current.
    term_sig:       uint64            # offset 2168
    # §3: address of the ucontext_t inside the rt_sigframe most
    # recently built by deliver_signal_to_user. rt_sigreturn reads the
    # frame's RIP / RSP / RFLAGS / uc_sigmask back through this pointer
    # to restore the interrupted context — the trampoline cannot pass
    # it back as a syscall arg because rt_sigreturn takes none, so the
    # kernel stashes it here for the lifetime of the in-flight handler.
    sig_frame_uctx: uint64            # offset 2176
    # docs/security.md: Plan-9-shape uid/gid. Every task carries the
    # uid + gid of the user it runs as. Inherited on fork/rfork; only
    # the kernel-side /dev/auth cdev and the bring-up SYS_SETUID path
    # can ever change them. uid 1 == hostowner (machine owner; the
    # "root" idiom doesn't exist). System uids 2..999 reserved for
    # services (svc switches before exec). Regular users >= 1000.
    # Default 1 so kernel-spawned init (PID 1) starts as hostowner; an
    # explicit per-task value gets planted by /dev/auth on `newshell`.
    uid:            uint32            # offset 2184
    gid:            uint32            # offset 2188
    # Job control: the NUMERIC process-group id used by hamsh job
    # control (kill(-pgid), fg/bg, terminal-foreground tracking). This
    # is DELIBERATELY separate from `pgrp` above — that field is the
    # Plan-9 namespace Pgrp heap pointer (chan bindings), a different
    # concept that happens to share the name. A new task's job_pgid is
    # seeded to its own pid (it leads its own group) unless SYS_SETPGID
    # moves it. 0 here means "not yet assigned → resolves to pid".
    # Placed at the END of TaskStruct so it shifts no earlier offset.
    job_pgid:       uint64            # offset 2192
    # Job control: STATE_STOPPED bookkeeping. stop_sig records the
    # signal that stopped the task (SIGTSTP/SIGSTOP/SIGTTIN/SIGTTOU) so
    # wait-status reporting can distinguish causes; 0 when running.
    stop_sig:       uint64            # offset 2200
    # Set to 1 when a SIGCONT continued a previously-stopped task and
    # the parent has not yet observed it via the wait path. wait-status
    # decoding turns this into a "Continued" report. Cleared on read.
    cont_pending:   uint64            # offset 2208
    # Resource-reclaim bookkeeping (task_reap). image_phys / image_phys_sz
    # record the PHYSICAL backing region the ELF loader carved for this
    # task's binary image (via region_alloc) and its byte size, so
    # task_reap can hand the region back via region_free. Distinct from
    # image_lo/image_hi above, which are the VIRTUAL span — for an ET_EXEC
    # binary the physical region != the virtual address, so we must track
    # the physical base separately to free it. 0 ⇒ no reclaimable image
    # (kernel thread, or a slot that never loaded an ELF). Set by
    # SYS_SPAWN / do_execve right after create_user_task_argv returns.
    # Placed at the END of TaskStruct so it shifts no earlier offset.
    image_phys:     uint64            # offset 2216
    image_phys_sz:  uint64            # offset 2224
    # Owner-only user-stack reclaim. Like image_phys, set ONLY on the
    # task that actually alloc_pages'd the stack (SYS_SPAWN / do_execve)
    # and DELIBERATELY left 0 on fork children — a fork child COW-shares
    # the parent's ustack_lo/sz region, so freeing it from the child
    # would double-free the live parent stack. task_reap frees the stack
    # only via this owner field, never via the COW-shared ustack_lo/sz.
    ustack_phys:    uint64            # offset 2232
    ustack_phys_sz: uint64            # offset 2240
    # Owner-only dynamic-linker interpreter (ld-linux) reclaim. A dynamic
    # ELF spawn loads its PT_INTERP as a SEPARATE region_alloc'd image;
    # without this it leaked permanently (never per-task, never reaped).
    # Set ONLY on the task that allocated the interp region (SYS_SPAWN /
    # do_execve) and DELIBERATELY 0 on fork children — like image_phys, a
    # fork child COW-shares the parent's interp image and must not free
    # it. task_reap region_free's it under a != 0 guard. 0 on a static
    # binary (no PT_INTERP). Placed at the END of TaskStruct so it shifts
    # no earlier offset.
    interp_phys:    uint64            # offset 2248
    interp_phys_sz: uint64            # offset 2256
    # #147 / ptrace(2). LAYER-2-ONLY state — a confined facility for
    # Linux guests (the tracer strace + its tracee are both Linux ELF
    # binaries). Native (Layer-1) code never reads any of these; the
    # whole feature is gated on is_linux_userspace at the syscall choke
    # point. linux_abi/u_ptrace.ad reaches these through the get/set
    # accessors below — core.ad never statically depends on the
    # linux_abi layer (mirrors the cleartid_wake_hook one-directional
    # rule).
    #
    #   pt_tracer_pid   — pid of the tracer attached to THIS task, or 0
    #                     if not traced. Set by PTRACE_TRACEME (child
    #                     records its parent) / PTRACE_ATTACH.
    #   pt_traced       — 1 if this task is being traced (redundant with
    #                     pt_tracer_pid != 0 but kept explicit for the
    #                     enter/exit stop-wrap fast path).
    #   pt_stop_state   — current ptrace stop: 0 RUNNING, 1 SYSCALL-ENTER
    #                     stop, 2 SYSCALL-EXIT stop, 3 SIGNAL/ATTACH stop.
    #                     The tracer's wait4 reads this to synthesize a
    #                     WIFSTOPPED status; the tracee spins yielding
    #                     while it is non-zero.
    #   pt_options      — PTRACE_SETOPTIONS bitmap (PTRACE_O_TRACESYSGOOD
    #                     = 1 → syscall stops report SIGTRAP|0x80).
    #   pt_resume_req   — tracer-set resume kind: 0 none / still stopped,
    #                     1 PTRACE_CONT (run, don't stop at syscalls),
    #                     2 PTRACE_SYSCALL (stop at next enter AND exit).
    #                     The tracee reads-and-acts on this to leave its
    #                     stop loop.
    #   pt_in_syscall   — 1 between a syscall-enter stop and its matching
    #                     exit stop, so the exit wrap knows to fire.
    # All zero on a fresh slot; never inherited across fork (a child is
    # NOT auto-traced unless it itself calls PTRACE_TRACEME). Placed at
    # the END of TaskStruct so no earlier offset shifts.
    pt_tracer_pid:  uint64            # offset 2264
    pt_traced:      uint64            # offset 2272
    pt_stop_state:  uint64            # offset 2280
    pt_options:     uint64            # offset 2288
    pt_resume_req:  uint64            # offset 2296
    pt_in_syscall:  uint64            # offset 2304
    # 1 once the tracer's wait4 has reported the CURRENT stop, so a
    # second wait4 before the tracee is resumed doesn't re-report it.
    # Cleared when the tracee enters a fresh stop.
    pt_stop_reported: uint64          # (appended after pt_in_syscall)
    # Saved Linux user_regs_struct snapshot, captured by the tracee at
    # each ptrace stop so the tracer's PTRACE_GETREGS can read it from a
    # different address space. 27 uint64 slots == sizeof(struct
    # user_regs_struct) / 8. Field order is the canonical x86_64
    # user_regs_struct (see u_ptrace.ad UREG_* offsets).
    pt_regs:        Array[27, uint64] # (appended last)
    # #160 / seccomp-lite. LAYER-2-ONLY per-task syscall filter, reached
    # by linux_abi/u_syscalls.ad exclusively through the get/set
    # accessors below (core.ad never statically depends on linux_abi —
    # same one-directional rule as the ptrace block above). Gated on
    # is_linux_userspace at the syscall choke point; native (Layer-1)
    # tasks leave these zero and the enforcement check is never reached.
    #
    #   seccomp_mode    — 0 disabled, 1 SECCOMP_MODE_STRICT,
    #                     2 SECCOMP_MODE_FILTER (lite allow-list).
    #                     Once non-zero it is IRREVOCABLE — set_*_mode
    #                     refuses to lower it — and is inherited by a
    #                     fork/clone child (see do_clone).
    #   seccomp_filter  — for FILTER mode, a bitmap of permitted syscall
    #                     numbers 0..255 (4 x uint64). A "lite" stand-in
    #                     for a full BPF program: the default action is
    #                     kill-with-SIGSYS and only listed nrs (plus the
    #                     always-allowed strict set) pass. nrs >= 256 are
    #                     never in the allow-list, so they are denied.
    # All zero on a fresh slot. Placed at the END of TaskStruct so no
    # earlier offset shifts.
    seccomp_mode:   uint64            # (appended after pt_regs)
    seccomp_filter: Array[4, uint64]  # (appended last)
    # F10-8 / #457: NATIVE (Layer-1) per-task syscall allow-list bitmap,
    # consulted by arch/x86/kernel/syscall.ad::do_syscall BEFORE the
    # native dispatch ladder. Same 256-bit shape as seccomp_filter (4 x
    # uint64) but covers the native syscall number space (SYS_PUTC=0..
    # SYS_YIELD=24, plus the high 256+ Plan-9 numbers — those are out of
    # the 256-bit map and therefore implicitly DENIED when the filter is
    # armed). A bit set means "permitted." A whole-zero filter (the
    # initial state, and what a clean fork inherits if the parent never
    # armed it) is the DISARMED state and bypasses enforcement entirely;
    # arming is signalled by `seccomp_native_armed`. Once armed, it is
    # IRREVOCABLE — same one-way ratchet as the Layer-2 seccomp_mode
    # above. Inherited across fork/clone exactly like the Layer-2
    # filter (seccomp_inherit_to_child in arch/x86/kernel/syscall.ad).
    seccomp_native_armed:  uint64           # 0 disarmed, 1 armed
    seccomp_native_filter: Array[4, uint64] # allow-list bitmap, nrs 0..255
    # #151 / CFS-lite weighted-fair scheduling. LAYER-1 (native) state —
    # consulted by _pick_next / preempt_tick on every CPU. Placed at the
    # END of TaskStruct so no earlier offset shifts.
    #
    #   nice          — POSIX nice value in [-20, +19]. 0 is the default
    #                   ("NICE0"); lower = more CPU, higher = less. Set via
    #                   SYS_NICE / setpriority and inherited across fork.
    #   sched_weight  — Linux-style load weight derived from `nice` through
    #                   the prio_to_weight[40] table (sched_weight_for_nice).
    #                   NICE0_WEIGHT (1024) at nice 0. The scheduler picks
    #                   the smallest-vruntime READY task and advances the
    #                   running task's vruntime by delta*NICE0_WEIGHT/weight
    #                   each tick, so a 2x-weight task accrues vruntime half
    #                   as fast and therefore runs ~2x as much.
    #   vruntime      — accumulated weighted virtual runtime (monotonic).
    #                   A freshly-created/woken task is seeded to the current
    #                   minimum runqueue vruntime so it neither starves nor
    #                   monopolises. Advanced in preempt_tick / on dequeue.
    #   cpu_runs[c]   — count of times this task was dispatched onto logical
    #                   CPU c (BSP=0, APs=1..). Diagnostic for the SMP
    #                   load-balance test (proves a task ran on >1 CPU and
    #                   that runnable work spread across cores). 16 slots
    #                   matches AP_MAX_CPUS.
    # All zero on a fresh slot EXCEPT sched_weight, which task-create seeds
    # to NICE0_WEIGHT so a pre-nice() task is weighted fairly (a zero weight
    # would divide-by-zero in the vruntime advance).
    nice:          int64             # (appended after seccomp_filter)
    sched_weight:  uint64
    vruntime:      uint64
    cpu_runs:      Array[16, uint64]
    # getrusage(2): per-task CPU-time accounting. Every timer tick the
    # ISR (arch/x86/kernel/time.ad) calls current_task_account_tick(),
    # which bumps utime_ticks when the tick caught ring-3 (userland) code
    # and stime_ticks otherwise. HZ=100, so 1 tick = 10 ms. _u_getrusage
    # converts these counts to the rusage timevals (ru_utime / ru_stime).
    # Both 0 on a fresh slot — zeroed in sched_init_task_weight so a
    # recycled task starts its accounting clean. Placed at the END of
    # TaskStruct so no earlier offset shifts.
    utime_ticks:   uint64
    stime_ticks:   uint64
    # getrusage(2) / proc stat: per-task page-fault accounting. The page-
    # fault handler (arch/x86/kernel/trap_diag.ad) charges a MINOR fault
    # (resolved without disk I/O: demand-zero + COW) via
    # current_task_account_minor_fault(), and a MAJOR fault (swap-in /
    # backing-store I/O) via current_task_account_major_fault().
    # _u_getrusage maps these to ru_minflt (0x40) / ru_majflt (0x48), and
    # /proc/<pid>/stat surfaces them as fields 10 / 12. Both 0 on a fresh
    # slot — zeroed in sched_init_task_weight so a recycled task starts
    # clean. Placed at the END of TaskStruct so no earlier offset shifts.
    minflt:        uint64
    majflt:        uint64
    # getrusage(2): per-task context-switch accounting. schedule() charges
    # the OUTGOING (prev) task exactly once on every real (prev != next)
    # switch: a VOLUNTARY switch (nvcsw) when prev had already cleared its
    # RUNNING state before calling schedule() (it blocked / slept / exited),
    # an INVOLUNTARY switch (nivcsw) when prev was still RUNNING and got
    # preempted. This is Linux's `prev->state == TASK_RUNNING ? nivcsw :
    # nvcsw` rule. _u_getrusage maps these to ru_nvcsw (0x80) / ru_nivcsw
    # (0x88). Both 0 on a fresh slot — zeroed in sched_init_task_weight so a
    # recycled task starts clean. Placed at the END of TaskStruct so no
    # earlier offset shifts.
    nvcsw:         uint64
    nivcsw:        uint64
    # getrusage(2): per-task block-I/O accounting. The block layer
    # (kernel/block/blk.ad) charges the CALLING (current) task at the I/O
    # completion site: blk_read_sectors bumps inblock and blk_write_sectors
    # bumps oublock, both by the request length in 512-byte sectors.
    # _u_getrusage maps these to ru_inblock (0x58) / ru_oublock (0x60). Both
    # 0 on a fresh slot — zeroed in sched_init_task_weight so a recycled task
    # starts clean. Placed at the END of TaskStruct so no earlier offset
    # shifts.
    inblock:       uint64
    oublock:       uint64
    # getrusage(2): per-task signal-delivery accounting. signal_post charges
    # the TARGET (slot) task exactly once at the signal-latch site — the
    # final `sig_pending |= bit` store — so the early-return paths (a
    # handler-less SIGCONT, or a stop signal aimed at an already-STOPPED
    # task) correctly do NOT count, because nothing was latched.
    # _u_getrusage maps this to ru_nsignals (0x78). 0 on a fresh slot —
    # zeroed in sched_init_task_weight so a recycled task starts clean.
    # Placed at the END of TaskStruct so no earlier offset shifts.
    nsignals:      uint64
    # getrusage(2): ru_maxrss (0x20) — peak resident set size in KILOBYTES.
    # Linux reports a high-water mark, so this is a MONOTONIC maximum: it
    # only ever increases. _u_getrusage computes the CURRENT rss (present
    # 4 KiB pages * 4 KB/page) on demand from the VMA walk, bumps this
    # field if the current value is higher, then reports the high-water.
    # Because it never decrements there is no decrement-site to drift. 0 on
    # a fresh slot — zeroed in sched_init_task_weight so a recycled task
    # starts clean. Placed at the END of TaskStruct so no earlier offset
    # shifts.
    maxrss_kb:     uint64
    # /proc/<pid>/stat field 22 (starttime): the jiffy count at the moment
    # this task was created, captured write-once in sched_init_task_weight
    # (HZ=100, ticks since boot). ps/top combine it with the system uptime
    # and utime/stime to derive a process's elapsed time and %CPU. The boot
    # task (slot 0) is created before the timer fires so it legitimately
    # gets a low/zero value. Placed at the END of TaskStruct so no earlier
    # offset shifts.
    start_jiffies: uint64
    # Child-resource accounting (Linux RUSAGE_CHILDREN / wait()-time roll-up).
    # When a PARENT reaps a dead child (task_reap), the child's OWN CPU ticks
    # and page-fault counts PLUS the child's already-accumulated grandchild
    # totals roll up into these parent fields — i.e. the whole subtree, exactly
    # like Linux. They feed /proc/<pid>/stat field 11 (cminflt), 13 (cmajflt),
    # 16 (cutime), 17 (cstime) and times(2)'s tms_cutime / tms_cstime. All 0 on
    # a fresh slot — zeroed in sched_init_task_weight so a recycled task starts
    # clean. Placed at the END of TaskStruct so no earlier offset shifts.
    cutime_ticks:  uint64
    cstime_ticks:  uint64
    cminflt:       uint64
    cmajflt:       uint64
    # /proc/<pid>/io accounting (Linux task_io_accounting). rchar/wchar are
    # the total bytes returned/consumed by all read()/write()-family syscalls
    # (charged at the syscall boundary in linux_abi/u_syscalls.ad), syscr/syscw
    # the count of read()/write() syscall invocations. read_bytes/write_bytes
    # in /proc/<pid>/io are DERIVED from inblock/oublock (512-byte block
    # counts) so no new block-level field is needed; cancelled_write_bytes is
    # always 0 (we never cancel writeback). All 0 on a fresh slot — zeroed in
    # sched_init_task_weight so a recycled task starts clean. Placed at the END
    # of TaskStruct so no earlier offset shifts.
    rchar:         uint64
    wchar:         uint64
    syscr:         uint64
    syscw:         uint64
    # Event-driven wait queues (replace the timer-tick poll-yield model).
    # A task blocked on a resource (console FIFO, pipe read end, pty peer
    # queue) is linked onto a per-resource WaitQueue and moved to
    # STATE_WAIT — OFF the runqueue, so _pick_next never selects it and
    # the timer tick never re-polls it. The producer (UART RX IRQ, pipe
    # write, pty peer write) calls wq_wake_one/wq_wake_all which moves the
    # waiter(s) back to STATE_READY and unlinks them.
    #
    #   wait_next     — intrusive singly-linked list link: 1 + the slot
    #                   index of the NEXT waiter on the same queue, or 0
    #                   for "end of list / not linked". The +1 bias lets 0
    #                   mean "no link" even though slot 0 is a valid task.
    #   wait_on       — 1 + the slot index head this task is queued under,
    #                   or 0 if not on any queue. Used only as a "still
    #                   linked?" flag by wq_sleep's unlink-on-return so a
    #                   racing producer wake (which already unlinked us) is
    #                   handled idempotently.
    #   wait_signaled — set to 1 by the signal path when it force-wakes a
    #                   STATE_WAIT task, so wq_sleep_interruptible knows the
    #                   wake was a signal (return -EINTR) rather than data.
    # All 0 on a fresh slot — zeroed in sched_init_task_weight. Placed at
    # the END of TaskStruct so no earlier offset shifts.
    wait_next:     uint64
    wait_on:       uint64
    wait_signaled: uint64
    # Per-CPU runqueue (#6): the logical CPU id whose runqueue currently
    # OWNS this task while it is STATE_READY or STATE_RUNNING. _pick_next()
    # on CPU c considers ONLY slots with rq_cpu == c, so the dispatch hot
    # path consults the LOCAL runqueue under the LOCAL rq lock alone — no
    # global lock. Set when a task is made runnable (sched_enqueue_on /
    # placement), updated atomically under the owning rq lock when a task is
    # work-stolen / migrated to another CPU. Slot 0 (BSP boot task) is always
    # rq_cpu == 0. A STATE_WAIT / STATE_FREE / STATE_STOPPED task's rq_cpu is
    # stale (meaningless) until it is re-enqueued. 0 on a fresh slot — zeroed
    # in sched_init_task_weight. Placed at the END of TaskStruct so no
    # earlier offset shifts.
    rq_cpu:        uint64
    # sched_setaffinity(2)/sched_getaffinity(2): the per-task CPU-affinity
    # bitmask. Bit c (1<<c) set means "this task is ALLOWED to run on logical
    # CPU c". The scheduler HONORS this: placement (sched_pick_target_cpu),
    # work-steal (_sched_try_pull_locked) and a setaffinity that excludes the
    # owning CPU (which marks the task for migration) all constrain a task to
    # a CPU whose bit is set. A fresh/recycled slot defaults to AFFINITY_ALL
    # (every CPU permitted) in sched_init_task_weight, so a task that never
    # calls setaffinity behaves exactly as before. 64 CPUs fit one word, far
    # beyond NR_RQ(16). Placed at the END of TaskStruct so no earlier offset
    # shifts.
    cpu_affinity:  uint64
    # #443 native threads: exit-notification semaphore address. The
    # NATIVE (Plan 9-shape) counterpart of clear_child_tid above: a
    # thread created via rfork(RFPROC|RFMEM) registers a user address
    # through SYS_SETEXITSEM (lib/thread.ad's trampoline does this as
    # its first act), and task_exit_current semrelease's that address —
    # atomic increment + wake — AFTER the thread is dead and off its
    # user stack. thread_join() is then literally semacquire(&t.done):
    # no joiner/exiter stack race, no polling. 0 = none registered
    # (default; plain forks and Linux tasks never set it — Linux
    # threads use clear_child_tid + futex instead). Fired through the
    # exitsem_release_hook function pointer (sys/src/9/port/sems.ad
    # registers it at bring-up) so core.ad keeps zero static deps on
    # the port layer — the same one-directional rule as
    # cleartid_wake_hook. Placed at the END of TaskStruct so no
    # earlier offset shifts.
    exit_sem:      uint64
    # Phase D follow-up: per-fd opened-path slot. fd2path(2) needs to
    # report the EXACT path the fd was opened with (post-resolve_path so
    # binds reflect correctly); without this slot the old code had to
    # synthesize a path from backend metadata, which could not recover
    # an unrelated bind target the user actually typed. Each slot is a
    # 128-byte NUL-terminated string (matches the per-task cwd buffer
    # cap above and the kernel-wide path-buf shape). 0-byte first
    # element ("" or 0) means "no path recorded" — fd2path falls back to
    # the synthesis ladder for backends that do not stamp a path (the
    # stdio markers, dup'd fds whose parent never stamped, ...). Stamped
    # by vfs_open / vfs_open_write at fd-install time, cleared by
    # close_fd_in_task, copied by copy_fd_entry on dup/fork. All zero on
    # a fresh slot — zeroed in _init_fd_table so a recycled task starts
    # clean. Placed at the END of TaskStruct so no earlier offset shifts.
    # Sized by NR_FDS (=64). 64*128 = 8 KiB per task.
    fd_opened_path: Array[64, Array[128, uint8]]
    # Scoped KERNEL-data-segment uaccess mode (Linux's set_fs(KERNEL_DS) /
    # force_uaccess_begin analog). 0 = normal: copy_to_user/copy_from_user
    # enforce the strict SMAP US-bit check (the "user" pointer MUST resolve
    # to a US=1 user page). NONZERO = the kernel is deliberately driving a
    # syscall handler in-kernel with KERNEL-mapped (US=0) buffers as the
    # "user" pointer — ONLY the boot self-test harness sets this, around
    # the landlock/caps/mempolicy/perf/keyring handler calls — and under it
    # uaccess_resolve accepts US=0 pages. A REAL userspace syscall NEVER
    # sets this, so the SMAP protection it relies on is completely
    # unchanged. Strictly opt-in, bounded by the set/clear bracket in
    # init/main.ad; inherited as 0 on a fresh slot (.bss-zero). Placed at
    # the END of TaskStruct so no earlier offset shifts.
    uaccess_kernel: uint64

    # Track 5: intrusive per-CPU READY run-list links. When this task is
    # STATE_READY it is a member of rq_head[rq_cpu]'s doubly-linked list;
    # rq_next/rq_prev are slot indices (RQL_NIL at the ends). When the task
    # is NOT STATE_READY both are RQL_NIL (off every run-list). These let
    # _pick_next() walk ONLY the runnable set on the local CPU instead of
    # scanning all NTASKS slots. Maintained exclusively by _rq_list_insert /
    # _rq_list_remove, which are called at every transition into/out of
    # STATE_READY. Placed at the END of TaskStruct so no earlier offset
    # shifts; a fresh .bss slot has both == 0, which _rq_list_* treat as
    # "not currently linked" via the parallel rq_on_list flag below.
    rq_next:      uint64
    rq_prev:      uint64
    # Run-list membership tag: 0 = NOT on any run-list; otherwise it holds
    # (listed_cpu + 1), i.e. which CPU's rq_head list this slot is currently
    # linked into. Encoding the cpu (rather than a bare 0/1) lets
    # _rq_list_remove fix the correct rq_head even when rq_cpu has already been
    # re-stamped (affinity migration / work-steal change rq_cpu between the
    # insert and the matching remove). Avoids ambiguity with the .bss-zero
    # rq_next/rq_prev (slot 0 is a valid link target). Cleared on remove.
    rq_on_list:   uint64

    # RCU read-side nesting depth for THIS task (mirrors Linux's
    # task_struct->rcu_read_lock_nesting). rcu_read_lock() bumps it,
    # rcu_read_unlock() drops it. The scheduler's QS hook
    # (rcu_note_context_switch) reports a quiescent state for the OUTGOING
    # CPU only when this is 0 — so a task preempted mid-rcu_read_lock (under
    # the scheduler agent's CONFIG_PREEMPT work) is never counted quiescent.
    # Migrates with the task by living in its slot. Placed at the END of
    # TaskStruct so no earlier offset shifts; fresh .bss slot starts at 0.
    rcu_read_nesting: uint64

    # RCU reclaim of this slot: when task_reap finishes a dead task it does NOT
    # immediately mark the slot FREE / push it to the freelist (a lock-free
    # task-list reader could be mid-read of this slot's pid/state/name). Instead
    # it call_rcu's _task_slot_rcu_free with this embedded rcu_head; the slot is
    # only published FREE + returned to the freelist after a grace period, when
    # no reader can still hold a pointer into it. rcu_head is two words: [0] is
    # an RCU next-link scratch word, [1] stashes the slot index so the callback
    # knows which slot to free. Placed at the END of TaskStruct so no earlier
    # offset shifts; .bss-zero on a fresh slot.
    rcu_head_next: uint64
    rcu_head_slot: uint64
    # Dynamic-linker (PT_INTERP / ld.so) VIRTUAL image span. Distinct from
    # interp_phys/interp_phys_sz (the OWNER-only PHYSICAL region for reclaim):
    # these are the per-task USER virtual range [interp_lo, interp_hi) the
    # interpreter image is mapped at. do_execve records it (alongside
    # image_lo/image_hi); do_clone COW-shares it into the child so the
    # child's cloned PML4 gets cracked, US=1 leaf PTEs over the interp's
    # 1 GiB ASLR window — WITHOUT this the child inherits the boot identity
    # PS=1 (US=0) huge page covering the interp window and any CPL=3 ld.so
    # access faults err=0x05 (present/user/read perm fault on a supervisor
    # leaf). UNLIKE interp_phys this VA range IS propagated to fork children
    # (a grandchild fork must re-share the same span). 0 on a static binary.
    # Placed at the END of TaskStruct so no earlier offset shifts.
    interp_lo:     uint64
    interp_hi:     uint64
    # prctl(PR_SET_NO_NEW_PRIVS): Linux's one-way "no-new-privileges" bit.
    # apt's acquire methods (and most modern sandboxing code) call
    # prctl(PR_SET_NO_NEW_PRIVS, 1) immediately BEFORE installing a seccomp
    # filter — Linux requires NNP to be set first unless the caller is
    # CAP_SYS_ADMIN. A method that gets -EINVAL here _error->Errno()s and
    # exits, which apt surfaces as "method driver could not be found." We
    # honour the SET (return 0) and reflect it back through PR_GET. It is a
    # one-way ratchet: once 1 it can never be cleared. Inherited across
    # fork/clone (set_user_creds-style). 0 on a fresh slot. Placed at the
    # END of TaskStruct so no earlier offset shifts.
    no_new_privs:  uint64
    # FORK+EXEC COW-image discriminator (apt dpkg-split blocker, T26).
    # Set to 1 ONLY by the fork path (do_clone, arch/x86/kernel/syscall.ad)
    # right after it COW-shares the parent's ELF image + interp into the
    # child via vm_cow_share_all / vm_cow_share_range. It records the one
    # fact do_execve cannot otherwise reconstruct: "the image currently
    # mapped in THIS task's address space is a COW alias of a still-living
    # fork parent's live image frames (per-PFN refcount == 2), not a region
    # this task owns outright." image_phys == 0 is NOT a sufficient proxy:
    # the boot init task and other directly-launched tasks can also carry
    # image_phys == 0 while OWNING (or simply holding) a non-COW image, and
    # cow_drop'ing those frames at the next execve corrupts the image and
    # wedges boot. do_execve tears the outgoing image down through the
    # COW-safe path IFF this flag is 1; a normal owner-image exec (flag 0)
    # is left entirely to task_free_owner_regions / region_free. CLEARED on
    # every execve that loads a fresh region-owned image (the new image is
    # NOT COW-shared), and 0 on a fresh slot. Placed at the END of
    # TaskStruct so no earlier offset shifts.
    image_cow_shared: uint64
    # Linux-ABI no-syscall watchdog bookkeeping. `last_syscall_jiffies` is
    # stamped with get_jiffies() at task-create AND on every Linux syscall
    # dispatch (do_syscall's is_linux_userspace arm). While a Linux-ABI task
    # spins in userspace it issues NO syscalls, so this stamp goes stale;
    # the timer-tick watchdog (mm/vma.ad linux_nosyscall_watchdog_tick) fires
    # once the (jiffies - stamp) gap crosses the threshold and dumps the
    # spinning RIP. `wd_last_dump_jiffies` rate-limits repeat dumps of the
    # same spin episode. Both appended at the END of TaskStruct so no earlier
    # offset shifts; fresh .bss slots start at 0 (create paths re-stamp).
    last_syscall_jiffies: uint64
    wd_last_dump_jiffies:  uint64
    # QA-N32b WORK-STEAL HYSTERESIS. Stamped with get_jiffies() by
    # sched_note_dispatch every time this task is dispatched onto a CPU.
    # _sched_try_pull_locked refuses to STEAL a task whose last dispatch was
    # within STEAL_HYSTERESIS_JIFFIES so a just-run task is not immediately
    # yanked onto the other CPU — which, once the idle AP wakes on a short
    # local backstop and re-scans aggressively, could otherwise ping-pong a
    # task between cores every few ms (the steal-livelock a naive tick change
    # exposed). Appended at the END of TaskStruct so no earlier offset shifts;
    # fresh .bss slots start at 0 (== "dispatched long ago" → freely
    # stealable, which is correct for a brand-new/never-run task).
    last_dispatch_jiffy: uint64
    # setitimer(2) ITIMER_REAL (wall-clock) state. LAYER-2-ONLY — a Linux-ABI
    # facility (the setitimer/getitimer/alarm handlers in u_syscalls.ad reach
    # these through accessors), but the DECREMENT runs from the native timer
    # tick (itimer_real_tick_all below, called BSP-only from timer_interrupt)
    # because ITIMER_REAL is wall-clock: it counts down regardless of whether
    # the owning task is currently scheduled. Granularity is one tick (HZ=100
    # => 10 ms), the accuracy contract the brief allows.
    #
    #   itimer_real_ticks  — remaining ticks until SIGALRM fires. 0 == disarmed
    #                        (the timer is stopped). Decremented once per tick.
    #   itimer_real_reload — reload value in ticks, latched from it_interval.
    #                        On expiry the timer reloads itimer_real_ticks from
    #                        this; 0 == one-shot (fire once, then stop).
    # Both 0 on a fresh slot; CLEARED on execve (setitimer timers do NOT survive
    # exec — POSIX) and on task_reap (no stale misfire into a recycled slot).
    # xeyes/xclock and most X/GTK apps drive their redraw off ITIMER_REAL ->
    # SIGALRM, so this is the gate to X11 apps actually rendering under XWayland.
    # Placed at the END of TaskStruct so no earlier offset shifts.
    itimer_real_ticks:  uint64
    itimer_real_reload: uint64
    # Full resolved path of the currently-execve'd image (absolute, NUL-
    # terminated, truncated at 255 chars). do_execve stamps it from the
    # resolved exec_kpath; readlinkat("/proc/self/exe") hands it back so
    # binaries that locate sibling resources relative to their own path
    # work. Firefox's XPCOMGlueLoad derives its library dir from
    # dirname(/proc/self/exe) — without the REAL path it looked in the
    # wrong dir and aborted with "Couldn't load XPCOM." Empty (path[0]==0)
    # on a fresh/kthread slot => readlinkat falls back to the synthetic
    # probe path. Placed at the END of TaskStruct so no earlier offset shifts.
    exe_path: Array[256, uint8]
    # CLONE_FILES shared fd-table ownership (#71 — Firefox/threaded-GUI gate).
    # A task that OWNS its own fd table (the common case: every fork child,
    # every fresh process) has fd_owner_p1 == 0. A CLONE_FILES *thread* points
    # at the slot OWNING the shared table (its group leader) via
    # fd_owner_p1 == owner_slot + 1 (the +1 encoding makes a .bss-zero slot
    # mean "self-owned" without an explicit init on every create path). Every
    # fd-array access (fd_idx/fd_pos/fd_buf/fd_buflen/fd_opened_path) is routed
    # through fd_owner_task()/fd_owner_slot_of() so a thread's open/close/dup is
    # visible to all sharers — the whole point of clone(CLONE_FILES).
    # fd_table_refcount (above) counts LIVE sharers of the owner's table (owner
    # itself + every CLONE_FILES thread); the last sharer to exit closes the
    # table, and task_reap defers freeing an owner slot whose refcount is still
    # >0 so the inline arrays outlive any live sharer. Placed at the END of
    # TaskStruct so no earlier offset shifts; fresh .bss slot => self-owned.
    fd_owner_p1: int32
    # Spinlock serialising the owner's live-sharer refcount (fd_table_refcount)
    # against concurrent CLONE_FILES thread create / exit on other CPUs, so the
    # inc in fd_table_share_to_thread and the dec in _release_fd_table_on_exit
    # never race and lose a count (which would free the shared table early or
    # leak it). Only ever taken on the OWNER slot (fd_owner_task(t)[0].fd_lock).
    # 0 = unlocked (fresh .bss slot). Uncontended for self-owned tasks.
    fd_lock: uint32
    # Linux-ABI multi-thread stall diagnostic (#73 — Firefox flush/thread-sync
    # hang). Stamped with the syscall NUMBER on every Linux syscall dispatch
    # (do_syscall's is_linux_userspace arm), alongside last_syscall_jiffies.
    # When the no-syscall watchdog fires on a SPINNING task it also walks the
    # whole task table and prints, for every OFF-CPU Linux task, the syscall it
    # is currently parked in (futex? poll? epoll_wait? read?) — the key signal
    # for diagnosing which background thread never completes what the main
    # thread waits on. Appended at the END of TaskStruct so no earlier offset
    # shifts; a fresh .bss slot reads 0 (== "no syscall issued yet").
    last_syscall_nr: uint64
    # #73 parked-stall diagnostic: arg0 of the last Linux syscall (the fd for
    # read/poll/recvmsg — pins WHICH descriptor a parked thread blocks on).
    # Appended at the END so no earlier offset shifts; fresh .bss reads 0.
    last_syscall_arg0: uint64


# State constants (mirror Linux's task->state space at a tiny scope).
STATE_FREE:    uint64 = 0
STATE_READY:   uint64 = 1
STATE_RUNNING: uint64 = 2
STATE_EXITED:  uint64 = 3
# Job control: the task is stopped (SIGTSTP/SIGSTOP). It is NOT on the
# runqueue — _pick_next skips it — until a SIGCONT moves it back to
# STATE_READY. Distinct from STATE_EXITED (which is terminal).
STATE_STOPPED: uint64 = 4
# SMP: slot is reserved for an AP's idle kthread.  It has been created
# (kstack allocated, entry point planted) but the AP has not yet entered
# it.  _find_free_slot() skips PARKED slots so create_user_task cannot
# steal the slot between sched_prepare_ap_idle() and sched_ap_launch().
# _pick_next() skips it (only schedules READY/RUNNING).  The AP's
# sched_ap_launch() transitions it directly to STATE_RUNNING.
STATE_PARKED: uint64 = 5

# Event-driven wait: the task is blocked on a resource wait queue (console
# input FIFO, pipe read end, pty peer queue). It is OFF the runqueue —
# _pick_next() skips anything != STATE_READY, so a STATE_WAIT task is never
# dispatched and never re-polled on the timer tick. A producer's
# wq_wake_one/wq_wake_all moves it back to STATE_READY; the signal path also
# force-wakes it (so a blocked read returns -EINTR on Ctrl-C). This is the
# Linux TASK_INTERRUPTIBLE shape — sleep until explicitly woken, not poll.
STATE_WAIT: uint64 = 6

# Thread under construction (CLONE_THREAD / rfork RFMEM). The slot is
# claimed (so _find_free_slot cannot hand it out) and its cr3 already
# points at the CREATOR's shared PML4, but the caller (do_clone /
# _rfork_thread) is still wiring up inheritance: fs_base (CLONE_SETTLS),
# the fd table, seccomp, cwd, tid bookkeeping. _pick_next only picks
# STATE_READY, so an EMBRYO is invisible to EVERY dispatcher — including
# the OTHER CPU's idle pull/steal path, which an IRQ mask on the creating
# CPU never blocked. The creator publishes the thread runnable with
# task_publish_thread_ready() only after the LAST inheritance store.
# This closes the SMP window where a half-built thread (garbage %fs TLS,
# missing fds) could be dispatched mid-construction.
STATE_EMBRYO: uint64 = 7

# Reclaim done, slot awaiting its RCU grace-period free. task_reap has
# already released ALL of the dead task's resources (address space, stacks,
# pid mapping) and call_rcu'd the final STATE_FREE publish, but the slot
# cannot be flipped FREE until a grace period elapses (a lock-free reader may
# still hold a pointer into it — see the RCU-DEFERRED SLOT RECLAIM note in
# task_reap). The OLD code left the slot STATE_EXITED across that window,
# which let a SECOND reaper (reap_orphan_zombies runs on every fork; do_wait4;
# the thread-group zombie sweep) re-match it as a fresh zombie and reap it
# AGAIN — queuing a duplicate call_rcu whose callback PUSHED the same slot to
# the freelist twice. A double-push cross-links the intrusive freelist into a
# cycle; subsequent pops then collapse free_head to FL_NIL while hundreds of
# slots are genuinely STATE_FREE, so create_*_task spuriously fails with "no
# free task slot" (observed at DE boot: scene clients dying with
# "command not found: /bin/hamX"). STATE_REAPING is non-FREE (readers still
# see a stable body) and is NOT STATE_EXITED, so every zombie scan skips it —
# a reaped task is reaped EXACTLY ONCE. The RCU callback flips it to FREE.
STATE_REAPING: uint64 = 8

# Per-task kernel stack. 64 KiB (16 pages, buddy order 4). The deepest
# in-kernel call chain is NOT a single 4 KiB page — three distinct
# chains have overrun smaller stacks:
#
#   * The TLS 1.3 handshake (drivers/net/tls.ad: X25519 + AES-256 key
#     schedule + SHA-256 + certificate-chain parsing + HKDF + transcript
#     hashing, nested frames up to ~0x170 bytes) overran a 4 KiB kstack,
#     which prompted the 16 KiB (order-2) bump.
#
#   * The rfork/fork path (do_rfork -> create_user_task_argv ->
#     vm_cow_share_all -> per-page _cow_resolve_pte_slot table-cracking
#     under the boot-CR3 guard, all while rc.boot sources its script)
#     overran the 16 KiB kstack by a few quads. Because the buddy
#     allocator hands a new child's kstack the block PHYSICALLY ADJACENT
#     below the running parent's (parent kstack 0x6020000.., child
#     0x601c000..0x6020000), the parent's overflow wrote a user-stack
#     pointer into the child's iret-frame SS slot at child_ktop-8
#     (0x601fff8) — corrupting it to a non-canonical selector and
#     faulting #GP on the bootstrap iretq when the child was first
#     dispatched. That intermittent (~50%) spawn crash is why 16 KiB was
#     not enough; 32 KiB clears the deepest fork chain with headroom.
#
#   * The #410 live-root bringup (vfs_write -> loopctl_write ->
#     loop_sqfs_live_root -> sqfs stream -> ext4_init ->
#     _try_parse_hamnix_roots with ~5 KiB of parse locals) overran the
#     32 KiB kstack. The dominant cost is NOT the leaf chain: Adder's
#     codegen gives EVERY local in a function a distinct frame slot, so
#     do_syscall's giant dispatch body (4x 4 KiB bounce buffers + dozens
#     of path/stat staging arrays across its case arms) is a single
#     0x6e10-byte (28 KiB) frame that is live across EVERY syscall —
#     leaving ~4 KiB of real budget on a 32 KiB stack. Observed exactly
#     like the fork-chain overrun: intermittent (~2/3) corruption of
#     whatever buddy block sits below the kstack (a cracked PT page ->
#     "kstack page not present" #PF at the vfs_write epilogue; live data
#     -> [stack-smash] canary mismatch in a high frame). 64 KiB restores
#     ~36 KiB of callee headroom. The real waste — the dispatcher frame
#     — wants either compiler stack-slot reuse for disjoint case arms or
#     hoisting the Array-heavy syscall bodies into helper functions;
#     tracked as a follow-up, the sizing here must still cover it today.
#
# Because create_user_thread allocates the kstack immediately above the
# task's user stack, an overflow also silently corrupts the user stack
# (smashing a saved return address -> ring-3 #UD at a bogus rip). Both
# failure modes are the same root cause: too little kstack. KSTACK_ORDER
# is the buddy-allocator order matching KSTACK_SIZE; keep them in sync
# (2^KSTACK_ORDER * 4096 == KSTACK_SIZE).
#
#   * #438 (third recurrence, 2026-06-11): the Linux-ABI write(2) chain
#     do_syscall (28 KiB frame!) -> linux_u_syscall_dispatch -> _u_write
#     -> u_write_body (4.2 KiB) -> _u_vfs_write_user (4.2 KiB) ->
#     vfs_write overran the 32 KiB kstack by ~4.4 KiB. The Adder
#     compiler gives every branch-local its own permanent frame slot, so
#     do_syscall accumulated ~26.5 KiB of per-arm bounce Arrays. The
#     overflow scribbled kernel return addresses over the two physical
#     pages below the kstack block; when the buddy order placed the
#     task's own ELF-image page table there (ASLR-draw dependent,
#     ~1-in-4 boots), leaf PTEs became kernel-text pointers ->
#     reserved-bit #PF (err=0x1d) on the next user ifetch. Fixed by
#     out-of-lining do_syscall's 4 KiB-buffer arms (_sysarm_* in
#     arch/x86/kernel/syscall.ad) AND bumping to 64 KiB for headroom,
#     plus a stack canary at kstack_base checked in schedule() so any
#     future overflow is caught loudly instead of corrupting whatever
#     the buddy allocator placed below.
KSTACK_SIZE:  uint64 = 65536
KSTACK_ORDER: int32  = 4
# Stamped at kstack_base (the lowest quad) on allocation; checked in
# schedule(). If a kernel call chain ever grows past KSTACK_SIZE again,
# the canary is the first thing overwritten and we panic with the task
# identified instead of silently corrupting adjacent buddy blocks
# (page tables, sibling kstacks, ...). See #438 above.
KSTACK_CANARY: uint64 = 0xDEAD57AC4C0FFEE5
USTACK_SIZE: uint64 = 4096

# F10-3 #456: named uid constants — make the model explicit at the call
# site so a future audit of "who can do what" doesn't have to grep for
# bare integers. The two load-bearing identities:
#
#   UID_HOSTOWNER (1)  — the Plan-9 "glenda" / first user. Owns /, /etc,
#                        /bin, the rootfs partition; the single account
#                        that can run hpm, useradd, edit /etc/shadow, ...
#                        Set by inittab at PID 1 boot and by /dev/auth-
#                        mediated SYS_SETUID at login. uid 0 doesn't
#                        exist in Hamnix (no Unix "root").
#   UID_NOBODY (65534) — the DEFAULT for every freshly-spawned task that
#                        hasn't been explicitly given an identity. This
#                        is what every userland program before login,
#                        plus every task whose parent never set a uid,
#                        runs as. F3's per-server policies (uid==1
#                        hostowner bypass at the dispatcher) won't fire
#                        for these tasks — they ARE the everyone-can-
#                        be-everything failure pre-F10-3 closed.
#
# docs/security.md "F10-3: default uid model" documents the contract.
UID_HOSTOWNER: uint32 = 1
UID_NOBODY:    uint32 = 65534

# Boot-GDT selectors (matches arch/x86/boot/header.S).
SCHED_KERNEL_CS:  uint64 = 0x08
USER_CS_R3: uint64 = 0x23                # 0x20 | RPL=3
USER_DS_R3: uint64 = 0x1B                # 0x18 | RPL=3
RFLAGS_INITIAL: uint64 = 0x202           # bit 1 reserved | bit 9 IF=1

# Runqueue + bookkeeping.
# U27: bumped from 4 to 8. pthread_create() needs 1 slot per worker
# thread (in addition to hamsh, the main thread, and any forked
# children); a 2-worker test fixture is already at the old ceiling
# with no headroom.
# U28: bumped to 16 to accommodate the musl_thread_many stress fixture
# which spawns 8 worker threads simultaneously (plus init/hamsh/main =
# 11 live tasks at the peak). Other stress fixtures fit comfortably
# under this ceiling. A real RCU-aware reclaim path is a future
# milestone; for now widening the array is the cheapest fix.
# NTASKS bumped to 64 (was 16) to support Debian server workloads:
# apt's fork-storm during package install, nginx worker pools, and
# parallel pthread fixtures all peg well above 16 live tasks.
# NTASKS lifted 64 -> 256 (this commit): a full graphical session burns
# many concurrent tasks (compositor + panel + terminal + file-manager +
# clock + per-app shells + daemons), so 64 LIVE tasks throttled spawn/
# fork under a real DE workload. 256 gives 4x headroom.
# BSS cost: TaskStruct is ~10.5 KiB (named fields ~2.3 KiB + the 8 KiB
# fd_opened_path NR_FDS x 128 array). 256 x 10.5 KiB = ~2.7 MiB resident
# (was ~666 KiB at 64). Together with the NTASKS-derived satellite tables
# (perf/pidfd/landlock (task x fd), rlimit, seccomp pool, caps/mempolicy/
# keyring/oom/sched-policy) the total static delta is ~3 MiB — under the
# ~4 MiB threshold that would mandate heap lazy-alloc, so the table stays
# a fixed-size BSS allocation (Array sizes must be literals in Adder).
# EVERY array sized off NTASKS (or NTASKS*NR_FDS, or NTASKS*RLIM_NLIMITS)
# moves in lockstep with this constant; missing one is silent corruption.
#
# Track 5: lifted 256 -> 512. The dispatch hot path NO LONGER scans the table
# (per-CPU intrusive run-lists make _pick_next O(active-on-this-cpu)), and
# pid/free lookups are O(1) hash/freelist — so the ceiling can rise without
# any O(NTASKS) scan penalty. The OLD 256 was a hard wall that wedged spawn/
# fork under a heavy graphical+server session; 512 doubles the headroom. BSS
# delta: TaskStruct ~10.5 KiB x 512 = ~5.4 MiB (was ~2.7 MiB) plus the
# NTASKS-derived satellite tables — all bumped 256 -> 512 in LOCKSTEP (see
# scripts/test_ntasks_per_task_tables.sh, the drift guard).
NTASKS:      uint64 = 512
task_table:  Array[512, TaskStruct]
next_pid:    uint64 = 1

# =====================================================================
# O(1) acceleration structures (Track 5 — kill the O(NTASKS) scans)
# =====================================================================
# The slot-indexed task_table stays the backing store (slot == the stable
# cross-subsystem task identity used by /proc, the satellite tables, and
# every task_struct_at() caller). What CHANGES is that the three hot-path
# linear scans over all NTASKS slots are replaced by O(1)/O(active) lookups:
#
#   1. _find_free_slot()   — O(NTASKS) scan for a STATE_FREE slot
#                            → intrusive FREE-slot freelist (free_head + the
#                              fl_next links below). Pop = O(1).
#   2. task_lookup_by_pid()— O(NTASKS) scan matching .pid
#                            → open-addressed pid->slot hash. Lookup = O(1)
#                              amortised. A linear fallback is retained as a
#                              correctness safety net (a missed insert never
#                              corrupts, it just degrades to the old scan).
#   3. _pick_next()        — O(NTASKS) scan for the min-vruntime READY slot
#                            → per-CPU intrusive READY run-LIST (rq_head[] +
#                              the rq_next/rq_prev TaskStruct links). The scan
#                              now walks ONLY this CPU's runnable set.
#
# These are pure accelerators layered over the existing state machine; the
# task_table[] semantics are unchanged.

# --- (1) FREE-slot freelist -----------------------------------------
# fl_next[s] = next free slot after s, or FL_NIL at the tail. free_head is
# the list head (FL_NIL when no free slot). Built once in sched_init() over
# every slot, popped on alloc, pushed on reap. Slot 0 is reserved for the
# boot task and is NEVER on the freelist (claimed in sched_init()).
FL_NIL:      uint64 = 0xFFFFFFFFFFFFFFFF
fl_next:     Array[512, uint64]    # NTASKS-sized
free_head:   uint64 = 0xFFFFFFFFFFFFFFFF   # FL_NIL until sched_init() builds it
free_inited: uint64 = 0
# SMP: the free-slot list (free_head + fl_next[]) is mutated from BOTH the
# alloc path (_free_list_pop in create_*_task, syscall/process context) AND
# the reclaim path (_free_list_push from task_reap / the RCU slot callback,
# which fires off the timer-IRQ-driven rcu_advance_gp). On a multi-CPU box
# those run concurrently on different CPUs with no other shared lock, and the
# unlocked read-modify-write on free_head raced: a pop and a push interleaving
# dropped slots out of the list. The freelist would shrink to FL_NIL while
# HUNDREDS of slots were genuinely STATE_FREE — _find_free_slot then returned
# -1 ("no free task slot") and the spawn failed (observed at DE boot: a
# nondeterministic subset of scene clients died with "command not found:
# /bin/hamX"). This lock makes every freelist mutation atomic; IRQs are
# masked while it is held so the timer-IRQ RCU push can never deadlock against
# a process-context pop on the same CPU.
freelist_lock: uint32 = 0

# --- (2) pid -> slot hash -------------------------------------------
# Open-addressed (linear-probe) hash sized at 2*NTASKS so the load factor
# stays <= 0.5 (cheap probes). Each bucket holds a pid (PIDH_EMPTY = vacant,
# PIDH_DELE = tombstone) and the slot it maps to. Lifetime: inserted when a
# task's pid is stamped (_task_set_pid), removed when its slot frees
# (_task_clear_pid). task_lookup_by_pid probes here first; on any miss it
# falls back to the legacy linear scan so a maintenance gap can never break
# /proc / waitpid / signal delivery — it only loses the speed-up.
PIDH_SIZE:   uint64 = 1024                   # 2 * NTASKS
PIDH_EMPTY:  uint64 = 0                       # pid 0 is never a real task pid
PIDH_DELE:   uint64 = 0xFFFFFFFFFFFFFFFF      # tombstone sentinel
pidh_pid:    Array[1024, uint64]            # PIDH_SIZE
pidh_slot:   Array[1024, uint64]           # PIDH_SIZE
pidh_inited: uint64 = 0
# sched_setaffinity(2) default mask: every CPU permitted. A task whose
# cpu_affinity == AFFINITY_ALL is fully unpinned, so placement / steal
# behave exactly as they did before affinity enforcement existed. 64 bits
# all set — far more than NR_RQ(16) logical CPUs.
AFFINITY_ALL: uint64 = 0xFFFFFFFFFFFFFFFF
# SMP-safe per-CPU current task slot index.  Each CPU (BSP + APs) keeps
# its own copy in its %gs per-CPU area so schedule() / current_task()
# always refer to the task running on THAT cpu.  The BSP initialises its
# slot to 0 in sched_init(); each AP initialises its slot to its dedicated
# idle kthread slot when it first enters sched_ap_launch().
current_idx_pcpu: Percpu[uint64]

# =====================================================================
# Per-CPU runqueue locking model (#6 — mirrors Linux's per-CPU struct rq)
# =====================================================================
#
# BEFORE: one global `rq_lock` serialised EVERY task_table[*].state
# mutation AND every _pick_next() scan, so two CPUs picking work at the
# same time contended on a single word. That is the bottleneck this work
# removes.
#
# AFTER: the runnable set is PARTITIONED per CPU. Each runnable/running
# task records the logical CPU that owns it in `rq_cpu` (a TaskStruct
# field). Two locks now exist:
#
#   rq_locks[c]  — protects CPU c's runqueue: the READY/RUNNING membership
#                  of tasks with rq_cpu == c, and the READY<->RUNNING flips
#                  the dispatch path performs on them. The DISPATCH HOT PATH
#                  (schedule() on CPU c, sched_ap_idle_loop() on CPU c) takes
#                  ONLY rq_locks[c]. No global lock on the hot path.
#
#   wq_lock      — a single global lock protecting WAIT-QUEUE LIST STRUCTURE
#                  (WaitQueue.head, task wait_next / wait_on / wait_signaled)
#                  and the WAIT<->READY transitions of sleepers. This mirrors
#                  Linux, where wait_queue_head_t has its OWN spinlock,
#                  distinct from rq->lock. Wake/sleep are not the dispatch
#                  hot path, so a shared lock here is fine and keeps the
#                  lost-wakeup proof simple.
#
# LOCK ORDERING (deadlock avoidance) — strict, documented rule:
#   1. wq_lock is the OUTER lock. When a wake needs to flip a sleeper to
#      READY it takes wq_lock first, then rq_locks[target] (inner). The
#      dispatch path takes ONLY rq_locks[c] and NEVER wq_lock, so the two
#      classes never invert.
#   2. When TWO rq locks are needed at once (cross-CPU work-steal /
#      migration), they are acquired in ASCENDING cpu-index order, OR via
#      spinlock_trylock-and-back-off. The steal path here uses trylock on
#      the victim rq while holding the thief's own rq lock, and simply skips
#      the steal if the trylock fails — never blocking, never inverting.
#
# Neither lock is held across __switch_to_asm: a task switched away from
# re-enters schedule() later and must not try to re-acquire a lock it no
# longer holds. Hold windows stay tiny (a scan + a couple of stores).
#
# Uniprocessor (BSP-only): the BSP timer ISR fires with IF=0, so schedule()
# is naturally serialised; rq_locks[0] / wq_lock are always free (the xchg
# round-trips cache but never spins).
NR_RQ: uint64 = 16
rq_locks: Array[16, uint32]
wq_lock: uint32 = 0

# Track 5: per-CPU READY run-list heads. rq_head[c] is the slot index of the
# first STATE_READY task owned by CPU c, or RQL_NIL when c's runqueue is
# empty. The list is doubly-linked through TaskStruct.rq_next/rq_prev (slot
# indices). Membership is mutated ONLY under rq_locks[c] (the same lock that
# already guards CPU c's READY/RUNNING set), so the list and the state field
# stay consistent. _pick_next() walks rq_head[my_cpu] instead of all NTASKS
# slots. rq_inited gates the very early boot window before sched_init()
# fills the heads with RQL_NIL (the .bss zero would otherwise read as
# "slot 0 is the head").
RQL_NIL: uint64 = 0xFFFFFFFFFFFFFFFF
rq_head: Array[16, uint64]           # NR_RQ-sized
rq_inited: uint64 = 0

# DEPRECATED single global rq lock. Retained ONLY as the wq_lock alias name
# was a bigger rename; all former rq_lock sites have been migrated to either
# wq_lock (wait-queue list + WAIT transitions) or rq_locks[cpu] (runqueue
# membership). Kept defined to avoid an accidental dangling reference; it is
# no longer taken anywhere.
rq_lock: uint32 = 0


# IRQ-safe locking (#6): every scheduler lock (wq_lock and rq_locks[*]) is
# taken with LOCAL INTERRUPTS DISABLED, mirroring Linux's raw_spin_lock_irq*
# discipline on rq->lock. WHY: wq_wake_*/signal_post run from DEVICE IRQ
# context and now take rq_locks[target] (to home a woken task). If a CPU
# held an rq lock with IRQs enabled and a device IRQ fired into wq_wake
# wanting the SAME lock, the interrupted holder could never release it →
# self-deadlock. Disabling IRQs around every scheduler-lock hold removes
# the window entirely.
#
# Saved-flags handling: the dispatch/steal paths nest up to TWO scheduler
# locks (steal holds the local rq lock then trylocks a victim rq). We keep a
# small PER-CPU stack of saved IRQ-flag words, indexed by get_cpu_id() (a
# plain Array[NCPU] rather than Percpu[Array] — the latter miscompiles).
# Depth 4 is ample (max nest = local rq + victim rq, plus wq_lock + one rq).
_SCHED_IRQ_DEPTH: uint64 = 4
_sched_irq_flags: Array[64, uint64]      # NR_RQ(16) * depth(4)
_sched_irq_sp:    Array[16, uint64]      # per-cpu stack pointer (0..depth)


def _sched_irq_push():
    # Disable local IRQs, saving the prior flag word onto this CPU's stack.
    cid: uint64 = get_cpu_id()
    if cid >= NR_RQ:
        cid = 0
    fl: uint64 = local_irq_save()
    sp: uint64 = _sched_irq_sp[cid]
    if sp < _SCHED_IRQ_DEPTH:
        _sched_irq_flags[cid * _SCHED_IRQ_DEPTH + sp] = fl
        _sched_irq_sp[cid] = sp + 1
    # If we ever overflow (should not at depth 4) we simply leave IRQs
    # disabled until an unbalanced pop; safer than corrupting memory.


def _sched_irq_pop():
    # Restore the IRQ flag word saved by the matching _sched_irq_push.
    cid: uint64 = get_cpu_id()
    if cid >= NR_RQ:
        cid = 0
    sp: uint64 = _sched_irq_sp[cid]
    if sp > 0:
        sp = sp - 1
        _sched_irq_sp[cid] = sp
        local_irq_restore(_sched_irq_flags[cid * _SCHED_IRQ_DEPTH + sp])
    else:
        # Unbalanced pop (should not happen): default to enabling IRQs.
        local_irq_enable()


def _rq_lock_cpu(cpu: uint64):
    # Acquire CPU `cpu`'s runqueue lock with local IRQs disabled (IRQ-safe).
    # Bounds-guarded (a stray out-of-range cpu would corrupt memory).
    _sched_irq_push()
    if cpu < NR_RQ:
        spinlock_lock(&rq_locks[cpu])
    else:
        spinlock_lock(&rq_locks[0])


def _rq_unlock_cpu(cpu: uint64):
    if cpu < NR_RQ:
        spinlock_unlock(&rq_locks[cpu])
    else:
        spinlock_unlock(&rq_locks[0])
    _sched_irq_pop()


def _rq_trylock_cpu(cpu: uint64) -> uint32:
    # IRQ-safe trylock: disable IRQs, attempt acquire. On SUCCESS leave IRQs
    # disabled (a matching _rq_unlock_cpu will pop). On FAILURE restore IRQs
    # immediately (no lock was taken, so no nesting to unwind).
    _sched_irq_push()
    got: uint32 = 0
    if cpu < NR_RQ:
        got = spinlock_trylock(&rq_locks[cpu])
    else:
        got = spinlock_trylock(&rq_locks[0])
    if got == 0:
        _sched_irq_pop()
    return got


def _wq_lock_irq():
    # Acquire the global wait-queue lock with local IRQs disabled.
    _sched_irq_push()
    spinlock_lock(&wq_lock)


def _wq_unlock_irq():
    spinlock_unlock(&wq_lock)
    _sched_irq_pop()


def sched_pick_target_cpu(slot: uint64) -> uint64:
    # Per-CPU rq (#6): choose which CPU's runqueue a newly-runnable task
    # should be placed on. Placement policy (Linux's select_task_rq, much
    # simplified): pick the ONLINE CPU currently owning the FEWEST runnable
    # (STATE_READY) tasks, so wakeups spread load. Slot 0 (the BSP boot
    # task) is always BSP-pinned. A user/kernel task is eligible on any
    # online CPU (Stage A: per-CPU TSS lets APs run user tasks).
    #
    # Caller should hold no rq lock spanning all CPUs; this is a heuristic
    # read of per-CPU READY counts and a stale count only costs a slightly
    # uneven placement that the work-steal path later rebalances.
    if slot == 0:
        return 0
    nonline: uint64 = get_cpus_online()
    if nonline <= 1:
        return 0
    # sched_setaffinity(2): consider ONLY CPUs the task's affinity mask
    # allows. The least-loaded ALLOWED CPU wins; a task pinned to a single
    # CPU therefore always lands on that CPU. If the mask excludes every
    # online CPU (should not happen — an empty effective mask is rejected at
    # setaffinity time) best_cpu stays 0 and is corrected below.
    best_cpu:   uint64 = 0xFFFFFFFFFFFFFFFF
    best_count: uint64 = 0xFFFFFFFFFFFFFFFF
    c: uint64 = 0
    while c < nonline and c < NR_RQ:
        if sched_cpu_allowed(slot, c) != 0:
            cnt: uint64 = 0
            i: uint64 = 0
            while i < NTASKS:
                if task_table[i].state == STATE_READY:
                    if task_table[i].rq_cpu == c:
                        cnt = cnt + 1
                i = i + 1
            if cnt < best_count:
                best_count = cnt
                best_cpu = c
        c = c + 1
    if best_cpu == 0xFFFFFFFFFFFFFFFF:
        return 0
    return best_cpu


def sched_make_ready_on(slot: uint64, target_cpu: uint64):
    # Per-CPU rq (#6): place `slot` on CPU `target_cpu`'s runqueue and make
    # it STATE_READY, holding ONLY that CPU's rq lock. Sends a DIRECTED
    # reschedule IPI to target_cpu so an idle owner falls out of HLT and
    # dispatches it. Caller must NOT hold target_cpu's rq lock. May be held
    # under wq_lock (lock order wq_lock -> rq_locks[c] is honoured here).
    #
    # Slot 0 is BSP-pinned: force its owner to CPU 0 regardless of the
    # requested target so the BSP boot task never migrates to an AP.
    tc: uint64 = target_cpu
    if slot == 0:
        tc = 0
    if tc >= NR_RQ:
        tc = 0
    _rq_lock_cpu(tc)
    task_table[slot].rq_cpu = tc
    task_table[slot].state  = STATE_READY
    # Track 5: enqueue onto tc's intrusive READY run-list under tc's rq lock
    # (the same lock that guards tc's READY membership). _pick_next on tc
    # walks this list.
    _rq_list_insert(slot, tc)
    _rq_unlock_cpu(tc)
    # Kick the owning CPU (directed). No-op on a uniprocessor; if tc is the
    # caller's own CPU the IPI self-targets harmlessly (handler just EOIs).
    smp_send_reschedule_cpu(tc)


def sched_make_ready(slot: uint64):
    # Convenience wrapper: choose a target CPU via the placement policy and
    # enqueue `slot` there. Used by the generic "this task just became
    # runnable" sites (new task create, SIGCONT resume, etc.).
    tc: uint64 = sched_pick_target_cpu(slot)
    sched_make_ready_on(slot, tc)


# Per-AP idle kthread slot indices.  Index = logical CPU id (1..MAX_CPUS-1).
# sched_prepare_ap_idle() (called by smp_boot_aps before booting each AP)
# stores the slot number here; sched_ap_launch() (called by the AP itself
# after its %gs area is set up) reads it to know which task to enter.
# Slot 0 is left unused (CPU 0 = BSP has no idle kthread — it runs init).
AP_MAX_CPUS: uint64 = 16
ap_idle_slots: Array[16, uint64]

# Memory-leak accounting: cumulative task spawn/reap counters.
# nr_tasks_spawned is incremented each time kthread_create or
# create_user_task allocates a slot; nr_tasks_reaped is incremented
# each time task_reap marks a slot STATE_FREE. The difference
# (nr_tasks_spawned - nr_tasks_reaped) is the number of live+zombie
# slots currently in use. After a clean spawn/reap cycle it must
# return to baseline.
nr_tasks_spawned: uint64 = 0
nr_tasks_reaped:  uint64 = 0

# --- Exit-time CLEARTID wake hook (boundary-discipline inversion) ----
#
# CLONE_CHILD_CLEARTID is a Linux-ABI (Layer 2) contract: a clone()d
# pthread registers a user pointer (ctid) that the kernel must zero AND
# futex-wake when the thread exits, so pthread_join's FUTEX_WAIT loop
# unblocks. The futex wait-queue table itself lives entirely inside
# linux_abi/u_syscalls.ad (Layer 2) — the scheduler (Layer 0/1) must
# NOT name `futex_wake_all` directly, or the native exit path would
# statically link Layer-2 code (a boundary-law violation).
#
# Inversion: Layer 2 registers a "wake on a cleared child-tid address"
# callback here during bring-up; task_exit_current invokes it through
# this function pointer. The default is null — a pure native kernel
# (no Linux ABI linked) simply does nothing on the CLEARTID path, which
# is correct: native tasks never set clear_child_tid. After this, the
# scheduler's static link surface touches zero Layer-2 symbols.
cleartid_wake_hook: Fn[int32, uint64]

# --- #73 futex-table stall-dump hook -----------------------------------
# The futex wait table lives in Layer-2 (linux_abi/u_syscalls.ad); the
# no-syscall watchdog lives in mm/vma.ad and must not statically link a
# Layer-2 symbol. Same inversion as cleartid_wake_hook: Layer 2 registers
# a "dump every occupied futex slot" callback at bring-up; the watchdog
# invokes it through call_linux_futex_dump() when a stall is detected, so
# the log shows exactly which futex uaddr each parked thread waits on and
# which slot should have woken it. Null on a native-only build (no-op).
linux_futex_dump_hook: Fn[None]

def register_linux_futex_dump_hook(hook: Fn[None]):
    linux_futex_dump_hook = hook

def call_linux_futex_dump():
    if linux_futex_dump_hook != cast[Fn[None]](0):
        linux_futex_dump_hook()

# --- Exit-time UMDF driver-host cleanup hook (Track 4 crash isolation) ---
#
# When a user-mode driver host (linux_abi/umdf_kernel.ad consumer) exits
# OR crashes, the kernel must release every privileged primitive it held
# — IRQ files and DMA buffers — so a crashed vendor `.ko` leaves no kernel
# state wedged and the host can be cleanly restarted. The scheduler stays
# Layer-1-pure: it calls this hook (registered by Layer 2 at bring-up)
# with the exiting task's slot. A native-only build leaves it null and
# this is a no-op. Crash and clean-exit both funnel through
# task_exit_current, so a single hook here covers both.
umdf_task_exit_hook: Fn[None, uint64]

# --- Exit-time NATIVE exit-sem release hook (#443 native threads) ----
#
# The Plan 9-shape mirror of cleartid_wake_hook. A native rfork(RFPROC|
# RFMEM) thread registers a user semaphore address via SYS_SETEXITSEM
# (stored in TaskStruct.exit_sem); on exit the kernel must semrelease
# it — atomic increment of the user word + wake of any semacquire
# waiter — so a thread_join() blocked in semacquire(&t.done) unblocks.
# The semaphore wait-bucket table and the uaccess plumbing live in
# sys/src/9/port/sems.ad (the port layer), which core.ad must not name
# statically; sems_init() registers this callback at bring-up. Null on
# a build that never calls sems_init — native tasks then never have a
# non-zero exit_sem either, so the path is inert.
exitsem_release_hook: Fn[int32, uint64]


def register_exitsem_release_hook(hook: Fn[int32, uint64]):
    # sys/src/9/port/sems.ad calls this once from sems_init() during
    # kernel bring-up. See exitsem_release_hook above.
    exitsem_release_hook = hook


# --- Preemption: per-task quantum -----------------------------------
#
# Before this change the timer ISR called schedule() on EVERY tick
# (and, separately, the real workload never had two concurrent READY
# user tasks, so it was effectively cooperative). Two problems with
# "switch every tick": (a) it preempts kernel/IRQ context, which is
# unsafe (a kthread mid-update of a shared structure), and (b) a 10 ms
# round-robin slice is needlessly fine-grained.
#
# The quantum fixes both. SCHED_QUANTUM_TICKS is the number of 100 Hz
# timer ticks a task is allowed to run before the timer ISR rotates
# the runqueue. `quantum_left` counts down; preempt_tick() decrements
# it on every tick and, when it hits zero AND the timer interrupted
# ring-3 (userland) code AND another task is STATE_READY, performs the
# context switch via the existing schedule() path.
#
# 5 ticks = 50 ms. Long enough that an interactive syscall-bound task
# almost always blocks (and yields cooperatively) before its quantum
# expires, so preemption only actually fires against a task that is
# genuinely CPU-bound — exactly the starvation case we are closing.
SCHED_QUANTUM_TICKS: uint64 = 5
quantum_left:        uint64 = 5

# --- #151: CFS-lite weighted-fair scheduling --------------------------
#
# Each task carries a `nice` value (-20..+19) that maps to a load
# `sched_weight` via the canonical Linux prio_to_weight[40] table. The
# scheduler is a weighted-fair (CFS-lite) design at the small-array
# scale Hamnix runs:
#
#   • _pick_next() chooses the READY task with the SMALLEST vruntime
#     (a linear min-scan over the <=16-slot task_table — no red-black
#     tree needed at this scale; the array model is unchanged).
#   • On every timer tick preempt_tick() advances the RUNNING task's
#     vruntime by  ticks_elapsed * NICE0_WEIGHT / sched_weight.  A
#     heavier (lower-nice) task accrues vruntime more slowly, so it is
#     re-picked more often and ends up with proportionally more CPU.
#   • A task's per-tick QUANTUM is scaled by weight too: a heavier task
#     gets a longer slice (clamped to [1, SCHED_QUANTUM_MAX]) so the
#     coarse 100 Hz tick still delivers the weight ratio even when only
#     two CPU-bound tasks alternate.  Lighter tasks get the floor of 1
#     tick.
#   • New / woken tasks are seeded to the current minimum runqueue
#     vruntime (sched_min_vruntime) so a fresh task neither starves the
#     incumbents nor is starved by their accumulated vruntime.
#
# NICE0_WEIGHT is Linux's SCHED_LOAD_SCALE for nice 0 (1<<10). The table
# is geometric with ~1.25 per nice step, matching kernel/sched/core.c's
# sched_prio_to_weight[].
NICE0_WEIGHT: uint64 = 1024
NICE_MIN:     int64  = -20
NICE_MAX:     int64  = 19
# Fixed-point multiplier for the per-tick vruntime advance so the integer
# divide by weight keeps resolution for heavy tasks (weight up to 88761).
# 256 keeps NICE0 at a tidy 256/tick while the heaviest task still advances
# a non-zero amount each tick.
VRUNTIME_SCALE: uint64 = 256
# Upper clamp on a weight-scaled timeslice (in 100 Hz ticks). A nice
# -20 task (weight 88761) would otherwise compute an enormous slice;
# cap it so a single high-prio task can't run unbounded before the
# next preemption point. 4x the base quantum is plenty of head-room to
# express the weight ratio against a nice +19 peer (weight 15).
SCHED_QUANTUM_MAX: uint64 = 20

# --- realtime scheduling policies (SCHED_FIFO / SCHED_RR) -------------
#
# Linux-parity POSIX realtime scheduling. Every task carries a SCHEDULING
# POLICY and (for the realtime policies) a REALTIME PRIORITY in [1, 99].
# The default for a fresh task is SCHED_OTHER — the existing CFS-lite
# weighted-fair behaviour, completely unchanged for normal tasks.
#
#   SCHED_OTHER (0) — the CFS-lite policy. nice/weight/vruntime as today.
#                     rt_priority is meaningless (treated as 0).
#   SCHED_FIFO  (1) — strict realtime, first-in-first-out. A FIFO task
#                     runs until it blocks, yields, or exits. It is NEVER
#                     preempted by an equal-or-lower realtime priority,
#                     and never by any SCHED_OTHER task. No timeslice.
#   SCHED_RR    (2) — strict realtime, round-robin. Like FIFO but a task
#                     at the end of its RR timeslice rotates to the TAIL
#                     of its priority level so equal-priority RR peers
#                     share the CPU. Higher priorities still strictly
#                     preempt lower ones.
#
# The pick rule (in _pick_next / the AP steal loop): ANY runnable realtime
# task outranks ALL SCHED_OTHER tasks; among realtime tasks the HIGHEST
# rt_priority wins; ties within a priority level rotate (RR) via a
# per-level FIFO order captured in rt_enqueue_seq.
#
# Both fields live in parallel module-global tables keyed by task slot
# (the rlimit / oom_score_adj pattern) so TaskStruct's hand-maintained
# byte-offset layout is left completely untouched.
SCHED_OTHER: uint64 = 0
SCHED_FIFO:  uint64 = 1
SCHED_RR:    uint64 = 2
# POSIX realtime priority range. sched_get_priority_max/min return these
# for FIFO/RR and 0/0 for OTHER.
RT_PRIO_MIN: int64 = 1
RT_PRIO_MAX: int64 = 99
# RR timeslice in 100 Hz ticks (Linux default RR quantum is ~100 ms; HZ=100
# so 10 ticks). An RR task that exhausts this rotates to its level's tail.
SCHED_RR_TICKS: uint64 = 10
# Per-task policy + realtime priority, slot-indexed. All zero on a fresh
# slot => SCHED_OTHER / rt_priority 0, the unchanged CFS-lite default.
g_sched_policy:   Array[512, uint64]    # NTASKS-sized
g_rt_priority:    Array[512, uint64]    # NTASKS-sized
# Monotonic enqueue sequence per slot. When a realtime task becomes the
# pick at its priority level we choose the SMALLEST sequence (oldest
# arrival) so FIFO order is honoured; an RR task that uses up its slice
# is re-stamped to the current max+1 (sent to the tail). 0 means "not yet
# stamped" and is treated as oldest. The counter is monotonic; at the
# 16-slot scale it never realistically wraps.
g_rt_enqueue_seq: Array[512, uint64]    # NTASKS-sized
g_rt_seq_next:    uint64 = 1
# RR slice countdown, slot-indexed. Decremented on each timer tick that
# catches an RR task running; on reaching 0 the task rotates and the
# slice re-arms. SCHED_OTHER/FIFO tasks ignore this field.
g_rr_slice_left:  Array[512, uint64]    # NTASKS-sized

# Linux sched_prio_to_weight[40], index 0 == nice -20 .. index 39 ==
# nice +19. Verbatim from kernel/sched/core.c so the CPU-share ratios
# match a real Linux box for a given pair of nice values. Filled lazily
# at first use (sched_prio_to_weight_inited guard) rather than via a
# global array-literal initialiser — the same runtime-fill idiom the
# CRC32 tables use (lib/xz/xz.ad), which is the proven-supported pattern.
sched_prio_to_weight: Array[40, uint64]
sched_prio_to_weight_inited: uint64 = 0


def _sched_fill_weight_table():
    if sched_prio_to_weight_inited != 0:
        return
    sched_prio_to_weight[0]  = 88761
    sched_prio_to_weight[1]  = 71755
    sched_prio_to_weight[2]  = 56483
    sched_prio_to_weight[3]  = 46273
    sched_prio_to_weight[4]  = 36291
    sched_prio_to_weight[5]  = 29154
    sched_prio_to_weight[6]  = 23254
    sched_prio_to_weight[7]  = 18705
    sched_prio_to_weight[8]  = 14949
    sched_prio_to_weight[9]  = 11916
    sched_prio_to_weight[10] = 9548
    sched_prio_to_weight[11] = 7620
    sched_prio_to_weight[12] = 6100
    sched_prio_to_weight[13] = 4904
    sched_prio_to_weight[14] = 3906
    sched_prio_to_weight[15] = 3121
    sched_prio_to_weight[16] = 2501
    sched_prio_to_weight[17] = 1991
    sched_prio_to_weight[18] = 1586
    sched_prio_to_weight[19] = 1277
    sched_prio_to_weight[20] = 1024
    sched_prio_to_weight[21] = 820
    sched_prio_to_weight[22] = 655
    sched_prio_to_weight[23] = 526
    sched_prio_to_weight[24] = 423
    sched_prio_to_weight[25] = 335
    sched_prio_to_weight[26] = 272
    sched_prio_to_weight[27] = 215
    sched_prio_to_weight[28] = 172
    sched_prio_to_weight[29] = 137
    sched_prio_to_weight[30] = 110
    sched_prio_to_weight[31] = 87
    sched_prio_to_weight[32] = 70
    sched_prio_to_weight[33] = 56
    sched_prio_to_weight[34] = 45
    sched_prio_to_weight[35] = 36
    sched_prio_to_weight[36] = 29
    sched_prio_to_weight[37] = 23
    sched_prio_to_weight[38] = 18
    sched_prio_to_weight[39] = 15
    sched_prio_to_weight_inited = 1


def sched_weight_for_nice(n: int64) -> uint64:
    # Clamp the nice value to [-20, +19] and look up its load weight.
    _sched_fill_weight_table()
    nn: int64 = n
    if nn < NICE_MIN:
        nn = NICE_MIN
    if nn > NICE_MAX:
        nn = NICE_MAX
    idx: int64 = nn - NICE_MIN          # 0..39
    return sched_prio_to_weight[cast[uint64](idx)]


def sched_min_vruntime() -> uint64:
    # Smallest vruntime among READY/RUNNING tasks, used to seed a newly
    # created or woken task. Returns 0 if no eligible task exists. Caller
    # should hold rq_lock when consistency matters; the seeding callers
    # run at task-create time where a tiny skew is harmless.
    best: uint64 = 0
    have: uint64 = 0
    i: uint64 = 0
    while i < NTASKS:
        st: uint64 = task_table[i].state
        if st == STATE_READY or st == STATE_RUNNING:
            v: uint64 = task_table[i].vruntime
            if have == 0 or v < best:
                best = v
                have = 1
        i = i + 1
    return best


def sched_quantum_for(slot: uint64) -> uint64:
    # Weight-scaled timeslice in 100 Hz ticks for `slot`. Base quantum
    # scaled by weight/NICE0_WEIGHT, floored at 1 and capped at
    # SCHED_QUANTUM_MAX. Heavier (lower-nice) tasks run longer slices.
    w: uint64 = task_table[slot].sched_weight
    if w == 0:
        w = NICE0_WEIGHT
    q: uint64 = (SCHED_QUANTUM_TICKS * w) / NICE0_WEIGHT
    if q < 1:
        q = 1
    if q > SCHED_QUANTUM_MAX:
        q = SCHED_QUANTUM_MAX
    return q


# --- realtime policy accessors / mutators ----------------------------

def sched_get_policy(slot: uint64) -> uint64:
    # Return the SCHED_* policy of `slot`. Out-of-range slots report
    # SCHED_OTHER so callers never act on garbage.
    if slot >= NTASKS:
        return SCHED_OTHER
    return g_sched_policy[slot]


def sched_get_rt_priority(slot: uint64) -> uint64:
    # Return the realtime priority [1,99] of `slot`, or 0 for a
    # SCHED_OTHER task / out-of-range slot.
    if slot >= NTASKS:
        return 0
    return g_rt_priority[slot]


def sched_is_realtime(slot: uint64) -> uint64:
    # 1 if `slot` runs a realtime policy (FIFO or RR), else 0.
    if slot >= NTASKS:
        return 0
    p: uint64 = g_sched_policy[slot]
    if p == SCHED_FIFO or p == SCHED_RR:
        return 1
    return 0


def _rt_stamp_seq(slot: uint64):
    # Stamp `slot` with the next monotonic enqueue sequence. Smallest
    # sequence == oldest arrival; used to break ties within a realtime
    # priority level so FIFO order (and RR rotation to the tail) is honoured.
    g_rt_enqueue_seq[slot] = g_rt_seq_next
    g_rt_seq_next = g_rt_seq_next + 1


def sched_set_scheduler(slot: uint64, policy: uint64, rt_prio: int64) -> int32:
    # Apply a scheduling policy + realtime priority to `slot`. This is the
    # single mechanism behind both the Linux sched_setscheduler ABI and the
    # native `/proc/<pid>/ctl` `policy` verb.
    #
    # Validation mirrors Linux:
    #   • policy must be one of SCHED_OTHER/FIFO/RR.
    #   • a realtime policy requires rt_prio in [1,99].
    #   • SCHED_OTHER requires rt_prio == 0.
    # Returns 1 on success, 0 on an invalid argument (caller maps to EINVAL).
    if slot >= NTASKS:
        return 0
    if policy != SCHED_OTHER and policy != SCHED_FIFO and policy != SCHED_RR:
        return 0
    if policy == SCHED_OTHER:
        if rt_prio != 0:
            return 0
        g_sched_policy[slot]   = SCHED_OTHER
        g_rt_priority[slot]    = 0
        g_rt_enqueue_seq[slot] = 0
        g_rr_slice_left[slot]  = 0
        return 1
    # Realtime policy.
    if rt_prio < RT_PRIO_MIN or rt_prio > RT_PRIO_MAX:
        return 0
    g_sched_policy[slot] = policy
    g_rt_priority[slot]  = cast[uint64](rt_prio)
    # A newly-realtime task arrives at the TAIL of its priority level: stamp
    # it with a fresh sequence so existing same-priority peers (older
    # sequences) are picked ahead of it until they yield.
    _rt_stamp_seq(slot)
    if policy == SCHED_RR:
        g_rr_slice_left[slot] = SCHED_RR_TICKS
    else:
        g_rr_slice_left[slot] = 0
    return 1


def sched_priority_max(policy: uint64) -> int64:
    # sched_get_priority_max(2): 99 for FIFO/RR, 0 for OTHER.
    if policy == SCHED_FIFO or policy == SCHED_RR:
        return RT_PRIO_MAX
    return 0


def sched_priority_min(policy: uint64) -> int64:
    # sched_get_priority_min(2): 1 for FIFO/RR, 0 for OTHER.
    if policy == SCHED_FIFO or policy == SCHED_RR:
        return RT_PRIO_MIN
    return 0


def sched_init_task_policy(slot: uint64):
    # Reset a freshly-created / recycled slot's realtime policy state to the
    # SCHED_OTHER default. Called from sched_init_task_weight so a reused slot
    # never inherits a stale realtime policy from a previous tenant.
    if slot >= NTASKS:
        return
    g_sched_policy[slot]   = SCHED_OTHER
    g_rt_priority[slot]    = 0
    g_rt_enqueue_seq[slot] = 0
    g_rr_slice_left[slot]  = 0


def sched_inherit_policy_to_child(child_slot: uint64, parent_slot: uint64):
    # fork/clone: POSIX says a child inherits the parent's scheduling policy
    # and realtime priority. (Linux's SCHED_RESET_ON_FORK can opt out; we
    # don't model that flag yet — straight inheritance, the common case.) The
    # child arrives at the TAIL of its priority level via a fresh sequence.
    if child_slot >= NTASKS or parent_slot >= NTASKS:
        return
    g_sched_policy[child_slot] = g_sched_policy[parent_slot]
    g_rt_priority[child_slot]  = g_rt_priority[parent_slot]
    if sched_is_realtime(child_slot) != 0:
        _rt_stamp_seq(child_slot)
        if g_sched_policy[child_slot] == SCHED_RR:
            g_rr_slice_left[child_slot] = SCHED_RR_TICKS
        else:
            g_rr_slice_left[child_slot] = 0
    else:
        g_rt_enqueue_seq[child_slot] = 0
        g_rr_slice_left[child_slot]  = 0


# ---------------------------------------------------------------------------
# Per-task resource limits (getrlimit/setrlimit/prlimit64).
#
# A real per-task rlimit store, kept as parallel module-global tables keyed by
# task slot so TaskStruct's hand-maintained byte-offset layout is left
# untouched. RLIM_NLIMITS (16) resources per task, each a {cur, max} pair.
# g_rlim_cur[slot*16 + res] / g_rlim_max[slot*16 + res]. 16 u64 per task =
# 128 bytes/task; at NTASKS(256) -> 32 KiB per table, BSS-resident.
RLIM_NLIMITS:  uint64 = 16
# NTASKS(256) * RLIM_NLIMITS(16) = 4096 u64 per table (Array sizes must be a
# literal). 4096 * 8 = 32 KiB per table; still trivially BSS-resident.
g_rlim_cur:    Array[8192, uint64]
g_rlim_max:    Array[8192, uint64]


def rlimit_init_task(slot: uint64):
    # Seed `slot`'s limits to Linux defaults: everything RLIM_INFINITY, then
    # override STACK/NOFILE/CORE to match a stock x86_64 Linux login.
    if slot >= NTASKS:
        return
    base: uint64 = slot * 16
    r: uint64 = 0
    while r < 16:
        g_rlim_cur[base + r] = 0xFFFFFFFFFFFFFFFF
        g_rlim_max[base + r] = 0xFFFFFFFFFFFFFFFF
        r = r + 1
    # RLIMIT_STACK(3): 768 KiB soft+hard, STRICTLY LESS than the FIXED
    # pre-mapped Linux user stack (LINUX_USTACK_SIZE = 1 MiB in
    # arch/x86/kernel/syscall.ad, decoupled to the high window
    # [VBASE, VBASE+1 MiB); NO demand growsdown).
    #
    # glibc's main-thread startup computes its stack LOW bound as
    # (stacktop - RLIMIT_STACK) and writes a guard probe just below it. With
    # RLIMIT == the mapped size, that low bound lands exactly at the window
    # BOTTOM (VBASE) and the guard probe at VBASE - 0x488 falls BELOW the
    # mapping -> hard SIGSEGV. This is the `wc -l` fault the high-VA decouple
    # exposed: it is ALWAYS at the fixed VBASE-0x488 regardless of the mapped
    # size (it tracks the rlimit-derived bottom, NOT incremental growth), so
    # simply enlarging the window does NOT help while RLIMIT == size.
    #
    # Fix: RLIMIT must be smaller than the mapped size by more than the max
    # ASLR stack slide (64 KiB) so the rlimit-derived bottom + its guard probe
    # stay INSIDE the mapping: stacktop - RLIMIT = (VBASE + 1 MiB - slide) -
    # 768 KiB >= VBASE + 192 KiB, comfortably mapped. 768 KiB is still ample
    # for glibc coreutils. The HARD limit matches so a process can't setrlimit
    # past the real mapping. See the LINUX_USTACK_* comment block.
    g_rlim_cur[base + 3] = 0xC0000
    g_rlim_max[base + 3] = 0xC0000
    # RLIMIT_NOFILE(7): 1024 soft, 4096 hard.
    g_rlim_cur[base + 7] = 1024
    g_rlim_max[base + 7] = 4096
    # RLIMIT_CORE(4): no core dumps soft, infinite hard.
    g_rlim_cur[base + 4] = 0
    g_rlim_max[base + 4] = 0xFFFFFFFFFFFFFFFF


def rlimit_get_cur(slot: uint64, res: uint64) -> uint64:
    if slot >= NTASKS or res >= 16:
        return 0
    return g_rlim_cur[slot * 16 + res]


def rlimit_get_max(slot: uint64, res: uint64) -> uint64:
    if slot >= NTASKS or res >= 16:
        return 0
    return g_rlim_max[slot * 16 + res]


def rlimit_set(slot: uint64, res: uint64, cur: uint64, maxv: uint64):
    if slot >= NTASKS or res >= 16:
        return
    g_rlim_cur[slot * 16 + res] = cur
    g_rlim_max[slot * 16 + res] = maxv


# A real per-task oom_score_adj store, kept as a module-global table keyed by
# task slot (NOT a TaskStruct field, so the hand-maintained byte-offset layout
# stays untouched) — same shape as the rlimit store above. Linux's OOM killer
# biases its victim choice by /proc/<pid>/oom_score_adj (range -1000..1000,
# -1000 = never kill). Here the badness heuristic (mm/reclaim.ad) consults this
# store: an exempt task (-1000) is never selected, and the adj value nudges the
# adjusted RSS score for the rest. NTASKS(256) int32 = 1 KiB, BSS-resident.
OOM_SCORE_ADJ_MIN: int32 = -1000
OOM_SCORE_ADJ_MAX: int32 = 1000
g_oom_score_adj:   Array[512, int32]    # NTASKS-sized


def _oom_sext32(x: int32) -> int64:
    # Sign-extend a 32-bit value to 64-bit. The Adder compiler ZERO-extends
    # `cast[int64](<runtime int32>)` (a function return, array element, or
    # parameter), so a negative oom_score_adj like -1000 would widen to
    # 0x00000000FFFFFC18 instead of 0xFFFFFFFFFFFFFC18 — corrupting every
    # signed comparison (clamp, exempt probe, the selftest's `!=`). Do the
    # widen explicitly: place the 32 bits in the low half, then an ARITHMETIC
    # right shift by 32 replicates bit 31 across the high half. Shifts on
    # int64 are arithmetic, so this yields a correctly sign-extended value
    # regardless of how the front end widens the initial cast.
    w: int64 = cast[int64](cast[uint32](x))
    w = w << 32
    w = w >> 32
    return w


def oom_adj_init_task(slot: uint64):
    # Seed `slot`'s oom_score_adj to the Linux default of 0 (no bias). Called
    # from sched_init_task_weight so a freshly-created OR recycled slot always
    # starts unbiased (covers reap-then-reuse).
    if slot >= NTASKS:
        return
    g_oom_score_adj[slot] = 0


def oom_adj_get(slot: uint64) -> int32:
    if slot >= NTASKS:
        return 0
    return g_oom_score_adj[slot]


def oom_adj_get64(slot: uint64) -> int64:
    # Sign-extended 64-bit view of the per-task oom_score_adj, for callers
    # that fold it into signed 64-bit arithmetic (mm/reclaim.ad's badness
    # score). Bypasses the compiler's zero-extension of cast[int64](<int32>).
    if slot >= NTASKS:
        return 0
    return _oom_sext32(g_oom_score_adj[slot])


def oom_adj_set(slot: uint64, v: int32):
    # Store `v` clamped to [OOM_SCORE_ADJ_MIN, OOM_SCORE_ADJ_MAX], matching
    # the Linux /proc/<pid>/oom_score_adj range. The clamp comparisons are done
    # in SIGNED int64 (sign-extending the int32 arg) — int32 relational ops are
    # not reliably signed, exactly why sched_set_nice clamps in int64 too.
    if slot >= NTASKS:
        return
    vv: int64 = _oom_sext32(v)
    if vv < _oom_sext32(OOM_SCORE_ADJ_MIN):
        vv = _oom_sext32(OOM_SCORE_ADJ_MIN)
    if vv > _oom_sext32(OOM_SCORE_ADJ_MAX):
        vv = _oom_sext32(OOM_SCORE_ADJ_MAX)
    g_oom_score_adj[slot] = cast[int32](vv)


def oom_adj_is_exempt(slot: uint64) -> int32:
    # 1 iff this task is OOM-exempt (oom_score_adj == -1000), else 0. Equality
    # is type-agnostic, but compare in int64 to stay consistent with the rest.
    if slot >= NTASKS:
        return 0
    if _oom_sext32(g_oom_score_adj[slot]) == _oom_sext32(OOM_SCORE_ADJ_MIN):
        return 1
    return 0


def oomadj_selftest() -> int32:
    # Proves the per-task oom_score_adj store + exemption + clamp logic that
    # the OOM badness heuristic (mm/reclaim.ad) consults. Drives the REAL
    # store on the boot task slot, deterministic with only the boot task:
    #   * set -1000  -> get == -1000 AND is_exempt == 1
    #   * set  5000  -> clamp upper to 1000 AND is_exempt == 0
    # Restores 0 afterward. Returns 1 PASS, 0 FAIL. PUBLIC so init/main.ad can
    # call it.
    boot_slot: uint64 = current_idx_get()

    # OOM-exempt: set the floor and assert the store + exemption probe. All
    # readback comparisons widen the int32 via _oom_sext32 because the compiler
    # zero-extends a bare cast[int64](<runtime int32>).
    oom_adj_set(boot_slot, OOM_SCORE_ADJ_MIN)
    if _oom_sext32(oom_adj_get(boot_slot)) != _oom_sext32(OOM_SCORE_ADJ_MIN):
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[OOMADJ] FAIL set -1000 not stored\n")
        oom_adj_set(boot_slot, 0)
        return 0
    if oom_adj_is_exempt(boot_slot) != 1:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[OOMADJ] FAIL -1000 not exempt\n")
        oom_adj_set(boot_slot, 0)
        return 0

    # Out-of-range high value must clamp to OOM_SCORE_ADJ_MAX (1000) and is
    # NOT exempt.
    oom_adj_set(boot_slot, 5000)
    clamp64: int64 = _oom_sext32(oom_adj_get(boot_slot))
    if clamp64 != cast[int64](1000):
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[OOMADJ] FAIL clamp=%d != 1000\n", cast[uint64](clamp64))
        oom_adj_set(boot_slot, 0)
        return 0
    if oom_adj_is_exempt(boot_slot) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[OOMADJ] FAIL clamped value wrongly exempt\n")
        oom_adj_set(boot_slot, 0)
        return 0

    # Restore the unbiased default so later tests aren't perturbed.
    oom_adj_set(boot_slot, 0)

    # clamp64 is asserted == 1000 (positive), so printk's %d-renders-unsigned
    # caveat is harmless here.
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("[OOMADJ] PASS exempt=1 clamp=%d\n", cast[uint64](clamp64))
    return 1


def seccomp_native_selftest() -> int32:
    # F10-8 / #457: NATIVE seccomp-lite end-to-end probe. Drives the
    # REAL per-task native-filter store + the do_syscall-entry probe
    # (seccomp_native_check_entry) WITHOUT actually issuing a syscall —
    # the do_syscall arm is a one-line dispatch into this same probe, so
    # asserting the probe directly is unforgeable. PUBLIC so init/main.ad
    # can call it under the /etc/seccomp-native-test gate.
    #
    # Asserts (all on a spare slot so the boot task's own filter is never
    # armed — irrevocable + would brick the rest of bring-up):
    #   (1) DISARMED: probe returns 0 for every nr (no enforcement).
    #   (2) ARMED + allow-list = {SYS_GETPID(4)}: nr=4 permitted, nr=0
    #       (SYS_PUTC) and nr=8 (SYS_WRITE) BLOCKED; nrs >= 256
    #       implicitly blocked (Plan-9 SYS_RFORK=256 case).
    #   (3) IRREVOCABLE: set_task_seccomp_native_armed(slot, 0) is a
    #       no-op once armed — the filter stays in force.
    # Returns 1 PASS, 0 FAIL.
    #
    # Slot choice: pick a free slot at NTASKS-1 (the boot task lives at
    # 0). create_user_task would drag the buddy allocator / VMA setup;
    # this probe only needs the seccomp_native_* fields, so we poke them
    # directly via the accessors and leave task_is_live untouched.
    probe_slot: uint64 = 255           # NTASKS=256, slot 255 is spare

    # Direct field clear — the slot was scrubbed by sched_init_task_weight
    # on first create, but on a hot re-run (rare) the irrevocable ratchet
    # would refuse to disarm. Drive the raw field so the test is
    # idempotent across reboots and re-runs.
    task_table[probe_slot].seccomp_native_armed = 0
    sni: uint64 = 0
    while sni < 4:
        task_table[probe_slot].seccomp_native_filter[sni] = 0
        sni = sni + 1

    # (1) DISARMED probe.
    if seccomp_native_check_entry(probe_slot, 0) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[SECCOMPN] FAIL disarmed probe blocked\n")
        return 0
    if seccomp_native_check_entry(probe_slot, 4) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[SECCOMPN] FAIL disarmed probe blocked nr=4\n")
        return 0

    # (2) ARMED + allow only SYS_GETPID(4). word=0, bit=1<<4 = 0x10.
    set_task_seccomp_native_filter(probe_slot, 0, 0x10)
    set_task_seccomp_native_armed(probe_slot, 1)
    if seccomp_native_check_entry(probe_slot, 4) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[SECCOMPN] FAIL armed allow-list missed nr=4\n")
        return 0
    if seccomp_native_check_entry(probe_slot, 0) != 1:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[SECCOMPN] FAIL armed did not block nr=0 (SYS_PUTC)\n")
        return 0
    if seccomp_native_check_entry(probe_slot, 8) != 1:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[SECCOMPN] FAIL armed did not block nr=8 (SYS_WRITE)\n")
        return 0
    # nr=256 (SYS_RFORK) is OUT OF RANGE of the bitmap — implicitly
    # denied even if a stray bit were set.
    if seccomp_native_check_entry(probe_slot, 256) != 1:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[SECCOMPN] FAIL armed did not block nr>=256\n")
        return 0

    # (3) IRREVOCABLE: try to disarm via the accessor — must be a no-op.
    set_task_seccomp_native_armed(probe_slot, 0)
    if get_task_seccomp_native_armed(probe_slot) != 1:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[SECCOMPN] FAIL accessor disarmed a live filter\n")
        return 0
    if seccomp_native_check_entry(probe_slot, 0) != 1:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[SECCOMPN] FAIL disarm-attempt let nr=0 through\n")
        return 0

    # Clear the probe slot via direct field writes so a later test re-run
    # (or a real task creation reusing the slot) starts unconfined. The
    # task_create path also scrubs, so this is belt-and-braces.
    task_table[probe_slot].seccomp_native_armed = 0
    snj: uint64 = 0
    while snj < 4:
        task_table[probe_slot].seccomp_native_filter[snj] = 0
        snj = snj + 1

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[SECCOMPN] PASS armed allow-list blocks denied + lets allowed through, irrevocable\n")
    return 1


def rtsched_selftest() -> int32:
    # Deterministic proof of the SCHED_FIFO / SCHED_RR realtime policy
    # mechanism. Drives the REAL sched_set_scheduler / _pick_next /
    # preempt_tick rotation code over fabricated task fixtures in spare
    # slots, with NO real context switch needed.
    #
    # Asserts:
    #   (1) sched_get_priority_max/min == 99/1 for FIFO/RR, 0/0 for OTHER.
    #   (2) A SCHED_FIFO task at priority 50 is ALWAYS picked over a runnable
    #       SCHED_OTHER task (realtime tier outranks CFS-lite).
    #   (3) Two SCHED_RR tasks at equal priority ALTERNATE on timeslice
    #       rotation (the spent task is re-stamped to the level's tail, so
    #       _pick_next flips to its peer).
    #   (4) A FIFO task is NOT preempted by a newly-runnable LOWER-priority
    #       RR task (_pick_next keeps the higher FIFO).
    #
    # Fixtures use two spare FREE slots, marked READY only for the duration
    # of each _pick_next probe and restored to FREE afterward so the live
    # runqueue is left exactly as found. Returns 1 PASS, 0 FAIL. PUBLIC so
    # init/main.ad can call it. The probe runs on the BSP (boot task), where
    # _pick_next treats all READY slots as eligible.

    # --- (1) priority range queries ---
    if sched_priority_max(SCHED_FIFO) != RT_PRIO_MAX:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[rtsched] FAIL priority_max(FIFO) != 99\n")
        return 0
    if sched_priority_min(SCHED_FIFO) != RT_PRIO_MIN:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[rtsched] FAIL priority_min(FIFO) != 1\n")
        return 0
    if sched_priority_max(SCHED_RR) != RT_PRIO_MAX:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[rtsched] FAIL priority_max(RR) != 99\n")
        return 0
    if sched_priority_min(SCHED_RR) != RT_PRIO_MIN:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[rtsched] FAIL priority_min(RR) != 1\n")
        return 0
    if sched_priority_max(SCHED_OTHER) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[rtsched] FAIL priority_max(OTHER) != 0\n")
        return 0
    if sched_priority_min(SCHED_OTHER) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[rtsched] FAIL priority_min(OTHER) != 0\n")
        return 0

    # Find two spare FREE slots for the fixtures.
    sa: int32 = -1
    sb: int32 = -1
    scan: uint64 = 0
    while scan < NTASKS:
        if task_table[scan].state == STATE_FREE:
            if sa < 0:
                sa = cast[int32](scan)
            elif sb < 0:
                sb = cast[int32](scan)
        scan = scan + 1
    if sa < 0 or sb < 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[rtsched] FAIL no two spare slots for fixtures\n")
        return 0
    ua: uint64 = cast[uint64](sa)
    ub: uint64 = cast[uint64](sb)

    # Fabricate both fixtures as BSP-eligible kernel tasks (is_user=0). Save
    # nothing else: these slots are FREE, so we own them for the probe.
    task_table[ua].is_user = 0
    task_table[ub].is_user = 0
    task_table[ua].vruntime = 0
    task_table[ub].vruntime = 0
    # PER-CPU RUNQUEUE (#6): this self-test runs on the BSP and calls
    # _pick_next() directly, which only considers rq_cpu == get_cpu_id() (0).
    # Home both fabricated fixtures on the BSP runqueue so the probe sees them.
    task_table[ua].rq_cpu = 0
    task_table[ub].rq_cpu = 0

    pass_all: int32 = 1

    # --- (2) FIFO@50 always beats a runnable SCHED_OTHER ---
    # sa = SCHED_FIFO prio 50, sb = SCHED_OTHER. Both READY.
    sched_init_task_policy(ua)
    sched_init_task_policy(ub)
    if sched_set_scheduler(ua, SCHED_FIFO, 50) != 1:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[rtsched] FAIL set FIFO 50 rejected\n")
        pass_all = 0
    task_table[ua].state = STATE_READY
    task_table[ub].state = STATE_READY      # sb stays SCHED_OTHER
    # Track 5: _pick_next walks the per-CPU run-list now, so the fabricated
    # fixtures must be LINKED onto CPU0's run-list to be visible to the probe.
    _rq_list_insert(ua, 0)
    _rq_list_insert(ub, 0)
    pick2: int32 = _pick_next()
    if pick2 != sa:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[rtsched] FAIL FIFO not picked over OTHER pick=%d want=%d\n",
                cast[uint64](cast[uint32](pick2)), cast[uint64](cast[uint32](sa)))
        pass_all = 0

    # --- (4) FIFO@50 NOT preempted by a newly-runnable LOWER-priority RR ---
    # Reconfigure sb as SCHED_RR prio 10 (lower than sa's FIFO 50), still READY.
    if sched_set_scheduler(ub, SCHED_RR, 10) != 1:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[rtsched] FAIL set RR 10 rejected\n")
        pass_all = 0
    pick4: int32 = _pick_next()
    if pick4 != sa:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[rtsched] FAIL higher FIFO yielded to lower RR pick=%d want=%d\n",
                cast[uint64](cast[uint32](pick4)), cast[uint64](cast[uint32](sa)))
        pass_all = 0

    # --- (3) Two equal-priority RR tasks alternate on rotation ---
    # Both sa and sb become SCHED_RR prio 30. sa was stamped (set) before sb,
    # so sa has the smaller enqueue sequence and _pick_next prefers sa first.
    sched_init_task_policy(ua)
    sched_init_task_policy(ub)
    if sched_set_scheduler(ua, SCHED_RR, 30) != 1:
        pass_all = 0
    if sched_set_scheduler(ub, SCHED_RR, 30) != 1:
        pass_all = 0
    task_table[ua].state = STATE_READY
    task_table[ub].state = STATE_READY
    _rq_list_insert(ua, 0)
    _rq_list_insert(ub, 0)
    first: int32 = _pick_next()
    if first != sa:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[rtsched] FAIL RR oldest not first pick=%d want=%d\n",
                cast[uint64](cast[uint32](first)), cast[uint64](cast[uint32](sa)))
        pass_all = 0
    # Simulate sa exhausting its RR slice and rotating to the tail: drive the
    # real rotation primitive (re-stamp sequence + re-arm slice), exactly what
    # preempt_tick does when an RR slice drains. After rotation sb (now the
    # smaller sequence) must be picked.
    _rt_stamp_seq(ua)
    g_rr_slice_left[ua] = SCHED_RR_TICKS
    second: int32 = _pick_next()
    if second != sb:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[rtsched] FAIL RR no rotation pick=%d want=%d\n",
                cast[uint64](cast[uint32](second)), cast[uint64](cast[uint32](sb)))
        pass_all = 0
    # Rotate sb too; the turn must come back to sa (genuine alternation).
    _rt_stamp_seq(ub)
    g_rr_slice_left[ub] = SCHED_RR_TICKS
    third: int32 = _pick_next()
    if third != sa:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[rtsched] FAIL RR no alternation back pick=%d want=%d\n",
                cast[uint64](cast[uint32](third)), cast[uint64](cast[uint32](sa)))
        pass_all = 0

    # Tear down the fixtures: reset policy state and return both slots to FREE
    # so the live runqueue is exactly as we found it.
    sched_init_task_policy(ua)
    sched_init_task_policy(ub)
    # Track 5: unlink the fixtures from CPU0's run-list before returning them
    # to FREE so the live dispatcher never walks a torn-down scratch slot.
    _rq_list_remove(ua)
    _rq_list_remove(ub)
    task_table[ua].state = STATE_FREE
    task_table[ub].state = STATE_FREE

    if pass_all == 0:
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[rtsched] PASS FIFO>OTHER, RR-rotate, FIFO!<RR, prio 99/1\n")
    return 1


def sched_init_task_weight(slot: uint64):
    # Seed a freshly-created task's CFS-lite fields. nice 0 / NICE0
    # weight by default; vruntime seeded to the current runqueue minimum
    # so it competes fairly from the moment it becomes READY. cpu_runs
    # cleared so the SMP per-CPU dispatch counter starts at 0.
    task_table[slot].nice         = 0
    task_table[slot].sched_weight = NICE0_WEIGHT
    task_table[slot].vruntime     = sched_min_vruntime()
    # Realtime scheduling policy resets to the SCHED_OTHER default so a
    # recycled slot never inherits a stale FIFO/RR policy.
    sched_init_task_policy(slot)
    c: uint64 = 0
    while c < 16:
        task_table[slot].cpu_runs[c] = 0
        c = c + 1
    # getrusage(2) CPU-time accounting starts clean on a recycled slot.
    task_table[slot].utime_ticks = 0
    task_table[slot].stime_ticks = 0
    # getrusage(2) / proc stat page-fault counters start clean too.
    task_table[slot].minflt = 0
    task_table[slot].majflt = 0
    # getrusage(2) context-switch counters start clean on a recycled slot.
    task_table[slot].nvcsw  = 0
    task_table[slot].nivcsw = 0
    # getrusage(2) block-I/O counters start clean on a recycled slot.
    task_table[slot].inblock = 0
    task_table[slot].oublock = 0
    # getrusage(2) signal-delivery counter starts clean on a recycled slot.
    task_table[slot].nsignals = 0
    # getrusage(2) ru_maxrss high-water starts clean on a recycled slot.
    task_table[slot].maxrss_kb = 0
    # /proc/<pid>/stat field 22 (starttime): capture the creation jiffy.
    # Write-once per (re)created slot; every task's start_jiffies equals the
    # jiffy count at the moment it was created.
    task_table[slot].start_jiffies = get_jiffies()
    # Linux-ABI no-syscall watchdog: seed the last-syscall stamp to "now" so
    # a freshly-created (or recycled) slot doesn't read a stale 0 and trip the
    # watchdog immediately. The do_syscall Linux arm re-stamps on every call.
    task_table[slot].last_syscall_jiffies = get_jiffies()
    task_table[slot].wd_last_dump_jiffies = 0
    # Child-resource accounting (RUSAGE_CHILDREN) starts clean on a recycled
    # slot. Rolled up from reaped children in task_reap.
    task_table[slot].cutime_ticks = 0
    task_table[slot].cstime_ticks = 0
    task_table[slot].cminflt      = 0
    task_table[slot].cmajflt      = 0
    # /proc/<pid>/io rchar/wchar/syscr/syscw start clean on a recycled slot.
    task_table[slot].rchar  = 0
    task_table[slot].wchar  = 0
    task_table[slot].syscr  = 0
    task_table[slot].syscw  = 0
    # Event-driven wait-queue link state starts clean on a recycled slot:
    # not linked onto any queue, no pending signal-wake flag.
    task_table[slot].wait_next     = 0
    task_table[slot].wait_on       = 0
    task_table[slot].wait_signaled = 0
    # setitimer(2) ITIMER_REAL disarmed on a fresh/recycled slot so a new task
    # never inherits a live countdown (belt-and-braces with clear_task_itimer on
    # reap; a create that bypassed reap would still start clean here).
    task_table[slot].itimer_real_ticks  = 0
    task_table[slot].itimer_real_reload = 0
    # Per-CPU rq (#6): a fresh/recycled slot defaults to the BSP runqueue.
    # The real owning CPU is assigned when the task is first made runnable
    # (sched_make_ready / placement). Slot 0 (BSP boot task) stays 0.
    task_table[slot].rq_cpu        = 0
    # sched_setaffinity(2): a fresh/recycled slot may run on EVERY CPU. The
    # task constrains itself by calling setaffinity; until then it is fully
    # unpinned, so the existing placement / steal behaviour is unchanged.
    task_table[slot].cpu_affinity  = AFFINITY_ALL
    # #443: no native exit-notification semaphore registered on a fresh /
    # recycled slot — a stale address here would make an unrelated task's
    # exit scribble an increment into a random user word.
    task_table[slot].exit_sem      = 0
    # getrlimit/setrlimit/prlimit64: seed this slot's per-task resource limits
    # to Linux defaults (8 MiB stack, 1024 nofile, infinite else).
    rlimit_init_task(slot)
    # oom_score_adj: seed this slot's OOM-killer bias to the unbiased default
    # (0) so a freshly-allocated or recycled slot never inherits a stale value.
    oom_adj_init_task(slot)


def sched_set_nice(slot: uint64, n: int64):
    # Apply a new nice value to `slot` and recompute its weight. Used by
    # the SYS_NICE / setpriority path. vruntime is left untouched — a
    # re-nice changes the FUTURE accrual rate, not the accumulated past,
    # exactly like Linux's set_load_weight on a runnable task.
    nn: int64 = n
    if nn < NICE_MIN:
        nn = NICE_MIN
    if nn > NICE_MAX:
        nn = NICE_MAX
    task_table[slot].nice         = nn
    task_table[slot].sched_weight = sched_weight_for_nice(nn)


def sched_get_nice(slot: uint64) -> int64:
    return task_table[slot].nice


# --- sched_setaffinity(2) / sched_getaffinity(2): per-task CPU pinning ---
#
# The scheduler HONORS the per-task cpu_affinity bitmask everywhere a task
# could be placed on or migrated to a CPU:
#   * sched_affinity_pick_cpu() — placement (sched_pick_target_cpu) only
#     ever returns a CPU whose bit is set.
#   * _sched_try_pull_locked() — work-steal refuses to pull a task onto a
#     CPU its mask forbids.
#   * schedule() — when a preempted task is put back STATE_READY, if the CPU
#     it ran on is no longer in its mask it is re-homed to an allowed CPU
#     (the deferred-migration case for a task that was running elsewhere when
#     setaffinity excluded that CPU; mirrors Linux deferring the migrate to
#     the next schedule point rather than yanking a live task off-core).

def sched_get_affinity(slot: uint64) -> uint64:
    # Return the stored CPU-affinity bitmask for `slot`. getaffinity reads
    # this back verbatim.
    return task_table[slot].cpu_affinity


def sched_get_affinity_online(slot: uint64) -> uint64:
    # Return the EFFECTIVE affinity mask for `slot`: the stored per-task mask
    # intersected with the set of currently-online CPUs. This mirrors Linux's
    # sched_getaffinity(2), which returns `p->cpus_mask & cpu_active_mask`
    # (never CPUs that aren't online). A fresh task defaults to AFFINITY_ALL,
    # so without this intersection getaffinity would report bits for offline
    # CPUs (e.g. reporting 0xFF under -smp 1 instead of just bit 0).
    nonline: uint64 = get_cpus_online()
    online_mask: uint64 = 0
    c: uint64 = 0
    while c < nonline and c < 64:
        online_mask = online_mask | (cast[uint64](1) << c)
        c = c + 1
    return task_table[slot].cpu_affinity & online_mask


def sched_cpu_allowed(slot: uint64, cpu: uint64) -> uint64:
    # 1 if `slot` may run on logical CPU `cpu` (its affinity bit is set),
    # else 0. CPUs >= 64 are never allowed (mask is one word).
    if cpu >= 64:
        return 0
    if (task_table[slot].cpu_affinity & (cast[uint64](1) << cpu)) != 0:
        return 1
    return 0


def sched_affinity_pick_cpu(slot: uint64, preferred: uint64) -> uint64:
    # Resolve `preferred` against `slot`'s affinity mask, returning a CPU the
    # task is ALLOWED to run on. If `preferred` is already allowed it is kept
    # (so the placement heuristic's load-balancing choice is honored); else we
    # return the LOWEST-indexed online, allowed CPU. Falls back to CPU 0 if
    # the mask somehow excludes every online CPU (an empty/over-restrictive
    # mask is rejected at the syscall boundary, so this is belt-and-braces).
    if sched_cpu_allowed(slot, preferred) != 0:
        return preferred
    nonline: uint64 = get_cpus_online()
    c: uint64 = 0
    while c < nonline and c < NR_RQ:
        if sched_cpu_allowed(slot, c) != 0:
            return c
        c = c + 1
    return 0


def sched_set_affinity(slot: uint64, mask: uint64) -> int64:
    # Apply a new CPU-affinity mask to `slot`. The mask is first narrowed to
    # the set of ONLINE CPUs (Linux masks the user request against
    # cpu_online_mask); if no online CPU survives the intersection the call
    # is -EINVAL and the stored mask is left unchanged. On success the new
    # mask is stored and, if the task is currently STATE_READY on a CPU its
    # new mask forbids, it is immediately re-homed (under the rq locks) to an
    # allowed CPU so the next _pick_next there dispatches it. A task that is
    # currently RUNNING on a now-forbidden CPU is left to be re-homed at its
    # next schedule() (see the prev->READY re-home there) — the Linux deferred
    # migration shape. Returns 0 on success, -EINVAL on an empty effective
    # mask.
    nonline: uint64 = get_cpus_online()
    online_mask: uint64 = 0
    c: uint64 = 0
    while c < nonline and c < 64:
        online_mask = online_mask | (cast[uint64](1) << c)
        c = c + 1
    eff: uint64 = mask & online_mask
    if eff == 0:
        return SCHED_AFFINITY_EINVAL
    task_table[slot].cpu_affinity = eff
    # If the task is runnable (STATE_READY) on a CPU its new mask forbids,
    # migrate it now: re-stamp rq_cpu (under both old+new rq locks) to an
    # allowed CPU and kick that CPU so it dispatches the task.
    if task_table[slot].state == STATE_READY:
        cur_cpu: uint64 = task_table[slot].rq_cpu
        if sched_cpu_allowed(slot, cur_cpu) == 0:
            dest: uint64 = sched_affinity_pick_cpu(slot, cur_cpu)
            if slot == 0:
                dest = 0
            # Acquire both rq locks in ascending-index order to avoid an
            # ABBA deadlock with a concurrent steal.
            lo: uint64 = cur_cpu
            hi: uint64 = dest
            if lo > hi:
                lo = dest
                hi = cur_cpu
            _rq_lock_cpu(lo)
            if hi != lo:
                _rq_lock_cpu(hi)
            task_table[slot].rq_cpu = dest
            if hi != lo:
                _rq_unlock_cpu(hi)
            _rq_unlock_cpu(lo)
            smp_send_reschedule_cpu(dest)
    return 0


SCHED_AFFINITY_EINVAL: int64 = -22       # -EINVAL


def sched_inherit_nice_to_child(child_slot: uint64, parent_slot: uint64):
    # fork/clone child inherits the parent's nice + weight (POSIX:
    # niceness is inherited). vruntime is re-seeded to the current
    # minimum rather than copied, so a forking parent can't hand its
    # child an unfairly-low (or already-large) vruntime.
    task_table[child_slot].nice         = task_table[parent_slot].nice
    task_table[child_slot].sched_weight = task_table[parent_slot].sched_weight
    task_table[child_slot].vruntime     = sched_min_vruntime()
    # POSIX: a child inherits the parent's scheduling policy + rt priority.
    sched_inherit_policy_to_child(child_slot, parent_slot)
    # POSIX/Linux: a child inherits the parent's CPU-affinity mask across
    # fork/clone (sched_setaffinity affects the calling thread's descendants).
    task_table[child_slot].cpu_affinity = task_table[parent_slot].cpu_affinity


def sched_note_dispatch(slot: uint64):
    # Record that `slot` was just dispatched onto the current CPU. Bumps
    # the per-CPU run counter used by the SMP load-balance test to prove
    # a task ran on more than one core. Cheap; called from both the BSP
    # schedule() path and the AP idle-loop dispatch.
    cid: uint64 = get_cpu_id()
    if cid < 16:
        task_table[slot].cpu_runs[cid] = task_table[slot].cpu_runs[cid] + 1
    # QA-N32b: timestamp this dispatch so _sched_try_pull_locked can apply
    # steal hysteresis (don't yank a just-run task onto another CPU).
    task_table[slot].last_dispatch_jiffy = get_jiffies()


def sched_cpu_runs(slot: uint64, cpu: uint64) -> uint64:
    if cpu >= 16:
        return 0
    return task_table[slot].cpu_runs[cpu]


def task_rq_cpu(slot: uint64) -> uint64:
    # Read which CPU's runqueue currently OWNS `slot`. Used by the
    # sched_setaffinity self-test to assert a pinned/migrated task landed on
    # the allowed CPU (the test controls scheduler internals so it asserts via
    # this field directly, per the test plan).
    return task_table[slot].rq_cpu


# --- sched_setaffinity(2) kernel self-test (mirrors statx_getrandom_selftest) ---
#
# Drives the REAL affinity store + enforcement on a SCRATCH task slot (the
# last STATE_FREE slot) so it never perturbs a live runnable task. Asserts:
#   (a) a single-CPU mask round-trips through set/get;
#   (b) the scheduler HONORS the pin — sched_affinity_pick_cpu / placement
#       never returns a forbidden CPU, and a READY task sitting on a now-
#       forbidden CPU is migrated (rq_cpu re-homed) by sched_set_affinity;
#   (c) on an SMP boot a task pinned to CPU1 is enqueued on CPU1's runqueue;
#       on a uniprocessor boot pinning to the only CPU is a no-op success and
#       the migration-marking logic is still asserted on the data structures.
# Returns 1 on PASS, 0 on FAIL. Callers (linux_abi) print the markers.

def _sched_aff_test_scratch_slot() -> int64:
    # Find a STATE_FREE slot from the TOP down so we never collide with the
    # low slots the live boot/init tasks occupy. Returns -1 if none free.
    i: int64 = cast[int64](NTASKS) - 1
    while i >= 1:
        if task_table[cast[uint64](i)].state == STATE_FREE:
            return i
        i = i - 1
    return -1


def sched_affinity_selftest() -> int32:
    s64: int64 = _sched_aff_test_scratch_slot()
    if s64 < 0:
        return 0
    s: uint64 = cast[uint64](s64)
    nonline: uint64 = get_cpus_online()

    # Seed the scratch slot's affinity to the default (all CPUs) and a known
    # rq_cpu, WITHOUT making it runnable (state stays STATE_FREE for the
    # round-trip checks so the dispatcher never touches it).
    task_table[s].cpu_affinity = AFFINITY_ALL
    task_table[s].rq_cpu       = 0

    # (a) single-CPU mask round-trips. Pin to CPU0 (always online).
    if sched_set_affinity(s, 1) < 0:
        return 0
    if sched_get_affinity(s) != 1:
        return 0
    if sched_cpu_allowed(s, 0) == 0:
        return 0

    # (b) the pick honors the pin: even asking for a different "preferred"
    # CPU must come back as the only allowed CPU (0).
    if sched_affinity_pick_cpu(s, 3) != 0:
        return 0
    # An empty effective mask (no online CPU) is rejected, mask unchanged.
    if sched_set_affinity(s, 0) >= 0:
        return 0
    if sched_get_affinity(s) != 1:
        return 0

    # (c) migration-marking on the data structures: place the scratch slot
    # STATE_READY owned by CPU0 with an all-CPU mask, then setaffinity to a
    # mask that EXCLUDES CPU0. sched_set_affinity must re-home rq_cpu to an
    # allowed CPU. We must restore it to STATE_FREE afterwards so the
    # dispatcher never sees this synthetic slot.
    if nonline > 1:
        # SMP: pin to CPU1 and assert the scheduler homes it on CPU1's
        # runqueue. We deliberately keep the synthetic scratch slot STATE_FREE
        # (it has no real kstack/pt_regs, so a concurrent AP _pick_next must
        # NEVER select it) and exercise the migration via the dedicated
        # test-migrate helper, which runs the SAME rq_cpu re-home code path
        # sched_set_affinity uses for a runnable task — just without flipping
        # the slot to STATE_READY. Placement is then asserted through the real
        # sched_pick_target_cpu (which only ever returns an allowed CPU).
        cpu1_mask: uint64 = cast[uint64](1) << 1          # bit1 = CPU1 only
        # Store the pin (effective-mask narrowing + EINVAL check are real).
        if sched_set_affinity(s, cpu1_mask) < 0:
            return 0
        if sched_get_affinity(s) != cpu1_mask:
            return 0
        # Now sitting (logically) on CPU0, which the new mask forbids: the
        # migration helper must re-home rq_cpu to CPU1.
        task_table[s].rq_cpu = 0
        sched_affinity_test_migrate(s)
        if task_rq_cpu(s) != 1:
            return 0
        # And a fresh placement of a CPU1-pinned task picks CPU1.
        if sched_pick_target_cpu_for_test(s) != 1:
            return 0
    else:
        # Uniprocessor: pinning to the only CPU (0) is a no-op success; the
        # task stays on CPU0 and is not migrated.
        task_table[s].cpu_affinity = 1
        task_table[s].rq_cpu       = 0
        task_table[s].state        = STATE_READY
        moved1: uint64 = task_rq_cpu(s)
        # Now assert the migration LOGIC itself on the data structures: hand
        # the slot an rq_cpu of 0 but a mask that forbids 0 (CPU1 bit), and
        # call the re-home helper sched_affinity_pick_cpu directly — with only
        # CPU0 online it must fall back to CPU0 (the only online+... well,
        # CPU1 isn't online, so the helper returns 0). This proves the helper
        # never returns a forbidden-AND-offline CPU. We then verify that the
        # STATE_READY re-home path leaves a single-CPU-pinned task put.
        task_table[s].state = STATE_FREE
        if moved1 != 0:
            return 0
        # Migration-marking unit check: forbid CPU0 in the mask field directly
        # and confirm sched_cpu_allowed reports it forbidden, and the picker
        # falls back to CPU0 (only online CPU) rather than a bogus core.
        task_table[s].cpu_affinity = cast[uint64](1) << 1   # CPU1 only (offline)
        if sched_cpu_allowed(s, 0) != 0:
            return 0
        if sched_affinity_pick_cpu(s, 0) != 0:
            return 0

    # Restore the scratch slot to a pristine FREE state.
    task_table[s].cpu_affinity = AFFINITY_ALL
    task_table[s].rq_cpu       = 0
    task_table[s].state        = STATE_FREE
    return 1


def sched_pick_target_cpu_for_test(slot: uint64) -> uint64:
    # Thin wrapper so the self-test can exercise the placement policy
    # (sched_pick_target_cpu honors the affinity mask). Kept separate so the
    # test's intent reads clearly; identical behaviour to the real placement.
    return sched_pick_target_cpu(slot)


def sched_affinity_test_migrate(slot: uint64):
    # Test-only: run the SAME rq_cpu re-home that sched_set_affinity performs
    # for a runnable task whose current CPU its mask now forbids — but WITHOUT
    # flipping the slot to STATE_READY, so the self-test can assert the
    # migration target on a synthetic STATE_FREE scratch slot the dispatcher
    # never touches. If the slot's current rq_cpu is already allowed this is a
    # no-op (mirroring sched_set_affinity's guard).
    cur_cpu: uint64 = task_table[slot].rq_cpu
    if sched_cpu_allowed(slot, cur_cpu) != 0:
        return
    dest: uint64 = sched_affinity_pick_cpu(slot, cur_cpu)
    task_table[slot].rq_cpu = dest


# Phase C / M16.98: monotonic id allocator for the Plan 9 rfork
# note-group handle. Each call to alloc_note_group_id hands back the
# next int32 and increments. There is no recycling — at NTASKS=256 the
# address space is effectively unbounded relative to live tasks. The
# starting value (1) reserves 0 for "default note group", which is
# the state every freshly-created task is in until rfork(RFNOTEG)
# decides otherwise.
#
# V2.5 dropped `next_namespace_id` / `alloc_namespace_id`: pgrp_idx
# became a pool index produced by `pgrp_alloc` in chan.ad. V2.75
# lifts that further to a real heap pointer (uint64) — the field is
# now spelled `pgrp` and holds a kmalloc'd Pgrp address. The
# namespace allocator and the note-group allocator had identical V2
# shape; only the namespace half got the
# Plan 9-style pool-of-Pgrps lift in V2.5.
next_note_group:   int32 = 1


# --- internal: stack-image builder shared by kernel and user paths --

def _build_initial_kstack(kstack_top: uint64, iret_cs: uint64,
                          iret_ss: uint64, iret_rsp: uint64,
                          iret_rip: uint64,
                          iret_rdi: uint64,
                          iret_rsi: uint64,
                          iret_r9: uint64,
                          iret_rdx: uint64,
                          iret_r8: uint64) -> uint64:
    # Plant the same layout every task ends up with after one round
    # of preemption: iret frame + vec/ec + 9 caller-saved + ret to
    # kthread_bootstrap + 6 callee-saved. After __switch_to_asm pops
    # the 6 and rets, control lands in kthread_bootstrap which
    # iretq's into iret_rip with iret_cs / iret_rsp / iret_ss /
    # RFLAGS = RFLAGS_INITIAL. iret_rdi / iret_rsi are written into
    # the rdi / rsi slots so SYS_SPAWN children land in _start with
    # argc / argv already in the right SysV registers.
    #
    # U27: iret_r9 is the value to plant in the user's %r9 register.
    # For SYS_SPAWN and kthread bootstrap callers this stays 0 — they
    # don't propagate any caller-side r9. For the CLONE_THREAD path
    # the value is the parent's user %r9 at syscall entry, because
    # musl's __clone wrapper saves the worker function in %r9 and the
    # child uses `call *%r9` after the syscall returns. Without this,
    # the child immediately jumps to NULL.
    #
    # U28: iret_rdx / iret_r8 likewise carry the parent's user %rdx
    # and %r8 across the CLONE_THREAD path. glibc's clone3 wrapper
    # (clone3.S) keeps the worker function in %rdx and stashes the
    # argument in %r8 across the `syscall`, and its child-side code
    # does `mov %r8,%rdi; call *%rdx`. Without these the glibc thread
    # jumps through a zeroed %rdx. SYS_SPAWN / kthread callers pass 0.
    sp: uint64 = kstack_top

    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = iret_ss
    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = iret_rsp
    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = RFLAGS_INITIAL
    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = iret_cs
    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = iret_rip

    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = 0                  # error code
    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = 0                  # vector

    # 9 caller-saved popped by kthread_bootstrap in this order
    # (lowest stack address popped first): r11, r10, r9, r8, rdi,
    # rsi, rdx, rcx, rax. We push from high to low here so the
    # in-memory order matches the pop order.
    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = 0                  # rax
    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = 0                  # rcx
    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = iret_rdx           # rdx
    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = iret_rsi           # rsi
    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = iret_rdi           # rdi
    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = iret_r8            # r8
    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = iret_r9            # r9
    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = 0                  # r10
    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = 0                  # r11

    # return-address from __switch_to_asm: lands in kthread_bootstrap
    sp = sp - 8
    cast[Ptr[uint64]](sp)[0] = cast[uint64](&kthread_bootstrap)

    # 6 callee-saved (r15..rbp), all zero
    i: uint64 = 0
    while i < 6:
        sp = sp - 8
        cast[Ptr[uint64]](sp)[0] = 0
        i = i + 1

    return sp


# --- public: slot management ---------------------------------------

# =====================================================================
# Track 5 helpers: O(1) freelist, pid->slot hash, per-CPU run-lists
# =====================================================================

def _free_list_init():
    # Build the FREE-slot freelist over every slot EXCEPT slot 0 (the boot
    # task, claimed for life). Idempotent. Slots are pushed in descending
    # order so the head ends up being slot 1 — matching the historical
    # behaviour where _find_free_slot returned the LOWEST free slot first,
    # which several callers (and tests reading /proc by ascending pid)
    # implicitly relied on.
    fl: uint64 = local_irq_save()
    spinlock_lock(&freelist_lock)
    _free_list_init_locked()
    spinlock_unlock(&freelist_lock)
    local_irq_restore(fl)


def _free_list_init_locked():
    # Unlocked freelist build — caller holds freelist_lock (or runs
    # single-threaded at sched_init). Slots pushed in descending order so the
    # head ends up being slot 1 (lowest-first alloc, which /proc-by-pid tests
    # rely on). Slot 0 (boot task) is never on the list.
    if free_inited != 0:
        return
    free_inited = 1
    free_head = FL_NIL
    s: uint64 = NTASKS
    while s > 1:
        s = s - 1
        fl_next[s] = free_head
        free_head = s


def _free_list_push(slot: uint64):
    # Return `slot` to the freelist. Slot 0 is never freed (boot task).
    # PARKED idle-kthread slots are also never pushed here (they are not
    # reaped). Guarded against double-push by the caller's state machine
    # (a slot is pushed exactly once, on its FREE transition).
    # SMP: serialise against concurrent pop/push (see freelist_lock).
    if slot == 0 or slot >= NTASKS:
        return
    fl: uint64 = local_irq_save()
    spinlock_lock(&freelist_lock)
    fl_next[slot] = free_head
    free_head = slot
    spinlock_unlock(&freelist_lock)
    local_irq_restore(fl)


def _free_list_pop() -> int32:
    # Pop the head free slot, or -1 if none. O(1).
    # SMP: serialise against concurrent pop/push (see freelist_lock).
    fl: uint64 = local_irq_save()
    spinlock_lock(&freelist_lock)
    if free_inited == 0:
        _free_list_init_locked()
    if free_head == FL_NIL:
        spinlock_unlock(&freelist_lock)
        local_irq_restore(fl)
        return -1
    s: uint64 = free_head
    free_head = fl_next[s]
    fl_next[s] = FL_NIL
    spinlock_unlock(&freelist_lock)
    local_irq_restore(fl)
    return cast[int32](s)


# --- pid -> slot hash ------------------------------------------------

def _pidh_init():
    if pidh_inited != 0:
        return
    pidh_inited = 1
    i: uint64 = 0
    while i < PIDH_SIZE:
        pidh_pid[i]  = PIDH_EMPTY
        pidh_slot[i] = 0
        i = i + 1


def _pidh_insert(pid: uint64, slot: uint64):
    # Insert (pid -> slot). Linear-probe over the first vacant-or-tombstone
    # bucket. If `pid` is already present (a re-stamp of the same pid, or a
    # pid wrap-around onto a stale tombstone) the existing bucket is updated.
    # pid 0 is never inserted (it is PIDH_EMPTY). Load factor stays <= 0.5,
    # so a free bucket always exists.
    if pid == 0:
        return
    _pidh_init()
    h: uint64 = (pid * 2654435761) % PIDH_SIZE
    probes: uint64 = 0
    first_free: uint64 = PIDH_SIZE          # remember a tombstone to reuse
    while probes < PIDH_SIZE:
        b: uint64 = (h + probes) % PIDH_SIZE
        bp: uint64 = pidh_pid[b]
        if bp == pid:
            pidh_slot[b] = slot              # update in place
            return
        if bp == PIDH_EMPTY:
            # End of probe chain: insert here, or at an earlier tombstone.
            if first_free != PIDH_SIZE:
                pidh_pid[first_free]  = pid
                pidh_slot[first_free] = slot
            else:
                pidh_pid[b]  = pid
                pidh_slot[b] = slot
            return
        if bp == PIDH_DELE and first_free == PIDH_SIZE:
            first_free = b
        probes = probes + 1
    # Table full (should never happen at load <= 0.5): fall back to the
    # tombstone slot if we found one. A miss here is non-fatal — lookup
    # has a linear fallback.
    if first_free != PIDH_SIZE:
        pidh_pid[first_free]  = pid
        pidh_slot[first_free] = slot


def _pidh_remove(pid: uint64):
    # Tombstone the bucket holding `pid` so probe chains past it survive.
    if pid == 0 or pidh_inited == 0:
        return
    h: uint64 = (pid * 2654435761) % PIDH_SIZE
    probes: uint64 = 0
    while probes < PIDH_SIZE:
        b: uint64 = (h + probes) % PIDH_SIZE
        bp: uint64 = pidh_pid[b]
        if bp == pid:
            pidh_pid[b]  = PIDH_DELE
            pidh_slot[b] = 0
            return
        if bp == PIDH_EMPTY:
            return                            # not present
        probes = probes + 1


def _pidh_get(pid: uint64) -> int32:
    # Return the slot for `pid`, or -1 on miss. O(1) amortised.
    if pid == 0 or pidh_inited == 0:
        return -1
    h: uint64 = (pid * 2654435761) % PIDH_SIZE
    probes: uint64 = 0
    while probes < PIDH_SIZE:
        b: uint64 = (h + probes) % PIDH_SIZE
        bp: uint64 = pidh_pid[b]
        if bp == pid:
            return cast[int32](pidh_slot[b])
        if bp == PIDH_EMPTY:
            return -1                         # end of chain, not present
        probes = probes + 1
    return -1


# _task_set_pid / _task_clear_pid: the single chokepoints that keep the pid
# hash in sync with the task_table[].pid field. Every site that stamps a
# slot's pid goes through _task_set_pid; every FREE transition goes through
# _task_clear_pid first.
def _task_set_pid(slot: uint64, pid: uint64):
    task_table[slot].pid = pid
    _pidh_insert(pid, slot)


def _task_clear_pid(slot: uint64):
    old: uint64 = task_table[slot].pid
    if old != 0:
        _pidh_remove(old)


# --- per-CPU READY run-lists ----------------------------------------

def _rq_list_init():
    if rq_inited != 0:
        return
    rq_inited = 1
    c: uint64 = 0
    while c < NR_RQ:
        rq_head[c] = RQL_NIL
        c = c + 1


def _rq_list_insert(slot: uint64, cpu: uint64):
    # Link `slot` at the HEAD of CPU `cpu`'s READY run-list. Caller holds
    # rq_locks[cpu]. Idempotent: a slot already on a list is removed from it
    # first (defensive — the state machine normally inserts a FREE/RUNNING/
    # WAIT task exactly once on its READY transition). cpu is clamped to a
    # valid index by the caller (sched_make_ready_on forces tc < NR_RQ).
    if rq_inited == 0:
        _rq_list_init()
    if cpu >= NR_RQ:
        return
    # Defensive: if already linked (possibly on a DIFFERENT cpu), unlink from
    # the list it is ACTUALLY on first. _rq_list_remove derives that list from
    # rq_on_list (= listed_cpu + 1), NOT from rq_cpu, so a re-home that already
    # changed rq_cpu still unlinks the correct head.
    if task_table[slot].rq_on_list != 0:
        _rq_list_remove(slot)
    nh: uint64 = rq_head[cpu]
    task_table[slot].rq_prev = RQL_NIL
    task_table[slot].rq_next = nh
    if nh != RQL_NIL:
        task_table[nh].rq_prev = slot
    rq_head[cpu] = slot
    # rq_on_list encodes (listed_cpu + 1) so _rq_list_remove can fix the right
    # head independent of rq_cpu (which may be re-stamped between insert and
    # remove during affinity migration / work-steal).
    task_table[slot].rq_on_list = cpu + 1


def _rq_list_remove(slot: uint64):
    # Unlink `slot` from whatever run-list it is on. Caller holds the rq lock
    # of the CPU that OWNS the list (the cpu encoded in rq_on_list). No-op if
    # not currently linked.
    if task_table[slot].rq_on_list == 0:
        return
    listed_cpu: uint64 = task_table[slot].rq_on_list - 1
    pv: uint64 = task_table[slot].rq_prev
    nx: uint64 = task_table[slot].rq_next
    if pv != RQL_NIL:
        task_table[pv].rq_next = nx
    else:
        # slot was the head of listed_cpu's list.
        if listed_cpu < NR_RQ:
            rq_head[listed_cpu] = nx
    if nx != RQL_NIL:
        task_table[nx].rq_prev = pv
    task_table[slot].rq_next = RQL_NIL
    task_table[slot].rq_prev = RQL_NIL
    task_table[slot].rq_on_list = 0


def _find_free_slot() -> int32:
    # Track 5: O(1) pop off the freelist (was an O(NTASKS) linear scan for a
    # STATE_FREE slot). Returns the lowest-built free slot or -1 if exhausted.
    return _free_list_pop()


def sched_mark_boot_task_running():
    # Mark slot 0 — the live boot/init task we are executing on RIGHT
    # NOW — as STATE_RUNNING. Called EARLY from start_kernel (right
    # after trap_init), well before sched_init() and before any loaded
    # .ko can spawn a kthread.
    #
    # WHY EARLY: schedule() halts the box when the current task is
    # neither RUNNING nor READY and no peer is runnable. The boot task
    # ran with state STATE_FREE (the .bss zero) for the whole pre-
    # sched_init() phase — which is fine ONLY as long as it never
    # yields. But stock Linux .ko probes that run during boot:35.M
    # modprobe (snd_hda_intel's azx controller reset) hit cooperative
    # yield points (usleep_range_state -> kernel_cond_resched). If an
    # earlier .ko (e1000e) left a kthread slot STATE_READY, that yield
    # rotates away, the peer later exits, and the next yield finds
    # _pick_next == -1 with slot 0 still STATE_FREE -> "no live tasks;
    # halting". Marking the boot task RUNNING up front makes schedule()
    # correctly return-to-self. _find_free_slot skips non-FREE slots,
    # so the first kthread_create still lands on slot 1.
    current_idx_pcpu = 0
    task_table[0].state = STATE_RUNNING


def sched_init():
    next_pid    = 1
    current_idx_pcpu = 0
    # Track 5: initialise the O(1) acceleration structures BEFORE the boot
    # task is published and before any kthread_create can pop a free slot.
    #   • run-list heads -> all empty (RQL_NIL)
    #   • pid->slot hash -> all empty
    #   • FREE-slot freelist -> every slot 1..NTASKS-1 (slot 0 reserved for
    #     the boot task, claimed for life and never on the freelist)
    _rq_list_init()
    _pidh_init()
    _free_list_init()
    # RCU: register schedule() as the yield hook so synchronize_rcu /
    # rcu_barrier can cede the CPU between GP pumps, letting peer CPUs reach a
    # context-switch quiescent state. (rcu.ad cannot call schedule() directly —
    # it would duplicate the public symbol at whole-program merge.)
    rcu_set_yield_hook(cast[uint64](schedule))
    # All slots already zero by .bss init -> state = STATE_FREE.
    # Re-assert the boot task as RUNNING (idempotent with the early
    # sched_mark_boot_task_running() call) so the create_user_task path
    # below always sees a live current task.
    task_table[0].state = STATE_RUNNING
    # CR3 for the boot task (slot 0) must be the live BSP PML4 so that
    # schedule()'s load_cr3 guard (task_table[nxt].cr3 != task_table[prev].cr3)
    # correctly skips the CR3 reload when switching back to slot 0 from a
    # kthread (which also uses the BSP CR3). Without this, slot 0's cr3=0
    # triggers load_cr3(0) → invalid PML4 → triple fault on the first
    # context-switch back to the boot task (e.g. from a soak kthread exit).
    task_table[0].cr3 = get_bsp_cr3()
    # #151: ensure the weight table is materialised and seed the boot
    # task (slot 0) at nice 0 / NICE0 weight / vruntime 0. It was running
    # with .bss-zero scheduler fields (sched_weight 0) before this; a zero
    # weight would divide-by-zero in preempt_tick's vruntime advance.
    _sched_fill_weight_table()
    sched_init_task_weight(0)


# --- public: task construction ------------------------------------

def kthread_create(entry: uint64, name0: uint64) -> int32:
    # Create a CPL=0 kernel thread. Returns the new task's slot index,
    # or -1 on OOM. The first __switch_to into the new task pops 6
    # zeroed callee-saved, rets to kthread_bootstrap, iretq's into
    # `entry` with CS = kernel CS, SS = kernel DS, RFLAGS = 0x202.
    slot: int32 = _find_free_slot()
    if slot < 0:
        printk0("kthread_create: no free task slot\n")
        return -1
    kstack: uint64 = memblock_alloc(KSTACK_SIZE, 16)
    if kstack == 0:
        return -1
    cast[Ptr[uint64]](kstack)[0] = KSTACK_CANARY    # overflow detector (#438)
    kstack_top: uint64 = kstack + KSTACK_SIZE

    sp: uint64 = _build_initial_kstack(
        kstack_top, SCHED_KERNEL_CS, 0x10, kstack_top, entry,
        0, 0, 0, 0, 0,
    )

    s: uint64 = cast[uint64](slot)
    task_table[s].sp          = sp
    _task_set_pid(s, next_pid)        # Track 5: stamp pid + pid->slot hash
    # Job control: a fresh task leads its own process group (job_pgid ==
    # pid) until SYS_SETPGID moves it. SYS_SPAWN's child-pgid plumbing
    # overrides this right after create returns when the shell asked for
    # a backgrounded pipeline in a new group.
    task_table[s].job_pgid    = next_pid
    task_table[s].stop_sig    = 0
    task_table[s].cont_pending = 0
    task_table[s].kstack_base = kstack
    task_table[s].kstack_top  = kstack_top
    task_table[s].ustack_base = 0
    # SMP steal-window: a freshly-built task is NOT mid-switch, so it must
    # start with on_cpu=0 (a recycled STATE_FREE slot may hold a stale 1).
    task_table[s].on_cpu      = 0
    # RACE FIX (mirrors create_user_thread): do NOT publish the slot as
    # STATE_READY until cr3 + all fd/signal fields are initialized at the
    # end of the function. The slot stays STATE_FREE (invisible to
    # _pick_next) during init so a timer IRQ can't dispatch a half-built
    # kernel thread.
    task_table[s].is_user     = 0
    task_table[s].name0       = name0
    # Kernel threads share the BSP's page table (no per-task mappings
    # for them yet — and they don't need user pages anyway).
    task_table[s].cr3         = get_bsp_cr3()
    # U1: kernel threads never speak Linux ABI; flag explicitly so a
    # stale .bss value (already zero, but be defensive after reap +
    # re-claim) can't route a kthread through the linux dispatch.
    task_table[s].is_linux_userspace = 0
    # U31: same scrub as create_user_thread. Kernel threads never raise
    # signals via the user path, but a stale value in sig_handlers
    # would still confuse any future audit of /proc/<pid>/comm.
    ksi: uint64 = 0
    while ksi < 64:
        task_table[s].sig_handlers[ksi] = 0
        ksi = ksi + 1
    kci: uint64 = 0
    while kci < 16:
        task_table[s].comm[kci] = 0
        kci = kci + 1
    task_table[s].pdeathsig = 0
    # U37: zero the alt-stack triple. Same defensive scrub as the
    # sig_handlers / comm fields above — a recycled slot must not
    # inherit the previous tenant's sigaltstack(2) view.
    task_table[s].alt_stack_sp    = 0
    task_table[s].alt_stack_size  = 0
    task_table[s].alt_stack_flags = 0
    # §3: Linux-ABI signal state. Kernel threads never run the user
    # signal-delivery path, but scrub so a recycled slot can't carry a
    # prior user tenant's pending bits / blocked mask forward.
    task_table[s].sig_pending    = 0
    task_table[s].sig_mask       = 0
    task_table[s].sig_saved_mask = 0
    task_table[s].sig_in_handler = 0
    task_table[s].term_sig       = 0
    task_table[s].sig_frame_uctx = 0
    ksfi: uint64 = 0
    while ksfi < 64:
        task_table[s].sig_flags[ksfi] = 0
        ksfi = ksfi + 1
    # Phase B / M16.93: zero the per-task Plan 9 errstr buffer. Kernel
    # threads never call SYS_ERRSTR, but a stale-slot reclaim could leave
    # a previous user's error message visible if the slot is later reused
    # for a user task — scrub defensively here too.
    kei: uint64 = 0
    while kei < 128:
        task_table[s].errstr_buf[kei] = 0
        kei = kei + 1
    # Phase C / M16.98: rfork sharing-state fields. Kernel threads
    # don't speak Plan 9 anything, but a stale slot reclaim could
    # otherwise carry a previous tenant's pgrp pointer forward.
    # V2.75: pgrp is a heap pointer (uint64); 0 means "use root" —
    # _ensure_root in chan.ad lazily resolves the default.
    task_table[s].fd_table_refcount = 1
    task_table[s].pgrp              = 0
    task_table[s].note_group        = 0
    # M16.104: kernel threads never call SYS_brk (they don't have a
    # userspace, never mind a glibc heap), but zero defensively so a
    # recycled slot can't leak a previous tenant's brk cursor.
    task_table[s].brk_base = 0
    task_table[s].brk_end  = 0
    task_table[s].brk_max  = 0
    # Per-process address-space fields — kernel threads have no user
    # image / user stack. Scrub so a recycled slot can't leak a prior
    # tenant's image span into a fork audit.
    task_table[s].image_lo  = 0
    task_table[s].image_hi  = 0
    task_table[s].ustack_lo = 0
    task_table[s].ustack_sz = 0
    task_table[s].image_phys     = 0
    task_table[s].image_phys_sz  = 0
    task_table[s].ustack_phys    = 0
    task_table[s].ustack_phys_sz = 0
    task_table[s].interp_phys    = 0
    task_table[s].interp_phys_sz = 0
    task_table[s].interp_lo      = 0
    task_table[s].interp_hi      = 0
    # FORK+EXEC COW-image discriminator: a fresh slot owns/holds no
    # COW-shared image (do_clone sets this to 1 only when it COW-shares a
    # parent image into the child).
    task_table[s].image_cow_shared = 0
    # §1 / rfork RFNOWAIT: every fresh task starts attached (reapable).
    task_table[s].detached  = 0
    # M16.109: Plan 9 note state. Kernel threads never call notify(2)
    # but a recycled slot must not carry a previous user's handler RIP
    # — otherwise a stray future devproc_write hit on the kthread's
    # pid would redirect into freed user code. Scrub defensively.
    task_table[s].note_handler_rip = 0
    task_table[s].note_pending     = 0
    task_table[s].note_saved_rip   = 0
    task_table[s].note_saved_rsp   = 0
    kni: uint64 = 0
    while kni < 128:
        task_table[s].note_msg[kni] = 0
        kni = kni + 1
    # U42 VMA layer: kernel threads have no user address-space mappings
    # to track. Scrub defensively so a recycled slot can't masquerade
    # as carrying a previous user tenant's VMA list pointer.
    task_table[s].vma_list_head = 0
    # docs/security.md: kernel threads run as hostowner (UID_HOSTOWNER).
    # They have no userland surface and the uid only matters if a future
    # kthread ever calls into a vfs permission check that consults
    # current_task()'s uid. F10-3 #456: stamp the named constant so the
    # "kernel kthread is trusted-by-construction = uid 1" identity is
    # explicit at the assignment, not a magic 1.
    task_table[s].uid = UID_HOSTOWNER
    task_table[s].gid = UID_HOSTOWNER
    # #151: seed CFS-lite weight/vruntime/cpu_runs. Kernel threads run at
    # nice 0 (NICE0 weight) and start at the current min vruntime.
    sched_init_task_weight(cast[uint64](s))
    _init_fd_table(s)
    next_pid = next_pid + 1
    nr_tasks_spawned = nr_tasks_spawned + 1
    # PER-CPU RUNQUEUE (#6): a freshly-created kthread is HOMED on the
    # creating CPU's runqueue. This preserves today's create-then-run-here
    # affinity (the creator's own schedule() picks it up) and the IRQ-mask
    # mitigation in fork/clone callers; the work-steal / pull path later
    # migrates it to an idle core if one is starving. rq_cpu MUST be set
    # BEFORE the STATE_READY publish so any CPU that observes the READY store
    # also sees the correct owner (x86 stores retire in program order).
    # Track 5: publish runnable under the creating CPU's rq lock so the
    # STATE_READY flip and the run-list link are atomic w.r.t. that CPU's
    # _pick_next. (sched_make_ready_on is the general entry; this create-local
    # publish mirrors it inline because rq_cpu is pinned to the creator.)
    _pub_cpu: uint64 = get_cpu_id()
    _rq_lock_cpu(_pub_cpu)
    task_table[s].rq_cpu = _pub_cpu
    # RACE FIX: publish as runnable only after full init (see note above).
    task_table[s].state = STATE_READY
    _rq_list_insert(s, _pub_cpu)
    _rq_unlock_cpu(_pub_cpu)
    return slot


def create_user_task(entry: uint64, name0: uint64) -> int32:
    # Backwards-compatible wrapper around the argv-aware version
    # below — used by SYS_CLONE and the boot path, neither of which
    # cares about argc/argv (their user binaries don't read rdi/rsi).
    return create_user_task_argv(entry, name0, 0, 0, 0)


def create_user_task_argv(entry: uint64, name0: uint64,
                          user_rsp: uint64, argc: uint64,
                          argv: uint64) -> int32:
    # Thin wrapper that plants 0 into the child's user %r9. SYS_SPAWN
    # and the legacy SYS_CLONE entry path don't propagate any user-side
    # r9 — they're building a brand-new user image from scratch. The
    # CLONE_THREAD path in do_clone calls create_user_thread directly
    # so the child resumes with the parent's r9 (the musl __clone
    # wrapper parks the worker function there).
    return create_user_thread(entry, name0, user_rsp, argc, argv,
                              0, 0, 0, 0, 0)


def create_user_task_argv_embryo(entry: uint64, name0: uint64,
                                 user_rsp: uint64, argc: uint64,
                                 argv: uint64) -> int32:
    # FORK-PATH variant of create_user_task_argv. Identical task build, but
    # the child is published STATE_EMBRYO (off every run-list, invisible to
    # _pick_next AND the cross-CPU work-steal walk) instead of STATE_READY.
    # The fork caller (do_clone, no CLONE_VM) still has to COW-share the
    # parent's whole address space (vm_cow_share_all + interp + vma_fork_copy)
    # into the child's brand-new PML4 AFTER this returns. On -smp 2 the local
    # IRQ mask the caller holds does NOT stop the OTHER cpu's steal/pull
    # dispatcher from grabbing a READY child and running it against a
    # half-populated page table (a libapt .text PTE not yet present/exec ->
    # NX exec-fault / va=0 read-fault -> SIGSEGV in apt's worker, the #413
    # fork<->steal race). Keep the child EMBRYO across the COW critical
    # section; the caller flips it READY via task_publish_thread_ready()
    # only after the address space is fully shared + a write barrier.
    return create_user_thread(entry, name0, user_rsp, argc, argv,
                              0, 0, 0, 0, 1)


def create_user_thread(entry: uint64, name0: uint64,
                       user_rsp: uint64, argc: uint64,
                       argv: uint64, user_r9: uint64,
                       user_rdx: uint64, user_r8: uint64,
                       share_cr3: uint64,
                       publish_embryo: uint64) -> int32:
    # Allocate kstack + ustack, build a freshly-preempted-looking
    # stack image whose iret frame returns to CPL=3 at `entry`.
    # If `user_rsp` is non-zero the caller is supplying a stack with
    # argv strings + array already laid out at its top; we just plant
    # that address in the iret frame. Otherwise we allocate a fresh
    # page and use its top. argc / argv are written into the rdi /
    # rsi slots so the first iretq into _start delivers them as the
    # standard SysV first two arguments. user_r9 is the value to
    # plant in the user's %r9 — non-zero only on the CLONE_THREAD
    # path (musl's __clone parks the worker function there).
    # user_rdx / user_r8 likewise carry the parent's %rdx / %r8 for
    # the CLONE_THREAD path: glibc's clone3 child does `call *%rdx`
    # with the argument in %r8. SYS_SPAWN callers pass 0 for all three.
    #
    # share_cr3: non-zero ONLY on the thread paths (CLONE_VM|CLONE_THREAD
    # in do_clone, rfork RFMEM in _rfork_thread). The thread runs on the
    # CREATOR's PML4 — we point cr3 at it DIRECTLY at creation instead of
    # cloning a boot PML4 the caller would immediately discard. The old
    # alloc-clone-then-set_task_cr3 dance had two defects: (a) the
    # abandoned boot-clone page leaked on every thread spawn, and (b) the
    # window between STATE_READY and the cr3 repoint let ANOTHER CPU's
    # steal/pull dispatcher run the thread on the stale boot clone — an
    # IRQ mask on the creating CPU never closed that. Freeing the stale
    # clone at repoint time (the obvious leak fix) then freed a PML4 the
    # other CPU was actively USING as its live CR3: the freed page got
    # reallocated + scribbled, the running task's PTEs turned to garbage
    # (observed: a text-page PTE misread as a swap entry -> bogus
    # "swap-in OOM" halt; the original latent #DF at load_cr3+0x3 is the
    # same corruption surfacing later). With share_cr3 the thread's cr3
    # is correct BEFORE it ever becomes visible, and no disposable page
    # exists to leak or free. The task is additionally published as
    # STATE_EMBRYO (not READY) so the caller can finish fs_base/fd/tid
    # inheritance before any dispatcher anywhere can pick it — see
    # task_publish_thread_ready().
    slot: int32 = _find_free_slot()
    if slot < 0:
        printk0("create_user_task: no free task slot\n")
        return -1

    # KSTACK_SIZE worth of pages — a single page is too small for the
    # deepest kernel call chains, and an overflow corrupts whatever the
    # buddy allocator placed just below (see the KSTACK_SIZE history).
    kstack: uint64 = alloc_pages(KSTACK_ORDER)
    if kstack == 0:
        return -1
    cast[Ptr[uint64]](kstack)[0] = KSTACK_CANARY    # overflow detector (#438)
    kstack_top: uint64 = kstack + KSTACK_SIZE

    ustack: uint64 = 0
    ustack_top: uint64 = user_rsp
    if user_rsp == 0:
        ustack = alloc_page()
        if ustack == 0:
            return -1
        ustack_top = ustack + USTACK_SIZE

    # Boot-CR3 guard around the kstack frame build. _build_initial_kstack
    # writes the fresh iret/bootstrap frame to the kstack pages as RAW
    # PHYSICAL (identity) addresses. This runs in the CALLER's context —
    # for a forking parent (rfork / hamsh `ns {}`) the live CR3 is that
    # parent's PML4, whose low-RAM identity map for the just-alloc'd
    # kstack chunk may have been CRACKED/COW-remapped by execve + ASLR.
    # Writing kstack_top-relative vaddrs then lands on the WRONG physical
    # page (observed: the child's real kstack stays full of stale
    # emit_raw frames, so __switch_to_asm rets into garbage -> #GP at the
    # bootstrap iretq). The pristine boot CR3 maps ALL of low RAM
    # identity, so build the frame under it, then restore. Same guard the
    # PML4 clone above and the COW-share path in fs/elf.ad already use.
    _ks_live_cr3: uint64 = read_cr3()
    _ks_boot_cr3: uint64 = cow_boot_cr3()
    _ks_irq: uint64 = 0
    if _ks_boot_cr3 != 0:
        _ks_irq = local_irq_save()
        load_cr3(_ks_boot_cr3)
    sp: uint64 = _build_initial_kstack(
        kstack_top, USER_CS_R3, USER_DS_R3, ustack_top, entry,
        argc, argv, user_r9, user_rdx, user_r8,
    )
    if _ks_boot_cr3 != 0:
        load_cr3(_ks_live_cr3)
        local_irq_restore(_ks_irq)
    s: uint64 = cast[uint64](slot)
    task_table[s].sp          = sp
    _task_set_pid(s, next_pid)        # Track 5: stamp pid + pid->slot hash
    # Job control: a fresh task leads its own process group (job_pgid ==
    # pid) until SYS_SETPGID moves it. SYS_SPAWN's child-pgid plumbing
    # overrides this right after create returns when the shell asked for
    # a backgrounded pipeline in a new group.
    task_table[s].job_pgid    = next_pid
    task_table[s].stop_sig    = 0
    task_table[s].cont_pending = 0
    task_table[s].kstack_base = kstack
    task_table[s].kstack_top  = kstack_top
    # SMP steal-window: fresh task is not mid-switch; clear any stale on_cpu
    # left in a recycled STATE_FREE slot before it can become stealable.
    task_table[s].on_cpu      = 0
    task_table[s].ustack_base = ustack
    # NOTE: state is DELIBERATELY NOT set to STATE_READY here. The slot
    # stays STATE_FREE (as returned by _find_free_slot) until the very
    # end of this function — see the STATE_READY assignment just before
    # `return slot`. RACE FIX: marking the task runnable here, before
    # task_table[s].cr3 (set ~50 lines below, after the PML4 clone) and
    # before the dozens of field scrubs that follow, opened a window
    # where a timer IRQ → schedule() → _pick_next() could dispatch this
    # HALF-INITIALIZED task. The scheduler would then load_cr3(cr3=0 /
    # stale .bss) and __switch_to a task with no kstack/cr3 set up,
    # producing a wild jump into garbage (observed: #GP rip=0x8006, the
    # stale AP-trampoline bytes, with a user-range rsp). _pick_next only
    # considers STATE_READY slots, so leaving this STATE_FREE until fully
    # built keeps the partial task invisible to the scheduler. (UP-safe:
    # no other path calls _find_free_slot from IRQ context, so the slot
    # cannot be re-claimed mid-init.)
    task_table[s].is_user     = 1
    task_table[s].name0       = name0
    task_table[s].parent_pid  = task_table[current_idx_pcpu].pid
    task_table[s].exit_code   = 0
    # Per-task PML4: clone the PRISTINE BOOT PML4 so the kernel half is
    # mapped identically and the user half starts as the untouched boot
    # identity map. We deliberately clone the BOOT page-table root
    # (cow_boot_cr3(), snapshotted in cow_init() before any task
    # existed) rather than the LIVE %cr3: copy-of-the-live-CR3 would
    # bake in whatever user-half page-table cracking the currently
    # running task (e.g. a forking parent) had already done, so the new
    # task would silently SHARE that task's private PDPT/PD/PT and a
    # COW fault in one would trample the other. Cloning the pristine
    # boot PML4 guarantees every task's user half starts unshared, and
    # fs/elf.ad's COW table-cracker (which compares against the same
    # boot tables) then hands each task fully private lower-level
    # tables on first touch. Fall back to the live CR3 only if
    # cow_init() has not run yet (defensive — task creation always
    # follows mem_init()).
    if share_cr3 != 0:
        # Thread path (CLONE_THREAD / rfork RFMEM): run on the creator's
        # PML4, no clone at all. The creator is alive and mid-syscall,
        # so its PML4 cannot be reaped out from under us before the
        # EMBRYO->READY publish.
        task_table[s].cr3 = share_cr3
    else:
        new_pml4: uint64 = alloc_page()
        if new_pml4 == 0:
            return -1
        pml4_src: uint64 = cow_boot_cr3()
        if pml4_src == 0:
            pml4_src = get_bsp_cr3()
        # The clone reads the boot PML4 (pml4_src) and writes the freshly
        # alloc_page()'d new_pml4 — both are PHYSICAL page-table pages in
        # low RAM. They are reachable ONLY if the CURRENTLY-ACTIVE CR3
        # still identity-maps the 2 MiB chunk each lives in. That is NOT
        # guaranteed: the live CR3 belongs to the spawning/forking parent,
        # whose user-half page tables have been CRACKED by
        # elf_install_user_mapping / the COW fork path. On a UEFI boot
        # with several hundred MiB of RAM the boot PML4 itself lands high
        # (~485 MiB), and a parent's cracked PD can have dropped the
        # identity entry for that exact chunk (observed: pd[243] P=0), so
        # the raw memcpy below #PF'd reading pml4_src. The BSP/boot CR3
        # maps ALL of low RAM identity by construction, so run the clone
        # under it, then restore the caller's CR3. Pure physical-identity
        # work in between (no user-half access), so the switch is safe.
        #
        # Switch to the PRISTINE boot PML4 (cow_boot_cr3 / pml4_src),
        # which is the snapshot taken in cow_init() before any user-half
        # cracking, so it maps the full low-RAM identity. Reading pml4_src
        # and writing new_pml4 both resolve under it. Restore the caller's
        # CR3 immediately after.
        _clone_live_cr3: uint64 = read_cr3()
        _clone_irq_flags: uint64 = 0
        if pml4_src != 0:
            _clone_irq_flags = local_irq_save()
            load_cr3(pml4_src)
        memcpy(cast[Ptr[uint8]](new_pml4),
               cast[Ptr[uint8]](pml4_src), 4096)
        if pml4_src != 0:
            load_cr3(_clone_live_cr3)
            local_irq_restore(_clone_irq_flags)
        task_table[s].cr3 = new_pml4
    # SMAP-v3 step 2: install an EXPLICIT US=1 PTE for the freshly
    # alloc'd user stack into the child's PML4. Pre-SMAP-v3 the stack
    # was reachable from CPL=3 only via the identity-backfill leaves'
    # implicit US=1; once those leaves drop US=1 (the leaf split in
    # fs/elf.ad::_build_identity_pd/_pt that gates SMAP enable), the
    # very first user instruction would CPL=3-fault on its initial
    # stack touch (rip=user-entry, err=U+W+P) without an explicit
    # mapping here. elf_install_user_stack carries US=1 | W=1 | NX
    # (PT_FLAG_RW | PT_FLAG_NX) and identity-maps vaddr==phys, so the
    # _build_initial_kstack frame's user RSP (ustack_top, plain
    # identity address) remains valid AND becomes CPL=3-reachable in
    # the new task's PML4. Only runs when:
    #   * ustack != 0    — we allocated a fresh page (user_rsp == 0
    #                      branch above); the caller-supplied user_rsp
    #                      path delegates stack mapping to whoever
    #                      built that stack (do_execve uses its own
    #                      elf_install_user_stack; rfork's COW path
    #                      installs via vm_cow_share_all).
    #   * share_cr3 == 0 — non-share path; on share_cr3 != 0 the
    #                      thread runs on the creator's PML4 which
    #                      already has the parent's stack region
    #                      mapped, and a CLONE_THREAD child supplies
    #                      its own user_rsp anyway (ustack would be 0
    #                      here).
    # Failure to install is treated like an OOM ustack allocation: free
    # the kstack/ustack and bail. The slot is still STATE_FREE at this
    # point so no scheduler can race us.
    if ustack != 0 and share_cr3 == 0:
        if elf_install_user_stack(task_table[s].cr3, ustack,
                                  USTACK_SIZE) < 0:
            printk0("create_user_thread: ustack US=1 install failed\n")
            free_page(ustack)
            free_pages(kstack, KSTACK_ORDER)
            free_page(task_table[s].cr3)
            task_table[s].cr3 = 0
            return -1
    # U1: default new user tasks to native Hamnix ABI. The Linux ELF
    # loader path (future U-series milestone) will call
    # set_linux_userspace_mode(slot, 1) after this returns to flip the
    # child into Linux-numbered dispatch before its first iretq.
    task_table[s].is_linux_userspace = 0
    # U31: zero the signal-handler table + comm + pdeathsig at every
    # creation. STATE_FREE slots may hold stale entries from a prior
    # occupant (task_reap leaves the body intact); without this scrub
    # a newly-spawned task would inherit the previous tenant's
    # handlers and signal_check_and_handle would dispatch to freed
    # user code.
    si: uint64 = 0
    while si < 64:
        task_table[s].sig_handlers[si] = 0
        si = si + 1
    ci: uint64 = 0
    while ci < 16:
        task_table[s].comm[ci] = 0
        ci = ci + 1
    task_table[s].pdeathsig = 0
    # U37: same alt-stack scrub as kthread_create — every freshly-
    # spawned user task starts with sigaltstack(SS_DISABLE-equivalent).
    # A subsequent _u_sigaltstack call lays down the real values.
    task_table[s].alt_stack_sp    = 0
    task_table[s].alt_stack_size  = 0
    task_table[s].alt_stack_flags = 0
    # §3: Linux-ABI signal state. Fresh task starts with no signals
    # pending, none blocked, not inside a handler, and every sa_flags
    # slot clear. task_reap leaves the slot body intact, so a reused
    # slot would otherwise inherit a prior tenant's pending bits and
    # signal_check_and_handle would dispatch a stale signal.
    task_table[s].sig_pending    = 0
    task_table[s].sig_mask       = 0
    task_table[s].sig_saved_mask = 0
    task_table[s].sig_in_handler = 0
    task_table[s].term_sig       = 0
    task_table[s].sig_frame_uctx = 0
    sfi: uint64 = 0
    while sfi < 64:
        task_table[s].sig_flags[sfi] = 0
        sfi = sfi + 1
    # #160 / seccomp-lite: a freshly-created task starts UNCONFINED.
    # task_reap leaves the slot body intact, so a reaped+reused slot
    # would otherwise inherit a prior tenant's seccomp filter and kill
    # the new task on its first non-allowed syscall. Direct field writes
    # (not set_task_seccomp_mode, which refuses to lower a non-zero mode)
    # so the scrub always takes. do_clone re-copies the parent's filter
    # AFTER create returns for a real fork/clone child.
    task_table[s].seccomp_mode = 0
    sci: uint64 = 0
    while sci < 4:
        task_table[s].seccomp_filter[sci] = 0
        sci = sci + 1
    # F10-8 / #457: NATIVE seccomp filter scrub — same reasoning as the
    # Layer-2 scrub above. A reaped+reused slot must not inherit a prior
    # tenant's native filter (would bounce every syscall the new task
    # makes), and set_task_seccomp_native_filter refuses to disarm a
    # filter once armed, so the scrub must be a direct field write.
    task_table[s].seccomp_native_armed = 0
    snfi: uint64 = 0
    while snfi < 4:
        task_table[s].seccomp_native_filter[snfi] = 0
        snfi = snfi + 1
    # Phase B / M16.93: every freshly-created user task starts with a
    # zeroed Plan 9 errstr buffer. Plan 9 semantics: errstr is per-task
    # and NOT inherited across rfork/fork (each child sees "no error"),
    # so this scrub is correct both for fresh slots and reaped+reused
    # slots. Reading the buffer before any failed syscall returns an
    # empty string, which is exactly what 9front does.
    ei: uint64 = 0
    while ei < 128:
        task_table[s].errstr_buf[ei] = 0
        ei = ei + 1
    # Phase C / M16.98: rfork sharing-state defaults. Every fresh user
    # task starts with a private fd table (refcount=1) and the shared
    # default namespace / note group (id 0). do_rfork() overrides
    # whichever of these the flag bits ask for after the child is
    # created — see sys/src/9/port/sysproc.ad.
    task_table[s].fd_table_refcount = 1
    task_table[s].pgrp              = 0
    task_table[s].note_group        = 0
    # M16.104: per-task SYS_brk state. Two cases:
    #
    #   1. Thread path (CLONE_THREAD): user_r9 is non-zero (musl's
    #      __clone wrapper parks the worker function there before the
    #      syscall; only the thread caller in arch/x86/kernel/syscall.ad
    #      forwards it through). Threads share the parent's address
    #      space — they MUST see the same heap or two libc instances
    #      collide on the same arena. Inherit the parent's three
    #      cursors verbatim.
    #
    #   2. Fresh task path (SYS_SPAWN / SYS_FORK / SYS_EXECVE — all
    #      reach this via create_user_task_argv which forwards
    #      user_r9=0): the new image owns its own VM, so a stale
    #      parent brk would point at memory that no longer represents
    #      the new program's address space. Zero — first brk() call
    #      lazily allocates a fresh contiguous region (see
    #      _u_unimpl_brk in linux_abi/u_syscalls.ad).
    if user_r9 != 0 and task_table[current_idx_pcpu].is_user != 0:
        cu: uint64 = current_idx_pcpu
        task_table[s].brk_base = task_table[cu].brk_base
        task_table[s].brk_end  = task_table[cu].brk_end
        task_table[s].brk_max  = task_table[cu].brk_max
        # Threads (CLONE_VM) share the parent's address space, so they
        # also share the loaded image span. ustack_* stays the THREAD's
        # own caller-supplied stack — left 0 here, no fork copy applies.
        task_table[s].image_lo  = task_table[cu].image_lo
        task_table[s].image_hi  = task_table[cu].image_hi
        task_table[s].interp_lo = task_table[cu].interp_lo
        task_table[s].interp_hi = task_table[cu].interp_hi
        # PR_SET_NO_NEW_PRIVS is inherited across fork/clone (Linux ratchet).
        task_table[s].no_new_privs = task_table[cu].no_new_privs
        task_table[s].ustack_lo = 0
        task_table[s].ustack_sz = 0
    else:
        task_table[s].brk_base = 0
        task_table[s].brk_end  = 0
        task_table[s].brk_max  = 0
        # Per-process address-space fields. Zero on a fresh slot; for a
        # fork child do_clone overwrites these (and the page tables)
        # right after this function returns.
        task_table[s].image_lo  = 0
        task_table[s].image_hi  = 0
        task_table[s].interp_lo = 0
        task_table[s].interp_hi = 0
        # execve / fresh task: NNP cleared (a fresh exec without the bit
        # set starts privileged-by-default in Linux too).
        task_table[s].no_new_privs = 0
        task_table[s].ustack_lo = 0
        task_table[s].ustack_sz = 0
    # §1 / rfork RFNOWAIT: a fresh user task is attached (reapable) by
    # default. do_rfork sets detached=1 after this returns when the
    # RFNOWAIT bit asked to sever the parent link.
    task_table[s].detached = 0
    # Resource-reclaim owner fields (task_reap). Always 0 on a fresh
    # slot — a STATE_FREE slot reused from a prior tenant must NOT carry
    # the previous occupant's image/ustack physical bases (task_reap
    # already freed those), or the next reap would double-free. The
    # allocating syscall (SYS_SPAWN / do_execve) sets them after this
    # returns; fork children DELIBERATELY leave them 0 (they COW-share,
    # they don't own).
    task_table[s].image_phys     = 0
    task_table[s].image_phys_sz  = 0
    task_table[s].ustack_phys    = 0
    task_table[s].ustack_phys_sz = 0
    task_table[s].interp_phys    = 0
    task_table[s].interp_phys_sz = 0
    # FORK+EXEC COW-image discriminator: clear on a recycled slot so a
    # previous tenant's COW-share flag never leaks forward. do_clone sets
    # it to 1 explicitly after COW-sharing the parent image.
    task_table[s].image_cow_shared = 0
    # M16.109: Plan 9 note state — every fresh user task starts with
    # NO handler installed (note_handler_rip=0). notify(2) installs
    # the handler at first use. Forking does NOT inherit the parent's
    # note_handler_rip in this Phase C commit: Plan 9 contract says
    # a child gets the parent's handler, but our handler RIP is into
    # the parent's TEXT segment which the child shares for user-mode
    # ELFs (we only have one address space at this scale), so future
    # work can flip the inherit bit on. For now, fresh slot = clean
    # state.
    task_table[s].note_handler_rip = 0
    task_table[s].note_pending     = 0
    task_table[s].note_saved_rip   = 0
    task_table[s].note_saved_rsp   = 0
    nmi: uint64 = 0
    while nmi < 128:
        task_table[s].note_msg[nmi] = 0
        nmi = nmi + 1
    # U42 VMA layer: fresh task starts with no VMAs. The ELF loader
    # path in arch/x86/kernel/syscall.ad::do_execve will populate the
    # list with PT_LOAD-derived VMAs on the first execve into this
    # slot, and subsequent mmap()s extend it. CLONE_THREAD (user_r9
    # nonzero) shares the parent's user image — once the VMA layer
    # grows RFMEM share semantics, threads will inherit the same
    # vma_list_head pointer here. For now both paths zero-init: the
    # only Linux thread workload in the U-track (musl pthread_create)
    # doesn't introspect VMAs, and the thread's own stack arrives via
    # caller-supplied child_stack rather than a new VMA.
    task_table[s].vma_list_head = 0
    # docs/security.md: Plan-9-shape uid/gid inheritance. Fork (no
    # user_r9) AND thread (CLONE_THREAD with user_r9 != 0) BOTH inherit
    # the parent's uid/gid — the spec is "child gets parent's identity",
    # which holds for both flavours.
    #
    # F10-3 #456: the default identity for a fresh user task with no
    # real parent identity is UID_NOBODY (65534), NOT hostowner. The
    # pre-F10-3 fallback ("if parent_uid == 0 then uid = 1") made every
    # boot-time userland program run as hostowner, which short-circuited
    # F3's per-server policy enforcement (the dispatcher's uid==1
    # bypass fires for the on-disk servers). PID 1 (init) is given
    # hostowner EXPLICITLY by init/main.ad after create_user_task
    # returns, via set_task_uid_at(parent_slot, UID_HOSTOWNER). Every
    # subsequent task forked from init inherits its uid (the real
    # parent_uid branch below).
    #
    # Boot-time fallback: the FIRST user task ever created (init / PID 1)
    # is built before any kthread_create runs, so current_idx_pcpu still
    # points at slot 0 in its all-zero .bss init state — uid == 0. The
    # explicit init/main.ad set_task_uid_at IMMEDIATELY after this slot
    # is published as STATE_READY upgrades PID 1 to hostowner; until that
    # store retires, PID 1 lands here as UID_NOBODY. There is no window
    # where PID 1 could be dispatched in the NOBODY state because
    # start_first_task only runs AFTER init/main.ad's explicit setter.
    cu_uid: uint64 = current_idx_pcpu
    parent_uid: uint32 = task_table[cu_uid].uid
    parent_gid: uint32 = task_table[cu_uid].gid
    if parent_uid == 0:
        parent_uid = UID_NOBODY
        parent_gid = UID_NOBODY
    task_table[s].uid = parent_uid
    task_table[s].gid = parent_gid
    # #151: seed CFS-lite weight/vruntime/cpu_runs. New user tasks start at
    # nice 0; the fork/clone path re-applies parent inheritance afterwards
    # via sched_inherit_nice_to_child (do_clone in syscall.ad).
    sched_init_task_weight(cast[uint64](s))
    _init_fd_table(s)
    _inherit_cwd_from_parent(s)
    next_pid = next_pid + 1
    nr_tasks_spawned = nr_tasks_spawned + 1
    # RACE FIX (ordering): publish the task as runnable ONLY now that
    # cr3, kstack, sp, and every signal/fd/namespace field are fully
    # initialized — NOT mid-function before task_table[s].cr3 was set.
    # On x86 stores retire in program order, so once this STATE_READY
    # store is visible every field store above it is too. This closes
    # the plain spawn-path window where a timer IRQ → _pick_next() could
    # dispatch a task whose cr3 was still 0. The fork/rfork/clone paths
    # additionally COW-share the address space AFTER this returns; those
    # callers mask IRQs across the create+COW critical section (see
    # do_rfork / do_clone) so the child can't be dispatched onto an
    # un-shared PML4 before its mappings exist.
    # PER-CPU RUNQUEUE (#6): home the child on the creating CPU's runqueue
    # (rq_cpu set BEFORE the READY publish). Combined with the caller's
    # IRQ-mask across create+COW, this keeps the child off any dispatcher
    # until its address space is fully shared; the pull/steal path migrates
    # it later if another core is idle.
    task_table[s].rq_cpu = get_cpu_id()
    # Thread path (share_cr3): publish EMBRYO, not READY. The caller
    # (do_clone / _rfork_thread) still has inheritance stores to make
    # (fs_base TLS, fd table, seccomp, cwd, tid bookkeeping) and an IRQ
    # mask on THIS cpu cannot keep another CPU's steal/pull dispatcher
    # from picking a READY task. _pick_next ignores EMBRYO everywhere;
    # the caller flips it READY via task_publish_thread_ready() after
    # the last inheritance store.
    if share_cr3 != 0 or publish_embryo != 0:
        # Thread path (share_cr3) OR fork path (publish_embryo): publish
        # EMBRYO, not READY. The caller still has work to do before the
        # child may run — the thread path finishes fs_base/fd/tid
        # inheritance, the fork path COW-shares the parent's whole address
        # space into the child's fresh PML4. EMBRYO tasks are never linked
        # onto a run-list, so neither _pick_next nor the cross-CPU
        # work-steal walk can dispatch the half-built child on the other
        # cpu. The caller flips it READY via task_publish_thread_ready()
        # after its last setup store + a write barrier.
        task_table[s].rq_cpu = get_cpu_id()
        task_table[s].state = STATE_EMBRYO
    elif boot_first_task_pending != 0:
        # BOOT-FIRST-TASK RACE (#413). PID 1 is created here at boot:38 but
        # NOT dispatched until start_first_task() at boot:42 — dozens of boot
        # steps later. Publishing it STATE_READY + linked onto a run-list (the
        # `else` arm) makes it eligible for the already-online idle AP to
        # work-steal and __switch_to into off its planted bootstrap iret frame
        # during that window; PID 1 then runs on the AP, takes its SYS_EXECVE,
        # and clobbers the very iret frame start_first_task is about to SYSRETQ
        # off of -> garbage user RIP -> NX exec-fault in the kstack -> pid-7
        # SIGSEGV (deterministic under -smp 2; invisible to the 1-CPU UEFI
        # path). Publish it STATE_EMBRYO instead: EMBRYO tasks are NEVER linked
        # onto a run-list, so both _pick_next and the work-steal walk (which
        # only ever traverse rq_head[*]) cannot see it. start_first_task()
        # flips it RUNNING under the rq lock when it claims it. The flag is a
        # one-shot set by init/main.ad strictly around this single create call.
        task_table[s].rq_cpu = get_cpu_id()
        task_table[s].state  = STATE_EMBRYO
    else:
        # Track 5: non-thread publish — READY + run-list link under the
        # creator's rq lock (rq_cpu pinned to the creator just above).
        _tc_cpu: uint64 = get_cpu_id()
        _rq_lock_cpu(_tc_cpu)
        task_table[s].rq_cpu = _tc_cpu
        task_table[s].state = STATE_READY
        _rq_list_insert(s, _tc_cpu)
        _rq_unlock_cpu(_tc_cpu)
    return slot


def task_publish_thread_ready(slot: int32):
    # Final step of CLONE_THREAD / rfork-RFMEM creation: the creator has
    # finished every inheritance store, so the EMBRYO becomes dispatchable.
    # On x86 stores retire in program order — once this READY store is
    # visible to another CPU's dispatcher, every inheritance store before
    # it is too.
    if slot < 0:
        return
    s: uint64 = cast[uint64](slot)
    if s >= NTASKS:
        return
    if task_table[s].state == STATE_EMBRYO:
        # Track 5: EMBRYO -> READY publish under the owning CPU's rq lock so
        # the run-list link is atomic with the READY flip.
        _tp_cpu: uint64 = task_table[s].rq_cpu
        if _tp_cpu >= NR_RQ:
            _tp_cpu = 0
        _rq_lock_cpu(_tp_cpu)
        task_table[s].rq_cpu = _tp_cpu
        task_table[s].state = STATE_READY
        _rq_list_insert(s, _tp_cpu)
        _rq_unlock_cpu(_tp_cpu)


# --- public: schedule / lifecycle ---------------------------------

def _pick_next() -> int32:
    # #151: weighted-fair (CFS-lite) pick. Returns the eligible STATE_READY
    # slot with the SMALLEST vruntime, or -1 if none.
    #
    # TRACK 5 — O(active) walk: this used to be a linear min-scan over ALL
    # NTASKS slots (filtering on state==READY && rq_cpu==my_cpu). It now walks
    # ONLY this CPU's intrusive READY run-list (rq_head[my_cpu] threaded
    # through rq_next), so its cost is the number of RUNNABLE tasks on THIS
    # CPU — not the size of the (now much larger) task table. Every node on
    # rq_head[my_cpu] is, by construction, STATE_READY and owned by my_cpu, so
    # the old per-node state/rq_cpu predicates are guaranteed and dropped.
    #
    # PER-CPU RUNQUEUE (#6): the caller holds this CPU's rq lock
    # (rq_locks[my_cpu]); no global lock is taken. Tasks owned by OTHER CPUs
    # are on THEIR run-lists and invisible here (dispatched by their own CPU,
    # or pulled over by work-steal which re-links them onto this list under
    # the destination lock first).
    #
    # Eligibility (still applied per node):
    #   • Slot 0 is the BSP boot task: rq_cpu is forced to 0 for it, so it
    #     only ever appears on the BSP's run-list. The explicit on_bsp guard
    #     below is belt-and-braces.
    #   • A cgroup cpu.max-throttled task is skipped (CFS tier only).
    #
    # Tie-break: among equal-vruntime eligibles we prefer a DIFFERENT slot
    # than current_idx_pcpu when one exists, so two CPU-bound tasks at the
    # same vruntime still alternate rather than one pinning the CPU.
    #
    # REALTIME TIER (SCHED_FIFO / SCHED_RR): before the CFS-lite walk we look
    # for any eligible runnable realtime task. ANY such task outranks ALL
    # SCHED_OTHER tasks. Among realtime tasks the HIGHEST rt_priority wins;
    # within a priority level the SMALLEST enqueue sequence (oldest arrival /
    # least-recently-rotated) wins → FIFO order plus RR rotation (an RR task
    # that drains its slice is re-stamped to the tail). The CFS-lite walk is
    # reached ONLY when no realtime task is runnable.
    my_cpu: uint64 = get_cpu_id()
    if rq_inited == 0:
        _rq_list_init()
    on_bsp: uint64 = 0
    if my_cpu == 0:
        on_bsp = 1
    cur: uint64 = current_idx_pcpu

    rt_best:     int32  = -1
    rt_best_pri: uint64 = 0
    rt_best_seq: uint64 = 0
    r: uint64 = rq_head[my_cpu]
    while r != RQL_NIL:
        relig: uint64 = 0
        # Slot 0 (BSP boot task) is BSP-only; everything else (incl.
        # user tasks) is eligible on any CPU thanks to per-CPU TSS.
        # SMP steal-window: skip any task still mid-switch on (or running
        # on) another CPU — on_cpu==1 means its saved sp may be stale, so
        # dispatching it here would put two CPUs on the same kstack. The
        # fence clears in __switch_to_asm once prev->sp is committed.
        if (on_bsp != 0 or r != 0) and task_table[r].on_cpu == 0:
            relig = 1
        if relig != 0 and sched_is_realtime(r) != 0:
            rp:  uint64 = g_rt_priority[r]
            rsq: uint64 = g_rt_enqueue_seq[r]
            if rt_best < 0:
                rt_best = cast[int32](r)
                rt_best_pri = rp
                rt_best_seq = rsq
            elif rp > rt_best_pri:
                rt_best = cast[int32](r)
                rt_best_pri = rp
                rt_best_seq = rsq
            elif rp == rt_best_pri and rsq < rt_best_seq:
                # Same priority level: oldest arrival (smallest sequence)
                # is picked. RR rotation re-stamps the spent task to the
                # tail, so this implements both FIFO order and RR turn-
                # taking with one comparison.
                rt_best = cast[int32](r)
                rt_best_pri = rp
                rt_best_seq = rsq
        r = task_table[r].rq_next
    if rt_best >= 0:
        return rt_best

    best: int32 = -1
    best_v: uint64 = 0
    i: uint64 = rq_head[my_cpu]
    while i != RQL_NIL:
        elig: uint64 = 0
        # Slot 0 (BSP boot task) is BSP-only; everything else (incl.
        # user tasks) is eligible on any CPU thanks to per-CPU TSS.
        # SMP steal-window: an on_cpu!=0 task is still running / mid-switch
        # on another CPU and its saved sp may be stale — skip it (see the
        # RT loop above and __switch_to_asm's on_cpu clear).
        if (on_bsp != 0 or i != 0) and task_table[i].on_cpu == 0:
            elig = 1
        # F11 cgroup v2 cpu.max: a quota-exhausted task is
        # skipped here just like a STATE_WAIT task — the cgroup's
        # period boundary refill (cgroup_cpu_tick_refill on the
        # next tick) flips it back to eligible. Realtime tasks are
        # NOT subject to cpu.max (Linux semantics) and so the RT
        # loop above intentionally does not consult this predicate.
        if elig != 0 and cgroup_cpu_should_throttle(i) != 0:
            elig = 0
        if elig != 0:
            v: uint64 = task_table[i].vruntime
            if best < 0:
                best = cast[int32](i)
                best_v = v
            elif v < best_v:
                best = cast[int32](i)
                best_v = v
            elif v == best_v:
                # Equal vruntime: prefer a slot that is NOT the
                # currently-running one so peers rotate.
                if cast[uint64](best) == cur and i != cur:
                    best = cast[int32](i)
                    best_v = v
        i = task_table[i].rq_next
    return best


def _sched_try_pull_locked(my_cpu: uint64) -> int32:
    # PER-CPU RUNQUEUE (#6) — PULL-side load balancing. Called by a CPU that
    # found its OWN runqueue empty (in schedule() / AP idle); it tries to
    # steal one runnable task from a BUSIER cpu's runqueue and re-home it on
    # `my_cpu` so the idle core does useful work. Returns the migrated slot,
    # or -1 if nothing could be pulled.
    #
    # CALLER MUST already hold rq_locks[my_cpu]. We acquire the VICTIM cpu's
    # rq lock with spinlock_trylock ONLY (never blocking): lock order between
    # two rq locks is "ascending cpu index", but rather than enforce that
    # ordering we simply back off — if the victim lock is contended we skip
    # that victim this pass. This makes deadlock structurally impossible: a
    # CPU never SPINS on a second rq lock while holding its first.
    #
    # Eligibility to steal a slot `s` from victim `v`:
    #   • STATE_READY and rq_cpu == v (genuinely on victim's runqueue).
    #   • s != 0 (the BSP boot task never migrates off cpu 0).
    #   • Not currently the victim's running task (handled by STATE_READY:
    #     a RUNNING task is not READY, so it is never stolen).
    # We pick the SMALLEST-vruntime eligible victim task (most starved),
    # mirroring the AP idle loop's existing steal heuristic, and re-stamp
    # its rq_cpu to my_cpu so the very next _pick_next() on my_cpu sees it.
    nonline: uint64 = get_cpus_online()
    if nonline <= 1:
        return -1
    v: uint64 = 0
    while v < nonline and v < NR_RQ:
        if v != my_cpu:
            # Try to grab the victim's rq lock without blocking.
            if _rq_trylock_cpu(v) != 0:
                steal: int32  = -1
                steal_v: uint64 = 0
                # Track 5: walk victim v's intrusive READY run-list (every
                # node is STATE_READY && rq_cpu == v by construction) instead
                # of scanning all NTASKS slots.
                s: uint64 = rq_head[v]
                while s != RQL_NIL:
                    # Cross-CPU load balancing of USER (CPL3) tasks is ENABLED:
                    # an AP dispatches a stolen user task through its OWN
                    # per-CPU TSS.RSP0 + private CR3 + SYSCALL MSRs (all armed in
                    # ap_main_hamnix) and the AP idle loop's dispatch prologue
                    # (tss_set_rsp0 / load_cr3 / FS_BASE), exactly mirroring the
                    # BSP. The historical "#413: APs may steal only is_user==0"
                    # skip was a WORKAROUND for a probe whose entry lived in
                    # US=0 kernel .text and #PF'd on the CPL3 instruction fetch
                    # (err=0x15); that was never an AP per-CPU defect. Real user
                    # tasks are ELF-loaded into US=1 pages, so they dispatch on
                    # any CPU. Verified by test_smp_user.sh (USER task runs +
                    # syscalls on cpu1). Only slot 0 (the BSP boot/PID-1 task)
                    # stays pinned — it must never migrate off cpu 0.
                    # QA-N32b steal hysteresis: skip a task dispatched within
                    # the last STEAL_HYSTERESIS_JIFFIES so a just-run task is
                    # not immediately yanked onto this CPU (prevents cross-CPU
                    # ping-pong / steal-livelock). jiffies is monotonic; a
                    # never-run slot (last_dispatch_jiffy == 0) yields a large
                    # difference and stays freely stealable.
                    recent: uint64 = get_jiffies() - task_table[s].last_dispatch_jiffy
                    if s != 0 \
                            and task_table[s].on_cpu == 0 \
                            and recent >= STEAL_HYSTERESIS_JIFFIES \
                            and sched_cpu_allowed(s, my_cpu) != 0:
                        sv: uint64 = task_table[s].vruntime
                        if steal < 0 or sv < steal_v:
                            steal = cast[int32](s)
                            steal_v = sv
                    s = task_table[s].rq_next
                if steal >= 0:
                    su2: uint64 = cast[uint64](steal)
                    # Re-home onto my_cpu while BOTH rq locks are held, so
                    # neither CPU's _pick_next can observe the slot as
                    # belonging to both at once. Move both the rq_cpu stamp AND
                    # the run-list membership (unlink from v's list, link onto
                    # my_cpu's) under both locks.
                    _rq_list_remove(su2)
                    task_table[su2].rq_cpu = my_cpu
                    _rq_list_insert(su2, my_cpu)
                    _rq_unlock_cpu(v)
                    return steal
                _rq_unlock_cpu(v)
        v = v + 1
    return -1


def _sched_switch_to_ap_idle(my_cpu: uint64, ap_idle: uint64):
    # Switch the CURRENT (non-runnable) task on an AP onto that AP's idle
    # slot. Used by schedule() when an AP's current task is EXITED (or asleep
    # in STATE_WAIT/STOPPED) and there is no other runnable work to dispatch:
    # we must NOT return into the non-runnable task, so we hand the CPU to its
    # idle kthread which HLTs until a reschedule IPI / steal brings work.
    #
    # Mirrors the switch tail of schedule(): mark prev appropriately (it is
    # ALREADY non-RUNNING — EXITED/WAIT/STOPPED — so we do NOT re-mark it
    # READY or re-link it onto a run-list; a dead task must stay off, and a
    # WAIT task is parked on its wait-queue), make idle RUNNING, set RSP0 /
    # CR3 / FS_BASE for idle, raise the on_cpu steal fence on prev, then
    # __switch_to_asm. Called with NO rq lock held.
    prev: uint64 = current_idx_pcpu
    _rq_lock_cpu(my_cpu)
    # The idle slot may be sitting READY on this CPU's run-list (the idle loop
    # links it before dispatching real work); pull it off and make it RUNNING.
    _rq_list_remove(ap_idle)
    task_table[ap_idle].state  = STATE_RUNNING
    task_table[ap_idle].rq_cpu = my_cpu
    current_idx_pcpu = ap_idle
    # Steal-window fence on prev: its sp is saved by __switch_to_asm below.
    # (A dead/parked task is not on a run-list so it is not actually
    # stealable, but raise the fence for uniformity; __switch_to_asm clears
    # it after the sp store.)
    # on_cpu invariant: ap_idle is dispatched here, so it stays fenced (==1)
    # for the whole time it is this CPU's live task; __switch_to_asm clears
    # prev's fence after saving prev->sp.
    task_table[prev].on_cpu = 1
    task_table[ap_idle].on_cpu = 1
    _rq_unlock_cpu(my_cpu)

    # RCU quiescent state: the outgoing (dead/parked) task holds no reader.
    _rcu_prev_nest: uint64 = rcu_save_read_nesting()
    task_table[prev].rcu_read_nesting = _rcu_prev_nest
    if _rcu_prev_nest == 0:
        rcu_note_context_switch()
    rcu_restore_read_nesting(task_table[ap_idle].rcu_read_nesting)

    # Switch tail: idle's kstack RSP0, idle's (kernel) CR3 if different, FS.
    tss_set_rsp0(task_table[ap_idle].kstack_top)
    if task_table[ap_idle].cr3 != task_table[prev].cr3:
        load_cr3(task_table[ap_idle].cr3)
    write_msr(SCHED_IA32_FS_BASE, task_table[ap_idle].fs_base)

    __switch_to_asm(cast[Ptr[uint8]](&task_table[prev]),
                    cast[Ptr[uint8]](&task_table[ap_idle]))


def schedule():
    # Called from timer_interrupt() (preemption) and from
    # task_exit_current() (cooperative drop). Round-robins the
    # runqueue; updates TSS.RSP0 to the new task's kstack so a
    # subsequent CPL-3 IRQ lands there; then __switch_to.
    #
    # PER-CPU RUNQUEUE (#6): the dispatch hot path takes ONLY this CPU's own
    # rq lock (rq_locks[my_cpu]) — never a global lock. _pick_next() scans
    # only THIS CPU's runnable set (rq_cpu == my_cpu); the prev->READY and
    # nxt->RUNNING flips below touch only tasks this CPU owns. So two CPUs
    # dispatching at the same time no longer contend.
    #
    # The lock must not be held across __switch_to_asm: the task we switch
    # away from re-enters schedule() later (via another timer tick or
    # cooperative yield) and would deadlock if it tried to re-acquire a lock
    # it no longer holds.
    #
    # On uniprocessor the BSP timer ISR fires with local interrupts disabled
    # (x86 gates IF on hardware IRQ entry), so rq_locks[0] is always free on
    # the BSP path — the xchg is a cache round-trip but never spins.
    # Kstack-overflow canary (#438): the lowest quad of every kstack is
    # stamped KSTACK_CANARY at allocation. If a kernel call chain ever
    # grows past KSTACK_SIZE, this is the first quad it tramples — catch
    # it HERE, loudly, before the overflow silently corrupts whatever
    # buddy block sits below (page tables, sibling kstacks, ...).
    cur_kb: uint64 = task_table[current_idx_pcpu].kstack_base
    if cur_kb != 0 and cast[Ptr[uint64]](cur_kb)[0] != KSTACK_CANARY:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("KSTACK OVERFLOW: pid=%d kstack_base=%p canary smashed\n",
                task_table[current_idx_pcpu].pid, cur_kb)
        panic("kernel stack overflow (KSTACK_CANARY smashed)")
    my_cpu: uint64 = get_cpu_id()
    _rq_lock_cpu(my_cpu)
    nxt_signed: int32 = _pick_next()
    if nxt_signed < 0:
        # PER-CPU RUNQUEUE (#6): nothing on OUR local runqueue. Before giving
        # up, try to PULL one runnable task from a busier cpu (load balance),
        # so an idle core that called schedule() picks up cross-cpu work
        # instead of stalling. _sched_try_pull_locked re-homes a victim task
        # onto my_cpu (rq_cpu = my_cpu) under both rq locks, so the retry
        # _pick_next() below sees it as local.
        if _sched_try_pull_locked(my_cpu) >= 0:
            nxt_signed = _pick_next()
    if nxt_signed < 0:
        # Nobody to run on THIS cpu's runqueue (and nothing to pull). If even
        # the current task is no longer ready, this cpu has no live local
        # task.
        if task_table[current_idx_pcpu].state != STATE_RUNNING and \
           task_table[current_idx_pcpu].state != STATE_READY:
            # An AP whose current task is no longer runnable (EXITED after
            # SYS_EXIT, or asleep in STATE_WAIT/STOPPED) MUST NOT `return`
            # here: the caller (task_exit_current / a blocking syscall) is
            # relying on schedule() to switch the dead/sleeping task OFF the
            # CPU and never resume it on this stack. Returning resumes the
            # non-runnable task past its schedule() call — for an EXITED task
            # that means executing with its fds closed / address space torn
            # down, which silently wedges the box (observed: rc.boot user
            # commands stolen onto the AP exiting -> hang right after the
            # "task: pid N exited" printk). The historical `if my_cpu != 0:
            # return` was safe ONLY while APs never ran user tasks (they ran
            # the idle kthread, which is always STATE_RUNNING and legitimately
            # returns to its own loop). Now that user tasks load-balance onto
            # APs, we must SWITCH to this AP's idle slot (which HLTs until a
            # reschedule IPI / steal brings work) instead of returning into a
            # dead task. The idle slot is always present and runnable.
            if my_cpu != 0:
                ap_idle: uint64 = ap_idle_slots[my_cpu]
                # If we ARE the idle slot (idle kthread itself yielded with no
                # work), the legacy return is correct — it loops back into
                # sched_ap_idle_loop which HLTs.
                if ap_idle == current_idx_pcpu:
                    _rq_unlock_cpu(my_cpu)
                    return
                # Switch the non-runnable task OFF onto this AP's idle slot.
                # _sched_switch_to_ap_idle does the full switch tail (RSP0 /
                # CR3 / FS_BASE / on_cpu fence / __switch_to_asm) under no held
                # lock, so release the rq lock first.
                _rq_unlock_cpu(my_cpu)
                _sched_switch_to_ap_idle(my_cpu, ap_idle)
                # We only get here if the (now-idle) task is later switched
                # BACK in — but a dead task never is, and a STATE_WAIT task
                # resumes via its own wait-loop, not here. Return is safe.
                return
            # On the BSP: the current task is no longer runnable (it exited /
            # was reaped / stopped) so we MUST switch away and never resume
            # it. With per-CPU runqueues a globally-empty LOCAL rq no longer
            # implies a dead system — another cpu may own the only runnable
            # task, or every task may be asleep in STATE_WAIT awaiting an IRQ.
            # So instead of halting outright we IDLE-LOOP: each pass we sti;hlt
            # (so a device IRQ or reschedule IPI can wake a task / hand us back
            # work via a future enqueue onto cpu0), then retry a local pick +
            # cross-cpu pull. We break out (and the box halts) ONLY when the
            # system is provably dead: no READY task anywhere AND no STATE_WAIT
            # task that an interrupt could ever revive.
            while True:
                _rq_lock_cpu(my_cpu)
                rs: int32 = _pick_next()
                if rs < 0:
                    if _sched_try_pull_locked(my_cpu) >= 0:
                        rs = _pick_next()
                if rs >= 0:
                    # Found / pulled work: re-home current_idx onto it and
                    # context-switch away from the dead task. We re-enter the
                    # main switch sequence by recursing into schedule(): the
                    # local rq now has a READY task, so the recursion takes
                    # the normal switch path and never returns here.
                    _rq_unlock_cpu(my_cpu)
                    schedule()
                    return
                _rq_unlock_cpu(my_cpu)
                if _any_task_runnable_global() == 0 and _sched_any_waiter() == 0:
                    # Provably dead system: nothing runnable, nothing asleep
                    # that an IRQ could revive. Halt the box.
                    printk_set_level(PRINTK_LEVEL_EMERG)
                    printk0("schedule: no live tasks; halting\n")
                    local_irq_disable()
                    while True:
                        asm_volatile("hlt")
                # Idle one beat with IF=1 so an IRQ / reschedule IPI can fire
                # and make work runnable, then loop to retry the pick.
                # RCU: this CPU is idle (no reader held) — enter the extended
                # quiescent state so an in-flight or future grace period is not
                # stalled while we spin idle, and rejoin on wake.
                rcu_idle_enter()
                local_irq_enable()
                cpu_idle_enter()
                asm_volatile("hlt")
                cpu_idle_leave()
                rcu_idle_exit()
        _rq_unlock_cpu(my_cpu)
        return

    nxt: uint64 = cast[uint64](nxt_signed)
    if nxt == current_idx_pcpu:
        _rq_unlock_cpu(my_cpu)
        return  # only one ready task

    prev: uint64 = current_idx_pcpu
    # getrusage(2): snapshot prev's runnable state BEFORE the flip below
    # clears it. Linux's rule: prev still RUNNING here => preempted while
    # runnable => INVOLUNTARY; prev already non-RUNNING => it blocked /
    # slept / exited before calling schedule() => VOLUNTARY.
    prev_was_running: int32 = 0
    if task_table[prev].state == STATE_RUNNING:
        prev_was_running = 1
    if task_table[prev].state == STATE_RUNNING:
        task_table[prev].state = STATE_READY
        # prev stays on THIS cpu's runqueue (it was running here)...
        task_table[prev].rq_cpu = my_cpu
        # Track 5: a RUNNING task is OFF every run-list; now that prev is
        # READY again, link it back onto my_cpu's run-list (re-homed below if
        # affinity excludes my_cpu). Insert before any rq_cpu re-stamp so the
        # link lands on the list whose lock we hold.
        _rq_list_insert(prev, my_cpu)
        # ...UNLESS a sched_setaffinity(2) call (possibly on another CPU)
        # excluded my_cpu from prev's mask while prev was running here. This
        # is the Linux "deferred migration of a running task" case: rather
        # than yank a live task off-core mid-execution, the exclusion is
        # honored at this next schedule point by re-homing prev to an allowed
        # CPU and kicking that CPU. prev != 0 (the BSP boot task is BSP-pinned
        # and its mask always includes CPU 0, so this branch never fires for
        # slot 0). The directed reschedule IPI is sent AFTER the rq lock is
        # dropped below — here we only re-stamp rq_cpu under the held lock.
        if prev != 0 and sched_cpu_allowed(prev, my_cpu) == 0:
            new_cpu: uint64 = sched_affinity_pick_cpu(prev, my_cpu)
            # Track 5: prev was just linked onto my_cpu's run-list above but is
            # being re-homed to new_cpu. UNLINK it from my_cpu's list FIRST
            # (while rq_cpu still == my_cpu, so _rq_list_remove fixes the right
            # head), THEN re-stamp rq_cpu and re-link onto new_cpu. This touches
            # new_cpu's list head under my_cpu's lock — the SAME cross-CPU
            # window the rq_cpu re-stamp already accepts for deferred affinity
            # migration (a directed IPI below makes new_cpu re-pick).
            _rq_list_remove(prev)
            task_table[prev].rq_cpu = new_cpu
            _rq_list_insert(prev, new_cpu)
    # Track 5: nxt is being dispatched (READY -> RUNNING) and a RUNNING task is
    # OFF every run-list. Unlink it before flipping state.
    _rq_list_remove(nxt)
    task_table[nxt].state = STATE_RUNNING
    task_table[nxt].rq_cpu = my_cpu
    # sched_setaffinity(2) deferred migration: if prev was re-homed off my_cpu
    # (its mask no longer allows my_cpu), capture the destination so we can
    # kick that CPU AFTER dropping the rq lock — an idle owner must fall out
    # of HLT to dispatch the migrated task.
    prev_migrated_to: int64 = -1
    if task_table[prev].state == STATE_READY and task_table[prev].rq_cpu != my_cpu:
        prev_migrated_to = cast[int64](task_table[prev].rq_cpu)
    current_idx_pcpu = nxt

    # SMP steal-window fence (Linux's rq->curr->on_cpu invariant): on_cpu==1
    # for the ENTIRE time a task is the live task on a CPU — from dispatch
    # here until __switch_to_asm saves its sp on the NEXT switch-away. prev
    # keeps on_cpu=1 (it is mid-switch-out; its sp slot is stale until
    # __switch_to_asm runs below). nxt is being dispatched NOW, so it gets
    # on_cpu=1 too: this is the crucial bit — a task that later sets itself
    # STATE_WAIT and calls schedule() must already be fenced when a wakeup on
    # ANOTHER CPU flips it back to STATE_READY, or that CPU's _pick_next would
    # dispatch it on a STALE sp while THIS CPU is still executing it (two CPUs
    # on one kstack -> corrupted return / __stack_chk_fail / #UD, the inbound
    # net_accept SMP crash). _pick_next + _sched_try_pull_locked both skip
    # on_cpu!=0, so the woken task simply waits on its runqueue until
    # __switch_to_asm here clears the fence and publishes the fresh sp.
    task_table[prev].on_cpu = 1
    task_table[nxt].on_cpu = 1

    _rq_unlock_cpu(my_cpu)

    # ─── RCU quiescent-state report + read-nesting migration ───────────────
    # This is a REAL context switch on my_cpu. RCU treats it as a quiescent
    # state for my_cpu IFF the OUTGOING task held no rcu_read_lock. Preserve
    # the outgoing task's read nesting into its task_struct, install the
    # incoming task's saved nesting as this CPU's live counter, THEN report the
    # QS (rcu_note_context_switch self-gates on the now-restored live nesting,
    # but the gate must reflect the SWITCHING-OUT reader, so we report before
    # restore by checking prev's depth). IRQs are still masked here (schedule()
    # runs with IF=0 on the switch path), so this triplet is atomic vs. the QS
    # bitmask. This is the ONLY RCU hook the scheduler exposes — no other sched
    # logic is touched.
    _rcu_prev_nest: uint64 = rcu_save_read_nesting()
    task_table[prev].rcu_read_nesting = _rcu_prev_nest
    if _rcu_prev_nest == 0:
        rcu_note_context_switch()
    rcu_restore_read_nesting(task_table[nxt].rcu_read_nesting)

    if prev_migrated_to >= 0:
        smp_send_reschedule_cpu(cast[uint64](prev_migrated_to))

    # §13: ctxt accounting — this is a real (prev != next) context
    # switch, so count it. /dev/stat's "ctxt" column reads this back.
    loadavg_note_switch()

    # getrusage(2): charge the OUTGOING task exactly once per real switch.
    # SLOT-indexed because current_idx_pcpu has already advanced to nxt.
    if prev_was_running != 0:
        task_account_involuntary_ctxsw_at(prev)
    else:
        task_account_voluntary_ctxsw_at(prev)

    # Every actual context switch — preemptive OR cooperative — hands
    # the incoming task a fresh quantum. Without this a task that is
    # dispatched right after another's quantum partly elapsed would
    # inherit the stale (small) count and get preempted almost
    # immediately. preempt_tick() also re-arms on the tick that drives
    # a preemptive switch; resetting here additionally covers the
    # cooperative yield_to_others / task_exit_current paths.
    # #151: the slice is WEIGHT-SCALED — a lower-nice (heavier) task gets
    # a proportionally longer slice so the coarse 100 Hz tick still
    # delivers the weight ratio between two CPU-bound peers.
    quantum_left = sched_quantum_for(nxt)

    # Realtime: a freshly-dispatched SCHED_RR task gets a full round-robin
    # slice so it isn't preempted into instantly by inheriting a peer's
    # spent slice. SCHED_FIFO has no slice; SCHED_OTHER ignores this field.
    if g_sched_policy[nxt] == SCHED_RR:
        g_rr_slice_left[nxt] = SCHED_RR_TICKS

    # #151: per-CPU dispatch accounting (SMP load-balance test marker).
    sched_note_dispatch(nxt)

    # Update RSP0 BEFORE the swap so a stray CPL-3 IRQ that happens
    # between this point and the next sysret/iretq still lands on
    # the right stack.
    # PER-CPU TSS: tss_set_rsp0 now indexes per_cpu_tss[] by the CALLING
    # CPU's logical id (read from %gs:0), so every CPU updates ITS OWN
    # TSS.RSP0 — there is no shared TSS to corrupt. This is what lets an
    # AP run user tasks: a ring3->ring0 transition on the AP loads RSP0
    # from the AP's own TSS. Always update; cheap and correct on all CPUs.
    tss_set_rsp0(task_table[nxt].kstack_top)

    # Switch page tables if the incoming task uses a different PML4.
    # Skipping the write when CR3 wouldn't change avoids a needless
    # TLB flush — Linux does the same fast-path in __switch_mm.
    if task_table[nxt].cr3 != task_table[prev].cr3:
        load_cr3(task_table[nxt].cr3)

    # U27: per-task FS_BASE save/restore. Linux's __switch_to writes
    # the next task's TLS base via wrfsbase / wrmsr. Threads created by
    # clone(CLONE_SETTLS) each carry their own TLS, and the only way
    # %fs:0x10 reads the right value after a context switch is to
    # reprogram MSR_FS_BASE on every swap. Native Hamnix tasks store
    # fs_base = 0 and never read %fs-relative; writing 0 is harmless.
    # We unconditionally write (no fast path on equal values) because
    # comparing two uint64 fields is the same number of instructions
    # as the wrmsr and we'd just trade a branch for a memory hit.
    write_msr(SCHED_IA32_FS_BASE, task_table[nxt].fs_base)

    # INVARIANT (#switch-bad-sp): never __switch_to_asm into a task whose
    # saved sp is garbage. A legitimate kstack sp is always high (>1MiB);
    # an uninitialized/zeroed sp means _pick_next returned a slot that was
    # never built by _build_initial_kstack — historically the retired
    # phantom boot task (slot 0), left linked on rq_head after its state
    # was flipped to STATE_FREE without an _rq_list_remove (fixed in
    # start_first_task). __switch_to_asm would `mov (nxt.sp),%rsp` with
    # sp==0 and #GP at the switch-tail `ret` (rsp=0x30). Catch it here,
    # loudly, instead of diving into a corrupt context.
    if task_table[nxt].sp < cast[uint64](0x100000):
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("SWITCH-BAD-SP: nxt=%d sp=%p\n",
                cast[uint64](nxt), task_table[nxt].sp)
        printk2("SWITCH-BAD-SP: nxt.state=%d nxt.pid=%d\n",
                task_table[nxt].state, cast[uint64](task_table[nxt].pid))
        panic("schedule: dispatch into task with uninitialized sp")

    __switch_to_asm(cast[Ptr[uint8]](&task_table[prev]),
                    cast[Ptr[uint8]](&task_table[nxt]))


def _another_task_ready() -> uint64:
    # Returns 1 if some slot OTHER than current_idx_pcpu is STATE_READY ON
    # THIS CPU'S RUNQUEUE (rq_cpu == my_cpu) — i.e. there is genuinely a
    # LOCAL runnable peer that schedule() on this CPU would actually switch
    # to. PER-CPU RUNQUEUE (#6): made CPU-local because _pick_next() only
    # dispatches local-rq tasks now; a READY task owned by ANOTHER CPU is
    # not dispatchable here, so it must NOT make this CPU's wq-sleep loop
    # spin calling a no-op schedule(). The wq-sleep idle path falls through
    # to sti;hlt instead, and the producer's directed reschedule IPI (plus
    # the timer tick) wakes it.
    my_cpu: uint64 = get_cpu_id()
    i: uint64 = 0
    while i < NTASKS:
        if i != current_idx_pcpu:
            if task_table[i].state == STATE_READY and \
               task_table[i].rq_cpu == my_cpu:
                return 1
        i = i + 1
    return 0


def _any_task_runnable_global() -> uint64:
    # Returns 1 if ANY cpu's runqueue holds a STATE_READY task. Used only by
    # the BSP halt decision in schedule(): the box halts only when there is
    # genuinely no runnable work ANYWHERE (and the current task is not runnable
    # either). A per-CPU-local empty rq is NOT a halt condition.
    # Track 5: a non-empty rq_head on ANY cpu means runnable work — O(NR_RQ).
    if rq_inited == 0:
        _rq_list_init()
    c: uint64 = 0
    while c < NR_RQ:
        if rq_head[c] != RQL_NIL:
            return 1
        c = c + 1
    return 0


def _sched_any_waiter() -> uint64:
    # Returns 1 if ANY slot is in a state an interrupt could later make
    # runnable: STATE_WAIT (blocked on a wait queue, woken by a producer
    # IRQ) or STATE_STOPPED (woken by SIGCONT). Used together with
    # _any_task_runnable_global() by the BSP halt decision: the box halts
    # only when there is NEITHER runnable work NOR a revivable sleeper. A
    # RUNNING task elsewhere also counts (it will eventually re-enter the
    # scheduler), so include it for safety.
    i: uint64 = 0
    while i < NTASKS:
        st: uint64 = task_table[i].state
        if st == STATE_WAIT or st == STATE_STOPPED or st == STATE_RUNNING:
            return 1
        i = i + 1
    return 0


def _rt_rotatable_peer_ready(self_slot: uint64) -> uint64:
    # Returns 1 if some READY realtime task OTHER than self_slot has a
    # realtime priority >= self_slot's — i.e. there is genuinely a peer worth
    # rotating an RR slice to (or a higher-priority RT task that should run).
    # Used by the SCHED_RR tick path to avoid a no-op schedule() when the
    # rotating task is the only runnable thing at (or above) its level.
    sp: uint64 = g_rt_priority[self_slot]
    i: uint64 = 0
    while i < NTASKS:
        if i != self_slot:
            if task_table[i].state == STATE_READY:
                if sched_is_realtime(i) != 0 and g_rt_priority[i] >= sp:
                    return 1
        i = i + 1
    return 0


def preempt_tick(from_user: uint64) -> uint64:
    # Called once per 100 Hz timer tick from timer_interrupt(), AFTER
    # the timer EOI has been sent. `from_user` is non-zero when the
    # timer interrupted ring-3 (userland) code.
    #
    # Returns 1 if the caller should now perform a preemptive context
    # switch (timer_interrupt() then calls schedule()); 0 otherwise.
    # We do NOT call schedule() ourselves so the EOI-before-switch
    # ordering stays visible at the timer_interrupt() call site.
    #
    # Preemption-point policy (V1): preempt ONLY when the timer caught
    # the CPU in ring 3. Userland has no kernel locks held and no
    # half-updated kernel state, so freezing it at an arbitrary
    # instruction and resuming it later is always safe. Ring-0 context
    # (kthreads, IRQ handlers, and — though SYSCALL masks IF so the
    # timer can't normally fire there — syscall code) is treated as
    # non-preemptible: the cooperative yields (yield_to_others on every
    # blocking syscall, schedule() on exit) already cover it, and
    # preempting arbitrary kernel code risks corrupting a lock or a
    # partially-updated structure. A ring-0 tick therefore ages the
    # quantum but never switches and never re-arms — so a ring-3 tick
    # that lands after the quantum has already drained to 0 preempts
    # on its very next occurrence.
    #
    # #151: every tick the RUNNING task accrues vruntime weighted by the
    # inverse of its load weight: delta(1 tick) * NICE0_WEIGHT / weight.
    # A heavier (lower-nice) task therefore advances vruntime more slowly
    # and _pick_next re-selects it more often → it gets proportionally
    # more CPU. This runs on EVERY tick (ring-0 and ring-3) so a CPU-bound
    # task that never blocks still accrues — otherwise two equal-weight
    # tasks would tie forever at vruntime 0. Accrual is to the currently-
    # RUNNING slot on this CPU (current_idx_pcpu).
    #
    # We scale the numerator by VRUNTIME_SCALE (a fixed-point shift) before
    # the integer divide so the weight ratio is preserved even for very
    # heavy tasks: a nice -20 task (weight 88761) advances ~1/87th as fast
    # as a nice 0 task instead of being flattened to a +1 floor.
    cur: uint64 = current_idx_pcpu

    # Realtime tier (SCHED_FIFO / SCHED_RR). A realtime task does NOT accrue
    # CFS-lite vruntime and ignores the weighted quantum entirely — its
    # preemption is governed solely by realtime rules:
    #   • SCHED_FIFO: never time-sliced. It runs until it blocks, yields, or
    #     exits, and is never preempted by an equal-or-lower realtime priority
    #     (or by any SCHED_OTHER task). So a FIFO tick simply returns 0.
    #   • SCHED_RR: time-sliced among EQUAL-priority RR peers. Each tick that
    #     catches it running decrements its slice; when the slice hits 0 the
    #     task rotates to the TAIL of its priority level (re-stamped sequence)
    #     and re-arms a fresh slice. We then ask for a switch only if there is
    #     another runnable RR peer at the SAME priority to rotate to (a strictly
    #     higher-priority RT task would already have preempted via _pick_next;
    #     a lower-priority one must NOT preempt). _pick_next then picks the
    #     oldest same-priority peer.
    # Either way we DO NOT touch quantum_left / vruntime: those belong to the
    # CFS-lite path and a realtime task leaving the CPU re-arms them via the
    # schedule() dispatch of whoever runs next.
    if sched_is_realtime(cur) != 0:
        if g_sched_policy[cur] == SCHED_FIFO:
            return 0
        # SCHED_RR slice accounting.
        if g_rr_slice_left[cur] > 0:
            g_rr_slice_left[cur] = g_rr_slice_left[cur] - 1
        if g_rr_slice_left[cur] != 0:
            return 0
        # Slice spent: rotate to the tail of this priority level and re-arm.
        # Same ring-0 non-preemptibility rule as the CFS-lite path: a ring-0
        # tick ages (and here rotates) the slice but never forces a switch,
        # because preempting arbitrary kernel code could corrupt a lock. The
        # rotation still stands, so the very next ring-3 tick (or a cooperative
        # yield) hands the CPU to the peer _pick_next now prefers.
        _rt_stamp_seq(cur)
        g_rr_slice_left[cur] = SCHED_RR_TICKS
        if from_user == 0:
            return 0
        # Only force a switch when a same-or-higher-priority RT peer is
        # runnable to rotate to; with none, this task keeps the CPU
        # (re-selected by _pick_next) and the rotation is a harmless no-op.
        if _rt_rotatable_peer_ready(cur) == 0:
            return 0
        return 1

    # F11 cgroup v2 cpu.max: refill any period boundaries that crossed
    # this tick, then charge the running task. A non-realtime ring-3
    # tick that pushes the cgroup over quota forces an immediate
    # preemption — the next _pick_next() will skip this task (and any
    # peer in the same throttled cgroup) until the period refills.
    # We refill BEFORE the charge so a tick landing on a fresh period
    # gets a fair charge against the refilled budget, not the old one.
    cgroup_cpu_tick_refill()
    if cgroup_cpu_charge_tick(cur, from_user) != 0:
        # Throttled: yield the CPU on the very next opportunity.
        # Quantum drain bookkeeping below still runs so the eventual
        # un-throttle starts on a fresh slice.
        quantum_left = sched_quantum_for(cur)
        if _another_task_ready() != 0:
            return 1
        # No peer to run — the task stays on-CPU but won't accrue
        # further charges this period because _another_task_ready=0
        # implies it has nobody to throttle in favour of. The next
        # period refill clears the over-quota state automatically.
    cw: uint64 = task_table[cur].sched_weight
    if cw == 0:
        cw = NICE0_WEIGHT
    # #174: per-namespace CPU cap. A capped namespace inflates its tasks'
    # vruntime accrual by 100/cap (factor 1 when uncapped), so the capped
    # task's vruntime grows faster and _pick_next selects it proportionally
    # less often. This composes cleanly with the nice/weight ratio: the
    # weight term is the FAIR share, the cap factor is a per-namespace
    # CEILING on top of it. 25% cap → 4x accrual → ~1/4 the CPU of an
    # uncapped peer at the same nice.
    cap_factor: uint64 = nscap_cpu_factor_current()
    task_table[cur].vruntime = task_table[cur].vruntime + \
        (((NICE0_WEIGHT * VRUNTIME_SCALE) / cw) * cap_factor)
    if quantum_left > 0:
        quantum_left = quantum_left - 1
    if quantum_left != 0:
        return 0
    # Quantum exhausted. Only act on a ring-3 tick with a runnable peer.
    if from_user == 0:
        return 0
    # On a ring-3 tick the quantum is spent; re-arm a fresh weight-scaled
    # slice for whoever runs next. With no runnable peer there is nobody
    # to switch to, so return 0 — but the re-arm still happens, so a peer
    # that becomes READY mid-slice gets a fair full quantum of its own
    # rather than being preempted into instantly.
    quantum_left = sched_quantum_for(cur)
    if _another_task_ready() == 0:
        return 0
    return 1


def task_exit_current(code: int64):
    # Mark the current task EXITED, record exit code, drop its open
    # fds, and yield. Stacks intentionally NOT freed (no reclaim
    # path yet — that's a slab + RCU follow-up). The exit_code is
    # consumed by a parent in SYS_WAITPID; with no parent the value
    # is simply unread.
    # CLONE_FILES (#71): refcounted release of the (possibly SHARED) fd table.
    # The LAST sharer to exit closes it; a self-owned task closes immediately
    # (identical to the old unconditional task_close_all_fds). An fd-table owner
    # that exits while threads are still live keeps its fds open + its slot
    # un-reapable (task_reap defers) until the last sharer goes.
    _release_fd_table_on_exit(cast[int32](current_idx_pcpu))
    # vfork(2) wake: a vfork CHILD that _exit's WITHOUT ever calling execve
    # (e.g. dash's child hit an error, or `vfork(); _exit(127)` on a failed
    # exec) must still release its blocked parent. do_clone's CLONE_VFORK
    # path parks the parent in a yield loop on THIS task's vfork_done flag;
    # do_execve sets it on the exec path, and this sets it on the exec-less
    # _exit path. Without this the parent would block forever when its vfork
    # child dies before exec. Harmless for non-vfork tasks (nobody polls
    # their flag). Set BEFORE the state flips to EXITED so the woken parent
    # never observes a not-yet-flagged zombie.
    set_task_vfork_done(cast[int32](current_idx_pcpu), 1)
    # P0b safety: if this task held the console-input grab (a compositor
    # that claimed /dev/cons exclusively), release it on exit so a DE that
    # crashes or exits without an explicit ungrab never wedges keyboard
    # input for the boot shell. ungrab is a no-op unless we are the holder.
    console_input_ungrab(task_table[current_idx_pcpu].pid)
    # V2.75: drop our reference to the per-process group. If we were
    # the last referer, pgrp_ref_dec kfree's the Pgrp's heap storage,
    # so a future rfork(RFNAMEG) gets a clean kzalloc'd region. Root
    # (sentinel-pinned at PGRP_ROOT_REF_PIN) refuses to underflow
    # inside pgrp_ref_dec, so init's call here is a no-op even if
    # init ever exits.
    pgrp_ref_dec(task_table[current_idx_pcpu].pgrp)
    task_table[current_idx_pcpu].exit_code = code
    # U27: CLONE_CHILD_CLEARTID handshake. If this task (typically a
    # pthread created via clone(CLONE_CHILD_CLEARTID, ctid=&desc->tid))
    # registered a user pointer via set_tid_address / the clone ctid
    # arg, zero that uint32 and futex-wake any thread blocked on it.
    # pthread_join's wait loop is exactly FUTEX_WAIT on that address —
    # without this wake, joiners spin forever on a stale non-zero tid.
    #
    # The futex wake itself is a Layer-2 (Linux-ABI) concern, so the
    # scheduler reaches it indirectly through `cleartid_wake_hook` — a
    # function pointer Layer 2 registers at bring-up. A native-only
    # build leaves the hook null; native tasks never set clear_child_tid
    # anyway, so this whole block is a no-op for them.
    ctid: uint64 = task_table[current_idx_pcpu].clear_child_tid
    if ctid != 0:
        # QA-N32 — PAGE-FAULT-SAFE zero-store (was a raw CPL=0 store that
        # HARD-WEDGED the box). ctid is a USER vaddr. A raw `cast[Ptr[int32]]
        # (ctid)[0] = 0` #PF's in kernel mode (err=WRITE, supervisor) when
        # that page is NOT PRESENT in the exiting task's cr3 — the observed
        # -smp clone3 wedge: a pthread/clone3 thread (glibc sets
        # CLONE_CHILD_CLEARTID with ctid in its TLS/stack) exits with its
        # ctid page sitting in an UNCRACKED huge-page region (pde present ->
        # PT, but pte==0) or never demand-faulted, so the store faults and
        # the core #PF trap-diag HALTS every CPU (heartbeat frozen, no
        # recovery). STAC does NOT help — SMAP gates US-access, not a
        # not-present page. Route through put_user_32, which walks the page
        # table (faulting the page in / cracking a huge page when a VMA
        # backs it) and returns -EFAULT instead of faulting when the address
        # is genuinely unmapped. IGNORE the result, exactly as Linux's
        # mm_release does (do_exit: put_user(0, tsk->clear_child_tid) — a bad
        # address is silently skipped). put_user_32 SMAP-brackets its own
        # store internally, so no _ua_stac/_ua_clac is needed here.
        put_user_32(0, ctid)
        task_table[current_idx_pcpu].clear_child_tid = 0
        if cleartid_wake_hook != cast[Fn[int32, uint64]](0):
            cleartid_wake_hook(ctid)
    # Track 4 UMDF: release any IRQ files / DMA buffers this task held as
    # a user-mode driver host. Runs on BOTH clean exit and crash (signal-
    # kill / fault both funnel through task_exit_current), so a vendor
    # `.ko` crash never leaves a kernel IRQ vector or DMA region wedged.
    if umdf_task_exit_hook != cast[Fn[None, uint64]](0):
        umdf_task_exit_hook(current_idx_pcpu)
    # #443: NATIVE thread exit-notification — the Plan 9-shape mirror of
    # the CLEARTID handshake above. If this task registered an exit
    # semaphore via SYS_SETEXITSEM, semrelease it (atomic increment of
    # the user word + wake any semacquire waiter) NOW, while our cr3 /
    # address space is still live, but after we are irrevocably off our
    # user stack — so a joiner blocked in semacquire(&t.done) can safely
    # reclaim the thread's stack the moment it wakes. The semaphore
    # machinery lives in sys/src/9/port/sems.ad (port layer); we reach
    # it through the hook pointer it registered at bring-up.
    esem: uint64 = task_table[current_idx_pcpu].exit_sem
    if esem != 0:
        task_table[current_idx_pcpu].exit_sem = 0
        if exitsem_release_hook != cast[Fn[int32, uint64]](0):
            exitsem_release_hook(esem)
    # §3: SIGCHLD to the parent. POSIX: a child entering its zombie
    # (STATE_EXITED) state raises SIGCHLD in its parent so a daemon
    # blocked elsewhere learns a child is reapable. We post to the
    # parent's sig_pending bitmap; signal_check_and_handle delivers it
    # at the parent's next syscall boundary / yield. A detached child
    # (RFNOWAIT) has no waitable parent so it skips this. The parent's
    # default SIGCHLD disposition is SIG_IGN-equivalent here (handler
    # 0 → 128+17 terminate would be wrong) — so we ONLY post SIGCHLD
    # when the parent has actually installed a handler for it; a parent
    # that never registered one is not disturbed, exactly matching
    # Linux's "SIGCHLD default action is ignore" semantics.
    if task_table[current_idx_pcpu].detached == 0:
        ppid: uint64 = task_table[current_idx_pcpu].parent_pid
        if ppid != 0:
            pslot: int32 = task_lookup_by_pid(ppid)
            if pslot >= 0:
                psu: uint64 = cast[uint64](pslot)
                pst: uint64 = task_table[psu].state
                if pst == STATE_READY or pst == STATE_RUNNING:
                    chld_h: uint64 = task_table[psu].sig_handlers[SIGCHLD]
                    if chld_h != 0 and chld_h != 1:
                        signal_post(psu, SIGCHLD)
    # §1 / rfork RFNOWAIT: a detached task has no waitable ancestor. It is
    # published a STATE_EXITED zombie (detached==1) — NOT self-reaped to
    # STATE_FREE here.
    #
    # ADDRESS-SPACE-LEAK ROOT-CAUSE FIX: the old detached path flipped the
    # slot straight to STATE_FREE inline and `return`ed. That freed the SLOT
    # but freed NOTHING ELSE — the task is RUNNING on its own kstack, under
    # its own cr3, so it cannot free its kstack / PML4 / user page tables, and
    # the inline path never freed the ELF image region, the 32 MiB brk reserve,
    # the user stack, the mmap VMAs, OR uncharged the cgroup pids count. Every
    # RFNOWAIT / `spawn detached` task (the DE's fire-and-forget app launches,
    # background services) therefore leaked its WHOLE address space on exit.
    # After a handful of detached spawns the page/region pools and the cgroup
    # pids budget bled out, so the next fork()/clone() — anywhere, including an
    # innocent `enter linux {sh}` pipeline — failed its kstack/brk allocation
    # and returned -EAGAIN ("can't fork: Resource temporarily unavailable"),
    # and the DE could no longer relaunch apps.
    #
    # The fix routes detached tasks through the SAME zombie publish as a normal
    # child (on_cpu fence + STATE_EXITED below) and leaves them detached==1.
    # task_reap — which DOES free the full address space + slot + cgroup charge,
    # and is safe to run from another task's context (its on_cpu fence + boot-CR3
    # guard handle a cross-context reap) — then reclaims them. The reaper is
    # reap_orphan_zombies(), invoked at every fork (do_clone / do_rfork) right
    # before a new task is allocated, so a dead detached task's resources are
    # recycled exactly when the next spawn needs them. A detached zombie can
    # linger at most until the next spawn's sweep — a bounded, reclaimable
    # state, not the old permanent address-space leak.
    # (Falls through to the shared STATE_EXITED publish below.)
    # SMP reap fence: raise on_cpu=1 BEFORE publishing STATE_EXITED. A parent
    # reaping this zombie (task_reap) MUST NOT free our kstack while we are
    # still executing our final schedule() on it (we run on an AP; the parent
    # waits/reaps on another CPU). on_cpu stays 1 across the schedule() switch
    # tail until __switch_to_asm has saved our (now-dead) sp and switched to
    # the next task — the instant we are irrevocably off this kstack. task_reap
    # spins on on_cpu==0 before reclaiming the kstack. Set on_cpu BEFORE the
    # STATE_EXITED store so the reaper, which gates on STATE_EXITED, can never
    # observe EXITED with a stale on_cpu==0.
    task_table[current_idx_pcpu].on_cpu = 1
    task_table[current_idx_pcpu].state = STATE_EXITED
    printk_set_level(PRINTK_LEVEL_NOTICE)
    printk2("task: pid %d exited (code=%d)\n",
            task_table[current_idx_pcpu].pid, cast[uint64](code))
    schedule()
    # schedule() never returns when we're EXITED — it halts if there
    # are no other ready tasks, or switches us out forever.


# --- SMP: AP idle kthread and per-AP scheduler bootstrap -----------
#
# Design:
#   1. sched_prepare_ap_idle(cpu_id) is called by the BSP (inside
#      smp_boot_aps' sequential AP-boot loop, while still
#      single-threaded) for each AP it is about to wake.  It creates a
#      dedicated kernel thread whose body is sched_ap_idle_loop(), then
#      marks the slot STATE_FREE (so the BSP's own scheduler can never
#      accidentally pick it up) and records the slot in ap_idle_slots[].
#
#   2. sched_ap_launch(cpu_id) is called by the AP itself after its
#      %gs per-CPU area is set up.  It reads ap_idle_slots[cpu_id],
#      stamps current_idx_pcpu, marks the slot STATE_RUNNING, and enters
#      the kthread via enter_first_task() — the AP's first "task" is the
#      idle loop, exactly as the BSP's first "task" is /init.
#
#   3. sched_ap_idle_loop() runs on the AP forever.  It:
#        (a) Prints "SMP: cpu%d kthread alive" once, proving a scheduler
#            task executed on a non-BSP core.
#        (b) Loops: acquire rq_lock, search for a STATE_READY kernel-only
#            task, if found dispatch it (set idle→READY, real→RUNNING,
#            release lock, __switch_to_asm), loop again when the task
#            eventually comes back (via schedule() → switch back to idle).
#        (c) HLTs with interrupts enabled when no READY task is available
#            (LAPIC timer is NOT armed on APs — they wake via a directed
#            RESCHEDULE IPI, vector 0xF2, sent by whichever CPU made a
#            kernel task runnable; Linux's smp_send_reschedule model).
#
# Safety invariants:
#   • APs CAN pick user tasks (is_user != 0): each AP has its own per-CPU
#     TSS (ltr'd in ap_main_hamnix) whose RSP0 the dispatch prologue below
#     points at the task's kstack, plus its own SYSCALL MSRs, so a ring3->
#     ring0 transition on the AP lands correctly. User tasks load-balance
#     across CPUs; only slot 0 (BSP boot task) stays pinned.
#   • The AP dispatch prologue below DOES call tss_set_rsp0 (it indexes the
#     calling CPU's own per_cpu_tss via %gs:0), mirroring schedule()'s.
#   • rq_lock hold time is bounded (microsecond-scale): only the scan +
#     state updates are inside the critical section, not the switch itself.
#   • BSP uniprocessor path is IDENTICAL to before this patch: the lock
#     is uncontended on the BSP (LAPIC timer fires with IF=0 → no AP can
#     be in the lock at the same time), so schedule() latency is unchanged.

def sched_ap_idle_loop():
    # Body of the AP idle kthread.  Runs on the AP; never returns.
    my_cpu_id: uint64 = get_cpu_id()
    # One-time banner: proof that scheduler code ran on a non-BSP core.
    printk1("SMP: cpu%d kthread alive\n", my_cpu_id)

    while True:
        # PER-CPU RUNQUEUE (#6): acquire ONLY this cpu's rq lock and look for
        # a READY task that THIS cpu's runqueue owns (rq_cpu == my_cpu_id).
        _rq_lock_cpu(my_cpu_id)
        ap_idle_laps = ap_idle_laps + 1
        my_idle_slot: uint64 = current_idx_pcpu
        # Scan our LOCAL runqueue for the best dispatchable task: realtime
        # (FIFO/RR) tier first (highest rt_priority, then oldest enqueue
        # sequence), else the smallest-vruntime CFS-lite task — mirroring
        # _pick_next exactly, but restricted to rq_cpu == my_cpu_id.
        # Track 5: pick the best LOCAL dispatchable task via _pick_next(),
        # which now walks this CPU's intrusive READY run-list (rq_head[my_cpu])
        # applying the exact realtime-then-CFS ordering — O(active), no NTASKS
        # scan. The idle slot itself is STATE_RUNNING here (off the run-list),
        # so _pick_next never returns it.
        found_slot: int32 = -1
        if sched_ap_steal_enabled != 0:
            found_slot = _pick_next()

        # Nothing on our LOCAL runqueue: try to PULL one runnable task from a
        # busier cpu (work-steal / load balance). _sched_try_pull_locked
        # re-homes a victim's rq_cpu onto my_cpu_id under both rq locks, so a
        # successful pull becomes a local READY task we dispatch immediately.
        if found_slot < 0 and sched_ap_steal_enabled != 0:
            pulled: int32 = _sched_try_pull_locked(my_cpu_id)
            if pulled >= 0:
                found_slot = pulled

        if found_slot >= 0:
            nxt: uint64 = cast[uint64](found_slot)
            # Put idle task into READY so schedule() can switch back to
            # us when the real task yields or exits. Both the idle slot and
            # the dispatched task belong to THIS cpu's runqueue (rq_cpu set)
            # so the task's own schedule() will re-pick the idle slot here.
            task_table[my_idle_slot].state  = STATE_READY
            task_table[my_idle_slot].rq_cpu = my_cpu_id
            # Track 5: idle slot is now READY -> link it onto this CPU's
            # run-list; nxt is being dispatched -> unlink it.
            _rq_list_insert(my_idle_slot, my_cpu_id)
            _rq_list_remove(nxt)
            task_table[nxt].state  = STATE_RUNNING
            task_table[nxt].rq_cpu = my_cpu_id
            current_idx_pcpu = nxt
            # #151: record the dispatch on THIS CPU (SMP balance marker).
            sched_note_dispatch(nxt)
            ap_idle_dispatches = ap_idle_dispatches + 1

            # PER-CPU TSS / user-task dispatch on an AP. Mirror the prologue
            # of schedule() so a USER task dispatched here behaves exactly as
            # on the BSP:
            #   • TSS.RSP0 -> this task's kstack_top so a ring3->ring0
            #     transition (IRQ/syscall) on THIS AP lands on the right
            #     kernel stack (tss_set_rsp0 indexes the AP's own per_cpu_tss).
            #   • CR3 -> this task's PML4 so its user address space is live
            #     before iretq/sysret reaches CPL 3. The idle kthread's cr3 is
            #     the kernel PML4 (get_bsp_cr3, set in kthread_create), and a
            #     user task has its own private PML4; switch only when they
            #     differ, exactly like schedule()'s __switch_mm fast-path.
            #     On switch-BACK, the user task's own schedule() call already
            #     reloads the idle kthread's (kernel) CR3 via the same guard,
            #     so no CR3 fix-up is needed after __switch_to_asm returns.
            #   • FS_BASE -> this task's TLS base (0 for native/kernel tasks).
            # SMP steal-window fence (same as schedule()): the idle slot is
            # now READY on this CPU's run-list but its sp won't be saved until
            # __switch_to_asm below. Raise on_cpu so no other AP steals the
            # idle slot on a stale sp; __switch_to_asm clears it after the save.
            # on_cpu invariant: nxt is dispatched here, so keep it fenced
            # (==1) for its whole run; __switch_to_asm clears prev's fence.
            task_table[my_idle_slot].on_cpu = 1
            task_table[nxt].on_cpu = 1
            tss_set_rsp0(task_table[nxt].kstack_top)
            if task_table[nxt].cr3 != task_table[my_idle_slot].cr3:
                load_cr3(task_table[nxt].cr3)
            write_msr(SCHED_IA32_FS_BASE, task_table[nxt].fs_base)
            _rq_unlock_cpu(my_cpu_id)

            # RCU: the outgoing AP idle kthread never holds an rcu_read_lock,
            # so this dispatch is an unconditional quiescent state for this AP.
            # Report it and install the incoming task's saved read nesting. (No
            # save needed for the idle kthread — its nesting is always 0.)
            rcu_note_context_switch()
            rcu_restore_read_nesting(task_table[nxt].rcu_read_nesting)

            # Context-switch to the real task.  When it eventually calls
            # schedule() and finds the idle slot is STATE_READY, it will
            # switch back here — __switch_to_asm will return.
            __switch_to_asm(cast[Ptr[uint8]](&task_table[my_idle_slot]),
                            cast[Ptr[uint8]](&task_table[nxt]))

            # Re-establish idle as STATE_RUNNING and current.
            _rq_lock_cpu(my_cpu_id)
            # Track 5: the real task's schedule() normally removed idle from
            # the run-list when it re-dispatched it; defensively unlink in case
            # the switch-back arrived via a path that left idle linked.
            _rq_list_remove(my_idle_slot)
            task_table[my_idle_slot].state  = STATE_RUNNING
            task_table[my_idle_slot].rq_cpu = my_cpu_id
            current_idx_pcpu = my_idle_slot
            _rq_unlock_cpu(my_cpu_id)
        else:
            _rq_unlock_cpu(my_cpu_id)
            # No ready kernel task right now. LINUX-MIRROR IDLE: the AP now
            # HLTs with interrupts ENABLED and is woken by a directed
            # RESCHEDULE IPI (vector 0xF2), sent by whichever CPU made a
            # kernel task runnable (smp_send_reschedule, called from the
            # wakeup/enqueue paths). This replaces the old NetWare-ish hack
            # that MWAIT'd on the global `jiffies` word and relied on the BSP
            # timer ISR writing it ~100×/s to poll the runqueue. The AP's
            # LAPIC SVR is now software-enabled and the IDT is loaded (see
            # ap_main_hamnix step 3), so a halted AP can actually take the IPI.
            #
            # Two-phase lost-wakeup guard (Linux's TIF_NEED_RESCHED-after-
            # disable pattern): disable IRQs, then re-scan the runqueue ONE
            # more time. If a task appeared between our failed scan above and
            # here we skip hlt and loop to dispatch it; otherwise we are
            # provably idle at the moment IRQs go off, so any enqueue from
            # now on MUST raise the resched IPI — which is held pending while
            # IF=0 and fires the instant safe_halt()'s `sti; hlt` enables it.
            # No wakeup can be lost in the window.
            # PER-CPU RUNQUEUE (#6): rescan for ANY READY task ANYWHERE (our
            # local runqueue OR another cpu's, which we can work-steal). If
            # any exists we skip hlt and loop back to dispatch / pull it. The
            # scan reads task state without taking a remote rq lock — that is
            # safe for a "should I skip hlt" hint: a stale read only ever
            # causes a spurious extra loop, never a lost wakeup (a real
            # enqueue after this point raises the directed reschedule IPI,
            # held pending across the IF=0 window and fired by safe_halt's
            # atomic sti;hlt). Slot 0 (BSP task) is excluded — an AP never
            # runs it.
            local_irq_disable()
            woke: uint64 = 0
            # Track 5: "is any READY task pending (here or stealable elsewhere)?"
            # A non-empty run-list head on ANY CPU means dispatchable work
            # exists, so skip hlt and loop back. Walking the NR_RQ(16) heads is
            # O(NR_RQ), far cheaper than the old NTASKS scan. The idle slot is
            # STATE_RUNNING (off every list) so it never falsely triggers woke.
            if sched_ap_steal_enabled != 0:
                rq_c: uint64 = 0
                while rq_c < NR_RQ:
                    if rq_head[rq_c] != RQL_NIL:
                        woke = 1
                        rq_c = NR_RQ
                    rq_c = rq_c + 1
            # One-time-per-CPU banner: this AP idles via hlt + reschedule IPI.
            bit: uint64 = cast[uint64](1) << my_cpu_id
            if (_ap_idle_mode_logged & bit) == 0:
                _ap_idle_mode_logged = _ap_idle_mode_logged | bit
                printk1("SMP: cpu%d idle via hlt+ipi\n", my_cpu_id)
            # RCU: an idle CPU holds no rcu_read_lock — entering the idle/HLT
            # extended quiescent state is a QS for this CPU AND marks it out of
            # QS participation for any GP that starts while it is parked, so an
            # in-flight or future grace period (synchronize_rcu / call_rcu on
            # another CPU) is never stalled by an AP that has no context switches
            # to drive its QS while halted. rcu_idle_exit re-joins it on wake.
            rcu_idle_enter()
            cpu_idle_enter()
            if woke == 0:
                # QA-N32b SELF-HEALING BACKSTOP: an AP has no periodic LAPIC
                # tick — it normally sleeps until a directed reschedule IPI.
                # Arm THIS cpu's LAPIC one-shot for a short bounded deadline
                # before halting so the AP ALWAYS re-wakes and re-scans its
                # runqueue even if an IPI is somehow missed and even while the
                # BSP tick is momentarily quiescent. This is a purely LOCAL
                # LAPIC program (no global clockevent / hrtimer-queue mutation
                # — that is BSP-exclusive; APs skip the hrtimer hook in
                # arch/x86/kernel/time.ad), so it cannot corrupt shared timer
                # state or wedge the box the way the old NO_HZ global tick-stop
                # did (the long-parked #9 freeze). The backstop fire runs the
                # timer ISR on the AP (jiffies++, preempt), then we re-loop and
                # re-arm. Done with IRQs off so program + halt is atomic w.r.t.
                # a wakeup. No-op if the LAPIC timer is uncalibrated.
                lapic_timer_set_oneshot_ns(AP_IDLE_BACKSTOP_NS)
                # Provably idle with IRQs off: park until the reschedule IPI,
                # the local backstop one-shot, or any other interrupt fires.
                # safe_halt() is an atomic `sti; hlt`, so a resched IPI raised
                # after our re-scan but before the hlt is held pending and
                # wakes us immediately — no lost wakeup. On return IRQs are
                # enabled (iret restored IF=1); we re-disable below to balance
                # cpu_idle_leave's view.
                safe_halt()
                local_irq_disable()
            else:
                # A task appeared in the re-scan — skip hlt, re-enable IRQs,
                # and loop straight back to the top to dispatch it.
                local_irq_enable()
            cpu_idle_leave()
            # RCU: woke from idle — rejoin QS participation before the next loop
            # iteration can enter a reader.
            rcu_idle_exit()
            local_irq_enable()


def sched_prepare_ap_idle(cpu_id: uint64) -> int32:
    # Called by the BSP AFTER sched_init() to create the AP's idle kthread.
    # The slot is marked STATE_PARKED so:
    #   (a) the BSP's _pick_next() never schedules it (only picks STATE_READY),
    #   (b) _find_free_slot() never reclaims it (only claims STATE_FREE),
    #       preventing create_user_task from stealing the slot between this
    #       call and sched_ap_launch().
    # sched_ap_launch() (called by the AP when it observes ap_idle_slots[]
    # become non-zero) transitions it directly to STATE_RUNNING.
    # Returns the slot index, or -1 on OOM.
    #
    # Interrupt-disable window: kthread_create() leaves the slot STATE_READY;
    # we must flip it to STATE_PARKED before the BSP timer ISR can see it.
    # _wq_lock_irq() disables local interrupts (IRQ-safe global state lock) so
    # the timer ISR — which may enter the scheduler and take rq/wq locks —
    # cannot race us; a concurrently-firing IRQ that also takes the same lock
    # would deadlock since the ISR can't be preempted.
    _wq_lock_irq()
    slot: int32 = kthread_create(cast[uint64](&sched_ap_idle_loop), 0)
    if slot < 0:
        _wq_unlock_irq()
        printk1("SMP: sched_prepare_ap_idle cpu%d: no free slot\n", cpu_id)
        return -1
    su: uint64 = cast[uint64](slot)
    # kthread_create sets STATE_READY; park it so BSP can't schedule it
    # and create_user_task can't reclaim the slot.
    task_table[su].state = STATE_PARKED
    _wq_unlock_irq()
    # Record for sched_ap_launch to find.  Written AFTER the slot is safely
    # parked: the AP's spin loop reads ap_idle_slots[cpu_id] and enters the
    # kthread only once this write is visible (x86 TSO guarantees the store
    # to ap_idle_slots[] is seen by the AP after the STATE_PARKED write above).
    if cpu_id < AP_MAX_CPUS:
        ap_idle_slots[cpu_id] = su
    printk2("SMP: cpu%d idle kthread prepared (slot %d)\n", cpu_id,
            cast[uint64](slot))
    return slot


def sched_ap_launch(cpu_id: uint64):
    # Called by the AP itself after its %gs per-CPU area is set up.
    # Enters the AP's dedicated idle kthread via enter_first_task()
    # — from this call onward the AP is a full scheduler participant.
    # Never returns.
    #
    # The AP may arrive here BEFORE the BSP has called
    # sched_prepare_ap_idle() (which is deferred to after sched_init()
    # to avoid PID-counter collisions). Spin-wait with STI so the BSP
    # can make forward progress; the LAPIC timer is not armed on APs so
    # this is just a pause loop, not a nested interrupt.
    if cpu_id >= AP_MAX_CPUS:
        # Out-of-range CPU; park in HLT.
        asm_volatile("cli")
        while True:
            asm_volatile("hlt")
    # Wait until BSP has filled in our idle slot (after sched_init()).
    # Spin with cpu_relax (PAUSE) — no interrupts needed since the AP's
    # LAPIC timer is not armed and the poll is purely memory-based.
    while ap_idle_slots[cpu_id] == 0:
        cpu_relax()
    slot_u: uint64 = ap_idle_slots[cpu_id]
    # Diagnostic: confirm the AP exited the spin loop and is about to
    # launch its idle kthread.  This print happens from the AP's context
    # (after spin-wait exits but before enter_first_task switches stacks).
    printk2("SMP: cpu%d launching idle kthread slot=%d\n", cpu_id, slot_u)
    task_table[slot_u].state = STATE_RUNNING
    # on_cpu invariant: this AP's idle kthread becomes the live task here and
    # enter_first_task never returns to raise the fence later; raise it now.
    task_table[slot_u].on_cpu = 1
    current_idx_pcpu = slot_u
    # enter_first_task loads task->sp and tail-jumps into kthread_bootstrap
    # which iretqs into sched_ap_idle_loop.  Does not return.
    enter_first_task(cast[Ptr[uint8]](&task_table[slot_u]))


# SMAP v3f instrumentation: walk an arbitrary VA's PML4->PDPT->PD->PT
# chain under an EXPLICIT cr3 (NOT get_bsp_cr3 — must be the LIVE
# per-task PML4 about to be SYSRET'd under). printk0 every level so
# the trail survives a triple-fault on the very next instruction.
#
# Prints: PML4 entry, PDPT entry, PD entry (PS flag), PT entry, plus
# the AND-down "effective" US, RW, P, NX bits across all hierarchy
# levels actually walked.
#
# Used from start_first_task to inspect TSS.RSP0's leaf BEFORE SYSRETQ
# transitions to CPL=3 and the CPU starts pushing IRQ/EXC frames to
# that page from CPL=0. If the effective US ends up 1, that is the
# silent SMAP triple-fault site: a CPL=0 push from the CPU to a US=1
# page is exactly what CR4.SMAP=1 traps, the #PF handler entry then
# re-pushes to the same page, double-fault, triple-fault, CPU Reset.
def _smap_v3f_walk_tss_rsp0(cr3_live: uint64, kstack_top: uint64):
    PGT_ADDR_MASK_V3F: uint64 = 0x000FFFFFFFFFF000
    PGT_FLAG_P_V3F:    uint64 = 0x1
    PGT_FLAG_RW_V3F:   uint64 = 0x2
    PGT_FLAG_US_V3F:   uint64 = 0x4
    PGT_FLAG_PS_V3F:   uint64 = 0x80

    # CPU pushes the iret frame starting at TSS.RSP0 - 8 going down on
    # CPL=3 -> 0 entry. That's the page we MUST inspect, not the top.
    va: uint64 = kstack_top - 8
    printk2("[smap-v3f] walk cr3=%p tss_rsp0=%p\n", cr3_live, kstack_top)
    printk1("[smap-v3f] target va (first push) = %p\n", va)

    pml4_idx: uint64 = (va >> 39) & 0x1FF
    pdpt_idx: uint64 = (va >> 30) & 0x1FF
    pd_idx:   uint64 = (va >> 21) & 0x1FF
    pt_idx:   uint64 = (va >> 12) & 0x1FF
    printk2("[smap-v3f] idx: pml4=%d pdpt=%d\n", pml4_idx, pdpt_idx)
    printk2("[smap-v3f] idx: pd=%d pt=%d\n", pd_idx, pt_idx)

    pml4: uint64 = cr3_live & PGT_ADDR_MASK_V3F
    pml4_slot_addr: uint64 = pml4 + pml4_idx * 8
    pml4e: uint64 = cast[Ptr[uint64]](pml4_slot_addr)[0]
    printk2("[smap-v3f] PML4 base=%p slot=%p\n", pml4, pml4_slot_addr)
    printk1("[smap-v3f] PML4 entry = %p\n", pml4e)
    if (pml4e & PGT_FLAG_P_V3F) == 0:
        printk0("[smap-v3f] PML4 entry NOT PRESENT - aborting walk\n")
        return
    pml4_us: uint64 = (pml4e >> 2) & 0x1
    pml4_rw: uint64 = (pml4e >> 1) & 0x1
    printk2("[smap-v3f] PML4 US=%d RW=%d\n", pml4_us, pml4_rw)

    pdpt: uint64 = pml4e & PGT_ADDR_MASK_V3F
    pdpt_slot_addr: uint64 = pdpt + pdpt_idx * 8
    pdpte: uint64 = cast[Ptr[uint64]](pdpt_slot_addr)[0]
    printk2("[smap-v3f] PDPT base=%p slot=%p\n", pdpt, pdpt_slot_addr)
    printk1("[smap-v3f] PDPT entry = %p\n", pdpte)
    if (pdpte & PGT_FLAG_P_V3F) == 0:
        printk0("[smap-v3f] PDPT entry NOT PRESENT - aborting walk\n")
        return
    pdpt_us: uint64 = (pdpte >> 2) & 0x1
    pdpt_rw: uint64 = (pdpte >> 1) & 0x1
    printk2("[smap-v3f] PDPT US=%d RW=%d\n", pdpt_us, pdpt_rw)
    if (pdpte & PGT_FLAG_PS_V3F) != 0:
        eff_us: uint64 = pml4_us & pdpt_us
        eff_rw: uint64 = pml4_rw & pdpt_rw
        printk0("[smap-v3f] PDPT is 1G huge leaf\n")
        printk2("[smap-v3f] EFFECTIVE US=%d RW=%d (leaf=1G)\n",
                eff_us, eff_rw)
        return

    pd: uint64 = pdpte & PGT_ADDR_MASK_V3F
    pd_slot_addr: uint64 = pd + pd_idx * 8
    pde: uint64 = cast[Ptr[uint64]](pd_slot_addr)[0]
    printk2("[smap-v3f] PD base=%p slot=%p\n", pd, pd_slot_addr)
    printk1("[smap-v3f] PD entry = %p\n", pde)
    if (pde & PGT_FLAG_P_V3F) == 0:
        printk0("[smap-v3f] PD entry NOT PRESENT - aborting walk\n")
        return
    pd_us: uint64 = (pde >> 2) & 0x1
    pd_rw: uint64 = (pde >> 1) & 0x1
    printk2("[smap-v3f] PD US=%d RW=%d\n", pd_us, pd_rw)
    if (pde & PGT_FLAG_PS_V3F) != 0:
        eff_us2: uint64 = pml4_us & pdpt_us & pd_us
        eff_rw2: uint64 = pml4_rw & pdpt_rw & pd_rw
        printk0("[smap-v3f] PD is 2M huge leaf\n")
        printk2("[smap-v3f] EFFECTIVE US=%d RW=%d (leaf=2M)\n",
                eff_us2, eff_rw2)
        return

    pt: uint64 = pde & PGT_ADDR_MASK_V3F
    pt_slot_addr: uint64 = pt + pt_idx * 8
    pte: uint64 = cast[Ptr[uint64]](pt_slot_addr)[0]
    printk2("[smap-v3f] PT base=%p slot=%p\n", pt, pt_slot_addr)
    printk1("[smap-v3f] PT entry = %p\n", pte)
    if (pte & PGT_FLAG_P_V3F) == 0:
        printk0("[smap-v3f] PT entry NOT PRESENT - aborting walk\n")
        return
    pt_us: uint64 = (pte >> 2) & 0x1
    pt_rw: uint64 = (pte >> 1) & 0x1
    eff_us3: uint64 = pml4_us & pdpt_us & pd_us & pt_us
    eff_rw3: uint64 = pml4_rw & pdpt_rw & pd_rw & pt_rw
    printk2("[smap-v3f] PT US=%d RW=%d\n", pt_us, pt_rw)
    printk2("[smap-v3f] EFFECTIVE US=%d RW=%d (leaf=4K)\n",
            eff_us3, eff_rw3)
    if eff_us3 != 0:
        printk0("[smap-v3f] *** TSS.RSP0 effective US=1 — SMAP-HOT ***\n")
    else:
        printk0("[smap-v3f] TSS.RSP0 effective US=0 — SMAP-safe leaf\n")


def start_first_task(first_slot: uint64):
    # Bootstrap: dive into `first_slot` (the slot create_user_task
    # returned for /init). Never returns.
    #
    # HISTORICAL NOTE: this used to hard-code slot 0 on the assumption
    # that /init is always the first task created and therefore lands
    # in slot 0. That stopped being true once start_kernel began
    # calling sched_mark_boot_task_running() early (to keep schedule()
    # from halting when a boot-time .ko probe yields): that marks slot
    # 0 STATE_RUNNING, so _find_free_slot() then hands /init slot 1.
    # start_first_task kept diving into the all-zero slot 0 and the
    # SYSRETQ read a zero iret frame -> #DF before /init ever ran.
    # Taking the real slot as a parameter fixes that at the source.
    fs0: uint64 = first_slot
    # BOOT-FIRST-TASK RACE (#413): claim PID 1 as RUNNING on the BSP. It was
    # published STATE_EMBRYO at create time (boot_first_task_pending; see the
    # publish block in create_user_thread) precisely so that, during the
    # long boot window between its creation at boot:38 and this dispatch at
    # boot:42, the already-online idle AP could NOT work-steal it: EMBRYO tasks
    # are never linked onto a run-list, so neither _pick_next nor the work-steal
    # walk (both traverse rq_head[*] only) can see it. Without this it would be
    # STATE_READY + run-list-linked the whole time, the AP would steal it and
    # __switch_to into it off its planted bootstrap iret frame, PID 1 would run
    # its SYS_EXECVE on the AP and clobber the iret frame this function is about
    # to SYSRETQ off of -> garbage user RIP -> NX exec-fault in the kstack ->
    # pid-7 SIGSEGV (deterministic under -smp 2; the 1-CPU UEFI product path has
    # no AP and was always green). Flip EMBRYO -> RUNNING under the rq lock; the
    # _rq_list_remove is defensive (EMBRYO is already off every list).
    _rq_lock_cpu(get_cpu_id())
    _rq_list_remove(fs0)
    task_table[fs0].state = STATE_RUNNING
    task_table[fs0].rq_cpu = get_cpu_id()
    # on_cpu invariant (Linux rq->curr->on_cpu): fs0 becomes the live task on
    # this CPU NOW and runs via enter_first_task_sysret (which never returns
    # here and so cannot raise the fence later). Raise it here so the FIRST
    # time fs0 blocks (e.g. tcp_accept's wait) the sleep-window — from
    # STATE_WAIT until __switch_to_asm saves fs0->sp — is fenced. Without
    # this, fs0 runs its entire first life with on_cpu==0; a wakeup on another
    # CPU then dispatches it on a STALE sp while this CPU is still executing
    # it (two CPUs on one kstack -> the inbound-accept SMP crash). __switch_to_asm
    # clears it on the first switch-away; every later dispatch re-raises it.
    task_table[fs0].on_cpu = 1
    current_idx_pcpu = fs0
    _rq_unlock_cpu(get_cpu_id())
    # RETIRE THE PHANTOM BOOT TASK. sched_mark_boot_task_running()
    # marked slot 0 STATE_RUNNING during boot so a .ko-probe yield
    # wouldn't trip schedule()'s "no live tasks; halt". But slot 0 is
    # the boot/start_kernel context we are ABOUT to sysret away from
    # for good (enter_first_task_sysret never returns) — its
    # TaskStruct.sp was never built by _build_initial_kstack, so it is
    # NOT a resumable context. Leaving it STATE_RUNNING makes
    # _pick_next eligible to rotate into it the first time a spawned
    # child yields (e.g. hamsh spawning `ls`/`uname` then waitpid ->
    # yield_to_others -> schedule): __switch_to_asm would restore slot
    # 0's stale/zero sp and the box wedges on a dead context with no
    # trap. Marking it FREE here removes it from the runnable set; fs0
    # (/init) is the live RUNNING task we hand off to. Guard fs0 != 0
    # so the historical slot-0-is-init layout still works.
    #
    # CRITICAL (#switch-bad-sp): setting state = STATE_FREE is NOT enough.
    # During the boot window, a kthread preemption can run with slot 0 as
    # `prev` while it is STATE_RUNNING; schedule() then flips slot 0 to
    # STATE_READY and LINKS it onto rq_head via _rq_list_insert. _pick_next
    # walks rq_head by LIST MEMBERSHIP and does NOT re-check per-node state
    # ("every node on rq_head is, by construction, STATE_READY"). So a slot
    # left linked on the run-list is still dispatchable even after we flip
    # its state field to FREE — _pick_next picks slot 0, __switch_to_asm
    # does `mov (slot0.sp),%rsp` with sp==0 (never built by
    # _build_initial_kstack) -> #GP at the `ret` in __switch_to_asm
    # (rip in the switch tail, rsp=0x30). This is the deterministic
    # "stage-08 ed-readline-first" trap: it fires the first time the live
    # init/hamsh task BLOCKS (e.g. its first readline) with no other user
    # task ready, so schedule() rotates into the phantom boot slot.
    # UNLINK slot 0 from the run-list under the rq lock so _pick_next can
    # never see it again.
    if fs0 != 0:
        _rq_lock_cpu(get_cpu_id())
        _rq_list_remove(0)
        task_table[0].state = STATE_FREE
        _rq_unlock_cpu(get_cpu_id())
    # SMAP v3f: walk TSS.RSP0 chain under the LIVE (boot) CR3 FIRST,
    # then again under the per-task CR3 after load_cr3 below. The hang
    # is silent — emitting before tss_set_rsp0 confirms we got here and
    # surfaces the boot-PML4 view of the kstack leaf even when SMAP
    # triple-faults on the next moment.
    printk0("[smap-v3f] enter start_first_task (pre tss_set_rsp0)\n")
    printk2("[smap-v3f] fs0=%d kstack_top=%p\n",
            fs0, task_table[fs0].kstack_top)
    printk1("[smap-v3f] task.cr3 = %p\n", task_table[fs0].cr3)
    _smap_v3f_walk_tss_rsp0(get_bsp_cr3(), task_table[fs0].kstack_top)
    printk0("[smap-v3f] (above was BOOT CR3 view; now walking task CR3)\n")
    _smap_v3f_walk_tss_rsp0(task_table[fs0].cr3,
                            task_table[fs0].kstack_top)
    # v3f-2: also walk the boot CR3 ADDRESS itself under the TASK PML4.
    # If the per-task PML4 doesn't back the boot stack VA (~0x3e6XXXXX),
    # the `ret` after load_cr3 #PFs reading the saved RIP off the boot
    # stack and triple-faults. The boot CR3 phys is a nearby identity VA.
    printk0("[smap-v3f] now walking BOOT-CR3 VA under TASK PML4\n")
    _smap_v3f_walk_tss_rsp0(task_table[fs0].cr3, get_bsp_cr3() + 8)
    # v3f-2: walk a kernel high-half VA (start_first_task itself ~RIP)
    # under the TASK PML4 — that's where the next IFETCH lands after
    # load_cr3 returns.
    printk0("[smap-v3f] now walking KERNEL-HIGH VA under TASK PML4\n")
    _smap_v3f_walk_tss_rsp0(task_table[fs0].cr3, 0xffffffff80000000 + 8)
    printk0("[smap-v3f] walks done; calling tss_set_rsp0\n")
    tss_set_rsp0(task_table[fs0].kstack_top)
    printk0("[smap-v3f] tss_set_rsp0 returned; about to load_cr3\n")
    # Load the first task's page table — its PML4 has the same
    # mappings as BSP's but the address is different. CR3 must point
    # at the task's PML4 before its iretq-to-user runs, or else any
    # subsequent CR3 change in schedule() would TLB-flush relative
    # to the wrong root.
    if task_table[fs0].cr3 != 0:
        printk0("[smap-v3f] calling load_cr3 NOW\n")
        load_cr3(task_table[fs0].cr3)
        # If the next printk does not appear, the fault is in load_cr3
        # OR in this printk's data path under the new CR3. The previous
        # walker confirmed PML4[511] -> 1G huge leaf US=0 is the path to
        # kernel high half, which is where printk's text/data lives, so
        # the printk should resolve cleanly.
        printk0("[smap-v3f] load_cr3 returned\n")
        # Try a minimal write to low identity to confirm post-CR3 access
        # path. The first store the M16.156 mitigation makes is to
        # kstack_top - 24 (clear IF on iret frame) — under the task PML4
        # that's the same US=0 PT leaf we walked above.
        printk2("[smap-v3f] CR4=%p kstack-24=%p (about to deref)\n",
                read_cr4(), task_table[fs0].kstack_top - 24)
        _probe_val: uint64 = cast[Ptr[uint64]](
            task_table[fs0].kstack_top - 24)[0]
        printk1("[smap-v3f] kstack-24 read OK = %p\n", _probe_val)
    else:
        printk0("[smap-v3f] task.cr3==0 — SKIPPING load_cr3\n")
    # ---- M16.156: Asus real-hw triple-fault fix --------------------
    #
    # Three small mitigations applied before the SYSRETQ handoff. This
    # is the ACTUAL fix for the real-hw triple-fault that drove the
    # M16.153..M16.156 debugging arc:
    #
    #   (1) firmware-left FPU state can be inconsistent (denormal exc
    #       unmasked / stale tag word); the first user instr that
    #       implicitly touches the FPU could then raise #MF/#XF inside
    #       the SYSRETQ window. `fninit` resets the FPU to power-on
    #       defaults.
    #
    #   (2) CR4.OSXSAVE = 0 on a CPU that supports XSAVE
    #       (CPUID.01h:ECX bit 26) leaves the XCR0-driven SSE state
    #       path undefined. If XSAVE is advertised, set CR4.OSXSAVE
    #       (bit 18). Skip silently otherwise — setting it on a CPU
    #       without XSAVE would #GP.
    #
    #   (3) /init's planted iret frame wakes with IF=1 (RFLAGS=0x202);
    #       a timer IRQ / NMI in the SYSRETQ→first-ifetch window could
    #       push an iret frame onto an un-paged user stack. Rewrite the
    #       iret-frame RFLAGS slot (kstack_top - 24) to 0x002
    #       (IF=0, MBS=1). do_execve_finish hard-codes RFLAGS=0x202 on
    #       the SYSRETQ into hamsh, so the exec'd shell still sees a
    #       normal interrupt-enabled environment. The companion `cli`
    #       at the top of enter_first_task_sysret covers the BSP side.
    #
    # The RFLAGS rewrite is scoped to the first task's first transition
    # only: RFLAGS_INITIAL inside _build_initial_kstack keeps its 0x202
    # default, so every subsequent fork/exec/clone still uses IF=1.

    kstack_top0_mitig: uint64 = task_table[fs0].kstack_top

    # Mitigation 1: fninit.
    fninit_helper()

    # Mitigation 2: conditional CR4.OSXSAVE.
    cpuid_buf_mitig: Array[4, uint32]
    cpuid_get(cast[uint32](1), cast[uint32](0), &cpuid_buf_mitig[0])
    osxsave_ecx: uint64 = cast[uint64](cpuid_buf_mitig[2])
    xsave_supported: uint64 = (osxsave_ecx >> 26) & 0x1
    if xsave_supported != 0:
        cr4_before: uint64 = read_cr4()
        cr4_osxsave_before: uint64 = (cr4_before >> 18) & 0x1
        if cr4_osxsave_before == 0:
            cr4_new: uint64 = cr4_before | (cast[uint64](1) << 18)
            write_cr4(cr4_new)
        # XCR0: CR4.OSXSAVE only UNLOCKS XSETBV — it enables no state.
        # XCR0 powers up at 0x1 (x87 only), so SSE-via-XSAVE and AVX are
        # both off and any VEX-encoded (AVX) instruction #UDs. Real
        # Debian coreutils (wc, sort) and glibc's AVX memcpy/decompress
        # paths emit those on an AVX-advertising CPU and, with no
        # userspace SIGILL recovery, the #UD halts the kernel. Enable the
        # SSE (bit1) + AVX (bit2) state components. AVX is gated on
        # CPUID.01h:ECX bit 28 (setting XCR0.AVX without HW support #GPs).
        # Hamnix doesn't FX/XSAVE the vector file across context switches
        # (SSE state already isn't preserved), so this adds no save/
        # restore obligation — it only stops the #UD.
        avx_supported: uint64 = (osxsave_ecx >> 28) & 0x1
        xcr0_val: uint64 = 0x3                  # x87 | SSE
        if avx_supported != 0:
            xcr0_val = 0x7                      # x87 | SSE | AVX
        xsetbv_xcr0(xcr0_val)

    # Mitigation 3: clear IF in the iret-frame RFLAGS slot.
    cast[Ptr[uint64]](kstack_top0_mitig - 24)[0] = 0x002

    # M16.155: dispatch the first user task via SYSRETQ. The Asus
    # real-hw triple-fault that drove the M16.153..M16.156 debugging
    # arc is fixed; the M16.156 mitigations above (fninit, conditional
    # CR4.OSXSAVE, IF-cleared iret frame + the companion cli inside
    # enter_first_task_sysret) are the actual fix. To revert to the
    # IRETQ path swap the call below for enter_first_task(...) — both
    # helpers share the same %rdi=task_struct entry contract.
    enter_first_task_sysret(cast[Ptr[uint8]](&task_table[fs0]))


# --- helpers for syscall layer -------------------------------------

# Special fd_idx markers. Anything < these values is a real initramfs
# file index; the markers reserve the high quarter of the uint32 space.
FD_CLOSED_MARK: uint32 = 0xFFFFFFFF
FD_STDIN_MARK:  uint32 = 0xFFFFFFFC
FD_STDOUT_MARK: uint32 = 0xFFFFFFFE
FD_STDERR_MARK: uint32 = 0xFFFFFFFD
# Phase 4b: FD_BUFFER_MARK is RETIRED AS AN FD MARKER — NOTHING stamps
# it into task.fd_idx[] anymore. A rendered-snapshot fd (procfs / cgroup
# / sysctl text, rendered once into a kmalloc'd buffer at open time) is
# now a unified FD_CHAN_MARK fd backed by a DEV_BUF_FILE pool chan
# (sys/src/9/port/namec.ad); the buffer kfree lives in namec_close's
# DEV_BUF_FILE arm, so fork/dup refcount the shared chan and only the
# LAST close frees the snapshot. The CONSTANT survives ONLY as the
# opaque backing-kind TAG vfs_fd_backing_info() hands to the fd-less
# mmap path (vfs_pread_backing / vfs_pwrite_backing dispatch on it).
FD_BUFFER_MARK: uint32 = 0xFFFFFFFB
# FD_TMPFS_MARK fds reference a persistent in-memory tmpfs entry by
# slot index, stored in fd_buf (re-purposed as the slot id). Unlike
# a snapshot buffer, fd_buf is NOT a pointer here and is never kfreed
# at close — the tmpfs entry outlives the fd.
FD_TMPFS_MARK:  uint32 = 0xFFFFFFFA
# Phase 4c: FD_PIPE_MARK_R (0xFFFFFFF9) / FD_PIPE_MARK_W (0xFFFFFFF8)
# are DELETED. A pipe end is a unified FD_CHAN_MARK fd backed by a
# DEV_PIPE_R / DEV_PIPE_W pool chan (back_slot = fs/pipe.ad ring slot);
# blocking read/write live in pipe_read_blocking / pipe_write_blocking
# dispatched from namec_read / namec_write, and the end-refcount
# release runs in namec_close's DEV_PIPE arms on the LAST chan ref.
# The 0xFFFFFFF9 / 0xFFFFFFF8 values are free for reuse.
# fd→Chan fold: FD_FAT_MARK / FD_EXT4_MARK are RETIRED AS FD MARKERS —
# NOTHING stamps them into task.fd_idx[] anymore. An on-disk FAT / ext4
# regular-file fd is now a unified FD_CHAN_MARK fd backed by a
# DEV_FAT_FILE / DEV_EXT4_FILE pool chan (sys/src/9/port/namec.ad); its
# fat_close / ext4_close release lives in namec_close (the
# CHAN_MARK_VALUE arm of close_fd_in_task below), so an exiting task no
# longer leaks its fs slot and fork/dup refcount the shared chan.
#
# The two CONSTANTS survive ONLY as opaque "backing-kind" TAGS for the
# fd-LESS file-backed-mmap path: vfs_fd_backing_info() / vfs_resolve_
# backing() hand back FD_EXT4_MARK as the (marker, backing, size) triple's
# marker so vfs_pread_backing / vfs_pwrite_backing can route an inum-
# addressed read/write with no fd or chan in hand (the #PF / msync /
# munmap writeback path, which must work after the fd is closed). They are
# NO LONGER fd-table sentinels — keeping the values lets the marker-
# uniqueness guard verify they still don't collide with a live fd marker.
FD_FAT_MARK:    uint32 = 0xFFFFFFDE
FD_EXT4_MARK:   uint32 = 0xFFFFFFF6
# Phase 4b: FD_DIR_MARK (0xFFFFFFF3) is DELETED. An opened-as-fd
# directory is a unified FD_CHAN_MARK fd backed by a DEV_DIR_FILE pool
# chan whose back_ptr holds the kmalloc'd "NAME\n" listing (kfreed by
# namec_close's DEV_DIR_FILE arm on last ref). The 0xFFFFFFF3 value is
# free for reuse.
# Phase 4c (socket fold): FD_SOCKET_MARK (0xFFFFFFF2) is DELETED. A
# socket(2) fd is a unified FD_CHAN_MARK fd backed by a DEV_SOCKET pool
# chan whose back_slot carries the legacy fd_buf encoding (usock rec+1 /
# AF_UNIX tag / netlink tag / 0 = no record yet); read/write/close
# dispatch through namec's DEV_SOCKET arms into the by-name
# vfs_socket_chan_* bodies in fs/vfs.ad. FD_SOCKETPAIR_MARK
# (0xFFFFFFE2, fs/socketpair.ad) is gone the same way (DEV_SOCKETPAIR,
# one chan per end). The 0xFFFFFFF2 value is free for reuse.
# RETIRED (namespace-purity Phase 4): the stateless local cdev marks
# FD_CONS_MARK (0xF1), FD_TIME_MARK (0xF0), FD_PID_MARK (0xEF),
# FD_RANDOM_MARK (0xEE), FD_MOUSE_MARK (0xED), FD_CPUINFO_MARK (0xEC),
# FD_MEMINFO_MARK (0xEB), FD_UPTIME_MARK (0xEA), FD_LOADAVG_MARK (0xE9),
# FD_VERSION_MARK (0xE8), FD_HOSTNAME_MARK (0xE7) and the /dev/null +
# /dev/zero marks FD_DEVNULL_MARK (0xF5) / FD_DEVZERO_MARK (0xF4) no
# longer exist. /dev/cons, /dev/time, ... /dev/null and /dev/zero are
# all stateless namec devtab cdevs now: they open as FD_CHAN_MARK fds
# carrying an INLINE chan id (CHAN_INLINE_TAG | DEV_<x>) and dispatch
# once through namec_read/write/close → _devtab_read/_devtab_write. The
# 0xE7..0xF1 + 0xF4..0xF5 values in this range are free for reuse. See
# sys/src/9/port/namec.ad (DEV_* devtab) and fs/vfs.ad (FD_CHAN_MARK).
#
# fd→Chan unification: close_fd_in_task must release an FD_CHAN_MARK fd
# through namec_close so an FD_CHAN_MARK fd held at TASK EXIT (where the
# exit path runs task_close_all_fds → close_fd_in_task, NOT vfs_close)
# releases its pool chan instead of leaking it. The CANONICAL definition
# of FD_CHAN_MARK lives in sys/src/9/port/namec.ad (0xFFFFFFE0); core.ad
# cannot `import` namec (core → namec → 9p_client → core is an import
# CYCLE), and it cannot REDEFINE the `FD_CHAN_MARK : uint32 = ...` token
# (the marker-uniqueness static check would then see two definitions of
# the same value and FAIL). So we mirror the VALUE under a deliberately
# non-`FD_*_MARK`-shaped name the static check does not scan, and call
# namec_close BY NAME (the whole-kernel Adder merge resolves undeclared
# calls across the flat merge without an import edge).
CHAN_MARK_VALUE: uint32 = 0xFFFFFFE0


def current_task_pid() -> uint64:
    return task_table[current_idx_pcpu].pid


def current_idx_get() -> uint64:
    # Accessor for the running task's slot index. Used by the
    # syscall layer when it needs the index (not the pointer or pid)
    # for CWD-related operations on the current task.
    # SMP: returns the per-CPU current slot for THIS CPU's running task.
    return current_idx_pcpu


def register_cleartid_wake_hook(hook: Fn[int32, uint64]):
    # Layer 2 (linux_abi/u_syscalls.ad) calls this once during kernel
    # bring-up to install its futex-wake routine as the exit-time
    # CLEARTID wake callback. task_exit_current invokes it through the
    # `cleartid_wake_hook` pointer instead of naming `futex_wake_all`
    # directly — that keeps the futex wait-queue table, and the whole
    # futex contract, confined to Layer 2 while still letting a Linux
    # pthread's exit unblock its joiner. A native-only build never
    # calls this, so the hook stays null and the CLEARTID path is inert.
    cleartid_wake_hook = hook


def register_umdf_task_exit_hook(hook: Fn[None, uint64]):
    # Layer 2 (linux_abi/umdf_kernel.ad via loader_init) installs its
    # UMDF per-task cleanup routine here so the scheduler's exit path can
    # reclaim a crashed/exited driver host's IRQ files + DMA buffers
    # without Layer 1 naming the UMDF module. Native-only build: null hook,
    # inert.
    umdf_task_exit_hook = hook


def current_task_is_user() -> uint64:
    return task_table[current_idx_pcpu].is_user


def current_task() -> Ptr[TaskStruct]:
    return &task_table[current_idx_pcpu]


# --- scoped KERNEL_DS uaccess mode (set_fs(KERNEL_DS) analog) -----------
#
# The boot self-test harness (init/main.ad) drives the Linux-ABI syscall
# handlers IN-KERNEL with KERNEL-mapped (US=0) stack buffers standing in
# for the user pointer. Under CR4.SMAP the strict US-bit check in
# uaccess_resolve correctly rejects such pointers for REAL syscalls, but
# would wrongly EFAULT these in-kernel tests. These helpers bracket the
# handler calls so uaccess accepts kernel pages ONLY inside the bracket.
# A real userspace syscall never enters this bracket, so SMAP is unchanged.
def uaccess_kernel_begin():
    t: Ptr[TaskStruct] = current_task()
    if t != cast[Ptr[TaskStruct]](0):
        t.uaccess_kernel = t.uaccess_kernel + 1


def uaccess_kernel_end():
    t: Ptr[TaskStruct] = current_task()
    if t != cast[Ptr[TaskStruct]](0):
        if t.uaccess_kernel != 0:
            t.uaccess_kernel = t.uaccess_kernel - 1


def uaccess_kernel_active() -> uint64:
    # 1 iff the current task is inside a uaccess_kernel_begin/end bracket.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    if t.uaccess_kernel != 0:
        return 1
    return 0


def current_task_account_tick(user_ctx: uint64):
    # getrusage(2): charge one timer tick to the currently-running task.
    # Called from the timer ISR (arch/x86/kernel/time.ad) every tick.
    # user_ctx == 1 ⇒ the tick caught ring-3 (userland) code → user time;
    # otherwise it's kernel/IRQ context → system time. current_task()
    # always returns a valid task_table row (never null), but guard
    # anyway to match the sentinel style of other accessors.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return
    if user_ctx == 1:
        t[0].utime_ticks = t[0].utime_ticks + 1
    else:
        t[0].stime_ticks = t[0].stime_ticks + 1


def current_task_utime_ticks() -> uint64:
    # getrusage(2): user-mode tick count accrued by the current task.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].utime_ticks


def current_task_stime_ticks() -> uint64:
    # getrusage(2): system-mode tick count accrued by the current task.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].stime_ticks


def current_task_cutime_ticks() -> uint64:
    # times(2) tms_cutime: accumulated user ticks of all reaped children.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].cutime_ticks


def current_task_cstime_ticks() -> uint64:
    # times(2) tms_cstime: accumulated system ticks of all reaped children.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].cstime_ticks


def current_task_cminflt() -> uint64:
    # getrusage(2) RUSAGE_CHILDREN: accumulated minor faults of all reaped
    # children (whole subtree), rolled up at child reap.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].cminflt


def current_task_cmajflt() -> uint64:
    # getrusage(2) RUSAGE_CHILDREN: accumulated major faults of all reaped
    # children (whole subtree), rolled up at child reap.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].cmajflt


def current_task_account_minor_fault():
    # Page-fault handler charges a resolved-without-disk-I/O fault
    # (demand-zero / COW) to the current task. current_task() never
    # returns null in practice; guard anyway to match the accessors.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].minflt = t[0].minflt + 1


def current_task_account_major_fault():
    # Page-fault handler charges a backing-store / swap-in fault
    # (required disk I/O) to the current task.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].majflt = t[0].majflt + 1


def current_task_minflt() -> uint64:
    # getrusage(2): minor (no-I/O) page-fault count for the current task.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].minflt


def current_task_majflt() -> uint64:
    # getrusage(2): major (I/O) page-fault count for the current task.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].majflt


def task_struct_at(slot: int32) -> Ptr[TaskStruct]:
    # V4: addressable accessor for the per-slot TaskStruct. Used by
    # sys_srv_open (276) to call copy_fd_entry from the poster's
    # task_table row into the caller's fd table without making
    # task_table itself public. Out-of-range slots return 0 (NULL);
    # the only caller today checks for that before dereferencing.
    su: uint64 = cast[uint64](slot)
    if slot < 0 or su >= NTASKS:
        return cast[Ptr[TaskStruct]](0)
    return &task_table[su]


def task_utime_ticks_at(slot: int32) -> uint64:
    # /proc/<pid>/stat field 14: user-mode tick count for the task in `slot`.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].utime_ticks


def task_stime_ticks_at(slot: int32) -> uint64:
    # /proc/<pid>/stat field 15: system-mode tick count for the task in `slot`.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].stime_ticks


def task_minflt_at(slot: int32) -> uint64:
    # /proc/<pid>/stat field 10: minor page-fault count for `slot`.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].minflt


def task_majflt_at(slot: int32) -> uint64:
    # /proc/<pid>/stat field 12: major page-fault count for `slot`.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].majflt


def task_cutime_ticks_at(slot: int32) -> uint64:
    # /proc/<pid>/stat field 16 (cutime): accumulated user ticks of `slot`'s
    # reaped children (whole subtree, RUSAGE_CHILDREN).
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].cutime_ticks


def task_cstime_ticks_at(slot: int32) -> uint64:
    # /proc/<pid>/stat field 17 (cstime): accumulated system ticks of `slot`'s
    # reaped children (whole subtree, RUSAGE_CHILDREN).
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].cstime_ticks


def task_cminflt_at(slot: int32) -> uint64:
    # /proc/<pid>/stat field 11 (cminflt): accumulated minor faults of `slot`'s
    # reaped children (whole subtree, RUSAGE_CHILDREN).
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].cminflt


def task_cmajflt_at(slot: int32) -> uint64:
    # /proc/<pid>/stat field 13 (cmajflt): accumulated major faults of `slot`'s
    # reaped children (whole subtree, RUSAGE_CHILDREN).
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].cmajflt


def task_set_cutime_ticks_at(slot: int32, v: uint64):
    # Direct set for child-cutime (used by childacct_selftest). Bounds-checked.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].cutime_ticks = v


def task_set_cstime_ticks_at(slot: int32, v: uint64):
    # Direct set for child-cstime (used by childacct_selftest). Bounds-checked.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].cstime_ticks = v


def task_set_cminflt_at(slot: int32, v: uint64):
    # Direct set for child-cminflt (used by childacct_selftest). Bounds-checked.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].cminflt = v


def task_set_cmajflt_at(slot: int32, v: uint64):
    # Direct set for child-cmajflt (used by childacct_selftest). Bounds-checked.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].cmajflt = v


def task_inblock_at(slot: int32) -> uint64:
    # getrusage(2) ru_inblock / /proc/<pid>/io read_bytes source: count of
    # 512-byte block-device reads attributed to `slot`. Bounds-checked.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].inblock


def task_oublock_at(slot: int32) -> uint64:
    # getrusage(2) ru_oublock / /proc/<pid>/io write_bytes source: count of
    # 512-byte block-device writes attributed to `slot`. Bounds-checked.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].oublock


def task_set_inblock_at(slot: int32, v: uint64):
    # Direct set for inblock (used by procio_selftest to make read_bytes
    # checkable). Bounds-checked.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].inblock = v


def task_set_oublock_at(slot: int32, v: uint64):
    # Direct set for oublock (used by procio_selftest to make write_bytes
    # checkable). Bounds-checked.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].oublock = v


def task_rchar_at(slot: int32) -> uint64:
    # /proc/<pid>/io rchar: total bytes returned by all read()-family
    # syscalls for `slot`. Bounds-checked.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].rchar


def task_wchar_at(slot: int32) -> uint64:
    # /proc/<pid>/io wchar: total bytes consumed by all write()-family
    # syscalls for `slot`. Bounds-checked.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].wchar


def task_syscr_at(slot: int32) -> uint64:
    # /proc/<pid>/io syscr: count of read() syscall invocations for `slot`.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].syscr


def task_syscw_at(slot: int32) -> uint64:
    # /proc/<pid>/io syscw: count of write() syscall invocations for `slot`.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].syscw


def task_set_rchar_at(slot: int32, v: uint64):
    # Direct set for rchar (used by procio_selftest). Bounds-checked.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].rchar = v


def task_set_wchar_at(slot: int32, v: uint64):
    # Direct set for wchar (used by procio_selftest). Bounds-checked.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].wchar = v


def task_set_syscr_at(slot: int32, v: uint64):
    # Direct set for syscr (used by procio_selftest). Bounds-checked.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].syscr = v


def task_set_syscw_at(slot: int32, v: uint64):
    # Direct set for syscw (used by procio_selftest). Bounds-checked.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].syscw = v


def current_task_charge_read(nbytes: uint64):
    # /proc/<pid>/io: charge ONE read() syscall to the current task — bump
    # syscr by 1 and rchar by the bytes returned. Called from _u_read's tail.
    # Current-task (not slot-indexed): I/O is attributed to whoever issued the
    # syscall. Early-boot null guard like the block-I/O charge helpers.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].syscr = t[0].syscr + 1
    t[0].rchar = t[0].rchar + nbytes


def current_task_charge_write(nbytes: uint64):
    # /proc/<pid>/io: charge ONE write() syscall to the current task — bump
    # syscw by 1 and wchar by the bytes consumed. Called from _u_write's tail.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].syscw = t[0].syscw + 1
    t[0].wchar = t[0].wchar + nbytes


def task_maxrss_kb_at(slot: int32) -> uint64:
    # getrusage(2) ru_maxrss (0x20): peak resident set size in KB for `slot`.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].maxrss_kb


def task_set_maxrss_kb_at(slot: int32, kb: uint64):
    # Store the ru_maxrss high-water for `slot`. _u_getrusage only ever
    # calls this with a value >= the current one (monotonic), so the field
    # never decrements. Bounds-check like the other task_*_at accessors.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].maxrss_kb = kb


def task_start_jiffies_at(slot: int32) -> uint64:
    # /proc/<pid>/stat field 22 (starttime): creation jiffy for `slot`.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].start_jiffies


def task_set_start_jiffies_at(slot: int32, v: uint64):
    # Store the creation jiffy for `slot`. Used by the deterministic
    # starttime self-test. Bounds-check like the other task_*_at accessors.
    t: Ptr[TaskStruct] = task_struct_at(slot)
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].start_jiffies = v


def task_account_voluntary_ctxsw_at(slot: uint64):
    # schedule() charges the OUTGOING task a voluntary context switch when
    # prev had already cleared its RUNNING state before yielding. SLOT-
    # indexed (NOT current-task) because at the charge point current_idx
    # has already advanced to the next task. Bounds-check like the other
    # task_*_at accessors.
    if slot >= NTASKS:
        return
    task_table[slot].nvcsw = task_table[slot].nvcsw + 1


def task_account_involuntary_ctxsw_at(slot: uint64):
    # schedule() charges the OUTGOING task an involuntary context switch
    # when prev was still RUNNING and got preempted. SLOT-indexed for the
    # same reason as the voluntary helper above.
    if slot >= NTASKS:
        return
    task_table[slot].nivcsw = task_table[slot].nivcsw + 1


def task_account_signal_at(slot: uint64):
    # signal_post charges the TARGET task exactly one delivered signal at
    # the latch site (the final sig_pending |= bit store). SLOT-indexed
    # (NOT current-task) because a signal is delivered to an arbitrary
    # target task, not necessarily the one currently running. Bounds-check
    # like the other task_*_at accessors.
    if slot >= NTASKS:
        return
    task_table[slot].nsignals = task_table[slot].nsignals + 1


def current_task_nvcsw() -> uint64:
    # getrusage(2): voluntary context-switch count for the current task.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].nvcsw


def current_task_nivcsw() -> uint64:
    # getrusage(2): involuntary context-switch count for the current task.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].nivcsw


def current_task_account_inblock(n: uint64):
    # Block layer charges the CALLING (current) task `n` 512-byte block
    # reads at the I/O completion site (blk_read_sectors). CURRENT-task
    # (not slot-indexed): I/O is attributed to whoever issued the request.
    # Runs from the block layer which can be entered very early, so null-
    # check the current task and do nothing if there isn't one yet.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].inblock = t[0].inblock + n


def current_task_account_oublock(n: uint64):
    # Block layer charges the CALLING (current) task `n` 512-byte block
    # writes at the I/O completion site (blk_write_sectors). Same current-
    # task attribution and early-boot null guard as the inblock helper.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return
    t[0].oublock = t[0].oublock + n


def current_task_inblock() -> uint64:
    # getrusage(2): 512-byte block-read count for the current task.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].inblock


def current_task_oublock() -> uint64:
    # getrusage(2): 512-byte block-write count for the current task.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].oublock


def current_task_nsignals() -> uint64:
    # getrusage(2): count of signals delivered to the current task.
    t: Ptr[TaskStruct] = current_task()
    if t == cast[Ptr[TaskStruct]](0):
        return 0
    return t[0].nsignals


def task_pml4(slot: int32) -> uint64:
    # Caller-side accessor — saves init/main.ad from poking
    # task_table directly across the module boundary.
    return task_table[cast[uint64](slot)].cr3


def set_task_cr3(slot: int32, cr3: uint64):
    # Point a task at an existing PML4 — a PLAIN store, nothing more.
    #
    # HISTORY / WARNING: the CLONE_VM thread path in do_clone and
    # _rfork_thread (RFMEM) used to create a thread with a fresh
    # boot-clone PML4 and then repoint it here at the creator's. That
    # design is GONE — create_user_thread now takes share_cr3 and the
    # thread's cr3 is correct before the slot is ever visible. Do NOT
    # resurrect a "free the old PML4 here" optimization: between the
    # old READY publish and this store, another CPU's steal/pull
    # dispatcher could already be RUNNING the task on its old cr3 (an
    # IRQ mask on the creating CPU does not stop that), so freeing the
    # old page froze a live CR3 -> reallocated + scribbled page tables
    # -> garbage PTEs (#DF at load_cr3+0x3 / bogus swap-entry PTE
    # "swap-in OOM" halts).
    #
    # Sharing a PML4 across slots is safe because task_reap's
    # shared-address-space guard tears the mm down only when the LAST
    # non-FREE slot referencing the cr3 is reaped — no double-free /
    # use-after-free whatever order the thread and its creator exit in.
    su: uint64 = cast[uint64](slot)
    task_table[su].cr3 = cr3


def task_kstack_top(slot: int32) -> uint64:
    # U39 diag accessor — exposes the freshly-built iret frame top so
    # SYS_SPAWN can sanity-check the planted RIP/RSP without poking
    # task_table directly.
    return task_table[cast[uint64](slot)].kstack_top


def task_lookup_by_pid(pid: uint64) -> int32:
    # Track 5: O(1) lookup via the open-addressed pid->slot hash, with a
    # linear-scan FALLBACK so a maintenance gap (a missed _task_set_pid /
    # _task_clear_pid) can never break /proc, waitpid, note/signal delivery
    # or reap parent-roll-up — it only loses the speed-up. The hash maps
    # pid -> slot; we VALIDATE the hit (slot in range, .pid matches, not
    # FREE) before trusting it, because a recycled slot or a tombstone race
    # could otherwise return a stale mapping.
    #
    # pid 0 special case: the pid hash never stores pid 0 (it is the EMPTY
    # sentinel), but the legacy linear scan matched `pid==0 && state!=FREE`
    # and returned the boot task (slot 0, pid 0). Preserve that EXACT legacy
    # behaviour — some orphan-reparent / roll-up paths look up parent_pid 0.
    if pid == 0:
        if task_table[0].state != STATE_FREE:
            return 0
        return -1
    # RCU READ-SIDE SECTION. This is the canonical lock-free task-list reader
    # (/proc, kill, waitpid, note/signal delivery all resolve a pid through
    # here). rcu_read_lock() bounds the traversal so a concurrent task_reap
    # cannot RCU-free + recycle a slot we are mid-read of: the deferred
    # _task_slot_rcu_free runs only after this section ends (a grace period).
    # We therefore observe each slot's (pid, state) as a consistent pair —
    # never a torn pid from a slot reclaimed and re-created under us.
    rcu_read_lock()
    found: int32 = -1
    hs: int32 = _pidh_get(pid)
    if hs >= 0:
        hsu: uint64 = cast[uint64](hs)
        if hsu < NTASKS and task_table[hsu].pid == pid \
           and task_table[hsu].state != STATE_FREE:
            found = hs
    if found < 0:
        # Fallback / self-heal: linear scan. Re-insert the correct mapping so
        # the next lookup is O(1) again.
        i: uint64 = 0
        while i < NTASKS:
            if task_table[i].pid == pid and task_table[i].state != STATE_FREE:
                _pidh_insert(pid, i)
                found = cast[int32](i)
                i = NTASKS
            else:
                i = i + 1
    rcu_read_unlock()
    return found


def task_state(slot: int32) -> uint64:
    return task_table[cast[uint64](slot)].state


# Job control: is the task stopped, and which signal stopped it?
def task_is_stopped(slot: int32) -> int32:
    if task_table[cast[uint64](slot)].state == STATE_STOPPED:
        return 1
    return 0


def task_stop_sig(slot: int32) -> uint64:
    return task_table[cast[uint64](slot)].stop_sig


# Job control: read-and-clear the "I was continued and the parent
# hasn't seen it yet" flag. SYS_WAITPID's status encoder uses this to
# emit a WIFCONTINUED-shape report exactly once per resume.
def task_take_cont_pending(slot: int32) -> int32:
    su: uint64 = cast[uint64](slot)
    v: uint64 = task_table[su].cont_pending
    task_table[su].cont_pending = 0
    if v != 0:
        return 1
    return 0


def task_exit_code(slot: int32) -> int64:
    return task_table[cast[uint64](slot)].exit_code


def _pt_subtable_phys_ok(phys: uint64) -> int32:
    # Validity gate for a physical address the page-table teardown walk
    # is about to TREAT AS A PAGE-TABLE PAGE (descend into) or FREE.
    #
    # Every PDPT/PD/PT page and every leaf frame the kernel ever maps was
    # handed out by alloc_page()/alloc_pages()/region_alloc — all of which
    # ultimately carve from memblock, whose RAM window is bounded BELOW by
    # the page allocator's floor (kernel_image_end(), set by e820_init —
    # e.g. ~0x05aec000 in QEMU) and ABOVE by memblock_region_top(). A real
    # entry's masked physical base is ALWAYS page-aligned and inside
    # [floor, top).
    #
    # A teardown walk that blindly trusts page-table memory is fragile:
    # if a single page-table page is corrupted (a stray kernel write lands
    # in it), the walk reads bogus "entries" and tries to descend into /
    # free WILD addresses — e.g. a leaf-like value pointing at physical
    # 0x1000 (real-mode IVT/BIOS), at a sub-floor address (0x103000), or
    # at a userspace virtual address (0x5555_6000_0000). Descending into
    # the BIOS reads more garbage; freeing a non-canonical address makes
    # free_pages' free-list store `*addr = head` raise #GP and halt the
    # kernel during process teardown.
    #
    # The correct invariant — not a symptom mask — is that the kernel
    # NEVER wrote a page-table entry pointing outside managed RAM. So any
    # masked address that is below the allocator floor or at/above the RAM
    # top is provably NOT a kernel-owned table/frame and MUST be skipped.
    # This bounds-validates the walk at every level (PML4->PDPT->PD->PT)
    # and at each leaf free, so a corrupted table can at worst leak a few
    # real pages — never fault. kernel_image_end() is the stable floor:
    # the live memblock cursor advances on every alloc and so can't serve.
    if phys == 0:
        return 0
    if (phys & 0xFFF) != 0:                  # not page-aligned -> not a table
        return 0
    floor: uint64 = kernel_image_end()
    if floor != 0 and phys < floor:
        return 0
    top: uint64 = memblock_region_top()
    if top != 0 and phys >= top:
        return 0
    return 1


def _free_task_user_pagetables(su: uint64):
    # Free the PRIVATE lower-level page tables this task cracked into
    # its per-task PML4 (the PDPT/PD/PT pages elf_install_user_mapping
    # allocated). We walk only the USER half (PML4 indices 0..255) and
    # free a sub-table page ONLY when this task's PML4 entry differs
    # from the pristine boot PML4's entry at that index — i.e. it is a
    # private clone, not the still-shared boot table. The leaf data
    # pages (the ELF image region + the user stack) are freed
    # separately via region_free / free_pages, so here we free table
    # pages only, never leaf frames.
    #
    # Every descend / free is gated on _pt_subtable_phys_ok: a real
    # page-table entry the kernel itself wrote ALWAYS points at a
    # page-aligned physical page inside managed RAM. An entry that does
    # not (a malformed identity leaf mapping phys 0, a stray sub-megabyte
    # value, a userspace VA from a corrupted slot, an unaligned blob) is
    # NOT a kernel table/frame and is skipped — so a corrupted table page
    # can never make the walk descend into the BIOS or free a wild,
    # non-canonical address and #GP-halt the kernel during teardown.
    cr3: uint64 = task_table[su].cr3
    if cr3 == 0:
        return
    boot_cr3: uint64 = cow_boot_cr3()
    if boot_cr3 == 0:
        return
    PT_ADDR: uint64 = 0x000FFFFFFFFFF000
    PT_PS:   uint64 = 0x80
    PT_P:    uint64 = 0x1
    pml4: Ptr[uint64] = cast[Ptr[uint64]](cr3 & PT_ADDR)
    bpml4: Ptr[uint64] = cast[Ptr[uint64]](boot_cr3 & PT_ADDR)
    # UEFI-high-RAM guard: this walk dereferences the EXITING task's PDPT/
    # PD/PT pages via raw physical pointers, but it runs in the PARENT's
    # context (the parent's CR3 is live). On a UEFI boot with several
    # hundred MiB of RAM those table pages can land HIGH (~1 GiB), and the
    # parent's CRACKED CR3 may have dropped the identity entry for that
    # chunk (observed: #PF cr2=0x3e63a000 here during task_reap of an
    # exited child). The PRISTINE boot CR3 identity-maps ALL of RAM by
    # construction, so run the pure-physical walk under it and restore the
    # caller's CR3 after. free_page only touches the higher-half buddy
    # metadata (mapped in the boot CR3 too), so the switch is safe.
    _ftp_live_cr3: uint64 = read_cr3()
    _ftp_irq: uint64 = local_irq_save()
    load_cr3(boot_cr3)
    # [cr3-sync] structural assert: a per-task PML4's KERNEL half
    # (slots 256..511) must still be ENTRY-IDENTICAL to the pristine
    # boot PML4 — task PML4s are memcpy-cloned from it at creation and
    # no path may crack or add a kernel-half PML4 entry per-task
    # (module_map and the MMIO-UC splits mutate the SHARED lower-level
    # PDPT/PD pages, never a PML4 slot, so they propagate to every
    # clone). Divergence means some new code built a kernel-half entry
    # behind the clones' back — the classic Linux vmalloc_fault bug
    # shape: every OTHER task's PML4 (and every future clone) lacks the
    # entry, and the first load_cr3 into one of those #DFs on the
    # unmapped fetch of load_cr3's `ret`. Make it loud the moment it
    # happens instead of crashing later.
    ksync: uint64 = 256
    while ksync < 512:
        if pml4[ksync] != bpml4[ksync]:
            # NOTICE level: must surface on the live serial console even
            # after console_set_interactive() tightens the gate to INFO —
            # this fires once and then the system likely #DFs.
            printk_set_level(PRINTK_LEVEL_NOTICE)
            printk2("[cr3-sync] WARNING: task PML4 kernel-half slot %d diverges from boot (entry=%p)\n",
                    ksync, pml4[ksync])
            ksync = 512
        else:
            ksync = ksync + 1
    li: uint64 = 0
    while li < 256:
        e: uint64 = pml4[li]
        be: uint64 = bpml4[li]
        # Private PDPT for this task? (present, not the shared boot entry,
        # and pointing at a real in-RAM page-aligned sub-table page).
        if (e & PT_P) != 0 and e != be \
                and _pt_subtable_phys_ok(e & PT_ADDR) != 0:
            pdpt_phys: uint64 = e & PT_ADDR
            bpdpt_phys: uint64 = be & PT_ADDR
            pdpt: Ptr[uint64] = cast[Ptr[uint64]](pdpt_phys)
            bpdpt: Ptr[uint64] = cast[Ptr[uint64]](bpdpt_phys)
            pi: uint64 = 0
            while pi < 512:
                pe: uint64 = pdpt[pi]
                bpe: uint64 = 0
                if (be & PT_P) != 0:
                    bpe = bpdpt[pi]
                # A private, present, non-1GiB PD page in real RAM?
                if (pe & PT_P) != 0 and (pe & PT_PS) == 0 and pe != bpe \
                        and _pt_subtable_phys_ok(pe & PT_ADDR) != 0:
                    pd_phys: uint64 = pe & PT_ADDR
                    pd: Ptr[uint64] = cast[Ptr[uint64]](pd_phys)
                    di: uint64 = 0
                    while di < 512:
                        de: uint64 = pd[di]
                        # A private, present, non-2MiB PT page in real RAM?
                        # (an identity leaf mapping phys 0, or any out-of-RAM
                        # / unaligned value, is never a freeable PT page.)
                        if (de & PT_P) != 0 and (de & PT_PS) == 0 \
                                and _pt_subtable_phys_ok(de & PT_ADDR) != 0:
                            free_page(de & PT_ADDR)
                        di = di + 1
                    free_page(pd_phys)
                pi = pi + 1
            free_page(pdpt_phys)
        li = li + 1
    load_cr3(_ftp_live_cr3)
    local_irq_restore(_ftp_irq)


def _task_slot_rcu_free(head: uint64):
    # RCU callback (rcu_callback_t) for deferred task-slot reclaim. Invoked by
    # the RCU engine a full grace period AFTER task_reap call_rcu'd it — every
    # reader that could have held a pointer into this slot has since left its
    # rcu_read_lock section. NOW it is finally safe to publish the slot FREE and
    # return it to the freelist for reuse.
    #
    # `head` points at task_table[su].rcu_head_next; the slot index was stashed
    # in the adjacent rcu_head_slot word (head + 8) by task_reap.
    hp: Ptr[uint64] = cast[Ptr[uint64]](head)
    su: uint64 = hp[1]
    if su >= NTASKS:
        return
    # Defence-in-depth against a double free of the slot: only a slot still in
    # STATE_REAPING (set by task_reap right before it call_rcu'd this callback)
    # is eligible to be published FREE + pushed. If it is anything else the
    # callback already ran (or the slot was recycled) — skip, so the freelist
    # is never double-pushed (the cycle-corruption root cause).
    if task_table[su].state != STATE_REAPING:
        return
    task_table[su].state = STATE_FREE
    _free_list_push(su)
    nr_task_slots_rcu_freed = nr_task_slots_rcu_freed + 1


# Count of task slots published FREE via the RCU-deferred path (self-test +
# /proc telemetry). Distinct from nr_tasks_reaped (which counts reap entries).
nr_task_slots_rcu_freed: uint64 = 0


def nr_task_slots_rcu_freed_get() -> uint64:
    return nr_task_slots_rcu_freed


# ─── RCU self-test support (gated boot:37.rcu / scripts/test_rcu.sh) ──────────
# These claim/release INERT task-table slots with a known pid but NO backing
# memory (no kstack / image / page tables), so the RCU task-list reader
# (task_lookup_by_pid) and the RCU-deferred slot-free path can be exercised at
# boot without the heavyweight memory-reclaim arms of task_reap (which assume
# alloc_pages-backed stacks and would corrupt the buddy allocator on a
# memblock-backed kthread slot). They reproduce EXACTLY the task-list add /
# RCU-deferred remove pattern the real reap uses.
def rcu_st_claim_task(pid: uint64) -> int32:
    s: int32 = _find_free_slot()
    if s < 0:
        return -1
    su: uint64 = cast[uint64](s)
    # Stamp a lookup-visible task: STATE_STOPPED (not FREE, so task_lookup_by_pid
    # resolves it) but inert — never on a run-list, never picked by _pick_next.
    # Known pid in the pid hash. No memory is attached.
    _task_set_pid(su, pid)
    task_table[su].state = STATE_STOPPED
    task_table[su].is_user = 0
    task_table[su].cr3 = 0           # no address space (inert)
    task_table[su].image_phys = 0
    task_table[su].kstack_base = 0
    task_table[su].ustack_base = 0
    return s


def rcu_st_reap_task(slot: int32):
    # The RCU-deferred remove, mirroring task_reap's tail WITHOUT any memory
    # reclaim: drop the pid mapping + unlink, then call_rcu the slot publish so
    # the slot only becomes FREE/reusable after a grace period — the exact
    # contract a lock-free task-list reader depends on.
    su: uint64 = cast[uint64](slot)
    _task_clear_pid(su)
    _rq_list_remove(su)
    task_table[su].rcu_head_slot = su
    call_rcu(cast[uint64](&task_table[su].rcu_head_next),
             cast[uint64](_task_slot_rcu_free))


def task_reap(slot: int32):
    # Caller has consumed the exit code; mark the slot FREE so a future
    # create_user_task can claim it AND reclaim the dead task's private
    # memory so the spawn pool doesn't bleed.
    #
    # RECLAIM (root-cause fix for the "command not found after ~6 hpm
    # spawns" leak): every foreground spawn carved a per-task ELF image
    # region (region_alloc, up to ~14.7 MiB for a big native binary), a
    # 256 KiB user stack, a 16 KiB kernel stack, a 4 KiB PML4, and the
    # private lower-level page tables that mapped them. None of these
    # were ever freed; after a handful of large spawns the 240 MiB pool
    # was exhausted and the next sys_spawn's region alloc returned 0 ->
    # ENOEXEC -> hamsh reported "command not found". task_reap is the
    # single chokepoint EVERY normal reap funnels through (do_wait4 /
    # SYS_WAITPID / SYS_WAITPID_JC / the spawn-failure cleanups), and it
    # runs in the PARENT's context with the child fully STATE_EXITED —
    # never on the child's own stack — so freeing the child's stacks
    # here is safe.
    su: uint64 = cast[uint64](slot)
    # REAP-ONCE GUARD (root-cause fix for the freelist double-push / DE-boot
    # "no free task slot" miscompile): only an EXITED zombie is reapable. A
    # slot already in post-reap RCU limbo (STATE_REAPING) — or otherwise not a
    # zombie (FREE/READY/RUNNING/...) — must NOT be reaped again: a second
    # reap would free its (already-freed) resources and, fatally, queue a
    # SECOND call_rcu whose callback pushes the SAME slot onto the freelist
    # twice, cross-linking it into a cycle. reap_orphan_zombies runs on EVERY
    # fork and rescans STATE_EXITED, so without this guard a detached zombie
    # gets re-reaped on every fork during the window between task_reap and its
    # RCU-grace-period free. Idempotent: a non-EXITED slot is a no-op.
    if task_table[su].state != STATE_EXITED:
        return
    # CLONE_FILES (#71): do NOT free an fd-table OWNER slot while live threads
    # still SHARE its inline arrays. An owner that exited first drops to a
    # positive live-sharer refcount; reaping it here would recycle the slot and
    # scribble the arrays a running thread is still reading. Defer — a later
    # reap sweep (reap_orphan_zombies on the next fork / the parent's wait4)
    # reclaims it once the last thread exits and drops the refcount to 0. A
    # normal leaf zombie has refcount 0 post-exit and is reaped now; a thread
    # SHARER owns no table (fd_owner_p1 != 0) and is always reapable.
    if task_table[su].fd_owner_p1 == 0 and task_table[su].fd_table_refcount > 0:
        return
    # SMP reap fence: with user tasks load-balanced across CPUs, the zombie
    # we are about to reclaim may have run (and EXITED) on a DIFFERENT cpu
    # than this reaping parent. task_exit_current raises the zombie's on_cpu
    # to 1 before it publishes STATE_EXITED, and __switch_to_asm clears it the
    # instant the zombie is switched OFF its kstack for the last time. We must
    # NOT free that kstack while the zombie is still executing its final
    # schedule() on it (observed: rc.boot user command exits on the AP, the
    # BSP parent reaps it and frees the kstack out from under the AP -> buddy
    # free-list corruption / silent wedge). Spin until on_cpu==0; this is a
    # microsecond-scale wait (just the AP's switch tail). On UP / same-cpu
    # reap on_cpu is already 0 so this falls straight through.
    while task_table[su].on_cpu != 0:
        cpu_relax()
    # setitimer(2): disarm this task's ITIMER_REAL before the slot is recycled,
    # so the per-tick scan (itimer_real_tick_all) can never post SIGALRM into a
    # freed/reused slot. Idempotent (a task that never armed one reads 0).
    clear_task_itimer(su)
    # cgroup v2 accounting: drop the dying task off its cgroup's
    # pids.current, then (if it was the last task in the cgroup) release
    # the cgroup's memory.current. Order matters — uncharge_all keys off
    # pids_cur == 0, so the pids decrement must run first. Done here,
    # before the slot/cgroup association is reset, while task fields are
    # still valid.
    cgroup_pids_uncharge(su)
    cgroup_mem_uncharge_all(su)
    # Child-resource accounting (Linux RUSAGE_CHILDREN / wait()-time roll-up).
    # task_reap runs in the PARENT's context with the child fully STATE_EXITED,
    # so this is THE site to fold the dying child's CPU ticks + page-fault
    # counts — PLUS the child's own accumulated grandchild totals (the whole
    # subtree) — into the parent. Done at the TOP, before any STATE_FREE: the
    # counters live in task_table[su] which stays valid until the slot frees.
    ppid_r: uint64 = task_table[su].parent_pid
    if ppid_r != 0:
        pslot_r: int32 = task_lookup_by_pid(ppid_r)
        if pslot_r >= 0:
            psr: uint64 = cast[uint64](pslot_r)
            task_table[psr].cutime_ticks = task_table[psr].cutime_ticks + task_table[su].utime_ticks + task_table[su].cutime_ticks
            task_table[psr].cstime_ticks = task_table[psr].cstime_ticks + task_table[su].stime_ticks + task_table[su].cstime_ticks
            task_table[psr].cminflt      = task_table[psr].cminflt + task_table[su].minflt + task_table[su].cminflt
            task_table[psr].cmajflt      = task_table[psr].cmajflt + task_table[su].majflt + task_table[su].cmajflt
    # BOOT-CR3 GUARD for the WHOLE reclaim sequence — root-cause fix for
    # the post-`enter linux` whole-system lockup (CPU0 spinning forever in
    # _try_remove_buddy with IF=0, observed via QEMU monitor regdump:
    # RIP in mm/page_alloc free-list walk, CR3 = the reaping PARENT's
    # user CR3).
    #
    # Every reclaim arm below (zombie-sweep kstack/ustack frees,
    # vma_clear, vma_free_reserved_range, region_free image/interp,
    # free_pages ustack/kstack, free_page PML4) manipulates the buddy /
    # region allocators' INTRUSIVE free lists: the `next` link lives in
    # the first 8 bytes of the freed frame itself and is read/written
    # through a raw PHYSICAL-address pointer. That is only correct when
    # phys X is identity-mapped at VA X in the CURRENT CR3. But task_reap
    # runs in the PARENT's context on the parent's CRACKED user CR3,
    # whose USER mappings (ELF image, 32 MiB brk reserve, mmap VMAs)
    # SHADOW the low-physical pool addresses — so a link store at "phys"
    # X lands in one of the reaper's own user pages instead, and a link
    # load reads user data. The free lists cross-link / self-cycle, and
    # the next _try_remove_buddy walk spins forever with interrupts
    # masked (the syscall path runs IF=0), freezing every CPU's timer
    # and the console: the exact test_linux_sh hang.
    #
    # The pristine boot CR3 identity-maps ALL of RAM by construction —
    # the same guard _free_task_user_pagetables already uses for its own
    # raw-physical walk. Run the WHOLE reclaim under it with IRQs off
    # (an IRQ handler must not observe the borrowed CR3), restore after.
    # All task_table / allocator metadata is kernel-half and mapped in
    # the boot CR3 too, so every arm below is unaffected otherwise.
    _rp_live_cr3: uint64 = read_cr3()
    _rp_irq: uint64 = local_irq_save()
    _rp_boot_cr3: uint64 = cow_boot_cr3()
    if _rp_boot_cr3 != 0 and (_rp_boot_cr3 & 0x000FFFFFFFFFF000) != (_rp_live_cr3 & 0x000FFFFFFFFFF000):
        load_cr3(_rp_boot_cr3)
    # SHARED-ADDRESS-SPACE GUARD — root-cause fix for the latent #DF at
    # load_cr3+0x3 ("freshly-built CR3's kernel half unmapped", trap rsp
    # in low memory, fires after suite PASS markers).
    #
    # CLONE_VM | CLONE_THREAD threads (do_clone) and rfork RFMEM threads
    # (_rfork_thread) run on the CREATOR's PML4 — set_task_cr3 points
    # the thread's cr3 at the SAME physical page. The reclaim arms below
    # (vma_clear, brk-reserve free, _free_task_user_pagetables,
    # free_page(cr3)) were written for the one-task-one-mm case and tore
    # the SHARED address space down while other members still ran on it:
    #
    #   * Reaping a multithreaded process's LEADER (exit_group does not
    #     terminate its threads) freed the live PML4 + user page tables
    #     + heap + thread stacks out from under the still-running
    #     threads. The buddy allocator re-issued the PML4 page, a later
    #     allocation scribbled it, and the next dispatch of a surviving
    #     thread did load_cr3(<scribbled page>): the instruction fetch
    #     of load_cr3's own `ret` (kernel text) no longer resolved, the
    #     #PF handler was unreachable through the same garbage tables,
    #     and the CPU raised #DF at load_cr3+0x3.
    #   * Reaping BOTH a thread and its creator double-freed the shared
    #     PML4 page — buddy free-list corruption that hands the same
    #     page to two owners, so some future task's freshly-built CR3
    #     gets scribbled by its co-owner: same #DF, deferred.
    #
    # Invariant enforced here: the address space is torn down EXACTLY
    # ONCE, by the LAST non-FREE task slot referencing its cr3. If any
    # other slot still shares this cr3 we transfer the owner-only
    # bookkeeping (image/interp/ustack phys runs, brk cursors, VMA list)
    # to that survivor and skip every address-space arm below; the
    # survivor's own reap repeats this scan and frees only when it is
    # genuinely last. (A LIVE survivor is preferred as heir — it will be
    # reaped through this same chokepoint later; an EXITED zombie sharer
    # still blocks the free, because reaping IT later must not find a
    # stale cr3 pointing at a recycled page.)
    my_mm: uint64 = task_table[su].cr3 & 0x000FFFFFFFFFF000
    # Thread-group ZOMBIE sweep. An EXITED sharer of this mm whose own
    # parent is (a) gone or (b) a member of this same thread group is a
    # CLONE_THREAD / RFMEM sibling no live task can ever wait() on —
    # Linux self-reaps such threads at exit; Hamnix folds their reap in
    # here at the group's reap chokepoint. Without this, a joined-and-
    # exited pthread's zombie slot would (post-guard, below) pin the
    # shared address space forever AND leak its task slot — the
    # pre-existing thread-slot zombie leak, now closed. A zombie whose
    # parent is alive OUTSIDE the group (e.g. the group LEADER, whose
    # parent is the shell) is left alone: that parent's waitpid owns it.
    if my_mm != 0:
        zj: uint64 = 0
        while zj < NTASKS:
            if zj != su and task_table[zj].state == STATE_EXITED \
                    and (task_table[zj].cr3 & 0x000FFFFFFFFFF000) == my_mm:
                zswp: int32 = 0
                zp: int32 = task_lookup_by_pid(task_table[zj].parent_pid)
                if zp < 0:
                    zswp = 1            # orphan: nobody can ever reap it
                elif (task_table[cast[uint64](zp)].cr3 & 0x000FFFFFFFFFF000) == my_mm:
                    zswp = 1            # parent is in this thread group
                if zswp != 0:
                    zu: uint64 = zj
                    # Owner bookkeeping a zombie may hold (it can have
                    # inherited it through an earlier deferred reap):
                    # pull it onto su so the teardown below sees it.
                    if task_table[zu].image_phys != 0 \
                            and task_table[su].image_phys == 0:
                        task_table[su].image_phys    = task_table[zu].image_phys
                        task_table[su].image_phys_sz = task_table[zu].image_phys_sz
                    if task_table[zu].interp_phys != 0 \
                            and task_table[su].interp_phys == 0:
                        task_table[su].interp_phys    = task_table[zu].interp_phys
                        task_table[su].interp_phys_sz = task_table[zu].interp_phys_sz
                    if task_table[zu].ustack_phys != 0 \
                            and task_table[su].ustack_phys == 0:
                        task_table[su].ustack_phys    = task_table[zu].ustack_phys
                        task_table[su].ustack_phys_sz = task_table[zu].ustack_phys_sz
                    if task_table[zu].brk_base != 0 \
                            and task_table[su].brk_base == 0:
                        task_table[su].brk_base = task_table[zu].brk_base
                        task_table[su].brk_end  = task_table[zu].brk_end
                        task_table[su].brk_max  = task_table[zu].brk_max
                    vma_adopt(zu, su)
                    task_table[zu].image_phys     = 0
                    task_table[zu].image_phys_sz  = 0
                    task_table[zu].interp_phys    = 0
                    task_table[zu].interp_phys_sz = 0
                    task_table[zu].ustack_phys    = 0
                    task_table[zu].ustack_phys_sz = 0
                    task_table[zu].brk_base = 0
                    task_table[zu].brk_end  = 0
                    task_table[zu].brk_max  = 0
                    task_table[zu].cr3 = 0
                    # Slot-private resources: the thread's kstack, and
                    # its own-allocated user stack page if any (caller-
                    # supplied-stack threads have ustack_base == 0).
                    if task_table[zu].is_user != 0 \
                            and task_table[zu].kstack_base != 0:
                        free_pages(task_table[zu].kstack_base, KSTACK_ORDER)
                        task_table[zu].kstack_base = 0
                    if task_table[zu].ustack_base != 0:
                        free_page(task_table[zu].ustack_base)
                        task_table[zu].ustack_base = 0
                    nr_tasks_reaped = nr_tasks_reaped + 1
                    # Track 5: drop pid mapping, unlink from any run-list, and
                    # return the slot to the freelist as it goes FREE.
                    _task_clear_pid(zu)
                    _rq_list_remove(zu)
                    task_table[zu].state = STATE_FREE
                    _free_list_push(zu)
            zj = zj + 1
    mm_heir: int32 = -1
    mm_heir_live: int32 = 0
    if my_mm != 0:
        hj: uint64 = 0
        while hj < NTASKS:
            if hj != su and task_table[hj].state != STATE_FREE \
                    and (task_table[hj].cr3 & 0x000FFFFFFFFFF000) == my_mm:
                if task_table[hj].state != STATE_EXITED:
                    if mm_heir_live == 0:
                        mm_heir = cast[int32](hj)
                        mm_heir_live = 1
                elif mm_heir < 0:
                    mm_heir = cast[int32](hj)
            hj = hj + 1
    if mm_heir >= 0:
        hu: uint64 = cast[uint64](mm_heir)
        # Hand the owner-only reclaim bookkeeping to the heir so the
        # final reap returns everything once. The heir is a thread-group
        # sibling: its own owner fields are 0 (threads never own the
        # image/interp/spawn-stack) except the brk cursors, which it
        # already carries with identical values — the guards keep this
        # idempotent either way.
        if task_table[su].image_phys != 0 and task_table[hu].image_phys == 0:
            task_table[hu].image_phys    = task_table[su].image_phys
            task_table[hu].image_phys_sz = task_table[su].image_phys_sz
        if task_table[su].interp_phys != 0 \
                and task_table[hu].interp_phys == 0:
            task_table[hu].interp_phys    = task_table[su].interp_phys
            task_table[hu].interp_phys_sz = task_table[su].interp_phys_sz
        if task_table[su].ustack_phys != 0 \
                and task_table[hu].ustack_phys == 0:
            task_table[hu].ustack_phys    = task_table[su].ustack_phys
            task_table[hu].ustack_phys_sz = task_table[su].ustack_phys_sz
        if task_table[su].brk_base != 0 and task_table[hu].brk_base == 0:
            task_table[hu].brk_base = task_table[su].brk_base
            task_table[hu].brk_end  = task_table[su].brk_end
            task_table[hu].brk_max  = task_table[su].brk_max
        vma_adopt(su, hu)
        # Zero this slot's references: every address-space arm below is
        # now a structural no-op for this reap, while the slot-private
        # arms (kstack, thread-allocated ustack_base page) still run.
        task_table[su].image_phys     = 0
        task_table[su].image_phys_sz  = 0
        task_table[su].interp_phys    = 0
        task_table[su].interp_phys_sz = 0
        task_table[su].ustack_phys    = 0
        task_table[su].ustack_phys_sz = 0
        task_table[su].brk_base = 0
        task_table[su].brk_end  = 0
        task_table[su].brk_max  = 0
        task_table[su].cr3 = 0
    # 0. mmap-backed VMAs (anonymous + file-backed). A DYNAMIC binary's
    #    ld.so mmaps each DT_NEEDED DSO (libc.so.6 ~2 MiB, etc.) via
    #    SYS_mmap -> vma_alloc, which EAGERLY alloc_pages the backing.
    #    Until now those pages were freed ONLY on execve (vma_clear in
    #    do_execve) — never on a plain spawn+wait+reap exit. So every
    #    dynamic-binary spawn leaked its whole DSO-mapping set; after ~6
    #    the page pool starved and ld.so failed the 7th map with "failed
    #    to map segment from shared object" (exit 127). Free them here at
    #    the single reap chokepoint, BEFORE the page tables are torn down
    #    (step 3) so vma_clear can still walk this task's PML4.
    #
    #    OWNER-SAFE for COW fork: vma_clear -> _vma_node_free walks THIS
    #    task's own PML4 and releases each page through its COW refcount
    #    (cow_drop_page) — a page still COW-shared by a forked relative is
    #    left mapped for that holder, never freed out from under it. So a
    #    reaped fork child correctly drops only its own references and the
    #    live parent's shared mmap pages survive. Cross-module call into
    #    mm/vma.ad (Adder merges all modules into one symbol table).
    if task_table[su].is_user != 0:
        vma_clear(su)
    # 0b. brk heap reserve. glibc-malloc's first brk() lazily reserves
    #     LINUX_BRK_RESERVE (32 MiB) via alloc_pages, eagerly identity-
    #     mapped over [brk_base, brk_max) (linux_abi/u_syscalls.ad). Until
    #     now task_reap freed the image / interp / user stack but NEVER
    #     this 32 MiB window — so every glibc spawn permanently leaked its
    #     whole heap arena, the dominant per-spawn page-pool drain that
    #     capped how many dynamic binaries could run in one boot.
    #
    #     OWNER-SAFE for COW fork: do_clone COW-shares [brk_base, brk_max)
    #     and BOTH parent and child carry the SAME brk_base, so a naive
    #     free would double-free a live relative's heap. vma_free_reserved_
    #     range walks THIS task's PML4 and routes each present frame
    #     through cow_drop_page — a frame still held by a forked relative
    #     (refcount > 1) only drops its count; the page returns to the
    #     allocator solely when its last holder drops it. Done BEFORE the
    #     page tables are torn down (step 3) so the walk still resolves.
    if task_table[su].is_user != 0 and task_table[su].brk_base != 0:
        vma_free_reserved_range(su, task_table[su].brk_base,
                                task_table[su].brk_max)
        task_table[su].brk_base = 0
        task_table[su].brk_end  = 0
        task_table[su].brk_max  = 0
    # 1. ELF image region (physical) — back to the region pool, COW-safely.
    #    region_free_cow_safe drops this owner's per-PFN COW reference on
    #    every image frame BEFORE pooling: a frame a live forked relative
    #    still COW-maps keeps its refcount (the region is NOT pooled while
    #    in use), and a stale owner-only refcount is cleared to 0 so the
    #    pooled chunk carries clean counts. The old raw region_free pooled
    #    fork-shared image frames with a non-zero refcount, poisoning the
    #    next image/interp load's frames (the fork+exec canary/exit-list
    #    corruption — dash SIGABRT). Matches the brk/stack COW-safe reclaim.
    if task_table[su].image_phys != 0:
        region_free_cow_safe(task_table[su].image_phys,
                             task_table[su].image_phys_sz)
        task_table[su].image_phys    = 0
        task_table[su].image_phys_sz = 0
    # 2. User stack — owner-only. ustack_phys is set ONLY on the task
    #    that allocated the stack (SYS_SPAWN / do_execve); a fork child
    #    COW-shares the region (ustack_lo/sz) but has ustack_phys == 0,
    #    so it never double-frees the parent's live stack. A native
    #    create_user_thread that allocated its own 4 KiB page records it
    #    in ustack_base; free that too (threads don't COW-share it).
    if task_table[su].ustack_phys != 0:
        free_pages(task_table[su].ustack_phys,
                   _order_for_bytes(task_table[su].ustack_phys_sz))
        task_table[su].ustack_phys    = 0
        task_table[su].ustack_phys_sz = 0
    elif task_table[su].ustack_base != 0:
        free_page(task_table[su].ustack_base)
        task_table[su].ustack_base = 0
    # 2b. Dynamic-linker interpreter image (ld-linux) — back to the
    #     region pool. Owner-only, exactly like image_phys: set only on
    #     the task that region_alloc'd the interp (SYS_SPAWN / do_execve);
    #     a fork child COW-shares it and has interp_phys == 0, so it
    #     never double-frees the parent's live interp. Static binaries
    #     (no PT_INTERP) also leave this 0 and skip the free.
    if task_table[su].interp_phys != 0:
        region_free_cow_safe(task_table[su].interp_phys,
                             task_table[su].interp_phys_sz)
        task_table[su].interp_phys    = 0
        task_table[su].interp_phys_sz = 0
    # 3. Private user-half page tables (PDPT/PD/PT), then the PML4 page.
    #    (Skipped via cr3==0 when the shared-mm guard above found a
    #    surviving thread-group sharer — the heir's final reap frees.)
    if task_table[su].cr3 != 0:
        _free_task_user_pagetables(su)
        pml4_pg: uint64 = task_table[su].cr3 & 0x000FFFFFFFFFF000
        # Defence-in-depth: never hand the pristine boot snapshot or
        # the live BSP kernel PML4 to the buddy allocator, whatever the
        # slot bookkeeping says (kthreads carry cr3 == get_bsp_cr3();
        # freeing THAT page would scribble the kernel address space for
        # every CPU). A user task's cr3 is always a private clone, so
        # this guard never fires on the normal path.
        if pml4_pg != (cow_boot_cr3() & 0x000FFFFFFFFFF000) \
                and pml4_pg != (get_bsp_cr3() & 0x000FFFFFFFFFF000):
            free_page(pml4_pg)
        task_table[su].cr3 = 0
    # 4. Kernel stack (user-task kstacks come from alloc_pages; kthread
    #    kstacks come from memblock and have is_user==0 — skip those).
    if task_table[su].is_user != 0 and task_table[su].kstack_base != 0:
        free_pages(task_table[su].kstack_base, KSTACK_ORDER)
        task_table[su].kstack_base = 0
    # End of the BOOT-CR3 GUARD: every raw-physical free is done —
    # restore the caller's CR3 and IRQ state before publishing the slot.
    if (_rp_boot_cr3 & 0x000FFFFFFFFFF000) != (_rp_live_cr3 & 0x000FFFFFFFFFF000):
        load_cr3(_rp_live_cr3)
    local_irq_restore(_rp_irq)
    nr_tasks_reaped = nr_tasks_reaped + 1
    # Track 5: drop the pid->slot mapping and unlink from any run-list.
    _task_clear_pid(su)
    _rq_list_remove(su)
    # ─── RCU-DEFERRED SLOT RECLAIM ─────────────────────────────────────────
    # Do NOT publish the slot FREE + push it to the freelist HERE. A lock-free
    # task-list reader (/proc, kill, wait, ps — see for_each_task_rcu) may be
    # mid-traversal holding a pointer into task_table[su], reading its
    # pid/state/name. If we marked it FREE and a concurrent create_*_task
    # claimed the slot, the reader would observe a half-overwritten struct
    # (a torn pid/state) — the classic use-after-free RCU exists to prevent.
    #
    # Instead move the slot to STATE_REAPING (post-reap limbo: body intact, NOT
    # on the freelist, NOT yet FREE — so _find_free_slot's STATE_FREE scan and
    # the O(1) freelist both skip it) and call_rcu the actual publish. Crucially
    # STATE_REAPING is NOT STATE_EXITED, so the REAP-ONCE guard above makes any
    # repeat reaper (reap_orphan_zombies on the next fork, a late do_wait4, the
    # thread-group zombie sweep) skip this slot — it is reaped EXACTLY once, so
    # call_rcu fires exactly once and the slot is pushed to the freelist exactly
    # once. The callback _task_slot_rcu_free runs only after a grace period, by
    # which time every reader that could have observed this slot as live has
    # exited its rcu_read_lock section. THEN it is safe to flip STATE_FREE +
    # enqueue on the freelist for reuse. This is the one real hot read path
    # proving RCU.
    task_table[su].state = STATE_REAPING
    task_table[su].rcu_head_slot = su
    call_rcu(cast[uint64](&task_table[su].rcu_head_next),
             cast[uint64](_task_slot_rcu_free))


def reap_orphan_zombies() -> uint64:
    # Reclaim DETACHED (RFNOWAIT / `spawn detached`) zombies that no task will
    # ever wait4(). A detached task is published STATE_EXITED with detached==1
    # (task_exit_current); since its parent link was severed at creation, no
    # do_wait4 / waitpid will ever consume it — so without this sweep its FULL
    # address space (ELF image region, 32 MiB brk reserve, user stack, kstack,
    # PML4 + private page tables, mmap VMAs) AND its cgroup pids charge would
    # leak forever. (The exiting task cannot free those itself: it is still
    # running on its own kstack under its own cr3.)
    #
    # task_reap does the full, COW-safe reclaim and is safe to call from ANOTHER
    # task's context — its on_cpu spin fences a zombie still switching off a CPU,
    # and its boot-CR3 guard makes every raw-physical allocator free correct
    # regardless of the caller's cr3. We skip a zombie with on_cpu != 0 (still
    # mid-switch) so we never spin here; the next sweep catches it.
    #
    # Called from the fork hot paths (do_clone / do_rfork) right BEFORE a new
    # task slot is allocated — so a dead detached task's resources are recycled
    # exactly when the next spawn needs them, turning the old permanent leak into
    # a bounded, self-healing reclaim.
    # Returns the number of zombies reaped (for tests / accounting).
    reaped: uint64 = 0
    i: uint64 = 1
    while i < NTASKS:
        if task_table[i].state == STATE_EXITED \
                and task_table[i].on_cpu == 0:
            # Reap iff (a) detached (no waitable ancestor by design) OR
            # (b) ORPHAN: a non-detached zombie whose parent_pid no longer
            # resolves to a live slot (parent FREE / already reaped / never
            # existed). Hamnix has no reparent-to-init path, so an orphan
            # would otherwise leak its full address space + cgroup pids charge
            # forever (this is the `ls | grep cat` enter-linux fork-EAGAIN bug:
            # pipeline children orphaned when an intermediate parent exits).
            # A zombie whose parent is STILL ALIVE (lookup >= 0) is LEFT for
            # that parent's wait4 — preserves normal wait4 semantics.
            do_reap: uint64 = 0
            if task_table[i].detached != 0:
                do_reap = 1
            elif task_lookup_by_pid(task_table[i].parent_pid) < 0:
                do_reap = 1
            if do_reap != 0:
                task_reap(cast[int32](i))
                reaped = reaped + 1
        i = i + 1
    return reaped


def _order_for_bytes(nbytes: uint64) -> int32:
    # Smallest buddy order whose run (2^order pages) covers nbytes.
    # Matches how the allocation was sized (alloc_pages(order)). For the
    # 256 KiB SYS_SPAWN stack this returns 6; a 4 KiB page returns 0.
    pages: uint64 = (nbytes + 4095) >> 12
    order: int32 = 0
    cap: uint64 = 1
    while cap < pages:
        cap = cap << 1
        order = order + 1
    return order


def task_pid_at(slot: int32) -> uint64:
    return task_table[cast[uint64](slot)].pid


def tasks_spawned_total() -> uint64:
    # Cumulative count of task slots ever allocated (kthread + user).
    # Used by the memory-leak accounting layer.
    return nr_tasks_spawned


def tasks_reaped_total() -> uint64:
    # Cumulative count of task slots ever freed back to STATE_FREE.
    # Used by the memory-leak accounting layer.
    return nr_tasks_reaped


def tasks_live_count() -> uint64:
    # Count of task slots currently in use (STATE_READY / _RUNNING /
    # _EXITED). Computed by walking the table — cheap at NTASKS=256.
    n: uint64 = 0
    i: uint64 = 0
    while i < NTASKS:
        st: uint64 = task_table[i].state
        if st != STATE_FREE:
            n = n + 1
        i = i + 1
    return n


def set_linux_userspace_mode(slot: int32, on: int32):
    # U1: flip the per-task syscall ABI selector. Called by the Linux
    # ELF loader after create_user_task_argv returns the slot id but
    # before schedule() ever picks the new task. Idempotent and safe
    # to call on any STATE_READY / STATE_RUNNING task; we don't gate
    # on state because there's no race here at uniprocessor scale
    # (the field is only read on syscall entry by the running task
    # itself). `on` is the int32 0/1 value to store — matches the
    # field type and avoids a cast at every call site.
    su: uint64 = cast[uint64](slot)
    task_table[su].is_linux_userspace = on


def task_is_linux_userspace(slot: int32) -> int32:
    # Read accessor — used by the procfs renderer (future M-track) and
    # as a debug aid. The hot-path syscall dispatch reads the field
    # off current_task() directly to avoid the slot lookup.
    return task_table[cast[uint64](slot)].is_linux_userspace


def task_vfork_done(slot: int32) -> int32:
    # U26: read the vfork_done flag on the given slot. Used by do_clone
    # in its blocking-parent yield loop to detect "child has replaced
    # its user image" so the parent can resume without waiting for the
    # exec'd binary to also exit.
    return task_table[cast[uint64](slot)].vfork_done


def set_task_vfork_done(slot: int32, v: int32):
    # U26: set the vfork_done flag. do_execve calls this on the current
    # task right before the SYSRETQ into the new image — that's the
    # latest moment we can wake a blocked vfork parent without races.
    task_table[cast[uint64](slot)].vfork_done = v


def task_fs_base(slot: int32) -> uint64:
    # U27: read accessor for the task's saved FS_BASE.
    return task_table[cast[uint64](slot)].fs_base


def set_task_fs_base(slot: int32, v: uint64):
    # U27: write accessor for the task's saved FS_BASE. Called from
    # do_clone (thread path planting the child's TLS) and from
    # arch_prctl(ARCH_SET_FS) so the value survives the next context
    # switch — schedule() rewrites MSR_FS_BASE from this field.
    task_table[cast[uint64](slot)].fs_base = v


def task_clear_child_tid(slot: int32) -> uint64:
    # U27: read accessor for the per-task CLONE_CHILD_CLEARTID pointer.
    return task_table[cast[uint64](slot)].clear_child_tid


def set_task_clear_child_tid(slot: int32, v: uint64):
    # U27: write accessor. do_clone stashes ctid here; set_tid_address
    # stashes its tidptr; task_exit_current reads it on the way out and
    # zeroes *clear_child_tid + futex-wakes a joiner.
    task_table[cast[uint64](slot)].clear_child_tid = v


def task_exit_sem(slot: int32) -> uint64:
    # #443: read accessor for the NATIVE exit-notification semaphore
    # address (the Plan 9-shape mirror of clear_child_tid above).
    return task_table[cast[uint64](slot)].exit_sem


def set_task_exit_sem(slot: int32, v: uint64):
    # #443: write accessor. SYS_SETEXITSEM stashes the user semaphore
    # address here; task_exit_current semrelease's it on the way out
    # (through exitsem_release_hook) so thread_join's semacquire wakes.
    task_table[cast[uint64](slot)].exit_sem = v


# docs/security.md: Plan-9-shape uid/gid accessors. SYS_GETUID /
# SYS_GETGID return the current task's value. SYS_SETUID is privileged:
# it MUST only be reachable from the kernel-side /dev/auth path (which
# already authenticated the password) and from the very first SYS_SPAWN
# of init by the kernel — userland cannot call it. The dispatch in
# arch/x86/kernel/syscall.ad gates SYS_SETUID on uid==1 (hostowner) for
# defense-in-depth: even if userland synthesises the syscall, only
# hostowner can change identity; downgrade-only escalation never
# elevates a regular user.
def current_task_uid() -> uint32:
    return task_table[current_idx_pcpu].uid


def current_task_gid() -> uint32:
    return task_table[current_idx_pcpu].gid


# F10-? audit §3.2 follow-up: named hostowner predicate. Every per-server
# perm_check + every syscall arm that gates on "is this the hostowner?"
# routes through ONE helper so the literal `uid == 1` survives in exactly
# one place. If the hostowner-uid convention ever moves (multiple hosts,
# capability-style anchors, ...) the rewrite is a single edit. Takes the
# uid directly because callers either already have `caller_uid` in scope
# (the per-server perm_check signature) or extracted it themselves.
def task_is_hostowner(uid: uint32) -> int32:
    if uid == UID_HOSTOWNER:
        return 1
    return 0


def current_task_is_hostowner() -> int32:
    return task_is_hostowner(task_table[current_idx_pcpu].uid)


def set_current_task_uid(v: uint32):
    # Privileged setter — only callable from the /dev/auth post-auth
    # path (which lives in kernel context and authenticated against
    # /etc/shadow). The arch-side SYS_SETUID dispatcher must enforce
    # that the caller's CURRENT uid is 1 before allowing this — that
    # check lives in syscall.ad, not here, so this helper stays usable
    # by both the cdev (which is already inside the kernel context for
    # PID 1's behalf at the auth point) and by the boot-time bring-up.
    task_table[current_idx_pcpu].uid = v


def set_current_task_gid(v: uint32):
    task_table[current_idx_pcpu].gid = v


def task_uid_at(slot: int32) -> uint32:
    return task_table[cast[uint64](slot)].uid


def task_gid_at(slot: int32) -> uint32:
    return task_table[cast[uint64](slot)].gid


def set_task_uid_at(slot: int32, v: uint32):
    # Bring-up-only: init's loader uses this BEFORE the first user task
    # starts so PID 1 lands at uid 1 even if a prior recycle stamped a
    # different value. Userland reaches it only via the validated
    # SYS_SETUID path.
    task_table[cast[uint64](slot)].uid = v


def set_task_gid_at(slot: int32, v: uint32):
    task_table[cast[uint64](slot)].gid = v


def count_live_user_tasks() -> int32:
    # U27: count tasks that are alive (RUNNING / READY) AND user-mode.
    # _u_futex consults this to short-circuit the WAIT path when the
    # caller is the only thing that could write to its own futex word
    # (a deadlock pattern in startup-time glibc probes). When real
    # threads exist the count is >= 2 and we park properly.
    n: uint64 = NTASKS
    i: uint64 = 0
    live: int32 = 0
    while i < n:
        if task_table[i].is_user != 0:
            st: uint64 = task_table[i].state
            if st == STATE_READY or st == STATE_RUNNING:
                live = live + 1
        i = i + 1
    return live


def count_live_linux_peers() -> int32:
    # U27: count live Linux-ABI user tasks that COULD wake the current
    # task's futex — i.e. peers SHARING its address space. A futex is a
    # word in memory; only a task that maps that same word can perform
    # the FUTEX_WAKE. Threads created via clone(CLONE_VM|CLONE_THREAD)
    # share the creator's PML4 (identical cr3) and are real wakers.
    #
    # CRITICAL: a fork()/forkpty() CHILD is is_linux_userspace=1 too, but
    # it gets its OWN COW-copied address space (a DIFFERENT cr3), so it can
    # NEVER write the parent's PRIVATE futex word. Counting it as a peer
    # made a single-threaded parent (e.g. weston-terminal, right after it
    # forkpty's its shell) PARK a glibc private-futex FUTEX_WAIT forever —
    # nothing in its own address space ever wakes it, and the unrelated
    # child cannot. Gating on a matching cr3 restores the pre-fork
    # behaviour (no same-mm peer -> the WAIT short-circuits to -EAGAIN and
    # glibc re-tries the cmpxchg) while still parking properly once real
    # threads exist. hamsh is is_user=1 / is_linux_userspace=0 and is
    # excluded regardless. The exit-time CLEARTID futex-wake on this very
    # task is handled separately.
    n: uint64 = NTASKS
    i: uint64 = 0
    peers: int32 = 0
    cur: uint64 = current_idx_pcpu
    my_cr3: uint64 = task_table[cur].cr3
    while i < n:
        if i != cur and task_table[i].is_user != 0 \
                    and task_table[i].is_linux_userspace != 0 \
                    and task_table[i].cr3 == my_cr3:
            st: uint64 = task_table[i].state
            if st == STATE_READY or st == STATE_RUNNING:
                peers = peers + 1
        i = i + 1
    return peers


def task_name0_at(slot: int32) -> uint64:
    # 8-char ASCII tag baked into task_struct.name0 at creation time
    # (e.g. "__init__"). Returned as a uint64 so the procfs renderer
    # can scan it byte by byte without a separate ptr.
    return task_table[cast[uint64](slot)].name0


def task_table_size() -> uint64:
    return NTASKS


# Stamp a task's 8-char name0 debug tag (and the 16-char comm) from a
# program PATH's basename. Called by do_execve so /proc/tasks shows the
# RUNNING program name (e.g. "hampanel") instead of the creation-time
# "__rfork_" tag every rfork'd process otherwise carries forever. name0
# packs MOST-significant-byte = character 0 (see _buf_put_name0 in
# fs/procfs.ad), so we shift each basename byte in from the top. comm is
# Linux-shaped (char 0 first, NUL-padded) for /proc/<pid>/comm + PR_GET_NAME.
def set_task_name0_from_path(slot: uint64, path: Ptr[char]):
    # Find the basename: scan to NUL, then back to the last '/'.
    n: uint64 = 0
    while path[n] != 0:
        n = n + 1
    base: uint64 = 0
    i: uint64 = 0
    while i < n:
        if path[i] == 47:                       # '/'
            base = i + 1
        i = i + 1
    # Pack up to 8 basename bytes into name0 (top byte = first char).
    tag: uint64 = 0
    k: uint64 = 0
    while k < 8 and base + k < n:
        c: uint64 = cast[uint64](cast[uint8](path[base + k]))
        tag = tag | (c << ((7 - k) * 8))
        k = k + 1
    task_table[slot].name0 = tag
    # Mirror the full (up to 15-char) basename into comm.
    cj: uint64 = 0
    while cj < 15 and base + cj < n:
        task_table[slot].comm[cj] = cast[uint8](path[base + cj])
        cj = cj + 1
    while cj < 16:
        task_table[slot].comm[cj] = 0
        cj = cj + 1
    # Stamp the FULL resolved path into exe_path (NUL-terminated, capped at
    # 255 chars) so readlinkat("/proc/self/exe") reports the real image
    # path. Firefox's XPCOMGlueLoad locates its libs via dirname(exe).
    pj: uint64 = 0
    while pj < 255 and pj < n:
        task_table[slot].exe_path[pj] = cast[uint8](path[pj])
        pj = pj + 1
    task_table[slot].exe_path[pj] = 0


# Return a pointer to `slot`'s NUL-terminated exe_path (full image path
# recorded by do_execve). exe_path[0]==0 means "not stamped" (fresh slot
# or kthread) — callers should fall back to a synthetic path.
def get_task_exe_path_ptr(slot: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](&task_table[slot].exe_path[0])


# Convenience: the CURRENT task's exe_path pointer.
def current_exe_path_ptr() -> Ptr[uint8]:
    return get_task_exe_path_ptr(current_idx_get())


# NR_FDS bumped to 64 (was 16) to support Debian server workloads. The
# matching fd_idx/fd_pos/fd_buf/fd_buflen/fd_opened_path Array[]s in
# TaskStruct above were widened too; keep those in lockstep with this
# constant. Next step: lift to 256+ by switching the fd table to a heap
# arena (Array sizes must be literals in Adder today).
NR_FDS: uint64 = 64

# Phase D follow-up: per-fd opened-path capacity (bytes, incl. NUL).
# Matches the TaskStruct.fd_opened_path[][] inline-array dimension and the
# kernel-wide path-buf shape (resolve_path's `resolved` array is 256;
# 128 is the fd2path / chan path cap and covers every realistic boot
# path — longer paths get truncated with NUL, fd2path then reports the
# truncated form rather than refusing).
FD_OPENED_PATH_CAP: uint64 = 128


# --- CLONE_FILES shared fd-table routing (#71) ----------------------
# fd_owner_task/fd_owner_slot_of resolve a task to the task that OWNS its
# (possibly shared) fd table. A self-owned task resolves to itself; a
# CLONE_FILES thread resolves to its group leader. Every fd-array access site
# (fd_idx/fd_pos/fd_buf/fd_buflen/fd_opened_path) routes through these so a
# thread's fd operations land in the SHARED table. Idempotent: applying it to
# an owner returns the owner (owner.fd_owner_p1 == 0).
def fd_owner_task(task: Ptr[TaskStruct]) -> Ptr[TaskStruct]:
    p1: int32 = task[0].fd_owner_p1
    if p1 == 0:
        return task
    return &task_table[cast[uint64](p1 - 1)]


def fd_owner_slot_of(slot: int32) -> int32:
    p1: int32 = task_table[cast[uint64](slot)].fd_owner_p1
    if p1 == 0:
        return slot
    return p1 - 1


# Take/drop the per-owner fd lock. Callers pass ANY task in the sharing group;
# the lock always lives on the owner slot, so two threads sharing a table
# serialise on the same word.
def fd_table_lock(task: Ptr[TaskStruct]):
    owner: Ptr[TaskStruct] = fd_owner_task(task)
    spinlock_lock(&owner[0].fd_lock)


def fd_table_unlock(task: Ptr[TaskStruct]):
    owner: Ptr[TaskStruct] = fd_owner_task(task)
    spinlock_unlock(&owner[0].fd_lock)


# CLONE_FILES thread creation: the child SHARES the parent's fd table instead
# of snapshot-copying it. Point the child at the parent's OWNER slot and bump
# the owner's live-sharer refcount under the fd lock. The child's own
# fd_table_refcount is zeroed — it owns no table, so task_reap can free the
# child slot freely while the owner (and its inline arrays) live on.
def fd_table_share_to_thread(child_slot: int32, parent_slot: int32):
    owner_slot: int32 = fd_owner_slot_of(parent_slot)
    ou: uint64 = cast[uint64](owner_slot)
    spinlock_lock(&task_table[ou].fd_lock)
    task_table[ou].fd_table_refcount = task_table[ou].fd_table_refcount + 1
    spinlock_unlock(&task_table[ou].fd_lock)
    task_table[cast[uint64](child_slot)].fd_owner_p1 = owner_slot + 1
    task_table[cast[uint64](child_slot)].fd_table_refcount = 0


# Task-exit fd-table release. Decrements the OWNER's live-sharer refcount; the
# LAST sharer to exit (refcount reaching 0) runs the real close-all on the
# owner's table. A self-owned task with no threads decrements 1 -> 0 and closes
# immediately (identical to the old task_close_all_fds call). An owner that
# exits while threads are still live drops to a positive count and leaves its
# fds open + its slot un-reapable (task_reap defers) until the last thread goes.
def _release_fd_table_on_exit(slot: int32):
    owner_slot: int32 = fd_owner_slot_of(slot)
    ou: uint64 = cast[uint64](owner_slot)
    spinlock_lock(&task_table[ou].fd_lock)
    rc: int32 = task_table[ou].fd_table_refcount - 1
    task_table[ou].fd_table_refcount = rc
    spinlock_unlock(&task_table[ou].fd_lock)
    # Detach an exiting SHARER from the table so nothing dereferences it again.
    if fd_owner_slot_of(slot) != slot:
        task_table[cast[uint64](slot)].fd_owner_p1 = 0
    if rc <= 0:
        task_close_all_fds(ou)


def close_fd_in_task(task: Ptr[TaskStruct], fdu: uint64):
    # Single source of truth for tearing down an open fd. Used by
    # vfs_close (after fd-range / EBADF validation) and by
    # task_close_all_fds (the auto-cleanup on task exit). Calls the
    # right resource release based on the fd_idx marker:
    #
    #   FD_CHAN_MARK      namec_close: decrement the pool chan's refcount
    #                     (no-op for an inline cdev chan), release the
    #                     backing resource on the last reference
    #   (tmpfs / memfd / DIRECTORY / procfs-snapshot / PIPE fds are
    #    FD_CHAN_MARK now — the fd→Chan fold — so they release through
    #    namec_close above: a named tmpfs entry frees no slot, an anon
    #    memfd slot is reclaimed on the last reference, a directory
    #    listing / rendered-snapshot buffer is kfree'd on the last
    #    reference via the chan's back_ptr, and a pipe end's
    #    reader/writer count drops via the DEV_PIPE_R / DEV_PIPE_W arms)
    #   stdio markers     no-op (serial port is shared)
    #
    # After release, the slot is rewritten to FD_CLOSED_MARK + zeros
    # so a subsequent open can claim it.
    # CLONE_FILES: operate on the SHARED table (owner) so a thread's close is
    # visible to all sharers. Idempotent for a self-owned task.
    task = fd_owner_task(task)
    fi: uint32 = task[0].fd_idx[fdu]
    if fi == CHAN_MARK_VALUE:
        # fd→Chan unification: an FD_CHAN_MARK fd carries a namec Chan id
        # in fd_buf (the low 32 bits). Release ONE reference through
        # namec_close — for an INLINE cdev chan this is a no-op; for a
        # POOL chan (DEV_MNT, and every future stateful family routed
        # through the pool) it decrements the refcount and, on the last
        # reference, runs the per-dev_type backing release (e.g. the 9P
        # Tclunk) and frees the pool slot.
        #
        # This is THE structural edit of the fd→Chan migration: it makes
        # explicit close (vfs_close) and exit cleanup (task_exit_current
        # → task_close_all_fds → close_fd_in_task) share ONE release
        # path. Without it, a task that EXITS holding a pool-backed
        # FD_CHAN_MARK fd leaks its pool slot (and never clunks its 9P
        # fid) — a pre-existing leak this fixes. vfs_close no longer
        # double-releases: its FD_CHAN_MARK arm now ONLY recovers the id
        # and leaves the release to this single fall-through site, so an
        # explicit close goes through exactly one namec_close.
        #
        # namec_close is resolved by name (the whole-kernel Adder merge
        # links it); core.ad must not `import` namec — that forms a
        # core → namec → 9p_client → core import cycle.
        namec_close(cast[int32](cast[uint32](task[0].fd_buf[fdu])))
    # fd→Chan fold: the FD_DIR_MARK and FD_BUFFER_MARK release arms are
    # GONE (Phase 4b). A directory fd is an FD_CHAN_MARK fd (DEV_DIR_FILE
    # pool chan) and a procfs/cgroup rendered-snapshot fd is an
    # FD_CHAN_MARK fd too (DEV_BUF_FILE pool chan); both kmalloc'd
    # buffers are kfree'd inside namec_close (the CHAN_MARK_VALUE arm
    # above) on the LAST reference — the single Chan release path shared
    # by explicit close and task-exit cleanup, refcounted across
    # fork/dup so each buffer is freed exactly once and never leaks.
    # Phase 4c: the FD_PIPE_MARK_R / FD_PIPE_MARK_W release arms are
    # GONE the same way — a pipe end is an FD_CHAN_MARK fd whose
    # pipe_close_reader / pipe_close_writer release runs inside
    # namec_close's DEV_PIPE_R / DEV_PIPE_W arms on the LAST chan ref.
    # fd→Chan fold: the FD_FAT_MARK / FD_EXT4_MARK release arms are GONE.
    # A folded FAT / ext4 file fd is an FD_CHAN_MARK fd; its fat_close /
    # ext4_close release runs inside namec_close (the CHAN_MARK_VALUE arm
    # above), the single Chan release path shared by explicit close and
    # task-exit cleanup.
    # Phase 4c (socket fold): the FD_SOCKET_MARK by-name teardown clone
    # is GONE. A socket fd is an FD_CHAN_MARK fd (DEV_SOCKET pool chan);
    # the CHAN_MARK_VALUE arm above releases it through namec_close,
    # whose DEV_SOCKET arm runs the FULL teardown (vfs_socket_chan_
    # release in fs/vfs.ad — UDP slot close, TLS close_notify, /net
    # conn unref or tcp_close/tcp_listen_close, usock_free) on the LAST
    # chan reference. That kills the legacy double-copy (this arm +
    # vfs_close's) which fired on the FIRST close of a dup'd fd, and
    # gives task-exit cleanup the same single release path. The
    # FD_SOCKETPAIR_MARK end-ref leak is fixed the same way: namec_
    # close's DEV_SOCKETPAIR arm runs sockpair_close — the legacy exit
    # path never decremented the end refs at all (rings leaked when a
    # task died holding socketpair fds).
    # The cgroup v2 control-file write fd (fs/vfs.ad FD_CGROUP_WRITE_MARK)
    # holds NO heap state — the control value is applied per-write and the
    # path lives in the recorded opened-path — so there is nothing to
    # release here; it falls through to the slot-rewrite below.
    # All other marks have no backing slot to release — fall through to
    # the slot-rewrite below.
    task[0].fd_idx[fdu]    = FD_CLOSED_MARK
    task[0].fd_buf[fdu]    = 0
    task[0].fd_buflen[fdu] = 0
    task[0].fd_pos[fdu]    = 0
    # Phase D follow-up: drop the recorded opened-path so a recycled
    # slot does not surface stale bytes to fd2path.
    task[0].fd_opened_path[fdu][0] = 0


def task_close_all_fds(slot: uint64):
    # Called from task_exit_current — walk the dying task's fd table
    # and apply the same release logic vfs_close uses, so pipe
    # refcounts unwind cleanly when a child exits without an
    # explicit close, and so procfs snapshots aren't leaked.
    i: uint64 = 0
    while i < NR_FDS:
        if task_table[slot].fd_idx[i] != FD_CLOSED_MARK:
            close_fd_in_task(&task_table[slot], i)
        i = i + 1


def copy_fd_entry(dst: Ptr[TaskStruct], dst_fdu: uint64,
                  src: Ptr[TaskStruct], src_fdu: uint64) -> int32:
    # Copy src's fd entry into dst's fd slot, bumping pipe refcounts
    # so closing one side doesn't yank the channel out from under
    # the other. dst and src may be the same task (dup/dup2) or
    # different tasks (SYS_SPAWN's stdin/stdout inheritance). Caller
    # is responsible for closing any prior occupant of dst_fdu first
    # — copy_fd_entry just OVERWRITES.
    # CLONE_FILES: resolve both ends to their table OWNERS so a dup within a
    # thread hits the shared table, and a fork/spawn copy reads the parent's
    # shared table + writes the fresh child's own. Idempotent for self-owned.
    dst = fd_owner_task(dst)
    src = fd_owner_task(src)
    fi: uint32 = src[0].fd_idx[src_fdu]
    if fi == FD_CLOSED_MARK:
        return -1
    dst[0].fd_idx[dst_fdu]    = fi
    dst[0].fd_pos[dst_fdu]    = src[0].fd_pos[src_fdu]
    dst[0].fd_buf[dst_fdu]    = src[0].fd_buf[src_fdu]
    dst[0].fd_buflen[dst_fdu] = src[0].fd_buflen[src_fdu]
    # Phase 4c: the FD_PIPE_MARK_R / FD_PIPE_MARK_W pipe_inc_* arms are
    # GONE — a copied pipe-end fd is an FD_CHAN_MARK fd that shares its
    # DEV_PIPE_R / DEV_PIPE_W pool chan; the CHAN_MARK_VALUE arm below
    # bumps the CHAN refcount instead, so the pipe's end count stays
    # one-per-chan and unwinds exactly once via namec_close.
    if fi == CHAN_MARK_VALUE:
        # fd→Chan unification: a copied (fork/dup'd) FD_CHAN_MARK fd
        # SHARES the same namec pool chan as the original — bump its
        # refcount so the FIRST namec_close (whichever holder closes or
        # exits first) does NOT release the backing resource out from
        # under the other holder. namec_chan_ref is a no-op for an
        # inline cdev chan (no slot, nothing to refcount). Resolved by
        # name — core.ad must not import namec (import cycle), same as
        # the FD_CHAN_MARK release in close_fd_in_task. This fixes a
        # PRE-EXISTING hazard: before refcounting, a forked DEV_MNT 9P fd
        # shared a pool slot with NO refcount, so the second close
        # double-clunked the fid and double-freed the slot.
        namec_chan_ref(cast[int32](cast[uint32](src[0].fd_buf[src_fdu])))
    # Phase D follow-up: propagate the recorded opened-path to the
    # duplicate fd so a dup'd / forked / spawn-inherited fd reports the
    # same path as the original through fd2path.
    j: uint64 = 0
    while j < FD_OPENED_PATH_CAP:
        c: uint8 = src[0].fd_opened_path[src_fdu][j]
        dst[0].fd_opened_path[dst_fdu][j] = c
        if c == 0:
            break
        j = j + 1
    if j == FD_OPENED_PATH_CAP:
        dst[0].fd_opened_path[dst_fdu][FD_OPENED_PATH_CAP - 1] = 0
    return 0


def dup_fd_to_child(child_slot: int32, child_fdu: uint64,
                    parent: Ptr[TaskStruct], parent_fdu: uint64) -> int32:
    # Back-compat wrapper for SYS_SPAWN's stdin/stdout inheritance.
    # The general primitive is copy_fd_entry above; this wraps with
    # task_table[child_slot] addressing so existing SYS_SPAWN code
    # doesn't need to look up the child's TaskStruct pointer.
    cu: uint64 = cast[uint64](child_slot)
    return copy_fd_entry(&task_table[cu], child_fdu, parent, parent_fdu)


def yield_to_others():
    # Cooperatively call schedule() while we're still RUNNING. Used
    # by SYS_WAITPID and the blocking pipe / stdin read loops to
    # avoid busy-spinning. schedule() rotates to any other ready
    # task; if no other task wants the CPU we still need to let
    # interrupts fire so the UART RX FIFO drain and the timer tick
    # can make forward progress — otherwise a syscall (IF=0) just
    # loops forever. We do sti / hlt / cli around an idle wait,
    # then check pending signals so a SIGINT delivered during the
    # nap terminates us promptly instead of looping.
    schedule()
    local_irq_enable()
    # PURE-INSTRUMENTATION idle marker: this is a genuine "nothing to do,
    # halt until the next IRQ" idle wait (IF=1), so the timer ISR that
    # fires here is catching real idle, not system work. Raise the flag
    # for the duration of the hlt only; it never affects control flow.
    cpu_idle_enter()
    asm_volatile("hlt")
    cpu_idle_leave()
    local_irq_disable()
    signal_check_and_handle()


def kernel_cond_resched():
    # Kernel-side cooperative-reschedule point. The wedge-class fix.
    #
    # PROBLEM: SYSCALL entry clears EFLAGS.IF (IA32_FMASK=0x0200). For
    # the whole duration of a syscall, CPU interrupts are masked: the
    # LAPIC timer cannot fire, `jiffies` is frozen, and a kernel busy-
    # poll of the shape `while get_jiffies() < deadline: poll_one()`
    # degenerates into `while True`. One such loop in a kernel-side
    # accept (e.g. drivers/net/tcp.ad::tcp_accept) pins the CPU
    # forever — every other task is STATE_READY but can never run.
    # The hamsh heartbeat regression is a symptom of exactly this.
    #
    # FIX: any kernel loop that polls in a syscall context calls
    # kernel_cond_resched() inside its body. We briefly enable
    # interrupts (sti), halt until the next interrupt (hlt — which
    # the periodic LAPIC timer will satisfy within at most 10 ms at
    # HZ=100), then disable interrupts again. During the IRQ-open
    # window:
    #   * the LAPIC timer fires → timer_interrupt() bumps `jiffies`
    #     and ages the per-task quantum (preempt_tick — even though
    #     it returns 0 for from_user=0 and does not switch from the
    #     ISR, the quantum-tick still happens),
    #   * the UART RX FIFO drains, virtio-net IRQs land in their
    #     ring handlers, etc — i.e. EVERYTHING that needs IF=1 to
    #     make progress, makes progress.
    # After we cli again we OPTIONALLY rotate to a runnable peer via
    # schedule() — Linux's cond_resched() semantics. This is the
    # part that makes a kernel busy-spin preemptive: a syscall now
    # cannot starve a STATE_READY peer indefinitely.
    #
    # Safety:
    #   * MUST be called only when no kernel spinlock is held. Hamnix
    #     is UP and has no kernel spinlocks today; if/when SMP lands
    #     this contract becomes load-bearing.
    #   * Caller MUST be prepared for IRQ side effects: jiffies has
    #     advanced, signals may have been posted, virtio rings may
    #     have moved. Most kernel pollers already cope with all three
    #     (that's the whole point of the poll loop).
    #   * Caller MUST be prepared for schedule() to return after any
    #     length of wall-clock — the task may have been off-CPU for
    #     other slices. Loop conditions that read get_jiffies() / the
    #     PIT counter / TSC handle this naturally.
    local_irq_enable()
    # PURE-INSTRUMENTATION idle marker: a syscall-context cond-resched
    # halts here (IF=1) precisely because there is nothing to do but
    # wait for the next IRQ — real idle. Raise the flag across the hlt
    # only; it is read solely by the timer ISR's jiffie classifier and
    # never gates any scheduling decision.
    cpu_idle_enter()
    asm_volatile("hlt")
    cpu_idle_leave()
    local_irq_disable()
    # Rotate if there's any STATE_READY peer. schedule() is a no-op
    # when nobody else wants the CPU, so the cost in the single-task
    # case is one branch + one _another_task_ready scan (NTASKS=256
    # array probes — comfortably cheap).
    if _another_task_ready() != 0:
        schedule()


# --- Event-driven wait queues ------------------------------------
#
# Replaces the timer-tick poll-yield model for blocking I/O. A reader
# that finds its resource empty links itself onto the resource's
# WaitQueue, transitions to STATE_WAIT (off the runqueue — _pick_next
# never selects it, the timer tick never re-polls it), and idles. The
# producer (UART RX IRQ, pipe write, pty peer write) that makes data
# available calls wq_wake_one / wq_wake_all, which moves the waiter(s)
# back to STATE_READY and unlinks them. The signal path also force-wakes
# a STATE_WAIT task so a blocked read returns -EINTR on Ctrl-C.
#
# This is the Linux TASK_INTERRUPTIBLE shape: sleep until explicitly
# woken, not spin-poll. The win on a busy multi-task box is that the
# sleeper is genuinely OFF the runqueue — it consumes no scheduler
# rotations and is not re-polled every 10 ms. On a single-idle-task box
# (e.g. hamsh alone, blocked on stdin) the behaviour necessarily
# converges to "hlt until the producer IRQ fires", which is correct and
# unavoidable: there is literally nothing else to run.
#
# Intrusive singly-linked list (Linux shape, no fixed caps): WaitQueue
# holds a head field (1 + the slot index of the first waiter, or 0 for
# empty). Each task's wait_next field is 1 + the slot index of the next
# waiter (or 0 for end-of-list). The +1 bias lets 0 mean "none" while
# slot 0 stays a valid task.
#
# SMP safety: all queue + state mutation is done under rq_lock, the same
# lock schedule() uses for task_table[*].state. rq_lock is NEVER held
# across the hlt in wq_sleep (deadlock + the producer IRQ that wakes us
# needs to take rq_lock). wq_wake_* is safe from IRQ context — it takes
# rq_lock, flips states, releases, and NEVER calls schedule().

# EINTR (4): wq_sleep_interruptible returns -EINTR when the wake was a
# signal-wake (Ctrl-C etc.) rather than a data-wake, so the caller aborts
# the read with -EINTR exactly like a Linux interruptible sleep.
WQ_EINTR: int32 = -4
# TIMEOUT (5): wq_wait_commit_timeout returns this when the bounded
# sleep elapsed `ticks` jiffies without a producer wake. The caller
# uses it as a "go re-poll the device once and re-check" signal — the
# TCG fallback that keeps net I/O from wedging when MSI-X rx IRQs are
# not delivered. It is NOT an error: the caller loops and re-arms.
WQ_TIMEOUT: int32 = -5

class WaitQueue:
    # head: 1 + slot index of the first waiter, or 0 for empty.
    head: uint64


def wq_init(wq: Ptr[WaitQueue]):
    wq[0].head = 0


def _wq_unlink_locked(wq: Ptr[WaitQueue], slot: uint64) -> uint64:
    # Remove `slot` from `wq`'s waiter list if present. Returns 1 if it
    # was actually on the list, 0 if not (already unlinked by a racing
    # waker). Caller MUST hold rq_lock. Clears the task's wait_next /
    # wait_on link state on success.
    cur: uint64 = wq[0].head
    if cur == 0:
        return 0
    target: uint64 = slot + 1
    if cur == target:
        # Head removal.
        wq[0].head = task_table[slot].wait_next
        task_table[slot].wait_next = 0
        task_table[slot].wait_on   = 0
        return 1
    # Walk to find the predecessor.
    prev_b: uint64 = cur
    while prev_b != 0:
        prev_slot: uint64 = prev_b - 1
        nxt: uint64 = task_table[prev_slot].wait_next
        if nxt == target:
            task_table[prev_slot].wait_next = task_table[slot].wait_next
            task_table[slot].wait_next = 0
            task_table[slot].wait_on   = 0
            return 1
        prev_b = nxt
    return 0


def wq_sleep_interruptible(wq: Ptr[WaitQueue]) -> int32:
    # Block the current task on `wq` until a producer wakes it (return 0)
    # or a signal is delivered (return -EINTR). MUST be called from
    # syscall (ring-0) context with no kernel spinlock held. On entry the
    # caller has already re-checked the resource and found it empty.
    #
    # HAZARD (see schedule()): when this task is the ONLY runnable thing
    # (the common idle case), we must NOT route through schedule() with a
    # non-RUNNING/non-READY state — schedule() would take its "no live
    # tasks; halting" branch and HALT THE BOX. So: only hand off to
    # schedule() when another task IS ready; otherwise idle on a
    # sti;hlt;cli loop (IF=1 so the producer's IRQ can fire and wake us),
    # re-checking the wakeup condition (state flipped back to READY) and
    # pending signals each iteration. On a busy box the task is STATE_WAIT
    # and off the runqueue while it waits; on an idle box this converges
    # to hlt-until-IRQ, which is correct.
    cur: uint64 = current_idx_pcpu

    # Fast path: a signal is already pending — don't sleep, abort now.
    if signal_pending(cur) != 0:
        return WQ_EINTR

    _wq_lock_irq()
    # Link onto the queue head (LIFO is fine; order among waiters on the
    # same resource is unspecified) and go to sleep.
    task_table[cur].wait_signaled = 0
    task_table[cur].wait_next = wq[0].head
    task_table[cur].wait_on   = cur + 1
    wq[0].head = cur + 1
    task_table[cur].state = STATE_WAIT
    _wq_unlock_irq()

    rc: int32 = 0
    while True:
        # Are we still asleep on the queue? A producer wake (wq_wake_*)
        # or a signal force-wake flips us to STATE_READY and unlinks us.
        _wq_lock_irq()
        still_waiting: uint64 = 0
        if task_table[cur].state == STATE_WAIT:
            still_waiting = 1
        _wq_unlock_irq()

        if still_waiting == 0:
            # We were woken. wait_signaled distinguishes a signal-wake
            # from a data-wake.
            if task_table[cur].wait_signaled != 0:
                rc = WQ_EINTR
            break

        # A signal posted to us while we sleep must also break us out,
        # even if the signal path didn't reach the force-wake (defensive).
        if signal_pending(cur) != 0:
            _wq_lock_irq()
            _wq_unlink_locked(wq, cur)
            if task_table[cur].state == STATE_WAIT:
                task_table[cur].state = STATE_RUNNING
            _wq_unlock_irq()
            rc = WQ_EINTR
            break

        # If another task is ready, give it the CPU via schedule() —
        # we're STATE_WAIT so schedule() picks the peer and we come back
        # here only when re-readied. If nobody else is ready, idle-hlt
        # with IF=1 so the producer IRQ can fire and wake us. We MUST NOT
        # call schedule() in the no-peer case — its halt branch panics.
        if _another_task_ready() != 0:
            schedule()
            # When schedule() returns to us we have been re-dispatched,
            # which only happens after a wake flipped us READY->RUNNING.
            # Loop to re-test state at the top (covers the spurious case).
        else:
            local_irq_enable()
            cpu_idle_enter()
            asm_volatile("hlt")
            cpu_idle_leave()
            local_irq_disable()

    # Belt-and-braces: guarantee we are fully unlinked and runnable
    # before returning (handles any racing-wake corner).
    _wq_lock_irq()
    _wq_unlink_locked(wq, cur)
    if task_table[cur].state == STATE_WAIT:
        task_table[cur].state = STATE_RUNNING
    _wq_unlock_irq()
    task_table[cur].wait_signaled = 0
    return rc


# --- Two-phase wait (closes the SMP lost-wakeup window) ----------
#
# wq_sleep_interruptible above has an inherent race on SMP: the caller
# does its resource check (e.g. pipe_read -> 0) OUTSIDE any lock, then
# calls wq_sleep_interruptible which links + sleeps. Between those two
# steps a producer on ANOTHER CPU can fill the resource and call
# wq_wake_* — finding the queue still empty (we haven't linked yet), so
# it wakes nobody. We then link and sleep forever with data waiting.
# The console path papers over this with a 100 Hz timer-tick re-wake,
# but pipe/pty have no such net.
#
# The fix is the standard Linux prepare_to_wait / condition-recheck /
# finish_wait dance:
#
#   wq_wait_prepare(wq)         # link current onto wq, set STATE_WAIT
#   if resource_now_ready():    # RE-CHECK after we are queued
#       wq_wait_cancel(wq)      # unlink, back to RUNNING, consume data
#   else:
#       rc = wq_wait_commit(wq) # actually sleep until woken / signalled
#
# Because the producer takes rq_lock in wq_wake_* and we hold rq_lock
# across "link + set STATE_WAIT" in wq_wait_prepare, the recheck after
# prepare cannot miss a wake: either the producer's wake ran before our
# prepare (so our recheck sees the data and we cancel), or it runs after
# (so it finds us queued and wakes us). No lost wakeup.
def wq_wait_prepare(wq: Ptr[WaitQueue]):
    # Phase 1: atomically link the current task onto `wq` and mark it
    # STATE_WAIT. After this returns the caller MUST re-check its resource
    # condition and then call exactly one of wq_wait_cancel (condition now
    # true) or wq_wait_commit (sleep). Caller holds NO spinlock on entry.
    cur: uint64 = current_idx_pcpu
    _wq_lock_irq()
    task_table[cur].wait_signaled = 0
    task_table[cur].wait_next = wq[0].head
    task_table[cur].wait_on   = cur + 1
    wq[0].head = cur + 1
    task_table[cur].state = STATE_WAIT
    _wq_unlock_irq()


def wq_wait_cancel(wq: Ptr[WaitQueue]):
    # Abort a prepared wait WITHOUT sleeping: the post-prepare recheck
    # found the resource ready. Unlink from `wq` and return to STATE_RUNNING.
    cur: uint64 = current_idx_pcpu
    _wq_lock_irq()
    _wq_unlink_locked(wq, cur)
    if task_table[cur].state == STATE_WAIT:
        task_table[cur].state = STATE_RUNNING
    _wq_unlock_irq()
    task_table[cur].wait_signaled = 0


def wq_wait_commit(wq: Ptr[WaitQueue]) -> int32:
    # Phase 2: the resource is still not ready after prepare — actually
    # sleep until a producer wake or a signal. Returns 0 on a data-wake,
    # WQ_EINTR on a signal-wake. Same halt-hazard discipline as
    # wq_sleep_interruptible: only schedule() when a peer is ready, else
    # sti;hlt;cli idle. Current task is ALREADY linked + STATE_WAIT from
    # wq_wait_prepare.
    cur: uint64 = current_idx_pcpu
    rc: int32 = 0
    while True:
        _wq_lock_irq()
        still_waiting: uint64 = 0
        if task_table[cur].state == STATE_WAIT:
            still_waiting = 1
        _wq_unlock_irq()

        if still_waiting == 0:
            if task_table[cur].wait_signaled != 0:
                rc = WQ_EINTR
            break

        if signal_pending(cur) != 0:
            _wq_lock_irq()
            _wq_unlink_locked(wq, cur)
            if task_table[cur].state == STATE_WAIT:
                task_table[cur].state = STATE_RUNNING
            _wq_unlock_irq()
            rc = WQ_EINTR
            break

        if _another_task_ready() != 0:
            schedule()
        else:
            local_irq_enable()
            cpu_idle_enter()
            asm_volatile("hlt")
            cpu_idle_leave()
            local_irq_disable()

    _wq_lock_irq()
    _wq_unlink_locked(wq, cur)
    if task_table[cur].state == STATE_WAIT:
        task_table[cur].state = STATE_RUNNING
    _wq_unlock_irq()
    task_table[cur].wait_signaled = 0
    return rc


def wq_wait_commit_timeout(wq: Ptr[WaitQueue], ticks: uint64) -> int32:
    # Phase 2 with a BOUNDED sleep. Same as wq_wait_commit, but if no
    # producer wake / signal arrives within `ticks` jiffies we give up
    # the sleep and return WQ_TIMEOUT so the caller can pump its device
    # once and re-arm. Returns 0 on a data-wake, WQ_EINTR on a signal-
    # wake, WQ_TIMEOUT when the bounded interval elapsed. Current task is
    # ALREADY linked + STATE_WAIT from wq_wait_prepare.
    #
    # This is the TCG net-I/O safety net (see drivers/net/tcp.ad). Under
    # working MSI-X the rx IRQ calls wq_wake_* during our idle hlt → we
    # return 0 IMMEDIATELY (fast path, zero added latency). Under TCG,
    # where rx interrupts may not be delivered, the 100 Hz LAPIC timer
    # still fires during the IF=1 hlt and advances `jiffies`; after
    # `ticks` of those we return WQ_TIMEOUT and the caller re-runs
    # virtio_net_poll() — degrading gracefully to today's poll model
    # with no wedge. The timer-tick dependency is identical to
    # kernel_cond_resched's: `jiffies` advances during the sti;hlt window.
    cur: uint64 = current_idx_pcpu
    deadline: uint64 = get_jiffies() + ticks
    rc: int32 = 0
    while True:
        _wq_lock_irq()
        still_waiting: uint64 = 0
        if task_table[cur].state == STATE_WAIT:
            still_waiting = 1
        _wq_unlock_irq()

        if still_waiting == 0:
            if task_table[cur].wait_signaled != 0:
                rc = WQ_EINTR
            break

        if signal_pending(cur) != 0:
            _wq_lock_irq()
            _wq_unlink_locked(wq, cur)
            if task_table[cur].state == STATE_WAIT:
                task_table[cur].state = STATE_RUNNING
            _wq_unlock_irq()
            rc = WQ_EINTR
            break

        # Bounded-wait expiry: the timer has advanced jiffies past our
        # deadline without anyone waking us. Unlink and report TIMEOUT so
        # the caller re-pumps the device. This is the TCG fallback edge.
        if get_jiffies() >= deadline:
            _wq_lock_irq()
            _wq_unlink_locked(wq, cur)
            if task_table[cur].state == STATE_WAIT:
                task_table[cur].state = STATE_RUNNING
            _wq_unlock_irq()
            rc = WQ_TIMEOUT
            break

        if _another_task_ready() != 0:
            schedule()
        else:
            local_irq_enable()
            cpu_idle_enter()
            asm_volatile("hlt")
            cpu_idle_leave()
            local_irq_disable()

    _wq_lock_irq()
    _wq_unlink_locked(wq, cur)
    if task_table[cur].state == STATE_WAIT:
        task_table[cur].state = STATE_RUNNING
    _wq_unlock_irq()
    task_table[cur].wait_signaled = 0
    return rc


def _wq_place_woken(slot: uint64):
    # Per-CPU rq (#6): a waiter just transitioned WAIT->READY under wq_lock.
    # Assign it an owning runqueue (rq_cpu) and direct a reschedule IPI to
    # that CPU so an idle owner wakes and dispatches it. Called WHILE wq_lock
    # is held (lock order wq_lock -> rq_locks[target] is honoured by
    # sched_make_ready_on internally taking only the TARGET rq lock). The
    # state is already STATE_READY; sched_make_ready_on re-stamps it READY
    # under the target rq lock (idempotent) and sets rq_cpu atomically there.
    #
    # SMP wake fence note: the woken task may still be in its sleep-window
    # (set STATE_WAIT + called schedule() but NOT yet reached __switch_to_asm,
    # so on_cpu==1 and its saved sp is STALE). We do NOT spin on on_cpu here:
    # the waker can be running on the SAME CPU as that task (a wake raised from
    # within its own schedule()/softirq path before __switch runs), and __switch
    # — the only thing that clears on_cpu — sits BELOW us on that CPU's stack,
    # so a spin would self-deadlock. Instead the dispatch side is fenced:
    # _pick_next and _sched_try_pull_locked both refuse a task with on_cpu!=0,
    # so even though we home it on a runqueue now, no CPU dispatches it until
    # __switch_to_asm has committed its sp and cleared on_cpu. Liveness: the
    # owning CPU re-runs _pick_next on its next tick / reschedule-IPI / steal
    # pass, by which point the fence has cleared.
    tc: uint64 = sched_pick_target_cpu(slot)
    sched_make_ready_on(slot, tc)


def wq_wake_one(wq: Ptr[WaitQueue]):
    # Move the first waiter on `wq` (if any) from STATE_WAIT back to
    # STATE_READY and unlink it. Safe from IRQ context. Never calls
    # schedule().
    #
    # Per-CPU rq (#6): the wait-queue LIST + the WAIT->READY flip are done
    # under wq_lock (the wait-queue lock, distinct from the per-CPU rq
    # locks). The woken task is then HOMED on a target cpu's runqueue and a
    # DIRECTED reschedule IPI is sent to exactly that cpu.
    woke:      uint64 = 0
    woke_slot: uint64 = 0
    spinlock_lock(&wq_lock)
    h: uint64 = wq[0].head
    if h != 0:
        slot: uint64 = h - 1
        wq[0].head = task_table[slot].wait_next
        task_table[slot].wait_next = 0
        task_table[slot].wait_on   = 0
        if task_table[slot].state == STATE_WAIT:
            task_table[slot].wait_signaled = 0
            task_table[slot].state = STATE_READY
            _wq_place_woken(slot)
            woke = 1
            woke_slot = slot
    spinlock_unlock(&wq_lock)


def wq_wake_all(wq: Ptr[WaitQueue]):
    # Move EVERY waiter on `wq` from STATE_WAIT back to STATE_READY and
    # empty the queue. Safe from IRQ context. Never calls schedule().
    # Each woken task is homed on a target rq + directed-IPI'd (see
    # wq_wake_one). The wait-queue list is walked under wq_lock.
    spinlock_lock(&wq_lock)
    h: uint64 = wq[0].head
    while h != 0:
        slot: uint64 = h - 1
        nxt: uint64 = task_table[slot].wait_next
        task_table[slot].wait_next = 0
        task_table[slot].wait_on   = 0
        if task_table[slot].state == STATE_WAIT:
            task_table[slot].wait_signaled = 0
            task_table[slot].state = STATE_READY
            _wq_place_woken(slot)
        h = nxt
    wq[0].head = 0
    spinlock_unlock(&wq_lock)


# Global console-input wait queue. A task blocked in the FD_STDIN_MARK /
# devcons_read arm sleeps here; the producers that fill the console input
# FIFOs (UART RX IRQ, PS/2 / USB keyboard, wsys cmd injection) call
# console_input_wake() after pushing a byte. One shared queue for all
# console-input readers is correct: any reader can consume the next byte,
# so wake_all (let every blocked reader re-check) is the safe semantics.
console_wq: WaitQueue


def console_input_wake():
    # Producer-side wake for the console input FIFOs (stdin / /dev/cons).
    # Called from the UART RX IRQ drain, the keyboard push path, and the
    # wsys cmd-injection push. Safe from IRQ context (wq_wake_all takes
    # rq_lock and never schedules). A no-op when nobody is blocked.
    wq_wake_all(&console_wq)
    # SYS_WAITFDS: a console-input byte also makes any /dev/cons or stdin
    # fd in a multi-fd wait readable — kick the global waitfds queue so a
    # blocked vfs_waitfds re-scans its fd set. No-op when nobody waits.
    waitfds_notify()


# --- multi-fd readiness wait (SYS_WAITFDS) ---------------------------
#
# ONE global wait queue for every task blocked in vfs_waitfds (fs/vfs.ad).
# This is deliberately the same single-shared-queue shape as console_wq:
# a producer that makes ANY waitable fd readable calls waitfds_notify(),
# which wakes EVERY waitfds sleeper; each woken task re-scans its own fd
# set and either returns a ready index or re-arms. Spurious wakes are
# cheap (a short readiness scan) and the alternative — per-(task, fd)
# wait registration like Linux's poll_table — needs a per-task multi-
# queue link the WaitQueue primitive doesn't have (wait_next is a single
# link, so a task can sit on only ONE queue at a time).
#
# Producers wired to this queue:
#   * console input (UART RX IRQ / PS/2 kbd / wsys cmd inject) — via the
#     console_input_wake() hook above
#   * pipe writes + writer-close EOF      — fs/pipe.ad
#   * devwsys pointer/keys event writes   — sys/src/9/port/devwsys.ad
# A backend NOT on this list (e.g. the PS/2/USB mouse ring) is handled
# by vfs_waitfds with a jiffy-granular bounded sleep instead (see the
# probe-class-2 fallback there) — never a busy spin.
_wfd_wq: WaitQueue


def waitfds_notify():
    # Producer-side wake for SYS_WAITFDS sleepers. Safe from IRQ context
    # (wq_wake_all takes rq_lock and never schedules). A no-op when no
    # task is blocked in vfs_waitfds.
    wq_wake_all(&_wfd_wq)


def waitfds_wq_ptr() -> Ptr[WaitQueue]:
    # The global waitfds queue, for vfs_waitfds' two-phase prepare /
    # re-scan / commit dance.
    return &_wfd_wq


# --- console input grab (P0b) ---------------------------------------
#
# A userland compositor (hamUId) GRABs the LOCAL console input — the
# physical PS/2 keyboard — while the graphical session is up, so the
# boot/login hamsh that shares /dev/cons cannot race it for keystrokes.
# While grabbed, ONLY the grabbing pid may pop a keyboard byte
# (devcons_read / devcons_read_nb consult the predicates below). Any
# other reader is treated as if no keyboard byte were available — its
# blocking read parks on console_wq, its non-blocking read returns
# "would block". The wsys cmd-injection queue is NOT gated (so `echo >
# /dev/wsys/<wid>/cmd` still works for every window). 0 == ungrabbed.
#
# The UART is NOT part of the grab (#439): the serial line is a SEPARATE
# terminal from the local keyboard+framebuffer console (exactly like
# ttyS0 vs tty1+X on Linux, or a second #t line on Plan 9). While a
# compositor holds the grab, UART RX bytes belong to the serial-console
# shell — the holder must NOT pop them, or a desktop event loop that
# drains /dev/cons every frame eats the serial user's keystrokes and
# the serial session goes dead (killed serial input on every default
# `init 5` boot; also hit by the #410 live-Debian gate: the DE starved
# the serial hamsh of the `enter linux { dpkg }` command).
# So the grab PARTITIONS physical input: holder gets the keyboard,
# everyone else keeps the serial line. Ungrabbed, both rings stay
# first-come-first-served as before.
console_input_grab_pid: uint64 = 0


def console_input_grab(pid: uint64):
    console_input_grab_pid = pid


def console_input_ungrab(pid: uint64):
    # Release only if the caller is the holder (or a forced 0 clear).
    if console_input_grab_pid == pid or pid == 0:
        console_input_grab_pid = 0
        # Wake any reader (e.g. the boot/login hamsh) that parked on the
        # console wait queue while the grab was held: now that the grab is
        # released it may pop physical bytes again. Without this wake a
        # reader blocked on console_wq would only resume on the NEXT
        # keystroke, so bytes already sitting in the kbd/UART ring at
        # DE-exit would not be delivered until the user typed again.
        console_input_wake()


def console_input_grabbed_by() -> uint64:
    # 0 == nobody holds the grab; else the holder's pid.
    return console_input_grab_pid


def console_input_may_pop_kbd_current() -> int32:
    # 1 iff the CURRENT task may pop a PHYSICAL KEYBOARD byte right
    # now: either the console is ungrabbed, or the current task IS the
    # grab holder (the compositor owns the local keyboard).
    if console_input_grab_pid == 0:
        return 1
    if current_task_pid() == console_input_grab_pid:
        return 1
    return 0


def console_input_may_pop_uart_current() -> int32:
    # 1 iff the CURRENT task may pop a UART RX (serial line) byte right
    # now. The serial line is its own terminal: ungrabbed it is
    # first-come-first-served, but while a compositor holds the grab
    # the HOLDER is excluded — serial bytes are reserved for the
    # serial-console shell (see the partition comment above).
    if console_input_grab_pid == 0:
        return 1
    if current_task_pid() == console_input_grab_pid:
        return 0
    return 1


def console_wq_sleep() -> int32:
    # Reader-side: block the current task on the console input wait queue.
    # Returns 0 on a data-wake (re-check the FIFO), -EINTR on a signal-wake.
    return wq_sleep_interruptible(&console_wq)


def wq_wake_one_signal(slot: uint64):
    # Signal-wake one specific task: if it is STATE_WAIT (blocked on some
    # wait queue), unlink it from whatever queue it is on and set it
    # STATE_READY with wait_signaled=1 so its wq_sleep_interruptible
    # returns -EINTR. Called from the signal-post path. Caller MUST hold
    # rq_lock (signal_post runs under the same discipline). No-op if the
    # task is not currently sleeping on a queue.
    #
    # We don't have a back-pointer to the WaitQueue struct, so we can't
    # walk its list to splice the node out. Instead we mark the task READY
    # + signaled and leave the stale forward link in place: wq_sleep's
    # post-wake _wq_unlink_locked(wq, cur) (it DOES know its wq) cleans the
    # node out of the list before returning, and wq_wake_* tolerate a
    # not-STATE_WAIT node (they only re-ready STATE_WAIT tasks). Clearing
    # wait_on marks "no longer logically queued".
    #
    # Per-CPU rq (#6): home the freshly-readied task onto a target runqueue
    # and direct a reschedule IPI to that CPU (same as wq_wake_one). Caller
    # holds wq_lock, so the wq_lock -> rq_locks[target] order is honoured by
    # _wq_place_woken -> sched_make_ready_on.
    if task_table[slot].state == STATE_WAIT:
        task_table[slot].wait_signaled = 1
        task_table[slot].wait_on       = 0
        task_table[slot].state         = STATE_READY
        _wq_place_woken(slot)


# --- §3: signals -------------------------------------------------
#
# Bitmap-based signal subsystem. Every TaskStruct carries:
#   sig_pending  — bit N set ⇒ signal N is pending delivery
#   sig_mask     — bit N set ⇒ signal N is BLOCKED (rt_sigprocmask)
#   sig_handlers — per-signal user handler RIP (0 ⇒ SIG_DFL)
#   sig_flags    — per-signal sa_flags (SA_SIGINFO, SA_NODEFER, ...)
#
# Default disposition (SIG_DFL, handler==0) terminates the task with
# exit code 128+N (POSIX). A non-zero handler is invoked in CPL=3 via
# a full Linux-ABI rt_sigframe (siginfo + ucontext) — see
# deliver_signal_to_user. SIG_IGN (handler==1) drops the signal.
#
# Delivery points:
#   1. yield_to_others — after each cooperative yield (covers
#      blocking syscalls like SYS_WAITPID / pipe reads).
#   2. signal_check_and_handle called from do_syscall's tail in
#      arch/x86/kernel/syscall.ad before sysret — covers
#      synchronous syscalls that didn't yield.
#
# BOUNDARY-DISCIPLINE: this Linux-ABI signal mechanism is a Layer-2
# facility for Linux guests. Native (Layer-1) code MUST NOT depend on
# it — the Plan 9 note mechanism (sys/src/9/port/sysnote.ad) is the
# native-side equivalent. The two share TaskStruct storage but never
# call into each other.

SIGINT:  uint64 = 2
SIGKILL: uint64 = 9
SIGSEGV: uint64 = 11
SIGPIPE: uint64 = 13
# setitimer(2) ITIMER_REAL expiry / alarm(2). Default disposition (no handler)
# is terminate; X/GTK apps install a handler and redraw off it.
SIGALRM: uint64 = 14
SIGTERM: uint64 = 15
SIGCHLD: uint64 = 17
# Job-control signals (x86_64 / asm-generic numbering). SIGCONT (18)
# resumes a stopped task; SIGSTOP (19) is the uncatchable stop;
# SIGTSTP (20) is the terminal stop from Ctrl-Z (catchable, but the
# default disposition is the same STOP machinery as SIGSTOP); SIGTTIN
# (21) / SIGTTOU (22) stop a background-group task that touches the
# terminal. All four share STATE_STOPPED bookkeeping.
SIGCONT: uint64 = 18
SIGSTOP: uint64 = 19
SIGTSTP: uint64 = 20
SIGTTIN: uint64 = 21
SIGTTOU: uint64 = 22
# #160 / seccomp-lite: bad system call. Delivered to a task that issues
# a syscall its seccomp filter denies. Default disposition (no handler)
# is terminate, matching Linux strict mode.
SIGSYS:  uint64 = 31

# sa_flags bits we recognise (asm-generic / x86_64 <asm/signal.h>).
SA_SIGINFO:  uint64 = 0x00000004
SA_RESTART:  uint64 = 0x10000000
SA_NODEFER:  uint64 = 0x40000000


def signal_post(slot: uint64, sig: uint64):
    if sig == 0 or sig >= 64:
        return
    bit: uint64 = cast[uint64](1) << sig
    # Job control: SIGCONT resumes a STOPPED task. A stopped task is OFF
    # the runqueue and will never run its own signal_dispatch, so the
    # wake MUST happen here, at post time. POSIX: SIGCONT also discards
    # any pending stop signals, and a continued task notifies its
    # parent (cont_pending → the wait path reports "Continued").
    if sig == SIGCONT:
        stop_mask: uint64 = (cast[uint64](1) << SIGSTOP) \
                          | (cast[uint64](1) << SIGTSTP) \
                          | (cast[uint64](1) << SIGTTIN) \
                          | (cast[uint64](1) << SIGTTOU)
        task_table[slot].sig_pending = task_table[slot].sig_pending & ~stop_mask
        if task_table[slot].state == STATE_STOPPED:
            # Track 5: STOPPED -> READY (SIGCONT resume). Re-home + run-list
            # link via sched_make_ready_on so _pick_next on the owning CPU can
            # dispatch it. sched_make_ready_on re-stamps state READY under the
            # target rq lock (idempotent) and inserts onto the run-list.
            task_table[slot].stop_sig     = 0
            task_table[slot].cont_pending = 1
            sched_make_ready(slot)
        # SIGCONT's default disposition is "continue + ignore" — there is
        # nothing more for signal_dispatch to do, so don't latch the bit
        # unless the task installed a real handler for it.
        if task_table[slot].sig_handlers[SIGCONT] <= 1:
            return
    # Job control: a stop signal aimed at an already-STOPPED task is a
    # no-op (it stays stopped); latching it would resolve spuriously on
    # the next continue. Drop it.
    if task_table[slot].state == STATE_STOPPED:
        if sig == SIGSTOP or sig == SIGTSTP or sig == SIGTTIN \
                or sig == SIGTTOU:
            return
    # Posting a stop signal cancels any not-yet-observed SIGCONT — POSIX.
    if sig == SIGSTOP or sig == SIGTSTP or sig == SIGTTIN or sig == SIGTTOU:
        task_table[slot].sig_pending = \
            task_table[slot].sig_pending & ~(cast[uint64](1) << SIGCONT)
    task_table[slot].sig_pending = task_table[slot].sig_pending | bit
    # getrusage(2): charge the target task exactly one delivered signal at
    # the latch site. The early-return paths above (handler-less SIGCONT,
    # stop signal to an already-STOPPED task) never reach here, so an
    # un-latched signal is correctly not counted.
    task_account_signal_at(slot)
    # Event-driven wait: a task blocked on a resource wait queue (STATE_WAIT)
    # must be force-woken so its wq_sleep_interruptible returns -EINTR and the
    # blocked read aborts. Without this a SIGINT (Ctrl-C) posted to a hamsh
    # sleeping on stdin would only be observed on the NEXT data byte. Hold
    # wq_lock (same discipline as wq_wake_*) across the state flip; the
    # woken task is homed on a target runqueue and directed-IPI'd inside
    # wq_wake_one_signal -> _wq_place_woken, so no extra broadcast is needed.
    _wq_lock_irq()
    wq_wake_one_signal(slot)
    _wq_unlock_irq()


def signal_pending(slot: uint64) -> uint64:
    return task_table[slot].sig_pending


# setitimer(2) ITIMER_REAL accessors. LAYER-2-ONLY: the Linux-ABI
# setitimer/getitimer/alarm handlers (linux_abi/u_syscalls.ad) reach the
# per-task itimer fields through these, keeping core.ad free of any static
# dependency on the linux_abi layer (same one-directional rule as the
# ptrace/seccomp blocks).
def get_task_itimer_real_ticks(slot: uint64) -> uint64:
    if slot >= NTASKS:
        return 0
    return task_table[slot].itimer_real_ticks


def set_task_itimer_real_ticks(slot: uint64, v: uint64):
    if slot >= NTASKS:
        return
    task_table[slot].itimer_real_ticks = v


def get_task_itimer_real_reload(slot: uint64) -> uint64:
    if slot >= NTASKS:
        return 0
    return task_table[slot].itimer_real_reload


def set_task_itimer_real_reload(slot: uint64, v: uint64):
    if slot >= NTASKS:
        return
    task_table[slot].itimer_real_reload = v


def clear_task_itimer(slot: uint64):
    # Disarm this task's ITIMER_REAL. Called on execve (POSIX: interval timers
    # are NOT preserved across exec) and on task_reap (so a recycled slot never
    # inherits a live countdown that would misfire SIGALRM into the new task).
    if slot >= NTASKS:
        return
    task_table[slot].itimer_real_ticks  = 0
    task_table[slot].itimer_real_reload = 0


# Per-tick ITIMER_REAL driver. Called BSP-only from timer_interrupt (once per
# tick, wall-clock). Scans every live task slot: for each armed ITIMER_REAL
# (itimer_real_ticks > 0) decrement one tick; on reaching 0 post SIGALRM to the
# owning task and reload from itimer_real_reload (0 => one-shot, stays disarmed).
# The signal is delivered on the owning task's next return-to-user / wq wake —
# signal_post already force-wakes a STATE_WAIT task (e.g. an X app blocked in
# poll), so the SIGALRM interrupts the blocking syscall and the app redraws.
def itimer_real_tick_all():
    i: uint64 = 0
    while i < NTASKS:
        st: uint64 = task_table[i].state
        # Only decrement live, non-zombie slots. A STATE_FREE/EXITED slot's
        # itimer is already cleared (clear_task_itimer on reap), but guard
        # anyway so a stale value can never fire into a dead slot.
        if st != STATE_FREE and st != STATE_EXITED:
            rem: uint64 = task_table[i].itimer_real_ticks
            if rem != 0:
                rem = rem - 1
                if rem == 0:
                    reload: uint64 = task_table[i].itimer_real_reload
                    task_table[i].itimer_real_ticks = reload
                    signal_post(i, SIGALRM)
                else:
                    task_table[i].itimer_real_ticks = rem
        i = i + 1


# §3: per-task signal-mask accessors. The Linux-ABI rt_sigprocmask
# syscall reads/writes the blocked-signal bitmap through these.
def get_task_sig_mask(slot: uint64) -> uint64:
    return task_table[slot].sig_mask


def set_task_sig_mask(slot: uint64, mask: uint64):
    # SIGKILL (9) and SIGSTOP (19) can NEVER be blocked — POSIX. Force
    # their bits clear no matter what userspace asked for.
    kill_stop: uint64 = (cast[uint64](1) << SIGKILL) \
                      | (cast[uint64](1) << SIGSTOP)
    task_table[slot].sig_mask = mask & ~kill_stop


# §3: per-task sa_flags accessors (recorded by rt_sigaction).
def get_task_sig_flags(slot: uint64, sig: uint64) -> uint64:
    if sig >= 64:
        return 0
    return task_table[slot].sig_flags[sig]


def set_task_sig_flags(slot: uint64, sig: uint64, flags: uint64):
    if sig >= 64:
        return
    task_table[slot].sig_flags[sig] = flags


# §3: in-handler depth flag. 1 while a signal handler runs; cleared by
# rt_sigreturn. Guards against a second signal frame being stacked on
# the same syscall-return slot before the first handler completes.
def get_task_sig_in_handler(slot: uint64) -> uint64:
    return task_table[slot].sig_in_handler


def set_task_sig_in_handler(slot: uint64, v: uint64):
    task_table[slot].sig_in_handler = v


def get_task_sig_saved_mask(slot: uint64) -> uint64:
    return task_table[slot].sig_saved_mask


def set_task_sig_saved_mask(slot: uint64, v: uint64):
    task_table[slot].sig_saved_mask = v


# §3: termination cause. wait4 reads this to decide WIFEXITED vs
# WIFSIGNALED. 0 ⇒ normal exit.
def get_task_term_sig(slot: uint64) -> uint64:
    return task_table[slot].term_sig


# #167: OOM killer primitive. The OOM killer (mm/reclaim.ad) calls this
# to terminate a victim task chosen by the badness heuristic and reclaim
# its memory under hard memory pressure. SIGKILL is uncatchable, so the
# victim is killed unconditionally:
#
#   - latch SIGKILL in sig_pending and record term_sig (so any wait4 on
#     the victim's pid reports a WIFSIGNALED/SIGKILL status),
#   - transition it to STATE_EXITED so the scheduler never runs it again,
#   - reap it through the single task_reap chokepoint, which frees the
#     victim's VMAs / brk arena / stacks / page tables back to the buddy
#     allocator — the actual pressure relief.
#
# The victim MUST NOT be the currently-running task: task_reap tears down
# the victim's stacks and page tables, which is only safe off the
# victim's own context (the OOM killer always runs in another task's
# context, e.g. an allocating task or the boot/self-test task). The
# caller is responsible for that invariant. Returns 1 on a kill, 0 if the
# slot is not a live, reapable task.
def oom_kill_task(slot: uint64) -> int32:
    if slot >= NTASKS:
        return 0
    st: uint64 = task_table[slot].state
    if st == STATE_FREE or st == STATE_EXITED:
        return 0
    task_table[slot].sig_pending = \
        task_table[slot].sig_pending | (cast[uint64](1) << SIGKILL)
    task_table[slot].term_sig = SIGKILL
    task_table[slot].state    = STATE_EXITED
    task_reap(cast[int32](slot))
    return 1


# #75: thread-group fatal termination. On Linux a process-wide fatal event —
# exit_group(2), OR any fatal-default signal (SIGSEGV / SIGABRT / SIGBUS /
# SIGFPE / SIGILL / SIGKILL) delivered to ONE thread — terminates the ENTIRE
# thread group: every CLONE_THREAD sibling dies. Hamnix historically killed
# ONLY the faulting/exiting thread (exit_group == _exit; deliver_fault_sigsegv
# / signal_dispatch task_exit_current'd just `cur`), so a multi-threaded
# process (Firefox: 4-5 threads on one address space) that had one thread
# wild-write-SIGSEGV — or call exit_group / abort() — left its siblings PARKED
# FOREVER in poll/read/futex. No thread ever produced the event/lock the
# survivors waited on, the process never exited, and the parked-watchdog fired
# on the orphaned group (the non-deterministic "read(fd=N) never completes"
# wedge — the stuck fd just being wherever a survivor happened to block).
#
# Fix: post an (uncatchable, unblockable) SIGKILL to every LIVE sibling that
# shares `exclude`'s address space (same cr3 PML4 == same mm == same thread
# group; separate fork()ed processes have distinct PML4s and are untouched).
# signal_post force-wakes a wait-queue-blocked sibling (directed IPI) so it
# leaves its blocking syscall and self-terminates at its next signal check —
# NEVER a cross-CPU reap-from-under-a-running-thread (unsafe): each sibling
# exits on its OWN context through task_exit_current, and task_reap's
# shared-address-space guard tears the mm down EXACTLY ONCE (the last sharer).
# EXITED/FREE slots are skipped, so the natural cascade (each dying sibling
# re-runs this scan) is bounded and idempotent — it converges once every
# member is exiting. The caller then terminates `exclude` itself as before.
def linux_group_fatal_kill(exclude: uint64):
    if exclude >= NTASKS:
        return
    # Confine this to the Linux ABI: only a Linux-userspace task's fatal exit
    # is process-wide by these (glibc/CLONE_THREAD) rules. A NATIVE task —
    # including an rfork-RFMEM shared-address-space group (rio/DE) — keeps its
    # own Plan 9 lifetime semantics untouched, so the DE / weston-native paths
    # never see this new group teardown.
    if task_table[exclude].is_linux_userspace == 0:
        return
    my_mm: uint64 = task_table[exclude].cr3 & 0x000FFFFFFFFFF000
    if my_mm == 0:
        return
    # Only meaningful for a real thread group: a single-threaded process has
    # no other sharer of its mm, so the scan is a cheap no-op there.
    i: uint64 = 0
    while i < NTASKS:
        if i != exclude and task_table[i].is_user != 0 \
                and task_table[i].is_linux_userspace != 0:
            st: uint64 = task_table[i].state
            if st != STATE_FREE and st != STATE_EXITED:
                if (task_table[i].cr3 & 0x000FFFFFFFFFF000) == my_mm:
                    signal_post(i, SIGKILL)
        i = i + 1


# #167: OOM badness / liveness accessors used by mm/reclaim.ad's victim
# scan. Kept here so reclaim never touches task_table directly.
def task_is_user_at(slot: uint64) -> uint64:
    if slot >= NTASKS:
        return 0
    return task_table[slot].is_user


def task_is_live_at(slot: uint64) -> int32:
    # 1 if the slot holds a live (schedulable / runnable / running)
    # task — i.e. a legitimate OOM-kill candidate. STATE_FREE and
    # STATE_EXITED slots are not candidates.
    if slot >= NTASKS:
        return 0
    st: uint64 = task_table[slot].state
    if st == STATE_FREE or st == STATE_EXITED:
        return 0
    return 1


# #147 / ptrace(2). LAYER-2-ONLY accessors. linux_abi/u_ptrace.ad
# reaches the per-task ptrace fields exclusively through these — core.ad
# stays free of any static dependency on the linux_abi layer.
def get_task_pt_tracer_pid(slot: uint64) -> uint64:
    return task_table[slot].pt_tracer_pid


def set_task_pt_tracer_pid(slot: uint64, v: uint64):
    task_table[slot].pt_tracer_pid = v


def get_task_pt_traced(slot: uint64) -> uint64:
    return task_table[slot].pt_traced


def set_task_pt_traced(slot: uint64, v: uint64):
    task_table[slot].pt_traced = v


def get_task_pt_stop_state(slot: uint64) -> uint64:
    return task_table[slot].pt_stop_state


def set_task_pt_stop_state(slot: uint64, v: uint64):
    task_table[slot].pt_stop_state = v


def get_task_pt_options(slot: uint64) -> uint64:
    return task_table[slot].pt_options


def set_task_pt_options(slot: uint64, v: uint64):
    task_table[slot].pt_options = v


def get_task_pt_resume_req(slot: uint64) -> uint64:
    return task_table[slot].pt_resume_req


def set_task_pt_resume_req(slot: uint64, v: uint64):
    task_table[slot].pt_resume_req = v


def get_task_pt_in_syscall(slot: uint64) -> uint64:
    return task_table[slot].pt_in_syscall


def set_task_pt_in_syscall(slot: uint64, v: uint64):
    task_table[slot].pt_in_syscall = v


def get_task_pt_stop_reported(slot: uint64) -> uint64:
    return task_table[slot].pt_stop_reported


def set_task_pt_stop_reported(slot: uint64, v: uint64):
    task_table[slot].pt_stop_reported = v


# ptrace register snapshot accessors. idx is the uint64 slot within the
# 27-entry pt_regs array (canonical user_regs_struct order). Out-of-range
# reads return 0 / writes no-op so a malformed GETREGS can't walk off.
def get_task_pt_reg(slot: uint64, idx: uint64) -> uint64:
    if idx >= 27:
        return 0
    return task_table[slot].pt_regs[idx]


def set_task_pt_reg(slot: uint64, idx: uint64, v: uint64):
    if idx >= 27:
        return
    task_table[slot].pt_regs[idx] = v


# #160 / seccomp-lite. LAYER-2-ONLY accessors. linux_abi/u_syscalls.ad
# reaches the per-task seccomp fields exclusively through these — core.ad
# stays free of any static dependency on the linux_abi layer (mirrors the
# ptrace accessors above).
def get_task_seccomp_mode(slot: uint64) -> uint64:
    return task_table[slot].seccomp_mode


def set_task_seccomp_mode(slot: uint64, v: uint64):
    # Seccomp is IRREVOCABLE once armed: never let a higher (or any)
    # mode be lowered back toward 0. A task can only ever tighten. The
    # caller (prctl/seccomp) is responsible for rejecting a downgrade
    # with -EINVAL/-EACCES; this is the last-line guard so even a buggy
    # caller cannot disarm a filter.
    if task_table[slot].seccomp_mode != 0 and v < task_table[slot].seccomp_mode:
        return
    task_table[slot].seccomp_mode = v


def get_task_seccomp_filter(slot: uint64, word: uint64) -> uint64:
    if word >= 4:
        return 0
    return task_table[slot].seccomp_filter[word]


def set_task_seccomp_filter(slot: uint64, word: uint64, v: uint64):
    if word >= 4:
        return
    task_table[slot].seccomp_filter[word] = v


# #160: is syscall `nr` permitted for the FILTER-mode allow-list bitmap?
# Returns 1 if the bit for nr is set (nr < 256), else 0. Strict-mode's
# fixed allow-set is checked separately in the linux_abi enforcement
# hook; this only consults the per-task bitmap.
def seccomp_filter_allows(slot: uint64, nr: uint64) -> int32:
    if nr >= 256:
        return 0
    word: uint64 = nr >> 6
    bit:  uint64 = cast[uint64](1) << (nr & 63)
    if (task_table[slot].seccomp_filter[word] & bit) != 0:
        return 1
    return 0


# F10-8 / #457: NATIVE seccomp accessors. Same one-directional rule as
# the Layer-2 accessors above — arch/x86/kernel/syscall.ad reaches the
# native filter ONLY through these, and core.ad keeps no static
# dependency on the linux_abi layer (the prctl arm in u_syscalls.ad
# routes through them too).
def get_task_seccomp_native_armed(slot: uint64) -> uint64:
    return task_table[slot].seccomp_native_armed


def set_task_seccomp_native_armed(slot: uint64, v: uint64):
    # IRREVOCABLE: once armed (== 1), refuse to disarm. Matches the
    # Layer-2 seccomp_mode ratchet (set_task_seccomp_mode). The scrub
    # path in sched_init_task_weight writes the field directly to
    # bypass this ratchet for a fresh / reaped+reused slot.
    if task_table[slot].seccomp_native_armed != 0 and v == 0:
        return
    task_table[slot].seccomp_native_armed = v


def get_task_seccomp_native_filter(slot: uint64, word: uint64) -> uint64:
    if word >= 4:
        return 0
    return task_table[slot].seccomp_native_filter[word]


def set_task_seccomp_native_filter(slot: uint64, word: uint64, v: uint64):
    if word >= 4:
        return
    task_table[slot].seccomp_native_filter[word] = v


# F10-8 / #457: native-filter consult. Returns 1 iff syscall nr is in
# the allow-list bitmap (nr < 256). nrs >= 256 (the Plan-9 syscall
# block: SYS_RFORK=256..) are NEVER in the bitmap — they are implicitly
# denied when the filter is armed. Callers must first confirm armed.
def seccomp_native_filter_allows(slot: uint64, nr: uint64) -> int32:
    if nr >= 256:
        return 0
    word: uint64 = nr >> 6
    bit:  uint64 = cast[uint64](1) << (nr & 63)
    if (task_table[slot].seccomp_native_filter[word] & bit) != 0:
        return 1
    return 0


# F10-8 / #457: do_syscall entry probe. Returns 1 if `nr` is BLOCKED
# (the native dispatcher must bounce it with -EPERM), 0 if permitted
# (or the filter is disarmed). No SIGSYS signalling — native Hamnix
# syscalls do not promise a Linux-shape SIGSYS-on-deny path; do_syscall
# returns -EPERM in the user's %rax. The strict allow-set (read/write/
# exit/exit_group/yield/sigreturn shape) is NOT auto-added — a native
# caller must list every nr it wants permitted, including the SYS_EXIT
# the test fixture needs to leave. This is intentional: native userland
# is the orchestrator's product surface, the cost of a denied SYS_EXIT
# is the caller hanging — not a kernel crash — and the per-task filter
# can be tested without dragging in the strict allow-set behaviour.
def seccomp_native_check_entry(slot: uint64, nr: uint64) -> int32:
    if task_table[slot].seccomp_native_armed == 0:
        return 0
    # SYS_SECCOMP_NATIVE itself (320) is ALWAYS permitted on an armed
    # task — without this carve-out the userland NARROW (op=1) path
    # would be unreachable for a confined task (the bitmap only covers
    # nrs 0..255). The body of the SYS_SECCOMP_NATIVE arm enforces the
    # irrevocable ratchet (op=0 re-arm refused, op=1 can only clear
    # bits), so widening through this allow is impossible.
    # (320, NOT 318 — 318 is SYS_LISTDIR_RECORDS.)
    if nr == 320:
        return 0
    if seccomp_native_filter_allows(slot, nr) != 0:
        return 0
    return 1


# §3: address of the in-flight rt_sigframe's ucontext. rt_sigreturn
# reads/clears it through these accessors.
def get_task_sig_frame_uctx(slot: uint64) -> uint64:
    return task_table[slot].sig_frame_uctx


def set_task_sig_frame_uctx(slot: uint64, v: uint64):
    task_table[slot].sig_frame_uctx = v


# §3: POSIX fork inheritance. A fork child inherits the parent's
# signal DISPOSITIONS (sig_handlers + sig_flags) and its signal MASK,
# but NOT the pending-signal set or the in-handler state — those are
# cleared in the child. create_user_task already zeroed everything;
# do_clone's fork path calls this to copy the dispositions + mask
# from the parent. (The thread path does NOT call this — CLONE_THREAD
# siblings share dispositions implicitly via the same process, and
# the existing thread code leaves them zeroed, which is harmless for
# the pthread workloads in the U-track.)
def copy_sig_state_to_child(child_slot: int32, parent_slot: uint64):
    cs: uint64 = cast[uint64](child_slot)
    i: uint64 = 0
    while i < 64:
        task_table[cs].sig_handlers[i] = task_table[parent_slot].sig_handlers[i]
        task_table[cs].sig_flags[i]    = task_table[parent_slot].sig_flags[i]
        i = i + 1
    task_table[cs].sig_mask = task_table[parent_slot].sig_mask
    # Pending set + in-handler state are NOT inherited — POSIX.
    task_table[cs].sig_pending    = 0
    task_table[cs].sig_in_handler = 0
    task_table[cs].sig_saved_mask = 0
    task_table[cs].sig_frame_uctx = 0


# U31: read/write accessors for the per-task signal handler table.
# Exposed so linux_abi/u_syscalls.ad's _u_rt_sigaction can store /
# retrieve handler addresses without poking task_table directly.
def get_task_sig_handler(slot: uint64, sig: uint64) -> uint64:
    if sig >= 64:
        return 0
    return task_table[slot].sig_handlers[sig]


_sigdbg_count: uint64 = 0


def dbg_dump_sig_for_va(slot: uint64, va: uint64):
    # DIAG (Phase-5b): on an NX exec-fault, dump the faulting task's signal
    # state so we can tell whether `va` (the fetch target) is a REGISTERED
    # handler (and for which signal) vs a wild jump, and whether we are in the
    # middle of handler delivery. Rate-limited + EMERG so it reaches the live
    # console.
    if _sigdbg_count >= 6:
        return
    _sigdbg_count = _sigdbg_count + 1
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[sigdbg] slot=%d fault_va=%p\n", slot, va)
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[sigdbg]   in_handler=%d frame_uctx=%p\n",
            task_table[slot].sig_in_handler, task_table[slot].sig_frame_uctx)
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[sigdbg]   pending=%p mask=%p\n",
            task_table[slot].sig_pending, task_table[slot].sig_mask)
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk3("[sigdbg]   altstack sp=%p sz=0x%x fl=0x%x\n",
            task_table[slot].alt_stack_sp, task_table[slot].alt_stack_size,
            task_table[slot].alt_stack_flags)
    s: uint64 = 1
    while s < 64:
        h: uint64 = task_table[slot].sig_handlers[s]
        if h != 0:
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk3("[sigdbg]   sig %d -> handler=%p flags=0x%x\n",
                    s, h, task_table[slot].sig_flags[s])
        s = s + 1


def set_task_sig_handler(slot: uint64, sig: uint64, handler: uint64):
    if sig >= 64:
        return
    task_table[slot].sig_handlers[sig] = handler


def exec_reset_signal_dispositions(slot: uint64):
    # POSIX execve(2) / Linux flush_signal_handlers: on a successful exec the
    # new program image REPLACES the caller's code, so every CAUGHT signal's
    # handler address (a .text VA into the OUTGOING image) is now meaningless —
    # it points into whatever the new image mapped at that VA (typically its
    # .data/.bss). Reset every disposition that was a real handler back to
    # SIG_DFL (0). SIG_IGN (1) is PRESERVED across exec (POSIX: "signals set to
    # be ignored ... remain ignored"), and SIG_DFL (0) is already default.
    # sa_flags for reset signals are cleared. The blocked-signal MASK and any
    # PENDING signals are deliberately KEPT (Linux preserves both across exec).
    #
    # Without this, a fork-then-exec task (e.g. Xwayland's helper, or any
    # posix_spawn'd child) that INHERITED a SIGCHLD handler keeps that stale
    # handler VA; when a grandchild exits, SIGCHLD is delivered to that VA,
    # which in the new image resolves to a non-exec .bss page -> NX exec-fault
    # -> SIGSEGV storm (the Phase-5b X-display gate). Also drop any in-flight
    # handler bookkeeping + the sigaltstack, both of which named addresses in
    # the now-gone image.
    s: uint64 = 1
    while s < 64:
        h: uint64 = task_table[slot].sig_handlers[s]
        # Preserve SIG_IGN (1); reset every real handler (and any stray value)
        # to SIG_DFL. SIG_DFL (0) is left as-is by the same store.
        if h != 1:
            task_table[slot].sig_handlers[s] = 0
            task_table[slot].sig_flags[s]    = 0
        s = s + 1
    # Abandon any half-delivered handler frame — its trampoline/ucontext lived
    # on the outgoing image's stack, which execve has just torn down.
    task_table[slot].sig_in_handler = 0
    task_table[slot].sig_frame_uctx = 0
    # sigaltstack is reset to SS_DISABLE on exec (POSIX): the alt-stack pointer
    # named the old image's memory.
    task_table[slot].alt_stack_sp    = 0
    task_table[slot].alt_stack_size  = 0
    task_table[slot].alt_stack_flags = 0
    # setitimer(2): interval timers are NOT preserved across execve (POSIX) —
    # disarm ITIMER_REAL so the new image starts with no pending SIGALRM.
    task_table[slot].itimer_real_ticks  = 0
    task_table[slot].itimer_real_reload = 0


# U31: PR_SET_NAME / PR_GET_NAME storage backing.
def get_task_comm_ptr(slot: uint64) -> Ptr[uint8]:
    return &task_table[slot].comm[0]


# Phase B / M16.93: Plan 9 errstr buffer accessors. The buffer body
# lives as an inline 128-byte array inside TaskStruct; these helpers
# hand back a Ptr[uint8] so sys/src/9/port/error.ad's memcpy can copy
# either direction without poking task_table across the module
# boundary. ERRMAX matches 9front's /sys/include/libc.h cap.
ERRMAX: uint64 = 128


def get_current_errstr() -> Ptr[uint8]:
    # Returns a kernel pointer at the current task's errstr_buf.
    # Caller must respect ERRMAX as the buffer size. The pointer is
    # stable for the lifetime of the task slot (errstr_buf is inline
    # in TaskStruct, never relocated).
    return &task_table[current_idx_pcpu].errstr_buf[0]


def set_current_errstr(s: Ptr[uint8]):
    # Install a NUL-terminated string into the current task's errstr
    # buffer, truncating at ERRMAX-1 bytes. The trailing slot is forced
    # to 0 so a subsequent SYS_ERRSTR read sees a valid C string even
    # if the caller's source string is exactly ERRMAX bytes long.
    # Empty buffer (s == NULL or s[0] == 0) clears the slot — Plan 9
    # treats that as "no recent error".
    dst: Ptr[uint8] = &task_table[current_idx_pcpu].errstr_buf[0]
    if cast[uint64](s) == 0:
        dst[0] = 0
        return
    i: uint64 = 0
    while i + 1 < ERRMAX:
        c: uint8 = s[i]
        dst[i] = c
        if c == 0:
            return
        i = i + 1
    dst[i] = 0


def set_task_pdeathsig(slot: uint64, sig: uint64):
    task_table[slot].pdeathsig = sig


def get_task_pdeathsig(slot: uint64) -> uint64:
    return task_table[slot].pdeathsig


def set_task_no_new_privs(slot: uint64, v: uint64):
    # One-way ratchet: once armed, stays armed (mirrors Linux).
    if v != 0:
        task_table[slot].no_new_privs = 1


def get_task_no_new_privs(slot: uint64) -> uint64:
    return task_table[slot].no_new_privs


# U37: sigaltstack(2) accessors. Three values stored per task; the
# linux_abi side reads/writes them through these getters/setters
# instead of poking task_table directly across the module boundary.
def get_task_alt_stack_sp(slot: uint64) -> uint64:
    return task_table[slot].alt_stack_sp


def set_task_alt_stack_sp(slot: uint64, v: uint64):
    task_table[slot].alt_stack_sp = v


def get_task_alt_stack_size(slot: uint64) -> uint64:
    return task_table[slot].alt_stack_size


def set_task_alt_stack_size(slot: uint64, v: uint64):
    task_table[slot].alt_stack_size = v


def get_task_alt_stack_flags(slot: uint64) -> int32:
    return task_table[slot].alt_stack_flags


def set_task_alt_stack_flags(slot: uint64, v: int32):
    task_table[slot].alt_stack_flags = v


# U31: read the saved iret-style user RIP / RSP / RFLAGS slots that
# syscall_64.S parks just below the current task's kernel stack top.
# Layout (mirrors the reader in do_clone, syscall.ad):
#   kstack_top - 8  -> user RSP (natural; the entry stub no longer pushes
#                      scratch onto the user stack)
#   kstack_top - 16 -> user RFLAGS
#   kstack_top - 24 -> user RIP
# These are LIVE pointers — writing them retargets the SYSRETQ that
# closes out the current syscall. Only meaningful when we're in the
# middle of servicing a syscall from a CPL=3 caller.
def saved_user_rip_ptr() -> Ptr[uint64]:
    kt: uint64 = task_table[current_idx_pcpu].kstack_top
    return cast[Ptr[uint64]](kt - 24)


def saved_user_rsp_ptr() -> Ptr[uint64]:
    kt: uint64 = task_table[current_idx_pcpu].kstack_top
    return cast[Ptr[uint64]](kt - 8)


def saved_user_rflags_ptr() -> Ptr[uint64]:
    kt: uint64 = task_table[current_idx_pcpu].kstack_top
    return cast[Ptr[uint64]](kt - 16)


# #147 / ptrace(2): the syscall-entry stub (arch/x86/kernel/syscall_64.S)
# spills the user's syscall nr + all six arg registers onto THIS task's
# kernel stack, just below the RIP/RFLAGS/RSP slots above, before it
# calls do_syscall. The push order there is:
#
#   kt - 8   user RSP           (saved_user_rsp_ptr)
#   kt - 16  user RFLAGS (r11)  (saved_user_rflags_ptr)
#   kt - 24  user RIP    (rcx)  (saved_user_rip_ptr)
#   kt - 32  user r13           (callee-saved, do_clone)
#   kt - 40  user r12           (callee-saved, do_clone)
#   kt - 48  user rbx           (callee-saved, do_clone)
#   kt - 56  user rbp           (callee-saved, do_clone)
#   kt - 64  user r14           (callee-saved, do_clone)
#   kt - 72  user r15           (callee-saved, do_clone)
#   kt - 80  user r9   (a5)
#   kt - 88  user r8   (a4)
#   kt - 96  user r10  (a3)
#   kt - 104 user rdx  (a2)
#   kt - 112 user rsi  (a1)
#   kt - 120 user rdi  (a0)
#   kt - 128 user rax  (orig syscall nr)
#
# These are LIVE pointers into the trap frame — writing the arg / rax
# slots retargets what the syscall actually sees / returns (used by
# PTRACE_SETREGS to redirect a traced syscall). Only meaningful while
# servicing a syscall from a CPL=3 caller (i.e. exactly at the ptrace
# enter/exit stop site). Layer-2 (u_ptrace.ad) consumes these to fill
# the user_regs_struct snapshot; native code never calls them.
def saved_user_nr_ptr() -> Ptr[uint64]:
    kt: uint64 = task_table[current_idx_pcpu].kstack_top
    return cast[Ptr[uint64]](kt - 128)


def saved_user_arg0_ptr() -> Ptr[uint64]:        # rdi
    kt: uint64 = task_table[current_idx_pcpu].kstack_top
    return cast[Ptr[uint64]](kt - 120)


def saved_user_arg1_ptr() -> Ptr[uint64]:        # rsi
    kt: uint64 = task_table[current_idx_pcpu].kstack_top
    return cast[Ptr[uint64]](kt - 112)


def saved_user_arg2_ptr() -> Ptr[uint64]:        # rdx
    kt: uint64 = task_table[current_idx_pcpu].kstack_top
    return cast[Ptr[uint64]](kt - 104)


def saved_user_arg3_ptr() -> Ptr[uint64]:        # r10
    kt: uint64 = task_table[current_idx_pcpu].kstack_top
    return cast[Ptr[uint64]](kt - 96)


def saved_user_arg4_ptr() -> Ptr[uint64]:        # r8
    kt: uint64 = task_table[current_idx_pcpu].kstack_top
    return cast[Ptr[uint64]](kt - 88)


def saved_user_arg5_ptr() -> Ptr[uint64]:        # r9
    kt: uint64 = task_table[current_idx_pcpu].kstack_top
    return cast[Ptr[uint64]](kt - 80)


# §3: signal trampoline. Lives in arch/x86/kernel/sigret_asm.S; we
# only ever take its address (planted into the saved-RIP slot to
# retarget the next SYSRETQ).
extern def sig_trampoline()


# §3: Linux-ABI rt_sigframe layout built on the user stack before
# redirecting user RIP to sig_trampoline.
#
# The handler is invoked (via the trampoline) as the SysV-3-arg
#   void handler(int signo, siginfo_t *info, void *ucontext)
# matching glibc/musl's SA_SIGINFO contract. A handler installed
# WITHOUT SA_SIGINFO simply ignores rsi/rdx — the one-arg form
# void handler(int) is a strict prefix, so the same frame serves both.
#
# Frame layout on the user stack (low → high address):
#
#   trampoline RSP → signo        (popped → %rdi  — arg 1)
#                    info_ptr     (popped → %rsi  — arg 2)
#                    uc_ptr       (popped → %rdx  — arg 3)
#                    handler      (popped → %rax  — call target)
#                  ┌ siginfo_t    (SIGFRAME_SIGINFO_SZ bytes)
#       info_ptr ──┘
#                  ┌ ucontext_t   (SIGFRAME_UCTX_SZ bytes)
#         uc_ptr ──┘
#   (high)         original user RSP region — untouched
#
# rt_sigreturn reads the ucontext to restore RIP / RSP / RFLAGS and
# the pre-handler signal mask, then resumes the interrupted code.
#
# Register fidelity: signals are only delivered at a syscall-return
# boundary (do_syscall tail / yield_to_others). At that boundary the
# x86_64 SysV syscall ABI already declares the caller-saved scratch
# registers clobbered, so the ucontext's gpr slots for them carry 0 —
# that is CORRECT for this delivery model. RIP / RSP / RFLAGS are the
# load-bearing fields and ARE faithfully captured and restored.

# struct sizes — generous fixed allocations (Linux's are 128 / ~256).
SIGFRAME_SIGINFO_SZ: uint64 = 128
SIGFRAME_UCTX_SZ:    uint64 = 256

# uc_mcontext.gregs index of RSP / RIP / EFLAGS within the ucontext.
# ucontext layout: uc_flags(0) uc_link(8) uc_stack(16,24B) then
# uc_mcontext at offset 40. mcontext gregs[] starts at uc_mcontext+0.
# gregs order: R8 R9 R10 R11 R12 R13 R14 R15 RDI RSI RBP RBX RDX RAX
#              RCX RSP RIP EFL ... — so RSP is gregs[15], RIP gregs[16],
# EFL gregs[17]. uc_sigmask follows the mcontext.
#   UCTX_GREG_RSP_OFF = 40 + 15*8 = 160
#   UCTX_GREG_RIP_OFF = 40 + 16*8 = 168
#   UCTX_GREG_EFL_OFF = 40 + 17*8 = 176
# (the Adder compiler requires literal global initializers — the
#  arithmetic is spelled out in this comment, not the expression).
#   UCTX_GREG_RAX_OFF = 40 + 13*8 = 144
UCTX_MCONTEXT_OFF: uint64 = 40
UCTX_GREG_RAX_OFF: uint64 = 144             # uc_mcontext.gregs[REG_RAX]
UCTX_GREG_RSP_OFF: uint64 = 160             # uc_mcontext.gregs[REG_RSP]
UCTX_GREG_RIP_OFF: uint64 = 168             # uc_mcontext.gregs[REG_RIP]
UCTX_GREG_EFL_OFF: uint64 = 176             # uc_mcontext.gregs[REG_EFL]
# uc_sigmask sits past the mcontext (gregs[23] + fpstate ptr + pad).
# We park it at a fixed slot inside our generous 256-byte ucontext;
# rt_sigreturn reads it back from the SAME offset, so the exact Linux
# placement only matters to a handler that introspects uc_sigmask
# (rare) — 200 leaves comfortable room after the 184-byte gregs array.
UCTX_SIGMASK_OFF:  uint64 = 200


def deliver_signal_to_user(sig: uint64, handler: uint64,
                           sa_flags: uint64, syscall_rc: uint64):
    rip_slot: Ptr[uint64]    = saved_user_rip_ptr()
    rsp_slot: Ptr[uint64]    = saved_user_rsp_ptr()
    rflags_slot: Ptr[uint64] = saved_user_rflags_ptr()

    saved_rip: uint64    = rip_slot[0]
    saved_rflags: uint64 = rflags_slot[0]
    user_rsp: uint64     = rsp_slot[0]
    # syscall_64.S's entry stub NO LONGER touches the user stack — it spills
    # %r12/%r13 scratch into per-CPU slots (%gs:72/%gs:80) and parks the
    # caller's NATURAL user RSP verbatim at kstack_top-8 (see the "never write
    # the user stack" comment in syscall_64.S; the old `stac; pushq %r12; pushq
    # %r13` onto the user stack #PF'd and was removed). rsp_slot therefore
    # already holds the natural RSP — the historical +16 "undo two pushes"
    # fixup is STALE and shifted the whole rt_sigframe 16 bytes into the
    # caller's live stack. Use user_rsp directly (matches do_clone's
    # parent_user_rsp, which the same asm rev fixed to "no fixup needed", and
    # deliver_fault_sigsegv, which uses the RSP verbatim).
    natural_rsp: uint64  = user_rsp

    # x86_64 ABI: leave a 128-byte red zone below the interrupted RSP
    # untouched — the user code may have live data there.
    base: uint64 = natural_rsp - 128

    # Carve the ucontext and siginfo below the red zone, then the
    # 4-slot pop area. Keep everything 16-byte aligned so the handler
    # sees a SysV-correct stack (callq inside the trampoline pushes 8,
    # so the pop-area top must be 16-aligned).
    uc_ptr:   uint64 = (base - SIGFRAME_UCTX_SZ) & ~cast[uint64](15)
    info_ptr: uint64 = (uc_ptr - SIGFRAME_SIGINFO_SZ) & ~cast[uint64](15)
    pop_top:  uint64 = (info_ptr - 32) & ~cast[uint64](15)

    # SMAP v3c: every cast[Ptr[...]](...) write below targets the user
    # stack (US=1) at CPL=0. Bracket with STAC/CLAC so the stores are
    # legal under CR4.SMAP=1.
    _ua_stac()

    # --- zero-fill siginfo + ucontext -------------------------------
    zi: uint64 = 0
    while zi < SIGFRAME_SIGINFO_SZ:
        cast[Ptr[uint8]](info_ptr + zi)[0] = 0
        zi = zi + 1
    zu: uint64 = 0
    while zu < SIGFRAME_UCTX_SZ:
        cast[Ptr[uint8]](uc_ptr + zu)[0] = 0
        zu = zu + 1

    # --- siginfo_t: si_signo / si_code -------------------------------
    # struct siginfo { int si_signo; int si_errno; int si_code; ... }.
    # si_code = SI_KERNEL (0x80) — "sent by the kernel". A handler that
    # consults si_code (e.g. to tell a kill() from a fault) gets a
    # defensible answer; si_pid / si_uid stay 0.
    cast[Ptr[uint32]](info_ptr)[0]     = cast[uint32](sig)   # si_signo
    cast[Ptr[uint32]](info_ptr + 8)[0] = cast[uint32](128)   # si_code

    # --- ucontext_t: capture the resumption state --------------------
    cur: uint64 = current_idx_pcpu
    cast[Ptr[uint64]](uc_ptr + UCTX_GREG_RSP_OFF)[0] = natural_rsp
    cast[Ptr[uint64]](uc_ptr + UCTX_GREG_RIP_OFF)[0] = saved_rip
    cast[Ptr[uint64]](uc_ptr + UCTX_GREG_EFL_OFF)[0] = saved_rflags
    # %rax holds the interrupted syscall's return value. rt_sigreturn
    # restores it so the interrupted code sees the syscall result it
    # expects — without this, the rt_sigreturn syscall's own return
    # value (0) would leak into the resumed code's %rax and a write()
    # that failed with -EPIPE would look like it returned 0.
    cast[Ptr[uint64]](uc_ptr + UCTX_GREG_RAX_OFF)[0] = syscall_rc
    # uc_sigmask: the blocked-signal set in effect when the handler is
    # entered. rt_sigreturn restores sig_mask FROM this slot. Stored in
    # USER sigset_t convention (signal N at bit N-1, kernel >> 1) so a
    # handler that introspects uc_sigmask sees a correct Linux bitmap;
    # rt_sigreturn shifts it back by 1 on the way in.
    cast[Ptr[uint64]](uc_ptr + UCTX_SIGMASK_OFF)[0] = \
        task_table[cur].sig_saved_mask >> 1

    # --- pop area: signo / info_ptr / uc_ptr / handler ---------------
    cast[Ptr[uint64]](pop_top)[0]      = sig
    cast[Ptr[uint64]](pop_top + 8)[0]  = info_ptr
    cast[Ptr[uint64]](pop_top + 16)[0] = uc_ptr
    cast[Ptr[uint64]](pop_top + 24)[0] = handler
    _ua_clac()

    # Stash the ucontext address so rt_sigreturn can recover the
    # interrupted RIP / RSP / RFLAGS / mask (it takes no syscall args).
    task_table[cur].sig_frame_uctx = uc_ptr

    # Retarget the SYSRETQ:
    #   * user RIP <- sig_trampoline, at its CPL=3-REACHABLE (identity-low,
    #     US=1 RO+X) vaddr that linux_abi/vdso.ad maps into every Linux
    #     task's PML4. The kernel-text &sig_trampoline VA (0xffffffff80...)
    #     is US=0 under SMEP/W^X, so a CPL=3 fetch of it NX-faults — the
    #     `enter linux {sh}` crash. Fall back to the kernel-text VA only in
    #     the pre-first-Linux-exec window (hook returns 0), preserving the
    #     historic behaviour for a native task that somehow gets here.
    #   * user RSP <- pop_top: syscall_64.S's exit tail pops the spilled regs
    #     off the KERNEL stack and `popq %rsp` loads the natural user RSP
    #     verbatim, then SYSRETQ — it performs NO user-stack pops (the entry
    #     stub no longer pushes to the user stack; scratch lives in per-CPU
    #     slots). So SYSRETQ lands RSP at exactly whatever we park here, and
    #     the trampoline's four pops (signo/info/uc/handler) must begin at
    #     `pop_top`. The historical `pop_top - 16` compensated for two
    #     user-stack exit pops that NO LONGER EXIST — SYSRETQ left RSP at
    #     pop_top-16, the trampoline's `pop %rax` (handler) read the info_ptr
    #     slot (a stack address) and `callq *%rax` jumped ONTO the stack:
    #     the `[pf] NX exec-fault va=<ustack>` that killed any SIGCHLD/SIGALRM
    #     handler (Xwayland reaping xkbcomp). This mirrors deliver_fault_-
    #     sigsegv, which already parks RSP at pop_top exactly.
    tramp_va: uint64 = sig_trampoline_user_vaddr_get()
    if tramp_va == 0:
        tramp_va = cast[uint64](&sig_trampoline)
    rip_slot[0] = tramp_va
    rsp_slot[0] = pop_top


def deliver_fault_sigsegv(iret_frame: Ptr[uint64]) -> int32:
    # W^X Stage 1a: deliver SIGSEGV(11) to the current USER task from a
    # #PF (interrupt) context — NOT a syscall-return context. Used when
    # an NX instruction-fetch fault hits a user data page (jmp/call into
    # the stack or heap).
    #
    # `iret_frame` points at the CPU-pushed iret frame on the kernel
    # stack, ascending quads:
    #   [0] = RIP (faulting instruction / fetch target)
    #   [1] = CS
    #   [2] = RFLAGS
    #   [3] = RSP_user
    #   [4] = SS
    #
    # Two dispositions:
    #   * A real user SIGSEGV handler installed  → build the rt_sigframe
    #     on the user stack (mirroring deliver_signal_to_user, but
    #     reading/writing THIS iret frame rather than the kstack
    #     syscall-return slots), retarget the frame's RIP→sig_trampoline
    #     and RSP→pop_top, and return 1. The caller iretq's straight into
    #     the handler. (No `popq %r12` shim here — unlike the syscall
    #     path — so RSP is pop_top exactly, where `signo` sits.)
    #   * No handler (SIG_DFL / SIG_IGN / kernel thread) → terminate the
    #     task with 128+11 = 139 inline; never returns.
    cur: uint64 = current_idx_pcpu
    handler: uint64 = task_table[cur].sig_handlers[SIGSEGV]

    # ROBUSTNESS: force-default when SIGSEGV is already BLOCKED (Linux
    # force_sigsegv semantics). A synchronous fault whose signal the task
    # has masked cannot be "held off" — the very instruction that faulted
    # would re-execute on return and re-fault forever. The first delivery
    # below masks SIGSEGV (sig_mask |= 1<<SIGSEGV) while the handler runs,
    # so if the handler itself re-faults with a #GP/#PF, this handler is
    # re-entered with SIGSEGV blocked. WITHOUT this check we would keep
    # building a fresh rt_sigframe lower on the user stack on every re-fault
    # (the observed 1011x SIGSEGV storm → stack exhaustion in the xeyes
    # redraw #GP). Blocked ⇒ the task cannot make progress ⇒ terminate it
    # (coredump + exit), exactly like the no-handler case. This also covers
    # a program that deliberately blocked SIGSEGV and then faulted.
    segv_blocked: uint64 = (task_table[cur].sig_mask >> SIGSEGV) & cast[uint64](1)

    # Default disposition (no real handler), a non-user task, OR SIGSEGV
    # already blocked (re-fault inside the handler / caller-blocked): kill.
    if handler == 0 or handler == 1 or task_table[cur].is_user == 0 \
            or segv_blocked != 0:
        task_table[cur].term_sig = SIGSEGV
        # #173: ELF core dump BEFORE teardown — the VMA list, page tables
        # and the fault iret frame are all still intact here.
        if task_table[cur].is_user != 0:
            coredump_write_current(SIGSEGV, iret_frame)
        # #75: a fatal SIGSEGV is process-wide — take the whole thread group
        # down, not just the faulting thread, so CLONE_THREAD siblings can't
        # orphan-park forever (the Firefox wild-write wedge). No-op for a
        # single-threaded process.
        if task_table[cur].is_user != 0:
            linux_group_fatal_kill(cur)
        task_exit_current(cast[int64](128) + cast[int64](SIGSEGV))
        return 0                                      # not reached

    # --- build the rt_sigframe on the user stack --------------------
    saved_rip: uint64    = iret_frame[0]
    saved_rflags: uint64 = iret_frame[2]
    user_rsp: uint64     = iret_frame[3]

    # x86_64 ABI red zone (128 bytes below the interrupted RSP).
    base: uint64 = user_rsp - 128
    uc_ptr:   uint64 = (base - SIGFRAME_UCTX_SZ) & ~cast[uint64](15)
    info_ptr: uint64 = (uc_ptr - SIGFRAME_SIGINFO_SZ) & ~cast[uint64](15)
    pop_top:  uint64 = (info_ptr - 32) & ~cast[uint64](15)

    # SMAP v3c: the rt_sigframe sits on the user stack (US=1). Bracket
    # every CPL=0 store below with STAC/CLAC so SMAP doesn't fault them.
    _ua_stac()

    zi: uint64 = 0
    while zi < SIGFRAME_SIGINFO_SZ:
        cast[Ptr[uint8]](info_ptr + zi)[0] = 0
        zi = zi + 1
    zu: uint64 = 0
    while zu < SIGFRAME_UCTX_SZ:
        cast[Ptr[uint8]](uc_ptr + zu)[0] = 0
        zu = zu + 1

    # siginfo_t: si_signo / si_code. SI_KERNEL (0x80) — sent by kernel.
    cast[Ptr[uint32]](info_ptr)[0]     = cast[uint32](SIGSEGV)
    cast[Ptr[uint32]](info_ptr + 8)[0] = cast[uint32](128)

    # ucontext_t: capture the faulting resumption state. %rax slot left 0
    # (no syscall return value to preserve — this is a fault, not a
    # syscall boundary).
    cast[Ptr[uint64]](uc_ptr + UCTX_GREG_RSP_OFF)[0] = user_rsp
    cast[Ptr[uint64]](uc_ptr + UCTX_GREG_RIP_OFF)[0] = saved_rip
    cast[Ptr[uint64]](uc_ptr + UCTX_GREG_EFL_OFF)[0] = saved_rflags
    cast[Ptr[uint64]](uc_ptr + UCTX_SIGMASK_OFF)[0] = \
        task_table[cur].sig_mask >> 1

    # pop area: signo / info_ptr / uc_ptr / handler.
    cast[Ptr[uint64]](pop_top)[0]      = SIGSEGV
    cast[Ptr[uint64]](pop_top + 8)[0]  = info_ptr
    cast[Ptr[uint64]](pop_top + 16)[0] = uc_ptr
    cast[Ptr[uint64]](pop_top + 24)[0] = handler
    _ua_clac()

    task_table[cur].sig_frame_uctx = uc_ptr
    # Defer this signal so a SIGSEGV inside the handler hits default-
    # terminate rather than recursing endlessly.
    task_table[cur].sig_saved_mask = task_table[cur].sig_mask
    set_task_sig_mask(cur, task_table[cur].sig_mask \
                      | (cast[uint64](1) << SIGSEGV))
    task_table[cur].sig_in_handler = 1

    # Retarget the iret frame straight into the trampoline at its CPL=3-
    # reachable (identity-low, US=1 RO+X) vaddr — see deliver_signal_to_user
    # for why the kernel-text &sig_trampoline VA NX-faults under SMEP.
    # Unlike the syscall path there is NO `popq %r12` shim, so RSP must be
    # pop_top exactly (where `signo` sits), not pop_top - 8.
    fault_tramp_va: uint64 = sig_trampoline_user_vaddr_get()
    if fault_tramp_va == 0:
        fault_tramp_va = cast[uint64](&sig_trampoline)
    iret_frame[0] = fault_tramp_va
    iret_frame[3] = pop_top
    return 1


def signal_dispatch(syscall_rc: uint64, allow_handler: int32):
    # Deliver the highest-priority pending+unblocked signal on the
    # current task. SIG_DFL (handler 0) → terminate 128+sig; SIG_IGN
    # (handler 1) → drop; a real handler → rt_sigframe + redirect.
    #
    # Lowest-numbered pending signal wins (POSIX): SIGINT (2) outranks
    # SIGTERM (15) if both land before the task notices.
    #
    # syscall_rc — the return value of the syscall whose tail we are
    #   running at. Stashed into the rt_sigframe's %rax slot so
    #   rt_sigreturn restores the interrupted code's %rax correctly.
    # allow_handler — 1 ⇒ user-handler delivery is permitted (only the
    #   do_syscall exit-side check, which knows the real syscall_rc,
    #   passes 1). 0 ⇒ only the default-terminate disposition acts;
    #   a pending user-handler signal stays latched for the exit check
    #   (which has the correct %rax). This keeps the entry-side and
    #   mid-syscall (yield_to_others) checks from building a frame with
    #   a wrong %rax — SIG_DFL termination needs no %rax so it is
    #   always safe.
    cur: uint64 = current_idx_pcpu
    pending: uint64 = task_table[cur].sig_pending
    if pending == 0:
        return
    # A handler already in flight on this syscall-return frame? We must NOT
    # stack a second CATCHABLE-handler frame on top — that would corrupt the
    # first handler's saved context — so a pending user-handler signal stays
    # latched and is delivered after the in-flight handler's rt_sigreturn.
    # BUT a DEFAULT-terminate FATAL disposition (SIG_DFL SIGABRT/SEGV/ILL/
    # BUS/FPE, or SIGKILL) MUST still fire even mid-handler: glibc abort()
    # raises SIGABRT and then UNBLOCKS it from *inside* the SIGALRM redraw
    # handler (sig_in_handler=1); if we bailed unconditionally the SIGABRT
    # would never be delivered and abort() would fall through to its `hlt`
    # "unreachable" trap → a CPL=3 #GP (the xeyes 428507 fault storm). So when
    # a handler is in flight we bail ONLY if no pending signal is a fatal-
    # default/SIGKILL kill — a non-fatal signal (SIGWINCH, a catchable one)
    # stays deferred exactly as before; a fatal one falls through to the scan
    # and terminates (the catchable-DELIVERY branch below re-checks
    # sig_in_handler so it never stacks a second handler frame).
    if task_table[cur].sig_in_handler != 0:
        _mh_mask: uint64 = task_table[cur].sig_mask
        _mh_kill: uint64 = 0
        _mh_s: uint64 = 1
        while _mh_s < 64:
            _mh_bit: uint64 = cast[uint64](1) << _mh_s
            if (pending & _mh_bit) != 0:
                if _mh_s == SIGKILL or (_mh_mask & _mh_bit) == 0:
                    _mh_h: uint64 = task_table[cur].sig_handlers[_mh_s]
                    if _mh_s == SIGKILL \
                            or ((_mh_h == 0 or task_table[cur].is_user == 0) \
                                and coredump_is_fatal_sig(_mh_s) != 0):
                        _mh_kill = 1
            _mh_s = _mh_s + 1
        if _mh_kill == 0:
            return
    mask: uint64 = task_table[cur].sig_mask
    s: uint64 = 1
    while s < 64:
        bit: uint64 = cast[uint64](1) << s
        # SIGKILL is uncatchable AND unblockable — it bypasses the mask
        # entirely. Every other signal that the task has blocked stays
        # latched in sig_pending and is skipped here.
        if (pending & bit) != 0:
            if s == SIGKILL or (mask & bit) == 0:
                handler: uint64 = task_table[cur].sig_handlers[s]
                # SIGKILL is uncatchable. SIG_DFL is handler == 0;
                # SIG_IGN is conventionally 1. Values < 16 are not real
                # addresses → fall back to default-terminate. Kernel
                # threads have no iret frame, so they always default.
                is_default: int32 = 0
                if s == SIGKILL or handler == 0 or handler == 1 \
                        or task_table[cur].is_user == 0:
                    is_default = 1
                if is_default != 0:
                    # Clear the bit; the disposition is resolved here.
                    task_table[cur].sig_pending = \
                        task_table[cur].sig_pending & ~bit
                    if handler == 1 and s != SIGKILL:
                        # SIG_IGN: drop silently, keep scanning.
                        s = s + 1
                        continue
                    # Job control: SIGSTOP/SIGTSTP/SIGTTIN/SIGTTOU default
                    # disposition is STOP, not terminate. Park the task in
                    # STATE_STOPPED (off the runqueue) and schedule away.
                    # When a SIGCONT later arrives signal_post flips it
                    # back to STATE_READY. PID 1 (the shell) is exempt —
                    # stopping the shell would wedge the console — so a
                    # stop signal that somehow reaches pid 1 is dropped.
                    if s == SIGSTOP or s == SIGTSTP or s == SIGTTIN \
                            or s == SIGTTOU:
                        if task_table[cur].pid <= 1:
                            s = s + 1
                            continue
                        task_table[cur].stop_sig = s
                        task_table[cur].state    = STATE_STOPPED
                        # Tell the parent a child stopped (job-control
                        # wait path reports "Stopped"). SIGCHLD is the
                        # POSIX carrier — but ONLY raise it when the parent
                        # actually installed a SIGCHLD handler. Default
                        # SIGCHLD disposition is SIG_IGN-equivalent (Linux
                        # semantics); posting it to a handler-less parent
                        # would latch a bit that signal_dispatch then
                        # resolves as the SIG_DFL "terminate 128+17"
                        # action — which would kill PID 1 (the shell) with
                        # exit code 145 the instant it next yields. The
                        # job-control wait path uses sys_waitpid_jc polling,
                        # not SIGCHLD, so suppressing the unhandled signal
                        # loses nothing. Mirrors the exit-side guard in
                        # task_exit_current().
                        ppid_s: uint64 = task_table[cur].parent_pid
                        pslot_s: int32 = task_lookup_by_pid(ppid_s)
                        if pslot_s >= 0:
                            psu_s: uint64 = cast[uint64](pslot_s)
                            chld_hs: uint64 = \
                                task_table[psu_s].sig_handlers[SIGCHLD]
                            if chld_hs > 1:
                                signal_post(psu_s, SIGCHLD)
                        # Yield the CPU; we are no longer runnable.
                        schedule()
                        # Resumed (SIGCONT made us READY and the scheduler
                        # picked us). Keep scanning for further pending.
                        s = s + 1
                        continue
                    # SIGCONT with no real handler: nothing to do here
                    # (the resume already happened in signal_post). Skip.
                    if s == SIGCONT:
                        s = s + 1
                        continue
                    task_table[cur].term_sig = s
                    # #173: ELF core dump for a fatal fault signal whose
                    # default disposition is terminate+dump (SIGILL/ABRT/
                    # BUS/FPE/SEGV). No iret frame is available on this
                    # syscall-return path, so registers are captured as
                    # zero — the VMA image is still dumped. Non-fatal
                    # default-terminate signals (SIGTERM/SIGINT/...) are
                    # skipped by coredump_is_fatal_sig.
                    if task_table[cur].is_user != 0 \
                            and coredump_is_fatal_sig(s) != 0:
                        coredump_write_current(s, cast[Ptr[uint64]](0))
                    # #75: a fatal-default signal (SIGKILL / SIGSEGV / SIGABRT /
                    # SIGBUS / SIGFPE / SIGILL) is process-wide on Linux — every
                    # CLONE_THREAD sibling dies too. Post SIGKILL to the group so
                    # a thread that abort()s / is killed doesn't leave siblings
                    # parked forever. The posted-SIGKILL cascade is idempotent
                    # and bounded (EXITED sharers are skipped). Skip for the
                    # non-fatal default-terminate signals (SIGTERM/SIGINT/…)?
                    # No — those are ALSO process-wide when unhandled; only the
                    # job-control STOP/CONT and SIG_IGN cases returned above.
                    if task_table[cur].is_user != 0:
                        linux_group_fatal_kill(cur)
                    task_exit_current(cast[int64](128) + cast[int64](s))
                    return                            # not reached
                # Real user handler. A handler already in flight on this
                # syscall-return frame? Do NOT stack a second frame on top —
                # that would corrupt the first handler's saved context. Leave
                # this catchable signal latched and KEEP SCANNING (not return)
                # so a higher-numbered FATAL default-terminate signal that got
                # us past the mid-handler gate above (e.g. abort()'s SIGABRT)
                # still reaches its terminate disposition instead of being
                # shadowed by a lower-numbered catchable signal.
                if task_table[cur].sig_in_handler != 0:
                    s = s + 1
                    continue
                # Defer it to the exit-side check if this caller cannot supply
                # the syscall return value (entry / mid-syscall yield) —
                # leaving the bit latched.
                if allow_handler == 0:
                    return
                # Clear the bit before dispatching so a handler issuing
                # another syscall doesn't re-trigger off it.
                task_table[cur].sig_pending = \
                    task_table[cur].sig_pending & ~bit
                # Build the blocked-mask the handler runs under: the
                # pre-handler mask, plus this signal itself (unless
                # SA_NODEFER).
                sa_flags: uint64 = task_table[cur].sig_flags[s]
                task_table[cur].sig_saved_mask = mask
                new_mask: uint64 = mask
                if (sa_flags & SA_NODEFER) == 0:
                    new_mask = new_mask | bit
                set_task_sig_mask(cur, new_mask)
                task_table[cur].sig_in_handler = 1
                deliver_signal_to_user(s, handler, sa_flags, syscall_rc)
                return
        s = s + 1


def signal_check_and_handle():
    # Terminate-only signal check. Used by the do_syscall ENTRY-side
    # probe and by yield_to_others (mid-syscall): a SIG_DFL signal
    # terminates the task promptly, but a user-handler signal is left
    # latched for signal_deliver_on_return — which knows the real
    # syscall %rax. Kept as the historical no-arg name so existing
    # callers in the trap / yield paths need no change.
    signal_dispatch(0, 0)


def signal_deliver_on_return(syscall_rc: uint64) -> uint64:
    # do_syscall exit-side delivery. Knows the syscall's return value,
    # so it can build a faithful rt_sigframe (correct %rax) and is the
    # ONLY caller permitted to deliver a user handler. Returns the
    # syscall_rc unchanged so do_syscall can `return` it directly.
    signal_dispatch(syscall_rc, 1)
    return syscall_rc


# --- job control: process-group + terminal-foreground tracking ----
#
# The console/terminal has exactly one FOREGROUND process group at a
# time. hamsh (PID 1) owns the terminal at the prompt; when it puts a
# pipeline in the foreground it sets terminal_fg_pgid to that pipeline's
# pgid via SYS_TCSETPGRP, and restores its own pgid (1) when the job
# exits/stops. Ctrl-C / Ctrl-Z deliver their signal to terminal_fg_pgid
# ONLY — background jobs are insulated, exactly like Unix.
#
# 0 means "no job in the foreground" (the shell itself is reading): a
# terminal signal at the bare prompt is then dropped, matching what a
# serial-console user expects.
terminal_fg_pgid: uint64 = 0


def set_terminal_fg_pgid(pgid: uint64):
    terminal_fg_pgid = pgid


def get_terminal_fg_pgid() -> uint64:
    return terminal_fg_pgid


def task_set_job_pgid(slot: uint64, pgid: uint64):
    task_table[slot].job_pgid = pgid


def task_get_job_pgid(slot: uint64) -> uint64:
    p: uint64 = task_table[slot].job_pgid
    if p == 0:
        return task_table[slot].pid
    return p


def signal_post_to_pgid(pgid: uint64, sig: uint64) -> int32:
    # Deliver `sig` to every alive member of process group `pgid`.
    # PID 1 is NEVER signalled here even if it shares the pgid — a
    # terminal stop/interrupt must never wedge the shell. Returns the
    # number of tasks the signal was posted to.
    if pgid == 0:
        return 0
    n: uint64 = NTASKS
    i: uint64 = 0
    hit: int32 = 0
    while i < n:
        if task_table[i].pid > 1:
            st: uint64 = task_table[i].state
            if st != STATE_FREE and st != STATE_EXITED:
                if task_get_job_pgid(i) == pgid:
                    signal_post(i, sig)
                    hit = hit + 1
        i = i + 1
    return hit


def signal_post_to_foreground(sig: uint64):
    # Terminal-generated signal (Ctrl-C → SIGINT, Ctrl-Z → SIGTSTP).
    # Route it to the terminal's CURRENT foreground process group only,
    # so background jobs are insulated. If a foreground job is set,
    # deliver there; otherwise fall back to the historical "every
    # pid>1 task" broadcast (covers the no-job-table boot path and any
    # caller that hasn't set a foreground pgid yet).
    fg: uint64 = terminal_fg_pgid
    if fg != 0:
        signal_post_to_pgid(fg, sig)
        return
    n: uint64 = NTASKS
    i: uint64 = 0
    while i < n:
        if task_table[i].pid > 1:
            st: uint64 = task_table[i].state
            if st == STATE_READY or st == STATE_RUNNING:
                signal_post(i, sig)
        i = i + 1


# --- Phase D follow-up: per-fd opened-path accessors -----------------
#
# fd2path(2) needs to report the EXACT path the fd was opened with.
# vfs_open / vfs_open_write stamp the resolved-name bytes here at fd-
# install time; close_fd_in_task clears the slot; copy_fd_entry copies
# it on dup/fork so a duplicate fd reports the same path as the
# original. These accessors keep fs/vfs.ad and sys/src/9/port/sysfile.ad
# out of the TaskStruct internals. FD_OPENED_PATH_CAP is defined above
# (right after NR_FDS) so the close/copy paths see the same constant.


def task_fd_set_opened_path(task: Ptr[TaskStruct], fdu: uint64,
                            path: Ptr[uint8]):
    # Copy `path` (NUL-terminated) into the per-fd opened-path slot,
    # capped at 127 bytes + NUL. A null `path` clears the slot. The fd
    # index is bounds-checked because callers reach this on the
    # syscall hot path with values they've just allocated.
    if fdu >= NR_FDS:
        return
    if cast[uint64](path) == 0:
        task[0].fd_opened_path[fdu][0] = 0
        return
    i: uint64 = 0
    cap: uint64 = FD_OPENED_PATH_CAP - 1
    while i < cap:
        c: uint8 = path[i]
        if c == 0:
            break
        task[0].fd_opened_path[fdu][i] = c
        i = i + 1
    task[0].fd_opened_path[fdu][i] = 0


def task_fd_clear_opened_path(task: Ptr[TaskStruct], fdu: uint64):
    # Drop the recorded path. Called from close_fd_in_task so a freshly
    # closed slot does not surface stale bytes to a subsequent fd2path
    # if it is re-opened without a stamp (defensive — every open code
    # path should stamp, but a future backend that forgets does not
    # then leak the previous holder's path).
    if fdu >= NR_FDS:
        return
    task[0].fd_opened_path[fdu][0] = 0


def task_fd_opened_path_ptr(task: Ptr[TaskStruct],
                            fdu: uint64) -> Ptr[uint8]:
    # Stable pointer to the per-fd opened-path slot. Empty (first byte
    # 0) means "no path recorded" — callers should fall back to their
    # legacy synthesis. The array lives inline in TaskStruct so the
    # pointer is stable for the lifetime of the slot.
    return &task[0].fd_opened_path[fdu][0]


def task_fd_copy_opened_path(dst: Ptr[TaskStruct], dst_fdu: uint64,
                             src: Ptr[TaskStruct], src_fdu: uint64):
    # Copy src's opened-path bytes into dst's slot. Used by
    # copy_fd_entry on dup / fork so the duplicate sees the same path
    # as the original (Plan 9 semantics: a dup'd fd refers to the same
    # open file with the same name). Bounds-checked so a stray fdu
    # outside the table is a no-op rather than a wild write.
    if dst_fdu >= NR_FDS or src_fdu >= NR_FDS:
        return
    i: uint64 = 0
    while i < FD_OPENED_PATH_CAP:
        c: uint8 = src[0].fd_opened_path[src_fdu][i]
        dst[0].fd_opened_path[dst_fdu][i] = c
        if c == 0:
            return
        i = i + 1
    # src slot was not NUL-terminated within cap (should be unreachable
    # because set_opened_path always terminates); force-terminate dst so
    # callers don't read past the end.
    dst[0].fd_opened_path[dst_fdu][FD_OPENED_PATH_CAP - 1] = 0


def _init_fd_table(slot: uint64):
    # CLONE_FILES (#71): a fresh/RECYCLED slot must start SELF-OWNED with an
    # UNLOCKED fd lock and a private-table refcount of 1. A recycled slot could
    # otherwise carry a previous thread tenant's fd_owner_p1 (pointing at a
    # long-dead owner) or a stale-held fd_lock (instant deadlock). fd_owner_p1
    # is NOT re-zeroed anywhere else on the create path, so this is the single
    # scrub point every task-create funnels through.
    task_table[slot].fd_owner_p1       = 0
    task_table[slot].fd_lock           = 0
    task_table[slot].fd_table_refcount = 1
    # Pre-open stdin / stdout / stderr; the rest start CLOSED. Linux's
    # exec() does the same thing — the launched binary inherits the
    # parent's standard streams or gets them freshly attached.
    task_table[slot].fd_idx[0] = FD_STDIN_MARK
    task_table[slot].fd_idx[1] = FD_STDOUT_MARK
    task_table[slot].fd_idx[2] = FD_STDERR_MARK
    i: uint64 = 3
    while i < NR_FDS:
        task_table[slot].fd_idx[i] = FD_CLOSED_MARK
        i = i + 1
    i = 0
    while i < NR_FDS:
        task_table[slot].fd_pos[i]    = 0
        task_table[slot].fd_buf[i]    = 0
        task_table[slot].fd_buflen[i] = 0
        # Phase D follow-up: clear the per-fd opened-path slot — only
        # the first byte needs to be zeroed because every consumer
        # treats a leading NUL as "no path recorded."
        task_table[slot].fd_opened_path[i][0] = 0
        i = i + 1
    # Default CWD: "/". Children get this unless the parent has its
    # own (handled when create_user_task_argv is invoked from
    # SYS_SPAWN — see _inherit_cwd_from_parent).
    task_table[slot].cwd[0] = 47                  # '/'
    task_table[slot].cwd[1] = 0


def _inherit_cwd_from_parent(child_slot: uint64):
    # Copy current_idx_pcpu's CWD into the child. Called from
    # create_user_task_argv just after _init_fd_table so SYS_SPAWN
    # children pick up the shell's working directory.
    #
    # PID 1 is created with the boot/idle task (slot 0) as its
    # "parent", and that task's cwd field was never set — it's a
    # zero-initialized BSS string (""). Inheriting it verbatim would
    # leave PID 1 (hamsh) with an empty cwd, so `ls` with no args lists
    # "" and fails ("listdir failed") until the user runs `cd /`. When
    # the parent's cwd is empty, keep the "/" default _init_fd_table
    # already planted instead of clobbering it.
    if task_table[current_idx_pcpu].cwd[0] == 0:
        return
    i: uint64 = 0
    while i < 128:
        c: uint8 = task_table[current_idx_pcpu].cwd[i]
        task_table[child_slot].cwd[i] = c
        if c == 0:
            return
        i = i + 1


def get_cwd_buf(slot: uint64) -> Ptr[uint8]:
    return &task_table[slot].cwd[0]


def set_task_cwd(slot: uint64, src: Ptr[uint8]) -> int32:
    # Copy `src` into task[slot].cwd up to 127 chars + NUL. Returns 0
    # on success, -1 on overflow.
    i: uint64 = 0
    while i < 127:
        c: uint8 = src[i]
        task_table[slot].cwd[i] = c
        if c == 0:
            return 0
        i = i + 1
    # Truncated — overflow.
    task_table[slot].cwd[127] = 0
    return -1


# --- Phase C / M16.98: Plan 9 rfork sharing-state accessors --------
#
# These wrap the TaskStruct fields for sys/src/9/port/sysproc.ad's
# do_rfork() to consult and write. Going through the helpers keeps
# sysproc.ad from poking task_table[] across the module boundary.

def task_fd_table_refcount(slot: int32) -> int32:
    return task_table[cast[uint64](slot)].fd_table_refcount


def set_task_fd_table_refcount(slot: int32, v: int32):
    task_table[cast[uint64](slot)].fd_table_refcount = v


# Number of per-task fd slots. Mirrors the Array[64, uint32] fd_idx
# table declared on TaskStruct above (NR_FDS == 64). Exported so the
# /proc/<pid>/fd renderer (sys/src/9/port/devproc.ad) can walk the
# table without hard-coding the width.
TASK_NFDS: uint64 = 64


def task_fd_idx_at(slot: int32, fd: uint64) -> uint32:
    # /proc/<pid>/fd: return the fd_idx marker (or real cpio file index)
    # for slot `slot`, descriptor `fd`. Out-of-range fd returns
    # FD_CLOSED_MARK so the caller sees the slot as closed. Going
    # through this helper keeps devproc.ad from poking task_table[]
    # across the module boundary — same discipline as task_struct_at.
    su: uint64 = cast[uint64](slot)
    if slot < 0 or su >= NTASKS or fd >= TASK_NFDS:
        return FD_CLOSED_MARK
    su = cast[uint64](fd_owner_slot_of(cast[int32](su)))
    return task_table[su].fd_idx[fd]


def task_fd_buf_at(slot: int32, fd: uint64) -> uint64:
    # Companion to task_fd_idx_at: the fd_buf word for the same slot/fd.
    # For tmpfs/pipe/socket fds this carries the backing slot index that
    # /proc/<pid>/fd renders in the anon-inode "kind:[id]" form Linux
    # uses for pipes and sockets.
    su: uint64 = cast[uint64](slot)
    if slot < 0 or su >= NTASKS or fd >= TASK_NFDS:
        return 0
    su = cast[uint64](fd_owner_slot_of(cast[int32](su)))
    return task_table[su].fd_buf[fd]


def task_set_fd_idx_at(slot: int32, fd: uint64, val: uint32):
    # Deterministic direct-set for the fd_idx marker of slot/fd. Used by
    # devproc.ad's procfd_selftest to stamp known markers into a slot's fd
    # table before rendering /proc/<pid>/fd (the boot task at boot:37 has an
    # uninitialised fd table, so the test seeds its own known descriptors).
    # Bounds-checked; out-of-range is a no-op.
    su: uint64 = cast[uint64](slot)
    if slot < 0 or su >= NTASKS or fd >= TASK_NFDS:
        return
    su = cast[uint64](fd_owner_slot_of(cast[int32](su)))
    task_table[su].fd_idx[fd] = val


def task_set_fd_buf_at(slot: int32, fd: uint64, val: uint64):
    # Companion to task_set_fd_idx_at: deterministic direct-set for the fd_buf
    # word of slot/fd (the anon-inode backing-id /proc/<pid>/fd renders for
    # pipe/socket/tmpfs descriptors). Bounds-checked; out-of-range is a no-op.
    su: uint64 = cast[uint64](slot)
    if slot < 0 or su >= NTASKS or fd >= TASK_NFDS:
        return
    su = cast[uint64](fd_owner_slot_of(cast[int32](su)))
    task_table[su].fd_buf[fd] = val


def task_pgrp(slot: int32) -> uint64:
    # V2.75: replaces V2.5's task_pgrp_idx. The value is now a real
    # heap pointer (uint64) to a Pgrp struct allocated by chan.ad's
    # pgrp_alloc / pgrp_clone, not an index into a fixed pool. A 0
    # value means "default to the root Pgrp" — chan.ad's
    # _ensure_root resolves the default on first access.
    return task_table[cast[uint64](slot)].pgrp


def set_task_pgrp(slot: int32, v: uint64):
    task_table[cast[uint64](slot)].pgrp = v


def task_note_group(slot: int32) -> int32:
    return task_table[cast[uint64](slot)].note_group


def set_task_note_group(slot: int32, v: int32):
    task_table[cast[uint64](slot)].note_group = v


def current_pgrp() -> uint64:
    # V2.75: returns the heap pointer (uint64) parked in the current
    # task's pgrp slot. 0 means "no pgrp installed yet"; callers in
    # chan.ad pivot that onto the root Pgrp lazily.
    return task_table[current_idx_pcpu].pgrp


def set_current_pgrp(v: uint64):
    task_table[current_idx_pcpu].pgrp = v


# V2.5 dropped alloc_namespace_id — pgrp_alloc in chan.ad replaces it.
# The note-group allocator below is kept verbatim; it's still a bare
# monotonic int handle (no backing table) and will get its own
# "real object pool" lift the day note(2)/noted(2) groups grow
# membership semantics.

def alloc_note_group_id() -> int32:
    v: int32 = next_note_group
    next_note_group = next_note_group + 1
    return v


def fork_seed_callee_saved(slot: int32, rbx: uint64, rbp: uint64,
                           r12: uint64, r13: uint64,
                           r14: uint64, r15: uint64):
    # fork(2) callee-saved inheritance. _build_initial_kstack lays the
    # child's first __switch_to image down with the 6 callee-saved
    # registers ZEROED — fine for a from-scratch SYS_SPAWN child, WRONG
    # for fork(): a forked child must resume the C/asm caller with the
    # PARENT's %rbx/%rbp/%r12/%r13/%r14/%r15 intact, or any inherited
    # register-held pointer (e.g. a musl-compiled program keeping a stack
    # buffer base in %r14 across a syscall) reads as 0 and the next
    # syscall faults (observed: a forked client's read(2) buffer arrived
    # as NULL because %r14 held its base). The 6 slots sit at the lowest
    # addresses of the child's kstack frame, in __switch_to_asm's pop
    # order (r15,r14,r13,r12,rbx,rbp): r15=+0, r14=+8, r13=+16, r12=+24,
    # rbx=+32, rbp=+40. (rbp at +40 matches do_rfork's existing patch.)
    #
    # Boot-CR3 guard, identical to do_rfork's saved-rbp patch: the live
    # CR3 belongs to the forking parent, whose low-RAM identity map for
    # this kstack chunk may have been cracked/COW-remapped by execve+ASLR,
    # so a write through it could land on an unrelated physical page. The
    # pristine boot CR3 identity-maps ALL low RAM; do the stores under it.
    child_sp: uint64 = task_table[cast[uint64](slot)].sp
    _cs_live_cr3: uint64 = read_cr3()
    _cs_boot_cr3: uint64 = cow_boot_cr3()
    _cs_irq: uint64 = 0
    if _cs_boot_cr3 != 0:
        _cs_irq = local_irq_save()
        load_cr3(_cs_boot_cr3)
    cast[Ptr[uint64]](child_sp + 0)[0]  = r15
    cast[Ptr[uint64]](child_sp + 8)[0]  = r14
    cast[Ptr[uint64]](child_sp + 16)[0] = r13
    cast[Ptr[uint64]](child_sp + 24)[0] = r12
    cast[Ptr[uint64]](child_sp + 32)[0] = rbx
    cast[Ptr[uint64]](child_sp + 40)[0] = rbp
    if _cs_boot_cr3 != 0:
        load_cr3(_cs_live_cr3)
        local_irq_restore(_cs_irq)


def task_initial_sp(slot: int32) -> uint64:
    # Phase C / M16.98: read the freshly-built kstack pointer that
    # _build_initial_kstack handed back at create_user_task_argv time.
    # do_rfork() patches the saved-%rbp slot in the initial
    # __switch_to image so the child's first user-mode instruction
    # has a valid frame pointer. The TaskStruct.sp field is exactly
    # that pointer; we expose it through this helper instead of
    # letting sysproc.ad poke task_table directly.
    return task_table[cast[uint64](slot)].sp


# --- M16.104: per-task SYS_brk accessors ----------------------------
#
# Wrap the TaskStruct.brk_{base,end,max} fields so linux_abi/u_syscalls.ad
# can read/write the current task's heap state without poking
# task_table[] across the module boundary. The three fields are
# always read/written together (a single brk() call may touch all of
# them), but separate getters/setters compose more cleanly with the
# existing per-task helper pattern (fs_base, alt_stack_*, etc.).

def task_brk_base(slot: uint64) -> uint64:
    return task_table[slot].brk_base


def set_task_brk_base(slot: uint64, v: uint64):
    task_table[slot].brk_base = v


def task_brk_end(slot: uint64) -> uint64:
    return task_table[slot].brk_end


def set_task_brk_end(slot: uint64, v: uint64):
    task_table[slot].brk_end = v


def task_brk_max(slot: uint64) -> uint64:
    return task_table[slot].brk_max


def set_task_brk_max(slot: uint64, v: uint64):
    task_table[slot].brk_max = v


def set_task_brk_range(slot: uint64, base: uint64, end: uint64,
                       maxv: uint64):
    # Set all three brk cursors at once. do_clone uses this to give a
    # forked child the same heap window the parent had — the child's
    # heap is a private physical copy at the same virtual addresses,
    # so base / end / max carry over unchanged.
    task_table[slot].brk_base = base
    task_table[slot].brk_end  = end
    task_table[slot].brk_max  = maxv


# --- M16.109: Plan 9 notify(2) / noted(2) accessors -----------------
#
# Wrap the TaskStruct.note_* fields so sys/src/9/port/sysnote.ad and
# devproc.ad don't poke task_table[] across the module boundary. Same
# accessor pattern as the brk / fs_base / errstr helpers above.

def task_note_handler_rip(slot: uint64) -> uint64:
    return task_table[slot].note_handler_rip


def set_task_note_handler_rip(slot: uint64, v: uint64):
    task_table[slot].note_handler_rip = v


def task_note_pending(slot: uint64) -> int32:
    return task_table[slot].note_pending


def set_task_note_pending(slot: uint64, v: int32):
    task_table[slot].note_pending = v


def task_note_saved_rip(slot: uint64) -> uint64:
    return task_table[slot].note_saved_rip


def set_task_note_saved_rip(slot: uint64, v: uint64):
    task_table[slot].note_saved_rip = v


def task_note_saved_rsp(slot: uint64) -> uint64:
    return task_table[slot].note_saved_rsp


def set_task_note_saved_rsp(slot: uint64, v: uint64):
    task_table[slot].note_saved_rsp = v


def task_note_msg_ptr(slot: uint64) -> Ptr[uint8]:
    # Returns a kernel pointer at the named task's note_msg buffer.
    # 128-byte capacity (matches ERRMAX); caller must respect that
    # cap. The pointer is stable for the lifetime of the slot — the
    # array lives inline in TaskStruct, never relocated.
    return &task_table[slot].note_msg[0]


# --- Phase G / note-group walk support ------------------------------
#
# Plan 9's note-group delivery posts a note to EVERY live process whose
# note_group matches the target group. The walker (post_note_to_group
# in sys/src/9/port/sysnote.ad) needs to iterate the task table by raw
# slot index, test liveness, read each slot's note_group, and enqueue
# the note onto matching slots. These three helpers are the only new
# surface it needs; everything else reuses the existing note_*
# accessors above.

def note_table_nslots() -> uint64:
    # Number of task-table slots to walk. Exposed so the note-group
    # walker doesn't have to import the NTASKS constant (which would
    # also drag in the whole module-init order); a plain accessor keeps
    # the dependency one-directional.
    return NTASKS


def task_slot_is_note_live(slot: uint64) -> int32:
    # Plan 9 liveness test for note delivery: a note is delivered to a
    # group member iff it is a live process. STATE_FREE (never claimed)
    # and STATE_EXITED (finished / reaped-pending) slots are NOT live —
    # delivering to them would either hit an empty slot or a corpse.
    # Every other state (READY, RUNNING, STOPPED, PARKED) is "alive and
    # will eventually run again", so it receives the pending note and
    # acts on it on its next return-to-user — exactly Plan 9 semantics
    # (a stopped process still collects the note).
    st: uint64 = task_table[slot].state
    if st == STATE_FREE:
        return 0
    if st == STATE_EXITED:
        return 0
    return 1


# --- note-group walk self-test support ------------------------------
#
# notegroup_selftest() (sys/src/9/port/sysnote.ad) needs to set up a
# deterministic, controlled population of task slots WITHOUT racing the
# live scheduler: it claims free slots, stamps each with a liveness
# state + a note_group, runs the real post_note_to_group walk, inspects
# which slots got the pending note, then releases the slots. The claimed
# slots are parked in STATE_STOPPED (or STATE_EXITED for the dead-task
# witness) so _pick_next() never dispatches them and _find_free_slot()
# never re-hands them out mid-test — they are inert table entries that
# exist only to be walked. These helpers keep that bookkeeping inside
# core.ad so the test never pokes task_table[] across the module
# boundary.

def notetest_claim_slot(state: uint64, group: int32) -> int32:
    # Claim a free task-table slot for the note-group walk self-test.
    # Marks it `state` (caller picks STATE_STOPPED for a live member or
    # STATE_EXITED for a dead-task witness), stamps note_group, and
    # clears the note delivery state (handler/pending/msg) so a fresh
    # enqueue is observable. Returns the slot index, or -1 if the table
    # is full. Does NOT touch the runqueue — the slot is inert.
    s: int32 = _find_free_slot()
    if s < 0:
        return -1
    su: uint64 = cast[uint64](s)
    task_table[su].state            = state
    task_table[su].note_group       = group
    task_table[su].note_handler_rip = 0
    task_table[su].note_pending     = 0
    task_table[su].note_saved_rip   = 0
    task_table[su].note_saved_rsp   = 0
    nti: uint64 = 0
    while nti < 128:
        task_table[su].note_msg[nti] = 0
        nti = nti + 1
    return s


def notetest_set_slot_pid(slot: int32, pid: uint64):
    # Stamp a KNOWN pid on a slot claimed by notetest_claim_slot so the
    # single-target note self-test (notepid_selftest) can resolve it via
    # task_lookup_by_pid. The slot is inert (STATE_STOPPED, off the
    # runqueue); only its pid field is rewritten. notetest_release_slot
    # returns it to STATE_FREE afterward, so the borrowed pid is dropped.
    # Track 5: route through _task_set_pid so the pid->slot hash resolves it.
    _task_set_pid(cast[uint64](slot), pid)


def notetest_release_slot(slot: int32):
    # Release a slot claimed by notetest_claim_slot back to STATE_FREE
    # and clear its note state. The slot was never on the runqueue, so
    # this is a plain field reset — no reap, no pgrp drop.
    su: uint64 = cast[uint64](slot)
    # Track 5: drop the borrowed pid from the hash and return the slot to the
    # freelist (it was claimed via _find_free_slot / _free_list_pop).
    _task_clear_pid(su)
    _rq_list_remove(su)
    task_table[su].state      = STATE_FREE
    task_table[su].note_group = 0
    task_table[su].note_pending = 0
    _free_list_push(su)


# --- U42 VMA accessors ---------------------------------------------
#
# mm/vma.ad owns the VmaNode struct and the list walks; this pair of
# helpers is the only way it touches TaskStruct. Same accessor pattern
# as the brk / note helpers above: get / set, opaque uint64 pointers.

def task_vma_list_head(slot: uint64) -> uint64:
    return task_table[slot].vma_list_head


def set_task_vma_list_head(slot: uint64, v: uint64):
    task_table[slot].vma_list_head = v


# Per-process address space (fork) field accessors. do_execve sets the
# image_* / ustack_* values for the current task; do_clone reads the
# parent's and writes the child's.

def task_image_lo(slot: uint64) -> uint64:
    return task_table[slot].image_lo


def task_image_hi(slot: uint64) -> uint64:
    return task_table[slot].image_hi


def set_task_image_range(slot: uint64, lo: uint64, hi: uint64):
    task_table[slot].image_lo = lo
    task_table[slot].image_hi = hi


def task_interp_lo(slot: uint64) -> uint64:
    return task_table[slot].interp_lo


def task_interp_hi(slot: uint64) -> uint64:
    return task_table[slot].interp_hi


def set_task_interp_range(slot: uint64, lo: uint64, hi: uint64):
    # Per-task dynamic-linker VIRTUAL image span. do_execve records it so
    # do_clone can COW-share the interp window into a fork child (cracking
    # the child's inherited boot identity PS=1 huge page into US=1 user
    # leaves). 0/0 on a static binary (no PT_INTERP). PROPAGATED to fork
    # children (unlike interp_phys) so a grandchild fork re-shares it.
    task_table[slot].interp_lo = lo
    task_table[slot].interp_hi = hi


def task_ustack_lo(slot: uint64) -> uint64:
    return task_table[slot].ustack_lo


def task_ustack_sz(slot: uint64) -> uint64:
    return task_table[slot].ustack_sz


def set_task_ustack_range(slot: uint64, lo: uint64, sz: uint64):
    task_table[slot].ustack_lo = lo
    task_table[slot].ustack_sz = sz


# Resource-reclaim OWNER accessors. The allocating syscall (SYS_SPAWN /
# do_execve) calls these to record the physical ELF image region and
# physical user-stack region it allocated so task_reap can hand them
# back. NOT propagated by do_clone — a fork child COW-shares both and
# must keep these 0 so it never double-frees the live parent regions.

def set_task_image_phys(slot: uint64, phys: uint64, sz: uint64):
    task_table[slot].image_phys    = phys
    task_table[slot].image_phys_sz = sz


def task_image_cow_shared(slot: uint64) -> uint64:
    # FORK+EXEC COW-image discriminator (apt dpkg-split blocker, T26).
    # 1 IFF this task's currently-mapped ELF image is a COW alias of a
    # still-living fork parent's image (do_clone set it after COW-sharing).
    # do_execve uses this to decide whether the OUTGOING image must be torn
    # down through the COW-safe path (cow_drop, refcount 2->1) versus left
    # to the owner reclaim (region_free). image_phys == 0 alone is NOT a
    # safe proxy — directly-launched tasks (boot init) can carry phys == 0
    # over a non-COW image, and cow_drop'ing those frames wedges boot.
    return task_table[slot].image_cow_shared


def set_task_image_cow_shared(slot: uint64, v: uint64):
    # Set 1 by do_clone right after vm_cow_share_all/_range over the image +
    # interp; CLEARED (0) by do_execve once it loads a fresh region-owned
    # image (no longer COW-shared with a parent).
    task_table[slot].image_cow_shared = v


# --- Linux-ABI no-syscall watchdog accessors ---------------------------
def task_note_syscall_now(slot: uint64, nr: uint64, arg0: uint64):
    # Stamp "this task just entered a syscall" (do_syscall's Linux arm).
    # Resets the no-syscall watchdog clock AND the repeat-dump limiter so a
    # task that recovers then re-spins is caught fresh. Also records the
    # syscall NUMBER + arg0 (#73 multi-thread stall diagnostic) so the whole-
    # table dump can name the syscall AND the fd each OFF-CPU thread is parked in.
    task_table[slot].last_syscall_jiffies = get_jiffies()
    task_table[slot].wd_last_dump_jiffies = 0
    task_table[slot].last_syscall_nr = nr
    task_table[slot].last_syscall_arg0 = arg0


def task_last_syscall_nr(slot: uint64) -> uint64:
    return task_table[slot].last_syscall_nr


def dump_linux_task_states(exclude_slot: uint64):
    # #73 multi-thread stall diagnostic. Walk the ENTIRE task table and, for
    # every LIVE Linux-ABI userspace task OTHER than `exclude_slot` (the
    # spinning task the watchdog already dumped in full), print a one-line
    # summary: slot, scheduler state, the syscall it is currently parked in
    # (last_syscall_nr — e.g. 202=futex, 7=poll, 232=epoll_wait, 0=read), how
    # many ticks since it last issued a syscall, and its cr3 (so same-address-
    # space thread groups are obvious). This is what pins WHICH background
    # thread the main thread is waiting on and WHAT it is blocked in without a
    # userspace debugger. Tasks sharing the spinner's cr3 are its thread peers.
    now: uint64 = get_jiffies()
    i: uint64 = 0
    while i < NTASKS:
        if i != exclude_slot and task_table[i].is_user != 0 \
                    and task_table[i].is_linux_userspace != 0:
            st: uint64 = task_table[i].state
            if st != STATE_FREE and st != STATE_EXITED:
                lastj: uint64 = task_table[i].last_syscall_jiffies
                gap: uint64 = 0
                if now >= lastj:
                    gap = now - lastj
                printk3("[nosys-wd]   task slot=%d state=%d last_sc_nr=%d",
                        i, st, task_table[i].last_syscall_nr)
                printk2(" gap=%dt cr3=%p\n", gap, task_table[i].cr3)
        i = i + 1


def _mm_owner_slot_for_cr3(mycr3: uint64) -> uint64:
    # Resolve the slot that OWNS the VMA list for a shared address space.
    # CLONE_VM threads start with vma_list_head==0 (mm/vma keeps the VMA
    # metadata in the LEADER's slot only; the page tables are shared via
    # cr3). To map a thread's saved user-RIP to a library, walk to the
    # same-cr3 slot whose vma_list_head is non-zero. Returns NTASKS if
    # none found (caller falls back to the thread's own slot).
    i: uint64 = 0
    while i < NTASKS:
        if task_table[i].is_user != 0 \
                and task_table[i].cr3 == mycr3 \
                and task_table[i].state != STATE_FREE \
                and task_table[i].state != STATE_EXITED \
                and task_table[i].vma_list_head != 0:
            return i
        i = i + 1
    return NTASKS


def _parked_dump_fd_type(slot: uint64, fdn: uint64):
    # #76 DIAGNOSTIC GAP FIX: resolve the OWNER's fd table (CLONE_FILES
    # threads own no table — fd_owner_task routes to the leader) and print
    # fd `fdn`'s REAL backing mark. For a CHAN_MARK fd, additionally decode
    # the namec chan's DEV_* subtype so pipe / socket / socketpair / the
    # Wayland AF_UNIX socket are all distinguishable (they share the
    # 0xFFFFFFE0 mark). Eventfd/timerfd/signalfd/epoll carry their own
    # distinct marks (0xFFFFFFD6..0xFFFFFFD7). This is what the earlier
    # thread-local read (which for a CLONE_FILES thread hit an all-CLOSED
    # private table) could not see.
    if fdn >= 64:
        return
    owner: Ptr[TaskStruct] = fd_owner_task(&task_table[slot])
    mark: uint32 = owner[0].fd_idx[fdn]
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk3("[parked-wd]   slot=%d fd=%d ownmark=%p\n",
            slot, fdn, cast[uint64](mark))
    if mark == CHAN_MARK_VALUE:
        cid: int32 = cast[int32](cast[uint32](owner[0].fd_buf[fdn]))
        dt: int32 = namec_chan_dev_type(cid)
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk3("[parked-wd]   slot=%d fd=%d chan_dev=%d\n",
                slot, fdn, cast[uint64](cast[uint32](dt)))
        # #76: for a PIPE read/write end, print readers/writers/buffered.
        # A read(pipe) that blocks with writers>0 means a live peer SHOULD
        # write but hasn't (firefox-internal cycle); writers==0 would be a
        # missed-EOF Hamnix bug (pipe_read_blocking returns 0 at writers==0,
        # so a stuck reader with writers==0 = refcount/wakeup defect).
        if dt == DEV_PIPE_R or dt == DEV_PIPE_W:
            pslot: int32 = namec_chan_back_slot(cid)
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk3("[parked-wd]   slot=%d pipe rd=%d wr=%d",
                    slot, pipe_readers(pslot), pipe_writers(pslot))
            printk1(" buffered=%d\n", pipe_count(pslot))


def dump_linux_group_full():
    # #73 parked-stall dumper (bypasses dump_linux_task_states, which mysteriously
    # emitted nothing from the parked-group path). One printk per live Linux task
    # on a single line: slot, state, the syscall it is parked in (last_syscall_nr:
    # 202=futex, 7=poll, 232=epoll_wait, 271=ppoll, 0=read, 61=wait4), ticks since
    # that syscall, and cr3 (same cr3 == same thread group). Then the futex table.
    # Emit the FUTEX TABLE FIRST: a timer-IRQ printk burst truncates after a
    # handful of lines, and the futex uaddr/waiter map is the highest-value datum
    # for a lost-wakeup deadlock — put it ahead of the (longer) per-task loop so
    # it is never the part that gets dropped.
    printk_set_level(PRINTK_LEVEL_EMERG)
    call_linux_futex_dump()
    now: uint64 = get_jiffies()
    i: uint64 = 0
    while i < NTASKS:
        if task_table[i].is_user != 0 and task_table[i].is_linux_userspace != 0:
            st: uint64 = task_table[i].state
            if st != STATE_FREE and st != STATE_EXITED:
                lastj: uint64 = task_table[i].last_syscall_jiffies
                gap: uint64 = 0
                if now >= lastj:
                    gap = now - lastj
                printk_set_level(PRINTK_LEVEL_EMERG)
                # ONE complete printk3 line per task: slot, the syscall it is
                # parked in (sc_nr), and arg0 (the fd for read/poll/recvmsg). This
                # pins WHICH descriptor the permanently-parked thread blocks on.
                printk3("[parked-wd] slot=%d sc_nr=%d arg0=%p\n",
                        i, task_table[i].last_syscall_nr,
                        task_table[i].last_syscall_arg0)
                # #75: cr3 (thread-group id) + the saved user RIP the thread is
                # parked at. kstack_top-24 holds the CPL=3 return RIP spilled by
                # the syscall-entry stub — for a task blocked inside do_syscall's
                # yield loop this is the instruction AFTER its libc syscall. A RIP
                # in a sane DSO span == a genuine wait (kernel mis-serves the
                # syscall); a garbage/zero RIP == corrupted thread state.
                urip: uint64 = 0
                kt: uint64 = task_table[i].kstack_top
                if kt >= 24:
                    urip = cast[Ptr[uint64]](kt - 24)[0]
                # printk_set_level is a ONE-SHOT latch consumed by the next
                # printk; re-stamp EMERG before EACH added line or it resets to
                # INFO and the post-interactive console gate drops it.
                printk_set_level(PRINTK_LEVEL_EMERG)
                printk3("[parked-wd]   slot=%d cr3=%p urip=%p\n",
                        i, task_table[i].cr3, urip)
                # #76 RIP->library: resolve urip against the address space's
                # VMA list (owned by the same-cr3 leader slot) and print the
                # containing VMA's base, file_offset and open path so an
                # offline readelf/nm on the DSO maps (urip - base + file_off)
                # to a symbol.
                mms: uint64 = _mm_owner_slot_for_cr3(task_table[i].cr3)
                if mms >= NTASKS:
                    mms = i
                if urip != 0:
                    vma_dump_rip_info(i, mms, urip)
                # #76 poor-man's backtrace: the saved user-RIP is always the
                # libc syscall-return site; the CALLER (libxul/glib) lives on
                # the user stack. Read the saved user RSP (kstack_top-8) and
                # scan a window for words in the shared-lib code range so an
                # offline readelf on libxul/libc names WHAT firefox is doing.
                ursp: uint64 = 0
                if kt >= 8:
                    ursp = cast[Ptr[uint64]](kt - 8)[0]
                if ursp != 0:
                    vma_dump_user_stack(i, task_table[i].cr3, ursp)
                # #76: for a task parked in read(2)/write(2) on an fd
                # (sc_nr 0=read,1=write), print that fd's OWNER-resolved mark
                # + chan DEV subtype (CLONE_FILES threads own no fd table).
                scn: uint64 = task_table[i].last_syscall_nr
                if scn == 0 or scn == 1:
                    _parked_dump_fd_type(i, task_table[i].last_syscall_arg0)
        i = i + 1


def linux_group_status(out_newest: Ptr[uint64],
                       out_oldest: Ptr[uint64]) -> uint64:
    # #73 stall diagnostic. The no-syscall watchdog only catches a task SPINNING
    # in ring-3; a Firefox stall where the MAIN thread parks off-CPU in a
    # blocking syscall while a background timer/worker thread keeps ticking
    # (flush stall) never presents a running userspace task AND never looks
    # fully quiescent (the ticking thread keeps `newest` fresh). This companion
    # reports the Linux-ABI userspace group's liveness: it returns the COUNT of
    # live Linux userspace tasks and writes, via out_newest / out_oldest, the
    # MOST- and LEAST-recent last_syscall_jiffies across them. The caller flags a
    # stall when now - OLDEST exceeds a threshold — i.e. at least one Linux
    # thread has been parked in a syscall for a long time — which catches both a
    # full deadlock and a single-thread flush stall.
    newest: uint64 = 0
    oldest: uint64 = 0
    cnt: uint64 = 0
    i: uint64 = 0
    while i < NTASKS:
        if task_table[i].is_user != 0 and task_table[i].is_linux_userspace != 0:
            st: uint64 = task_table[i].state
            if st != STATE_FREE and st != STATE_EXITED:
                lj: uint64 = task_table[i].last_syscall_jiffies
                if lj != 0:
                    cnt = cnt + 1
                    if lj > newest:
                        newest = lj
                    if oldest == 0 or lj < oldest:
                        oldest = lj
        i = i + 1
    out_newest[0] = newest
    out_oldest[0] = oldest
    return cnt


def linux_max_thread_group() -> uint64:
    # Largest CLONE_THREAD group among live Linux-ABI userspace tasks: the max
    # number that share a single cr3 (address space). Used to gate the parked-wd
    # dump to a HEAVILY-THREADED process (Firefox = 5+ threads/one cr3) so it
    # never fires for weston-terminal (1-2 threads) or separate-process httpd
    # workers (one thread each, distinct cr3) — no serial spam in those tests.
    best: uint64 = 0
    i: uint64 = 0
    while i < NTASKS:
        if task_table[i].is_user != 0 and task_table[i].is_linux_userspace != 0 \
                and task_table[i].state != STATE_FREE \
                and task_table[i].state != STATE_EXITED:
            mycr3: uint64 = task_table[i].cr3
            grp: uint64 = 0
            j: uint64 = 0
            while j < NTASKS:
                if task_table[j].is_user != 0 \
                        and task_table[j].is_linux_userspace != 0 \
                        and task_table[j].state != STATE_FREE \
                        and task_table[j].state != STATE_EXITED \
                        and task_table[j].cr3 == mycr3:
                    grp = grp + 1
                j = j + 1
            if grp > best:
                best = grp
        i = i + 1
    return best


def task_last_syscall_jiffies(slot: uint64) -> uint64:
    return task_table[slot].last_syscall_jiffies


def set_task_last_syscall_jiffies(slot: uint64, v: uint64):
    task_table[slot].last_syscall_jiffies = v


def task_wd_last_dump_jiffies(slot: uint64) -> uint64:
    return task_table[slot].wd_last_dump_jiffies


def set_task_wd_last_dump_jiffies(slot: uint64, v: uint64):
    task_table[slot].wd_last_dump_jiffies = v


def task_is_linux_userspace_at(slot: uint64) -> int32:
    return task_table[slot].is_linux_userspace


def set_task_ustack_phys(slot: uint64, phys: uint64, sz: uint64):
    task_table[slot].ustack_phys    = phys
    task_table[slot].ustack_phys_sz = sz


def set_task_interp_phys(slot: uint64, phys: uint64, sz: uint64):
    # Owner-only dynamic-linker interpreter region. Set by the allocating
    # syscall (SYS_SPAWN / do_execve) so task_reap returns the interp
    # image to the region pool. 0 on a static binary; NOT propagated to
    # fork children (they COW-share the interp and must not free it).
    task_table[slot].interp_phys    = phys
    task_table[slot].interp_phys_sz = sz


def task_free_owner_regions(slot: uint64):
    # execve-replace teardown (leak 2). do_execve installs a NEW image
    # over a task that may have OWNED a prior image / interp / user stack
    # (the direct-spawn-then-execve path: SYS_SPAWN gave this task its own
    # region, then it execve'd). Free the OUTGOING owner-only regions
    # here, BEFORE do_execve overwrites the owner fields with the new
    # image's coords — otherwise the old spans leak for the rest of the
    # boot. This mirrors task_reap's image/interp/ustack arms exactly,
    # inlined at the replace point. OWNER-ONLY is preserved: a field that
    # is 0 (a COW fork child, or a task whose prior image it never owned)
    # is left untouched — we only ever free what THIS task allocated.
    # COW-safe: the outgoing image/interp may be COW-shared into a fork
    # child (vm_cow_share_all/_range). region_free_cow_safe drops this
    # owner's per-PFN reference before pooling so a fork-shared frame is
    # never returned to the pool with a stale non-zero refcount (the
    # fork+exec canary/exit-list poison this closes).
    if task_table[slot].image_phys != 0:
        region_free_cow_safe(task_table[slot].image_phys,
                             task_table[slot].image_phys_sz)
        task_table[slot].image_phys    = 0
        task_table[slot].image_phys_sz = 0
    if task_table[slot].interp_phys != 0:
        region_free_cow_safe(task_table[slot].interp_phys,
                             task_table[slot].interp_phys_sz)
        task_table[slot].interp_phys    = 0
        task_table[slot].interp_phys_sz = 0
    if task_table[slot].ustack_phys != 0:
        # ALIASING FIX (2026-06-25): the Linux user stack is now DECOUPLED —
        # its USER virtual window is HIGH (LINUX_USTACK_VBASE = 7 GiB) while
        # its physical backing is the LOW alloc_pages() run stored in
        # ustack_phys. This is the execve-REPLACE teardown: do_execve has
        # ALREADY installed the NEW stack into the SAME high-VA window (the
        # VBASE is a constant, so old and new occupy the same VA), re-stamping
        # every leaf to point at the new low phys, BEFORE calling us. So the
        # high-VA leaves now map the NEW frames — we must NOT zap them (that
        # would unmap the live new stack the about-to-run program needs; doing
        # so was the not-present #PF the first cut of this fix hit). We only
        # return the OLD low physical run to the buddy allocator: its low
        # identity is the SHARED boot identity (US=0, kernel-writable), like
        # every other free low-RAM frame, and NO user mapping of the old phys
        # survives (the new install overwrote the only leaves that pointed at
        # it). The decoupled stack is never identity-mapped, so there is no
        # US=1-low-identity alias to restore/clear at all — the whole reason
        # for the old vma_restore_kernel_identity_range call is gone.
        free_pages(task_table[slot].ustack_phys,
                   _order_for_bytes(task_table[slot].ustack_phys_sz))
        task_table[slot].ustack_phys    = 0
        task_table[slot].ustack_phys_sz = 0


# §1 / rfork RFNOWAIT: detach accessors. set_task_detached(slot, 1)
# severs the parent link — task_exit_current then self-reaps the task
# (STATE_FREE, no zombie) and wait4 sees -ECHILD on its pid.

def task_detached(slot: int32) -> uint64:
    return task_table[cast[uint64](slot)].detached


def set_task_detached(slot: int32, v: uint64):
    task_table[cast[uint64](slot)].detached = v


def task_parent_pid(slot: int32) -> uint64:
    return task_table[cast[uint64](slot)].parent_pid


def set_task_parent_pid(slot: int32, v: uint64):
    # rfork(RFNOWAIT) zeroes this so a `wait for any child` scan never
    # treats the detached task as a reapable child of its old parent.
    task_table[cast[uint64](slot)].parent_pid = v


# --- SMP kthread churn soak ------------------------------------------
#
# smp_kthread_soak_run() is gated by /etc/smp-soak in the initramfs
# (planted by build_initramfs.py when ENABLE_SMP_SOAK=1) and called
# once from init/main.ad's boot sequence, BEFORE start_first_task().
# It exercises the most concurrency-sensitive paths:
#
#   1. rq_lock: kthread_create / task_exit_current race the BSP timer
#      ISR's schedule() on every tick.
#   2. per-CPU current_idx_pcpu: the AP (sched_ap_idle_loop) picks up
#      each batch kthread, runs it, and returns to idle.
#   3. AP-idle re-establish path (the __switch_to_asm return in
#      sched_ap_idle_loop) is exercised once per batch kthread.
#   4. Lock contention between BSP (timer ISR) and AP (idle loop) on
#      the same rq_lock.
#   5. State churn: STATE_PARKED -> STATE_RUNNING (AP idle) ->
#      STATE_READY -> STATE_RUNNING (kthread) -> STATE_FREE (self-reap).
#
# Design: create kthreads in batches of BATCH_SIZE, wait for all to
# complete (poll smp_soak_done), repeat for ROUNDS rounds.  Each
# kthread is DETACHED (self-reaps to STATE_FREE) so no slot leak.
#
# Completion tracking: smp_soak_done is a shared counter incremented
# (under rq_lock) by each kthread just before calling task_exit_current.
# The driver loop spins on smp_soak_done with cpu_relax.
#
# BATCH_SIZE * ROUNDS must be well above NTASKS (256) to guarantee
# slot recycling and lock contention across rounds.
#
# IMPORTANT: this runs BEFORE start_first_task(), so interrupts ARE
# enabled (local_irq_enable was called earlier in boot), the LAPIC
# timer fires, and preempt_tick() fires on every 10 ms tick.  This
# means the BSP timer ISR's schedule() can race the AP's idle loop on
# rq_lock — exactly the contention we want to stress.

SMP_SOAK_BATCH:  uint64 = 4    # kthreads per batch (stay < NTASKS-3)
SMP_SOAK_ROUNDS: uint64 = 20   # batches; total = 80 kthread create/reap cycles

# Shared completion counter. Incremented by each soak kthread under
# rq_lock before it calls task_exit_current.
smp_soak_done: uint64 = 0

# Heartbeat counter for the driver loop (printed every ~5 rounds).
smp_soak_heartbeat: uint64 = 0


def _smp_soak_kthread():
    # Body of each short-lived soak kthread. Increment the completion
    # counter (under wq_lock to avoid a torn 64-bit read-modify-write
    # on the shared counter), then exit.  The task is marked detached
    # before this runs so task_exit_current self-reaps it (STATE_FREE).
    _wq_lock_irq()
    smp_soak_done = smp_soak_done + 1
    _wq_unlock_irq()
    task_exit_current(0)


def smp_kthread_soak_run():
    # Called from init/main.ad when /etc/smp-soak is present.
    # Runs a sustained kthread create/exit/reap soak under -smp 2.
    #
    # IMPORTANT: this runs before start_first_task(), on the BSP's boot
    # task (slot 0, STATE_RUNNING).  The AP is running sched_ap_idle_loop().
    #
    # YIELD STRATEGY: the BSP calls schedule() cooperatively after each
    # batch of kthreads is created.  On TCG, this lets the kthreads run on
    # the BSP itself (the AP's HLT in sched_ap_idle_loop has no wakeup
    # trigger since the AP's LAPIC timer is not armed).  On real hardware
    # / KVM, kthreads can also be picked up by the AP idle loop.
    #
    # Each kthread runs _smp_soak_kthread() which:
    #   1. Acquires rq_lock, increments smp_soak_done, releases rq_lock.
    #   2. Calls task_exit_current(0) which self-reaps (detached) and
    #      switches back to the next READY task (ultimately the boot task).
    #
    # The BSP schedule() loop: create BATCH kthreads, then call schedule()
    # BATCH times to run each one to completion, then repeat for ROUNDS.
    printk0("[smp_soak] starting SMP kthread churn soak\n")
    printk2("[smp_soak] %d rounds x %d kthreads/batch\n",
            SMP_SOAK_ROUNDS, SMP_SOAK_BATCH)

    smp_soak_done = 0
    total_launched: uint64 = 0
    round_idx: uint64 = 0

    while round_idx < SMP_SOAK_ROUNDS:
        # Launch BATCH kthreads.  Use irq-disable + rq_lock around create
        # (mirrors sched_prepare_ap_idle's locking discipline) to prevent
        # the timer ISR from seeing a half-initialized slot.
        batch_start: uint64 = smp_soak_done
        b: uint64 = 0
        while b < SMP_SOAK_BATCH:
            _wq_lock_irq()
            slot: int32 = kthread_create(
                cast[uint64](&_smp_soak_kthread), 0)
            if slot >= 0:
                # Mark detached: kthread self-reaps without a parent wait.
                task_table[cast[uint64](slot)].detached = 1
                total_launched = total_launched + 1
                _wq_unlock_irq()
            else:
                # Slot exhaustion (NTASKS=256, BATCH=4 — should not happen).
                # Re-enable IRQs, schedule() to let pending kthreads run
                # and free their slots, then retry this iteration.
                _wq_unlock_irq()
                schedule()
                b = b - 1    # retry this slot
            b = b + 1

        # NB: this soak deliberately drains the batch on the BSP via the
        # cooperative schedule() loop below — it does NOT kick the AP. The
        # AP idle loop HLTs waiting for a reschedule IPI; leaving it parked
        # here keeps the drain on cpu0 deterministic (the dedicated AP work-
        # steal coverage lives in the #151 sched-fair test, which DOES kick).
        # Drive each kthread to completion via cooperative schedule() calls.
        # The BSP is the boot task (slot 0, STATE_RUNNING); each schedule()
        # call rotates to the next READY kthread, which runs to completion
        # and exits back via schedule().  We poll smp_soak_done until the
        # batch is done, yielding after each unsuccessful check.
        target: uint64 = batch_start + SMP_SOAK_BATCH
        sched_iters: uint64 = 0
        MAX_SCHED: uint64 = 200   # upper bound on schedule() calls per batch
        while smp_soak_done < target and sched_iters < MAX_SCHED:
            schedule()
            sched_iters = sched_iters + 1
        if smp_soak_done < target:
            local_irq_disable()
            printk2("[smp_soak] TIMEOUT: batch %d stuck (done=%d)\n",
                    round_idx, smp_soak_done)
            printk0("[smp_soak] FAIL: batch timeout\n")
            return

        # Heartbeat every 5 rounds.
        smp_soak_heartbeat = smp_soak_heartbeat + 1
        if smp_soak_heartbeat % 5 == 0:
            printk2("[smp_soak] heartbeat: round %d done=%d\n",
                    round_idx, smp_soak_done)

        round_idx = round_idx + 1

    local_irq_disable()
    printk2("[smp_soak] PASS: %d kthreads launched, %d completed\n",
            total_launched, smp_soak_done)
    printk0("[smp_soak] cpus_online check below\n")


# ---------------------------------------------------------------------
# NTASKS-ceiling proof (gated on /etc/ntasks-test in the initramfs,
# planted by build_initramfs.py when ENABLE_NTASKS_TEST=1). Called once
# from init/main.ad's boot sequence, BEFORE start_first_task().
#
# WHY: the spawn-loop / spawn-stress tests recycle a small number of
# task slots SEQUENTIALLY — they prove the reap path, not the ceiling.
# This test proves the NTASKS lift (64 -> 256) actually took effect by
# holding MANY MORE than the OLD 64-task ceiling LIVE SIMULTANEOUSLY in
# distinct task_table slots at one instant, then draining them cleanly.
#
# HOW: create kthreads in a tight loop with IRQs DISABLED and WITHOUT
# calling schedule() in between, so none of them run yet — each
# kthread_create publishes its slot as STATE_READY but the cooperative
# BSP never dispatches it during the create phase. They therefore pile
# up as concurrently-LIVE slots. We count how many we hold at the peak
# (slot 0 is the running boot task; APs hold their idle kthreads), then
# assert the peak EXCEEDS the old 64 ceiling. Finally each kthread is
# marked detached and we schedule() until they have all self-reaped to
# STATE_FREE, leaving the table clean for start_first_task().
#
# The body just bumps a counter and exits (detached self-reap), so the
# drain is a bounded cooperative schedule() loop exactly like the soak.

ntasks_test_done: uint64 = 0

# Target: hold well above the OLD 256 ceiling concurrently (Track 5 lifted
# NTASKS 256 -> 512). Leave headroom below NTASKS(512) for slot 0 (boot task),
# AP idle kthreads, and kthread kstack-alloc slack. 300 > 256 proves the old
# hard wall is gone, and draining 300 READY tasks via cooperative schedule()
# exercises the O(active) run-list _pick_next at scale (the old O(NTASKS) scan
# would have walked all 512 slots per pick).
NTASKS_TEST_HOLD: uint64 = 300


def _ntasks_test_kthread():
    # Increment the completion counter (under wq_lock against a torn
    # 64-bit RMW), then self-reap (the slot was marked detached).
    _wq_lock_irq()
    ntasks_test_done = ntasks_test_done + 1
    _wq_unlock_irq()
    task_exit_current(0)


def _ntasks_count_live() -> uint64:
    # Count non-FREE task_table slots (== concurrently-live tasks).
    n: uint64 = 0
    i: uint64 = 0
    while i < NTASKS:
        if task_table[i].state != STATE_FREE:
            n = n + 1
        i = i + 1
    return n


def ntasks_ceiling_test_run():
    printk0("[ntasks_test] starting NTASKS-ceiling concurrency proof\n")
    printk2("[ntasks_test] NTASKS=%d, will hold %d kthreads live at once\n",
            NTASKS, NTASKS_TEST_HOLD)

    ntasks_test_done = 0
    live_before: uint64 = _ntasks_count_live()
    printk1("[ntasks_test] live tasks before create burst = %d\n", live_before)

    # CREATE BURST: IRQs off, no schedule() between creates, so every
    # kthread piles up as STATE_READY without running. They are all
    # simultaneously live in the table at the end of this loop.
    local_irq_disable()
    launched: uint64 = 0
    k: uint64 = 0
    while k < NTASKS_TEST_HOLD:
        slot: int32 = kthread_create(
            cast[uint64](&_ntasks_test_kthread), 0)
        if slot < 0:
            # Ran out of slots (or kstack memory) before the target.
            k = NTASKS_TEST_HOLD
        else:
            task_table[cast[uint64](slot)].detached = 1
            launched = launched + 1
            k = k + 1

    # PEAK: count live slots while every just-created kthread is still
    # un-run (STATE_READY). This is the simultaneous-live high-water mark.
    peak_live: uint64 = _ntasks_count_live()
    local_irq_enable()

    printk2("[ntasks_test] launched %d kthreads; PEAK live slots = %d\n",
            launched, peak_live)

    # The proof: we held MORE than the old 256-task ceiling concurrently
    # (Track 5 lifted NTASKS 256 -> 512). Holding > 256 live tasks in distinct
    # slots at one instant is impossible under the old hard wall.
    if peak_live > 256:
        printk1("[ntasks_test] PASS: held %d > 256 live tasks at once\n",
                peak_live)
    else:
        printk1("[ntasks_test] FAIL: only held %d live tasks (<= old 256 ceiling)\n",
                peak_live)

    # DRAIN: mark done-target and cooperatively schedule() until every
    # launched kthread has bumped the counter and self-reaped.
    target: uint64 = launched
    sched_iters: uint64 = 0
    MAX_SCHED: uint64 = 100000   # generous bound for 200 cooperative reaps
    while ntasks_test_done < target and sched_iters < MAX_SCHED:
        schedule()
        sched_iters = sched_iters + 1

    local_irq_disable()
    if ntasks_test_done < target:
        printk2("[ntasks_test] DRAIN TIMEOUT: done=%d target=%d\n",
                ntasks_test_done, target)
        printk0("[ntasks_test] FAIL: drain timeout\n")
        return

    live_after: uint64 = _ntasks_count_live()
    printk2("[ntasks_test] drained: %d kthreads completed, live now = %d\n",
            ntasks_test_done, live_after)
    printk0("[ntasks_test] DONE\n")


# ---------------------------------------------------------------------
# #151: CFS-lite + SMP load-balance self-test (gated on /etc/sched-fair
# in the initramfs, planted by build_initramfs.py when
# ENABLE_SCHED_FAIR=1). Two halves:
#
#   (A) SMP spread — spawn SCHED_FAIR_NWORKERS long-lived CPU-bound
#       kthreads that each run a bounded busy loop, periodically
#       yielding so the BSP schedule() and the AP idle loop both get a
#       chance to dispatch them. Because kthreads (is_user==0) ARE
#       eligible on APs, under -smp 2 the AP idle loop work-steals some
#       of them. Each dispatch bumps the task's cpu_runs[cpu] counter
#       (sched_note_dispatch). After the workers finish we report, per
#       worker, how many times it ran on cpu0 vs cpu1. The test asserts
#       that the workers collectively ran on MORE THAN ONE CPU.
#
#   (B) weight ordering — verify sched_weight_for_nice / _pick_next
#       favour lower-nice tasks: print the computed weights for nice
#       -20 / 0 / +19 and a synthetic vruntime-accrual comparison so the
#       test can assert the heavier task accrues vruntime more slowly.
#       (The end-to-end ring-3 CPU-share proof lives in the userland
#       half of the test — test_sched_fair.sh — where preempt_tick's
#       vruntime accrual actually fires.)
#
# Runs on the BSP boot task (slot 0) before start_first_task(), same as
# the soak. Workers self-reap (detached).
# ---------------------------------------------------------------------
SCHED_FAIR_NWORKERS: uint64 = 4
SCHED_FAIR_WORKLOOP: uint64 = 2000000

# Per-worker completion + per-CPU dispatch tallies shared with the driver.
# CRITICAL: a worker self-reaps (task_exit_current) on exit, which frees
# its slot — and the next kthread_create may RECYCLE that slot, clobbering
# its cpu_runs[]. So a worker must NOT be read back from task_table after
# it exits. Instead each worker, while it is still the running task, reads
# its OWN final cpu_runs[0]/[1] and folds them into these shared totals
# under rq_lock right before exiting. The driver reads only these totals.
sched_fair_done:       uint64 = 0
sched_fair_cpu0_total: uint64 = 0
sched_fair_cpu1_total: uint64 = 0
# Diagnostic telemetry for the AP work-steal path (#151). ap_idle_laps is
# bumped at the top of every AP idle-loop iteration (so it only advances
# when the AP actually wakes/runs), ap_idle_dispatches each time the AP
# successfully steals+dispatches a task. Lets the selftest distinguish
# "AP never woke" from "AP woke but found nothing" from "AP dispatched".
ap_idle_laps:        uint64 = 0
ap_idle_dispatches:  uint64 = 0
# Gate for AP work-stealing. Default 1: APs steal runnable kernel tasks
# from the shared runqueue as normal. The #151 SMP self-test toggles this
# to 0 to fence off a deterministic window where ONLY the BSP runs workers
# (proving cpu0 gets load), then back to 1 to hand the remainder to the AP
# (proving cpu1 gets load). Production code never touches it.
sched_ap_steal_enabled: uint64 = 1

# BOOT-FIRST-TASK RACE (#413) one-shot. Set to 1 by init/main.ad strictly
# around the single create_user_task() call that builds PID 1, so that
# create_user_thread publishes PID 1 STATE_EMBRYO (off every run-list,
# unstealable) instead of STATE_READY. Cleared immediately after. 0 for every
# other task so normal spawns/forks publish READY as usual. See the publish
# block in create_user_thread and the claim in start_first_task.
boot_first_task_pending: uint64 = 0


def set_boot_first_task_pending(v: uint64):
    boot_first_task_pending = v

# AP-idle state.
#   _ap_idle_mode_logged — per-CPU one-shot bitmask so each AP prints its
#                     idle banner ("idle via hlt+ipi") exactly once, not
#                     every loop. Bit (1<<cpu_id) is set after the banner.
#                     The old MONITOR/MWAIT probe (g_ap_mwait_ok /
#                     _ap_probe_mwait) is gone: idle APs now HLT and wake on
#                     a reschedule IPI (Linux-mirror), so there is no
#                     capability gate and no jiffies-poll fallback.
_ap_idle_mode_logged:  uint64 = 0


def _sched_fair_worker():
    # Bounded CPU-bound kthread body. Spins, yielding cooperatively every
    # so often so the BSP/AP schedulers can rotate it across CPUs (each
    # dispatch bumps cpu_runs via sched_note_dispatch). Self-reaps.
    i: uint64 = 0
    acc: uint64 = 0
    while i < SCHED_FAIR_WORKLOOP:
        acc = acc + i + 1
        i = i + 1
    # NB: this worker runs to completion in a SINGLE dispatch — it never
    # yields mid-flight. The selftest spreads load by placing DIFFERENT
    # workers on different CPUs (BSP workers in phase 1, an AP worker in
    # phase 2), not by migrating one worker. Crucially this keeps the AP
    # path free of mid-run schedule() re-entry: the only scheduler op a
    # worker performs on the AP is the final task_exit_current() self-reap.
    # Fold this worker's own per-CPU dispatch counts into the shared totals
    # BEFORE exiting, while our slot is still live. current_idx_pcpu is the
    # slot we are running in (per-CPU). Reading our own cpu_runs here is
    # safe; reading it after self-reap would race slot recycling.
    _wq_lock_irq()
    my_slot: uint64 = current_idx_pcpu
    sched_fair_cpu0_total = sched_fair_cpu0_total + task_table[my_slot].cpu_runs[0]
    sched_fair_cpu1_total = sched_fair_cpu1_total + task_table[my_slot].cpu_runs[1]
    sched_fair_done = sched_fair_done + 1
    _wq_unlock_irq()
    task_exit_current(0)


def sched_fair_smp_selftest():
    printk0("[sched_fair] starting CFS-lite + SMP load-balance self-test\n")

    # --- Half (B): weight ordering sanity (cheap, deterministic) -------
    _sched_fill_weight_table()
    w_hi: uint64 = sched_weight_for_nice(-20)
    w_z:  uint64 = sched_weight_for_nice(0)
    w_lo: uint64 = sched_weight_for_nice(19)
    printk2("[sched_fair] weight(nice -20)=%d weight(nice 0)=%d\n", w_hi, w_z)
    printk1("[sched_fair] weight(nice +19)=%d\n", w_lo)
    if w_hi > w_z and w_z > w_lo:
        printk0("[sched_fair] PASS: weight strictly decreases with nice\n")
    else:
        printk0("[sched_fair] FAIL: weight ordering wrong\n")
    # vruntime-accrual ratio: per-tick advance is NICE0*SCALE/weight, so a
    # heavier task advances LESS per tick. Confirm the inequality on the
    # actual arithmetic the scheduler uses.
    adv_hi: uint64 = (NICE0_WEIGHT * VRUNTIME_SCALE) / w_hi
    adv_lo: uint64 = (NICE0_WEIGHT * VRUNTIME_SCALE) / w_lo
    printk2("[sched_fair] vruntime advance/tick: nice-20=%d nice+19=%d\n",
            adv_hi, adv_lo)
    if adv_hi < adv_lo:
        printk0("[sched_fair] PASS: heavy task accrues vruntime slower\n")
    else:
        printk0("[sched_fair] FAIL: vruntime accrual ratio wrong\n")

    # --- Half (A): SMP spread ------------------------------------------
    sched_fair_done = 0
    sched_fair_cpu0_total = 0
    sched_fair_cpu1_total = 0
    printk1("[sched_fair] launching %d CPU-bound worker kthreads\n",
            SCHED_FAIR_NWORKERS)

    # Drive the workers to completion with a DETERMINISTIC cpu0/cpu1 split.
    # Each worker runs to completion in a single dispatch and folds its own
    # per-CPU run counts into sched_fair_cpu{0,1}_total right before
    # self-reaping, so we only ever read these shared totals, never a freed/
    # recycled slot.
    #
    # The AP idle loop HLTs when no work is ready and is woken by a
    # reschedule IPI (vector 0xF2) sent from the spawn/wake paths (Linux-
    # mirror idle; see ap_main_hamnix + sched_ap_idle_loop). This phase
    # explicitly kicks the AP with smp_send_reschedule() after enabling
    # steal. sched_ap_steal_enabled fences the AP so we can place load
    # deterministically across two bounded phases:
    #
    #   Phase 1 (AP fenced OFF): launch N-1 workers and let the BSP
    #     schedule() drain them to completion. Each runs entirely on cpu0
    #     -> cpu0_total > 0. There is always a READY worker until they are
    #     all done, so schedule() never halts.
    #
    #   Phase 2 (AP fenced ON): launch ONE more worker, then the BSP stops
    #     scheduling and just spin-polls with cpu_relax(), yielding host
    #     vCPU time to the AP under QEMU TCG's round-robin. The AP steals
    #     that worker and runs it to completion -> cpu1_total > 0. Because
    #     the worker never yields, the AP performs no mid-run schedule() —
    #     only the final task_exit_current() self-reap, the path APs already
    #     execute reliably. Bounded so a wedged AP can't hang boot.
    MAXI: uint64 = 2000000

    # --- Phase 1: launch N-1 workers, BSP drains them (AP fenced off) ----
    sched_ap_steal_enabled = 0
    w: uint64 = 0
    while (w + 1) < SCHED_FAIR_NWORKERS:
        _wq_lock_irq()
        slot: int32 = kthread_create(cast[uint64](&_sched_fair_worker), 0)
        if slot >= 0:
            task_table[cast[uint64](slot)].detached = 1
        _wq_unlock_irq()
        w = w + 1
    iters: uint64 = 0
    while (sched_fair_done + 1) < SCHED_FAIR_NWORKERS and iters < MAXI:
        schedule()
        iters = iters + 1

    # --- Phase 2: launch the final worker, hand it to the AP (fence on) --
    _wq_lock_irq()
    lslot: int32 = kthread_create(cast[uint64](&_sched_fair_worker), 0)
    if lslot >= 0:
        task_table[cast[uint64](lslot)].detached = 1
    _wq_unlock_irq()
    sched_ap_steal_enabled = 1
    # Linux-mirror idle: the AP is HLTed waiting for a reschedule IPI. Now
    # that the final worker is runnable AND steal is enabled, kick the AP so
    # it falls out of HLT and work-steals it (no jiffies poll any more).
    smp_send_reschedule()
    iters = 0
    while sched_fair_done < SCHED_FAIR_NWORKERS and iters < MAXI:
        relax2: uint64 = 0
        while relax2 < 1024:
            cpu_relax()
            relax2 = relax2 + 1
        iters = iters + 1
        # Keep nudging: under TCG the AP may have re-HLTed between steals.
        smp_send_reschedule()
    # Re-fence the AP for the remainder of boot now that the test is done.
    sched_ap_steal_enabled = 0

    local_irq_disable()
    if sched_fair_done < SCHED_FAIR_NWORKERS:
        printk2("[sched_fair] FAIL: only %d/%d workers finished\n",
                sched_fair_done, SCHED_FAIR_NWORKERS)
        local_irq_enable()
        return
    cpu0_total: uint64 = sched_fair_cpu0_total
    cpu1_total: uint64 = sched_fair_cpu1_total
    local_irq_enable()

    # Tally per-CPU dispatches: each worker folded its own cpu_runs[] into
    # these shared totals just before self-reaping (safe — read while the
    # worker's slot was still live), so there is no recycled-slot race.
    cpus_used: uint64 = 0
    if cpu0_total > 0:
        cpus_used = cpus_used + 1
    if cpu1_total > 0:
        cpus_used = cpus_used + 1
    printk2("[sched_fair] AP diag: idle_laps=%d ap_dispatches=%d\n",
            ap_idle_laps, ap_idle_dispatches)
    printk2("[sched_fair] dispatch totals: cpu0=%d cpu1=%d\n",
            cpu0_total, cpu1_total)
    printk1("[sched_fair] distinct CPUs that ran a worker: %d\n", cpus_used)
    if cpus_used >= 2:
        printk0("[sched_fair] PASS: workers spread across >1 CPU\n")
    else:
        # On -smp 1 only cpu0 is present — that's expected, not a failure.
        # The test script distinguishes the -smp 1 and -smp 2 cases.
        printk0("[sched_fair] NOTE: workers ran on a single CPU (smp1 or AP idle)\n")
    printk0("[sched_fair] self-test complete\n")


# STAGE A per-CPU TSS proof (gated on /etc/smp-user in the initramfs,
# planted by build_initramfs.py when ENABLE_SMP_USER=1). Proves the
# headline Stage-A deliverable: a USER task (is_user=1, CPL3) is
# dispatched and runs on a NON-BSP CPU (cpu1) without faulting — which is
# only possible because each CPU now has its own per_cpu_tss (loaded with
# ltr during bring-up) whose RSP0 the AP dispatch path keeps pointing at
# the running task's kstack, so the ring3->ring0 transition the task's
# SYS_WRITE/SYS_EXIT triggers on the AP lands on a valid kernel stack.
#
# Method (mirrors sched_fair_smp_selftest's phase-2 AP hand-off, but with
# a USER task instead of a kthread):
#   1. Fence the AP OFF, create the user task running smp_user_probe_entry
#      (STATE_READY, detached so it self-reaps on SYS_EXIT).
#   2. Fence the AP ON and kick it with smp_send_reschedule(); the BSP does
#      NOT call schedule() — it only spin-polls — so the BSP never steals
#      the task and the AP is the only CPU that can run it.
#   3. While the task is alive, snapshot its cpu_runs[1] (dispatches on
#      cpu1) — keep the max seen, since the slot is recycled on self-reap.
#   4. Assert the task ran on cpu1 and emit a PASS/FAIL banner the test
#      script greps.
# Runs on the BSP boot task before start_first_task(), same context the
# soak / sched-fair self-tests use.
smp_user_probe_done: uint64 = 0


def smp_user_ap_selftest():
    printk0("[smp_user] starting Stage-A per-CPU-TSS USER-on-AP self-test\n")
    if get_cpus_online() < 2:
        printk0("[smp_user] NOTE: only 1 CPU online — cannot prove AP user run\n")
        printk0("[smp_user] self-test complete\n")
        return

    # Phase 1: create the user probe task with the AP fenced off so the
    # BSP can't see it dispatched anywhere yet. is_user=1 is set by
    # create_user_task (CPL3 task with its own PML4 + user stack).
    sched_ap_steal_enabled = 0
    smp_user_probe_done = 0
    # The probe body lives in kernel .text, which is US=0 (W^X/SMEP restamps
    # every high-half leaf supervisor-only), so a CPL3 task cannot fetch it
    # at its kernel VA — that is the #PF (err=0x15: P|U|I-fetch) the bare
    # &smp_user_probe_entry entry hit. Copy the self-contained, PIC
    # [smp_user_probe_entry, smp_user_probe_end) span (code + inline banner)
    # into a fresh page and map it US=1 (read-only, executable: extra_flags=0)
    # at a low user VA in the task's PML4, then start the task THERE.
    pe: uint64 = cast[uint64](&smp_user_probe_entry)
    pend: uint64 = cast[uint64](&smp_user_probe_end)
    blob_len: uint64 = pend - pe
    SMP_USER_PROBE_VA: uint64 = 0x600000          # low user VA, 4 KiB aligned
    code_page: uint64 = alloc_page()
    if code_page == 0:
        printk0("[smp_user] FAIL: OOM allocating probe code page\n")
        return
    memcpy(cast[Ptr[uint8]](code_page), cast[Ptr[uint8]](pe), blob_len)
    _wq_lock_irq()
    uslot: int32 = create_user_task(SMP_USER_PROBE_VA, 0)
    if uslot >= 0:
        task_table[cast[uint64](uslot)].detached = 1
        # Overlay the US=1 executable code page at SMP_USER_PROBE_VA in the
        # probe task's private PML4. extra_flags=0 -> read-only + executable
        # (no PT_FLAG_RW, no PT_FLAG_NX) US=1 leaf.
        if elf_install_user_mapping(task_table[cast[uint64](uslot)].cr3,
                                    SMP_USER_PROBE_VA,
                                    SMP_USER_PROBE_VA + 4096,
                                    code_page, 0) < 0:
            printk0("[smp_user] FAIL: could not map probe code US=1\n")
    _wq_unlock_irq()
    if uslot < 0:
        printk0("[smp_user] FAIL: could not create user probe task\n")
        return
    us: uint64 = cast[uint64](uslot)
    printk1("[smp_user] user probe task @ slot %d\n", us)

    # Phase 2: hand it to the AP. Enable steal, kick the AP out of HLT, and
    # spin-poll WITHOUT scheduling on the BSP so only the AP can run it.
    #
    # Snapshot whether the task ever became live-on-cpu1 AND whether it
    # ran far enough to issue its SYS_EXIT (which only fires AFTER its
    # SYS_WRITE — both are ring3->ring0 SYSCALLs on the AP). A clean
    # self-reap to STATE_FREE with exit_code 0 is direct proof the
    # ring3->ring0 syscall transition completed on the AP: SYS_EXIT IS a
    # syscall, so reaching STATE_FREE means a `syscall` instruction
    # executed on the AP without #UD/#GP. We watch for the transition
    # rather than relying on the probe's fd=2 banner reaching the serial
    # console — a bare early-boot AP task's stderr need not be wired to
    # -serial stdio, but the kernel-side reap is always observable.
    cpu1_seen: uint64 = 0
    saw_cpu1_live: uint64 = 0
    syscall_proven: uint64 = 0
    sched_ap_steal_enabled = 1
    smp_send_reschedule()
    # Generous budget: wait for the probe to actually self-reap (SYS_EXIT,
    # which only runs AFTER its SYS_WRITE banner) rather than giving up
    # mid-spin. Under TCG the AP may re-HLT between dispatches, so each
    # outer lap also re-kicks it; the dominant cost is the AP doing real
    # ring3 work, not these spins.
    MAXI_U: uint64 = 40000000
    itu: uint64 = 0
    while task_table[us].state != STATE_FREE and itu < MAXI_U:
        # Snapshot dispatches-on-cpu1 while the slot is still live (it is
        # recycled the instant the task self-reaps to STATE_FREE).
        c1: uint64 = task_table[us].cpu_runs[1]
        if c1 > cpu1_seen:
            cpu1_seen = c1
        # Remember we saw it dispatched on cpu1 at least once.
        if c1 > 0:
            saw_cpu1_live = 1
        r: uint64 = 0
        while r < 512:
            cpu_relax()
            r = r + 1
        itu = itu + 1
        # Keep nudging: under TCG the AP may re-HLT between dispatches.
        smp_send_reschedule()
    # One last snapshot in case it ran-and-reaped between our checks.
    c1f: uint64 = task_table[us].cpu_runs[1]
    if c1f > cpu1_seen:
        cpu1_seen = c1f
    # The probe only leaves STATE_FREE again by reaching SYS_EXIT, which it
    # issues IMMEDIATELY AFTER its SYS_WRITE — both are `syscall`
    # instructions executed in ring3 on the AP. So a detached probe that
    # was dispatched on cpu1 AND is now STATE_FREE proves the ring3->ring0
    # SYSCALL transition completed on the AP (a missing/un-armed per-CPU
    # SYSCALL MSR set, or a missing per-CPU TSS.RSP0, would #UD/#GP before
    # the task could self-reap). This is the kernel-observable equivalent
    # of the probe's fd=2 banner, which need not reach -serial stdio from a
    # bare early-boot task.
    if saw_cpu1_live != 0 and task_table[us].state == STATE_FREE:
        syscall_proven = 1
    # Re-fence the AP for the rest of boot.
    sched_ap_steal_enabled = 0

    printk2("[smp_user] AP diag: idle_laps=%d ap_dispatches=%d\n",
            ap_idle_laps, ap_idle_dispatches)
    printk1("[smp_user] user probe dispatched on cpu1: %d time(s)\n",
            cpu1_seen)
    if cpu1_seen > 0:
        printk0("[smp_user] PASS: USER task ran on a non-BSP CPU (cpu1) via per-CPU TSS\n")
    else:
        printk0("[smp_user] FAIL: USER task never dispatched on cpu1\n")
    if syscall_proven != 0:
        printk0("[smp_user] ring3 task ran a syscall on its CPU\n")
    else:
        printk0("[smp_user] FAIL: probe did not complete a syscall on the AP\n")
    printk0("[smp_user] self-test complete\n")

# kernel/panic.ad
#
# Mirrors the smallest meaningful slice of kernel/panic.c in Linux:
# panic(), BUG(), and WARN_ON(). All three terminate or interrupt the
# normal printk flow with a recognizable banner so an operator can spot
# them in serial logs.
#
# Hamnix's lack of varargs and lack of `__FILE__`/`__LINE__` macros means
# call sites supply a single descriptive string. The convention is the
# same as Linux when reading panic.c without the macros:
#
#     panic("oom");                       -- Linux
#     panic("OOM in early_init")          -- Hamnix equivalent
#
#     BUG();                              -- Linux (macro grabs file/line)
#     BUG("free of unowned page")         -- Hamnix supplies it explicitly
#
#     WARN_ON(x > MAX);                   -- Linux
#     WARN_ON(x > MAX, "x exceeded MAX")  -- Hamnix equivalent
#
# Backtrace: dump_stack() below walks the saved-%rbp frame-pointer chain
# (Adder's codegen always frames with %rbp — compiler/codegen_x86.py:21 —
# so every frame is [%rbp]=saved-caller-rbp, [%rbp+8]=return-address, a
# walkable singly-linked list). panic()/BUG()/WARN_ON() all call it.
#
# Symbolization: the MAIN kernel image carries no runtime symbol table
# (kallsyms-style) — the only symbol facility is the .ko loader's
# function-pointer __ksymtab, which covers loadable modules, not the
# kernel image itself. Rather than invent a heavy build-time kallsyms
# table, dump_stack() prints RAW high-VMA return addresses plus the
# kernel text base, exactly like Linux with CONFIG_KALLSYMS=n: an
# operator symbolizes them offline against the build's unstripped ELF
# (the kernel is linked `ld -static` with no `-s`, so .symtab survives)
# via e.g. `addr2line -e build/hamnix-kernel.elf <addr>`.

from kernel.printk.printk import printk1, printk2, printk_set_level
# TEMP_DEBUG_TRAP_VISIBILITY: panic / BUG / WARN_ON output must survive
# the post-interactive console-loglevel gate (013fe0c). EMERG is
# severity 0, strictly below every threshold the console-split
# shipped, so a panic line always reaches the live console even after
# console_set_interactive() tightened it.
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG

extern def local_irq_disable()

# Frame-pointer + text-bound accessors (arch/x86/kernel/head_64.S).
#   read_rbp()           -> the CALLER's %rbp (start of the frame chain)
#   kernel_text_start()  -> high-VMA __kernel_text_start (0xffffffff80...)
#   kernel_text_end()    -> high-VMA __kernel_text_end   (past .data/.bss)
extern def read_rbp() -> uint64
extern def kernel_text_start() -> uint64
extern def kernel_text_end() -> uint64

# Cap the walk so a corrupt %rbp chain can never loop forever.
DUMP_STACK_MAX_FRAMES: uint64 = 32


def dump_stack():
    # Walk the saved-%rbp frame-pointer linked list and print each
    # return address. Mirrors Linux dump_stack(): symbolized when a
    # symbol table exists, raw addresses otherwise. Hamnix's kernel
    # image has no runtime symtab, so we print raw high-VMA addresses
    # plus the text base for offline symbolization.
    #
    # TEMP_DEBUG_TRAP_VISIBILITY: every line is stamped EMERG (severity
    # 0) before its printk so the backtrace survives the post-interactive
    # console-loglevel gate, identical to the panic banner above. The
    # latch is one-shot (consumed by console_begin_msg), hence the
    # re-stamp before each printk call.
    text_lo: uint64 = kernel_text_start()
    text_hi: uint64 = kernel_text_end()

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("Call trace (kernel text base = %p):\n", text_lo)

    # Start at our caller's frame. read_rbp() is a leaf asm helper with
    # no prologue, so it returns dump_stack()'s %rbp — the first frame.
    fp: uint64 = read_rbp()
    i: uint64 = 0
    while i < DUMP_STACK_MAX_FRAMES:
        # A valid frame pointer is non-zero and 8-byte aligned. The
        # kernel boot stack lives in LOW identity-mapped RAM (see
        # arch/x86/boot/header.S boot_stack_top — set via `movl
        # $boot_stack_top, %esp`), NOT in the high-half kernel mapping,
        # so a frame pointer is a SMALL low address — we must NOT reject
        # it for being below the .text base. We only reject the obvious
        # corruption: 0 (the outermost frame; head-stub %rbp), a value
        # in the unmapped null page (< 0x1000, would fault on deref), or
        # an address that is neither in the low <4 GiB identity map nor
        # in the high-half kernel window (a wild pointer we won't deref).
        # The ascending-chain + max-frames bounds below guarantee
        # termination regardless.
        if fp == 0:
            break
        if (fp & cast[uint64](7)) != 0:
            break
        if fp < cast[uint64](0x1000):
            break
        # Mapped-range gate: low identity map [0x1000, 4 GiB) OR the
        # high-half kernel window [text_lo, ...). Anything else is wild;
        # stop rather than risk a fault dereferencing it.
        fp_low_ok: uint64 = 0
        if fp < cast[uint64](0x100000000):
            fp_low_ok = 1
        if fp >= text_lo:
            fp_low_ok = 1
        if fp_low_ok == 0:
            break

        # [%rbp+8] = return address pushed by `call`; [%rbp] = caller %rbp.
        ret_addr: uint64 = cast[Ptr[uint64]](fp + 8)[0]
        next_fp: uint64 = cast[Ptr[uint64]](fp)[0]

        # Only print addresses that land inside the kernel image; skip
        # (but keep walking) anything outside so trampoline/IRQ frames
        # don't emit noise as bogus addresses.
        if ret_addr >= text_lo and ret_addr < text_hi:
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk2("  [<%p>] +0x%x\n", ret_addr, ret_addr - text_lo)

        # The chain must strictly ascend toward the stack top; a
        # non-increasing next_fp means corruption (or we've unwound off
        # the top) — stop to avoid an infinite loop on a self-referential
        # frame.
        if next_fp <= fp:
            break
        fp = next_fp
        i = i + 1


def _hang_forever():
    # Interrupts off so a stray IRQ can't drag execution out of the
    # halt loop and obscure the panic banner. HLT yields the CPU until
    # the next interrupt — which can't happen with IF=0 — making this
    # a true sleep, not a busy spin.
    local_irq_disable()
    while True:
        asm_volatile("hlt")


def panic(msg: Ptr[char]):
    # Unrecoverable. Linux's panic() also tries to invoke registered
    # panic notifiers, possibly reboots, and dumps a stack trace; we
    # have none of that infrastructure yet, so the body is just the
    # banner + halt. Notifiers / stack dumps land when their underlying
    # subsystems exist.
    # TEMP_DEBUG_TRAP_VISIBILITY: stamp EMERG on each printk1 (one-shot
    # latch, consumed by console_begin_msg). A panic line MUST reach
    # the live console even after the post-interactive gate.
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("\n--- Kernel panic: %s ---\n", cast[uint64](msg))
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("Halting CPU. msg @ %p\n", cast[uint64](msg))
    dump_stack()
    _hang_forever()


def BUG(msg: Ptr[char]):
    # Used at assertion sites the kernel can't recover from but that
    # aren't quite "the system is fundamentally broken" the way panic()
    # implies. In practice on Linux they end up doing the same thing.
    # TEMP_DEBUG_TRAP_VISIBILITY: stamp EMERG so the banner is never
    # gated.
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("\n*** BUG: %s ***\n", cast[uint64](msg))
    dump_stack()
    _hang_forever()


def WARN_ON(cond: uint64, msg: Ptr[char]) -> uint64:
    # Returns the condition value so callers can chain inside an `if`,
    # mirroring Linux's `if (WARN_ON(x))` idiom. Treats any non-zero
    # cond as fired. Caller continues executing — WARN is for
    # "shouldn't happen but the kernel can keep going".
    if cond != 0:
        # TEMP_DEBUG_TRAP_VISIBILITY: stamp EMERG so a WARN_ON fires on
        # the live console even after the post-interactive gate tightens.
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("WARN: %s\n", cast[uint64](msg))
        # Unlike panic()/BUG(), WARN_ON does NOT halt — the kernel keeps
        # running — but a backtrace is just as useful for "shouldn't
        # happen" diagnostics, so emit one here too (Linux's WARN dumps
        # a stack as well).
        dump_stack()
    return cond

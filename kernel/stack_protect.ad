# kernel/stack_protect.ad
#
# V0 stack-protector runtime for Hamnix's own Adder-compiled kernel
# code. The codegen (compiler/codegen_x86.py) emits this pattern at
# every function it tags `needs_canary` (mirrors gcc's
# `-fstack-protector-strong` heuristic — Array[N>=8] local or any
# `&local`):
#
#   prologue:
#     movq __stack_chk_guard(%rip), %rax
#     movq %rax, -8(%rbp)
#   epilogue:
#     movq -8(%rbp), %rax
#     xorq __stack_chk_guard(%rip), %rax
#     testq %rax, %rax
#     jnz __stack_chk_fail
#
# Why this exists right now: today's TLS work surfaced a real bug in
# this class — `_tls_aead_seal`'s on-stack Array[2048, uint8] was
# too small for inbound 2.5 KiB+ Certificate records, padding ran off
# the end into the saved return-address territory, and the next ret
# trapped #GP at an rip far from the actual overrun site. Two prior
# debug agents had to find it. With a canary in place the prologue
# stamps a known value just below the saved return address; the
# epilogue compares; mismatch tail-calls __stack_chk_fail which
# prints a recognisable banner and halts. The crash now points at
# the FUNCTION that wrote past its buffer, not at whatever happened
# to be the next victim in iret/ret.
#
# Linux's analogue: arch/x86/include/asm/stackprotector.h installs a
# per-task random canary in the GS-area at task setup; __stack_chk_fail
# in lib/string_helpers.c hands off to panic(). Hamnix's V0 keeps the
# guard global rather than per-task (no per-task storage plumbed yet)
# and the failure path is a printk0 + hlt-loop rather than a full
# panic() — adequate to make the failure recognisable in the serial
# log without dragging the rest of the panic plumbing into a code
# path that may itself be running on a half-corrupted stack.
#
# IMPORTANT: __stack_chk_fail / __stack_chk_init MUST NOT themselves
# receive a canary (the prologue would call them, they'd return
# through their own canary check, infinite recursion / immediate
# crash). The compiler skips them by exact-match name via
# STACK_PROTECTOR_SKIP_NAMES in codegen_x86.py.
#
# This module also owns the canonical __stack_chk_guard storage. The
# Linux-ABI export table (linux_abi/exports.ad) imports the symbol
# from here and re-publishes it under the EXPORT_SYMBOL name so .ko
# modules find the same global as Hamnix's native code — one canary
# shared across both worlds keeps the failure semantics consistent.

from kernel.printk.printk import printk0, printk1, printk2
from mm.cow import cow_boot_cr3
from arch.x86.kernel.time import get_jiffies

extern def local_irq_disable()
extern def read_cr3() -> uint64
extern def load_cr3(cr3: uint64)


def _sp_pte_walk(cr3: uint64, va: uint64):
    # Self-contained diagnostic page walk (duplicated from trap_diag's
    # trap_diag_pte_walk to keep this module import-leaf — trap_diag's
    # import chain is deep and __stack_chk_fail must stay callable from
    # EVERYTHING). Caller must be on a CR3 that identity-maps the table
    # pages (we switch to the boot CR3 before calling).
    m: uint64 = 0x000FFFFFFFFFF000
    i4: uint64 = (va >> 39) & 0x1FF
    i3: uint64 = (va >> 30) & 0x1FF
    i2: uint64 = (va >> 21) & 0x1FF
    i1: uint64 = (va >> 12) & 0x1FF
    pml4: Ptr[uint64] = cast[Ptr[uint64]](cr3 & m)
    e4: uint64 = pml4[i4]
    printk2("[stack-smash]   pml4e[%d]=%p\n", i4, e4)
    if (e4 & 0x1) == 0:
        return
    pdpt: Ptr[uint64] = cast[Ptr[uint64]](e4 & m)
    e3: uint64 = pdpt[i3]
    printk2("[stack-smash]   pdpte[%d]=%p\n", i3, e3)
    if (e3 & 0x1) == 0 or (e3 & 0x80) != 0:
        return
    pd: Ptr[uint64] = cast[Ptr[uint64]](e3 & m)
    e2: uint64 = pd[i2]
    printk2("[stack-smash]   pde[%d]=%p\n", i2, e2)
    if (e2 & 0x1) == 0 or (e2 & 0x80) != 0:
        return
    pt: Ptr[uint64] = cast[Ptr[uint64]](e2 & m)
    e1: uint64 = pt[i1]
    printk2("[stack-smash]   pte[%d]=%p\n", i1, e1)


# Pre-init magic. The codegen-emitted prologue runs from the very
# first protected function call (which can be early in start_kernel,
# before __stack_chk_init has had a chance to randomise the guard),
# so the magic MUST be non-zero AND non-all-ones — a zero canary
# would pass against a zeroed-stack overrun, and an all-ones canary
# would pass against a memset-0xFF overrun. The value below has good
# Hamming distance from both common overrun-fill patterns (0x00 and
# 0xFF) and is recognisable in a hexdump.
__stack_chk_guard: uint64 = 0xC0FFEEDEADBEEFC0


def __stack_chk_init():
    # Mix the boot-time jiffies count into the canary. Not crypto-
    # quality randomness — get_jiffies returns the timer-tick count
    # since boot, which an attacker with serial-console visibility
    # can read — but it's deterministically different from the
    # build-time magic above, so a hardcoded-canary attack that
    # works against one boot doesn't trivially carry to the next.
    # When RDRAND / a real PRNG is wired up (post M16.69 random
    # subsystem work), replace this body with a read from there.
    # The high half stays the magic so the canary remains
    # recognisable in a hexdump even after init.
    seed: uint64 = get_jiffies()
    if seed == 0:
        # get_jiffies before time_init returns 0; don't downgrade
        # the canary to all-zero in that case. Stir in a build-stable
        # constant so the post-init guard still differs from the
        # pre-init magic (avoids "did init even run?" ambiguity).
        seed = 0x9E3779B97F4A7C15
    __stack_chk_guard = 0xC0FFEE00_00000000 ^ (seed * 0x9E3779B97F4A7C15)


def __stack_chk_fail():
    # Reached when a canary-protected function's prologue value
    # differs from the live guard at epilogue — a stack-buffer write
    # overflowed past its bounds. Interrupts off so a stray IRQ
    # can't unwind us out of the halt and re-enter potentially-
    # corrupted code; printk0 with a stable banner so an operator
    # grepping the serial log sees the failure. V0 intentionally
    # doesn't try to dump %rbp / a stack walk — the stack itself is
    # known-bad at this point.
    printk0("[stack-smash] kernel halted\n")
    local_irq_disable()
    # Kstack-corruption forensics (#410 live-root intermittent failure):
    # a canary mismatch in a HIGH kernel frame can mean the canary
    # memory itself was never overwritten — instead the kstack VADDR was
    # remapped/cleared in the live CR3 (identity-map crack / freed-and-
    # reused page-table page), so the epilogue read someone else's
    # frame. Print who we are and page-walk the CURRENT STACK PAGE
    # (&probe) under the live CR3's structures, reading the table pages
    # under the pristine boot CR3 so the walk itself cannot re-fault.
    # An identity-intact kstack shows pte phys == page vaddr; anything
    # else is the smoking gun.
    probe: uint64 = 0
    sp_va: uint64 = cast[uint64](&probe)
    live_cr3: uint64 = read_cr3()
    printk2("[stack-smash] sp~=%p live cr3=%p\n", sp_va, live_cr3)
    printk1("[stack-smash] guard now=%p\n", __stack_chk_guard)
    boot_cr3: uint64 = cow_boot_cr3()
    if boot_cr3 != 0:
        load_cr3(boot_cr3)
        printk0("[stack-smash] walk sp under LIVE cr3:\n")
        _sp_pte_walk(live_cr3, sp_va)
        if boot_cr3 != live_cr3:
            printk0("[stack-smash] walk sp under BOOT cr3:\n")
            _sp_pte_walk(boot_cr3, sp_va)
    while True:
        asm_volatile("hlt")

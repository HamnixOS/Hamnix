# kernel/boot_flags.ad
#
# F9 #452 namespace-purity sweep — boot-flag ctl surface.
#
# Audit #444 finding F9 flagged "modprobe reads ten /etc/*-ko flag files
# from kernel context (→ one ctl file)" as a residual literal-path
# bypass. Before this module the kernel had 14 separate functions, each
# with its OWN hardcoded `/etc/<flag>` string, each calling
# `_find_initramfs_entry` against the cpio entry table from boot context
# (no Pgrp, no namespace consultation). 14 literal paths, one per flag.
#
# This module collapses all 14 into a single `boot_flag_get(name)` ctl
# surface. The kernel still consults a `/etc/<name>` cpio entry — the
# build artefact convention is unchanged — but the ONE place that
# resolves a flag name to a cpio probe lives here, with the literal
# `/etc/` prefix baked in exactly once. Every caller (kernel/modprobe.ad
# marker_found wrappers, linux_abi/api_xhci_real.ad, drivers/net/
# e1000e_traffic.ad) becomes a thin wrapper. Adding a new boot flag is
# now one line and one cpio entry — no new literal-path arm.
#
# Architecturally these flags are KERNEL boot-configuration markers
# planted by `scripts/build_initramfs.py` against ENABLE_* environment
# variables at build time. They are read ONCE per boot (or lazily on
# first query) from the kernel-embedded cpio blob — the cpio is itself
# a server-anchored namespace artifact (the `#r` boot file server), so
# there is no global path fall-through involved. The "literal path"
# audit hit was about the COUNT of pre-namec strcmp arms and the
# kernel-context "reach into the FS by name" shape, both of which this
# module retires.
#
# Why NOT a per-Pgrp `bind` lookup
# --------------------------------
# Boot flags are consulted at the EARLIEST kernel-init phase — before
# pgrp_init plants the default namespace, before any user task exists,
# from the linker's __init body. There is no Pgrp to walk yet. The
# `#r` boot server (kernel-embedded cpio) is the only file source live
# at this point by design; flagging through it is namespace-coherent
# (the same cpio every Pgrp's `#r` arm reads) without requiring a Pgrp.
#
# Why NOT a single /etc/boot-flags key=val file
# ---------------------------------------------
# That was considered; the parser would have to live in this module
# anyway, and the cpio entry-table is already the kernel's key/value
# store (NAME -> bytes). Keeping the existing one-file-per-flag layout
# means scripts/build_initramfs.py needs zero changes — F9's
# architectural purification is in the kernel's CONSUMPTION, not the
# build artifact's shape. A future revision can fold the cpio entries
# into one consolidated file by changing this module's body without
# touching any caller.

from fs.cpio import (
    cpio_init,
    initramfs_entry_count, initramfs_entry_name,
)


# Adder can't take String[N] addresses in function-local frames; we
# bake every legal flag name into a top-level string-pointer table. The
# function-local prefix concatenation runs against a top-level scratch
# buffer; single-threaded boot phase, no locking needed. 64 bytes is
# ample headroom — the longest flag in the registry today is
# "/etc/xhci-ko-real-mmio" at 22 chars (with /etc/ prefix), and we cap
# at 63+NUL so a stray oversized query short-circuits cleanly.
_BF_SCRATCH_CAP: uint64 = 64
_bf_scratch: Array[64, uint8]


def _bf_compose(name: Ptr[uint8], out_len: Ptr[uint64]) -> int32:
    # Compose "/etc/<name>" into _bf_scratch, NUL-terminated. Returns
    # the total byte length WITHOUT the trailing NUL via *out_len and
    # 0 on success, -1 if the result would not fit. Stops on a NUL in
    # `name` — name MUST be NUL-terminated.
    prefix: Ptr[uint8] = "/etc/"
    pl: uint64 = 5
    j: uint64 = 0
    while j < pl:
        _bf_scratch[j] = prefix[j]
        j = j + 1
    k: uint64 = 0
    while True:
        if pl + k + 1 >= _BF_SCRATCH_CAP:                # leave room for NUL
            return -1
        c: uint8 = name[k]
        _bf_scratch[pl + k] = c
        if c == 0:
            out_len[0] = pl + k
            return 0
        k = k + 1
    return -1                                            # unreachable


def _bf_cpio_probe(target: Ptr[uint8], target_len: uint64) -> int32:
    # Linear scan over the cpio table for a NUL-terminated NAME that
    # matches `target[0..target_len]` plus a trailing NUL. Returns 1 on
    # hit, 0 on miss. Same shape as the legacy per-flag bodies that USED
    # to live in kernel/modprobe.ad — but now there is exactly ONE arm.
    cpio_init()
    count: uint64 = initramfs_entry_count()
    i: uint64 = 0
    while i < count:
        nm: Ptr[char] = initramfs_entry_name(i)
        np: Ptr[uint8] = cast[Ptr[uint8]](nm)
        ok: int32 = 1
        j: uint64 = 0
        while j < target_len:
            if np[j] != target[j]:
                ok = 0
                j = target_len                           # break
            else:
                j = j + 1
        if ok == 1 and np[target_len] == 0:
            return 1
        i = i + 1
    return 0


def boot_flag_get(name: Ptr[uint8]) -> int32:
    # F9 #452 canonical query: returns 1 iff the boot flag identified by
    # `name` is set. `name` is the bare flag identifier (e.g. "ahci-ko",
    # "auto-modules", "xhci-ko-real-mmio") — the "/etc/" prefix is added
    # here so every caller passes the same shape and the literal prefix
    # lives in exactly ONE place. A name that overflows the 63-byte
    # scratch returns 0 (not set), which is the SAFE default for every
    # marker today (absent = legacy/default behaviour).
    out_len: uint64 = 0
    if _bf_compose(name, &out_len) != 0:
        return 0
    return _bf_cpio_probe(&_bf_scratch[0], out_len)

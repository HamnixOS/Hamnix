    # only calls devmouse_write/devmouse_read/mouse_rx_push directly — no
    # file opens — so it is safe at boot:37 without fd-table priming.
    # Prints "[DEVMOUSE_WRITE] PASS" / "[DEVMOUSE_WRITE] FAIL ...".
    printk0("[boot:37.dmw] checking /etc/devmouse-write-test marker\n")
    dmw_marker_found: int32 = 0
    dmw_idx: uint64 = 0
    dmw_count: uint64 = initramfs_entry_count()
    while dmw_idx < dmw_count:
        dmw_name: Ptr[char] = initramfs_entry_name(dmw_idx)
        # Compare byte-by-byte with "/etc/devmouse-write-test\0" (25 bytes inc NUL).
        dmw_ok: int32 = 1
        dmw_tgt: Ptr[uint8] = "/etc/devmouse-write-test"
        dmw_j: uint64 = 0
        while dmw_j < 25:
            if cast[uint8](dmw_name[dmw_j]) != dmw_tgt[dmw_j]:
                dmw_ok = 0
                dmw_j = 25
            else:
                dmw_j = dmw_j + 1
        if dmw_ok == 1:
            dmw_marker_found = 1
            dmw_idx = dmw_count
        else:
            dmw_idx = dmw_idx + 1
    if dmw_marker_found == 1:
        printk0("[boot:37.dmw] /etc/devmouse-write-test found — running self-test\n")
        devmouse_write_selftest()
    else:
        printk0("[DEVMOUSE_WRITE] skipped (no /etc/devmouse-write-test marker)\n")


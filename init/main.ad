    # ru_stime reflects a non-zero tick count — proving real per-task
    # CPU-time accounting. Lives here (not in the ext4-gated block) because
    # it needs no block device. Returns 1 on PASS; we printk a FAIL banner
    # otherwise. Prints "[RUSAGE] PASS" / "[RUSAGE] FAIL ...".
    if g_rusage_test == 1:
        printk0("[boot:37.ru] /etc/rusage-test found — running self-test\n")
        if rusage_selftest() != 1:

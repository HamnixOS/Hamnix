        else:
            rdr_idx = rdr_idx + 1
    if rdr_marker_found == 1:
        printk0("[boot:30.a] http_redirect_smoke_test\n")
        http_redirect_smoke_test()
    else:
        printk0("[http-redirect] skipped (no /etc/http-redirect-test marker)\n")

    # --- TCP loopback smoke (single-process in-kernel round-trip) ----
    # Gated on /etc/tcp-loopback-test (planted by
    # scripts/test_tcp_loopback.sh via ENABLE_TCP_LOOPBACK_SMOKE=1 in
    # build_initramfs.py). Proves the loopback state machine works
    # without SLIRP or a second process: tcp_listen + tcp_connect to
    # 127.0.0.1 in one kernel context, then a data byte each direction.
    # No guestfwd needed — 127.0.0.1 is handled entirely in ip_send's
    # loopback shortcut. Placed after DHCP (ip_our_ip set), after
    # vfs_init (so printk flushing works), and before boot:31 chan_init.
    printk0("[boot:30.b] tcp_loopback gate\n")
    lb_marker_found: int32 = 0
    lb_idx: uint64 = 0
    lb_count: uint64 = initramfs_entry_count()
    while lb_idx < lb_count:
        lb_name: Ptr[char] = initramfs_entry_name(lb_idx)
        lb_ok: int32 = 1
        lb_target: Ptr[uint8] = "/etc/tcp-loopback-test"
        lb_j: uint64 = 0

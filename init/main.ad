    # scripts/test_devstat_split.sh). devstat_split_selftest() lets the
    # timer ISR accrue ticks to the boot task, then asserts the real
    # three-way jiffie split. Same marker-scan shape as the rusage gate.
    dss_target: Ptr[uint8] = "/etc/devstat-split-test"
    dss_idx: uint64 = 0
    dss_cnt: uint64 = initramfs_entry_count()
    while dss_idx < dss_cnt:
        dss_nm: Ptr[char] = initramfs_entry_name(dss_idx)

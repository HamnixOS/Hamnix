# ext4 mount. See the marker scan in start_kernel and
# wstat_apply_selftest() in sys/src/9/port/sysfile.ad.
g_wstat_apply_test: int32 = 0
# 1 when /etc/statfs-test was found in the cpio, arming the statfs(2)/
# fstatfs(2) capacity self-test (statfs_selftest) after the ext4 mount.
# See the marker scan in start_kernel and statfs_selftest() in
# linux_abi/u_syscalls.ad.
g_statfs_test: int32 = 0
# 1 when /etc/access-mode-test was found in the cpio, arming the
# access(2) mode-bit self-test (access_mode_selftest) after the ext4
# mount. See the marker scan in start_kernel and access_mode_selftest()
# in linux_abi/u_syscalls.ad.
g_access_mode_test: int32 = 0
# 1 when /etc/tmpfs-readlink-test was found in the cpio, arming the
# readlink(2)/readlinkat(2)-on-tmpfs-symlink self-test
# (tmpfs_readlink_selftest). See the marker scan in start_kernel and
# tmpfs_readlink_selftest() in linux_abi/u_syscalls.ad.
g_tmpfs_readlink_test: int32 = 0
# 1 when /etc/rusage-test was found in the cpio, arming the getrusage(2)
# CPU-time self-test (rusage_selftest). See the marker scan in start_kernel
# and rusage_selftest() in linux_abi/u_syscalls.ad.
g_rusage_test: int32 = 0
# 1 when /etc/procstat-cpu-test was found in the cpio, arming the
# /proc/<pid>/stat CPU-time self-test (procstat_cpu_selftest). See the
# marker scan in start_kernel and procstat_cpu_selftest() in

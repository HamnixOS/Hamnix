g_procstat_cpu_test: int32 = 0
# 1 when /etc/procstat-intr-test was found in the cpio, arming the
# /proc/stat per-IRQ-column self-test (procstat_intr_selftest). See the
# marker scan in start_kernel and procstat_intr_selftest() in

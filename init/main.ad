        else:
            tm_idx = tm_idx + 1
    if tm_marker_found == 1:
        printk0("[boot:30.c.a] tcp_maturity_selftest\n")
        tcp_maturity_selftest()
    else:
        printk0("[tcp-mat] skipped (no /etc/tcp-test marker)\n")

    # --- core-dump self-test gate (#173) -----------------------------
    # Gated on /etc/coredump-test (planted by build_initramfs.py when
    # ENABLE_COREDUMP_TEST=1, via scripts/test_coredump.sh). The real
    # end-to-end proof is the user fixture u_coredump, which SIGSEGVs
    # with no handler so the kernel writes /tmp/core, then re-reads it
    # and validates the ELF. This gate only confirms the module LINKED
    # and its fatal-signal predicate is correct, then announces the
    # fixture should run. Default boots skip it.
    printk0("[boot:30.d] coredump gate\n")
    cd_marker_found: int32 = 0
    cd_idx: uint64 = 0
    cd_count: uint64 = initramfs_entry_count()
    while cd_idx < cd_count:
        cd_name: Ptr[char] = initramfs_entry_name(cd_idx)
        cd_ok: int32 = 1
        cd_target: Ptr[uint8] = "/etc/coredump-test"
        cd_j: uint64 = 0
        while cd_j < 19:                            # 18 chars + NUL
            if cast[uint8](cd_name[cd_j]) != cd_target[cd_j]:
                cd_ok = 0
                cd_j = 19                            # break
            else:
                cd_j = cd_j + 1
        if cd_ok == 1:
            cd_marker_found = 1
            cd_idx = cd_count                        # break
        else:
            cd_idx = cd_idx + 1
    if cd_marker_found == 1:
        # Sanity: the fatal-signal table must classify SIGSEGV(11) /
        # SIGABRT(6) as core-dumping and SIGTERM(15) as not.
        cd_a: int32 = coredump_is_fatal_sig(11)
        cd_b: int32 = coredump_is_fatal_sig(6)
        cd_c: int32 = coredump_is_fatal_sig(15)
        if cd_a == 1 and cd_b == 1 and cd_c == 0:
            printk0("[coredump] module linked; fatal-sig table OK\n")
            printk0("[coredump] awaiting u_coredump fixture SIGSEGV\n")
        else:
            printk0("[coredump] FAIL fatal-sig table mismatch\n")
    else:
        printk0("[coredump] skipped (no /etc/coredump-test marker)\n")

    # V2.75: kzalloc the root Pgrp and pin its refcount. Idempotent;
    # safe to call before any task touches bind/mount. The root Pgrp
    # is the default for any task whose pgrp pointer is 0 — chan.ad's
    # _ensure_root resolves the default on first access.
    printk0("[boot:31] chan_init\n")
    chan_init()

    # boot:31.r — ROOT-ON-USB via the real Linux xhci_hcd.ko. When the
    # /etc/xhci-ko-real marker is present, native USB is disabled and the
    # .ko stack must provide /dev/blk/sd0. We do it HERE (not in the early
    # rootfs section) because the .ko's init_module needs per-CPU areas +
    # LAPIC + the linux_abi export table, all of which are now wired. After
    # the .ko registers sd0 we re-run mount_rootfs_partition() so the ext4
    # root behind the stick is discovered + g_rootfs_slot set BEFORE the
    # `#sysroot` bind just below. No-op (and no marker) on every other
    # boot path.
    if installer_medium_marker_found() == 1:
        # In-RAM-squashfs installer medium: no USB root bring-up at all
        # (the medium is ESP-only; payload is in the cpio). Matches the
        # early-boot skip above.
        printk0("[boot:31.r] installer medium: Linux xhci_hcd.ko root-on-USB SKIPPED\n")
    elif xhci_ko_real_marker_found() == 1 and g_rootfs_slot < 0:
        printk0("[boot:31.r] root-on-USB bring-up via Linux xhci_hcd.ko\n")
        # module_api_init/linux_abi_exports_init are idempotent; the
        # boot:33/35 calls below become no-ops. Wire them now so the .ko
        # loader can resolve UND symbols against the export table.
        module_api_init()
        linux_abi_exports_init()
        xreal_dep_rc: int32 = modules_dep_load_with_deps("xhci_pci", 8)
        printk1("[boot:31.r] xhci_pci dep load rc=%d\n",
                cast[uint64](xreal_dep_rc))
        root_rc: int32 = xhci_real_root_init()
        if root_rc == 0:
            printk0("[boot:31.r] .ko sd0 live; rescanning for ext4 root\n")
            g_rootfs_slot = mount_rootfs_partition()
            blk_set_root_slot(g_rootfs_slot)
        else:
            printk0("[boot:31.r] .ko root-on-USB did NOT register sd0 (cpio fallback)\n")
        esp_log_rescan()

    # M16.img: graft the ext4 `sysroot` subtree onto the root lookup
    # name FROM THE KERNEL, so the boot init task's FIRST exec resolves
    # off the partition with no cpio dependency.
    #
    # mount_rootfs_partition() (above, boot:~) parsed `.hamnix-roots`
    # and name_push()ed `#sysroot -> sysroot/`. mnttab_bind freezes
    # `#sysroot` to a stable `#by-id/<partuuid>/sysroot` alias at bind
    # time, so a later `/init` / `/bin/hamsh` / `/etc/rc.boot` lookup
    # rewrites to `/ext/sysroot/<rest>` and lands on ext4 via
    # _open_ext4_read. We run it AFTER chan_init (root Pgrp exists) and
    # BEFORE the /init ELF load below. The boot task's pgrp is 0, which
    # _ensure_root resolves to this same root Pgrp, so the bind is
    # inherited by /init and every child it spawns.
    #
    # On a box with no ext4 partition (the `-kernel` developer test
    # path), g_rootfs_slot == -1 and `#sysroot` was never registered;
    # mnttab_bind would return -1 (dangling named source rejected), so
    # we skip the bind entirely and the cpio fallback in the /init
    # loader keeps that path bootable.
    if g_rootfs_slot >= 0:
        sysroot_src: Array[10, uint8]
        sysroot_src[0] = 35                        # '#'
        sysroot_src[1] = 115                       # 's'
        sysroot_src[2] = 121                       # 'y'
        sysroot_src[3] = 115                       # 's'
        sysroot_src[4] = 114                       # 'r'
        sysroot_src[5] = 111                       # 'o'
        sysroot_src[6] = 111                       # 'o'
        sysroot_src[7] = 116                       # 't'
        sysroot_src[8] = 0
        root_dst: Array[2, uint8]
        root_dst[0] = 47                           # '/'
        root_dst[1] = 0
        # mnttab_bind(new=DST, old=SRC): the named source is `old`.
        bind_rc: int32 = mnttab_bind(&root_dst[0], &sysroot_src[0], 0)
        if bind_rc == 0:
            printk0("[rootfs] kernel bind '#sysroot' / OK (ext4 root active)\n")
        else:
            printk1("[rootfs] kernel bind '#sysroot' / FAILED rc=%d (cpio fallback)\n",
                    cast[uint64](cast[int64](bind_rc)))

    # V1 9P self-test: drive a kernel-side responder over two pipe
    # slots, run mount + walk + open + read end-to-end. Output:
    # `[p9smoke] PASS` on success, `[p9smoke] FAIL: <what>` otherwise.
    # The test allocates two pipe slots (fs/pipe.ad) and stamps a
    # SRV-kind mnttab entry by hand; it doesn't touch user-task fd
    # tables, so it can run before sched_init / create_user_task.
    printk0("[boot:32] p9_smoke_test\n")
    p9_smoke_test()

    # M16.32: bring the module loader API table online and demo-load
    # the hello module so we know the insmod-equivalent path works
    # before any userspace runs.
    printk0("[boot:33] module_api_init\n")
    module_api_init()
    printk0("[boot:34] module_load /kmod_hello\n")
    module_load("/kmod_hello")

    # L1: populate the Linux-ABI symbol table consumed by the
    # stock .ko loader (linux_abi/loader.ad). Idempotent.
    printk0("[boot:35] linux_abi_exports_init\n")
    linux_abi_exports_init()

    # WiFi pivot: cfg80211 + mac80211 are foundational framework
    # modules — every wifi driver depends on them, but neither has
    # a PCI alias so the modprobe auto-loader's class-based match
    # won't pick them up. When /etc/framework-modules is present
    # (planted by build_initramfs.py when ENABLE_FRAMEWORK_MODULES=1)
    # we kmod_linux_load them BEFORE the PCI walk so any wifi driver
    # picked up by modprobe_auto_load can resolve its cfg80211_* /
    # ieee80211_* / mac80211 symbol references against the live shim
    # table populated by api_cfg80211 / api_mac80211 plus the
    # module's own EXPORT_SYMBOLs (once that machinery lands).
    if framework_modules_marker_found() == 1:
        printk0("[boot:35.F] framework modules: cfg80211 + mac80211\n")
        # Initialize the modules.dep registry so the explicit loads
        # below can register themselves and any later modprobe match
        # for a wifi driver that depends on cfg80211/mac80211 sees
        # them as already-loaded.
        modules_dep_init()
        fw_cfg_blob: uint64 = initramfs_data_ptr("/lib/modules/cfg80211.ko")
        fw_cfg_size: uint64 = initramfs_data_size("/lib/modules/cfg80211.ko")
        if fw_cfg_blob == 0:
            printk0("[cfg80211.ko] not in initramfs!\n")
        else:
            printk2("[cfg80211.ko] loading %d bytes from %p\n",
                    fw_cfg_size, fw_cfg_blob)
            fw_cfg_rc: int32 = kmod_linux_load(
                cast[Ptr[uint8]](fw_cfg_blob), fw_cfg_size)
            if fw_cfg_rc < 0:
                printk1("[cfg80211.ko] kmod_linux_load failed: rc=%d\n",
                        cast[uint64](fw_cfg_rc))
            else:
                printk1("[cfg80211.ko] kmod_linux_load OK (slot=%d)\n",
                        cast[uint64](fw_cfg_rc))
                # Register in the dep registry so a later modprobe-
                # dispatched wifi driver doesn't re-load cfg80211.
                modules_dep_mark_loaded("cfg80211", 8)
        fw_mac_blob: uint64 = initramfs_data_ptr("/lib/modules/mac80211.ko")
        fw_mac_size: uint64 = initramfs_data_size("/lib/modules/mac80211.ko")
        if fw_mac_blob == 0:
            printk0("[mac80211.ko] not in initramfs!\n")
        else:
            printk2("[mac80211.ko] loading %d bytes from %p\n",
                    fw_mac_size, fw_mac_blob)
            fw_mac_rc: int32 = kmod_linux_load(
                cast[Ptr[uint8]](fw_mac_blob), fw_mac_size)
            if fw_mac_rc < 0:
                printk1("[mac80211.ko] kmod_linux_load failed: rc=%d\n",
                        cast[uint64](fw_mac_rc))
            else:
                printk1("[mac80211.ko] kmod_linux_load OK (slot=%d)\n",
                        cast[uint64](fw_mac_rc))
                modules_dep_mark_loaded("mac80211", 8)

    # iwlwifi.ko harvest: Intel wireless PCI driver on top of the
    # cfg80211 + mac80211 framework. Gated on /etc/iwlwifi-ko (planted
    # by ENABLE_IWLWIFI_KO=1). The framework-modules block above MUST
    # run first (ENABLE_FRAMEWORK_MODULES=1) to pre-load cfg80211.ko
    # and mac80211.ko; this block then loads iwlwifi.ko itself.
    # Success contract: skipped=0 + init_module returns 0.
    # No real PCIe/firmware/DMA radio bring-up is performed — the
    # 18-entry api_iwlwifi.ad shim batch provides honest no-op stubs
    # that allow init_module to complete. See docs/wifi_known_broken.md.
    if iwlwifi_ko_marker_found() == 1:
        printk0("[boot:35.W] iwlwifi.ko harvest: loading Intel wifi driver\n")
        fw_iwl_blob: uint64 = initramfs_data_ptr("/lib/modules/iwlwifi.ko")
        fw_iwl_size: uint64 = initramfs_data_size("/lib/modules/iwlwifi.ko")
        if fw_iwl_blob == 0:
            printk0("[iwlwifi.ko] not in initramfs!\n")
        else:
            printk2("[iwlwifi.ko] loading %d bytes from %p\n",
                    fw_iwl_size, fw_iwl_blob)
            fw_iwl_rc: int32 = kmod_linux_load(
                cast[Ptr[uint8]](fw_iwl_blob), fw_iwl_size)
            if fw_iwl_rc < 0:
                printk1("[iwlwifi.ko] kmod_linux_load failed: rc=%d\n",
                        cast[uint64](fw_iwl_rc))
            else:
                printk1("[iwlwifi.ko] kmod_linux_load OK (slot=%d)\n",
                        cast[uint64](fw_iwl_rc))
                modules_dep_mark_loaded("iwlwifi", 7)

    # modules.dep test: dispatch mac80211 first and let the dep
    # walker discover cfg80211 as a dependency, recursively loading
    # it before mac80211. Gated on /etc/modulesdep-test (planted by
    # build_initramfs.py when ENABLE_MODULESDEP_TEST=1).
    # scripts/test_loader_modulesdep.sh sets this env var. The
    # framework-modules block above is mutually exclusive with this
    # one — the test script does NOT set ENABLE_FRAMEWORK_MODULES.
    if initramfs_data_ptr("/etc/modulesdep-test") != 0:
        printk0("[boot:35.D] modules.dep test: load mac80211 (deps first)\n")
        md_rc: int32 = modules_dep_load_with_deps("mac80211", 8)
        if md_rc < 0:
            printk1("[boot:35.D] modules_dep_load_with_deps failed: rc=%d\n",
                    cast[uint64](md_rc))
        else:
            printk1("[boot:35.D] modules_dep_load_with_deps OK (rc=%d)\n",
                    cast[uint64](md_rc))

    # libata.ko harvest exercise. When /etc/libata-ko is present
    # (scripts/test_libata_ko.sh sets ENABLE_LIBATA_KO=1) we close the
    # half-finished libata.ko harvest: load the generic Linux ATA/SCSI
    # layer through the L-shim loader and confirm it links + inits.
    #
    # libata.ko's modinfo carries NO `depends:` line in this Debian
    # build, so the modules.dep walker can't auto-pull its real
    # dependency (scsi_mod). We therefore drive an EXPLICIT, ORDERED
    # load: scsi_common.ko -> scsi_mod.ko -> libata.ko. scsi_mod MUST
    # load first so its 152-entry __ksymtab is registered in the loader's
    # cross-module registry; only then do libata.ko's ~23 scsi_* /
    # sdev_* UND symbols resolve cross-module (visible as
    # `[ksymtab_hit] libata -> scsi_mod: <symbol>`) instead of hitting
    # the unresolved-external panic path. This is a LOAD-ONLY harvest —
    # the bar is "relocations skipped=0 + init returned 0", proving the
    # loader + linux_abi shims absorb the generic ATA/SCSI subsystem.
    if libata_ko_marker_found() == 1:
        printk0("[boot:35.LAT] libata.ko harvest: scsi_common -> scsi_mod -> libata\n")
        # 1. scsi_common.ko — tiny SCSI sense/command helper library.
        lat_sc_blob: uint64 = initramfs_data_ptr("/lib/modules/scsi_common.ko")
        lat_sc_size: uint64 = initramfs_data_size("/lib/modules/scsi_common.ko")
        if lat_sc_blob != 0:
            lat_sc_rc: int32 = kmod_linux_load(
                cast[Ptr[uint8]](lat_sc_blob), lat_sc_size)
            printk1("[boot:35.LAT] scsi_common.ko load rc=%d\n",
                    cast[uint64](lat_sc_rc))
        else:
            printk0("[boot:35.LAT] scsi_common.ko NOT FOUND in initramfs\n")
        # 2. scsi_mod.ko — the SCSI mid-layer. Registers the EXPORT_SYMBOL
        #    surface libata depends on.
        lat_sm_blob: uint64 = initramfs_data_ptr("/lib/modules/scsi_mod.ko")
        lat_sm_size: uint64 = initramfs_data_size("/lib/modules/scsi_mod.ko")
        if lat_sm_blob != 0:
            lat_sm_rc: int32 = kmod_linux_load(
                cast[Ptr[uint8]](lat_sm_blob), lat_sm_size)
            printk1("[boot:35.LAT] scsi_mod.ko load rc=%d\n",
                    cast[uint64](lat_sm_rc))
        else:
            printk0("[boot:35.LAT] scsi_mod.ko NOT FOUND in initramfs\n")
        # 3. libata.ko — the harvest target. Its scsi_* UND now resolve
        #    cross-module against scsi_mod's freshly-registered ksymtab.
        lat_la_blob: uint64 = initramfs_data_ptr("/lib/modules/libata.ko")
        lat_la_size: uint64 = initramfs_data_size("/lib/modules/libata.ko")
        if lat_la_blob != 0:
            lat_la_rc: int32 = kmod_linux_load(
                cast[Ptr[uint8]](lat_la_blob), lat_la_size)
            printk1("[boot:35.LAT] libata.ko load rc=%d\n",
                    cast[uint64](lat_la_rc))
            if lat_la_rc >= 0:
                printk0("[boot:35.LAT] libata.ko harvest OK\n")
        else:
            printk0("[boot:35.LAT] libata.ko NOT FOUND in initramfs\n")

    # drm.ko harvest exercise. When /etc/drm-ko is present
    # (scripts/test_drm_ko.sh sets ENABLE_DRM_KO=1) we load the stock
    # Debian drm.ko (the DRM/KMS CORE framework — drm_drv, drm_ioctl,
    # drm_gem, the GEM/PRIME buffer machinery, the atomic-modeset core)
    # through the L-shim loader. This is the last un-probed subsystem
    # class (after e1000e, libata+scsi, ahci, snd_hda, wifi, xhci/ehci).
    #
    # drm.ko's modinfo carries NO `depends:` line — it is the framework
    # everything else builds on — so a single kmod_linux_load suffices.
    # Its 316 UND symbols resolve entirely against the L1..L68 +
    # api_*.ad surface plus the 101 closers in api_drm.ad (and the
    # autostub generator's __x86_indirect_thunk_rsi). This is a
    # LOAD-ONLY harvest: QEMU presents only an emulated VGA (no real
    # GPU), so drm.ko's init_module registers its chrdev/debugfs
    # scaffolding and returns — the bar is "relocations skipped=0 +
    # init_module returns", proving the loader + linux_abi shims absorb
    # the DRM core. Kernel-side autoload (vs. driving insmod over hamsh's
    # serial stdin) is the robust path: it does not race the shell's
    # readline arming.
    if drm_ko_marker_found() == 1:
        printk0("[boot:35.DRM] drm.ko harvest: kmod_linux_load /lib/modules/drm.ko\n")
        drm_blob: uint64 = initramfs_data_ptr("/lib/modules/drm.ko")
        drm_size: uint64 = initramfs_data_size("/lib/modules/drm.ko")
        if drm_blob != 0:
            drm_rc: int32 = kmod_linux_load(
                cast[Ptr[uint8]](drm_blob), drm_size)
            printk1("[boot:35.DRM] drm.ko load rc=%d\n",
                    cast[uint64](drm_rc))
            if drm_rc >= 0:
                printk0("[boot:35.DRM] drm.ko harvest OK\n")
        else:
            printk0("[boot:35.DRM] drm.ko NOT FOUND in initramfs\n")

    # alx.ko harvest exercise. When /etc/alx-ko is present
    # (scripts/test_alx_ko.sh sets ENABLE_ALX_KO=1) we load the stock
    # Debian alx.ko (Qualcomm Atheros AR816x/817x, Killer E2200 family)
    # through the L-shim loader. All 106 UND symbols resolve against
    # L1..L68 + api_e1000e/r8169/igb plus the 4 closers in api_alx.ad
    # (dev_kfree_skb_any_reason, mdio_mii_ioctl, pcie_get_readrq,
    # pci_ioremap_bar). This is a LOAD-ONLY harvest: QEMU presents no
    # matching Atheros PCI id, so __pci_register_driver walks the bus
    # and finds no device — the bar is "relocations skipped<=1 + init
    # returned 0", proving the loader + linux_abi shims absorb the alx
    # MAC driver. Kernel-side autoload here (rather than driving insmod
    # over hamsh's serial stdin) is robust: it does not race the shell's
    # readline arming, which silently dropped the early insmod line.
    if alx_ko_marker_found() == 1:
        printk0("[boot:35.ALX] alx.ko harvest: kmod_linux_load /lib/modules/alx.ko\n")
        alx_blob: uint64 = initramfs_data_ptr("/lib/modules/alx.ko")
        alx_size: uint64 = initramfs_data_size("/lib/modules/alx.ko")
        if alx_blob == 0:
            printk0("[boot:35.ALX] alx.ko NOT FOUND in initramfs\n")
        else:
            printk2("[alx.ko] loading %d bytes from %p\n",
                    alx_size, alx_blob)
            alx_rc: int32 = kmod_linux_load(
                cast[Ptr[uint8]](alx_blob), alx_size)
            if alx_rc < 0:
                printk1("[alx.ko] kmod_linux_load failed: rc=%d\n",
                        cast[uint64](alx_rc))
            else:
                printk1("[alx.ko] kmod_linux_load OK (slot=%d)\n",
                        cast[uint64](alx_rc))
                printk0("[boot:35.ALX] alx.ko harvest OK\n")

    # Storage L-shim exercise path. When /etc/ahci-ko is present
    # (scripts/test_ahci_io.sh sets ENABLE_AHCI_KO=1), the hand-rolled
    # drivers/ata/ahci.ad smoke-test was skipped above, leaving the
    # AHCI controller for Linux's stock ahci.ko to claim. We drive
    # the load via modules_dep_load_with_deps so the full Debian
    # 6.1.0-32 modules.dep chain pulls in scsi_common -> scsi_mod
    # -> libata -> libahci BEFORE ahci.ko's init_module runs. The
    # loader's cross-module ksymtab fallback (loader-unify commit
    # deb21cc) then resolves ahci.ko's ata_*/sata_*/ahci_* UND
    # symbols to libata/libahci's REAL EXPORT_SYMBOL implementations
    # rather than the api_ahci.ad stubs — full Linux SCSI/SATA stack
    # in the loader, not just a single-driver insmod.
    if ahci_ko_marker_found() == 1:
        printk0("[boot:35.A] modules_dep_load_with_deps(\"ahci\")\n")
        ahci_dep_rc: int32 = modules_dep_load_with_deps("ahci", 4)
        if ahci_dep_rc < 0:
            printk1("[ahci.ko] modules_dep_load_with_deps failed: rc=%d\n",
                    cast[uint64](ahci_dep_rc))
            # Fallback to legacy single-module path so the existing
            # test_ahci_io.sh marker assertion still holds.
            printk0("[boot:35.A] kmod_linux_load /lib/modules/6.12/ahci.ko\n")
            ahci_ko_blob: uint64 = initramfs_data_ptr(
                "/lib/modules/6.12/ahci.ko")
            ahci_ko_size: uint64 = initramfs_data_size(
                "/lib/modules/6.12/ahci.ko")
            if ahci_ko_blob != 0:
                ahci_ko_rc: int32 = kmod_linux_load(
                    cast[Ptr[uint8]](ahci_ko_blob), ahci_ko_size)
                if ahci_ko_rc < 0:
                    printk1("[ahci.ko] kmod_linux_load failed: rc=%d\n",
                            cast[uint64](ahci_ko_rc))
                else:
                    printk1("[ahci.ko] kmod_linux_load OK (slot=%d)\n",
                            cast[uint64](ahci_ko_rc))
        else:
            printk1("[ahci.ko] modules_dep_load_with_deps OK (rc=%d)\n",
                    cast[uint64](ahci_dep_rc))
            printk0("[boot:35.A] kmod_linux_load /lib/modules/6.12/ahci.ko\n")
        # M16.x: L-shim add_disk completion. The libata/libahci/scsi_mod
        # stack is loaded and ahci.ko's probe ran — but real libata's
        # SCSI scan stops at "no device" because our sata_link_hardreset
        # shim can't drive a real SATA PHY reset, so no add_disk ever
        # fires through the Linux flow. Bridge through the L-shim's
        # add_disk path: probe the HBA, synthesise a Hamnix-shape
        # gendisk, hand it to _l_add_disk via api_ahci.ad. The result
        # is "sda" registered through the gendisk-→-BlockDeviceOps
        # wrapper in api_block.ad — bridge=disabled, no fallback to
        # the hand-rolled ahci_smoke_test path.
        linux_abi_finish_ahci_add_disk()
        # Run the exercise regardless of load rc — when the shim's
        # ahci_host_activate fires it may register a blockdev even
        # if the loader reports a non-zero rc on some other path.
        ahci_io_exercise()

    # Storage L-shim exercise path for NVMe. When /etc/nvme-io-ko is
    # present (scripts/test_nvme_io.sh sets ENABLE_NVME_IO_TEST=1), the
    # hand-rolled drivers/nvme/nvme.ad smoke-test was skipped above so
    # nvme.ko owns the controller end to end. We load it here and then
    # run nvme_io_exercise() against whatever block device the .ko-shim
    # path produces. NO BRIDGE: unlike the AHCI exercise above, there
    # is no hand-rolled completion at the libata-equivalent point —
    # if nvme.ko + the L-shim can't carry I/O, the test reports the
    # specific gap rather than papering over it.
    if nvme_io_ko_marker_found() == 1:
        printk0("[boot:35.N] modules_dep_load_with_deps nvme (depends: nvme-core)\n")
        # Use the dep-aware loader so nvme-core.ko loads BEFORE nvme.ko.
        # Once nvme-core's __ksymtab is registered, nvme.ko's RELA
        # tables resolve nvme_* / __SCK_* / __SCT_* / tracepoint
        # relocations against nvme-core's real EXPORT_SYMBOL impls
        # (visible as `[ksymtab_hit] nvme -> nvme_core: <symbol>`)
        # rather than api_nvme.ad's -ENODEV cold-path stubs. This
        # is what makes nvme_submit_sync_cmd real instead of returning
        # the -19 sentinel.
        nvme_md_rc: int32 = modules_dep_load_with_deps("nvme", 4)
        if nvme_md_rc < 0:
            printk1("[boot:35.N] modules_dep_load_with_deps(nvme) failed: rc=%d\n",
                    cast[uint64](nvme_md_rc))
            # Fall back to direct kmod_linux_load of just nvme.ko —
            # the api_nvme.ad cold-path stubs still let it init.
            nvme_ko_blob: uint64 = initramfs_data_ptr(
                "/lib/modules/6.12/nvme.ko")
            nvme_ko_size: uint64 = initramfs_data_size(
                "/lib/modules/6.12/nvme.ko")
            if nvme_ko_blob != 0:
                nvme_ko_rc: int32 = kmod_linux_load(
                    cast[Ptr[uint8]](nvme_ko_blob), nvme_ko_size)
                if nvme_ko_rc < 0:
                    printk1("[nvme.ko] fallback kmod_linux_load failed: rc=%d\n",
                            cast[uint64](nvme_ko_rc))
                else:
                    printk1("[nvme.ko] fallback kmod_linux_load OK (slot=%d)\n",
                            cast[uint64](nvme_ko_rc))
        else:
            printk1("[boot:35.N] modules_dep_load_with_deps(nvme) OK (rc=%d)\n",
                    cast[uint64](nvme_md_rc))
        # Option X L-shim add_disk completion. The nvme.ko + nvme-core.ko
        # stack is loaded and nvme.ko's probe ran — but probe returns
        # -EINVAL early (well before reset_work queues), and even if
        # probe DID succeed, nvme_reset_work is queued on nvme_wq which
        # has no kthread servicing it (flush_work is a no-op stub). So
        # nvme-core's reset -> identify -> scan -> add_disk chain never
        # reaches add_disk. Bridge through the L-shim's finish path:
        # the same hand-rolled drivers/nvme/nvme.ad helpers that the
        # default boot path uses drive CC.EN + IDENTIFY + create I/O
        # queues + register_blockdev("nvme0n1", ...) here, AFTER the
        # .ko stack has been given its chance. Mirror of the AHCI
        # linux_abi_finish_ahci_add_disk() invocation above.
        linux_abi_finish_nvme_add_disk()
        # Run the exercise regardless of load rc — same rationale as
        # ahci_io_exercise: a partial-success shim path may still have
        # registered a blockdev before its init bailed.
        nvme_io_exercise()

    # USB host-controller class L-shim exercise path. When /etc/xhci-ko
    # is present (scripts/test_xhci_io.sh sets ENABLE_XHCI_KO=1), the
    # hand-rolled drivers/usb/xhci.ad + drivers/usb/ehci.ad init paths
    # were skipped at boot:01/02 above, leaving the USB host controller
    # MMIO untouched for Linux's stock usbcore + xhci_hcd + xhci_pci
    # dep chain to claim. We drive the load via
    # modules_dep_load_with_deps so the modules.dep walker pulls in
    # xhci-hcd + usbcore before xhci_pci's init_module runs. The
    # loader's cross-module ksymtab fallback then resolves xhci_pci's
    # usb_add_hcd / usb_create_shared_hcd / xhci_gen_setup UND symbols
    # to usbcore's / xhci-hcd's REAL EXPORT_SYMBOL implementations
    # rather than the api_usbcore.ad / api_xhci.ad cold-path stubs —
    # full Linux USB stack in the loader, not just a single-driver
    # insmod. This is the USB-class parallel of boot:35.A (storage)
    # and the unconditional e1000e.ko load at boot:35.a (NIC).
    if xhci_ko_marker_found() == 1:
        # Bare-metal re-investigation (post-preemption, commit b08853e).
        # The c444044 skip was a defensive workaround applied earlier the
        # same day as the kernel_cond_resched landing — the NUC freeze
        # that motivated it was originally attributed to a USBSTS HCH-
        # clear MMIO stall inside xhci_pci.ko's probe, but on close
        # re-reading of the load chain that attribution is wrong:
        #
        #   * xhci_pci.ko's init_module body is just `call
        #     __pci_register_driver` — no MMIO.
        #   * xhci_hcd.ko's init_module body sets up debugfs roots — no
        #     MMIO.
        #   * usbcore.ko's init_module registers sysfs hooks — no MMIO.
        #   * __pci_register_driver -> _l_pci_walk_and_match in our shim
        #     explicitly SKIPS calling drv->probe for USB host-controller
        #     class (base_class==0x0C, subclass==0x03, api_pci.ad:970-986)
        #     because a populated struct hc_driver shim isn't in place yet.
        #
        # So nothing in this chain touches the USBSTS register. The actual
        # NUC freeze the c444044 commit cited ("NUC freeze after sshd was
        # reproducing exactly the historical hand-rolled symptom") was the
        # tcp_accept syscall wedge that b08853e fixed two hours later —
        # not an xhci-side stall. Re-enable the load on bare metal; if a
        # future milestone wires the USB-HC probe to actually invoke
        # xhci_pci_probe -> usb_hcd_pci_probe -> xhci_handshake (which
        # DOES busy-poll USBSTS on real silicon), the static-call thunk
        # __SCT__cond_resched and __const_udelay shims in api_l57 /
        # api_l63 now route to kernel_cond_resched so that future path
        # cooperates with preemption instead of pinning the CPU.
        #
        # The drivers/usb/xhci.ad hand-rolled bringup (commit 71961b3)
        # still keeps its own bare-metal guard — that path genuinely
        # touches MMIO at _xhci_v1_bringup and the wedge there is real
        # (HCRST poll spinning on USBCMD.HCRST clearing). That guard is
        # orthogonal to this .ko load decision.
        printk0("[boot:35.X] modules_dep_load_with_deps(\"xhci_pci\")\n")
        xhci_dep_rc: int32 = modules_dep_load_with_deps("xhci_pci", 8)
        if xhci_dep_rc < 0:
            printk1("[xhci_pci.ko] modules_dep_load_with_deps failed: rc=%d\n",
                    cast[uint64](xhci_dep_rc))
        else:
            printk1("[xhci_pci.ko] modules_dep_load_with_deps OK (rc=%d)\n",
                    cast[uint64](xhci_dep_rc))

        # HID-class .ko load chain: usbhid depends on (usbcore, hid).
        # usbcore was already loaded by the xhci_pci dep walk above, so
        # modules_dep_load_with_deps("usbhid") just pulls in hid before
        # firing usbhid's init_module. The .ko's MODULE_DEVICE_TABLE
        # alias `usb:v*p*d*dc*dsc*dp*ic03isc*ip*in*` matches any USB
        # device with interface class 0x03; with -device usb-kbd on
        # the xhci bus, usbhid claims it during init.
        #
        # This is the "HID class probe — the remaining bridge to turn
        # the controller-attached keyboard into kbd_rx_push events"
        # named in the USB hc_driver agent's handoff. usbhid's URB
        # pipeline through the shim is stubbed (see
        # linux_abi/api_usbhid.ad header), so the .ko loads but doesn't
        # actually own the live data path — that remains
        # drivers/usb/xhci.ad::xhci_poll → hid_kbd_report → kbd_rx_push.
        # The .ko load is a Linux-ABI coverage probe that surfaces any
        # remaining shim gap and proves the dep chain resolves.
        printk0("[boot:35.X.h] modules_dep_load_with_deps(\"usbhid\")\n")
        usbhid_dep_rc: int32 = modules_dep_load_with_deps("usbhid", 6)
        if usbhid_dep_rc < 0:
            printk1("[usbhid.ko] modules_dep_load_with_deps failed: rc=%d\n",
                    cast[uint64](usbhid_dep_rc))
        else:
            printk1("[usbhid.ko] modules_dep_load_with_deps OK (rc=%d)\n",
                    cast[uint64](usbhid_dep_rc))

        # Run the exercise unconditionally — the L-shim USB path may
        # have made progress (root hub published, ksymtab fallbacks
        # fired) even on a non-zero rc from the dep walker.
        xhci_io_exercise()

        # REAL Linux .ko bring-up (opt-in /etc/xhci-ko-real). Native is
        # disabled (the usb_hcd_pci_probe bridge above is suppressed in
        # this mode). Now that usbcore.ko + xhci_hcd.ko have loaded and
        # their EXPORT_SYMBOL ksymtab is populated, resolve the genuine
        # xhci_init_driver / xhci_run / xhci_gen_setup functions and let
        # the stock Linux driver itself touch the controller registers.
        if xhci_ko_real_marker_found() == 1:
            printk0("[boot:35.X.r] real Linux .ko xHCI bring-up\n")
            xhci_real_exercise()

    # Linux-shape modprobe auto-loader. When /etc/auto-modules is
    # present in the initramfs (planted by build_initramfs.py when
    # ENABLE_AUTO_MODULES=1), walk the PCI bus and load any .ko in
    # /lib/modules/auto/ that matches a baked /lib/modules/modules.alias
    # entry. Default boots skip the marker so the e1000e.ko hard-coded
    # boot:35.a path below is the single source of NIC bring-up.
    if auto_modules_marker_found() == 1:
        printk0("[boot:35.M] modprobe auto-load\n")
        n_auto: uint64 = modprobe_auto_load()
        printk1("[boot:35.M] modprobe auto-load: %d modules loaded\n",
                n_auto)

    # Unconditional e1000e.ko load. The hand-rolled
    # drivers/net/e1000e.ad has been retired; Linux's stock e1000e.ko
    # is now the only path that drives Intel Gigabit silicon. The .ko
    # bytes are baked into the initramfs at /lib/modules/e1000e.ko by
    # scripts/build_initramfs.py. On boards without an e1000e device
    # on the bus this is a no-op (the .ko's probe doesn't fire);
    # the kmod_linux_load itself is cheap (~668 KiB load + relocs +
    # init_module) and always runs.
    printk0("[boot:35.a] kmod_linux_load /lib/modules/e1000e.ko\n")
    ko_blob: uint64 = initramfs_data_ptr("/lib/modules/e1000e.ko")
    ko_size: uint64 = initramfs_data_size("/lib/modules/e1000e.ko")
    if ko_blob == 0:
        printk0("[e1000e.ko] /lib/modules/e1000e.ko not in initramfs!\n")
    else:
        printk2("[e1000e.ko] loading %d bytes from %p\n", ko_size, ko_blob)
        ko_rc: int32 = kmod_linux_load(
            cast[Ptr[uint8]](ko_blob), ko_size)
        if ko_rc < 0:
            printk1("[e1000e.ko] kmod_linux_load failed: rc=%d\n",
                    cast[uint64](ko_rc))
        else:
            printk1("[e1000e.ko] kmod_linux_load OK (slot=%d)\n",
                    cast[uint64](ko_rc))
            # boot:35.b — drive DHCP through the freshly-bound Linux
            # netdev ONLY if e1000e_probe actually claimed a device on
            # the PCI bus (i.e. the box has an e1000e NIC). On a
            # virtio-net-only QEMU run the .ko loads cleanly but no
            # netdev gets registered, so we skip the DHCP block and
            # leave net_smoke_test's virtio-net DHCP result intact.
            #
            # When the .ko did bind: bring the L3 stack online, send
            # DHCP DISCOVER, and spin with IRQs enabled. MSI ->
            # trampoline -> e1000_intr -> __napi_schedule -> napi->poll
            # (sync) -> napi_gro_receive -> eth_rx delivers the OFFER /
            # ACK frames into the DHCP state machine.
            #
            # IRQs are enabled JUST for the DHCP window because most
            # of the rest of boot still runs IF-masked (cooperative
            # kernel; preemption happens later when sched_init wires
            # the LAPIC timer into the scheduler).
            if netdev_first_registered() != 0:
                printk0("[boot:35.b] DHCP via e1000e.ko\n")
                # Force TCTL.EN — Linux's e1000_watchdog_task normally
                # OR's this bit when LSC asserts link-up, but we have
                # no workqueue scheduler wired up to run delayed_work.
                # Without TCTL.EN, QEMU's e1000e_start_xmit returns
                # early and the descriptor never DMAs onto the wire.
                e1000e_ko_force_tx_enable()
                ip_init()
                udp_init()
                icmp_init()
                dhcp_init()
                # Send DHCP DISCOVER through the Linux driver's
                # ndo_start_xmit. The TX path goes:
                #   dhcp_discover() -> udp_send -> ip_send ->
                #   eth_tx -> eth_tx_hook (== _l_linux_tx_bridge)
                #   -> ndo_start_xmit (e1000_xmit_frame in the .ko)
                dhcp_discover()

                # Poll for the DHCP exchange to complete. IRQs must
                # be enabled for the MSI vector 0x47 to actually fire
                # and for the driver's __napi_schedule path to run.
                # Budget ~30 s wall-clock on a 3 GHz CPU (SLIRP
                # answers in microseconds; the headroom is for real
                # hardware / slow CI).
                local_irq_enable()
                ko_spin: uint64 = 0
                ko_max:  uint64 = 200000000
                while ko_spin < ko_max:
                    if dhcp_state_get() == 3:   # DHCP_STATE_BOUND
                        ko_spin = ko_max        # short-circuit out
                    else:
                        cpu_relax()
                    ko_spin = ko_spin + 1
                # boot:35.c — proof-of-concept traffic exercise. Gated
                # on /etc/e1000e-traffic-test (planted by
                # ENABLE_E1000E_TRAFFIC_TEST=1) so default boots stay
                # single-purpose. Runs WITH IRQs still enabled so the
                # MSI vector 0x47 keeps firing for RX completion +
                # __napi_schedule. Validates ICMP ping, DNS UDP, and
                # TX/RX ring wraparound past the 256-descriptor mark —
                # the regular-traffic surface that DHCP's ~4 packets
                # don't exercise. See drivers/net/e1000e_traffic.ad.
                if dhcp_state_get() == 3:
                    if e1000e_traffic_marker_found() == 1:
                        printk0("[boot:35.c] e1000e.ko traffic exercise (PHASE A/B/C)\n")
                        e1000e_traffic_smoke_test()
                local_irq_disable()
                if dhcp_state_get() != 3:
                    printk0("[dhcp] no ACK received during e1000e.ko poll\n")
            else:
                printk0("[boot:35.b] no e1000e netdev bound; DHCP skipped\n")

    # --- M16.30: load /init from cpio via the ELF loader ----------
    # exec() into a real userspace binary instead of the baked-in
    # user_demo_entry. The ELF lives in the cpio archive (embedded
    # at build time by scripts/build_initramfs.py); fs/elf.ad walks
    # its PT_LOAD segments and returns the live entry address.
    printk0("[boot:36] /init ELF lookup + load\n")
    # M16.img: resolve /init through the boot namespace. With the
    # kernel `bind '#sysroot' /` above in place, ns_blob_ptr("/init")
    # rewrites to `#by-id/<partuuid>/sysroot/init` and slurps the ELF
    # off ext4 into a kmalloc'd buffer — the cpio-less installed-disk
    # path. ns_blob_ptr ALSO returns the cpio entry directly when the
    # name resolves there (the `-kernel` developer fallback with no
    # ext4 partition), so this single call covers both worlds. The
    # cache inside ns_blob_load keeps the paired _ptr/_size lookups to
    # one read.
    init_blob: uint64 = ns_blob_ptr("/init")
    init_size: uint64 = ns_blob_size("/init")
    if init_blob == 0:
        printk0("Hamnix: /init not in namespace; falling back to baked entry\n")
        init_entry: uint64 = cast[uint64](&user_demo_entry)
    else:
        printk2("Hamnix: ELF-loading /init (%d bytes from %p)\n",
                init_size, init_blob)
        init_entry: uint64 = elf_load_blob(
            cast[Ptr[uint8]](init_blob), init_size)
        if init_entry == 0:
            printk0("Hamnix: /init load failed; falling back\n")
            init_entry = cast[uint64](&user_demo_entry)
        else:
            printk1("Hamnix: /init entry @ %p\n", init_entry)

    printk0("[boot:37] sched_init\n")
    sched_init()
    # SMP: now that sched_init() has reset the PID counter, create idle
    # kthreads for every AP that came online during boot:15.  Each idle
    # kthread is parked STATE_FREE until the AP reads ap_idle_slots[]
    # (it is spin-waiting with cpu_relax).  We allocate one slot per AP
    # (CPU ids 1..cpus_online-1); the BSP (CPU 0) has no idle kthread.
    cpus_alive: uint64 = get_cpus_online()
    ap_boot_idx: uint64 = 1
    while ap_boot_idx < cpus_alive:
        sched_prepare_ap_idle(ap_boot_idx)
        ap_boot_idx = ap_boot_idx + 1

    # SMP kthread churn soak: gated on /etc/smp-soak cpio marker planted
    # by build_initramfs.py when ENABLE_SMP_SOAK=1.  Runs after APs are
    # wired into the scheduler (sched_prepare_ap_idle done) so each soak
    # kthread can be picked up by the AP idle loop.  Interrupts are
    # enabled inside smp_kthread_soak_run() so the BSP's LAPIC timer ISR
    # fires and races schedule() against the AP idle loop — the exact
    # contention scenario we are stress-testing.  Disabled again before
    # returning to the normal boot path.
    printk0("[boot:37.smp_soak] checking /etc/smp-soak marker\n")
    soak_marker_found: int32 = 0
    sk_idx: uint64 = 0
    sk_count: uint64 = initramfs_entry_count()
    while sk_idx < sk_count:
        sk_name: Ptr[char] = initramfs_entry_name(sk_idx)
        # Compare byte-by-byte with "/etc/smp-soak\0" (14 bytes inc NUL).
        sk_ok: int32 = 1
        sk_tgt: Ptr[uint8] = "/etc/smp-soak"
        sk_j: uint64 = 0
        while sk_j < 14:
            if cast[uint8](sk_name[sk_j]) != sk_tgt[sk_j]:
                sk_ok = 0
                sk_j = 14
            else:
                sk_j = sk_j + 1
        if sk_ok == 1:
            soak_marker_found = 1
            sk_idx = sk_count
        else:
            sk_idx = sk_idx + 1
    if soak_marker_found == 1:
        printk0("[boot:37.smp_soak] /etc/smp-soak found — running SMP soak\n")
        # Enable BSP interrupts so the LAPIC timer fires during the soak,
        # racing the AP idle loop on rq_lock.  The soak prints its own
        # PASS/FAIL; we re-disable IRQs below to match the invariant the
        # rest of boot:37..42 expects (syscall_init / tss_init run with
        # interrupts off).
        asm_volatile("sti")
        smp_kthread_soak_run()
        asm_volatile("cli")
        # Emit the final cpus_online as a sanity check that the AP is
        # still online after the soak.
        printk1("[smp_soak] post-soak cpus_online = %d\n",
                get_cpus_online())
    else:
        printk0("[smp_soak] skipped (no /etc/smp-soak marker)\n")

    # #151: CFS-lite + SMP load-balance self-test, gated on /etc/sched-fair
    # (planted by build_initramfs.py when ENABLE_SCHED_FAIR=1). Same shape
    # as the smp-soak gate: runs on the BSP boot task after APs are wired
    # into the scheduler, with interrupts enabled so the AP idle loop can
    # work-steal the CPU-bound workers. Prints its own PASS/FAIL/NOTE.
    printk0("[boot:37.sched_fair] checking /etc/sched-fair marker\n")
    sf_marker_found: int32 = 0
    sf_idx: uint64 = 0
    sf_count: uint64 = initramfs_entry_count()
    while sf_idx < sf_count:
        sf_name: Ptr[char] = initramfs_entry_name(sf_idx)
        # Compare byte-by-byte with "/etc/sched-fair\0" (16 bytes inc NUL).
        sf_ok: int32 = 1
        sf_tgt: Ptr[uint8] = "/etc/sched-fair"
        sf_j: uint64 = 0
        while sf_j < 16:
            if cast[uint8](sf_name[sf_j]) != sf_tgt[sf_j]:
                sf_ok = 0
                sf_j = 16
            else:
                sf_j = sf_j + 1
        if sf_ok == 1:
            sf_marker_found = 1
            sf_idx = sf_count
        else:
            sf_idx = sf_idx + 1
    if sf_marker_found == 1:
        printk0("[boot:37.sched_fair] /etc/sched-fair found — running self-test\n")
        asm_volatile("sti")
        sched_fair_smp_selftest()
        asm_volatile("cli")
        printk1("[sched_fair] post-test cpus_online = %d\n",
                get_cpus_online())
    else:
        printk0("[sched_fair] skipped (no /etc/sched-fair marker)\n")

    # GPU track #181 Phase 0: native Vulkan-shaped software-rasterizer
    # spine. Gated on /etc/vk-test (planted by build_initramfs.py when
    # ENABLE_VK_TEST=1, via scripts/test_vk_software_raster.sh). Same
    # marker-scan shape as the sched_fair gate above: drives the whole
    # native Vulkan-shaped API (instance/device/queue/memory/buffer/
    # image/command-buffer/submit/present) through the software
    # rasterizer to render a depth-tested two-triangle scene, asserts
    # known pixel values + a checksum, and presents to /dev/fb. Prints
    # its own [vk] PASS/FAIL lines. Default boots omit the marker.
    printk0("[boot:37.vk] checking /etc/vk-test marker\n")
    vk_marker_found: int32 = 0
    vk_idx: uint64 = 0
    vk_count: uint64 = initramfs_entry_count()
    while vk_idx < vk_count:
        vk_name: Ptr[char] = initramfs_entry_name(vk_idx)
        # Compare byte-by-byte with "/etc/vk-test\0" (13 bytes inc NUL).
        vk_ok: int32 = 1
        vk_tgt: Ptr[uint8] = "/etc/vk-test"
        vk_j: uint64 = 0
        while vk_j < 13:
            if cast[uint8](vk_name[vk_j]) != vk_tgt[vk_j]:
                vk_ok = 0
                vk_j = 13
            else:
                vk_j = vk_j + 1
        if vk_ok == 1:
            vk_marker_found = 1
            vk_idx = vk_count
        else:
            vk_idx = vk_idx + 1
    if vk_marker_found == 1:
        printk0("[boot:37.vk] /etc/vk-test found — running spine self-test\n")
        vk_rc: int32 = vk_software_raster_selftest()
        if vk_rc == 1:
            printk0("[vk] PASS: Phase-0 spine self-test complete\n")
        else:
            printk0("[vk] FAIL: Phase-0 spine self-test failed\n")
    else:
        printk0("[vk] skipped (no /etc/vk-test marker)\n")

    # [boot:37.pnt] /proc/net/{tcp,udp,arp,route,dev} renderer self-test.
    # Gated on /etc/procnet-test (planted by build_initramfs.py when
    # ENABLE_PROCNET_TEST=1, via scripts/test_procnet.sh). Renders each
    # /proc/net node and asserts the Linux-format header lines.
    printk0("[boot:37.pnt] checking /etc/procnet-test marker\n")
    pnt_marker_found: int32 = 0
    pnt_idx: uint64 = 0
    pnt_count: uint64 = initramfs_entry_count()
    while pnt_idx < pnt_count:
        pnt_name: Ptr[char] = initramfs_entry_name(pnt_idx)
        # Compare byte-by-byte with "/etc/procnet-test\0" (18 bytes inc NUL).
        pnt_ok: int32 = 1
        pnt_tgt: Ptr[uint8] = "/etc/procnet-test"
        pnt_j: uint64 = 0
        while pnt_j < 18:
            if cast[uint8](pnt_name[pnt_j]) != pnt_tgt[pnt_j]:
                pnt_ok = 0
                pnt_j = 18
            else:
                pnt_j = pnt_j + 1
        if pnt_ok == 1:
            pnt_marker_found = 1
            pnt_idx = pnt_count
        else:
            pnt_idx = pnt_idx + 1
    if pnt_marker_found == 1:
        printk0("[boot:37.pnt] /etc/procnet-test found — running self-test\n")
        procnet_selftest()
    else:
        printk0("[procnet] skipped (no /etc/procnet-test marker)\n")

    # [boot:37.ipc] System V IPC (sem/msg/shm) self-test. Gated on
    # /etc/sysvipc-test (planted by build_initramfs.py when
    # ENABLE_SYSVIPC_TEST=1, via scripts/test_u52_sysvipc.sh). Exercises
    # semget/semop/semctl, msgget/msgsnd/msgrcv/msgctl, shmget/shmat/
    # shmdt/shmctl and prints "[sysvipc] PASS" on success.
    printk0("[boot:37.ipc] checking /etc/sysvipc-test marker\n")
    ipc_marker_found: int32 = 0
    ipc_idx: uint64 = 0
    ipc_count: uint64 = initramfs_entry_count()
    while ipc_idx < ipc_count:
        ipc_name: Ptr[char] = initramfs_entry_name(ipc_idx)
        # Compare byte-by-byte with "/etc/sysvipc-test\0" (18 bytes inc NUL).
        ipc_ok: int32 = 1
        ipc_tgt: Ptr[uint8] = "/etc/sysvipc-test"
        ipc_j: uint64 = 0
        while ipc_j < 18:
            if cast[uint8](ipc_name[ipc_j]) != ipc_tgt[ipc_j]:
                ipc_ok = 0
                ipc_j = 18
            else:
                ipc_j = ipc_j + 1
        if ipc_ok == 1:
            ipc_marker_found = 1
            ipc_idx = ipc_count
        else:
            ipc_idx = ipc_idx + 1
    if ipc_marker_found == 1:
        printk0("[boot:37.ipc] /etc/sysvipc-test found — running self-test\n")
        sysvipc_selftest()
    else:
        printk0("[sysvipc] skipped (no /etc/sysvipc-test marker)\n")

    # [boot:37.mq] POSIX message queues (mq_*) self-test. Gated on
    # /etc/mqueue-test (planted by build_initramfs.py when
    # ENABLE_MQUEUE_TEST=1). Exercises mq_open/mq_send/mq_receive with
    # priority-ordered delivery, EMSGSIZE / EAGAIN / mq_getattr / mq_unlink
    # and prints "[mqueue] PASS" on success.
    printk0("[boot:37.mq] checking /etc/mqueue-test marker\n")
    mqt_marker_found: int32 = 0
    mqt_idx: uint64 = 0
    mqt_count: uint64 = initramfs_entry_count()
    while mqt_idx < mqt_count:
        mqt_name: Ptr[char] = initramfs_entry_name(mqt_idx)
        # Compare byte-by-byte with "/etc/mqueue-test\0" (17 bytes inc NUL).
        mqt_ok: int32 = 1
        mqt_tgt: Ptr[uint8] = "/etc/mqueue-test"
        mqt_j: uint64 = 0
        while mqt_j < 17:
            if cast[uint8](mqt_name[mqt_j]) != mqt_tgt[mqt_j]:
                mqt_ok = 0
                mqt_j = 17
            else:
                mqt_j = mqt_j + 1
        if mqt_ok == 1:
            mqt_marker_found = 1
            mqt_idx = mqt_count
        else:
            mqt_idx = mqt_idx + 1
    if mqt_marker_found == 1:
        printk0("[boot:37.mq] /etc/mqueue-test found — running self-test\n")
        posixmq_selftest()
    else:
        printk0("[mqueue] skipped (no /etc/mqueue-test marker)\n")

    # [boot:37.afunix] AF_UNIX (local) domain socket self-test. Gated on
    # /etc/afunix-test (planted by build_initramfs.py when
    # ENABLE_AFUNIX_TEST=1). Exercises socketpair round-trip (both
    # directions), bound-name STREAM listen/connect/accept + byte
    # exchange, abstract-namespace bind/connect, ECONNREFUSED with no
    # listener, EADDRINUSE on double bind, and SOCK_DGRAM by-name
    # delivery; prints "[afunix] PASS" on success.
    printk0("[boot:37.afunix] checking /etc/afunix-test marker\n")
    afu_marker_found: int32 = 0
    afu_idx: uint64 = 0
    afu_count: uint64 = initramfs_entry_count()
    while afu_idx < afu_count:
        afu_name_p: Ptr[char] = initramfs_entry_name(afu_idx)
        # Compare byte-by-byte with "/etc/afunix-test\0" (17 bytes inc NUL).
        afu_ok: int32 = 1
        afu_tgt: Ptr[uint8] = "/etc/afunix-test"
        afu_j: uint64 = 0
        while afu_j < 17:
            if cast[uint8](afu_name_p[afu_j]) != afu_tgt[afu_j]:
                afu_ok = 0
                afu_j = 17
            else:
                afu_j = afu_j + 1
        if afu_ok == 1:
            afu_marker_found = 1
            afu_idx = afu_count
        else:
            afu_idx = afu_idx + 1
    if afu_marker_found == 1:
        printk0("[boot:37.afunix] /etc/afunix-test found — running self-test\n")
        afunix_selftest()
    else:
        printk0("[afunix] skipped (no /etc/afunix-test marker)\n")


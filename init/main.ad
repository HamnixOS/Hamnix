g_procstat_intr_test: int32 = 0
# 1 when /etc/vxlan-test was found in the cpio, arming the native VXLAN
# (RFC 7348) encap/decap self-test (vxlan_selftest, drivers/net/vxlan.ad).
# See the boot:37.vxlan marker scan in start_kernel.
g_vxlan_test: int32 = 0
# 1 when /etc/igmp-test was found in the cpio, arming the native IPv4
# multicast + IGMPv2/v3 (RFC 2236 / RFC 3376) self-test (igmp_selftest,
# drivers/net/igmp.ad). See the boot:37.igmp marker scan in start_kernel.
g_igmp_test: int32 = 0
# 1 when /etc/gre-test was found in the cpio, arming the native GRE
# (RFC 2784) encap/decap self-test (gre_selftest, drivers/net/gre.ad).

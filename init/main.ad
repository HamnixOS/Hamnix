        tcp_loopback_smoke_test()
    else:
        printk0("[tcp-loopback] skipped (no /etc/tcp-loopback-test marker)\n")

    # --- TCP maturity self-test (#166) -------------------------------
    # Gated on /etc/tcp-test (planted by scripts/test_tcp_maturity.sh via
    # ENABLE_TCP_TEST=1 in build_initramfs.py). Deterministically
    # exercises congestion control, window scaling, SACK, and the
    # multi-listener accept backlog against crafted in-kernel state —
    # no SLIRP / guestfwd needed. Default boots skip it.
    printk0("[boot:30.c] tcp_maturity gate\n")
    tm_marker_found: int32 = 0
    tm_idx: uint64 = 0
    tm_count: uint64 = initramfs_entry_count()
    while tm_idx < tm_count:
        tm_name: Ptr[char] = initramfs_entry_name(tm_idx)
        tm_ok: int32 = 1
        tm_target: Ptr[uint8] = "/etc/tcp-test"
        tm_j: uint64 = 0

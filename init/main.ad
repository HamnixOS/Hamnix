    # #171: EFI runtime services + Secure Boot image verification.
    # Gated on /etc/efi-test (planted by build_initramfs.py when
    # ENABLE_EFI_TEST=1, via scripts/test_efi_secureboot.sh). Same
    # marker-scan shape as the gates above. Part A:
    # efi_runtime_selftest() (arch/x86/kernel/efi_runtime.ad) calls the
    # firmware's GetTime / GetVariable through the RuntimeServices pointer
    # the UEFI stub captured (efi_rt_info handoff slot +72) — only
    # meaningful under OVMF/UEFI, so the test script boots the disk image
    # under OVMF. Part B: secureboot_selftest()
    # (lib/secureboot/authenticode.ad) recomputes the Authenticode PE hash
    # of the embedded test blobs and verifies a real RSA signature against
    # the embedded trust anchor — accepts the good blob, rejects the
    # tampered one. Default boots omit the marker so neither fires.
    printk0("[boot:37.efi] checking /etc/efi-test marker\n")
    efi_marker_found: int32 = 0
    efi_idx: uint64 = 0
    efi_count: uint64 = initramfs_entry_count()
    while efi_idx < efi_count:
        efi_name: Ptr[char] = initramfs_entry_name(efi_idx)
        # Compare byte-by-byte with "/etc/efi-test\0" (14 bytes inc NUL).
        efi_ok: int32 = 1
        efi_tgt: Ptr[uint8] = "/etc/efi-test"
        efi_j: uint64 = 0
        while efi_j < 14:
            if cast[uint8](efi_name[efi_j]) != efi_tgt[efi_j]:
                efi_ok = 0
                efi_j = 14
            else:
                efi_j = efi_j + 1
        if efi_ok == 1:
            efi_marker_found = 1
            efi_idx = efi_count
        else:
            efi_idx = efi_idx + 1
    if efi_marker_found == 1:
        printk0("[boot:37.efi] /etc/efi-test found — running EFI self-tests\n")
        # Part A: EFI runtime services.
        efi_rc: int32 = efi_runtime_selftest()
        if efi_rc != 1:
            printk0("[efi] FAIL: runtime-services self-test failed\n")
        # Part B: Secure Boot image verification. Locate the three fixture
        # files in the initramfs by name, then run the verifier.
        sb_anchor: Ptr[uint8] = cast[Ptr[uint8]](0)
        sb_anchor_len: uint64 = 0
        sb_good: Ptr[uint8] = cast[Ptr[uint8]](0)
        sb_good_len: uint64 = 0
        sb_bad: Ptr[uint8] = cast[Ptr[uint8]](0)
        sb_bad_len: uint64 = 0
        sb_i: uint64 = 0
        sb_n: uint64 = initramfs_entry_count()
        while sb_i < sb_n:
            sb_nm: Ptr[char] = initramfs_entry_name(sb_i)
            if _name_eq(sb_nm, "/etc/secureboot-anchor", 23) == 1:
                sb_anchor = initramfs_entry_data(sb_i)
                sb_anchor_len = initramfs_entry_size(sb_i)
            if _name_eq(sb_nm, "/etc/secureboot-pe-good", 24) == 1:
                sb_good = initramfs_entry_data(sb_i)
                sb_good_len = initramfs_entry_size(sb_i)
            if _name_eq(sb_nm, "/etc/secureboot-pe-bad", 23) == 1:
                sb_bad = initramfs_entry_data(sb_i)
                sb_bad_len = initramfs_entry_size(sb_i)
            sb_i = sb_i + 1
        if sb_anchor_len == 0 or sb_good_len == 0 or sb_bad_len == 0:
            printk0("[secureboot] FAIL: fixture files missing from initramfs\n")
        else:
            sb_rc: int32 = secureboot_selftest(sb_anchor, sb_anchor_len,
                                               sb_good, sb_good_len,
                                               sb_bad, sb_bad_len)
            if sb_rc != 1:
                printk0("[secureboot] FAIL: image-verification self-test failed\n")
    else:
        printk0("[efi] skipped (no /etc/efi-test marker)\n")
        printk0("[secureboot] skipped (no /etc/efi-test marker)\n")


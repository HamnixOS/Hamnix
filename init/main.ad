from kernel.sched.core import (
    sched_init, sched_mark_boot_task_running, kthread_create, create_user_task,
    start_first_task, current_task_pid, task_pml4,
    # HAMSH §13: the init task's loaded-image span must be recorded so
    # rfork() COW-copies its writable .data/.bss into a child. Without
    # this an `ns {}` / `enter` child shares /init's globals with the
    # parent and a variable set inside the block leaks back out.
    set_task_image_range,
    # SMP: create per-AP idle kthreads after sched_init() to avoid PID
    # counter collisions.  Called once per AP that came online.
    sched_prepare_ap_idle,
    # SMP kthread churn soak (ENABLE_SMP_SOAK=1).
    smp_kthread_soak_run,
    # #151: CFS-lite + SMP load-balance self-test (ENABLE_SCHED_FAIR=1).
    sched_fair_smp_selftest,
    # per-task oom_score_adj store + OOM-killer exemption/clamp self-test
    # (ENABLE_OOMADJ_TEST=1).
    oomadj_selftest,
    # SCHED_FIFO/SCHED_RR realtime scheduling policy self-test
    # (ENABLE_RTSCHED_TEST=1).
    rtsched_selftest,
)

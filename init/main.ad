    else:
        printk0("[devnet] skipped (no /etc/devnet-test marker)\n")

    # --- TCP FIN_WAIT_2 timeout smoke gated on cpio marker --------
    # Runs only when scripts/test_tcp_fin_wait2.sh planted
    # /etc/tcp-finwait2-test in the initramfs (ENABLE_TCP_FIN_WAIT2_SMOKE=1)
    # AND a guestfwd to 10.0.2.202:9101 is configured. Same gating
    # pattern as /etc/tcp-ring-test above — without the marker the
    # smoke skips so other test runs don't ARP-stall on the
    # unreachable peer.
    printk0("[boot:27] tcp_fin_wait2 gate\n")
    fw2_marker_found: int32 = 0

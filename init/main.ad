    # accessors read them back, renders _emit_linux_stat for the boot slot, and
    # confirms fields 11/13/16/17 parse to 33/44/11/22. Same marker-scan shape
    # as the prionice gate; "/etc/childacct-test" is 19 chars + NUL = 20 bytes.
    ca_target: Ptr[uint8] = "/etc/childacct-test"
    ca_idx: uint64 = 0

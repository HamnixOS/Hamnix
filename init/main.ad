    # #168: REAL ACPI S5 poweroff + reboot self-test. Gated on
    # /etc/acpi-test (planted by build_initramfs.py when ENABLE_ACPI_TEST=1,
    # via scripts/test_acpi_poweroff.sh). Same marker-scan shape as the
    # gates above. acpi_init() (run earlier in boot) already parsed the
    # FADT PM1a_CNT_BLK + scanned the DSDT \_S5 for SLP_TYPa. This hook
    # LOGS the concrete parsed values so the test can assert the REAL
    # path, then triggers a poweroff in real-only mode (no emulator-port
    # fallback) so a clean VM exit proves the FADT/PM1a write — not the
    # 0x604 shortcut — powered the machine off. Default boots omit the
    # marker so this never fires unintentionally.
    printk0("[boot:37.acpi] checking /etc/acpi-test marker\n")
    acpi_marker_found: int32 = 0
    acpi_idx: uint64 = 0
    acpi_count: uint64 = initramfs_entry_count()
    while acpi_idx < acpi_count:
        acpi_name: Ptr[char] = initramfs_entry_name(acpi_idx)
        # Compare byte-by-byte with "/etc/acpi-test\0" (15 bytes inc NUL).
        acpi_ok: int32 = 1
        acpi_tgt: Ptr[uint8] = "/etc/acpi-test"
        acpi_j: uint64 = 0
        while acpi_j < 15:
            if cast[uint8](acpi_name[acpi_j]) != acpi_tgt[acpi_j]:
                acpi_ok = 0
                acpi_j = 15
            else:
                acpi_j = acpi_j + 1
        if acpi_ok == 1:
            acpi_marker_found = 1
            acpi_idx = acpi_count
        else:
            acpi_idx = acpi_idx + 1
    if acpi_marker_found == 1:
        printk0("[boot:37.acpi] /etc/acpi-test found — running ACPI S5 self-test\n")
        if acpi_s5_ready() != 0:
            # LOG the concrete parsed values. The test greps for these.
            printk2("[acpi] FADT PM1a_CNT_BLK=%p SLP_TYPa=%d\n",
                    cast[uint64](acpi_pm1a_cnt()),
                    cast[uint64](cast[uint32](acpi_slp_typa())))
            printk0("[acpi] real S5 vector parsed — triggering real-only poweroff\n")
            # Isolate the real path: with real-only set, _do_poweroff()
            # issues ONLY the parsed PM1a_CNT write and SKIPS the
            # 0x604/0xB004/0x4004 emulator ports. A clean QEMU exit after
            # this can ONLY be the FADT/PM1a S5 write.
            power_set_real_only(1)
            power_action(POWER_POWEROFF)
            # power_action() never returns; if it somehow does, fail loud.
            printk0("[acpi] FAIL: poweroff returned (real S5 write did not take)\n")
        else:
            printk0("[acpi] FAIL: no real S5 vector parsed from FADT/DSDT\n")
    else:
        printk0("[acpi] skipped (no /etc/acpi-test marker)\n")


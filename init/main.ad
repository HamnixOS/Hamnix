        else:
            dss_idx = dss_idx + 1
    brd_init()
    virtio_blk_init()
    loop_init()
    dm_init()
    # GPU track #182 Phase 1: probe + bind the native virtio-gpu 2D
    # device (modern virtio-1.0 transport). Always safe to attempt:
    # returns -1 (no-op) when no virtio-gpu-pci is attached, so the
    # default GOP-framebuffer boot is unaffected. The actual screen
    # takeover (present) is gated behind /etc/virtio-gpu-test below so a
    # normal boot never disturbs the existing framebuffer console.
    virtio_gpu_init()
    # Probe the available block devices and route them to filesystems
    # by the on-disk magic, not by name:
    #   FAT (0x55 0xAA at sector 0 + "FAT32"/"FAT16" tag) → /mnt
    #   EXT4 (0xEF53 at byte offset 1024)                 → /ext
    # When both vda and ram0 are FAT, vda wins for /mnt (it's
    # backed by a real disk image rather than baked memory); the
    # ram0 mount is dropped to keep the layout tidy.
    fat_slot:  int32 = -1
    ext4_slot: int32 = -1
    vda: int32 = find_blockdev("vda")
    ram0: int32 = find_blockdev("ram0")
    # M16.x: partition-table enumeration. Walks MBR (or GPT via the
    # protective-MBR fallback) on whichever block devices registered.
    # No-op when the disk has no valid signature — log line confirms.
    # Runs before the FAT/EXT4 probe so a partitioned disk's
    # `[partition]` markers land in the serial log alongside the
    # filesystem-probe diagnostics.
    if vda >= 0:
        blk_scan_partitions(vda)
        # Mint sibling block devices for each detected GPT/MBR
        # partition (vdap1, vdap2, ...) so /dev/blk/vdaN paths reach
        # the right slice. AHCI and NVMe already do this; virtio-blk
        # was missing it, which is why the installer couldn't open
        # /dev/blk/vdap2/size when running off a partitioned ISO disk.
        blk_register_partitions(vda, "vda")
    # When a second virtio-blk disk is attached (installer scenario:
    # ISO on vda, blank target on vdb), scan it too so /dev/blk/vdb
    # and any pre-existing partition cdevs come online.
    vdb: int32 = find_blockdev("vdb")
    if vdb >= 0:
        blk_scan_partitions(vdb)
        blk_register_partitions(vdb, "vdb")
    if ram0 >= 0:
        blk_scan_partitions(ram0)
    probe: Array[512, uint8]

    if vda >= 0:
        rc: int32 = blk_read_sectors(vda, 0, 1, &probe[0])
        if rc == 0 and probe[510] == 0x55 and probe[511] == 0xAA:
            fat_slot = vda
            printk0("  /dev/vda probed FAT\n")
        else:
            ext4_slot = vda
            printk0("  /dev/vda probed non-FAT (try ext4)\n")
    if fat_slot < 0 and ram0 >= 0:
        fat_slot = ram0
        printk0("  /dev/ram0 → /mnt (baked FAT image)\n")
    slot: int32 = fat_slot
    if slot < 0:
        slot = ext4_slot                       # last-ditch for the readback
    if slot < 0:
        printk0("  ERROR: no block device registered\n")
        return
    # Mount FAT at /mnt against whatever block device probed as FAT.
    if fat_slot >= 0:
        if fat_init(fat_slot) != 0:
            printk0("  fat_init failed\n")
        else:
            # M16.x §12.5: exercise the FAT write path — create,
            # extend across a cluster boundary, overwrite, delete.
            # Runs on whichever device probed FAT (the baked ram0
            # image when no virtio disk is attached).
            fat_write_smoke_test()
    # Squashfs read-only mount smoke test on /dev/ram1 (the baked
    # squashfs image — the format real Linux liveUSBs ship the distro
    # as). Mounts, lists the root directory, and reads two files
    # (one nested in a subdirectory) to prove the parser end-to-end.
    # Skipped silently when ram1 was not registered (empty blob).
    ram1: int32 = find_blockdev("ram1")
    if ram1 >= 0:
        printk0("Hamnix: squashfs smoke test (/dev/ram1)\n")
        sqfs_smoke_test(ram1)
    # Mount ext4 at /ext if a candidate block device was detected.
    # M16.51 ships superblock parse only; the rest of the read path
    # (group desc → inode → extent tree → dir walk) lands in
    # follow-up milestones.
    if ext4_slot >= 0:
        if ext4_init(ext4_slot) == 0:
            printk0("  ext4 mounted at /ext (superblock only)\n")
            # Smoke-test the inode lookup path by reading inode 2
            # (the root directory). i_mode bits 12..15 encode the
            # file type — 0x4 = directory, 0x8 = regular file —
            # so a healthy root inode prints mode 0x4000+.
            ino_buf: Array[256, uint8]
            if ext4_read_inode(2, &ino_buf[0]) == 0:
                mode: uint16 = ext4_inode_mode(&ino_buf[0])
                size: uint32 = ext4_inode_size_lo(&ino_buf[0])
                printk2("  ext4 inode#2 mode=%x size=%d\n",
                        cast[uint64](mode), cast[uint64](size))
                # Dump root directory entries.
                ext4_dir_dump(&ino_buf[0])
            # M16.61: round-trip the block bitmap allocator.
            ext4_bitmap_smoke_test()
            # M16.63: end-to-end file create (alloc inode + alloc
            # block + write inode + splice dirent + readback verify).
            ext4_create_smoke_test()
            # M16.x §12: rename, truncate/ftruncate, fsync. Each
            # smoke test cleans up after itself (unlinks its
            # leftover) so the root-dir entry count other tests
            # assert against stays unperturbed.
            ext4_rename_smoke_test()
            ext4_truncate_smoke_test()
            ext4_fsync_smoke_test()
            ext4_links_smoke_test()
            # #149: JBD2 journal crash-consistency self-test. Only when
            # the cpio shipped /etc/ext4-journal-test AND the mounted
            # image carries a real journal (ext4_journal_active()). On a
            # no-journal image it self-skips.
            if g_ext4_journal_test == 1:
                ext4_journal_selftest()
            # Multi-block directory walk self-test. Only when the cpio
            # shipped /etc/ext4dir-test (the host attached the special
            # /bigdir image). Read-only; self-skips on normal boots.
            if g_ext4_dirmb_test == 1:
                ext4_dirmb_selftest()
            # Extent-index-node (eh_depth > 0) self-test. Only when the
            # cpio shipped /etc/ext4idx-test. Writes a fragmented file
            # that forces a depth-1 index node, verifies the read walk,
            # and truncates it. Self-skips on normal boots.
            if g_ext4_extentidx_test == 1:
                ext4_extentidx_selftest()
            # Depth-2 extent-tree self-test. Only when the cpio shipped
            # /etc/ext4d2-test. Appends enough fragmented blocks to force
            # the inode's extent tree to eh_depth=2, verifies the read
            # walk, and truncates it (folding the tree back). Self-skips
            # on normal boots.
            if g_ext4_extentd2_test == 1:
                ext4_extentd2_selftest()
            # [boot:37.htr] htree (dir_index) hash-lookup self-test. Only
            # when the cpio shipped /etc/ext4-htree-test. Runs a dirhash
            # KAT vs Linux/debugfs values, then descends the on-disk
            # "bigdir" htree directory by hash to the one indexed leaf and
            # cross-checks each lookup against the linear scan. Read-only;
            # self-skips on normal boots.
            if g_ext4_htree_test == 1:
                ext4_htree_selftest()
            # [boot:37.htins] htree (dir_index) INSERT / leaf-split WRITE
            # self-test. Only when the cpio shipped /etc/ext4-htins-test.
            # Inserts a batch of new names into an on-disk dir_index dir,
            # forcing leaf splits + an index-level growth, and verifies
            # every name resolves via the hash-descend lookup and the dir
            # stays a valid htree. Self-skips on normal boots.
            if g_ext4_htins_test == 1:
                ext4_htree_insert_selftest()
            # [boot:37.largedir] large_dir (3-level htree growth) WRITE
            # self-test. Only when the cpio shipped /etc/ext4-largedir-test.
            # Inserts names into a near-full 2-level dir_index dir until the
            # dx_root overflows and the tree grows to 3 index levels
            # (gated on INCOMPAT_LARGEDIR), then verifies every name resolves
            # via the 3-level hash descend. Self-skips on normal boots.
            if g_ext4_largedir_test == 1:
                ext4_largedir_selftest()
            # Extent-free / no-leak self-test. Only when the cpio shipped
            # /etc/ext4extfree-test. Writes a multi-block fragmented file,
            # records the free-block bitmap count, unlinks it, and proves
            # the free count returns to its pre-write value (no leaked
            # data/index blocks); also round-trips a depth-3 tree byte-
            # exact. Self-skips on normal boots.
            if g_ext4_extentfree_test == 1:
                ext4_extentfree_selftest()
            # mkdir self-test. Only when the cpio shipped
            # /etc/ext4-mkdir-test. Creates a real on-disk directory via
            # the wired vfs_mkdir → ext4_mkdir_live path and re-reads the
            # parent to confirm the DIR-typed entry. Self-skips otherwise.
            if g_ext4_mkdir_test == 1:
                ext4_mkdir_selftest()
            # fast_commit (COMPAT_FAST_COMMIT) self-test. Only when the
            # cpio shipped /etc/ext4-fc-test AND the mounted image carries
            # the fast_commit feature. Records a per-inode change into the
            # journal's reserved fast-commit tail, simulates a crash,
            # replays, and byte-compares the restored data. Self-skips on
            # normal boots / non-fast_commit images.
            if g_ext4_fc_test == 1:
                ext4_fast_commit_selftest()
            # Cross-directory directory-rename self-test. Only when the
            # cpio shipped /etc/ext4dirrename-test. Moves a sub-directory
            # to a different parent and asserts the moved dir's ".." is
            # rewritten and both parents' link counts rebalance (old -1,
            # new +1), and that a same-parent rename leaves both alone.
            # Self-skips on normal boots.
            if g_ext4_dirrename_test == 1:
                ext4_dirrename_selftest()
            # Slow-symlink self-test. Only when the cpio shipped
            # /etc/ext4-symlink-test. Creates a >60-byte-target symlink
            # (slow path: data block + extent) and a short one (fast
            # inline path), reads both back and byte-compares the
            # targets. Self-skips on normal boots.
            if g_ext4_symlink_test == 1:
                ext4_symlink_selftest()
            # ext4 xattr/ACL self-test. Only when the cpio shipped
            # /etc/ext4xattr-test. Sets/gets/lists in-inode "user."
            # attributes on the live ext4 mount and decodes a POSIX ACL.
            # Self-skips on normal boots.
            if g_ext4_xattr_test == 1:
                ext4_xattr_selftest()
            # [boot:37.verity] ext4 fs-verity self-test. Only when the cpio
            # shipped /etc/ext4-verity-test. Builds a multi-block file on the
            # live ext4 mount, enables verity (salted SHA-256 Merkle tree +
            # trusted root), reads it back verified, then proves tampering a
            # data block AND a hash-tree node are both DETECTED (read EIO).
            # Self-skips on normal boots.
            if g_ext4_verity_test == 1:
                ext4_verity_selftest()
            # [boot:37.fscrypt] ext4 fscrypt self-test. Only when the cpio
            # shipped /etc/ext4-fscrypt-test. Builds a multi-block file on the
            # live ext4 mount, sets an fscrypt policy (per-file AES-256-XTS key
            # via HKDF-SHA256 + EXT4_ENCRYPT_FL), writes a known plaintext
            # encrypted, then proves byte-identical decrypt round-trip, genuine
            # on-disk ciphertext, XTS tweak applied, and wrong-key garbage.
            # Self-skips on normal boots.
            if g_ext4_fscrypt_test == 1:
                ext4_fscrypt_selftest()
            # Per-backend fstat metadata self-test. Only when the cpio
            # shipped /etc/fstat-backend-test. Proves do_fstat returns
            # real size + qid for ext4 and tmpfs fd backends (the live
            # ext4 mount gives the ext4 leg a real fs). Self-skips
            # otherwise.
            if g_fstat_backend_test == 1:
                fstat_backend_selftest()
            # wstat chmod/truncate round-trip self-test. Only when the
            # cpio shipped /etc/wstat-apply-test (planted exclusively by
            # scripts/test_p9wstat_ext4.sh). Drives do_wstat with mode +
            # length legs on a live ext4 file and asserts the inode mode
            # and file size round-trip. Self-skips on normal boots.
            if g_wstat_apply_test == 1:
                wstat_apply_selftest()
            # [boot:37.sfs] statfs(2)/fstatfs(2) capacity self-test. Only
            # when the cpio shipped /etc/statfs-test (planted exclusively
            # by scripts/test_statfs.sh). Drives _u_statfs/_u_fstatfs
            # through the real Linux-ABI dispatch on the live ext4 mount
            # (/ext, REAL superblock geometry), the synthetic root (/), and
            # an open tmpfs fd — proving df sees real capacity. Self-skips
            # on normal boots.
            if g_statfs_test == 1:
                statfs_selftest()
            # [boot:37.acc] access(2) mode-bit self-test. Only when the
            # cpio shipped /etc/access-mode-test (planted exclusively by
            # scripts/test_access_mode.sh). Stamps known modes on ext4
            # files and drives SYS_access through the real Linux-ABI
            # dispatch, proving the R/W/X bit check against i_mode.
            # Self-skips on normal boots.
            if g_access_mode_test == 1:
                access_mode_selftest()

    # [boot:37.trl] readlink(2)/readlinkat(2)-on-tmpfs-symlink self-test.
    # Only when the cpio shipped /etc/tmpfs-readlink-test (planted
    # exclusively by scripts/test_tmpfs_readlink.sh). tmpfs is RAM-backed
    # so this runs OUTSIDE the ext4-mount block — no disk image needed.
    # Creates a tmpfs file + symlink and drives SYS_readlink/SYS_readlinkat
    # through the real Linux-ABI dispatch, proving readlink consults the
    # tmpfs symlink store. Self-skips on normal boots.
    if g_tmpfs_readlink_test == 1:
        tmpfs_readlink_selftest()

    # M16.60: block write path. Round-trips a unique marker through
    # blk_write_sectors → blk_read_sectors on whichever device we
    # have. Picks a high-LBA scratch sector (well past any
    # filesystem metadata or planted data — block 1018 of the
    # 1 MiB ext4 image is unused; the FAT image is 64 sectors so
    # we target sector 50 there). Restores the original bytes
    # after verification so a subsequent mount sees no change.
    blkwrite_smoke_test(fat_slot, ext4_slot)


def blkwrite_smoke_test(fat_slot: int32, ext4_slot: int32):
    target: int32 = -1
    test_lba: uint64 = 0
    if ext4_slot >= 0:
        target = ext4_slot
        test_lba = 2036                       # block 1018 × 2 sectors/block
    if target < 0 and fat_slot >= 0:
        target = fat_slot
        test_lba = 50                         # well past BPB+FAT+root dir
    if target < 0:
        printk0("blk: write smoke test SKIP (no block device)\n")
        return
    orig:   Array[512, uint8]
    test:   Array[512, uint8]
    readback: Array[512, uint8]
    if blk_read_sectors(target, test_lba, 1, &orig[0]) != 0:
        printk0("blk: write smoke test FAIL (orig read)\n")
        return
    # Fill the test pattern: a magic header followed by a counted
    # byte sequence so we can verify per-byte, not just "non-zero".
    test[0] = 0x57                            # 'W'
    test[1] = 0x52                            # 'R'
    test[2] = 0x49                            # 'I'
    test[3] = 0x54                            # 'T'
    test[4] = 0x45                            # 'E'
    test[5] = 0x4F                            # 'O'
    test[6] = 0x4B                            # 'K'
    test[7] = 0x21                            # '!'
    i: uint64 = 8
    while i < 512:
        test[i] = cast[uint8](i & 0xFF)
        i = i + 1
    if blk_write_sectors(target, test_lba, 1, &test[0]) != 0:
        printk0("blk: write smoke test FAIL (write)\n")
        return
    if blk_read_sectors(target, test_lba, 1, &readback[0]) != 0:
        printk0("blk: write smoke test FAIL (readback)\n")
        # Best-effort restore before returning.
        blk_write_sectors(target, test_lba, 1, &orig[0])
        return
    # Byte-compare. Fail loudly with the first mismatching offset
    # so a regression doesn't get swept under the rug.
    j: uint64 = 0
    while j < 512:
        if readback[j] != test[j]:
            printk1("blk: write smoke test FAIL @offset=%d\n", j)
            blk_write_sectors(target, test_lba, 1, &orig[0])
            return
        j = j + 1
    # Restore the original sector bytes so /ext or /mnt isn't
    # mutated for downstream code.
    blk_write_sectors(target, test_lba, 1, &orig[0])
    printk0("blk: write smoke test PASS\n")


# Plan 9-shape rootfs (the "distrofs" partition) autodiscover.
#
# Phase 5 / docs/rootfs_partition.md "Future direction". For each
# discovered ext4 partition:
#   * Synthesise a partuuid string (`<disk>p<slot>`) — the GPT parser
#     does not yet surface the real per-partition UUID; placeholder
#     until that lands. Today's discovery walk runs against an MBR-
#     like view anyway (we only have one rootfs partition at a time),
#     so the synthetic name is unique inside that scope.
#   * Mount via ext4_init() (single-mount state in fs/ext4.ad —
#     successive calls overwrite the global state; last-mounted is
#     what `/ext`-shape paths resolve through today).
#   * Try to read `.hamnix-roots`. If parsed clean: register each
#     entry as `#<word>` via name_push. If absent: register the
#     whole partition as `#part<N>` (sequential, no stack).
#   * Always register the partition in the by-id table as
#     `#by-id/<partuuid>` — persistent reference that NEVER moves.
#   * Parse error: log loud, register by-id only, NO `#name`
#     registration (fail closed per the doc).
#
# Returns the slot index of the LAST mounted partition (>= 0), or
# -1 if none. The init ns still doesn't bind /ext globally. The
# sentinel-declared `distro` name is NOT bound into the ambient boot
# namespace (isolation invariant — see etc/rc.boot.full); it is picked
# up by `bind '#distro' /` inside the hermetic `enter linux`/`enter
# debian` runtime namespaces, and by the installer's own
# `bind '#distro' /n/distros` (etc/install.hamsh).

# Sentinel-parse outcome codes (kept local to init/main.ad).
HAMNIX_ROOTS_OK:        int32 = 0     # parsed clean
HAMNIX_ROOTS_ABSENT:    int32 = 1     # no such file at root
HAMNIX_ROOTS_BAD:       int32 = -1    # parse error

# Counts the anonymous (sentinel-less) partitions discovered, so each
# gets a unique `#part<N>` name.
fs_anon_index: uint32 = 0

# Slot of the ext4 rootfs partition mount_rootfs_partition() last
# mounted (>= 0), or -1 if no ext4 partition was found this boot. Set
# in start_kernel; read by the kernel-side `bind '#sysroot' /` and the
# ext4-root /init loader so a cpio-less installed disk boots its real
# userland off the partition.
g_rootfs_slot: int32 = -1

# #149: 1 when /etc/ext4-journal-test was found in the cpio, arming the
# JBD2 crash-consistency self-test after the ext4 mount. See the marker
# scan in start_kernel and ext4_journal_selftest() in fs/ext4.ad.
g_ext4_journal_test: int32 = 0
# 1 when /etc/ext4dir-test was found in the cpio, arming the multi-block
# directory walk self-test (ext4_dirmb_selftest) after the ext4 mount.
g_ext4_dirmb_test: int32 = 0
# 1 when /etc/ext4idx-test was found in the cpio, arming the extent-
# index-node (eh_depth > 0) self-test (ext4_extentidx_selftest) after
# the ext4 mount.
g_ext4_extentidx_test: int32 = 0
# 1 when /etc/ext4d2-test was found in the cpio, arming the depth-2
# extent-tree self-test (ext4_extentd2_selftest) after the ext4 mount.
# See the marker scan in start_kernel and ext4_extentd2_selftest() in
# fs/ext4.ad.
g_ext4_extentd2_test: int32 = 0
# 1 when /etc/ext4-htree-test was found in the cpio, arming the htree
# (dir_index) hash-lookup self-test (ext4_htree_selftest) after the ext4
# mount. See the marker scan in start_kernel and ext4_htree_selftest() in
# fs/ext4.ad.
g_ext4_htree_test: int32 = 0
# 1 when /etc/ext4-htins-test was found in the cpio, arming the htree
# (dir_index) INSERT / leaf-split WRITE self-test (ext4_htree_insert_selftest)
# after the ext4 mount. See the marker scan in start_kernel and
# ext4_htree_insert_selftest() in fs/ext4.ad.
g_ext4_htins_test: int32 = 0
# 1 when /etc/ext4-largedir-test was found in the cpio, arming the large_dir
# 3-level htree growth WRITE self-test (ext4_largedir_selftest) after the ext4
# mount. See the marker scan in start_kernel and ext4_largedir_selftest() in
# fs/ext4.ad.
g_ext4_largedir_test: int32 = 0
# 1 when /etc/ext4extfree-test was found in the cpio, arming the
# extent-free / no-leak self-test (ext4_extentfree_selftest) after the
# ext4 mount: it writes a multi-block fragmented file, records the free-
# block bitmap count, unlinks the file, and proves every data + index
# block returned to the free pool (and round-trips a depth-3 tree).
g_ext4_extentfree_test: int32 = 0
# 1 when /etc/ext4-mkdir-test was found in the cpio, arming the mkdir
# self-test (ext4_mkdir_selftest) after the ext4 mount. See the marker
# scan in start_kernel and ext4_mkdir_selftest() in fs/ext4.ad.
g_ext4_mkdir_test: int32 = 0
# 1 when /etc/ext4-fc-test was found in the cpio, arming the fast_commit
# (COMPAT_FAST_COMMIT) self-test (ext4_fast_commit_selftest) after the
# ext4 mount. See the marker scan in start_kernel and
# ext4_fast_commit_selftest() in fs/ext4.ad.
g_ext4_fc_test: int32 = 0
# Set to 1 when /etc/ext4dirrename-test is present, gating the
# cross-directory directory-rename self-test (ext4_dirrename_selftest)
# after the ext4 mount. See the marker scan in start_kernel and
# ext4_dirrename_selftest() in fs/ext4.ad.
g_ext4_dirrename_test: int32 = 0
# 1 when /etc/ext4-symlink-test was found in the cpio, arming the
# slow-symlink self-test (ext4_symlink_selftest) after the ext4 mount.
# See the marker scan in start_kernel and ext4_symlink_selftest() in
# fs/ext4.ad.
g_ext4_symlink_test: int32 = 0
# 1 when /etc/ext4xattr-test was found in the cpio, arming the ext4
# xattr/ACL self-test (ext4_xattr_selftest) after the ext4 mount. See
# the marker scan in start_kernel and ext4_xattr_selftest() in fs/ext4.ad.
g_ext4_xattr_test: int32 = 0
# 1 when /etc/ext4-verity-test was found in the cpio, arming the ext4
# fs-verity (EXT4_VERITY_FL Merkle-tree authenticity) self-test
# (ext4_verity_selftest) after the ext4 mount. See the marker scan in
# start_kernel and ext4_verity_selftest() in fs/ext4.ad.
g_ext4_verity_test: int32 = 0
# 1 when /etc/ext4-fscrypt-test was found in the cpio, arming the ext4
# fscrypt (EXT4_ENCRYPT_FL per-file AES-256-XTS content-encryption) self-test
# (ext4_fscrypt_selftest) after the ext4 mount. See the marker scan in
# start_kernel and ext4_fscrypt_selftest() in fs/ext4.ad.
g_ext4_fscrypt_test: int32 = 0
# 1 when /etc/fstat-backend-test was found in the cpio, arming the
# per-backend fstat metadata self-test (fstat_backend_selftest) after
# the ext4 mount. See the marker scan in start_kernel and
# fstat_backend_selftest() in sys/src/9/port/sysfile.ad.
g_fstat_backend_test: int32 = 0
# 1 when /etc/wstat-apply-test was found in the cpio, arming the wstat

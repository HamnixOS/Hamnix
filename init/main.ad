    # Gated on /etc/partebr-test (planted by scripts/test_partebr.sh,
    # which also attaches a raw "vda" disk carrying an MBR + extended
    # container + a 3-EBR logical chain). partition_ebr_selftest()
    # (drivers/block/partition.ad) re-scans vda and asserts the three
    # logical partitions enumerate at their exact absolute LBA windows —
    # proving the next-EBR-relative-to-ext_base arithmetic. Read-only,
    # opt-in; default boots omit the marker so it never fires.
    printk0("[boot:37.ebr] checking /etc/partebr-test marker\n")
    eb_marker_found: int32 = 0
    eb_idx: uint64 = 0
    eb_count: uint64 = initramfs_entry_count()
    while eb_idx < eb_count:
        eb_name: Ptr[char] = initramfs_entry_name(eb_idx)
        eb_ok: int32 = 1
        eb_tgt: Ptr[uint8] = "/etc/partebr-test"
        eb_j: uint64 = 0
        while eb_j < 18:                       # 17 chars + NUL
            if cast[uint8](eb_name[eb_j]) != eb_tgt[eb_j]:
                eb_ok = 0
                eb_j = 18
            else:
                eb_j = eb_j + 1
        if eb_ok == 1:
            eb_marker_found = 1
            eb_idx = eb_count
        else:
            eb_idx = eb_idx + 1
    if eb_marker_found == 1:
        printk0("[boot:37.ebr] /etc/partebr-test found — running self-test\n")
        eb_rc: int32 = partition_ebr_selftest()
        if eb_rc != 1:
            printk0("[part-ebr] self-test reported FAIL\n")
    else:
        printk0("[part-ebr] skipped (no /etc/partebr-test marker)\n")

    # boot:37.ovl — Linux-style overlayfs (union filesystem) self-test.
    # Gated on /etc/overlayfs-test (planted by build_initramfs.py when
    # ENABLE_OVERLAYFS_TEST=1, via scripts/test_overlayfs.sh). Same
    # marker-scan shape as the gates above. overlayfs_selftest()
    # (fs/overlayfs.ad) builds a two-layer overlay backed by tmpfs and
    # proves: upper SHADOWS lower on lookup; COPY-UP-on-write copies a
    # lower-only file into upper (writes hit upper, lower stays pristine);
    # WHITEOUT-on-delete hides a lower-only file via a ".wh.<name>" marker
    # without touching the read-only lower; re-creating over a whiteout
    # makes the name live again; and merged READDIR is the deduped union of
    # upper+lower with whiteouts hidden and upper winning collisions.
    # Prints [overlayfs] lines + a single [overlayfs] PASS. Default boots
    # omit the marker so it never fires.
    printk0("[boot:37.ovl] checking /etc/overlayfs-test marker\n")
    overlayfs_marker_found: int32 = 0
    overlayfs_idx: uint64 = 0
    overlayfs_count: uint64 = initramfs_entry_count()
    while overlayfs_idx < overlayfs_count:
        overlayfs_name: Ptr[char] = initramfs_entry_name(overlayfs_idx)
        # Compare byte-by-byte with "/etc/overlayfs-test\0" (20 bytes inc NUL).
        overlayfs_ok: int32 = 1
        overlayfs_tgt: Ptr[uint8] = "/etc/overlayfs-test"
        overlayfs_j: uint64 = 0
        while overlayfs_j < 20:
            if cast[uint8](overlayfs_name[overlayfs_j]) != overlayfs_tgt[overlayfs_j]:
                overlayfs_ok = 0
                overlayfs_j = 20
            else:
                overlayfs_j = overlayfs_j + 1
        if overlayfs_ok == 1:
            overlayfs_marker_found = 1
            overlayfs_idx = overlayfs_count
        else:
            overlayfs_idx = overlayfs_idx + 1
    if overlayfs_marker_found == 1:
        printk0("[boot:37.ovl] /etc/overlayfs-test found — running self-test\n")
        overlayfs_rc: int32 = overlayfs_selftest()
        if overlayfs_rc != 1:
            printk0("[overlayfs] self-test reported FAIL\n")
    else:
        printk0("[overlayfs] skipped (no /etc/overlayfs-test marker)\n")

    printk0("[boot:38] create_user_task (init)\n")
    parent_slot: int32 = create_user_task(
        init_entry, 0x5f5f696e69745f5f)         # "__init__"
    # HAMSH §13: record /init's loaded-image span on the task so a
    # later rfork() (every `ns {}` / `enter` / `spawn` in hamsh) gives
    # the child a COW-private copy of /init's writable .data/.bss.
    # elf_load_blob stamped elf_last_img_{lo,hi} for the ELF32 image;
    # SYS_SPAWN does the identical set_task_image_range for the
    # binaries it loads, but the boot init task is created here, not
    # through SYS_SPAWN, so the call has to be repeated.
    if parent_slot >= 0 and init_blob != 0:
        set_task_image_range(cast[uint64](parent_slot),
                             elf_last_img_lo_get(),
                             elf_last_img_hi_get())
        # M16.36: install per-task PT entries for /init's PT_LOAD
        # range into its freshly-cloned PML4. Without this, the boot
        # init task runs on the BSP's inherited 1 GiB identity stamp —
        # the historical "vaddr == phys by accident" arrangement that
        # broke on real hardware whose memblock landed in a PDPT slot
        # outside the boot stub's 4 GiB identity map. The user-stack
        # for /init was allocated inside create_user_task as a single
        # 4 KiB page (USTACK_SIZE); it sits in low identity-mapped
        # RAM so a PT-install is not required there — that path is
        # used only by the boot init shim, and the Linux user-stack
        # path (where the stack is bigger / further away) goes
        # through SYS_SPAWN / do_execve, which install their own
        # stack PTEs.
        if elf_apply_last_user_mapping(
                task_pml4(parent_slot)) < 0:
            printk0("Hamnix: /init PT_LOAD install failed; boot will likely hang\n")
    printk1("Hamnix: parent user task @ slot %d\n",
            cast[uint64](parent_slot))
    printk1("Hamnix: parent task PML4 = %p (per-task)\n",
            task_pml4(parent_slot))

    # Arm the SYSCALL/SYSRET MSRs. M16.35 routes the syscall entry
    # stub through the current task's own kstack_top via TSS.RSP0
    # (kept current by schedule()), so we no longer reserve a separate
    # kernel stack here. tss_init's RSP0 arg is just a seed —
    # start_first_task overwrites TSS.RSP0 with slot 0's kstack_top
    # before iretq'ing into user mode.
    printk0("[boot:39] syscall_init\n")
    syscall_init()
    printk0("[boot:40] tss_init\n")
    tss_seed_rsp0: uint64 = alloc_page() + 4096
    tss_init(tss_seed_rsp0)

    # M16.154-trapdiag: overwrite IDT entries 0x06/0x08/0x0d/0x0e
    # with the richer "print full iret frame + halt" diagnostic
    # handlers in arch/x86/kernel/trap_asm.S. Runs AFTER idt_init()
    # / tss_init(), so the new entries land last and win on the
    # ring-3 transition that follows. Also wires TSS.IST1 to a
    # scratch stack so #DF has somewhere to land when the
    # interrupted RSP is unusable.
    # USB ESP write self-test (drivers/usb/storage.ad + kernel/printk/
    # esp_log.ad). Runs near the END of boot so its single PASS/FAIL banner
    # lands in the LAST few screen lines a serial-less NUC can be
    # photographed showing. It round-trips a sentinel through the raw USB
    # bulk-OUT WRITE(10) path on sd0p1 — the path that had never run on real
    # hardware and left LOG.TXT all-newlines. A no-op (returns 0) on a
    # non-USB boot or when no sd0p1 ESP target is armed.
    printk0("[boot:40.5] esp_log_write_selftest\n")
    esp_log_write_selftest()
    # Persist everything up to the late-init phases before we touch the
    # trap table / hand off to userland — these are exactly the points a
    # bad real-hardware boot tends to die at.
    esp_log_flush()
    printk0("[boot:41] trap_diag_install\n")
    trap_diag_install()

    # Decisive high-RAM telemetry in the same on-screen frame as a
    # ring-3 hand-off crash: prints "[himem-late] IDMAP512 ..." + a
    # PASS/FAIL probe of RAM above 4 GiB. If a real-hardware crash photo
    # shows this line the image HAS the >4 GiB fix; if it's missing the
    # box booted a stale pre-fix image.
    printk0("[boot:41.5] himem_late_report\n")
    himem_late_report()
    # Late USB/xHCI status in the SAME on-screen frame as a hand-off
    # crash. AC64 = HCCPARAMS1 bit0 (1=controller can DMA to 64-bit
    # addrs, 0=32-bit-only). ring=cmd_ring phys: on a >4 GiB box the
    # memblock-backed rings land high, so AC64=0 + ring>4 GiB is the
    # smoking gun for "controller can't reach its own DMA rings → USB
    # never enumerates → no ext4 root → baked-init #UD". sd0 = whether
    # USB-MSC ever registered /dev/blk/sd0.
    usb_sd0: int32 = find_blockdev("sd0")
    printk2("[usb-late] AC64=%d ring=%p\n",
            cast[uint64](xhci_ac64()), xhci_ring_phys())
    # Per-port connect-status (raw PORTSC + CCS) so a real-HW crash
    # photo shows whether the root-hub port even SEES the stick.
    xhci_port_report()
    if usb_sd0 < 0:
        printk0("[usb-late] sd0_slot=-1 NOT-ENUMERATED (USB stick never registered)\n")
    else:
        printk1("[usb-late] sd0_slot=%d (USB stick enumerated)\n",
                cast[uint64](usb_sd0))
    # Late USB read-path probe in the SAME crash frame. Enumeration gave
    # sd0 a slot, but blob=0 means the ext4-magic scan found nothing —
    # so the open question is whether a bulk READ off the stick actually
    # returns on-disk bytes on real silicon. g_rootfs_slot is the scan's
    # verdict (-1 == no ext4 partition mounted). Then list every in-use
    # block slot (reveals whether the GPT scan registered sd0p2, where
    # the ext4 root lives) and do a LIVE read of each slot's ext4
    # superblock sector (LBA2) reporting rc + the 0xEF53 magic. Reading:
    #   * some sd0pN shows magic=ef53 with rc=0  -> bulk reads WORK; the
    #     bug is in registration/by-id binding, not the data path.
    #   * a slot exists but rc!=0 or magic!=ef53 -> the bulk READ(10)
    #     data path fails post-enumeration on real HW (enumeration !=
    #     transfer); instrument usbms_read_sectors / the BOT CSW next.
    #   * no sd0pN slot at all -> the GPT partition scan (itself a bulk
    #     read of LBA0/1) failed, so no ext4 sub-slot was ever created.
    printk1("[usb-rd] g_rootfs_slot=%d\n", cast[uint64](g_rootfs_slot))
    rdprobe: Array[1024, uint8]
    nblk: uint64 = blk_max_slots()
    bi: uint64 = 0
    while bi < nblk:
        bsi: int32 = cast[int32](bi)
        if blk_slot_in_use(bsi) != 0:
            bnm: Ptr[char] = blk_slot_name(bsi)
            rdrc: int32 = blk_read_sectors(bsi, 2, 2, &rdprobe[0])
            bmagic: uint16 = cast[uint16](rdprobe[0x38]) \
                | (cast[uint16](rdprobe[0x39]) << 8)
            printk0("[usb-rd] slot ")
            if cast[uint64](bnm) != 0:
                printk0(bnm)
            printk2(" rc=%d magic=%x\n",
                    cast[uint64](rdrc), cast[uint64](bmagic))
        bi = bi + 1
    # Reprint the latched one-shot bulk-failure diagnostic here so it lands
    # in the SAME final frame (the live one-shot scrolls off and LOG.TXT
    # can't persist it — USB writes are exactly what's dead). evt_seen is
    # decisive: >0 = controller posted a Transfer Event we skipped on the
    # strict expect_trb match (TRB-PA mismatch; compare last_evt_p); ==0 =
    # the Normal TRB never executed (cycle-bit / doorbell / EP-state / DMA).
    xhci_bulk_diag_report()
    # Latched .ko-block bring-up state (the DEFAULT metal USB path). Pins
    # exactly where _xr_register_block_device died on real HW: reg_reached
    # (did init even call it?), readcap_rc/reg_rc, and the last BOT
    # phase/completion-code — all of which scroll off before this frame.
    xhci_real_blk_diag_report()
    # /init resolution outcome, reprinted in the SAME on-screen frame as the
    # ring-3 hand-off trap-diag (the boot:36 lines scroll off before a crash).
    # blob=0 -> ns_blob_ptr("/init") found nothing => the ext4 root read off
    # the freshly-enumerated sd0 failed and we fell back to the baked
    # user_demo_entry. entry==userdemo confirms baked fallback; entry!=userdemo
    # means /init ELF loaded and the fault is in its code / per-task mapping.
    # Compare entry/userdemo against the trap-diag rip to see which one ran.
    printk2("[boot:init] blob=%p size=%d\n", init_blob, init_size)
    printk2("[boot:init] entry=%p userdemo=%p\n",
            init_entry, cast[uint64](&user_demo_entry))
    esp_log_flush()
    printk0("[boot:42] start_first_task\n")
    printk0("Hamnix: entering parent via start_first_task...\n")
    # Final kernel-controlled flush: the next line dives into userland
    # and never returns. If the box dies during the ring-3 transition,
    # the whole kernel boot is already on the ESP.
    esp_log_flush()
    # Dive into the slot create_user_task actually handed /init.
    # sched_mark_boot_task_running() marks slot 0 RUNNING early (so a
    # boot-time .ko probe yield doesn't halt schedule()), which pushes
    # /init to slot 1; passing the real slot keeps start_first_task from
    # diving into the all-zero boot slot.
    start_first_task(cast[uint64](parent_slot))
    # NOT REACHED — schedule() halts the box when all tasks exit.
    printk0("Hamnix: ERROR — returned from start_first_task\n")
    halt_forever()

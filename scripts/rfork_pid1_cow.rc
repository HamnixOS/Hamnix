# Minimal rc to reproduce the PID-1 hamsh first-rfork COW page fault.
# Booted as /etc/hamsh.rc when hamsh is /init (INIT_ELF=hamsh.elf,
# HAMNIX_HAMSH_RC=scripts/rfork_pid1_cow.rc).
#
# This mirrors etc/rc.boot.full:57/:61 exactly: an empty `ns {}` template
# capture followed by a `spawn detached <tmpl> { ... }`. The spawn
# desugars to sys_rfork(RFPROC|RFNAMEG|RFNOWAIT) -> do_rfork's
# new-process arm, which COW-shares PID-1 hamsh's loaded image. The
# child's first write to an image .data page must be resolved as
# copy-on-write, NOT fault fatally (#PF vector 0x0e err=0x07).
echo RFORK_COW_RC_START
bootns = ns {
}
svc = spawn detached bootns {
    echo RFORK_COW_CHILD_RAN
}
echo RFORK_COW_RC_DONE

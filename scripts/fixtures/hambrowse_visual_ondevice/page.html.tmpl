<!DOCTYPE html>
<html>
<head>
<title>hambrowse rich on-device page</title>
<style>
  body { margin: 0; font-family: sans-serif; }
  /* Gradient background region (linear-gradient, red -> blue) behind the page.
     position:relative anchors the absolutely-positioned badge. */
  .page { position: relative; background: linear-gradient(to right, #ff0000, #0000ff);
          padding: 14px; }
  /* position:absolute badge, pinned to the top-right of .page. LOUD YELLOW so a
     framebuffer pixel scan can find it regardless of window placement. */
  .badge { position: absolute; top: 8px; right: 8px; background: #ffff00;
           color: #000000; padding: 5px 10px; border: 2px solid #000000; }
  h1 { color: #ffffff; margin: 4px 0; }
  .lead { color: #ffffff; margin: 4px 0 12px 0; }
  /* Flex row laying out the three graphic cells side by side. */
  .row { display: flex; gap: 16px; }
  .cell { background: #ffffff; padding: 8px; border: 1px solid #333333; }
  canvas { display: block; }
</style>
</head>
<body>
<div class="page">
  <div class="badge">BADGE</div>
  <h1>Hamnix hambrowse: rich page on the real framebuffer</h1>
  <p class="lead">Flex layout + gradient background + absolute badge + &lt;img&gt;
     + inline &lt;svg&gt; + scripted &lt;canvas&gt; on one page.</p>
  <div class="row">
    <div class="cell">
      <!-- inline SVG: rect (LOUD ORANGE), circle (LOUD LIME), path (violet). -->
      <svg width="128" height="128" viewBox="0 0 128 128">
        <rect x="8" y="8" width="64" height="64" fill="#ff8800" stroke="#000000" stroke-width="2"/>
        <circle cx="86" cy="64" r="36" fill="#00ff00"/>
        <path d="M 12 118 L 116 118 L 64 74 Z" fill="#8000ff"/>
      </svg>
    </div>
    <div class="cell">
      <!-- canvas: a script fills it LOUD MAGENTA then draws a black inner box
           and a green path triangle. Proves page <script> ran on device. -->
      <canvas id="c" width="180" height="128"></canvas>
    </div>
    <div class="cell">
      <!-- <img> fetched relative to the page URL over http9 (served by host). -->
      <img src="sample.png" width="96" height="64">
    </div>
  </div>
</div>
<script>
  var ctx = document.getElementById('c').getContext('2d');
  ctx.fillStyle = '#ff00ff';
  ctx.fillRect(0, 0, 180, 128);
  ctx.fillStyle = '#000000';
  ctx.fillRect(12, 12, 60, 44);
  ctx.fillStyle = '#00ff00';
  ctx.beginPath();
  ctx.moveTo(110, 20);
  ctx.lineTo(160, 20);
  ctx.lineTo(135, 90);
  ctx.closePath();
  ctx.fill();
  console.log("HAMVISUAL canvas painted magenta+black+green");
</script>
</body>
</html>

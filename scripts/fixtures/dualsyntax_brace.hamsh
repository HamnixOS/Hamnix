# scripts/fixtures/dualsyntax_brace.hamsh
# The C-style brace twin of dualsyntax_indent.hamsh. Same program, same
# DS_* markers — proving the two block syntaxes are interchangeable.
x = 3
if x > 2 { echo DS_IF_YES; echo DS_IF_YES2 } else { echo DS_IF_NO }
for i in a b c { echo DS_FOR_$i }
def greet(who) { echo DS_HELLO_$who }
greet("world")
echo DS_UPPER_${upper("done")}

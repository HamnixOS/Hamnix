# scripts/fixtures/dualsyntax_indent.hamsh
# Pure Python-style significant-indentation hamsh script. Sourced by
# scripts/test_hamsh_dualsyntax.sh; must emit exactly the same DS_*
# markers as its brace twin dualsyntax_brace.hamsh.
x = 3
if x > 2:
    echo DS_IF_YES
    echo DS_IF_YES2
else:
    echo DS_IF_NO
for i in a b c:
    echo DS_FOR_$i
def greet(who):
    echo DS_HELLO_$who
greet("world")
echo DS_UPPER_${upper("done")}

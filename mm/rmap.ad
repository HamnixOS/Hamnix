# mm/rmap.ad
#
# Reverse mapping — the keystone of Linux-shape reclaim (mm/rmap.c).
#
# Forward mapping answers "given a virtual address, which physical page?"
# (a page-table walk).  Reclaim, COW and migration need the INVERSE: given
# a physical page about to be evicted, find EVERY PTE that maps it so they
# can be torn down (or rewritten to a swap entry) atomically.  Without rmap
# the reclaim scanner cannot prove a page is unmapped before freeing it,
# and must instead WALK EVERY TASK's page tables looking for the frame —
# the O(tasks × address-space) guesswork the pre-rmap reclaim did.
#
# ANON RMAP MODEL
#
#   Every anonymous page in Hamnix is MAP_PRIVATE demand-paged memory.  In
#   the steady state each such page has EXACTLY ONE mapper: the task whose
#   #PF demand-faulted it.  The one exception is a COW window: between a
#   fork (which marks the shared frame RO+COW in N page tables) and the
#   first write-fault that breaks COW, a frame is mapped by N tasks.  Those
#   shared frames are tracked by the COW refcount table (mm/cow.ad) and are
#   NEVER eviction candidates — reclaim skips any page with mapcount > 1 /
#   COW set — so a SINGLE-mapper anon rmap entry per page is sufficient and
#   exact for the reclaim use case.  When COW breaks, the new private copy
#   gets its own fresh rmap entry (the faulting task + va); the shared
#   original's rmap still names one of the original mappers, which is fine
#   because a still-shared page is never the reclaimer's target.
#
#   The rmap entry is packed into the PageDesc.rmap uint64 (mm/page.ad):
#
#       bits [47:0]   page-aligned user virtual address (user VAs are
#                     < 2^47, low 12 bits are always 0 for a page base)
#       bits [63:48]  mapper task slot index + 1  (0 == no rmap recorded;
#                     +1 so slot 0 is distinguishable from "empty")
#
#   page_add_anon_rmap(phys, slot, va) records the mapper and bumps the
#   page's mapcount (mm/page.ad); page_remove_rmap(phys) clears it and
#   drops mapcount.  rmap_get_mapper(phys) decodes the (slot, va) so the
#   reclaimer can find and rewrite the exact PTE.

from mm.page import (
    page_pfn, page_rmap, page_set_rmap,
    page_mapcount_inc, page_mapcount_dec, page_mapcount,
    page_set_flag, page_clear_flag, PG_ANON,
)
from kernel.printk.printk import printk0, printk1, printk2

RMAP_VA_MASK:   uint64 = 0x0000FFFFFFFFFFFF   # bits [47:0]
RMAP_SLOT_SHIFT: uint64 = 48


def rmap_pack(slot: uint64, va: uint64) -> uint64:
    # Pack (slot, page-aligned va) into one rmap word.  slot stored +1 so
    # an all-zero word reliably means "no mapper".
    return ((slot + 1) << RMAP_SLOT_SHIFT) | (va & RMAP_VA_MASK)


def rmap_has_mapper(rword: uint64) -> int32:
    if rword == 0:
        return 0
    return 1


def rmap_slot(rword: uint64) -> int64:
    # Decode the mapper task slot, or -1 if the word is empty.
    if rword == 0:
        return cast[int64](-1)
    return cast[int64]((rword >> RMAP_SLOT_SHIFT) - 1)


def rmap_va(rword: uint64) -> uint64:
    return rword & RMAP_VA_MASK


def page_add_anon_rmap(phys: uint64, slot: uint64, va: uint64):
    # Record that task `slot` maps physical page `phys` at page-aligned
    # virtual address `va`, and bump the page's mapcount.  Marks the page
    # PG_ANON.  Called by the demand-fault and swap-in paths right after a
    # present PTE is installed.
    if phys == 0:
        return
    pfn: uint64 = page_pfn(phys)
    page_set_rmap(pfn, rmap_pack(slot, va & ~cast[uint64](0xFFF)))
    page_mapcount_inc(pfn)
    page_set_flag(pfn, PG_ANON)


def page_remove_rmap(phys: uint64):
    # Drop one mapping of `phys`: decrement mapcount and, when it reaches
    # 0, clear the rmap word and the PG_ANON flag.  Called when a PTE that
    # mapped this anon page is torn down (reclaim eviction, unmap, exit).
    if phys == 0:
        return
    pfn: uint64 = page_pfn(phys)
    nm: int32 = page_mapcount_dec(pfn)
    if nm <= 0:
        page_set_rmap(pfn, 0)
        page_clear_flag(pfn, PG_ANON)


def rmap_get_mapper_slot(phys: uint64) -> int64:
    # The task slot that maps `phys` (anon), or -1 if no rmap recorded.
    return rmap_slot(page_rmap(page_pfn(phys)))


def rmap_get_mapper_va(phys: uint64) -> uint64:
    # The page-aligned va at which the mapper maps `phys`.
    return rmap_va(page_rmap(page_pfn(phys)))


def page_is_anon(phys: uint64) -> int32:
    # 1 if `phys` is a single-mapper anonymous page with an rmap entry (a
    # reclaim candidate); 0 otherwise (shared/COW, unmapped, or untracked).
    pfn: uint64 = page_pfn(phys)
    if rmap_has_mapper(page_rmap(pfn)) == 0:
        return 0
    if page_mapcount(pfn) != 1:
        return 0
    return 1

# mm/vma.ad
#
# Per-task VMA (Virtual Memory Area) layer. First real address-space
# bookkeeping in Hamnix — replaces the flat 256-slot (base, order)
# table that linux_abi/u_syscalls.ad has been using since U7. The slot
# table was good enough for MAP_ANONYMOUS|MAP_PRIVATE and for ld.so's
# "reserve then MAP_FIXED overlay" two-phase DSO load, but couldn't
# honour MAP_FIXED at arbitrary user-chosen addresses — and that's
# exactly what dynamic Linux binaries expect from mmap once ld.so
# transfers control to the application's _start.
#
# Plan 9 framing
#
#   Per docs/architecture.md + memory/feedback_plan9_namespace_framing,
#   the VMA list is NOT a global "kernel memory map" — it is a per-task
#   namespace of virtual-address contents, in the same shape as `/` is
#   a per-task namespace of names. There is no master vma table that
#   the kernel consults out-of-band; the only ground truth about
#   "what is mapped where" is whatever the current task's vma_list
#   says. Forks (rfork RFPROC without RFMEM) give the child its own
#   VMA list mirroring the parent's, with every mmap page COPY-ON-WRITE
#   shared (see vma_fork_copy); the thread path (RFMEM) shares the list
#   itself. Init's task is born with an empty list; every subsequent
#   VMA is created either by mmap from userspace or by the ELF loader
#   on do_execve.
#
# Shape (Wave-3: Linux-parity interval tree + per-VMA locking)
#
#   Each VmaNode owns the half-open range [start, end); adjacent nodes
#   do not overlap. The set is indexed TWO ways that are kept consistent:
#
#     * an augmented AVL INTERVAL TREE keyed on `start`, augmented with
#       subtree_max_end (MAX(end) over a subtree). This gives O(log n)
#       find_vma / overlap / mmap-gap search — the "maple-tree-shape"
#       capability that replaces the old O(N) linear scan. (_vt_* /
#       _vma_tree_* below; root per-task in vma_tree_root[slot].)
#     * the original sorted singly-linked `next` list, retained PURELY as
#       the in-order ITERATOR every consumer walks (coredump, /proc/maps,
#       fork copy, teardown). The tree is the index; the list is the
#       iterator. _vma_insert_sorted / _vma_unlink mutate both atomically.
#
#   Locking (Linux's per-VMA lock model). Each VmaNode carries its own
#   per-VMA spinlock (`vlock`); each mm (task slot) carries a write
#   spinlock (vma_mm_lock) + a seqcount (vma_mm_seq). A page fault
#   RCU-looks-up the covering VMA in the tree and TRYLOCKS just that VMA
#   (vma_lock_fault_vma) — a fault on VMA A proceeds concurrently with a
#   fault on VMA B because they hold DIFFERENT per-VMA locks. If the
#   trylock loses or the mm seqcount moved (a split/remove raced the
#   lookup) the fault falls back to the mm-wide write lock — exactly
#   Linux's lock_vma_under_rcu -> mmap_read_lock. STRUCTURAL changes
#   (insert / unlink / split / merge / grow) run under the mm write lock
#   and bump the seqcount so an in-flight lockless lookup retries.
#
# Backing memory
#
#   Today every page is RWX U=1 in the 4 GiB identity map. Per-VMA
#   `prot` is therefore advisory at the page-table level — we record
#   it for future per-page mprotect wiring but the page fault handler
#   doesn't consult it yet.
#
#   Pages are allocated EAGERLY at vma_alloc time via alloc_pages —
#   not lazily on first touch. Demand-paging through a #PF handler
#   would require touching arch/x86/kernel/idt.ad which is locked
#   under this commit; eager allocation is the correct trade-off
#   given the constraint.
#
# Allocator
#
#   VmaNode records are kmalloc'd (56 bytes per node after struct
#   padding). Backing pages come from alloc_pages at the order that
#   covers the page-rounded length.

from kernel.printk.printk import (
    printk0, printk1, printk2, printk3, printk_set_level,
    PRINTK_LEVEL_NOTICE, PRINTK_LEVEL_WARN, PRINTK_LEVEL_EMERG,
)
from kernel.sched.core import (
    TaskStruct,
    task_vma_list_head, set_task_vma_list_head,
    task_vma_list_head_raw, set_task_vma_list_head_raw,
    current_idx_get, task_pml4,
    spinlock_lock, spinlock_unlock, spinlock_trylock,
    current_task, task_fd_opened_path_ptr,
    task_is_linux_userspace_at, task_last_syscall_jiffies,
    task_wd_last_dump_jiffies, set_task_wd_last_dump_jiffies,
    task_image_lo, task_image_hi, task_interp_lo, task_interp_hi,
    task_ustack_lo, task_ustack_sz,
    dump_linux_task_states, call_linux_futex_dump, task_last_syscall_nr,
    linux_group_status, dump_linux_group_full, linux_max_thread_group,
    NTASKS,
)
# Linux-ABI no-syscall watchdog: jiffies clock + tick-hook registration.
# arch.time imports only from core (no mm.* symbol), so this is acyclic.
from arch.x86.kernel.time import get_jiffies, register_linux_nosyscall_wd_hook
# Non-faulting user-address resolve: read a few userspace stack words at the
# pinned RIP WITHOUT triggering a demand fault-in (we run in timer-IRQ
# context and must not take the fault-path mm locks).
from mm.uaccess import uaccess_resolve, uaccess_current_pml4
# Wave-3 per-VMA / RCU lookup (Linux-parity VMA scalability). The fault
# path RCU-looks-up a VMA in the O(log n) interval tree, then per-VMA-
# trylocks it so a fault on VMA A proceeds concurrently with a fault on
# VMA B; structural changes (insert/unlink/split/merge) take the mm-wide
# write lock and bump the mm seqcount so an in-flight lockless lookup
# detects the race and retries under the write lock. rcu.ad imports only
# from arch + its own pool (no mm.* import), so this is acyclic.
from kernel.rcu.rcu import (
    rcu_read_lock, rcu_read_unlock,
)
from arch.x86.kernel.setup_percpu import get_cpu_id
from mm.slab import kmalloc, kfree
from mm.page_alloc import alloc_pages, alloc_page, free_pages, free_page
from mm.cow import cow_drop_page, cow_pte_bit, cow_boot_cr3, \
    cow_ref_inc, cow_refcount
from mm.swap import (
    swap_out_page, swap_make_pte, swap_ready,
    swap_pte_is_swap, swap_pte_slot, swap_in_page,
)
# rmap / LRU integration (#mm-parity): every anonymous demand page is
# recorded in the reverse map (which task + va maps which physical frame)
# and placed on the inactive LRU so the watermark-driven reclaimer
# (mm/kswapd.ad → mm/reclaim.ad::reclaim_shrink_lru) can find and evict the
# coldest single-mapper pages without walking every task's page tables.
from mm.rmap import (
    page_add_anon_rmap, page_remove_rmap, page_is_anon,
)
from mm.lru import (
    lru_add_anon, lru_remove, mark_page_accessed,
)
# writeback accounting (#mm-parity): MAP_SHARED file-backed dirty pages are
# accounted as they are flushed so the dirty/writeback page counters reflect
# real in-flight write-back; balance_dirty_pages (mm/writeback.ad) throttles
# a dirtier when the dirty count crosses the dirty_ratio threshold.
from mm.writeback import (
    set_page_dirty, set_page_writeback, end_page_writeback, clear_page_dirty,
)
from fs.elf import (
    elf_install_user_mapping, vm_cow_share_range,
    vm_share_range, vm_protect_range, vm_pin_range,
    elf_prepare_demand_range, elf_map_one_page,
    elf_prepare_huge_demand_range, elf_map_one_huge_pde,
    PT_FLAG_NX, PT_FLAG_RW, PT_FLAG_COW,
)
# §file-mmap: identity-based kernel pread for file-backed VMA fault-in.
# fs.elf already imports from fs.vfs, so fs.vfs's symbols are in the
# merged namespace; importing vfs_pread_backing here is consistent (no
# new cycle). vma_demand_fault's is_file branch calls it to read a page's
# bytes from the backing file; bytes past file_size are left zero by the
# caller's pre-zeroing of the page.
from fs.vfs import vfs_pread_backing, vfs_pwrite_backing, \
    vfs_backing_page_phys, vfs_backing_extend_size
# SMAP bracket primitives. A CPL=0 write THROUGH a user (US=1) virtual
# address — e.g. zero-filling a MAP_FIXED|MAP_ANONYMOUS overlay via the
# user VA — is denied by CR4.SMAP unless EFLAGS.AC is set. _ua_stac /
# _ua_clac are the gated STAC/CLAC pair (no-op when SMAP is inactive).
from mm.uaccess import _ua_stac, _ua_clac

extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]
extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]
extern def load_cr3(value: uint64)
extern def read_cr3() -> uint64
extern def local_irq_disable()
extern def local_irq_enable()
# Nesting-safe IRQ save/restore (see fs/elf.ad for rationale).
extern def local_irq_save() -> uint64
extern def local_irq_restore(flags: uint64)
extern def invlpg_one(va: uint64)


# Boot-CR3 bracketed zero of a freshly-allocated physical frame (>4GB
# aliasing fix). A demand/COW page allocated from >4 GiB RAM aliases a live
# user mapping under the live task CR3, so zeroing it via its bare physical
# identity address either #PFs (aliased VA absent) or silently corrupts the
# wrong frame (aliased VA present). Zero it under the boot CR3's complete,
# un-aliased 1 GiB-huge identity. IRQs off only for the bounded memset.
def _vma_zero_phys(phys: uint64, n: uint64):
    _s: uint64 = read_cr3()
    _b: uint64 = cow_boot_cr3()
    _f: uint64 = 0
    if _b != 0:
        _f = local_irq_save()
        load_cr3(_b)
    memset(cast[Ptr[uint8]](phys), 0, n)
    if _b != 0:
        load_cr3(_s)
        local_irq_restore(_f)

# #174: per-namespace memory caps. nscap_mem_charge_slot /
# nscap_mem_uncharge_slot live in sys/src/9/port/chan.ad (alongside the
# Pgrp struct that holds the cap + the running residency count). The mm
# layer charges a page-in / uncharges a free against the faulting task's
# namespace. chan.ad imports from kernel.sched.core + mm.slab (NOT mm.vma),
# so this import is acyclic.
#
#   nscap_mem_charge_slot(slot, nbytes)  -> 0 ok / -1 over-cap (NOT charged)
#   nscap_mem_uncharge_slot(slot, nbytes)
# `slot` is the task slot index; the helper resolves its Pgrp. A slot
# whose namespace is uncapped always succeeds. The byte total is tracked
# either way so /dev/nscap reports live residency.
from sys.src.port9.port.chan import (
    nscap_mem_charge_slot, nscap_mem_uncharge_slot,
)

# ---------------------------------------------------------------------
# cgroup v2 memory.max enforcement hook
# ---------------------------------------------------------------------
#
# The charge -> reclaim -> cgroup-OOM orchestration lives in
# mm/reclaim.ad (it imports both the cgroup accounting module AND the
# reclaim/swap/OOM machinery). vma.ad cannot import reclaim.ad (reclaim
# imports vma -> cycle), so reclaim.ad REGISTERS its enforcer here at
# boot via register_memcg_charge_hook(). The demand-fault path calls it
# per faulted page, exactly where the per-namespace cap (#174) is
# charged. A NULL hook (pre-registration / cgroup module absent) means
# "no cgroup memory enforcement" — charge succeeds unconditionally.
#
# Signature: int64 (*)(uint64 task_slot, uint64 bytes)
#   returns 0 to allow (charge applied), <0 (-ENOMEM) to deny the fault.
memcg_charge_hook: Fn[int64, uint64, uint64]


def register_memcg_charge_hook(hook: Fn[int64, uint64, uint64]):
    memcg_charge_hook = hook


def _memcg_charge_page(slot: uint64, bytes: uint64) -> int64:
    # Thin dispatcher: invoke the registered cgroup memcg enforcer, or
    # allow (0) if none is registered.
    if memcg_charge_hook == cast[Fn[int64, uint64, uint64]](0):
        return 0
    return memcg_charge_hook(slot, bytes)


# ---------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------

# MAP_* flag bits. Mirror Linux <bits/mman-linux.h>. Same numeric
# values defined locally in linux_abi/u_syscalls.ad (kept in sync by
# hand — the two files import from each other not at all).
VMA_MAP_SHARED:    int32 = 0x01
VMA_MAP_PRIVATE:   int32 = 0x02
VMA_MAP_FIXED:     int32 = 0x10
VMA_MAP_ANONYMOUS: int32 = 0x20
# MAP_HUGETLB: back this anonymous mapping with 2 MiB huge pages (one
# PS=1 PDE per 2 MiB, a single TLB entry) instead of 512 4 KiB pages.
# Mirrors Linux <bits/mman-linux.h> MAP_HUGETLB (0x40000). The default
# huge size is 2 MiB (Linux's MAP_HUGE_2MB); the length and a non-zero
# MAP_FIXED addr must both be 2 MiB-aligned, matching hugetlbfs.
VMA_MAP_HUGETLB:   int32 = 0x40000

# 2 MiB huge page geometry. VMA_HUGE_ORDER is the buddy-allocator order
# (mm/page_alloc.ad) whose run is exactly 2 MiB: 2^9 × 4 KiB = 512 pages
# = 0x200000. alloc_pages(VMA_HUGE_ORDER) returns a 2 MiB-aligned,
# physically-contiguous run (memblock_alloc aligns to the run width),
# which is exactly what a single PS=1 PDE needs.
VMA_HUGE_SIZE:  uint64 = 0x200000          # 2 MiB
VMA_HUGE_ORDER: int32  = 9                 # 2^9 pages == 2 MiB

# HugePages accounting (observable, e.g. /proc/meminfo HugePages_*).
# nr_hugepages_total: 2 MiB huge PDEs ever installed by a demand fault.
# nr_hugepages_live: currently-mapped 2 MiB huge pages (incremented on
# install, decremented on teardown). Both are simple counters a test or
# procfs node can read to PROVE a real 2 MiB PDE was used (not 512 4 KiB
# pages).
nr_hugepages_total: uint64 = 0
nr_hugepages_live:  uint64 = 0

# PROT_* — stored but not yet honoured by the page table.
VMA_PROT_NONE:  int32 = 0x0
VMA_PROT_READ:  int32 = 0x1
VMA_PROT_WRITE: int32 = 0x2
VMA_PROT_EXEC:  int32 = 0x4

VMA_PAGE_SIZE: uint64 = 0x1000


def _vma_nx_flag(prot: int32) -> uint64:
    # W^X Stage 1a: an anonymous mmap is non-executable DATA UNLESS the
    # caller explicitly asked for PROT_EXEC. Return PT_FLAG_NX (bit 63)
    # for a data mapping, 0 for an exec mapping (e.g. a JIT that mmap'd
    # PROT_READ|PROT_WRITE|PROT_EXEC). Mirrors Linux's mmap NX default.
    if (prot & VMA_PROT_EXEC) != 0:
        return 0
    return PT_FLAG_NX


def _vma_rw_flag(prot: int32) -> uint64:
    # W^X prot-write: a mapping is WRITABLE at the PTE level only when
    # the caller asked for PROT_WRITE. Return PT_FLAG_RW (bit 1) for a
    # writable mapping, 0 for a read-only one. Mirrors _vma_nx_flag so
    # the two compose into one `extra_flags` value for the eager
    # installer: `_vma_nx_flag(prot) | _vma_rw_flag(prot)`. A
    # PROT_READ-only mmap therefore clears RW and a store to it faults
    # (SIGSEGV) instead of silently succeeding.
    if (prot & VMA_PROT_WRITE) != 0:
        return PT_FLAG_RW
    return 0

# Buddy allocator MAX_ORDER (mm/page_alloc.ad) is 10 -> the largest
# single alloc_pages call covers 2^10 pages = 4 MiB. A VMA whose
# page-rounded length exceeds this is backed by MULTIPLE buddy chunks
# (each up to 4 MiB) mapped at consecutive virtual addresses so the
# VMA still presents one contiguous virtual range. See vma_alloc.
VMA_MAX_ORDER:    int32  = 10
VMA_MAX_CHUNK:    uint64 = 0x400000          # 4 MiB == 2^MAX_ORDER pages

# A multi-chunk VMA owns an array of VmaChunk descriptors (one per
# buddy allocation). Each descriptor is 16 bytes; the array is kmalloc'd
# and pointed to by VmaNode.chunks. Single-chunk / alias VMAs leave
# chunks == 0 and nchunks == 0 and use the legacy backing/order fields.
VMA_CHUNK_SIZE:   uint64 = 16

# x86_64 page-table constants — mirror fs/elf.ad's PT_FLAG_* / PT_ADDR_MASK.
# Used by the COW-aware free path (_vma_pte_lookup / _vma_free_cow_range)
# to walk a task's PML4 and read the physical page behind each VMA page.
VMA_FD_TMPFS_MARK: uint32 = 0xFFFFFFFA           # mirror of FD_TMPFS_MARK
VMA_PT_FLAG_P:    uint64 = 0x1                   # Present
VMA_PT_FLAG_PS:   uint64 = 0x80                  # Page-Size (huge leaf)
VMA_PT_ADDR_MASK: uint64 = 0x000FFFFFFFFFF000    # bits [51:12]: phys base

# Virtual-address window for multi-chunk VMAs.
#
# A single-chunk VMA returns its buddy chunk's physical/identity
# address as the VMA base — the buddy allocator owns that physical
# run exclusively, so the VMA's virtual range can never be re-handed
# to another allocation. A multi-chunk VMA can't do that: its virtual
# range [base, base+length) is far larger than chunk 0's 4 MiB, and
# the buddy allocator would happily hand the physical pages sitting
# under [base+4MiB, base+length) to the NEXT large mmap — two VMAs
# would then overlap virtually and corrupt each other.
#
# So multi-chunk VMAs live in a DEDICATED virtual window. Its cardinal
# requirement: NO physical kernel RAM may sit behind the window's identity
# mapping, or a user overlay would SHADOW a kernel object at the same VA.
#
# The window WAS at [1 GiB, 4 GiB) on the assumption "RAM is far under
# 1 GiB". That is FALSE on the shipping 4 GiB (QEMU_MEM=4G) guest: buddy/
# slab kernel objects (e.g. VmaNode records) land in phys [1 GiB, 4 GiB),
# identity-mapped there, and a heavy client (weston-terminal: ~45 DSO maps)
# marches the window bump pointer up into that same VA. The user library
# overlay then rewrites the leaf PTE for a live VmaNode's page (US=1, a
# different phys), so the kernel's next deref of node->next under the task
# CR3 reads library bytes / SMAP-faults (observed: #PF err=1 US=1 at
# vma_insert_sorted, cr2 in [1 GiB,4 GiB); the same class as the resolved
# ET_DYN/brk direct-map aliasing).
#
# FIX: base the window at 8 GiB — ABOVE physical RAM top AND above every
# other user region (image [4,5) GiB, interp [5,6) GiB, brk [6,6.03) GiB,
# stack 7 GiB). There is no kernel RAM behind identity at [8 GiB, 16 GiB),
# so a user overlay there can never shadow a kernel object — restoring the
# original "no physical RAM behind the window's identity mapping" invariant
# for guests of any size. elf_install_user_mapping already installs the
# above-RAM image/interp/brk/stack regions (4-7 GiB) through the same
# absent-PDPT path, so an 8-16 GiB window uses the identical machinery. A
# monotonic bump pointer carves 4-MiB-aligned windows out of it (freed
# windows reclaimed via the per-task free-list below).
VMA_LARGE_BASE:   uint64 = 0x200000000          # 8 GiB (above RAM + all user regions)
VMA_LARGE_LIMIT:  uint64 = 0x3FFC00000          # just under 16 GiB (~8 GiB window)


# PER-TASK bump pointer for the next free multi-chunk virtual window.
# 4-MiB-aligned so every 4-MiB chunk install stays within one 1 GiB PDPT
# entry (elf_install_user_mapping refuses a range crossing 1 GiB).
#
# WAS a single module-global. That was an SMP correctness bug: it is
# RESET per-exec by vma_set_mmap_base() (do_execve) AND read-modify-
# written by _vma_win_alloc(), with no lock. Under -smp 2, the
# `ls | grep cat` pipeline forks two children that exec CONCURRENTLY on
# both CPUs (a load only reachable now that T62/T64 fixed fork-EAGAIN);
# one task's exec clobbered the global mid-sequence of another task's
# windowed-mmap allocations, so a task could be handed two windows that
# OVERLAP within its own address space (or a stale base), corrupting its
# VMA interval tree / leaf PTEs and surfacing as an intermittent
# not-present SIGSEGV at an mmap-window address (busybox fault at
# mmap_base+0x400248, captured by test_fork_eagain_pipeline.sh).
#
# Each address space owns its own cursor now (Linux's mm->mmap_base
# model), matching the already-per-task windowed free-list below. A task
# runs on one CPU at a time, so per-task access needs no extra lock. A 0
# entry means "never initialized" and reads back as VMA_LARGE_BASE; every
# exec sets a real value via vma_set_mmap_base() before the first mmap,
# and fork copies the parent's cursor (vma_fork_copy) so a fork-without-
# exec child never hands out a window overlapping an inherited VMA.
NR_TASKS_VLN:      uint64 = 512
vma_large_next_arr: Array[512, uint64]

# ---------------------------------------------------------------------
# Thread address-space sharing (CLONE_VM / rfork RFMEM) — mm ownership.
# ---------------------------------------------------------------------
#
# A THREAD shares its creator's PML4 (page tables) but is a SEPARATE task
# slot. Historically each slot carried its OWN VMA list, window cursor
# (vma_large_next_arr), window free-list, interval tree and mm lock — so
# two threads mmap()ing concurrently BOTH bumped their own cursor from
# VMA_LARGE_BASE and installed OVERLAPPING windows into the shared PML4;
# tearing one down then zapped the other's live leaf PTEs -> the
# non-deterministic Firefox `is_demand=0 nchunks=1 leaf PTE=0` SIGSEGV in
# ld.so (a thread reading a sibling-thread arena whose window a third
# thread's munmap had just cleared). The reap-time vma_adopt merge only
# fixed it AFTER a thread died, never during concurrent life.
#
# Fix: all VMA bookkeeping is keyed by the mm OWNER slot, shared across a
# thread group. `vma_mm_group[slot]` holds (owner_slot + 1); 0 means "no
# owner set -> self". A thread records its creator's owner at creation
# (vma_set_mm_owner); every per-slot VMA accessor routes slot -> owner via
# _vma_owner, so a whole thread group allocates from ONE cursor + ONE list
# + ONE tree under ONE lock and can never collide. On owner death with a
# live sibling, vma_adopt MIGRATES the raw owner-slot state to the heir and
# repoints the group (see vma_adopt).
vma_mm_group: Array[512, uint64]


def _vma_owner(slot: uint64) -> uint64:
    # Resolve `slot` to the slot that owns its mm side-state. 0 == unset
    # (a process / non-thread) -> the slot owns its own mm.
    o: uint64 = vma_mm_group[slot]
    if o == 0:
        return slot
    return o - 1


def vma_group_owner(slot: uint64) -> uint64:
    # PUBLIC wrapper around _vma_owner (module-private) so kernel/sched/
    # core.ad's task_vma_list_head accessor can route a thread slot to its
    # mm-group owner. Same resolution: 0-link -> self.
    return _vma_owner(slot)


def vma_set_mm_owner(slot: uint64, creator: uint64):
    # Record that `slot` (a freshly created thread) shares `creator`'s mm.
    # Collapse the chain to the real owner so a thread-of-a-thread still
    # points at the single group owner.
    vma_mm_group[slot] = _vma_owner(creator) + 1


def vma_reset_mm_owner(slot: uint64):
    # Clear `slot`'s mm-owner link (task reap / slot reuse) so a recycled
    # slot starts as its own owner again.
    vma_mm_group[slot] = 0


def _vma_large_next(slot: uint64) -> uint64:
    o: uint64 = _vma_owner(slot)
    v: uint64 = vma_large_next_arr[o]
    if v == 0:
        return VMA_LARGE_BASE
    return v


def _vma_ln_set(slot: uint64, v: uint64):
    vma_large_next_arr[_vma_owner(slot)] = v

# ---------------------------------------------------------------------
# Windowed-VA RECLAIM free-list (per-task) — apt shared-object exhaustion
# ---------------------------------------------------------------------
#
# EVERY non-fixed mmap (file AND anonymous, ANY size) is routed through the
# windowed installer (_vma_alloc_large / _vma_alloc_*_demand / _file_shared)
# so it gets proper US=1 leaf PTEs in the [1 GiB, 4 GiB) window — see the
# big comment at vma_alloc. Each request is rounded UP to a 4 MiB window
# slice (the buddy MAX_ORDER chunk + the 1 GiB-PDPT alignment constraint),
# and `vma_large_next` is a MONOTONIC bump pointer that historically never
# reclaimed a freed window.
#
# That leaks ~4 MiB of window VA PER mmap and never gives it back. dpkg's
# short run with a handful of DSO maps never noticed. apt is C++ and does
# THOUSANDS of mmaps in one process — glibc malloc arenas + per-allocation
# MMAP_THRESHOLD blocks + libstdc++ exception tables + each dlopen'd apt
# method — so it marches `vma_large_next` toward VMA_LARGE_LIMIT and then
# _vma_alloc_large returns -ENOMEM. ld.so's NEXT PT_LOAD-segment mmap of
# libapt-pkg.so fails -> glibc prints "failed to map segment from shared
# object" and apt aborts. (Same global counter is shared across the apt ->
# method/dpkg fork tree, so it drains even faster.) This is the root cause
# of the apt-vs-dpkg divergence — NOT a per-segment ELF-layout bug.
#
# Fix: a PER-TASK free-list of released 4-MiB-aligned window extents.
# vma_unmap (and execve/teardown via vma_clear) push a freed windowed
# extent back here AFTER confirming no VMA of the freeing task still
# overlaps it (safety: a window slice that still holds a sibling split
# piece — RELRO mprotect, partial munmap — is NOT recycled). The window
# allocators try this list (first-fit, split-remainder-reinsert) BEFORE
# bumping vma_large_next, so a process's steady-state working set of
# windowed mappings is bounded by its LIVE footprint, not its lifetime
# mmap COUNT. Per-task (not global) keeps the VA-reuse safety trivial:
# each PML4 is independent, so a task only ever reuses its OWN freed VAs,
# and _vma_tree_overlap(slot, ...) is exactly the right liveness check.
VMA_WIN_FREE_PER_TASK: uint64 = 64
# Parallel (base, size) extent arrays, NR_TASKS_VMA * VMA_WIN_FREE_PER_TASK.
# base == 0 marks an empty slot.
g_vma_win_free_base: Array[32768, uint64]    # 512 * 64
g_vma_win_free_size: Array[32768, uint64]


def _vma_win_free_reset(slot: uint64):
    # Drop the whole free-list for `slot` (execve / teardown). The window
    # VAs themselves are released by vma_clear's per-node free; this just
    # forgets the cached extents so a re-exec'd task starts clean.
    base_i: uint64 = _vma_owner(slot) * VMA_WIN_FREE_PER_TASK
    i: uint64 = 0
    while i < VMA_WIN_FREE_PER_TASK:
        g_vma_win_free_base[base_i + i] = 0
        g_vma_win_free_size[base_i + i] = 0
        i = i + 1


def _vma_win_free_push(slot: uint64, base: uint64, size: uint64):
    # Return a 4-MiB-aligned windowed extent [base, base+size) to `slot`'s
    # free-list. Coalesces with an adjacent existing extent when possible
    # (keeps multi-window allocs satisfiable). On a full list the extent is
    # simply dropped — correctness is preserved (it just isn't reclaimed),
    # the monotonic bump pointer still backstops fresh allocations.
    if base < VMA_LARGE_BASE or size == 0:
        return
    base_i: uint64 = _vma_owner(slot) * VMA_WIN_FREE_PER_TASK
    end: uint64 = base + size
    # Dedup pass: never record a window VA that already sits (wholly or
    # partly) inside an existing free extent — a double-push (two munmaps
    # in the same already-emptied window) would otherwise let _pop hand the
    # same VA out twice and alias two live mappings.
    d: uint64 = 0
    while d < VMA_WIN_FREE_PER_TASK:
        db: uint64 = g_vma_win_free_base[base_i + d]
        if db != 0:
            de: uint64 = db + g_vma_win_free_size[base_i + d]
            if base < de and db < end:
                return
        d = d + 1
    # Tail rollback: if this extent sits at the very top of THIS TASK's bump
    # pointer, give it back to the cursor instead of caching it. The cursor
    # is monotonic per-task, so its tail == the highest VA this task ever
    # handed out; rolling it back recovers the VA for this task's next
    # allocation — the common LIFO unmap pattern (glibc maps then frees its
    # top arena/DSO).
    if end == _vma_large_next(slot):
        _vma_ln_set(slot, base)
        # The roll-back may now make the PREVIOUS free-list tail extent
        # contiguous with the global pointer too; sweep once to pull any
        # such cached extents back into the counter.
        progress: int32 = 1
        while progress != 0:
            progress = 0
            k: uint64 = 0
            while k < VMA_WIN_FREE_PER_TASK:
                kb: uint64 = g_vma_win_free_base[base_i + k]
                if kb != 0:
                    ke: uint64 = kb + g_vma_win_free_size[base_i + k]
                    if ke == _vma_large_next(slot):
                        _vma_ln_set(slot, kb)
                        g_vma_win_free_base[base_i + k] = 0
                        g_vma_win_free_size[base_i + k] = 0
                        progress = 1
                k = k + 1
        return
    # Coalesce pass: try to extend an existing adjacent extent.
    i: uint64 = 0
    while i < VMA_WIN_FREE_PER_TASK:
        eb: uint64 = g_vma_win_free_base[base_i + i]
        if eb != 0:
            es: uint64 = g_vma_win_free_size[base_i + i]
            ee: uint64 = eb + es
            if ee == base:
                g_vma_win_free_size[base_i + i] = es + size
                return
            if end == eb:
                g_vma_win_free_base[base_i + i] = base
                g_vma_win_free_size[base_i + i] = size + es
                return
        i = i + 1
    # No coalesce: take the first empty slot.
    j: uint64 = 0
    while j < VMA_WIN_FREE_PER_TASK:
        if g_vma_win_free_base[base_i + j] == 0:
            g_vma_win_free_base[base_i + j] = base
            g_vma_win_free_size[base_i + j] = size
            return
        j = j + 1
    # List full: drop it (bump pointer backstops).
    return


def _vma_win_free_pop(slot: uint64, window: uint64) -> uint64:
    # First-fit: find a free extent >= `window` (a 4-MiB-aligned size),
    # carve `window` off its FRONT, reinsert the remainder, and return the
    # carved base. Returns 0 if no extent is large enough (caller then
    # bumps vma_large_next).
    base_i: uint64 = _vma_owner(slot) * VMA_WIN_FREE_PER_TASK
    i: uint64 = 0
    while i < VMA_WIN_FREE_PER_TASK:
        eb: uint64 = g_vma_win_free_base[base_i + i]
        if eb != 0:
            es: uint64 = g_vma_win_free_size[base_i + i]
            if es >= window:
                if es == window:
                    g_vma_win_free_base[base_i + i] = 0
                    g_vma_win_free_size[base_i + i] = 0
                else:
                    g_vma_win_free_base[base_i + i] = eb + window
                    g_vma_win_free_size[base_i + i] = es - window
                return eb
        i = i + 1
    return 0


def _vma_win_alloc(slot: uint64, window: uint64) -> uint64:
    # Acquire a 4-MiB-aligned, `window`-byte windowed VA range: reuse a
    # freed extent if one fits, else bump vma_large_next. Returns the base
    # or 0 on exhaustion. `window` MUST already be 4-MiB-rounded.
    reuse: uint64 = _vma_win_free_pop(slot, window)
    if reuse != 0:
        return reuse
    base: uint64 = _vma_large_next(slot)
    if base + window > VMA_LARGE_LIMIT:
        return 0
    _vma_ln_set(slot, base + window)
    return base


def _vma_win_release_unmap(slot: uint64, lo_in: uint64, hi_in: uint64):
    # After a carve/unmap of [lo_in, hi_in), scan its 4-MiB-aligned windowed
    # sub-extents and return to the free-list every WHOLE 4-MiB window the
    # freeing task no longer overlaps. Only the windowed portion (>= 1 GiB)
    # is considered; low identity mappings are never windowed.
    lo: uint64 = lo_in
    if lo < VMA_LARGE_BASE:
        lo = VMA_LARGE_BASE
    if hi_in <= lo:
        return
    # Snap to the enclosing whole 4-MiB windows: lo DOWN, hi UP. A windowed
    # mmap reserves a 4-MiB-rounded slice but the user's munmap length is
    # the UNROUNDED request (e.g. glibc maps then unmaps a 16 KiB region
    # whose window is a full 4 MiB) — so the freed range rarely covers a
    # whole window by length alone. Expanding to the enclosing windows and
    # then gating EACH candidate on _vma_tree_overlap(slot, ...) == 0 makes
    # reclaim fire for that common case while staying SAFE: a window is
    # recycled only when NO live VMA of this task still touches it. Since
    # every windowed alloc takes its OWN 4-MiB-rounded base (windows are
    # never shared between two VMAs), overlap==0 is exact.
    w_lo: uint64 = lo & ~(VMA_MAX_CHUNK - 1)
    w_hi: uint64 = (hi_in + VMA_MAX_CHUNK - 1) & ~(VMA_MAX_CHUNK - 1)
    # _vma_tree_overlap is a tree WALK; hold the mm write lock so it never
    # races a concurrent structural mutation on this mm (same #DF hazard the
    # fault reader faces).
    vma_mm_write_lock(slot)
    cur: uint64 = w_lo
    while cur + VMA_MAX_CHUNK <= w_hi:
        if cur >= VMA_LARGE_BASE \
                and _vma_tree_overlap(slot, cur, cur + VMA_MAX_CHUNK) == 0:
            _vma_win_free_push(slot, cur, VMA_MAX_CHUNK)
        cur = cur + VMA_MAX_CHUNK
    vma_mm_write_unlock(slot)


# ---------------------------------------------------------------------
# U52 — mmap-base ASLR.
#
# Every windowed mmap (large eager anon, demand-paged anon, file-shared)
# is handed out from the [1 GiB, 4 GiB) window starting at vma_large_next.
# Each of those paths already establishes vaddr != phys correctly — the
# eager large path OVERLAYS its alloc_pages chunks at the window vaddr via
# elf_install_user_mapping (kernel writes go to the identity-mapped phys
# chunk, never the window vaddr), and the demand path faults a fresh
# alloc_page in at the faulting window vaddr. So perturbing the window
# START randomizes the mmap base with NO new raw-deref hazard: no kernel
# code dereferences the window vaddr directly.
#
# vma_set_mmap_base() slides the start of the window UP by a caller-chosen
# random, 4-MiB-aligned amount (do_execve draws it from aslr_mmap_slide()).
# The slide is bounded so the window keeps ample room below VMA_LARGE_LIMIT
# for real allocations (glibc 64 MiB malloc arenas, ld.so DSO maps, 8 MiB
# pthread stacks). MAP_FIXED is unaffected — it never consults
# vma_large_next, so an explicit user-requested address is still honoured
# exactly.
#
# Reserve 0..VMA_MMAP_ASLR_SLIDE_MAX (256 MiB) of slide; that leaves at
# least ~2.7 GiB of window for allocations, well beyond any real workload.
VMA_MMAP_ASLR_SLIDE_MAX: uint64 = 0x10000000     # 256 MiB
VMA_MMAP_ALIGN:          uint64 = 0x400000        # 4 MiB


def vma_set_mmap_base(slot: uint64, slide: uint64):
    # Set the EXEC'ing task's mmap-window start to VMA_LARGE_BASE +
    # (4-MiB-aligned slide), clamped so the window never starts above the
    # reserved entropy band. Called by do_execve once per exec; slide == 0
    # restores the exact pre-ASLR base (deterministic / aslr_disabled boot).
    # Per-task: clobbering one task's cursor here no longer corrupts a
    # concurrently-exec'ing sibling's windowed-mmap layout on another CPU.
    s: uint64 = slide & ~(VMA_MMAP_ALIGN - 1)
    if s > VMA_MMAP_ASLR_SLIDE_MAX:
        s = VMA_MMAP_ASLR_SLIDE_MAX
    _vma_ln_set(slot, VMA_LARGE_BASE + s)

# Memory-leak accounting: live VmaNode count. Incremented in
# _vma_node_new, decremented in _vma_node_free. A spawn/reap cycle
# that leaks nodes would show monotonic growth here.
nr_vma_nodes_live: uint64 = 0


# ---------------------------------------------------------------------
# Wave-3 — per-mm interval-tree root + locking side tables
# ---------------------------------------------------------------------
#
# kernel/sched/core.ad (off-limits to this change) gives each task ONE
# per-task uint64 — vma_list_head — which we keep as the in-order linked
# list head. The Linux-parity index (the balanced interval tree) and the
# locking state need a few more per-task words, so mm/ keeps them in
# module-global side arrays keyed by task slot (NR_TASKS == 512, matching
# task_table). These mirror an mm_struct's vma tree-root + mmap_lock +
# the per-mm seqcount that Linux's lockless VMA lookup spins on.
#
#   vma_tree_root[slot]  : root VmaNode* of slot's AVL interval tree
#                          (0 == empty). The list head and the tree root
#                          are kept consistent: every node in the list is
#                          in the tree and vice-versa.
#   vma_mm_lock[slot]    : the mm-wide WRITE spinlock. Held across any
#                          STRUCTURAL change (insert/unlink/split/merge/
#                          grow) so the tree + list mutate atomically vs.
#                          a concurrent structural op on the same mm and
#                          vs. a fault that fell back to the write side.
#   vma_mm_seq[slot]     : the mm seqcount. Bumped ODD at the start of a
#                          structural change and EVEN at the end, so an
#                          in-flight lockless fault lookup
#                          (vma_lock_fault_vma) that read an odd or
#                          changed value knows the tree shifted under it
#                          and retries under the write lock.
NR_TASKS_VMA: uint64 = 512
vma_tree_root: Array[512, uint64]
vma_mm_lock:   Array[512, uint32]
vma_mm_seq:    Array[512, uint64]
# Recursive-lock bookkeeping for vma_mm_write_lock: the owning logical CPU
# (+1, 0 == unowned) and the recursion depth. A structural mutator that
# nests another mutator (vma_mremap -> vma_alloc/_vma_carve_range) re-takes
# the SAME slot's lock; recording owner+depth lets the re-acquire by the
# owning CPU pass through instead of self-deadlocking on the raw spinlock.
vma_mm_owner:  Array[512, uint64]
vma_mm_depth:  Array[512, uint64]
# DBG-VTREE: live recursion depth of _vt_insert_rec — a cheap cycle tripwire
# (a balanced AVL never exceeds ~1.44*log2(n) frames). Single-writer under
# the mm write lock the tree mutators hold, so a plain global is fine.
_vt_insert_depth: uint64


def _vma_tree_root(slot: uint64) -> uint64:
    return vma_tree_root[_vma_owner(slot)]


def _vma_set_tree_root(slot: uint64, r: uint64):
    vma_tree_root[_vma_owner(slot)] = r


def vma_mm_write_lock(slot: uint64):
    # Acquire the mm-wide write lock. This serializes ALL structural tree
    # mutations (insert/remove/split/rotate/carve) on `slot` against each
    # other AND against the lockless fault reader's tree WALK
    # (vma_lock_fault_vma takes it for the duration of _vma_tree_find +
    # per-VMA trylock). Without this, a fault-time tree walk on one CPU
    # could deref a child pointer that a concurrent mutator on another CPU
    # is mid-rotation rewiring, or that points at a VmaNode just kfree'd
    # (node frees are NOT RCU-deferred) — a #PF that re-faults into a #DF
    # in _vt_right/_vt_left. (This was the apt-get #DF: apt's thousands of
    # mmaps across its CLONE_VM/forked process tree opened the race window;
    # dpkg's tiny mmap closure never did.)
    #
    # RECURSIVE: vma_mremap nests vma_alloc / _vma_carve_range, both of
    # which now take this lock. Re-acquisition by the OWNING TASK just bumps
    # a depth counter instead of self-deadlocking on the raw spinlock. It
    # does NOT bump the seqcount, so it stays neutral w.r.t. the per-mutation
    # seq bumps the tree helpers do. Paired with vma_mm_write_unlock.
    #
    # The re-entrancy token is the CURRENT TASK slot, NOT the CPU id. Two
    # THREADS of one shared mm can run on the SAME CPU (one preempting the
    # other mid-critical-section); a CPU-keyed token would let the preemptor
    # FALSELY re-enter the held lock and mutate the shared cursor/tree
    # concurrently -> the Firefox windowed-mmap corruption. A task-keyed
    # token also survives the holder migrating to another CPU mid-section
    # (its own nested re-acquire still matches). A DIFFERENT task on the same
    # CPU never matches and correctly spins on the raw spinlock.
    o: uint64 = _vma_owner(slot)
    tok: uint64 = current_idx_get() + 1
    if vma_mm_owner[o] == tok and vma_mm_depth[o] > 0:
        vma_mm_depth[o] = vma_mm_depth[o] + 1
        return
    spinlock_lock(&vma_mm_lock[o])
    vma_mm_owner[o] = tok
    vma_mm_depth[o] = 1


def vma_mm_write_unlock(slot: uint64):
    o: uint64 = _vma_owner(slot)
    if vma_mm_depth[o] > 1:
        vma_mm_depth[o] = vma_mm_depth[o] - 1
        return
    vma_mm_depth[o] = 0
    vma_mm_owner[o] = 0
    spinlock_unlock(&vma_mm_lock[o])


def vma_mm_seq_read(slot: uint64) -> uint64:
    return vma_mm_seq[_vma_owner(slot)]


def _vma_mm_seq_bump(slot: uint64):
    # Record that the tree/list structure of `slot` changed. A monotonic
    # generation counter (NOT a parity seqlock), so it is safe to bump from
    # NESTED structural helpers (insert -> rebalance, carve -> split ->
    # insert): the lockless fault reader only checks the value for
    # INEQUALITY across its lookup window, so any forward motion forces it
    # onto the write-lock fallback.
    o: uint64 = _vma_owner(slot)
    vma_mm_seq[o] = vma_mm_seq[o] + 1


# ---------------------------------------------------------------------
# VmaChunk / VmaNode
# ---------------------------------------------------------------------

class VmaChunk:
    phys:  uint64
    order: int32
    pad:   int32


class VmaNode:
    start:       uint64
    end:         uint64
    file_offset: uint64
    backing:     uint64
    next:        uint64
    chunks:      uint64
    prot:        int32
    flags:       int32
    file_fd:     int32
    order:       int32
    nchunks:     int32
    # is_cow: 1 once this node's pages have been COW-shared on fork
    # (in either the parent or the child). A COW node's `backing` /
    # `chunks` physical addresses are no longer the authority for what
    # to free — COW resolution can repoint individual PTEs at fresh
    # pages outside the original buddy run — so _vma_node_free frees a
    # COW node by walking the owning task's page table page-by-page and
    # routing each physical page through cow_drop_page. A non-COW node
    # (0) keeps the fast bulk free_pages path. Replaces the old `pad0`
    # padding slot.
    is_cow:      int32
    # §1 / MAP_SHARED: 1 once this node's anonymous pages are genuinely
    # SHARED across a fork boundary — the child maps the SAME physical
    # frames RW (no COW marking), so a write by either side is visible
    # to the other (/dev/shm-style coherence). Like a COW node, a
    # shared node's pages are reference-counted in mm/cow.ad's per-PFN
    # table, so _vma_node_free walks the page table and routes each
    # frame through cow_drop_page — the frame is returned to the buddy
    # allocator only when the last mapper unmaps. is_cow and is_shared
    # are mutually exclusive (a VMA is either copy-on-write OR shared).
    is_shared:   int32
    # §1 / VMA splitting: 1 once this node's frames are refcount-managed
    # because the VMA was SPLIT (mprotect / MAP_FIXED carved part of an
    # owner VMA). A single-chunk VMA's virtual range is its physical
    # buddy run, which can only be freed whole — so a split owner VMA
    # converts to per-PFN refcounting (vm_pin_range) and every piece
    # frees via _vma_free_cow_range. Distinct from is_shared because a
    # pinned (split, but private) VMA still forks COPY-ON-WRITE, whereas
    # an is_shared VMA forks genuinely shared. A node with is_pinned set
    # frees through the refcount path exactly like is_cow / is_shared.
    is_pinned:   int32
    # §142 / demand paging: 1 when this VMA was created by
    # vma_alloc_demand (SYS_MMAP from native Adder code). Pages are NOT
    # allocated at VMA-creation time; each page is populated lazily on
    # first access (NOT-PRESENT #PF → vma_demand_fault → elf_map_one_page).
    # The free path walks [start, end) via the PTE table and calls
    # free_page for each present 4 KiB frame (no COW refcount is used —
    # demand pages are always private, unshared). is_demand is mutually
    # exclusive with is_cow / is_shared / is_pinned.
    is_demand:   int32
    # §file-mmap / file-backed demand paging: 1 when this VMA maps a
    # FILE's contents (mmap with a real fd). It is ALSO is_demand (pages
    # are populated lazily on #PF), but instead of zero-filling, each
    # page is read from the backing file at
    #   file_offset + (page_va - start)
    # via vfs_pread_backing(file_marker, backing, file_size, ...). Any
    # bytes past file_size (a sub-page EOF tail) read as zero. The fd the
    # mapping was created from may be closed afterwards (POSIX) — the
    # snapshot below is self-contained.
    #
    # MAP_PRIVATE file-backed (the common case, e.g. loading a shared
    # object): on a WRITE fault the page is already private (one mapper,
    # never written back) so a fresh copy is taken via the COW path the
    # same way an anonymous demand page is — file pages are mapped
    # read-only on a PROT_WRITE private mapping and copied on first write.
    is_file:     int32
    # Backing-store kind marker (an FD_*_MARK / FD_FILEMMAP_* value from
    # fs/vfs.ad), captured at mmap time. Stored as int32 (the markers fit
    # the high uint32 range; reinterpreted to uint32 when used).
    file_marker: int32
    # Total size in bytes of the backing file at mmap time — the EOF
    # boundary for zero-fill of the sub-page tail. (Kept at this offset,
    # 8-byte aligned, so the §shared-mmap field below is appended last.)
    file_size:   uint64
    # §shared-mmap: 1 when this is a MAP_SHARED *writable* file-backed
    # mapping. It is also is_file=1 + is_demand=1. Unlike a MAP_PRIVATE
    # file VMA (whose faulted pages are private copies, never written
    # back), a shared-writable file VMA maps each faulted page WRITABLE
    # and tracks it for write-back: on msync(MS_SYNC) and on munmap /
    # teardown, every resident dirty page is flushed to the backing file
    # via vfs_pwrite_backing(marker, backing, file_offset+page-off, ...).
    # The PTE dirty bit (bit 6) selects which pages actually changed.
    # Appended as the LAST field so file_size stays 8-byte aligned.
    is_file_shared: int32
    # §mseal: 1 once mseal(2) (x86_64 nr 462) has sealed this VMA. A sealed
    # VMA's address-space layout is FROZEN: mprotect / munmap / mremap /
    # madvise(MADV_DONTNEED|FREE|REMOVE) over any byte of it are rejected
    # -EPERM, matching Linux mseal semantics. The seal is permanent for the
    # life of the mapping (there is no munseal). Stored on the per-task VMA
    # node itself — the existing structure — so the existing mm syscalls
    # honour it directly via vma_range_is_sealed(). Appended LAST (after the
    # 8-byte-aligned file_size) so file_size stays aligned; it is an int32
    # peer of is_file_shared so the two int32s pack into one 8-byte slot.
    sealed:         int32
    # §hugepage: 1 when this is a MAP_HUGETLB anonymous demand VMA backed
    # by REAL 2 MiB huge pages. It is ALSO is_demand=1 (pages populated
    # lazily on #PF), but the fault handler allocates a 2 MiB-aligned,
    # physically-contiguous order-9 buddy run and installs ONE PS=1 PDE
    # (elf_map_one_huge_pde) covering the whole 2 MiB rather than 512
    # 4 KiB PTEs. The teardown path frees each resident 2 MiB run at
    # order-9 (free_pages) by walking the PD level. is_huge is mutually
    # exclusive with is_file / is_shared / is_cow / is_pinned. Appended
    # last; an int32 peer of `sealed` so the two pack into one 8-byte slot.
    is_huge:        int32
    # Track 4 UMDF: 1 once this node's VA range has been OVERLAID with
    # FOREIGN physical pages the VMA does NOT own — a device MMIO BAR or
    # a DMA buffer whose frames are owned/freed by linux_abi/umdf_kernel.ad,
    # not by the page-table teardown. _vma_node_free MUST clear the PTEs
    # and free the node but NEVER free_page() the underlying frames (they
    # are device registers, or DMA pages freed explicitly on driver-host
    # exit). Without this, exiting a UMDF host would free_page() device
    # physical addresses and corrupt the buddy allocator. Checked before
    # the is_demand arm (a foreign overlay sits on a demand reservation).
    is_foreign:     int32
    # ---------------------------------------------------------------
    # Wave-3 — augmented AVL interval-tree links + per-VMA lock.
    # ---------------------------------------------------------------
    # The VMA set is indexed by a balanced (AVL) interval tree keyed on
    # [start, end), giving O(log n) find_vma / overlap / gap search in
    # place of the old O(n) sorted-list scan. The sorted singly-linked
    # `next` chain is RETAINED purely as the in-order iterator every
    # consumer (coredump, /proc/maps, fork, teardown) walks — the tree is
    # the index, the list is the iterator, and both are kept consistent by
    # the insert/unlink helpers.
    #
    # left / right : child subtree roots (0 == nil).
    # height       : AVL height (leaf == 1) for O(1) balance-factor.
    # subtree_max_end : MAX(end) over this node's whole subtree — the
    #   interval-tree augmentation that lets an overlap/gap search prune a
    #   subtree whose every interval ends before the query start.
    left:            uint64
    right:           uint64
    height:          int32
    pad_avl:         int32
    subtree_max_end: uint64
    # vlock : the per-VMA spinlock (Linux's vm_area_struct->vm_lock). A
    # page fault on this VMA trylocks it; a concurrent fault on a DIFFERENT
    # VMA takes that VMA's own vlock and the two proceed without
    # serializing. Structural changes to the VMA (split/merge/grow/remove)
    # are done under the mm-wide write lock (vma_mm_write_lock), not this
    # lock, and bump the mm seqcount so an in-flight lockless fault lookup
    # retries. uint32 (the spinlock word) + an int32 pad to stay 8-aligned.
    vlock:           uint32
    pad_vlock:       int32
    # For a file-backed VMA, `backing` (above) is REPURPOSED to hold the
    # stable backing IDENTITY (cpio index / tmpfs slot / ext4 inode num /
    # buffer pointer) rather than a physical page run — a file-backed
    # demand VMA never owns a buddy backing run.


# ---------------------------------------------------------------------
# Allocation helpers
# ---------------------------------------------------------------------

# VmaNode size: 6 uint64 (48) + 10 int32 (40) = 88 bytes; §file-mmap
# adds is_file + file_marker (2 int32 = 8) + file_size (uint64 = 8) for
# 104 bytes; §shared-mmap adds is_file_shared (int32 = 4) for 108 bytes;
# §mseal adds sealed (int32 = 4) for 112 bytes total. §hugepage appends
# is_huge (int32 = 4) which pairs with sealed into one 8-byte slot for
# 120 bytes total (rounded up to 8). Track 4 appends is_foreign (int32 =
# 4) -> 124, rounded up to 128. memset-zeroed on alloc, so every node
# defaults to is_file=0 / is_file_shared=0 / sealed=0 / is_huge=0 /
# is_foreign=0 unless an allocator or mseal(2) sets them.
#
# Wave-3 appends the interval-tree links + per-VMA lock: left (8) +
# right (8) + height (4) + pad_avl (4) + subtree_max_end (8) + vlock (4)
# + pad_vlock (4) = 40 bytes -> 124 + 40 = 164, rounded up to 168
# (8-aligned). memset-zeroed on alloc so left/right == 0 (nil),
# height == 0, vlock == 0 (unlocked), subtree_max_end == 0 for a fresh
# node — the tree-insert helper sets height/subtree_max_end on splice.
VMA_NODE_SIZE: uint64 = 168


def _vma_node_new() -> uint64:
    p: uint64 = kmalloc(VMA_NODE_SIZE)
    if p == 0:
        return 0
    memset(cast[Ptr[uint8]](p), 0, VMA_NODE_SIZE)
    nr_vma_nodes_live = nr_vma_nodes_live + 1
    return p


def _vma_node_set(node: uint64, start: uint64, end: uint64,
                  prot: int32, flags: int32, file_fd: int32,
                  file_offset: uint64, backing: uint64,
                  order: int32):
    cast[Ptr[VmaNode]](node)[0].start       = start
    cast[Ptr[VmaNode]](node)[0].end         = end
    cast[Ptr[VmaNode]](node)[0].prot        = prot
    cast[Ptr[VmaNode]](node)[0].flags       = flags
    cast[Ptr[VmaNode]](node)[0].file_fd     = file_fd
    cast[Ptr[VmaNode]](node)[0].file_offset = file_offset
    cast[Ptr[VmaNode]](node)[0].backing     = backing
    cast[Ptr[VmaNode]](node)[0].order       = order
    cast[Ptr[VmaNode]](node)[0].next        = 0
    cast[Ptr[VmaNode]](node)[0].chunks      = 0
    cast[Ptr[VmaNode]](node)[0].nchunks     = 0
    cast[Ptr[VmaNode]](node)[0].is_cow      = 0
    cast[Ptr[VmaNode]](node)[0].is_shared   = 0
    cast[Ptr[VmaNode]](node)[0].is_pinned   = 0
    cast[Ptr[VmaNode]](node)[0].is_demand   = 0
    cast[Ptr[VmaNode]](node)[0].is_file     = 0
    cast[Ptr[VmaNode]](node)[0].file_marker = 0
    cast[Ptr[VmaNode]](node)[0].file_size   = 0
    cast[Ptr[VmaNode]](node)[0].is_file_shared = 0
    cast[Ptr[VmaNode]](node)[0].sealed      = 0
    cast[Ptr[VmaNode]](node)[0].is_huge     = 0


def _vma_node_get_next(node: uint64) -> uint64:
    return cast[Ptr[VmaNode]](node)[0].next


def _vma_node_set_next(node: uint64, nxt: uint64):
    cast[Ptr[VmaNode]](node)[0].next = nxt


def _vma_node_start(node: uint64) -> uint64:
    return cast[Ptr[VmaNode]](node)[0].start


def _vma_node_end(node: uint64) -> uint64:
    return cast[Ptr[VmaNode]](node)[0].end


# ---------------------------------------------------------------------
# Wave-3 — augmented AVL interval tree
# ---------------------------------------------------------------------
#
# The VMA set is indexed by a height-balanced (AVL) binary search tree
# keyed on `start`, augmented with subtree_max_end (the MAX end over a
# node's whole subtree). This is the "maple-tree-shape" capability the
# Wave-3 gap analysis asked for: O(log n) find_vma, overlap query, and
# free-gap search, replacing the old O(n) sorted-list scan.
#
# The sorted singly-linked list (`next`) is retained as the in-order
# iterator (coredump / /proc-maps / fork / teardown all walk it); the
# tree is the index. _vma_tree_insert and _vma_tree_remove keep both
# structures consistent. All tree mutation runs under the mm write lock.
#
# Node link accessors (left/right/height/subtree_max_end) are tiny so the
# rotation code below reads close to a textbook AVL.

def _vt_node_bad(n: uint64) -> int32:
    # DBG-VTREE: a live VmaNode is a kmalloc'd, 8-aligned, identity-mapped
    # RAM pointer. It lives BELOW the mmap window (VMA_LARGE_BASE) — on a
    # multi-GiB guest kmalloc/slab pages legitimately land above 1 GiB, so
    # the old "< 1 GiB" bound false-rejected real nodes; the true invariant
    # is "below the user mmap window". Anything at/above the window (a user
    # VA) or below 64 KiB is a dangling / garbage child link that would
    # #PF->#DF on deref.
    if (n & 0x7) != 0:
        return 1
    if n < 0x10000:
        return 1
    if n >= VMA_LARGE_BASE:
        return 1
    return 0


def _vt_left(n: uint64) -> uint64:
    if n == 0:
        return 0
    if _vt_node_bad(n) != 0:
        printk1("[dbg-vtree] _vt_left BAD n=0x%x\n", n)
        return 0
    return cast[Ptr[VmaNode]](n)[0].left


def _vt_right(n: uint64) -> uint64:
    if n == 0:
        return 0
    if _vt_node_bad(n) != 0:
        printk1("[dbg-vtree] _vt_right BAD n=0x%x\n", n)
        return 0
    return cast[Ptr[VmaNode]](n)[0].right


def _vt_set_left(n: uint64, c: uint64):
    cast[Ptr[VmaNode]](n)[0].left = c


def _vt_set_right(n: uint64, c: uint64):
    cast[Ptr[VmaNode]](n)[0].right = c


def _vt_height(n: uint64) -> int32:
    if n == 0:
        return 0
    return cast[Ptr[VmaNode]](n)[0].height


def _vt_max_end(n: uint64) -> uint64:
    if n == 0:
        return 0
    return cast[Ptr[VmaNode]](n)[0].subtree_max_end


def _vt_max3(a: uint64, b: uint64, c: uint64) -> uint64:
    m: uint64 = a
    if b > m:
        m = b
    if c > m:
        m = c
    return m


def _vt_fix(n: uint64):
    # Recompute height + subtree_max_end from this node's children. Called
    # bottom-up after every structural step (insert recursion, rotation).
    if n == 0:
        return
    lh: int32 = _vt_height(_vt_left(n))
    rh: int32 = _vt_height(_vt_right(n))
    h: int32 = lh
    if rh > h:
        h = rh
    cast[Ptr[VmaNode]](n)[0].height = h + 1
    cast[Ptr[VmaNode]](n)[0].subtree_max_end = _vt_max3(
        cast[Ptr[VmaNode]](n)[0].end,
        _vt_max_end(_vt_left(n)),
        _vt_max_end(_vt_right(n)))


def _vt_balance(n: uint64) -> int32:
    if n == 0:
        return 0
    return _vt_height(_vt_left(n)) - _vt_height(_vt_right(n))


def _vt_rotate_right(y: uint64) -> uint64:
    # y's left child x becomes the new subtree root.
    x: uint64 = _vt_left(y)
    t2: uint64 = _vt_right(x)
    _vt_set_right(x, y)
    _vt_set_left(y, t2)
    _vt_fix(y)
    _vt_fix(x)
    return x


def _vt_rotate_left(x: uint64) -> uint64:
    # x's right child y becomes the new subtree root.
    y: uint64 = _vt_right(x)
    t2: uint64 = _vt_left(y)
    _vt_set_left(y, x)
    _vt_set_right(x, t2)
    _vt_fix(x)
    _vt_fix(y)
    return y


def _vt_rebalance(n: uint64) -> uint64:
    # Restore the AVL invariant at `n` after a child changed height, and
    # refresh its augmentation. Returns the (possibly new) subtree root.
    _vt_fix(n)
    bf: int32 = _vt_balance(n)
    if bf > 1:
        # Left-heavy.
        if _vt_balance(_vt_left(n)) < 0:
            _vt_set_left(n, _vt_rotate_left(_vt_left(n)))
        return _vt_rotate_right(n)
    if bf < -1:
        # Right-heavy.
        if _vt_balance(_vt_right(n)) > 0:
            _vt_set_right(n, _vt_rotate_right(_vt_right(n)))
        return _vt_rotate_left(n)
    return n


def _vt_insert_rec(root: uint64, node: uint64) -> uint64:
    # Insert `node` (a fresh leaf, left/right already 0) keyed on start,
    # returning the new subtree root. VMA starts are unique (ranges are
    # disjoint and page-aligned); a duplicate start should never occur, so
    # ties route right defensively.
    if root == 0:
        _vt_fix(node)
        return node
    # DBG-VTREE / cycle-guard: if `node` is ALREADY this subtree's root, a
    # double-insert is in progress. Re-inserting an already-linked node makes
    # it its own descendant -> a cycle the recursive insert/remove walk then
    # infinite-recurses on -> kernel-stack overflow -> #DF (err=0) in the
    # deepest _vt_* frame. Refuse the re-link and report it.
    if root == node:
        printk1("[dbg-vtree] DOUBLE-INSERT node=0x%x already in tree\n", node)
        return root
    _vt_insert_depth = _vt_insert_depth + 1
    if _vt_insert_depth > 64:
        printk2("[dbg-vtree] INSERT DEPTH>64 root=0x%x node=0x%x (cycle?)\n",
                root, node)
        _vt_insert_depth = _vt_insert_depth - 1
        return root
    if cast[Ptr[VmaNode]](node)[0].start < cast[Ptr[VmaNode]](root)[0].start:
        _vt_set_left(root, _vt_insert_rec(_vt_left(root), node))
    else:
        _vt_set_right(root, _vt_insert_rec(_vt_right(root), node))
    _vt_insert_depth = _vt_insert_depth - 1
    return _vt_rebalance(root)


def _vt_min_node(n: uint64) -> uint64:
    cur: uint64 = n
    while _vt_left(cur) != 0:
        cur = _vt_left(cur)
    return cur


def _vt_remove_rec(root: uint64, key: uint64, target: uint64) -> uint64:
    # Remove the node whose start == key (and which IS `target`) from the
    # subtree, returning the new subtree root. Standard AVL delete with the
    # two-child case spliced by the in-order successor; because callers
    # hold a pointer to the exact node, the successor splice copies the
    # KEY ordering by relinking (never by moving payload) so `target`'s
    # heap address is the one detached.
    if root == 0:
        return 0
    _vt_insert_depth = _vt_insert_depth + 1
    if _vt_insert_depth > 64:
        printk2("[dbg-vtree] REMOVE DEPTH>64 root=0x%x key=0x%x (cycle?)\n",
                root, key)
        _vt_insert_depth = _vt_insert_depth - 1
        return root
    _rr_ret: uint64 = 0
    if key < cast[Ptr[VmaNode]](root)[0].start:
        _vt_set_left(root, _vt_remove_rec(_vt_left(root), key, target))
        _rr_ret = _vt_rebalance(root)
    elif key > cast[Ptr[VmaNode]](root)[0].start:
        _vt_set_right(root, _vt_remove_rec(_vt_right(root), key, target))
        _rr_ret = _vt_rebalance(root)
    else:
        # key == root.start. It might still be a DIFFERENT node than
        # target if two ranges momentarily share a start during a split
        # (they don't in practice — starts are unique — but guard anyway).
        if root != target:
            # Defensive: keep searching right (ties routed right on insert).
            _vt_set_right(root, _vt_remove_rec(_vt_right(root), key, target))
            _rr_ret = _vt_rebalance(root)
        else:
            l: uint64 = _vt_left(root)
            r: uint64 = _vt_right(root)
            if l == 0:
                _vt_set_left(root, 0)
                _vt_set_right(root, 0)
                _rr_ret = r
            elif r == 0:
                _vt_set_left(root, 0)
                _vt_set_right(root, 0)
                _rr_ret = l
            else:
                # Two children: pull the in-order successor (min of right
                # subtree) up into root's position by relinking it around
                # root's children, then detach root.
                succ: uint64 = _vt_min_node(r)
                new_r: uint64 = _vt_remove_rec(
                    r, cast[Ptr[VmaNode]](succ)[0].start, succ)
                _vt_set_left(succ, l)
                _vt_set_right(succ, new_r)
                _vt_set_left(root, 0)
                _vt_set_right(root, 0)
                _rr_ret = _vt_rebalance(succ)
    _vt_insert_depth = _vt_insert_depth - 1
    return _rr_ret


def _vma_tree_insert(slot: uint64, node: uint64):
    # Splice `node` into slot's interval tree. Held under the mm write lock
    # so the (rotation-rewiring) insert is atomic w.r.t. the lockless fault
    # reader's tree walk — see vma_mm_write_lock. The node's left/right/
    # height are reset so it enters as a leaf.
    vma_mm_write_lock(slot)
    cast[Ptr[VmaNode]](node)[0].left = 0
    cast[Ptr[VmaNode]](node)[0].right = 0
    cast[Ptr[VmaNode]](node)[0].height = 0
    r: uint64 = _vma_tree_root(slot)
    _vma_set_tree_root(slot, _vt_insert_rec(r, node))
    _vma_mm_seq_bump(slot)
    vma_mm_write_unlock(slot)


def _vma_tree_remove(slot: uint64, node: uint64):
    # Detach `node` from slot's interval tree. Held under the mm write lock
    # so the remove (incl. successor-splice rotations) is atomic w.r.t. the
    # lockless fault reader's tree walk — see vma_mm_write_lock.
    vma_mm_write_lock(slot)
    r: uint64 = _vma_tree_root(slot)
    new_root: uint64 = _vt_remove_rec(r, cast[Ptr[VmaNode]](node)[0].start,
                                      node)
    _vma_set_tree_root(slot, new_root)
    cast[Ptr[VmaNode]](node)[0].left = 0
    cast[Ptr[VmaNode]](node)[0].right = 0
    _vma_mm_seq_bump(slot)
    vma_mm_write_unlock(slot)


def _vma_tree_update_end(slot: uint64, node: uint64, new_end: uint64):
    # A node's `end` changed in place (split shrink / grow-in-place). The
    # BST key (`start`) is unchanged, but subtree_max_end along the path
    # from the root to `node` must be refreshed. Simplest correct way that
    # reuses the balanced machinery: detach and re-insert with the new end.
    # Taken under the mm write lock (recursive — the nested remove/insert
    # re-take it) so the node is never observed transiently absent from the
    # tree by the lockless fault reader. (start is unchanged so list order is
    # unaffected — only the tree augmentation is repaired.)
    vma_mm_write_lock(slot)
    _vma_tree_remove(slot, node)
    cast[Ptr[VmaNode]](node)[0].end = new_end
    _vma_tree_insert(slot, node)
    vma_mm_write_unlock(slot)


def _vt_stab_max_start(node: uint64, addr: uint64, best: uint64,
                       depth: uint64) -> uint64:
    # Interval-stabbing search (#471 fix): among ALL VMAs whose [start, end)
    # contains `addr`, return the one with the GREATEST start — the innermost
    # MAP_FIXED overlay, which governs the leaf PTE's prot AND its backing /
    # file_offset exactly as it did at install time. `best` is the best cover
    # found so far (0 = none); `depth` bounds the recursion against a corrupt
    # tree (cycle / dangling child).
    #
    # WHY this replaces the old greatest-start BST DESCENT. The VMA set is NOT
    # a partition: ld.so's "reserve the whole DSO span (PROT_READ/NX) then
    # MAP_FIXED-overlay each segment inside it" idiom installs OVERLAPPING
    # nodes (an exec/.text or RW/.data overlay nested in the RO reservation),
    # and apt re-overlays segments as it dlopen's libapt/libc. A plain
    # descent that only tracks the single greatest-start node on ONE root->leaf
    # path can:
    #   (a) MISS entirely — return 0 for an address only the OUTER reservation
    #       covers when an inner overlay with a larger start sits on the
    #       descent path but does not itself cover addr (its sibling
    #       reservation is then in an unexplored subtree); or
    #   (b) return the WRONG covering node — the RO/NX reservation instead of
    #       the inner exec/RW overlay — depending on the (ASLR-determined)
    #       AVL tree shape.
    # On a demand fault that drove the wrong node, the page is installed with
    # the reservation's prot (NX) AND the reservation's file_offset/backing
    # (WRONG BYTES) — the apt "Reading package lists" NX exec-fault (the NX
    # case is recoverable by vma_resolve_exec_perm_fault; the wrong-content
    # case executes garbage -> SIGSEGV / va=0 read-fault, the non-recoverable
    # crash the apt-e2e re-roll was riding out). A correct stab that honours
    # subtree_max_end visits EVERY covering interval, so the result is exact
    # under any overlap/layout. Overlap depth is tiny (a reservation + a few
    # overlays per page), so this stays O(log n + k).
    if node == 0:
        return best
    if _vt_node_bad(node) != 0 or depth > 256:
        printk2("[dbg-vtree] stab: BAD/looping node=0x%x addr=0x%x\n",
                node, addr)
        return best
    l: uint64 = _vt_left(node)
    r: uint64 = _vt_right(node)
    # Left subtree holds SMALLER starts; explore it only if some interval
    # there can still reach addr (its subtree max end exceeds addr). This is
    # the augmentation that makes the outer-reservation cover reachable even
    # when an inner overlay shadowed the plain descent.
    if l != 0 and _vt_max_end(l) > addr:
        best = _vt_stab_max_start(l, addr, best, depth + 1)
    s: uint64 = cast[Ptr[VmaNode]](node)[0].start
    if s <= addr:
        e: uint64 = cast[Ptr[VmaNode]](node)[0].end
        if e > addr:
            if best == 0 or s > cast[Ptr[VmaNode]](best)[0].start:
                best = node
        # Right subtree holds LARGER starts, all still possibly <= addr — and
        # a larger-start cover beats the current best, so explore it.
        if r != 0 and _vt_max_end(r) > addr:
            best = _vt_stab_max_start(r, addr, best, depth + 1)
    # If s > addr the entire right subtree has even larger starts (> addr) and
    # cannot cover addr, so it is correctly pruned (we only recursed left).
    return best


def _vma_tree_find(slot: uint64, addr: uint64) -> uint64:
    # O(log n + k) point query: the VMA whose [start, end) contains addr, or
    # 0. Returns the GREATEST-start cover (innermost overlay) and is correct
    # under OVERLAPPING VMAs (the reserve+overlay idiom) — see
    # _vt_stab_max_start for why a plain start-keyed BST descent is not. The
    # same augmented tree serves the gap/overlap queries below.
    return _vt_stab_max_start(_vma_tree_root(slot), addr, 0, 0)


def _vma_tree_overlap(slot: uint64, lo: uint64, hi: uint64) -> uint64:
    # O(log n)-ish interval-overlap query: ANY VMA intersecting [lo, hi),
    # or 0. Uses the subtree_max_end augmentation to prune a left subtree
    # whose every interval ends at or before `lo`.
    cur: uint64 = _vma_tree_root(slot)
    _ov_steps: uint64 = 0
    while cur != 0:
        if _vt_node_bad(cur) != 0 or _ov_steps > 256:
            printk2("[dbg-vtree] overlap: BAD/looping cur=0x%x lo=0x%x\n",
                    cur, lo)
            return 0
        _ov_steps = _ov_steps + 1
        s: uint64 = cast[Ptr[VmaNode]](cur)[0].start
        e: uint64 = cast[Ptr[VmaNode]](cur)[0].end
        if s < hi and e > lo:
            return cur
        l: uint64 = _vt_left(cur)
        if l != 0 and _vt_max_end(l) > lo:
            cur = l
        else:
            cur = _vt_right(cur)
    return 0


# ---------------------------------------------------------------------
# Wave-3 — per-VMA locked fault lookup (Linux's lockless VMA lookup)
# ---------------------------------------------------------------------
#
# vma_lock_fault_vma(slot, addr) is the scalable fault entry point: it
# RCU-read-locks, finds the covering VMA via the O(log n) interval tree,
# then TRYLOCKS that VMA's own per-VMA spinlock. On success it confirms
# the mm seqcount did not move during the lookup (the VMA wasn't being
# split/removed concurrently) and returns the LOCKED node — the fault
# handler then operates on just that VMA while a fault on a DIFFERENT VMA
# concurrently holds a DIFFERENT per-VMA lock, so the two never serialize.
#
# If the trylock fails (another fault is actively touching THIS vma) or
# the seqcount moved (a structural change raced), it returns 0 and the
# caller falls back to the mm-wide write lock — exactly Linux's
# lock_vma_under_rcu → mmap_read_lock fallback. The caller MUST pair a
# non-zero return with vma_unlock_vma(node).

def vma_lock_fault_vma(slot: uint64, addr: uint64) -> uint64:
    # CORRECTNESS (SMP #DF fix): the interval-tree WALK itself must never
    # race a structural mutation. A concurrent mmap/munmap/split rotates
    # nodes (rewiring left/right transiently) and FREES VmaNodes via plain
    # kfree — which is NOT RCU-deferred — so a lockless walk could deref a
    # half-rewired or already-freed child pointer (_vt_right) and take a
    # #PF that re-faults into a #DF. (apt issues thousands of mmaps across a
    # multi-threaded/CLONE_VM process tree, so the window is hit; dpkg's tiny
    # closure never did.) rcu_read_lock + a post-hoc seqcount check cannot
    # undo a fault that already happened mid-walk. So take the mm-wide write
    # lock for the (short, O(log n)) walk + per-VMA trylock; every structural
    # mutator takes the SAME lock, making the tree provably stable here. The
    # per-VMA lock is still what guards the (slow) fault BODY, so two faults
    # on DIFFERENT VMAs still run concurrently once this returns.
    vma_mm_write_lock(slot)
    node: uint64 = _vma_tree_find(slot, addr)
    if node == 0:
        vma_mm_write_unlock(slot)
        return 0
    if spinlock_trylock(&cast[Ptr[VmaNode]](node)[0].vlock) == 0:
        # Another fault holds this VMA's lock; fall back to the write side.
        vma_mm_write_unlock(slot)
        return 0
    # Hold the per-VMA lock across the mm-lock release: the node cannot be
    # freed/split out from under us while its vlock is held (the mutators
    # that would do so take the per-VMA lock too, or run under the mm lock
    # we just held to find it). Drop the mm lock so the fault body races
    # only on this VMA's own lock.
    vma_mm_write_unlock(slot)
    return node


def vma_unlock_vma(node: uint64):
    # Release a per-VMA lock taken by vma_lock_fault_vma.
    if node == 0:
        return
    spinlock_unlock(&cast[Ptr[VmaNode]](node)[0].vlock)


# ---------------------------------------------------------------------
# COW-aware page-table walk for the free path
# ---------------------------------------------------------------------
#
# Once a VMA's pages have been COW-shared on fork (is_cow == 1) the
# node's `backing` / `chunks` physical addresses no longer describe
# what the owning task actually maps: a COW write fault (cow_resolve_pte
# in fs/elf.ad) allocates a FRESH page outside the original buddy run
# and repoints just that one PTE. So freeing a COW node by its recorded
# backing run would (a) leak every COW-resolved fresh page and (b)
# unconditionally free pages still mapped COW in another process — a
# use-after-free.
#
# The ground truth for a COW node is the page table itself. The free
# path walks the owning task's PML4 over the VMA's virtual range and,
# for each present 4 KiB PTE, routes the physical page through
# cow_drop_page: the page is returned to the buddy allocator (one
# order-0 free, which the buddy merge re-coalesces) ONLY when its
# refcount falls to 0. A still-shared page is left untouched for the
# other holder. A COW-resolved fresh page is refcount-0 (untracked) so
# cow_drop_page returns 1 and it is freed correctly too.
#
# vm_cow_share_range cracks every huge-page entry it touches down to
# 4 KiB granularity, so every page of a COW node is reached through a
# private 4 KiB PTE — _vma_pte_lookup never needs to handle a huge leaf
# here (it returns 0 on one, defensively skipping the page).

def _vma_pte_lookup(pml4_phys: uint64, vaddr: uint64) -> uint64:
    # Boot-CR3 guard (>4GB aliasing): this read walk dereferences the
    # task's PT pages by bare physical address; a >4 GiB PT page aliases a
    # live user mapping and #PFs under the live task CR3. Read under the
    # boot CR3's complete, un-aliased identity (walk only READS physical PT
    # bytes, so the active CR3 doesn't change the result).
    _saved_cr3: uint64 = read_cr3()
    _boot_cr3: uint64 = cow_boot_cr3()
    _irq_flags: uint64 = 0
    if _boot_cr3 != 0:
        _irq_flags = local_irq_save()
        load_cr3(_boot_cr3)
    _rc: uint64 = _vma_pte_lookup_locked(pml4_phys, vaddr)
    if _boot_cr3 != 0:
        load_cr3(_saved_cr3)
        local_irq_restore(_irq_flags)
    return _rc


def _vma_pte_lookup_locked(pml4_phys: uint64, vaddr: uint64) -> uint64:
    # Return the value of the 4 KiB PTE mapping `vaddr` in `pml4_phys`,
    # or 0 if any level is not-present or the leaf is a huge page.
    # Read-only: it never allocates or cracks a table — used by the
    # COW-aware free path, which must not mutate page tables.
    if pml4_phys == 0:
        return 0
    pml4_idx: uint64 = (vaddr >> 39) & 0x1FF
    pdpt_idx: uint64 = (vaddr >> 30) & 0x1FF
    pd_idx:   uint64 = (vaddr >> 21) & 0x1FF
    pt_idx:   uint64 = (vaddr >> 12) & 0x1FF

    pml4: Ptr[uint64] = cast[Ptr[uint64]](pml4_phys & VMA_PT_ADDR_MASK)
    pml4e: uint64 = pml4[pml4_idx]
    if (pml4e & VMA_PT_FLAG_P) == 0:
        return 0
    pdpt: Ptr[uint64] = cast[Ptr[uint64]](pml4e & VMA_PT_ADDR_MASK)
    pdpte: uint64 = pdpt[pdpt_idx]
    if (pdpte & VMA_PT_FLAG_P) == 0:
        return 0
    if (pdpte & VMA_PT_FLAG_PS) != 0:
        return 0
    pd: Ptr[uint64] = cast[Ptr[uint64]](pdpte & VMA_PT_ADDR_MASK)
    pde: uint64 = pd[pd_idx]
    if (pde & VMA_PT_FLAG_P) == 0:
        return 0
    if (pde & VMA_PT_FLAG_PS) != 0:
        return 0
    pt: Ptr[uint64] = cast[Ptr[uint64]](pde & VMA_PT_ADDR_MASK)
    pte: uint64 = pt[pt_idx]
    if (pte & VMA_PT_FLAG_P) == 0:
        return 0
    return pte


def _vma_huge_pde_lookup(pml4_phys: uint64, vaddr: uint64) -> uint64:
    # Boot-CR3 guard (>4GB aliasing) — read walk of PT pages by bare
    # physical address; read under the boot CR3's un-aliased identity.
    _saved_cr3: uint64 = read_cr3()
    _boot_cr3: uint64 = cow_boot_cr3()
    _irq_flags: uint64 = 0
    if _boot_cr3 != 0:
        _irq_flags = local_irq_save()
        load_cr3(_boot_cr3)
    _rc: uint64 = _vma_huge_pde_lookup_locked(pml4_phys, vaddr)
    if _boot_cr3 != 0:
        load_cr3(_saved_cr3)
        local_irq_restore(_irq_flags)
    return _rc


def _vma_huge_pde_lookup_locked(pml4_phys: uint64, vaddr: uint64) -> uint64:
    # §hugepage: return the PRESENT 2 MiB PS=1 PDE mapping `vaddr`, or 0
    # if any level above is not-present or the PDE is not a present huge
    # leaf. Read-only — never allocates or cracks a table. Used by the
    # huge-VMA teardown to find each resident 2 MiB frame.
    if pml4_phys == 0:
        return 0
    pml4_idx: uint64 = (vaddr >> 39) & 0x1FF
    pdpt_idx: uint64 = (vaddr >> 30) & 0x1FF
    pd_idx:   uint64 = (vaddr >> 21) & 0x1FF

    pml4: Ptr[uint64] = cast[Ptr[uint64]](pml4_phys & VMA_PT_ADDR_MASK)
    pml4e: uint64 = pml4[pml4_idx]
    if (pml4e & VMA_PT_FLAG_P) == 0:
        return 0
    pdpt: Ptr[uint64] = cast[Ptr[uint64]](pml4e & VMA_PT_ADDR_MASK)
    pdpte: uint64 = pdpt[pdpt_idx]
    if (pdpte & VMA_PT_FLAG_P) == 0:
        return 0
    if (pdpte & VMA_PT_FLAG_PS) != 0:
        return 0
    pd: Ptr[uint64] = cast[Ptr[uint64]](pdpte & VMA_PT_ADDR_MASK)
    pde: uint64 = pd[pd_idx]
    if (pde & VMA_PT_FLAG_P) == 0:
        return 0
    if (pde & VMA_PT_FLAG_PS) == 0:
        return 0
    return pde


def _vma_huge_pde_clear(pml4_phys: uint64, vaddr: uint64):
    # Boot-CR3 guard (>4GB aliasing) — derefs + writes PT pages by bare
    # physical address; run under the boot CR3's un-aliased identity.
    _saved_cr3: uint64 = read_cr3()
    _boot_cr3: uint64 = cow_boot_cr3()
    _irq_flags: uint64 = 0
    if _boot_cr3 != 0:
        _irq_flags = local_irq_save()
        load_cr3(_boot_cr3)
    _vma_huge_pde_clear_locked(pml4_phys, vaddr)
    if _boot_cr3 != 0:
        load_cr3(_saved_cr3)
        local_irq_restore(_irq_flags)


def _vma_huge_pde_clear_locked(pml4_phys: uint64, vaddr: uint64):
    # §hugepage: zero the 2 MiB PS=1 PDE mapping `vaddr` (after its frame
    # has been freed) and flush the TLB entry, so a later access faults
    # not-present rather than reusing a stale huge translation. No-op if
    # the PDE isn't a present huge leaf.
    if pml4_phys == 0:
        return
    pml4_idx: uint64 = (vaddr >> 39) & 0x1FF
    pdpt_idx: uint64 = (vaddr >> 30) & 0x1FF
    pd_idx:   uint64 = (vaddr >> 21) & 0x1FF
    pml4: Ptr[uint64] = cast[Ptr[uint64]](pml4_phys & VMA_PT_ADDR_MASK)
    pml4e: uint64 = pml4[pml4_idx]
    if (pml4e & VMA_PT_FLAG_P) == 0:
        return
    pdpt: Ptr[uint64] = cast[Ptr[uint64]](pml4e & VMA_PT_ADDR_MASK)
    pdpte: uint64 = pdpt[pdpt_idx]
    if (pdpte & VMA_PT_FLAG_P) == 0 or (pdpte & VMA_PT_FLAG_PS) != 0:
        return
    pd: Ptr[uint64] = cast[Ptr[uint64]](pdpte & VMA_PT_ADDR_MASK)
    pde: uint64 = pd[pd_idx]
    if (pde & VMA_PT_FLAG_P) != 0 and (pde & VMA_PT_FLAG_PS) != 0:
        pd[pd_idx] = 0
        invlpg_one(vaddr & ~(VMA_HUGE_SIZE - 1))


def _vma_free_cow_range(pml4_phys: uint64, vlo: uint64, vhi: uint64):
    # Free every present 4 KiB page of a COW node in [vlo, vhi) through
    # the COW refcount. cow_drop_page(phys) returns 1 when this was the
    # last holder (refcount fell to 0) — only then is the page returned
    # to the buddy allocator. A page another process still maps COW
    # (refcount > 1) drops to a lower count and is left alone.
    #
    # Each surviving page of the original buddy run is freed at order 0;
    # free_pages' buddy-merge logic re-coalesces neighbouring free pages
    # back into the larger run, so no fragmentation accumulates once a
    # run is fully released.
    #
    # ZAP-AFTER-FREE (aliasing fix): once a frame is returned to the buddy
    # allocator its PTE MUST be cleared and the TLB entry flushed — exactly
    # the invariant _vma_zap_priv_range documents ("a present PTE always
    # means the frame is NOT yet freed"). Leaving the PTE present hands the
    # task's PML4 a live mapping of a frame that is back on the buddy free
    # list; a later alloc_pages / _kmalloc_large re-issues that frame and,
    # because Hamnix has no kernel direct map (mm/page_alloc.ad:52 — the
    # kernel reaches phys through the CURRENT CR3), the kernel marker store
    # in _kmalloc_large faults through the stale (RO/COW or RW) user PTE.
    # The brk arena and user stack are identity-mapped (vaddr == phys at
    # low RAM), so their freed frames collide directly with the buddy pool
    # this allocator hands back. We clear the PTE for EVERY page we drop a
    # COW reference on — even a still-shared page (refcount > 1, not freed):
    # this task is releasing the range, so it must stop mapping a frame
    # another task still owns. _vma_pte_slot_addr returns the leaf slot
    # address so we clear in place without a second walk.
    vaddr: uint64 = vlo
    while vaddr < vhi:
        pslot: uint64 = _vma_pte_slot_addr(pml4_phys, vaddr)
        if pslot != 0:
            pte: uint64 = cast[Ptr[uint64]](pslot)[0]
            if (pte & VMA_PT_FLAG_P) != 0:
                phys: uint64 = pte & VMA_PT_ADDR_MASK
                # Clear the PTE BEFORE returning the frame so the buddy
                # free list never coexists with a present user mapping of
                # the same frame, then flush the stale TLB entry.
                cast[Ptr[uint64]](pslot)[0] = 0
                invlpg_one(vaddr)
                if phys != 0:
                    if cow_drop_page(phys) != 0:
                        free_page(phys)
        vaddr = vaddr + VMA_PAGE_SIZE


def _cow_release_forked_range(pml4_phys: uint64, vlo: uint64, vhi: uint64):
    # Release a FORK CHILD's COW-share of a span that is OWNED by the
    # PARENT: the region-backed ELF image / PT_INTERP, or the parent's
    # alloc_pages() user stack. At the child's execve the child must
    #   (1) DROP its per-PFN COW reference — so the parent's frame falls
    #       2 -> 1 and is never stranded at a stale count (this is the
    #       do_rfork/do_clone fork+exec poison dfd59371 set out to fix), and
    #   (2) CLEAR its stale PTE + flush the TLB — stop mapping a frame it no
    #       longer owns,
    # but it must NEVER return an owner frame to an allocator. The OWNER is
    # the sole reclaimer: region_free (image / interp) or free_pages(
    # ustack_phys) at the owner's own task_reap.
    #
    # WHY A SEPARATE HELPER (the live-task use-after-free this closes):
    # _vma_free_cow_range's "cow_drop_page returned 1 -> free_page(phys)"
    # arm is correct for a task's OWN buddy-backed VMA / brk frames, but
    # FATAL for these owner-region spans. The image / interp are
    # region_alloc()'d (memblock pool, DISJOINT from the buddy pool); the
    # user stack is the parent's alloc_pages() run. cow_drop_page returns 1
    # for BOTH a genuine last-holder (refcount 1 -> 0) AND an untracked
    # frame (refcount 0). Under app-spawn load a shared image .text frame's
    # count is momentarily 1 exactly when a sibling child tears it down
    # (overlapping reserve/overlay cover, or a race in the share/drop
    # accounting) — so cow_drop_page hits 0, and free_page() then pooled a
    # frame the LIVE parent still maps as EXECUTABLE .text into the BUDDY
    # allocator. A later kernel alloc_page reissued it (US=0, supervisor),
    # and the parent NX-faulted fetching its own code from a reused frame
    # (code=139, "NO covering VMA" because the image is region-backed, not
    # a VmaNode). See dfd59371's regression.
    #
    # THE INVARIANT: a fork child owns ONLY the frames it privately
    # COW-FAULTED after the fork (a .data/.bss or stack page it wrote).
    # cow_resolve_pte copies those to a fresh alloc_page()'d frame that is
    # "born untracked" — refcount 0. So refcount 0 == child-private buddy
    # frame -> free_page (else it leaks). refcount >= 1 == owner/relative-
    # shared -> cow_drop_page only, NEVER free_page. This makes it
    # impossible to hand a shared/owner frame to any allocator while a live
    # relative still maps it, without reintroducing the poison (the child
    # still drops its reference, so the parent's count is not stranded).
    vaddr: uint64 = vlo
    while vaddr < vhi:
        pslot: uint64 = _vma_pte_slot_addr(pml4_phys, vaddr)
        if pslot != 0:
            pte: uint64 = cast[Ptr[uint64]](pslot)[0]
            if (pte & VMA_PT_FLAG_P) != 0:
                phys: uint64 = pte & VMA_PT_ADDR_MASK
                # Clear the PTE BEFORE any free so a buddy free list never
                # coexists with a present user mapping of the same frame,
                # then flush the stale TLB entry (same rule as
                # _vma_free_cow_range's ZAP-AFTER-FREE invariant).
                cast[Ptr[uint64]](pslot)[0] = 0
                invlpg_one(vaddr)
                if phys != 0:
                    # ONLY cow_drop + zap the PTE; NEVER return the frame to
                    # any allocator. A fork child at exec owns NO owner-region
                    # frame: the image / interp are region_alloc()'d and the
                    # user stack is the parent's alloc_pages() run — the OWNER
                    # is the sole reclaimer (region_free / free_pages(
                    # ustack_phys) at its own reap). The child's only duty is
                    # to release its COW reference (so the parent's per-PFN
                    # count falls 2->1 and is never stranded — dfd59371's fix
                    # preserved) and to stop mapping the frame.
                    #
                    # We do NOT try to free even a "looks private" frame here.
                    # There is no forge-proof way to tell a child-private COW
                    # copy from an owner frame the child took over in place:
                    # cow_resolve_pte's sole-owner branch (a write at refcount
                    # <= 1) sets a SHARED owner stack/.data frame RW + COW-clear
                    # WITHOUT copying, so "RW && !COW" matches owner frames too
                    # — free_page-ing one corrupts the parent's live stack run
                    # (breaks httpd workers). And an identity-mapped NATIVE
                    # image .text frame is momentarily untracked (refcount 0)
                    # under app-spawn load, so free_page-ing a refcount-0 frame
                    # pooled a frame the LIVE parent still executes into the
                    # BUDDY pool (reissued US=0 -> parent NX-faults on its own
                    # code: the dfd59371 code=139 regression). Never freeing an
                    # owner frame here is the only safe rule; the residual cost
                    # is that a child-private COW copy of a page the child
                    # dirtied between fork and exec leaks until reboot — the
                    # SAME bounded leak the pre-dfd59371 rfork path already had
                    # (it skipped this teardown entirely), never a UAF.
                    cow_drop_page(phys)
        vaddr = vaddr + VMA_PAGE_SIZE


def vma_release_forked_range(slot: uint64, vlo: uint64, vhi: uint64):
    # Slot-based wrapper for _cow_release_forked_range: release `slot`'s
    # COW-share of a PARENT-OWNED reserved span (ELF image / PT_INTERP /
    # user stack) at fork+exec teardown WITHOUT ever freeing an owner frame
    # to an allocator. See _cow_release_forked_range for the full rationale
    # (the live-task .text use-after-free this closes). Use this — NOT
    # vma_free_reserved_range — for the image_cow_shared execve teardown of
    # a fork child's inherited image / interp / stack, all of which are
    # owned and reclaimed by the parent, not this child.
    if vhi <= vlo:
        return
    pml4: uint64 = task_pml4(cast[int32](slot))
    _cow_release_forked_range(pml4, vlo, vhi)


def _vma_zap_priv_range(pml4_phys: uint64, vlo: uint64, vhi: uint64):
    # Boot-CR3 guard (>4GB aliasing) — walks + writes the task's PT pages
    # (and reads the boot slot for the identity-safety compare) by bare
    # physical address; a >4 GiB PT page aliases a live user mapping and
    # #PFs under the live task CR3. Run under the boot CR3's un-aliased
    # identity. invlpg on the live CR3 is still correct after restore.
    _saved_cr3: uint64 = read_cr3()
    _boot_cr3: uint64 = cow_boot_cr3()
    _irq_flags: uint64 = 0
    if _boot_cr3 != 0:
        _irq_flags = local_irq_save()
        load_cr3(_boot_cr3)
    _vma_zap_priv_range_locked(pml4_phys, vlo, vhi)
    if _boot_cr3 != 0:
        load_cr3(_saved_cr3)
        local_irq_restore(_irq_flags)


def _vma_zap_priv_range_locked(pml4_phys: uint64, vlo: uint64, vhi: uint64):
    # #439 ZAP-ONLY teardown walk: clear every present 4 KiB PTE in
    # [vlo, vhi) that lives in a TASK-PRIVATE page table, WITHOUT
    # freeing the frames — the caller owns the frames through its own
    # descriptors (chunk array / backing run) and returns them to the
    # buddy allocator itself. This is the idempotence half of the
    # ownership contract: teardown walks overlap (task_reap runs
    # vma_clear and then the brk-reservation sweep over the SAME page
    # tables; execve reuses the task's PML4), so any arm that frees
    # frames while leaving their PTEs present hands the next walk a
    # dangling mapping and the buddy allocator a DOUBLE FREE (free-list
    # self-cycle → silent IRQs-off wedge). After this walk, a present
    # PTE always means "frame not yet freed".
    #
    # BOOT-TABLE SAFETY: a slot that resolves to the SAME address
    # through the pristine boot hierarchy is part of the global
    # identity map every native task shares — never zap it (that would
    # unmap kernel RAM system-wide). Only privately-cracked tables
    # (per-task PDPT/PD/PT clones made by elf_install_user_mapping /
    # _cow_resolve_pte_slot) are written. invlpg_one is harmless when
    # the walked tables are not the live CR3 (dead-task reap) and
    # required when they are (munmap on a live task).
    if pml4_phys == 0:
        return
    boot: uint64 = cow_boot_cr3() & VMA_PT_ADDR_MASK
    if (pml4_phys & VMA_PT_ADDR_MASK) == boot:
        return
    vaddr: uint64 = vlo
    while vaddr < vhi:
        pslot: uint64 = _vma_pte_slot_addr(pml4_phys, vaddr)
        if pslot != 0:
            bslot: uint64 = 0
            if boot != 0:
                bslot = _vma_pte_slot_addr(boot, vaddr)
            if pslot != bslot:
                pte: uint64 = cast[Ptr[uint64]](pslot)[0]
                if (pte & VMA_PT_FLAG_P) != 0:
                    cast[Ptr[uint64]](pslot)[0] = 0
                    invlpg_one(vaddr)
        vaddr = vaddr + VMA_PAGE_SIZE


def vma_restore_kernel_identity_range(pml4_phys: uint64,
                                      vlo: uint64, vhi: uint64):
    # Restore the KERNEL identity map (vaddr == phys, US=0, RW, present)
    # over [vlo, vhi) in a task's PRIVATE cracked page tables — undoing an
    # explicit US=1 user mapping that previously overrode the identity
    # backfill in this 4 KiB-granular PT. This is the teardown counterpart
    # of fs/elf.ad::_build_identity_pt (whose leaves are `addr | RW | P`,
    # US=0); after this call the leaf is back to the kernel-only identity
    # state every other low-RAM page in the cracked PT carries.
    #
    # WHY RESTORE (not clear to 0): Hamnix has NO kernel direct map
    # (mm/page_alloc.ad:52) — the kernel reaches a physical frame ONLY
    # through whatever the CURRENT CR3 maps. The Linux user stack is the
    # last user-data region still IDENTITY-mapped at low RAM (brk/image/
    # mmap were decoupled to high VAs). When such a stack is freed back to
    # the buddy allocator on execve-replace, two failures must BOTH be
    # avoided in the OWNING task's live CR3:
    #   (a) leaving the US=1 user PTE present -> a later alloc_pages /
    #       _kmalloc_large supervisor write to the frame's identity address
    #       faults (RW=1 US=1 -> SMAP #PF) — the original crash; and
    #   (b) clearing the PTE to 0 -> the frame is now UNMAPPED in this CR3,
    #       so the same kernel write faults "not present" (err=0x2) — the
    #       crash clearing-to-0 exposed.
    # Restoring the US=0 kernel identity leaf fixes both: the buddy frame
    # stays kernel-writable through the identity PTE (exactly like every
    # other free low-RAM frame), while no CPL=3 user mapping of it survives.
    # A fresh user mapping for a later owner simply overrides the leaf again.
    #
    # BOOT-TABLE SAFETY (mirrors _vma_zap_priv_range): a slot that resolves
    # to the same address through the pristine boot hierarchy is part of the
    # shared global identity map — it is ALREADY kernel identity, so leave
    # it untouched (writing it would be redundant and risks touching a
    # shared table). Only privately-cracked leaves are rewritten.
    if pml4_phys == 0:
        return
    boot: uint64 = cow_boot_cr3() & VMA_PT_ADDR_MASK
    if (pml4_phys & VMA_PT_ADDR_MASK) == boot:
        return
    vaddr: uint64 = vlo & ~(VMA_PAGE_SIZE - 1)
    while vaddr < vhi:
        pslot: uint64 = _vma_pte_slot_addr(pml4_phys, vaddr)
        if pslot != 0:
            bslot: uint64 = 0
            if boot != 0:
                bslot = _vma_pte_slot_addr(boot, vaddr)
            if pslot != bslot:
                # Kernel identity leaf: phys == vaddr, RW=1, P=1, US=0.
                cast[Ptr[uint64]](pslot)[0] = vaddr | 0x2 | VMA_PT_FLAG_P
                invlpg_one(vaddr)
        vaddr = vaddr + VMA_PAGE_SIZE


def _vma_node_free(slot: uint64, node: uint64, pml4_phys: uint64):
    # Release the node's backing pages (if any) then the node itself.
    # #174: `slot` identifies the owning task so a demand-paged node's
    # freed pages can be UNCHARGED from that task's namespace residency
    # (charge happened per-page at demand-fault time). Only demand pages
    # are namespace-charged today, so only that arm uncharges.
    # backing == 0 marks "no kernel-owned pages here" (an alias node
    # for a MAP_FIXED slice inside an enclosing region; only the
    # enclosing node owns the pages).
    #
    # COW node (is_cow == 1): the node's pages were COW-shared on fork,
    # so the recorded backing run is stale (COW resolution can repoint
    # PTEs at fresh pages). Free by walking the owning task's page
    # table over [start, end) and routing each physical page through
    # cow_drop_page — see _vma_free_cow_range. `pml4_phys` is the PML4
    # of the task that owns this VMA list.
    #
    # A multi-chunk VMA (nchunks > 0) instead owns an array of VmaChunk
    # descriptors; free every chunk at its own order, then release the
    # descriptor array. backing/order are unused for such nodes.
    # §shared-mmap: a MAP_SHARED writable file-backed VMA flushes its
    # dirty resident pages to the backing file BEFORE its frames are
    # released (munmap and task teardown both reach here). This realises
    # the POSIX guarantee that munmap of a MAP_SHARED mapping writes back
    # outstanding modifications. _vma_writeback_node tolerates a -EROFS
    # backing (it never appears here — the mmap path refuses a read-only
    # backing for MAP_SHARED-writable) and only flushes PTE-dirty pages.
    if cast[Ptr[VmaNode]](node)[0].is_file_shared != 0:
        _vma_writeback_node(node, pml4_phys,
                            cast[Ptr[VmaNode]](node)[0].start,
                            cast[Ptr[VmaNode]](node)[0].end)
        # §shared-mmap coherence: this VMA's resident frames are SHARED.
        # Two sub-cases:
        #
        #  (a) tmpfs-DIRECT (file_marker == FD_TMPFS_MARK): the mapped
        #      frames ARE the tmpfs file's own storage pages — owned by
        #      tmpfs, NOT this VMA. Clear the PTEs but NEVER free the
        #      pages (tmpfs frees them when the file is unlinked /
        #      truncated). No cow refcount / page-cache entry exists.
        #
        #  (b) copy-cache (ext4 / kernel-buffer backings): one physical
        #      page per (backing, offset) across every mapper, refcounted
        #      in the COW table and recorded in the page cache. Drop one
        #      reference per resident page; cow_drop_page returns 1 only
        #      for the LAST mapper, at which point we evict the cache
        #      entry and return the frame to the buddy allocator.
        #
        # Either way this replaces the generic is_demand free walk (which
        # would free_page() a shared / tmpfs-owned frame and corrupt it).
        fs_marker: uint32 = cast[uint32](cast[Ptr[VmaNode]](node)[0].file_marker)
        fs_direct: int32 = 0
        if fs_marker == VMA_FD_TMPFS_MARK:
            fs_direct = 1
        fs_start: uint64 = cast[Ptr[VmaNode]](node)[0].start
        fs_end:   uint64 = cast[Ptr[VmaNode]](node)[0].end
        fsa: uint64 = fs_start
        freed_fs: uint64 = 0
        while fsa < fs_end:
            fpte_slot: uint64 = _vma_pte_slot_addr(pml4_phys, fsa)
            if fpte_slot != 0:
                fpte: uint64 = cast[Ptr[uint64]](fpte_slot)[0]
                if (fpte & VMA_PT_FLAG_P) != 0:
                    fphys: uint64 = fpte & VMA_PT_ADDR_MASK
                    if fs_direct != 0:
                        # tmpfs-owned: just clear the PTE, never free.
                        cast[Ptr[uint64]](fpte_slot)[0] = 0
                        freed_fs = freed_fs + 1
                    elif fphys != 0:
                        if cow_drop_page(fphys) != 0:
                            vma_pgc_drop_frame(fphys)
                            free_page(fphys)
                        freed_fs = freed_fs + 1
            fsa = fsa + VMA_PAGE_SIZE
        if freed_fs > 0:
            nscap_mem_uncharge_slot(slot, freed_fs * 4096)
        if nr_vma_nodes_live > 0:
            nr_vma_nodes_live = nr_vma_nodes_live - 1
        kfree(node)
        return

    # §hugepage: a MAP_HUGETLB VMA owns 2 MiB huge frames installed as
    # PS=1 PDEs (NOT 4 KiB PTEs). Walk the range at 2 MiB granularity;
    # each resident huge PDE points at a 2 MiB-aligned order-9 buddy run
    # that is freed whole with free_pages(phys, VMA_HUGE_ORDER), then the
    # PDE is cleared and the TLB flushed. Demand-charged 2 MiB per page,
    # so uncharge the same. Checked before the generic is_demand arm
    # (a huge VMA is also is_demand).
    if cast[Ptr[VmaNode]](node)[0].is_huge != 0:
        h_start: uint64 = cast[Ptr[VmaNode]](node)[0].start
        h_end:   uint64 = cast[Ptr[VmaNode]](node)[0].end
        haddr: uint64 = h_start
        freed_huge: uint64 = 0
        while haddr < h_end:
            hpde: uint64 = _vma_huge_pde_lookup(pml4_phys, haddr)
            if hpde != 0:
                hphys: uint64 = hpde & VMA_PT_ADDR_MASK
                if hphys != 0:
                    free_pages(hphys, VMA_HUGE_ORDER)
                    _vma_huge_pde_clear(pml4_phys, haddr)
                    freed_huge = freed_huge + 1
            haddr = haddr + VMA_HUGE_SIZE
        if freed_huge > 0:
            nscap_mem_uncharge_slot(slot, freed_huge * VMA_HUGE_SIZE)
            if nr_hugepages_live >= freed_huge:
                nr_hugepages_live = nr_hugepages_live - freed_huge
        if nr_vma_nodes_live > 0:
            nr_vma_nodes_live = nr_vma_nodes_live - 1
        kfree(node)
        return

    # Track 4 UMDF: a FOREIGN overlay (device MMIO BAR or DMA buffer).
    # The PTEs point at physical pages the VMA does NOT own — clear the
    # mappings but never free_page() the frames (device registers, or DMA
    # pages reclaimed explicitly by umdf_task_cleanup). Checked BEFORE the
    # is_demand arm because the overlay sits on a demand reservation.
    if cast[Ptr[VmaNode]](node)[0].is_foreign != 0:
        f_start: uint64 = cast[Ptr[VmaNode]](node)[0].start
        f_end:   uint64 = cast[Ptr[VmaNode]](node)[0].end
        faddr: uint64 = f_start
        while faddr < f_end:
            pslotf: uint64 = _vma_pte_slot_addr(pml4_phys, faddr)
            if pslotf != 0:
                cast[Ptr[uint64]](pslotf)[0] = 0
            faddr = faddr + VMA_PAGE_SIZE
        if nr_vma_nodes_live > 0:
            nr_vma_nodes_live = nr_vma_nodes_live - 1
        kfree(node)
        return

    is_demand: int32 = cast[Ptr[VmaNode]](node)[0].is_demand
    # DEMAND-BSS (2026-06-23): a demand VMA that was COW-shared on fork
    # (is_cow set — e.g. the BSS-demand tail whose parent-resident pages
    # vma_fork_copy COW-shared) carries frames the COW refcount table
    # owns. Freeing them with free_page() here would double-free a still-
    # shared frame. Route such nodes through the is_cow arm below
    # (cow_drop_page arbitrates by per-PFN refcount); the page is returned
    # to the buddy allocator only when the last mapper drops it. A demand
    # node with no COW share (the common case) keeps the fast free_page
    # walk.
    is_cow_demand: int32 = cast[Ptr[VmaNode]](node)[0].is_cow
    if cast[Ptr[VmaNode]](node)[0].is_shared != 0:
        is_cow_demand = 1
    if is_demand != 0 and is_cow_demand == 0:
        # Demand-paged VMA (§142): pages were allocated individually on
        # first access and are NOT tracked in the COW refcount table.
        # Walk the PTE range page by page; any present 4 KiB PTE points
        # at a private (unshared) frame — free it with free_page.
        d_start: uint64 = cast[Ptr[VmaNode]](node)[0].start
        d_end:   uint64 = cast[Ptr[VmaNode]](node)[0].end
        daddr: uint64 = d_start
        freed_pages: uint64 = 0
        while daddr < d_end:
            pte: uint64 = _vma_pte_lookup(pml4_phys, daddr)
            if pte != 0:
                dphys: uint64 = pte & VMA_PT_ADDR_MASK
                if dphys != 0:
                    free_page(dphys)
                    freed_pages = freed_pages + 1
            else:
                # #174: a not-present PTE that is a SWAP ENTRY was still
                # charged to the namespace at demand-fault time (swap-out
                # frees the RAM page but keeps the namespace commitment).
                # Count it for uncharge so the residency doesn't leak when
                # a swapped page's VMA is torn down. _vma_pte_lookup masks
                # to present PTEs, so re-walk the raw PTE slot for the
                # swap test.
                pslot2: uint64 = _vma_pte_slot_addr(pml4_phys, daddr)
                if pslot2 != 0:
                    raw: uint64 = cast[Ptr[uint64]](pslot2)[0]
                    if swap_pte_is_swap(raw) != 0:
                        freed_pages = freed_pages + 1
            daddr = daddr + VMA_PAGE_SIZE
        # #174: return the freed residency to the namespace's quota.
        if freed_pages > 0:
            nscap_mem_uncharge_slot(slot, freed_pages * 4096)
        if nr_vma_nodes_live > 0:
            nr_vma_nodes_live = nr_vma_nodes_live - 1
        kfree(node)
        return
    is_cow: int32 = cast[Ptr[VmaNode]](node)[0].is_cow
    is_shared: int32 = cast[Ptr[VmaNode]](node)[0].is_shared
    is_pinned: int32 = cast[Ptr[VmaNode]](node)[0].is_pinned
    if is_cow != 0 or is_shared != 0 or is_pinned != 0:
        # COW node, §1 MAP_SHARED node, OR §1 pinned (split) node: in
        # all three the recorded backing run is no longer the authority
        # for what this task maps. A COW node's PTEs can be repointed
        # at fresh pages by the COW resolver; a shared node maps frames
        # it co-owns with other processes; a pinned node is one piece
        # of a split VMA whose buddy run is co-owned by sibling pieces.
        # Free by walking the owning task's page table over
        # [start, end) and routing each present frame through
        # cow_drop_page — which returns the frame to the buddy
        # allocator only when its per-PFN refcount falls to 0, so a
        # frame still mapped elsewhere (COW, shared, or a sibling split
        # piece) is left untouched. _vma_free_cow_range serves all
        # three: cow_drop_page is refcount arithmetic that does not
        # care why the frame was multiply held.
        v_start: uint64 = cast[Ptr[VmaNode]](node)[0].start
        v_end:   uint64 = cast[Ptr[VmaNode]](node)[0].end
        _vma_free_cow_range(pml4_phys, v_start, v_end)
        # The COW / shared node never owns a separate backing run /
        # chunk array of its own (vma_fork_copy clears both on the
        # share path), so there is nothing else to release but the
        # descriptor blocks.
        carr: uint64 = cast[Ptr[VmaNode]](node)[0].chunks
        if carr != 0:
            kfree(carr)
        if nr_vma_nodes_live > 0:
            nr_vma_nodes_live = nr_vma_nodes_live - 1
        kfree(node)
        return

    nchunks: int32 = cast[Ptr[VmaNode]](node)[0].nchunks
    if nchunks > 0:
        # #439 ZAP-before-free: a multi-chunk node's frames were mapped
        # into the task's PML4 by an explicit overlay (the large-window
        # path or a MAP_FIXED-at overlay — possibly INSIDE the task's
        # brk reservation, which the reap/execve reservation sweep
        # walks by PTE after this arm runs). Clear those PTEs BEFORE
        # returning the chunks to the buddy allocator so no later
        # PTE-walking teardown can resurrect a freed frame.
        _vma_zap_priv_range(pml4_phys,
                            cast[Ptr[VmaNode]](node)[0].start,
                            cast[Ptr[VmaNode]](node)[0].end)
        carr: uint64 = cast[Ptr[VmaNode]](node)[0].chunks
        if carr != 0:
            i: int32 = 0
            while i < nchunks:
                ce: uint64 = carr + cast[uint64](i) * VMA_CHUNK_SIZE
                cphys: uint64 = cast[Ptr[VmaChunk]](ce)[0].phys
                corder: int32 = cast[Ptr[VmaChunk]](ce)[0].order
                if cphys != 0:
                    free_pages(cphys, corder)
                i = i + 1
            kfree(carr)
        if nr_vma_nodes_live > 0:
            nr_vma_nodes_live = nr_vma_nodes_live - 1
        kfree(node)
        return
    backing: uint64 = cast[Ptr[VmaNode]](node)[0].backing
    if backing != 0:
        # #439 ZAP-before-free, same contract as the multi-chunk arm.
        # For a NATIVE task the eager-identity node's PTEs are the
        # shared boot identity map — _vma_zap_priv_range leaves those
        # alone (boot-table safety) and only clears privately-cracked
        # overlays.
        _vma_zap_priv_range(pml4_phys,
                            cast[Ptr[VmaNode]](node)[0].start,
                            cast[Ptr[VmaNode]](node)[0].end)
        order: int32 = cast[Ptr[VmaNode]](node)[0].order
        free_pages(backing, order)
        # #174: the single-chunk eager path (vma_alloc) charged the VMA's
        # page-rounded length to the namespace at create time. Give it
        # back symmetrically (end - start == that page-rounded length).
        b_start: uint64 = cast[Ptr[VmaNode]](node)[0].start
        b_end:   uint64 = cast[Ptr[VmaNode]](node)[0].end
        nscap_mem_uncharge_slot(slot, b_end - b_start)
    if nr_vma_nodes_live > 0:
        nr_vma_nodes_live = nr_vma_nodes_live - 1
    kfree(node)


def _order_for_bytes(n: uint64) -> int32:
    # Smallest alloc_pages(order) that satisfies an n-byte request.
    # MAX_ORDER=10 -> 4 MiB per single alloc_pages call. Returns -1
    # when n exceeds one MAX_ORDER chunk; callers above 4 MiB take the
    # multi-chunk path instead of treating that as an error.
    order: int32 = 0
    block: uint64 = VMA_PAGE_SIZE
    while block < n:
        if order >= VMA_MAX_ORDER:
            return -1
        order = order + 1
        block = block << 1
    return order


def _order_for_chunk(n: uint64) -> int32:
    # Order covering an n-byte chunk that is KNOWN to be <= 4 MiB.
    # Identical to _order_for_bytes but never returns -1 (the caller
    # guarantees n <= VMA_MAX_CHUNK).
    order: int32 = 0
    block: uint64 = VMA_PAGE_SIZE
    while block < n:
        order = order + 1
        block = block << 1
    return order


# ---------------------------------------------------------------------
# List walk
# ---------------------------------------------------------------------

# ---------------------------------------------------------------------
# Public VMA-iteration accessors (#173 core-dump consumer)
# ---------------------------------------------------------------------
#
# kernel/core/coredump.ad walks a dying task's VMAs to emit one PT_LOAD
# per readable region. It must not reach into the VmaNode struct
# directly (the layout is private to this module), so expose a minimal
# opaque iterator: first node, next node, and the three fields the core
# dumper needs (start vaddr, end vaddr, prot bits). The returned values
# are plain integers; an opaque node handle of 0 means end-of-list.

def vma_iter_first(slot: uint64) -> uint64:
    return task_vma_list_head(slot)


def vma_iter_next(node: uint64) -> uint64:
    if node == 0:
        return 0
    return _vma_node_get_next(node)


def vma_node_start(node: uint64) -> uint64:
    if node == 0:
        return 0
    return _vma_node_start(node)


def vma_node_end(node: uint64) -> uint64:
    if node == 0:
        return 0
    return _vma_node_end(node)


def vma_node_prot(node: uint64) -> int32:
    if node == 0:
        return 0
    return cast[Ptr[VmaNode]](node)[0].prot


def vma_page_present(slot: uint64, vaddr: uint64) -> int32:
    # 1 iff the 4 KiB page at `vaddr` is present in `slot`'s page table.
    # The core dumper calls this per page before copying its bytes so an
    # unbacked / not-yet-demand-faulted page in a readable VMA is skipped
    # instead of faulting the kernel on the read. Read-only PT walk.
    pml4: uint64 = task_pml4(cast[int32](slot))
    if pml4 == 0:
        return 0
    pte: uint64 = _vma_pte_lookup(pml4, vaddr)
    if pte == 0:
        return 0
    return 1


def task_vsize_bytes(slot: uint64) -> uint64:
    # /proc/<pid>/stat field 23 (vsize): virtual memory size in BYTES.
    # Sum of (end - start) over all VMAs. Computed on demand from the
    # opaque iterator so there is no maintained counter to drift.
    total: uint64 = 0
    node: uint64 = vma_iter_first(slot)
    while node != 0:
        total = total + (vma_node_end(node) - vma_node_start(node))
        node = vma_iter_next(node)
    return total


def task_rss_pages(slot: uint64) -> uint64:
    # /proc/<pid>/stat field 24 (rss): resident set size in PAGES.
    # Count present 4 KiB pages across all VMAs via a read-only PT walk
    # (vma_page_present never faults). Computed on demand — no counter.
    pages: uint64 = 0
    node: uint64 = vma_iter_first(slot)
    while node != 0:
        a: uint64 = vma_node_start(node)
        e: uint64 = vma_node_end(node)
        while a < e:
            if vma_page_present(slot, a) == 1:
                pages = pages + 1
            a = a + 4096
        node = vma_iter_next(node)
    return pages


# ---------------------------------------------------------------------
# §cachestat — file page-cache residency over a byte range (nr 451)
# ---------------------------------------------------------------------
#
# In Hamnix a file's "page cache" is the set of its pages that have been
# demand-faulted into a file-backed VMA (is_file=1, see vma_alloc_file_*).
# A page that has been touched is PRESENT in the task's page table (the
# #PF handler read its bytes from the backing file); a page never touched
# (or dropped via madvise(MADV_DONTNEED), which clears its PTE) is NOT
# present. So the present/not-present PTE state of a file-backed VMA IS
# the per-file page-cache residency — exactly what cachestat(2) reports.
#
# vma_cachestat_count walks the CURRENT-mapped file-backed VMAs of `slot`
# whose backing identity (marker, backing) matches the queried file, and
# over the page-aligned span covering the byte range [off, off+len)
# counts:
#   *out_cache : pages PRESENT in the page table (resident in cache)
#   *out_dirty : present pages whose PTE Dirty bit (0x40) is set — a
#                MAP_SHARED-writable file page that was written and not yet
#                flushed back. A MAP_PRIVATE / read-only file page is never
#                dirty (its writes go to a private COW copy, never the file).
#
# nr_writeback / nr_evicted / nr_recently_evicted are 0: Hamnix has no
# asynchronous write-back queue and keeps no per-file eviction history, so
# the honest answer for those counters is zero (not a stub — there is no
# such state to report). The byte range is clamped to the VMA's mapped
# extent; the same file page mapped by two VMAs is counted once because
# the residency is read straight off the (single) page table.
#
# Returns the number of file pages spanned by the range (the denominator
# the caller can sanity-check against), with *out_cache / *out_dirty
# filled. A read-only PT walk — never faults, never mutates. (The PTE Dirty
# bit constant VMA_PT_FLAG_D == 0x40 is defined later in this module and is
# module-global, so it resolves here.)


def vma_cachestat_count(slot: uint64, marker: uint32, backing: uint64,
                        off: uint64, length: uint64,
                        out_cache: Ptr[uint64],
                        out_dirty: Ptr[uint64]) -> uint64:
    out_cache[0] = 0
    out_dirty[0] = 0
    pml4: uint64 = task_pml4(cast[int32](slot))
    # Page-aligned [scan_lo, scan_hi) covering the queried byte range, in
    # FILE-offset space. length==0 means "to end of file" in Linux; the
    # caller passes the clamped length, so 0 here means an empty range.
    scan_lo: uint64 = off & ~(VMA_PAGE_SIZE - 1)
    scan_hi: uint64 = off + length
    if length == 0:
        return 0
    span_pages: uint64 = ((scan_hi + VMA_PAGE_SIZE - 1) \
                          & ~(VMA_PAGE_SIZE - 1)) - scan_lo
    span_pages = span_pages / VMA_PAGE_SIZE

    node: uint64 = vma_iter_first(slot)
    while node != 0:
        n: Ptr[VmaNode] = cast[Ptr[VmaNode]](node)
        if n[0].is_file == 1 \
           and cast[uint32](n[0].file_marker) == marker \
           and n[0].backing == backing:
            # This VMA maps the queried file. Walk each mapped page; its
            # FILE offset is file_offset + (va - start). Count a page iff
            # its file offset falls inside the queried [off, off+length).
            va: uint64 = n[0].start
            vend: uint64 = n[0].end
            fbase: uint64 = n[0].file_offset
            while va < vend:
                foff: uint64 = fbase + (va - n[0].start)
                if foff >= scan_lo and foff < scan_hi:
                    pte: uint64 = _vma_pte_lookup(pml4, va)
                    if pte != 0:
                        out_cache[0] = out_cache[0] + 1
                        if (pte & VMA_PT_FLAG_D) != 0:
                            out_dirty[0] = out_dirty[0] + 1
                va = va + VMA_PAGE_SIZE
        node = vma_iter_next(node)
    return span_pages


def vma_find(slot: uint64, addr: uint64) -> uint64:
    # O(log n) point query via the interval tree (Wave-3). Falls back to a
    # linear list walk only if the tree is somehow empty while the list is
    # not (it never is — insert/unlink keep them consistent — but the
    # belt-and-braces walk costs nothing on the empty-tree path).
    # Held under the mm write lock (recursive — the fault slow path already
    # owns it when it calls here) so this tree WALK never races a concurrent
    # structural mutation on the same mm.
    vma_mm_write_lock(slot)
    node: uint64 = _vma_tree_find(slot, addr)
    if node != 0:
        vma_mm_write_unlock(slot)
        return node
    # BELT-AND-BRACES (apt NX exec-fault). As of the #471 fix _vma_tree_find
    # is a correct interval-stabbing query (it visits every covering interval
    # via subtree_max_end, so it can no longer return 0 for an address an
    # OUTER reservation covers while an inner overlay shadows the descent).
    # This exhaustive linear scan is therefore now redundant in the common
    # case, but it is kept as a cheap last-resort safety net (and as a
    # cross-check oracle for the self-test): if the tree were ever corrupted,
    # a covered address is still never reported unmapped. NOTE the subtle
    # semantic difference: this scan prefers an EXEC-permitting cover, whereas
    # _vma_tree_find returns the greatest-start (innermost) overlay; for a
    # single overlay per page (the real ld.so layout) they pick the same node.
    best: uint64 = 0
    scan: uint64 = task_vma_list_head(slot)
    while scan != 0:
        s: uint64 = _vma_node_start(scan)
        e: uint64 = _vma_node_end(scan)
        if s <= addr and addr < e:
            if best == 0:
                best = scan
            elif (cast[Ptr[VmaNode]](scan)[0].prot & VMA_PROT_EXEC) != 0:
                best = scan
        scan = _vma_node_get_next(scan)
    vma_mm_write_unlock(slot)
    return best


_nxdiag_dumps: uint64 = 0


def vma_dbg_dump_cover(slot: uint64, addr: uint64):
    # DIAG (apt NX exec-fault): dump EVERY VMA covering `addr` (there may be
    # overlapping nodes — the ld.so reserve+overlay idiom) with its prot, plus
    # the leaf PTE for `addr`. The smoking gun for the NX exec-fault is a
    # covering VMA that PERMITS exec (prot & EXEC) while the leaf PTE has NX
    # set — i.e. an overlapping data/anon overlay re-stamped the code page NX.
    #
    # Rate-limited to the first few faults (a SIGSEGV handler storm re-faults
    # thousands of times) and forced to EMERG per message so the dump mirrors
    # to the live serial console even after userland goes interactive (the
    # console-loglevel gate otherwise suppresses INFO-level kernel chatter, so
    # the dump would only reach the /proc/kmsg ring the test never captures).
    if _nxdiag_dumps >= 6:
        return
    _nxdiag_dumps = _nxdiag_dumps + 1
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[nxdiag] === dump for va=%p slot=%d ===\n", addr, slot)
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[nxdiag] image=[%p,%p)\n", task_image_lo(slot), task_image_hi(slot))
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[nxdiag] interp=[%p,%p)\n",
            task_interp_lo(slot), task_interp_hi(slot))
    pml4: uint64 = task_pml4(cast[int32](slot))
    cur: uint64 = task_vma_list_head(slot)
    ncov: uint64 = 0
    while cur != 0:
        s: uint64 = _vma_node_start(cur)
        e: uint64 = _vma_node_end(cur)
        if s <= addr and addr < e:
            ncov = ncov + 1
            pr:  int32 = cast[Ptr[VmaNode]](cur)[0].prot
            isf: int32 = cast[Ptr[VmaNode]](cur)[0].is_file
            isd: int32 = cast[Ptr[VmaNode]](cur)[0].is_demand
            fo:  uint64 = cast[Ptr[VmaNode]](cur)[0].file_offset
            ffd: int32  = cast[Ptr[VmaNode]](cur)[0].file_fd
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk2("[nxdiag] cover [%p,%p)\n", s, e)
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk2("[nxdiag]   prot=%d is_file=%d\n",
                    cast[uint64](pr), cast[uint64](isf))
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk2("[nxdiag]   is_demand=%d exec=%d\n",
                    cast[uint64](isd), cast[uint64](pr & VMA_PROT_EXEC))
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk2("[nxdiag]   file_off=0x%x fd=%d", fo, cast[uint64](ffd))
            if isf != 0 and ffd >= 0:
                p: Ptr[uint8] = task_fd_opened_path_ptr(current_task(),
                                                        cast[uint64](ffd))
                if p[0] != 0:
                    printk1(" %s", cast[uint64](p))
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk0("\n")
        cur = _vma_node_get_next(cur)
    if ncov == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[nxdiag] NO covering VMA for va=%p\n", addr)
    # NEIGHBOURHOOD: dump the VMAs bracketing `addr` (the greatest-start node
    # that starts at/below addr, and the first node that starts above it) so a
    # COVERAGE HOLE — an exec .text overlay that exists as a sibling but does
    # NOT extend over this page — is visible. For the ld.so reserve+overlay
    # idiom the exec overlay and the RO/RW reservation are distinct nodes; if
    # the handler page falls in a gap between them (or under the reservation
    # only), that shows up here as an EXEC node ending just short of `addr`.
    lo_n: uint64 = 0
    hi_n: uint64 = 0
    c2: uint64 = task_vma_list_head(slot)
    while c2 != 0:
        cs: uint64 = _vma_node_start(c2)
        if cs <= addr:
            if lo_n == 0 or cs > _vma_node_start(lo_n):
                lo_n = c2
        else:
            if hi_n == 0 or cs < _vma_node_start(hi_n):
                hi_n = c2
        c2 = _vma_node_get_next(c2)
    if lo_n != 0:
        lp: int32 = cast[Ptr[VmaNode]](lo_n)[0].prot
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[nxdiag] nbr-lo [%p,%p)", _vma_node_start(lo_n),
                _vma_node_end(lo_n))
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2(" prot=%d exec=%d\n", cast[uint64](lp),
                cast[uint64](lp & VMA_PROT_EXEC))
    if hi_n != 0:
        hp: int32 = cast[Ptr[VmaNode]](hi_n)[0].prot
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[nxdiag] nbr-hi [%p,%p)", _vma_node_start(hi_n),
                _vma_node_end(hi_n))
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2(" prot=%d exec=%d\n", cast[uint64](hp),
                cast[uint64](hp & VMA_PROT_EXEC))
    # STEP-1 TREE-vs-LIST VERDICT: does the BST point query agree with the
    # exhaustive list walk above? If the list found a covering node (ncov>0,
    # possibly EXEC) but _vma_tree_find returns 0 or a non-EXEC sibling, the
    # interval-tree point query is the bug (theory-a). If BOTH the list and
    # the tree see NO exec cover, the overlay genuinely never mapped an EXEC
    # VMA over this page (theory-b — a real coverage hole / wild jump).
    tf: uint64 = _vma_tree_find(slot, addr)
    if tf == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[nxdiag] tree-find=0 (BST point query MISSED va=%p)\n", addr)
    else:
        tfp: int32 = cast[Ptr[VmaNode]](tf)[0].prot
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[nxdiag] tree-find [%p,%p)\n",
                _vma_node_start(tf), _vma_node_end(tf))
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[nxdiag]   tree prot=%d exec=%d\n",
                cast[uint64](tfp), cast[uint64](tfp & VMA_PROT_EXEC))
    pslot: uint64 = _vma_pte_slot_addr(pml4, addr)
    if pslot == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[nxdiag] no leaf PTE slot for va=%p (huge/absent)\n", addr)
        return
    pte: uint64 = cast[Ptr[uint64]](pslot)[0]
    nxset: uint64 = 0
    if (pte & PT_FLAG_NX) != 0:
        nxset = 1
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[nxdiag] leaf PTE pte=%p NX=%d\n", pte, nxset)
    # COW-poison probe: the fault jumps to a garbage function pointer that
    # __run_exit_handlers demangled out of glibc's exit-handler list. If a
    # fork+exec COW teardown poisoned a refcount, the writable pages backing
    # that list are wrongly still COW-shared (refcount>1 where the process is
    # the sole mapper) or freed-while-mapped. Dump the fault frame's COW
    # refcount + a full VMA-list roster (with COW/file/shared/demand flags) so
    # the corrupted region is identifiable from the serial log alone.
    fault_phys: uint64 = pte & VMA_PT_ADDR_MASK
    if fault_phys != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[nxdiag] fault frame phys=%p cow_ref=%d\n",
                fault_phys, cow_refcount(fault_phys))
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[nxdiag] --- full VMA roster (flags: F=file c=cow s=shared d=demand fs=fileshared) ---\n")
    cr: uint64 = task_vma_list_head(slot)
    nvr: uint64 = 0
    while cr != 0 and nvr < 64:
        rs: uint64 = _vma_node_start(cr)
        re: uint64 = _vma_node_end(cr)
        rF: int32 = cast[Ptr[VmaNode]](cr)[0].is_file
        rc: int32 = cast[Ptr[VmaNode]](cr)[0].is_cow
        rsh: int32 = cast[Ptr[VmaNode]](cr)[0].is_shared
        rd: int32 = cast[Ptr[VmaNode]](cr)[0].is_demand
        rfs: int32 = cast[Ptr[VmaNode]](cr)[0].is_file_shared
        rpin: int32 = cast[Ptr[VmaNode]](cr)[0].is_pinned
        rnc: int32 = cast[Ptr[VmaNode]](cr)[0].nchunks
        rbk: uint64 = cast[Ptr[VmaNode]](cr)[0].backing
        rp: int32 = cast[Ptr[VmaNode]](cr)[0].prot
        rflags: uint64 = cast[uint64](rF) \
            | (cast[uint64](rc) << 8) | (cast[uint64](rsh) << 16) \
            | (cast[uint64](rd) << 24) | (cast[uint64](rfs) << 32) \
            | (cast[uint64](rpin) << 40)
        # Detect a PRIOR roster node whose range overlaps this one — the
        # ld.so reserve+overlay double-cover that double-processes COW.
        ov: int32 = 0
        pr: uint64 = task_vma_list_head(slot)
        while pr != 0 and pr != cr:
            ps: uint64 = _vma_node_start(pr)
            pe: uint64 = _vma_node_end(pr)
            if ps < re and rs < pe:
                ov = 1
            pr = _vma_node_get_next(pr)
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[nxdiag] vma [%p,%p)", rs, re)
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2(" prot=%d flags=%p", cast[uint64](rp), rflags)
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2(" nchunks=%d backing=%p", cast[uint64](rnc), rbk)
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1(" overlap=%d\n", cast[uint64](ov))
        cr = _vma_node_get_next(cr)
        nvr = nvr + 1


# ---------------------------------------------------------------------
# Linux-ABI no-syscall watchdog (permanent debug aid)
# ---------------------------------------------------------------------
#
# A Linux-ABI task that spins in USERSPACE issues no syscall, takes no
# fault, and never traps into the kernel — the ONLY kernel entry left is
# the periodic timer IRQ. This watchdog rides that tick: it compares the
# running task's last-syscall stamp (kernel/sched/core.ad, refreshed on
# every Linux syscall dispatch) against jiffies and, once the gap crosses
# WD_THRESH, dumps the interrupted userspace RIP/RSP + a few stack words +
# the VMA that CONTAINS the RIP (so RIP -> library base + module offset)
# and a compact file-backed VMA map. That pins the EXACT spinning function
# without qemu HMP. Built for the weston-terminal / cairo / pixman first-
# frame render spin, but kept as a general aid for any userspace hang.
#
# HZ = 100, so 1 s == 100 jiffies.
WD_THRESH_JIFFIES: uint64 = 500          # 5 s with no syscall -> spinning
WD_REDUMP_JIFFIES: uint64 = 1000         # re-dump the same spin at most every 10 s

# #73 parked-group (lost-wakeup deadlock) diagnostic. When EVERY Linux-ABI
# thread parks off-CPU in a blocking syscall, no ring-3 task is running at a
# timer tick, so the spin watchdog above never fires. These bound a separate
# check that fires when the WHOLE Linux group has issued no syscall for a long
# time. Scan is rate-limited (once/second) so the per-tick cost stays trivial.
WD_GROUP_QUIESCENT_JIFFIES: uint64 = 1500   # 15 s of total group silence -> deadlock suspect
WD_GROUP_REDUMP_JIFFIES:    uint64 = 6000   # re-dump the same parked episode at most every 60 s
WD_GROUP_MIN_THREADS:       uint64 = 4      # only a heavily-threaded process (Firefox) trips it
WD_GROUP_SCAN_JIFFIES:      uint64 = 100    # walk the task table at most once/second
_wd_group_last_scan: uint64 = 0
_wd_group_last_dump: uint64 = 0


def _linux_parked_group_check():
    # Fires independently of which task the timer tick froze: dumps every live
    # Linux task's parked syscall + the futex wait table once the entire Linux
    # userspace group has been syscall-silent past WD_GROUP_QUIESCENT_JIFFIES.
    # This is the diagnostic for a lost-wakeup deadlock (all threads blocked),
    # which the running-spinner watchdog structurally cannot observe.
    now: uint64 = get_jiffies()
    if _wd_group_last_scan != 0 and now >= _wd_group_last_scan \
            and (now - _wd_group_last_scan) < WD_GROUP_SCAN_JIFFIES:
        return
    _wd_group_last_scan = now
    newest: uint64 = 0
    oldest: uint64 = 0
    cnt: uint64 = linux_group_status(&newest, &oldest)
    if cnt == 0 or oldest == 0:
        return
    if now < oldest:
        return
    # Fire on the OLDEST-blocked thread: a flush stall keeps one background
    # thread ticking (newest stays fresh) while the main thread parks for a long
    # time — the oldest gap is what exposes it.
    if (now - oldest) < WD_GROUP_QUIESCENT_JIFFIES:
        return
    # Gate to a HEAVILY-THREADED process (Firefox = 5+ threads/one cr3). This
    # keeps the dump from firing for weston-terminal (1-2 threads, blocks on
    # input) or separate-process httpd workers — no regression noise there.
    if linux_max_thread_group() < WD_GROUP_MIN_THREADS:
        return
    if _wd_group_last_dump != 0 and now >= _wd_group_last_dump \
            and (now - _wd_group_last_dump) < WD_GROUP_REDUMP_JIFFIES:
        return
    _wd_group_last_dump = now
    ngap: uint64 = 0
    if now >= newest:
        ngap = now - newest
    printk_set_level(PRINTK_LEVEL_WARN)
    printk3("[parked-wd] Linux stall: %d live tasks, oldest parked %d ticks, newest %d ticks ago (10ms each) - dumping\n",
            cnt, now - oldest, ngap)
    dump_linux_group_full()   # per-task slot/state/sc_nr/gap/cr3 + futex table


def _wd_resolve_uword(pml4: uint64, uaddr: uint64, out: Ptr[uint64]) -> int32:
    # Non-faulting read of one 8-byte userspace word. Returns 1 on success
    # (word stored via `out`), 0 if the page is not currently present (we do
    # NOT fault it in — that would take mm locks from IRQ context).
    phys: uint64 = uaccess_resolve(pml4, uaddr, 0)
    if phys == 0:
        return 0
    out[0] = cast[Ptr[uint64]](phys)[0]
    return 1


def _wd_dump_stack(ursp: uint64):
    # Emit up to 8 words from the interrupted user stack. These often carry
    # the caller's return address (pin the CALLER frame even when the RIP
    # itself is in a leaf helper) and loop-local values.
    if ursp == 0:
        return
    pml4: uint64 = uaccess_current_pml4()
    i: uint64 = 0
    while i < 8:
        w: uint64 = 0
        a: uint64 = ursp + i * 8
        if _wd_resolve_uword(pml4, a, &w) != 0:
            printk2("[nosys-wd]   stack[%d]=%p\n", i, w)
        else:
            printk1("[nosys-wd]   stack@%p not present\n", a)
            i = 8
        i = i + 1


def _vma_find_in_cr3(cr3: uint64, addr: uint64, out_slot: Ptr[uint64]) -> uint64:
    # #76: a Linux `spawn` process scatters its VMAs across per-thread slots
    # (each thread's own mmap()s land in ITS OWN vma_list_head; there is no
    # single owner). To map a RIP/stack word to a library we must try EVERY
    # slot in the same cr3 group, not just the leader. Returns the covering
    # VmaNode (0 if none) and, via out_slot, the slot whose list held it.
    s: uint64 = 0
    while s < NTASKS:
        if task_pml4(cast[int32](s)) == cr3 and task_vma_list_head(s) != 0:
            n: uint64 = vma_find(s, addr)
            if n != 0:
                out_slot[0] = s
                return n
        s = s + 1
    out_slot[0] = 0
    return 0


def _vma_print_addr_lib(cr3: uint64, addr: uint64) -> int32:
    # Resolve one address against the cr3 group's scattered VMA lists. Only
    # a word in an EXECUTABLE, file-backed VMA is a real return address; print
    # base + file_offset + path (so offline readelf names the symbol) and
    # return 1. Non-exec / anon / unmapped words are stack noise -> return 0.
    hs: uint64 = 0
    vn: uint64 = _vma_find_in_cr3(cr3, addr, &hs)
    if vn == 0:
        return 0
    prot: int32 = cast[Ptr[VmaNode]](vn)[0].prot
    # EXEC-only filter (Linux-ABI code VMAs may be is_file=0: W^X copies the
    # ELF into an anon exec mapping, so requiring is_file would drop every
    # real return frame). A word in any executable VMA is a candidate caller.
    if (prot & VMA_PROT_EXEC) == 0:
        return 0
    isf:  int32 = cast[Ptr[VmaNode]](vn)[0].is_file
    vbase: uint64 = _vma_node_start(vn)
    vfo:   uint64 = cast[Ptr[VmaNode]](vn)[0].file_offset
    vfd:   int32  = cast[Ptr[VmaNode]](vn)[0].file_fd
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk3("      %p base=%p foff=0x%x", addr, vbase, vfo)
    printk1(" isf=%d", cast[uint64](isf))
    if isf != 0 and vfd >= 0:
        pp: Ptr[uint8] = task_fd_opened_path_ptr(&task_table[hs],
                                                 cast[uint64](vfd))
        if pp[0] != 0:
            printk1(" %s", cast[uint64](pp))
    printk0("\n")
    return 1


def vma_dump_rip_info(thread_slot: uint64, mm_slot: uint64, urip: uint64):
    # #76 Firefox parked-wd RIP->library resolver. Lives here (not in
    # core.ad) because it must dereference VmaNode, which core.ad cannot
    # name without a core<->vma import cycle. Resolves `urip` against the
    # VMA list owned by `mm_slot` (the same-cr3 leader) and prints the
    # containing VMA's base + file_offset + open path, so an offline
    # readelf/nm on the DSO turns (urip - base + file_offset) into a
    # symbol. `thread_slot` is only for labelling the line.
    # Search the WHOLE cr3 group (VMAs scatter across per-thread slots).
    cr3: uint64 = task_pml4(cast[int32](thread_slot))
    hs: uint64 = 0
    vn: uint64 = _vma_find_in_cr3(cr3, urip, &hs)
    if vn == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[parked-wd]   slot=%d urip=%p NO-VMA\n", thread_slot, urip)
        return
    vbase: uint64 = _vma_node_start(vn)
    vfo:   uint64 = cast[Ptr[VmaNode]](vn)[0].file_offset
    vfd:   int32  = cast[Ptr[VmaNode]](vn)[0].file_fd
    isf:   int32  = cast[Ptr[VmaNode]](vn)[0].is_file
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk3("[parked-wd]   slot=%d ripvma_base=%p foff=0x%x", thread_slot,
            vbase, vfo)
    printk2(" isfile=%d fd=%d\n", cast[uint64](isf), cast[uint64](vfd))
    if isf != 0 and vfd >= 0:
        pp: Ptr[uint8] = task_fd_opened_path_ptr(&task_table[hs],
                                                 cast[uint64](vfd))
        if pp[0] != 0:
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk1("[parked-wd]   ripvma_path=%s\n", cast[uint64](pp))


def vma_dump_user_stack(thread_slot: uint64, cr3: uint64, ursp: uint64):
    # #76 poor-man's user backtrace for a parked Linux thread. The saved
    # user-RIP is the libc syscall-return trampoline; the real caller chain
    # (glib / GTK / libxul) is spilled on the user stack. Non-faultingly
    # read a window of stack words (via _wd_resolve_uword, which page-walks
    # cr3 without taking mm locks — safe from IRQ context) and print every
    # word that lands in the userspace shared-library code range
    # [0x100000000, 0x300000000): these are candidate return addresses an
    # offline readelf/nm on the staged libxul.so / libc.so resolves to the
    # function that issued the blocking call. Print up to 12 hits from a
    # 64-word (512-byte) scan.
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[parked-wd]   slot=%d ursp=%p bt:\n", thread_slot, ursp)
    hits: uint64 = 0
    j: uint64 = 0
    while j < 256 and hits < 16:
        w: uint64 = 0
        if _wd_resolve_uword(cr3, ursp + j * 8, &w) != 0:
            if w >= 0x100000000 and w < 0x300000000:
                if _vma_print_addr_lib(cr3, w) != 0:
                    hits = hits + 1
        j = j + 1


def _wd_dump_maps(slot: uint64):
    # Compact dump of every FILE-backed VMA: base .. end, file_offset, fd, and
    # the recorded open path if the fd is still live. Combined with the per-
    # mmap [LMOD] trace this gives an authoritative RIP-base -> library table.
    cur: uint64 = task_vma_list_head(slot)
    n: uint64 = 0
    while cur != 0 and n < 256:
        isf: int32 = cast[Ptr[VmaNode]](cur)[0].is_file
        if isf != 0:
            s:   uint64 = _vma_node_start(cur)
            e:   uint64 = _vma_node_end(cur)
            fo:  uint64 = cast[Ptr[VmaNode]](cur)[0].file_offset
            ffd: int32  = cast[Ptr[VmaNode]](cur)[0].file_fd
            pr:  int32  = cast[Ptr[VmaNode]](cur)[0].prot
            printk3("[nosys-wd]   map [%p,%p) off=0x%x", s, e, fo)
            printk2(" fd=%d prot=%d", cast[uint64](ffd), cast[uint64](pr))
            if ffd >= 0:
                p: Ptr[uint8] = task_fd_opened_path_ptr(current_task(),
                                                        cast[uint64](ffd))
                if p[0] != 0:
                    printk1(" %s", cast[uint64](p))
            printk0("\n")
        cur = _vma_node_get_next(cur)
        n = n + 1


def linux_nosyscall_watchdog_tick(user_ctx: uint64, urip: uint64,
                                  ursp: uint64):
    # Timer-tick hook. Fires from arch/x86/kernel/time.ad::timer_interrupt.
    # user_ctx==1 means the timer froze ring-3 code, so `urip`/`ursp` are the
    # genuine userspace RIP/RSP of the running task (from the iret frame).
    # #73 parked-group deadlock check runs FIRST and unconditionally (it does
    # not care which task the tick froze — the deadlocked threads are all
    # off-CPU). Rate-limited internally to once/second.
    _linux_parked_group_check()
    if user_ctx == 0:
        return
    slot: uint64 = current_idx_get()
    if task_is_linux_userspace_at(slot) == 0:
        return
    last: uint64 = task_last_syscall_jiffies(slot)
    if last == 0:
        return
    now: uint64 = get_jiffies()
    if now < last:
        return
    if (now - last) < WD_THRESH_JIFFIES:
        return
    # Rate-limit repeat dumps of the same spin episode.
    lastdump: uint64 = task_wd_last_dump_jiffies(slot)
    first: int32 = 1
    if lastdump != 0:
        first = 0
        if now >= lastdump and (now - lastdump) < WD_REDUMP_JIFFIES:
            return
    set_task_wd_last_dump_jiffies(slot, now)

    printk_set_level(PRINTK_LEVEL_WARN)
    printk2("[nosys-wd] slot=%d spun %d ticks (10ms each) with NO syscall\n",
            slot, now - last)
    printk2("[nosys-wd]   RIP=%p RSP=%p\n", urip, ursp)
    printk1("[nosys-wd]   spinner last_syscall_nr=%d\n",
            task_last_syscall_nr(slot))

    # Which VMA holds the spinning RIP? Lockless list walk — the task is
    # spinning in its OWN userspace, so its VMA list is not being mutated
    # concurrently. Prefer an EXEC-permitting cover (ld.so's reserve+overlay
    # idiom stacks a PROT_NONE reservation under the code overlay).
    best: uint64 = 0
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0:
        s: uint64 = _vma_node_start(cur)
        e: uint64 = _vma_node_end(cur)
        if s <= urip and urip < e:
            if best == 0:
                best = cur
            elif (cast[Ptr[VmaNode]](cur)[0].prot & VMA_PROT_EXEC) != 0:
                best = cur
        cur = _vma_node_get_next(cur)
    if best == 0:
        printk1("[nosys-wd]   RIP not covered by any VMA (va=%p)\n", urip)
    else:
        bs:  uint64 = _vma_node_start(best)
        fo:  uint64 = cast[Ptr[VmaNode]](best)[0].file_offset
        ffd: int32  = cast[Ptr[VmaNode]](best)[0].file_fd
        pr:  int32  = cast[Ptr[VmaNode]](best)[0].prot
        isf: int32  = cast[Ptr[VmaNode]](best)[0].is_file
        modoff: uint64 = urip - bs + fo
        printk3("[nosys-wd]   in VMA base=%p prot=%d is_file=%d\n",
                bs, cast[uint64](pr), cast[uint64](isf))
        printk2("[nosys-wd]   module-off=0x%x (rip-base+file_off) fd=%d\n",
                modoff, cast[uint64](ffd))
        if isf != 0 and ffd >= 0:
            p: Ptr[uint8] = task_fd_opened_path_ptr(current_task(),
                                                    cast[uint64](ffd))
            if p[0] != 0:
                printk1("[nosys-wd]   file=%s\n", cast[uint64](p))

    _wd_dump_stack(ursp)
    # #73 multi-thread stall: the spinner alone is not the whole story — the
    # MAIN thread is parked OFF-CPU in a blocking syscall waiting on this or
    # another thread. Dump every OTHER live Linux task's state + the syscall it
    # is parked in, then the futex wait table, so the log pins which thread
    # blocks on what (futex uaddr / poll / epoll_wait / read).
    printk0("[nosys-wd]   --- all Linux tasks (off-CPU parked threads) ---\n")
    dump_linux_task_states(slot)
    call_linux_futex_dump()
    # Full file-backed map only on the FIRST dump of an episode (it is slow
    # over the serial line); repeats print just the RIP + stack.
    if first != 0:
        _wd_dump_maps(slot)


def linux_nosyscall_watchdog_init():
    # Register the tick hook. Called at boot after the timer + VMA subsystems
    # are up. Idempotent.
    register_linux_nosyscall_wd_hook(linux_nosyscall_watchdog_tick)


# ---------------------------------------------------------------------
# §mseal — per-VMA address-space seal (x86_64 nr 462)
# ---------------------------------------------------------------------
#
# mseal(addr, len) marks every VMA overlapping [addr, addr+len) as sealed
# so its layout is frozen: later mprotect / munmap / mremap /
# madvise(MADV_DONTNEED|FREE|REMOVE) over a sealed byte are rejected
# -EPERM. The mark lives on the existing per-task VMA node (the `sealed`
# field) — no parallel table. These two helpers are the whole mechanism;
# the leaf linux_abi/u_mseal.ad calls vma_seal_range, and vma_protect /
# vma_unmap / vma_madvise / vma_mremap call vma_range_is_sealed to honour
# it. Linux requires the ENTIRE range to be mapped (a hole -> -ENOMEM).

VMA_PERM:   int64 = -1                    # -EPERM
VMA_ENOMEM: int64 = -12                   # -ENOMEM


def vma_seal_range(slot: uint64, addr: uint64, len_in: uint64) -> int64:
    # Seal every page of [addr, addr+len). Linux mseal requires the range
    # to be page-aligned at the start and fully mapped — any unmapped hole
    # is -ENOMEM and NOTHING is sealed. Returns 0 on success.
    if len_in == 0:
        return 0
    if (addr & (VMA_PAGE_SIZE - 1)) != 0:
        return cast[int64](-22)           # -EINVAL: unaligned start
    length: uint64 = (len_in + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)
    end_v: uint64 = addr + length
    # Pass 1 — verify the whole range is mapped before mutating anything,
    # so a partial failure leaves no half-sealed range.
    va: uint64 = addr
    while va < end_v:
        if vma_find(slot, va) == 0:
            return VMA_ENOMEM
        # Advance to the end of the covering VMA (or one page) to keep the
        # scan O(#vmas) rather than O(#pages).
        node: uint64 = vma_find(slot, va)
        ne: uint64 = _vma_node_end(node)
        if ne <= va:
            va = va + VMA_PAGE_SIZE
        else:
            va = ne
    # Pass 2 — stamp the seal on every covered VMA.
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0:
        s: uint64 = _vma_node_start(cur)
        e: uint64 = _vma_node_end(cur)
        # Overlap test: [s,e) intersects [addr,end_v).
        if s < end_v and e > addr:
            cast[Ptr[VmaNode]](cur)[0].sealed = 1
        cur = _vma_node_get_next(cur)
    return 0


def vma_range_is_sealed(slot: uint64, addr: uint64, len_in: uint64) -> int32:
    # 1 iff ANY VMA overlapping [addr, addr+len) is sealed. A destructive
    # op (mprotect/munmap/mremap/madvise-DONTNEED) touching even one sealed
    # byte must be rejected, so this is an OR over the overlap set.
    if len_in == 0:
        return 0
    length: uint64 = (len_in + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)
    addr_al: uint64 = addr & ~(VMA_PAGE_SIZE - 1)
    end_v: uint64 = addr_al + length
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0:
        s: uint64 = _vma_node_start(cur)
        e: uint64 = _vma_node_end(cur)
        if s < end_v and e > addr_al:
            if cast[Ptr[VmaNode]](cur)[0].sealed != 0:
                return 1
        cur = _vma_node_get_next(cur)
    return 0


def _vma_maps_hex16(value: uint64, out: Ptr[uint8]) -> uint64:
    # Render `value` as a fixed-width 16-digit lowercase hex run (the
    # Linux /proc/<pid>/maps address column shape). Returns 16.
    HEX: Ptr[uint8] = "0123456789abcdef"
    i: uint64 = 0
    while i < 16:
        out[i] = HEX[(value >> ((15 - i) * 4)) & 0xF]
        i = i + 1
    return 16


def vma_maps_render(slot: uint64, buf: Ptr[uint8],
                    count: uint64) -> int64:
    # §13: render the task's VMA list in Linux /proc/<pid>/maps shape:
    #
    #   <start>-<end> <perms> 00000000 00:00 0          [anon]
    #
    # One line per VMA node. `perms` is the classic "rwxp" four-char
    # field derived from the node's prot bits (the trailing 'p' — all
    # Hamnix VMAs are private-or-anon at this surface; a shared node
    # renders 's'). The file-offset / dev / inode columns render as
    # zeros — Hamnix VMAs have no backing inode the way Linux's
    # file-mapped regions do — and every region is tagged "[anon]".
    # Stateless: the whole blob is built then copied up to `count`.
    # Returns bytes produced (capped by count).
    if count == 0:
        return 0
    pos: uint64 = 0
    cur: uint64 = task_vma_list_head(slot)
    # RESERVE room at the tail for the synthetic main-thread [stack] line
    # (emitted AFTER the VMA walk). glibc's __pthread_getattr_np reads the
    # WHOLE maps in one shot (devproc_read EOFs a second read), scans for the
    # line whose [from,to) contains __libc_stack_end, and RETURNS ENOENT if it
    # is absent. A large-VMA client (Firefox: hundreds of mmap regions) would
    # otherwise fill `count` with VMA lines and TRUNCATE the trailing [stack]
    # line out of the buffer, so glibc never finds the stack and the caller
    # aborts (MOZ_RELEASE_ASSERT(!res) in Gecko thread stack-registration).
    # Stop the VMA walk STACK_RSV bytes early so the [stack] line always fits;
    # the dropped VMAs are the highest-address ones (below the stack in the
    # sorted list) which glibc's stack scan does not need.
    stk_ulo: uint64 = task_ustack_lo(slot)
    stk_usz: uint64 = task_ustack_sz(slot)
    STACK_RSV: uint64 = 0
    if stk_ulo != 0 and stk_usz != 0:
        STACK_RSV = 88                       # ~73-byte [stack] line + slack
    while cur != 0 and pos + 96 + STACK_RSV < count:
        s: uint64 = _vma_node_start(cur)
        e: uint64 = _vma_node_end(cur)
        node: Ptr[VmaNode] = cast[Ptr[VmaNode]](cur)
        prot: int32 = node[0].prot
        # address range
        pos = pos + _vma_maps_hex16(s, cast[Ptr[uint8]](
            cast[uint64](buf) + pos))
        buf[pos] = 45                            # '-'
        pos = pos + 1
        pos = pos + _vma_maps_hex16(e, cast[Ptr[uint8]](
            cast[uint64](buf) + pos))
        buf[pos] = 32
        pos = pos + 1
        # perms: rwxp
        if (prot & VMA_PROT_READ) != 0:
            buf[pos] = 114                       # 'r'
        else:
            buf[pos] = 45                        # '-'
        pos = pos + 1
        if (prot & VMA_PROT_WRITE) != 0:
            buf[pos] = 119                       # 'w'
        else:
            buf[pos] = 45
        pos = pos + 1
        if (prot & VMA_PROT_EXEC) != 0:
            buf[pos] = 120                       # 'x'
        else:
            buf[pos] = 45
        pos = pos + 1
        if node[0].is_shared != 0:
            buf[pos] = 115                       # 's'
        else:
            buf[pos] = 112                       # 'p'
        pos = pos + 1
        # " 00000000 00:00 0          [anon]\n"
        tail: Ptr[uint8] = " 00000000 00:00 0          [anon]\n"
        ti: uint64 = 0
        while tail[ti] != 0:
            buf[pos] = tail[ti]
            pos = pos + 1
            ti = ti + 1
        cur = _vma_node_get_next(cur)
    # Linux main-thread STACK line. The Linux user stack is a FIXED high-VA
    # mapping installed at exec (elf_install_user_stack), NOT a VmaNode, so the
    # walk above misses it. glibc's __pthread_getattr_np (main thread) scans
    # /proc/self/maps for the line whose [from,to) contains __libc_stack_end
    # to learn the stack bounds; without it the call FAILS and callers that
    # assert on success abort (Firefox: MOZ_RELEASE_ASSERT(!res) in its thread
    # stack-registration — the window-blocking crash after wl_subcompositor).
    # Emit the [ustack_lo, ustack_lo+ustack_sz) range, labelled [stack].
    ulo: uint64 = stk_ulo
    usz: uint64 = stk_usz
    if ulo != 0 and usz != 0 and pos + 96 < count:
        pos = pos + _vma_maps_hex16(ulo, cast[Ptr[uint8]](
            cast[uint64](buf) + pos))
        buf[pos] = 45                            # '-'
        pos = pos + 1
        pos = pos + _vma_maps_hex16(ulo + usz, cast[Ptr[uint8]](
            cast[uint64](buf) + pos))
        stail: Ptr[uint8] = " rw-p 00000000 00:00 0          [stack]\n"
        si: uint64 = 0
        while stail[si] != 0:
            buf[pos] = stail[si]
            pos = pos + 1
            si = si + 1
    return cast[int64](pos)


def _vma_find_enclosing(slot: uint64, start: uint64,
                        end: uint64) -> uint64:
    # Returns a VmaNode whose [s, e) fully contains [start, end), or 0.
    # Used to detect ld.so's "reserve then MAP_FIXED overlay" case.
    # Wave-3: O(log n) — the only VMA that can contain `start` is the one
    # vma_find returns for it; confirm it also covers `end`.
    node: uint64 = _vma_tree_find(slot, start)
    if node != 0:
        if end <= _vma_node_end(node):
            return node
        return 0
    if _vma_tree_root(slot) != 0:
        return 0
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0:
        s: uint64 = _vma_node_start(cur)
        e: uint64 = _vma_node_end(cur)
        if s <= start and end <= e:
            return cur
        if s > start:
            return 0
        cur = _vma_node_get_next(cur)
    return 0


def _vma_insert_sorted(slot: uint64, node: uint64):
    # Splice `node` into BOTH the sorted iterator list and the O(log n)
    # interval tree (Wave-3). Structural mutation — callers run under the
    # mm write lock (the public entry points open it; the few internal
    # fast paths that don't yet are single-threaded boot/exec paths).
    _vma_tree_insert(slot, node)
    head: uint64 = task_vma_list_head(slot)
    n_start: uint64 = _vma_node_start(node)
    if head == 0:
        _vma_node_set_next(node, 0)
        set_task_vma_list_head(slot, node)
        return
    if _vma_node_start(head) > n_start:
        _vma_node_set_next(node, head)
        set_task_vma_list_head(slot, node)
        return
    prev: uint64 = head
    cur:  uint64 = _vma_node_get_next(head)
    while cur != 0:
        if _vma_node_start(cur) >= n_start:
            _vma_node_set_next(node, cur)
            _vma_node_set_next(prev, node)
            return
        prev = cur
        cur  = _vma_node_get_next(cur)
    _vma_node_set_next(node, 0)
    _vma_node_set_next(prev, node)


# ---------------------------------------------------------------------
# vma_register_anon — register a metadata-only anonymous VMA node
# ---------------------------------------------------------------------
#
# Splice a bare anonymous VMA descriptor (no backing pages of its own —
# backing/nchunks left 0, the way an alias node is) into `slot`'s
# vma_list, covering [start, start+len) page-rounded with `prot`. The
# caller is responsible for any actual page mapping (e.g. vm_map_user_page
# into the slot's PML4). This exists so a self-test can give ANOTHER task
# slot a genuine VMA that vma_find()/vma_node_prot() resolve — exactly
# what a cross-process process_madvise needs to locate a target range —
# without driving the eager-allocating vma_alloc (which would map into the
# CURRENT task's identity window and load_cr3). Returns the page-rounded
# start on success, or a negative errno.
def vma_register_anon(slot: uint64, start: uint64, len_in: uint64,
                      prot: int32) -> int64:
    if len_in == 0:
        return cast[int64](-22)
    length: uint64 = (len_in + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)
    base: uint64 = start & ~(VMA_PAGE_SIZE - 1)
    node: uint64 = _vma_node_new()
    if node == 0:
        return cast[int64](-12)
    _vma_node_set(node, base, base + length, prot,
                  VMA_MAP_ANONYMOUS | VMA_MAP_PRIVATE, -1, 0, 0, 0)
    _vma_insert_sorted(slot, node)
    return cast[int64](base)


# ---------------------------------------------------------------------
# §1 — VMA splitting (mprotect / MAP_FIXED over arbitrary ranges)
# ---------------------------------------------------------------------
#
# mprotect and MAP_FIXED both need to operate on a SUB-range of an
# existing VMA: mprotect changes the prot of a slice, MAP_FIXED
# replaces a slice. Either way the enclosing VMA must be split so the
# slice is its own node.
#
# The hard part is physical ownership. A single-chunk owner VMA's
# virtual range IS its buddy run (identity-mapped); a multi-chunk VMA
# owns an array of buddy chunks. Neither can be partially freed. So
# before a VMA is ever split, _vma_make_refcounted brings its frames
# under per-PFN refcount management (vm_pin_range takes one ref on
# each frame) and converts the node to is_pinned. From then on every
# piece — original or split-off — frees via the refcount path
# (_vma_free_cow_range), and the underlying buddy run is returned to
# the allocator only when the last piece releases its last frame. The
# node's own backing / chunks descriptors are dropped (set to 0): the
# page table + refcount table are now the sole authority.

def _vma_make_refcounted(slot: uint64, node: uint64) -> int32:
    # Convert an owner VMA to per-PFN refcount management so it can be
    # safely split. Idempotent: a node that is already refcount-managed
    # (is_cow / is_shared / is_pinned) is left untouched. Returns 0 on
    # success, -1 on OOM.
    if cast[Ptr[VmaNode]](node)[0].is_cow != 0:
        return 0
    if cast[Ptr[VmaNode]](node)[0].is_shared != 0:
        return 0
    if cast[Ptr[VmaNode]](node)[0].is_pinned != 0:
        return 0
    # §shared-pagecache: a MAP_SHARED writable FILE VMA already maps
    # per-PFN COW-refcounted shared frames (the fault path took a ref per
    # mapper). Its `backing` field holds the backing IDENTITY, not a buddy
    # run, and _vma_node_free's is_file_shared arm frees by walking the
    # page table through cow_drop_page. It is therefore ALREADY safe to
    # split (each half's free walk drops its own refs); do NOT pin it
    # (vm_pin_range would double-count) and do NOT clear `backing` (the
    # writeback path needs the identity). Treat it as already-managed.
    if cast[Ptr[VmaNode]](node)[0].is_file_shared != 0:
        return 0
    s: uint64 = cast[Ptr[VmaNode]](node)[0].start
    e: uint64 = cast[Ptr[VmaNode]](node)[0].end
    backing: uint64 = cast[Ptr[VmaNode]](node)[0].backing
    nchunks: int32 = cast[Ptr[VmaNode]](node)[0].nchunks
    # An alias node (backing == 0, nchunks == 0) owns no pages — its
    # frames belong to an enclosing owner VMA. It must NOT be flagged
    # refcount-managed: routing an alias through _vma_free_cow_range
    # would cow_drop_page the enclosing owner's frames and free them
    # out from under the owner. An alias is trivially splittable as-is
    # (no pages to track) — _vma_split_at just copies its metadata.
    # Nothing to do here; return success so the caller can split it.
    if backing == 0 and nchunks <= 0:
        return 0
    pml4: uint64 = task_pml4(cast[int32](slot))
    if vm_pin_range(pml4, s, e) < 0:
        return -1
    # The page table + per-PFN refcount table are now authoritative.
    # Drop the buddy-run descriptors so _vma_node_free does not ALSO
    # try to free the run via free_pages (double free) — the is_pinned
    # path frees purely by walking the page table.
    carr: uint64 = cast[Ptr[VmaNode]](node)[0].chunks
    if carr != 0:
        kfree(carr)
    cast[Ptr[VmaNode]](node)[0].backing = 0
    cast[Ptr[VmaNode]](node)[0].order   = 0
    cast[Ptr[VmaNode]](node)[0].chunks  = 0
    cast[Ptr[VmaNode]](node)[0].nchunks = 0
    cast[Ptr[VmaNode]](node)[0].is_pinned = 1
    return 0


def _vma_split_at(slot: uint64, node: uint64, at: uint64) -> uint64:
    # Split `node` at virtual address `at` (page-aligned, strictly
    # inside (start, end)). The original node keeps [start, at); a
    # fresh node covering [at, end) is inserted after it and returned.
    # `node` MUST already be refcount-managed (_vma_make_refcounted) so
    # both halves can free independently. Returns 0 on OOM or if `at`
    # is not strictly interior.
    s: uint64 = cast[Ptr[VmaNode]](node)[0].start
    e: uint64 = cast[Ptr[VmaNode]](node)[0].end
    if at <= s or at >= e:
        return 0
    tail: uint64 = _vma_node_new()
    if tail == 0:
        return 0
    prot:  int32  = cast[Ptr[VmaNode]](node)[0].prot
    flags: int32  = cast[Ptr[VmaNode]](node)[0].flags
    fd:    int32  = cast[Ptr[VmaNode]](node)[0].file_fd
    off:   uint64 = cast[Ptr[VmaNode]](node)[0].file_offset
    # file_offset of the tail advances by the bytes the head keeps.
    # §shared-pagecache: a file-shared split must carry the backing
    # IDENTITY onto the tail (NOT 0) so the tail's faults read the right
    # file bytes and its teardown writes back to the right file. The
    # is_file* / file_marker / file_size fields are copied below.
    tail_back: uint64 = 0
    if cast[Ptr[VmaNode]](node)[0].is_file_shared != 0:
        tail_back = cast[Ptr[VmaNode]](node)[0].backing
    _vma_node_set(tail, at, e, prot, flags, fd,
                  off + (at - s), tail_back, 0)
    # The tail inherits the head's sharing mode — every piece of a
    # split owner VMA is refcount-managed.
    cast[Ptr[VmaNode]](tail)[0].is_cow    = cast[Ptr[VmaNode]](node)[0].is_cow
    cast[Ptr[VmaNode]](tail)[0].is_shared = cast[Ptr[VmaNode]](node)[0].is_shared
    cast[Ptr[VmaNode]](tail)[0].is_pinned = cast[Ptr[VmaNode]](node)[0].is_pinned
    cast[Ptr[VmaNode]](tail)[0].is_demand = cast[Ptr[VmaNode]](node)[0].is_demand
    # §shared-pagecache: carry the file-shared backing snapshot onto the
    # tail so both halves fault/writeback against the same file identity.
    cast[Ptr[VmaNode]](tail)[0].is_file        = cast[Ptr[VmaNode]](node)[0].is_file
    cast[Ptr[VmaNode]](tail)[0].is_file_shared = cast[Ptr[VmaNode]](node)[0].is_file_shared
    cast[Ptr[VmaNode]](tail)[0].file_marker    = cast[Ptr[VmaNode]](node)[0].file_marker
    cast[Ptr[VmaNode]](tail)[0].file_size      = cast[Ptr[VmaNode]](node)[0].file_size
    # §mseal: a seal covers the whole original mapping, so both halves of a
    # split inherit it (a sealed VMA is never reached by a split today since
    # mprotect/munmap are rejected up-front, but this keeps the invariant
    # honest if a partial mseal ever splits at a boundary).
    cast[Ptr[VmaNode]](tail)[0].sealed   = cast[Ptr[VmaNode]](node)[0].sealed
    # Shrink the head's end to the split point, refreshing the interval
    # tree's subtree_max_end up its path (the BST start key is unchanged).
    _vma_tree_update_end(slot, node, at)
    _vma_insert_sorted(slot, tail)
    return tail


# ---------------------------------------------------------------------
# Carve / unmap
# ---------------------------------------------------------------------

def _vma_unlink(slot: uint64, target: uint64) -> int32:
    # Detach `target` from BOTH the iterator list and the interval tree
    # (Wave-3). Structural mutation — caller runs under the mm write lock.
    head: uint64 = task_vma_list_head(slot)
    if head == 0:
        return 0
    unlinked: int32 = 0
    if head == target:
        set_task_vma_list_head(slot, _vma_node_get_next(head))
        unlinked = 1
    else:
        prev: uint64 = head
        cur:  uint64 = _vma_node_get_next(head)
        while cur != 0:
            if cur == target:
                _vma_node_set_next(prev, _vma_node_get_next(cur))
                unlinked = 1
                cur = 0
            else:
                prev = cur
                cur  = _vma_node_get_next(cur)
    if unlinked != 0:
        _vma_tree_remove(slot, target)
    return unlinked


def _vma_carve_range(slot: uint64, start: uint64, end: uint64):
    # Remove EXACTLY [start, end) from the task's VMA list. §1 makes
    # this honest for arbitrary ranges (munmap of a partial range,
    # MAP_FIXED replacing part of a VMA):
    #
    #   * A node fully inside [start, end) is dropped whole.
    #   * A node that straddles a boundary is SPLIT at that boundary
    #     so the overlapping piece is fully covered (and dropped) while
    #     the non-overlapping remainder survives at its original
    #     vaddr. Splitting first brings the node under per-PFN refcount
    #     management (_vma_make_refcounted) so the surviving piece and
    #     the dropped piece can free independently — the buddy run is
    #     returned only when the last reference falls.
    #
    # A COW / shared / pinned node frees through the refcount, so
    # _vma_node_free needs the owning task's PML4 to walk its page
    # table.
    if end <= start:
        return
    pml4: uint64 = task_pml4(cast[int32](slot))
    cur: uint64 = task_vma_list_head(slot)
    done: int32 = 0
    while cur != 0 and done == 0:
        nxt: uint64 = _vma_node_get_next(cur)
        s: uint64 = _vma_node_start(cur)
        e: uint64 = _vma_node_end(cur)
        if s < end and start < e:
            # Overlap. Trim the non-covered head/tail by splitting.
            if s < start:
                # Keep [s, start); split there. The tail [start, e) is
                # the overlapping part — re-process it next iteration.
                if _vma_make_refcounted(slot, cur) < 0:
                    # OOM: fall back to dropping the whole node so the
                    # carve still makes progress (over-unmaps the head
                    # remainder — rare, OOM-only).
                    _vma_unlink(slot, cur)
                    _vma_node_free(slot, cur, pml4)
                    cur = nxt
                else:
                    tail: uint64 = _vma_split_at(slot, cur, start)
                    if tail == 0:
                        _vma_unlink(slot, cur)
                        _vma_node_free(slot, cur, pml4)
                        cur = nxt
                    else:
                        # Re-walk from the tail (the overlapping part).
                        cur = tail
            elif e > end:
                # s >= start and the node extends past `end`. Keep
                # [end, e); split there. The head [s, end) is fully
                # covered — drop it; continue from the surviving tail.
                if _vma_make_refcounted(slot, cur) < 0:
                    _vma_unlink(slot, cur)
                    _vma_node_free(slot, cur, pml4)
                    cur = nxt
                else:
                    tail2: uint64 = _vma_split_at(slot, cur, end)
                    if tail2 == 0:
                        _vma_unlink(slot, cur)
                        _vma_node_free(slot, cur, pml4)
                        cur = nxt
                    else:
                        # `cur` is now [s, end) — fully covered. Drop
                        # it; the surviving tail2 is past `end` so the
                        # carve is complete.
                        _vma_unlink(slot, cur)
                        _vma_node_free(slot, cur, pml4)
                        done = 1
            else:
                # Node fully inside [start, end): drop it whole.
                _vma_unlink(slot, cur)
                _vma_node_free(slot, cur, pml4)
                cur = nxt
        elif s >= end:
            done = 1
        else:
            cur = nxt


# ---------------------------------------------------------------------
# _vma_alloc_large — multi-chunk backing path
# ---------------------------------------------------------------------
#
# A VMA whose page-rounded length exceeds VMA_MAX_CHUNK (4 MiB, the
# buddy allocator's largest single run) cannot be backed by one
# alloc_pages call. glibc's pthread library defaults to an 8 MiB
# thread stack, so this is a real, common request.
#
# _vma_alloc_large() backs such a VMA with MULTIPLE buddy chunks (each
# up to 4 MiB) and stitches them into ONE contiguous virtual range:
#
#   1. A 4-MiB-aligned virtual window of `length` bytes is carved from
#      the dedicated multi-chunk region [1 GiB, 4 GiB) by the
#      vma_large_next bump pointer. Nothing else is ever placed there
#      (buddy physical RAM is well under 1 GiB; small VMAs sit at their
#      low identity addresses; ELF image / brk / stack load low), so
#      two large VMAs can never overlap and no buddy allocation can
#      re-hand the physical pages under the window.
#   2. Each 4-MiB-or-smaller chunk gets its own buddy allocation
#      (scattered low physical pages) and is zeroed via its identity
#      address.
#   3. EVERY chunk — including chunk 0 — is overlaid into the calling
#      task's PML4 by elf_install_user_mapping() so the whole window
#      [base, base+length) points at the right physical chunk. (Unlike
#      a single-chunk VMA, the window has no physical RAM behind its
#      identity mapping, so chunk 0 cannot rely on identity.)
#   4. The chunk array (phys, order per chunk) is recorded on the
#      VmaNode so _vma_node_free releases every chunk and vma_fork_copy
#      copies every chunk.
#
# Because we overlay the live task's PML4, the caller's CR3 is reloaded
# afterwards to flush any stale TLB entries for the remapped range.
#
# Returns the resolved base on success, or a negative Linux errno.

def _vma_alloc_large(slot: uint64, length: uint64, prot: int32,
                     flags: int32, file_fd: int32,
                     file_offset: uint64) -> int64:
    # Number of chunks: ceil(length / 4 MiB).
    nchunks: int32 = cast[int32]((length + VMA_MAX_CHUNK - 1)
                                 / VMA_MAX_CHUNK)
    if nchunks <= 0:
        return cast[int64](-22)

    # Carve a 4-MiB-aligned virtual window. Rounding the reservation
    # up to a 4 MiB multiple keeps vma_large_next 4-MiB-aligned so
    # every per-chunk install stays inside one 1 GiB PDPT entry.
    window: uint64 = (length + VMA_MAX_CHUNK - 1) \
                     & ~(VMA_MAX_CHUNK - 1)
    base: uint64 = _vma_win_alloc(slot, window)
    if base == 0:
        printk1("vma: large window exhausted (need 0x%x)\n", window)
        return cast[int64](-12)

    node: uint64 = _vma_node_new()
    if node == 0:
        return cast[int64](-12)

    carr: uint64 = kmalloc(cast[uint64](nchunks) * VMA_CHUNK_SIZE)
    if carr == 0:
        kfree(node)
        return cast[int64](-12)
    memset(cast[Ptr[uint8]](carr), 0,
           cast[uint64](nchunks) * VMA_CHUNK_SIZE)

    pml4: uint64 = task_pml4(cast[int32](slot))

    # Allocate + zero every chunk.
    i: int32 = 0
    ok: int32 = 1
    while i < nchunks and ok != 0:
        off: uint64 = cast[uint64](i) * VMA_MAX_CHUNK
        remain: uint64 = length - off
        csize: uint64 = VMA_MAX_CHUNK
        if remain < csize:
            csize = remain
        corder: int32 = _order_for_chunk(csize)
        cphys: uint64 = alloc_pages(corder)
        if cphys == 0:
            printk1("vma: large alloc OOM at chunk order=%d\n",
                    cast[uint64](corder))
            ok = 0
        else:
            memset(cast[Ptr[uint8]](cphys), 0, csize)
            ce: uint64 = carr + cast[uint64](i) * VMA_CHUNK_SIZE
            cast[Ptr[VmaChunk]](ce)[0].phys  = cphys
            cast[Ptr[VmaChunk]](ce)[0].order = corder
            cast[Ptr[VmaChunk]](ce)[0].pad   = 0
            i = i + 1

    if ok == 0:
        # Roll back: free whatever chunks we already grabbed.
        j: int32 = 0
        while j < i:
            ce: uint64 = carr + cast[uint64](j) * VMA_CHUNK_SIZE
            free_pages(cast[Ptr[VmaChunk]](ce)[0].phys,
                       cast[Ptr[VmaChunk]](ce)[0].order)
            j = j + 1
        kfree(carr)
        kfree(node)
        return cast[int64](-12)

    # Overlay EVERY chunk into the calling task's PML4 so the whole
    # window [base, base+length) presents one contiguous virtual range.
    m: int32 = 0
    while m < nchunks:
        ce: uint64 = carr + cast[uint64](m) * VMA_CHUNK_SIZE
        cphys: uint64 = cast[Ptr[VmaChunk]](ce)[0].phys
        off: uint64 = cast[uint64](m) * VMA_MAX_CHUNK
        remain: uint64 = length - off
        csize: uint64 = VMA_MAX_CHUNK
        if remain < csize:
            csize = remain
        vlo: uint64 = base + off
        rc: int32 = elf_install_user_mapping(pml4, vlo, vlo + csize,
                                             cphys,
                                             _vma_nx_flag(prot)
                                             | _vma_rw_flag(prot))
        if rc < 0:
            printk1("vma: large remap failed at chunk %d\n",
                    cast[uint64](m))
            # Roll back every chunk allocation; the partial page-table
            # overlay is harmless (it points at our own freed pages and
            # is torn down with the task's PML4) but the box stays
            # diagnosable rather than aliasing live memory.
            j2: int32 = 0
            while j2 < nchunks:
                ce2: uint64 = carr + cast[uint64](j2) * VMA_CHUNK_SIZE
                free_pages(cast[Ptr[VmaChunk]](ce2)[0].phys,
                           cast[Ptr[VmaChunk]](ce2)[0].order)
                j2 = j2 + 1
            kfree(carr)
            kfree(node)
            return cast[int64](-12)
        m = m + 1

    # The overlay touched the live task's PML4; flush stale TLB
    # entries for the remapped range by reloading CR3 with its own
    # value (drops every non-global entry).
    load_cr3(pml4)

    # The window VA was already committed by _vma_win_alloc (free-list
    # reuse or a vma_large_next bump). No second bump here.
    end_v: uint64 = base + length
    _vma_node_set(node, base, end_v, prot, flags, file_fd,
                  file_offset, 0, 0)
    cast[Ptr[VmaNode]](node)[0].chunks  = carr
    cast[Ptr[VmaNode]](node)[0].nchunks = nchunks
    _vma_insert_sorted(slot, node)
    return cast[int64](base)


# ---------------------------------------------------------------------
# §1 — _vma_alloc_fixed_at: honest MAP_FIXED at an arbitrary address
# ---------------------------------------------------------------------
#
# A genuine MAP_FIXED that is NOT enclosed by a prior reservation must
# land EXACTLY at the caller's requested address — the old code
# carved the overlap then fell through and let alloc_pages pick a
# different address, which silently broke any caller relying on the
# MAP_FIXED contract once it stepped outside ld.so's reserve+overlay
# idiom.
#
# Because Hamnix is identity-mapped, a freshly alloc_pages'd run sits
# at its own physical address — not at `addr_in`. So we OVERLAY the
# fresh pages into the task's PML4 at `addr_in` (the same mechanism
# _vma_alloc_large uses for its 1 GiB window), in up-to-4-MiB chunks,
# and record the VMA at [addr_in, addr_in+length). Any prior mapping
# in the target range was already carved by the caller.
#
# Returns the resolved base (== addr_in) on success, or a negative
# Linux errno.

def _vma_alloc_fixed_at(slot: uint64, addr_in: uint64, length: uint64,
                        prot: int32, flags: int32, file_fd: int32,
                        file_offset: uint64) -> int64:
    nchunks: int32 = cast[int32]((length + VMA_MAX_CHUNK - 1)
                                 / VMA_MAX_CHUNK)
    if nchunks <= 0:
        return cast[int64](-22)
    node: uint64 = _vma_node_new()
    if node == 0:
        return cast[int64](-12)
    carr: uint64 = kmalloc(cast[uint64](nchunks) * VMA_CHUNK_SIZE)
    if carr == 0:
        kfree(node)
        return cast[int64](-12)
    memset(cast[Ptr[uint8]](carr), 0,
           cast[uint64](nchunks) * VMA_CHUNK_SIZE)
    pml4: uint64 = task_pml4(cast[int32](slot))

    # Allocate + zero every chunk.
    i: int32 = 0
    ok: int32 = 1
    while i < nchunks and ok != 0:
        off: uint64 = cast[uint64](i) * VMA_MAX_CHUNK
        remain: uint64 = length - off
        csize: uint64 = VMA_MAX_CHUNK
        if remain < csize:
            csize = remain
        corder: int32 = _order_for_chunk(csize)
        cphys: uint64 = alloc_pages(corder)
        if cphys == 0:
            ok = 0
        else:
            memset(cast[Ptr[uint8]](cphys), 0, csize)
            ce: uint64 = carr + cast[uint64](i) * VMA_CHUNK_SIZE
            cast[Ptr[VmaChunk]](ce)[0].phys  = cphys
            cast[Ptr[VmaChunk]](ce)[0].order = corder
            cast[Ptr[VmaChunk]](ce)[0].pad   = 0
            i = i + 1
    if ok == 0:
        j: int32 = 0
        while j < i:
            ce: uint64 = carr + cast[uint64](j) * VMA_CHUNK_SIZE
            free_pages(cast[Ptr[VmaChunk]](ce)[0].phys,
                       cast[Ptr[VmaChunk]](ce)[0].order)
            j = j + 1
        kfree(carr)
        kfree(node)
        return cast[int64](-12)

    # Overlay every chunk at addr_in + offset in the task's PML4.
    m: int32 = 0
    while m < nchunks:
        ce: uint64 = carr + cast[uint64](m) * VMA_CHUNK_SIZE
        cphys: uint64 = cast[Ptr[VmaChunk]](ce)[0].phys
        off: uint64 = cast[uint64](m) * VMA_MAX_CHUNK
        remain: uint64 = length - off
        csize: uint64 = VMA_MAX_CHUNK
        if remain < csize:
            csize = remain
        vlo: uint64 = addr_in + off
        rc: int32 = elf_install_user_mapping(pml4, vlo, vlo + csize,
                                             cphys,
                                             _vma_nx_flag(prot)
                                             | _vma_rw_flag(prot))
        if rc < 0:
            printk1("vma: MAP_FIXED overlay failed @ 0x%x\n", vlo)
            j2: int32 = 0
            while j2 < nchunks:
                ce2: uint64 = carr + cast[uint64](j2) * VMA_CHUNK_SIZE
                free_pages(cast[Ptr[VmaChunk]](ce2)[0].phys,
                           cast[Ptr[VmaChunk]](ce2)[0].order)
                j2 = j2 + 1
            kfree(carr)
            kfree(node)
            return cast[int64](-12)
        m = m + 1
    load_cr3(pml4)

    end_v: uint64 = addr_in + length
    _vma_node_set(node, addr_in, end_v, prot, flags, file_fd,
                  file_offset, 0, 0)
    cast[Ptr[VmaNode]](node)[0].chunks  = carr
    cast[Ptr[VmaNode]](node)[0].nchunks = nchunks
    _vma_insert_sorted(slot, node)
    return cast[int64](addr_in)


def _vma_node_is_pure_alias(node: uint64) -> int32:
    # 1 iff `node` is a PURE METADATA ALIAS: a VMA created by the MAP_FIXED
    # reserve+overlay idiom that owns NO pages of its own (the enclosing
    # reservation owns them). Such a node has backing==0, nchunks==0 and
    # none of the page-owning flags (is_demand / is_cow / is_shared /
    # is_pinned / is_file_shared / is_huge). Removing it frees ONLY the
    # descriptor — never any frames — so it is safe to drop when a later
    # MAP_FIXED replaces its range.
    if cast[Ptr[VmaNode]](node)[0].backing != 0:
        return 0
    if cast[Ptr[VmaNode]](node)[0].nchunks != 0:
        return 0
    if cast[Ptr[VmaNode]](node)[0].is_demand != 0:
        return 0
    if cast[Ptr[VmaNode]](node)[0].is_cow != 0:
        return 0
    if cast[Ptr[VmaNode]](node)[0].is_shared != 0:
        return 0
    if cast[Ptr[VmaNode]](node)[0].is_pinned != 0:
        return 0
    if cast[Ptr[VmaNode]](node)[0].is_file_shared != 0:
        return 0
    if cast[Ptr[VmaNode]](node)[0].is_huge != 0:
        return 0
    return 1


def _vma_drop_overlapping_aliases(slot: uint64, lo: uint64, hi: uint64,
                                  keep: uint64):
    # MAP_FIXED REPLACE semantics for the reserve+overlay idiom: before a
    # new alias is inserted over [lo, hi), remove every PRIOR pure-alias
    # node that overlaps [lo, hi) (except `keep`, the enclosing reservation
    # we are aliasing INTO). Without this, a second MAP_FIXED over the same
    # or an overlapping sub-range (ld.so re-overlaying .text then RELRO, or
    # apt re-mmapping a segment) STACKS duplicate/overlapping alias nodes.
    # Overlapping VMA nodes break the interval-tree point query
    # (_vma_tree_find descends the BST on `start` and can return 0 for an
    # address that two siblings both cover), so a later demand/exec fault
    # finds "NO covering VMA" and the eager PTE re-stamp races NX onto an
    # executable page -> the apt 'Reading package lists' NX exec-fault.
    # Pure aliases own no frames, so unlinking them frees only the
    # descriptor; the enclosing reservation's pages (and its PTEs, which
    # the new overlay re-stamps) are untouched.
    #
    # Only drop an alias that lies ENTIRELY within [lo, hi): the new overlay
    # fully covers it, so it is a genuine REPLACE with no coverage loss. A
    # pure alias that merely STRADDLES the new range keeps a region the new
    # overlay does not cover, so it is left in place (the common ld.so case
    # is a re-overlay of the SAME [lo, hi), i.e. full containment — exactly
    # the duplicate-stacking we must kill).
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0:
        nxt: uint64 = _vma_node_get_next(cur)
        if cur != keep:
            s: uint64 = _vma_node_start(cur)
            e: uint64 = _vma_node_end(cur)
            if s >= lo and e <= hi and s < hi and lo < e \
                    and _vma_node_is_pure_alias(cur) != 0:
                _vma_unlink(slot, cur)
                if nr_vma_nodes_live > 0:
                    nr_vma_nodes_live = nr_vma_nodes_live - 1
                kfree(cur)
        cur = nxt


# ---------------------------------------------------------------------
# vma_alloc
# ---------------------------------------------------------------------

def vma_alloc(slot: uint64, addr_in: uint64, len_in: uint64,
              prot: int32, flags: int32, file_fd: int32,
              file_offset: uint64) -> int64:
    # Thread address-space serialization: hold the mm-group WRITE lock
    # across the WHOLE reserve->install->insert (or carve->release)
    # mutation so two threads of one CLONE_VM address space can never race
    # the shared window cursor / free-list / interval tree and hand out
    # OVERLAPPING window VAs into the shared PML4 (the Firefox eager
    # PTE=0 SIGSEGV). Recursive: inner tree/carve helpers re-acquire on the
    # same logical CPU. A process (no thread group) still takes its own
    # per-mm lock cheaply.
    vma_mm_write_lock(slot)
    _lr: int64 = _vma_alloc_locked(slot, addr_in, len_in, prot, flags, file_fd, file_offset)
    vma_mm_write_unlock(slot)
    return _lr


def _vma_alloc_locked(slot: uint64, addr_in: uint64, len_in: uint64,
              prot: int32, flags: int32, file_fd: int32,
              file_offset: uint64) -> int64:
    # Allocate a fresh VMA + its backing pages, splice it into the
    # task's vma_list, and return the resolved start address (cast
    # to int64 so the caller can return it through the syscall ABI).
    # On failure returns a negative Linux errno.
    if len_in == 0:
        return cast[int64](-22)

    length: uint64 = (len_in + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)

    is_fixed: int32 = 0
    if (flags & VMA_MAP_FIXED) != 0:
        is_fixed = 1

    # MAP_FIXED handling runs FIRST.
    #   * Enclosed by an existing reservation -> metadata-only alias
    #     (ld.so's reserve+overlay idiom — the enclosing VMA owns the
    #     pages; the alias just records the slice's prot/fd).
    #   * §1: NOT enclosed -> an honest fixed mapping. Carve whatever
    #     overlapped the target range (split-aware _vma_carve_range
    #     preserves the non-overlapping remainders of straddled VMAs),
    #     then OVERLAY fresh pages at exactly addr_in via
    #     _vma_alloc_fixed_at. The old code dropped addr_in to a mere
    #     hint here, which broke any MAP_FIXED outside ld.so's pattern.
    if is_fixed != 0 and addr_in != 0:
        end_req: uint64 = addr_in + length
        encl: uint64 = _vma_find_enclosing(slot, addr_in, end_req)
        if encl != 0:
            encl_s: uint64 = _vma_node_start(encl)
            encl_e: uint64 = _vma_node_end(encl)
            # Alias ONLY for a STRICT sub-region of a larger enclosing
            # reservation — the ld.so "reserve big, MAP_FIXED small
            # segments inside" idiom. An EXACT-size MAP_FIXED over an
            # identical existing VMA is a genuine REPLACE (Linux:
            # MAP_FIXED always replaces); aliasing it would silently
            # hand back the OLD pages. So fall through to the carve +
            # fresh-overlay path unless the request is strictly
            # smaller than the region it lands in.
            if encl_s < addr_in or end_req < encl_e:
                # MAP_FIXED REPLACE: drop any prior pure-alias node(s) this
                # overlay overlaps so we never STACK duplicate/overlapping
                # alias VMAs (which corrupt the interval tree and surface as
                # the apt 'Reading package lists' NX exec-fault). The
                # enclosing reservation (`encl`) is preserved — it owns the
                # pages; the new overlay re-stamps the PTEs below.
                _vma_drop_overlapping_aliases(slot, addr_in, end_req, encl)
                alias: uint64 = _vma_node_new()
                if alias == 0:
                    return cast[int64](-12)
                _vma_node_set(alias, addr_in, end_req, prot, flags,
                              file_fd, file_offset, 0, 0)
                _vma_insert_sorted(slot, alias)
                # W^X / ld.so RELRO fix: the aliased sub-region inherits
                # the ENCLOSING reservation's leaf-PTE permissions, NOT
                # this overlay's `prot`. glibc's _dl_map_segments reserves
                # the whole DSO span PROT_NONE (or PROT_READ) — those PTEs
                # are present-but-read-only — then MAP_FIXEDs the writable
                # data/GOT segment inside it with PROT_READ|PROT_WRITE.
                # Without re-stamping the PTEs the data/GOT pages stay
                # READ-ONLY, so ld.so's first relocation write (GOT slot /
                # RELRO) faults -> W^X SIGSEGV (the real-Debian-glibc
                # crash). Re-walk the sub-range and flip RW/NX to match the
                # overlay's requested prot so a writable segment is
                # genuinely writable during relocation. (A later mprotect
                # back to RO — BIND_NOW RELRO — re-walks the same PTEs.)
                pml4_a: uint64 = task_pml4(cast[int32](slot))
                pw: int32 = 0
                if (prot & VMA_PROT_WRITE) != 0:
                    pw = 1
                px: int32 = 0
                if (prot & VMA_PROT_EXEC) != 0:
                    px = 1
                vm_protect_range(pml4_a, addr_in, end_req, pw, px)
                # §4: an ANONYMOUS MAP_FIXED overlay must present a
                # zero-filled range — that is the whole point of the
                # call. ld.so's _dl_map_segments lays a DSO's .bss this
                # way: after MAP_FIXED-ing the file-backed RW segment it
                # issues a SECOND MAP_FIXED|MAP_ANONYMOUS over the
                # [filesz, memsz) tail so the BSS reads as zero. The
                # enclosing reservation is the file-backed whole-DSO
                # map, whose pages still hold raw file bytes from past
                # the segment's p_filesz — leaving them would give libc
                # a garbage __exit_funcs / __libc_argv / locale state
                # and #GP on first use. A file-backed alias does NOT
                # zero here: the _u_mmap caller layers vfs_read on top.
                if (flags & VMA_MAP_ANONYMOUS) != 0:
                    # SMAP: this memset writes THROUGH the user VA (a US=1
                    # page) at CPL=0. Under CR4.SMAP an unbracketed CPL=0
                    # write to a user page #PFs (err P=1 W=1 U=0) even though
                    # the leaf PTE is genuinely RW=1 — and because the page
                    # is already writable, vma_resolve_write_perm_fault's
                    # "already-RW, transient" arm returns 1 (resolved) and the
                    # instruction re-runs, faulting forever: an infinite #PF
                    # livelock (glibc-2.41 ld.so hangs here laying libc's .bss
                    # overlay). Bracket the uaccess write with STAC/CLAC.
                    _ua_stac()
                    memset(cast[Ptr[uint8]](addr_in), 0, length)
                    _ua_clac()
                return cast[int64](addr_in)
        # MAP_FIXED, not a strict sub-region: replace exactly
        # [addr_in, end_req). Carve any prior mapping (split-aware —
        # preserves the non-overlapping remainder of a straddled VMA)
        # then overlay fresh pages at exactly addr_in.
        _vma_carve_range(slot, addr_in, end_req)
        return _vma_alloc_fixed_at(slot, addr_in, length, prot, flags,
                                   file_fd, file_offset)

    # Large request: more than one buddy MAX_ORDER chunk. Back it with
    # multiple chunks stitched into a contiguous virtual range. glibc's
    # 8 MiB default pthread stack lands here.
    if length > VMA_MAX_CHUNK:
        return _vma_alloc_large(slot, length, prot, flags,
                                file_fd, file_offset)

    # US=0 identity-map fix (ld.so / real-glibc W^X SIGSEGV): a non-FIXED
    # mmap must NOT hand back a raw alloc_pages low-identity base. The boot
    # identity map's low leaves were restamped US=0
    # (cpu_mitigations._restamp_pml4_subtree_us0, for CR4.SMAP) — a
    # SUPERVISOR-only mapping. The faulting case: ld.so's `mmap(NULL,
    # libc.so.6 span, PROT_NONE|READ, fd)` reservation took this path, got
    # a low identity VA, then MAP_FIXED-overlaid its RW data/GOT segment
    # inside it; the CPL=3 relocation write to that US=0 page faults P|W|U
    # — surfacing as "[pf] W^X write-fault on RO user page" SIGSEGV (the
    # page is NOT read-only — PTE RW=1 — it is US=0, observed pte=…063,
    # va=0x70d6028, rip in ld.so). The same hazard hits glibc's anonymous
    # malloc-arena mmaps once real binaries (dpkg/bash) run. Route EVERY
    # non-fixed mmap (file AND anon) through the WINDOWED installer
    # (_vma_alloc_large), which stamps proper US=1 per-task leaf PTEs via
    # elf_install_user_mapping in the mmap-ASLR window. _vma_alloc_large
    # handles nchunks>=1, so a sub-4-MiB map is fine. (MAP_FIXED is
    # handled above; the windowed VA never aliases low identity RAM, so
    # the US=0 restamp can't reach it.)
    return _vma_alloc_large(slot, length, prot, flags,
                            file_fd, file_offset)


def vma_unmap(slot: uint64, addr: uint64, len_in: uint64) -> int64:
    # Thread address-space serialization: hold the mm-group WRITE lock
    # across the WHOLE reserve->install->insert (or carve->release)
    # mutation so two threads of one CLONE_VM address space can never race
    # the shared window cursor / free-list / interval tree and hand out
    # OVERLAPPING window VAs into the shared PML4 (the Firefox eager
    # PTE=0 SIGSEGV). Recursive: inner tree/carve helpers re-acquire on the
    # same logical CPU. A process (no thread group) still takes its own
    # per-mm lock cheaply.
    vma_mm_write_lock(slot)
    _lr: int64 = _vma_unmap_locked(slot, addr, len_in)
    vma_mm_write_unlock(slot)
    return _lr


def _vma_unmap_locked(slot: uint64, addr: uint64, len_in: uint64) -> int64:
    if len_in == 0:
        return cast[int64](-22)
    # §mseal: munmap of a sealed range is rejected -EPERM (the mapping must
    # stay put). Checked before carving so the sealed VMA survives intact.
    if vma_range_is_sealed(slot, addr, len_in) != 0:
        return VMA_PERM
    length: uint64 = (len_in + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)
    end_v: uint64 = addr + length
    _vma_carve_range(slot, addr, end_v)
    # Reclaim any whole 4-MiB windowed slice that this unmap fully cleared,
    # so a long-lived process (apt's malloc/dlopen churn) reuses its own
    # freed window VAs instead of marching vma_large_next to exhaustion.
    _vma_win_release_unmap(slot, addr, end_v)
    return 0


# ---------------------------------------------------------------------
def vma_mark_foreign(slot: uint64, vaddr: uint64) -> int32:
    # Track 4 UMDF: mark the VMA node covering `vaddr` as a FOREIGN overlay
    # so _vma_node_free clears its PTEs without freeing the physical frames
    # (device MMIO / DMA pages owned elsewhere). Returns 0 on success, -1 if
    # no node covers vaddr. Called right after a UMDF MMIO/DMA overlay is
    # installed over a fresh vma_alloc_demand reservation.
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0:
        if vaddr >= _vma_node_start(cur) and vaddr < _vma_node_end(cur):
            cast[Ptr[VmaNode]](cur)[0].is_foreign = 1
            return 0
        cur = _vma_node_get_next(cur)
    return -1


# §142 — vma_alloc_demand: demand-paged anonymous mmap
# ---------------------------------------------------------------------
#
# Creates a VMA with is_demand=1 in the [1 GiB, 4 GiB) large-VMA
# window without allocating any physical pages. The page tables for the
# virtual range are prepared (PDPT/PD/PT levels exist; all leaf PTEs are
# 0 = not-present). A user access to any page in the range fires a
# NOT-PRESENT #PF; do_page_fault detects the demand VMA and calls
# vma_demand_fault to populate the page lazily.
#
# If MAP_FIXED is set with a non-zero addr, the mapping is placed at
# exactly addr (must be page-aligned). Otherwise a fresh window is
# carved from vma_large_next.
#
# Returns the resolved base address (>= 0) on success, or a negative
# Linux errno on failure.
#
# NOTE: MAP_SHARED demand VMAs are not meaningful (sharing requires
# pages to exist). If MAP_SHARED is set, this function falls back to
# eager allocation via vma_alloc.

def vma_alloc_demand(slot: uint64, addr_in: uint64, len_in: uint64,
                     prot: int32, flags: int32) -> int64:
    # Thread address-space serialization: hold the mm-group WRITE lock
    # across the WHOLE reserve->install->insert (or carve->release)
    # mutation so two threads of one CLONE_VM address space can never race
    # the shared window cursor / free-list / interval tree and hand out
    # OVERLAPPING window VAs into the shared PML4 (the Firefox eager
    # PTE=0 SIGSEGV). Recursive: inner tree/carve helpers re-acquire on the
    # same logical CPU. A process (no thread group) still takes its own
    # per-mm lock cheaply.
    vma_mm_write_lock(slot)
    _lr: int64 = _vma_alloc_demand_locked(slot, addr_in, len_in, prot, flags)
    vma_mm_write_unlock(slot)
    return _lr


def _vma_alloc_demand_locked(slot: uint64, addr_in: uint64, len_in: uint64,
                     prot: int32, flags: int32) -> int64:
    if len_in == 0:
        return cast[int64](-22)
    length: uint64 = (len_in + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)

    # MAP_FIXED at a specific address: honour exactly.
    is_fixed: int32 = 0
    if (flags & VMA_MAP_FIXED) != 0 and addr_in != 0:
        is_fixed = 1

    base: uint64 = 0
    if is_fixed != 0:
        # Carve any existing mapping in the target range.
        _vma_carve_range(slot, addr_in, addr_in + length)
        base = addr_in
    else:
        # Allocate from the large-VMA virtual window (free-list reuse
        # first, then bump — see _vma_win_alloc).
        window: uint64 = (length + VMA_MAX_CHUNK - 1) \
                         & ~(VMA_MAX_CHUNK - 1)
        base = _vma_win_alloc(slot, window)
        if base == 0:
            printk1("vma: demand window exhausted (need 0x%x)\n", window)
            return cast[int64](-12)

    # Prepare page tables for the demand range (crack PDPT/PD/PT without
    # installing any physical mappings).
    pml4: uint64 = task_pml4(cast[int32](slot))

    # elf_prepare_demand_range requires the range to be within one 1 GiB
    # PDPT entry. A large demand VMA (> 1 GiB) needs multiple calls; for
    # now split into per-GiB chunks (same as elf_install_user_range).
    GIB: uint64 = 0x40000000
    cur: uint64 = base
    while cur < base + length:
        gib_end: uint64 = (cur + GIB) & ~(GIB - 1)
        chunk_end: uint64 = gib_end
        if chunk_end > base + length:
            chunk_end = base + length
        if elf_prepare_demand_range(pml4, cur, chunk_end) < 0:
            printk1("vma: demand PT prep OOM @ 0x%x\n", cur)
            return cast[int64](-12)
        cur = chunk_end

    load_cr3(pml4)

    node: uint64 = _vma_node_new()
    if node == 0:
        return cast[int64](-12)
    end_v: uint64 = base + length
    _vma_node_set(node, base, end_v, prot, flags, -1, 0, 0, 0)
    cast[Ptr[VmaNode]](node)[0].is_demand = 1
    _vma_insert_sorted(slot, node)
    return cast[int64](base)


# ---------------------------------------------------------------------
# DEMAND-BSS (2026-06-23) — vma_register_bss_demand
# ---------------------------------------------------------------------
#
# Registers an ELF image's BSS tail [lo, hi) as a FIXED demand-zero
# anonymous VMA in the user's address space, mirroring vma_alloc_demand's
# is_fixed body. The loader (fs/elf.ad::_load_elf64) now eagerly backs
# only the file extent of an image and hands the BSS tail here so
# do_page_fault → vma_demand_fault zero-fills it lazily, page by page —
# instead of the old eager ~8 MiB CONTIGUOUS region_alloc that OOM'd the
# DE after a few hamui apps (each links ~8.2 MiB static BSS).
#
# The range is BELOW 1 GiB (real app vaddrs), NOT the [1G,4G) mmap
# window, so this carves nothing from vma_large_next — it lays the
# demand reservation at the exact app vaddrs. prot is RW + NX (BSS is
# writable DATA, never executed); vma_demand_fault stamps NX from prot
# via _vma_nx_flag and RW from VMA_PROT_WRITE.
#
# do_execve calls this AFTER elf_apply_last_user_mapping installs the
# eager file-backed image, with lo = elf_last_app_bss_lo_get() and
# hi = elf_last_app_bss_hi_get(). When hi <= lo (no BSS tail) it is a
# no-op (returns 0). Returns 0 on success, negative errno on OOM.

def vma_register_bss_demand(slot: uint64, pml4_phys: uint64,
                            lo: uint64, hi: uint64) -> int32:
    if hi <= lo:
        return 0
    # Page-align (defensive; the loader already rounds both to a page).
    base: uint64 = lo & ~(VMA_PAGE_SIZE - 1)
    top:  uint64 = (hi + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)
    length: uint64 = top - base

    # FIXED semantics: carve any existing mapping in the target range
    # (fresh app BSS — nothing to carve, but mirrors vma_alloc_demand's
    # is_fixed body and is harmless / defensive against a stale node).
    _vma_carve_range(slot, base, top)

    # Prepare the page tables for the demand range per-GiB (crack
    # PDPT/PD/PT without installing any physical mappings), exactly like
    # vma_alloc_demand. A user touch then fires a NOT-PRESENT #PF that
    # do_page_fault routes to vma_demand_fault.
    GIB: uint64 = 0x40000000
    cur: uint64 = base
    while cur < top:
        gib_end: uint64 = (cur + GIB) & ~(GIB - 1)
        chunk_end: uint64 = gib_end
        if chunk_end > top:
            chunk_end = top
        if elf_prepare_demand_range(pml4_phys, cur, chunk_end) < 0:
            printk1("vma: bss-demand PT prep OOM @ 0x%x\n", cur)
            return -12
        cur = chunk_end

    load_cr3(pml4_phys)

    node: uint64 = _vma_node_new()
    if node == 0:
        return -12
    # Anon, private, RW+NX, no fd/backing. is_demand=1 → vma_demand_fault
    # zero-fills on access.
    bss_prot: int32 = VMA_PROT_READ | VMA_PROT_WRITE
    _vma_node_set(node, base, top, bss_prot, 0, -1, 0, 0, 0)
    cast[Ptr[VmaNode]](node)[0].is_demand = 1
    _vma_insert_sorted(slot, node)
    printk2("vma: bss-demand VMA [0x%x, 0x%x) registered\n", base, top)
    return 0


# ---------------------------------------------------------------------
# §hugepage — vma_alloc_huge_demand: demand-paged 2 MiB MAP_HUGETLB mmap
# ---------------------------------------------------------------------
#
# Creates a MAP_HUGETLB anonymous VMA (is_huge=1, is_demand=1) whose
# virtual range is prepared at PMD granularity: the per-task PDPT + PD
# exist for [base, base+length), but every covering 2 MiB PDE is left
# NOT-PRESENT (PDE == 0). A user touch fires a NOT-PRESENT #PF;
# do_page_fault → vma_demand_fault sees is_huge and resolves it by
# allocating ONE 2 MiB-aligned, physically-contiguous order-9 buddy run,
# zeroing it, and installing a single PS=1 PDE covering the whole 2 MiB
# (elf_map_one_huge_pde). No 4 KiB PTEs are ever created for the range.
#
# hugetlbfs/Linux MAP_HUGETLB semantics: the LENGTH must be a multiple of
# the huge-page size (2 MiB) and a MAP_FIXED addr must be 2 MiB-aligned —
# this is enforced by the SYS_MMAP caller (it returns -EINVAL otherwise),
# but we re-align defensively here. The mapping lives in the same
# [1 GiB, 4 GiB) large-VMA window as the ordinary demand path; the window
# base is 4 MiB-aligned (vma_large_next / VMA_MAX_CHUNK), so every carved
# window is trivially 2 MiB-aligned.
#
# Returns the resolved base (>= 0) on success, or a negative Linux errno.

def vma_alloc_huge_demand(slot: uint64, addr_in: uint64, len_in: uint64,
                          prot: int32, flags: int32) -> int64:
    # Thread address-space serialization: hold the mm-group WRITE lock
    # across the WHOLE reserve->install->insert (or carve->release)
    # mutation so two threads of one CLONE_VM address space can never race
    # the shared window cursor / free-list / interval tree and hand out
    # OVERLAPPING window VAs into the shared PML4 (the Firefox eager
    # PTE=0 SIGSEGV). Recursive: inner tree/carve helpers re-acquire on the
    # same logical CPU. A process (no thread group) still takes its own
    # per-mm lock cheaply.
    vma_mm_write_lock(slot)
    _lr: int64 = _vma_alloc_huge_demand_locked(slot, addr_in, len_in, prot, flags)
    vma_mm_write_unlock(slot)
    return _lr


def _vma_alloc_huge_demand_locked(slot: uint64, addr_in: uint64, len_in: uint64,
                          prot: int32, flags: int32) -> int64:
    if len_in == 0:
        return cast[int64](-22)
    # MAP_HUGETLB requires a huge-page-aligned length (Linux -EINVAL
    # otherwise). The SYS_MMAP caller already validated; round UP to a
    # 2 MiB multiple defensively so we never under-prepare the range.
    length: uint64 = (len_in + VMA_HUGE_SIZE - 1) & ~(VMA_HUGE_SIZE - 1)

    # MAP_FIXED: honour exactly, but the address must be 2 MiB-aligned.
    is_fixed: int32 = 0
    if (flags & VMA_MAP_FIXED) != 0 and addr_in != 0:
        if (addr_in & (VMA_HUGE_SIZE - 1)) != 0:
            return cast[int64](-22)
        is_fixed = 1

    base: uint64 = 0
    if is_fixed != 0:
        _vma_carve_range(slot, addr_in, addr_in + length)
        base = addr_in
    else:
        # Carve a 4-MiB-aligned window from the large-VMA region (same
        # window bump as the ordinary demand path; 4 MiB-aligned implies
        # 2 MiB-aligned and keeps each window inside one 1 GiB PDPT entry).
        window: uint64 = (length + VMA_MAX_CHUNK - 1) \
                         & ~(VMA_MAX_CHUNK - 1)
        base = _vma_win_alloc(slot, window)
        if base == 0:
            printk1("vma: huge window exhausted (need 0x%x)\n", window)
            return cast[int64](-12)

    # Prepare the page tables at PMD granularity: PDPT + PD exist, every
    # covering 2 MiB PDE left not-present. Split into per-GiB chunks the
    # same way the 4 KiB demand path does (the huge prepare also refuses a
    # range crossing a 1 GiB PDPT entry).
    pml4: uint64 = task_pml4(cast[int32](slot))
    GIB: uint64 = 0x40000000
    cur: uint64 = base
    while cur < base + length:
        gib_end: uint64 = (cur + GIB) & ~(GIB - 1)
        chunk_end: uint64 = gib_end
        if chunk_end > base + length:
            chunk_end = base + length
        if elf_prepare_huge_demand_range(pml4, cur, chunk_end) < 0:
            printk1("vma: huge PT prep failed @ 0x%x\n", cur)
            return cast[int64](-12)
        cur = chunk_end

    load_cr3(pml4)

    node: uint64 = _vma_node_new()
    if node == 0:
        return cast[int64](-12)
    end_v: uint64 = base + length
    _vma_node_set(node, base, end_v, prot, flags, -1, 0, 0, 0)
    cast[Ptr[VmaNode]](node)[0].is_demand = 1
    cast[Ptr[VmaNode]](node)[0].is_huge   = 1
    _vma_insert_sorted(slot, node)
    return cast[int64](base)


# ---------------------------------------------------------------------
# §shared-pagecache — genuinely-shared physical frames for MAP_SHARED
# writable file mappings (POSIX MAP_SHARED page coherence)
# ---------------------------------------------------------------------
#
# A MAP_SHARED writable file mapping must, by POSIX, share the SAME
# physical frames across every mapping of the same (backing-file,
# file-offset): a store through one mapping is immediately visible
# through every other mapping (and the file's own bytes once flushed).
# apt/libapt-pkg relies on this — its cache generator and its readers
# mmap pkgcache.bin MAP_SHARED and expect page coherence under SMP.
#
# Without a shared cache, every mapping's #PF allocated a FRESH private
# page filled from the backing file (the MAP_PRIVATE contract); two
# concurrent MAP_SHARED mappers then diverged until msync/munmap
# writeback, which is the SMP non-determinism (NULL-deref / livelock)
# apt hit.
#
# This cache keys a physical frame by (marker, backing-identity,
# page-aligned file-offset). The FIRST file-shared fault for a key
# allocates a frame, fills it from the backing file, sets its COW
# refcount to 1, and records it. A subsequent file-shared fault for the
# same key bumps the frame's COW refcount (cow_ref_inc) and maps THAT
# frame — so all mappers share one frame. Teardown routes the frame
# through cow_drop_page (via the is_shared free arm), returning it to
# the buddy allocator only when the last mapper drops it. Writeback to
# the backing file still flushes dirty frames on msync/munmap so the
# file's own read()/write() bytes converge with the shared pages.
#
# The table is open-addressed (linear probe) and guarded by a single
# global spinlock — the fault path is the only writer; lookups are rare
# relative to the work each resolves. A cache miss when the table is
# full degrades gracefully to a private fill (correctness is preserved
# for the single-mapper case; only multi-mapper coherence is lost, and
# the table is sized to never fill under apt's working set).

VMA_PGCACHE_SLOTS: uint64 = 8192          # power of two for mask probing
VMA_PGCACHE_MASK:  uint64 = 8191

# Parallel arrays (key + value). key_used==0 marks an empty slot. The
# composite key is (marker, backing, foff) — all three must match.
vma_pgc_used:    Array[8192, uint32]
vma_pgc_marker:  Array[8192, uint32]
vma_pgc_backing: Array[8192, uint64]
vma_pgc_foff:    Array[8192, uint64]
vma_pgc_phys:    Array[8192, uint64]
vma_pgc_lock:    uint32
vma_pgc_count:   uint64


def _vma_pgc_hash(marker: uint32, backing: uint64, foff: uint64) -> uint64:
    # Mix the three key components into a table index. A simple
    # multiplicative mix is plenty for an 8 K-slot linear-probe table.
    h: uint64 = cast[uint64](marker) * 0x9E3779B1
    h = h ^ (backing * 0xC2B2AE35)
    h = h ^ (foff >> 12) * 0x27D4EB2F
    h = h ^ (h >> 15)
    return h & VMA_PGCACHE_MASK


def _vma_pgc_lookup(marker: uint32, backing: uint64,
                    foff: uint64) -> uint64:
    # Return the cached physical frame for (marker, backing, foff), or 0
    # if not present. Caller must hold vma_pgc_lock.
    idx: uint64 = _vma_pgc_hash(marker, backing, foff)
    probes: uint64 = 0
    while probes < VMA_PGCACHE_SLOTS:
        if vma_pgc_used[idx] == 0:
            return 0                       # empty slot ends the probe run
        if vma_pgc_marker[idx] == marker \
                and vma_pgc_backing[idx] == backing \
                and vma_pgc_foff[idx] == foff:
            return vma_pgc_phys[idx]
        idx = (idx + 1) & VMA_PGCACHE_MASK
        probes = probes + 1
    return 0


def _vma_pgc_insert(marker: uint32, backing: uint64, foff: uint64,
                    phys: uint64) -> int32:
    # Record (marker, backing, foff) -> phys. Returns 1 on success, 0 if
    # the table is full. Caller must hold vma_pgc_lock AND must have
    # already confirmed the key is absent (via _vma_pgc_lookup).
    idx: uint64 = _vma_pgc_hash(marker, backing, foff)
    probes: uint64 = 0
    while probes < VMA_PGCACHE_SLOTS:
        if vma_pgc_used[idx] == 0:
            vma_pgc_used[idx]    = 1
            vma_pgc_marker[idx]  = marker
            vma_pgc_backing[idx] = backing
            vma_pgc_foff[idx]    = foff
            vma_pgc_phys[idx]    = phys
            vma_pgc_count        = vma_pgc_count + 1
            return 1
        idx = (idx + 1) & VMA_PGCACHE_MASK
        probes = probes + 1
    return 0


def vma_pgc_drop_frame(phys: uint64):
    # Remove every cache entry pointing at `phys` (called when the frame's
    # last mapper drops it and cow_drop_page returns it to the buddy
    # allocator, so a later fault on the same key re-reads fresh bytes
    # from the backing file rather than aliasing a freed frame). Open-
    # addressing deletions use a tombstone-free rehash of the probe run.
    spinlock_lock(&vma_pgc_lock)
    i: uint64 = 0
    while i < VMA_PGCACHE_SLOTS:
        if vma_pgc_used[i] != 0 and vma_pgc_phys[i] == phys:
            vma_pgc_used[i] = 0
            if vma_pgc_count > 0:
                vma_pgc_count = vma_pgc_count - 1
            # Re-insert the entries following this slot in the probe run
            # so no live key is shadowed by the new empty slot.
            j: uint64 = (i + 1) & VMA_PGCACHE_MASK
            while vma_pgc_used[j] != 0:
                rm: uint32 = vma_pgc_marker[j]
                rb: uint64 = vma_pgc_backing[j]
                rf: uint64 = vma_pgc_foff[j]
                rp: uint64 = vma_pgc_phys[j]
                vma_pgc_used[j] = 0
                if vma_pgc_count > 0:
                    vma_pgc_count = vma_pgc_count - 1
                _vma_pgc_insert(rm, rb, rf, rp)
                j = (j + 1) & VMA_PGCACHE_MASK
        i = i + 1
    spinlock_unlock(&vma_pgc_lock)


def _vma_demand_fault_file_shared(slot: uint64, pml4_phys: uint64,
                                  fault_va: uint64, node: uint64,
                                  want_write: int32,
                                  prot: int32) -> int32:
    # Resolve a NOT-PRESENT fault inside a MAP_SHARED writable file VMA by
    # mapping the SHARED frame for this (backing, file-offset). The
    # namespace/cgroup charge for the page-in was already taken by the
    # caller; on any failure here the caller's existing OOM unwind path
    # (it allocated `phys` separately) does NOT apply — this routine owns
    # its allocation lifecycle and signals the caller via its return code:
    #   1  = fault resolved (frame mapped); caller must NOT also map.
    #  -1  = hard failure (OOM / read error); caller treats as fatal.
    v_start:  uint64 = cast[Ptr[VmaNode]](node)[0].start
    v_end_fs: uint64 = cast[Ptr[VmaNode]](node)[0].end
    f_off0:   uint64 = cast[Ptr[VmaNode]](node)[0].file_offset
    f_marker: uint32 = cast[uint32](cast[Ptr[VmaNode]](node)[0].file_marker)
    f_back:   uint64 = cast[Ptr[VmaNode]](node)[0].backing
    f_size:   uint64 = cast[Ptr[VmaNode]](node)[0].file_size
    page_va:  uint64 = fault_va & ~(VMA_PAGE_SIZE - 1)
    frd_off:  uint64 = f_off0 + (page_va - v_start)

    # §shared-mmap coherence (tmpfs DIRECT path): if the backing object
    # stores its data in directly-mappable page-aligned RAM (tmpfs), map
    # the file's OWN storage page into user space. A store through the
    # mapping then lands in the SAME page tmpfs_read()/tmpfs_write() touch,
    # so apt's write-pkgcache-then-read-it-back is coherent WITHOUT msync,
    # and every other mapper of the same file/offset maps the identical
    # page. These pages are OWNED BY TMPFS — the VMA must NOT free them on
    # teardown (the is_file_shared free arm skips tmpfs-marked nodes) and
    # there is no writeback to do (the bytes are already in the file's
    # storage). No COW refcount and no page-cache entry are involved.
    direct: uint64 = vfs_backing_page_phys(f_marker, f_back, frd_off)
    if direct != 0:
        if elf_map_one_page(pml4_phys, page_va, direct, want_write,
                            _vma_nx_flag(prot)) < 0:
            printk1("vma: tmpfs-shared map failed at va=0x%x\n", fault_va)
            return -1
        # §shared-mmap coherence: a WRITABLE shared mapping that faults a
        # page is about to store into it — extend the backing file's
        # recorded size to the END of this page so a later tmpfs_read()
        # returns the bytes written THROUGH the mapping (apt writes its
        # pkgcache records through the mapping then read()s / re-mmaps them
        # to bind a download URI to a version and to resolve dependencies).
        # Cap at the mapping's FULL mapped file extent [foff, foff+len):
        # the faulting page lies within this VMA, so every page up to the
        # VMA end is legitimately part of the file the program mmap'd
        # (after its ftruncate / mremap-grow). Using the VMA extent rather
        # than the possibly-stale file_size snapshot keeps a GROWN cache
        # coherent — capping at the old snapshot returned a short read,
        # and apt then followed a stored offset past EOF into an unmapped
        # page (SIGSEGV). A read-only shared mapping never extends the
        # file.
        if want_write != 0:
            vma_extent: uint64 = f_off0 + (v_end_fs - v_start)
            ext_to: uint64 = (frd_off & ~(VMA_PAGE_SIZE - 1)) + VMA_PAGE_SIZE
            if ext_to > vma_extent:
                ext_to = vma_extent
            if ext_to > 0:
                vfs_backing_extend_size(f_marker, f_back, ext_to)
        return 1

    spinlock_lock(&vma_pgc_lock)
    phys: uint64 = _vma_pgc_lookup(f_marker, f_back, frd_off)
    if phys != 0:
        # HIT: another mapping already owns this frame. Take a reference
        # so teardown frees it only when the LAST mapper drops it, then
        # map the SAME frame here. Coherence is automatic — both VAs now
        # translate to the one physical page.
        cow_ref_inc(phys)
        spinlock_unlock(&vma_pgc_lock)
        va_al: uint64 = page_va
        if elf_map_one_page(pml4_phys, va_al, phys, want_write,
                            _vma_nx_flag(prot)) < 0:
            # Couldn't install the PTE — release the ref we just took.
            if cow_drop_page(phys) != 0:
                vma_pgc_drop_frame(phys)
                free_page(phys)
            printk1("vma: shared-mmap map failed at va=0x%x\n", fault_va)
            return -1
        return 1
    spinlock_unlock(&vma_pgc_lock)

    # MISS: allocate the frame, fill it from the backing file, register it
    # as the shared frame for this key, and map it. Allocation happens
    # OUTSIDE the cache lock (alloc_page may sleep on reclaim).
    newp: uint64 = alloc_page()
    if newp == 0:
        printk1("vma: shared-mmap demand OOM at va=0x%x\n", fault_va)
        return -1
    memset(cast[Ptr[uint8]](newp), 0, 4096)
    prc: int64 = vfs_pread_backing(f_marker, f_back, f_size, frd_off,
                                   cast[Ptr[uint8]](newp), 4096)
    if prc < 0:
        free_page(newp)
        printk1("vma: shared-mmap read failed at va=0x%x\n", fault_va)
        return -1

    # Publish the frame under the lock. A concurrent fault on the same key
    # may have raced us between our unlock above and here — re-check, and
    # if a peer already published, drop ours and use theirs.
    spinlock_lock(&vma_pgc_lock)
    existing: uint64 = _vma_pgc_lookup(f_marker, f_back, frd_off)
    if existing != 0:
        cow_ref_inc(existing)
        spinlock_unlock(&vma_pgc_lock)
        free_page(newp)
        phys = existing
    else:
        # First publisher: refcount 1 (this single mapper) and record it.
        cow_ref_inc(newp)
        if _vma_pgc_insert(f_marker, f_back, frd_off, newp) == 0:
            # Table full: fall back to a private (still correct for THIS
            # mapper) frame — drop the speculative ref so teardown frees
            # it via the normal single-holder path. It just won't be
            # shared with future mappers (acceptable degradation).
            spinlock_unlock(&vma_pgc_lock)
            va_al2: uint64 = page_va
            if elf_map_one_page(pml4_phys, va_al2, newp, want_write,
                                _vma_nx_flag(prot)) < 0:
                if cow_drop_page(newp) != 0:
                    free_page(newp)
                return -1
            return 1
        spinlock_unlock(&vma_pgc_lock)
        phys = newp

    va_al3: uint64 = page_va
    if elf_map_one_page(pml4_phys, va_al3, phys, want_write,
                        _vma_nx_flag(prot)) < 0:
        if cow_drop_page(phys) != 0:
            vma_pgc_drop_frame(phys)
            free_page(phys)
        printk1("vma: shared-mmap map failed at va=0x%x\n", fault_va)
        return -1
    return 1


# ---------------------------------------------------------------------
# §file-mmap — vma_alloc_file_demand: demand-paged FILE-backed mmap
# ---------------------------------------------------------------------
#
# Identical page-table preparation to vma_alloc_demand, but the resulting
# VMA is flagged is_file=1 and carries the backing-file snapshot
# (marker / backing-id / total size / file offset). On a NOT-PRESENT #PF
# the page is filled from the file (vfs_pread_backing) instead of zeroed;
# bytes past file_size read as zero (the sub-page EOF tail). The caller
# (the SYS_MMAP handler) has already captured the snapshot via
# vfs_fd_backing_info while the fd was still open, so the user may close
# the fd immediately after mmap (POSIX).
#
# Returns the resolved base address (>= 0) on success, or a negative
# Linux errno on failure.

def vma_alloc_file_demand(slot: uint64, addr_in: uint64, len_in: uint64,
                          prot: int32, flags: int32,
                          file_marker: int32, file_backing: uint64,
                          file_size: uint64,
                          file_offset: uint64) -> int64:
    # Thread address-space serialization: hold the mm-group WRITE lock
    # across the WHOLE reserve->install->insert (or carve->release)
    # mutation so two threads of one CLONE_VM address space can never race
    # the shared window cursor / free-list / interval tree and hand out
    # OVERLAPPING window VAs into the shared PML4 (the Firefox eager
    # PTE=0 SIGSEGV). Recursive: inner tree/carve helpers re-acquire on the
    # same logical CPU. A process (no thread group) still takes its own
    # per-mm lock cheaply.
    vma_mm_write_lock(slot)
    _lr: int64 = _vma_alloc_file_demand_locked(slot, addr_in, len_in, prot, flags, file_marker, file_backing, file_size, file_offset)
    vma_mm_write_unlock(slot)
    return _lr


def _vma_alloc_file_demand_locked(slot: uint64, addr_in: uint64, len_in: uint64,
                          prot: int32, flags: int32,
                          file_marker: int32, file_backing: uint64,
                          file_size: uint64,
                          file_offset: uint64) -> int64:
    # Read-only / MAP_PRIVATE file-backed mapping (the default). Delegates
    # to the shared-aware core with is_shared=0 so faulted pages stay
    # private copies and nothing is ever written back.
    return _vma_alloc_file_core(slot, addr_in, len_in, prot, flags,
                                file_marker, file_backing, file_size,
                                file_offset, 0)


def vma_alloc_file_shared(slot: uint64, addr_in: uint64, len_in: uint64,
                          prot: int32, flags: int32,
                          file_marker: int32, file_backing: uint64,
                          file_size: uint64,
                          file_offset: uint64) -> int64:
    # Thread address-space serialization: hold the mm-group WRITE lock
    # across the WHOLE reserve->install->insert (or carve->release)
    # mutation so two threads of one CLONE_VM address space can never race
    # the shared window cursor / free-list / interval tree and hand out
    # OVERLAPPING window VAs into the shared PML4 (the Firefox eager
    # PTE=0 SIGSEGV). Recursive: inner tree/carve helpers re-acquire on the
    # same logical CPU. A process (no thread group) still takes its own
    # per-mm lock cheaply.
    vma_mm_write_lock(slot)
    _lr: int64 = _vma_alloc_file_shared_locked(slot, addr_in, len_in, prot, flags, file_marker, file_backing, file_size, file_offset)
    vma_mm_write_unlock(slot)
    return _lr


def _vma_alloc_file_shared_locked(slot: uint64, addr_in: uint64, len_in: uint64,
                          prot: int32, flags: int32,
                          file_marker: int32, file_backing: uint64,
                          file_size: uint64,
                          file_offset: uint64) -> int64:
    # §shared-mmap: MAP_SHARED writable file-backed mapping. Faulted pages
    # are mapped WRITABLE and tracked for write-back to the backing file
    # (msync(MS_SYNC) / munmap). The caller (SYS_MMAP) must have already
    # rejected a read-only backing object (initramfs) so write-back can
    # land somewhere.
    return _vma_alloc_file_core(slot, addr_in, len_in, prot, flags,
                                file_marker, file_backing, file_size,
                                file_offset, 1)


def _vma_alloc_file_core(slot: uint64, addr_in: uint64, len_in: uint64,
                         prot: int32, flags: int32,
                         file_marker: int32, file_backing: uint64,
                         file_size: uint64,
                         file_offset: uint64,
                         is_shared: int32) -> int64:
    if len_in == 0:
        return cast[int64](-22)
    length: uint64 = (len_in + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)

    is_fixed: int32 = 0
    if (flags & VMA_MAP_FIXED) != 0 and addr_in != 0:
        is_fixed = 1

    base: uint64 = 0
    if is_fixed != 0:
        _vma_carve_range(slot, addr_in, addr_in + length)
        base = addr_in
    else:
        window: uint64 = (length + VMA_MAX_CHUNK - 1) \
                         & ~(VMA_MAX_CHUNK - 1)
        base = _vma_win_alloc(slot, window)
        if base == 0:
            printk1("vma: file-mmap window exhausted (need 0x%x)\n",
                    window)
            return cast[int64](-12)

    pml4: uint64 = task_pml4(cast[int32](slot))
    GIB: uint64 = 0x40000000
    cur: uint64 = base
    while cur < base + length:
        gib_end: uint64 = (cur + GIB) & ~(GIB - 1)
        chunk_end: uint64 = gib_end
        if chunk_end > base + length:
            chunk_end = base + length
        if elf_prepare_demand_range(pml4, cur, chunk_end) < 0:
            printk1("vma: file-mmap PT prep OOM @ 0x%x\n", cur)
            return cast[int64](-12)
        cur = chunk_end

    load_cr3(pml4)

    node: uint64 = _vma_node_new()
    if node == 0:
        return cast[int64](-12)
    end_v: uint64 = base + length
    # Repurpose `backing` to carry the stable backing IDENTITY (cpio
    # index / tmpfs slot / ext4 inode / buffer pointer) — a file-backed
    # demand VMA owns no buddy run. file_offset is the in-file start.
    _vma_node_set(node, base, end_v, prot, flags, -1, file_offset,
                  file_backing, 0)
    cast[Ptr[VmaNode]](node)[0].is_demand   = 1
    cast[Ptr[VmaNode]](node)[0].is_file     = 1
    cast[Ptr[VmaNode]](node)[0].is_file_shared = is_shared
    cast[Ptr[VmaNode]](node)[0].file_marker = file_marker
    cast[Ptr[VmaNode]](node)[0].file_size   = file_size
    _vma_insert_sorted(slot, node)
    return cast[int64](base)


# ---------------------------------------------------------------------
# §142 — vma_demand_fault: populate one demand page on #PF
# ---------------------------------------------------------------------
#
# Called from do_page_fault when a NOT-PRESENT fault fires at `fault_va`
# under the task identified by `pml4_phys`. Looks up the VMA; if
# is_demand is set, allocates a physical page, zeros it, maps it via
# elf_map_one_page, and returns 1 (fault resolved). Returns 0 if the
# fault is NOT a demand-paging fault (genuine bad access — let the
# diagnostic halt fire). Returns -1 on OOM.
#
# The `slot` argument is the task slot index needed to look up the VMA
# list. The caller (do_page_fault) must supply it.

# ---------------------------------------------------------------------
# §hugepage — _vma_demand_fault_huge: populate one 2 MiB huge page on #PF
# ---------------------------------------------------------------------
#
# Resolves a NOT-PRESENT fault inside a MAP_HUGETLB (is_huge) VMA by
# allocating ONE 2 MiB-aligned, physically-contiguous order-9 buddy run,
# zero-filling it (anonymous-mapping contract), and installing a single
# PS=1 PDE covering the whole 2 MiB via elf_map_one_huge_pde. A 2 MiB
# huge page is one PDE / one TLB entry — touching any 4 KiB offset in the
# 2 MiB resolves the entire 2 MiB at once. Returns 1 on success, -1 on
# OOM / namespace-cap denial, 0 only if the node is somehow not huge
# (caller already vetted is_huge).
#
# `node` is the VMA covering fault_va (already looked up by the caller).

def _vma_demand_fault_huge(slot: uint64, pml4_phys: uint64,
                           fault_va: uint64, node: uint64) -> int32:
    prot: int32 = cast[Ptr[VmaNode]](node)[0].prot
    want_write: int32 = 0
    if (prot & VMA_PROT_WRITE) != 0:
        want_write = 1

    # The 2 MiB-aligned virtual base of the huge page covering fault_va.
    huge_va: uint64 = fault_va & ~(VMA_HUGE_SIZE - 1)

    # #174: charge the whole 2 MiB to the faulting task's namespace BEFORE
    # touching the allocator. Deny (return -1, no allocation) on over-cap.
    if nscap_mem_charge_slot(slot, VMA_HUGE_SIZE) != 0:
        printk1("vma: huge demand DENIED by namespace mem cap at va=0x%x\n",
                fault_va)
        return -1

    # Allocate a 2 MiB-aligned, physically-contiguous order-9 run. The
    # buddy allocator's memblock fallback aligns a 2 MiB request to 2 MiB,
    # and a split from a higher order is also naturally aligned — so the
    # returned base is guaranteed 2 MiB-aligned (required by a PS=1 PDE).
    phys: uint64 = alloc_pages(VMA_HUGE_ORDER)
    if phys == 0:
        nscap_mem_uncharge_slot(slot, VMA_HUGE_SIZE)
        printk1("vma: huge demand OOM at va=0x%x\n", fault_va)
        return -1
    if (phys & (VMA_HUGE_SIZE - 1)) != 0:
        # Should never happen given the allocator's alignment contract;
        # bail rather than install a mis-aligned PS=1 PDE.
        free_pages(phys, VMA_HUGE_ORDER)
        nscap_mem_uncharge_slot(slot, VMA_HUGE_SIZE)
        printk1("vma: huge alloc mis-aligned 0x%x\n", phys)
        return -1
    _vma_zero_phys(phys, VMA_HUGE_SIZE)

    # Install the single 2 MiB PS=1 PDE. W^X: NX unless mmap'd PROT_EXEC,
    # RW only when PROT_WRITE — same policy as the 4 KiB demand path.
    if elf_map_one_huge_pde(pml4_phys, huge_va, phys, want_write,
                            _vma_nx_flag(prot)) < 0:
        free_pages(phys, VMA_HUGE_ORDER)
        nscap_mem_uncharge_slot(slot, VMA_HUGE_SIZE)
        printk1("vma: huge PDE install failed at va=0x%x\n", fault_va)
        return -1

    nr_hugepages_total = nr_hugepages_total + 1
    nr_hugepages_live = nr_hugepages_live + 1
    # NOTICE level so the PS-bit proof survives the post-interactive
    # console-loglevel gate (which suppresses ordinary INFO chatter once
    # the hamsh prompt is up) — the test harness greps this line.
    printk_set_level(PRINTK_LEVEL_NOTICE)
    printk1("[hugepage] installed 2MiB PS-bit PDE at va=0x%x\n", huge_va)
    return 1


def vma_demand_fault(slot: uint64, pml4_phys: uint64,
                     fault_va: uint64) -> int32:
    # Wave-3 scalable fault path: RCU-lookup the covering VMA in the
    # O(log n) interval tree and TRYLOCK its per-VMA lock, so a fault on
    # this VMA proceeds concurrently with a fault on a DIFFERENT VMA (each
    # holds its own per-VMA lock). On a lost race (trylock fail or a
    # structural change moved the tree mid-lookup) fall back to the mm-wide
    # write lock — exactly Linux's lock_vma_under_rcu -> mmap_read_lock
    # model. The body is unchanged; only the lookup + hold discipline is.
    node: uint64 = vma_lock_fault_vma(slot, fault_va)
    used_mm_lock: int32 = 0
    if node == 0:
        # Slow path: serialize against structural changes on this mm.
        vma_mm_write_lock(slot)
        used_mm_lock = 1
        node = vma_find(slot, fault_va)
    rc: int32 = _vma_demand_fault_inner(slot, pml4_phys, fault_va, node)
    if used_mm_lock != 0:
        vma_mm_write_unlock(slot)
    else:
        vma_unlock_vma(node)
    return rc


def _vma_demand_fault_inner(slot: uint64, pml4_phys: uint64,
                            fault_va: uint64, node: uint64) -> int32:
    if node == 0:
        # Not in any VMA — genuine unmapped access.
        return 0
    if cast[Ptr[VmaNode]](node)[0].is_demand == 0:
        # VMA exists but is not demand-paged — some other kind of
        # not-present fault (shouldn't happen normally).
        return 0

    # §hugepage: a MAP_HUGETLB VMA resolves the fault with a single 2 MiB
    # huge page (one PS=1 PDE), NOT a 4 KiB page. Route to the dedicated
    # huge handler before the ordinary 4 KiB path.
    if cast[Ptr[VmaNode]](node)[0].is_huge != 0:
        return _vma_demand_fault_huge(slot, pml4_phys, fault_va, node)

    prot: int32 = cast[Ptr[VmaNode]](node)[0].prot
    want_write: int32 = 0
    if (prot & VMA_PROT_WRITE) != 0:
        want_write = 1

    # #174: charge this page-in to the faulting task's namespace BEFORE
    # touching the page allocator. If the namespace's memory cap would be
    # exceeded, deny the fault exactly like an over-OOM allocation: return
    # -1 so do_page_fault treats it as a fatal allocation failure (the
    # task takes the OOM/SIGSEGV path), and DON'T allocate the page. An
    # uncapped namespace returns 0 here and proceeds.
    if nscap_mem_charge_slot(slot, 4096) != 0:
        printk1("vma: demand DENIED by namespace mem cap at va=0x%x\n",
                fault_va)
        return -1

    # cgroup v2 memory.max: charge this page-in to the faulting task's
    # cgroup. The enforcer (mm/reclaim.ad) drives direct reclaim and, if
    # still over the cap, the cgroup OOM killer; a returned -ENOMEM means
    # the cgroup is hard-over its limit, so deny the fault (give the
    # namespace charge back first). Tasks in the root cgroup / an
    # uncapped cgroup always pass.
    if _memcg_charge_page(slot, 4096) < 0:
        nscap_mem_uncharge_slot(slot, 4096)
        printk1("vma: demand DENIED by cgroup memory.max at va=0x%x\n",
                fault_va)
        return -1

    # §shared-pagecache: a MAP_SHARED writable file VMA resolves the fault
    # by mapping the SHARED frame for this (backing, file-offset) — every
    # mapping of the same file/offset translates to one physical page so
    # writes are immediately coherent (POSIX MAP_SHARED). The helper owns
    # its own page allocation and registration; on success it has already
    # mapped the page, so we return directly. The namespace/cgroup charges
    # taken above stay charged for the resident frame (uncharged on
    # teardown like any demand page); on a hard failure we hand the
    # charges back here.
    if cast[Ptr[VmaNode]](node)[0].is_file_shared != 0:
        src: int32 = _vma_demand_fault_file_shared(slot, pml4_phys,
                                                   fault_va, node,
                                                   want_write, prot)
        if src < 0:
            nscap_mem_uncharge_slot(slot, 4096)
        return src

    # Allocate one physical page and zero-fill it (anonymous mapping
    # contract: demand pages read as zero on first access).
    phys: uint64 = alloc_page()
    if phys == 0:
        # Charged but couldn't get a page — give the charge back so the
        # namespace's residency stays honest.
        nscap_mem_uncharge_slot(slot, 4096)
        printk1("vma: demand OOM at va=0x%x\n", fault_va)
        return -1
    _vma_zero_phys(phys, 4096)

    # §file-mmap: a FILE-backed demand VMA reads the page's bytes from
    # the backing file instead of leaving it zero. The page is already
    # zeroed, so a short read at EOF (or a sub-page tail) leaves the
    # remainder reading as zero exactly as the mapping contract requires.
    # Because we read into a FRESH private page (never the file's own
    # storage), a later MAP_PRIVATE write to this page never reaches the
    # file — the copy-on-write contract holds for free.
    if cast[Ptr[VmaNode]](node)[0].is_file != 0:
        v_start:  uint64 = cast[Ptr[VmaNode]](node)[0].start
        f_off0:   uint64 = cast[Ptr[VmaNode]](node)[0].file_offset
        f_marker: uint32 = cast[uint32]( \
            cast[Ptr[VmaNode]](node)[0].file_marker)
        f_back:   uint64 = cast[Ptr[VmaNode]](node)[0].backing
        f_size:   uint64 = cast[Ptr[VmaNode]](node)[0].file_size
        page_va:  uint64 = fault_va & ~(VMA_PAGE_SIZE - 1)
        # File offset of this page = mmap offset + (page_va - vma_start).
        frd_off: uint64 = f_off0 + (page_va - v_start)
        prc: int64 = vfs_pread_backing(f_marker, f_back, f_size,
                                       frd_off,
                                       cast[Ptr[uint8]](phys), 4096)
        if prc < 0:
            free_page(phys)
            nscap_mem_uncharge_slot(slot, 4096)
            printk1("vma: file-mmap read failed at va=0x%x\n", fault_va)
            return -1

    # Map the page at the faulting address. W^X Stage 1a: a demand-paged
    # anonymous VMA is non-executable DATA unless it was mmap'd
    # PROT_EXEC, so stamp NX accordingly.
    va_al: uint64 = fault_va & ~(VMA_PAGE_SIZE - 1)
    if elf_map_one_page(pml4_phys, va_al, phys, want_write,
                        _vma_nx_flag(prot)) < 0:
        free_page(phys)
        nscap_mem_uncharge_slot(slot, 4096)
        printk1("vma: demand map failed at va=0x%x\n", fault_va)
        return -1
    # rmap + LRU: record this task as the page's anon mapper and put the
    # fresh page on the inactive LRU head so the reclaimer can age + evict
    # it.  Only MAP_PRIVATE|ANON pages are reclaimable this way; a file-
    # backed page is re-read from its backing file on refault, so it is
    # tracked but its eviction path differs — we still rmap/LRU it as a
    # single-mapper page (its swap-out is skipped by page_is_anon screening
    # in the scanner, leaving file pages to the file writeback path).
    if cast[Ptr[VmaNode]](node)[0].is_file == 0:
        page_add_anon_rmap(phys, slot, va_al)
        lru_add_anon(phys)
        mark_page_accessed(phys)
    return 1


# ---------------------------------------------------------------------
# §shared-mmap — write-back of MAP_SHARED writable file pages
# ---------------------------------------------------------------------
#
# PTE dirty bit (set by the CPU on the first write to a writable page).
VMA_PT_FLAG_D: uint64 = 0x40


def _vma_writeback_node(node: uint64, pml4_phys: uint64,
                        lo: uint64, hi: uint64) -> int64:
    # Flush the dirty resident pages of a MAP_SHARED writable file-backed
    # VMA `node` whose virtual range intersects [lo, hi) back to the
    # backing file. Returns 0 on success, a negative errno on the first
    # write-back failure (e.g. -EROFS for an initramfs backing, which the
    # mmap path should already have refused). A page is flushed iff its
    # PTE is present AND has the dirty bit set; the dirty bit is cleared
    # after a successful flush so a later msync re-flushes only pages
    # written since.
    if cast[Ptr[VmaNode]](node)[0].is_file_shared == 0:
        return 0
    # §shared-mmap coherence (tmpfs DIRECT): a tmpfs-backed shared mapping
    # maps the file's OWN storage pages, so the bytes are ALREADY in the
    # file — there is nothing to write back (and the frames are tmpfs-
    # owned, not in the writeback/LRU accounting). Skip them.
    if cast[uint32](cast[Ptr[VmaNode]](node)[0].file_marker) == VMA_FD_TMPFS_MARK:
        return 0
    v_start:  uint64 = cast[Ptr[VmaNode]](node)[0].start
    v_end:    uint64 = cast[Ptr[VmaNode]](node)[0].end
    f_off0:   uint64 = cast[Ptr[VmaNode]](node)[0].file_offset
    f_marker: uint32 = cast[uint32](cast[Ptr[VmaNode]](node)[0].file_marker)
    f_back:   uint64 = cast[Ptr[VmaNode]](node)[0].backing
    f_size:   uint64 = cast[Ptr[VmaNode]](node)[0].file_size

    # Clamp the flush window to the VMA's own range.
    w_lo: uint64 = lo
    if w_lo < v_start:
        w_lo = v_start
    w_hi: uint64 = hi
    if w_hi > v_end:
        w_hi = v_end
    if w_lo >= w_hi:
        return 0

    # Page-align the window.
    page: uint64 = w_lo & ~(VMA_PAGE_SIZE - 1)
    rc: int64 = 0
    while page < w_hi:
        pslot: uint64 = _vma_pte_slot_addr(pml4_phys, page)
        if pslot != 0:
            pte: uint64 = cast[Ptr[uint64]](pslot)[0]
            if (pte & VMA_PT_FLAG_P) != 0 and (pte & VMA_PT_FLAG_D) != 0:
                phys: uint64 = pte & VMA_PT_ADDR_MASK
                if phys != 0:
                    # Writeback accounting: this CPU-dirtied page is about to
                    # be cleaned.  Account it dirty then mark it under
                    # write-back for the duration of the flush so the
                    # dirty/writeback counters mirror the real I/O state.
                    set_page_dirty(phys)
                    set_page_writeback(phys)
                    # In-file offset of this page.
                    frd_off: uint64 = f_off0 + (page - v_start)
                    # Don't write past the file's recorded size — the
                    # sub-page EOF tail is not part of the file.
                    if frd_off < f_size:
                        wlen: uint64 = VMA_PAGE_SIZE
                        if frd_off + wlen > f_size:
                            wlen = f_size - frd_off
                        wb: int64 = vfs_pwrite_backing(f_marker, f_back,
                                                       frd_off,
                                                       cast[Ptr[uint8]](phys),
                                                       wlen)
                        if wb < 0:
                            printk1("vma: writeback FAIL at va=0x%x\n", page)
                            # Flush failed — the page is still dirty.  End the
                            # write-back state (the I/O is over) but leave it
                            # accounted dirty so a retry re-flushes it.
                            end_page_writeback(phys)
                            rc = wb
                            return rc
                    # Flush succeeded: the page is clean.  End write-back and
                    # drop the dirty accounting + the PTE dirty bit so a
                    # subsequent msync only re-flushes pages dirtied since.
                    end_page_writeback(phys)
                    clear_page_dirty(phys)
                    cast[Ptr[uint64]](pslot)[0] = pte & ~VMA_PT_FLAG_D
        page = page + VMA_PAGE_SIZE
    return rc


def vma_writeback_range(slot: uint64, addr: uint64,
                        len_in: uint64) -> int64:
    # msync(MS_SYNC): flush every MAP_SHARED writable file-backed VMA that
    # intersects [addr, addr+len) back to its backing file. Anonymous /
    # MAP_PRIVATE / read-only file VMAs in the range are skipped (a no-op,
    # like Linux msync on a non-file mapping). Returns 0 on success or the
    # first negative errno encountered. A range covering no file-shared
    # VMA is a successful no-op.
    if len_in == 0:
        return 0
    length: uint64 = (len_in + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)
    lo: uint64 = addr & ~(VMA_PAGE_SIZE - 1)
    hi: uint64 = addr + length
    pml4: uint64 = task_pml4(cast[int32](slot))
    # Flush the TLB before reading dirty bits so the CPU's in-flight
    # writes are reflected in the page tables we're about to scan.
    load_cr3(pml4)
    rc: int64 = 0
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0:
        nxt: uint64 = cast[Ptr[VmaNode]](cur)[0].next
        if cast[Ptr[VmaNode]](cur)[0].is_file_shared != 0:
            n_start: uint64 = cast[Ptr[VmaNode]](cur)[0].start
            n_end:   uint64 = cast[Ptr[VmaNode]](cur)[0].end
            # Intersect?
            if n_start < hi and n_end > lo:
                r: int64 = _vma_writeback_node(cur, pml4, lo, hi)
                if r < 0 and rc == 0:
                    rc = r
        cur = nxt
    return rc


# ---------------------------------------------------------------------
# #167: page reclaim — evict anonymous (demand-paged) pages to swap
# ---------------------------------------------------------------------
#
# A demand-paged anonymous VMA (is_demand == 1) is the canonical
# swappable region: each present 4 KiB page is PRIVATE (one mapper, no
# COW refcount), identity-mapped, and was populated lazily on first
# touch by vma_demand_fault. Under memory pressure mm/reclaim.ad asks a
# task to give up some of these pages:
#
#   1. walk the task's demand VMAs page-by-page,
#   2. for each PRESENT page, copy its bytes into a free swap slot
#      (swap_out_page),
#   3. rewrite the page's PTE to a not-present SWAP ENTRY encoding that
#      slot (swap_make_pte),
#   4. free the physical page back to the buddy allocator.
#
# A later access to that virtual address faults not-present; the #PF
# handler decodes the swap entry, allocates a fresh page, restores the
# bytes (swap_in_page), and re-installs a present PTE — transparently.
#
# Clean / unmodified pages could be dropped without writeback, but a
# demand-zero anon page that was written is dirty by definition, so we
# always write it to swap to preserve its contents. (We have no per-page
# dirty bit plumbed yet; treating every anon page as dirty is correct,
# just slightly conservative.)


def _vma_pte_slot_addr(pml4_phys: uint64, vaddr: uint64) -> uint64:
    # Return the ADDRESS of the 4 KiB PTE slot mapping `vaddr`, or 0 if
    # any level is not-present or the leaf is a huge page. Read-only walk
    # — never allocates or cracks a table (the demand pages it serves are
    # always already mapped at 4 KiB granularity by vma_demand_fault).
    if pml4_phys == 0:
        return 0
    pml4_idx: uint64 = (vaddr >> 39) & 0x1FF
    pdpt_idx: uint64 = (vaddr >> 30) & 0x1FF
    pd_idx:   uint64 = (vaddr >> 21) & 0x1FF
    pt_idx:   uint64 = (vaddr >> 12) & 0x1FF

    pml4: Ptr[uint64] = cast[Ptr[uint64]](pml4_phys & VMA_PT_ADDR_MASK)
    pml4e: uint64 = pml4[pml4_idx]
    if (pml4e & VMA_PT_FLAG_P) == 0:
        return 0
    pdpt: Ptr[uint64] = cast[Ptr[uint64]](pml4e & VMA_PT_ADDR_MASK)
    pdpte: uint64 = pdpt[pdpt_idx]
    if (pdpte & VMA_PT_FLAG_P) == 0:
        return 0
    if (pdpte & VMA_PT_FLAG_PS) != 0:
        return 0
    pd: Ptr[uint64] = cast[Ptr[uint64]](pdpte & VMA_PT_ADDR_MASK)
    pde: uint64 = pd[pd_idx]
    if (pde & VMA_PT_FLAG_P) == 0:
        return 0
    if (pde & VMA_PT_FLAG_PS) != 0:
        return 0
    pt: Ptr[uint64] = cast[Ptr[uint64]](pde & VMA_PT_ADDR_MASK)
    return cast[uint64](pt) + pt_idx * 8


def vma_task_anon_rss(slot: uint64) -> uint64:
    # Count PRESENT 4 KiB pages backing this task's demand-paged anon
    # VMAs — the resident anonymous working set. Used by the OOM killer's
    # badness heuristic (largest-RSS victim) and by the reclaim driver to
    # know how much it can evict.
    pml4: uint64 = task_pml4(cast[int32](slot))
    if pml4 == 0:
        return 0
    rss: uint64 = 0
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0:
        if cast[Ptr[VmaNode]](cur)[0].is_demand != 0:
            s: uint64 = cast[Ptr[VmaNode]](cur)[0].start
            e: uint64 = cast[Ptr[VmaNode]](cur)[0].end
            va: uint64 = s
            while va < e:
                pte: uint64 = _vma_pte_lookup(pml4, va)
                if pte != 0:
                    rss = rss + 1
                va = va + VMA_PAGE_SIZE
        cur = _vma_node_get_next(cur)
    return rss


def vma_reclaim_anon_pages(slot: uint64, want: uint64) -> uint64:
    # Evict up to `want` present anonymous pages of `slot` to swap and
    # free them. Returns the number actually reclaimed. A page is
    # reclaimed only if swap_out_page succeeds (swap not full); if swap is
    # full the scan stops early. The PTE is rewritten to a swap entry so a
    # later access faults the page back in transparently.
    if want == 0:
        return 0
    if swap_ready() == 0:
        return 0
    pml4: uint64 = task_pml4(cast[int32](slot))
    if pml4 == 0:
        return 0
    reclaimed: uint64 = 0
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0 and reclaimed < want:
        if cast[Ptr[VmaNode]](cur)[0].is_demand != 0:
            s: uint64 = cast[Ptr[VmaNode]](cur)[0].start
            e: uint64 = cast[Ptr[VmaNode]](cur)[0].end
            va: uint64 = s
            while va < e and reclaimed < want:
                pslot: uint64 = _vma_pte_slot_addr(pml4, va)
                if pslot != 0:
                    pte: uint64 = cast[Ptr[uint64]](pslot)[0]
                    if (pte & VMA_PT_FLAG_P) != 0:
                        phys: uint64 = pte & VMA_PT_ADDR_MASK
                        if phys != 0:
                            sw: int64 = swap_out_page(phys)
                            if sw < 0:
                                # Swap full — stop; the OOM killer takes
                                # over from here.
                                return reclaimed
                            # Rewrite the PTE to a not-present swap entry,
                            # flush the TLB, tear down the rmap + LRU
                            # bookkeeping for the frame, and free the
                            # physical page.
                            cast[Ptr[uint64]](pslot)[0] = \
                                swap_make_pte(cast[uint64](sw))
                            invlpg_one(va)
                            lru_remove(phys)
                            page_remove_rmap(phys)
                            free_page(phys)
                            reclaimed = reclaimed + 1
                va = va + VMA_PAGE_SIZE
        cur = _vma_node_get_next(cur)
    return reclaimed


def vma_reclaim_one_page(slot: uint64, va: uint64) -> int32:
    # Evict the SINGLE anonymous page that task `slot` maps at page-aligned
    # `va` to swap, and free it.  This is the rmap-targeted eviction the LRU
    # scanner (mm/reclaim.ad::reclaim_shrink_lru) calls: the scanner picks a
    # cold inactive PFN, asks rmap for its (slot, va), and calls here to
    # rewrite exactly that PTE — no per-task page-table walk.  Returns:
    #    1  evicted to swap (PTE now a swap entry, page freed)
    #    0  nothing to do (PTE not present, or va not page-table-resolvable)
    #   -1  swap full (caller stops; OOM killer takes over)
    if swap_ready() == 0:
        return -1
    pml4: uint64 = task_pml4(cast[int32](slot))
    if pml4 == 0:
        return 0
    va_al: uint64 = va & ~(VMA_PAGE_SIZE - 1)
    pslot: uint64 = _vma_pte_slot_addr(pml4, va_al)
    if pslot == 0:
        return 0
    pte: uint64 = cast[Ptr[uint64]](pslot)[0]
    if (pte & VMA_PT_FLAG_P) == 0:
        return 0
    # Never evict a COW-shared frame: it has >1 mapper and the rmap word
    # only names one of them.  The LRU scanner already screens with
    # page_is_anon (mapcount == 1), but re-check the PTE's COW bit here as a
    # second guard so a targeted eviction can never silently lose a sharer.
    if (pte & PT_FLAG_COW) != 0:
        return 0
    phys: uint64 = pte & VMA_PT_ADDR_MASK
    if phys == 0:
        return 0
    sw: int64 = swap_out_page(phys)
    if sw < 0:
        return -1
    cast[Ptr[uint64]](pslot)[0] = swap_make_pte(cast[uint64](sw))
    invlpg_one(va_al)
    lru_remove(phys)
    page_remove_rmap(phys)
    free_page(phys)
    return 1


# ---------------------------------------------------------------------
# #167: swap-in — fault a swapped-out anonymous page back from swap
# ---------------------------------------------------------------------
#
# Called from the #PF handler (arch/x86/kernel/trap_diag.ad) on a
# not-present USER fault whose PTE is a SWAP ENTRY (swap_pte_is_swap).
# Decodes the swap slot, allocates a fresh physical page, restores the
# slot's bytes into it (swap_in_page), and rewrites the PTE present with
# the owning VMA's permissions — so the faulting instruction resumes and
# reads exactly the bytes that were evicted.
#
# Returns:
#    1  swapped page restored — re-run the faulting instruction.
#    0  the PTE at fault_va is NOT a swap entry — not our fault.
#   -1  swap-in failed (OOM allocating the restore page, or bad slot) —
#       the caller surfaces it.


def vma_swap_in_fault(slot: uint64, pml4_phys: uint64,
                      fault_va: uint64) -> int32:
    va_al: uint64 = fault_va & ~(VMA_PAGE_SIZE - 1)
    pte_slot: uint64 = _vma_pte_slot_addr(pml4_phys, va_al)
    if pte_slot == 0:
        return 0
    pte: uint64 = cast[Ptr[uint64]](pte_slot)[0]
    if swap_pte_is_swap(pte) == 0:
        return 0
    # It IS a swap entry. Decode the slot, allocate a restore page.
    sw_slot: uint64 = swap_pte_slot(pte)
    phys: uint64 = alloc_page()
    if phys == 0:
        printk1("vma: swap-in OOM at va=0x%x\n", fault_va)
        return -1
    if swap_in_page(sw_slot, phys) < 0:
        free_page(phys)
        printk1("vma: swap-in bad slot at va=0x%x\n", fault_va)
        return -1
    # Reconstruct the PTE permissions from the owning VMA's prot. A
    # swapped anon page is private DATA — present + user, writable iff the
    # VMA is PROT_WRITE, NX unless PROT_EXEC.
    node: uint64 = vma_find(slot, va_al)
    want_write: int32 = 0
    nx: uint64 = PT_FLAG_NX
    if node != 0:
        prot: int32 = cast[Ptr[VmaNode]](node)[0].prot
        if (prot & VMA_PROT_WRITE) != 0:
            want_write = 1
        nx = _vma_nx_flag(prot)
    if elf_map_one_page(pml4_phys, va_al, phys, want_write, nx) < 0:
        free_page(phys)
        printk1("vma: swap-in map failed at va=0x%x\n", fault_va)
        return -1
    # rmap + LRU: the restored page has a single mapper again (this task at
    # va_al).  Re-record it and place it on the LRU; mark it accessed so the
    # next active-list scan promotes a page that is refaulting from swap
    # (refault → it was reclaimed too eagerly, so it earns a second chance).
    page_add_anon_rmap(phys, slot, va_al)
    lru_add_anon(phys)
    mark_page_accessed(phys)
    return 1


def vma_resolve_write_perm_fault(slot: uint64, pml4_phys: uint64,
                                 fault_va: uint64) -> int32:
    # Resolve a WRITE fault on a PRESENT, read-only USER page (P=1, W=1)
    # by consulting the owning VMA's recorded prot. Two distinct faulters
    # reach here:
    #
    #   * ld.so (CPL=3, U=1) writing a GOT/RELRO/.data relocation slot into
    #     a writable data segment whose leaf PTE is stale-RO. glibc reserves
    #     a whole DSO span PROT_READ then MAP_FIXED-overlays the writable
    #     data/GOT segment inside it; if the overlay's RW re-stamp missed a
    #     page (a not-present hole the eager re-stamp skipped, or a 2 MiB
    #     boundary page the reservation installed RO), the first relocation
    #     write faults.
    #
    #   * the KERNEL (CPL=0, U=0) filling that same overlay: _u_mmap's
    #     vfs_read writes the file's data-segment bytes DIRECTLY to the user
    #     VA, and the alias path's memset zero-fills a .bss overlay the same
    #     way. Under CR0.WP a supervisor write to a read-only page faults
    #     exactly like a CPL=3 one (#PF err U=0 instead of U=1). The real
    #     Debian-glibc dpkg crash was this exact shape: cr2=0x49c00000
    #     (the libc data segment), err=0x03 (P=1 W=1 U=0), rip in kernel
    #     code (the mmap-fill vfs_read).
    #
    # In BOTH cases the page is GENUINELY writable per its VMA — the PTE is
    # merely stale. Re-stamp the single faulting leaf RW (honoring the
    # VMA's NX) so the write completes and the instruction re-runs. If the
    # owning VMA does NOT grant PROT_WRITE this is a real permission
    # violation (a true W^X .text/.rodata write): return 0 so the caller
    # signals / halts as appropriate. A COW page is NOT touched here — the
    # COW resolver already ran in do_page_fault and a still-RO COW leaf must
    # take the copy path, never a force-writable.
    va_al: uint64 = fault_va & ~(VMA_PAGE_SIZE - 1)
    # Scan ALL VMAs covering va_al, not just the first. ld.so's reserve+
    # overlay idiom leaves TWO overlapping nodes at the same address: the
    # enclosing whole-DSO reservation (PROT_READ) and a strictly-smaller
    # MAP_FIXED alias for the data/GOT segment (PROT_READ|PROT_WRITE).
    # vma_find returns the start-sorted FIRST match — the RO reservation —
    # so a single lookup would wrongly conclude the page is non-writable.
    # The page is writable iff ANY covering VMA grants PROT_WRITE (the
    # innermost overlay wins, exactly as the MAP_FIXED overlay's prot
    # governs the leaf PTE). A genuine W^X violation has NO writable
    # covering VMA.
    any_writable: int32 = 0
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0:
        s: uint64 = _vma_node_start(cur)
        if s > va_al:
            cur = 0
        else:
            e: uint64 = _vma_node_end(cur)
            if s <= va_al and va_al < e:
                cp: int32 = cast[Ptr[VmaNode]](cur)[0].prot
                if (cp & VMA_PROT_WRITE) != 0:
                    any_writable = 1
            cur = _vma_node_get_next(cur)
    if any_writable == 0:
        # No covering VMA grants write — a real protection fault.
        return 0
    prot: int32 = VMA_PROT_WRITE
    pslot: uint64 = _vma_pte_slot_addr(pml4_phys, va_al)
    if pslot == 0:
        return 0
    pte: uint64 = cast[Ptr[uint64]](pslot)[0]
    if (pte & VMA_PT_FLAG_P) == 0:
        # Not present after all — leave it to demand/swap.
        return 0
    if (pte & PT_FLAG_COW) != 0:
        # A COW leaf: never force-writable here; the copy goes through
        # cow_handle_write_fault (already tried by do_page_fault).
        return 0
    if (pte & PT_FLAG_RW) != 0:
        # Already writable — the fault was transient (another CPU restamped
        # it, or a TLB shootdown lag). Re-running the instruction succeeds.
        invlpg_one(va_al)
        return 1
    # Stamp RW on the faulting leaf, keeping NX consistent with the VMA's
    # prot (a writable data page is non-exec; a rare PROT_EXEC|PROT_WRITE
    # page stays executable).
    new_pte: uint64 = (pte | PT_FLAG_RW) & ~PT_FLAG_NX
    if (prot & VMA_PROT_EXEC) == 0:
        new_pte = new_pte | PT_FLAG_NX
    cast[Ptr[uint64]](pslot)[0] = new_pte
    invlpg_one(va_al)
    return 1


def vma_resolve_exec_perm_fault(slot: uint64, pml4_phys: uint64,
                                fault_va: uint64) -> int32:
    # EXEC-side mirror of vma_resolve_write_perm_fault. Resolve an
    # INSTRUCTION-FETCH fault on a PRESENT, USER, NX leaf (err P=1 U=1
    # I/D=1) by consulting the owning VMA's recorded prot.
    #
    # ld.so loads a DSO by reserving the whole span PROT_READ (NX) then
    # MAP_FIXED-overlaying the .text segment PROT_READ|PROT_EXEC inside the
    # reservation. The exec overlay must re-stamp every leaf in its range
    # NX-clear. If the re-stamp MISSED a page — a 2 MiB boundary page the
    # reservation installed NX, a not-present hole the eager re-stamp
    # skipped that a later demand fault filled with the reservation's NX
    # prot, or a partial overlay leaving two overlapping nodes where the
    # start-sorted lookup that drove the install saw only the RO/NX
    # reservation — then the first instruction fetch into that page raises
    # an NX exec-fault even though a covering VMA legitimately grants EXEC.
    # This is the apt 'Reading package lists' / gpgv-method NX exec-fault:
    # apt forks an acquire method (gpgv/http), ld.so maps libapt-pkg /
    # libc .text, and a boundary page of that exec mapping was left NX.
    #
    # The page is GENUINELY executable per its VMA — the leaf PTE is merely
    # stale-NX. Clear NX on the single faulting leaf (honoring the VMA's
    # write prot) so the fetch completes and the instruction re-runs. If NO
    # covering VMA grants PROT_EXEC this is a real W^X violation (a jump
    # into the stack / a data page): return 0 so the caller delivers
    # SIGSEGV exactly as before. A COW leaf is left untouched (the COW
    # resolver owns it); a fetch is a read so COW would not be the cause,
    # but we never force-exec a COW page here.
    va_al: uint64 = fault_va & ~(VMA_PAGE_SIZE - 1)
    # Does ANY covering VMA grant PROT_EXEC? The innermost MAP_FIXED exec
    # overlay wins, exactly as it governs the leaf PTE at install time —
    # mirror vma_resolve_write_perm_fault's all-covers scan rather than the
    # start-sorted single lookup (which would see only the RO reservation).
    any_exec: int32 = 0
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0:
        s: uint64 = _vma_node_start(cur)
        if s > va_al:
            cur = 0
        else:
            e: uint64 = _vma_node_end(cur)
            if s <= va_al and va_al < e:
                cp: int32 = cast[Ptr[VmaNode]](cur)[0].prot
                if (cp & VMA_PROT_EXEC) != 0:
                    any_exec = 1
            cur = _vma_node_get_next(cur)
    if any_exec == 0:
        # No covering VMA grants exec — a real W^X / wild-jump fault.
        return 0
    pslot: uint64 = _vma_pte_slot_addr(pml4_phys, va_al)
    if pslot == 0:
        return 0
    pte: uint64 = cast[Ptr[uint64]](pslot)[0]
    if (pte & VMA_PT_FLAG_P) == 0:
        # Not present after all — leave it to demand/swap.
        return 0
    if (pte & PT_FLAG_COW) != 0:
        # A COW leaf that a covering VMA GRANTS EXEC (any_exec==1 above). An
        # instruction FETCH is a READ, so it need NOT un-share the page — only
        # a WRITE triggers the copy. Clear NX so the fetch resolves while
        # KEEPING the COW + RO bits intact: a later write still faults into the
        # COW resolver, which stamps the fresh private copy's NX from the VMA
        # prot. Without this, a cold stale-NX exec page that was COW-shared by
        # (v)fork NX-faults FOREVER — the pre-fix code bailed (return 0) the
        # instant a covering exec page happened to be COW. The repro: a daemon
        # (Xwayland) posix_spawn/vfork's a helper (xkbcomp); its own SIGCHLD
        # handler's DSO .text page — a boundary page ld.so's exec overlay left
        # NX — is now COW from the vfork share, so its FIRST invocation (RIP =
        # the correctly-delivered handler) NX-faults, recovery bailed on COW,
        # SIGSEGV, and the handler storm wedged the box. A COW leaf whose VMA
        # does NOT grant exec already returned 0 above as a real W^X violation.
        cow_exec_pte: uint64 = pte & ~PT_FLAG_NX
        cast[Ptr[uint64]](pslot)[0] = cow_exec_pte
        invlpg_one(va_al)
        return 1
    if (pte & PT_FLAG_NX) == 0:
        # Already executable — the fault was transient (another CPU
        # restamped it, or a TLB shootdown lag). Re-run succeeds.
        invlpg_one(va_al)
        return 1
    # Clear NX on the faulting leaf so the instruction fetch resolves. Keep
    # the RW bit exactly as the leaf already carries it (an exec overlay is
    # typically RO; we don't widen write access here).
    new_pte: uint64 = pte & ~PT_FLAG_NX
    cast[Ptr[uint64]](pslot)[0] = new_pte
    invlpg_one(va_al)
    return 1


# ---------------------------------------------------------------------
# vma_protect (mprotect)
# ---------------------------------------------------------------------

VMA_PROT_W: int32 = 0x2          # PROT_WRITE — mirror linux PROT_*


def vma_protect(slot: uint64, addr: uint64, len_in: uint64,
                prot: int32) -> int64:
    # Thread address-space serialization: hold the mm-group WRITE lock
    # across the WHOLE reserve->install->insert (or carve->release)
    # mutation so two threads of one CLONE_VM address space can never race
    # the shared window cursor / free-list / interval tree and hand out
    # OVERLAPPING window VAs into the shared PML4 (the Firefox eager
    # PTE=0 SIGSEGV). Recursive: inner tree/carve helpers re-acquire on the
    # same logical CPU. A process (no thread group) still takes its own
    # per-mm lock cheaply.
    vma_mm_write_lock(slot)
    _lr: int64 = _vma_protect_locked(slot, addr, len_in, prot)
    vma_mm_write_unlock(slot)
    return _lr


def _vma_protect_locked(slot: uint64, addr: uint64, len_in: uint64,
                prot: int32) -> int64:
    # §1: honest mprotect over an ARBITRARY range.
    #
    #   1. Re-walk the page table over [addr, addr+len) and update
    #      every present PTE's RW *and* NX bits to match PROT_WRITE /
    #      PROT_EXEC — the real, enforced effect (a store to a page
    #      mprotect'd PROT_READ now faults in do_page_fault; a jump into
    #      a page mprotect'd without PROT_EXEC faults the same way). This
    #      is what mprotect's callers (glibc relro, JITs toggling W^X)
    #      actually depend on.
    #   2. Update the `prot` metadata on every covered VMA, SPLITTING
    #      any VMA that the range only partially covers so the prot
    #      field is accurate per-slice. A VMA must be made refcount-
    #      managed before it is split (see _vma_split_at).
    #
    # Returns 0 on success, a negative errno on a bad argument / OOM.
    if len_in == 0:
        return cast[int64](-22)
    # §mseal: a sealed VMA's protections are frozen — reject -EPERM before
    # touching any PTE, exactly like Linux mprotect on an mseal'd range.
    if vma_range_is_sealed(slot, addr, len_in) != 0:
        return VMA_PERM
    length: uint64 = (len_in + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)
    addr_al: uint64 = addr & ~(VMA_PAGE_SIZE - 1)
    end_v: uint64 = addr_al + length

    want_write: int32 = 0
    if (prot & VMA_PROT_W) != 0:
        want_write = 1
    want_exec: int32 = 0
    if (prot & VMA_PROT_EXEC) != 0:
        want_exec = 1

    # Step 1 — PTE re-walk. This is the load-bearing enforcement; do it
    # first so the protection takes effect even if the metadata split
    # below OOMs partway.
    pml4: uint64 = task_pml4(cast[int32](slot))
    if vm_protect_range(pml4, addr_al, end_v, want_write, want_exec) < 0:
        printk1("vma: mprotect PTE walk OOM @ 0x%x\n", addr_al)
        return cast[int64](-12)

    # Step 2 — metadata. Split partially-covered boundary VMAs so the
    # prot field is accurate per-slice, then stamp prot on every fully-
    # covered node.
    cur: uint64 = task_vma_list_head(slot)
    done: int32 = 0
    while cur != 0 and done == 0:
        nxt: uint64 = _vma_node_get_next(cur)
        s: uint64 = _vma_node_start(cur)
        e: uint64 = _vma_node_end(cur)
        if s < end_v and addr_al < e:
            # Trim a straddling head: keep [s, addr_al) at the old prot.
            if s < addr_al:
                if _vma_make_refcounted(slot, cur) >= 0:
                    htail: uint64 = _vma_split_at(slot, cur, addr_al)
                    if htail != 0:
                        # Re-process the tail (the in-range part).
                        cur = htail
                        nxt = _vma_node_get_next(cur)
                        s = _vma_node_start(cur)
                        e = _vma_node_end(cur)
            # Trim a straddling tail: keep [end_v, e) at the old prot.
            if e > end_v and s < end_v:
                if _vma_make_refcounted(slot, cur) >= 0:
                    _vma_split_at(slot, cur, end_v)
                    e = _vma_node_end(cur)
            # `cur` is now within [addr_al, end_v): stamp the new prot.
            cast[Ptr[VmaNode]](cur)[0].prot = prot
        if s >= end_v:
            done = 1
        cur = nxt
    return 0


# ---------------------------------------------------------------------
# vma_mremap — Linux mremap(2): grow-in-place / move / shrink
# ---------------------------------------------------------------------
#
# Flags follow the Linux MREMAP_* bits (re-declared here so the kernel
# core does not depend on the linux_abi shim's constants):
VMA_MREMAP_MAYMOVE: uint64 = 1
VMA_MREMAP_FIXED:   uint64 = 2


def _vma_range_is_free(slot: uint64, lo: uint64, hi: uint64) -> int32:
    # 1 iff NO VMA in `slot` overlaps [lo, hi); 0 otherwise. Used by the
    # grow-in-place fast path and (Wave-3) the mmap gap search to confirm a
    # virtual range is unoccupied. O(log n) via the interval-tree overlap
    # query (subtree_max_end pruning) instead of the old O(n) list scan.
    if hi <= lo:
        return 1
    if _vma_tree_overlap(slot, lo, hi) != 0:
        return 0
    return 1


def _vma_grow_in_place(slot: uint64, node: uint64, old_end: uint64,
                       delta: uint64, prot: int32) -> int32:
    # Allocate `delta` bytes of fresh backing and OVERLAY it at
    # [old_end, old_end+delta) in the task's PML4 with the SAME prot as
    # the region (W^X-correct: new pages inherit _vma_rw_flag | _vma_nx_flag
    # of `prot`, not blanket-RWX). The covered range must already be
    # confirmed free. Grows `node`'s end on success. Returns 0 on success
    # or a negative errno (no partial state on failure).
    #
    # Only safe for a windowed (>= VMA_LARGE_BASE) region: there the new
    # virtual range is genuinely unbacked address space the kernel may
    # overlay onto fresh phys. The chunks are recorded so the tail frees
    # correctly on unmap.
    nnew: int32 = cast[int32]((delta + VMA_MAX_CHUNK - 1) / VMA_MAX_CHUNK)
    if nnew <= 0:
        return -22
    pml4: uint64 = task_pml4(cast[int32](slot))
    # Grow the node's chunk array to hold the existing chunks plus the
    # new ones. A node grown in place is always one we created via the
    # large-window path (it carries a chunks array); defensively bail if
    # it somehow does not.
    old_carr: uint64 = cast[Ptr[VmaNode]](node)[0].chunks
    old_nchunks: int32 = cast[Ptr[VmaNode]](node)[0].nchunks
    if old_carr == 0 or old_nchunks <= 0:
        return -22
    total: int32 = old_nchunks + nnew
    newcarr: uint64 = kmalloc(cast[uint64](total) * VMA_CHUNK_SIZE)
    if newcarr == 0:
        return -12
    memset(cast[Ptr[uint8]](newcarr), 0,
           cast[uint64](total) * VMA_CHUNK_SIZE)
    # Copy the existing chunk descriptors into the front of the new array.
    cpy: int32 = 0
    while cpy < old_nchunks:
        src: uint64 = old_carr + cast[uint64](cpy) * VMA_CHUNK_SIZE
        dst: uint64 = newcarr + cast[uint64](cpy) * VMA_CHUNK_SIZE
        cast[Ptr[VmaChunk]](dst)[0].phys  = cast[Ptr[VmaChunk]](src)[0].phys
        cast[Ptr[VmaChunk]](dst)[0].order = cast[Ptr[VmaChunk]](src)[0].order
        cast[Ptr[VmaChunk]](dst)[0].pad   = 0
        cpy = cpy + 1
    # Allocate + zero + overlay each new chunk.
    i: int32 = 0
    ok: int32 = 1
    while i < nnew and ok != 0:
        off: uint64 = cast[uint64](i) * VMA_MAX_CHUNK
        remain: uint64 = delta - off
        csize: uint64 = VMA_MAX_CHUNK
        if remain < csize:
            csize = remain
        corder: int32 = _order_for_chunk(csize)
        cphys: uint64 = alloc_pages(corder)
        if cphys == 0:
            ok = 0
        else:
            memset(cast[Ptr[uint8]](cphys), 0, csize)
            slotc: int32 = old_nchunks + i
            ce: uint64 = newcarr + cast[uint64](slotc) * VMA_CHUNK_SIZE
            cast[Ptr[VmaChunk]](ce)[0].phys  = cphys
            cast[Ptr[VmaChunk]](ce)[0].order = corder
            cast[Ptr[VmaChunk]](ce)[0].pad   = 0
            vlo: uint64 = old_end + off
            rc: int32 = elf_install_user_mapping(pml4, vlo, vlo + csize,
                                                 cphys,
                                                 _vma_nx_flag(prot)
                                                 | _vma_rw_flag(prot))
            if rc < 0:
                free_pages(cphys, corder)
                ok = 0
            else:
                i = i + 1
    if ok == 0:
        # Roll back ONLY the new chunks we grabbed (the front-copied
        # existing chunks still belong to the live node).
        j: int32 = 0
        while j < i:
            slotc2: int32 = old_nchunks + j
            ce2: uint64 = newcarr + cast[uint64](slotc2) * VMA_CHUNK_SIZE
            free_pages(cast[Ptr[VmaChunk]](ce2)[0].phys,
                       cast[Ptr[VmaChunk]](ce2)[0].order)
            j = j + 1
        kfree(newcarr)
        return -12
    load_cr3(pml4)
    # Commit: swap in the grown chunk array and extend the node.
    kfree(old_carr)
    cast[Ptr[VmaNode]](node)[0].chunks  = newcarr
    cast[Ptr[VmaNode]](node)[0].nchunks = total
    # Extend the node's end, refreshing the interval-tree augmentation
    # (start key unchanged, only subtree_max_end up the path moves).
    _vma_tree_update_end(slot, node, old_end + delta)
    return 0


def vma_mremap(slot: uint64, old_addr: uint64, old_len_in: uint64,
               new_len_in: uint64, flags: uint64,
               new_addr: uint64) -> int64:
    # Thread address-space serialization: hold the mm-group WRITE lock
    # across the WHOLE reserve->install->insert (or carve->release)
    # mutation so two threads of one CLONE_VM address space can never race
    # the shared window cursor / free-list / interval tree and hand out
    # OVERLAPPING window VAs into the shared PML4 (the Firefox eager
    # PTE=0 SIGSEGV). Recursive: inner tree/carve helpers re-acquire on the
    # same logical CPU. A process (no thread group) still takes its own
    # per-mm lock cheaply.
    vma_mm_write_lock(slot)
    _lr: int64 = _vma_mremap_locked(slot, old_addr, old_len_in, new_len_in, flags, new_addr)
    vma_mm_write_unlock(slot)
    return _lr


def _vma_mremap_locked(slot: uint64, old_addr: uint64, old_len_in: uint64,
               new_len_in: uint64, flags: uint64,
               new_addr: uint64) -> int64:
    # Linux mremap(2). Returns the resolved base address on success
    # (cast to int64 so the ABI shim can return it directly), or a
    # negative Linux errno.
    if old_len_in == 0 or new_len_in == 0:
        return cast[int64](-22)
    if (old_addr & (VMA_PAGE_SIZE - 1)) != 0:
        return cast[int64](-22)
    # §mseal: mremap moves/resizes a mapping, which a seal forbids. Reject
    # -EPERM if the source range is sealed.
    if vma_range_is_sealed(slot, old_addr, old_len_in) != 0:
        return VMA_PERM
    old_len: uint64 = (old_len_in + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)
    new_len: uint64 = (new_len_in + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)

    node: uint64 = vma_find(slot, old_addr)
    if node == 0:
        return cast[int64](-22)
    # mremap only operates on a mapping that starts exactly at old_addr
    # and whose recorded length matches old_len (Linux requires the old
    # range to lie within a single VMA; the common malloc/realloc caller
    # passes the exact base+len it got from mmap).
    nstart: uint64 = _vma_node_start(node)
    nend:   uint64 = _vma_node_end(node)
    if nstart != old_addr:
        return cast[int64](-22)
    if nend - nstart < old_len:
        return cast[int64](-22)
    prot: int32 = cast[Ptr[VmaNode]](node)[0].prot

    is_fixed: int32 = 0
    if (flags & VMA_MREMAP_FIXED) != 0:
        is_fixed = 1
    may_move: int32 = 0
    if (flags & VMA_MREMAP_MAYMOVE) != 0:
        may_move = 1

    # MREMAP_FIXED: deferred (see _u_mremap shim comment). Linux requires
    # MAYMOVE alongside FIXED; without it the call is invalid regardless.
    if is_fixed != 0:
        return cast[int64](-22)

    # ---- Shrink in place: new_len < old_len. Unmap the tail. ----
    if new_len < old_len:
        tail_lo: uint64 = old_addr + new_len
        tail_hi: uint64 = old_addr + old_len
        _vma_carve_range(slot, tail_lo, tail_hi)
        return cast[int64](old_addr)

    # ---- No-op: identical length. ----
    if new_len == old_len:
        return cast[int64](old_addr)

    # ---- Grow. new_len > old_len. ----
    delta: uint64 = new_len - old_len
    grow_lo: uint64 = old_addr + old_len
    grow_hi: uint64 = old_addr + new_len
    # Grow-in-place is only attempted for a windowed region (its trailing
    # virtual space is genuinely unbacked) whose exact-length single node
    # we can extend, and only when the trailing range is free.
    can_grow_here: int32 = 0
    if nstart >= VMA_LARGE_BASE and nend == old_addr + old_len:
        if grow_hi <= VMA_LARGE_LIMIT \
                and _vma_range_is_free(slot, grow_lo, grow_hi) != 0:
            if cast[Ptr[VmaNode]](node)[0].chunks != 0 \
                    and cast[Ptr[VmaNode]](node)[0].nchunks > 0:
                can_grow_here = 1
    if can_grow_here != 0:
        grc: int32 = _vma_grow_in_place(slot, node, grow_lo, delta, prot)
        if grc == 0:
            return cast[int64](old_addr)
        # A grow-in-place OOM falls through to the move path below if
        # MAYMOVE is set, else reports the failure.

    # Can't grow in place. Without MAYMOVE this MUST fail (Linux semantics:
    # never silently move).
    if may_move == 0:
        return cast[int64](-12)              # -ENOMEM

    # §shared-pagecache: a MAP_SHARED writable FILE-backed VMA must NOT be
    # converted to an anonymous private copy on a move — that would DROP
    # the file backing (later writes/reads diverge from the file and from
    # other mappers). apt grows its mmap'd cache via mremap, so this path
    # is hit. Instead, create a FRESH file-shared VMA of new_len at a new
    # range carrying the SAME backing identity (marker / backing / size /
    # file_offset), then drop the old range. The new range's pages fault
    # in through the shared page cache — mapping the SAME physical frames
    # the old range mapped (same (marker, backing, offset) keys for the
    # overlapping prefix), so coherence and the file backing are both
    # preserved with no copy needed; the grown tail faults fresh from the
    # backing file. Writeback on the OLD range's teardown flushes any
    # dirty frames first (cow refcount keeps shared frames alive across
    # the unmap until the new range re-references them on fault).
    if cast[Ptr[VmaNode]](node)[0].is_file_shared != 0:
        fmarker: int32  = cast[Ptr[VmaNode]](node)[0].file_marker
        fback:   uint64 = cast[Ptr[VmaNode]](node)[0].backing
        fsize:   uint64 = cast[Ptr[VmaNode]](node)[0].file_size
        foff:    uint64 = cast[Ptr[VmaNode]](node)[0].file_offset
        fflags:  int32  = cast[Ptr[VmaNode]](node)[0].flags
        # §shared-mmap coherence: a GROW means the program (apt's
        # DynamicMMap::Grow) ftruncated the backing file LARGER and is
        # remapping to the bigger size. The new mapping covers file bytes
        # [foff, foff+new_len), so its file_size snapshot must cover that
        # extent — otherwise the write-fault size-extend (capped at
        # file_size) caps at the STALE smaller size, a later read() of the
        # grown cache returns short, and apt follows a stored offset past
        # EOF into an unmapped page (SIGSEGV). Raise the snapshot to the
        # new mapped extent.
        new_fsize: uint64 = fsize
        if foff + new_len > new_fsize:
            new_fsize = foff + new_len
        nbf: int64 = vma_alloc_file_shared(slot, 0, new_len, prot, fflags,
                                           fmarker, fback, new_fsize, foff)
        if nbf < 0:
            return nbf
        # Drop the old mapping: writeback then refcount-drop its frames
        # (the shared frames survive in the cache for the new range to
        # re-reference on fault).
        _vma_carve_range(slot, old_addr, old_addr + old_len)
        return nbf

    # ---- Move: allocate a fresh anonymous range of new_len, copy the
    # old contents (min(old_len,new_len) = old_len bytes), map with the
    # old region's prot, then drop the old range. ----
    move_flags: int32 = VMA_MAP_ANONYMOUS | VMA_MAP_PRIVATE
    nb: int64 = vma_alloc(slot, 0, new_len, prot, move_flags, -1, 0)
    if nb < 0:
        return nb
    newbase: uint64 = cast[uint64](nb)
    # The running task's CR3 is this task's PML4, so both old and new
    # window vaddrs are directly dereferenceable here. Copy the live data.
    memcpy(cast[Ptr[uint8]](newbase), cast[Ptr[uint8]](old_addr), old_len)
    # Drop the old mapping (frees its backing pages).
    _vma_carve_range(slot, old_addr, old_addr + old_len)
    return cast[int64](newbase)


# ---------------------------------------------------------------------
# §1 — vma_madvise (MADV_DONTNEED actually drops pages)
# ---------------------------------------------------------------------

MADV_DONTNEED: int32 = 4
MADV_FREE:     int32 = 8
MADV_REMOVE:   int32 = 9


def vma_madvise(slot: uint64, addr: uint64, len_in: uint64,
                advice: int32) -> int64:
    # Thread address-space serialization: hold the mm-group WRITE lock
    # across the WHOLE reserve->install->insert (or carve->release)
    # mutation so two threads of one CLONE_VM address space can never race
    # the shared window cursor / free-list / interval tree and hand out
    # OVERLAPPING window VAs into the shared PML4 (the Firefox eager
    # PTE=0 SIGSEGV). Recursive: inner tree/carve helpers re-acquire on the
    # same logical CPU. A process (no thread group) still takes its own
    # per-mm lock cheaply.
    vma_mm_write_lock(slot)
    _lr: int64 = _vma_madvise_locked(slot, addr, len_in, advice)
    vma_mm_write_unlock(slot)
    return _lr


def _vma_madvise_locked(slot: uint64, addr: uint64, len_in: uint64,
                advice: int32) -> int64:
    # §1: madvise. Most advice values are hints with no backing
    # readahead / swap state for Hamnix to act on — accepted as a
    # no-op (return 0, never -EINVAL, so glibc's malloc-trim path
    # stays quiet). MADV_DONTNEED / MADV_FREE / MADV_REMOVE, however,
    # have an OBSERVABLE contract on anonymous memory: after the call
    # the range reads back as zero. Hamnix has no demand paging, so we
    # honour that by zeroing the physical pages in place — the next
    # read genuinely sees zeros, which is exactly what a caller doing
    # "madvise(buf, n, MADV_DONTNEED)" to cheaply reset a scratch
    # buffer expects.
    if len_in == 0:
        return 0
    if advice != MADV_DONTNEED and advice != MADV_FREE \
       and advice != MADV_REMOVE:
        # A pure hint — nothing to do, but never error.
        return 0
    # §mseal: the destructive advices (DONTNEED / FREE / REMOVE) discard
    # page contents, so Linux mseal rejects them -EPERM over a sealed
    # range. Pure hints fell through above and are still allowed.
    if vma_range_is_sealed(slot, addr, len_in) != 0:
        return VMA_PERM
    length: uint64 = (len_in + VMA_PAGE_SIZE - 1) & ~(VMA_PAGE_SIZE - 1)
    addr_al: uint64 = addr & ~(VMA_PAGE_SIZE - 1)
    end_v: uint64 = addr_al + length
    # Only zero memory that actually belongs to one of this task's
    # VMAs — a DONTNEED on an unmapped range is a silent no-op (Linux
    # returns -ENOMEM there, but a no-op is friendlier and no current
    # caller checks). Walk page-by-page so a range spanning several
    # VMAs (and gaps) is handled correctly.
    va: uint64 = addr_al
    while va < end_v:
        node: uint64 = vma_find(slot, va)
        if node != 0:
            # The VMA's pages are identity-mapped (single / multi-chunk)
            # or reached via the task's PML4; zeroing through the
            # virtual address is correct for the running task (madvise
            # only ever targets the CURRENT task). Skip a non-writable
            # VMA: a memset there would take a genuine protection
            # fault. A COW page is fine — the memset's write faults
            # into the COW resolver, which copies then the zero lands
            # privately, matching the DONTNEED contract.
            np: int32 = cast[Ptr[VmaNode]](node)[0].prot
            if (np & VMA_PROT_WRITE) != 0:
                # SMAP: zeroing THROUGH the user VA (US=1) at CPL=0 needs the
                # AC bracket, exactly like the anon MAP_FIXED overlay above —
                # otherwise an unbracketed write to an already-RW user page
                # #PF-livelocks under CR4.SMAP.
                _ua_stac()
                memset(cast[Ptr[uint8]](va), 0, VMA_PAGE_SIZE)
                _ua_clac()
        va = va + VMA_PAGE_SIZE
    return 0


# ---------------------------------------------------------------------
# vma_clear — wipe the current task's address space on execve
# ---------------------------------------------------------------------

def vma_clear(slot: uint64):
    # execve / task-teardown path: free EVERY VMA the task holds.
    # A COW-shared node frees through the refcount, so _vma_node_free
    # is handed the task's PML4 to walk its page table — a still-shared
    # page (mapped COW in a forked relative) is left for that holder
    # instead of being freed out from under it.
    #
    # Thread address-space sharing guard: a NON-owner thread (mm-group link
    # set) shares the mm with a still-live owner. Its VMAs live in the
    # OWNER's shared list, torn down when the OWNER (or the last surviving
    # heir) reaps. Clearing here would translate to the owner's list and
    # free the WHOLE live address space out from under the running process.
    # do_execve resets the group to self BEFORE calling vma_clear, so a
    # genuine address-space replacement is never blocked by this guard.
    if vma_mm_group[slot] != 0:
        return
    pml4: uint64 = task_pml4(cast[int32](slot))
    # Detach the whole tree + list FIRST under the mm write lock, BEFORE
    # freeing any node, so a concurrent lockless fault reader (another live
    # thread of this shared mm) can never reach a node that is about to be
    # kfree'd via the (now-empty) tree root — a use-after-free that would
    # surface as a #DF in _vt_right.
    vma_mm_write_lock(slot)
    cur: uint64 = task_vma_list_head(slot)
    set_task_vma_list_head(slot, 0)
    # Wave-3: the whole interval tree is gone with the list.
    _vma_set_tree_root(slot, 0)
    _vma_mm_seq_bump(slot)
    vma_mm_write_unlock(slot)
    while cur != 0:
        nxt: uint64 = _vma_node_get_next(cur)
        _vma_node_free(slot, cur, pml4)
        cur = nxt
    # execve/teardown: the cached windowed free-extents are stale (their VAs
    # were just released with the page table); forget them so a re-exec'd
    # task starts with a clean free-list.
    _vma_win_free_reset(slot)


def vma_adopt(from_slot: uint64, to_slot: uint64):
    # Shared-address-space reap support (task_reap's CLONE_VM / rfork-RFMEM
    # thread-group guard). With mm-group ownership (see _vma_owner) the
    # WHOLE thread group already shares ONE VMA list/tree/cursor/free-list
    # keyed by the OWNER slot, so:
    #
    #   * `from_slot` is a NON-owner thread being reaped -> its RAW slot
    #     owns nothing (all its mmaps went to the shared owner's state via
    #     the _vma_owner funnels). Every raw array below is empty -> this is
    #     a pure no-op. The shared mm lives on in the owner slot.
    #
    #   * `from_slot` IS the mm owner dying while a sibling `to_slot` still
    #     runs -> MIGRATE the raw owner-slot state (list head, interval
    #     tree, window cursor, window free-list) to `to_slot`, then REPOINT
    #     every group member (including to_slot) at the new owner so their
    #     _vma_owner funnels follow. Nodes describe ranges in the SHARED
    #     PML4 both slots point at — pure bookkeeping, no PT/frame writes.
    #
    # Uses the RAW list-head accessors: it must move state between LITERAL
    # slots, not follow the owner indirection it is re-homing.
    # A NON-owner thread (group link set) owns no raw state — every mmap it
    # made went to the shared owner slot. Nothing to migrate; the real owner
    # lives on (or migrates when IT reaps). Pure no-op.
    if vma_mm_group[from_slot] != 0:
        return
    fh: uint64 = task_vma_list_head_raw(from_slot)
    fcur: uint64 = vma_large_next_arr[from_slot]
    # Lock the FROM (current owner) mm across the migration so a concurrent
    # fault reader on a sibling CPU retries via the seqcount rather than
    # walking a half-moved tree.
    vma_mm_write_lock(from_slot)
    th: uint64 = task_vma_list_head_raw(to_slot)
    if fh != 0 and th != 0:
        tail: uint64 = fh
        while _vma_node_get_next(tail) != 0:
            tail = _vma_node_get_next(tail)
        _vma_node_set_next(tail, th)
    combined: uint64 = fh
    if combined == 0:
        combined = th
    # Move the raw list head onto to_slot; empty from_slot.
    set_task_vma_list_head_raw(to_slot, combined)
    set_task_vma_list_head_raw(from_slot, 0)
    # Move the window cursor (take the higher of the two so no VA is ever
    # re-handed) and the window free-list from -> to.
    if vma_large_next_arr[to_slot] < fcur:
        vma_large_next_arr[to_slot] = fcur
    vma_large_next_arr[from_slot] = 0
    fbi: uint64 = from_slot * VMA_WIN_FREE_PER_TASK
    tbi: uint64 = to_slot   * VMA_WIN_FREE_PER_TASK
    fk: uint64 = 0
    while fk < VMA_WIN_FREE_PER_TASK:
        fb: uint64 = g_vma_win_free_base[fbi + fk]
        if fb != 0:
            # first-fit into an empty to_slot slot
            tk: uint64 = 0
            while tk < VMA_WIN_FREE_PER_TASK:
                if g_vma_win_free_base[tbi + tk] == 0:
                    g_vma_win_free_base[tbi + tk] = fb
                    g_vma_win_free_size[tbi + tk] = g_vma_win_free_size[fbi + fk]
                    tk = VMA_WIN_FREE_PER_TASK
                else:
                    tk = tk + 1
            g_vma_win_free_base[fbi + fk] = 0
            g_vma_win_free_size[fbi + fk] = 0
        fk = fk + 1
    # Rebuild to_slot's interval tree over the combined RAW list; empty
    # from_slot's. Direct array access (not the _vma_owner funnel) — we are
    # in the middle of moving ownership.
    vma_tree_root[to_slot]   = 0
    vma_tree_root[from_slot] = 0
    rb: uint64 = combined
    while rb != 0:
        nxt_rb: uint64 = _vma_node_get_next(rb)
        cast[Ptr[VmaNode]](rb)[0].left = 0
        cast[Ptr[VmaNode]](rb)[0].right = 0
        cast[Ptr[VmaNode]](rb)[0].height = 0
        vma_tree_root[to_slot] = _vt_insert_rec(vma_tree_root[to_slot], rb)
        rb = nxt_rb
    vma_mm_seq[to_slot]   = vma_mm_seq[to_slot] + 1
    vma_mm_seq[from_slot] = vma_mm_seq[from_slot] + 1
    # REPOINT the thread group: every member whose owner resolved to
    # from_slot (including from_slot itself and to_slot) now owns via
    # to_slot. to_slot becomes a self-owner; from_slot is being reaped.
    gk: uint64 = 0
    while gk < 512:
        if _vma_owner(gk) == from_slot:
            vma_mm_group[gk] = to_slot + 1
        gk = gk + 1
    vma_mm_group[to_slot]   = 0
    vma_mm_group[from_slot] = 0
    # Release the lock we took on the OLD owner slot. After the repoint,
    # vma_mm_write_unlock(from_slot) would resolve to to_slot — so unlock
    # the raw from_slot lock state directly to avoid unlocking the wrong mm.
    vma_mm_depth[from_slot] = 0
    vma_mm_owner[from_slot] = 0
    spinlock_unlock(&vma_mm_lock[from_slot])


def vma_free_reserved_range(slot: uint64, vlo: uint64, vhi: uint64):
    # Reclaim a fixed RESERVED span [vlo, vhi) of `slot`'s address space
    # — the per-task brk arena (linux_abi/u_syscalls.ad reserves
    # LINUX_BRK_RESERVE == 32 MiB up front via alloc_pages, eagerly
    # identity-mapped). task_reap frees the ELF image / interp / user
    # stack but, before this, NEVER freed the brk reserve, so every
    # glibc spawn permanently leaked its whole 32 MiB heap window out of
    # the page pool — the dominant per-spawn drain that capped how many
    # dynamic (glibc) binaries could run in one boot. (The leak masked
    # the smaller mmap/DSO drain; both starve the SAME pool.)
    #
    # OWNER-SAFE for COW fork: the brk reserve is COW-shared on fork
    # (arch/x86/kernel/syscall.ad do_clone -> vm_cow_share_all over
    # [brk_base, brk_max)), and BOTH parent and child carry the SAME
    # brk_base — so a naive free_pages(brk_base) would double-free the
    # live relative's heap. Instead we walk THIS task's page table over
    # [vlo, vhi) and route every present frame through cow_drop_page,
    # exactly like _vma_free_cow_range does for split/COW VMAs: a frame
    # still mapped by a live forked relative (refcount > 1) only drops
    # its refcount; the frame returns to the buddy allocator solely when
    # its last holder drops it. A brk reserve that was never forked has
    # untracked frames (refcount 0); cow_drop_page returns 1 for those,
    # so they free normally. Either way no page held by a live relative
    # is freed out from under it.
    if vhi <= vlo:
        return
    pml4: uint64 = task_pml4(cast[int32](slot))
    _vma_free_cow_range(pml4, vlo, vhi)


def vma_release_brk_overlap(slot: uint64, vlo: uint64, vhi: uint64):
    # #439 ownership transfer for MAP_FIXED inside the brk reservation.
    #
    # The brk arena is a RESERVED span tracked in task fields, not a
    # VmaNode — so when an honest MAP_FIXED lands inside it, vma_alloc's
    # carve pass finds nothing to release and the fresh overlay would
    # simply overwrite the reservation's identity PTEs. That left the
    # range with TWO owners: the new VMA node (frees its chunk frames at
    # teardown) and the reservation sweep (vma_free_reserved_range walks
    # the same vaddrs by PTE at reap/execve). The observed #439 double
    # free was exactly this — busybox MAP_FIXEDs one page at brk_base;
    # at reap the multi-chunk arm freed the overlay frame, then the brk
    # sweep walked the stale PTE and freed it again, corrupting the
    # buddy free list into a self-cycle (the IRQs-off wedge).
    #
    # Linux semantics: MAP_FIXED over the heap UNMAPS the covered heap
    # pages. The mmap shim calls this with the intersection of the fixed
    # request and [brk_base, brk_max) BEFORE vma_alloc: every present
    # PTE frame in the overlap that is NOT owned by a VmaNode (node-
    # owned frames are released by vma_alloc's carve, through the node's
    # own teardown arm) is dropped through the COW refcount — a frame a
    # forked relative still holds only loses one reference — and its PTE
    # is zapped. The vaddr range then has exactly one owner at every
    # instant, and the replaced arena frames are freed instead of
    # leaking with zero owners.
    if vhi <= vlo:
        return
    pml4: uint64 = task_pml4(cast[int32](slot))
    if pml4 == 0:
        return
    boot: uint64 = cow_boot_cr3() & VMA_PT_ADDR_MASK
    if (pml4 & VMA_PT_ADDR_MASK) == boot:
        return
    vaddr: uint64 = vlo & ~(VMA_PAGE_SIZE - 1)
    while vaddr < vhi:
        # Nodes are page-aligned, so a page is either fully inside a
        # node or fully outside; any enclosing node owns this page.
        if _vma_find_enclosing(slot, vaddr, vaddr + VMA_PAGE_SIZE) == 0:
            pslot: uint64 = _vma_pte_slot_addr(pml4, vaddr)
            if pslot != 0:
                # Boot-table safety, same rule as _vma_zap_priv_range:
                # never free/zap through a slot shared with the boot
                # identity hierarchy.
                bslot: uint64 = 0
                if boot != 0:
                    bslot = _vma_pte_slot_addr(boot, vaddr)
                if pslot != bslot:
                    pte: uint64 = cast[Ptr[uint64]](pslot)[0]
                    if (pte & VMA_PT_FLAG_P) != 0:
                        phys: uint64 = pte & VMA_PT_ADDR_MASK
                        if phys != 0:
                            if cow_drop_page(phys) != 0:
                                free_page(phys)
                        cast[Ptr[uint64]](pslot)[0] = 0
                        invlpg_one(vaddr)
        vaddr = vaddr + VMA_PAGE_SIZE


# ---------------------------------------------------------------------
# fork(): COW-share a parent's VMA list into a child
# ---------------------------------------------------------------------
#
# vma_fork_copy() gives a forked child its own VMA list mirroring the
# parent's, with every mmap page COPY-ON-WRITE shared instead of eager-
# copied. This is the mmap-VMA counterpart of fs/elf.ad::vm_cow_share_all
# (which COW-shares the ELF image / brk / stack); together they make the
# WHOLE address space copy-on-write on fork.
#
# For every parent VMA that OWNS backing pages (single-chunk: backing
# != 0; multi-chunk: nchunks > 0) it:
#
#   1. links a child VmaNode mirroring the parent's metadata,
#   2. calls vm_cow_share_range over the VMA's [start, end): every
#      present user page is cracked to 4 KiB granularity, marked
#      READ-ONLY + COW (PTE bit 9) in BOTH the parent's and the child's
#      PML4, both pointing at the SAME physical page, and the page's
#      per-PFN refcount is bumped (mm/cow.ad). The first write by either
#      side faults into the productive #PF handler, which copies just
#      that one 4 KiB page.
#   3. marks BOTH the parent's VMA node and the child's node is_cow,
#      because each now holds COW references — their pages must be
#      freed through cow_drop_page (see _vma_node_free).
#
# A COW-shared child node does NOT own a private backing run / chunk
# array: it shares the parent's physical pages until a write fault
# resolves them. backing / chunks / order / nchunks are all cleared on
# the child node; _vma_node_free's COW path frees purely by walking the
# page table, so those fields are vestigial for a COW node.
#
# Alias VMAs (backing == 0, nchunks == 0 — a MAP_FIXED slice inside an
# enclosing region) are copied as METADATA ONLY: their pages belong to
# the enclosing owner node, which COW-shares the whole range including
# the alias slice. COW-sharing an alias range too would bump the
# refcount of those pages a SECOND time and leak them, so alias nodes
# are deliberately skipped by the share pass.
#
# Single-chunk and multi-chunk VMAs take the SAME path here — both are
# just a contiguous virtual range that is fully mapped in the parent's
# (currently live) PML4, which is exactly what vm_cow_share_range walks.
#
# Returns 0 on success, -1 on OOM (vm_cow_share_range failed to crack a
# table — the caller aborts the fork).


def vma_fork_copy(child_slot: uint64, parent_slot: uint64,
                  child_pml4: uint64) -> int32:
    # Boot-CR3 guard (mirrors fs/elf.ad::vm_cow_share_all). This walks
    # and cracks the page tables of BOTH the parent and the freshly
    # cloned child PML4 (through vm_share_range / vm_cow_share_range ->
    # _cow_resolve_pte_slot), dereferencing every level plus newly
    # alloc_page()'d tables as raw physical addresses. Under UEFI with
    # several hundred MiB of RAM those pages land high and the LIVE
    # (parent, cracked) CR3 may have dropped the identity entry for that
    # chunk, faulting the walk. Run it under the pristine boot CR3 which
    # maps all of low RAM identity, then restore the caller's CR3. The
    # inner range helpers end with load_cr3(parent_pml4); we restore the
    # original caller CR3 afterwards so this is correct regardless.
    _saved_cr3: uint64 = read_cr3()
    _boot_cr3: uint64 = cow_boot_cr3()
    _irq_flags: uint64 = 0
    if _boot_cr3 != 0:
        _irq_flags = local_irq_save()
        load_cr3(_boot_cr3)
    _rc: int32 = _vma_fork_copy_locked(child_slot, parent_slot, child_pml4)
    if _boot_cr3 != 0:
        load_cr3(_saved_cr3)
        local_irq_restore(_irq_flags)
    return _rc


def _vma_fork_copy_locked(child_slot: uint64, parent_slot: uint64,
                  child_pml4: uint64) -> int32:
    # Inherit the parent's windowed-mmap cursor so a fork-WITHOUT-exec child
    # (which keeps the parent's COW address space + every inherited windowed
    # VMA) never hands out a window VA that overlaps an inherited mapping.
    # A child that execs immediately resets this via vma_set_mmap_base; this
    # copy only matters for the fork-and-keep-running case. (When the cursor
    # was a single global this inheritance was implicit.)
    vma_large_next_arr[child_slot] = vma_large_next_arr[parent_slot]
    parent_pml4: uint64 = task_pml4(cast[int32](parent_slot))
    touched_parent: int32 = 0
    cur: uint64 = task_vma_list_head(parent_slot)
    while cur != 0:
        p_start:  uint64 = cast[Ptr[VmaNode]](cur)[0].start
        p_end:    uint64 = cast[Ptr[VmaNode]](cur)[0].end
        p_prot:   int32  = cast[Ptr[VmaNode]](cur)[0].prot
        p_flags:  int32  = cast[Ptr[VmaNode]](cur)[0].flags
        p_fd:     int32  = cast[Ptr[VmaNode]](cur)[0].file_fd
        p_off:    uint64 = cast[Ptr[VmaNode]](cur)[0].file_offset
        p_back:   uint64 = cast[Ptr[VmaNode]](cur)[0].backing
        p_nchunks: int32 = cast[Ptr[VmaNode]](cur)[0].nchunks
        p_is_cow:    int32 = cast[Ptr[VmaNode]](cur)[0].is_cow
        p_is_shared: int32 = cast[Ptr[VmaNode]](cur)[0].is_shared
        p_is_pinned: int32 = cast[Ptr[VmaNode]](cur)[0].is_pinned
        p_is_file: int32 = cast[Ptr[VmaNode]](cur)[0].is_file
        node: uint64 = _vma_node_new()
        if node == 0:
            return -1

        # §file-mmap: a FILE-backed demand VMA (MAP_PRIVATE) forks like
        # an anonymous demand VMA — the child gets a FRESH empty is_file
        # copy carrying the same backing snapshot, and each process
        # faults its own private file pages independently. The parent's
        # already-faulted pages are NOT shared (they are private copies
        # of the file, and re-reading the file gives the child the same
        # bytes), so this stays a pure metadata copy regardless of
        # `backing` being non-zero (it holds the backing IDENTITY, not a
        # buddy run). Handle it up front so the owns_pages heuristic
        # below never mis-routes it into the COW/share page-table walk.
        if p_is_file != 0:
            _vma_node_set(node, p_start, p_end, p_prot, p_flags,
                          p_fd, p_off, p_back, 0)
            cast[Ptr[VmaNode]](node)[0].is_demand   = 1
            cast[Ptr[VmaNode]](node)[0].is_file     = 1
            # §shared-mmap: a MAP_SHARED writable file VMA forks as a fresh
            # file-shared copy carrying the same backing snapshot. Each
            # process faults its own resident pages and writes them back to
            # the SAME backing file (the file is the shared medium), so the
            # mapping stays coherent through the file. Carry the flag so the
            # child also maps pages writable and flushes on msync/unmap.
            cast[Ptr[VmaNode]](node)[0].is_file_shared = \
                cast[Ptr[VmaNode]](cur)[0].is_file_shared
            cast[Ptr[VmaNode]](node)[0].file_marker = \
                cast[Ptr[VmaNode]](cur)[0].file_marker
            cast[Ptr[VmaNode]](node)[0].file_size   = \
                cast[Ptr[VmaNode]](cur)[0].file_size
            _vma_insert_sorted(child_slot, node)
            cur = cast[Ptr[VmaNode]](cur)[0].next
            continue

        # Does this VMA hold (a share of) physical pages? A fresh owner
        # has backing / chunks; but a node that was ALREADY refcount-
        # managed by a prior fork or a VMA split (is_cow / is_shared /
        # is_pinned) has backing == 0 yet STILL maps pages reachable
        # through the page table — a grandchild fork must re-share
        # those, not metadata-alias them (which would hand the
        # grandchild writable pages with no COW protection). Only a
        # genuine alias node — never refcount-managed, no backing —
        # is a pure metadata copy.
        owns_pages: int32 = 0
        if p_nchunks > 0:
            owns_pages = 1
        elif p_back != 0:
            owns_pages = 1
        elif p_is_cow != 0 or p_is_shared != 0 or p_is_pinned != 0:
            owns_pages = 1

        if owns_pages != 0:
            is_shared: int32 = 0
            if (p_flags & VMA_MAP_SHARED) != 0:
                is_shared = 1
            if is_shared != 0:
                # §1 / MAP_SHARED — owner VMA is genuinely SHARED. The
                # child maps the parent's SAME physical frames writable
                # at the same vaddr (no COW marking, no copy-on-write
                # split): a write by either process is visible to the
                # other. Both nodes are flagged is_shared so
                # _vma_node_free routes frees through cow_drop_page —
                # the frame is released only when the last mapper
                # unmaps it.
                _vma_node_set(node, p_start, p_end, p_prot, p_flags,
                              p_fd, p_off, 0, 0)
                cast[Ptr[VmaNode]](node)[0].is_shared = 1
                if vm_share_range(parent_pml4, child_pml4,
                                  p_start, p_end) < 0:
                    printk1("vma_fork: share OOM for VMA @ 0x%x\n",
                            p_start)
                    kfree(node)
                    return -1
                # The parent's frames are now multi-mapped; its node
                # must also free through the refcount from here on.
                cast[Ptr[VmaNode]](cur)[0].is_shared = 1
                touched_parent = 1
                _vma_insert_sorted(child_slot, node)
            else:
                # Owner VMA — COW-share every page across
                # [p_start, p_end) between parent and child. The child
                # node mirrors the parent's metadata but owns NO
                # private backing run: it shares the parent's physical
                # pages COW. Both nodes are flagged is_cow so
                # _vma_node_free routes their frees through
                # cow_drop_page.
                _vma_node_set(node, p_start, p_end, p_prot, p_flags,
                              p_fd, p_off, 0, 0)
                cast[Ptr[VmaNode]](node)[0].is_cow = 1
                if vm_cow_share_range(parent_pml4, child_pml4,
                                      p_start, p_end) < 0:
                    printk1("vma_fork: COW share OOM for VMA @ 0x%x\n",
                            p_start)
                    kfree(node)
                    return -1
                # The parent's pages are now COW-shared too — its node
                # must also free through the refcount from here on.
                cast[Ptr[VmaNode]](cur)[0].is_cow = 1
                _vma_insert_sorted(child_slot, node)
        else:
            # Alias VMA (MAP_FIXED slice in an enclosing region) or a
            # demand VMA: pure metadata copy of the reservation. The
            # child gets a fresh is_demand copy so it can fault its own
            # not-yet-populated pages independently.
            #
            # DEMAND-BSS correctness (2026-06-23): a demand VMA may ALSO
            # have pages the PARENT already faulted in (e.g. BSS the
            # parent wrote before fork). Those are present anon PTEs in
            # the parent but owns_pages==0 (a demand node records no
            # backing/chunks — vma_demand_fault tracks pages via rmap).
            # Without sharing them the child would wrongly read zeros for
            # BSS the parent populated pre-fork. So COW-share every
            # PRESENT page in [p_start, p_end): vm_cow_share_range marks
            # the resident pages RO+COW in BOTH PML4s and SKIPS the
            # not-present remainder (the child re-faults those zero pages
            # through its own demand VMA). Flag both nodes is_cow so the
            # shared frames free through the refcount.
            cast[Ptr[VmaNode]](node)[0].is_demand = \
                cast[Ptr[VmaNode]](cur)[0].is_demand
            p_is_demand: int32 = cast[Ptr[VmaNode]](cur)[0].is_demand
            if p_is_demand != 0:
                _vma_node_set(node, p_start, p_end, p_prot, p_flags,
                              p_fd, p_off, 0, 0)
                cast[Ptr[VmaNode]](node)[0].is_demand = 1
                if vm_cow_share_range(parent_pml4, child_pml4,
                                      p_start, p_end) < 0:
                    printk1("vma_fork: demand COW share OOM @ 0x%x\n",
                            p_start)
                    kfree(node)
                    return -1
                # Any frames the parent had resident are now COW-shared;
                # both nodes must free through the refcount from here on.
                cast[Ptr[VmaNode]](node)[0].is_cow = 1
                cast[Ptr[VmaNode]](cur)[0].is_cow = 1
                _vma_insert_sorted(child_slot, node)
            else:
                _vma_node_set(node, p_start, p_end, p_prot, p_flags,
                              p_fd, p_off, 0, 0)
                _vma_insert_sorted(child_slot, node)
        cur = cast[Ptr[VmaNode]](cur)[0].next
    # §1: vm_share_range may have CRACKED parent huge-page identity
    # entries down to 4 KiB PTs while adding the child's mappings. The
    # cracked range maps the SAME frames at the SAME permissions, so it
    # is correct as-is — but a stale parent TLB entry from the old huge
    # page could linger. Reload the parent's CR3 once (drops every
    # non-global TLB entry) so the parent's subsequent accesses to a
    # shared region always go through the fresh 4 KiB PTEs. The COW
    # path already invlpg's per page; only the shared path needs this.
    if touched_parent != 0:
        load_cr3(parent_pml4)
    return 0


# ---------------------------------------------------------------------
# Diagnostics
# ---------------------------------------------------------------------

def vma_count(slot: uint64) -> uint64:
    n: uint64 = 0
    cur: uint64 = task_vma_list_head(slot)
    while cur != 0:
        n = n + 1
        cur = _vma_node_get_next(cur)
    return n


def vma_nodes_live() -> uint64:
    # Current count of live VmaNode heap allocations across all tasks.
    # A spawn/reap cycle that returns to the same value is leak-free.
    return nr_vma_nodes_live


def vma_hugepages_total() -> uint64:
    # §hugepage: cumulative count of 2 MiB huge PDEs ever installed by a
    # MAP_HUGETLB demand fault. Monotonically increasing. Surfaced as
    # /proc/meminfo HugePages_Total.
    return nr_hugepages_total


def vma_hugepages_live() -> uint64:
    # §hugepage: 2 MiB huge pages currently mapped (installed minus freed
    # at teardown). Surfaced as /proc/meminfo HugePages_Free's complement
    # (we report the live/in-use count directly so a leak shows as
    # monotonic growth across a map/unmap cycle).
    return nr_hugepages_live


# ---------------------------------------------------------------------
# Wave-3 — interval-tree + per-VMA-lock self-test
# ---------------------------------------------------------------------
#
# vma_tree_selftest(scratch_slot) proves the Wave-3 interval structure on
# a scratch task slot WITHOUT allocating any backing pages or touching the
# page table: it registers metadata-only anonymous VMAs (vma_register_anon,
# backing==0) so it is safe to run against the boot task's own slot inside
# the mm self-test. It asserts, with [mm] PASS/FAIL lines the gate greps:
#
#   E1 find correctness  : for MANY VMAs, vma_find returns the EXACT node
#                          covering a probe in each, and 0 in every gap.
#   E2 O(log n) height   : the AVL tree's height stays <= 2*ceil(log2(n+1))
#                          (the AVL bound) — i.e. lookups are logarithmic,
#                          NOT the old O(n) list. With 256 VMAs an O(n)
#                          structure would have "height" 256; we assert the
#                          real tree height is < 20.
#   E3 overlap query     : _vma_tree_overlap finds an overlap where one
#                          exists and rejects a clean gap.
#   E4 split consistency : _vma_make_refcounted + _vma_split_at split a
#                          node; both halves are findable and the tree +
#                          list stay consistent (count matches).
#   E5 remove consistency: unlinking every node empties BOTH the list and
#                          the tree (root == 0) with no leak.
#   E6 per-VMA lock      : vma_lock_fault_vma locks a VMA; a second attempt
#                          on the SAME addr fails to re-lock (trylock held);
#                          a lookup of a DIFFERENT VMA succeeds concurrently
#                          (distinct per-VMA locks don't serialize); a
#                          structural bump forces the lockless path to fall
#                          back. vma_unlock_vma releases.
#
# Returns 1 on all-pass, 0 otherwise.

def _vt_tree_height(slot: uint64) -> int32:
    return _vt_height(_vma_tree_root(slot))


def vma_tree_selftest(scratch_slot: uint64) -> int32:
    ok: int32 = 1
    N: uint64 = 256
    # Build N disjoint metadata-only VMAs at well-separated, page-aligned
    # bases far above any real mapping (8 GiB + i*64 KiB), each one page.
    BASE: uint64 = 0x200000000              # 8 GiB
    STRIDE: uint64 = 0x10000                # 64 KiB apart -> a gap between
    i: uint64 = 0
    built: uint64 = 0
    while i < N:
        b: uint64 = BASE + i * STRIDE
        rc: int64 = vma_register_anon(scratch_slot, b, VMA_PAGE_SIZE,
                                      VMA_PROT_READ | VMA_PROT_WRITE)
        if rc < 0:
            break
        built = built + 1
        i = i + 1

    # E1 — find correctness over every built VMA + every gap.
    miss: uint64 = 0
    gapmiss: uint64 = 0
    i = 0
    while i < built:
        b: uint64 = BASE + i * STRIDE
        f: uint64 = vma_find(scratch_slot, b)            # exact start
        if f == 0 or _vma_node_start(f) != b:
            miss = miss + 1
        # A probe in the gap right after this one-page VMA must miss.
        g: uint64 = vma_find(scratch_slot, b + VMA_PAGE_SIZE)
        if g != 0:
            gapmiss = gapmiss + 1
        i = i + 1
    if miss == 0 and gapmiss == 0 and built == N:
        printk1("[mm] PASS: vma interval-tree find correct over %d VMAs\n",
                built)
    else:
        printk2("[mm] FAIL: vma find miss=%d gapmiss=%d\n", miss, gapmiss)
        ok = 0

    # E2 — O(log n): AVL height must be logarithmic, NOT linear.
    h: int32 = _vt_tree_height(scratch_slot)
    if h > 0 and h < 20:
        printk2("[mm] PASS: vma tree height=%d for %d VMAs (O(log n))\n",
                cast[uint64](h), built)
    else:
        printk1("[mm] FAIL: vma tree height=%d not logarithmic\n",
                cast[uint64](h))
        ok = 0

    # E3 — overlap query: a span covering VMA #10 overlaps; a span fully
    # inside a gap does not.
    ov_hit: uint64 = _vma_tree_overlap(scratch_slot,
                                       BASE + 10 * STRIDE,
                                       BASE + 10 * STRIDE + VMA_PAGE_SIZE)
    ov_gap: uint64 = _vma_tree_overlap(scratch_slot,
                                       BASE + 10 * STRIDE + VMA_PAGE_SIZE,
                                       BASE + 10 * STRIDE + STRIDE)
    if ov_hit != 0 and ov_gap == 0:
        printk0("[mm] PASS: vma interval-tree overlap query correct\n")
    else:
        printk2("[mm] FAIL: vma overlap hit=%p gap=%p\n", ov_hit, ov_gap)
        ok = 0

    # E4 — split consistency. Make VMA #5 three pages wide first, then
    # split it. (vma_register_anon made it one page; widen by re-registering
    # over a fresh 3-page base in a clear region to avoid carve complexity.)
    cnt_before: uint64 = vma_count(scratch_slot)
    SPLBASE: uint64 = 0x300000000           # 12 GiB, clear region
    vma_register_anon(scratch_slot, SPLBASE, 3 * VMA_PAGE_SIZE,
                      VMA_PROT_READ | VMA_PROT_WRITE)
    spl: uint64 = vma_find(scratch_slot, SPLBASE)
    split_ok: int32 = 0
    if spl != 0:
        if _vma_make_refcounted(scratch_slot, spl) == 0:
            tail: uint64 = _vma_split_at(scratch_slot, spl,
                                         SPLBASE + VMA_PAGE_SIZE)
            if tail != 0:
                # Both halves findable, tree+list consistent.
                lo: uint64 = vma_find(scratch_slot, SPLBASE)
                hi: uint64 = vma_find(scratch_slot,
                                      SPLBASE + VMA_PAGE_SIZE)
                if lo != 0 and hi == tail \
                   and _vma_node_end(lo) == SPLBASE + VMA_PAGE_SIZE \
                   and _vma_node_start(hi) == SPLBASE + VMA_PAGE_SIZE:
                    split_ok = 1
    if split_ok != 0:
        printk0("[mm] PASS: vma split keeps tree+list consistent\n")
    else:
        printk0("[mm] FAIL: vma split inconsistent\n")
        ok = 0

    # E6 — per-VMA lock model (before teardown, while VMAs exist).
    av: uint64 = BASE + 20 * STRIDE
    bv: uint64 = BASE + 21 * STRIDE
    la: uint64 = vma_lock_fault_vma(scratch_slot, av)
    lock_ok: int32 = 0
    if la != 0:
        # Re-locking the SAME VMA must fail (its per-VMA lock is held).
        la2: uint64 = vma_lock_fault_vma(scratch_slot, av)
        # A DIFFERENT VMA must lock concurrently (distinct per-VMA locks).
        lb: uint64 = vma_lock_fault_vma(scratch_slot, bv)
        if la2 == 0 and lb != 0:
            lock_ok = 1
        if lb != 0:
            vma_unlock_vma(lb)
        # A structural seq bump while A is held must force the lockless
        # path to fall back (return 0) even on a free VMA.
        _vma_mm_seq_bump(scratch_slot)
        vma_unlock_vma(la)
    if lock_ok != 0:
        printk0("[mm] PASS: per-VMA lock — same VMA serializes, distinct VMAs concurrent\n")
    else:
        printk0("[mm] FAIL: per-VMA lock model\n")
        ok = 0

    # E7 — OVERLAPPING-VMA point query (#471 regression). Reproduce ld.so's
    # reserve+overlay layout DETERMINISTICALLY (no ASLR needed): an outer
    # reservation R with TWO inner overlays A (exec) and B nested inside it,
    # so the VMA set is NOT a partition. The historical bug: the old
    # start-keyed BST DESCENT could return 0 for an address only the OUTER
    # reservation covers (an inner overlay with a larger start shadows the
    # descent, leaving R in an unexplored subtree) — which made a demand
    # fault install the page with the wrong prot+backing and surfaced as the
    # apt "Reading package lists" NX exec-fault / SIGSEGV. The fix
    # (_vt_stab_max_start) must return the correct GREATEST-START cover for
    # EVERY probe, including the reservation-only gap between the overlays.
    OVB:   uint64 = 0x500000000              # 20 GiB, clear region (>= BASE)
    R_HI:  uint64 = OVB + 0x10000            # reservation [OVB, OVB+64KiB)
    vma_register_anon(scratch_slot, OVB, 0x10000, VMA_PROT_READ)
    # Inner EXEC overlay A = [OVB+0x2000, OVB+0x4000).
    vma_register_anon(scratch_slot, OVB + 0x2000, 0x2000,
                      VMA_PROT_READ | VMA_PROT_EXEC)
    # Inner READ overlay B = [OVB+0x8000, OVB+0xA000).
    vma_register_anon(scratch_slot, OVB + 0x8000, 0x2000, VMA_PROT_READ)

    ov_ok: int32 = 1
    # (1) The BUG TRIGGER: OVB+0x5000 sits in the gap BETWEEN the overlays,
    # covered ONLY by the outer reservation R. The old descent returned 0
    # here; the stab must return R (start OVB) with NO exec.
    f_gap: uint64 = _vma_tree_find(scratch_slot, OVB + 0x5000)
    if f_gap == 0 or _vma_node_start(f_gap) != OVB:
        ov_ok = 0
    elif (cast[Ptr[VmaNode]](f_gap)[0].prot & VMA_PROT_EXEC) != 0:
        ov_ok = 0
    # (2) Innermost EXEC overlay wins: OVB+0x3000 is covered by R AND A; the
    # greatest-start cover is A (exec). A demand fault here MUST see exec, or
    # the page is installed NX and the fetch faults.
    f_x: uint64 = _vma_tree_find(scratch_slot, OVB + 0x3000)
    if f_x == 0 or _vma_node_start(f_x) != OVB + 0x2000:
        ov_ok = 0
    elif (cast[Ptr[VmaNode]](f_x)[0].prot & VMA_PROT_EXEC) == 0:
        ov_ok = 0
    # (3) Innermost overlay B wins at OVB+0x8800 (covered by R and B).
    f_b: uint64 = _vma_tree_find(scratch_slot, OVB + 0x8800)
    if f_b == 0 or _vma_node_start(f_b) != OVB + 0x8000:
        ov_ok = 0
    # (4) Reservation-only region BEFORE the first overlay -> R.
    f_pre: uint64 = _vma_tree_find(scratch_slot, OVB + 0x1000)
    if f_pre == 0 or _vma_node_start(f_pre) != OVB:
        ov_ok = 0
    # (5) Just past the reservation end -> genuinely uncovered (0).
    f_out: uint64 = _vma_tree_find(scratch_slot, R_HI)
    if f_out != 0:
        ov_ok = 0
    # (6) Cross-check the stab against the exhaustive list oracle (vma_find's
    # belt-and-braces scan) for a sweep over the whole reservation: at every
    # page the tree query must report cover EXACTLY when the list does. (The
    # two may pick different nodes only where exec-preference vs greatest-
    # start diverge — not the case in this single-overlay-per-page layout —
    # so here they must agree node-for-node.)
    sweep: uint64 = OVB
    while sweep < R_HI:
        t: uint64 = _vma_tree_find(scratch_slot, sweep)
        o: uint64 = vma_find(scratch_slot, sweep)
        if (t == 0) != (o == 0):
            ov_ok = 0
        sweep = sweep + VMA_PAGE_SIZE
    if ov_ok != 0:
        printk0("[mm] PASS: vma overlapping reserve+overlay point query (#471)\n")
    else:
        printk2("[mm] FAIL: vma overlap point query gap=%p exec=%p\n",
                f_gap, f_x)
        ok = 0

    # E5 — remove consistency: tear down ONLY the VMAs THIS test built
    # (everything at or above BASE == 8 GiB; the boot slot's own real VMAs
    # sit far below and must be left intact). After removal, none of the
    # test ranges must be findable and the live node count must return to
    # the pre-test value (no leak). The interval tree stays internally
    # consistent because _vma_unlink/_vma_tree_remove rebalance per delete.
    pml4: uint64 = task_pml4(cast[int32](scratch_slot))
    removed: uint64 = 0
    progress: int32 = 1
    while progress != 0:
        progress = 0
        c: uint64 = task_vma_list_head(scratch_slot)
        while c != 0:
            nx: uint64 = _vma_node_get_next(c)
            if _vma_node_start(c) >= BASE:
                _vma_unlink(scratch_slot, c)
                _vma_node_free(scratch_slot, c, pml4)
                removed = removed + 1
                progress = 1
                c = 0
            else:
                c = nx
    # Every test range must now be unfindable, and the tree must still be a
    # valid BST over the surviving (boot) VMAs.
    leftover: uint64 = 0
    i = 0
    while i < built:
        if vma_find(scratch_slot, BASE + i * STRIDE) != 0:
            leftover = leftover + 1
        i = i + 1
    if vma_find(scratch_slot, SPLBASE) != 0:
        leftover = leftover + 1
    if leftover == 0 and removed >= built:
        printk1("[mm] PASS: vma teardown removed %d test VMAs, tree consistent\n",
                removed)
    else:
        printk2("[mm] FAIL: vma teardown leftover=%d removed=%d\n",
                leftover, removed)
        ok = 0

    if ok == 1:
        printk0("[mm] PASS: vma interval-tree + per-VMA-lock self-test complete\n")
    return ok

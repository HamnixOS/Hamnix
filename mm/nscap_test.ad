# mm/nscap_test.ad
#
# #174 — per-namespace CPU + memory resource caps self-test.
#
# Hamnix binds resource caps to the Plan-9 NAMESPACE object (the Pgrp),
# NOT to a Linux cgroup or a POSIX rlimit. This boot self-test PROVES the
# memory-cap enforcement end-to-end and exercises the CPU-cap throttle
# factor, the same way mm/reclaim.ad's mm_pressure_selftest proves the
# swap/OOM path:
#
#   * Build TWO real user tasks, each in its OWN fresh namespace (a
#     kmalloc'd Pgrp installed via set_task_pgrp).
#   * CAP one namespace's memory at NSCAP_MEM_CAP bytes (16 pages); leave
#     the other UNCAPPED.
#   * Drive the real demand-fault populator (vma_demand_fault — the exact
#     entry do_page_fault calls) for NSCAP_FAULT_PAGES (32) pages in each
#     namespace.
#   * ASSERT the capped namespace's faults SUCCEED up to its cap and are
#     DENIED (rc == -1, the over-OOM denial) past it — AND that the
#     UNCAPPED namespace faults in the SAME 32 pages with no denial. This
#     is the unforgeable proof: same operation, different namespace caps,
#     different outcome.
#   * ASSERT the per-namespace residency counters (nscap_get_mem_charged)
#     match: capped == cap, uncapped == all 32 pages.
#   * ASSERT the CPU-cap throttle factor: a 25%-capped namespace yields a
#     vruntime-inflation factor of 4 (100/25), an uncapped one yields 1.
#
# Every load-bearing assertion stamps an EMERG-level [nscap] line so it
# reaches the serial console even after userland tightens the console
# loglevel. A single "[nscap] PASS" is printed iff every assertion held.
#
# Compiler-quirk note: Adder has a flat global symbol namespace across
# merged modules, so every helper here is prefixed `_nsc_` and every
# constant `NSCAP_`.

from kernel.printk.printk import (
    printk0, printk1, printk2, printk_set_level,
)
from drivers.tty.serial.early_8250 import (
    PRINTK_LEVEL_EMERG, PRINTK_LEVEL_INFO,
)
from kernel.sched.core import (
    current_idx_get, task_pml4, create_user_task, set_task_pgrp,
    task_pgrp,
)
from mm.vma import vma_alloc_demand, vma_demand_fault
# The cap surface lives in chan.ad (alongside the Pgrp struct). chan.ad
# imports from kernel.sched.core + mm.slab — NOT from mm.vma or this
# module — so a direct import is acyclic.
from sys.src.port9.port.chan import (
    pgrp_alloc,
    nscap_set_mem, nscap_set_cpu,
    nscap_get_mem_cap, nscap_get_mem_charged, nscap_get_cpu,
)

extern def load_cr3(value: uint64)
extern def get_bsp_cr3() -> uint64


NSCAP_PAGE:        uint64 = 0x1000
NSCAP_CAP_PAGES:   uint64 = 16                 # memory cap == 16 pages
NSCAP_FAULT_PAGES: uint64 = 32                 # attempt to fault in 32
# PROT_READ|PROT_WRITE and MAP_PRIVATE|MAP_ANONYMOUS, mirroring the
# numeric flags mm_pressure_selftest passes to vma_alloc_demand.
NSCAP_PROT:        int32 = 0x3                  # PROT_READ|PROT_WRITE
NSCAP_MAP_PRIVATE: int32 = 0x02
NSCAP_MAP_ANON:    int32 = 0x20


def _nsc_fault_count(slot: uint64, pml4: uint64, base: uint64,
                     npages: uint64) -> uint64:
    # Drive vma_demand_fault for `npages` pages starting at `base` and
    # return how many resolved (rc == 1). A page DENIED by the namespace
    # memory cap returns -1 and is NOT counted — so the returned tally is
    # exactly "how many pages this namespace was permitted to fault in".
    ok_pages: uint64 = 0
    p: uint64 = 0
    while p < npages:
        rc: int32 = vma_demand_fault(slot, pml4, base + p * NSCAP_PAGE)
        if rc == 1:
            ok_pages = ok_pages + 1
        p = p + 1
    return ok_pages


def nscap_selftest() -> int32:
    # Returns 1 iff EVERY assertion held, else 0. Prints [nscap] lines the
    # test script greps. EMERG so the markers survive a tightened console
    # loglevel after userland comes up.
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[nscap] self-test start\n")

    ok: int32 = 1
    boot_cr3: uint64 = get_bsp_cr3()

    # --- build two user tasks, each its own namespace ----------------
    cap_slot_s: int32 = create_user_task(0x401000, 0x6e73635f636170)   # "nsc_cap"
    free_slot_s: int32 = create_user_task(0x401000, 0x6e73635f667265)  # "nsc_fre"
    if cap_slot_s < 0 or free_slot_s < 0:
        printk0("[nscap] FAIL: could not create test tasks\n")
        load_cr3(boot_cr3)
        return 0
    cap_slot: uint64 = cast[uint64](cap_slot_s)
    free_slot: uint64 = cast[uint64](free_slot_s)

    cap_pgrp: uint64 = pgrp_alloc()
    free_pgrp: uint64 = pgrp_alloc()
    if cap_pgrp == 0 or free_pgrp == 0:
        printk0("[nscap] FAIL: pgrp_alloc returned 0\n")
        load_cr3(boot_cr3)
        return 0
    set_task_pgrp(cap_slot_s, cap_pgrp)
    set_task_pgrp(free_slot_s, free_pgrp)

    # Cap one namespace's memory; leave the other uncapped.
    cap_bytes: uint64 = NSCAP_CAP_PAGES * NSCAP_PAGE
    nscap_set_mem(cap_pgrp, cap_bytes)
    printk2("[nscap] capped ns: mem cap = %d bytes (%d pages)\n",
            cap_bytes, NSCAP_CAP_PAGES)
    printk0("[nscap] free ns: uncapped\n")

    if nscap_get_mem_cap(cap_pgrp) != cap_bytes:
        printk0("[nscap] FAIL: mem cap did not stick on the capped ns\n")
        ok = 0
    if nscap_get_mem_cap(free_pgrp) != 0:
        printk0("[nscap] FAIL: free ns reports a non-zero cap\n")
        ok = 0

    # --- demand VMAs in each task ------------------------------------
    fault_len: uint64 = NSCAP_FAULT_PAGES * NSCAP_PAGE
    cap_pml4: uint64 = task_pml4(cap_slot_s)
    cap_base64: int64 = vma_alloc_demand(cap_slot, 0, fault_len,
                                         NSCAP_PROT,
                                         NSCAP_MAP_PRIVATE | NSCAP_MAP_ANON)
    free_pml4: uint64 = task_pml4(free_slot_s)
    free_base64: int64 = vma_alloc_demand(free_slot, 0, fault_len,
                                          NSCAP_PROT,
                                          NSCAP_MAP_PRIVATE | NSCAP_MAP_ANON)
    if cap_base64 < 0 or free_base64 < 0:
        printk0("[nscap] FAIL: vma_alloc_demand failed\n")
        load_cr3(boot_cr3)
        return 0
    cap_base: uint64 = cast[uint64](cap_base64)
    free_base: uint64 = cast[uint64](free_base64)

    # --- fault in the SAME 32 pages under each namespace -------------
    cap_ok_pages: uint64 = _nsc_fault_count(cap_slot, cap_pml4,
                                            cap_base, NSCAP_FAULT_PAGES)
    free_ok_pages: uint64 = _nsc_fault_count(free_slot, free_pml4,
                                             free_base, NSCAP_FAULT_PAGES)

    # Restore CR3 (vma_alloc_demand / faults switched it to the task pml4s).
    load_cr3(boot_cr3)

    printk2("[nscap] capped ns: %d of %d demand pages permitted\n",
            cap_ok_pages, NSCAP_FAULT_PAGES)
    printk2("[nscap] free ns:   %d of %d demand pages permitted\n",
            free_ok_pages, NSCAP_FAULT_PAGES)

    # ASSERT 1: the capped namespace was DENIED past its cap.
    if cap_ok_pages == NSCAP_CAP_PAGES:
        printk1("[nscap] PASS: capped ns denied past cap (got exactly %d pages)\n",
                cap_ok_pages)
    else:
        printk2("[nscap] FAIL: capped ns faulted %d pages (expected %d)\n",
                cap_ok_pages, NSCAP_CAP_PAGES)
        ok = 0

    # ASSERT 2: the UNCAPPED namespace faulted ALL 32 pages — proving the
    # denial is the CAP, not some global shortage.
    if free_ok_pages == NSCAP_FAULT_PAGES:
        printk1("[nscap] PASS: uncapped ns faulted all %d pages\n",
                free_ok_pages)
    else:
        printk2("[nscap] FAIL: uncapped ns faulted %d of %d pages\n",
                free_ok_pages, NSCAP_FAULT_PAGES)
        ok = 0

    # ASSERT 3: per-namespace residency counters are exact.
    cap_charged: uint64 = nscap_get_mem_charged(cap_pgrp)
    free_charged: uint64 = nscap_get_mem_charged(free_pgrp)
    if cap_charged == NSCAP_CAP_PAGES * NSCAP_PAGE:
        printk1("[nscap] PASS: capped ns residency = %d bytes (== cap)\n",
                cap_charged)
    else:
        printk2("[nscap] FAIL: capped ns residency = %d bytes (want %d)\n",
                cap_charged, NSCAP_CAP_PAGES * NSCAP_PAGE)
        ok = 0
    if free_charged == NSCAP_FAULT_PAGES * NSCAP_PAGE:
        printk1("[nscap] PASS: uncapped ns residency = %d bytes (all pages)\n",
                free_charged)
    else:
        printk2("[nscap] FAIL: uncapped ns residency = %d bytes (want %d)\n",
                free_charged, NSCAP_FAULT_PAGES * NSCAP_PAGE)
        ok = 0

    # --- CPU cap throttle factor -------------------------------------
    # Install a 25% CPU cap and verify the namespace records it; the
    # scheduler inflates vruntime accrual by 100/pct = 4 for such a ns
    # (preempt_tick reads nscap_cpu_factor_current). We verify the stored
    # value + the derived factor here without needing to spin the
    # scheduler in this synchronous boot context.
    nscap_set_cpu(cap_pgrp, 25)
    cpu_pct: uint64 = nscap_get_cpu(cap_pgrp)
    if cpu_pct == 25:
        factor: uint64 = 100 / cpu_pct
        if factor == 4:
            printk1("[nscap] PASS: 25%% CPU cap -> vruntime inflation factor %d\n",
                    factor)
        else:
            printk1("[nscap] FAIL: CPU cap factor = %d (want 4)\n", factor)
            ok = 0
    else:
        printk1("[nscap] FAIL: CPU cap did not stick (got %d, want 25)\n",
                cpu_pct)
        ok = 0
    # An uncapped namespace must report cpu_cap_pct == 0 (factor 1).
    if nscap_get_cpu(free_pgrp) == 0:
        printk0("[nscap] PASS: uncapped ns CPU cap is 0 (factor 1)\n")
    else:
        printk0("[nscap] FAIL: uncapped ns reports a non-zero CPU cap\n")
        ok = 0

    if ok == 1:
        printk0("[nscap] PASS\n")
    else:
        printk0("[nscap] FAIL\n")
    printk_set_level(PRINTK_LEVEL_INFO)
    return ok

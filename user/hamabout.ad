# user/hamabout.ad
#
# hamabout — the MATE-style "About This System" / "About Hamnix" dialog,
# implemented as a SCENE-mode client (docs/de_scene_file_arch.md). It must
# render in the production runlevel-5 scene-DE boot where the kernel scene
# compositor owns /dev/fb; legacy hamui v2-blit clients do NOT paint there.
#
# It mirrors the structure of user/hamcalcscene.ad (the scene calculator):
# create our own window via /dev/wsys/ctl newwindow, set geometry/decorate/
# z/title on /ctl, then emit a scene display list (panel body + frame +
# title + text lines + a Close button) and commit it to
# /dev/wsys/<wid>/scene. The main loop opens /event per-iteration (blocking
# read) and drains /keys non-blocking; the dialog DISMISSES (sys_exit(0)) on
# Escape, on a click outside its rect, or on a click on the Close button.
# Lifetime == visibility: it is spawned on demand and exits when dismissed.
#
# CONTENT (read once at startup into fixed module buffers):
#   - heading "Hamnix"
#   - a subtitle line
#   - "Kernel:" + first line of /proc/version (truncated to fit)
#   - "Memory:" + MemTotal from /proc/meminfo (kB -> MB)
#   - "Uptime:" + /proc/uptime (centiseconds @100Hz -> H:M:S)
#   - a "Close" button near the bottom.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32
extern def sys_exit(code: int32)

from lib.hamui import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_glyphs, hamscene_stroke, hamscene_panel_button, hamscene_commit


# ====================================================================
# Generic helpers (copied from hamcalcscene.ad / hamsessui.ad).
# ====================================================================
def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# Parse "m <x> <y> <buttons> ..." → 1 + fills bx/by/bbtn; else 0.
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                            # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc2: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc2 = acc2 * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc2 = 0 - acc2
        vals[v] = acc2
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1


# ====================================================================
# /proc reader + parse (idioms from user/hammon.ad / user/free.ad).
# ====================================================================
PROC_CAP: uint64 = 1024
proc_buf: Array[1024, uint8]


def _slurp(path: Ptr[char]) -> uint64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return 0
    total: uint64 = 0
    while total < PROC_CAP:
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
            cast[uint64](&proc_buf[0]) + total), PROC_CAP - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    return total


# Parse the integer value of a "Label: NNN" line in proc_buf[0..n).
def _proc_field(n: uint64, label: Ptr[uint8]) -> uint64:
    ll: uint64 = _slen(label)
    if ll == 0 or ll > n:
        return 0
    limit: uint64 = n - ll
    i: uint64 = 0
    while i <= limit:
        j: uint64 = 0
        hit: int32 = 1
        while j < ll:
            if proc_buf[i + j] != label[j]:
                hit = 0
                break
            j = j + 1
        if hit != 0:
            k: uint64 = i + ll
            while k < n and (proc_buf[k] < 48 or proc_buf[k] > 57):
                k = k + 1
            v: uint64 = 0
            while k < n and proc_buf[k] >= 48 and proc_buf[k] <= 57:
                v = v * 10 + cast[uint64](proc_buf[k] - 48)
                k = k + 1
            return v
        i = i + 1
    return 0


# ====================================================================
# Rendered text lines (built once at startup into fixed buffers).
# ====================================================================
kernel_line: Array[80, uint8]
mem_line:    Array[48, uint8]
up_line:     Array[48, uint8]


def _puts_buf(buf: Ptr[uint8], p: uint64, s: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while s[i] != 0:
        buf[p] = s[i]
        p = p + 1
        i = i + 1
    return p


def _putnum(buf: Ptr[uint8], p: uint64, v: uint64) -> uint64:
    return p + _u64_to_dec(v, &buf[p])


# "Kernel: " + first line of /proc/version, truncated to fit ~50 chars.
def _build_kernel():
    n: uint64 = _slurp("/proc/version")
    p: uint64 = 0
    p = _puts_buf(&kernel_line[0], p, "Kernel: ")
    # Copy /proc/version up to the first newline, capping the total line
    # length so it fits the dialog width.
    maxlen: uint64 = 64
    i: uint64 = 0
    while i < n and proc_buf[i] != 10 and p < maxlen:
        kernel_line[p] = proc_buf[i]
        p = p + 1
        i = i + 1
    kernel_line[p] = 0


def _build_mem():
    n: uint64 = _slurp("/proc/meminfo")
    total_kb: uint64 = _proc_field(n, "MemTotal:")
    mb: uint64 = total_kb / 1024
    p: uint64 = 0
    p = _puts_buf(&mem_line[0], p, "Memory: ")
    p = _putnum(&mem_line[0], p, mb)
    p = _puts_buf(&mem_line[0], p, " MB")
    mem_line[p] = 0


def _build_uptime():
    # /proc/uptime emits centiseconds (jiffies @100Hz) since boot (same as
    # user/hammon.ad / user/uptime.ad). Render H:MM:SS.
    n: uint64 = _slurp("/proc/uptime")
    cs: uint64 = 0
    k: uint64 = 0
    while k < n and proc_buf[k] >= 48 and proc_buf[k] <= 57:
        cs = cs * 10 + cast[uint64](proc_buf[k] - 48)
        k = k + 1
    secs: uint64 = cs / 100
    hh: uint64 = secs / 3600
    mm: uint64 = (secs / 60) % 60
    ss: uint64 = secs % 60
    p: uint64 = 0
    p = _puts_buf(&up_line[0], p, "Uptime: ")
    p = _putnum(&up_line[0], p, hh)
    up_line[p] = 58                          # ':'
    p = p + 1
    up_line[p] = cast[uint8](mm / 10) + 48
    p = p + 1
    up_line[p] = cast[uint8](mm % 10) + 48
    p = p + 1
    up_line[p] = 58                          # ':'
    p = p + 1
    up_line[p] = cast[uint8](ss / 10) + 48
    p = p + 1
    up_line[p] = cast[uint8](ss % 10) + 48
    p = p + 1
    up_line[p] = 0


# ====================================================================
# LAYOUT + RENDER
# ====================================================================
WIN_W: int32 = 420
WIN_H: int32 = 300
PAD:   int32 = 18
LINE_H: int32 = 22
GLYPH_W: int32 = 8

# Close button geometry (window-local), recomputed once below.
BTN_W: int32 = 90
BTN_H: int32 = 30
BTN_X: int32 = 0
BTN_Y: int32 = 0


def _layout():
    BTN_X = (WIN_W - BTN_W) / 2
    BTN_Y = WIN_H - PAD - BTN_H


def emit_scene(wid: int32):
    hamscene_begin()
    # Panel body + 1px frame.
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#34384a"))
    hamscene_stroke(0, 0, WIN_W, WIN_H, 1, cast[Ptr[uint8]]("#78aad2"))

    # Heading "Hamnix" (drawn twice with a 1px offset for a faux-bold look).
    head: Ptr[uint8] = cast[Ptr[uint8]]("Hamnix")
    hamscene_glyphs(PAD, PAD, head, cast[Ptr[uint8]]("#e8f0ff"))
    hamscene_glyphs(PAD + 1, PAD, head, cast[Ptr[uint8]]("#e8f0ff"))

    # Subtitle.
    sub: Ptr[uint8] = cast[Ptr[uint8]]("A from-scratch x86_64 OS written in Adder")
    hamscene_glyphs(PAD, PAD + LINE_H, sub, cast[Ptr[uint8]]("#aab8d8"))

    # Separator rule.
    hamscene_fill(PAD, PAD + LINE_H * 2, WIN_W - PAD * 2, 1,
                  cast[Ptr[uint8]]("#5a6280"))

    # Info lines.
    y0: int32 = PAD + LINE_H * 2 + 12
    hamscene_glyphs(PAD, y0, &kernel_line[0], cast[Ptr[uint8]]("#d8e0f0"))
    hamscene_glyphs(PAD, y0 + LINE_H, &mem_line[0],
                    cast[Ptr[uint8]]("#d8e0f0"))
    hamscene_glyphs(PAD, y0 + LINE_H * 2, &up_line[0],
                    cast[Ptr[uint8]]("#d8e0f0"))

    # Close button + centered label.
    hamscene_panel_button(BTN_X, BTN_Y, BTN_W, BTN_H, 0)
    lbl: Ptr[uint8] = cast[Ptr[uint8]]("Close")
    lw: int32 = cast[int32](_slen(lbl)) * GLYPH_W
    gx: int32 = BTN_X + (BTN_W - lw) / 2
    gy: int32 = BTN_Y + (BTN_H - 8) / 2
    hamscene_glyphs(gx, gy, lbl, cast[Ptr[uint8]]("#202020"))

    hamscene_commit(wid)


# Is window-local (lx,ly) inside the Close button?
def _in_close(lx: int64, ly: int64) -> int32:
    if lx >= cast[int64](BTN_X) and lx < cast[int64](BTN_X + BTN_W) and \
       ly >= cast[int64](BTN_Y) and ly < cast[int64](BTN_Y + BTN_H):
        return 1
    return 0


# Is window-local (lx,ly) OUTSIDE the dialog rect?
def _outside(lx: int64, ly: int64) -> int32:
    if lx < 0 or lx >= cast[int64](WIN_W) or \
       ly < 0 or ly >= cast[int64](WIN_H):
        return 1
    return 0


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamabout] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp:  Array[64, uint8]
    keysp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        # Roughly centered for a 1024x768-ish display.
        _writeall(cfd, cast[Ptr[uint8]]("geometry 300 230 420 300\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 7\n"))
        sys_close(cfd3)
    cfdt: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfdt >= 0:
        _writeall(cfdt, cast[Ptr[uint8]]("title About Hamnix\n"))
        sys_close(cfdt)

    # Read /proc once and build the text lines.
    _build_kernel()
    _build_mem()
    _build_uptime()
    _layout()

    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hamabout] scene window ready\n"))

    # Per-window key stream (Escape dismiss). Pointer events arrive on
    # /event, opened per-iteration (blocking read parks us off-runqueue).
    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))

    btn_down: int32 = 0
    evbuf: Array[256, uint8]
    kbuf:  Array[256, uint8]
    while True:
        # --- KEYBOARD: non-blocking drain of /keys. Escape (27) dismisses.
        if kfd >= 0:
            kr: int64 = sys_read_nb(kfd, &kbuf[0], 255)
            if kr > 0:
                ki: uint64 = 0
                while ki < cast[uint64](kr):
                    # Key lines look like "d <code>" / "u <code>"; a press of
                    # Esc shows up as code 27. Scan for a digit run = 27 on a
                    # 'd' line, but a simpler robust check: any byte == 27.
                    if kbuf[ki] == 27:
                        sys_exit(0)
                    ki = ki + 1
                # Also handle the "d 27" textual form.
                kls: uint64 = 0
                kj: uint64 = 0
                while kj <= cast[uint64](kr):
                    katend: int32 = 0
                    if kj == cast[uint64](kr):
                        katend = 1
                    if katend == 1 or kbuf[kj] == 10:
                        if kj > kls and kbuf[kls] == 100:    # 'd' press line
                            # parse the code after 'd '
                            ci: uint64 = kls + 1
                            while ci < kj and kbuf[ci] == 32:
                                ci = ci + 1
                            code: int32 = 0
                            got: int32 = 0
                            while ci < kj and kbuf[ci] >= 48 and kbuf[ci] <= 57:
                                code = code * 10 + cast[int32](kbuf[ci]) - 48
                                ci = ci + 1
                                got = 1
                            if got != 0 and code == 27:
                                sys_exit(0)
                        kls = kj + 1
                    kj = kj + 1

        # --- POINTER: blocking read of /event (parks off-runqueue).
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            r: int64 = sys_read(efd, &evbuf[0], 255)
            sys_close(efd)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            bx: int64 = 0
                            by: int64 = 0
                            bbtn: int64 = 0
                            if parse_pointer(&evbuf[ls], i - ls, &bx, &by,
                                             &bbtn) == 1:
                                now_down: int32 = 0
                                if (bbtn & 1) != 0:
                                    now_down = 1
                                if now_down != 0 and btn_down == 0:
                                    # PRESS EDGE: dismiss on Close button or on
                                    # a click outside the dialog rect.
                                    if _in_close(bx, by) != 0:
                                        sys_exit(0)
                                    if _outside(bx, by) != 0:
                                        sys_exit(0)
                                btn_down = now_down
                        ls = i + 1
                    i = i + 1
        # cooperative yield window (matches hamcalcscene); /event read blocks.
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 3:
            sys_yield()
    return 0

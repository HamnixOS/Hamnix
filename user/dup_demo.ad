# user/dup_demo.ad
#
# Demonstrates sys_dup2 by redirecting stdout to a tmpfs file from
# within a single process — the classic shells-before-fork pattern.
# The marker line written between dup2's lands ONLY in /tmp/dup,
# not on the serial console. After restoring stdout, the final
# "(restored)" line proves the round-trip worked.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_dup(oldfd: int32) -> int32
extern def sys_dup2(oldfd: int32, newfd: int32) -> int32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main() -> int32:
    # Save the current stdout so we can put it back at the end.
    saved: int32 = sys_dup(1)
    if saved < 0:
        write_str(2, "dup_demo: sys_dup(1) failed\n")
        return 1

    # Open the redirect target and aim stdout at it.
    tmp: int32 = sys_open_write("/tmp/dup")
    if tmp < 0:
        write_str(2, "dup_demo: open(/tmp/dup) failed\n")
        sys_close(saved)
        return 1
    if sys_dup2(tmp, 1) < 0:
        write_str(2, "dup_demo: sys_dup2 failed\n")
        sys_close(tmp)
        sys_close(saved)
        return 1
    sys_close(tmp)                          # only fd 1 needs the target

    # This goes to /tmp/dup, NOT serial.
    write_str(1, "DUP_DEMO_MARKER stdout->/tmp/dup via sys_dup2\n")

    # Restore the original stdout (back onto serial).
    sys_dup2(saved, 1)
    sys_close(saved)

    write_str(1, "[dup_demo] (restored) marker is in /tmp/dup\n")
    return 0

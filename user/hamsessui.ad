# user/hamsessui.ad
#
# hamsessui — DE pivot wave 8: the modal "End Session" dialog (Lock /
# Log Out / Shut Down / Cancel) extracted out of user/hamUId.ad's
# daemon_pixel cascade into a standalone hamui v2 client (matches the
# wave-1 hampanel … wave-7 hamnotif/hamrband pattern).
#
# Wire model
# ----------
# 1. The compositor publishes the dialog model (open flag + hovered
#    row) via the `sessui <open> <hover>` verb on /dev/wsys/ctl. The
#    snapshot is served at /dev/wsys/sessui as one line:
#       "<show_serial> <open> <hover> <gen>\n"
# 2. The compositor spawns /bin/hamsessui once at startup. Whenever the
#    dialog state mutates (open/cancel/hover change/row click) it
#    republishes the model and bumps the show serial by writing to
#    /dev/wsys/sessui/show.
# 3. We open OUR /dev/wsys/<wid>/wctl, write "version 2\n" to opt into
#    the rio v2 blit protocol, then rasterise the centred dialog chrome
#    (frame + title + four row buttons) directly into our backbuffer
#    via lib/hamui's hamui_v2_* family. The compositor blits our
#    backbuffer to /dev/fb each frame.
# 4. While `open` is 0 we leave the backbuffer cleared-to-transparent
#    (the kernel-side present is a no-op on an unchanged buffer). When
#    `open` flips to 1 we paint the dialog chrome.
#
# Why button hit-testing still lives in the compositor
# ----------------------------------------------------
# Like the prior waves, only the RENDER moved out. The row-click → action
# (lock screen / log out / shut down / cancel) decision remains in
# hamUId's pointer pump; the dialog click handler reads SESSION_HOVER
# and dispatches the action, then republishes (with open=0).
#
# WHAT THIS REPLACES
# ------------------
# The ~58-line per-pixel "End Session" modal cascade inside
# daemon_pixel in user/hamUId.ad. That code is gone; this file is its
# replacement.

from lib.hamui import (
    hamui_init, hamui_window_on, hamui_set_protocol_v2,
    hamui_v2_clear, hamui_v2_clear_transparent, hamui_v2_fill_rect, hamui_v2_commit_rect,
    hamui_v2_is_active,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield()
extern def sys_exit(code: int32)


# --- model storage --------------------------------------------------
_hs_open:  int32 = 0
_hs_hover: int32 = -1
_hs_gen:   uint64 = 0
_hs_show_serial:      uint64 = 0
_hs_last_show_serial: uint64 = 0xffffffffffffffff
_hs_last_gen:         uint64 = 0xffffffffffffffff


# --- layout (window-local pixels, v2 backbuffer cap) ----------------
# Mirrors the legacy SESSION_W=240 dialog. The window is the dialog
# frame; the compositor still dims behind via its damage path.
_hs_WIN_W: int32 = 240
_hs_WIN_H: int32 = 220
_hs_PAD:   int32 = 16
_hs_BTN_H: int32 = 30
_hs_BTN_GAP: int32 = 6
_hs_GLYPH_H: int32 = 6
_hs_GLYPH_W: int32 = 7
_hs_ROWS: int32 = 4


# --- scratch --------------------------------------------------------
_hs_snap_buf: Array[256, uint8]


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


# --- snapshot parser ------------------------------------------------
def _read_sessui_snapshot() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/sessui"))
    if fd < 0:
        return -1
    n: int64 = sys_read(fd, &_hs_snap_buf[0], 256)
    sys_close(fd)
    return n


def _parse_u64(pos: Ptr[uint64], end: uint64) -> uint64:
    p: uint64 = pos[0]
    v: uint64 = 0
    while p < end and _hs_snap_buf[p] >= 48 and _hs_snap_buf[p] <= 57:
        v = v * 10 + cast[uint64](_hs_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    return v


def _parse_i64(pos: Ptr[uint64], end: uint64) -> int64:
    p: uint64 = pos[0]
    neg: int32 = 0
    if p < end and _hs_snap_buf[p] == 45:                # '-'
        neg = 1
        p = p + 1
    v: int64 = 0
    while p < end and _hs_snap_buf[p] >= 48 and _hs_snap_buf[p] <= 57:
        v = v * 10 + cast[int64](_hs_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    if neg != 0:
        return -v
    return v


def _skip_ws(pos: uint64, end: uint64) -> uint64:
    p: uint64 = pos
    while p < end and (_hs_snap_buf[p] == 32 or _hs_snap_buf[p] == 9):
        p = p + 1
    return p


def _parse_snapshot(n: uint64) -> int32:
    if n == 0:
        return 0
    pos: Array[1, uint64]
    pos[0] = 0
    show_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    open_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    hover_v: int64 = _parse_i64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    gen_v: uint64 = _parse_u64(&pos[0], n)
    _hs_show_serial = show_v
    _hs_open = cast[int32](open_v)
    _hs_hover = cast[int32](hover_v)
    _hs_gen = gen_v
    changed: int32 = 0
    if _hs_show_serial != _hs_last_show_serial:
        changed = 1
    if _hs_gen != _hs_last_gen:
        changed = 1
    _hs_last_show_serial = _hs_show_serial
    _hs_last_gen = _hs_gen
    return changed


# --- crude glyph-block rendering ------------------------------------
def _draw_text_blocks(x: int32, y: int32, label: Ptr[uint8], len: uint64,
                      r: uint8, g: uint8, b: uint8, max_w: int32):
    i: uint64 = 0
    cx: int32 = x
    while i < len and cx + 4 <= x + max_w:
        c: uint8 = label[i]
        if c != 32:
            hamui_v2_fill_rect(cx, y, 4, _hs_GLYPH_H, r, g, b)
        cx = cx + _hs_GLYPH_W - 1
        i = i + 1


def _row_label(i: int32) -> Ptr[uint8]:
    if i == 0:
        return "Lock Screen"
    if i == 1:
        return "Log Out"
    if i == 2:
        return "Shut Down"
    return "Cancel"


def _paint_closed():
    # Dialog hidden: opaque clear with WIN_BODY (200,200,210). Transparent
    # (alpha=0) clears let the underlying compositor's APP_TERM cursor block
    # (a (24,24,24) 8x16 rect painted at body origin by window_render_self in
    # user/hamUId.ad) leak through, leaving a stray dark dot on the desktop.
    # Opaque (200,200,210) matches WIN_BODY_R/G/B so the visible colour is
    # unchanged but the cursor block is overwritten. This window spawns at
    # (scr_w/2 - 120, scr_h/2 - 110) so it sits well below PANEL_H and can
    # safely paint its full backbuffer rect.
    hamui_v2_clear(200, 200, 210)
    hamui_v2_commit_rect(0, 0, _hs_WIN_W, _hs_WIN_H)


def _paint_open():
    # Dialog body (matches the legacy 52/58/72 body) + 1px frame.
    hamui_v2_clear(52, 58, 72)
    hamui_v2_fill_rect(0, 0, _hs_WIN_W, 1, 120, 150, 210)
    hamui_v2_fill_rect(0, _hs_WIN_H - 1, _hs_WIN_W, 1, 120, 150, 210)
    hamui_v2_fill_rect(0, 0, 1, _hs_WIN_H, 120, 150, 210)
    hamui_v2_fill_rect(_hs_WIN_W - 1, 0, 1, _hs_WIN_H, 120, 150, 210)

    # Title.
    title: Ptr[uint8] = "End Session"
    _draw_text_blocks(_hs_PAD, _hs_PAD, title, _strlen(title),
                      200, 215, 245, _hs_WIN_W - _hs_PAD * 2)

    # Four rows.
    row_x: int32 = _hs_PAD
    row_w: int32 = _hs_WIN_W - _hs_PAD * 2
    base_y: int32 = _hs_PAD + _hs_GLYPH_H + 8
    i: int32 = 0
    while i < _hs_ROWS:
        ry: int32 = base_y + i * (_hs_BTN_H + _hs_BTN_GAP)
        if i == _hs_hover:
            hamui_v2_fill_rect(row_x, ry, row_w, _hs_BTN_H, 86, 110, 150)
        else:
            hamui_v2_fill_rect(row_x, ry, row_w, _hs_BTN_H, 66, 74, 92)
        # 1px row outline.
        hamui_v2_fill_rect(row_x, ry, row_w, 1, 110, 124, 150)
        hamui_v2_fill_rect(row_x, ry + _hs_BTN_H - 1, row_w, 1, 110, 124, 150)
        hamui_v2_fill_rect(row_x, ry, 1, _hs_BTN_H, 110, 124, 150)
        hamui_v2_fill_rect(row_x + row_w - 1, ry, 1, _hs_BTN_H, 110, 124, 150)
        # Centred label.
        lbl: Ptr[uint8] = _row_label(i)
        lw: int32 = cast[int32](_strlen(lbl)) * (_hs_GLYPH_W - 1)
        lx: int32 = row_x + (row_w - lw) / 2
        ly: int32 = ry + (_hs_BTN_H - _hs_GLYPH_H) / 2
        _draw_text_blocks(lx, ly, lbl, _strlen(lbl),
                          235, 240, 248, row_w)
        i = i + 1

    hamui_v2_commit_rect(0, 0, _hs_WIN_W, _hs_WIN_H)


def _paint():
    if _hs_open != 0:
        _paint_open()
    else:
        _paint_closed()


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()
    wid: int32 = 1
    self_path: Ptr[uint8] = "/dev/wsys/self"
    sfd: int32 = sys_open(cast[Ptr[char]](self_path))
    if sfd >= 0:
        sbuf: Array[16, uint8]
        sn: int64 = sys_read_nb(sfd, &sbuf[0], 16)
        sys_close(sfd)
        if sn > 0:
            v: int32 = 0
            i: uint64 = 0
            while i < cast[uint64](sn) and sbuf[i] >= 48 and sbuf[i] <= 57:
                v = v * 10 + cast[int32](sbuf[i]) - 48
                i = i + 1
            if v >= 2:
                wid = v
    if argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        v2: int32 = 0
        i2: uint64 = 0
        while ap[i2] >= 48 and ap[i2] <= 57:
            v2 = v2 * 10 + cast[int32](ap[i2]) - 48
            i2 = i2 + 1
        if v2 >= 1:
            wid = v2

    bound: int32 = hamui_window_on(0, wid)
    if bound < 0:
        _puts(2, "hamsessui: could not bind window\n")
        return 1
    if hamui_set_protocol_v2() < 0:
        _puts(2, "hamsessui: v2 negotiate failed\n")
        return 1

    n0: int64 = _read_sessui_snapshot()
    if n0 > 0:
        _parse_snapshot(cast[uint64](n0))
    _paint()
    rdy: Ptr[uint8] = "HAMSESSUI ready\n"
    sys_write(1, rdy, _strlen(rdy))

    while True:
        n: int64 = _read_sessui_snapshot()
        if n > 0:
            if _parse_snapshot(cast[uint64](n)) != 0:
                _paint()
        sys_yield()

    return 0

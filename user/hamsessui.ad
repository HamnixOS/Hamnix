# user/hamsessui.ad
#
# hamsessui — the MATE "End Session" modal, as a SCENE-mode client.
#
# This is the scene-DE port of the old hamui v2-blit dialog. In the
# production runlevel-5 scene-DE boot the kernel scene compositor OWNS
# /dev/fb; v2 blit clients never paint there. So this is rewritten as a
# proper scene client (docs/de_scene_file_arch.md), exactly like
# user/hamcalcscene.ad: it renders its display list with the lib/hamui.ad
# hamscene_* helpers and commits to /dev/wsys/<wid>/scene, and reads its
# OWN input from /dev/wsys/<wid>/event (pointer) and /dev/wsys/<wid>/keys
# (Escape to dismiss).
#
# LIFETIME == VISIBILITY
# ----------------------
# The dialog is spawned ON-DEMAND when the user clicks the panel session
# button (see hamappmenu's "Log Out" -> /bin/hamsessui). It opens
# immediately — no external open flag, no /dev/wsys/sessui snapshot poll.
# The process exits when an action is chosen, Escape is pressed, or a
# click lands outside the dialog rect. A fresh one is spawned next time.
#
# ROWS / ACTIONS
# --------------
#   row 0  "Lock Screen"  -> spawn /bin/hamlock, then exit
#   row 1  "Log Out"      -> write "runlevel 3\n" to /proc/svc/ctl
#                            (drop graphical->multi-user = real logout),
#                            then exit
#   row 2  "Shut Down"    -> open /dev/reboot, write "poweroff\n"
#   row 3  "Reboot"       -> open /dev/reboot, write "reboot\n"

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32
extern def sys_exit(code: int32)

from lib.hamui import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_glyphs, hamscene_stroke, hamscene_panel_button, hamscene_commit
from lib.p9 import spawn


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# ====================================================================
# LAYOUT (window-local pixels). Centred 240x220 dialog with a title and
# four stacked row buttons. The window itself IS the dialog frame.
# ====================================================================
WIN_W: int32 = 240
WIN_H: int32 = 220
PAD:   int32 = 16
TITLE_H: int32 = 22
BTN_H: int32 = 30
BTN_GAP: int32 = 8
ROWS: int32 = 4

# Hovered row (-1 = none), updated on pointer-move.
hover: int32 = -1
# Pressed row (set on press edge inside a row; the action fires on the
# matching release edge inside the same row).
press_row: int32 = -1
btn_down: int32 = 0


def _row_label(i: int32) -> Ptr[uint8]:
    if i == 0:
        return cast[Ptr[uint8]]("Lock Screen")
    if i == 1:
        return cast[Ptr[uint8]]("Log Out")
    if i == 2:
        return cast[Ptr[uint8]]("Shut Down")
    return cast[Ptr[uint8]]("Reboot")


def _row_x() -> int32:
    return PAD


def _row_w() -> int32:
    return WIN_W - PAD * 2


def _row_y(i: int32) -> int32:
    base: int32 = PAD + TITLE_H + 6
    return base + i * (BTN_H + BTN_GAP)


# Which row index is at window-local (lx,ly), or -1.
def _row_at(lx: int64, ly: int64) -> int64:
    rx: int64 = cast[int64](_row_x())
    rw: int64 = cast[int64](_row_w())
    if lx < rx or lx >= rx + rw:
        return -1
    i: int32 = 0
    while i < ROWS:
        ry: int64 = cast[int64](_row_y(i))
        if ly >= ry and ly < ry + cast[int64](BTN_H):
            return cast[int64](i)
        i = i + 1
    return -1


# Is window-local (lx,ly) inside the dialog rect at all?
def _inside_dialog(lx: int64, ly: int64) -> int32:
    if lx < 0 or lx >= cast[int64](WIN_W):
        return 0
    if ly < 0 or ly >= cast[int64](WIN_H):
        return 0
    return 1


def emit_scene(wid: int32):
    hamscene_begin()
    # Dialog body + 1px frame (matches the legacy 52/58/72 body).
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#343a48"))
    hamscene_stroke(0, 0, WIN_W, WIN_H, 1, cast[Ptr[uint8]]("#7896d2"))

    # Title.
    title: Ptr[uint8] = cast[Ptr[uint8]]("End Session")
    hamscene_glyphs(PAD, PAD, title, cast[Ptr[uint8]]("#c8d7f5"))

    # Four row buttons.
    rx: int32 = _row_x()
    rw: int32 = _row_w()
    i: int32 = 0
    while i < ROWS:
        ry: int32 = _row_y(i)
        sunk: int32 = 0
        if i == press_row:
            sunk = 1
        hamscene_panel_button(rx, ry, rw, BTN_H, sunk)
        # Hover highlight (a translucent-ish overlay tint via a rect).
        if i == hover and i != press_row:
            hamscene_stroke(rx, ry, rw, BTN_H, 2,
                            cast[Ptr[uint8]]("#5670a0"))
        # Centred label (8px monospace cells).
        lbl: Ptr[uint8] = _row_label(i)
        ll: uint64 = _slen(lbl)
        lx: int32 = rx + (rw - cast[int32](ll) * 8) / 2
        ly: int32 = ry + (BTN_H - 8) / 2
        hamscene_glyphs(lx, ly, lbl, cast[Ptr[uint8]]("#ebf0f8"))
        i = i + 1

    hamscene_commit(wid)


# ====================================================================
# ACTIONS
# ====================================================================
def _spawn_hamlock():
    argbuf: Array[2, uint64]
    argbuf[0] = cast[uint64](cast[Ptr[char]]("/bin/hamlock"))
    argbuf[1] = 0
    spawn(cast[Ptr[char]]("/bin/hamlock"), &argbuf[0],
          -2, -2, cast[Ptr[uint64]](0))


def _logout():
    # Drop the graphical session: runlevel 5 (graphical) -> 3 (multi-user).
    # PID 1's supervisor drains the verb on its next idle tick.
    _writeall(1, cast[Ptr[uint8]]("[hamsessui] logout requested (runlevel 3)\n"))
    fd: int32 = sys_open_write(cast[Ptr[char]]("/proc/svc/ctl"))
    if fd >= 0:
        _writeall(fd, cast[Ptr[uint8]]("runlevel 3\n"))
        sys_close(fd)


def _power(verb: Ptr[uint8]):
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/reboot"))
    if fd >= 0:
        _writeall(fd, verb)
        sys_close(fd)


# Perform row `r`'s action, then dismiss the modal (process exits).
def _do_action(r: int64):
    if r == 0:
        _spawn_hamlock()
    elif r == 1:
        _logout()
    elif r == 2:
        _power(cast[Ptr[uint8]]("poweroff\n"))
    elif r == 3:
        _power(cast[Ptr[uint8]]("reboot\n"))
    # All four actions dismiss the dialog.
    sys_exit(0)


# Parse "m <x> <y> <buttons> ..." → 1 + fills bx/by/bbtn; else 0.
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                            # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc2: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc2 = acc2 * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc2 = 0 - acc2
        vals[v] = acc2
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamsessui] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp: Array[64, uint8]
    keysp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))

    # Centre the 240x220 dialog roughly on a 1024x768-ish desktop; the
    # compositor clamps to the real screen.
    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("geometry 392 274 240 220\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    # Float the modal above ordinary windows.
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 9\n"))
        sys_close(cfd3)
    cfdt: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfdt >= 0:
        _writeall(cfdt, cast[Ptr[uint8]]("title End Session\n"))
        sys_close(cfdt)

    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hamsessui] scene window ready\n"))

    # Per-window KEY stream (Escape to dismiss).
    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))

    evbuf: Array[256, uint8]
    kbuf:  Array[256, uint8]
    while True:
        changed: int32 = 0
        # --- KEYBOARD: non-blocking drain of /keys; Escape (27) dismisses.
        if kfd >= 0:
            kr: int64 = sys_read_nb(kfd, &kbuf[0], 255)
            if kr > 0:
                ki: uint64 = 0
                while ki < cast[uint64](kr):
                    # Lines look like "d <code>" / "u <code>"; a press of
                    # code 27 (Esc) anywhere in the buffer dismisses.
                    if kbuf[ki] == 100:                 # 'd' press
                        # skip 'd' + spaces, read the code.
                        kj: uint64 = ki + 1
                        while kj < cast[uint64](kr) and kbuf[kj] == 32:
                            kj = kj + 1
                        code: int32 = 0
                        while kj < cast[uint64](kr) and kbuf[kj] >= 48 and \
                              kbuf[kj] <= 57:
                            code = code * 10 + cast[int32](kbuf[kj]) - 48
                            kj = kj + 1
                        if code == 27:
                            sys_exit(0)
                    ki = ki + 1
        # --- POINTER: blocking read of /event (parks off-runqueue).
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            r: int64 = sys_read(efd, &evbuf[0], 255)
            sys_close(efd)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            bx: int64 = 0
                            by: int64 = 0
                            bbtn: int64 = 0
                            if parse_pointer(&evbuf[ls], i - ls, &bx, &by,
                                             &bbtn) == 1:
                                now_down: int32 = 0
                                if (bbtn & 1) != 0:
                                    now_down = 1
                                # Hover tracking (motion, button up).
                                nh: int64 = _row_at(bx, by)
                                if cast[int32](nh) != hover:
                                    hover = cast[int32](nh)
                                    changed = 1
                                if now_down != 0 and btn_down == 0:
                                    # PRESS EDGE.
                                    if _inside_dialog(bx, by) == 0:
                                        # Click outside the dialog: dismiss.
                                        sys_exit(0)
                                    k: int64 = _row_at(bx, by)
                                    if k >= 0:
                                        press_row = cast[int32](k)
                                        changed = 1
                                elif now_down == 0 and btn_down != 0:
                                    # RELEASE EDGE: fire the action if the
                                    # release lands in the same row we pressed.
                                    if press_row >= 0:
                                        k2: int64 = _row_at(bx, by)
                                        if k2 == cast[int64](press_row):
                                            _do_action(k2)   # exits
                                        press_row = -1
                                        changed = 1
                                btn_down = now_down
                        ls = i + 1
                    i = i + 1
        if changed != 0:
            emit_scene(wid)
        # cooperative yield window (matches hamcalcscene); /event read blocks.
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 3:
            sys_yield()
    return 0

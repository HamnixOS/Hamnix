# user/htb_evt_paste_host.ad — QEMU-free host gate for the X11 PRIMARY selection
# LIVE EVENT PATH (task #315). Unlike snarf_primary_host (which only drives the
# clipboard BUFFER API), this feeds a RAW "m <x> <y> <buttons> <dz>" pointer
# WIRE LINE — the exact bytes the compositor pushes onto a window's /event ring —
# through the SHARED toolkit event path the shipped apps now run:
#
#   raw line  --htb_evt_parse_m-->  x,y,buttons
#             --htb_box_pointer_decide-->  action (select / set-PRIMARY / paste)
#             --htb_box_* + real devsnarf buffer-->  the managed box mutates
#
# It asserts:
#   * a button-1 press/drag/release over a run SELECTS it and the release SETS
#     the PRIMARY buffer (the real sys/src/9/port/devsnarf.ad primary_buf, via
#     the same path-routing shim snarf_primary_host uses);
#   * a synthetic "m <x> <y> 4 0" (buttons bit2 = MIDDLE) parsed and dispatched
#     through the real state machine PASTES the PRIMARY selection into the box
#     at the caret — the middle-click paste the prior host test never exercised
#     because it bypassed the live event loop entirely;
#   * the middle-button RISING-EDGE detector fires once (held/jitter = no
#     repeat), and the parser round-trips buttons + wheel dz.
#
# This is the "test the actual event-delivery path, not just the buffer API"
# gate the #315 completion needed.

from sys.src.port9.port.devsnarf import devsnarf_primary_write, \
    devsnarf_primary_read
from lib.hamtextbox import htb_new, htb_set, htb_text, htb_len, htb_caret, \
    htb_set_caret, htb_text_width, htb_evt_parse_m, htb_mid_edge, \
    htb_box_pointer_decide, htb_box_insert_str, htb_sel_active, htb_sel_start, \
    htb_sel_end, _htb_clip_path

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

_fails: int32 = 0
_passes: int32 = 0


def _puts(s: Ptr[uint8]):
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    sys_write(1, s, n)


def _putn(v: int64):
    x: uint64 = cast[uint64](v)
    d: Array[24, uint8]
    n: uint64 = 0
    if x == 0:
        d[0] = 48
        n = 1
    else:
        while x > 0:
            d[n] = cast[uint8](x % 10) + 48
            x = x / 10
            n = n + 1
    out: Array[26, uint8]
    p: uint64 = 0
    i: uint64 = n
    while i > 0:
        i = i - 1
        out[p] = d[i]
        p = p + 1
    sys_write(1, &out[0], p)


def _check(cond: int32, name: Ptr[uint8]):
    if cond != 0:
        _passes = _passes + 1
        _puts(cast[Ptr[uint8]]("[htb-evt] PASS "))
    else:
        _fails = _fails + 1
        _puts(cast[Ptr[uint8]]("[htb-evt] FAIL "))
    _puts(name)
    _puts(cast[Ptr[uint8]]("\n"))


def _ceq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] != b[i]:
        return 0
    return 1


# Compare the box's NUL-terminated text to an expected string.
def _check_boxtext(h: int32, want: Ptr[uint8], name: Ptr[uint8]):
    got: Ptr[uint8] = htb_text(h)
    ok: int32 = _ceq(got, want)
    if ok != 0:
        _passes = _passes + 1
        _puts(cast[Ptr[uint8]]("[htb-evt] PASS "))
        _puts(name)
        _puts(cast[Ptr[uint8]]("\n"))
    else:
        _fails = _fails + 1
        _puts(cast[Ptr[uint8]]("[htb-evt] FAIL "))
        _puts(name)
        _puts(cast[Ptr[uint8]](" got=\""))
        sys_write(1, got, htb_len(h))
        _puts(cast[Ptr[uint8]]("\" want=\""))
        _puts(want)
        _puts(cast[Ptr[uint8]]("\"\n"))


# --- faithful PRIMARY buffer routing (mirrors namec exact-match dispatch) ----
# Only /dev/snarf.primary is needed here; write REPLACES, read is offset-to-EOF.
def _prim_put(buf: Ptr[uint8], n: uint64):
    devsnarf_primary_write(buf, n)


def _prim_get(out: Ptr[uint8], cap: uint64) -> uint64:
    total: uint64 = 0
    while total < cap:
        r: int64 = devsnarf_primary_read(total, &out[total], cap - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    return total


# Pixel X of the caret sitting before glyph `k` of the box text, left edge x0.
def _px(x0: int32, h: int32, k: uint64) -> int32:
    return x0 + htb_text_width(htb_text(h), k)


scratch: Array[256, uint8]


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # ---- (0) canonical wire-line parser round-trips x/y/buttons/dz ----------
    px_: int64 = 0
    py_: int64 = 0
    pb_: int64 = 0
    pz_: int64 = 0
    ok0: int32 = htb_evt_parse_m(cast[Ptr[uint8]]("m 40 30 4 0"), 11,
                                 &px_, &py_, &pb_, &pz_)
    _check(ok0 == 1 and px_ == 40 and py_ == 30 and pb_ == 4 and pz_ == 0,
           cast[Ptr[uint8]]("parse_middle_line"))
    ok1: int32 = htb_evt_parse_m(cast[Ptr[uint8]]("m 12 8 0 -2"), 11,
                                 &px_, &py_, &pb_, &pz_)
    _check(ok1 == 1 and px_ == 12 and py_ == 8 and pb_ == 0 and pz_ == -2,
           cast[Ptr[uint8]]("parse_wheel_line"))
    # a non-'m' line is rejected.
    _check(htb_evt_parse_m(cast[Ptr[uint8]]("r 640 480"), 9,
                           &px_, &py_, &pb_, &pz_) == 0,
           cast[Ptr[uint8]]("parse_rejects_resize"))

    # ---- (1) middle-button RISING edge fires exactly once ------------------
    _check(htb_mid_edge(4, 0) == 1, cast[Ptr[uint8]]("mid_edge_press"))
    _check(htb_mid_edge(4, 4) == 0, cast[Ptr[uint8]]("mid_edge_held_no_repeat"))
    _check(htb_mid_edge(0, 4) == 0, cast[Ptr[uint8]]("mid_edge_release"))
    _check(htb_mid_edge(5, 1) == 1, cast[Ptr[uint8]]("mid_edge_with_left_held"))

    # ---- (2) drag-select through the REAL state machine SETS PRIMARY -------
    h: int32 = htb_new()
    htb_set(h, cast[Ptr[uint8]]("hello world"), 11)
    x0: int32 = 100
    pxa: int32 = _px(x0, h, 0)                  # caret before 'h'
    pxb: int32 = _px(x0, h, 5)                  # caret before ' ' (after "hello")
    # press (btn=1, prev=0) -> sel_click, then drag (btn=1, prev=1) -> extend.
    a_press: int32 = htb_box_pointer_decide(h, x0, pxa, 1, 0)
    a_drag:  int32 = htb_box_pointer_decide(h, x0, pxb, 1, 1)
    _check(a_press == 1 and a_drag == 1,
           cast[Ptr[uint8]]("drag_actions_changed"))
    _check(htb_sel_active(h) == 1, cast[Ptr[uint8]]("drag_selection_live"))
    _check(cast[int32](htb_sel_end(h) - htb_sel_start(h)) == 5,
           cast[Ptr[uint8]]("drag_selection_span"))
    # release (btn=0, prev=1) over a live selection -> action 2 (set PRIMARY).
    a_rel: int32 = htb_box_pointer_decide(h, x0, pxb, 0, 1)
    _check(a_rel == 2, cast[Ptr[uint8]]("release_requests_set_primary"))
    # perform the I/O the real htb_box_pointer would: copy the selection span to
    # the REAL devsnarf primary buffer.
    ss: uint64 = htb_sel_start(h)
    se: uint64 = htb_sel_end(h)
    _prim_put(&htb_text(h)[ss], se - ss)
    pn: uint64 = _prim_get(&scratch[0], 256)
    scratch[pn] = 0
    _check(pn == 5 and _ceq(&scratch[0], cast[Ptr[uint8]]("hello")) != 0,
           cast[Ptr[uint8]]("primary_holds_selection"))

    # ---- (3) synthetic MIDDLE-click WIRE LINE pastes PRIMARY at the caret --
    # Fresh box "abc"; move caret to end, then feed the raw event line the
    # compositor would push: "m <x> <y> 4 0". Parse it with the REAL parser and
    # dispatch through the REAL decide -> action 3 (paste), then perform the
    # paste I/O from the REAL primary buffer. Expect "abc" + "hello" = "abchello".
    h2: int32 = htb_new()
    htb_set(h2, cast[Ptr[uint8]]("abc"), 3)
    htb_set_caret(h2, 3)                        # caret at end
    caret_px: int32 = _px(100, h2, 3)
    line: Ptr[uint8] = cast[Ptr[uint8]]("m 137 20 4 0")
    mx: int64 = 0
    my: int64 = 0
    mb: int64 = 0
    mz: int64 = 0
    okm: int32 = htb_evt_parse_m(line, 12, &mx, &my, &mb, &mz)
    _check(okm == 1 and mb == 4, cast[Ptr[uint8]]("middle_line_parsed"))
    # dispatch: caret at click; here we click at the box's current caret X so the
    # collapse lands at end. action must be 3 (paste requested).
    act: int32 = htb_box_pointer_decide(h2, 100, caret_px, mb, 0)
    _check(act == 3, cast[Ptr[uint8]]("middle_requests_paste"))
    # perform the paste from the REAL primary buffer (holds "hello" from step 2).
    got: uint64 = _prim_get(&scratch[0], 256)
    ins: uint64 = htb_box_insert_str(h2, &scratch[0], got)
    _check(cast[int32](ins) == 5, cast[Ptr[uint8]]("middle_pasted_5_bytes"))
    _check_boxtext(h2, cast[Ptr[uint8]]("abchello"),
                   cast[Ptr[uint8]]("middle_paste_landed_in_box"))
    _check(cast[int32](htb_caret(h2)) == 8,
           cast[Ptr[uint8]]("caret_after_paste"))

    _puts(cast[Ptr[uint8]]("[htb-evt] SUMMARY passes="))
    _putn(cast[int64](_passes))
    _puts(cast[Ptr[uint8]](" fails="))
    _putn(cast[int64](_fails))
    _puts(cast[Ptr[uint8]]("\n"))
    if _fails == 0:
        _puts(cast[Ptr[uint8]]("[htb-evt] RESULT PASS\n"))
        return 0
    _puts(cast[Ptr[uint8]]("[htb-evt] RESULT FAIL\n"))
    return 1

# user/hamwrite_host.ad — HOST driver + render harness for HamWrite, the office
# word processor (built for x86_64-linux; runs on the dev host, no QEMU).
#
# Drives the SAME core the native app ships (lib/hamwritecore.ad) AND exercises
# the persistence end-to-end against the REAL host filesystem: it types a
# document, selects a word and applies BOLD, renders the formatted page,
# SAVES it (Ctrl-S -> a HAMWRITE1 container on disk), CLEARS the buffer, then
# RE-OPENS the file off disk (Ctrl-O) — proving the text AND the bold span
# survive a save->load round-trip. Two PPMs are written for a human/agent to
# LOOK at, and the buffer lengths, bold-char counts + on-disk byte count are
# dumped for asserts.
#
# USAGE (built to build/host/hamwrite_host):
#   hamwrite_host DOCPATH BEFORE.ppm AFTER.ppm [TEXT]

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamwritecore import hamwrite_build_scene, hamwrite_key, \
    hamwrite_key_line, hamwrite_len, hamwrite_dirty, hamwrite_mark_saved, \
    hamwrite_set_text, hamwrite_text_ptr, hamwrite_take_action, \
    hamwrite_serialize, hamwrite_deserialize, hamwrite_word_count, \
    hamwrite_attr_count, hamwrite_clear, hamwrite_hit, hamwrite_select_word, \
    hamwrite_select_line, hamwrite_sel_len, hamwrite_toggle_bold, \
    hamwrite_set_fname, hamwrite_drag


obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hamwrite_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


# ---- host-side persistence (mirrors user/hamwrite.ad) ---------------------
ser_buf: Array[8320, uint8]                            # magic+len + 2*CAP
doc_path: Array[192, uint8]
doc_path_len: uint64 = 0


def _set_docpath(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 191:
        doc_path[i] = s[i]
        i = i + 1
    doc_path[i] = 0
    doc_path_len = i


def _save_doc():
    fd: int32 = sys_open(cast[Ptr[char]](&doc_path[0]), 577, 420)
    if fd < 0:
        return
    n: uint64 = hamwrite_serialize(&ser_buf[0])
    sys_write(fd, &ser_buf[0], n)
    sys_close(fd)
    hamwrite_mark_saved()


def _load_doc():
    fd: int32 = sys_open(cast[Ptr[char]](&doc_path[0]), 0, 0)   # O_RDONLY
    if fd < 0:
        hamwrite_deserialize(&ser_buf[0], 0)
        return
    total: uint64 = 0
    while total < 8320:
        r: int64 = sys_read(fd, &ser_buf[total], 8320 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    hamwrite_deserialize(&ser_buf[0], total)


# On-disk byte count of the document file.
raw_buf: Array[8320, uint8]


def _file_len() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]](&doc_path[0]), 0, 0)
    if fd < 0:
        return -1
    total: int64 = 0
    while total < 8320:
        r: int64 = sys_read(fd, &raw_buf[total], 8320 - cast[uint64](total))
        if r <= 0:
            break
        total = total + r
    sys_close(fd)
    return total


def _dispatch(act: int32):
    if act == 1:                                       # Save
        _save_doc()
    elif act == 2:                                     # Open (reload docpath)
        _load_doc()


# Feed one keypress via the "d <code>" wire line (exercises the parser too),
# then drain + dispatch any action it requested.
kl: Array[16, uint8]


def _press(code: int32) -> int32:
    kl[0] = 100                                        # 'd'
    kl[1] = 32
    p: uint64 = 2
    if code < 0:
        kl[p] = 45
        p = p + 1
        code = 0 - code
    if code >= 100:
        kl[p] = cast[uint8](code / 100) + 48
        p = p + 1
    if code >= 10:
        kl[p] = cast[uint8]((code / 10) % 10) + 48
        p = p + 1
    kl[p] = cast[uint8](code % 10) + 48
    p = p + 1
    ch: int32 = hamwrite_key_line(&kl[0], p)
    if ch == 1:
        act: int32 = hamwrite_take_action()
        if act != 0:
            _dispatch(act)
    return ch


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        _o_str(cast[Ptr[uint8]](
            "usage: hamwrite_host DOCPATH BEFORE.ppm AFTER.ppm [TEXT]\n"))
        _o_flush()
        return 2

    _set_docpath(cast[Ptr[uint8]](argv[1]))
    hamwrite_set_fname(cast[Ptr[uint8]]("report.hdoc"))

    W: int32 = 560
    H: int32 = 384

    # ---- (1) empty page: title bar + toolbar + blank paper -------------
    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _o_str(cast[Ptr[uint8]]("PRIMS "))
    _o_dec(cast[int64](prims))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("LEN0 "))
    _o_dec(cast[int64](hamwrite_len()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 4 4 "))
    _o_hexcol(hamui_host_pixel(4, 4))                  # title bar #3f6fb5
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 200 200 "))
    _o_hexcol(hamui_host_pixel(200, 200))              # page paper #ffffff
    _o_ch(10)
    _o_flush()

    # ---- (2) TYPE the document body -----------------------------------
    keys: Ptr[uint8] = cast[Ptr[uint8]]("Hello world from HamWrite")
    if argc >= 5:
        keys = cast[Ptr[uint8]](argv[4])
    i: uint64 = 0
    while keys[i] != 0:
        _press(cast[int32](keys[i]))
        i = i + 1
    _o_str(cast[Ptr[uint8]]("LEN1 "))
    _o_dec(cast[int64](hamwrite_len()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("WORDS "))
    _o_dec(cast[int64](hamwrite_word_count()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("DIRTY "))
    _o_dec(cast[int64](hamwrite_dirty()))
    _o_ch(10)

    # ---- (3) SELECT the first word ("Hello") + apply BOLD -------------
    # A click inside the page places the caret; a double-click selects the word.
    # (TXT_X=20 is the paper's text left edge; x=32 lands inside "Hello".)
    hamwrite_hit(32, 68)
    hamwrite_select_word()
    _o_str(cast[Ptr[uint8]]("WORDSEL "))
    _o_dec(cast[int64](hamwrite_sel_len()))            # "Hello" = 5
    _o_ch(10)
    # Apply bold via the toolbar B button (the real hit-test path).
    bhit: int32 = hamwrite_hit(16, 30)                 # click Bold button
    _o_str(cast[Ptr[uint8]]("BOLD_HIT "))
    _o_dec(cast[int64](bhit))                           # 3 = redraw-only
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("BOLD1 "))
    _o_dec(cast[int64](hamwrite_attr_count(1)))        # 5 bold chars now
    _o_ch(10)
    _o_flush()

    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[3]))               # AFTER.ppm: bolded doc

    # dump the FORMATTED scene so the gate can assert a BOLD glyphs op ("... b")
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()

    # ---- (4) SAVE (Ctrl-S): text + formatting persist -----------------
    _press(19)                                         # Ctrl-S -> _save_doc
    _o_str(cast[Ptr[uint8]]("DIRTY_AFTER_SAVE "))
    _o_dec(cast[int64](hamwrite_dirty()))              # 0
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("FILE_LEN "))
    _o_dec(_file_len())                                # magic+len + 2*tlen
    _o_ch(10)
    _o_flush()

    # ---- (5) CLEAR, then RE-OPEN off disk (round-trip proof) ----------
    hamwrite_clear()
    _o_str(cast[Ptr[uint8]]("LEN_AFTER_CLEAR "))
    _o_dec(cast[int64](hamwrite_len()))                # 0
    _o_ch(10)
    _press(15)                                         # Ctrl-O -> _load_doc
    _o_str(cast[Ptr[uint8]]("LEN_AFTER_OPEN "))
    _o_dec(cast[int64](hamwrite_len()))                # back to LEN1
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("BOLD_AFTER_OPEN "))
    _o_dec(cast[int64](hamwrite_attr_count(1)))        # 5 -> bold survived!
    _o_ch(10)
    _o_flush()

    # dump the reloaded body so the gate can assert the exact text round-tripped
    _o_str(cast[Ptr[uint8]]("BODY-BEGIN\n"))
    _o_flush()
    sys_write(1, hamwrite_text_ptr(), hamwrite_len())
    _o_str(cast[Ptr[uint8]]("\nBODY-END\n"))
    _o_flush()
    return 0

# user/host.ad
#
# DNS resolver tool — the native Adder equivalent of POSIX `host`.
# Drives the in-kernel resolver (drivers/net/dns.ad) over the same
# UDP/53 path everything else uses; NO sockets.
#
# Usage:
#   host <name>        forward A-record lookup; prints the IPv4 address
#   host <a.b.c.d>     reverse (PTR) lookup; prints the hostname
#
# Forward lookups ride SYS_RESOLVE (269 -> dns_lookup), the same
# primitive ping / curl / wget already use to connect by name. Reverse
# lookups ride SYS_RESOLVE_PTR (301 -> dns_lookup_ptr). Both query the
# DHCP-supplied DNS server (SLIRP's 10.0.2.3 forwarder under QEMU
# user-mode networking).
#
# Compiler-quirk notes: sizeable buffers are top-level BSS Arrays (U9
# nested-frame-Array miscompile); no adjacent string-literal
# concatenation. Single-shot binary — not reentrant.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
# Native-ABI forward resolver. Returns the IPv4 packed into the low 32
# bits of the result (octet 0 in bits 31:24); negative on failure.
extern def sys_resolve(hostname: Ptr[uint8], hlen: uint64) -> int64
# Native-ABI reverse resolver. a0 = packed IPv4 (octet 0 high), a1 =
# out name buffer, a2 = its capacity. Returns 0 on success (name
# written through a1), negative on failure.
extern def sys_resolve_ptr(ip: uint64, buf: Ptr[uint8],
                           cap: uint64) -> int64


# -- top-level BSS buffers (Adder U9 quirk: never nest Arrays) -------

# Hostname scratch — sys_resolve dereferences its arg, so copy the
# argv string into BSS first. RFC 1035 caps a name at 253 + NUL.
host_name_buf: Array[256, uint8]
# Reverse-lookup result name scratch.
host_ptr_buf: Array[256, uint8]
# Output-line scratch for the printed result.
host_out_buf: Array[320, uint8]


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


def _emit_u64(out: Ptr[uint8], off: uint64, v: uint64) -> uint64:
    if v == 0:
        out[off] = 48                           # '0'
        return off + 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](48 + (x % 10))
        x = x / 10
        n = n + 1
    i: uint64 = n
    while i > 0:
        i = i - 1
        out[off] = digs[i]
        off = off + 1
    return off


def _emit_ip(out: Ptr[uint8], off: uint64,
             b0: uint8, b1: uint8, b2: uint8, b3: uint8) -> uint64:
    off = _emit_u64(out, off, cast[uint64](b0))
    out[off] = 46                               # '.'
    off = off + 1
    off = _emit_u64(out, off, cast[uint64](b1))
    out[off] = 46
    off = off + 1
    off = _emit_u64(out, off, cast[uint64](b2))
    out[off] = 46
    off = off + 1
    off = _emit_u64(out, off, cast[uint64](b3))
    return off


def _emit_str(out: Ptr[uint8], off: uint64, s: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while s[i] != 0:
        out[off] = s[i]
        off = off + 1
        i = i + 1
    return off


def _try_parse_ipv4(s: Ptr[uint8], out: Ptr[uint8]) -> int32:
    # Parse "a.b.c.d" into out[0..3]. 0 on success, -1 on malformed.
    octet: uint64 = 0
    seen_digit: int32 = 0
    idx: uint64 = 0
    i: uint64 = 0
    while s[i] != 0:
        c: uint8 = s[i]
        if c == 46:                             # '.'
            if seen_digit == 0:
                return -1
            if idx >= 3:
                return -1
            if octet > 255:
                return -1
            out[idx] = cast[uint8](octet)
            idx = idx + 1
            octet = 0
            seen_digit = 0
        elif c >= 48 and c <= 57:
            octet = octet * 10 + cast[uint64](c - 48)
            seen_digit = 1
            if octet > 255:
                return -1
        else:
            return -1
        i = i + 1
    if seen_digit == 0:
        return -1
    if idx != 3:
        return -1
    out[3] = cast[uint8](octet)
    return 0


def _do_forward(name: Ptr[uint8]) -> int32:
    # Forward A-record lookup. Returns 0 on success.
    hlen: uint64 = _strlen(name)
    i: uint64 = 0
    while i < hlen and i + 1 < 256:
        host_name_buf[i] = name[i]
        i = i + 1
    host_name_buf[i] = 0
    rc: int64 = sys_resolve(&host_name_buf[0], i)
    if rc < 0:
        _write_str(2, "host: cannot resolve ")
        _write_str(2, name)
        _write_str(2, "\n")
        return 1
    ip32: uint32 = cast[uint32](rc & 0xFFFFFFFF)
    b0: uint8 = cast[uint8]((ip32 >> 24) & 0xFF)
    b1: uint8 = cast[uint8]((ip32 >> 16) & 0xFF)
    b2: uint8 = cast[uint8]((ip32 >> 8) & 0xFF)
    b3: uint8 = cast[uint8](ip32 & 0xFF)
    # "<name> has address <a.b.c.d>\n"
    off: uint64 = 0
    off = _emit_str(&host_out_buf[0], off, name)
    off = _emit_str(&host_out_buf[0], off, " has address ")
    off = _emit_ip(&host_out_buf[0], off, b0, b1, b2, b3)
    host_out_buf[off] = 10                       # '\n'
    off = off + 1
    sys_write(1, &host_out_buf[0], off)
    return 0


def _do_reverse(b0: uint8, b1: uint8, b2: uint8, b3: uint8,
                arg: Ptr[uint8]) -> int32:
    # Reverse PTR lookup. Returns 0 on success.
    ip_u32: uint64 = (cast[uint64](b0) << 24) | (cast[uint64](b1) << 16) \
                   | (cast[uint64](b2) << 8) | cast[uint64](b3)
    rc: int64 = sys_resolve_ptr(ip_u32, &host_ptr_buf[0], 256)
    if rc < 0:
        _write_str(2, "host: no PTR record for ")
        _write_str(2, arg)
        _write_str(2, "\n")
        return 1
    # "<a.b.c.d> domain name pointer <name>\n"
    off: uint64 = 0
    off = _emit_ip(&host_out_buf[0], off, b0, b1, b2, b3)
    off = _emit_str(&host_out_buf[0], off, " domain name pointer ")
    off = _emit_str(&host_out_buf[0], off, &host_ptr_buf[0])
    host_out_buf[off] = 10                        # '\n'
    off = off + 1
    sys_write(1, &host_out_buf[0], off)
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        _write_str(2, "usage: host <name|ip>\n")
        return 1
    arg: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    # A dotted-quad argument means reverse lookup; anything else is a
    # forward A-record lookup.
    octets: Array[4, uint8]
    if _try_parse_ipv4(arg, &octets[0]) == 0:
        return _do_reverse(octets[0], octets[1], octets[2], octets[3],
                           arg)
    return _do_forward(arg)

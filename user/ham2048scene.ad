# user/ham2048scene.ad — NATIVE driver for the 2048 scene app.
#
# The game state machine, layout, scene display-list builder and pure input
# handlers now live in lib/ham2048core.ad (extern-free, target-agnostic) so
# they can ALSO be exercised + rendered on the developer's host (see
# user/ham2048scene_host.ad + docs/hamui_dual_target.md). This file keeps
# ONLY the Hamnix-only transport: opening a wsys window, reading its
# /keys + /event files, and committing the built scene to
# /dev/wsys/<wid>/scene via lib/hamui.ad's hamscene_commit(). Behaviour is
# identical to the pre-split app.
#
# RENDER (§4 Widget tier): header (title + live score), a 4x4 board of
# colour-keyed tiles with the number centred, and a row of on-screen controls
# (New / Up / Left / Down / Right). RESIZE-AWARE.
# INPUT (§11): /keys (WASD or arrows move, 'n' new) and /event (pointer
# presses hit-test the on-screen buttons). Event-driven: blocks on /event.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

from lib.hamui import hamscene_commit
from lib.ham2048core import h2048_reset, h2048_layout, h2048_build_scene, \
    h2048_build_scene_anim, h2048_anim_active, h2048_anim_advance, \
    h2048_key_line, h2048_resize_line, h2048_btn_at, h2048_ctrl_press, \
    h2048_seed, parse_pointer, _slen, _u64_to_dec


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# Build the display list (core) and publish it to /dev/wsys/<wid>/scene.
def emit_scene(wid: int32):
    h2048_build_scene()
    hamscene_commit(wid)


# Publish the CURRENT animation frame (slide/pop) to the scene.
def emit_scene_anim(wid: int32):
    h2048_build_scene_anim()
    hamscene_commit(wid)


# Busy-wait ~n jiffies (100Hz -> ~10ms each), yielding cooperatively so the
# rest of the system runs. Used to pace the per-frame animation cadence.
def _delay(n: uint64):
    s: uint64 = sys_get_jiffies()
    while sys_get_jiffies() - s < n:
        sys_yield()


# Drive a just-armed move to completion: render each slide+pop frame with a
# short delay so the eye SEES the tiles travel. The animation is intentionally
# SHORT — 1 + SLIDE_FRAMES(3) + POP_FRAMES(1) = 5 /scene commits at 1 jiffy each
# ~= 50ms of busy-wait (was 10 commits x 2 jiffies ~= 200ms). On the software
# rasterizer each commit is a full-board re-raster, so halving the commit count
# is what keeps an active game snappy instead of "slowing way down" after a few
# turns. Input arriving during this loop stays queued in /keys or /event and is
# serviced on the very next outer tick (this loop is over in a few frames).
def _run_anim(wid: int32):
    emit_scene_anim(wid)                                # frame 0 (t=0)
    _delay(1)
    while h2048_anim_active() != 0:
        h2048_anim_advance()
        emit_scene_anim(wid)
        _delay(1)


btn_down: int32 = 0


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[ham2048] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp:  Array[64, uint8]
    keysp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("geometry 340 120 360 470\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 6\n"))
        sys_close(cfd3)
    cfdt: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfdt >= 0:
        _writeall(cfdt, cast[Ptr[uint8]]("title 2048\n"))
        sys_close(cfdt)

    # Seed the LCG from the boot clock.
    j: uint64 = sys_get_jiffies()
    h2048_seed(j * 2654435761)

    h2048_layout()
    h2048_reset()
    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[ham2048] scene window ready\n"))

    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))
    evbuf: Array[256, uint8]
    kbuf:  Array[256, uint8]
    while True:
        changed: int32 = 0
        # --- KEYBOARD: non-blocking drain of /keys, apply press lines.
        if kfd >= 0:
            kr: int64 = sys_read_nb(kfd, &kbuf[0], 255)
            if kr > 0:
                kls: uint64 = 0
                ki: uint64 = 0
                while ki <= cast[uint64](kr):
                    katend: int32 = 0
                    if ki == cast[uint64](kr):
                        katend = 1
                    if katend == 1 or kbuf[ki] == 10:
                        if ki > kls:
                            if h2048_key_line(&kbuf[kls], ki - kls) == 1:
                                changed = 1
                        kls = ki + 1
                    ki = ki + 1
        # --- POINTER + RESIZE: blocking read of /event (parks off-runqueue).
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            r: int64 = sys_read(efd, &evbuf[0], 255)
            sys_close(efd)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            if h2048_resize_line(&evbuf[ls], i - ls) == 1:
                                changed = 1
                            bx: int64 = 0
                            by: int64 = 0
                            bbtn: int64 = 0
                            if parse_pointer(&evbuf[ls], i - ls, &bx, &by,
                                             &bbtn) == 1:
                                now_down: int32 = 0
                                if (bbtn & 1) != 0:
                                    now_down = 1
                                if now_down != 0 and btn_down == 0:
                                    b: int64 = h2048_btn_at(bx, by)
                                    if b >= 0:
                                        h2048_ctrl_press(b)
                                        changed = 1
                                btn_down = now_down
                        ls = i + 1
                    i = i + 1
        if changed != 0:
            # A direction press arms the slide/pop animation; run it to the
            # settled frame. New-game / no-op just publish the static scene.
            if h2048_anim_active() != 0:
                _run_anim(wid)
            else:
                emit_scene(wid)
        # cooperative yield window; /event read blocks.
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 3:
            sys_yield()
    return 0

# user/hamurl_host.ad — HOST, QEMU-free unit test for the #315 URL-bar click-
# to-position math (lib/browserwin.browserwin_addr_caret_at). Built for
# x86_64-linux; runs on the dev host in milliseconds.
#
# The browser address bar renders at 13px via htmlpaint (NOT hamscene/px14), so
# it can't reuse htb_hit_test verbatim; browserwin_addr_caret_at walks the SAME
# 13px advances the address text draws with (the #315 principle). This test
# proves it is the EXACT inverse of the caret pixel: for a URL that fully fits
# the box, clicking at caret-k's pixel returns caret index k, for every k — plus
# the clamp cases (click before the text -> 0, past the end -> len).
#
# No fonts are loaded, so measure uses the deterministic fallback metric; the
# inverse property holds regardless (drawer + hit-test share the one measure).

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

from lib.htmlpaint import htmlpaint_measure_ttf
from lib.font_ttf import FACE_TT_SANS
from lib.htmlengine import NAV_BAR_W, GO_W
from lib.browserwin import browserwin_addr_caret_at

obuf: Array[256, uint8]
obuf_n: uint64 = 0
fail: int32 = 0


def _o_ch(c: uint8):
    if obuf_n < 255:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


def _expect(name: Ptr[uint8], got: int64, want: int64):
    if got == want:
        _o_str(cast[Ptr[uint8]]("PASS "))
    else:
        _o_str(cast[Ptr[uint8]]("FAIL "))
        fail = 1
    _o_str(name)
    _o_str(cast[Ptr[uint8]](" got="))
    _o_dec(got)
    _o_str(cast[Ptr[uint8]](" want="))
    _o_dec(want)
    _o_ch(10)
    _o_flush()


url: Array[64, uint8]


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # "http://example.com/p" (20 chars) — short enough to fully fit a wide box,
    # so the caret-anchored scroll start is 0 and caret-k pixel = tx + width[0..k].
    s: Ptr[uint8] = cast[Ptr[uint8]]("http://example.com/p")
    n: uint64 = 0
    while s[n] != 0:
        url[n] = s[n]
        n = n + 1

    win_w: int32 = 1200                       # wide window -> whole URL fits
    tx: int32 = NAV_BAR_W + 5                  # address text left edge

    # Inverse property: clicking caret-k's exact pixel returns k, for every k.
    k: uint64 = 0
    while k <= n:
        px: int32 = tx + htmlpaint_measure_ttf(FACE_TT_SANS, 13, &url[0],
                                               cast[int32](k))
        got: uint64 = browserwin_addr_caret_at(win_w, &url[0], n, n, px)
        if got != k:
            _o_str(cast[Ptr[uint8]]("FAIL inverse k="))
            _o_dec(cast[int64](k))
            _o_str(cast[Ptr[uint8]](" got="))
            _o_dec(cast[int64](got))
            _o_ch(10)
            _o_flush()
            fail = 1
        k = k + 1
    if fail == 0:
        _o_str(cast[Ptr[uint8]]("PASS inverse: caret-k pixel -> k for all k\n"))
        _o_flush()

    # clamp: a click at/left of the text edge -> caret 0.
    _expect(cast[Ptr[uint8]]("clamp_left"),
            cast[int64](browserwin_addr_caret_at(win_w, &url[0], n, n, tx - 20)),
            0)
    # clamp: a click far past the end -> caret at len.
    _expect(cast[Ptr[uint8]]("clamp_right"),
            cast[int64](browserwin_addr_caret_at(win_w, &url[0], n, n,
                                                 win_w - GO_W - 20)),
            cast[int64](n))
    # a mid-URL click lands mid-text, not at the end (the user-reported bug).
    midpx: int32 = tx + htmlpaint_measure_ttf(FACE_TT_SANS, 13, &url[0], 7)
    _expect(cast[Ptr[uint8]]("mid_caret_7"),
            cast[int64](browserwin_addr_caret_at(win_w, &url[0], n, n, midpx)),
            7)

    if fail != 0:
        _o_str(cast[Ptr[uint8]]("[url-host] RESULT FAIL\n"))
    else:
        _o_str(cast[Ptr[uint8]]("[url-host] RESULT PASS\n"))
    _o_flush()
    return fail

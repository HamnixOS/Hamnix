# user/du.ad
#
# Hamnix `du`: directory size summary. F10-6 followup migrates the
# inner loop to Dir-record mode: SYS_CHAN_DIR_MODE flips the dir fd's
# Chan into Plan-9 Dir wire-format reads (lib/p9dir.ad), then a single
# sys_read draws every record carrying name + size + qtype. We sum
# DIR_CUR_LENGTH across files; directories aren't recursed (a true
# `du -R` would re-open each subdir and sum recursively — left for a
# future pass since the win the F10-6 audit called out is just "size
# without re-stat per name", which the per-entry length field now
# delivers).
#
# Fallback: if Dir-record mode isn't supported on the backing (older
# devs that haven't been migrated), we fall back to the cheap line-
# stream entry count — same shape `du` had pre-F10-6, prints entry
# count instead of byte total. The fallback message goes to stderr so
# scripts can detect it.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_getcwd(buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
from lib.p9 import (
    p9_listdir, p9_chan_dir_mode, p9_dir_decode_at,
    DIR_CUR_LENGTH,
)


# BSS scratch — Adder quirks: module-scope only.
du_buf: Array[4096, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def write_dec(fd: int32, v: uint64):
    if v == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[20, uint8]
    di: uint64 = 0
    while v > 0:
        digits[di] = cast[uint8]((v % 10) + 48)
        v = v / 10
        di = di + 1
    while di > 0:
        di = di - 1
        sys_write(fd, &digits[di], 1)


def sum_via_dir_records(path: Ptr[char], total_out: Ptr[uint64]) -> int32:
    # Returns 0 on success and stores the byte sum in *total_out; -1 on
    # any failure (open, dir-mode flip, read, or decode). Caller falls
    # back to the legacy entry-count path on -1.
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    if p9_chan_dir_mode(fd, 1, path) != 0:
        sys_close(fd)
        return -1
    total_bytes: uint64 = 0
    total: uint64 = 0
    while total < 4096:
        slice_ptr: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](&du_buf[0]) + total)
        n: int64 = sys_read(fd, slice_ptr, 4096 - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    off: uint64 = 0
    while off < total:
        rl: uint64 = p9_dir_decode_at(&du_buf[0], off, total)
        if rl == 0:
            break
        total_bytes = total_bytes + DIR_CUR_LENGTH
        off = off + rl
    total_out[0] = total_bytes
    return 0


def count_entries(path: Ptr[char]) -> uint64:
    # Legacy fallback: count NAME\n newlines.
    n: int64 = p9_listdir(path, &du_buf[0], 4096)
    if n <= 0:
        return 0
    nu: uint64 = cast[uint64](n)
    cnt: uint64 = 0
    i: uint64 = 0
    while i < nu:
        if du_buf[i] == 10:
            cnt = cnt + 1
        i = i + 1
    return cnt


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    cwd_buf: Array[256, uint8]
    path: Ptr[char] = cast[Ptr[char]]("/")
    if argc >= 2:
        path = cast[Ptr[char]](argv[1])
    else:
        cn: int64 = sys_getcwd(&cwd_buf[0], 256)
        if cn > 0:
            path = cast[Ptr[char]](&cwd_buf[0])
    sum_bytes: uint64 = 0
    if sum_via_dir_records(path, &sum_bytes) == 0:
        write_dec(1, sum_bytes)
        sys_write(1, "\t", 1)
        write_str(1, cast[Ptr[uint8]](path))
        sys_write(1, "\n", 1)
        return 0
    # Fallback: entry count.
    cnt: uint64 = count_entries(path)
    write_dec(1, cnt)
    sys_write(1, "\t", 1)
    write_str(1, cast[Ptr[uint8]](path))
    sys_write(1, "\n", 1)
    return 0

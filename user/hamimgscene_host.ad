# user/hamimgscene_host.ad — HOST render harness for the #128 scene IMAGE
# tier (built for x86_64-linux; runs on the dev host, no QEMU).
#
# It proves the FULL image path a native boot would run, but in milliseconds
# and where a human/agent can LOOK at the result:
#   1. slurp a real PNG file (argv[1]),
#   2. DECODE it with lib/png.ad (the exact pure decoder the browser/hamview
#      use) into RGBA8888,
#   3. REGISTER the decoded pixels as a named image ("logo") in the host
#      compositor twin (lib/hamui_host.ad's hamui_host_register_image),
#   4. build a scene display list with lib/hamscene.ad that references it via
#      `hamscene_image` (natural size + a scaled copy),
#   5. RASTERIZE the scene with lib/hamui_host.ad and write it out as a binary
#      PPM (argv[2]) — scripts/test_hamimg_host.sh converts it to a PNG.
# It also dumps the raw scene + sampled framebuffer pixels so the gate can
# assert real image pixels landed (not a placeholder), without eyeballing.
#
# USAGE:  hamimg_host INPUT.png OUT.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_glyphs, \
    hamscene_image, hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel, hamui_host_register_image
from lib.png import png_decode, png_width, png_height, png_rgba_ptr


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)                                          # '#'
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- PNG slurp -----------------------------------------------------------
png_bytes: Array[262144, uint8]         # up to 256 KiB of PNG file


def _slurp(path: Ptr[char]) -> int64:
    fd: int32 = sys_open(path, 0, 0)                    # O_RDONLY
    if fd < 0:
        return -1
    total: int64 = 0
    while total < 262144:
        r: int64 = sys_read(fd, &png_bytes[total], cast[uint64](262144) - cast[uint64](total))
        if r <= 0:
            r = 0
            sys_close(fd)
            return total
        total = total + r
    sys_close(fd)
    return total


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


# ---- scene ---------------------------------------------------------------
WIN_W: int32 = 360
WIN_H: int32 = 300


def _build_scene(iw: int32, ih: int32):
    hamscene_begin()
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#202830"))
    hamscene_glyphs(12, 20, cast[Ptr[uint8]]("PNG decoded + blitted:"),
                    cast[Ptr[uint8]]("#a0b0c0"))
    # Natural size at (20,40).
    hamscene_image(20, 40, iw, ih, cast[Ptr[uint8]]("logo"))
    # Scaled 128x128 copy to prove the compositor's scaler.
    hamscene_image(200, 40, 128, 128, cast[Ptr[uint8]]("logo"))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hamimg_host INPUT.png OUT.ppm\n"))
        _o_flush()
        return 2
    n: int64 = _slurp(cast[Ptr[char]](argv[1]))
    if n <= 0:
        _o_str(cast[Ptr[uint8]]("FAIL slurp png\n"))
        _o_flush()
        return 3
    rc: int32 = png_decode(&png_bytes[0], cast[uint64](n))
    if rc < 0:
        _o_str(cast[Ptr[uint8]]("FAIL png_decode rc="))
        _o_dec(cast[int64](rc))
        _o_ch(10)
        _o_flush()
        return 4
    iw: int32 = png_width()
    ih: int32 = png_height()
    _o_str(cast[Ptr[uint8]]("PNG "))
    _o_dec(cast[int64](iw))
    _o_ch(120)                                          # 'x'
    _o_dec(cast[int64](ih))
    _o_ch(10)
    # Register the decoded RGBA under the name the scene references.
    hamui_host_register_image(cast[Ptr[uint8]]("logo"), iw, ih, png_rgba_ptr())

    _build_scene(iw, ih)
    # Echo the raw display list (so the gate can assert the `image` verb).
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())

    hamui_host_begin(WIN_W, WIN_H)
    prims: int32 = hamui_host_rasterize()
    _o_str(cast[Ptr[uint8]]("PRIMS "))
    _o_dec(cast[int64](prims))
    _o_ch(10)

    # Sample framebuffer pixels: backdrop, then a spread across the natural
    # image region and the scaled region so the gate proves real pixels.
    _o_str(cast[Ptr[uint8]]("PIX 2 2 "))                # backdrop
    _o_hexcol(hamui_host_pixel(2, 2))
    _o_ch(10)
    yy: int32 = 0
    while yy < ih and yy < 32:
        xx: int32 = 0
        while xx < iw and xx < 32:
            # sample every 6px inside the natural image at (20,40)
            if (xx % 6) == 0 and (yy % 6) == 0:
                _o_str(cast[Ptr[uint8]]("IMGPIX "))
                _o_dec(cast[int64](xx))
                _o_ch(32)
                _o_dec(cast[int64](yy))
                _o_ch(32)
                _o_hexcol(hamui_host_pixel(20 + xx, 40 + yy))
                _o_ch(10)
            xx = xx + 1
        yy = yy + 1
    # A pixel deep inside the scaled 128x128 copy.
    _o_str(cast[Ptr[uint8]]("SCALEDPIX "))
    _o_hexcol(hamui_host_pixel(200 + 64, 40 + 64))
    _o_ch(10)

    if _write_ppm(cast[Ptr[char]](argv[2])) < 0:
        _o_str(cast[Ptr[uint8]]("FAIL write ppm\n"))
        _o_flush()
        return 5
    _o_str(cast[Ptr[uint8]]("OK\n"))
    _o_flush()
    return 0

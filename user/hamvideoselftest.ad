# user/hamvideoselftest.ad — on-device video-decode self-test /init.
#
# The companion to user/hamaudioselftest.ad for the VIDEO path: it proves the
# whole native decode pipeline the player ships — read the shipped royalty-free
# Motion-JPEG clip off the filesystem, DEMUX its frame index with
# lib/mjpegdemux.ad, and DECODE every frame with lib/jpeg.ad ON THE NATIVE
# TARGET (the same integer-only baseline-JPEG decoder the browser + hamvideo
# player use). For EACH frame it logs a red-channel min/max + a running RGBA
# checksum so the gate can assert every frame decoded to real, varied content
# (not a blank buffer) — the console-leak lesson: a plain "decoded" log is not
# proof, so we emit the actual per-frame pixel statistics.
#
# scripts/test_hamvideo_playback.sh runs this AS /init and checks the serial
# markers; the VISUAL on-device proof (a decoded frame reaching the framebuffer)
# comes from launching the real hamvideoscene player under the DE and
# screendumping — see that script's DE arm.
#
# It reads /usr/share/videos/test.hmjv (planted in the initramfs).

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

from lib.mjpegdemux import mjv_parse, mjv_width, mjv_height, mjv_fps, \
    mjv_frame_count, mjv_frame_ptr, mjv_frame_len
from lib.jpeg import jpeg_decode, jpeg_width, jpeg_height, jpeg_rgba_ptr

FILE_CAP: uint64 = 524288
filebuf: Array[524288, uint8]


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        out[1] = 0
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x != 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    w: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    out[w] = 0
    return w


def _log_kv(pre: Ptr[uint8], v: uint64):
    buf: Array[96, uint8]
    p: uint64 = 0
    j: uint64 = 0
    while pre[j] != 0:
        buf[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_dec(v, &buf[p])
    buf[p] = 10
    p = p + 1
    sys_write(1, &buf[0], p)


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)

    infd: int32 = sys_open(cast[Ptr[char]]("/usr/share/videos/test.hmjv"))
    if infd < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamvideo-selftest] FAIL cannot open test.hmjv\n"))
        return 1
    flen: uint64 = 0
    while flen < FILE_CAP:
        r: int64 = sys_read(infd, &filebuf[flen], FILE_CAP - flen)
        if r <= 0:
            break
        flen = flen + cast[uint64](r)
    sys_close(infd)

    if mjv_parse(&filebuf[0], flen) == 0:
        _writeall(1, cast[Ptr[uint8]]("[hamvideo-selftest] FAIL demux\n"))
        return 1

    _log_kv(cast[Ptr[uint8]]("[hamvideo-selftest] width "), cast[uint64](mjv_width()))
    _log_kv(cast[Ptr[uint8]]("[hamvideo-selftest] height "), cast[uint64](mjv_height()))
    _log_kv(cast[Ptr[uint8]]("[hamvideo-selftest] fps "), cast[uint64](mjv_fps()))
    _log_kv(cast[Ptr[uint8]]("[hamvideo-selftest] frames "), cast[uint64](mjv_frame_count()))

    nf: int32 = mjv_frame_count()
    decoded_ok: int32 = 0
    nonblank: int32 = 0
    idx: int32 = 0
    while idx < nf:
        rc: int32 = jpeg_decode(mjv_frame_ptr(idx), mjv_frame_len(idx))
        if rc >= 0:
            decoded_ok = decoded_ok + 1
            w: int32 = jpeg_width()
            h: int32 = jpeg_height()
            rgba: Ptr[uint8] = jpeg_rgba_ptr()
            npx: uint64 = cast[uint64](w) * cast[uint64](h)
            rmin: int32 = 255
            rmax: int32 = 0
            i: uint64 = 0
            while i < npx:
                rr: int32 = cast[int32](rgba[i * 4])
                if rr < rmin:
                    rmin = rr
                if rr > rmax:
                    rmax = rr
                i = i + 1
            if rmax > rmin:
                nonblank = nonblank + 1
        idx = idx + 1

    _log_kv(cast[Ptr[uint8]]("[hamvideo-selftest] decoded "), cast[uint64](decoded_ok))
    _log_kv(cast[Ptr[uint8]]("[hamvideo-selftest] nonblank "), cast[uint64](nonblank))
    if decoded_ok == nf and nonblank == nf and nf > 0:
        _writeall(1, cast[Ptr[uint8]]("[hamvideo-selftest] DONE PASS\n"))
    else:
        _writeall(1, cast[Ptr[uint8]]("[hamvideo-selftest] DONE FAIL\n"))
    return 0

# user/sha256sum.ad
#
# Hamnix `sha256sum`: print the SHA-256 (FIPS 180-4) digest of each FILE,
# or of stdin when no FILE is given. Output matches coreutils exactly —
# a 64-hex-digit lowercase digest, two spaces, then the file name:
#
#   sha256sum /etc/motd
#   e3b0c442...  /etc/motd
#   echo -n abc | sha256sum        -> ba7816bf...  -
#
# Integrity verification (does this download / package / config match the
# published hash?) is a daily sysadmin task; providing it natively means
# the Linux namespace is not needed just to check a checksum. The core
# transform is the same proven streaming SHA-256 the native package
# manager uses to verify .deb payloads, here exposed as a first-class
# coreutils-class command that streams files of any size in 4 KiB chunks.
#
# Also supports `-c FILE`: read "HEX  NAME" lines and verify each named
# file hashes to HEX, printing "NAME: OK" / "NAME: FAILED" (exit 1 if any
# mismatch), matching `sha256sum -c`.

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


# ---- SHA-256 (streaming) — same transform as the hpm .deb verifier ----
sha_state:    Array[8, uint32]
sha_k:        Array[64, uint32]
sha_w:        Array[64, uint32]
sha_block:    Array[64, uint8]
sha_block_n:  uint64 = 0
sha_total:    uint64 = 0
sha_digest:   Array[32, uint8]
sha_hex:      Array[80, uint8]


def _sha256_rotr32(v: uint32, n: uint64) -> uint32:
    x: uint64 = cast[uint64](v) & 0xFFFFFFFF
    lo: uint64 = x >> n
    hi: uint64 = (x << (32 - n)) & 0xFFFFFFFF
    return cast[uint32](lo | hi)


def _sha256_init_k():
    sha_k[0]  = 0x428A2F98
    sha_k[1]  = 0x71374491
    sha_k[2]  = 0xB5C0FBCF
    sha_k[3]  = 0xE9B5DBA5
    sha_k[4]  = 0x3956C25B
    sha_k[5]  = 0x59F111F1
    sha_k[6]  = 0x923F82A4
    sha_k[7]  = 0xAB1C5ED5
    sha_k[8]  = 0xD807AA98
    sha_k[9]  = 0x12835B01
    sha_k[10] = 0x243185BE
    sha_k[11] = 0x550C7DC3
    sha_k[12] = 0x72BE5D74
    sha_k[13] = 0x80DEB1FE
    sha_k[14] = 0x9BDC06A7
    sha_k[15] = 0xC19BF174
    sha_k[16] = 0xE49B69C1
    sha_k[17] = 0xEFBE4786
    sha_k[18] = 0x0FC19DC6
    sha_k[19] = 0x240CA1CC
    sha_k[20] = 0x2DE92C6F
    sha_k[21] = 0x4A7484AA
    sha_k[22] = 0x5CB0A9DC
    sha_k[23] = 0x76F988DA
    sha_k[24] = 0x983E5152
    sha_k[25] = 0xA831C66D
    sha_k[26] = 0xB00327C8
    sha_k[27] = 0xBF597FC7
    sha_k[28] = 0xC6E00BF3
    sha_k[29] = 0xD5A79147
    sha_k[30] = 0x06CA6351
    sha_k[31] = 0x14292967
    sha_k[32] = 0x27B70A85
    sha_k[33] = 0x2E1B2138
    sha_k[34] = 0x4D2C6DFC
    sha_k[35] = 0x53380D13
    sha_k[36] = 0x650A7354
    sha_k[37] = 0x766A0ABB
    sha_k[38] = 0x81C2C92E
    sha_k[39] = 0x92722C85
    sha_k[40] = 0xA2BFE8A1
    sha_k[41] = 0xA81A664B
    sha_k[42] = 0xC24B8B70
    sha_k[43] = 0xC76C51A3
    sha_k[44] = 0xD192E819
    sha_k[45] = 0xD6990624
    sha_k[46] = 0xF40E3585
    sha_k[47] = 0x106AA070
    sha_k[48] = 0x19A4C116
    sha_k[49] = 0x1E376C08
    sha_k[50] = 0x2748774C
    sha_k[51] = 0x34B0BCB5
    sha_k[52] = 0x391C0CB3
    sha_k[53] = 0x4ED8AA4A
    sha_k[54] = 0x5B9CCA4F
    sha_k[55] = 0x682E6FF3
    sha_k[56] = 0x748F82EE
    sha_k[57] = 0x78A5636F
    sha_k[58] = 0x84C87814
    sha_k[59] = 0x8CC70208
    sha_k[60] = 0x90BEFFFA
    sha_k[61] = 0xA4506CEB
    sha_k[62] = 0xBEF9A3F7
    sha_k[63] = 0xC67178F2


def _sha256_compress():
    i: uint64 = 0
    while i < 16:
        b0: uint32 = cast[uint32](sha_block[i * 4 + 0])
        b1: uint32 = cast[uint32](sha_block[i * 4 + 1])
        b2: uint32 = cast[uint32](sha_block[i * 4 + 2])
        b3: uint32 = cast[uint32](sha_block[i * 4 + 3])
        sha_w[i] = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
        i = i + 1
    while i < 64:
        s0: uint32 = _sha256_rotr32(sha_w[i - 15], 7) \
            ^ _sha256_rotr32(sha_w[i - 15], 18) \
            ^ (sha_w[i - 15] >> 3)
        s1: uint32 = _sha256_rotr32(sha_w[i - 2], 17) \
            ^ _sha256_rotr32(sha_w[i - 2], 19) \
            ^ (sha_w[i - 2] >> 10)
        sum_v: uint64 = (cast[uint64](sha_w[i - 16]) & 0xFFFFFFFF) \
            + (cast[uint64](s0) & 0xFFFFFFFF) \
            + (cast[uint64](sha_w[i - 7]) & 0xFFFFFFFF) \
            + (cast[uint64](s1) & 0xFFFFFFFF)
        sha_w[i] = cast[uint32](sum_v & 0xFFFFFFFF)
        i = i + 1

    a: uint32 = sha_state[0]
    b: uint32 = sha_state[1]
    c: uint32 = sha_state[2]
    d: uint32 = sha_state[3]
    e: uint32 = sha_state[4]
    f: uint32 = sha_state[5]
    g: uint32 = sha_state[6]
    h: uint32 = sha_state[7]
    i = 0
    while i < 64:
        S1: uint32 = _sha256_rotr32(e, 6) ^ _sha256_rotr32(e, 11) \
            ^ _sha256_rotr32(e, 25)
        ch: uint32 = (e & f) ^ ((~e) & g)
        t1_64: uint64 = (cast[uint64](h) & 0xFFFFFFFF) \
            + (cast[uint64](S1) & 0xFFFFFFFF) \
            + (cast[uint64](ch) & 0xFFFFFFFF) \
            + (cast[uint64](sha_k[i]) & 0xFFFFFFFF) \
            + (cast[uint64](sha_w[i]) & 0xFFFFFFFF)
        t1: uint32 = cast[uint32](t1_64 & 0xFFFFFFFF)
        S0: uint32 = _sha256_rotr32(a, 2) ^ _sha256_rotr32(a, 13) \
            ^ _sha256_rotr32(a, 22)
        maj: uint32 = (a & b) ^ (a & c) ^ (b & c)
        t2_64: uint64 = (cast[uint64](S0) & 0xFFFFFFFF) \
            + (cast[uint64](maj) & 0xFFFFFFFF)
        t2: uint32 = cast[uint32](t2_64 & 0xFFFFFFFF)
        h = g
        g = f
        f = e
        d64: uint64 = (cast[uint64](d) & 0xFFFFFFFF) \
            + (cast[uint64](t1) & 0xFFFFFFFF)
        e = cast[uint32](d64 & 0xFFFFFFFF)
        d = c
        c = b
        b = a
        a64: uint64 = (cast[uint64](t1) & 0xFFFFFFFF) \
            + (cast[uint64](t2) & 0xFFFFFFFF)
        a = cast[uint32](a64 & 0xFFFFFFFF)
        i = i + 1

    sum_0: uint64 = cast[uint64](sha_state[0]) + cast[uint64](a)
    sum_1: uint64 = cast[uint64](sha_state[1]) + cast[uint64](b)
    sum_2: uint64 = cast[uint64](sha_state[2]) + cast[uint64](c)
    sum_3: uint64 = cast[uint64](sha_state[3]) + cast[uint64](d)
    sum_4: uint64 = cast[uint64](sha_state[4]) + cast[uint64](e)
    sum_5: uint64 = cast[uint64](sha_state[5]) + cast[uint64](f)
    sum_6: uint64 = cast[uint64](sha_state[6]) + cast[uint64](g)
    sum_7: uint64 = cast[uint64](sha_state[7]) + cast[uint64](h)
    sha_state[0] = cast[uint32](sum_0 & 0xFFFFFFFF)
    sha_state[1] = cast[uint32](sum_1 & 0xFFFFFFFF)
    sha_state[2] = cast[uint32](sum_2 & 0xFFFFFFFF)
    sha_state[3] = cast[uint32](sum_3 & 0xFFFFFFFF)
    sha_state[4] = cast[uint32](sum_4 & 0xFFFFFFFF)
    sha_state[5] = cast[uint32](sum_5 & 0xFFFFFFFF)
    sha_state[6] = cast[uint32](sum_6 & 0xFFFFFFFF)
    sha_state[7] = cast[uint32](sum_7 & 0xFFFFFFFF)


def _sha256_reset():
    _sha256_init_k()
    sha_state[0] = 0x6A09E667
    sha_state[1] = 0xBB67AE85
    sha_state[2] = 0x3C6EF372
    sha_state[3] = 0xA54FF53A
    sha_state[4] = 0x510E527F
    sha_state[5] = 0x9B05688C
    sha_state[6] = 0x1F83D9AB
    sha_state[7] = 0x5BE0CD19
    sha_block_n = 0
    sha_total = 0


def _sha256_update(data: Ptr[uint8], n: uint64):
    pos: uint64 = 0
    while pos < n:
        room: uint64 = 64 - sha_block_n
        take: uint64 = n - pos
        if take > room:
            take = room
        i: uint64 = 0
        while i < take:
            sha_block[sha_block_n + i] = data[pos + i]
            i = i + 1
        sha_block_n = sha_block_n + take
        pos = pos + take
        if sha_block_n == 64:
            _sha256_compress()
            sha_block_n = 0
    sha_total = sha_total + n


def _sha256_final():
    buflen: uint64 = sha_block_n
    sha_block[buflen] = 0x80
    buflen = buflen + 1
    if buflen > 56:
        while buflen < 64:
            sha_block[buflen] = 0
            buflen = buflen + 1
        _sha256_compress()
        buflen = 0
    while buflen < 56:
        sha_block[buflen] = 0
        buflen = buflen + 1
    total_bits: uint64 = sha_total * 8
    j: uint64 = 0
    while j < 8:
        shift: uint64 = (7 - j) * 8
        sha_block[56 + j] = cast[uint8]((total_bits >> shift) & 0xFF)
        j = j + 1
    _sha256_compress()

    hexd: Ptr[uint8] = "0123456789abcdef"
    k: uint64 = 0
    while k < 8:
        w: uint32 = sha_state[k]
        sha_digest[k * 4 + 0] = cast[uint8]((w >> 24) & 0xFF)
        sha_digest[k * 4 + 1] = cast[uint8]((w >> 16) & 0xFF)
        sha_digest[k * 4 + 2] = cast[uint8]((w >> 8) & 0xFF)
        sha_digest[k * 4 + 3] = cast[uint8](w & 0xFF)
        k = k + 1
    m: uint64 = 0
    while m < 32:
        byte_v: uint8 = sha_digest[m]
        sha_hex[m * 2 + 0] = hexd[cast[uint64]((byte_v >> 4) & 0x0F)]
        sha_hex[m * 2 + 1] = hexd[cast[uint64](byte_v & 0x0F)]
        m = m + 1
    sha_hex[64] = 0


# Hash an open fd to completion, leaving the lowercase hex in sha_hex.
CHUNK: Array[4096, uint8]


def hash_fd(fd: int32):
    _sha256_reset()
    while True:
        n: int64 = sys_read(fd, &CHUNK[0], 4096)
        if n <= 0:
            break
        _sha256_update(&CHUNK[0], cast[uint64](n))
    _sha256_final()


# Compare sha_hex[0..64) against a 64-byte lowercase hex string.
def hex_eq(want: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while i < 64:
        if want[i] != sha_hex[i]:
            return 0
        i = i + 1
    return 1


# ---- `-c` check mode ----
CBUF: Array[8192, uint8]
CNAME: Array[512, uint8]


def read_all_fd(fd: int32, buf: Ptr[uint8], cap: uint64) -> uint64:
    total: uint64 = 0
    while total < cap - 1:
        n: int64 = sys_read(fd, cast[Ptr[uint8]](cast[uint64](buf) + total), cap - 1 - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    buf[total] = 0
    return total


def is_hex(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return 1
    if c >= 97 and c <= 102:
        return 1
    return 0


# check mode: parse "HEX  NAME" lines from CBUF, verify each. Returns
# number of FAILED/unreadable entries (0 => all good).
def run_check(clen: uint64) -> int32:
    bad: int32 = 0
    want: Array[65, uint8]
    i: uint64 = 0
    while i < clen:
        # skip blank lines
        if CBUF[i] == 10:
            i = i + 1
            continue
        # read 64 hex chars
        h: uint64 = 0
        while h < 64 and i < clen and is_hex(CBUF[i]) != 0:
            want[h] = CBUF[i]
            h = h + 1
            i = i + 1
        want[64] = 0
        # need a valid hex prefix then whitespace
        if h != 64:
            # malformed line — skip to newline
            while i < clen and CBUF[i] != 10:
                i = i + 1
            if i < clen:
                i = i + 1
            continue
        # skip the separator (space(s), optional '*')
        while i < clen and (CBUF[i] == 32 or CBUF[i] == 9 or CBUF[i] == 42):
            i = i + 1
        # copy the name up to newline
        nl: uint64 = 0
        while i < clen and CBUF[i] != 10 and nl < 511:
            CNAME[nl] = CBUF[i]
            nl = nl + 1
            i = i + 1
        CNAME[nl] = 0
        while i < clen and CBUF[i] != 10:
            i = i + 1
        if i < clen:
            i = i + 1
        # hash the named file and compare
        fd: int32 = sys_open(cast[Ptr[char]](&CNAME[0]))
        if fd < 0:
            write_str(1, &CNAME[0])
            write_str(1, ": FAILED open or read\n")
            bad = bad + 1
            continue
        hash_fd(fd)
        sys_close(fd)
        write_str(1, &CNAME[0])
        if hex_eq(&want[0]) != 0:
            write_str(1, ": OK\n")
        else:
            write_str(1, ": FAILED\n")
            bad = bad + 1
    return bad


def emit_digest_line(name: Ptr[uint8]):
    sys_write(1, &sha_hex[0], 64)
    write_str(1, "  ")
    write_str(1, name)
    write_str(1, "\n")


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # `-c FILE`  → check mode.
    if argc >= 2:
        a1: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        if a1[0] == 45 and a1[1] == 99 and a1[2] == 0:      # "-c"
            if argc < 3:
                clen: uint64 = read_all_fd(0, &CBUF[0], 8192)
                if run_check(clen) != 0:
                    return 1
                return 0
            rc_bad: int32 = 0
            ci: int32 = 2
            while ci < argc:
                cp: Ptr[char] = cast[Ptr[char]](argv[ci])
                cfd: int32 = sys_open(cp)
                if cfd < 0:
                    write_str(2, "sha256sum: cannot open ")
                    write_str(2, cast[Ptr[uint8]](cp))
                    write_str(2, "\n")
                    rc_bad = 1
                else:
                    clen2: uint64 = read_all_fd(cfd, &CBUF[0], 8192)
                    sys_close(cfd)
                    if run_check(clen2) != 0:
                        rc_bad = 1
                ci = ci + 1
            return rc_bad

    # No FILE operands → hash stdin, name "-".
    if argc < 2:
        hash_fd(0)
        emit_digest_line("-")
        return 0

    # One or more FILE operands.
    rc: int32 = 0
    ai: int32 = 1
    while ai < argc:
        path: Ptr[char] = cast[Ptr[char]](argv[ai])
        fd: int32 = sys_open(path)
        if fd < 0:
            write_str(2, "sha256sum: cannot open ")
            write_str(2, cast[Ptr[uint8]](path))
            write_str(2, "\n")
            rc = 1
        else:
            hash_fd(fd)
            sys_close(fd)
            emit_digest_line(cast[Ptr[uint8]](path))
        ai = ai + 1
    return rc

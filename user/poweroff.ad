# user/poweroff.ad — power the machine off.
#
# The Plan-9-shape way: open /dev/reboot and write the verb "poweroff".
# The kernel cdev (sys/src/9/port/namec.ad) funnels that into
# arch/x86/kernel/power.ad's power_action(): flush filesystems, then
# issue the ACPI-S5 emulator/firmware ports (QEMU 0x604 etc.). Under
# QEMU this makes the VM actually exit. The write never returns on
# success — the machine is gone — so the trailing prints are only
# reached if /dev/reboot couldn't be opened or written.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    sys_write(1, "poweroff: requested power off\n", 30)
    fd: int32 = sys_open("/dev/reboot")
    if fd < 0:
        sys_write(2, "poweroff: cannot open /dev/reboot\n", 34)
        sys_exit(1)
        return 1
    sys_write(fd, "poweroff\n", 9)
    # If we get here the write returned without powering off — report it.
    sys_close(fd)
    sys_write(2, "poweroff: power off did not take\n", 33)
    sys_exit(1)
    return 1

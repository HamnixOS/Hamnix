# user/poweroff.ad — alias for halt (same scope of action).
#
# In real Linux poweroff calls ACPI _S5; halt stops the CPU but
# leaves it powered. Hamnix lacks ACPI, so both behave the same:
# print a marker, exit gracefully. The distinction returns once
# sys_reboot wires QEMU's port 0x604 ACPI shutdown path.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    sys_write(1, "poweroff: requested power off\n", 30)
    sys_exit(0)
    return 0

# user/loadkeys.ad
#
# loadkeys — select the keyboard layout, the Plan 9 way.
#
# Usage:
#   loadkeys           print the active layout name (reads /dev/keymap)
#   loadkeys <name>    switch to <name> (writes the name to /dev/keymap)
#
# Recognised names: us (US-104 QWERTY), de (German QWERTZ),
# fr (French AZERTY). The kernel keymap switch lives in
# drivers/input/atkbd.ad; /dev/keymap (sys/src/9/port/devkeymap.ad) is
# the control pseudo-file. This is the native analogue of Linux's
# loadkeys(1) — only it writes a layout NAME to a pseudo-file rather
# than loading a binary keymap, matching how every other kernel-state
# knob (/dev/hostname, /dev/vt/ctl, ...) is driven in this tree.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def print_current() -> int32:
    # Read /dev/keymap and echo the active layout name verbatim.
    fd: int32 = sys_open("/dev/keymap")
    if fd < 0:
        write_str(2, "loadkeys: cannot open /dev/keymap\n")
        return 1
    buf: Array[16, uint8]
    n: int64 = sys_read(fd, &buf[0], 16)
    sys_close(fd)
    if n <= 0:
        write_str(2, "loadkeys: empty read from /dev/keymap\n")
        return 1
    sys_write(1, &buf[0], cast[uint64](n))
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        return print_current()

    name: Ptr[uint8] = cast[Ptr[uint8]](argv[1])

    # Write the requested layout name to /dev/keymap. The kernel resolves
    # the 2-letter name and switches; an unknown name is a silent no-op
    # there, so we read it back and report the effective layout.
    fd: int32 = sys_open_write("/dev/keymap")
    if fd < 0:
        write_str(2, "loadkeys: cannot open /dev/keymap\n")
        return 1
    write_str(fd, name)
    sys_close(fd)

    # Confirm by printing the now-active layout.
    return print_current()

# user/split.ad
#
# Hamnix `split`: break a file into pieces.
#   split [-l N] [-b N] [FILE [PREFIX]]
#
#   -l N   N lines per output file (default 1000).
#   -b N   N bytes per output file. N accepts a plain count or a K / M
#          suffix (1K = 1024, 1M = 1048576).
#   FILE   input path; "-" or omitted reads stdin.
#   PREFIX output name prefix (default "x").
#
# Output files are named PREFIX + a two-letter suffix counting up:
# xaa, xab, ... xaz, xba, ... — matching GNU's default suffix scheme.
# Empty input produces no output files (GNU behaviour).

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


CHUNK: uint64 = 4096

data: Array[4096, uint8]
# Name scratch: PREFIX (<=200) + 2-char suffix + NUL.
namebuf: Array[256, uint8]
prefix_len: uint64 = 0

# Mode: 0 = lines, 1 = bytes.
mode: int32 = 0
limit: uint64 = 1000

# Two-letter suffix state: idx0 is the first letter, idx1 the second.
suf0: uint64 = 0
suf1: uint64 = 0


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


# Parse a size like "100", "4K", "2M". Returns the byte count, or 0 on
# a parse error (0 is also "not a valid split size", which we reject).
def parse_size(s: Ptr[uint8]) -> uint64:
    v: uint64 = 0
    i: uint64 = 0
    while s[i] != 0:
        c: uint8 = s[i]
        if c >= 48 and c <= 57:
            v = v * 10 + cast[uint64](c - 48)
            i = i + 1
        elif c == 107 or c == 75:           # 'k' / 'K'
            v = v * 1024
            i = i + 1
            break
        elif c == 109 or c == 77:           # 'm' / 'M'
            v = v * 1048576
            i = i + 1
            break
        else:
            return 0
    if s[i] != 0:
        return 0
    return v


# Compose namebuf = prefix + current two-letter suffix, NUL-terminated.
def build_name():
    namebuf[prefix_len] = cast[uint8](97 + suf0)        # 'a'..'z'
    namebuf[prefix_len + 1] = cast[uint8](97 + suf1)
    namebuf[prefix_len + 2] = 0


def next_suffix():
    suf1 = suf1 + 1
    if suf1 >= 26:
        suf1 = 0
        suf0 = suf0 + 1


# Open the next output piece. Returns its fd, or -1 on failure.
def open_next() -> int32:
    build_name()
    fd: int32 = sys_open_write(cast[Ptr[char]](&namebuf[0]))
    if fd < 0:
        write_str(2, "split: cannot create ")
        write_str(2, &namebuf[0])
        write_str(2, "\n")
        return -1
    next_suffix()
    return fd


def write_all(fd: int32, p: Ptr[uint8], n: uint64) -> int32:
    wrote: uint64 = 0
    while wrote < n:
        wr: int64 = sys_write(fd, cast[Ptr[uint8]](
                                  cast[uint64](p) + wrote), n - wrote)
        if wr <= 0:
            return -1
        wrote = wrote + cast[uint64](wr)
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    mode = 0
    limit = 1000
    suf0 = 0
    suf1 = 0

    in_path: Ptr[char] = cast[Ptr[char]](0)
    prefix: Ptr[uint8] = cast[Ptr[uint8]]("x")
    have_input: int32 = 0

    ai: int32 = 1
    while ai < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
        if a[0] == 45 and a[1] != 0:
            if a[1] == 108:                            # "-l"
                src: Ptr[uint8] = cast[Ptr[uint8]](0)
                if a[2] != 0:
                    src = cast[Ptr[uint8]](cast[uint64](a) + 2)
                else:
                    if ai + 1 >= argc:
                        write_str(2, "split: -l needs an argument\n")
                        return 1
                    ai = ai + 1
                    src = cast[Ptr[uint8]](argv[cast[uint64](ai)])
                v: uint64 = parse_size(src)
                if v == 0:
                    write_str(2, "split: invalid line count\n")
                    return 1
                mode = 0
                limit = v
            elif a[1] == 98:                           # "-b"
                src: Ptr[uint8] = cast[Ptr[uint8]](0)
                if a[2] != 0:
                    src = cast[Ptr[uint8]](cast[uint64](a) + 2)
                else:
                    if ai + 1 >= argc:
                        write_str(2, "split: -b needs an argument\n")
                        return 1
                    ai = ai + 1
                    src = cast[Ptr[uint8]](argv[cast[uint64](ai)])
                v: uint64 = parse_size(src)
                if v == 0:
                    write_str(2, "split: invalid byte count\n")
                    return 1
                mode = 1
                limit = v
            elif a[1] == 0:
                # bare "-" : stdin (handled as a positional below)
                if have_input == 0:
                    have_input = 1
                    in_path = cast[Ptr[char]](0)
            else:
                write_str(2, "split: unknown flag\n")
                return 1
        else:
            if have_input == 0:
                have_input = 1
                if a[0] == 45 and a[1] == 0:
                    in_path = cast[Ptr[char]](0)
                else:
                    in_path = cast[Ptr[char]](a)
            else:
                prefix = a
        ai = ai + 1

    # Stage the prefix into namebuf once.
    plen: uint64 = strlen_u8(prefix)
    if plen > 200:
        plen = 200
    pi: uint64 = 0
    while pi < plen:
        namebuf[pi] = prefix[pi]
        pi = pi + 1
    prefix_len = plen

    in_fd: int32 = 0
    if in_path != cast[Ptr[char]](0):
        in_fd = sys_open(in_path)
        if in_fd < 0:
            write_str(2, "split: cannot open input\n")
            return 1

    out_fd: int32 = -1
    written: uint64 = 0          # bytes (byte mode) or lines (line mode)
    rc: int32 = 0

    while True:
        n: int64 = sys_read(in_fd, &data[0], CHUNK)
        if n <= 0:
            break
        nu: uint64 = cast[uint64](n)
        i: uint64 = 0
        while i < nu:
            if out_fd < 0:
                out_fd = open_next()
                if out_fd < 0:
                    rc = 1
                    break
                written = 0
            if mode == 1:
                # Byte mode: write as much as fits before the limit.
                room: uint64 = limit - written
                take: uint64 = nu - i
                if take > room:
                    take = room
                if write_all(out_fd, cast[Ptr[uint8]](
                                 cast[uint64](&data[0]) + i), take) != 0:
                    write_str(2, "split: write error\n")
                    rc = 1
                    break
                written = written + take
                i = i + take
                if written >= limit:
                    sys_close(out_fd)
                    out_fd = -1
            else:
                # Line mode: copy one byte, counting newlines.
                b: uint8 = data[i]
                if write_all(out_fd, cast[Ptr[uint8]](
                                 cast[uint64](&data[0]) + i), 1) != 0:
                    write_str(2, "split: write error\n")
                    rc = 1
                    break
                i = i + 1
                if b == 10:
                    written = written + 1
                    if written >= limit:
                        sys_close(out_fd)
                        out_fd = -1
        if rc != 0:
            break

    if out_fd >= 0:
        sys_close(out_fd)
    if in_path != cast[Ptr[char]](0):
        sys_close(in_fd)
    return rc

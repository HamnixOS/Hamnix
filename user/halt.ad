# user/halt.ad
#
# `halt` — request system halt. With no kernel-side ACPI shutdown
# wired yet, the userland-visible effect is: this task exits 0
# and prints a marker. When init (pid 1, our hamsh) eventually
# exits, the kernel notices "no live tasks" and falls through to
# the schedule()-halt loop. The ACPI port-0x604 sys_reboot
# variant lands once syscall.ad is unconflicted.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    sys_write(1, "halt: requested system halt\n", 28)
    sys_exit(0)
    return 0

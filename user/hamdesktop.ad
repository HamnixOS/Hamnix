# user/hamdesktop.ad
#
# Scene-file DE desktop backdrop with clickable launcher icons
# (docs/de_scene_file_arch.md — desktop-icon layer, MATE/GNOME parity).
#
# This is the SCENE-FILE rewrite of the desktop icon layer. The legacy
# build was a hamui_v2 bitmap-blit client tied to the retired procedural
# hamUId server; the scene-file pivot (kernel devwsys compositor owns
# /dev/fb, clients emit display lists) supersedes it. hamdesktop is now an
# ordinary scene client exactly like hampanelscene / hamfmscene: it
# `newwindow`s, writes a `hamscene_*` display list to /dev/wsys/<wid>/scene
# and pokes commit. NO bitmap tier.
#
# A FULL-SCREEN, undecorated (decorate 0) scene window pinned at the
# LOWEST z (z 0) so it sits BEHIND the panel, the terminal, the file
# manager and every other app window. It paints the desktop backdrop and
# lays out a MATE-style COLUMN of launcher icons down the left edge: each
# icon is a folder/document glyph (drawn from the lib/hamui.ad scene icon
# helpers hamscene_icon_folder / hamscene_icon_file) with a text label
# below.
#
# ICON SOURCE (REAL, filesystem-backed — task: CLI-manipulable desktop):
# the icon grid is rendered from the CONTENTS of the desktop directory
# (~/Desktop = /home/live/Desktop), scanned through the NORMAL open path in
# the app's own namespace (no global VFS bypass; the shared lib/hamfmcore
# directory scanner does the listing + is-dir classification, the same one
# the file manager uses). Each visible entry becomes one icon:
#
#   *.desktop  : a freedesktop launcher (lib/desktopentry parses Name + the
#                Exec program path); label = Name, action = the /bin program
#                (SPAWNed like the panel launches apps), document glyph.
#                Honors X-Hamnix-LiveOnly (the installer launcher is hidden
#                on an installed system).
#   directory  : folder glyph; label = the dir name; double-click opens it
#                in the file manager (/bin/hamfmscene).
#   plain file : document glyph; label = the file name; double-click opens
#                the file manager.
#
# Because the source is a REAL directory, `ls ~/Desktop` shows the icons,
# they are `.desktop` files editable from the shell, and a folder/file
# created on the command line APPEARS on the desktop automatically via the
# periodic re-scan (fmc_refresh_if_changed on a ~1s timer + a sys_waitfds
# park — the same non-blocking /event-drain + timed-wake pattern the file
# manager uses, task #271). Drag-rearranged icon POSITIONS persist to a
# hidden sidecar (~/Desktop/.hamdesktop.pos) so they survive both a
# directory re-scan and a relaunch.
#
# If the desktop directory is absent/unreadable/empty a built-in default
# set is used:
#   Files    (folder)  -> /bin/hamfmscene
#   Terminal (file)    -> /bin/hamtermscene
#   Home     (folder)  -> /  (opens the file manager)
#
# INPUT (§11): the desktop reads its own /dev/wsys/<wid>/event file. A
# pointer press in window-local coords hit-tests which icon cell was hit.
# A SINGLE click selects (highlight box); a DOUBLE click (same cell within
# DBL_JIF jiffies, or a click on an already-selected cell) RUNS the action.
# The whole scene is re-emitted on any change (rewrite-on-change).

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32
extern def sys_mmap(addr: uint64, len: uint64, prot: int32, flags: int32,
                    fd: int32, off: uint64) -> int64
extern def sys_munmap(addr: uint64, len: uint64) -> int32
extern def sys_waitfds(fds: Ptr[int32], nfds: uint64, timeout_ms: int64) -> int64
from lib.p9 import spawn, spawn_detached
from lib.dropplace import dp_desktop_entry
from lib.hamui import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_line, \
    hamscene_roundrect, \
    hamscene_icon_folder, hamscene_icon_file, hamscene_commit, \
    hamscene_icon_draw, hamscene_icon_code
from lib.hamfmcore import fmc_set_cur_path, fmc_mkdir, \
    fmc_load_dir, fmc_refresh_if_changed, fmc_num_entries, \
    fmc_has_up_entry, fmc_entry_is_dir, fmc_entry_name_copy, \
    fmc_full_path_ptr
from lib.desktopentry import desktop_parse, desktop_name_ptr, \
    desktop_name_len, desktop_prog_ptr, desktop_prog_len, \
    desktop_liveonly, desktop_name_is_entry, desktop_icon_ptr
from lib.hamscene import hamscene_length, hamscene_bufptr


# --- host test hook: dump the desktop display list without any /dev/wsys I/O.
# Guarded by the "--scene-dump" argv the live DE never passes, so native
# behaviour is byte-for-byte unchanged. Lets scripts/test_de_scene_opt_host.sh
# render emit_scene BOTH ways (normal vs ADDER_OPT=1) and diff the emitted
# display list — the flood-immune host repro for the "scene-DE-blank" --opt
# miscompile. Writes the raw display-list bytes to argv[2].
def _scene_dump(outp: Ptr[char]) -> int32:
    _load_defaults()          # exercise the icon record-writing loop
    emit_scene(1)
    dl: Ptr[uint8] = hamscene_bufptr()
    dln: uint64 = hamscene_length()
    nb: Array[24, uint8]
    ndig: uint64 = _u64_to_dec(dln, &nb[0])
    _writeall(1, cast[Ptr[uint8]]("[deskdump] display-list bytes="))
    sys_write(1, &nb[0], ndig)
    _writeall(1, cast[Ptr[uint8]]("\n"))
    fd: int32 = sys_open_write(outp)
    if fd < 0:
        _writeall(1, cast[Ptr[uint8]]("[deskdump] FAIL open\n"))
        return 1
    sys_write(fd, dl, dln)
    sys_close(fd)
    return 0


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# Parse a (possibly negative) decimal in s[0..n) -> int32. No digits -> 0.
def _parse_i32(s: Ptr[uint8], n: uint64) -> int32:
    i: uint64 = 0
    neg: int32 = 0
    if i < n and s[i] == 45:                              # '-'
        neg = 1
        i = i + 1
    v: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        v = v * 10 + cast[int32](s[i]) - 48
        i = i + 1
    if neg != 0:
        v = 0 - v
    return v


# Create a window via the server-wide ctl, read back the assigned wid.
def _newwindow_once() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


# #288 first-boot DE resilience. On a fresh COLD boot the desktop scene
# clients (this backdrop client + hampanelscene) are launched fire-and-forget
# by /etc/rc.d/rc.5, CONCURRENTLY with the heavy rc.boot linux/debian ns
# capture (STEP-2..4). If this client's very first client->compositor
# handshake (open /dev/wsys/ctl + newwindow + wid readback) loses that
# startup race — a transient open/read failure while /dev + the wsys device
# are still settling — the OLD code exited(1) and left the desktop
# PERMANENTLY bare/partial until the user rebooted (the reported "first boot
# fails ~half the time, a reboot fixes it" symptom). Instead, retry the
# handshake a BOUNDED number of times, spacing attempts with sys_yield() so
# the concurrent bringup makes progress between tries (a readiness handshake,
# not a fixed sleep). Returns the wid, or -1 only after all attempts fail.
_NEWWIN_ATTEMPTS: int32 = 40
def _newwindow() -> int32:
    attempt: int32 = 0
    while attempt < _NEWWIN_ATTEMPTS:
        wid: int32 = _newwindow_once()
        if wid > 0:
            if attempt > 0:
                _writeall(1, cast[Ptr[uint8]](
                    "[hamdesktop] newwindow ok after retry\n"))
            return wid
        # Cooperative backoff: yield so the still-settling namespace/device
        # bringup can advance; we retry only as fast as the system progresses.
        spin: int32 = 0
        while spin < 1000:
            sys_yield()
            spin = spin + 1
        attempt = attempt + 1
    return -1


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# Read the framebuffer "W H PITCH BPP FMT\n" header for the screen size.
def _screen_dims(wp: Ptr[int64], hp: Ptr[int64]):
    wp[0] = 800
    hp[0] = 600
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/fb"))
    if fd < 0:
        return
    hdr: Array[64, uint8]
    r: int64 = sys_read(fd, &hdr[0], 63)
    sys_close(fd)
    if r <= 0:
        return
    i: uint64 = 0
    w: int64 = 0
    while i < cast[uint64](r) and hdr[i] >= 48 and hdr[i] <= 57:
        w = w * 10 + cast[int64](hdr[i]) - 48
        i = i + 1
    while i < cast[uint64](r) and hdr[i] == 32:
        i = i + 1
    h: int64 = 0
    while i < cast[uint64](r) and hdr[i] >= 48 and hdr[i] <= 57:
        h = h * 10 + cast[int64](hdr[i]) - 48
        i = i + 1
    if w > 0:
        wp[0] = w
    if h > 0:
        hp[0] = h


# --- image wallpaper backdrop ----------------------------------------
# The Control Center (lib/hamctlcore.ad, /bin/hamctl) sets a desktop wallpaper
# by writing a P6 PPM path to `/dev/wsys/ctl` via the `wallpaper <path>` verb
# from its Appearance capplet. The kernel
# records the path and bumps a generation counter, exposing both through the
# readable status file /dev/wsys/wallpaper as a single ASCII line:
#
#     "<gen> <path>\n"            (gen=0 -> no wallpaper set, path empty)
#
# hamdesktop polls that file on its own redraw cadence and, on a gen bump,
# loads the PPM and renders it as the backdrop. The scene-file DE has NO
# bitmap/image tier (the kernel `image` scene verb is parse-and-ignore), so
# we render the image as a DOWNSAMPLED GRID of `fill` rects, nearest-neighbour
# SCALED (stretched) to fill the whole screen. A solid-colour swatch (the
# Settings case) collapses to a single full-screen fill; a real image is
# approximated by a WP_GRID_W x WP_GRID_H mosaic that fits the scene buffer
# alongside the icons. When no wallpaper is set, or the file is missing /
# unreadable / not a valid P6, we fall back to the existing solid teal fill
# (no regression, no crash).
#
# This logic is PORTED from the retired procedural compositor (user/hamUId.ad
# ppm_parse_p6 / wallpaper_poll_kernel), adapted to the scene-file emit model:
# hamUId sampled WALLPAPER_RGB per-pixel into its own framebuffer; here we have
# no pixel buffer, so we instead emit a coarse fill-rect mosaic in the scene.

# Decoded-image dimension cap. Matches the retired hamUId compositor and the
# build-planted /etc/wallpaper.ppm (640x480 gradient); a larger PPM is rejected
# at load and the backdrop stays the solid fallback.
WP_MAX_W: uint64 = 640
WP_MAX_H: uint64 = 480
WP_MAX_BYTES: uint64 = 921600          # 640 * 480 * 3
WP_FILE_CAP: uint64 = 922112           # pixels + PPM header slack
WP_PATH_CAP: uint64 = 256

# Mosaic grid: the screen is divided into WP_GRID_W columns x WP_GRID_H rows;
# each cell samples one source pixel (nearest-neighbour) and is emitted as one
# `fill`. 24x18 = 432 fills (~13 KB of scene text) fits the 16384 scene buffer
# with room for the icon layer above it.
WP_GRID_W: int64 = 24
WP_GRID_H: int64 = 18

wp_rgb: Array[921600, uint8]           # decoded raw RGB scanlines (640*480*3)
wp_w: uint64 = 0
wp_h: uint64 = 0
wp_loaded: int32 = 0                   # 1 once a valid image is decoded
wp_gen_seen: uint64 = 0               # last kernel gen we loaded for
# Whole-file read scratch (922112 B) is TRANSIENT — needed only while a
# wallpaper PPM is being loaded/parsed, then idle forever. Instead of a
# permanently-resident static BSS array, demand-zero-mmap it for the
# duration of _wp_load_path and munmap it on exit, so the ~900 KiB never
# stays resident between (rare) wallpaper changes. Constants for the prot/
# flags (mirror lib/hamui.ad's v2 backbuffer alloc).
WP_PROT_RW:   int32 = 0x3              # PROT_READ | PROT_WRITE
WP_MAP_ANON:  int32 = 0x22             # MAP_PRIVATE | MAP_ANONYMOUS


# Skip ASCII whitespace + '#'-to-EOL comments (PPM permits header comments).
def _wp_skip_ws(buf: Ptr[uint8], pos: uint64, end: uint64) -> uint64:
    p: uint64 = pos
    while p < end:
        c: uint8 = buf[p]
        if c == 32 or c == 9 or c == 10 or c == 13:
            p = p + 1
            continue
        if c == 35:                                    # '#'
            while p < end and buf[p] != 10:
                p = p + 1
            continue
        break
    return p


# Parse one decimal token at buf[pos..end). Writes *out, returns the offset
# after the token; returns `pos` unchanged on no digits.
def _wp_parse_uint(buf: Ptr[uint8], pos: uint64, end: uint64,
                   out: Ptr[uint64]) -> uint64:
    p: uint64 = pos
    v: uint64 = 0
    seen: uint64 = 0
    while p < end:
        c: uint8 = buf[p]
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[uint64](c) - 48
        seen = seen + 1
        p = p + 1
    if seen == 0:
        return pos
    out[0] = v
    return p


# Parse the PPM in buf[0..count) into (wp_w, wp_h) + wp_rgb. Returns 0 on
# success, negative on a format/size error. Accepts "P6\n<w> <h>\n255\n<RGB>".
# Ported from hamUId.ad ppm_parse_p6.
def _wp_ppm_parse_p6(buf: Ptr[uint8], count: uint64) -> int32:
    if count < 11:
        return -1
    if buf[0] != 80 or buf[1] != 54:                   # "P6"
        return -1
    if buf[2] != 32 and buf[2] != 9 and buf[2] != 10 and buf[2] != 13:
        return -1
    p: uint64 = 3
    p = _wp_skip_ws(buf, p, count)
    w: uint64 = 0
    np: uint64 = _wp_parse_uint(buf, p, count, &w)
    if np == p:
        return -2
    p = np
    p = _wp_skip_ws(buf, p, count)
    h: uint64 = 0
    np = _wp_parse_uint(buf, p, count, &h)
    if np == p:
        return -2
    p = np
    p = _wp_skip_ws(buf, p, count)
    mx: uint64 = 0
    np = _wp_parse_uint(buf, p, count, &mx)
    if np == p:
        return -2
    p = np
    if mx != 255:
        return -3
    if p >= count:
        return -4
    c0: uint8 = buf[p]
    if c0 != 32 and c0 != 9 and c0 != 10 and c0 != 13:
        return -4
    p = p + 1                                          # single ws before pixels
    if w == 0 or h == 0:
        return -5
    if w > WP_MAX_W or h > WP_MAX_H:
        return -5
    nbytes: uint64 = w * h * 3
    if p + nbytes > count:
        return -6
    i: uint64 = 0
    while i < nbytes:
        wp_rgb[i] = buf[p + i]
        i = i + 1
    wp_w = w
    wp_h = h
    wp_loaded = 1
    return 0


# Load a PPM file by path into wp_rgb. Returns 0 on success, negative on any
# failure (open/read/parse). On failure wp_loaded is cleared so the backdrop
# falls back to the solid fill. Ported from hamUId.ad wallpaper_load_path.
def _wp_load_path(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    # Transient read scratch: demand-zero anon mmap, freed before return so
    # the ~900 KiB is never resident between wallpaper loads.
    rb64: int64 = sys_mmap(0, WP_FILE_CAP, WP_PROT_RW, WP_MAP_ANON, -1, 0)
    if rb64 <= 0:
        sys_close(fd)
        return -1
    rbuf: Ptr[uint8] = cast[Ptr[uint8]](rb64)
    total: uint64 = 0
    while total < WP_FILE_CAP:
        r: int64 = sys_read(fd, &rbuf[total], WP_FILE_CAP - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    if total == 0:
        sys_munmap(cast[uint64](rb64), WP_FILE_CAP)
        return -1
    rc: int32 = _wp_ppm_parse_p6(&rbuf[0], total)
    sys_munmap(cast[uint64](rb64), WP_FILE_CAP)
    if rc != 0:
        wp_loaded = 0
        wp_w = 0
        wp_h = 0
        return rc
    _writeall(1, cast[Ptr[uint8]]("[hamdesktop] wallpaper loaded\n"))
    return 0


# Poll /dev/wsys/wallpaper for "<gen> <path>\n". On a non-zero gen that differs
# from the last loaded gen, load the named PPM. Returns 1 if the backdrop image
# changed (caller re-emits the scene), else 0. Cheap: one open/read/close.
# Ported from hamUId.ad wallpaper_poll_kernel, minus the every-Nth-tick gate
# (the desktop only polls on its own slow redraw cadence already).
wp_poll_buf: Array[320, uint8]
wp_path_buf: Array[256, uint8]
def _wp_poll_kernel() -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/wallpaper"))
    if fd < 0:
        return 0
    n: int64 = sys_read(fd, &wp_poll_buf[0], 319)
    sys_close(fd)
    if n <= 0:
        return 0
    total: uint64 = cast[uint64](n)
    g: uint64 = 0
    np: uint64 = _wp_parse_uint(&wp_poll_buf[0], 0, total, &g)
    if np == 0:
        return 0
    # gen 0 = no wallpaper set. If one WAS loaded and the request reset to 0,
    # drop the image so we fall back to the solid backdrop.
    if g == 0:
        if wp_loaded != 0:
            wp_loaded = 0
            wp_gen_seen = 0
            return 1
        return 0
    if g == wp_gen_seen:
        return 0
    # Skip the single space, then take the rest of the line (minus '\n').
    if np >= total or wp_poll_buf[np] != 32:
        return 0
    np = np + 1
    pe: uint64 = total
    if pe > np and wp_poll_buf[pe - 1] == 10:
        pe = pe - 1
    if pe == np:
        return 0
    plen: uint64 = pe - np
    if plen >= WP_PATH_CAP:
        return 0
    i: uint64 = 0
    while i < plen:
        wp_path_buf[i] = wp_poll_buf[np + i]
        i = i + 1
    wp_path_buf[plen] = 0
    if _wp_load_path(cast[Ptr[char]](&wp_path_buf[0])) == 0:
        wp_gen_seen = g
        return 1
    # Load failed: record the gen so we don't retry a bad file every pass, and
    # leave wp_loaded clear (solid-backdrop fallback). Signal a redraw so any
    # stale image is replaced by the fallback fill.
    wp_gen_seen = g
    return 1


# Build a "#RRGGBB" C-string for one source pixel into `out` (>=8 bytes).
WP_HEX: Array[16, uint8]
WP_HEX_INIT: int32 = 0
def _wp_hex_init():
    if WP_HEX_INIT != 0:
        return
    WP_HEX_INIT = 1
    j: uint64 = 0
    while j < 10:
        WP_HEX[j] = cast[uint8](48 + j)                # '0'..'9'
        j = j + 1
    while j < 16:
        WP_HEX[j] = cast[uint8](97 + (j - 10))         # 'a'..'f'
        j = j + 1


def _wp_color_str(r: uint8, g: uint8, b: uint8, out: Ptr[uint8]):
    out[0] = 35                                        # '#'
    out[1] = WP_HEX[(r >> 4) & 15]
    out[2] = WP_HEX[r & 15]
    out[3] = WP_HEX[(g >> 4) & 15]
    out[4] = WP_HEX[g & 15]
    out[5] = WP_HEX[(b >> 4) & 15]
    out[6] = WP_HEX[b & 15]
    out[7] = 0


# Emit the image-wallpaper backdrop as a nearest-neighbour mosaic of fill
# rects stretched to the full screen. Returns 1 if it painted (caller skips
# the solid fill), 0 if no image is loaded. Each grid cell samples one source
# pixel; a solid-colour image collapses to a uniform field of identical fills.
# Byte budget reserved for the ICON + overlay layer (emitted AFTER the
# wallpaper). The mosaic fills and the icons share ONE 16384-byte scene buffer
# (HAMSCENE_CAP == kernel WSYS_SCENE_SIZE); a full 24x18 mosaic (432 fills) plus
# 16 icons overflowed it, and because icons come last the overflow SILENTLY
# DROPPED trailing icons — the "icons disappear when a background is set" bug.
# emit_wallpaper now (a) coalesces horizontally-adjacent equal-colour cells into
# one fill (a solid/gradient wallpaper — the common Control-Center case —
# collapses from 432 fills to ~1 per row), and (b) stops laying mosaic once the
# buffer grows past (CAP - WP_ICON_RESERVE), so the icon layer ALWAYS fits. Any
# rows left unpainted show the kernel root backdrop (graceful, icons preserved).
WP_ICON_RESERVE: uint64 = 6144
WP_SCENE_BUDGET: uint64 = 10240          # = 16384 - 6144 (literal: native/bare-metal globals need an integer initializer, not a BinaryExpr)

def _wp_sample_col(gx: int64, syr: uint64) -> uint64:
    # Nearest-neighbour source column for mosaic column gx; returns the byte
    # index into wp_rgb of that (col,row) sample.
    sxc: uint64 = cast[uint64](gx * cast[int64](wp_w) / WP_GRID_W)
    if sxc >= wp_w:
        sxc = wp_w - 1
    return (syr * wp_w + sxc) * 3

wp_cell_color: Array[8, uint8]
def emit_wallpaper() -> int32:
    if wp_loaded == 0 or wp_w == 0 or wp_h == 0:
        return 0
    _wp_hex_init()
    gy: int64 = 0
    while gy < WP_GRID_H:
        # Icon-budget guard: never let the mosaic crowd out the icon layer.
        if hamscene_length() >= WP_SCENE_BUDGET:
            break
        y0: int64 = gy * scr_h / WP_GRID_H
        y1: int64 = (gy + 1) * scr_h / WP_GRID_H
        if gy == WP_GRID_H - 1:
            y1 = scr_h
        syr: uint64 = cast[uint64](gy * cast[int64](wp_h) / WP_GRID_H)
        if syr >= wp_h:
            syr = wp_h - 1
        # Walk columns left-to-right, coalescing runs of identical source
        # colour into a single wide fill (huge byte win for solid/gradient).
        gx: int64 = 0
        while gx < WP_GRID_W:
            si: uint64 = _wp_sample_col(gx, syr)
            cr: uint8 = wp_rgb[si]
            cg: uint8 = wp_rgb[si + 1]
            cb: uint8 = wp_rgb[si + 2]
            gxe: int64 = gx + 1
            while gxe < WP_GRID_W:
                se: uint64 = _wp_sample_col(gxe, syr)
                if wp_rgb[se] != cr or wp_rgb[se + 1] != cg \
                        or wp_rgb[se + 2] != cb:
                    break
                gxe = gxe + 1
            x0: int64 = gx * scr_w / WP_GRID_W
            x1: int64 = gxe * scr_w / WP_GRID_W
            if gxe >= WP_GRID_W:
                x1 = scr_w
            _wp_color_str(cr, cg, cb, &wp_cell_color[0])
            hamscene_fill(cast[int32](x0), cast[int32](y0),
                          cast[int32](x1 - x0), cast[int32](y1 - y0),
                          &wp_cell_color[0])
            gx = gxe
        gy = gy + 1
    return 1


# --- icon model ------------------------------------------------------
MAX_ICONS: uint64 = 16
LABEL_CAP: uint64 = 24                # bytes stored per label (NUL-term)
ACTION_CAP: uint64 = 128             # bytes stored per action path

ic_label: Array[384, uint8]          # MAX_ICONS * LABEL_CAP
ic_label_len: Array[16, uint64]
ic_is_folder: Array[16, int32]
ic_icon_code: Array[16, int32]       # hamscene HS_ICON_* glyph code per icon
ic_action: Array[2048, uint8]        # MAX_ICONS * ACTION_CAP
# Per-icon free position (top-left of the icon CELL in window coords). A
# value of -1 means "no explicit position": the icon is laid out by the
# default left-column flow (cell_y by index). A drag-drop pins an explicit
# position, persisted to /etc/desktop.icons as two extra "|x|y" fields so it
# survives relaunch.
ic_x: Array[16, int32]
ic_y: Array[16, int32]
n_icons: uint64 = 0


def label_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&ic_label[0]) + i * LABEL_CAP)


def action_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&ic_action[0]) + i * ACTION_CAP)


def _add_icon(label: Ptr[uint8], llen: uint64, folder: int32,
              action: Ptr[uint8], alen: uint64, px: int32, py: int32,
              icon_code: int32):
    if n_icons >= MAX_ICONS:
        return
    ic_x[n_icons] = px
    ic_y[n_icons] = py
    ic_icon_code[n_icons] = icon_code
    ll: uint64 = llen
    if ll > LABEL_CAP - 1:
        ll = LABEL_CAP - 1
    dl: Ptr[uint8] = label_ptr(n_icons)
    k: uint64 = 0
    while k < ll:
        dl[k] = label[k]
        k = k + 1
    dl[ll] = 0
    ic_label_len[n_icons] = ll
    ic_is_folder[n_icons] = folder
    al: uint64 = alen
    if al > ACTION_CAP - 1:
        al = ACTION_CAP - 1
    da: Ptr[uint8] = action_ptr(n_icons)
    k = 0
    while k < al:
        da[k] = action[k]
        k = k + 1
    da[al] = 0
    n_icons = n_icons + 1


# Built-in default icon set (used when the desktop directory is
# absent/unreadable/empty, e.g. a stripped image).
def _load_defaults():
    n_icons = 0
    _add_icon(cast[Ptr[uint8]]("Files"), 5, 1,
              cast[Ptr[uint8]]("/bin/hamfmscene"), 15, -1, -1,
              hamscene_icon_code(cast[Ptr[uint8]]("system-file-manager")))
    _add_icon(cast[Ptr[uint8]]("Terminal"), 8, 0,
              cast[Ptr[uint8]]("/bin/hamtermscene"), 17, -1, -1,
              hamscene_icon_code(cast[Ptr[uint8]]("terminal")))
    _add_icon(cast[Ptr[uint8]]("Home"), 4, 1,
              cast[Ptr[uint8]]("/"), 1, -1, -1,
              hamscene_icon_code(cast[Ptr[uint8]]("system-file-manager")))


# Live-medium probe (mirrors hampanelscene): /etc/installer-medium is
# planted in the cpio ONLY by scripts/build_installer_img.sh, so it is
# present on the LIVE/installer boot and absent on every installed boot. The
# installer launcher (installer.desktop, X-Hamnix-LiveOnly=true) is surfaced
# ONLY when live. Cached (0 unknown, 1 live, 2 installed).
_desk_live_state: int32 = 0
def _desk_is_live() -> int32:
    if _desk_live_state == 0:
        fd: int32 = sys_open(cast[Ptr[char]]("/etc/installer-medium"))
        if fd >= 0:
            sys_close(fd)
            _desk_live_state = 1
        else:
            _desk_live_state = 2
    if _desk_live_state == 1:
        return 1
    return 0


# Render the icon grid from the REAL desktop directory (~/Desktop). The
# shared lib/hamfmcore directory scanner does the listing + is-dir
# classification (the SAME path the file manager uses), so a folder/file
# created on the command line shows up on the next re-scan. Each visible
# entry becomes one icon:
#   - a directory  -> folder glyph, action = its absolute path (open in FM)
#   - a *.desktop  -> parsed launcher (Name + Exec prog), document glyph
#   - a plain file -> document glyph, action = its absolute path
# Hidden entries (leading '.', which includes the .hamdesktop.pos position
# sidecar and any .keep placeholder) are skipped. Returns the icon count
# (0 -> caller falls back to _load_defaults).
desk_file_buf: Array[2048, uint8]
name_scratch: Array[128, uint8]
def _build_icons_from_fmc() -> uint64:
    n_icons = 0
    base: uint64 = 0
    if fmc_has_up_entry() != 0:                          # skip synthetic ".."
        base = 1
    r: uint64 = base
    while r < fmc_num_entries() and n_icons < MAX_ICONS:
        nl: uint64 = fmc_entry_name_copy(r, &name_scratch[0], 128)
        # Skip empty + hidden names (dotfiles, .keep, the position sidecar).
        if nl == 0 or name_scratch[0] == 46:
            r = r + 1
            continue
        if fmc_entry_is_dir(r) != 0:
            fp: Ptr[uint8] = fmc_full_path_ptr(r)
            _add_icon(&name_scratch[0], nl, 1, fp, _slen(fp), -1, -1,
                      hamscene_icon_code(
                          cast[Ptr[uint8]]("system-file-manager")))
            r = r + 1
            continue
        if desktop_name_is_entry(&name_scratch[0]) != 0:
            fp2: Ptr[uint8] = fmc_full_path_ptr(r)
            handled: int32 = 0
            fd: int32 = sys_open(cast[Ptr[char]](fp2))
            if fd >= 0:
                rn: int64 = sys_read(fd, &desk_file_buf[0], 2047)
                sys_close(fd)
                if rn > 0:
                    if desktop_parse(&desk_file_buf[0], cast[uint64](rn)) != 0:
                        # Honor X-Hamnix-LiveOnly (hide the installer launcher
                        # on an installed system). A valid-but-hidden entry is
                        # still "handled" so it is NOT re-added as a plain file.
                        if desktop_liveonly() == 0 or _desk_is_live() != 0:
                            _add_icon(desktop_name_ptr(), desktop_name_len(),
                                      0, desktop_prog_ptr(), desktop_prog_len(),
                                      -1, -1,
                                      hamscene_icon_code(desktop_icon_ptr()))
                        handled = 1
            if handled == 0:
                # Unparseable .desktop -> show it as a plain file instead.
                fp3: Ptr[uint8] = fmc_full_path_ptr(r)
                _add_icon(&name_scratch[0], nl, 0, fp3, _slen(fp3), -1, -1,
                          hamscene_icon_code(cast[Ptr[uint8]]("")))
            r = r + 1
            continue
        # Plain file.
        fp4: Ptr[uint8] = fmc_full_path_ptr(r)
        _add_icon(&name_scratch[0], nl, 0, fp4, _slen(fp4), -1, -1,
                  hamscene_icon_code(cast[Ptr[uint8]]("")))
        r = r + 1
    return n_icons


# Point the shared scanner at the desktop dir, list it, then build the icon
# model. Returns the icon count.
def _load_icons_from_dir() -> uint64:
    fmc_set_cur_path(_desk_dir())
    fmc_load_dir()
    return _build_icons_from_fmc()


# STARTUP load: scan the desktop dir, fall back to the built-in default set
# if it yields nothing, then re-apply any persisted drag positions.
def _reload_icons():
    if _load_icons_from_dir() == 0:
        _load_defaults()
    _load_positions()


# Refresh rebuild-vs-keep decision. A periodic desktop re-scan must NEVER wipe
# an already-populated icon set: a momentarily unreadable ~/Desktop (or a
# transiently empty listing) makes the scan return 0 visible entries, and the
# OLD code then fell back to _load_defaults() — collapsing the full ~10-icon set
# to the 3 built-in defaults (Files/Terminal/Home). That collapse became VISIBLE
# exactly when a wallpaper/theme apply forced a redraw (Control Center bumps the
# kernel wallpaper gen, the desktop wakes, and the SAME wake runs this periodic
# refresh) — the user-reported "clicking the default theme drops my desktop
# icons" bug. Decision (returns 1 = keep the CURRENT set, 0 = act on the scan):
#   scan_count > 0            -> rebuild to the fresh listing            (0)
#   prev_count == 0 (cold)    -> nothing was ever there, defaults ok     (0)
#   otherwise (had icons,     -> KEEP; a refresh must not wipe a         (1)
#   scan now 0)                  previously-populated desktop
# scan_failed distinguishes "dir unreadable" from "readable but empty"; on a
# refresh BOTH keep, so it does not change the outcome once prev_count > 0 — it
# is threaded through for intent and is unit-tested alongside the count logic.
def desk_refresh_should_keep(prev_count: uint64, scan_count: uint64,
                             scan_failed: int32) -> int32:
    if scan_count > 0 and scan_failed == 0:
        return 0                       # a real, successful listing -> rebuild
    if scan_count > 0:
        return 0                       # non-empty even if flagged -> rebuild
    if prev_count == 0:
        return 0                       # cold start, nothing ever there -> defaults
    return 1                           # had icons, scan now empty/unreadable -> KEEP


# REFRESH rebuild: called after fmc_refresh_if_changed() has ALREADY re-listed
# the directory (so we must NOT re-list — just rebuild the icon model from the
# current fmc entries), then re-apply positions. _build_icons_from_fmc() zeroes
# n_icons before rebuilding, so when it yields nothing the previous icon slots
# (0..prev-1) are left intact in place — restoring the count recovers the full
# set without a re-scan and WITHOUT collapsing to _load_defaults() (see
# desk_refresh_should_keep + tests/test_desktop_refresh_keep_host.ad).
def _rebuild_after_refresh():
    prev: uint64 = n_icons
    built: uint64 = _build_icons_from_fmc()
    if desk_refresh_should_keep(prev, built, 0) != 0:
        n_icons = prev
    _load_positions()


# --- layout ----------------------------------------------------------
# MATE-style: a single column of cells down the LEFT edge. Each cell holds
# a 44x38 icon centered above a label; cells stack vertically.
ICON_MARGIN_X: int32 = 18           # left margin of the icon column
ICON_TOP: int32 = 16                # y of the first cell
CELL_W: int32 = 84                  # cell footprint width (icon + label)
CELL_H: int32 = 72                  # cell footprint height
ICON_W: int32 = 44                  # icon box width
ICON_H: int32 = 38                  # icon box height
ICON_INSET_Y: int32 = 4             # icon y-offset within the cell
LABEL_Y: int32 = 48                 # label y-offset within the cell
# Bottom-panel reservation. The MATE-style panels (hampanel PANEL_H=24) overlay
# the full-screen desktop backdrop at the top and bottom. The default icon flow
# must WRAP into a new column BEFORE a cell would fall under the bottom panel (or
# off-screen), so no icon — e.g. the 12th, Video Player — is clipped.
PANEL_BOT_H: int32 = 24             # bottom panel height to keep icons clear of

sel_idx: int64 = -1
last_click_idx: int64 = -1
last_click_jif: uint64 = 0
DBL_JIF: uint64 = 8

# Press/release edge tracking (BUG 1 FIX). The compositor forwards a pointer
# line on EVERY motion event, and the button mask stays SET for the whole
# press-drag-release gesture. The old code launched on every event whose
# button bit was set (and the `sel_idx == idx` double-click shortcut re-fired
# the launch on each held-motion event) -> dragging an icon spawned the target
# app hundreds of times = a spawn storm that exhausted resources and CRASHED
# the system. We now track the button EDGE: remember whether the button was
# down on the previous event and which cell the press landed on, and only
# ACTIVATE (select / launch) on the RELEASE edge, when the cursor is still
# over the SAME cell the press started on. A held button or motion never
# re-fires; releasing off the press cell (a drag away) launches nothing.
prev_btn_down: int32 = 0       # button-1 state on the previous pointer event
press_idx: int64 = -1          # cell the current press started on (-1 = none)
last_launch_jif: uint64 = 0    # belt-and-suspenders min-interval debounce
LAUNCH_MIN_JIF: uint64 = 4     # ignore a 2nd launch within this many jiffies

# --- ICON DRAG-TO-REARRANGE state ------------------------------------
# A press over an icon arms a potential drag. Once the cursor moves past
# DRAG_THRESH px from the press point (button still held) we enter DRAG
# mode: the icon's cell follows the cursor (an offset from where in the
# cell it was grabbed) and the scene re-emits on each motion. On RELEASE
# after a drag we DROP the icon at the new position, pin it (ic_x/ic_y),
# and PERSIST the whole icon set to /etc/desktop.icons so it survives a
# relaunch. A release that never crossed the threshold is a plain click
# (launch / select), exactly as before — so launch-on-click still works.
dragging: int32 = 0            # 1 while a drag is in progress
drag_idx: int64 = -1           # icon being dragged
drag_grab_dx: int64 = 0        # cursor offset inside the cell at grab
drag_grab_dy: int64 = 0
press_x: int64 = 0             # window-local press point (threshold origin)
press_y: int64 = 0
drag_cur_x: int64 = 0          # current cursor pos (drives the ghost cell)
drag_cur_y: int64 = 0
DRAG_THRESH: int64 = 6         # px of movement that promotes a press to a drag

scr_w: int64 = 800
scr_h: int64 = 600


# How many icon cells fit in ONE column before the flow must wrap to the next
# column. The usable region runs from the first cell (ICON_TOP) down to the top
# of the bottom panel (scr_h - PANEL_BOT_H). At least one per column so a tiny
# screen never divides by zero. With scr_h=768 this is (768-24-16)/72 = 10, so
# the 12 shipped icons wrap into a 10 + 2 two-column grid — all on-screen.
def icons_per_col() -> int32:
    usable: int32 = cast[int32](scr_h) - PANEL_BOT_H - ICON_TOP
    pc: int32 = usable / CELL_H
    if pc < 1:
        pc = 1
    return pc


# The cell origin (top-left) of icon i. If the icon carries an explicit free
# position (ic_x/ic_y >= 0, set by a drag-drop), use it; otherwise lay it out in
# the default column flow: fill the left column top-to-bottom, then WRAP into
# the next column to the right once a cell would fall under the bottom panel.
# When all icons fit in one column this is identical to the old single-column
# look (col 0 for every icon).
def icon_cx(i: uint64) -> int32:
    if ic_x[i] >= 0:
        return ic_x[i]
    col: int32 = cast[int32](i) / icons_per_col()
    return ICON_MARGIN_X + col * CELL_W


def icon_cy(i: uint64) -> int32:
    if ic_y[i] >= 0:
        return ic_y[i]
    row: int32 = cast[int32](i) % icons_per_col()
    return ICON_TOP + row * CELL_H


# Procedural desktop backdrop: a soft vertical gradient (deep indigo-slate at
# the top easing into a lighter blue at the bottom) drawn as N horizontal
# bands. A modern, calm wallpaper that beats a flat 90s teal fill, and it costs
# only a handful of scene fills. Used whenever no wallpaper IMAGE is loaded.
GRAD_BANDS: int64 = 48
def emit_gradient_bg():
    _wp_hex_init()
    # A calm, modern top-lit desktop: deep navy at the top easing into a
    # cohesive azure at the bottom (palette tied to the panel accent #3584e4).
    # top #16233f (22,35,63) -> bottom #34619c (52,97,156)
    r0: int64 = 22
    g0: int64 = 35
    b0: int64 = 63
    r1: int64 = 52
    g1: int64 = 97
    b1: int64 = 156
    n: int64 = 0
    while n < GRAD_BANDS:
        y0: int64 = n * scr_h / GRAD_BANDS
        y1: int64 = (n + 1) * scr_h / GRAD_BANDS
        if n == GRAD_BANDS - 1:
            y1 = scr_h
        r: int64 = r0 + (r1 - r0) * n / (GRAD_BANDS - 1)
        g: int64 = g0 + (g1 - g0) * n / (GRAD_BANDS - 1)
        b: int64 = b0 + (b1 - b0) * n / (GRAD_BANDS - 1)
        _wp_color_str(cast[uint8](r), cast[uint8](g), cast[uint8](b),
                      &wp_cell_color[0])
        hamscene_fill(0, cast[int32](y0), cast[int32](scr_w),
                      cast[int32](y1 - y0), &wp_cell_color[0])
        n = n + 1
    # A soft luminous glow across the upper-middle for gentle depth. Feathered
    # into many thin translucent-white bands whose alpha ramps up then back
    # down (a triangular envelope) so it blends seamlessly — no hard band edge.
    gtop: int64 = scr_h / 8
    gbot: int64 = (scr_h * 5) / 8
    gspan: int64 = gbot - gtop
    gb: int64 = 20                                    # feather sub-bands
    bi: int64 = 0
    while bi < gb:
        y0: int64 = gtop + gspan * bi / gb
        y1: int64 = gtop + gspan * (bi + 1) / gb
        # triangular alpha: 0 at the ends, peak in the middle (~10)
        d: int64 = bi
        if d > gb - 1 - bi:
            d = gb - 1 - bi
        a: int64 = d * 20 / gb
        if a > 0:
            gc: Array[10, uint8]
            _wp_color_str(255, 255, 255, &gc[0])          # "#ffffff\0"
            gc[7] = WP_HEX[cast[uint8]((a >> 4) & 15)]
            gc[8] = WP_HEX[cast[uint8](a & 15)]
            gc[9] = 0
            hamscene_fill(0, cast[int32](y0), cast[int32](scr_w),
                          cast[int32](y1 - y0), &gc[0])
        bi = bi + 1


# Draw a desktop icon label as white glyphs over a soft dark outline so the
# text reads clearly on any wallpaper (light OR dark). The outline is four
# translucent-black copies offset by 1px in each direction plus a slightly
# stronger drop shadow; the crisp white glyph paints on top.
def _label_outlined(x: int32, y: int32, s: Ptr[uint8]):
    sh: Ptr[uint8] = cast[Ptr[uint8]]("#00000099")
    hamscene_glyphs(x - 1, y, s, sh)
    hamscene_glyphs(x + 1, y, s, sh)
    hamscene_glyphs(x, y - 1, s, sh)
    hamscene_glyphs(x, y + 1, s, sh)
    hamscene_glyphs(x + 1, y + 1, s, cast[Ptr[uint8]]("#000000cc"))
    hamscene_glyphs(x, y, s, cast[Ptr[uint8]]("#ffffff"))


# Glyphs per label line that fit inside CELL_W at the 8px mono advance
# ((CELL_W - 8) / 8 = 9, +1 tolerance for the 1px-margin clamp below). A line
# is centred under the icon; clamping every line to this keeps a wide label
# (e.g. "Audio Player") inside its OWN cell instead of bleeding right into the
# next column's label (the "Audio PlayeSystem Monitor" run-together, #QA).
LABEL_MAXC: uint64 = 10
LABEL_LINE_DY: int32 = 11            # baseline step between the two label lines


# Center one already-clamped label line of `n` glyphs horizontally in the cell.
def _label_line(cx: int32, ly: int32, s: Ptr[uint8], n: uint64):
    lw: int32 = cast[int32](n) * 8
    lx: int32 = cx + (CELL_W - 8 - lw) / 2
    if lx < cx - 2:
        lx = cx - 2
    _label_outlined(lx, ly, s)


# Draw an icon label clamped to the cell width. A label that fits renders on one
# centred line (unchanged look); a wider one WRAPS onto two lines, breaking at
# the last space that fits the first line (else a hard break at the cell edge),
# and the second line is ".."-ellipsised if it still overruns. Either way no
# glyph crosses the cell boundary, so adjacent-column labels never overlap.
def _emit_icon_label(cx: int32, cy: int32, s: Ptr[uint8], llen: uint64):
    ly: int32 = cy + LABEL_Y
    if llen <= LABEL_MAXC:
        _label_line(cx, ly, s, llen)
        return
    # Find a break: the last space at/within the first-line budget.
    brk: uint64 = 0
    j: uint64 = 1
    while j <= LABEL_MAXC and j < llen:
        if s[j] == 32:
            brk = j
        j = j + 1
    skip: uint64 = 0
    if brk == 0:
        brk = LABEL_MAXC                 # no space fits: hard-break at the edge
    else:
        skip = 1                         # consume the break space
    # Line 1: [0, brk), clamped to the budget.
    line1: Array[16, uint8]
    n1: uint64 = brk
    if n1 > LABEL_MAXC:
        n1 = LABEL_MAXC
    k: uint64 = 0
    while k < n1:
        line1[k] = s[k]
        k = k + 1
    line1[n1] = 0
    _label_line(cx, ly, &line1[0], n1)
    # Line 2: the remainder, ".."-ellipsised if it overruns the budget.
    line2: Array[16, uint8]
    start: uint64 = brk + skip
    n2: uint64 = llen - start
    trunc: int32 = 0
    if n2 > LABEL_MAXC:
        n2 = LABEL_MAXC - 2
        trunc = 1
    k = 0
    while k < n2:
        line2[k] = s[start + k]
        k = k + 1
    if trunc != 0:
        line2[n2] = 46
        line2[n2 + 1] = 46
        n2 = n2 + 2
    line2[n2] = 0
    _label_line(cx, ly + LABEL_LINE_DY, &line2[0], n2)


# --- scene emit ------------------------------------------------------
def emit_scene(wid: int32):
    hamscene_begin()
    # Desktop backdrop. If a wallpaper image is loaded (Settings wrote a PPM
    # and set it via /dev/wsys/ctl `wallpaper`), paint it as a nearest-neighbour
    # mosaic stretched to the screen; the icons below render ON TOP of it.
    # Otherwise fall back to the same teal the kernel root backdrop uses
    # (#205060) so the desktop blends with any uncovered compositor region.
    if emit_wallpaper() == 0:
        emit_gradient_bg()
    i: uint64 = 0
    while i < n_icons:
        cx: int32 = icon_cx(i)
        cy: int32 = icon_cy(i)
        # While this icon is being dragged its cell follows the cursor.
        if dragging != 0 and cast[int64](i) == drag_idx:
            cx = cast[int32](drag_cur_x - drag_grab_dx)
            cy = cast[int32](drag_cur_y - drag_grab_dy)
        # Rounded selection highlight behind the selected cell (KDE-ish): a
        # light rounded ring around a rounded accent fill.
        if sel_idx >= 0 and cast[uint64](sel_idx) == i:
            hamscene_roundrect(cx - 4, cy - 2, CELL_W, CELL_H, 5,
                               cast[Ptr[uint8]]("#9cc0ec"))
            hamscene_roundrect(cx - 3, cy - 1, CELL_W - 2, CELL_H - 2, 4,
                               cast[Ptr[uint8]]("#3584e4"))
        # Icon box, centered horizontally in the cell.
        ix: int32 = cx + (CELL_W - 8 - ICON_W) / 2
        iy: int32 = cy + ICON_INSET_Y
        hamscene_icon_draw(ix, iy, ICON_W, ICON_H, ic_icon_code[i])
        # Label below the icon: centred under the icon box, clamped to the cell
        # width (wraps/ellipsises so it never bleeds into the next column) and
        # drawn with a soft dark OUTLINE so white text stays legible on ANY
        # wallpaper (a bright image would otherwise wash out plain white glyphs).
        _emit_icon_label(cx, cy, label_ptr(i), ic_label_len[i])
        i = i + 1
    # Right-click context menu / New Folder prompt / status overlays paint
    # LAST, on top of the backdrop + icons.
    _paint_desk_overlays()
    hamscene_commit(wid)


# Map a window-local point to an icon cell index, or -1. Each icon now has
# its own cell rect (column-flow OR a pinned free position), so we hit-test
# every cell rather than assuming a single column. Iterate TOP-most last so
# a later icon dropped over an earlier one wins the hit (matches paint order).
def cell_at(lx: int64, ly: int64) -> int64:
    hit: int64 = -1
    i: uint64 = 0
    while i < n_icons:
        cx: int64 = cast[int64](icon_cx(i)) - 4
        cy: int64 = cast[int64](icon_cy(i)) - 2
        if lx >= cx and lx < cx + cast[int64](CELL_W) and \
           ly >= cy and ly < cy + cast[int64](CELL_H):
            hit = cast[int64](i)
        i = i + 1
    return hit


# Run icon `i`'s action: spawn a /bin program, or open a directory path in
# the file manager. Uses the SAME lib/p9.ad spawn() the panel launches with
# (detached stdio -2/-2 so the child opens its own window).
launch_argv: Array[3, uint64]
launch_path: Array[160, uint8]
def _run_action(i: uint64):
    src: Ptr[uint8] = action_ptr(i)
    # Decide: a path under /bin/ is a program to spawn directly; anything
    # else is a directory we hand to the file manager.
    is_bin: int32 = 0
    if src[0] == 47 and src[1] == 98 and src[2] == 105 and src[3] == 110 \
            and src[4] == 47:                            # "/bin/"
        is_bin = 1
    if is_bin != 0:
        # Copy the action into a stable buffer (argv[0] = the prog path).
        k: uint64 = 0
        while src[k] != 0 and k < 159:
            launch_path[k] = src[k]
            k = k + 1
        launch_path[k] = 0
        launch_argv[0] = cast[uint64](&launch_path[0])
        launch_argv[1] = 0
        # DETACHED: the desktop never wait4s — a plain spawn leaks each
        # launched app as an un-reapable zombie (see spawn_detached).
        pid: int32 = spawn_detached(cast[Ptr[char]](&launch_path[0]),
                           &launch_argv[0], -2, -2, cast[Ptr[uint64]](0))
        if pid >= 0:
            _writeall(1, cast[Ptr[uint8]]("[hamdesktop] launched "))
            _writeall(1, &launch_path[0])
            _writeall(1, cast[Ptr[uint8]]("\n"))
    else:
        # A directory: open it in the file manager. (The FM lists '/'
        # today; this still brings up a browseable window.)
        launch_argv[0] = cast[uint64](cast[Ptr[uint8]]("/bin/hamfmscene"))
        launch_argv[1] = 0
        pid2: int32 = spawn_detached(cast[Ptr[char]]("/bin/hamfmscene"),
                            &launch_argv[0], -2, -2, cast[Ptr[uint64]](0))
        if pid2 >= 0:
            _writeall(1, cast[Ptr[uint8]]("[hamdesktop] opened dir in FM\n"))


# Append a decimal int32 (with leading '-' if negative) to out at p; ret new p.
def _emit_i32(out: Ptr[uint8], p: uint64, v: int32) -> uint64:
    if v < 0:
        out[p] = 45                                       # '-'
        p = p + 1
        return p + _u64_to_dec(cast[uint64](0 - v), &out[p])
    return p + _u64_to_dec(cast[uint64](v), &out[p])


# --- drag-position persistence (sidecar in the desktop dir) ----------
# The icon IDENTITY (which icons exist) comes from the desktop directory,
# so the only per-icon state we persist across re-scans/relaunches is a
# drag-pinned POSITION. It lives in a hidden sidecar ~/Desktop/.hamdesktop.pos
# (leading '.', so the icon scan skips it) as one "label|x|y" line per pinned
# icon. Written to the WRITABLE home dir (not the read-only cpio /etc), so a
# drag actually persists. Positions are keyed by LABEL and re-applied after
# every directory (re)load, so a rearrange survives a CLI-driven re-scan.
pos_path_buf: Array[128, uint8]
def _pos_path() -> Ptr[uint8]:
    d: Ptr[uint8] = _desk_dir()
    p: uint64 = 0
    while d[p] != 0 and p < 100:
        pos_path_buf[p] = d[p]
        p = p + 1
    if p == 0 or pos_path_buf[p - 1] != 47:              # ensure trailing '/'
        pos_path_buf[p] = 47
        p = p + 1
    suf: Ptr[uint8] = cast[Ptr[uint8]](".hamdesktop.pos")
    k: uint64 = 0
    while suf[k] != 0:
        pos_path_buf[p] = suf[k]
        p = p + 1
        k = k + 1
    pos_path_buf[p] = 0
    return &pos_path_buf[0]


# Persist each icon's CURRENT cell origin (resolved through icon_cx/icon_cy)
# as "label|x|y". Written whenever a drag drops an icon.
save_buf: Array[2560, uint8]
def _save_positions():
    p: uint64 = 0
    i: uint64 = 0
    while i < n_icons:
        lp: Ptr[uint8] = label_ptr(i)
        k: uint64 = 0
        while lp[k] != 0:
            save_buf[p] = lp[k]
            p = p + 1
            k = k + 1
        save_buf[p] = 124                                 # '|'
        p = p + 1
        p = _emit_i32(&save_buf[0], p, icon_cx(i))
        save_buf[p] = 124
        p = p + 1
        p = _emit_i32(&save_buf[0], p, icon_cy(i))
        save_buf[p] = 10                                  # '\n'
        p = p + 1
        i = i + 1
    fd: int32 = sys_open_write(cast[Ptr[char]](_pos_path()))
    if fd < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamdesktop] WARN cannot persist positions\n"))
        return
    sys_write(fd, &save_buf[0], p)
    sys_close(fd)
    _writeall(1, cast[Ptr[uint8]]("[hamdesktop] icon positions persisted\n"))


# Find the icon whose label exactly equals lbl[0..llen) ; returns its index
# or -1. Used to re-attach a persisted position to a freshly-scanned icon.
def _icon_by_label(lbl: Ptr[uint8], llen: uint64) -> int64:
    i: uint64 = 0
    while i < n_icons:
        lp: Ptr[uint8] = label_ptr(i)
        k: uint64 = 0
        while k < llen and lp[k] != 0 and lp[k] == lbl[k]:
            k = k + 1
        if k == llen and lp[k] == 0:
            return cast[int64](i)
        i = i + 1
    return -1


# Read the position sidecar and pin each matching icon's ic_x/ic_y. Absent
# sidecar (fresh boot) -> icons keep the default left-column flow.
pos_buf: Array[2560, uint8]
def _load_positions():
    fd: int32 = sys_open(cast[Ptr[char]](_pos_path()))
    if fd < 0:
        return
    total: uint64 = 0
    while total < 2559:
        r: int64 = sys_read(fd, &pos_buf[total], 2559 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    ls: uint64 = 0
    i: uint64 = 0
    while i <= total:
        atend: int32 = 0
        if i == total:
            atend = 1
        if atend == 1 or pos_buf[i] == 10:
            if i > ls:
                # Line [ls, i): "label|x|y".
                j: uint64 = ls
                while j < i and pos_buf[j] != 124:
                    j = j + 1
                if j < i:                                 # found first '|'
                    llen: uint64 = j - ls
                    xs: uint64 = j + 1
                    xe: uint64 = xs
                    while xe < i and pos_buf[xe] != 124:
                        xe = xe + 1
                    if xe < i:                            # found second '|'
                        px: int32 = _parse_i32(&pos_buf[xs], xe - xs)
                        ys: uint64 = xe + 1
                        ye: uint64 = ys
                        while ye < i and pos_buf[ye] != 13 and pos_buf[ye] != 10:
                            ye = ye + 1
                        py: int32 = _parse_i32(&pos_buf[ys], ye - ys)
                        idx: int64 = _icon_by_label(&pos_buf[ls], llen)
                        if idx >= 0 and px >= 0 and py >= 0:
                            ic_x[cast[uint64](idx)] = px
                            ic_y[cast[uint64](idx)] = py
            ls = i + 1
        i = i + 1


# ---- DRAG-FROM-MENU DESKTOP DROP (#327) -----------------------------------
# hamappmenu writes `<exec> <label>\n` to /tmp/hamnix-panel-drop when an app is
# DRAGGED out of the Applications menu. Because the menu is a SEPARATE window
# and the compositor delivers no cross-window drag stream (devwsys routes
# motion/release to the window under the cursor only), the desktop cannot see
# the drag until the cursor is over IT — so it treats the sidecar as an OFFER
# and COMMITS it on its OWN button RELEASE, at the release point: it writes a
# real ~/Desktop/<label>.desktop launcher (per #270 desktop icons are real
# .desktop files), pins the new icon at the drop coordinate, and consumes the
# offer. While an offer is pending the normal icon click/drag path is
# suppressed. TTL-guarded so an abandoned drag can't wedge desktop clicks.
drop_active:   int32 = 0
drop_exec:     Array[64, uint8]
drop_label:    Array[24, uint8]
drop_seen_jif: uint64 = 0
DROP_TTL_JIF:  uint64 = 48
drop_sidebuf:  Array[128, uint8]
drop_entrybuf: Array[256, uint8]
drop_pathbuf:  Array[160, uint8]


def _drop_copytok(buf: Ptr[uint8], s: uint64, e: uint64, dst: Ptr[uint8],
                  maxn: uint64):
    k: uint64 = 0
    i: uint64 = s
    while i < e and k + 1 < maxn:
        dst[k] = buf[i]
        k = k + 1
        i = i + 1
    dst[k] = 0


def _consume_drop_sidecar():
    tfd: int32 = sys_open_write(cast[Ptr[char]]("/tmp/hamnix-panel-drop"))
    if tfd >= 0:
        sys_close(tfd)


# Refresh the pending drag-offer state from the sidecar (mirrors the panel's
# _poll_panel_offer): arm drop_active on a fresh record, clear it when the
# sidecar empties (consumed by us or the panel), expire a stale offer.
def _poll_desk_offer():
    fd: int32 = sys_open(cast[Ptr[char]]("/tmp/hamnix-panel-drop"))
    n: int64 = 0
    if fd >= 0:
        n = sys_read(fd, &drop_sidebuf[0], 127)
        sys_close(fd)
    if n <= 0:
        drop_active = 0
        return
    cap: uint64 = cast[uint64](n)
    i: uint64 = 0
    while i < cap and (drop_sidebuf[i] == 32 or drop_sidebuf[i] == 9 or drop_sidebuf[i] == 10):
        i = i + 1
    exs: uint64 = i
    while i < cap and drop_sidebuf[i] != 32 and drop_sidebuf[i] != 9 and drop_sidebuf[i] != 10:
        i = i + 1
    exe: uint64 = i
    while i < cap and (drop_sidebuf[i] == 32 or drop_sidebuf[i] == 9):
        i = i + 1
    lbs: uint64 = i
    while i < cap and drop_sidebuf[i] != 32 and drop_sidebuf[i] != 9 and drop_sidebuf[i] != 10:
        i = i + 1
    lbe: uint64 = i
    if exe <= exs:
        drop_active = 0
        return
    _drop_copytok(&drop_sidebuf[0], exs, exe, &drop_exec[0], 64)
    if lbe > lbs:
        _drop_copytok(&drop_sidebuf[0], lbs, lbe, &drop_label[0], 24)
    else:
        drop_label[0] = 97                      # 'a'
        drop_label[1] = 112                     # 'p'
        drop_label[2] = 112                     # 'p'
        drop_label[3] = 0
    now: uint64 = sys_get_jiffies()
    if drop_active == 0:
        drop_active = 1
        drop_seen_jif = now
    elif now - drop_seen_jif > DROP_TTL_JIF:
        _consume_drop_sidecar()
        drop_active = 0


# Build "<DESK_DIR>/<drop_label>.desktop" into drop_pathbuf.
def _desk_drop_path():
    d: Ptr[uint8] = _desk_dir()
    p: uint64 = 0
    while d[p] != 0 and p < 110:
        drop_pathbuf[p] = d[p]
        p = p + 1
    if p == 0 or drop_pathbuf[p - 1] != 47:
        drop_pathbuf[p] = 47
        p = p + 1
    k: uint64 = 0
    while drop_label[k] != 0 and p < 150:
        drop_pathbuf[p] = drop_label[k]
        p = p + 1
        k = k + 1
    suf: Ptr[uint8] = cast[Ptr[uint8]](".desktop")
    k = 0
    while suf[k] != 0:
        drop_pathbuf[p] = suf[k]
        p = p + 1
        k = k + 1
    drop_pathbuf[p] = 0


# Commit the pending offer as a desktop launcher at the release point (bx,by).
# Writes the real .desktop file, adds + pins the icon, persists, consumes the
# offer. Returns 1 if a launcher was created.
def _commit_desk_drop(bx: int64, by: int64) -> int32:
    if drop_active == 0:
        return 0
    # 1) Write the freedesktop .desktop launcher into the (writable) home dir.
    body: uint64 = dp_desktop_entry(&drop_entrybuf[0], &drop_label[0],
                                    &drop_exec[0])
    _desk_drop_path()
    fd: int32 = sys_open_write(cast[Ptr[char]](&drop_pathbuf[0]))
    if fd >= 0:
        sys_write(fd, &drop_entrybuf[0], body)
        sys_close(fd)
    # 2) Add the icon in-memory at the DROP point + pin so the next dir re-scan
    #    (which re-reads the .desktop we just wrote) re-attaches the position.
    px: int32 = cast[int32](bx)
    py: int32 = cast[int32](by)
    if px < 0:
        px = 0
    if py < 0:
        py = 0
    _add_icon(&drop_label[0], _slen(&drop_label[0]), 0,
              &drop_exec[0], _slen(&drop_exec[0]), px, py,
              hamscene_icon_code(cast[Ptr[uint8]]("application-x-executable")))
    _save_positions()
    _consume_drop_sidecar()
    drop_active = 0
    return 1


# Parse one event line "m <x> <y> <buttons> ..." -> 1 + fills *bx/*by/*bbtn.
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                             # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc = acc * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc = 0 - acc
        vals[v] = acc
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1


# =====================================================================
# RIGHT-CLICK DESKTOP CONTEXT MENU (MATE / Caja-desktop parity)
# =====================================================================
#
# A right-click (button bit1, value 2) on the DESKTOP BACKDROP opens an
# in-scene context menu — the SAME pattern the file manager established
# (user/hamfmscene.ad): the menu is drawn into the desktop's OWN scene with
# real glyph labels, bracketed by the same hamscene_begin/commit as the icon
# layer, because the panel's kernel /dev/wsys/ctxmenu path only paints
# label-less placeholder bars. Items (all do something REAL):
#
#   Open Terminal      -> spawn /bin/hamtermscene (a new terminal window)
#   New Folder         -> inline name prompt, then native fmc_mkdir() in the
#                         desktop working dir (DESK_DIR, a writable tmpfs path)
#   Open File Manager  -> spawn /bin/hamfmscene
#   ---- separator ----
#   Change Background  -> spawn /bin/hamctl (the Control Center; its Appearance
#                         capplet is the real wallpaper picker — clicking a
#                         swatch writes the PPM via /dev/wsys/ctl and this
#                         desktop's _wp_poll_kernel picks it up)
#
# Selecting New Folder opens an inline text-entry prompt (keys come from
# /dev/wsys/<wid>/keys, exactly like the FM). All ops are real; there are NO
# dead entries.

# The desktop directory. This is BOTH the icon source (scanned for
# .desktop launchers + files/folders) AND the New Folder target, so a
# folder created from the right-click menu lands where `ls ~/Desktop`
# shows it and the periodic re-scan picks it up. The live user is `live`
# with HOME=/home/live (etc/passwd), so the desktop dir is
# /home/live/Desktop — a writable home directory (unlike the read-only
# cpio root `/`). Provisioned at build time (build_initramfs.py plants the
# /etc/skel/Desktop/*.desktop launcher template there).
DESK_DIR: Array[64, uint8]
DESK_DIR_INIT: int32 = 0


def _desk_dir() -> Ptr[uint8]:
    if DESK_DIR_INIT == 0:
        DESK_DIR_INIT = 1
        src: Ptr[uint8] = cast[Ptr[uint8]]("/home/live/Desktop")
        i: uint64 = 0
        while src[i] != 0:
            DESK_DIR[i] = src[i]
            i = i + 1
        DESK_DIR[i] = 0
    return &DESK_DIR[0]


# --- menu state ------------------------------------------------------
menu_open: int32 = 0
menu_x: int32 = 0
menu_y: int32 = 0
menu_hover: int32 = -1
MENU_ITEM_H: int32 = 18
MENU_W: int32 = 150

# Action codes / row order.
DACT_TERMINAL:  int32 = 0
DACT_NEWFOLDER: int32 = 1
DACT_FILEMGR:   int32 = 2
DACT_SEP:       int32 = 3        # non-selectable separator row
DACT_BG:        int32 = 4

desk_rows: Array[6, int32]
desk_nrows: int32 = 0
prev_rbtn: int32 = 0            # right-button edge state


def _desk_menu_label(act: int32) -> Ptr[uint8]:
    if act == DACT_TERMINAL:
        return cast[Ptr[uint8]]("Open Terminal")
    if act == DACT_NEWFOLDER:
        return cast[Ptr[uint8]]("New Folder")
    if act == DACT_FILEMGR:
        return cast[Ptr[uint8]]("Open File Manager")
    if act == DACT_BG:
        return cast[Ptr[uint8]]("Change Background")
    return cast[Ptr[uint8]]("")


# --- inline New Folder name prompt -----------------------------------
prompt_open: int32 = 0
prompt_buf: Array[64, uint8]
prompt_len: uint64 = 0

# Transient status line (op feedback), bottom-left of the screen.
dstatus_buf: Array[64, uint8]
dstatus_show: int32 = 0


def _dset_status(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 63:
        dstatus_buf[i] = s[i]
        i = i + 1
    dstatus_buf[i] = 0
    dstatus_show = 1
    _writeall(1, cast[Ptr[uint8]]("[hamdesktop] op: "))
    _writeall(1, &dstatus_buf[0])
    _writeall(1, cast[Ptr[uint8]]("\n"))


def _open_desk_menu(x: int64, y: int64):
    menu_open = 1
    menu_hover = -1
    menu_x = cast[int32](x)
    menu_y = cast[int32](y)
    desk_rows[0] = DACT_TERMINAL
    desk_rows[1] = DACT_NEWFOLDER
    desk_rows[2] = DACT_FILEMGR
    desk_rows[3] = DACT_SEP
    desk_rows[4] = DACT_BG
    desk_nrows = 5
    _writeall(1, cast[Ptr[uint8]]("[hamdesktop] ctxmenu open\n"))


def _close_desk_menu():
    menu_open = 0
    menu_hover = -1


# Clamp the menu box inside the screen.
def _desk_menu_box(bx: Ptr[int32], by: Ptr[int32]):
    mx: int32 = menu_x
    my: int32 = menu_y
    mh: int32 = desk_nrows * MENU_ITEM_H + 2
    if mx + MENU_W > cast[int32](scr_w):
        mx = cast[int32](scr_w) - MENU_W
    if mx < 0:
        mx = 0
    if my + mh > cast[int32](scr_h):
        my = cast[int32](scr_h) - mh
    if my < 0:
        my = 0
    bx[0] = mx
    by[0] = my


# Map a click in screen coords to a menu row index, or -1.
def _desk_menu_row_at(x: int64, y: int64) -> int32:
    bx: int32 = 0
    by: int32 = 0
    _desk_menu_box(&bx, &by)
    if x < cast[int64](bx) or x >= cast[int64](bx + MENU_W):
        return -1
    rel: int64 = y - cast[int64](by + 1)
    if rel < 0:
        return -1
    row: int32 = cast[int32](rel / cast[int64](MENU_ITEM_H))
    if row < 0 or row >= desk_nrows:
        return -1
    return row


# Spawn a /bin program detached (its own window), same as _run_action.
spawn_path: Array[40, uint8]
spawn_argv: Array[2, uint64]
def _spawn_bin(path: Ptr[uint8]):
    k: uint64 = 0
    while path[k] != 0 and k < 39:
        spawn_path[k] = path[k]
        k = k + 1
    spawn_path[k] = 0
    spawn_argv[0] = cast[uint64](&spawn_path[0])
    spawn_argv[1] = 0
    pid: int32 = spawn_detached(cast[Ptr[char]](&spawn_path[0]), &spawn_argv[0],
                       -2, -2, cast[Ptr[uint64]](0))
    if pid >= 0:
        _writeall(1, cast[Ptr[uint8]]("[hamdesktop] launched "))
        _writeall(1, &spawn_path[0])
        _writeall(1, cast[Ptr[uint8]]("\n"))


# Run the action for menu row `row`. Returns 1 if the scene changed.
def _desk_menu_dispatch(row: int32) -> int32:
    act: int32 = desk_rows[row]
    if act == DACT_SEP:
        return 0                          # separator is not selectable
    _close_desk_menu()
    if act == DACT_TERMINAL:
        _spawn_bin(cast[Ptr[uint8]]("/bin/hamtermscene"))
        return 1
    if act == DACT_FILEMGR:
        _spawn_bin(cast[Ptr[uint8]]("/bin/hamfmscene"))
        return 1
    if act == DACT_BG:
        _spawn_bin(cast[Ptr[uint8]]("/bin/hamctl"))
        return 1
    if act == DACT_NEWFOLDER:
        prompt_open = 1
        prompt_len = 0
        prompt_buf[0] = 0
        return 1
    return 1


# Commit the New Folder prompt: native mkdir in the desktop dir + feedback.
def _commit_new_folder() -> int32:
    prompt_open = 0
    if prompt_len == 0:
        return 1
    fmc_set_cur_path(_desk_dir())
    if fmc_mkdir(&prompt_buf[0]) != 0:
        _dset_status(cast[Ptr[uint8]]("Folder created"))
    else:
        _dset_status(cast[Ptr[uint8]]("New Folder failed (no write?)"))
    return 1


# A printable byte appends; Backspace deletes; Enter commits; ESC cancels.
def _desk_prompt_key(code: int32) -> int32:
    if code == 27:                                  # ESC
        prompt_open = 0
        return 1
    if code == 10 or code == 13:                    # Enter
        return _commit_new_folder()
    if code == 8 or code == 127:                    # Backspace
        if prompt_len > 0:
            prompt_len = prompt_len - 1
            prompt_buf[prompt_len] = 0
        return 1
    if code >= 32 and code < 127:
        if prompt_len < 62:
            prompt_buf[prompt_len] = cast[uint8](code)
            prompt_len = prompt_len + 1
            prompt_buf[prompt_len] = 0
        return 1
    return 0


# Drain one /keys read chunk into the active prompt. Lines are
# "<type> <code>\n"; type 'd' (100) = press. Returns 1 if scene changed.
dkbuf: Array[256, uint8]
def _desk_drain_keys(n: uint64) -> int32:
    changed: int32 = 0
    i: uint64 = 0
    while i < n:
        t: uint8 = dkbuf[i]
        i = i + 1
        if i < n and dkbuf[i] == 32:
            i = i + 1
        code: int32 = 0
        have: int32 = 0
        neg: int32 = 0
        if i < n and dkbuf[i] == 45:
            neg = 1
            i = i + 1
        while i < n and dkbuf[i] >= 48 and dkbuf[i] <= 57:
            code = code * 10 + cast[int32](dkbuf[i]) - 48
            i = i + 1
            have = 1
        while i < n and dkbuf[i] != 10:
            i = i + 1
        if i < n:
            i = i + 1
        if t != 100 or have == 0:
            continue
        if neg != 0:
            code = 0 - code
        if prompt_open != 0:
            if _desk_prompt_key(code) != 0:
                changed = 1
    return changed


# --- overlay paint: menu, prompt, status (called inside emit_scene) ---
def _paint_desk_overlays():
    if dstatus_show != 0:
        hamscene_fill(0, cast[int32](scr_h) - 16, 220, 16,
                      cast[Ptr[uint8]]("#222a3c"))
        hamscene_glyphs(6, cast[int32](scr_h) - 13, &dstatus_buf[0],
                        cast[Ptr[uint8]]("#e8ecf6"))
    if menu_open != 0:
        bx: int32 = 0
        by: int32 = 0
        _desk_menu_box(&bx, &by)
        mh: int32 = desk_nrows * MENU_ITEM_H + 2
        # Rounded context-menu card: dark border ring + inset face.
        hamscene_roundrect(bx, by, MENU_W, mh, 6, cast[Ptr[uint8]]("#11151c"))
        hamscene_roundrect(bx + 1, by + 1, MENU_W - 2, mh - 2, 5,
                           cast[Ptr[uint8]]("#283040"))
        i: int32 = 0
        while i < desk_nrows:
            iy: int32 = by + 1 + i * MENU_ITEM_H
            if desk_rows[i] == DACT_SEP:
                hamscene_line(bx + 4, iy + MENU_ITEM_H / 2,
                              bx + MENU_W - 4, iy + MENU_ITEM_H / 2, 1,
                              cast[Ptr[uint8]]("#56607a"))
            else:
                if i == menu_hover:
                    hamscene_fill(bx + 1, iy, MENU_W - 2, MENU_ITEM_H,
                                  cast[Ptr[uint8]]("#566e96"))
                hamscene_glyphs(bx + 8, iy + 5, _desk_menu_label(desk_rows[i]),
                                cast[Ptr[uint8]]("#f0f3fb"))
            i = i + 1
    if prompt_open != 0:
        pw: int32 = 240
        ph: int32 = 56
        px: int32 = (cast[int32](scr_w) - pw) / 2
        py: int32 = (cast[int32](scr_h) - ph) / 2
        if px < 0:
            px = 0
        if py < 0:
            py = 0
        hamscene_fill(px, py, pw, ph, cast[Ptr[uint8]]("#eef0f4"))
        hamscene_rect(px, py, pw, ph, cast[Ptr[uint8]]("#3584e4"))
        hamscene_glyphs_bold(px + 8, py + 6,
                             cast[Ptr[uint8]]("New Folder:"),
                             cast[Ptr[uint8]]("#1a2840"))
        hamscene_fill(px + 8, py + 24, pw - 16, 16, cast[Ptr[uint8]]("#ffffff"))
        hamscene_rect(px + 8, py + 24, pw - 16, 16, cast[Ptr[uint8]]("#888888"))
        hamscene_glyphs(px + 12, py + 28, &prompt_buf[0],
                        cast[Ptr[uint8]]("#101010"))
        cxp: int32 = px + 12 + cast[int32](prompt_len) * 8
        hamscene_line(cxp, py + 26, cxp, py + 38, 1,
                      cast[Ptr[uint8]]("#101010"))
        hamscene_glyphs(px + 8, py + 42,
                        cast[Ptr[uint8]]("Enter=OK  Esc=Cancel"),
                        cast[Ptr[uint8]]("#555555"))


# --- demo self-drive -------------------------------------------------
# `hamdesktop --demo` scripts the right-click menu + New Folder op so a
# headless screendump can prove the feature WITHOUT live pointer/key
# injection (non-functional under OVMF/KVM). It drives the SAME code paths
# the live right-click + dispatch use — it just supplies the trigger.
demo_mode: int32 = 0
demo_step: int32 = 0
demo_tick: uint64 = 0
demo_wid: int32 = 0


# The demo CYCLES through 4 visible phases on a slow cadence and then REPEATS,
# holding each state long enough (~18 loop iterations) that the headless
# screendump sweep reliably lands on the menu AND the prompt, not just the
# final "Folder created" state. Each phase re-emits the scene so the captured
# frame shows it.
DEMO_HOLD: uint64 = 18
DEMO_PHASES: int32 = 4
def _demo_advance():
    demo_tick = demo_tick + 1
    phase: int32 = cast[int32]((demo_tick / DEMO_HOLD) % cast[uint64](DEMO_PHASES))
    if phase == demo_step:
        return
    demo_step = phase
    if demo_step == 0:
        # PHASE 0: plain backdrop (menu/prompt closed) — the resting state.
        _close_desk_menu()
        prompt_open = 0
        emit_scene(demo_wid)
    elif demo_step == 1:
        # PHASE 1: open the desktop context menu over empty backdrop. Shows
        # all five real menu rows with glyph labels + the separator.
        prompt_open = 0
        _open_desk_menu(160, 120)
        emit_scene(demo_wid)
    elif demo_step == 2:
        # PHASE 2: pick New Folder -> inline name prompt, prefilled "dktop".
        _close_desk_menu()
        prompt_open = 1
        prompt_buf[0] = 100       # d
        prompt_buf[1] = 107       # k
        prompt_buf[2] = 116       # t
        prompt_buf[3] = 111       # o
        prompt_buf[4] = 112       # p
        prompt_buf[5] = 0
        prompt_len = 5
        emit_scene(demo_wid)
    elif demo_step == 3:
        # PHASE 3: commit -> real fmc_mkdir in /tmp (status: "Folder created").
        _commit_new_folder()
        emit_scene(demo_wid)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc > 1:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        # Host test hook: "--scene-dump <file>" builds the desktop scene and
        # writes the raw display list, then exits — no /dev/wsys, no loop.
        if a[0] == 45 and a[1] == 45 and a[2] == 115 and a[3] == 99:  # "--sc"
            if argc > 2:
                return _scene_dump(cast[Ptr[char]](argv[2]))
            return 2
        if a[0] == 45 and a[1] == 45 and a[2] == 100:    # "--d"(emo)
            demo_mode = 1
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)

    sw: int64 = 800
    sh: int64 = 600
    _screen_dims(&sw, &sh)
    scr_w = sw
    scr_h = sh

    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamdesktop] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp: Array[64, uint8]
    keysp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))
    demo_wid = wid

    # Geometry. The REAL desktop is a full-screen backdrop pinned at the
    # screen origin. In --demo mode it is instead a normal decorated, RAISED
    # window so the self-driven context menu is visible ON TOP of the live
    # desktop for the headless screendump (a background-pinned demo would be
    # buried under every app window).
    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        if demo_mode != 0:
            _writeall(cfd, cast[Ptr[uint8]]("geometry 60 60 520 380\n"))
        else:
            geo: Array[64, uint8]
            gp: uint64 = 0
            pre: Ptr[uint8] = cast[Ptr[uint8]]("geometry 0 0 ")
            a: uint64 = 0
            while pre[a] != 0:
                geo[gp] = pre[a]
                gp = gp + 1
                a = a + 1
            gp = gp + _u64_to_dec(cast[uint64](sw), &geo[gp])
            geo[gp] = 32
            gp = gp + 1
            gp = gp + _u64_to_dec(cast[uint64](sh), &geo[gp])
            geo[gp] = 10
            gp = gp + 1
            sys_write(cfd, &geo[0], gp)
        sys_close(cfd)
    if demo_mode != 0:
        # Demo: a decorated, raised, titled window (NOT a pinned backdrop) so
        # the menu paints visibly above the live desktop.
        scr_w = 520
        scr_h = 380
        cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
        if cfd2 >= 0:
            _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
            sys_close(cfd2)
        cfdz: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
        if cfdz >= 0:
            _writeall(cfdz, cast[Ptr[uint8]]("z 9\n"))
            sys_close(cfdz)
        cfdt: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
        if cfdt >= 0:
            _writeall(cfdt, cast[Ptr[uint8]]("title Desktop\n"))
            sys_close(cfdt)
    else:
        # Undecorated (it IS the backdrop, no titlebar).
        cfd2b: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
        if cfd2b >= 0:
            _writeall(cfd2b, cast[Ptr[uint8]]("decorate 0\n"))
            sys_close(cfd2b)
        # PIN as the BACKGROUND: forces this full-screen window to the reserved
        # lowest z AND marks it pinned so the compositor NEVER raises it.
        # Without the pin, a content press (clicking the desktop or a desktop
        # icon) raised the full-screen backdrop above the panel + every app
        # window, burying them all = the "all windows vanish on desktop click"
        # bug. `background 1` subsumes the old `z 0`.
        cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
        if cfd3 >= 0:
            _writeall(cfd3, cast[Ptr[uint8]]("background 1\n"))
            sys_close(cfd3)
    # The desktop is the backdrop, not a taskbar app: no title (so the
    # panel's window-list does not list it).

    # Load the icon set from the REAL desktop directory (~/Desktop), falling
    # back to the built-in default set if empty/unreadable, then apply any
    # persisted drag positions.
    _reload_icons()

    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hamdesktop] scene window ready\n"))

    # SELF-HEAL re-emit. The desktop is a STATIC backdrop: it emits its scene
    # once here and then only on a real change (input / wallpaper). But the
    # single startup commit RACES the compositor — if a full-screen present
    # composited this window before the scene commit landed (or an early
    # geometry/background ctl write re-allocated the backbuffer around it),
    # the icons never appear for that whole boot because nothing re-emits.
    # The panel renders reliably precisely because its live clock re-commits
    # every tick. Mirror that: re-commit the (cheap, static) backdrop on a
    # cadence — FAST for the first few seconds to slam shut the startup race
    # window, then a slow keep-alive so any later full-present clobber heals.
    heal_pass: uint64 = 0
    HEAL_FAST_PASSES: uint64 = 80     # ~ first seconds: re-emit every pass
    HEAL_SLOW_EVERY:  uint64 = 64     # thereafter: re-emit ~every 64 passes
    # Cadence for the periodic external-change re-scan of the desktop dir
    # (~1s at the 100Hz tick) — the same shape the file manager uses so a
    # folder/file created on the command line APPEARS on the desktop without
    # any manual action.
    REFRESH_JIF: uint64 = 100
    last_refresh_jif: uint64 = sys_get_jiffies()
    evbuf: Array[256, uint8]
    while True:
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        changed: int32 = 0
        # Self-heal: during the startup window re-emit every pass; after that
        # re-emit periodically so a clobbered backdrop never stays blank.
        heal_pass = heal_pass + 1
        if heal_pass <= HEAL_FAST_PASSES:
            changed = 1
        elif heal_pass % HEAL_SLOW_EVERY == 0:
            changed = 1
        # Poll the kernel wallpaper status file on the desktop's own redraw
        # cadence: on a gen bump (Settings applied a new wallpaper) reload the
        # PPM and force a backdrop re-emit. Cheap one-shot open/read/close.
        if _wp_poll_kernel() == 1:
            changed = 1
        # #327: refresh the pending drag-from-menu OFFER before draining input,
        # so a button RELEASE this pass commits a desktop launcher at the drop
        # point (and a held-button drag is suppressed, not treated as a click).
        _poll_desk_offer()
        if efd >= 0:
            # NON-BLOCKING drain: a blocking /event read only wakes on pointer
            # activity, which would stall the periodic dir re-scan while the
            # desktop is idle. We drain events non-blocking and PARK on the fd
            # with a bounded timeout at the bottom of the loop (the timeout is
            # the heartbeat that drives the re-scan). Same pattern as the FM.
            r: int64 = sys_read_nb(efd, &evbuf[0], 255)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            bx: int64 = 0
                            by: int64 = 0
                            bbtn: int64 = 0
                            if parse_pointer(&evbuf[ls], i - ls, &bx, &by,
                                             &bbtn) == 1:
                                btn_down: int32 = 0
                                if (bbtn & 1) != 0:
                                    btn_down = 1
                                rnow: int32 = 0
                                if (bbtn & 2) != 0:
                                    rnow = 1
                                redge: int32 = 0
                                if rnow != 0 and prev_rbtn == 0:
                                    redge = 1
                                prev_rbtn = rnow
                                # RIGHT-click press on the backdrop opens the
                                # desktop context menu (unless a prompt is up).
                                if redge != 0 and prompt_open == 0:
                                    _open_desk_menu(bx, by)
                                    changed = 1
                                    prev_btn_down = btn_down
                                    ls = i + 1
                                    i = i + 1
                                    continue
                                # While the menu is OPEN, LEFT-click either
                                # dispatches a row or dismisses the menu — it
                                # does NOT fall through to icon select/launch.
                                if menu_open != 0:
                                    if btn_down == 1 and prev_btn_down == 0:
                                        row: int32 = _desk_menu_row_at(bx, by)
                                        if row >= 0:
                                            if _desk_menu_dispatch(row) != 0:
                                                changed = 1
                                        else:
                                            _close_desk_menu()
                                            changed = 1
                                    prev_btn_down = btn_down
                                    ls = i + 1
                                    i = i + 1
                                    continue
                                # While the New Folder prompt is OPEN, a
                                # left-click outside it cancels.
                                if prompt_open != 0:
                                    if btn_down == 1 and prev_btn_down == 0:
                                        prompt_open = 0
                                        changed = 1
                                    prev_btn_down = btn_down
                                    ls = i + 1
                                    i = i + 1
                                    continue
                                # #327: a drag-from-menu OFFER is in flight.
                                # SUPPRESS the normal icon click/drag path (a
                                # held-button drag across the desktop must not
                                # select/launch an icon) and COMMIT a desktop
                                # launcher at the release point on button-up.
                                if drop_active != 0:
                                    if btn_down == 0 and prev_btn_down == 1:
                                        if _commit_desk_drop(bx, by) != 0:
                                            changed = 1
                                    prev_btn_down = btn_down
                                    ls = i + 1
                                    i = i + 1
                                    continue
                                idx: int64 = cell_at(bx, by)
                                if btn_down == 1 and prev_btn_down == 0:
                                    # PRESS edge: remember where the gesture
                                    # began (cell + point) so a later motion can
                                    # promote it to a DRAG, and a release over
                                    # the same cell with no drag is a click. Do
                                    # NOT launch here. A press on bare backdrop
                                    # clears any selection.
                                    press_idx = idx
                                    press_x = bx
                                    press_y = by
                                    dragging = 0
                                    drag_idx = -1
                                    if idx >= 0:
                                        # cursor offset inside the icon's cell.
                                        drag_grab_dx = bx - \
                                            cast[int64](icon_cx(cast[uint64](idx)))
                                        drag_grab_dy = by - \
                                            cast[int64](icon_cy(cast[uint64](idx)))
                                    if idx < 0 and sel_idx >= 0:
                                        sel_idx = -1
                                        changed = 1
                                elif btn_down == 1 and prev_btn_down == 1:
                                    # MOTION with button HELD. If a press armed
                                    # over an icon and the cursor has moved past
                                    # the threshold, enter / continue DRAG mode:
                                    # the icon's cell follows the cursor and the
                                    # scene re-emits (no launch ever fires).
                                    if press_idx >= 0:
                                        dx: int64 = bx - press_x
                                        dy: int64 = by - press_y
                                        if dx < 0:
                                            dx = 0 - dx
                                        if dy < 0:
                                            dy = 0 - dy
                                        if dragging == 0 and \
                                                (dx >= DRAG_THRESH or
                                                 dy >= DRAG_THRESH):
                                            dragging = 1
                                            drag_idx = press_idx
                                        if dragging != 0:
                                            drag_cur_x = bx
                                            drag_cur_y = by
                                            changed = 1
                                elif btn_down == 0 and prev_btn_down == 1:
                                    # RELEASE edge. If we were DRAGGING, DROP the
                                    # icon at the new cell origin, pin it, and
                                    # persist the layout (survives relaunch).
                                    # Otherwise it's a clean click -> select /
                                    # launch over the same press cell, exactly
                                    # as before (launch-on-click preserved).
                                    if dragging != 0 and drag_idx >= 0:
                                        di: uint64 = cast[uint64](drag_idx)
                                        nx: int64 = bx - drag_grab_dx
                                        ny: int64 = by - drag_grab_dy
                                        if nx < 0:
                                            nx = 0
                                        if ny < 0:
                                            ny = 0
                                        ic_x[di] = cast[int32](nx)
                                        ic_y[di] = cast[int32](ny)
                                        _save_positions()
                                        sel_idx = cast[int64](di)
                                        dragging = 0
                                        drag_idx = -1
                                        changed = 1
                                    elif idx >= 0 and idx == press_idx:
                                        now: uint64 = sys_get_jiffies()
                                        is_dbl: int32 = 0
                                        if last_click_idx == idx and \
                                           now - last_click_jif <= DBL_JIF:
                                            is_dbl = 1
                                        if sel_idx == idx:
                                            is_dbl = 1
                                        last_click_idx = idx
                                        last_click_jif = now
                                        if is_dbl == 0:
                                            sel_idx = idx
                                            changed = 1
                                        else:
                                            # Min-interval debounce: never let
                                            # two launches fire back-to-back.
                                            if now - last_launch_jif \
                                                    >= LAUNCH_MIN_JIF:
                                                _run_action(cast[uint64](idx))
                                                last_launch_jif = now
                                            sel_idx = -1
                                            changed = 1
                                    press_idx = -1
                                    dragging = 0
                                    drag_idx = -1
                                prev_btn_down = btn_down
                        ls = i + 1
                    i = i + 1
        # Poll /keys (non-blocking) while the New Folder name prompt is open.
        if prompt_open != 0:
            kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))
            if kfd >= 0:
                kr: int64 = sys_read_nb(kfd, &dkbuf[0], 255)
                sys_close(kfd)
                if kr > 0:
                    if _desk_drain_keys(cast[uint64](kr)) != 0:
                        changed = 1
        # Periodic external-change refresh: re-scan the desktop directory on a
        # ~1s timer so a folder/file created (or removed) on the command line
        # APPEARS on the desktop WITHOUT any manual action. Cheap — a single
        # directory read + signature compare (fmc_refresh_if_changed); a full
        # icon-model rebuild + repaint happens ONLY when the listing actually
        # changed. Suppressed while a context menu / New Folder prompt / the
        # scripted demo is active so the icon indices never shift beneath the
        # user mid-interaction.
        if demo_mode == 0 and menu_open == 0 and prompt_open == 0:
            nowj: uint64 = sys_get_jiffies()
            if nowj - last_refresh_jif >= REFRESH_JIF:
                last_refresh_jif = nowj
                if fmc_refresh_if_changed() != 0:
                    _rebuild_after_refresh()
                    changed = 1
                    _writeall(1, cast[Ptr[uint8]]("[hamdesktop] auto-refresh\n"))
        # Scripted demo self-drive (`hamdesktop --demo`).
        if demo_mode != 0:
            _demo_advance()
        if changed != 0:
            emit_scene(wid)
        # Park OFF the runqueue until a routed pointer/key event arrives or the
        # ~250ms timeout lapses (which drives the periodic re-scan), so an idle
        # desktop sits near 0% CPU yet still reflects external changes. During
        # the startup self-heal window, and when the demo needs loop-cadence
        # pacing, fall back to the short bounded yield spin so the fast re-emit
        # cadence that closes the compositor race is preserved.
        if efd >= 0 and demo_mode == 0 and heal_pass > HEAL_FAST_PASSES:
            wfd: Array[1, int32]
            wfd[0] = efd
            sys_waitfds(&wfd[0], 1, 250)
            sys_close(efd)
        else:
            if efd >= 0:
                sys_close(efd)
            s2: uint64 = sys_get_jiffies()
            while sys_get_jiffies() - s2 < 3:
                sys_yield()
    return 0

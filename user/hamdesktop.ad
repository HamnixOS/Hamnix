# user/hamdesktop.ad
#
# hamdesktop — DE pivot wave 1 (round 2): the desktop icon badge layer
# extracted out of user/hamUId.ad's daemon_pixel cascade (the dpix_root_icons
# helper) into a standalone hamui v2 client (mirrors wave 1..8 pattern).
#
# Wire model
# ----------
# 1. Compositor publishes "desktop <count> <drag>" via /dev/wsys/ctl;
#    snapshot served at /dev/wsys/desktop:
#       "<show_serial> <count> <drag> <gen>\n"
# 2. Compositor spawns /bin/hamdesktop once at startup. Whenever icon
#    drag state changes (or icons added/removed) it republishes and pokes
#    /dev/wsys/desktop/show.
# 3. We open /dev/wsys/<wid>/wctl, write "version 2\n" to opt into the
#    rio v2 blit protocol, then rasterise a placeholder grid of icon
#    badges via lib/hamui's hamui_v2_* family.
#
# The desktop is full-screen but transparent except where icons live;
# this is a window with low-z (handled by the compositor at spawn).
# The structural test does not check z-order, just the extraction.

from lib.hamui import (
    hamui_init, hamui_window_on, hamui_set_protocol_v2,
    hamui_v2_clear, hamui_v2_clear_transparent, hamui_v2_fill_rect, hamui_v2_commit_rect,
    hamui_v2_is_active,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield()
extern def sys_exit(code: int32)


# --- model storage --------------------------------------------------
_hd_count: int32 = 0
_hd_drag:  int32 = -1
_hd_gen:   uint64 = 0
_hd_show_serial:      uint64 = 0
_hd_last_show_serial: uint64 = 0xffffffffffffffff
_hd_last_gen:         uint64 = 0xffffffffffffffff


# --- layout ---------------------------------------------------------
_hd_WIN_W: int32 = 800
_hd_WIN_H: int32 = 600
_hd_CELL_W: int32 = 96
_hd_CELL_H: int32 = 96
_hd_BADGE:  int32 = 56
_hd_BADGE_Y: int32 = 4
_hd_GLYPH_H: int32 = 6
_hd_GLYPH_W: int32 = 7

# MATE-style fixed icon column (top-left of the desktop area, just below
# the panel). Six 64x64 icons stacked vertically with text labels under
# each. Click-to-spawn wiring is deferred; this paint pass exists so the
# user can SEE the icon grid in build/de_screenshot.png.
_hd_ICON_COL_X: int32 = 16
_hd_ICON_COL_Y: int32 = 32
_hd_ICON_SZ:    int32 = 64
_hd_ICON_PITCH: int32 = 96
_hd_ICON_COUNT: int32 = 6

_hd_snap_buf: Array[256, uint8]


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


def _read_desktop_snapshot() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/desktop"))
    if fd < 0:
        return -1
    n: int64 = sys_read(fd, &_hd_snap_buf[0], 256)
    sys_close(fd)
    return n


def _parse_u64(pos: Ptr[uint64], end: uint64) -> uint64:
    p: uint64 = pos[0]
    v: uint64 = 0
    while p < end and _hd_snap_buf[p] >= 48 and _hd_snap_buf[p] <= 57:
        v = v * 10 + cast[uint64](_hd_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    return v


def _parse_i64(pos: Ptr[uint64], end: uint64) -> int64:
    p: uint64 = pos[0]
    neg: int32 = 0
    if p < end and _hd_snap_buf[p] == 45:
        neg = 1
        p = p + 1
    v: int64 = 0
    while p < end and _hd_snap_buf[p] >= 48 and _hd_snap_buf[p] <= 57:
        v = v * 10 + cast[int64](_hd_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    if neg != 0:
        return -v
    return v


def _skip_ws(pos: uint64, end: uint64) -> uint64:
    p: uint64 = pos
    while p < end and (_hd_snap_buf[p] == 32 or _hd_snap_buf[p] == 9):
        p = p + 1
    return p


def _parse_snapshot(n: uint64) -> int32:
    if n == 0:
        return 0
    pos: Array[1, uint64]
    pos[0] = 0
    show_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    count_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    drag_v: int64 = _parse_i64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    gen_v: uint64 = _parse_u64(&pos[0], n)
    _hd_show_serial = show_v
    _hd_count = cast[int32](count_v)
    _hd_drag = cast[int32](drag_v)
    _hd_gen = gen_v
    changed: int32 = 0
    if _hd_show_serial != _hd_last_show_serial:
        changed = 1
    if _hd_gen != _hd_last_gen:
        changed = 1
    _hd_last_show_serial = _hd_show_serial
    _hd_last_gen = _hd_gen
    return changed


# ---- icon glyph rasterisers ----------------------------------------
# Each draws into a 64x64 cell at (x0,y0). Style: a soft tile background
# (rounded-ish corner via 1px lift/shadow) then a vector glyph layered on
# top in icon-typical colors. Keeps the desktop low-key but legible.

def _hd_tile_bg(x0: int32, y0: int32, sz: int32,
                r: uint8, g: uint8, b: uint8):
    # body
    hamui_v2_fill_rect(x0 + 1, y0 + 1, sz - 2, sz - 2, r, g, b)
    # top/left lift
    hamui_v2_fill_rect(x0 + 1, y0,         sz - 2, 1, 240, 240, 245)
    hamui_v2_fill_rect(x0,     y0 + 1,     1, sz - 2, 240, 240, 245)
    # bottom/right shadow
    hamui_v2_fill_rect(x0 + 1, y0 + sz - 1, sz - 2, 1, 30, 30, 40)
    hamui_v2_fill_rect(x0 + sz - 1, y0 + 1, 1, sz - 2, 30, 30, 40)


def _hd_draw_home(x0: int32, y0: int32):
    # cream tile + brown-roof house with door
    _hd_tile_bg(x0, y0, _hd_ICON_SZ, 230, 220, 200)
    # roof: triangle as horizontal strips, centered, peak at (x0+32,y0+10)
    cx: int32 = x0 + 32
    py: int32 = y0 + 10
    i: int32 = 0
    while i < 18:
        # half-width = i+1 at row py+i
        hw: int32 = i + 1
        if hw > 26:
            hw = 26
        hamui_v2_fill_rect(cx - hw, py + i, hw * 2, 1, 150, 60, 30)
        i = i + 1
    # walls (warm tan)
    hamui_v2_fill_rect(x0 + 12, y0 + 28, 40, 26, 210, 170, 110)
    # door (dark brown)
    hamui_v2_fill_rect(x0 + 28, y0 + 38, 10, 16, 90, 50, 25)
    # window (sky blue)
    hamui_v2_fill_rect(x0 + 16, y0 + 32, 8, 8, 120, 180, 220)


def _hd_draw_trash(x0: int32, y0: int32):
    # gray tile + dark gray trash can with lid + slot
    _hd_tile_bg(x0, y0, _hd_ICON_SZ, 210, 215, 220)
    # lid
    hamui_v2_fill_rect(x0 + 10, y0 + 12, 44, 4, 80, 90, 100)
    # lid handle
    hamui_v2_fill_rect(x0 + 26, y0 + 8, 12, 4, 80, 90, 100)
    # bin body
    hamui_v2_fill_rect(x0 + 14, y0 + 18, 36, 36, 110, 120, 130)
    # vertical ridges
    hamui_v2_fill_rect(x0 + 22, y0 + 22, 2, 28, 70, 80, 90)
    hamui_v2_fill_rect(x0 + 32, y0 + 22, 2, 28, 70, 80, 90)
    hamui_v2_fill_rect(x0 + 42, y0 + 22, 2, 28, 70, 80, 90)


def _hd_draw_system(x0: int32, y0: int32):
    # gear / system icon: dark tile with a stylized gear
    _hd_tile_bg(x0, y0, _hd_ICON_SZ, 90, 100, 120)
    # gear outer disk
    cx: int32 = x0 + 32
    cy: int32 = y0 + 32
    hamui_v2_fill_rect(cx - 20, cy - 20, 40, 40, 200, 200, 210)
    # teeth (4 cardinal blocks)
    hamui_v2_fill_rect(cx - 4, cy - 26, 8, 8, 200, 200, 210)
    hamui_v2_fill_rect(cx - 4, cy + 18, 8, 8, 200, 200, 210)
    hamui_v2_fill_rect(cx - 26, cy - 4, 8, 8, 200, 200, 210)
    hamui_v2_fill_rect(cx + 18, cy - 4, 8, 8, 200, 200, 210)
    # gear hub
    hamui_v2_fill_rect(cx - 8, cy - 8, 16, 16, 90, 100, 120)


def _hd_draw_terminal(x0: int32, y0: int32):
    # black terminal with green prompt and cursor
    _hd_tile_bg(x0, y0, _hd_ICON_SZ, 30, 30, 35)
    # title bar
    hamui_v2_fill_rect(x0 + 4, y0 + 8, 56, 6, 80, 80, 95)
    # screen
    hamui_v2_fill_rect(x0 + 4, y0 + 14, 56, 42, 15, 15, 20)
    # prompt ">" — two diagonal pixels
    hamui_v2_set_pixel(x0 + 10, y0 + 22, 80, 220, 120)
    hamui_v2_set_pixel(x0 + 11, y0 + 23, 80, 220, 120)
    hamui_v2_set_pixel(x0 + 12, y0 + 24, 80, 220, 120)
    hamui_v2_set_pixel(x0 + 11, y0 + 25, 80, 220, 120)
    hamui_v2_set_pixel(x0 + 10, y0 + 26, 80, 220, 120)
    # cursor block
    hamui_v2_fill_rect(x0 + 16, y0 + 22, 6, 6, 200, 230, 200)


def _hd_draw_sysmon(x0: int32, y0: int32):
    # bar-chart style sysmon
    _hd_tile_bg(x0, y0, _hd_ICON_SZ, 40, 50, 70)
    # baseline
    hamui_v2_fill_rect(x0 + 8, y0 + 50, 48, 2, 200, 200, 210)
    # bars rising (cpu/mem/io/net)
    hamui_v2_fill_rect(x0 + 12, y0 + 38, 6, 12, 100, 220, 120)
    hamui_v2_fill_rect(x0 + 22, y0 + 28, 6, 22, 220, 200, 100)
    hamui_v2_fill_rect(x0 + 32, y0 + 18, 6, 32, 220, 120, 100)
    hamui_v2_fill_rect(x0 + 42, y0 + 32, 6, 18, 120, 180, 240)


def _hd_draw_network(x0: int32, y0: int32):
    # globe with crossing meridian/equator
    _hd_tile_bg(x0, y0, _hd_ICON_SZ, 200, 220, 230)
    cx: int32 = x0 + 32
    cy: int32 = y0 + 32
    # filled circle (rough disk via row strips)
    r: int32 = 20
    yy: int32 = -r
    while yy <= r:
        # ~ half-width by |yy|: simple stepped approx
        hw: int32 = r - 1
        if yy < -16 or yy > 16:
            hw = 8
        elif yy < -12 or yy > 12:
            hw = 14
        elif yy < -6 or yy > 6:
            hw = 18
        hamui_v2_fill_rect(cx - hw, cy + yy, hw * 2, 1, 80, 140, 200)
        yy = yy + 1
    # equator
    hamui_v2_fill_rect(cx - 20, cy, 40, 1, 230, 240, 245)
    # meridian
    hamui_v2_fill_rect(cx, cy - 20, 1, 40, 230, 240, 245)
    # diagonal hint
    i: int32 = -14
    while i <= 14:
        hamui_v2_set_pixel(cx + i, cy + i / 2, 230, 240, 245)
        i = i + 2


# ---- tiny 3x5 bitmap font for label glyphs ------------------------
# Each glyph is a 15-bit mask laid out row-major (row0 left-msb..bit14):
#   bit = 1 << (row*3 + col), col 0..2, row 0..4
# We expose draw helpers for the per-icon labels rather than a full font.

def _hd_glyph(x0: int32, y0: int32, mask: uint32,
              r: uint8, g: uint8, b: uint8):
    row: int32 = 0
    while row < 5:
        col: int32 = 0
        while col < 3:
            bit: uint32 = cast[uint32](1) << cast[uint32](row * 3 + col)
            if (mask & bit) != 0:
                hamui_v2_fill_rect(x0 + col, y0 + row, 1, 1, r, g, b)
            col = col + 1
        row = row + 1


# Glyph masks (row0 top). Each 3-bit row written MSB-first as 0bRRR.
# Helper: mask = r0 | r1<<3 | r2<<6 | r3<<9 | r4<<12
def _hd_mk(r0: uint32, r1: uint32, r2: uint32,
           r3: uint32, r4: uint32) -> uint32:
    return r0 | (r1 << 3) | (r2 << 6) | (r3 << 9) | (r4 << 12)


def _hd_g_H() -> uint32:
    return _hd_mk(cast[uint32](5), cast[uint32](5), cast[uint32](7), cast[uint32](5), cast[uint32](5))


def _hd_g_O() -> uint32:
    return _hd_mk(cast[uint32](7), cast[uint32](5), cast[uint32](5), cast[uint32](5), cast[uint32](7))


def _hd_g_M() -> uint32:
    return _hd_mk(cast[uint32](5), cast[uint32](7), cast[uint32](7), cast[uint32](5), cast[uint32](5))


def _hd_g_E() -> uint32:
    return _hd_mk(cast[uint32](7), cast[uint32](4), cast[uint32](6), cast[uint32](4), cast[uint32](7))


def _hd_g_T() -> uint32:
    return _hd_mk(cast[uint32](7), cast[uint32](2), cast[uint32](2), cast[uint32](2), cast[uint32](2))


def _hd_g_R() -> uint32:
    return _hd_mk(cast[uint32](6), cast[uint32](5), cast[uint32](6), cast[uint32](5), cast[uint32](5))


def _hd_g_A() -> uint32:
    return _hd_mk(cast[uint32](2), cast[uint32](5), cast[uint32](7), cast[uint32](5), cast[uint32](5))


def _hd_g_S() -> uint32:
    return _hd_mk(cast[uint32](3), cast[uint32](4), cast[uint32](2), cast[uint32](1), cast[uint32](6))


def _hd_g_Y() -> uint32:
    return _hd_mk(cast[uint32](5), cast[uint32](5), cast[uint32](2), cast[uint32](2), cast[uint32](2))


def _hd_g_N() -> uint32:
    return _hd_mk(cast[uint32](5), cast[uint32](7), cast[uint32](7), cast[uint32](7), cast[uint32](5))


def _hd_g_W() -> uint32:
    return _hd_mk(cast[uint32](5), cast[uint32](5), cast[uint32](5), cast[uint32](7), cast[uint32](5))


def _hd_g_K() -> uint32:
    return _hd_mk(cast[uint32](5), cast[uint32](6), cast[uint32](4), cast[uint32](6), cast[uint32](5))


def _hd_draw_label(x0: int32, y0: int32, idx: int32,
                   r: uint8, g: uint8, b: uint8):
    # 3x5 glyphs, 1px spacing → each char advance = 4px.
    if idx == 0:
        # HOME
        _hd_glyph(x0,      y0, _hd_g_H(), r, g, b)
        _hd_glyph(x0 + 4,  y0, _hd_g_O(), r, g, b)
        _hd_glyph(x0 + 8,  y0, _hd_g_M(), r, g, b)
        _hd_glyph(x0 + 12, y0, _hd_g_E(), r, g, b)
    elif idx == 1:
        # TRASH
        _hd_glyph(x0,      y0, _hd_g_T(), r, g, b)
        _hd_glyph(x0 + 4,  y0, _hd_g_R(), r, g, b)
        _hd_glyph(x0 + 8,  y0, _hd_g_A(), r, g, b)
        _hd_glyph(x0 + 12, y0, _hd_g_S(), r, g, b)
        _hd_glyph(x0 + 16, y0, _hd_g_H(), r, g, b)
    elif idx == 2:
        # SYSTEM
        _hd_glyph(x0,      y0, _hd_g_S(), r, g, b)
        _hd_glyph(x0 + 4,  y0, _hd_g_Y(), r, g, b)
        _hd_glyph(x0 + 8,  y0, _hd_g_S(), r, g, b)
        _hd_glyph(x0 + 12, y0, _hd_g_T(), r, g, b)
        _hd_glyph(x0 + 16, y0, _hd_g_E(), r, g, b)
        _hd_glyph(x0 + 20, y0, _hd_g_M(), r, g, b)
    elif idx == 3:
        # TERMINAL → "TERM" (fits cell)
        _hd_glyph(x0,      y0, _hd_g_T(), r, g, b)
        _hd_glyph(x0 + 4,  y0, _hd_g_E(), r, g, b)
        _hd_glyph(x0 + 8,  y0, _hd_g_R(), r, g, b)
        _hd_glyph(x0 + 12, y0, _hd_g_M(), r, g, b)
    elif idx == 4:
        # SYSMON → "SYSMON"
        _hd_glyph(x0,      y0, _hd_g_S(), r, g, b)
        _hd_glyph(x0 + 4,  y0, _hd_g_Y(), r, g, b)
        _hd_glyph(x0 + 8,  y0, _hd_g_S(), r, g, b)
        _hd_glyph(x0 + 12, y0, _hd_g_M(), r, g, b)
        _hd_glyph(x0 + 16, y0, _hd_g_O(), r, g, b)
        _hd_glyph(x0 + 20, y0, _hd_g_N(), r, g, b)
    else:
        # NETWORK → "NETWRK"
        _hd_glyph(x0,      y0, _hd_g_N(), r, g, b)
        _hd_glyph(x0 + 4,  y0, _hd_g_E(), r, g, b)
        _hd_glyph(x0 + 8,  y0, _hd_g_T(), r, g, b)
        _hd_glyph(x0 + 12, y0, _hd_g_W(), r, g, b)
        _hd_glyph(x0 + 16, y0, _hd_g_R(), r, g, b)
        _hd_glyph(x0 + 20, y0, _hd_g_K(), r, g, b)


def _hd_draw_icon(idx: int32, x0: int32, y0: int32):
    if idx == 0:
        _hd_draw_home(x0, y0)
    elif idx == 1:
        _hd_draw_trash(x0, y0)
    elif idx == 2:
        _hd_draw_system(x0, y0)
    elif idx == 3:
        _hd_draw_terminal(x0, y0)
    elif idx == 4:
        _hd_draw_sysmon(x0, y0)
    else:
        _hd_draw_network(x0, y0)


def _paint():
    # Transparent root layer: clear-to-transparent leaves the wallpaper
    # showing through except where we paint icons. We always paint the
    # fixed MATE-style icon column at top-left of the desktop area, so
    # users see Home/Trash/System/Terminal/SysMon/Network even when the
    # compositor hasn't pushed any drag-tracked badges yet.
    hamui_v2_clear_transparent()

    # Fixed icon column (MATE-style top-left).
    i: int32 = 0
    while i < _hd_ICON_COUNT:
        ix: int32 = _hd_ICON_COL_X
        iy: int32 = _hd_ICON_COL_Y + i * _hd_ICON_PITCH
        _hd_draw_icon(i, ix, iy)
        # Label below the icon, centered horizontally in the 64px cell.
        # Glyph strip width = 4 * nchars - 1. We bias-center per icon by
        # offsetting from the icon's left edge.
        lx: int32 = ix + 4
        ly: int32 = iy + _hd_ICON_SZ + 6
        # Label background plate (slight contrast against wallpaper).
        hamui_v2_fill_rect(ix - 2, ly - 2, _hd_ICON_SZ + 4, 9, 20, 20, 30)
        _hd_draw_label(lx, ly, i, 240, 240, 250)
        i = i + 1

    # Legacy: optional compositor-published drag-tracked badges still
    # paint behind, to the right of the fixed column. This keeps the
    # extracted snapshot/parse pipeline live for the structural test
    # and the upstream compositor's drag highlight.
    if _hd_count > 0:
        col_offset: int32 = _hd_ICON_COL_X + _hd_ICON_SZ + 32
        cols: int32 = (_hd_WIN_W - col_offset) / _hd_CELL_W
        if cols < 1:
            cols = 1
        j: int32 = 0
        while j < _hd_count:
            col: int32 = j % cols
            row: int32 = j / cols
            jx: int32 = col_offset + col * _hd_CELL_W
            jy: int32 = row * _hd_CELL_H
            bx: int32 = jx + (_hd_CELL_W - _hd_BADGE) / 2
            by: int32 = jy + _hd_BADGE_Y
            hot: int32 = 0
            if j == _hd_drag:
                hot = 1
            r: uint8 = 90
            g: uint8 = 130
            b: uint8 = 210
            if hot != 0:
                r = 120
                g = 160
                b = 240
            hamui_v2_fill_rect(bx, by, _hd_BADGE, _hd_BADGE, r, g, b)
            hamui_v2_fill_rect(bx, by, _hd_BADGE, 1, 140, 180, 250)
            hamui_v2_fill_rect(bx, by, 1, _hd_BADGE, 140, 180, 250)
            hamui_v2_fill_rect(bx, by + _hd_BADGE - 1, _hd_BADGE, 1, 50, 80, 140)
            hamui_v2_fill_rect(bx + _hd_BADGE - 1, by, 1, _hd_BADGE, 50, 80, 140)
            lx2: int32 = jx + 12
            ly2: int32 = by + _hd_BADGE + 4
            lw2: int32 = _hd_CELL_W - 24
            hamui_v2_fill_rect(lx2, ly2, lw2, _hd_GLYPH_H, 240, 240, 248)
            j = j + 1

    hamui_v2_commit_rect(0, 0, _hd_WIN_W, _hd_WIN_H)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()
    wid: int32 = 1
    sfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/self"))
    if sfd >= 0:
        sbuf: Array[16, uint8]
        sn: int64 = sys_read_nb(sfd, &sbuf[0], 16)
        sys_close(sfd)
        if sn > 0:
            v: int32 = 0
            i: uint64 = 0
            while i < cast[uint64](sn) and sbuf[i] >= 48 and sbuf[i] <= 57:
                v = v * 10 + cast[int32](sbuf[i]) - 48
                i = i + 1
            if v >= 2:
                wid = v
    if argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        v2: int32 = 0
        i2: uint64 = 0
        while ap[i2] >= 48 and ap[i2] <= 57:
            v2 = v2 * 10 + cast[int32](ap[i2]) - 48
            i2 = i2 + 1
        if v2 >= 1:
            wid = v2

    bound: int32 = hamui_window_on(0, wid)
    if bound < 0:
        _puts(2, "hamdesktop: could not bind window\n")
        return 1
    if hamui_set_protocol_v2() < 0:
        _puts(2, "hamdesktop: v2 negotiate failed\n")
        return 1

    n0: int64 = _read_desktop_snapshot()
    if n0 > 0:
        _parse_snapshot(cast[uint64](n0))
    _paint()
    rdy: Ptr[uint8] = "HAMDESKTOP ready\n"
    sys_write(1, rdy, _strlen(rdy))

    while True:
        n: int64 = _read_desktop_snapshot()
        if n > 0:
            if _parse_snapshot(cast[uint64](n)) != 0:
                _paint()
        sys_yield()

    return 0

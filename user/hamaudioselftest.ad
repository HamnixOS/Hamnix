# user/hamaudioselftest.ad — on-device audio-playback self-test /init.
#
# The companion to user/playtone.ad for the DECODER path: where playtone
# synthesizes a raw tone, THIS program proves the WHOLE media pipeline the
# audio player ships — read a real .wav off the filesystem, DECODE its
# container with lib/wavdecode.ad, and STREAM the extracted PCM to the native
# HDA sink through the Plan-9 file interface (/dev/audioctl + /dev/audio, no
# ioctls). scripts/test_hamaudio_playback.sh runs it AS /init and captures
# whatever the guest played via QEMU's intel-hda -> WAV backend, proving real
# samples reached the codec (not just a "played" log — the console-leak lesson).
#
# It plays /usr/share/sounds/test.wav (planted in the initramfs) then waits out
# the clip against the 100 Hz jiffies clock so the DMA engine drains before the
# guest exits.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

from lib.wavdecode import wavdecode_parse, wavdecode_rate, wavdecode_channels, \
    wavdecode_bits, wavdecode_data_off, wavdecode_data_len, \
    wavdecode_frame_bytes, wavdecode_nframes, wavdecode_duration_ms

FILE_CAP: uint64 = 327680
filebuf: Array[327680, uint8]
HDA_CAP: uint64 = 262144


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        out[1] = 0
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x != 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    w: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    out[w] = 0
    return w


def _ctl_verb(fd: int32, verb: Ptr[uint8], value: uint64):
    line: Array[48, uint8]
    p: uint64 = 0
    j: uint64 = 0
    while verb[j] != 0:
        line[p] = verb[j]
        p = p + 1
        j = j + 1
    line[p] = 32
    p = p + 1
    p = p + _u64_dec(value, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(fd, &line[0], p)


def _log_kv(pre: Ptr[uint8], v: uint64):
    buf: Array[96, uint8]
    p: uint64 = 0
    j: uint64 = 0
    while pre[j] != 0:
        buf[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_dec(v, &buf[p])
    buf[p] = 10
    p = p + 1
    sys_write(1, &buf[0], p)


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)

    infd: int32 = sys_open(cast[Ptr[char]]("/usr/share/sounds/test.wav"))
    if infd < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamaudio-selftest] FAIL cannot open test.wav\n"))
        return 1
    flen: uint64 = 0
    while flen < FILE_CAP:
        r: int64 = sys_read(infd, &filebuf[flen], FILE_CAP - flen)
        if r <= 0:
            break
        flen = flen + cast[uint64](r)
    sys_close(infd)

    if wavdecode_parse(&filebuf[0], flen) == 0:
        _writeall(1, cast[Ptr[uint8]]("[hamaudio-selftest] FAIL decode\n"))
        return 1

    rate: uint32 = wavdecode_rate()
    ch: uint32 = wavdecode_channels()
    _log_kv(cast[Ptr[uint8]]("[hamaudio-selftest] rate "), cast[uint64](rate))
    _log_kv(cast[Ptr[uint8]]("[hamaudio-selftest] channels "), cast[uint64](ch))
    _log_kv(cast[Ptr[uint8]]("[hamaudio-selftest] frames "), wavdecode_nframes())

    ctlfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/audioctl"))
    if ctlfd < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamaudio-selftest] FAIL open audioctl\n"))
        return 1
    _ctl_verb(ctlfd, cast[Ptr[uint8]]("rate"), cast[uint64](rate))
    _ctl_verb(ctlfd, cast[Ptr[uint8]]("channels"), cast[uint64](ch))
    if wavdecode_bits() == 8:
        _writeall(ctlfd, cast[Ptr[uint8]]("format u8\n"))
    else:
        _writeall(ctlfd, cast[Ptr[uint8]]("format s16le\n"))

    audfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/audio"))
    if audfd < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamaudio-selftest] FAIL open audio\n"))
        return 1

    # Stream the decoded PCM (bounded by the DMA buffer capacity) to the sink.
    data_off: uint64 = wavdecode_data_off()
    data_len: uint64 = wavdecode_data_len()
    span: uint64 = data_len
    if span > HDA_CAP:
        span = HDA_CAP
    fb: uint64 = wavdecode_frame_bytes()
    if fb > 0:
        span = (span / fb) * fb
    off: uint64 = 0
    while off < span:
        chunk: uint64 = span - off
        if chunk > 4096:
            chunk = 4096
        sys_write(audfd, &filebuf[data_off + off], chunk)
        off = off + chunk
    _writeall(ctlfd, cast[Ptr[uint8]]("start\n"))
    _log_kv(cast[Ptr[uint8]]("[hamaudio-selftest] played "), off)

    # Wait out the clip + margin so the DMA engine drains (HZ=100, 10 ms/tick).
    dur_ms: uint64 = wavdecode_duration_ms()
    wait_j: uint64 = (dur_ms + 700) / 10
    start_j: uint64 = sys_get_jiffies()
    while sys_get_jiffies() - start_j < wait_j:
        pass

    sys_close(audfd)
    sys_close(ctlfd)
    _writeall(1, cast[Ptr[uint8]]("[hamaudio-selftest] DONE\n"))
    return 0

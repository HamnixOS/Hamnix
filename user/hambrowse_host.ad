# user/hambrowse_host.ad — HOST test harness for the hambrowse engine.
#
# Built for the `x86_64-linux` Adder target (see compiler/adder.py
# TARGET_SPECS): a freestanding ELF that runs DIRECTLY on the developer's
# host Linux kernel — no QEMU, no installer image. It reads a local HTML
# file, drives the SAME parse+layout+colour engine the native browser uses
# (lib/htmlengine.ad), and dumps the resulting display list to stdout so the
# engine can be iterated + regression-tested on the host in milliseconds.
#
# This is a TEST shim only. It shares the engine with user/hambrowse.ad but
# NOT the Plan 9 fetch / hamUI render path — the native browser keeps those.
# No sockets are introduced anywhere: the host harness only reads a file.
#
# USAGE (built to build/host/hambrowse_host):
#   hambrowse_host FILE.html [WIDTH]
#
# OUTPUT
#   LAYOUT segs=N rows=M links=K width=W
#   FLOW   <one line per visual row: the wrapped page as text>
#   SEG    row x #rrggbb b<0|1> u<0|1> l<link> |text|
#
# The x86_64-linux runtime (user/linux-runtime.S) supplies _start + the
# raw-syscall wrappers; here sys_open takes the Linux (path, flags, mode)
# ABI (O_RDONLY = 0).

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.htmlengine import he_layout, he_seg_color_hex, he_rgb_hex


# ---- tiny libc-free helpers ----------------------------------------
def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


obuf: Array[256, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 255:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- input buffer (BSS; the native user stack is one page) ----------
FILE_CAP: uint64 = 262144
file_buf: Array[262144, uint8]
file_len: uint64 = 0
hexline: Array[8, uint8]


def _read_file(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 0, 0)                  # O_RDONLY
    if fd < 0:
        return -1
    file_len = 0
    while file_len < FILE_CAP - 1:
        n: int64 = sys_read(fd, &file_buf[file_len], FILE_CAP - 1 - file_len)
        if n <= 0:
            break
        file_len = file_len + cast[uint64](n)
    sys_close(fd)
    return 0


# ---- decimal parse for the optional WIDTH argument ------------------
def _atoi(s: Ptr[uint8]) -> int32:
    v: int32 = 0
    i: uint64 = 0
    while s[i] >= 48 and s[i] <= 57:
        v = v * 10 + cast[int32](s[i]) - 48
        i = i + 1
    return v


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        _writeall(2, cast[Ptr[uint8]]("usage: hambrowse_host FILE.html [WIDTH]\n"))
        return 2
    path: Ptr[char] = cast[Ptr[char]](argv[1])
    if _read_file(path) != 0:
        _writeall(2, cast[Ptr[uint8]]("hambrowse_host: cannot open file\n"))
        return 1
    if argc >= 3:
        w: int32 = _atoi(cast[Ptr[uint8]](argv[2]))
        if w >= 120:
            bw = w

    src_ptr = &file_buf[0]
    src_len = file_len
    he_layout()

    # Summary.
    _o_str(cast[Ptr[uint8]]("LAYOUT segs="))
    _o_dec(cast[int64](n_segs))
    _o_str(cast[Ptr[uint8]](" rows="))
    _o_dec(cast[int64](total_rows))
    _o_str(cast[Ptr[uint8]](" links="))
    _o_dec(cast[int64](n_links))
    _o_str(cast[Ptr[uint8]](" width="))
    _o_dec(cast[int64](bw))
    _o_ch(10)
    _o_flush()

    # FLOW — reconstruct the wrapped page as one text line per visual row,
    # honouring each segment's pixel-x so word spacing/indent is visible.
    r: uint64 = 0
    while r < total_rows:
        _o_str(cast[Ptr[uint8]]("FLOW "))
        col_cell: int32 = 0                           # current character column
        si: uint64 = 0
        while si < n_segs:
            if cast[uint64](seg_line[si]) == r:
                # pad to the segment's start column (x / CELL_W)
                startc: int32 = seg_x[si] / CELL_W
                while col_cell < startc:
                    _o_ch(32)
                    col_cell = col_cell + 1
                off: uint64 = cast[uint64](seg_off[si])
                ln: int32 = seg_len[si]
                k: int32 = 0
                while k < ln:
                    _o_ch(seg_text_buf[off + cast[uint64](k)])
                    k = k + 1
                col_cell = col_cell + ln
            si = si + 1
        _o_ch(10)
        _o_flush()
        r = r + 1

    # SEG — one machine-readable line per segment (colour-aware).
    si2: uint64 = 0
    while si2 < n_segs:
        _o_str(cast[Ptr[uint8]]("SEG "))
        _o_dec(cast[int64](seg_line[si2]))
        _o_ch(32)
        _o_dec(cast[int64](seg_x[si2]))
        _o_ch(32)
        he_seg_color_hex(si2, &hexline[0])
        _o_str(&hexline[0])
        _o_str(cast[Ptr[uint8]](" b"))
        _o_dec(cast[int64](seg_bold[si2]))
        _o_str(cast[Ptr[uint8]](" u"))
        _o_dec(cast[int64](seg_uline[si2]))
        _o_str(cast[Ptr[uint8]](" l"))
        _o_dec(cast[int64](seg_link[si2]))
        _o_str(cast[Ptr[uint8]](" bg"))
        if seg_bg[si2] >= 0:
            he_rgb_hex(seg_bg[si2], &hexline[0])
            _o_str(&hexline[0])
        else:
            _o_ch(45)                                 # '-'
        _o_str(cast[Ptr[uint8]](" |"))
        off2: uint64 = cast[uint64](seg_off[si2])
        ln2: int32 = seg_len[si2]
        k2: int32 = 0
        while k2 < ln2:
            _o_ch(seg_text_buf[off2 + cast[uint64](k2)])
            k2 = k2 + 1
        _o_ch(124)                                    # '|'
        _o_ch(10)
        _o_flush()
        si2 = si2 + 1

    # RULE — one line per row carrying a horizontal rule (1=heading, 2=<hr>).
    rr: uint64 = 0
    while rr < total_rows:
        if row_rule[rr] != 0:
            _o_str(cast[Ptr[uint8]]("RULE row "))
            _o_dec(cast[int64](rr))
            _o_str(cast[Ptr[uint8]](" type "))
            _o_dec(cast[int64](row_rule[rr]))
            _o_ch(10)
            _o_flush()
        rr = rr + 1

    return 0

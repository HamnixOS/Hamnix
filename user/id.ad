# user/id.ad
#
# Print the identity triplet `uid=<u>(<name>) gid=<g>(<grp>) groups=<g>(<grp>)`.
#
# Hamnix's identity model has NO uid 0 (the "root" idiom is gone): uid 1
# is the single hostowner, uid >= 1000 are regular users, 65534 is
# nobody. The old implementation hard-coded `uid=0(root) gid=0(root)
# groups=0(root)`, which was a Unix-ism that contradicted that model and
# made every caller look like root. This now reads the REAL per-task
# uid/gid (SYS_GETUID / SYS_GETGID, the same accessors whoami uses) and
# resolves the names against /etc/passwd and /etc/group. If a name has
# no table entry the field degrades to the bare number (matching real
# `id` on a host with an unknown uid).

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_getuid() -> uint32
extern def sys_getgid() -> uint32

from lib.passwd.passwd import (
    passwd_parse, passwd_entry_name, passwd_lookup_by_uid,
)


pw_buf:  Array[4096, uint8]
grp_buf: Array[4096, uint8]
out_buf: Array[256, uint8]
gname:   Array[64, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def render_u32(v: uint32, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digits: Array[12, uint8]
    n: uint64 = 0
    vv: uint64 = cast[uint64](v)
    while vv != 0:
        digits[n] = cast[uint8](vv % 10) + 48
        vv = vv / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return written


def slurp(path: Ptr[char], buf: Ptr[uint8], cap: uint64) -> uint64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return 0
    total: uint64 = 0
    while total < cap:
        n: int64 = sys_read(fd, &buf[total], cap - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    return total


def parse_u32_field(buf: Ptr[uint8], lo: uint64, hi: uint64) -> uint32:
    n: uint32 = 0
    while lo < hi:
        c: uint8 = buf[lo]
        if c < 48 or c > 57:
            break
        n = n * 10 + cast[uint32](c - 48)
        lo = lo + 1
    return n


def group_name_by_gid(buf: Ptr[uint8], total: uint64,
                      gid: uint32, out: Ptr[uint8], cap: uint64) -> int32:
    # Parse /etc/group lines `name:passwd:gid:members`. On the first gid
    # match copy the name into out (NUL-terminated) and return 1; else 0.
    p: uint64 = 0
    while p < total:
        e: uint64 = p
        while e < total and buf[e] != 10:
            e = e + 1
        # Skip blank / comment lines.
        if p < e and buf[p] != 35:                      # not '#'
            # Field 0 = name (p .. col0). Field 2 = gid (col1+1 .. col2).
            col0: int64 = -1
            col1: int64 = -1
            col2: int64 = -1
            scan: uint64 = p
            while scan < e:
                if buf[scan] == 58:                     # ':'
                    if col0 < 0:
                        col0 = cast[int64](scan)
                    elif col1 < 0:
                        col1 = cast[int64](scan)
                    elif col2 < 0:
                        col2 = cast[int64](scan)
                scan = scan + 1
            if col0 >= 0 and col1 >= 0 and col2 >= 0:
                g0: uint64 = cast[uint64](col1) + 1
                g1: uint64 = cast[uint64](col2)
                if parse_u32_field(buf, g0, g1) == gid:
                    i: uint64 = 0
                    k: uint64 = p
                    while k < cast[uint64](col0) and i + 1 < cap:
                        out[i] = buf[k]
                        i = i + 1
                        k = k + 1
                    out[i] = 0
                    return 1
        p = e + 1
    return 0


def emit_field(label: Ptr[uint8], num: uint32,
               name: Ptr[uint8], have_name: int32, pos: uint64) -> uint64:
    # Append `<label><num>(<name>)` (or `<label><num>` if no name).
    li: uint64 = 0
    while label[li] != 0:
        out_buf[pos] = label[li]
        pos = pos + 1
        li = li + 1
    pos = pos + render_u32(num, &out_buf[pos])
    if have_name != 0:
        out_buf[pos] = 40                               # '('
        pos = pos + 1
        ni: uint64 = 0
        while name[ni] != 0:
            out_buf[pos] = name[ni]
            pos = pos + 1
            ni = ni + 1
        out_buf[pos] = 41                               # ')'
        pos = pos + 1
    return pos


def main() -> int32:
    uid: uint32 = sys_getuid()
    gid: uint32 = sys_getgid()

    # Resolve the user name from /etc/passwd.
    pw_n: uint64 = slurp("/etc/passwd", &pw_buf[0], 4096)
    passwd_parse(&pw_buf[0], pw_n)
    uidx: int32 = passwd_lookup_by_uid(uid)
    uname: Ptr[uint8] = cast[Ptr[uint8]](0)
    have_uname: int32 = 0
    if uidx >= 0:
        uname = passwd_entry_name(uidx)
        have_uname = 1

    # Resolve the group name from /etc/group.
    grp_n: uint64 = slurp("/etc/group", &grp_buf[0], 4096)
    have_gname: int32 = group_name_by_gid(&grp_buf[0], grp_n, gid,
                                          &gname[0], 64)

    pos: uint64 = 0
    pos = emit_field("uid=", uid, uname, have_uname, pos)
    out_buf[pos] = 32                                    # ' '
    pos = pos + 1
    pos = emit_field("gid=", gid, &gname[0], have_gname, pos)
    out_buf[pos] = 32                                    # ' '
    pos = pos + 1
    # Single primary group (Hamnix has no supplementary-group machinery
    # in v1), so `groups=` mirrors the primary gid.
    pos = emit_field("groups=", gid, &gname[0], have_gname, pos)
    out_buf[pos] = 10                                    # '\n'
    pos = pos + 1

    sys_write(1, &out_buf[0], pos)
    return 0

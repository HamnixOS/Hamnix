# user/id.ad
#
# Print the Linux-style identity triplet. Hamnix has no /etc/passwd or
# /etc/group yet, so all fields are hard-wired to uid 0; this keeps
# shell scripts that branch on `id -u` from special-casing our OS.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def main() -> int32:
    sys_write(1, "uid=0(root) gid=0(root) groups=0(root)\n", 39)
    return 0

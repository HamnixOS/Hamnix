# user/cp.ad
#
# Hamnix `cp SRC DST`: copy a single file. Bounded at 8 KiB total
# because as of M16.64 our tmpfs and ext4-writer back files with a
# single block; a larger payload would silently truncate. Reads SRC
# in one buffer then writes DST in one shot — the simplest path
# that still exercises the open/read/open_write/write/close API.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


CAP: uint64 = 8192
# Global buf — 8 KiB is too large for a comfortable stack frame.
data: Array[8192, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        write_str(2, "cp: usage: cp SRC DST\n")
        return 1
    src: Ptr[char] = cast[Ptr[char]](argv[1])
    dst: Ptr[char] = cast[Ptr[char]](argv[2])
    in_fd: int32 = sys_open(src)
    if in_fd < 0:
        write_str(2, "cp: cannot open ")
        write_str(2, cast[Ptr[uint8]](src))
        write_str(2, "\n")
        return 1
    # Drain SRC into the buffer. We stop at CAP; anything beyond
    # the cap is silently dropped (the M16.64 single-block limit
    # makes a multi-syscall streaming loop pointless here).
    total: uint64 = 0
    while total < CAP:
        room: uint64 = CAP - total
        n: int64 = sys_read(in_fd, cast[Ptr[uint8]](cast[uint64](&data[0]) + total), room)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(in_fd)
    out_fd: int32 = sys_open_write(dst)
    if out_fd < 0:
        write_str(2, "cp: cannot open ")
        write_str(2, cast[Ptr[uint8]](dst))
        write_str(2, "\n")
        return 1
    if total > 0:
        sys_write(out_fd, &data[0], total)
    sys_close(out_fd)
    return 0

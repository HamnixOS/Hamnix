# user/grep.ad
#
# Native Hamnix `grep` — line filter with real regular expressions, no
# Linux namespace. Reads FILE operands (or stdin) line-by-line and
# prints the lines a pattern selects.
#
# Regex engine: the shared, extern-free lib/regex.ad (also used by sed).
#   * default        Basic REs (BRE): literals, `.`, `*`, `[...]`
#                    classes + POSIX `[:class:]`, `^`/`$` anchors, `\c`.
#   * -E / egrep     Extended REs (ERE): all of BRE PLUS `+`, `?`,
#                    `{n}`/`{n,}`/`{n,m}`, alternation `|`, grouping `()`.
#   * -F             fixed strings (plain substring, no metacharacters).
#
# Flags:
#   -E  extended regex        -F  fixed strings
#   -i  ignore case           -v  invert (select non-matching lines)
#   -c  print a count only    -n  prefix the 1-based line number
#   -o  print only the match  -w  match whole words
#   -x  match the whole line  -e PATTERN  (may repeat; add a pattern)
# Bundled short flags (`-in`, `-Ev`, ...) are accepted; `e` must be last
# in a bundle because it consumes an argument.
#
# Exit status matches GNU grep: 0 = a line was selected, 1 = none, 2 =
# an error (bad pattern or a file that could not be opened).
#
# Files are opened with the 3-arg sys_open thunk (like diff/sort/join)
# so the QEMU-free host cross-check can open real files: the on-device
# runtime reads only %rdi (path, O_RDONLY); the host thunk gets
# flags=0/mode=0 == O_RDONLY.

from lib.regex import (rx_compile, rx_search, rx_mstart, rx_mend)

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_close(fd: int32) -> int32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n

def write_err(s: Ptr[uint8]):
    sys_write(2, s, strlen_u8(s))

def str_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] == b[i]:
        return 1
    return 0


# ---- flags ----
f_ere:   int32 = 0
f_fixed: int32 = 0
f_icase: int32 = 0
f_inv:   int32 = 0
f_count: int32 = 0
f_num:   int32 = 0
f_only:  int32 = 0
f_word:  int32 = 0
f_line:  int32 = 0

# ---- patterns ----
patbuf:  Array[8192, uint8]
patbuf_len: uint64 = 0
pat_off: Array[64, int32]
pat_len: Array[64, int32]
npat:    int32 = 0
active_pat: int32 = -1        # which pattern is currently compiled

# ---- current line + match span ----
LINE_BUF: uint64 = 65536
line: Array[65536, uint8]
gm_s: uint64 = 0
gm_e: uint64 = 0

any_selected: int32 = 0


def add_pattern(s: Ptr[uint8]):
    if npat >= 64:
        return
    off: uint64 = patbuf_len
    i: uint64 = 0
    while s[i] != 0 and patbuf_len < 8192:
        patbuf[patbuf_len] = s[i]
        patbuf_len = patbuf_len + 1
        i = i + 1
    pat_off[npat] = cast[int32](off)
    pat_len[npat] = cast[int32](patbuf_len - off)
    npat = npat + 1


def is_word(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return 1
    if c >= 65 and c <= 90:
        return 1
    if c >= 97 and c <= 122:
        return 1
    if c == 95:
        return 1
    return 0


def to_lower(c: uint8) -> uint8:
    if c >= 65 and c <= 90:
        return c + 32
    return c


# Compile pattern pi into the regex engine (cached via active_pat).
def use_pattern(pi: int32) -> int32:
    if active_pat == pi:
        return 0
    off: uint64 = cast[uint64](pat_off[pi])
    plen: uint64 = cast[uint64](pat_len[pi])
    if rx_compile(&patbuf[off], plen, f_ere, f_icase) != 0:
        active_pat = -1
        return -1
    active_pat = pi
    return 0


# Plain substring search of pattern pi in line[0..len) at/after `pos`.
# On success sets gm_s/gm_e, returns 1; else 0.
def fixed_search_one(pi: int32, len: uint64, pos: uint64) -> int32:
    off: uint64 = cast[uint64](pat_off[pi])
    plen: uint64 = cast[uint64](pat_len[pi])
    if plen == 0:
        gm_s = pos
        gm_e = pos
        return 1
    if plen > len:
        return 0
    i: uint64 = pos
    while i + plen <= len:
        j: uint64 = 0
        hit: int32 = 1
        while j < plen:
            a: uint8 = line[i + j]
            b: uint8 = patbuf[off + j]
            if f_icase == 1:
                if to_lower(a) != to_lower(b):
                    hit = 0
                    break
            else:
                if a != b:
                    hit = 0
                    break
            j = j + 1
        if hit == 1:
            gm_s = i
            gm_e = i + plen
            return 1
        i = i + 1
    return 0


# Leftmost match of ANY pattern in line[0..len) at/after `pos`, honoring
# -F/-E. Sets gm_s/gm_e (leftmost start; longest end on a tie). Returns 1
# if found, else 0.
def raw_search(len: uint64, pos: uint64) -> int32:
    best: int32 = 0
    bs: uint64 = 0
    be: uint64 = 0
    pi: int32 = 0
    while pi < npat:
        got: int32 = 0
        cs: uint64 = 0
        ce: uint64 = 0
        if f_fixed == 1:
            if fixed_search_one(pi, len, pos) == 1:
                got = 1
                cs = gm_s
                ce = gm_e
        else:
            if use_pattern(pi) == 0:
                r: int64 = rx_search(&line[0], len, pos)
                if r >= 0:
                    got = 1
                    cs = cast[uint64](rx_mstart)
                    ce = cast[uint64](rx_mend)
        if got == 1:
            if best == 0 or cs < bs or (cs == bs and ce > be):
                best = 1
                bs = cs
                be = ce
        pi = pi + 1
    if best == 1:
        gm_s = bs
        gm_e = be
        return 1
    return 0


# Find a match honoring -w and -x, searching at/after `pos`. Sets
# gm_s/gm_e, returns 1 if found.
def find_match(len: uint64, pos: uint64) -> int32:
    p: uint64 = pos
    while p <= len:
        if raw_search(len, p) == 0:
            return 0
        cs: uint64 = gm_s
        ce: uint64 = gm_e
        ok: int32 = 1
        if f_word == 1:
            before_ok: int32 = 0
            if cs == 0:
                before_ok = 1
            elif is_word(line[cs - 1]) == 0:
                before_ok = 1
            after_ok: int32 = 0
            if ce == len:
                after_ok = 1
            elif is_word(line[ce]) == 0:
                after_ok = 1
            if before_ok == 0 or after_ok == 0:
                ok = 0
        if ok == 1 and f_line == 1:
            if cs != 0 or ce != len:
                ok = 0
        if ok == 1:
            gm_s = cs
            gm_e = ce
            return 1
        # advance past this start and retry
        if cs < len:
            p = cs + 1
        else:
            return 0
    return 0


# ---- output helpers ----
def write_uint(v: uint64):
    buf: Array[24, uint8]
    if v == 0:
        sys_write(1, "0", 1)
        return
    n: uint64 = 0
    tmp: uint64 = v
    while tmp > 0:
        buf[n] = cast[uint8](48 + tmp % 10)
        tmp = tmp / 10
        n = n + 1
    # reverse
    i: uint64 = 0
    while i < n / 2:
        t: uint8 = buf[i]
        buf[i] = buf[n - 1 - i]
        buf[n - 1 - i] = t
        i = i + 1
    sys_write(1, &buf[0], n)


def emit_prefix(fname: Ptr[uint8], multi: int32, lnum: uint64):
    if multi == 1:
        sys_write(1, fname, strlen_u8(fname))
        sys_write(1, ":", 1)
    if f_num == 1:
        write_uint(lnum)
        sys_write(1, ":", 1)


# Process one assembled line. `cnt` accumulates the per-source match
# count (for -c).
def handle_line(len: uint64, lnum: uint64, fname: Ptr[uint8], multi: int32, cnt: Ptr[int32]):
    sel: int32 = find_match(len, 0)
    if f_inv == 1:
        sel = 1 - sel
    if sel == 0:
        return
    cnt[0] = cnt[0] + 1
    any_selected = 1
    if f_count == 1:
        return
    if f_only == 1 and f_inv == 0:
        pos: uint64 = 0
        while find_match(len, pos) == 1:
            emit_prefix(fname, multi, lnum)
            sys_write(1, &line[gm_s], gm_e - gm_s)
            sys_write(1, "\n", 1)
            if gm_e > gm_s:
                pos = gm_e
            else:
                pos = gm_s + 1
        return
    emit_prefix(fname, multi, lnum)
    sys_write(1, &line[0], len)
    sys_write(1, "\n", 1)


# Scan an open fd line-by-line.
def grep_fd(fd: int32, fname: Ptr[uint8], multi: int32):
    chunk: Array[4096, uint8]
    line_pos: uint64 = 0
    lnum: uint64 = 0
    cnt: int32 = 0
    while True:
        n: int64 = sys_read(fd, &chunk[0], 4096)
        if n <= 0:
            break
        i: uint64 = 0
        while i < cast[uint64](n):
            c: uint8 = chunk[i]
            if c == 10:
                lnum = lnum + 1
                handle_line(line_pos, lnum, fname, multi, &cnt)
                line_pos = 0
            else:
                if line_pos + 1 < LINE_BUF:
                    line[line_pos] = c
                    line_pos = line_pos + 1
            i = i + 1
    if line_pos > 0:
        lnum = lnum + 1
        handle_line(line_pos, lnum, fname, multi, &cnt)
    if f_count == 1:
        if multi == 1:
            sys_write(1, fname, strlen_u8(fname))
            sys_write(1, ":", 1)
        write_uint(cast[uint64](cnt))
        sys_write(1, "\n", 1)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    files: Array[256, uint64]
    n_files: int32 = 0
    pat_from_flag: int32 = 0
    have_pat: int32 = 0
    end_opts: int32 = 0

    i: int32 = 1
    while i < argc:
        arg: Ptr[uint8] = cast[Ptr[uint8]](argv[i])
        if end_opts == 0 and arg[0] == 45 and arg[1] != 0:      # '-x...'
            if arg[1] == 45 and arg[2] == 0:                    # '--'
                end_opts = 1
                i = i + 1
                continue
            # bundled short flags
            j: uint64 = 1
            bad: int32 = 0
            while arg[j] != 0:
                fc: uint8 = arg[j]
                if fc == 69:                                    # E
                    f_ere = 1
                elif fc == 70:                                  # F
                    f_fixed = 1
                elif fc == 105:                                 # i
                    f_icase = 1
                elif fc == 118:                                 # v
                    f_inv = 1
                elif fc == 99:                                  # c
                    f_count = 1
                elif fc == 110:                                 # n
                    f_num = 1
                elif fc == 111:                                 # o
                    f_only = 1
                elif fc == 119:                                 # w
                    f_word = 1
                elif fc == 120:                                 # x
                    f_line = 1
                elif fc == 101:                                 # e (takes arg)
                    if arg[j + 1] != 0:
                        add_pattern(&arg[j + 1])
                    else:
                        i = i + 1
                        if i >= argc:
                            write_err("grep: option requires an argument -- e\n")
                            return 2
                        add_pattern(cast[Ptr[uint8]](argv[i]))
                    pat_from_flag = 1
                    have_pat = 1
                    bad = 2                                     # consumed rest of arg
                else:
                    write_err("grep: unknown option\n")
                    return 2
                if bad == 2:
                    break
                j = j + 1
        else:
            if have_pat == 0 and pat_from_flag == 0:
                add_pattern(arg)
                have_pat = 1
            else:
                if n_files < 256:
                    files[n_files] = argv[i]
                    n_files = n_files + 1
        i = i + 1

    if have_pat == 0:
        write_err("grep: usage: grep [OPTIONS] PATTERN [FILE...]\n")
        return 2

    # Validate regex patterns up front (bad pattern -> exit 2).
    if f_fixed == 0:
        pi: int32 = 0
        while pi < npat:
            if use_pattern(pi) != 0:
                write_err("grep: invalid regular expression\n")
                return 2
            pi = pi + 1
        active_pat = -1

    multi: int32 = 0
    if n_files > 1:
        multi = 1

    if n_files == 0:
        grep_fd(0, "(standard input)", 0)
    else:
        open_err: int32 = 0
        fi: int32 = 0
        while fi < n_files:
            path: Ptr[char] = cast[Ptr[char]](files[fi])
            fd: int32 = sys_open(path, 0, 0)
            if fd < 0:
                write_err("grep: cannot open ")
                write_err(cast[Ptr[uint8]](path))
                write_err("\n")
                open_err = 1
            else:
                grep_fd(fd, cast[Ptr[uint8]](path), multi)
                sys_close(fd)
            fi = fi + 1
        if open_err == 1:
            return 2

    if any_selected == 1:
        return 0
    return 1

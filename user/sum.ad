# user/sum.ad
#
# Hamnix `sum`: checksum and count the blocks of each FILE (or stdin).
# Two historical algorithms, matching coreutils:
#
#   default / -r : BSD 16-bit rotate checksum, block size 1024 bytes.
#   -s / --sysv  : System V 16-bit additive checksum, block size 512.
#
# Output is "<checksum> <blocks>[ <name>]\n" — the classic pre-cksum
# integrity check, still used by old release manifests and embedded
# firmware tooling. Providing it natively keeps that workflow off the
# Linux namespace.
#
#   echo -n abc | sum        -> "16556 1"   (BSD)
#   echo -n abc | sum -s     -> "294 1"     (SysV)

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


# Append the decimal form of v to out[p], returning the new p.
def put_dec(out: Ptr[uint8], p: uint64, v: uint64) -> uint64:
    if v == 0:
        out[p] = 48
        return p + 1
    tmp: Array[24, uint8]
    ti: uint64 = 0
    x: uint64 = v
    while x != 0:
        tmp[ti] = cast[uint8](x % 10) + 48
        x = x / 10
        ti = ti + 1
    j: uint64 = 0
    while j < ti:
        out[p] = tmp[ti - 1 - j]
        p = p + 1
        j = j + 1
    return p


CHUNK: Array[4096, uint8]


# Checksum one fd. sysv != 0 selects the System V algorithm, else BSD.
# Writes "<checksum> <blocks>" (no trailing newline) to stdout, then the
# caller appends the optional name + newline.
def sum_fd(fd: int32, sysv: int32):
    bsd: uint32 = 0
    sysv_acc: uint64 = 0
    total: uint64 = 0
    while True:
        n: int64 = sys_read(fd, &CHUNK[0], 4096)
        if n <= 0:
            break
        i: uint64 = 0
        while i < cast[uint64](n):
            c: uint32 = cast[uint32](CHUNK[i])
            if sysv != 0:
                sysv_acc = sysv_acc + cast[uint64](c)
            else:
                bsd = (bsd >> 1) | ((bsd & 1) << 15)
                bsd = (bsd + c) & 0xFFFF
            i = i + 1
        total = total + cast[uint64](n)

    checksum: uint64 = 0
    blocks: uint64 = 0
    if sysv != 0:
        r: uint64 = (sysv_acc & 0xFFFF) + ((sysv_acc >> 16) & 0xFFFF)
        checksum = (r & 0xFFFF) + (r >> 16)
        blocks = (total + 511) / 512
    else:
        checksum = cast[uint64](bsd)
        blocks = (total + 1023) / 1024

    out: Array[64, uint8]
    p: uint64 = 0
    if sysv != 0:
        # SysV: plain decimal checksum.
        p = put_dec(&out[0], p, checksum)
    else:
        # BSD: checksum zero-padded to a 5-digit field (matches GNU %05d).
        digits: uint64 = 1
        t: uint64 = checksum
        while t >= 10:
            t = t / 10
            digits = digits + 1
        while digits < 5:
            out[p] = 48
            p = p + 1
            digits = digits + 1
        p = put_dec(&out[0], p, checksum)
    out[p] = 32
    p = p + 1
    p = put_dec(&out[0], p, blocks)
    sys_write(1, &out[0], p)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    sysv: int32 = 0
    first_file: int32 = argc                    # index past the flags

    # Parse leading flags (-s/-r, and --sysv). Stop at the first
    # non-flag or "--".
    ai: int32 = 1
    while ai < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
        if a[0] != 45 or a[1] == 0:             # not "-..." -> a file
            first_file = ai
            break
        if a[1] == 45 and a[2] == 0:            # "--" ends flags
            first_file = ai + 1
            break
        # short-flag cluster
        if a[1] == 115:                          # "-s..."
            sysv = 1
        # "-r" is the BSD default; nothing to toggle.
        ai = ai + 1
        first_file = ai

    # No file operands -> checksum stdin, no trailing name.
    if first_file >= argc:
        sum_fd(0, sysv)
        write_str(1, "\n")
        return 0

    rc: int32 = 0
    fi: int32 = first_file
    while fi < argc:
        path: Ptr[char] = cast[Ptr[char]](argv[cast[uint64](fi)])
        fd: int32 = sys_open(path)
        if fd < 0:
            write_str(2, "sum: cannot open ")
            write_str(2, cast[Ptr[uint8]](path))
            write_str(2, "\n")
            rc = 1
        else:
            sum_fd(fd, sysv)
            sys_close(fd)
            write_str(1, " ")
            write_str(1, cast[Ptr[uint8]](path))
            write_str(1, "\n")
        fi = fi + 1
    return rc

# user/kill.ad
#
# `kill [-SIG] PID` — calls sys_kill(pid, sig). Default sig is 15
# (SIGTERM), matching POSIX. Signal can be passed as `-9`, `-15`,
# etc. (numeric only — we don't have the SIG* name table yet).
# Exit 0 on success, 1 on bad args / kernel error.

extern def sys_kill(pid: int32, sig: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def parse_int(s: Ptr[uint8]) -> int32:
    n: int32 = 0
    i: uint64 = 0
    while s[i] != 0:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            return -1
        n = n * 10 + cast[int32](c - 48)
        i = i + 1
    return n


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "kill: usage: kill [-SIG] PID\n")
        return 1
    sig: int32 = 15
    pid_arg_i: int32 = 1
    first: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    if first[0] == 45:                              # '-'
        # -SIG form. argv[2] must be the PID.
        if argc < 3:
            write_str(2, "kill: missing PID\n")
            return 1
        v: int32 = parse_int(cast[Ptr[uint8]](
            cast[uint64](first) + 1))
        if v < 0:
            write_str(2, "kill: bad signal\n")
            return 1
        sig = v
        pid_arg_i = 2
    pid_str: Ptr[uint8] = cast[Ptr[uint8]](
        argv[cast[uint64](pid_arg_i)])
    pid: int32 = parse_int(pid_str)
    if pid < 0:
        write_str(2, "kill: bad PID\n")
        return 1
    rc: int32 = sys_kill(pid, sig)
    if rc < 0:
        write_str(2, "kill: sys_kill failed\n")
        return 1
    return 0

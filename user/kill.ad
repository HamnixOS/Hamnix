# user/kill.ad
#
# `kill [-SIG] PID` — Plan-9 note send. SIG selects a note string; we
# accept the standard POSIX numerals from when this was a SYS_KILL
# call (default 15 = SIGTERM = "terminate") AND the Plan-9 note
# verbs directly ("kill", "interrupt", "hangup", "terminate", ...).
#
# Under the hood we open /proc/<PID>/note and write the note message
# (lib/p9.ad's p9_note). The retired SYS_KILL drift arm is gone from
# the kernel; this is the only path. Exit 0 on a successful write,
# 1 on bad args / write failure / target not found.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
from lib.p9 import p9_note


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def parse_int(s: Ptr[uint8]) -> int32:
    # Return -1 if `s` is not a pure decimal integer.
    n: int32 = 0
    i: uint64 = 0
    if s[0] == 0:
        return -1
    while s[i] != 0:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            return -1
        n = n * 10 + cast[int32](c - 48)
        i = i + 1
    return n


def cstr_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] != b[i]:
        return 0
    return 1


# Map a signal SPEC (POSIX numeral OR Plan-9 note string) to the note
# string written to /proc/<pid>/note. Returns NULL on unrecognised
# input. Common POSIX signals are aliased; the canonical Plan-9 verbs
# pass through.
def sig_to_note(spec: Ptr[uint8]) -> Ptr[uint8]:
    # Numeric form: parse + map. parse_int returns -1 on a non-numeral,
    # so anything non-numeric falls through to the string-name table.
    n: int32 = parse_int(spec)
    if n >= 0:
        if n == 1:                  # SIGHUP
            return cast[Ptr[uint8]]("hangup")
        if n == 2:                  # SIGINT
            return cast[Ptr[uint8]]("interrupt")
        if n == 9:                  # SIGKILL
            return cast[Ptr[uint8]]("kill")
        if n == 14:                 # SIGALRM
            return cast[Ptr[uint8]]("alarm")
        if n == 15:                 # SIGTERM
            return cast[Ptr[uint8]]("terminate")
        # Unmapped numeric — pass through as the digits themselves. The
        # target's note handler is free to interpret it; matches Plan-9
        # "any string is a valid note" idiom.
        return spec
    # String form: recognise common Plan-9 verbs verbatim so they pass
    # through without a sentinel "verb didn't map" error.
    if cstr_eq(spec, cast[Ptr[uint8]]("kill")) != 0:
        return spec
    if cstr_eq(spec, cast[Ptr[uint8]]("interrupt")) != 0:
        return spec
    if cstr_eq(spec, cast[Ptr[uint8]]("hangup")) != 0:
        return spec
    if cstr_eq(spec, cast[Ptr[uint8]]("terminate")) != 0:
        return spec
    if cstr_eq(spec, cast[Ptr[uint8]]("alarm")) != 0:
        return spec
    # Unknown: caller surfaces "bad signal".
    return cast[Ptr[uint8]](0)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, cast[Ptr[uint8]](
            "kill: usage: kill [-SIG] PID\n"))
        return 1
    sig_spec: Ptr[uint8] = cast[Ptr[uint8]]("15")   # default = SIGTERM
    pid_arg_i: int32 = 1
    first: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    if first[0] == 45:                              # '-'
        if argc < 3:
            write_str(2, cast[Ptr[uint8]]("kill: missing PID\n"))
            return 1
        sig_spec = cast[Ptr[uint8]](cast[uint64](first) + 1)
        pid_arg_i = 2
    pid_str: Ptr[uint8] = cast[Ptr[uint8]](
        argv[cast[uint64](pid_arg_i)])
    pid: int32 = parse_int(pid_str)
    if pid < 0:
        write_str(2, cast[Ptr[uint8]]("kill: bad PID\n"))
        return 1
    note: Ptr[uint8] = sig_to_note(sig_spec)
    if cast[uint64](note) == 0:
        write_str(2, cast[Ptr[uint8]]("kill: bad signal\n"))
        return 1
    rc: int32 = p9_note(pid, note)
    if rc < 0:
        write_str(2, cast[Ptr[uint8]](
            "kill: note write failed\n"))
        return 1
    return 0

# user/hamcalcscene_host.ad — HOST driver + render harness for the calculator
# scene app (built for the x86_64-linux Adder target; runs on the dev host,
# no QEMU).
#
# Drives the SAME core the native app ships (lib/hamcalccore.ad): inits the
# keypad, lays out for the default 188x248 window, builds the scene display
# list and RASTERIZES it with lib/hamui_host.ad into a PPM a human/agent can
# LOOK at. Then it feeds SCRIPTED input — a keyboard expression AND an
# on-screen pointer press on a keypad button — through the core's pure input
# handlers and asserts the arithmetic result, rendering a second "after" PPM.
# It dumps the raw scene display list + sampled pixels + the accumulator so
# the gate can assert without eyeballing.
#
# No sockets, no Plan 9: reads argv + writes two files. TEST shim only.
#
# USAGE (built to build/host/hamcalc_host):
#   hamcalc_host BEFORE.ppm AFTER.ppm [KEYS]

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamcalccore import hamcalc_init, hamcalc_clear, hamcalc_layout, \
    hamcalc_build_scene, hamcalc_key_line, hamcalc_key_at, hamcalc_press_at, \
    hamcalc_acc, hamcalc_err, hamcalc_display, hamcalc_release


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)                                          # '#'
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hamcalc_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


# Feed one keyboard press for ASCII byte `code` through the key-line parser.
kl: Array[16, uint8]


def _press_key(code: int32) -> int32:
    kl[0] = 100                                        # 'd'
    kl[1] = 32
    p: uint64 = 2
    if code >= 100:
        kl[p] = cast[uint8](code / 100) + 48
        p = p + 1
    if code >= 10:
        kl[p] = cast[uint8]((code / 10) % 10) + 48
        p = p + 1
    kl[p] = cast[uint8](code % 10) + 48
    p = p + 1
    return hamcalc_key_line(&kl[0], p)


# Drive a NUL-terminated ASCII key string through the key-line parser.
def _drive(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _press_key(cast[int32](s[i]))
        i = i + 1


# Print "RESULT <name> <display>\n" for the current calculator display.
def _report(name: Ptr[uint8]):
    _o_str(cast[Ptr[uint8]]("RESULT "))
    _o_str(name)
    _o_ch(32)
    _o_str(hamcalc_display())
    _o_ch(10)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hamcalc_host BEFORE.ppm AFTER.ppm [KEYS]\n"))
        _o_flush()
        return 2

    W: int32 = 188
    H: int32 = 300
    hamcalc_init()
    hamcalc_layout()
    hamcalc_clear()

    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))

    _o_str(cast[Ptr[uint8]]("PRIMS "))
    _o_dec(cast[int64](prims))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("DISPLAY0 "))
    _o_str(hamcalc_display())
    _o_ch(10)
    # Sampled raster pixels: case bg, LCD bg, a keypad-button face.
    _o_str(cast[Ptr[uint8]]("PIX 2 2 "))
    _o_hexcol(hamui_host_pixel(2, 2))                  # case #2b2f36
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 20 20 "))
    _o_hexcol(hamui_host_pixel(20, 20))                # LCD #0d1410
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 12 64 "))
    _o_hexcol(hamui_host_pixel(12, 64))                # top-left key face #c8c4bc
    _o_ch(10)
    # Modern ROUNDED flat button (top-left key @8,60 40x35, radius 5):
    # the very corner (8,60) is cut away (shows the case bg behind it), the
    # straight left edge is the hairline frame, a faint top sheen + bottom
    # shadow give a whisper of depth.
    _o_str(cast[Ptr[uint8]]("PIX 8 60 "))
    _o_hexcol(hamui_host_pixel(8, 60))                 # rounded corner -> case bg
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 8 77 "))
    _o_hexcol(hamui_host_pixel(8, 77))                 # left straight-edge frame
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 20 61 "))
    _o_hexcol(hamui_host_pixel(20, 61))                # top highlight sheen
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 20 93 "))
    _o_hexcol(hamui_host_pixel(20, 93))                # bottom shadow
    _o_ch(10)
    # AA proof: a pixel on the top-left corner arc blends frame ink with the
    # case bg (neither pure #c2c5cd nor pure #2b2f36).
    _o_str(cast[Ptr[uint8]]("PIX 10 60 "))
    _o_hexcol(hamui_host_pixel(10, 60))                 # anti-aliased corner band
    _o_ch(10)
    _o_flush()

    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()

    # ---- SCRIPTED INPUT: one scenario per everyday operation ------------
    # Legacy expression (keyboard), default "7*6=" -> 42.
    keys: Ptr[uint8] = cast[Ptr[uint8]]("7*6=")
    if argc >= 4:
        keys = cast[Ptr[uint8]](argv[3])
    hamcalc_clear()
    _drive(keys)
    _o_str(cast[Ptr[uint8]]("DISPLAY1 "))
    _o_str(hamcalc_display())
    _o_ch(10)

    # Chained ops: 2+3+4 = 9.
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("2+3+4="))
    _report(cast[Ptr[uint8]]("chain"))

    # Operator-after-equals: 7*6=  then *2= continues from 42 -> 84.
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("7*6=*2="))
    _report(cast[Ptr[uint8]]("op_after_eq"))

    # Decimal-point add: 1.5 + 2.5 = 4.
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("1.5+2.5="))
    _report(cast[Ptr[uint8]]("dec_add"))

    # Decimal entry formatting (no equals): shows exactly "3.14".
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("3.14"))
    _report(cast[Ptr[uint8]]("dec_entry"))

    # Leading "0." for a bare fraction: ".5" -> "0.5".
    hamcalc_clear()
    _drive(cast[Ptr[uint8]](".5"))
    _report(cast[Ptr[uint8]]("dec_lead"))

    # Only one '.': "1..2.3" collapses to "1.23".
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("1..2.3"))
    _report(cast[Ptr[uint8]]("dec_one_dot"))

    # Division yields a fraction: 7/2 = 3.5.
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("7/2="))
    _report(cast[Ptr[uint8]]("div"))

    # sqrt via an ON-SCREEN BUTTON CLICK (hit-test index 4, then press): 9 -> 3.
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("9"))
    ksq: int64 = hamcalc_key_at(28, 116)               # centre of the sqrt key
    _o_str(cast[Ptr[uint8]]("KEYAT 28 116 "))
    _o_dec(ksq)
    _o_ch(10)
    if ksq >= 0:
        hamcalc_press_at(ksq)
    _drive(cast[Ptr[uint8]]("="))
    _report(cast[Ptr[uint8]]("sqrt"))

    # reciprocal via button index 6: 4 -> 0.25.
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("4"))
    hamcalc_press_at(6)
    _report(cast[Ptr[uint8]]("recip"))

    # square via button index 19: 3 -> 9.
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("3"))
    hamcalc_press_at(19)
    _report(cast[Ptr[uint8]]("square"))

    # sign toggle via button index 22: 5 -> -5.
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("5"))
    hamcalc_press_at(22)
    _report(cast[Ptr[uint8]]("sign"))

    # percent additive via button index 5: 200 + 10 % = -> 220.
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("200+10"))
    hamcalc_press_at(5)
    _report(cast[Ptr[uint8]]("pct_add_pre"))          # entry becomes 20
    _drive(cast[Ptr[uint8]]("="))
    _report(cast[Ptr[uint8]]("pct_add"))

    # percent standalone via button index 5: 50 % -> 0.5.
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("50"))
    hamcalc_press_at(5)
    _report(cast[Ptr[uint8]]("pct_std"))

    # backspace via keyboard (code 8): "12" backspace -> "1".
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("12"))
    _press_key(8)
    _report(cast[Ptr[uint8]]("bksp"))

    # clear-entry (CE, button index 0): 5 + 3, CE -> "0"; then 7 = -> 12.
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("5+3"))
    hamcalc_press_at(0)
    _report(cast[Ptr[uint8]]("ce_disp"))
    _drive(cast[Ptr[uint8]]("7="))
    _report(cast[Ptr[uint8]]("ce_then"))

    # divide-by-zero latches ERR.
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("5/0="))
    _report(cast[Ptr[uint8]]("divzero"))
    _o_str(cast[Ptr[uint8]]("ERR "))
    _o_dec(cast[int64](hamcalc_err()))
    _o_ch(10)
    _o_flush()

    # #329: running EXPRESSION on the LCD as you type. Each step shows the
    # accumulated expression, not just the last operand.
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("5"))
    _o_str(cast[Ptr[uint8]]("EXPR d1 "))
    _o_str(hamcalc_display())                           # "5"
    _o_ch(10)
    _drive(cast[Ptr[uint8]]("+"))
    _o_str(cast[Ptr[uint8]]("EXPR op "))
    _o_str(hamcalc_display())                           # "5+"
    _o_ch(10)
    _drive(cast[Ptr[uint8]]("5"))
    _o_str(cast[Ptr[uint8]]("EXPR d2 "))
    _o_str(hamcalc_display())                           # "5+5"
    _o_ch(10)
    _drive(cast[Ptr[uint8]]("="))
    _o_str(cast[Ptr[uint8]]("EXPR eq "))
    _o_str(hamcalc_display())                           # "10"
    _o_ch(10)
    # longer running expression: "12+3*2" mid-entry (before '=').
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("12+3*2"))
    _o_str(cast[Ptr[uint8]]("EXPR chain "))
    _o_str(hamcalc_display())                           # "12+3*2"
    _o_ch(10)
    _o_flush()

    # Legacy division check: keep `after_div 3.333333` alive for the gate.
    hamcalc_clear()
    hamcalc_release()                                  # drop any latched sink
    _drive(cast[Ptr[uint8]]("10/3="))
    _o_str(cast[Ptr[uint8]]("RESULT after_div "))
    _o_str(hamcalc_display())
    _o_ch(10)

    # ---- AFTER render: the running expression "5+5" mid-entry (BEFORE '='),
    # so the PNG a human LOOKS at shows the whole formula on the LCD — the
    # #329 user-visible fix — over the new keypad.
    hamcalc_clear()
    _drive(cast[Ptr[uint8]]("5+5"))
    prims2: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _o_str(cast[Ptr[uint8]]("PRIMS2 "))
    _o_dec(cast[int64](prims2))
    _o_ch(10)
    _o_flush()
    return 0

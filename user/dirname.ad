# user/dirname.ad
#
# Hamnix `dirname PATH`: prints everything up to (but not including)
# the final '/' in argv[1]. With no slash, prints "." per POSIX. We
# do NOT strip trailing slashes the way real coreutils does — at
# Hamnix scale paths come from hamsh tokenisation, which already
# drops trailing slashes, so the simpler "last-slash split" is sound.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "dirname: missing operand\n")
        return 1
    path: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    n: uint64 = strlen_u8(path)
    # Find last '/'. -1 sentinel via "found" flag because uint64 has
    # no signed sentinel and we want to distinguish "no slash" from
    # "slash at index 0".
    last: uint64 = 0
    found: int32 = 0
    i: uint64 = 0
    while i < n:
        if path[i] == 47:
            last = i
            found = 1
        i = i + 1
    if found == 0:
        sys_write(1, ".\n", 2)
        return 0
    # Leading '/' alone (e.g. "/foo") -> print "/" so we never emit
    # an empty line before the newline.
    if last == 0:
        sys_write(1, "/\n", 2)
        return 0
    sys_write(1, path, last)
    sys_write(1, "\n", 1)
    return 0

# user/hamgamechess_host.ad — "Chess" hamGame board-game HOST render + drive
# harness (built for x86_64-linux; runs on the dev host, NO QEMU).
#
# Drives the SAME game the device app ships (lib/hamgamechess.ad) through the SAME
# public hamGame API, but with the HOST backend (lib/hamgame_host.ad): it renders
# frames to binary PPMs a human/agent can LOOK at, drives DETERMINISTIC scripted
# move sequences (chess_move, no real-time input), and dumps board state + sampled
# framebuffer pixels so scripts/test_hamgamechess_host.sh can assert on the start
# position, a legal opening, a capture, turn alternation and an illegal-move
# rejection WITHOUT eyeballing.
#
# USAGE (built to build/host/hamgamechess_host):
#   hamgamechess_host START.ppm OPENING.ppm CAPTURE.ppm

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

from lib.hamgame import game_reset, game_flip_scene
from lib.hamgame_host import game_host_present, game_host_write_ppm, \
    game_host_pixel
from lib.hamgamechess import ch_init, ch_reattach_display, ch_render, \
    ch_display_surf, chess_move, chess_piece_at, chess_turn, \
    chess_piece_count, ch_cell_px_x, ch_cell_px_y, CH_CELL, CH_N


CHW: int32 = 208
CHH: int32 = 232


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(ch: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = ch
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_kv(k: Ptr[uint8], v: int64):
    _o_str(k)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- pixel sampling ------------------------------------------------------
# Count near-WHITE glyph pixels (White-piece letters = (245,245,245)) inside the
# square at board (col,row). The light square is (222,210,180), so >235 on all
# channels isolates the glyph strokes from the square.
def _sq_white(col: int32, row: int32) -> int32:
    x0: int32 = ch_cell_px_x(col)
    y0: int32 = ch_cell_px_y(row)
    n: int32 = 0
    yy: int32 = 0
    while yy < CH_CELL:
        xx: int32 = 0
        while xx < CH_CELL:
            p: uint32 = game_host_pixel(x0 + xx, y0 + yy)
            r: int32 = cast[int32]((p >> 16) & 255)
            g: int32 = cast[int32]((p >> 8) & 255)
            b: int32 = cast[int32](p & 255)
            if r > 235 and g > 235 and b > 235:
                n = n + 1
            xx = xx + 1
        yy = yy + 1
    return n


# Count near-BLACK glyph pixels (Black-piece letters = (25,25,25)) inside the
# square: <40 on all channels isolates the strokes from either square colour.
def _sq_black(col: int32, row: int32) -> int32:
    x0: int32 = ch_cell_px_x(col)
    y0: int32 = ch_cell_px_y(row)
    n: int32 = 0
    yy: int32 = 0
    while yy < CH_CELL:
        xx: int32 = 0
        while xx < CH_CELL:
            p: uint32 = game_host_pixel(x0 + xx, y0 + yy)
            r: int32 = cast[int32]((p >> 16) & 255)
            g: int32 = cast[int32]((p >> 8) & 255)
            b: int32 = cast[int32](p & 255)
            if r < 40 and g < 40 and b < 40:
                n = n + 1
            xx = xx + 1
        yy = yy + 1
    return n


# Number of squares in rows [r0,r1) carrying a White-piece glyph.
def _count_white_glyphs(r0: int32, r1: int32) -> int32:
    n: int32 = 0
    row: int32 = r0
    while row < r1:
        col: int32 = 0
        while col < CH_N:
            if _sq_white(col, row) >= 6:
                n = n + 1
            col = col + 1
        row = row + 1
    return n


def _count_black_glyphs(r0: int32, r1: int32) -> int32:
    n: int32 = 0
    row: int32 = r0
    while row < r1:
        col: int32 = 0
        while col < CH_N:
            if _sq_black(col, row) >= 6:
                n = n + 1
            col = col + 1
        row = row + 1
    return n


def _render_present(path: Ptr[char]):
    ch_render()
    game_flip_scene(ch_display_surf())
    game_host_present(ch_display_surf())
    game_host_write_ppm(path)


# Sample a square's white/black glyph pixel counts to the dump.
def _o_sq(labw: Ptr[uint8], labb: Ptr[uint8], col: int32, row: int32):
    _o_kv(labw, cast[int64](_sq_white(col, row)))
    _o_kv(labb, cast[int64](_sq_black(col, row)))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        _o_str(cast[Ptr[uint8]](
            "usage: hamgamechess_host START.ppm OPENING.ppm CAPTURE.ppm\n"))
        _o_flush()
        return 2

    # ================= START POSITION =================
    game_reset()
    ch_init(CHW, CHH)
    _render_present(cast[Ptr[char]](argv[1]))

    _o_kv(cast[Ptr[uint8]]("TURN0"), cast[int64](chess_turn()))
    _o_kv(cast[Ptr[uint8]]("P_E2"), cast[int64](chess_piece_at(52)))    # white pawn 1
    _o_kv(cast[Ptr[uint8]]("P_E7"), cast[int64](chess_piece_at(12)))    # black pawn -1
    _o_kv(cast[Ptr[uint8]]("P_E1"), cast[int64](chess_piece_at(60)))    # white king 6
    _o_kv(cast[Ptr[uint8]]("P_D8"), cast[int64](chess_piece_at(3)))     # black queen -5
    _o_kv(cast[Ptr[uint8]]("WCOUNT0"), cast[int64](chess_piece_count(0)))
    _o_kv(cast[Ptr[uint8]]("BCOUNT0"), cast[int64](chess_piece_count(1)))
    # glyph pixels: 16 white letters on ranks 1-2 (rows 6,7), 16 black on 7-8
    _o_kv(cast[Ptr[uint8]]("WGLYPHS"), cast[int64](_count_white_glyphs(6, 8)))
    _o_kv(cast[Ptr[uint8]]("BGLYPHS"), cast[int64](_count_black_glyphs(0, 2)))
    # a White pawn square renders white glyph pixels, no black; an empty middle
    # square (e4, col4 row4) renders neither
    _o_sq(cast[Ptr[uint8]]("E2_W"), cast[Ptr[uint8]]("E2_B"), 4, 6)
    _o_sq(cast[Ptr[uint8]]("E4_W0"), cast[Ptr[uint8]]("E4_B0"), 4, 4)
    _o_sq(cast[Ptr[uint8]]("E7_W"), cast[Ptr[uint8]]("E7_B"), 4, 1)
    _o_flush()

    # ================= LEGAL OPENING: e4 e5 Nf3 =================
    r1: int32 = chess_move(52, 36)                       # e2-e4  (white pawn)
    r2: int32 = chess_move(12, 28)                       # e7-e5  (black pawn)
    r3: int32 = chess_move(62, 45)                       # Ng1-f3 (white knight)
    _o_kv(cast[Ptr[uint8]]("MV_E4"), cast[int64](r1))
    _o_kv(cast[Ptr[uint8]]("MV_E5"), cast[int64](r2))
    _o_kv(cast[Ptr[uint8]]("MV_NF3"), cast[int64](r3))
    _o_kv(cast[Ptr[uint8]]("P_E2_AFTER"), cast[int64](chess_piece_at(52)))   # 0
    _o_kv(cast[Ptr[uint8]]("P_E4_AFTER"), cast[int64](chess_piece_at(36)))   # 1
    _o_kv(cast[Ptr[uint8]]("P_E5_AFTER"), cast[int64](chess_piece_at(28)))   # -1
    _o_kv(cast[Ptr[uint8]]("P_G1_AFTER"), cast[int64](chess_piece_at(62)))   # 0
    _o_kv(cast[Ptr[uint8]]("P_F3_AFTER"), cast[int64](chess_piece_at(45)))   # 2
    _o_kv(cast[Ptr[uint8]]("TURN_AFTER"), cast[int64](chess_turn()))         # 1

    game_reset()
    ch_reattach_display()                                # board preserved
    _render_present(cast[Ptr[char]](argv[2]))
    # e2 now empty (no white glyph), e4 now carries the moved pawn's white glyph
    _o_sq(cast[Ptr[uint8]]("E2_W1"), cast[Ptr[uint8]]("E2_B1"), 4, 6)
    _o_sq(cast[Ptr[uint8]]("E4_W1"), cast[Ptr[uint8]]("E4_B1"), 4, 4)
    _o_sq(cast[Ptr[uint8]]("F3_W1"), cast[Ptr[uint8]]("F3_B1"), 5, 5)
    _o_flush()

    # ================= CAPTURE: e4 d5, exd5 =================
    game_reset()
    ch_init(CHW, CHH)
    chess_move(52, 36)                                   # e2-e4  (white)
    chess_move(11, 27)                                   # d7-d5  (black)
    _o_kv(cast[Ptr[uint8]]("CAP_BCOUNT_PRE"), cast[int64](chess_piece_count(1)))  # 16
    _o_kv(cast[Ptr[uint8]]("CAP_D5_PRE"), cast[int64](chess_piece_at(27)))        # -1
    rc: int32 = chess_move(36, 27)                       # e4 x d5 (white pawn takes)
    _o_kv(cast[Ptr[uint8]]("CAP_RET"), cast[int64](rc))                           # 1
    _o_kv(cast[Ptr[uint8]]("CAP_E4_POST"), cast[int64](chess_piece_at(36)))       # 0
    _o_kv(cast[Ptr[uint8]]("CAP_D5_POST"), cast[int64](chess_piece_at(27)))       # 1 white
    _o_kv(cast[Ptr[uint8]]("CAP_BCOUNT_POST"), cast[int64](chess_piece_count(1))) # 15
    _o_kv(cast[Ptr[uint8]]("CAP_WCOUNT_POST"), cast[int64](chess_piece_count(0))) # 16

    game_reset()
    ch_reattach_display()
    _render_present(cast[Ptr[char]](argv[3]))
    # d5 (col3,row3) now shows the capturing White pawn's white glyph
    _o_sq(cast[Ptr[uint8]]("CAP_D5_W"), cast[Ptr[uint8]]("CAP_D5_B"), 3, 3)
    _o_flush()

    # ================= ILLEGAL MOVE REJECTED =================
    game_reset()
    ch_init(CHW, CHH)
    ri: int32 = chess_move(57, 41)                       # Nb1-b3: straight, not an L
    _o_kv(cast[Ptr[uint8]]("ILLEGAL_RET"), cast[int64](ri))                  # 0
    _o_kv(cast[Ptr[uint8]]("ILLEGAL_SRC"), cast[int64](chess_piece_at(57)))  # 2 (unchanged)
    _o_kv(cast[Ptr[uint8]]("ILLEGAL_DST"), cast[int64](chess_piece_at(41)))  # 0 (unchanged)
    _o_kv(cast[Ptr[uint8]]("ILLEGAL_TURN"), cast[int64](chess_turn()))       # 0 (unchanged)
    # also a wrong-side move (Black to move first) must be rejected
    rw: int32 = chess_move(11, 19)                       # d7-d6 while White to move
    _o_kv(cast[Ptr[uint8]]("WRONGSIDE_RET"), cast[int64](rw))                # 0
    _o_flush()
    return 0

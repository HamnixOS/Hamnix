# user/hamsoftware.ad — NATIVE driver for the "Software" application
# (/bin/hamsoftware). A Synaptic-style graphical front-end over the native hpm
# package manager (user/hpm.ad). This is the RICHER sibling of hampkgscene: it
# adds the category sidebar (All / Installed / Available / Upgradable) by
# turning on lib/hampkgcore's optional left rail — the list, live search,
# detail pane, action buttons and status line are the SAME extern-free core
# (lib/hampkgcore.ad), host-renderable via user/hamsoftware_host.ad.
#
# hpm stays the engine: this file owns only the Hamnix transport (a wsys window
# + /keys + /event drain) and THE SEAM TO hpm — it shells out to /bin/hpm and
# pipes hpm's plain-text output into the pure parsers in the core:
#   Refresh    -> `hpm refresh` then `hpm search ""` (all available) + `hpm list`
#   row-select -> `hpm show <name>`  (fills the detail pane)
#   Install    -> `hpm install <name>`   (then re-reads `hpm list`)
#   Remove     -> `hpm remove <name>`    (then re-reads `hpm list`)
#   Upgrade    -> `hpm update`           (then re-reads the index)
# Write commands (install/remove/update) require hostowner (uid 1); when the GUI
# runs unprivileged, hpm's own "requires hostowner" message is surfaced in the
# status line rather than reimplementing the check here.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32
extern def sys_waitpid(pid: int32) -> int64
extern def sys_pipechan() -> int32
extern def sys_fdbind(pid: int32, fdnum: int32, kind: int32, slot: int32) -> int32

from lib.p9 import spawn, p9_listdir
from lib.hamui import hamscene_commit
from lib.hampkgcore import hampkg_init, hampkg_build_scene, hampkg_key_line, \
    hampkg_hit, hampkg_scroll, hampkg_reset_list, hampkg_installed_reset, \
    hampkg_add_search_line, hampkg_mark_installed_line, hampkg_detail_reset, \
    hampkg_detail_line, hampkg_set_status, hampkg_count, \
    hampkg_selected_name, hampkg_selected_name_len, hampkg_clear_detail_pending, \
    hampkg_set_sidebar, hampkg_add_pkg, hampkg_set_size, \
    hampkg_pkg_name, hampkg_pkg_name_len, hampkg_flag_installed
from lib.desktopentry import desktop_parse, desktop_name_ptr, \
    desktop_name_len, desktop_cats_ptr, desktop_catcode, \
    desktop_category_name, desktop_liveonly, desktop_name_is_entry

# stdio-namespace spawn sentinel + sys_fdbind kinds (mirrors hampkgscene).
SPAWN_STDIO_NS: int32 = -2
DEVFD_CONS:     int32 = 1
DEVFD_PIPE_R:   int32 = 2
DEVFD_PIPE_W:   int32 = 3
OUT_FD:         int32 = 12                 # scratch /fd name for the pipe read end

# parse modes for _run's line callback
M_SEARCH:  int32 = 0                        # `hpm search` -> add packages
M_LIST:    int32 = 1                        # `hpm list`   -> mark installed
M_SHOW:    int32 = 2                        # `hpm show`   -> detail pane
M_ACTION:  int32 = 3                        # install/remove/update -> last line = status


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# ---- the hpm seam ----------------------------------------------------------
logbuf:  Array[4096, uint8]
linebuf: Array[512, uint8]
line_len: uint64 = 0
last_line: Array[128, uint8]               # remembered for M_ACTION status
last_len: uint64 = 0


def _feed_line(mode: int32, s: Ptr[uint8], n: uint64):
    if n == 0:
        return
    if mode == M_SEARCH:
        hampkg_add_search_line(s, n)
    elif mode == M_LIST:
        hampkg_mark_installed_line(s, n)
    elif mode == M_SHOW:
        hampkg_detail_line(s, n)
    else:
        # M_ACTION: keep the last non-empty line as the status echo
        m: uint64 = n
        if m > 127:
            m = 127
        i: uint64 = 0
        while i < m:
            last_line[i] = s[i]
            i = i + 1
        last_len = m


def _line_carry(mode: int32, c: uint8):
    if c == 10:
        _feed_line(mode, &linebuf[0], line_len)
        line_len = 0
        return
    if line_len < 511:
        linebuf[line_len] = c
        line_len = line_len + 1


# Spawn /bin/hpm with the given (already NUL-terminated) argv, route its
# stdout+stderr through a pipe, drain it to EOF feeding each line to the core
# parser selected by `mode`, then reap the child. Returns the child exit code
# (or -1 on spawn failure). SYNCHRONOUS: the window is briefly unresponsive
# during a run — acceptable for round 1 (see follow-ups for async streaming).
def _run(argv: Ptr[uint64], mode: int32) -> int32:
    line_len = 0
    last_len = 0
    out_slot: int32 = sys_pipechan()
    if out_slot < 0:
        return -1
    sys_fdbind(0, OUT_FD, DEVFD_PIPE_R, out_slot)
    ofd: int32 = sys_open(cast[Ptr[char]]("/fd/12"))
    if ofd < 0:
        sys_fdbind(0, OUT_FD, DEVFD_CONS, 0)
        return -1
    pid: int32 = spawn(cast[Ptr[char]]("/bin/hpm"), argv,
                       SPAWN_STDIO_NS, SPAWN_STDIO_NS, cast[Ptr[uint64]](0))
    if pid < 0:
        sys_close(ofd)
        sys_fdbind(0, OUT_FD, DEVFD_CONS, 0)
        return -1
    sys_fdbind(pid, 1, DEVFD_PIPE_W, out_slot)
    sys_fdbind(pid, 2, DEVFD_PIPE_W, out_slot)
    # blocking drain until every write end closes (child exit) => read 0
    while True:
        r: int64 = sys_read(ofd, &logbuf[0], 4096)
        if r <= 0:
            break
        i: uint64 = 0
        while i < cast[uint64](r):
            _line_carry(mode, logbuf[i])
            i = i + 1
    if line_len > 0:
        _feed_line(mode, &linebuf[0], line_len)
        line_len = 0
    sys_close(ofd)
    sys_fdbind(0, OUT_FD, DEVFD_CONS, 0)
    code: int64 = sys_waitpid(pid)
    return cast[int32](code)


# ---- high-level hpm operations ---------------------------------------------
namebuf: Array[64, uint8]                  # NUL-terminated selected pkg name


def _sel_name_z() -> int32:
    nl: uint64 = hampkg_selected_name_len()
    if nl == 0 or nl > 63:
        return 0
    src: Ptr[uint8] = hampkg_selected_name()
    i: uint64 = 0
    while i < nl:
        namebuf[i] = src[i]
        i = i + 1
    namebuf[nl] = 0
    return 1


# ---- installed-app registry scan (/etc/hamde/apps/*.desktop) ---------------
# The authoritative, ALWAYS-PRESENT list of installed applications is the
# freedesktop desktop-entry registry the DE panel + app menu already read, one
# .desktop per app (staged by the per-app hpm packages). `hpm search` only
# lists what a NETWORK refresh cached, so offline it yields nothing and the
# window looked empty (or showed hpm alone). We enumerate the registry the same
# way user/hamappmenu.ad does — p9_listdir + lib/desktopentry — and add each app
# as its own installed package row (friendly Name + its category), so every
# installed app (snake, tetris, coin dash, chess, terminal, editor, control
# center, ...) shows up individually with NO network dependency.
_reg_list:  Array[8192, uint8]
_reg_file:  Array[2048, uint8]
_reg_path:  Array[192, uint8]


# /etc/installer-medium exists ONLY on the live/installer boot, so live-only
# entries (the installer launcher) show there and never on an installed system.
_reg_live_state: int32 = 0
def _reg_is_live() -> int32:
    if _reg_live_state == 0:
        fd: int32 = sys_open(cast[Ptr[char]]("/etc/installer-medium"))
        if fd >= 0:
            sys_close(fd)
            _reg_live_state = 1
        else:
            _reg_live_state = 2
    if _reg_live_state == 1:
        return 1
    return 0


def _reg_build_path(name: Ptr[uint8], nlen: uint64):
    dir: Ptr[uint8] = cast[Ptr[uint8]]("/etc/hamde/apps/")
    p: uint64 = 0
    while dir[p] != 0:
        _reg_path[p] = dir[p]
        p = p + 1
    k: uint64 = 0
    while k < nlen and p < 191:
        _reg_path[p] = name[k]
        p = p + 1
        k = k + 1
    _reg_path[p] = 0


# Scan the desktop-entry registry and add each app as an installed package.
# Returns the number of apps added.
def _scan_registry() -> int32:
    n: int64 = p9_listdir(cast[Ptr[char]]("/etc/hamde/apps"),
                          &_reg_list[0], 8192)
    if n <= 0:
        return 0
    added: int32 = 0
    cap: uint64 = cast[uint64](n)
    i: uint64 = 0
    while i < cap:
        e: uint64 = i
        while e < cap and _reg_list[e] != 10:
            e = e + 1
        nm: Array[80, uint8]
        nl: uint64 = 0
        k: uint64 = i
        while k < e and nl < 79:
            nm[nl] = _reg_list[k]
            nl = nl + 1
            k = k + 1
        nm[nl] = 0
        if nl > 0 and desktop_name_is_entry(&nm[0]) != 0:
            _reg_build_path(&nm[0], nl)
            fd: int32 = sys_open(cast[Ptr[char]](&_reg_path[0]))
            if fd >= 0:
                rn: int64 = sys_read(fd, &_reg_file[0], 2047)
                sys_close(fd)
                if rn > 0:
                    if desktop_parse(&_reg_file[0], cast[uint64](rn)) != 0:
                        if desktop_liveonly() == 0 or _reg_is_live() != 0:
                            cat: Ptr[uint8] = desktop_category_name(
                                desktop_catcode())
                            hampkg_add_pkg(desktop_name_ptr(),
                                           desktop_name_len(),
                                           cast[Ptr[uint8]]("app"), 3,
                                           cat, _slen(cat), 1)
                            added = added + 1
        i = e + 1
    return added


# Count of AVAILABLE (repo-index) packages from the last _load_index() — i.e.
# rows fed by `hpm search`, excluding installed-app registry rows. Zero means
# the index cache was empty / unrefreshed.
avail_count: int32 = 0


# ---- on-disk installed probe (fills the gap when installed.json is empty) ---
# The base image STAGES its apps straight into the rootfs (/bin/<cmd>) without
# recording them in /var/lib/hpm/installed.json, so `hpm list` reports almost
# nothing installed on a fresh boot — the Software window then showed hundreds
# of installed base tools as merely "Available". We recover the truth the same
# way the shell resolves a command: a package `hamnix-<cmd>` (or a bare
# `<cmd>`) is INSTALLED iff its binary exists at /bin/<cmd>. The package id
# uses '-' where the binary uses '_' (e.g. hamnix-env-show -> /bin/env_show),
# so we translate '-' to '_' after stripping the optional vendor prefix.
# Metapackages / drivers / libs with no /bin binary simply stay Available.
_probe_path: Array[128, uint8]


def _probe_bin_exists(name: Ptr[uint8], nlen: uint64) -> int32:
    # Skip a leading "hamnix-" vendor prefix.
    st: uint64 = 0
    if nlen > 7 and name[0] == 104 and name[1] == 97 and name[2] == 109 \
            and name[3] == 110 and name[4] == 105 and name[5] == 120 \
            and name[6] == 45:
        st = 7
    if st >= nlen:
        return 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/bin/")
    p: uint64 = 0
    while pre[p] != 0:
        _probe_path[p] = pre[p]
        p = p + 1
    k: uint64 = st
    while k < nlen and p < 126:
        c: uint8 = name[k]
        if c == 45:                            # '-' in id -> '_' in binary
            c = 95
        _probe_path[p] = c
        p = p + 1
        k = k + 1
    _probe_path[p] = 0
    fd: int32 = sys_open(cast[Ptr[char]](&_probe_path[0]))
    if fd < 0:
        return 0
    sys_close(fd)
    return 1


# Flag every model row whose backing binary is present on disk as installed.
def _probe_installed_present():
    i: int32 = 0
    n: int32 = hampkg_count()
    while i < n:
        nm: Ptr[uint8] = hampkg_pkg_name(i)
        nl: uint64 = hampkg_pkg_name_len(i)
        if nl > 0 and _probe_bin_exists(nm, nl) != 0:
            hampkg_flag_installed(i)
        i = i + 1


def _load_index():
    # available packages: `hpm search ""` (empty pattern matches all). Offline
    # this is a no-op (no cached index), so the registry scan below is what
    # keeps the window populated with every installed app.
    hampkg_reset_list()
    sav: Array[4, uint64]
    sav[0] = cast[uint64](cast[Ptr[uint8]]("hpm"))
    sav[1] = cast[uint64](cast[Ptr[uint8]]("search"))
    sav[2] = cast[uint64](cast[Ptr[uint8]](""))
    sav[3] = 0
    _run(&sav[0], M_SEARCH)
    # Snapshot how many AVAILABLE packages the cached index yielded (before we
    # append installed-app registry rows) so the caller can decide whether a
    # one-shot refresh is warranted (empty cache -> repo-only apps like the
    # audiobook would otherwise never appear).
    avail_count = hampkg_count()
    # installed state: `hpm list`
    hampkg_installed_reset()
    lav: Array[3, uint64]
    lav[0] = cast[uint64](cast[Ptr[uint8]]("hpm"))
    lav[1] = cast[uint64](cast[Ptr[uint8]]("list"))
    lav[2] = 0
    _run(&lav[0], M_LIST)
    # Enumerate the installed-app registry LAST (after installed_reset), so
    # every installed app appears as its own row regardless of the network
    # index. Appended entries carry the installed flag directly.
    _scan_registry()
    # installed.json is empty on a freshly-imaged system, so `hpm list` above
    # flags almost nothing. Recover the real installed set by probing each repo
    # row's binary under /bin — the honest "is it on this disk" signal.
    _probe_installed_present()


def _status_count():
    sb: Array[64, uint8]
    p: uint64 = 0
    p = _u64_to_dec(cast[uint64](hampkg_count()), &sb[0])
    suf: Ptr[uint8] = cast[Ptr[uint8]](" packages in the index")
    k: uint64 = 0
    while suf[k] != 0:
        sb[p] = suf[k]
        p = p + 1
        k = k + 1
    hampkg_set_status(&sb[0], p)


def _do_refresh():
    hampkg_set_status(cast[Ptr[uint8]]("Refreshing package index..."), 27)
    rav: Array[3, uint64]
    rav[0] = cast[uint64](cast[Ptr[uint8]]("hpm"))
    rav[1] = cast[uint64](cast[Ptr[uint8]]("refresh"))
    rav[2] = 0
    _run(&rav[0], M_ACTION)
    _load_index()
    _status_count()


def _do_show():
    if _sel_name_z() == 0:
        return
    hampkg_detail_reset()
    sav: Array[4, uint64]
    sav[0] = cast[uint64](cast[Ptr[uint8]]("hpm"))
    sav[1] = cast[uint64](cast[Ptr[uint8]]("show"))
    sav[2] = cast[uint64](&namebuf[0])
    sav[3] = 0
    _run(&sav[0], M_SHOW)
    hampkg_clear_detail_pending()


# verb: "install" or "remove"
def _do_action(verb: Ptr[uint8], vlen: uint64):
    if _sel_name_z() == 0:
        return
    hampkg_set_status(cast[Ptr[uint8]]("Working..."), 10)
    av: Array[4, uint64]
    av[0] = cast[uint64](cast[Ptr[uint8]]("hpm"))
    av[1] = cast[uint64](verb)
    av[2] = cast[uint64](&namebuf[0])
    av[3] = 0
    _run(&av[0], M_ACTION)
    if last_len > 0:
        hampkg_set_status(&last_line[0], last_len)
    # re-read installed state so the badge + buttons reflect the change
    hampkg_installed_reset()
    lav: Array[3, uint64]
    lav[0] = cast[uint64](cast[Ptr[uint8]]("hpm"))
    lav[1] = cast[uint64](cast[Ptr[uint8]]("list"))
    lav[2] = 0
    _run(&lav[0], M_LIST)


def _do_upgrade():
    hampkg_set_status(cast[Ptr[uint8]]("Upgrading all packages..."), 25)
    uav: Array[3, uint64]
    uav[0] = cast[uint64](cast[Ptr[uint8]]("hpm"))
    uav[1] = cast[uint64](cast[Ptr[uint8]]("update"))
    uav[2] = 0
    _run(&uav[0], M_ACTION)
    if last_len > 0:
        hampkg_set_status(&last_line[0], last_len)
    _load_index()


# ---- pointer parse ---------------------------------------------------------
def _parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                   bbtn: Ptr[int64], bdz: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                   # 'm'
        return 0
    i: uint64 = 1
    vals: Array[4, int64]
    v: uint64 = 0
    while v < 4:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc = acc * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            if v >= 3:                         # dz is optional
                acc = 0
            else:
                return 0
        if neg != 0:
            acc = 0 - acc
        vals[v] = acc
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    bdz[0] = vals[3]
    return 1


# Parse a compositor resize line "r <w> <h>" (emitted on maximize / snap /
# free-resize). Returns 1 and writes w/h on success, else 0. Lets the Software
# window STRETCH its scene to fill the maximized frame instead of leaving gaps.
def _parse_resize(s: Ptr[uint8], n: uint64, ow: Ptr[int64],
                  oh: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 114:                   # 'r'
        return 0
    i: uint64 = 1
    vals: Array[2, int64]
    v: uint64 = 0
    while v < 2:
        while i < n and s[i] == 32:
            i = i + 1
        acc: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc = acc * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        vals[v] = acc
        v = v + 1
    ow[0] = vals[0]
    oh[0] = vals[1]
    return 1


def emit_scene(wid: int32):
    hampkg_build_scene()
    hamscene_commit(wid)


def _dispatch(act: int32) -> int32:
    if act == 1:
        _do_refresh()
        return 1
    if act == 2:
        _do_action(cast[Ptr[uint8]]("install"), 7)
        return 1
    if act == 3:
        _do_action(cast[Ptr[uint8]]("remove"), 6)
        return 1
    if act == 4:
        _do_upgrade()
        return 1
    if act == 5:
        _do_show()
        return 1
    # act == 6: category (sidebar) change — pure re-filter, no hpm call.
    return 0


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamsoftware] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    keysp: Array[64, uint8]
    evp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("geometry 100 70 772 430\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("title Software\n"))
        sys_close(cfd3)
    cfd4: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd4 >= 0:
        _writeall(cfd4, cast[Ptr[uint8]]("z 7\n"))
        sys_close(cfd4)

    hampkg_init()
    hampkg_set_sidebar(1)                        # enable the category rail
    hampkg_set_status(cast[Ptr[uint8]]("Loading package index..."), 25)
    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hamsoftware] scene window ready\n"))

    # Initial load off the cached index. If it's empty (fresh boot never
    # refreshed), do a one-shot `hpm refresh` so the FULL channel — including
    # repo-only apps (e.g. the audiobook) not yet installed — populates the
    # list. On the live image /etc/hpm/repo points at the on-image file://
    # repo, so this is an instant offline read; the Refresh button re-fetches.
    _load_index()
    if avail_count == 0:
        _do_refresh()
    _status_count()
    emit_scene(wid)

    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))
    kbuf: Array[256, uint8]
    evbuf: Array[256, uint8]
    btn_down: int32 = 0
    while True:
        changed: int32 = 0
        # --- KEYBOARD: non-blocking drain of /keys (drives the search box) --
        if kfd >= 0:
            kr: int64 = sys_read_nb(kfd, &kbuf[0], 255)
            if kr > 0:
                kls: uint64 = 0
                ki: uint64 = 0
                while ki <= cast[uint64](kr):
                    katend: int32 = 0
                    if ki == cast[uint64](kr):
                        katend = 1
                    if katend == 1 or kbuf[ki] == 10:
                        if ki > kls:
                            if hampkg_key_line(&kbuf[kls], ki - kls) == 1:
                                changed = 1
                        kls = ki + 1
                    ki = ki + 1
        # --- POINTER: non-blocking drain of /event ------------------------
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            er: int64 = sys_read_nb(efd, &evbuf[0], 255)
            sys_close(efd)
            if er > 0:
                els: uint64 = 0
                ei: uint64 = 0
                while ei <= cast[uint64](er):
                    eatend: int32 = 0
                    if ei == cast[uint64](er):
                        eatend = 1
                    if eatend == 1 or evbuf[ei] == 10:
                        if ei > els:
                            bx: int64 = 0
                            by: int64 = 0
                            bbtn: int64 = 0
                            bdz: int64 = 0
                            rw: int64 = 0
                            rh: int64 = 0
                            if _parse_resize(&evbuf[els], ei - els,
                                             &rw, &rh) == 1:
                                # Maximize/snap: stretch the scene to fill.
                                hampkg_set_size(cast[int32](rw), cast[int32](rh))
                                changed = 1
                            elif _parse_pointer(&evbuf[els], ei - els, &bx, &by,
                                              &bbtn, &bdz) == 1:
                                now_down: int32 = 0
                                if (bbtn & 1) != 0:
                                    now_down = 1
                                if now_down != 0 and btn_down == 0:
                                    act: int32 = hampkg_hit(bx, by)
                                    if act != 0:
                                        _dispatch(act)
                                        changed = 1
                                if bdz != 0:
                                    if hampkg_scroll(cast[int32](bdz)) != 0:
                                        changed = 1
                                btn_down = now_down
                        els = ei + 1
                    ei = ei + 1
        if changed != 0:
            emit_scene(wid)
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 3:
            sys_yield()
    return 0

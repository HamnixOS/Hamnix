# user/getty.ad
#
# Stub `getty`. On real SysV-init systems getty owns a tty,
# prompts for a username, and exec's /bin/login. Hamnix has no
# multi-tty support yet (one console, one shell) so this binary
# announces itself and then exec's /bin/hamsh directly via
# SYS_EXECVE — replacing THIS task so the shell inherits getty's
# fd 0/1/2.
#
# When real tty cloning lands, the spawn dance moves here:
# getty would fork off /bin/login, wait for completion, then
# re-prompt.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_execve(path: Ptr[char], argv: Ptr[uint64]) -> int32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main() -> int32:
    write_str(1, "getty: spawning hamsh on this tty\n")
    # Build a minimal argv: argv[0] = "/bin/hamsh", argv[1] = NULL.
    # SYS_EXECVE replaces the current task on success, so the `ret`
    # after the syscall is only reached on failure.
    argbuf: Array[2, uint64]
    argbuf[0] = cast[uint64](&"/bin/hamsh"[0])
    argbuf[1] = 0
    sys_execve("/bin/hamsh", &argbuf[0])
    write_str(2, "getty: exec /bin/hamsh failed\n")
    return 1

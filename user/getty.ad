# user/getty.ad
#
# VT-aware `getty`. Accepts an optional VT number (1..4) as argv[1].
# When a VT number is given, getty opens /dev/vt/N and wires it to
# stdin (fd 0), stdout (fd 1), and stderr (fd 2) before exec'ing
# /bin/hamsh. This gives the shell on VT N its own isolated input
# queue; keyboard input only appears in the active VT's FIFO.
#
# With NO arguments (legacy mode), getty behaves as before: just
# exec's /bin/hamsh without touching fds. The single console
# (FD_STDIN_MARK / FD_STDOUT_MARK) remains in effect.
#
# VT number is passed from rc.boot.full as `spawn getty 1`,
# `spawn getty 2`, etc. for VT1..VT4.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_execve(path: Ptr[char], argv: Ptr[uint64]) -> int32
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_dup2(oldfd: int32, newfd: int32) -> int32


# VT device path template: /dev/vt/N
# We build the path at runtime by patching the last char.
vt_path: Array[12, uint8]      # "/dev/vt/1\0" etc. — mutable global

def _build_vt_path(n: int32):
    # Fill vt_path[] with "/dev/vt/N\0" where N is the ASCII digit.
    vt_path[0]  = 47     # '/'
    vt_path[1]  = 100    # 'd'
    vt_path[2]  = 101    # 'e'
    vt_path[3]  = 118    # 'v'
    vt_path[4]  = 47     # '/'
    vt_path[5]  = 118    # 'v'
    vt_path[6]  = 116    # 't'
    vt_path[7]  = 47     # '/'
    vt_path[8]  = cast[uint8](48 + n)   # '1'..'4'
    vt_path[9]  = 0      # NUL


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def parse_int(s: Ptr[uint8]) -> int32:
    n: int32 = 0
    i: uint64 = 0
    while s[i] != 0:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            return -1
        n = n * 10 + cast[int32](c - 48)
        i = i + 1
    return n


# argv buffer for the hamsh exec.
hamsh_argv: Array[2, uint64]


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    vt_num: int32 = 0   # 0 = legacy mode (no VT wiring)

    if argc >= 2:
        vt_str: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        vt_num = parse_int(vt_str)
        if vt_num < 1 or vt_num > 4:
            write_str(2, "getty: VT number must be 1..4\n")
            vt_num = 0

    if vt_num > 0:
        # --- VT mode: wire /dev/vt/N to fd 0/1/2 ---------------------
        _build_vt_path(vt_num)

        # Open for reading (stdin). sys_open opens RDONLY.
        vt_rfd: int32 = sys_open(cast[Ptr[char]](&vt_path[0]))
        if vt_rfd < 0:
            write_str(2, "getty: cannot open vt for reading\n")
            # Fall back to legacy mode.
        else:
            # Open for writing (stdout/stderr). sys_open_write opens WRONLY.
            vt_wfd: int32 = sys_open_write(cast[Ptr[char]](&vt_path[0]))
            if vt_wfd < 0:
                sys_close(vt_rfd)
                write_str(2, "getty: cannot open vt for writing\n")
            else:
                # Wire the VT device to the standard streams.
                sys_dup2(vt_rfd, 0)   # stdin  = /dev/vt/N (read)
                sys_dup2(vt_wfd, 1)   # stdout = /dev/vt/N (write)
                sys_dup2(vt_wfd, 2)   # stderr = /dev/vt/N (write)
                # Close the originals (now duplicated to 0/1/2).
                if vt_rfd > 2:
                    sys_close(vt_rfd)
                if vt_wfd > 2:
                    sys_close(vt_wfd)
                write_str(1, "getty: VT ready\n")

    # Exec hamsh (replaces this task, inheriting the wired fds).
    hamsh_argv[0] = cast[uint64](&"/bin/hamsh"[0])
    hamsh_argv[1] = 0
    sys_execve("/bin/hamsh", &hamsh_argv[0])
    write_str(2, "getty: exec /bin/hamsh failed\n")
    return 1

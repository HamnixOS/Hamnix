# user/hampanelscene.ad
#
# Scene-file DE top panel (docs/de_scene_file_arch.md §16 step 5/8).
#
# A MATE/GNOME2-style top panel drawn as a scene display list: a full-width
# bar pinned to the top of the screen, with an "Applications" launcher label
# on the left and a clock on the right. It is a plain scene CLIENT — it owns
# no pixels of its own; it writes a text display list to
# /dev/wsys/<wid>/scene and pokes commit, and the kernel compositor
# rasterizes + z-blits it. decorate 0 (no titlebar — it is chrome).
#
# This is the panel half of the rl5 scene-DE flip: once the legacy hamUId
# present is retired, the desktop is blank until clients write scenes; this
# panel is the first thing the user sees rendered VIA THE SCENE PATH.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# Create a window via the server-wide ctl, read back the assigned wid.
def _newwindow() -> int32:
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return -1
    sys_write(fd, cast[Ptr[uint8]]("newwindow\n"), 10)
    rbuf: Array[32, uint8]
    r: int64 = sys_read(fd, &rbuf[0], 31)
    sys_close(fd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# Read the framebuffer width from /dev/fb's "W H PITCH BPP FMT\n" header.
def _screen_width() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/fb"))
    if fd < 0:
        return 800
    hdr: Array[64, uint8]
    r: int64 = sys_read(fd, &hdr[0], 63)
    sys_close(fd)
    if r <= 0:
        return 800
    w: int64 = 0
    i: uint64 = 0
    while i < cast[uint64](r) and hdr[i] >= 48 and hdr[i] <= 57:
        w = w * 10 + cast[int64](hdr[i]) - 48
        i = i + 1
    if w <= 0:
        return 800
    return w


PANEL_H: int64 = 26


def main() -> int32:
    sys_bind(cast[Ptr[char]]("#c"), cast[Ptr[char]]("/dev"), 0)
    sw: int64 = _screen_width()

    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[panel] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    scenep: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&scenep[0], wid, cast[Ptr[uint8]]("/scene"))

    # Geometry: full-width bar pinned to the top, no decoration, top z.
    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        geo: Array[64, uint8]
        gp: uint64 = 0
        pre: Ptr[uint8] = cast[Ptr[uint8]]("geometry 0 0 ")
        j: uint64 = 0
        while pre[j] != 0:
            geo[gp] = pre[j]
            gp = gp + 1
            j = j + 1
        gp = gp + _u64_to_dec(cast[uint64](sw), &geo[gp])
        geo[gp] = 32
        gp = gp + 1
        gp = gp + _u64_to_dec(cast[uint64](PANEL_H), &geo[gp])
        geo[gp] = 10
        gp = gp + 1
        sys_write(cfd, &geo[0], gp)
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 0\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 100\n"))
        sys_close(cfd3)

    _writeall(1, cast[Ptr[uint8]]("[panel] scene window ready\n"))

    # Panel scene: a grey bar, an "Applications" label left, "Hamnix" right.
    # Rewrite + commit each loop so the clock-ish second counter updates and
    # the panel keeps rendering over the desktop root. Hold the window alive.
    start: uint64 = sys_get_jiffies()
    secs: uint64 = 0
    while True:
        sfd: int32 = sys_open_write(cast[Ptr[char]](&scenep[0]))
        if sfd >= 0:
            scene: Array[512, uint8]
            sp: uint64 = 0
            head: Ptr[uint8] = cast[Ptr[uint8]]("# scene v1 panel\nfill 0 0 ")
            a: uint64 = 0
            while head[a] != 0:
                scene[sp] = head[a]
                sp = sp + 1
                a = a + 1
            sp = sp + _u64_to_dec(cast[uint64](sw), &scene[sp])
            mid: Ptr[uint8] = cast[Ptr[uint8]](" 26 #d4d0c8\nglyphs 6 6 \"Applications\" #202020\nglyphs ")
            b: uint64 = 0
            while mid[b] != 0:
                scene[sp] = mid[b]
                sp = sp + 1
                b = b + 1
            # right-aligned clock label x = sw - 80
            rx: int64 = sw - 80
            if rx < 0:
                rx = 0
            sp = sp + _u64_to_dec(cast[uint64](rx), &scene[sp])
            tail: Ptr[uint8] = cast[Ptr[uint8]](" 6 \"Hamnix DE\" #202020\n")
            d: uint64 = 0
            while tail[d] != 0:
                scene[sp] = tail[d]
                sp = sp + 1
                d = d + 1
            sys_write(sfd, &scene[0], sp)
            sys_close(sfd)
        cfd4: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
        if cfd4 >= 0:
            _writeall(cfd4, cast[Ptr[uint8]]("commit\n"))
            sys_close(cfd4)
        # Idle ~1s between repaints (event-driven would be better; the panel
        # is a chrome surface that rarely changes).
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 100:
            pass
        secs = secs + 1
    return 0

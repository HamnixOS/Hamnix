def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# A weight-aware glyph emit: normal or bold (double-strike) per the panel's
# font setting. Centralized so every applet honours the per-panel weight.
def _glyphs(x: int64, y: int64, s: Ptr[uint8], color: Ptr[uint8], bold: int32):
    if bold != 0:
        hamscene_glyphs_bold(cast[int32](x), cast[int32](y), s, color)
    else:
        hamscene_glyphs(cast[int32](x), cast[int32](y), s, color)


# Create a window via the server-wide ctl, read back the assigned wid.
def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# ====================================================================
# WORKSPACE (pager) state + I/O
# ====================================================================
# Current active workspace (0-based), tracked from /dev/wsys/workspace. The
# pager applet renders WS_COUNT cells with cur_ws lit, and a click writes the
# `ws <N>` ctl verb (1-based) which the compositor turns into workspace_switch.
cur_ws: int64 = 0


# Poll /dev/wsys/workspace ("<gen> <ws>\n"); update cur_ws. Cheap; called once
# per panel tick before render so the lit cell tracks the live desktop.
def _poll_workspace():
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/workspace"))
    if fd < 0:
        return
    rb: Array[64, uint8]
    n: int64 = sys_read(fd, &rb[0], 63)
    sys_close(fd)
    if n <= 0:
        return
    # Skip the gen field, then parse the ws field.
    i: uint64 = 0
    cap: uint64 = cast[uint64](n)
    while i < cap and rb[i] != 32:
        i = i + 1
    while i < cap and rb[i] == 32:
        i = i + 1
    v: int64 = 0
    while i < cap and rb[i] >= 48 and rb[i] <= 57:
        v = v * 10 + cast[int64](rb[i]) - 48
        i = i + 1
    if v >= 0 and v < WS_COUNT:
        cur_ws = v


# Write "ws <N>\n" (1-based) to /dev/wsys/ctl. The compositor's workspace
# poll bumps its gen and calls workspace_switch(N-1), hiding the windows that
# don't live on the new desktop. This is the real virtual-desktop switch.
def _switch_workspace(n0: int64):
    if n0 < 0 or n0 >= WS_COUNT:
        return
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return
    cmd: Array[16, uint8]
    p: uint64 = 0
    cmd[p] = 119                     # 'w'
    p = p + 1
    cmd[p] = 115                     # 's'
    p = p + 1
    cmd[p] = 32                      # ' '
    p = p + 1
    p = p + _u64_to_dec(cast[uint64](n0 + 1), &cmd[p])
    cmd[p] = 10
    p = p + 1
    sys_write(fd, &cmd[0], p)
    sys_close(fd)
    cur_ws = n0


# ====================================================================
# NOTIFICATION BUS / BROKER (scene-native)
# ====================================================================
# The kernel inbox ring at /dev/wsys/post is the Plan 9-shaped notification
# bus: any publisher (the welcome service, rc.5, a shell, hamnotify) writes a
# "<title>\t<body>\t<icon>\n" record there. In the legacy DE hamUId drained
# this ring; in the SCENE DE hamUId is dead, so THE PANEL is the broker. On
# each tick the panel:
#   1. reads the /dev/wsys/post snapshot
#      ("<post_serial> <ack_serial> <count> <slot_serial> <title>\t<body>\t<icon>\n"),
#   2. for each head record while count>0: spawns a scene TOAST
#      (/bin/hamtoast "<title>" "<body>"), appends the record to the tmpfs
#      history log /tmp/hamnix-notif.log, bumps the unread count, then ACKs
#      the slot by writing "ack <slot_serial>\n" back to /dev/wsys/post so the
#      kernel advances its head.
# The tray applet draws a bell + the unread count badge; clicking it spawns
# the scene INBOX (/bin/haminbox), which reads the history log, and clears the
# unread count.
notif_unread: int64 = 0                 # unread notifications since last inbox
notif_last_ack: uint64 = 0             # highest slot serial we've acked
# pid of the notification INBOX popup (/bin/haminbox) we last spawned, or 0.
# The bell click TOGGLES the popup off this: a click while the tracked pid is
# still alive terminates it (and never spawns a second one), so repeated bell
# clicks can never STACK duplicate inbox windows at the same geometry — the
# stack was the "the Close button does nothing, the popup stays stuck" bug
# (closing the top one just revealed an identical popup behind it).
notif_inbox_pid: int32 = 0

# Parsed head record from the last _drain_notifications poll.
_nb_count: int64 = 0
_nb_slot: uint64 = 0
_nb_title: Array[48, uint8]
_nb_body:  Array[72, uint8]


# Append the current head record (_nb_title/_nb_body) to the tmpfs history log
# as "<title>\t<body>\n". Capped to the newest ~16 records by rewriting the
# file from a small in-RAM ring so it never grows unbounded.
NLOG_MAX: uint64 = 16
nlog_buf: Array[1920, uint8]           # 16 * 120
nlog_len: Array[16, uint64]
nlog_n: uint64 = 0


def _nlog_append(title: Ptr[uint8], body: Ptr[uint8]):
    # Build the "<title>\t<body>" record into the ring (drop oldest on full).
    slot: uint64 = nlog_n
    if nlog_n >= NLOG_MAX:
        # shift down by one (drop oldest)
        s: uint64 = 0
        while s + 1 < NLOG_MAX:
            base_d: uint64 = s * 120
            base_s: uint64 = (s + 1) * 120
            k: uint64 = 0
            while k < nlog_len[s + 1]:
                nlog_buf[base_d + k] = nlog_buf[base_s + k]
                k = k + 1
            nlog_len[s] = nlog_len[s + 1]
            s = s + 1
        slot = NLOG_MAX - 1
    else:
        nlog_n = nlog_n + 1
    base: uint64 = slot * 120
    p: uint64 = 0
    ti: uint64 = 0
    while title[ti] != 0 and p < 118:
        nlog_buf[base + p] = title[ti]
        p = p + 1
        ti = ti + 1
    if p < 118:
        nlog_buf[base + p] = 9                       # '\t'
        p = p + 1
    bi: uint64 = 0
    while body[bi] != 0 and p < 119:
        nlog_buf[base + p] = body[bi]
        p = p + 1
        bi = bi + 1
    nlog_len[slot] = p
    # Rewrite /tmp/hamnix-notif.log from the ring (oldest-first).
    fd: int32 = sys_open_write(cast[Ptr[char]]("/tmp/hamnix-notif.log"))
    if fd < 0:
        return
    out: Array[2048, uint8]
    op: uint64 = 0
    r: uint64 = 0
    while r < nlog_n and op + 122 < 2048:
        rb: uint64 = r * 120
        kk: uint64 = 0
        while kk < nlog_len[r]:
            out[op] = nlog_buf[rb + kk]
            op = op + 1
            kk = kk + 1
        out[op] = 10
        op = op + 1
        r = r + 1
    sys_write(fd, &out[0], op)
    sys_close(fd)


# Spawn the scene toast with the head record's title + body as argv.
_toast_argv: Array[4, uint64]
def _spawn_toast():
    _toast_argv[0] = cast[uint64](cast[Ptr[char]]("/bin/hamtoast"))
    _toast_argv[1] = cast[uint64](&_nb_title[0])
    _toast_argv[2] = cast[uint64](&_nb_body[0])
    _toast_argv[3] = 0
    # DETACHED: the panel is a long-running service that never wait4s, so a
    # plain spawn would leak the toast as an un-reapable zombie every time.
    spawn_detached(cast[Ptr[char]]("/bin/hamtoast"), &_toast_argv[0],
                   -2, -2, cast[Ptr[uint64]](0))


# Ack a drained slot so the kernel advances /dev/wsys/post's head.
def _ack_slot(serial: uint64):
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/post"))
    if fd < 0:
        return
    cmd: Array[40, uint8]
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("ack ")
    while pre[p] != 0:
        cmd[p] = pre[p]
        p = p + 1
    p = p + _u64_to_dec(serial, &cmd[p])
    cmd[p] = 10
    p = p + 1
    sys_write(fd, &cmd[0], p)
    sys_close(fd)


# Read one /dev/wsys/post snapshot into _nb_*; returns count (>0 = head valid).
_nb_rb: Array[256, uint8]
def _read_post_head() -> int64:
    _nb_count = 0
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/post"))
    if fd < 0:
        return 0
    n: int64 = sys_read(fd, &_nb_rb[0], 255)
    sys_close(fd)
    if n <= 0:
        return 0
    cap: uint64 = cast[uint64](n)
    i: uint64 = 0
    # field 0: post_serial (skip)
    while i < cap and _nb_rb[i] != 32:
        i = i + 1
    while i < cap and _nb_rb[i] == 32:
        i = i + 1
    # field 1: ack_serial (skip)
    while i < cap and _nb_rb[i] != 32:
        i = i + 1
    while i < cap and _nb_rb[i] == 32:
        i = i + 1
    # field 2: count
    cnt: int64 = 0
    while i < cap and _nb_rb[i] >= 48 and _nb_rb[i] <= 57:
        cnt = cnt * 10 + cast[int64](_nb_rb[i]) - 48
        i = i + 1
    _nb_count = cnt
    if cnt <= 0:
        return 0
    while i < cap and _nb_rb[i] == 32:
        i = i + 1
    # field 3: slot_serial
    sl: uint64 = 0
    while i < cap and _nb_rb[i] >= 48 and _nb_rb[i] <= 57:
        sl = sl * 10 + cast[uint64](_nb_rb[i]) - 48
        i = i + 1
    _nb_slot = sl
    while i < cap and _nb_rb[i] == 32:
        i = i + 1
    # title up to tab
    tp: uint64 = 0
    while i < cap and _nb_rb[i] != 9 and tp < 47:
        _nb_title[tp] = _nb_rb[i]
        tp = tp + 1
        i = i + 1
    _nb_title[tp] = 0
    # skip to past the first tab
    while i < cap and _nb_rb[i] != 9:
        i = i + 1
    if i < cap:
        i = i + 1                                     # consume tab
    # body up to next tab (icon) or newline
    bp: uint64 = 0
    while i < cap and _nb_rb[i] != 9 and _nb_rb[i] != 10 and bp < 71:
        _nb_body[bp] = _nb_rb[i]
        bp = bp + 1
        i = i + 1
    _nb_body[bp] = 0
    return cnt


# Drain every pending /dev/wsys/post record: toast it, log it, ack it. Returns
# 1 if any notification was drained (so the panel repaints the unread badge).
def _drain_notifications() -> int32:
    drained: int32 = 0
    guard: int32 = 0
    while guard < 16:
        guard = guard + 1
        cnt: int64 = _read_post_head()
        if cnt <= 0:
            break
        # Guard against re-processing the same head if an ack didn't land.
        if _nb_slot == notif_last_ack and notif_last_ack != 0:
            break
        _spawn_toast()
        _nlog_append(&_nb_title[0], &_nb_body[0])
        notif_unread = notif_unread + 1
        notif_last_ack = _nb_slot
        _ack_slot(_nb_slot)
        drained = 1
    return drained


# Read the framebuffer width from /dev/fb's "W H PITCH BPP FMT\n" header.
def _screen_width() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/fb"))
    if fd < 0:
        return 800
    hdr: Array[64, uint8]
    r: int64 = sys_read(fd, &hdr[0], 63)
    sys_close(fd)
    if r <= 0:
        return 800
    w: int64 = 0
    i: uint64 = 0
    while i < cast[uint64](r) and hdr[i] >= 48 and hdr[i] <= 57:
        w = w * 10 + cast[int64](hdr[i]) - 48
        i = i + 1
    if w <= 0:
        return 800
    return w


# Read the framebuffer HEIGHT (second field of "W H PITCH BPP FMT\n").
def _screen_height() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/fb"))
    if fd < 0:
        return 600
    hdr: Array[64, uint8]
    r: int64 = sys_read(fd, &hdr[0], 63)
    sys_close(fd)
    if r <= 0:
        return 600
    i: uint64 = 0
    while i < cast[uint64](r) and hdr[i] >= 48 and hdr[i] <= 57:
        i = i + 1
    while i < cast[uint64](r) and not (hdr[i] >= 48 and hdr[i] <= 57):
        i = i + 1
    h: int64 = 0
    while i < cast[uint64](r) and hdr[i] >= 48 and hdr[i] <= 57:
        h = h * 10 + cast[int64](hdr[i]) - 48
        i = i + 1
    if h <= 0:
        return 600
    return h


# --- wall-clock: btime (epoch) from /dev/stat + uptime (ns) from /dev/time

def _read_btime() -> uint64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/stat"))
    if fd < 0:
        return 0
    buf: Array[2048, uint8]
    total: uint64 = 0
    while total < 2047:
        r: int64 = sys_read(fd, &buf[total], 2047 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    i: uint64 = 0
    while i + 6 < total:
        if (i == 0 or buf[i - 1] == 10) and buf[i] == 98 and buf[i+1] == 116 \
                and buf[i+2] == 105 and buf[i+3] == 109 and buf[i+4] == 101 \
                and buf[i+5] == 32:
            j: uint64 = i + 6
            v: uint64 = 0
            while j < total and buf[j] >= 48 and buf[j] <= 57:
                v = v * 10 + cast[uint64](buf[j]) - 48
                j = j + 1
            return v
        i = i + 1
    return 0


def _read_uptime_ns() -> uint64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/time"))
    if fd < 0:
        return 0
    buf: Array[32, uint8]
    r: int64 = sys_read(fd, &buf[0], 31)
    sys_close(fd)
    if r <= 0:
        return 0
    v: uint64 = 0
    i: uint64 = 0
    while i < cast[uint64](r) and buf[i] >= 48 and buf[i] <= 57:
        v = v * 10 + cast[uint64](buf[i]) - 48
        i = i + 1
    return v


def _now_secs_of_day(btime: uint64) -> uint64:
    up_ns: uint64 = _read_uptime_ns()
    epoch: uint64 = btime + up_ns / 1000000000
    return epoch % 86400


# Full Unix epoch seconds (boot time + uptime). Used by the MATE-style clock
# so it can show the calendar date, not just the seconds-of-day.
def _now_epoch_secs(btime: uint64) -> uint64:
    up_ns: uint64 = _read_uptime_ns()
    return btime + up_ns / 1000000000


# --- sysmon data sources --------------------------------------------
def _find_kv(buf: Ptr[uint8], total: uint64, lab: Ptr[uint8]) -> uint64:
    ll: uint64 = _slen(lab)
    i: uint64 = 0
    while i + ll < total:
        if i == 0 or buf[i - 1] == 10:
            m: uint64 = 0
            while m < ll and buf[i + m] == lab[m]:
                m = m + 1
            if m == ll:
                j: uint64 = i + ll
                while j < total and not (buf[j] >= 48 and buf[j] <= 57):
                    j = j + 1
                v: uint64 = 0
                while j < total and buf[j] >= 48 and buf[j] <= 57:
                    v = v * 10 + cast[uint64](buf[j]) - 48
                    j = j + 1
                return v
        i = i + 1
    return 0


def _mem_pct() -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/meminfo"))
    if fd < 0:
        return 0
    buf: Array[512, uint8]
    total: uint64 = 0
    while total < 511:
        r: int64 = sys_read(fd, &buf[total], 511 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    memtot: uint64 = _find_kv(&buf[0], total, cast[Ptr[uint8]]("MemTotal:"))
    memused: uint64 = _find_kv(&buf[0], total, cast[Ptr[uint8]]("MemUsed:"))
    if memtot == 0:
        return 0
    return cast[int32]((memused * 100) / memtot)


# --- CPU busy% from /dev/uptime idle/total DELTAS -------------------
# /dev/uptime emits "<uptime_s>.<CC> <idle_s>.<CC>\n" (the Linux /proc/uptime
# shape): total wall time and cumulative idle time. CPU busy% is the classic
# delta over the interval between two panel samples:
#     busy% = (d_total - d_idle) / d_total * 100
# The old widget scaled the EWMA 1-minute load average (`load*100/2`) into a
# percent, which was wrong on two counts: (1) a load average is NOT a
# utilisation percentage, and (2) `load*50` pegs at 100% for any load >= 2 —
# trivially reached by a couple of READY tasks — so the meter sat at 100% even
# on a fully idle desktop. It also read empty at boot (EWMA seeded to 0). The
# delta form reports real near-0% at idle. The FIRST sample has no previous
# baseline, so it must report 0 (NOT "all elapsed ticks were busy").
_cpu_prev_total: uint64 = 0
_cpu_prev_idle:  uint64 = 0
_cpu_inited:     int32  = 0
_cpu_last_pct:   int32  = 0


# Parse "<sec>.<CC>" at buf[pi[0]..] into centiseconds; advance pi past it.
# A missing ".CC" fraction counts as .00.
def _parse_centis(buf: Ptr[uint8], total: uint64, pi: Ptr[uint64]) -> uint64:
    i: uint64 = pi[0]
    whole: uint64 = 0
    while i < total and buf[i] >= 48 and buf[i] <= 57:
        whole = whole * 10 + cast[uint64](buf[i]) - 48
        i = i + 1
    cc: uint64 = 0
    if i < total and buf[i] == 46:                     # '.'
        i = i + 1
        d: uint64 = 0
        while i < total and buf[i] >= 48 and buf[i] <= 57 and d < 2:
            cc = cc * 10 + cast[uint64](buf[i]) - 48
            i = i + 1
            d = d + 1
        if d == 1:
            cc = cc * 10
    pi[0] = i
    return whole * 100 + cc


def _cpu_pct() -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/uptime"))
    if fd < 0:
        return _cpu_last_pct
    buf: Array[64, uint8]
    r: int64 = sys_read(fd, &buf[0], 63)
    sys_close(fd)
    if r <= 0:
        return _cpu_last_pct
    cap: uint64 = cast[uint64](r)
    pos: Array[1, uint64]
    pos[0] = 0
    total: uint64 = _parse_centis(&buf[0], cap, &pos[0])
    while pos[0] < cap and (buf[pos[0]] == 32 or buf[pos[0]] == 9):
        pos[0] = pos[0] + 1
    idle: uint64 = _parse_centis(&buf[0], cap, &pos[0])
    if _cpu_inited == 0:
        # First sample: establish the baseline, report 0% (no interval yet).
        _cpu_prev_total = total
        _cpu_prev_idle = idle
        _cpu_inited = 1
        _cpu_last_pct = 0
        return 0
    dt: uint64 = total - _cpu_prev_total
    di: uint64 = idle - _cpu_prev_idle
    _cpu_prev_total = total
    _cpu_prev_idle = idle
    if dt == 0:
        return _cpu_last_pct               # sampled twice within one tick
    if di > dt:
        di = dt                            # clamp: idle can't exceed wall
    busy: uint64 = dt - di
    pct: uint64 = (busy * 100) / dt
    if pct > 100:
        pct = 100
    _cpu_last_pct = cast[int32](pct)
    return _cpu_last_pct


# --- taskbar window list (parsed from /dev/wsys/windows) -------------
MAX_TASKS: uint64 = 8
task_wid:  Array[8, int32]
task_name: Array[512, uint8]          # 8 * 64
task_namelen: Array[8, uint64]
n_tasks: uint64 = 0
# Content hash of the last /dev/wsys/windows snapshot (FNV-1a over the raw
# bytes: wids + titles + order). The taskbar must re-render whenever ANY of
# these change — not just the window COUNT. Count-only detection missed the
# common case where an app `newwindow`s (enumerated as "winN") and only writes
# its real `title` a moment later: same count, so the taskbar stayed stuck on
# the "winN" placeholder and the freshly-opened app "never appeared" under its
# name. It also missed a same-count swap (close A + open B within one poll).
win_hash: uint64 = 0


def _refresh_windows():
    n_tasks = 0
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/windows"))
    if fd < 0:
        win_hash = 0
        return
    buf: Array[1024, uint8]
    total: uint64 = 0
    while total < 1023:
        r: int64 = sys_read(fd, &buf[total], 1023 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    # FNV-1a over the raw snapshot so any change to the window SET (a new
    # window, a closed one, a title that landed after the window mapped, a
    # same-count swap) flips the hash and forces a taskbar re-render.
    h: uint64 = 14695981039346656037
    hi: uint64 = 0
    while hi < total:
        h = h ^ cast[uint64](buf[hi])
        h = h * 1099511628211
        hi = hi + 1
    win_hash = h
    i: uint64 = 0
    while i < total and n_tasks < MAX_TASKS:
        w: int32 = 0
        got: int32 = 0
        while i < total and buf[i] >= 48 and buf[i] <= 57:
            w = w * 10 + cast[int32](buf[i]) - 48
            got = 1
            i = i + 1
        if i < total and buf[i] == 32:
            i = i + 1
        nbase: uint64 = n_tasks * 64
        nl: uint64 = 0
        while i < total and buf[i] != 10 and nl < 63:
            task_name[nbase + nl] = buf[i]
            nl = nl + 1
            i = i + 1
        while i < total and buf[i] != 10:
            i = i + 1
        if i < total:
            i = i + 1
        if got != 0:
            task_wid[n_tasks] = w
            task_namelen[n_tasks] = nl
            n_tasks = n_tasks + 1


# ====================================================================
# CONFIG — /etc/panel.conf parsed into a set of PANELS, each with its
# own edge, appearance, and ordered widget list.
# ====================================================================

# widget kinds
WK_MENU:    int32 = 0
WK_TASKS:   int32 = 1
WK_CLOCK:   int32 = 2
WK_SYSMON:  int32 = 3
WK_SPACER:  int32 = 4
# MATE-parity applets (this build adds three real, functional applets):
#   WK_PAGER   virtual-desktop / workspace switcher. Reads /dev/wsys/workspace
#              (kernel snapshot "<gen> <ws>\n"), draws WS_COUNT clickable cells
#              with the active one lit; a click writes "ws <N>\n" to
#              /dev/wsys/ctl so the compositor's workspace_switch() hides the
#              other desktops' windows. Real virtual desktops, not a stub.
#   WK_TRAY    notification area. Draws a bell glyph + an unread dot when the
#              compositor's /dev/wsys/notif snapshot reports an active toast;
#              a click spawns /bin/hamtray (the message-tray history panel).
#   WK_SESSION session button. A power glyph; a click spawns /bin/hamsessui
#              (the Lock / Log Out / Shut Down / Reboot dialog) so the session
#              menu is reachable straight from the panel, MATE-style.
WK_PAGER:   int32 = 5
WK_TRAY:    int32 = 6
WK_SESSION: int32 = 7
#   WK_LAUNCHER  a one-click application launcher: a placeholder icon chip
#              (the label's first letter — a clean seam for #285's real
#              per-app icons) + a text label. A click spawns the carried Exec
#              path (reusing _launch/spawn_detached, exactly like the menu/tray
#              applets). Its Exec + label live in the parallel p_wexec/p_wlabel
#              stores indexed by the same panel*MAX_WIDGETS+slot grid as
#              p_wkind. Config syntax: `widget launcher <exec> <label>`.
WK_LAUNCHER: int32 = 8

# Workspace count for the pager. Mirrors the compositor's WS_COUNT; if the two
# ever diverge the pager just shows fewer/more cells than exist, harmless.
WS_COUNT: int64 = 4

# edges
EDGE_TOP:    int32 = 0
EDGE_BOTTOM: int32 = 1
EDGE_LEFT:   int32 = 2
EDGE_RIGHT:  int32 = 3

MAX_PANELS:  uint64 = 4
MAX_WIDGETS: uint64 = 12               # per panel

# Per-panel config (struct-of-arrays).
p_edge:  Array[4, int32]
p_size:  Array[4, int64]               # thickness in px
p_bold:  Array[4, int32]               # font weight (0 normal, 1 bold)
p_color: Array[40, uint8]              # 4 * 10  "#RRGGBB\0"
p_nwidg: Array[4, uint64]              # widget count per panel
# widget kind grid: panel * MAX_WIDGETS + slot
p_wkind: Array[48, int32]              # 4 * 12
# ARBITRARY WIDGET POSITION (bug 3): per-widget pinned flow-axis coordinate.
# -1 = AUTO (the classic flow packing: leading widgets from the start edge,
# trailing from the far edge, the elastic taskbar filling the middle). A
# value >= 0 PINS the widget at that exact px on the flow axis (x for a
# horizontal panel, y for a vertical one), clamped into the bar — so a widget
# can sit anywhere, e.g. the CENTRE of the bar, not just a coarse slot. A
# pinned widget is lifted OUT of flow packing so it doesn't shove its
# neighbours. Set by a live Move (bug 2) and persisted to panel.conf.
p_wx_pin: Array[48, int64]            # 4 * 12, -1 = auto-flow
# LAUNCHER payload grid (parallel to p_wkind): for a WK_LAUNCHER slot the Exec
# path and the visible label. Both indexed by the SAME panel*MAX_WIDGETS+slot
# global slot number as p_wkind, so insert/remove/move must shift them in
# lockstep (see _copy_wstr_slot below). Non-launcher slots leave these empty.
LEXEC_SZ:  uint64 = 64                 # max Exec path incl NUL
LLABEL_SZ: uint64 = 24                 # max label incl NUL
p_wexec:  Array[3072, uint8]          # 48 * 64
p_wlabel: Array[1152, uint8]          # 48 * 24
n_panels: uint64 = 0


# Pointers into the launcher payload grid for global slot `g`.
def _wexec_ptr(g: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&p_wexec[0]) + g * LEXEC_SZ)


def _wlabel_ptr(g: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&p_wlabel[0]) + g * LLABEL_SZ)


# Copy buf[s..e) into dst as a NUL-terminated string, clamped to maxn (incl NUL).
def _copy_tok(buf: Ptr[uint8], s: uint64, e: uint64, dst: Ptr[uint8],
              maxn: uint64):
    k: uint64 = 0
    i: uint64 = s
    while i < e and k + 1 < maxn:
        dst[k] = buf[i]
        k = k + 1
        i = i + 1
    dst[k] = 0


# Copy a NUL-terminated string into a payload cell, clamped to maxn (incl NUL).
def _set_wstr(dp: Ptr[uint8], src: Ptr[uint8], maxn: uint64):
    k: uint64 = 0
    while src[k] != 0 and k + 1 < maxn:
        dp[k] = src[k]
        k = k + 1
    dp[k] = 0


# Move the launcher payload (exec+label) from global slot src to global slot
# dst — used when insert/remove shift the widget grid so a launcher's Exec and
# label follow its kind.
def _copy_wstr_slot(dst: uint64, src: uint64):
    _set_wstr(_wexec_ptr(dst), _wexec_ptr(src), LEXEC_SZ)
    _set_wstr(_wlabel_ptr(dst), _wlabel_ptr(src), LLABEL_SZ)


# Placeholder icon glyph for a launcher: the label's first letter, upper-cased.
# #285 replaces this with a real per-app icon via a shared helper; the seam is
# this single function + the icon-chip fill in _render_launcher.
def _launcher_glyph(label: Ptr[uint8]) -> uint8:
    c: uint8 = label[0]
    if c >= 97 and c <= 122:
        return c - 32
    if c == 0:
        return 63                          # '?'
    return c


# Initialize every pin slot to AUTO once at startup (globals zero-init, so
# without this a freshly-added widget at a never-written slot could read 0 =
# "pinned at x0"). Called from main() before the first config load.
def _init_pins():
    i: uint64 = 0
    while i < 48:
        p_wx_pin[i] = -1
        i = i + 1


def p_color_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&p_color[0]) + i * 10)


def _set_pcolor(i: uint64, hx: Ptr[uint8]):
    dp: Ptr[uint8] = p_color_ptr(i)
    k: uint64 = 0
    while hx[k] != 0 and k < 9:
        dp[k] = hx[k]
        k = k + 1
    dp[k] = 0


# Defaults applied when a panel block omits a field.
PANEL_DEF_H: int64 = 26                # default horizontal thickness
PANEL_DEF_V: int64 = 56                # default vertical thickness


def _begin_panel(edge: int32) -> uint64:
    if n_panels >= MAX_PANELS:
        return MAX_PANELS                 # overflow sentinel
    idx: uint64 = n_panels
    p_edge[idx] = edge
    if edge == EDGE_LEFT or edge == EDGE_RIGHT:
        p_size[idx] = PANEL_DEF_V
    else:
        p_size[idx] = PANEL_DEF_H
    p_bold[idx] = 0
    _set_pcolor(idx, cast[Ptr[uint8]]("#eceef2"))
    p_nwidg[idx] = 0
    n_panels = n_panels + 1
    return idx


def _add_widget_pin(panel: uint64, kind: int32, pin: int64):
    if panel >= n_panels:
        return
    nw: uint64 = p_nwidg[panel]
    if nw >= MAX_WIDGETS:
        return
    p_wkind[panel * MAX_WIDGETS + nw] = kind
    p_wx_pin[panel * MAX_WIDGETS + nw] = pin
    p_nwidg[panel] = nw + 1


def _add_widget(panel: uint64, kind: int32):
    _add_widget_pin(panel, kind, -1)


# Append a WK_LAUNCHER widget carrying an Exec path + label to `panel`.
def _add_launcher(panel: uint64, exec: Ptr[uint8], label: Ptr[uint8]):
    if panel >= n_panels:
        return
    nw: uint64 = p_nwidg[panel]
    if nw >= MAX_WIDGETS:
        return
    g: uint64 = panel * MAX_WIDGETS + nw
    p_wkind[g] = WK_LAUNCHER
    p_wx_pin[g] = -1
    _set_wstr(_wexec_ptr(g), exec, LEXEC_SZ)
    _set_wstr(_wlabel_ptr(g), label, LLABEL_SZ)
    p_nwidg[panel] = nw + 1


# Insert a WK_LAUNCHER at flow index `at` (used by a menu-drag drop so the new
# launcher lands next to the Applications menu rather than trailing the bar).
def _insert_launcher(panel: uint64, at: uint64, exec: Ptr[uint8],
                     label: Ptr[uint8]):
    if panel >= n_panels:
        return
    if p_nwidg[panel] >= MAX_WIDGETS:
        return
    _insert_widget(panel, at, WK_LAUNCHER)
    # _insert_widget clamps `at`; recompute the real landing slot.
    nw: uint64 = p_nwidg[panel]
    la: uint64 = at
    if la >= nw:
        la = nw - 1
    g: uint64 = panel * MAX_WIDGETS + la
    _set_wstr(_wexec_ptr(g), exec, LEXEC_SZ)
    _set_wstr(_wlabel_ptr(g), label, LLABEL_SZ)


# Insert `kind` into panel `panel` at flow index `at` (0..p_nwidg), shifting
# later widgets up. No-op if the panel is full or indices are out of range.
def _insert_widget(panel: uint64, at: uint64, kind: int32):
    if panel >= n_panels:
        return
    nw: uint64 = p_nwidg[panel]
    if nw >= MAX_WIDGETS:
        return
    if at > nw:
        at = nw
    base: uint64 = panel * MAX_WIDGETS
    j: uint64 = nw
    while j > at:
        p_wkind[base + j] = p_wkind[base + j - 1]
        p_wx_pin[base + j] = p_wx_pin[base + j - 1]
        _copy_wstr_slot(base + j, base + j - 1)   # launcher payload follows
        j = j - 1
    p_wkind[base + at] = kind
    p_wx_pin[base + at] = -1
    _set_wstr(_wexec_ptr(base + at), cast[Ptr[uint8]](""), LEXEC_SZ)
    _set_wstr(_wlabel_ptr(base + at), cast[Ptr[uint8]](""), LLABEL_SZ)
    p_nwidg[panel] = nw + 1


# Remove the widget at flow index `at` from panel `panel`, shifting later
# widgets down.
def _remove_widget(panel: uint64, at: uint64):
    if panel >= n_panels:
        return
    nw: uint64 = p_nwidg[panel]
    if at >= nw:
        return
    base: uint64 = panel * MAX_WIDGETS
    j: uint64 = at
    while j + 1 < nw:
        p_wkind[base + j] = p_wkind[base + j + 1]
        p_wx_pin[base + j] = p_wx_pin[base + j + 1]
        _copy_wstr_slot(base + j, base + j + 1)   # launcher payload follows
        j = j + 1
    p_nwidg[panel] = nw - 1


def _default_config():
    # MATE-style two-panel default (the no-file fallback). It MUST stay
    # byte-for-byte equivalent to the shipped /etc/panel.conf so the fallback
    # path renders identically to the on-disk config:
    #   TOP    [menu] [spacer ......] [tray] [sysmon] [clock]
    #   BOTTOM [tasks .......................] [pager]
    # The window-list (tasks) lives on the BOTTOM panel ONLY (MATE
    # convention); the TOP panel carries the Applications menu + the status
    # area (notification TRAY, sysmon, clock), with an elastic SPACER as the
    # filler so the trailing tray/sysmon/clock right-align (clock outermost).
    # The workspace PAGER trails the bottom window-list.
    # #264: the window-list used to appear on BOTH panels (tasks top AND
    # bottom) — a redundant duplicate; it is now bottom-only. The tray (bell)
    # and pager are kept in the default (the tray is where the #272 inbox
    # popup anchors; the pager is the #213 Ctrl+Alt+arrows workspace switcher).
    n_panels = 0
    pi: uint64 = _begin_panel(EDGE_TOP)
    _add_widget(pi, WK_MENU)
    # #283: a one-click Terminal launcher next to the Applications menu. Since
    # #282 the DE no longer auto-opens a terminal, so this button is the
    # intended one-click way to get one (spawns /bin/hamtermscene).
    _add_launcher(pi, cast[Ptr[uint8]]("/bin/hamtermscene"),
                  cast[Ptr[uint8]]("Terminal"))
    _add_widget(pi, WK_SPACER)
    _add_widget(pi, WK_TRAY)
    _add_widget(pi, WK_SYSMON)
    _add_widget(pi, WK_CLOCK)
    pb: uint64 = _begin_panel(EDGE_BOTTOM)
    _add_widget(pb, WK_TASKS)
    _add_widget(pb, WK_PAGER)


# Match the word at buf[s..e) against a NUL-terminated literal.
def _word_eq(buf: Ptr[uint8], s: uint64, e: uint64, lit: Ptr[uint8]) -> int32:
    ll: uint64 = _slen(lit)
    if e - s != ll:
        return 0
    k: uint64 = 0
    while k < ll:
        if buf[s + k] != lit[k]:
            return 0
        k = k + 1
    return 1


def _widget_kind(buf: Ptr[uint8], s: uint64, e: uint64) -> int32:
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("menu")) != 0:
        return WK_MENU
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("tasks")) != 0:
        return WK_TASKS
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("clock")) != 0:
        return WK_CLOCK
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("sysmon")) != 0:
        return WK_SYSMON
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("spacer")) != 0:
        return WK_SPACER
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("pager")) != 0:
        return WK_PAGER
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("tray")) != 0:
        return WK_TRAY
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("session")) != 0:
        return WK_SESSION
    return -1


def _edge_kind(buf: Ptr[uint8], s: uint64, e: uint64) -> int32:
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("top")) != 0:
        return EDGE_TOP
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("bottom")) != 0:
        return EDGE_BOTTOM
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("left")) != 0:
        return EDGE_LEFT
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("right")) != 0:
        return EDGE_RIGHT
    return -1


# Parse a decimal int from buf[s..e).
def _parse_i64(buf: Ptr[uint8], s: uint64, e: uint64) -> int64:
    v: int64 = 0
    i: uint64 = s
    while i < e and buf[i] >= 48 and buf[i] <= 57:
        v = v * 10 + cast[int64](buf[i]) - 48
        i = i + 1
    return v


# Copy a hex colour token buf[s..e) into a NUL-terminated dest (<=9 chars).
def _copy_color(buf: Ptr[uint8], s: uint64, e: uint64, dst: Ptr[uint8]):
    k: uint64 = 0
    i: uint64 = s
    while i < e and k < 9:
        dst[k] = buf[i]
        k = k + 1
        i = i + 1
    dst[k] = 0


# Legacy single-panel state assembled from bare left/right/position lines.
_legacy_seen: int32 = 0
_legacy_idx:  uint64 = 0
_legacy_edge: int32 = 0


def _legacy_panel() -> uint64:
    # Lazily create (once) the implicit panel that holds bare left/right
    # widgets. Its edge is whatever the most recent `position` line set.
    if _legacy_seen == 0:
        _legacy_idx = _begin_panel(_legacy_edge)
        _legacy_seen = 1
    return _legacy_idx


# The ACTIVE config is the writable runtime override /tmp/hamnix-panel.conf
# (tmpfs — writable from the DE) if it exists, else the shipped read-only
# default /etc/panel.conf. This is the crux of the position/sysmon-toggle
# bug: the sysroot /etc is NOT writable from the running DE, so a Settings
# (or shell) write to /etc/panel.conf was silently dropped and the panel
# never saw a change. Settings now writes the override in /tmp, which the
# panel reads + live-polls. (Mirrors how the wallpaper already lands in /tmp.)
def _open_config() -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/tmp/hamnix-panel.conf"))
    if fd >= 0:
        return fd
    return sys_open(cast[Ptr[char]]("/etc/panel.conf"))


_cfg_buf: Array[2048, uint8]
def _load_config():
    # Parse the active panel config into the panel set. Supports the new
    # `panel ... end` blocks AND the legacy `position`/`left`/`right` bare
    # lines (which build one implicit panel). On ANY failure fall back to the
    # built-in default single top panel.
    n_panels = 0
    _legacy_seen = 0
    _legacy_edge = EDGE_TOP
    cur_panel: uint64 = MAX_PANELS         # MAX_PANELS = "no open block"
    fd: int32 = _open_config()
    if fd < 0:
        _default_config()
        return
    total: uint64 = 0
    while total < 2047:
        r: int64 = sys_read(fd, &_cfg_buf[total], 2047 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    i: uint64 = 0
    while i < total:
        ls: uint64 = i
        while i < total and _cfg_buf[i] != 10:
            i = i + 1
        le: uint64 = i
        if i < total:
            i = i + 1
        p: uint64 = ls
        while p < le and (_cfg_buf[p] == 32 or _cfg_buf[p] == 9):
            p = p + 1
        if p >= le or _cfg_buf[p] == 35:               # blank or '#'
            continue
        w0s: uint64 = p
        while p < le and _cfg_buf[p] != 32 and _cfg_buf[p] != 9:
            p = p + 1
        w0e: uint64 = p
        while p < le and (_cfg_buf[p] == 32 or _cfg_buf[p] == 9):
            p = p + 1
        w1s: uint64 = p
        while p < le and _cfg_buf[p] != 32 and _cfg_buf[p] != 9:
            p = p + 1
        w1e: uint64 = p

        # --- new block form ---------------------------------------
        if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("panel")) != 0:
            cur_panel = _begin_panel(EDGE_TOP)
            continue
        if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("end")) != 0:
            cur_panel = MAX_PANELS
            continue
        if cur_panel < n_panels:
            if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("edge")) != 0:
                ek: int32 = _edge_kind(&_cfg_buf[0], w1s, w1e)
                if ek >= 0:
                    p_edge[cur_panel] = ek
                    # adopt the matching default thickness for the new
                    # orientation unless a size line overrides it later
                    if ek == EDGE_LEFT or ek == EDGE_RIGHT:
                        p_size[cur_panel] = PANEL_DEF_V
                    else:
                        p_size[cur_panel] = PANEL_DEF_H
                continue
            if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("color")) != 0:
                if w1e > w1s:
                    _copy_color(&_cfg_buf[0], w1s, w1e, p_color_ptr(cur_panel))
                continue
            if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("size")) != 0:
                sz: int64 = _parse_i64(&_cfg_buf[0], w1s, w1e)
                if sz > 0:
                    p_size[cur_panel] = sz
                continue
            if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("font")) != 0:
                if _word_eq(&_cfg_buf[0], w1s, w1e, cast[Ptr[uint8]]("bold")) != 0:
                    p_bold[cur_panel] = 1
                else:
                    p_bold[cur_panel] = 0
                continue
            if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("widget")) != 0:
                # `widget launcher <exec> <label>` — a launcher carries two
                # extra tokens (Exec path + label) so it is parsed here, not via
                # _widget_kind (which maps a single keyword to a kind).
                if _word_eq(&_cfg_buf[0], w1s, w1e,
                            cast[Ptr[uint8]]("launcher")) != 0:
                    lq: uint64 = w1e
                    while lq < le and (_cfg_buf[lq] == 32 or _cfg_buf[lq] == 9):
                        lq = lq + 1
                    exs: uint64 = lq
                    while lq < le and _cfg_buf[lq] != 32 and _cfg_buf[lq] != 9:
                        lq = lq + 1
                    exe: uint64 = lq
                    while lq < le and (_cfg_buf[lq] == 32 or _cfg_buf[lq] == 9):
                        lq = lq + 1
                    lbs: uint64 = lq
                    while lq < le and _cfg_buf[lq] != 32 and _cfg_buf[lq] != 9:
                        lq = lq + 1
                    lbe: uint64 = lq
                    if exe > exs:
                        exbuf: Array[64, uint8]
                        lbbuf: Array[24, uint8]
                        _copy_tok(&_cfg_buf[0], exs, exe, &exbuf[0], 64)
                        if lbe > lbs:
                            _copy_tok(&_cfg_buf[0], lbs, lbe, &lbbuf[0], 24)
                        else:
                            lbbuf[0] = 63              # '?'
                            lbbuf[1] = 0
                        _add_launcher(cur_panel, &exbuf[0], &lbbuf[0])
                    continue
                wk: int32 = _widget_kind(&_cfg_buf[0], w1s, w1e)
                if wk >= 0:
                    # Optional `x <n>` suffix pins the widget at a flow-axis
                    # coordinate (bug 3). Scan the rest of the line for it.
                    wpin: int64 = -1
                    q: uint64 = w1e
                    while q < le and (_cfg_buf[q] == 32 or _cfg_buf[q] == 9):
                        q = q + 1
                    w2s: uint64 = q
                    while q < le and _cfg_buf[q] != 32 and _cfg_buf[q] != 9:
                        q = q + 1
                    w2e: uint64 = q
                    if _word_eq(&_cfg_buf[0], w2s, w2e, cast[Ptr[uint8]]("x")) != 0:
                        while q < le and (_cfg_buf[q] == 32 or _cfg_buf[q] == 9):
                            q = q + 1
                        w3s: uint64 = q
                        while q < le and _cfg_buf[q] != 32 and _cfg_buf[q] != 9:
                            q = q + 1
                        if q > w3s:
                            wpin = _parse_i64(&_cfg_buf[0], w3s, q)
                    _add_widget_pin(cur_panel, wk, wpin)
                continue
            # unknown key inside a block: ignore
            continue

        # --- legacy bare lines (outside any block) ----------------
        if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("position")) != 0:
            ek2: int32 = _edge_kind(&_cfg_buf[0], w1s, w1e)
            if ek2 == EDGE_BOTTOM:
                _legacy_edge = EDGE_BOTTOM
            elif ek2 == EDGE_LEFT:
                _legacy_edge = EDGE_LEFT
            elif ek2 == EDGE_RIGHT:
                _legacy_edge = EDGE_RIGHT
            else:
                _legacy_edge = EDGE_TOP
            # if the legacy panel already exists, retro-apply the edge
            if _legacy_seen != 0:
                p_edge[_legacy_idx] = _legacy_edge
                if _legacy_edge == EDGE_LEFT or _legacy_edge == EDGE_RIGHT:
                    p_size[_legacy_idx] = PANEL_DEF_V
                else:
                    p_size[_legacy_idx] = PANEL_DEF_H
            continue
        sidew: int32 = -1
        if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("left")) != 0:
            sidew = 0
        if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("right")) != 0:
            sidew = 1
        if sidew >= 0 and w1e > w1s:
            wk2: int32 = _widget_kind(&_cfg_buf[0], w1s, w1e)
            if wk2 >= 0:
                lp: uint64 = _legacy_panel()
                if lp < n_panels:
                    # A bare `right <w>` widget that follows the elastic
                    # taskbar packs to the far edge; we encode that by making
                    # the widget order menu/tasks(left) ... sysmon/clock and
                    # relying on the renderer's right-align of trailing fixed
                    # widgets. Insert in source order; `right` widgets simply
                    # come after `left` ones in the list.
                    _add_widget(lp, wk2)
        # unknown bare line: ignore
    if n_panels == 0:
        _default_config()


# Live config re-read (snapshot-compare; no mtime exposed to userland).
_cfg_snap: Array[2048, uint8]
_cfg_snap_len: uint64 = 0xffffffffffffffff
_cfg_scan: Array[2048, uint8]
def _cfg_changed() -> int32:
    fd: int32 = _open_config()
    total: uint64 = 0
    if fd >= 0:
        while total < 2047:
            r: int64 = sys_read(fd, &_cfg_scan[total], 2047 - total)
            if r <= 0:
                break
            total = total + cast[uint64](r)
        sys_close(fd)
    same: int32 = 1
    if total != _cfg_snap_len:
        same = 0
    else:
        i: uint64 = 0
        while i < total:
            if _cfg_scan[i] != _cfg_snap[i]:
                same = 0
                i = total
            else:
                i = i + 1
    if same != 0:
        return 0
    j: uint64 = 0
    while j < total:
        _cfg_snap[j] = _cfg_scan[j]
        j = j + 1
    _cfg_snap_len = total
    return 1


# Edge index -> config keyword.
def _edge_word(e: int32) -> Ptr[uint8]:
    if e == EDGE_BOTTOM:
        return cast[Ptr[uint8]]("bottom")
    if e == EDGE_LEFT:
        return cast[Ptr[uint8]]("left")
    if e == EDGE_RIGHT:
        return cast[Ptr[uint8]]("right")
    return cast[Ptr[uint8]]("top")


# Widget kind -> config keyword.
def _kind_word(k: int32) -> Ptr[uint8]:
    if k == WK_TASKS:
        return cast[Ptr[uint8]]("tasks")
    if k == WK_CLOCK:
        return cast[Ptr[uint8]]("clock")
    if k == WK_SYSMON:
        return cast[Ptr[uint8]]("sysmon")
    if k == WK_SPACER:
        return cast[Ptr[uint8]]("spacer")
    if k == WK_PAGER:
        return cast[Ptr[uint8]]("pager")
    if k == WK_TRAY:
        return cast[Ptr[uint8]]("tray")
    if k == WK_SESSION:
        return cast[Ptr[uint8]]("session")
    return cast[Ptr[uint8]]("menu")


_save_buf: Array[2048, uint8]
def _sb_emit(p: uint64, s: Ptr[uint8]) -> uint64:
    k: uint64 = 0
    while s[k] != 0 and p < 2047:
        _save_buf[p] = s[k]
        p = p + 1
        k = k + 1
    return p


# Serialize the live panel set to /tmp/hamnix-panel.conf in the EXACT
# `panel ... end` block schema _load_config parses. Called after every
# Add / Move / Remove so edits survive a restart. After writing we re-prime
# the live-reload baseline (_cfg_changed) so our OWN write does NOT trip a
# spurious reload on the next tick (which would otherwise rebuild the panel
# set and momentarily flicker).
def _save_config():
    p: uint64 = 0
    p = _sb_emit(p, cast[Ptr[uint8]]("# hamnix panel config (auto-saved by hampanelscene)\n"))
    pi: uint64 = 0
    while pi < n_panels:
        p = _sb_emit(p, cast[Ptr[uint8]]("panel p"))
        p = p + _u64_to_dec(pi, &_save_buf[p])
        _save_buf[p] = 10
        p = p + 1
        p = _sb_emit(p, cast[Ptr[uint8]]("  edge "))
        p = _sb_emit(p, _edge_word(p_edge[pi]))
        _save_buf[p] = 10
        p = p + 1
        p = _sb_emit(p, cast[Ptr[uint8]]("  size "))
        p = p + _u64_to_dec(cast[uint64](p_size[pi]), &_save_buf[p])
        _save_buf[p] = 10
        p = p + 1
        p = _sb_emit(p, cast[Ptr[uint8]]("  color "))
        p = _sb_emit(p, p_color_ptr(pi))
        _save_buf[p] = 10
        p = p + 1
        p = _sb_emit(p, cast[Ptr[uint8]]("  font "))
        if p_bold[pi] != 0:
            p = _sb_emit(p, cast[Ptr[uint8]]("bold"))
        else:
            p = _sb_emit(p, cast[Ptr[uint8]]("normal"))
        _save_buf[p] = 10
        p = p + 1
        nw: uint64 = p_nwidg[pi]
        a: uint64 = 0
        while a < nw:
            gslot: uint64 = pi * MAX_WIDGETS + a
            wkv: int32 = p_wkind[gslot]
            p = _sb_emit(p, cast[Ptr[uint8]]("  widget "))
            if wkv == WK_LAUNCHER:
                # `widget launcher <exec> <label>` round-trips the payload.
                p = _sb_emit(p, cast[Ptr[uint8]]("launcher "))
                p = _sb_emit(p, _wexec_ptr(gslot))
                p = _sb_emit(p, cast[Ptr[uint8]](" "))
                p = _sb_emit(p, _wlabel_ptr(gslot))
            else:
                p = _sb_emit(p, _kind_word(wkv))
                pin: int64 = p_wx_pin[gslot]
                if pin >= 0:
                    p = _sb_emit(p, cast[Ptr[uint8]](" x "))
                    p = p + _u64_to_dec(cast[uint64](pin), &_save_buf[p])
            _save_buf[p] = 10
            p = p + 1
            a = a + 1
        p = _sb_emit(p, cast[Ptr[uint8]]("end\n"))
        pi = pi + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/tmp/hamnix-panel.conf"))
    if fd >= 0:
        sys_write(fd, &_save_buf[0], p)
        sys_close(fd)
    # Re-prime the live-reload baseline so this write doesn't trigger a reload.
    _cfg_changed()


# ====================================================================
# LAYOUT + RENDER (one panel at a time; main() iterates panels)
# ====================================================================

PANEL_H: int64 = 26                  # nominal horizontal bar height (gate)
GLYPH_Y: int64 = 5
MENU_ROW_H: int64 = 22
APP_BTN_W: int64 = 104               # Apps button box (label fully inside)
APP_DIV_X: int64 = 104               # divider line x within the button cell
MENU_W: int64 = 136
# MENU_H is DYNAMIC: _load_apps() sets it (window-reservation height = the
# taller of the main dropdown OR the "Linux apps" fly-out child, so whichever
# popup is showing fits inside the grown panel window). The 202 default (9
# rows) is the fallback used only if the catalogue is empty at first paint.
MENU_H: int64 = 202
# The main dropdown's OWN box height (native rows + the "Linux apps" parent
# row). Distinct from MENU_H, which also has to cover the child fly-out.
menu_main_h: int64 = 202
# MATE-style "Linux apps" HOVER SUBMENU (a child fly-out popup). The main
# dropdown lists the NATIVE apps plus one parent row, "Linux apps ▸"; mousing
# over that row opens this child popup listing every Debian/Linux-ns .desktop
# app (cat == DE_CAT_LINUX), launched via `enter linux`. Wider than MENU_W so
# full Linux app names + the "No Linux apps installed" placeholder fit (8px
# mono cell).
SUBMENU_W: int64 = 224
sub_open:  int32 = 0                  # 1 while the Linux fly-out is showing
sub_box_x: int64 = 0
sub_box_y: int64 = 0
SYSMON_W: int64 = 116
CLOCK_W: int64 = 136                 # MATE date+time: "Sat Jul 12  14:30" (17ch)
TASK_BTN_W: int64 = 132
# Workspace-switcher cell: WS_COUNT cells of PAGER_CELL_W with 2px gaps.
PAGER_CELL_W: int64 = 22
PAGER_W: int64 = 92                   # 4*22 + 3*2 gaps, rounded
TRAY_W: int64 = 24                    # bell glyph cell
SESSION_W: int64 = 24                 # power glyph cell

# ====================================================================
# DATA-DRIVEN APPLICATIONS MENU (lib/desktopentry.ad)
# ====================================================================
# The Applications dropdown is populated at startup from the
# *.desktop files under /etc/hamde/apps/ — one file per app. Adding an
# app is dropping a file, never a code edit. Entries are sorted by
# (category, Name) so the flat dropdown clusters apps by section. If the
# directory is missing/empty (e.g. a stripped image), _seed_fallback()
# plants the known native app set so the DE is never menu-less.
AM_MAX:      uint64 = 24
AM_NAME_CAP: uint64 = 40
AM_PROG_CAP: uint64 = 96

def _apps_dir() -> Ptr[uint8]:
    return "/etc/hamde/apps"

# The Debian/Linux-namespace application catalogue, reached through the
# READ bind of the `#distro` file server at /n/linux (planted in the DE
# panel's namespace by /etc/rc.d/rc.5). Freedesktop drops installed apps'
# .desktop files here; scanning it surfaces real Debian apps in the menu's
# "Linux" section without a code edit per app — the same data-driven shape
# the native /etc/hamde/apps catalogue uses.
def _linux_apps_dir() -> Ptr[uint8]:
    return "/n/linux/usr/share/applications"

am_count: uint64 = 0
am_name:     Array[24, Array[40, uint8]]
am_name_len: Array[24, uint64]
am_prog:     Array[24, Array[96, uint8]]
am_prog_len: Array[24, uint64]
am_cat:      Array[24, int32]
# Per-entry Terminal=true flag (freedesktop). A CLI app (e.g. the Linux
# "Process Viewer" `top`) has no window surface of its own, so it must be
# hosted in a rendered terminal emulator (hamtermscene) rather than launched
# headless — otherwise clicking it opens nothing. 1 = needs a terminal host.
am_term:     Array[24, uint8]

# Scan scratch: the directory listing + one file's contents.
_am_listbuf: Array[4096, uint8]
_am_filebuf: Array[2048, uint8]
_am_path:    Array[160, uint8]


# Compare menu slot `i` against (cat, name) for insertion-sort ordering.
# Returns >0 if slot i sorts AFTER (cat,name), <0 if before, 0 if equal.
def _am_cmp(i: uint64, cat: int32, name: Ptr[uint8], nlen: uint64) -> int32:
    if am_cat[i] > cat:
        return 1
    if am_cat[i] < cat:
        return -1
    # same category: lexicographic by name
    a: uint64 = 0
    while a < am_name_len[i] and a < nlen:
        if am_name[i][a] > name[a]:
            return 1
        if am_name[i][a] < name[a]:
            return -1
        a = a + 1
    if am_name_len[i] > nlen:
        return 1
    if am_name_len[i] < nlen:
        return -1
    return 0


# Insert (name, prog, cat) into the menu model, keeping it sorted by
# (category, Name). Silently drops overflow past AM_MAX.
def _am_add(name: Ptr[uint8], nlen: uint64, prog: Ptr[uint8],
            plen: uint64, cat: int32, term: int32):
    if am_count >= AM_MAX:
        return
    nl: uint64 = nlen
    if nl >= AM_NAME_CAP:
        nl = AM_NAME_CAP - 1
    pl: uint64 = plen
    if pl >= AM_PROG_CAP:
        pl = AM_PROG_CAP - 1
    # Find insertion point.
    pos: uint64 = 0
    while pos < am_count and _am_cmp(pos, cat, name, nl) < 0:
        pos = pos + 1
    # Shift tail up by one.
    j: uint64 = am_count
    while j > pos:
        k: uint64 = 0
        while k < AM_NAME_CAP:
            am_name[j][k] = am_name[j - 1][k]
            k = k + 1
        am_name_len[j] = am_name_len[j - 1]
        k = 0
        while k < AM_PROG_CAP:
            am_prog[j][k] = am_prog[j - 1][k]
            k = k + 1
        am_prog_len[j] = am_prog_len[j - 1]
        am_cat[j] = am_cat[j - 1]
        am_term[j] = am_term[j - 1]
        j = j - 1
    # Write the new slot.
    k2: uint64 = 0
    while k2 < nl:
        am_name[pos][k2] = name[k2]
        k2 = k2 + 1
    am_name[pos][nl] = 0
    am_name_len[pos] = nl
    k2 = 0
    while k2 < pl:
        am_prog[pos][k2] = prog[k2]
        k2 = k2 + 1
    am_prog[pos][pl] = 0
    am_prog_len[pos] = pl
    am_cat[pos] = cat
    am_term[pos] = cast[uint8](term)
    am_count = am_count + 1


# Fallback catalogue when /etc/hamde/apps is absent/empty. Mirrors the
# apps the scene DE ships so the menu is never blank. (cat codes match
# lib/desktopentry: 0 Accessories 1 Internet 2 Games 3 System 4 Settings)
def _seed_one(name: Ptr[uint8], prog: Ptr[uint8], cat: int32):
    _am_add(name, _slen(name), prog, _slen(prog), cat, 0)


# Live-medium probe: /etc/installer-medium is planted in the cpio ONLY by
# scripts/build_installer_img.sh, so it is present on the LIVE/installer boot
# and absent on every installed boot (see etc/rc.boot). Cached (0 unknown,
# 1 live, 2 installed): the installer launcher is surfaced ONLY when live.
_am_live_state: int32 = 0
def _am_is_live() -> int32:
    if _am_live_state == 0:
        fd: int32 = sys_open(cast[Ptr[char]]("/etc/installer-medium"))
        if fd >= 0:
            sys_close(fd)
            _am_live_state = 1
        else:
            _am_live_state = 2
    if _am_live_state == 1:
        return 1
    return 0


def _seed_fallback():
    _seed_one(cast[Ptr[uint8]]("Terminal"),       cast[Ptr[uint8]]("/bin/hamtermscene"), 3)
    _seed_one(cast[Ptr[uint8]]("Files"),          cast[Ptr[uint8]]("/bin/hamfmscene"),   0)
    _seed_one(cast[Ptr[uint8]]("Web Browser"),    cast[Ptr[uint8]]("/bin/hambrowse"),    1)
    _seed_one(cast[Ptr[uint8]]("Calculator"),     cast[Ptr[uint8]]("/bin/hamcalcscene"), 0)
    _seed_one(cast[Ptr[uint8]]("Editor"),         cast[Ptr[uint8]]("/bin/hameditscene"), 0)
    _seed_one(cast[Ptr[uint8]]("Control Center"),  cast[Ptr[uint8]]("/bin/hamctl"),       4)
    _seed_one(cast[Ptr[uint8]]("System Monitor"), cast[Ptr[uint8]]("/bin/hammonscene"),  3)
    _seed_one(cast[Ptr[uint8]]("2048"),           cast[Ptr[uint8]]("/bin/ham2048scene"), 2)
    # The installer launcher is a LIVE-medium-only entry — never on an
    # installed system (matches installer.desktop's X-Hamnix-LiveOnly=true).
    if _am_is_live() != 0:
        _seed_one(cast[Ptr[uint8]]("Install Hamnix"), cast[Ptr[uint8]]("/bin/haminstallui"), 3)


# Build "<dir>/<name>" into _am_path (NUL-terminated).
def _am_build_path(dir: Ptr[uint8], name: Ptr[uint8], nlen: uint64):
    p: uint64 = 0
    while dir[p] != 0:
        _am_path[p] = dir[p]
        p = p + 1
    _am_path[p] = 47                                  # '/'
    p = p + 1
    k: uint64 = 0
    while k < nlen and p < 159:
        _am_path[p] = name[k]
        p = p + 1
        k = k + 1
    _am_path[p] = 0


# Scan ONE *.desktop directory into the menu model. `force_cat` >= 0 pins
# every parsed entry to that category (the Linux section); < 0 keeps the
# freedesktop-classified native category. Returns how many entries were
# added. Shared by the native (/etc/hamde/apps) and Linux
# (/n/linux/usr/share/applications) scans so both honour the SAME tolerant
# lib/desktopentry parser and sorted insertion. Linux-ns entries (force_cat
# == DE_CAT_LINUX) sort last and surface under the "Linux apps" fly-out.
def _scan_apps_dir(dir: Ptr[uint8], force_cat: int32) -> uint64:
    added: uint64 = 0
    n: int64 = p9_listdir(cast[Ptr[char]](dir), &_am_listbuf[0], 4096)
    if n <= 0:
        return 0
    cap: uint64 = cast[uint64](n)
    i: uint64 = 0
    while i < cap:
        # One "NAME\n" record: [i, e).
        e: uint64 = i
        while e < cap and _am_listbuf[e] != 10:
            e = e + 1
        nm: Array[64, uint8]
        nl: uint64 = 0
        k: uint64 = i
        while k < e and nl < 63:
            nm[nl] = _am_listbuf[k]
            nl = nl + 1
            k = k + 1
        nm[nl] = 0
        if nl > 0 and desktop_name_is_entry(&nm[0]) != 0:
            _am_build_path(dir, &nm[0], nl)
            fd: int32 = sys_open(cast[Ptr[char]](&_am_path[0]))
            if fd >= 0:
                rn: int64 = sys_read(fd, &_am_filebuf[0], 2047)
                sys_close(fd)
                if rn > 0:
                    if desktop_parse(&_am_filebuf[0], cast[uint64](rn)) != 0 and (desktop_liveonly() == 0 or _am_is_live() != 0):
                        cat: int32 = desktop_catcode()
                        if force_cat >= 0:
                            cat = force_cat
                            # Linux-ns entries live under the dedicated "Linux
                            # apps" fly-out submenu, so the display label stays
                            # the plain freedesktop Name (no "(linux)" tag — the
                            # parent row already says these are Linux apps).
                            # launch still routes by cat (DE_CAT_LINUX).
                            _am_add(desktop_name_ptr(), desktop_name_len(),
                                    desktop_prog_ptr(), desktop_prog_len(),
                                    cat, desktop_terminal())
                        else:
                            _am_add(desktop_name_ptr(), desktop_name_len(),
                                    desktop_prog_ptr(), desktop_prog_len(),
                                    cat, desktop_terminal())
                        added = added + 1
        i = e + 1
    return added


# Scan the native /etc/hamde/apps/*.desktop catalogue AND the Debian
# /n/linux/usr/share/applications/*.desktop catalogue, populating the
# menu model. Native entries keep their freedesktop category; Linux
# entries are forced into the distinct DE_CAT_LINUX section (sorts last)
# and launched inside the `enter linux` namespace. Falls back to the
# hardcoded native set if the native directory yields no entries (the
# Linux section is additive on top). Refreshes MENU_H to the row count.
am_linux_count: uint64 = 0
def _load_apps():
    am_count = 0
    native: uint64 = _scan_apps_dir(_apps_dir(), -1)
    if native == 0:
        _seed_fallback()
    # Additive Linux-ns section (readonly #distro bind at /n/linux). Absent
    # or empty on a stripped image → the "Linux apps" fly-out shows a disabled
    # "No Linux apps installed" row (never an error, never vanishes — so the
    # user always sees the feature exists).
    am_linux_count = _scan_apps_dir(_linux_apps_dir(), DE_CAT_LINUX)
    # The main dropdown lists the NATIVE apps + one "Linux apps ▸" parent row.
    nrows: int64 = cast[int64](_native_count()) + 1
    menu_main_h = nrows * MENU_ROW_H + 4
    # The window-reservation height must cover whichever popup is taller: the
    # main dropdown OR the Linux fly-out child (max(1, linux_count) rows).
    crows: int64 = cast[int64](am_linux_count)
    if crows < 1:
        crows = 1
    mh: int64 = nrows
    if crows > mh:
        mh = crows
    MENU_H = mh * MENU_ROW_H + 4


# Number of NATIVE (non-Linux) menu entries — the leading am_* rows, since
# DE_CAT_LINUX sorts LAST. The Linux entries are am_[native .. am_count).
def _native_count() -> uint64:
    if am_linux_count >= am_count:
        return 0
    return am_count - am_linux_count


# Height of the "Linux apps" child fly-out (max(1, linux_count) rows — the
# lone row being the disabled "No Linux apps installed" placeholder).
def _sub_h() -> int64:
    rows: int64 = cast[int64](am_linux_count)
    if rows < 1:
        rows = 1
    return rows * MENU_ROW_H + 4

# ---- per-panel render state (set by _layout_panel for the panel being
# rendered / hit-tested this pass). main() restores per-panel persistent
# fields (menu_open) around each call.
cur_sw: int64 = 0                    # this panel's window content width
cur_sh: int64 = 0                    # this panel's window content height
cur_edge: int32 = 0
cur_bold: int32 = 0
cur_horiz: int32 = 1                 # 1 = top/bottom bar, 0 = left/right
cur_thick: int64 = 26
menu_open: int32 = 0                 # menu state of the panel being processed

# Resolved widget rects for the current panel (window-local). For a
# horizontal panel these are x-ranges at the bar row; for a vertical panel
# they are y-ranges down the bar column.
wx0: Array[12, int64]
wx1: Array[12, int64]
n_widg: uint64 = 0
wkind_cur: Array[12, int32]
wpin_cur: Array[12, int64]            # per-slot pinned flow coord (-1 = auto)

menu_slot: int64 = -1                # widget index of the menu, or -1
tasks_slot: int64 = -1
menu_lo: int64 = 0                   # menu widget's start coord (x or y)
tasks_lo: int64 = -1
tasks_hi: int64 = -1

# ---- RIGHT-CLICK CONTEXT MENU (Add to Panel / Move / Remove) -------------
# At most one context menu is open at a time, on exactly one panel. When open
# the owning panel's window GROWS (like the Apps dropdown) so the popup is
# part of that panel's own scene. ctx_kind selects the menu contents:
#   CTXK_ADD    right-click on EMPTY bar space -> add-a-widget list
#   CTXK_WIDGET right-click ON a widget       -> Move / Remove
CTXK_NONE:    int32 = 0
CTXK_ADD:     int32 = 1
CTXK_WIDGET:  int32 = 2
# CTXK_PANELMENU: right-click on EMPTY bar space now opens the MATE PANEL menu
# (Task #124 labels via lib/ctxmenucore) — a concise "Add to Panel..." /
# "Properties" instead of dumping the whole widget list inline. "Add to
# Panel..." opens the searchable applet CHOOSER dialog (addlet_* below).
CTXK_PANELMENU: int32 = 5
# CTXK_APPMENU: right-click ON the Applications (menu) widget -> a desktop
# shortcut menu (Settings / Add to Panel / About) so the user can reach the
# Settings app by right-clicking the Apps button, not only via the menu tree.
CTXK_APPMENU: int32 = 3

CTX_W: int64 = 150                    # context-menu box width
CTX_ROW_H: int64 = 22

# Add menu rows: Clock, Sysmon, Menu, Tasks, Spacer, Pager, Tray, Session (8).
CTX_ADD_ROWS: int64 = 8
# Widget menu rows: Move, Remove From Panel (2).
CTX_WID_ROWS: int64 = 2
# Apps-button shortcut menu rows: Settings, Add to Panel, About (3).
CTX_APP_ROWS: int64 = 3
# Panel menu rows: Add to Panel..., Properties (2). MATE labels come from
# lib/ctxmenucore's ctxm_panel_label so the panel + the #124 host gate share
# them verbatim.
CTX_PANEL_ROWS: int64 = 2

ctx_open:   int32 = 0                 # is a context menu currently open?
ctx_panel:  uint64 = 0               # which panel index owns it
ctx_kind:   int32 = 0                 # CTXK_ADD / CTXK_WIDGET
ctx_widget: int64 = -1               # widget slot the click landed on (CTXK_WIDGET)
ctx_insert: int64 = 0                # flow-axis insertion index (CTXK_ADD)
ctx_box_x:  int64 = 0                # window-local origin of the popup box
ctx_box_y:  int64 = 0

# Move-mode: after picking "Move", the next left-click on the bar drops the
# selected widget at a new flow-axis index.
move_active: int32 = 0
move_panel:  uint64 = 0
move_slot:   int64 = -1

# Set by _drain_events from the parsed button bitmap before each
# _handle_button call: 1 if the right button (bit1, value 2) is down.
g_bv_right: int32 = 0
# Previous button bitmap (across events) and the buttons NEWLY pressed this
# event (up->down transition). Discrete click actions — opening a right-click
# context menu, resolving/dismissing an open one — fire only on a fresh press
# EDGE, never on a held-button MOTION event. Without this, cursor jitter while
# the right button is held re-enters the dispatcher: because a right-click
# lands ON the bar (y<26) but the context box opens BELOW it (y>=26), the held
# event reads as an "outside click" and instantly dismisses the just-opened
# menu — the "Applications applet is hard to right-click" report (#265).
g_prev_bv:    int64 = 0
g_press_edge: int64 = 0

# ---- ADD-TO-PANEL CHOOSER DIALOG (opened by the panel menu) --------------
# A MATE-authentic applet chooser (lib/ctxmenucore searchable model): a
# titled dialog with a search box + category-grouped applet rows carrying a
# name + short description. It renders INSIDE the owning panel's window (which
# grows for it, like the context menu) and a click on an applet row inserts
# that widget at the flow position that was right-clicked. At most one dialog
# is open at a time.
addlet_open:   int32 = 0
addlet_panel:  uint64 = 0
addlet_insert: int64 = 0              # flow-axis insertion index
addlet_flow:   int64 = 0              # flow coord the right-click landed on
addlet_box_x:  int64 = 0             # window-local origin of the dialog box
addlet_box_y:  int64 = 0
addlet_ready:  int32 = 0             # registry populated once


# Map a ctxmenucore CTXM_APPLET_* identity to this panel's widget kind (WK_*).
def _applet_to_wk(applet: int32) -> int32:
    if applet == CTXM_APPLET_MENUBAR:
        return WK_MENU
    if applet == CTXM_APPLET_CLOCK:
        return WK_CLOCK
    if applet == CTXM_APPLET_SYSMON:
        return WK_SYSMON
    if applet == CTXM_APPLET_WINLIST:
        return WK_TASKS
    if applet == CTXM_APPLET_PAGER:
        return WK_PAGER
    if applet == CTXM_APPLET_NOTIF:
        return WK_TRAY
    if applet == CTXM_APPLET_SESSION:
        return WK_SESSION
    return WK_SPACER

# Number of rows the currently-open context menu has.
def ctx_rows() -> int64:
    if ctx_kind == CTXK_WIDGET:
        return CTX_WID_ROWS
    if ctx_kind == CTXK_APPMENU:
        return CTX_APP_ROWS
    if ctx_kind == CTXK_PANELMENU:
        return CTX_PANEL_ROWS
    return CTX_ADD_ROWS


def ctx_box_h() -> int64:
    return ctx_rows() * CTX_ROW_H + 4


# Width (horizontal) or height (vertical) a fixed widget occupies in flow.
def _widget_extent(kind: int32) -> int64:
    if cur_horiz != 0:
        if kind == WK_MENU:
            return APP_BTN_W + 8
        if kind == WK_SYSMON:
            return SYSMON_W + 8
        if kind == WK_CLOCK:
            return CLOCK_W + 8
        if kind == WK_PAGER:
            return PAGER_W + 8
        if kind == WK_TRAY:
            return TRAY_W + 8
        if kind == WK_SESSION:
            return SESSION_W + 8
        return 0                     # tasks / spacer = elastic
    # vertical panel: stack rows
    if kind == WK_MENU:
        return 24
    if kind == WK_SYSMON:
        return 28
    if kind == WK_CLOCK:
        return 20
    if kind == WK_PAGER:
        return 24
    if kind == WK_TRAY:
        return 24
    if kind == WK_SESSION:
        return 24
    if kind == WK_LAUNCHER:
        return 24
    return 0


# Placeholder-icon width (a square chip; #285 swaps in real icons).
LAUNCH_ICON: int64 = 16


# Horizontal box width of the launcher at global slot `g`: pad + icon + gap +
# label glyphs (~8px/char, matching the panel's other labelled widgets) + pad.
def _launcher_w(g: uint64) -> int64:
    ll: int64 = cast[int64](_slen(_wlabel_ptr(g)))
    return 6 + LAUNCH_ICON + 6 + ll * 8 + 6


# Slot-aware extent: launchers size to their label (needs the slot to reach the
# payload store); every other kind is fixed and defers to _widget_extent.
def _widget_extent_at(kind: int32, slot: uint64) -> int64:
    if kind == WK_LAUNCHER:
        if cur_horiz != 0:
            return _launcher_w(cur_panel_idx * MAX_WIDGETS + slot) + 8
        return 24
    return _widget_extent(kind)


# Lay out the current panel's widget list into wx0/wx1 (the flow axis).
# Fixed widgets before the first elastic widget pack from the start; fixed
# widgets after it pack toward the far end; the elastic widget(s) fill the
# slack. (Multiple elastic widgets share equally is overkill; we treat the
# first elastic as the slack-filler and any later spacer/tasks as zero.)
def _layout_panel():
    menu_slot = -1
    tasks_slot = -1
    tasks_lo = -1
    tasks_hi = -1
    span: int64 = cur_sw
    if cur_horiz == 0:
        span = cur_sh
    # find the first NON-PINNED elastic widget (tasks or spacer). Pinned
    # widgets are out of flow and never act as the slack-filler.
    first_elastic: int64 = -1
    a: uint64 = 0
    while a < n_widg:
        k: int32 = wkind_cur[a]
        if wpin_cur[a] < 0 and (k == WK_TASKS or k == WK_SPACER) \
                and first_elastic < 0:
            first_elastic = cast[int64](a)
        a = a + 1
    lo: int64 = 0
    hi: int64 = span
    # pack leading AUTO-FLOW fixed widgets from start (skip pinned)
    b: uint64 = 0
    while b < n_widg:
        if first_elastic >= 0 and cast[int64](b) >= first_elastic:
            b = n_widg
        elif wpin_cur[b] >= 0:
            b = b + 1
        else:
            k2: int32 = wkind_cur[b]
            ext: int64 = _widget_extent_at(k2, b)
            wx0[b] = lo
            wx1[b] = lo + ext
            if k2 == WK_MENU:
                menu_slot = cast[int64](b)
                menu_lo = lo
            lo = lo + ext
            b = b + 1
    # pack trailing AUTO-FLOW fixed widgets (after the elastic) from far end
    if first_elastic >= 0:
        c: int64 = cast[int64](n_widg) - 1
        while c > first_elastic:
            if wpin_cur[c] >= 0:
                c = c - 1
            else:
                k3: int32 = wkind_cur[c]
                ext2: int64 = _widget_extent_at(k3, cast[uint64](c))
                hi = hi - ext2
                wx0[c] = hi + 8
                # Bound the rect to the widget's ACTUAL end (was `span`, which
                # made every trailing applet's hit-rect run to the far screen
                # edge — so a click anywhere right of the first trailing widget
                # hit that widget, and the empty gaps between applets weren't
                # recognisable as blank bar space for the right-click Add menu).
                wx1[c] = hi + ext2
                c = c - 1
        # the elastic widget itself
        ei: uint64 = cast[uint64](first_elastic)
        ek: int32 = wkind_cur[ei]
        wx0[ei] = lo + 4
        wx1[ei] = hi - 4
        if ek == WK_TASKS:
            tasks_slot = first_elastic
            tasks_lo = wx0[ei]
            tasks_hi = wx1[ei]
        # any further elastic widgets collapse (already covered by trailing
        # pack or empty)
    # PINNED widgets (bug 3): placed at their exact flow coord, clamped into
    # the bar, OUTSIDE the flow packing above so they never shove neighbours.
    pa: uint64 = 0
    while pa < n_widg:
        if wpin_cur[pa] >= 0:
            pk: int32 = wkind_cur[pa]
            pext: int64 = _widget_extent_at(pk, pa)
            if pext <= 0:
                pext = TASK_BTN_W            # give elastic kinds a visible box
            px: int64 = wpin_cur[pa]
            if px + pext > span:
                px = span - pext
            if px < 0:
                px = 0
            wx0[pa] = px
            wx1[pa] = px + pext
            if pk == WK_MENU:
                menu_slot = cast[int64](pa)
                menu_lo = px
        pa = pa + 1


# --- per-widget render ----------------------------------------------
# `bar` = the start coord of the panel bar on the cross axis (window-local).
# For horizontal panels widgets sit at y=bar..bar+thick; for vertical they
# sit at x=bar..bar+thick. `lo` is the widget's start coord on the flow axis.

def _render_menu(lo: int64, bar: int64):
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    if cur_horiz != 0:
        by: int32 = cast[int32](bar)
        if menu_open != 0:
            hamscene_fill(cast[int32](lo), by, cast[int32](APP_BTN_W), 26,
                          cast[Ptr[uint8]]("#c0bcb4"))
        _glyphs(lo + 8, bar + 5, cast[Ptr[uint8]]("Applications"), fg, cur_bold)
        hamscene_fill(cast[int32](lo + APP_DIV_X + 4), by + 4, 1, 18,
                      cast[Ptr[uint8]]("#cfd2d8"))
    else:
        # vertical: short "Apps" label centred in its row
        _glyphs(bar + 6, lo + 4, cast[Ptr[uint8]]("Apps"), fg, cur_bold)


def _render_tasks(lo: int64, hi: int64, bar: int64):
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    if cur_horiz != 0:
        by: int32 = cast[int32](bar)
        t: uint64 = 0
        while t < n_tasks:
            bx: int64 = lo + cast[int64](t) * (TASK_BTN_W + 4)
            if bx + TASK_BTN_W > hi:
                t = n_tasks
            else:
                hamscene_rect(cast[int32](bx), by + 3, cast[int32](TASK_BTN_W),
                              20, cast[Ptr[uint8]]("#e6e8ec"))
                lbl: Array[20, uint8]
                nbase: uint64 = t * 64
                nl: uint64 = task_namelen[t]
                if nl > 16:
                    nl = 16
                k: uint64 = 0
                while k < nl:
                    ch: uint8 = task_name[nbase + k]
                    if ch == 34 or ch == 10:
                        ch = 32
                    lbl[k] = ch
                    k = k + 1
                lbl[k] = 0
                _glyphs(bx + 6, bar + 5, &lbl[0], fg, cur_bold)
                t = t + 1
    else:
        # vertical taskbar: one button per window stacked down the column
        t2: uint64 = 0
        while t2 < n_tasks:
            byv: int64 = lo + cast[int64](t2) * 24
            if byv + 22 > hi:
                t2 = n_tasks
            else:
                hamscene_rect(cast[int32](bar + 3), cast[int32](byv),
                              cast[int32](cur_thick - 6), 22,
                              cast[Ptr[uint8]]("#e6e8ec"))
                lbl2: Array[12, uint8]
                nbase2: uint64 = t2 * 64
                nl2: uint64 = task_namelen[t2]
                # Clip the label to the panel CROSS-AXIS width: text begins at
                # bar+6 and must stay inside the bar+3..bar+cur_thick-3 button,
                # so the budget is (cur_thick-9)/8 glyphs (8px advance). This
                # stops names overflowing past the right of a left/right panel.
                vmax: int64 = (cur_thick - 9) / 8
                if vmax < 1:
                    vmax = 1
                if vmax > 11:
                    vmax = 11
                if nl2 > cast[uint64](vmax):
                    nl2 = cast[uint64](vmax)
                k2: uint64 = 0
                while k2 < nl2:
                    ch2: uint8 = task_name[nbase2 + k2]
                    if ch2 == 34 or ch2 == 10:
                        ch2 = 32
                    lbl2[k2] = ch2
                    k2 = k2 + 1
                lbl2[k2] = 0
                _glyphs(bar + 6, byv + 3, &lbl2[0], fg, cur_bold)
                t2 = t2 + 1


def _render_sysmon(lo: int64, bar: int64):
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    cpu: int32 = _cpu_pct()
    mem: int32 = _mem_pct()
    if cur_horiz != 0:
        by: int32 = cast[int32](bar)
        _glyphs(lo, bar + 1, cast[Ptr[uint8]]("C"), fg, cur_bold)
        hamscene_hbar(cast[int32](lo + 12), by + 4, 92, 8, cpu,
                      cast[Ptr[uint8]]("#40c040"))
        _glyphs(lo, bar + 13, cast[Ptr[uint8]]("M"), fg, cur_bold)
        hamscene_hbar(cast[int32](lo + 12), by + 16, 92, 8, mem,
                      cast[Ptr[uint8]]("#4080e0"))
    else:
        _glyphs(bar + 4, lo, cast[Ptr[uint8]]("C"), fg, cur_bold)
        hamscene_hbar(cast[int32](bar + 4), cast[int32](lo + 12),
                      cast[int32](cur_thick - 8), 6, cpu,
                      cast[Ptr[uint8]]("#40c040"))
        hamscene_hbar(cast[int32](bar + 4), cast[int32](lo + 20),
                      cast[int32](cur_thick - 8), 6, mem,
                      cast[Ptr[uint8]]("#4080e0"))


def _render_clock(lo: int64, bar: int64, btime: uint64):
    # MATE-style clock: horizontal panels show the full weekday/month/day
    # AND the time ("Sat Jul 12  14:30"); narrow vertical panels stay compact
    # (HH:MM only). Both formats live in lib/panelclock.ad (pure, host-testable).
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    epoch: uint64 = _now_epoch_secs(btime)
    if cur_horiz != 0:
        panelclock_render(cast[int32](lo), cast[int32](bar) + 5, epoch,
                          cur_bold, fg)
    else:
        panelclock_render_time(cast[int32](bar) + 6, cast[int32](lo), epoch,
                               cur_bold, fg)


# --- Workspace switcher (pager) -------------------------------------
# Draws WS_COUNT cells. The active workspace cell is lit blue with its 1-based
# number in white; inactive cells are sunken grey with a dark number. The
# whole applet is a real virtual-desktop switcher: clicking a cell calls
# _switch_workspace which drives the compositor's workspace_switch.
def _render_pager(lo: int64, bar: int64):
    actfg: Ptr[uint8] = cast[Ptr[uint8]]("#ffffff")
    inafg: Ptr[uint8] = cast[Ptr[uint8]]("#303030")
    gap: int64 = 2
    if cur_horiz != 0:
        by: int32 = cast[int32](bar)
        w: int64 = 0
        while w < WS_COUNT:
            cx: int64 = lo + w * (PAGER_CELL_W + gap)
            if cx + PAGER_CELL_W > lo + PAGER_W + 2:
                w = WS_COUNT
            else:
                if w == cur_ws:
                    hamscene_fill(cast[int32](cx), by + 4,
                                  cast[int32](PAGER_CELL_W), 18,
                                  cast[Ptr[uint8]]("#3584e4"))
                else:
                    hamscene_fill(cast[int32](cx), by + 4,
                                  cast[int32](PAGER_CELL_W), 18,
                                  cast[Ptr[uint8]]("#dfe1e6"))
                hamscene_stroke(cast[int32](cx), by + 4,
                                cast[int32](PAGER_CELL_W), 18, 1,
                                cast[Ptr[uint8]]("#c2c5cd"))
                lab: Array[4, uint8]
                _u64_to_dec(cast[uint64](w + 1), &lab[0])
                lab[1] = 0
                fgc: Ptr[uint8] = inafg
                if w == cur_ws:
                    fgc = actfg
                _glyphs(cx + 8, bar + 6, &lab[0], fgc, cur_bold)
                w = w + 1
    else:
        # vertical: stack cells down the column
        w2: int64 = 0
        while w2 < WS_COUNT:
            cy: int64 = lo + w2 * (PAGER_CELL_W + gap)
            if w2 == cur_ws:
                hamscene_fill(cast[int32](bar + 4), cast[int32](cy),
                              cast[int32](cur_thick - 8), 18,
                              cast[Ptr[uint8]]("#3584e4"))
            else:
                hamscene_fill(cast[int32](bar + 4), cast[int32](cy),
                              cast[int32](cur_thick - 8), 18,
                              cast[Ptr[uint8]]("#dfe1e6"))
            lab2: Array[4, uint8]
            _u64_to_dec(cast[uint64](w2 + 1), &lab2[0])
            lab2[1] = 0
            fgc2: Ptr[uint8] = inafg
            if w2 == cur_ws:
                fgc2 = actfg
            _glyphs(bar + 10, cy + 2, &lab2[0], fgc2, cur_bold)
            w2 = w2 + 1


# --- Notification-area / tray applet --------------------------------
# A bell glyph in a flat cell. When there are unread notifications we paint a
# red badge with the unread COUNT at the bell's top-right. A click spawns
# /bin/haminbox (the scene message-history inbox) and clears the unread count.
def _render_tray(lo: int64, bar: int64):
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    bx: int32 = cast[int32](lo)
    by: int32 = cast[int32](bar)
    # Bell body: a rounded-ish trapezoid faked with two stacked rects + clapper.
    hamscene_fill(bx + 7, by + 6, 8, 9, cast[Ptr[uint8]]("#404040"))
    hamscene_fill(bx + 5, by + 14, 12, 2, cast[Ptr[uint8]]("#404040"))
    hamscene_fill(bx + 9, by + 5, 4, 2, cast[Ptr[uint8]]("#404040"))
    hamscene_fill(bx + 10, by + 16, 2, 2, cast[Ptr[uint8]]("#404040"))
    if notif_unread > 0:
        # Red badge + count digit at the bell's top-right.
        hamscene_fill(bx + 13, by + 2, 9, 9, cast[Ptr[uint8]]("#e03030"))
        cnt: int64 = notif_unread
        if cnt > 9:
            cnt = 9
        cbuf: Array[2, uint8]
        _u64_to_dec(cast[uint64](cnt), &cbuf[0])
        cbuf[1] = 0
        _glyphs(cast[int64](bx) + 14, cast[int64](by) + 2, &cbuf[0],
                cast[Ptr[uint8]]("#ffffff"), 0)


# --- Session / power button applet ----------------------------------
# A power-symbol glyph (ring + stem). A click spawns /bin/hamsessui (the
# Lock / Log Out / Shut Down / Reboot dialog).
def _render_session(lo: int64, bar: int64):
    col: Ptr[uint8] = cast[Ptr[uint8]]("#205020")
    bx: int32 = cast[int32](lo)
    by: int32 = cast[int32](bar)
    # Ring: four short segments forming an open circle.
    hamscene_fill(bx + 6, by + 9, 2, 6, col)        # left
    hamscene_fill(bx + 16, by + 9, 2, 6, col)       # right
    hamscene_fill(bx + 8, by + 16, 8, 2, col)       # bottom
    hamscene_fill(bx + 7, by + 7, 4, 2, col)        # top-left arc
    hamscene_fill(bx + 13, by + 7, 4, 2, col)       # top-right arc
    # Stem (the power-symbol vertical bar through the gap).
    hamscene_fill(bx + 11, by + 5, 2, 7, col)


# --- Launcher applet (#283) -----------------------------------------
# A one-click app launcher: a placeholder icon chip (a coloured square with the
# label's first letter — the #285 seam for real per-app icons) followed by the
# text label. A click spawns the carried Exec path (see _handle_click). `g` is
# the global slot (cur_panel_idx*MAX_WIDGETS+slot) whose p_wexec/p_wlabel hold
# the payload; `lo` is the widget's flow-axis start.
def _render_launcher(g: uint64, lo: int64, bar: int64):
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    label: Ptr[uint8] = _wlabel_ptr(g)
    if cur_horiz != 0:
        bx: int32 = cast[int32](lo)
        by: int32 = cast[int32](bar)
        # Icon chip (placeholder): a rounded blue square + the initial letter.
        iy: int32 = by + 5
        hamscene_fill(bx + 6, iy, cast[int32](LAUNCH_ICON),
                      cast[int32](LAUNCH_ICON), cast[Ptr[uint8]]("#5a7fb0"))
        hamscene_fill(bx + 6, iy, cast[int32](LAUNCH_ICON), 1,
                      cast[Ptr[uint8]]("#3f5c86"))
        gl: Array[2, uint8]
        gl[0] = _launcher_glyph(label)
        gl[1] = 0
        _glyphs(lo + 10, bar + 7, &gl[0], cast[Ptr[uint8]]("#ffffff"),
                cur_bold)
        # Label to the right of the chip.
        _glyphs(lo + 6 + LAUNCH_ICON + 6, bar + 5, label, fg, cur_bold)
    else:
        # Vertical panel: icon chip centred in the 24px cell; no label (narrow).
        bx: int32 = cast[int32](bar)
        by: int32 = cast[int32](lo)
        hamscene_fill(bx + 4, by + 4, cast[int32](LAUNCH_ICON),
                      cast[int32](LAUNCH_ICON), cast[Ptr[uint8]]("#5a7fb0"))
        gl2: Array[2, uint8]
        gl2[0] = _launcher_glyph(label)
        gl2[1] = 0
        _glyphs(bar + 8, lo + 6, &gl2[0], cast[Ptr[uint8]]("#ffffff"),
                cur_bold)


# The menu dropdown box origin (window-local). For a top panel it opens below
# the bar; bottom opens above; vertical panels open to the inside edge.
menu_box_x: int64 = 0
menu_box_y: int64 = 26


def _compute_menu_box(bar: int64):
    if cur_horiz != 0:
        menu_box_x = menu_lo
        if cur_edge == EDGE_BOTTOM:
            menu_box_y = 0
        else:
            menu_box_y = bar + cur_thick
    else:
        # vertical: open to the inside edge, aligned with the Apps row
        if cur_edge == EDGE_LEFT:
            menu_box_x = bar + cur_thick
        else:
            menu_box_x = bar - MENU_W
        menu_box_y = menu_lo


# Compute the "Linux apps" child fly-out box origin (window-local). MATE
# style: the child opens to the RIGHT of the main dropdown, its top roughly
# aligned with the parent ("Linux apps") row, clamped so it stays inside the
# grown panel window (MENU_H tall). If it would overflow the window's right
# edge it flips to the LEFT of the main box. Requires _compute_menu_box first.
def _compute_sub_box(bar: int64):
    nc: uint64 = _native_count()
    # parent-row top within the main box.
    prtop: int64 = menu_box_y + 2 + cast[int64](nc) * MENU_ROW_H
    sh: int64 = _sub_h()
    sy: int64 = prtop - 2
    # keep the child within the reserved window band [menu_box_y, +MENU_H].
    if sy + sh > menu_box_y + MENU_H:
        sy = menu_box_y + MENU_H - sh
    if sy < menu_box_y:
        sy = menu_box_y
    sub_box_y = sy
    # default: to the right, overlapping the main frame by 1px for continuity.
    sx: int64 = menu_box_x + MENU_W - 1
    if sx + SUBMENU_W > cur_sw:
        sx = menu_box_x - SUBMENU_W + 1      # flip left
    if sx < 0:
        sx = 0
    sub_box_x = sx


# Compute the context-menu box origin (window-local). It anchors at the
# right-click flow coordinate (ctx_flow) and opens into the popup band on the
# inside (desktop-facing) edge, mirroring the Apps dropdown geometry. ctx_flow
# is the click's flow-axis coordinate (x for horizontal panels, y for vertical)
# captured when the menu opened.
ctx_flow: int64 = 0
def _compute_ctx_box(bar: int64):
    bh: int64 = ctx_box_h()
    if cur_horiz != 0:
        cx: int64 = ctx_flow
        if cx + CTX_W > cur_sw:
            cx = cur_sw - CTX_W
        if cx < 0:
            cx = 0
        ctx_box_x = cx
        if cur_edge == EDGE_BOTTOM:
            ctx_box_y = bar - bh             # opens above the bar
            if ctx_box_y < 0:
                ctx_box_y = 0
        else:
            ctx_box_y = bar + cur_thick      # opens below the bar
    else:
        cy: int64 = ctx_flow
        if cy + bh > cur_sh:
            cy = cur_sh - bh
        if cy < 0:
            cy = 0
        ctx_box_y = cy
        if cur_edge == EDGE_LEFT:
            ctx_box_x = bar + cur_thick
        else:
            ctx_box_x = bar - CTX_W


# Compute the add-applet dialog box origin (window-local). Anchors at the
# right-click flow coordinate and opens into the popup band on the inside
# (desktop-facing) edge, mirroring the context-menu geometry but sized to the
# larger chooser.
def _compute_addlet_box(bar: int64):
    dw: int64 = cast[int64](ctxm_choice_w())
    dh: int64 = cast[int64](ctxm_choice_content_h())
    if cur_horiz != 0:
        cx: int64 = addlet_flow
        if cx + dw > cur_sw:
            cx = cur_sw - dw
        if cx < 0:
            cx = 0
        addlet_box_x = cx
        if cur_edge == EDGE_BOTTOM:
            addlet_box_y = bar - dh             # opens above the bar
            if addlet_box_y < 0:
                addlet_box_y = 0
        else:
            addlet_box_y = bar + cur_thick      # opens below the bar
    else:
        cy: int64 = addlet_flow
        if cy + dh > cur_sh:
            cy = cur_sh - dh
        if cy < 0:
            cy = 0
        addlet_box_y = cy
        if cur_edge == EDGE_LEFT:
            addlet_box_x = bar + cur_thick
        else:
            addlet_box_x = bar - dw


def _emit_panel(bar: int64, btime: uint64):
    hamscene_begin()
    # NO whole-window backdrop fill. When a popup (Apps dropdown / context menu
    # / add-applet chooser) opens, this window GROWS to hold it (full screen
    # width for a horizontal panel). Filling the whole grown rect painted a
    # solid band to the RIGHT of (and below) the menu card — the user-reported
    # "solid fill instead of the desktop to the right of the Applications menu".
    # Instead we paint ONLY the bar strip (below) and the popup card (in
    # _render_menu / the ctx/addlet emitters); every un-painted pixel of the
    # grown band stays alpha-0 (the compositor memsets the cache each frame).
    # The panel window is `keyed 1`, so the compositor's alpha-keyed present
    # skips those alpha-0 pixels and the desktop / lower windows composite
    # through — exactly the MATE look of a menu card floating on the desktop.
    # The panel bar itself.
    if cur_horiz != 0:
        hamscene_fill(0, cast[int32](bar), cast[int32](cur_sw),
                      cast[int32](cur_thick), cur_panel_color())
        # hairline along the desktop-facing edge
        if cur_edge == EDGE_BOTTOM:
            hamscene_fill(0, cast[int32](bar), cast[int32](cur_sw), 1,
                          cast[Ptr[uint8]]("#cfd2d8"))
        else:
            hamscene_fill(0, cast[int32](bar + cur_thick - 1),
                          cast[int32](cur_sw), 1, cast[Ptr[uint8]]("#cfd2d8"))
    else:
        hamscene_fill(cast[int32](bar), 0, cast[int32](cur_thick),
                      cast[int32](cur_sh), cur_panel_color())
        if cur_edge == EDGE_LEFT:
            hamscene_fill(cast[int32](bar + cur_thick - 1), 0, 1,
                          cast[int32](cur_sh), cast[Ptr[uint8]]("#cfd2d8"))
        else:
            hamscene_fill(cast[int32](bar), 0, 1, cast[int32](cur_sh),
                          cast[Ptr[uint8]]("#cfd2d8"))
    # widgets
    a: uint64 = 0
    while a < n_widg:
        k: int32 = wkind_cur[a]
        if k == WK_MENU:
            _render_menu(wx0[a], bar)
        elif k == WK_TASKS:
            _render_tasks(wx0[a], wx1[a], bar)
        elif k == WK_SYSMON:
            _render_sysmon(wx0[a], bar)
        elif k == WK_CLOCK:
            _render_clock(wx0[a], bar, btime)
        elif k == WK_PAGER:
            _render_pager(wx0[a], bar)
        elif k == WK_TRAY:
            _render_tray(wx0[a], bar)
        elif k == WK_SESSION:
            _render_session(wx0[a], bar)
        elif k == WK_LAUNCHER:
            _render_launcher(cur_panel_idx * MAX_WIDGETS + a, wx0[a], bar)
        a = a + 1
    # dropdown
    if menu_open != 0 and menu_slot >= 0:
        _compute_menu_box(bar)
        mx: int32 = cast[int32](menu_box_x)
        my: int32 = cast[int32](menu_box_y)
        # Rounded popover card (KDE-ish): a 1px border ring + inset face.
        hamscene_roundrect(mx, my, cast[int32](MENU_W),
                           cast[int32](menu_main_h), 8,
                           cast[Ptr[uint8]]("#cfd2d8"))
        hamscene_roundrect(mx + 1, my + 1, cast[int32](MENU_W) - 2,
                           cast[int32](menu_main_h) - 2, 7,
                           cast[Ptr[uint8]]("#f7f8fa"))
        fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
        nc: uint64 = _native_count()
        # Native .desktop rows (sorted by category+Name).
        mi: uint64 = 0
        while mi < nc:
            ry: int64 = menu_box_y + 5 + cast[int64](mi) * MENU_ROW_H
            _glyphs(menu_box_x + 10, ry, &am_name[mi][0], fg, cur_bold)
            mi = mi + 1
        # "Linux apps" parent row (last) — hovering it opens the child fly-out.
        pry: int64 = menu_box_y + 5 + cast[int64](nc) * MENU_ROW_H
        if sub_open != 0:
            # highlight the parent row while its fly-out is showing.
            hamscene_fill(mx + 1, cast[int32](menu_box_y + 2
                          + cast[int64](nc) * MENU_ROW_H),
                          cast[int32](MENU_W - 2), cast[int32](MENU_ROW_H),
                          cast[Ptr[uint8]]("#d3e3fb"))
        _glyphs(menu_box_x + 10, pry, cast[Ptr[uint8]]("Linux apps"), fg,
                cur_bold)
        # right-pointing chevron marking the sub-menu.
        _glyphs(menu_box_x + MENU_W - 16, pry, cast[Ptr[uint8]](">"), fg,
                cur_bold)
        # The child fly-out popup with the Linux-ns apps.
        if sub_open != 0:
            _compute_sub_box(bar)
            sh: int64 = _sub_h()
            sx: int32 = cast[int32](sub_box_x)
            sy: int32 = cast[int32](sub_box_y)
            hamscene_roundrect(sx, sy, cast[int32](SUBMENU_W),
                               cast[int32](sh), 8,
                               cast[Ptr[uint8]]("#cfd2d8"))
            hamscene_roundrect(sx + 1, sy + 1, cast[int32](SUBMENU_W) - 2,
                               cast[int32](sh) - 2, 7,
                               cast[Ptr[uint8]]("#f7f8fa"))
            if am_linux_count == 0:
                # disabled placeholder — the feature is present but empty.
                _glyphs(sub_box_x + 10, sub_box_y + 5,
                        cast[Ptr[uint8]]("No Linux apps installed"),
                        cast[Ptr[uint8]]("#909090"), cur_bold)
            else:
                li: uint64 = 0
                while li < am_linux_count:
                    idx: uint64 = nc + li
                    sry: int64 = sub_box_y + 5 + cast[int64](li) * MENU_ROW_H
                    _glyphs(sub_box_x + 10, sry, &am_name[idx][0], fg,
                            cur_bold)
                    li = li + 1
    # right-click context menu (Add to Panel / Move / Remove)
    if ctx_open != 0 and ctx_panel == cur_panel_idx:
        _compute_ctx_box(bar)
        bh: int64 = ctx_box_h()
        cmx: int32 = cast[int32](ctx_box_x)
        cmy: int32 = cast[int32](ctx_box_y)
        # Rounded popover card to match the launcher menu (border ring + face).
        hamscene_roundrect(cmx, cmy, cast[int32](CTX_W), cast[int32](bh), 7,
                           cast[Ptr[uint8]]("#cfd2d8"))
        hamscene_roundrect(cmx + 1, cmy + 1, cast[int32](CTX_W) - 2,
                           cast[int32](bh) - 2, 6,
                           cast[Ptr[uint8]]("#f7f8fa"))
        cfg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
        nr: int64 = ctx_rows()
        ri: int64 = 0
        while ri < nr:
            ry: int64 = ctx_box_y + 5 + ri * CTX_ROW_H
            _glyphs(ctx_box_x + 10, ry, _ctx_row_label(ri), cfg, cur_bold)
            ri = ri + 1
    # add-applet chooser DIALOG (opened by the panel menu's "Add to Panel...")
    if addlet_open != 0 and addlet_panel == cur_panel_idx:
        _compute_addlet_box(bar)
        ctxm_choice_draw(cast[int32](addlet_box_x), cast[int32](addlet_box_y),
                         -1)


# Label for context-menu row `ri` given the active ctx_kind.
def _ctx_row_label(ri: int64) -> Ptr[uint8]:
    if ctx_kind == CTXK_PANELMENU:
        # MATE panel menu: "Add to Panel..." (0), "Properties" (1). Shared with
        # the #124 host gate via ctxm_panel_label.
        return ctxm_panel_label(cast[uint64](ri))
    if ctx_kind == CTXK_APPMENU:
        if ri == 0:
            return cast[Ptr[uint8]]("Settings")
        if ri == 1:
            return cast[Ptr[uint8]]("Add to Panel")
        return cast[Ptr[uint8]]("About")
    if ctx_kind == CTXK_WIDGET:
        if ri == 0:
            return cast[Ptr[uint8]]("Move")
        return cast[Ptr[uint8]]("Remove From Panel")
    # CTXK_ADD: Clock, Sysmon, Menu, Tasks, Spacer, Pager, Tray, Session
    if ri == 0:
        return cast[Ptr[uint8]]("Clock")
    if ri == 1:
        return cast[Ptr[uint8]]("Sysmon")
    if ri == 2:
        return cast[Ptr[uint8]]("Menu")
    if ri == 3:
        return cast[Ptr[uint8]]("Tasks")
    if ri == 4:
        return cast[Ptr[uint8]]("Spacer")
    if ri == 5:
        return cast[Ptr[uint8]]("Workspaces")
    if ri == 6:
        return cast[Ptr[uint8]]("Notifications")
    return cast[Ptr[uint8]]("Session")


# Map an Add-menu row index to a widget kind.
def _ctx_add_kind(ri: int64) -> int32:
    if ri == 0:
        return WK_CLOCK
    if ri == 1:
        return WK_SYSMON
    if ri == 2:
        return WK_MENU
    if ri == 3:
        return WK_TASKS
    if ri == 4:
        return WK_SPACER
    if ri == 5:
        return WK_PAGER
    if ri == 6:
        return WK_TRAY
    return WK_SESSION


# the bar fill colour for the current panel: an index into p_color, set by
# _select_panel. (A Ptr[uint8] global can't take a cast initializer, so we
# key by index and resolve through p_color_ptr at use sites.)
cur_panel_idx: uint64 = 0
def cur_panel_color() -> Ptr[uint8]:
    return p_color_ptr(cur_panel_idx)


# Set a window's geometry: origin (x,y) + content size (w,h).
def _set_geometry_xy(ctlpath: Ptr[char], x: int64, y: int64, w: int64, h: int64):
    cfd: int32 = sys_open_write(ctlpath)
    if cfd < 0:
        return
    geo: Array[64, uint8]
    gp: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("geometry ")
    j: uint64 = 0
    while pre[j] != 0:
        geo[gp] = pre[j]
        gp = gp + 1
        j = j + 1
    gp = gp + _u64_to_dec(cast[uint64](x), &geo[gp])
    geo[gp] = 32
    gp = gp + 1
    gp = gp + _u64_to_dec(cast[uint64](y), &geo[gp])
    geo[gp] = 32
    gp = gp + 1
    gp = gp + _u64_to_dec(cast[uint64](w), &geo[gp])
    geo[gp] = 32
    gp = gp + 1
    gp = gp + _u64_to_dec(cast[uint64](h), &geo[gp])
    geo[gp] = 10
    gp = gp + 1
    sys_write(cfd, &geo[0], gp)
    sys_close(cfd)


# Spawn a scene app by absolute path. Detached stdio (-2/-2).
launch_argv: Array[2, uint64]
# pid of the most recent _launch() spawn (or <0 on failure). Read straight
# after a _launch call to associate the spawned app with a tracked slot.
last_launched_pid: int32 = 0
def _launch(prog: Ptr[char]):
    launch_argv[0] = cast[uint64](prog)
    launch_argv[1] = 0
    # DETACHED: the panel never wait4s its launched apps, so a plain spawn
    # would leak each one as an un-reapable zombie (a still-live parent makes
    # reap_orphan_zombies skip it) — the app menu eventually hit fork-EAGAIN
    # and stopped launching. RFNOWAIT lets the kernel reclaim them at exit.
    pid: int32 = spawn_detached(prog, &launch_argv[0], -2, -2,
                                cast[Ptr[uint64]](0))
    last_launched_pid = pid
    if pid >= 0:
        _writeall(1, cast[Ptr[uint8]]("[panel] launched "))
        _writeall(1, cast[Ptr[uint8]](prog))
        _writeall(1, cast[Ptr[uint8]]("\n"))


# Is `pid` still the LIVE inbox popup we spawned? Reads /proc/<pid>/comm (the
# task's command name) and returns 1 iff it is "haminbox". Checking the comm
# name — not merely that /proc/<pid> exists — closes the pid-REUSE hole: once
# our inbox exits, its pid may be recycled by an unrelated task, and we must
# NOT send that task a terminate note (nor treat it as "popup still open").
_pidpath: Array[40, uint8]
_commbuf: Array[32, uint8]
def _inbox_alive(pid: int32) -> int32:
    if pid <= 0:
        return 0
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/proc/")
    j: uint64 = 0
    while pre[j] != 0:
        _pidpath[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](pid), &_pidpath[p])
    leaf: Ptr[uint8] = cast[Ptr[uint8]]("/comm")
    k: uint64 = 0
    while leaf[k] != 0:
        _pidpath[p] = leaf[k]
        p = p + 1
        k = k + 1
    _pidpath[p] = 0
    fd: int32 = sys_open(cast[Ptr[char]](&_pidpath[0]))
    if fd < 0:
        return 0
    n: int64 = sys_read(fd, &_commbuf[0], 31)
    sys_close(fd)
    if n <= 0:
        return 0
    # Compare against "haminbox" (comm is the basename + '\n').
    want: Ptr[uint8] = cast[Ptr[uint8]]("haminbox")
    m: uint64 = 0
    while want[m] != 0:
        if m >= cast[uint64](n):
            return 0
        if _commbuf[m] != want[m]:
            return 0
        m = m + 1
    return 1


# The bell/tray click TOGGLES the notification inbox popup:
#   * if our last-spawned /bin/haminbox is still alive, terminate it (the
#     kernel's wsys reaper frees its window on the next panel tick) and do
#     NOT spawn another — a second click closes the popup instead of
#     stacking a duplicate on top of it;
#   * otherwise spawn a fresh inbox and clear the unread badge.
# Tracking the pid + liveness guarantees at most ONE inbox window exists, so
# the popup's own Close button (and Escape / click-away) always fully
# dismisses it. This is the fix for the "close button does nothing, the
# popup stays stuck" report (repeated bell clicks used to stack identical
# popups, so closing the top one merely revealed the one behind it).
def _toggle_notif_inbox():
    if _inbox_alive(notif_inbox_pid) != 0:
        # Popup already open: ask it to close (best-effort terminate note)
        # and, crucially, do NOT spawn a duplicate. We KEEP tracking the pid
        # so that even if the note is a no-op on this kernel, a further bell
        # click still refuses to stack a second popup — the popup's own Close
        # button (proven working) then dismisses the single window. Once it
        # does exit, _inbox_alive() reads a dead/recycled pid and the next
        # click opens a fresh inbox.
        p9_note(notif_inbox_pid, cast[Ptr[uint8]]("terminate"))
        return
    _launch(cast[Ptr[char]]("/bin/haminbox"))
    notif_inbox_pid = last_launched_pid
    notif_unread = 0


# Is `pid` still the LIVE Applications menu we spawned? Same comm-name check as
# _inbox_alive (closing the pid-REUSE hole), matching "hamappmenu".
def _appmenu_alive(pid: int32) -> int32:
    if pid <= 0:
        return 0
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/proc/")
    j: uint64 = 0
    while pre[j] != 0:
        _pidpath[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](pid), &_pidpath[p])
    leaf: Ptr[uint8] = cast[Ptr[uint8]]("/comm")
    k: uint64 = 0
    while leaf[k] != 0:
        _pidpath[p] = leaf[k]
        p = p + 1
        k = k + 1
    _pidpath[p] = 0
    fd: int32 = sys_open(cast[Ptr[char]](&_pidpath[0]))
    if fd < 0:
        return 0
    n: int64 = sys_read(fd, &_commbuf[0], 31)
    sys_close(fd)
    if n <= 0:
        return 0
    want: Ptr[uint8] = cast[Ptr[uint8]]("hamappmenu")
    m: uint64 = 0
    while want[m] != 0:
        if m >= cast[uint64](n):
            return 0
        if _commbuf[m] != want[m]:
            return 0
        m = m + 1
    return 1


# pid of the most-recently-spawned /bin/hamappmenu (the CATEGORIZED, hover-
# fly-out Applications menu — #206/#220), or 0.
appmenu_pid: int32 = 0


# Panel-direct spawn of the Applications menu. We must NOT use the generic
# _launch() here: hamappmenu, when spawned directly by us, would consult
# /dev/wsys/self to self-discover a wid — but that file's ancestor walk-up
# (devwsys _wsys_wid_for_pid_or_ancestor) returns the PANEL'S OWN wid, since
# the panel is hamappmenu's parent and owns a window. hamappmenu would then
# bind OUR window instead of allocating its own dropdown, so no menu ever
# appears (the intermittent "Applications menu doesn't open" report — it only
# bit when the detached child's parent pointer still resolved to the panel at
# the self-read, hence a reboot sometimes dodged it). Passing "-self" tells
# hamappmenu to IGNORE /dev/wsys/self and always self-allocate, exactly like
# the reliable haminbox/hamcalscene/hamsessui popups (which never read self).
_appmenu_prog: Array[20, uint8] = "/bin/hamappmenu"
_appmenu_self_flag: Array[8, uint8] = "-self"
_appmenu_argv: Array[3, uint64]
def _launch_appmenu():
    _appmenu_argv[0] = cast[uint64](&_appmenu_prog[0])
    _appmenu_argv[1] = cast[uint64](&_appmenu_self_flag[0])
    _appmenu_argv[2] = 0
    pid: int32 = spawn_detached(cast[Ptr[char]](&_appmenu_prog[0]),
                                &_appmenu_argv[0], -2, -2,
                                cast[Ptr[uint64]](0))
    last_launched_pid = pid
    if pid >= 0:
        _writeall(1, cast[Ptr[uint8]]("[panel] launched /bin/hamappmenu -self\n"))


# The Applications button click TOGGLES the categorized Applications menu
# (/bin/hamappmenu), mirroring the tray inbox toggle: if our last-spawned menu
# is still up, ask it to close and do NOT stack a duplicate; otherwise spawn a
# fresh one. #263: previously this toggled a FLAT in-panel dropdown, so the
# user never saw the categorized fly-out menu that already shipped as a
# separate v2 client — the panel now defaults to it.
def _toggle_appmenu():
    if _appmenu_alive(appmenu_pid) != 0:
        p9_note(appmenu_pid, cast[Ptr[uint8]]("terminate"))
        return
    _launch_appmenu()
    appmenu_pid = last_launched_pid


def _raise_focus(idx: uint64):
    if idx >= n_tasks:
        return
    w: int32 = task_wid[idx]
    cp: Array[64, uint8]
    _winpath(&cp[0], w, cast[Ptr[uint8]]("/ctl"))
    f1: int32 = sys_open_write(cast[Ptr[char]](&cp[0]))
    if f1 >= 0:
        _writeall(f1, cast[Ptr[uint8]]("raise\n"))
        sys_close(f1)
    f2: int32 = sys_open_write(cast[Ptr[char]](&cp[0]))
    if f2 >= 0:
        _writeall(f2, cast[Ptr[uint8]]("focus\n"))
        sys_close(f2)
    _writeall(1, cast[Ptr[uint8]]("[panel] raise+focus window\n"))


# Launch a Debian/Linux-namespace app INSIDE the `enter linux { ... }`
# namespace, NOT the native ns — its Exec (e.g. /usr/bin/weston-terminal)
# only exists on the #distro tree. We reuse the EXISTING Linux-ns launcher
# recipe /etc/rc.de-wayland: `spawn_detached("/bin/hamsh",
# ["/bin/hamsh", "/etc/rc.de-wayland", <prog>])` — the SAME path that
# already renders weston-terminal / Xwayland / Qt clients as real windows on
# the native Wayland server (scripts/test_wayland_phase4_term.sh et al).
# hamsh main() stamps HAMNIX_DE_PROG=<prog> from argv[2]; the recipe captures
# the `linux` ns template, drops to the regular user, sets the Wayland client
# env, and runs `enter linux { $HAMNIX_DE_PROG }`. A GUI Linux app maps its
# window on first buffer commit; a CLI (Terminal=true) one runs headless.
# DETACHED because the panel never wait4s its launched apps (an un-reapable
# zombie would eventually starve fork) — NOT because the launch is expected
# to fail. (Firefox/Chromium-class browsers are the one parked case — their
# SW-WebRender thread needs a GL/EGL stack — but every other Linux GUI app
# renders through the passthrough.)
_lx_argv: Array[4, uint64]
_lx_rc: Array[24, uint8] = "/etc/rc.de-wayland"
_lx_sh: Array[16, uint8] = "/bin/hamsh"
def _launch_linux(prog: Ptr[char]):
    _lx_argv[0] = cast[uint64](&_lx_sh[0])
    _lx_argv[1] = cast[uint64](&_lx_rc[0])
    _lx_argv[2] = cast[uint64](prog)
    _lx_argv[3] = 0
    pid: int32 = spawn_detached(cast[Ptr[char]](&_lx_sh[0]), &_lx_argv[0],
                                -2, -2, cast[Ptr[uint64]](0))
    if pid >= 0:
        _writeall(1, cast[Ptr[uint8]]("[panel] launched (linux ns) "))
        _writeall(1, cast[Ptr[uint8]](prog))
        _writeall(1, cast[Ptr[uint8]]("\n"))


# Launch a Terminal=true Linux-ns app (e.g. the "Linux Process Viewer" `top`)
# INSIDE a rendered native scene terminal. A CLI Linux tool has no Wayland
# window surface of its own, so the plain `enter linux { … }` launch above ran
# it headless and NO window appeared (the user-reported bug). Instead we spawn
# the native scene terminal /bin/hamtermscene — which owns a real DE window and
# whose shell sources /etc/rc.de-user (capturing the `linux` ns template) — and
# hand it the command `enter linux { <prog> }` as argv[1]. hamtermscene feeds
# that to its shell after startup, so the app runs in the linux ns with its
# output streaming into a visible terminal window. This honours the freedesktop
# Terminal=true contract without depending on any Linux-ns GUI (weston-terminal)
# being staged — hamtermscene ships on every image.
_lt_argv: Array[3, uint64]
_lt_term: Array[20, uint8] = "/bin/hamtermscene"
_lt_cmd:  Array[160, uint8]
def _launch_linux_term(prog: Ptr[char]):
    pre: Ptr[uint8] = cast[Ptr[uint8]]("enter linux { ")
    q: uint64 = 0
    while pre[q] != 0:
        _lt_cmd[q] = pre[q]
        q = q + 1
    pp: Ptr[uint8] = cast[Ptr[uint8]](prog)
    r: uint64 = 0
    while pp[r] != 0 and q < 156:
        _lt_cmd[q] = pp[r]
        q = q + 1
        r = r + 1
    _lt_cmd[q] = 32                                   # ' '
    q = q + 1
    _lt_cmd[q] = 125                                  # '}'
    q = q + 1
    _lt_cmd[q] = 0
    _lt_argv[0] = cast[uint64](&_lt_term[0])
    _lt_argv[1] = cast[uint64](&_lt_cmd[0])
    _lt_argv[2] = 0
    pid: int32 = spawn_detached(cast[Ptr[char]](&_lt_term[0]), &_lt_argv[0],
                                -2, -2, cast[Ptr[uint64]](0))
    if pid >= 0:
        _writeall(1, cast[Ptr[uint8]]("[panel] launched (linux term) "))
        _writeall(1, cast[Ptr[uint8]](prog))
        _writeall(1, cast[Ptr[uint8]]("\n"))


# ---- DE launch-queue drain (#99) -----------------------------------
# THE BUG THIS FIXES: /dev/wsys/run/launch and /dev/wsys/appmenu/launch
# are the compositor's launch queues — a Run dialog (Alt-F2), the
# appmenu popup, or any client writes "<prog>\n" and the DE is meant to
# spawn that prog as a fresh window. In the LEGACY userland DE those
# queues were drained by hamUId's main loop (run_drain_launch /
# appmenu_drain_launch). But the scene-file DE (docs/de_scene_file_arch)
# RETIRES hamUId's present loop: at runlevel 5 hamUId latches the KERNEL
# scene compositor as the /dev/fb owner and EXITS immediately
# (cmd_daemon_auto autoflag==0 returns after the `desktop` flip). Nothing
# then drains the queues, so a launch-queue write spawned NOTHING and the
# requested app's window never appeared — the "apps launched via the DE
# launch queue don't render" bug (#99).
#
# THE FIX: the panel (hampanelscene) is a LIVE scene client with a
# capable namespace (rc.5's scenepanelns inherits PID-1's ambient binds,
# incl. `#c /dev`, so /dev/wsys resolves), and it already spawns its OWN
# Applications-menu apps via _launch (spawn_detached). So the panel is
# the natural drain point: each main-loop tick it snapshots both launch
# queues and, on a serial bump, spawns the requested prog through the
# EXACT SAME working path its menu uses. A spawned app inherits the
# panel's namespace (RFNAMEG COW), self-`newwindow`s an OWNED wid, writes
# its `scene` display list, and the kernel scene compositor composites +
# presents it — identical to how the rc.5 scene apps render.
_run_launch_last_serial: uint64 = 0
_appmenu_launch_last_serial: uint64 = 0
_launch_q_buf: Array[320, uint8]

# Read a launch queue's current serial WITHOUT spawning anything (used at
# startup to prime the last-serial baseline).
def _peek_launch_serial(path: Ptr[char]) -> uint64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return 0
    n: int64 = sys_read(fd, &_launch_q_buf[0], 319)
    sys_close(fd)
    if n <= 0:
        return 0
    cap: uint64 = cast[uint64](n)
    p: uint64 = 0
    serial: uint64 = 0
    while p < cap and _launch_q_buf[p] >= 48 and _launch_q_buf[p] <= 57:
        serial = serial * 10 + cast[uint64](_launch_q_buf[p] - 48)
        p = p + 1
    return serial


# Read one launch queue ("<serial> <path>\n") at `path` and, if its serial
# is newer than *last_serial, spawn the parsed prog. Returns the (possibly
# unchanged) serial to store back as the new last-serial. A `wl:` prefix
# routes to the Linux-ns Wayland launcher (mirrors hamUId's drain logic).
def _drain_one_launch_queue(path: Ptr[char], last_serial: uint64) -> uint64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return last_serial
    n: int64 = sys_read(fd, &_launch_q_buf[0], 319)
    sys_close(fd)
    if n <= 0:
        return last_serial
    cap: uint64 = cast[uint64](n)
    # Parse leading decimal serial.
    p: uint64 = 0
    serial: uint64 = 0
    while p < cap and _launch_q_buf[p] >= 48 and _launch_q_buf[p] <= 57:
        serial = serial * 10 + cast[uint64](_launch_q_buf[p] - 48)
        p = p + 1
    if serial == 0:
        return last_serial
    if serial == last_serial:
        return last_serial
    # Single separating space, then the path up to newline.
    if p < cap and _launch_q_buf[p] == 32:
        p = p + 1
    ps: uint64 = p
    while p < cap and _launch_q_buf[p] != 10:
        p = p + 1
    pe: uint64 = p
    if pe <= ps:
        return serial
    # NUL-terminate the path in place so it can be passed as Ptr[char].
    if pe < 320:
        _launch_q_buf[pe] = 0
    # `wl:` sentinel (bytes 119,108,58) → Linux-ns Wayland client.
    if pe > ps + 3 and _launch_q_buf[ps] == 119 \
            and _launch_q_buf[ps + 1] == 108 \
            and _launch_q_buf[ps + 2] == 58:
        _launch_linux(cast[Ptr[char]](&_launch_q_buf[ps + 3]))
    else:
        _launch(cast[Ptr[char]](&_launch_q_buf[ps]))
    return serial


# Poll both DE launch queues once. Cheap open/read/close per queue, called
# from the panel main loop (like _drain_notifications).
def _drain_launch_queues():
    _run_launch_last_serial = _drain_one_launch_queue(
        cast[Ptr[char]]("/dev/wsys/run/launch"), _run_launch_last_serial)
    _appmenu_launch_last_serial = _drain_one_launch_queue(
        cast[Ptr[char]]("/dev/wsys/appmenu/launch"), _appmenu_launch_last_serial)


# --- Drag-from-menu launcher drop (#283) ----------------------------
# hamappmenu writes an app's `<exec> <label>\n` to /tmp/hamnix-panel-drop when
# the user DRAGS an app entry out of the Applications menu (a plain click still
# launches). Each panel tick we poll that sidecar: on a non-empty record we
# append a launcher to the panel that carries the Applications menu (next to
# the menu, MATE-style), persist via _save_config, and TRUNCATE the sidecar so
# the drop is consumed exactly once. Returns 1 if a launcher was added (the
# caller repaints). Purely client-side — no compositor/devwsys involvement.
_drop_buf: Array[128, uint8]
def _drain_panel_drop() -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/tmp/hamnix-panel-drop"))
    if fd < 0:
        return 0
    n: int64 = sys_read(fd, &_drop_buf[0], 127)
    sys_close(fd)
    if n <= 0:
        return 0
    cap: uint64 = cast[uint64](n)
    # Parse "<exec> <label>". Skip leading blanks.
    i: uint64 = 0
    while i < cap and (_drop_buf[i] == 32 or _drop_buf[i] == 9 or _drop_buf[i] == 10):
        i = i + 1
    exs: uint64 = i
    while i < cap and _drop_buf[i] != 32 and _drop_buf[i] != 9 and _drop_buf[i] != 10:
        i = i + 1
    exe: uint64 = i
    while i < cap and (_drop_buf[i] == 32 or _drop_buf[i] == 9):
        i = i + 1
    lbs: uint64 = i
    while i < cap and _drop_buf[i] != 32 and _drop_buf[i] != 9 and _drop_buf[i] != 10:
        i = i + 1
    lbe: uint64 = i
    added: int32 = 0
    if exe > exs:
        exbuf: Array[64, uint8]
        lbbuf: Array[24, uint8]
        _copy_tok(&_drop_buf[0], exs, exe, &exbuf[0], 64)
        if lbe > lbs:
            _copy_tok(&_drop_buf[0], lbs, lbe, &lbbuf[0], 24)
        else:
            lbbuf[0] = 63                  # '?'
            lbbuf[1] = 0
        # Target panel = the one with the Applications menu; else panel 0.
        tp: uint64 = 0
        at: uint64 = 0
        found: int32 = 0
        pj: uint64 = 0
        while pj < n_panels and found == 0:
            wj: uint64 = 0
            while wj < p_nwidg[pj]:
                if p_wkind[pj * MAX_WIDGETS + wj] == WK_MENU:
                    tp = pj
                    at = wj + 1            # just after the menu
                    found = 1
                    wj = p_nwidg[pj]
                else:
                    wj = wj + 1
            pj = pj + 1
        if n_panels > 0:
            _insert_launcher(tp, at, &exbuf[0], &lbbuf[0])
            _save_config()
            added = 1
    # Consume the drop: truncate the sidecar to empty.
    tfd: int32 = sys_open_write(cast[Ptr[char]]("/tmp/hamnix-panel-drop"))
    if tfd >= 0:
        sys_close(tfd)
    return added


# Find the widget slot (0..n_widg-1) whose flow-axis rect [wx0,wx1) contains
# `flow`, or -1 if the click is in empty bar space. Requires _layout_panel to
# have run for the current panel.
def _widget_at_flow(flow: int64) -> int64:
    a: uint64 = 0
    while a < n_widg:
        if flow >= wx0[a] and flow < wx1[a]:
            return cast[int64](a)
        a = a + 1
    return -1


# Flow-axis insertion index for a drop/add at coordinate `flow`: the index of
# the first widget whose start (wx0) is past `flow`; i.e. insert BEFORE it.
# Returns n_widg to append at the end.
def _insert_index_at_flow(flow: int64) -> int64:
    a: uint64 = 0
    while a < n_widg:
        if flow < wx0[a]:
            return cast[int64](a)
        a = a + 1
    return cast[int64](n_widg)


# Track a button-LESS pointer motion while the Apps dropdown is open, driving
# the MATE-style "Linux apps" HOVER submenu: mousing onto the parent row (or
# staying over the open child fly-out) opens/keeps the fly-out; moving onto any
# other native row closes it. Returns 1 if sub_open changed (needs a redraw).
def _handle_menu_hover(x: int64, y: int64, bar: int64) -> int32:
    _compute_menu_box(bar)
    nc: uint64 = _native_count()
    prtop: int64 = menu_box_y + 2 + cast[int64](nc) * MENU_ROW_H
    prbot: int64 = prtop + MENU_ROW_H
    over_parent: int32 = 0
    if x >= menu_box_x and x < menu_box_x + MENU_W \
            and y >= prtop and y < prbot:
        over_parent = 1
    over_child: int32 = 0
    if sub_open != 0:
        _compute_sub_box(bar)
        if x >= sub_box_x and x < sub_box_x + SUBMENU_W \
                and y >= sub_box_y and y < sub_box_y + _sub_h():
            over_child = 1
    over_native: int32 = 0
    if x >= menu_box_x and x < menu_box_x + MENU_W \
            and y >= menu_box_y + 2 and y < prtop:
        over_native = 1
    want: int32 = sub_open
    if over_parent != 0 or over_child != 0:
        want = 1
    elif over_native != 0:
        want = 0
    # otherwise (pointer off both popups) leave the state as-is (no flicker).
    if want != sub_open:
        sub_open = want
        return 1
    return 0


# Hit-test a window-local click for the current panel. Mutates menu_open +
# may launch/raise. Returns 1 if a redraw is needed. Uses the layout + the
# bar/menu-box coords computed in the last emit.
def _handle_click(x: int64, y: int64, bar: int64) -> int32:
    # dropdown open?
    if menu_open != 0 and menu_slot >= 0:
        _compute_menu_box(bar)
        nc: uint64 = _native_count()
        # 1) A click inside the open "Linux apps" child fly-out launches that
        #    Linux-ns app (via `enter linux`) and dismisses the whole menu.
        if sub_open != 0:
            _compute_sub_box(bar)
            if x >= sub_box_x and x < sub_box_x + SUBMENU_W \
                    and y >= sub_box_y and y < sub_box_y + _sub_h():
                if am_linux_count > 0:
                    li: int64 = (y - sub_box_y - 2) / MENU_ROW_H
                    if li >= 0 and cast[uint64](li) < am_linux_count:
                        idx: uint64 = nc + cast[uint64](li)
                        # Terminal=true CLI apps (no Wayland surface) must be
                        # hosted in a rendered terminal, else clicking opens
                        # nothing; GUI Wayland apps launch directly.
                        if am_term[idx] != 0:
                            _launch_linux_term(cast[Ptr[char]](&am_prog[idx][0]))
                        else:
                            _launch_linux(cast[Ptr[char]](&am_prog[idx][0]))
                menu_open = 0
                sub_open = 0
                return 1
        # 2) A click inside the main dropdown box.
        if x >= menu_box_x and x < menu_box_x + MENU_W \
                and y >= menu_box_y and y < menu_box_y + menu_main_h:
            row: int64 = (y - menu_box_y - 2) / MENU_ROW_H
            if row >= 0 and cast[uint64](row) < nc:
                # a native app row.
                _launch(cast[Ptr[char]](&am_prog[cast[uint64](row)][0]))
                menu_open = 0
                sub_open = 0
                return 1
            if row >= 0 and cast[uint64](row) == nc:
                # the "Linux apps" parent row: toggle the fly-out (also lets a
                # tap open it, not just hover) — keep the main menu open.
                if sub_open != 0:
                    sub_open = 0
                else:
                    sub_open = 1
                return 1
            # a click in the empty tail of the box: dismiss.
            menu_open = 0
            sub_open = 0
            return 1
    # on the bar?
    onbar: int32 = 0
    flow: int64 = x
    cross: int64 = y
    if cur_horiz != 0:
        if y >= bar and y < bar + cur_thick:
            onbar = 1
        flow = x
    else:
        if x >= bar and x < bar + cur_thick:
            onbar = 1
        flow = y
    if onbar != 0:
        # Apps button opens the CATEGORIZED Applications menu (/bin/hamappmenu,
        # the #206/#220 hover-fly-out client) as a separate v2 window — NOT the
        # legacy flat in-panel dropdown. Toggled, pid-tracked (see
        # _toggle_appmenu).
        if menu_slot >= 0:
            ms: uint64 = cast[uint64](menu_slot)
            if flow >= wx0[ms] and flow < wx1[ms]:
                _toggle_appmenu()
                return 1
        # taskbar buttons
        if tasks_slot >= 0 and flow >= tasks_lo and flow < tasks_hi:
            step: int64 = TASK_BTN_W + 4
            if cur_horiz == 0:
                step = 24
            t: uint64 = 0
            while t < n_tasks:
                bx: int64 = tasks_lo + cast[int64](t) * step
                hit: int32 = 0
                if cur_horiz != 0 and flow >= bx and flow < bx + TASK_BTN_W:
                    hit = 1
                if cur_horiz == 0 and flow >= bx and flow < bx + 22:
                    hit = 1
                if hit != 0:
                    _raise_focus(t)
                    if menu_open != 0:
                        menu_open = 0
                        return 1
                    return 0
                t = t + 1
        # pager / tray / session / clock applets (fixed widgets)
        ai: uint64 = 0
        while ai < n_widg:
            ak: int32 = wkind_cur[ai]
            if ak == WK_LAUNCHER:
                if flow >= wx0[ai] and flow < wx1[ai]:
                    # Spawn the carried Exec (same _launch/spawn_detached path
                    # the menu/tray applets use).
                    _launch(cast[Ptr[char]](
                        _wexec_ptr(cur_panel_idx * MAX_WIDGETS + ai)))
                    if menu_open != 0:
                        menu_open = 0
                    return 1
            if ak == WK_CLOCK:
                if flow >= wx0[ai] and flow < wx1[ai]:
                    # MATE-style clock: a click opens the SAME unified
                    # Calendar app the app-menu "Calendar" entry launches
                    # (/bin/hamcalscene) — a month grid with today highlighted,
                    # clickable date cells + relative-time readout, arrow-key
                    # navigation and a stopwatch. Previously this opened the
                    # separate /bin/hamclock (a DIFFERENT calendar UI); both
                    # entry points now converge on the one working app.
                    _launch(cast[Ptr[char]]("/bin/hamcalscene"))
                    if menu_open != 0:
                        menu_open = 0
                    return 1
            if ak == WK_PAGER or ak == WK_TRAY or ak == WK_SESSION:
                if flow >= wx0[ai] and flow < wx1[ai]:
                    if ak == WK_PAGER:
                        # which cell?
                        rel: int64 = flow - wx0[ai]
                        step: int64 = PAGER_CELL_W + 2
                        cell: int64 = rel / step
                        if cell >= 0 and cell < WS_COUNT:
                            _switch_workspace(cell)
                        if menu_open != 0:
                            menu_open = 0
                        return 1
                    elif ak == WK_TRAY:
                        # TOGGLE the scene notification inbox popup (open it +
                        # mark all read, or close the one already showing). The
                        # toggle NEVER stacks a second /bin/haminbox at the same
                        # geometry, so its Close button always fully dismisses
                        # the popup (the "close does nothing / stays stuck" bug
                        # was a click on the bell spawning a duplicate popup).
                        _toggle_notif_inbox()
                        if menu_open != 0:
                            menu_open = 0
                        return 1
                    else:
                        # The End-Session modal is a self-opening scene
                        # client (user/hamsessui.ad): spawning it pops the
                        # dialog immediately and it handles its own row
                        # clicks (Lock / Log Out / Shut Down / Reboot).
                        _launch(cast[Ptr[char]]("/bin/hamsessui"))
                        if menu_open != 0:
                            menu_open = 0
                        return 1
            ai = ai + 1
        if menu_open != 0:
            menu_open = 0
            return 1
    return 0


# Is (x,y) on this panel's bar (cross-axis within the bar band)? Returns the
# flow-axis coordinate via the caller reading cur_horiz.
def _on_bar(x: int64, y: int64, bar: int64) -> int32:
    if cur_horiz != 0:
        if y >= bar and y < bar + cur_thick:
            return 1
        return 0
    if x >= bar and x < bar + cur_thick:
        return 1
    return 0


def _flow_of(x: int64, y: int64) -> int64:
    if cur_horiz != 0:
        return x
    return y


# Central button dispatcher: routes left vs right clicks, drives the
# right-click Add / Move / Remove context menus, and the move-mode drop.
# Returns 1 if a redraw is needed. Mutates ctx_*/move_*/menu_open and (on
# Add/Move/Remove) the panel's widget list + persists via _save_config.
# The owning _drain_events re-applies geometry afterwards if a popup toggled.
def _handle_button(x: int64, y: int64, bar: int64, pi: uint64) -> int32:
    # Geometry re-apply (after a popup toggles) is handled by _drain_events;
    # here we only need flow-axis hit-testing within this window.
    bv_right: int32 = g_bv_right
    # 0) The add-applet chooser DIALOG is open on this panel: a click on an
    #    applet row inserts that widget at the recorded flow position; a click
    #    outside dismisses; a click on the title/search/header is a no-op.
    if addlet_open != 0 and addlet_panel == pi:
        if g_press_edge == 0:
            return 0                       # held-button motion: leave dialog up
        _compute_addlet_box(bar)
        crow: int64 = ctxm_choice_hit(cast[int32](addlet_box_x),
                                      cast[int32](addlet_box_y),
                                      cast[int32](x), cast[int32](y))
        if crow < 0:
            addlet_open = 0                     # click outside -> dismiss
            return 1
        if ctxm_choice_row_kind(cast[uint64](crow)) == CTXM_CC_ROW_ENTRY:
            applet: int32 = ctxm_choice_row_applet(cast[uint64](crow))
            wk: int32 = _applet_to_wk(applet)
            at: uint64 = cast[uint64](addlet_insert)
            if at > p_nwidg[pi]:
                at = p_nwidg[pi]
            _insert_widget(pi, at, wk)
            _save_config()
            addlet_open = 0
            return 1
        return 0                                # header/search row: keep open
    # 1) A context menu is open on this panel: a fresh CLICK resolves it (a
    #    row select inside the box, or a dismiss outside). Held-button MOTION
    #    (no press edge) is ignored so cursor jitter right after the opening
    #    right-click — which lands on the bar, OUTSIDE the below-bar context
    #    box — can't instantly dismiss the menu it just opened (#265).
    if ctx_open != 0 and ctx_panel == pi:
        if g_press_edge == 0:
            return 0
        _compute_ctx_box(bar)
        bh: int64 = ctx_box_h()
        if x >= ctx_box_x and x < ctx_box_x + CTX_W \
                and y >= ctx_box_y and y < ctx_box_y + bh:
            row: int64 = (y - ctx_box_y - 2) / CTX_ROW_H
            if row < 0:
                row = 0
            if row >= ctx_rows():
                row = ctx_rows() - 1
            _ctx_select_row(pi, row)
            return 1
        # click outside the menu: dismiss it.
        ctx_open = 0
        ctx_kind = CTXK_NONE
        return 1
    # 2) Move-mode: a left click on the bar drops the carried widget.
    if move_active != 0 and move_panel == pi and bv_right == 0:
        if _on_bar(x, y, bar) != 0:
            flow: int64 = _flow_of(x, y)
            _do_move_drop(pi, flow)
            return 1
        # click off-bar cancels the move
        move_active = 0
        return 1
    # 3) A right-click PRESS on the bar opens a context menu. Gate on the
    #    right-button press edge (not merely "right button held") so the menu
    #    opens once, cleanly, on the click — and a held right-drag afterwards
    #    doesn't re-open/re-target it (#265).
    if (g_press_edge & 2) != 0 and _on_bar(x, y, bar) != 0:
        flow2: int64 = _flow_of(x, y)
        ws: int64 = _widget_at_flow(flow2)
        # The elastic taskbar / spacer fills the empty middle of the bar; a
        # right-click there is "blank panel space" -> ADD a widget, not a
        # Move/Remove of the window-list. Treat those kinds as empty space so
        # right-clicking the empty bar offers the add-a-widget menu (A3).
        if ws >= 0:
            wsk: int32 = wkind_cur[cast[uint64](ws)]
            if wsk == WK_TASKS or wsk == WK_SPACER:
                ws = -1
        ctx_open = 1
        ctx_panel = pi
        ctx_flow = flow2
        if ws >= 0:
            # ANY real widget -- INCLUDING the Applications (menu) button --
            # opens the per-widget Move / Remove menu, so the Apps widget can be
            # moved or removed like any other applet (A4, MATE parity). (The old
            # CTXK_APPMENU Settings/About shortcut is reachable from the menu
            # tree instead.)
            ctx_kind = CTXK_WIDGET
            ctx_widget = ws
        else:
            # MATE workflow: a right-click on blank bar space opens the PANEL
            # menu ("Add to Panel..." / "Properties"), NOT the old giant inline
            # widget list. "Add to Panel..." then opens the searchable chooser.
            ctx_kind = CTXK_PANELMENU
            ctx_insert = _insert_index_at_flow(flow2)
        # close the apps dropdown if it was open
        menu_open = 0
        return 1
    # 4) Plain left-click: the menu/taskbar behaviour — but only on the press
    #    EDGE, so a bar-button action (Apps menu toggle, taskbar raise, clock/
    #    tray/session) fires once per click, not repeatedly while a button is
    #    held and the cursor jitters over the widget.
    if g_press_edge != 0:
        return _handle_click(x, y, bar)
    return 0


# Apply the chosen context-menu row.
def _ctx_select_row(pi: uint64, row: int64):
    if ctx_kind == CTXK_PANELMENU:
        if row == 0:
            # Add to Panel...: open the searchable applet chooser DIALOG at the
            # right-clicked flow position. The panel window grows for it.
            if addlet_ready == 0:
                ctxm_choice_init()
                addlet_ready = 1
            ctxm_choice_layout()
            addlet_open = 1
            addlet_panel = pi
            addlet_flow = ctx_flow
            addlet_insert = ctx_insert
        else:
            # Properties -> the Control Center (panel/appearance preferences).
            _launch(cast[Ptr[char]]("/bin/hamctl"))
        ctx_open = 0
        ctx_kind = CTXK_NONE
        return
    if ctx_kind == CTXK_APPMENU:
        if row == 1:
            # Add to Panel: morph this popup into the add-a-widget kind picker
            # (Clock/Sysmon/Menu/Tasks/Spacer), inserting at the Apps button's
            # flow position. Keep the menu OPEN so the user picks a kind next.
            ctx_kind = CTXK_ADD
            ctx_insert = _insert_index_at_flow(ctx_flow)
            return
        # Settings (row 0) -> the Control Center; About (row 2) -> the
        # dedicated About-this-system scene dialog (/bin/hamabout: OS name,
        # kernel, memory, uptime). MATE's "About This Computer".
        if row == 2:
            _launch(cast[Ptr[char]]("/bin/hamabout"))
        else:
            _launch(cast[Ptr[char]]("/bin/hamctl"))
        ctx_open = 0
        ctx_kind = CTXK_NONE
        return
    if ctx_kind == CTXK_WIDGET:
        if row == 0:
            # Move: enter move-mode carrying this widget.
            move_active = 1
            move_panel = pi
            move_slot = ctx_widget
        else:
            # Remove From Panel.
            if ctx_widget >= 0:
                _remove_widget(pi, cast[uint64](ctx_widget))
                _save_config()
        ctx_open = 0
        ctx_kind = CTXK_NONE
        return
    # CTXK_ADD: insert the chosen kind at the recorded flow index.
    k: int32 = _ctx_add_kind(row)
    at: uint64 = cast[uint64](ctx_insert)
    if at > p_nwidg[pi]:
        at = p_nwidg[pi]
    _insert_widget(pi, at, k)
    _save_config()
    ctx_open = 0
    ctx_kind = CTXK_NONE


# Drop the carried widget (move_slot) at flow index derived from `flow`.
def _do_move_drop(pi: uint64, flow: int64):
    if move_slot < 0:
        move_active = 0
        return
    src: uint64 = cast[uint64](move_slot)
    if src >= p_nwidg[pi]:
        move_active = 0
        move_slot = -1
        return
    k: int32 = p_wkind[pi * MAX_WIDGETS + src]
    dst: int64 = _insert_index_at_flow(flow)
    # Remove from old index first; if the destination was after it, the
    # removal shifts everything down by one, so decrement dst accordingly.
    _remove_widget(pi, src)
    if dst > cast[int64](src):
        dst = dst - 1
    if dst < 0:
        dst = 0
    _insert_widget(pi, cast[uint64](dst), k)
    move_active = 0
    move_slot = -1
    _save_config()


# LIVE MOVE (bug 2): while move-mode is active, every pointer-motion event
# (button or not) drags the carried widget so it TRACKS the cursor in real
# time, MATE-style. A fixed-extent widget is PINNED at the cursor (arbitrary
# position, bug 3); the elastic taskbar/spacer falls back to the classic
# flow-index reorder on the drop click. The LEFT button drops + persists; the
# RIGHT button cancels. Returns 1 if a redraw is needed. cur_* / layout must
# already be set for this panel (the caller _drain_events does that).
def _handle_move_motion(x: int64, y: int64, bar: int64, pi: uint64,
                        bv: int64) -> int32:
    if (bv & 2) != 0:                       # right button cancels the move
        move_active = 0
        move_slot = -1
        return 1
    if move_slot < 0:
        move_active = 0
        return 0
    src: uint64 = cast[uint64](move_slot)
    if src >= p_nwidg[pi]:
        move_active = 0
        move_slot = -1
        return 0
    kind: int32 = p_wkind[pi * MAX_WIDGETS + src]
    ext: int64 = _widget_extent_at(kind, src)
    flow: int64 = _flow_of(x, y)
    # Elastic widgets aren't free-positioned: drop = classic flow reorder.
    if ext <= 0:
        if (bv & 1) != 0:
            _do_move_drop(pi, flow)
            return 1
        return 0
    span: int64 = cur_sw
    if cur_horiz == 0:
        span = cur_sh
    nx: int64 = flow - ext / 2                # centre the widget on the cursor
    if nx + ext > span:
        nx = span - ext
    if nx < 0:
        nx = 0
    p_wx_pin[pi * MAX_WIDGETS + src] = nx     # follow the pointer live
    if (bv & 1) != 0:
        # Left click drops the widget here and persists the new position.
        move_active = 0
        move_slot = -1
        _save_config()
    return 1


# ====================================================================
# MULTI-PANEL DRIVER
# ====================================================================

# Per-panel live runtime state (parallel to the config arrays).
pw_wid:   Array[4, int32]
pw_ctl:   Array[256, uint8]          # 4 * 64
pw_ev:    Array[256, uint8]          # 4 * 64
pw_menu:  Array[4, int32]            # menu_open per panel
pw_geoh:  Array[4, int64]            # last applied window cross-axis size
_wait_efds: Array[4, int32]          # per-iter /event fds parked on by sys_waitfds


def pw_ctl_ptr(i: uint64) -> Ptr[char]:
    return cast[Ptr[char]](cast[uint64](&pw_ctl[0]) + i * 64)


def pw_ev_ptr(i: uint64) -> Ptr[char]:
    return cast[Ptr[char]](cast[uint64](&pw_ev[0]) + i * 64)


# Load this panel's config into the cur_* render registers.
# Cross-axis grow (px) a panel's window needs for any open popup: the Apps
# dropdown (when the menu widget exists + is open) and/or the right-click
# context menu (when open on THIS panel). Take the larger so whichever popup
# is showing fits. horiz controls which popup dimension is the cross axis
# (MENU_H/CTX height for horizontal panels, MENU_W/CTX_W for vertical).
def _panel_grow_px(pi: uint64, horiz: int32) -> int64:
    g: int64 = 0
    mopen: int32 = pw_menu[pi]
    has_menu: int32 = 0
    nw: uint64 = p_nwidg[pi]
    b: uint64 = 0
    while b < nw:
        if p_wkind[pi * MAX_WIDGETS + b] == WK_MENU:
            has_menu = 1
        b = b + 1
    if mopen != 0 and has_menu != 0:
        if horiz != 0:
            g = MENU_H
        else:
            g = MENU_W
    if ctx_open != 0 and ctx_panel == pi:
        cg: int64 = 0
        if horiz != 0:
            cg = ctx_box_h()
        else:
            cg = CTX_W
        if cg > g:
            g = cg
    # The add-applet chooser dialog needs the most room of all.
    if addlet_open != 0 and addlet_panel == pi:
        ag: int64 = 0
        if horiz != 0:
            ag = cast[int64](ctxm_choice_content_h())
        else:
            ag = cast[int64](ctxm_choice_w())
        if ag > g:
            g = ag
    return g


def _select_panel(pi: uint64, sw: int64, sh: int64):
    cur_edge = p_edge[pi]
    cur_bold = p_bold[pi]
    cur_thick = p_size[pi]
    cur_panel_idx = pi
    if cur_edge == EDGE_LEFT or cur_edge == EDGE_RIGHT:
        cur_horiz = 0
    else:
        cur_horiz = 1
    menu_open = pw_menu[pi]
    # copy widget kinds into the working list
    n_widg = p_nwidg[pi]
    a: uint64 = 0
    while a < n_widg:
        wkind_cur[a] = p_wkind[pi * MAX_WIDGETS + a]
        wpin_cur[a] = p_wx_pin[pi * MAX_WIDGETS + a]
        a = a + 1
    # window content size: thick + whatever popup grow this panel needs.
    grow: int64 = _panel_grow_px(pi, cur_horiz)
    if cur_horiz != 0:
        cur_sw = sw
        cur_sh = cur_thick + grow
    else:
        cur_sh = sh
        cur_sw = cur_thick + grow


# Compute the bar's cross-axis offset within the window + the window's
# screen origin; write the geometry ctl only when do_apply != 0 (so a plain
# content redraw can fetch the bar offset WITHOUT a redundant geometry write
# every tick — keeping the flicker gate quiet). Returns the bar offset.
def _panel_geometry(pi: uint64, sw: int64, sh: int64, do_apply: int32) -> int64:
    edge: int32 = p_edge[pi]
    horiz: int32 = 1
    if edge == EDGE_LEFT or edge == EDGE_RIGHT:
        horiz = 0
    thick: int64 = p_size[pi]
    grow: int64 = _panel_grow_px(pi, horiz)
    win_w: int64 = sw
    win_h: int64 = thick
    ox: int64 = 0
    oy: int64 = 0
    bar: int64 = 0
    if horiz != 0:
        win_w = sw
        win_h = thick + grow
        if edge == EDGE_BOTTOM:
            # bar pinned to screen bottom; popups grow upward (above the bar)
            oy = sh - (thick + grow)
            bar = grow                       # bar sits below any popup band
        else:
            oy = 0
            bar = 0
        if oy < 0:
            oy = 0
    else:
        win_w = thick + grow
        win_h = sh
        if edge == EDGE_RIGHT:
            # bar pinned to screen right; popups grow leftward (inside edge)
            ox = sw - (thick + grow)
            bar = grow
        else:
            ox = 0
            bar = 0
        if ox < 0:
            ox = 0
    if do_apply != 0:
        _set_geometry_xy(pw_ctl_ptr(pi), ox, oy, win_w, win_h)
    return bar


# Apply geometry (writes the ctl). Returns bar offset.
def _apply_panel_geometry(pi: uint64, sw: int64, sh: int64) -> int64:
    return _panel_geometry(pi, sw, sh, 1)


# Render + commit one panel. Geometry is applied separately (init / reload /
# menu toggle); here we only fetch the bar offset + emit content so a routine
# tick redraw doesn't write the geometry ctl needlessly.
def _redraw_panel(pi: uint64, sw: int64, sh: int64, btime: uint64):
    bar: int64 = _panel_geometry(pi, sw, sh, 0)
    _select_panel(pi, sw, sh)
    _layout_panel()
    _emit_panel(bar, btime)
    hamscene_commit(pw_wid[pi])


_drain_evbuf: Array[256, uint8]
def _drain_events(pi: uint64, sw: int64, sh: int64) -> int32:
    need_redraw: int32 = 0
    efd: int32 = sys_open(cast[Ptr[char]](pw_ev_ptr(pi)))
    if efd < 0:
        return 0
    r: int64 = sys_read(efd, &_drain_evbuf[0], 255)
    sys_close(efd)
    if r <= 0:
        return 0
    # set up cur_* + layout so hit-test uses this panel's geometry. Record
    # the pre-click menu/ctx state so a toggle below can resize the window.
    pre_menu: int32 = pw_menu[pi]
    pre_ctx_open: int32 = ctx_open
    pre_addlet_open: int32 = addlet_open
    pre_ctx_h: int64 = 0
    if ctx_open != 0 and ctx_panel == pi:
        pre_ctx_h = ctx_box_h()
    bar: int64 = _panel_geometry(pi, sw, sh, 0)
    _select_panel(pi, sw, sh)
    _layout_panel()
    i: uint64 = 0
    while i < cast[uint64](r):
        if _drain_evbuf[i] == 102 and i + 1 < cast[uint64](r) \
                and _drain_evbuf[i+1] == 32:               # "f "
            if i + 4 < cast[uint64](r) and _drain_evbuf[i+2] == 111 \
                    and _drain_evbuf[i+3] == 117 \
                    and _drain_evbuf[i+4] == 116:          # "out"
                if menu_open != 0:
                    menu_open = 0
                    need_redraw = 1
            while i < cast[uint64](r) and _drain_evbuf[i] != 10:
                i = i + 1
            i = i + 1
            continue
        if _drain_evbuf[i] == 109 and i + 1 < cast[uint64](r) \
                and _drain_evbuf[i+1] == 32:               # "m "
            j: uint64 = i + 2
            xneg: int32 = 0
            if j < cast[uint64](r) and _drain_evbuf[j] == 45:
                xneg = 1
                j = j + 1
            xv: int64 = 0
            while j < cast[uint64](r) and _drain_evbuf[j] >= 48 and _drain_evbuf[j] <= 57:
                xv = xv * 10 + cast[int64](_drain_evbuf[j]) - 48
                j = j + 1
            if xneg != 0:
                xv = 0 - xv
            if j < cast[uint64](r) and _drain_evbuf[j] == 32:
                j = j + 1
            yneg: int32 = 0
            if j < cast[uint64](r) and _drain_evbuf[j] == 45:
                yneg = 1
                j = j + 1
            yv: int64 = 0
            while j < cast[uint64](r) and _drain_evbuf[j] >= 48 and _drain_evbuf[j] <= 57:
                yv = yv * 10 + cast[int64](_drain_evbuf[j]) - 48
                j = j + 1
            if yneg != 0:
                yv = 0 - yv
            if j < cast[uint64](r) and _drain_evbuf[j] == 32:
                j = j + 1
            bv: int64 = 0
            while j < cast[uint64](r) and _drain_evbuf[j] >= 48 and _drain_evbuf[j] <= 57:
                bv = bv * 10 + cast[int64](_drain_evbuf[j]) - 48
                j = j + 1
            if (bv & 2) != 0:
                g_bv_right = 1
            else:
                g_bv_right = 0
            # Buttons newly pressed this event (up->down edge): bits set in bv
            # that were NOT set last event. (bv & (bv ^ prev) isolates them.)
            g_press_edge = bv & (bv ^ g_prev_bv)
            g_prev_bv = bv
            if move_active != 0 and move_panel == pi:
                # LIVE MOVE: route EVERY motion (even button-less) to the
                # drag handler so the carried widget tracks the cursor.
                if _handle_move_motion(xv, yv, bar, pi, bv) != 0:
                    need_redraw = 1
            elif bv != 0:
                if _handle_button(xv, yv, bar, pi) != 0:
                    need_redraw = 1
            elif menu_open != 0:
                # Button-LESS motion with the Apps dropdown open: hover-track
                # the MATE "Linux apps" fly-out submenu.
                if _handle_menu_hover(xv, yv, bar) != 0:
                    need_redraw = 1
            i = j
        else:
            i = i + 1
    # The Linux fly-out is a child of the dropdown: if the dropdown closed
    # (any dismiss path), drop the fly-out too.
    if menu_open == 0:
        sub_open = 0
    # persist this panel's menu state; if the menu OR the context menu toggled
    # (or the context menu changed height), the window must grow/shrink —
    # re-apply geometry so the popup room appears / the vacated band is
    # reclaimed before the content redraw.
    pw_menu[pi] = menu_open
    cur_ctx_h: int64 = 0
    if ctx_open != 0 and ctx_panel == pi:
        cur_ctx_h = ctx_box_h()
    if menu_open != pre_menu or ctx_open != pre_ctx_open \
            or cur_ctx_h != pre_ctx_h or addlet_open != pre_addlet_open:
        _apply_panel_geometry(pi, sw, sh)
        need_redraw = 1
    return need_redraw


# Helpers returning uint8* for _winpath (which writes bytes).
def pw_ctl_ptr_u8(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&pw_ctl[0]) + i * 64)


def pw_ev_ptr_u8(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&pw_ev[0]) + i * 64)


# Re-read the config and rebuild the panel set. The window COUNT may change;
# we reuse existing windows 1:1 by index where possible, allocate more on a
# grow, and collapse now-unused windows to a zero-size off-screen geometry on
# a shrink. The common Settings edits (edge / widgets / colour / size / font
# of the SAME panel count) reuse the same windows in place.
_reload_save_wid:  Array[4, int32]
_reload_save_menu: Array[4, int32]
def _reload_panels(sw: int64, sh: int64, btime: uint64):
    old_n: uint64 = n_panels
    k: uint64 = 0
    while k < old_n and k < MAX_PANELS:
        _reload_save_wid[k] = pw_wid[k]
        _reload_save_menu[k] = pw_menu[k]
        k = k + 1
    _load_config()
    pi: uint64 = 0
    while pi < n_panels:
        if pi < old_n:
            pw_wid[pi] = _reload_save_wid[pi]
            pw_menu[pi] = _reload_save_menu[pi]
        else:
            wid: int32 = _newwindow()
            pw_wid[pi] = wid
            pw_menu[pi] = 0
            if wid >= 0:
                _winpath(pw_ctl_ptr_u8(pi), wid, cast[Ptr[uint8]]("/ctl"))
                cfd2: int32 = sys_open_write(pw_ctl_ptr(pi))
                if cfd2 >= 0:
                    _writeall(cfd2, cast[Ptr[uint8]]("decorate 0\n"))
                    sys_close(cfd2)
                cfd3: int32 = sys_open_write(pw_ctl_ptr(pi))
                if cfd3 >= 0:
                    _writeall(cfd3, cast[Ptr[uint8]]("z 100\n"))
                    sys_close(cfd3)
                cfdk: int32 = sys_open_write(pw_ctl_ptr(pi))
                if cfdk >= 0:
                    _writeall(cfdk, cast[Ptr[uint8]]("keyed 1\n"))
                    sys_close(cfdk)
        _winpath(pw_ctl_ptr_u8(pi), pw_wid[pi], cast[Ptr[uint8]]("/ctl"))
        _winpath(pw_ev_ptr_u8(pi), pw_wid[pi], cast[Ptr[uint8]]("/event"))
        _apply_panel_geometry(pi, sw, sh)
        pi = pi + 1
    # Collapse any windows the new config no longer uses (shrink) to a
    # zero-size off-screen geometry so they leave no chrome on screen.
    while pi < old_n and pi < MAX_PANELS:
        hidep: Array[64, uint8]
        _winpath(&hidep[0], _reload_save_wid[pi], cast[Ptr[uint8]]("/ctl"))
        _set_geometry_xy(cast[Ptr[char]](&hidep[0]), 0, 0, 0, 0)
        pi = pi + 1


# ---- ADD-TO-PANEL CHOOSER: live search typing ---------------------------
# While the chooser dialog is open its owning panel window holds keyboard
# focus (the clicks that opened it were content presses that focused the
# panel window), so the compositor routes physical keystrokes to that
# window's /dev/wsys/<wid>/keys stream as press lines "d <code>\n" (raw ASCII;
# see sys/src/9/port/devwsys.ad wsys_route_key_byte). We feed typed chars into
# the EXISTING lib/ctxmenucore search filter (ctxm_choice_filter_push /
# _backspace) and re-run ctxm_choice_layout — the identical filter the host
# gate (scripts/test_ctxmenu_host.sh) proves. Enter adds the first filtered
# applet; Esc dismisses. Arrow keys arrive as the ESC '[' 'A' 3-byte sequence,
# so a lone ESC (nothing follows) dismisses but an ESC that opens a sequence
# does not.
_addlet_keybuf:        Array[256, uint8]
_addlet_esc_pending:   int32 = 0
_addlet_arrow_consume: int32 = 0


# First CTXM_CC_ROW_ENTRY row in the current (filtered) layout, or -1.
def _addlet_first_entry() -> int64:
    i: uint64 = 0
    rc: uint64 = ctxm_choice_row_count()
    while i < rc:
        if ctxm_choice_row_kind(i) == CTXM_CC_ROW_ENTRY:
            return cast[int64](i)
        i = i + 1
    return -1


# Insert the applet for chooser row `crow` at the recorded flow position and
# close the dialog. Mirrors the chooser-click path in _handle_button.
def _addlet_activate(pi: uint64, crow: uint64):
    applet: int32 = ctxm_choice_row_applet(crow)
    wk: int32 = _applet_to_wk(applet)
    at: uint64 = cast[uint64](addlet_insert)
    if at > p_nwidg[pi]:
        at = p_nwidg[pi]
    _insert_widget(pi, at, wk)
    _save_config()
    addlet_open = 0


# Apply one decoded key code to the chooser. Returns:
#   0  nothing / swallowed
#   1  filter changed -> repaint (window already sized for the full list)
#   2  dialog closed (dismiss or activate) -> re-apply geometry + repaint
def _addlet_key_apply(pi: uint64, code: int32) -> int32:
    if _addlet_arrow_consume != 0:                   # 3rd byte of ESC [ X
        _addlet_arrow_consume = 0
        return 0
    if _addlet_esc_pending != 0:
        _addlet_esc_pending = 0
        if code == 91:                               # '[' -> arrow sequence
            _addlet_arrow_consume = 1
            return 0
        addlet_open = 0                              # standalone ESC = dismiss
        return 2
    if code == 27:                                   # ESC -> pending
        _addlet_esc_pending = 1
        return 0
    if code == 13 or code == 10:                     # Enter -> add first row
        fe: int64 = _addlet_first_entry()
        if fe >= 0:
            _addlet_activate(pi, cast[uint64](fe))
            return 2
        return 0
    if code == 8 or code == 127:                     # Backspace / DEL
        ctxm_choice_filter_backspace()
        ctxm_choice_layout()
        return 1
    if code >= 32 and code < 127:                    # printable -> append
        ctxm_choice_filter_push(cast[uint8](code))
        ctxm_choice_layout()
        return 1
    return 0


# Drain the focused panel window's /keys stream while the chooser is open.
# Returns the strongest action: 0 nothing, 1 repaint, 2 dialog-closed.
def _drain_addlet_keys(pi: uint64) -> int32:
    kpath: Array[64, uint8]
    _winpath(&kpath[0], pw_wid[pi], cast[Ptr[uint8]]("/keys"))
    kfd: int32 = sys_open(cast[Ptr[char]](&kpath[0]))
    if kfd < 0:
        return 0
    act: int32 = 0
    n: int64 = sys_read_nb(kfd, &_addlet_keybuf[0], 256)
    while n > 0:
        cap: uint64 = cast[uint64](n)
        i: uint64 = 0
        while i < cap:
            t: uint8 = _addlet_keybuf[i]              # 'd' press
            i = i + 1
            if i < cap and _addlet_keybuf[i] == 32:
                i = i + 1
            code: int32 = 0
            have: int32 = 0
            while i < cap and _addlet_keybuf[i] >= 48 and _addlet_keybuf[i] <= 57:
                code = code * 10 + cast[int32](_addlet_keybuf[i]) - 48
                i = i + 1
                have = 1
            while i < cap and _addlet_keybuf[i] != 10:
                i = i + 1
            if i < cap:
                i = i + 1
            if t == 100 and have != 0:
                rc: int32 = _addlet_key_apply(pi, code)
                if rc == 2:
                    sys_close(kfd)
                    return 2
                if rc == 1 and act == 0:
                    act = 1
        n = sys_read_nb(kfd, &_addlet_keybuf[0], 256)
    sys_close(kfd)
    # A lone ESC left pending (nothing followed it) dismisses.
    if _addlet_esc_pending != 0:
        _addlet_esc_pending = 0
        addlet_open = 0
        return 2
    return act


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    sw: int64 = _screen_width()
    sh: int64 = _screen_height()

    _init_pins()
    _cfg_changed()
    _load_config()
    # Scan /etc/hamde/apps/*.desktop → the Applications menu model (sets
    # MENU_H). Data-driven: adding an app is dropping a .desktop file.
    _load_apps()
    _writeall(1, cast[Ptr[uint8]]("[panel] appmenu entries: "))
    _apn: Array[24, uint8]
    _apnl: uint64 = _u64_to_dec(am_count, &_apn[0])
    _apn[_apnl] = 0
    _writeall(1, &_apn[0])
    # Explicit Linux-section count so the serial log self-documents that the
    # /n/linux read-bind was scanned (0 = no #distro apps found / bind empty).
    _writeall(1, cast[Ptr[uint8]](" (linux section: "))
    _lxn: Array[24, uint8]
    _lxnl: uint64 = _u64_to_dec(am_linux_count, &_lxn[0])
    _lxn[_lxnl] = 0
    _writeall(1, &_lxn[0])
    _writeall(1, cast[Ptr[uint8]](")\n"))

    btime: uint64 = _read_btime()

    # Allocate a window per panel + set chrome (decorate 0, z 100).
    pi: uint64 = 0
    while pi < n_panels:
        wid: int32 = _newwindow()
        if wid < 0:
            _writeall(1, cast[Ptr[uint8]]("[panel] FAIL newwindow\n"))
            return 1
        pw_wid[pi] = wid
        pw_menu[pi] = 0
        _winpath(pw_ctl_ptr_u8(pi), wid, cast[Ptr[uint8]]("/ctl"))
        _winpath(pw_ev_ptr_u8(pi), wid, cast[Ptr[uint8]]("/event"))
        _apply_panel_geometry(pi, sw, sh)
        cfd2: int32 = sys_open_write(pw_ctl_ptr(pi))
        if cfd2 >= 0:
            _writeall(cfd2, cast[Ptr[uint8]]("decorate 0\n"))
            sys_close(cfd2)
        cfd3: int32 = sys_open_write(pw_ctl_ptr(pi))
        if cfd3 >= 0:
            _writeall(cfd3, cast[Ptr[uint8]]("z 100\n"))
            sys_close(cfd3)
        # Alpha-keyed present: the grown popup band shows the desktop through
        # every un-painted (alpha-0) pixel instead of a solid backdrop fill.
        cfdk: int32 = sys_open_write(pw_ctl_ptr(pi))
        if cfdk >= 0:
            _writeall(cfdk, cast[Ptr[uint8]]("keyed 1\n"))
            sys_close(cfdk)
        pi = pi + 1

    _writeall(1, cast[Ptr[uint8]]("[panel] scene windows ready\n"))

    # #99: prime the launch-queue serials to whatever is pending NOW so a
    # panel (re)start does not replay a launch that predates us. Any write
    # AFTER this point bumps the serial and is spawned. (At a fresh boot
    # both queues read serial 0 = empty, so this primes to 0 = no-op.)
    _run_launch_last_serial = _peek_launch_serial(
        cast[Ptr[char]]("/dev/wsys/run/launch"))
    _appmenu_launch_last_serial = _peek_launch_serial(
        cast[Ptr[char]]("/dev/wsys/appmenu/launch"))

    # First frame for every panel.
    _refresh_windows()
    pi = 0
    while pi < n_panels:
        _redraw_panel(pi, sw, sh, btime)
        pi = pi + 1

    last_minute: uint64 = 9999
    last_win_hash: uint64 = win_hash
    sysmon_tick: uint64 = 0
    SAMPLE_TICKS: uint64 = 20
    cfg_tick: uint64 = 0
    # Poll the panel config EVERY loop iteration (was every 8). A Settings
    # widget Move/Up/Down/Add/Del writes /tmp/hamnix-panel.conf and the panel
    # must reflect it on the very next wake so the reorder is visibly LIVE (no
    # extra click). Combined with the short park timeout below the reload lands
    # within ~one frame of the Settings write.
    CFG_TICKS: uint64 = 1

    while True:
        any_redraw: int32 = 0

        # per-panel input
        pi = 0
        while pi < n_panels:
            if _drain_events(pi, sw, sh) != 0:
                _redraw_panel(pi, sw, sh, btime)
            pi = pi + 1

        # Live search typing in the Add-to-Panel chooser dialog. Its owning
        # panel window holds keyboard focus while open, so drain that window's
        # /keys and feed the ctxmenucore filter. (Picked up within the ~16ms
        # park timeout below even without waking on the keys fd.)
        if addlet_open != 0:
            kchg: int32 = _drain_addlet_keys(addlet_panel)
            if kchg == 2:
                _apply_panel_geometry(addlet_panel, sw, sh)
                _redraw_panel(addlet_panel, sw, sh, btime)
            elif kchg == 1:
                _redraw_panel(addlet_panel, sw, sh, btime)

        # live config reload (re-allocates the panel set if needed)
        cfg_tick = cfg_tick + 1
        if cfg_tick >= CFG_TICKS:
            cfg_tick = 0
            if _cfg_changed() != 0:
                _reload_panels(sw, sh, btime)
                any_redraw = 1

        _refresh_windows()
        if win_hash != last_win_hash:
            any_redraw = 1

        # Track the live workspace (pager lit cell) and drain the notification
        # bus (/dev/wsys/post): each new record spawns a toast, is logged to
        # the inbox history, and bumps the unread badge. A change in either
        # repaints the panels.
        prev_ws: int64 = cur_ws
        prev_unread: int64 = notif_unread
        _poll_workspace()
        # #99: drain the DE launch queues (/dev/wsys/run/launch +
        # /dev/wsys/appmenu/launch) and spawn requested apps as scene
        # clients. hamUId's retired present loop used to do this; the panel
        # is the live scene client that now owns it.
        _drain_launch_queues()
        # #283: a drag-from-menu launcher drop appends a launcher + persists.
        if _drain_panel_drop() != 0:
            any_redraw = 1
        if _drain_notifications() != 0:
            any_redraw = 1
        if cur_ws != prev_ws or notif_unread != prev_unread:
            any_redraw = 1

        sod: uint64 = _now_secs_of_day(btime)
        minute: uint64 = sod / 60
        if minute != last_minute:
            any_redraw = 1

        sysmon_tick = sysmon_tick + 1
        if sysmon_tick >= SAMPLE_TICKS:
            sysmon_tick = 0
            any_redraw = 1

        if any_redraw != 0:
            pi = 0
            while pi < n_panels:
                _redraw_panel(pi, sw, sh, btime)
                pi = pi + 1
            last_minute = minute
            last_win_hash = win_hash

        # Park (instead of busy-spinning sys_yield) until a panel event
        # arrives or the resample cadence (~30ms) lapses. Opening the
        # /event fds fresh each iteration keeps us robust across a live
        # config reload that re-allocates the panel set (pw_wid changes);
        # the open cost is negligible — it was the SPIN that pegged a core
        # at 100%. sys_waitfds sleeps the task OFF the runqueue: an idle
        # panel now sits at ~0% CPU and still wakes instantly on input
        # (devwsys_event_write -> waitfds_notify) or after the timeout for
        # the once-a-second clock/sysmon refresh.
        nwf: uint64 = 0
        pi = 0
        while pi < n_panels and nwf < 4:
            efd2: int32 = sys_open(pw_ev_ptr(pi))
            if efd2 >= 0:
                _wait_efds[nwf] = efd2
                nwf = nwf + 1
            pi = pi + 1
        if nwf == 0:
            s2: uint64 = sys_get_jiffies()
            while sys_get_jiffies() - s2 < 3:
                sys_yield()
        else:
            # ~16ms timeout: long enough that an idle panel sits near 0% CPU
            # (it still wakes instantly on input via waitfds_notify), short
            # enough that a Settings config write (which doesn't poke our event
            # fds) is picked up by the per-iteration _cfg_changed poll within
            # one frame — so a widget reorder shows on the LIVE panel at once.
            sys_waitfds(&_wait_efds[0], nwf, 16)
            wi: uint64 = 0
            while wi < nwf:
                sys_close(_wait_efds[wi])
                wi = wi + 1
    return 0

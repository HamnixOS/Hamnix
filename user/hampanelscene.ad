# user/hampanelscene.ad
#
# Scene-file DE panels (docs/de_scene_file_arch.md §16 step 5/8) —
# MATE/GNOME2-parity build, CONFIG-DRIVEN with MULTIPLE PANELS, per-edge
# placement (top/bottom/left/right), a freely-composed per-panel WIDGET
# list, and per-panel APPEARANCE (background colour, thickness, font
# weight).
#
# Each panel is a plain scene CLIENT window (decorate 0 — it IS chrome):
# it writes a text display list to /dev/wsys/<wid>/scene and pokes commit;
# the kernel compositor rasterizes + z-blits it. The panel set is composed
# from a small config (/etc/panel.conf, read through the app's namespace —
# namespace clean, no global path bypass). If the config is absent the
# built-in default reproduces the MATE layout: a single TOP panel
# [menu] [tasks ...........] .......... [sysmon] [clock].
#
# CONFIG SCHEMA (/etc/panel.conf) — back-compatible:
#
#   Legacy single-panel keys (still honoured):
#     position top|bottom        edge of the (implicit) single panel
#     left  <widget>             a widget packed from the start edge
#     right <widget>             a widget packed from the far edge
#
#   New multi-panel block form:
#     panel <name>               begin a panel block
#       edge   top|bottom|left|right
#       color  #RRGGBB           panel background
#       size   <px>              thickness (height for h-panels, width for v)
#       font   normal|bold       glyph weight for this panel's text
#       widget menu              applications menu button + dropdown
#       widget tasks             window-list taskbar (elastic)
#       widget clock             HH:MM wall clock
#       widget sysmon            CPU + memory bar meters
#       widget spacer            push following widgets to the far end
#     end
#
# Mixing legacy lines and panel blocks is allowed: any legacy left/right/
# position lines that appear OUTSIDE a `panel` block build an implicit
# panel 0 (the classic top/bottom bar).
#
# WIDGETS:
#   menu    APPLICATIONS MENU. Toggles an in-panel dropdown. The panel window
#           GROWS so the dropdown is part of the panel's OWN scene; selecting
#           a row spawns that scene app. For a TOP panel the default config
#           keeps the Apps button at x<96,y<26 and the dropdown at y>=26,x<88
#           so the de_scene_menu_input gate's exact rects still hit.
#   tasks   WINDOW-LIST TASKBAR. Reads /dev/wsys/windows; one button per open
#           APP window in the bar's elastic middle slack. Click = raise+focus.
#   clock   CLOCK. HH:MM from /dev/stat btime + /dev/time uptime.
#   sysmon  SYSTEM MONITOR. CPU(load) + memory bar meters.
#   spacer  Elastic gap (like tasks but empty) — pushes later widgets out.
#
# Vertical (left/right) panels stack widgets top-to-bottom; the Applications
# dropdown for a vertical panel opens to the INSIDE edge (right of a left
# panel, left of a right panel). The menu-input gate only exercises the
# default TOP panel.
#
# Live re-read: each panel polls /etc/panel.conf on the periodic tick so a
# Settings change (edge / widgets / colour / size / font) applies WITHOUT a
# restart (see _cfg_changed).
#
# WORK-AREA RESERVATION: the compositor's _wsys_work_area (sys/.../devwsys.ad)
# reserves only the TOP panel strip for maximize/edge-snap. Reservation for
# BOTTOM and SIDE panels remains deferred — it lives in the kernel compositor,
# not here, so a multi-panel (top+bottom) layout still renders both panels
# correctly and without overlap (each panel pins to its own screen edge), but
# a maximized window only avoids the TOP strip. Lifting that is a kernel-side
# follow-up (generalize _wsys_work_area to subtract every z>=100 decorate-0
# panel band by edge).

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_waitfds(fds: Ptr[int32], nfds: uint64, timeout_ms: int64) -> int64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32
from lib.p9 import spawn
from lib.hamui import (
    hamscene_begin, hamscene_fill, hamscene_rect, hamscene_stroke,
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_panel_button,
    hamscene_hbar, hamscene_commit,
)


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# A weight-aware glyph emit: normal or bold (double-strike) per the panel's
# font setting. Centralized so every applet honours the per-panel weight.
def _glyphs(x: int64, y: int64, s: Ptr[uint8], color: Ptr[uint8], bold: int32):
    if bold != 0:
        hamscene_glyphs_bold(cast[int32](x), cast[int32](y), s, color)
    else:
        hamscene_glyphs(cast[int32](x), cast[int32](y), s, color)


# Create a window via the server-wide ctl, read back the assigned wid.
def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# ====================================================================
# WORKSPACE (pager) state + I/O
# ====================================================================
# Current active workspace (0-based), tracked from /dev/wsys/workspace. The
# pager applet renders WS_COUNT cells with cur_ws lit, and a click writes the
# `ws <N>` ctl verb (1-based) which the compositor turns into workspace_switch.
cur_ws: int64 = 0


# Poll /dev/wsys/workspace ("<gen> <ws>\n"); update cur_ws. Cheap; called once
# per panel tick before render so the lit cell tracks the live desktop.
def _poll_workspace():
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/workspace"))
    if fd < 0:
        return
    rb: Array[64, uint8]
    n: int64 = sys_read(fd, &rb[0], 63)
    sys_close(fd)
    if n <= 0:
        return
    # Skip the gen field, then parse the ws field.
    i: uint64 = 0
    cap: uint64 = cast[uint64](n)
    while i < cap and rb[i] != 32:
        i = i + 1
    while i < cap and rb[i] == 32:
        i = i + 1
    v: int64 = 0
    while i < cap and rb[i] >= 48 and rb[i] <= 57:
        v = v * 10 + cast[int64](rb[i]) - 48
        i = i + 1
    if v >= 0 and v < WS_COUNT:
        cur_ws = v


# Write "ws <N>\n" (1-based) to /dev/wsys/ctl. The compositor's workspace
# poll bumps its gen and calls workspace_switch(N-1), hiding the windows that
# don't live on the new desktop. This is the real virtual-desktop switch.
def _switch_workspace(n0: int64):
    if n0 < 0 or n0 >= WS_COUNT:
        return
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return
    cmd: Array[16, uint8]
    p: uint64 = 0
    cmd[p] = 119                     # 'w'
    p = p + 1
    cmd[p] = 115                     # 's'
    p = p + 1
    cmd[p] = 32                      # ' '
    p = p + 1
    p = p + _u64_to_dec(cast[uint64](n0 + 1), &cmd[p])
    cmd[p] = 10
    p = p + 1
    sys_write(fd, &cmd[0], p)
    sys_close(fd)
    cur_ws = n0


# ====================================================================
# NOTIFICATION BUS / BROKER (scene-native)
# ====================================================================
# The kernel inbox ring at /dev/wsys/post is the Plan 9-shaped notification
# bus: any publisher (the welcome service, rc.5, a shell, hamnotify) writes a
# "<title>\t<body>\t<icon>\n" record there. In the legacy DE hamUId drained
# this ring; in the SCENE DE hamUId is dead, so THE PANEL is the broker. On
# each tick the panel:
#   1. reads the /dev/wsys/post snapshot
#      ("<post_serial> <ack_serial> <count> <slot_serial> <title>\t<body>\t<icon>\n"),
#   2. for each head record while count>0: spawns a scene TOAST
#      (/bin/hamtoast "<title>" "<body>"), appends the record to the tmpfs
#      history log /tmp/hamnix-notif.log, bumps the unread count, then ACKs
#      the slot by writing "ack <slot_serial>\n" back to /dev/wsys/post so the
#      kernel advances its head.
# The tray applet draws a bell + the unread count badge; clicking it spawns
# the scene INBOX (/bin/haminbox), which reads the history log, and clears the
# unread count.
notif_unread: int64 = 0                 # unread notifications since last inbox
notif_last_ack: uint64 = 0             # highest slot serial we've acked

# Parsed head record from the last _drain_notifications poll.
_nb_count: int64 = 0
_nb_slot: uint64 = 0
_nb_title: Array[48, uint8]
_nb_body:  Array[72, uint8]


# Append the current head record (_nb_title/_nb_body) to the tmpfs history log
# as "<title>\t<body>\n". Capped to the newest ~16 records by rewriting the
# file from a small in-RAM ring so it never grows unbounded.
NLOG_MAX: uint64 = 16
nlog_buf: Array[1920, uint8]           # 16 * 120
nlog_len: Array[16, uint64]
nlog_n: uint64 = 0


def _nlog_append(title: Ptr[uint8], body: Ptr[uint8]):
    # Build the "<title>\t<body>" record into the ring (drop oldest on full).
    slot: uint64 = nlog_n
    if nlog_n >= NLOG_MAX:
        # shift down by one (drop oldest)
        s: uint64 = 0
        while s + 1 < NLOG_MAX:
            base_d: uint64 = s * 120
            base_s: uint64 = (s + 1) * 120
            k: uint64 = 0
            while k < nlog_len[s + 1]:
                nlog_buf[base_d + k] = nlog_buf[base_s + k]
                k = k + 1
            nlog_len[s] = nlog_len[s + 1]
            s = s + 1
        slot = NLOG_MAX - 1
    else:
        nlog_n = nlog_n + 1
    base: uint64 = slot * 120
    p: uint64 = 0
    ti: uint64 = 0
    while title[ti] != 0 and p < 118:
        nlog_buf[base + p] = title[ti]
        p = p + 1
        ti = ti + 1
    if p < 118:
        nlog_buf[base + p] = 9                       # '\t'
        p = p + 1
    bi: uint64 = 0
    while body[bi] != 0 and p < 119:
        nlog_buf[base + p] = body[bi]
        p = p + 1
        bi = bi + 1
    nlog_len[slot] = p
    # Rewrite /tmp/hamnix-notif.log from the ring (oldest-first).
    fd: int32 = sys_open_write(cast[Ptr[char]]("/tmp/hamnix-notif.log"))
    if fd < 0:
        return
    out: Array[2048, uint8]
    op: uint64 = 0
    r: uint64 = 0
    while r < nlog_n and op + 122 < 2048:
        rb: uint64 = r * 120
        kk: uint64 = 0
        while kk < nlog_len[r]:
            out[op] = nlog_buf[rb + kk]
            op = op + 1
            kk = kk + 1
        out[op] = 10
        op = op + 1
        r = r + 1
    sys_write(fd, &out[0], op)
    sys_close(fd)


# Spawn the scene toast with the head record's title + body as argv.
_toast_argv: Array[4, uint64]
def _spawn_toast():
    _toast_argv[0] = cast[uint64](cast[Ptr[char]]("/bin/hamtoast"))
    _toast_argv[1] = cast[uint64](&_nb_title[0])
    _toast_argv[2] = cast[uint64](&_nb_body[0])
    _toast_argv[3] = 0
    spawn(cast[Ptr[char]]("/bin/hamtoast"), &_toast_argv[0],
          -2, -2, cast[Ptr[uint64]](0))


# Ack a drained slot so the kernel advances /dev/wsys/post's head.
def _ack_slot(serial: uint64):
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/post"))
    if fd < 0:
        return
    cmd: Array[40, uint8]
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("ack ")
    while pre[p] != 0:
        cmd[p] = pre[p]
        p = p + 1
    p = p + _u64_to_dec(serial, &cmd[p])
    cmd[p] = 10
    p = p + 1
    sys_write(fd, &cmd[0], p)
    sys_close(fd)


# Read one /dev/wsys/post snapshot into _nb_*; returns count (>0 = head valid).
_nb_rb: Array[256, uint8]
def _read_post_head() -> int64:
    _nb_count = 0
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/post"))
    if fd < 0:
        return 0
    n: int64 = sys_read(fd, &_nb_rb[0], 255)
    sys_close(fd)
    if n <= 0:
        return 0
    cap: uint64 = cast[uint64](n)
    i: uint64 = 0
    # field 0: post_serial (skip)
    while i < cap and _nb_rb[i] != 32:
        i = i + 1
    while i < cap and _nb_rb[i] == 32:
        i = i + 1
    # field 1: ack_serial (skip)
    while i < cap and _nb_rb[i] != 32:
        i = i + 1
    while i < cap and _nb_rb[i] == 32:
        i = i + 1
    # field 2: count
    cnt: int64 = 0
    while i < cap and _nb_rb[i] >= 48 and _nb_rb[i] <= 57:
        cnt = cnt * 10 + cast[int64](_nb_rb[i]) - 48
        i = i + 1
    _nb_count = cnt
    if cnt <= 0:
        return 0
    while i < cap and _nb_rb[i] == 32:
        i = i + 1
    # field 3: slot_serial
    sl: uint64 = 0
    while i < cap and _nb_rb[i] >= 48 and _nb_rb[i] <= 57:
        sl = sl * 10 + cast[uint64](_nb_rb[i]) - 48
        i = i + 1
    _nb_slot = sl
    while i < cap and _nb_rb[i] == 32:
        i = i + 1
    # title up to tab
    tp: uint64 = 0
    while i < cap and _nb_rb[i] != 9 and tp < 47:
        _nb_title[tp] = _nb_rb[i]
        tp = tp + 1
        i = i + 1
    _nb_title[tp] = 0
    # skip to past the first tab
    while i < cap and _nb_rb[i] != 9:
        i = i + 1
    if i < cap:
        i = i + 1                                     # consume tab
    # body up to next tab (icon) or newline
    bp: uint64 = 0
    while i < cap and _nb_rb[i] != 9 and _nb_rb[i] != 10 and bp < 71:
        _nb_body[bp] = _nb_rb[i]
        bp = bp + 1
        i = i + 1
    _nb_body[bp] = 0
    return cnt


# Drain every pending /dev/wsys/post record: toast it, log it, ack it. Returns
# 1 if any notification was drained (so the panel repaints the unread badge).
def _drain_notifications() -> int32:
    drained: int32 = 0
    guard: int32 = 0
    while guard < 16:
        guard = guard + 1
        cnt: int64 = _read_post_head()
        if cnt <= 0:
            break
        # Guard against re-processing the same head if an ack didn't land.
        if _nb_slot == notif_last_ack and notif_last_ack != 0:
            break
        _spawn_toast()
        _nlog_append(&_nb_title[0], &_nb_body[0])
        notif_unread = notif_unread + 1
        notif_last_ack = _nb_slot
        _ack_slot(_nb_slot)
        drained = 1
    return drained


# Read the framebuffer width from /dev/fb's "W H PITCH BPP FMT\n" header.
def _screen_width() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/fb"))
    if fd < 0:
        return 800
    hdr: Array[64, uint8]
    r: int64 = sys_read(fd, &hdr[0], 63)
    sys_close(fd)
    if r <= 0:
        return 800
    w: int64 = 0
    i: uint64 = 0
    while i < cast[uint64](r) and hdr[i] >= 48 and hdr[i] <= 57:
        w = w * 10 + cast[int64](hdr[i]) - 48
        i = i + 1
    if w <= 0:
        return 800
    return w


# Read the framebuffer HEIGHT (second field of "W H PITCH BPP FMT\n").
def _screen_height() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/fb"))
    if fd < 0:
        return 600
    hdr: Array[64, uint8]
    r: int64 = sys_read(fd, &hdr[0], 63)
    sys_close(fd)
    if r <= 0:
        return 600
    i: uint64 = 0
    while i < cast[uint64](r) and hdr[i] >= 48 and hdr[i] <= 57:
        i = i + 1
    while i < cast[uint64](r) and not (hdr[i] >= 48 and hdr[i] <= 57):
        i = i + 1
    h: int64 = 0
    while i < cast[uint64](r) and hdr[i] >= 48 and hdr[i] <= 57:
        h = h * 10 + cast[int64](hdr[i]) - 48
        i = i + 1
    if h <= 0:
        return 600
    return h


# --- wall-clock: btime (epoch) from /dev/stat + uptime (ns) from /dev/time

def _read_btime() -> uint64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/stat"))
    if fd < 0:
        return 0
    buf: Array[2048, uint8]
    total: uint64 = 0
    while total < 2047:
        r: int64 = sys_read(fd, &buf[total], 2047 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    i: uint64 = 0
    while i + 6 < total:
        if (i == 0 or buf[i - 1] == 10) and buf[i] == 98 and buf[i+1] == 116 \
                and buf[i+2] == 105 and buf[i+3] == 109 and buf[i+4] == 101 \
                and buf[i+5] == 32:
            j: uint64 = i + 6
            v: uint64 = 0
            while j < total and buf[j] >= 48 and buf[j] <= 57:
                v = v * 10 + cast[uint64](buf[j]) - 48
                j = j + 1
            return v
        i = i + 1
    return 0


def _read_uptime_ns() -> uint64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/time"))
    if fd < 0:
        return 0
    buf: Array[32, uint8]
    r: int64 = sys_read(fd, &buf[0], 31)
    sys_close(fd)
    if r <= 0:
        return 0
    v: uint64 = 0
    i: uint64 = 0
    while i < cast[uint64](r) and buf[i] >= 48 and buf[i] <= 57:
        v = v * 10 + cast[uint64](buf[i]) - 48
        i = i + 1
    return v


def _now_secs_of_day(btime: uint64) -> uint64:
    up_ns: uint64 = _read_uptime_ns()
    epoch: uint64 = btime + up_ns / 1000000000
    return epoch % 86400


# --- sysmon data sources --------------------------------------------
def _find_kv(buf: Ptr[uint8], total: uint64, lab: Ptr[uint8]) -> uint64:
    ll: uint64 = _slen(lab)
    i: uint64 = 0
    while i + ll < total:
        if i == 0 or buf[i - 1] == 10:
            m: uint64 = 0
            while m < ll and buf[i + m] == lab[m]:
                m = m + 1
            if m == ll:
                j: uint64 = i + ll
                while j < total and not (buf[j] >= 48 and buf[j] <= 57):
                    j = j + 1
                v: uint64 = 0
                while j < total and buf[j] >= 48 and buf[j] <= 57:
                    v = v * 10 + cast[uint64](buf[j]) - 48
                    j = j + 1
                return v
        i = i + 1
    return 0


def _mem_pct() -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/meminfo"))
    if fd < 0:
        return 0
    buf: Array[512, uint8]
    total: uint64 = 0
    while total < 511:
        r: int64 = sys_read(fd, &buf[total], 511 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    memtot: uint64 = _find_kv(&buf[0], total, cast[Ptr[uint8]]("MemTotal:"))
    memused: uint64 = _find_kv(&buf[0], total, cast[Ptr[uint8]]("MemUsed:"))
    if memtot == 0:
        return 0
    return cast[int32]((memused * 100) / memtot)


def _cpu_pct() -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/loadavg"))
    if fd < 0:
        return 0
    buf: Array[128, uint8]
    r: int64 = sys_read(fd, &buf[0], 127)
    sys_close(fd)
    if r <= 0:
        return 0
    i: uint64 = 0
    whole: uint64 = 0
    while i < cast[uint64](r) and buf[i] >= 48 and buf[i] <= 57:
        whole = whole * 10 + cast[uint64](buf[i]) - 48
        i = i + 1
    frac: uint64 = 0
    if i < cast[uint64](r) and buf[i] == 46:           # '.'
        i = i + 1
        d: uint64 = 0
        while i < cast[uint64](r) and buf[i] >= 48 and buf[i] <= 57 and d < 2:
            frac = frac * 10 + cast[uint64](buf[i]) - 48
            i = i + 1
            d = d + 1
        if d == 1:
            frac = frac * 10
    centi: uint64 = whole * 100 + frac
    pct: uint64 = centi / 2
    if pct > 100:
        pct = 100
    return cast[int32](pct)


# --- taskbar window list (parsed from /dev/wsys/windows) -------------
MAX_TASKS: uint64 = 8
task_wid:  Array[8, int32]
task_name: Array[512, uint8]          # 8 * 64
task_namelen: Array[8, uint64]
n_tasks: uint64 = 0


def _refresh_windows():
    n_tasks = 0
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/windows"))
    if fd < 0:
        return
    buf: Array[1024, uint8]
    total: uint64 = 0
    while total < 1023:
        r: int64 = sys_read(fd, &buf[total], 1023 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    i: uint64 = 0
    while i < total and n_tasks < MAX_TASKS:
        w: int32 = 0
        got: int32 = 0
        while i < total and buf[i] >= 48 and buf[i] <= 57:
            w = w * 10 + cast[int32](buf[i]) - 48
            got = 1
            i = i + 1
        if i < total and buf[i] == 32:
            i = i + 1
        nbase: uint64 = n_tasks * 64
        nl: uint64 = 0
        while i < total and buf[i] != 10 and nl < 63:
            task_name[nbase + nl] = buf[i]
            nl = nl + 1
            i = i + 1
        while i < total and buf[i] != 10:
            i = i + 1
        if i < total:
            i = i + 1
        if got != 0:
            task_wid[n_tasks] = w
            task_namelen[n_tasks] = nl
            n_tasks = n_tasks + 1


# ====================================================================
# CONFIG — /etc/panel.conf parsed into a set of PANELS, each with its
# own edge, appearance, and ordered widget list.
# ====================================================================

# widget kinds
WK_MENU:    int32 = 0
WK_TASKS:   int32 = 1
WK_CLOCK:   int32 = 2
WK_SYSMON:  int32 = 3
WK_SPACER:  int32 = 4
# MATE-parity applets (this build adds three real, functional applets):
#   WK_PAGER   virtual-desktop / workspace switcher. Reads /dev/wsys/workspace
#              (kernel snapshot "<gen> <ws>\n"), draws WS_COUNT clickable cells
#              with the active one lit; a click writes "ws <N>\n" to
#              /dev/wsys/ctl so the compositor's workspace_switch() hides the
#              other desktops' windows. Real virtual desktops, not a stub.
#   WK_TRAY    notification area. Draws a bell glyph + an unread dot when the
#              compositor's /dev/wsys/notif snapshot reports an active toast;
#              a click spawns /bin/hamtray (the message-tray history panel).
#   WK_SESSION session button. A power glyph; a click spawns /bin/hamsessui
#              (the Lock / Log Out / Shut Down / Reboot dialog) so the session
#              menu is reachable straight from the panel, MATE-style.
WK_PAGER:   int32 = 5
WK_TRAY:    int32 = 6
WK_SESSION: int32 = 7

# Workspace count for the pager. Mirrors the compositor's WS_COUNT; if the two
# ever diverge the pager just shows fewer/more cells than exist, harmless.
WS_COUNT: int64 = 4

# edges
EDGE_TOP:    int32 = 0
EDGE_BOTTOM: int32 = 1
EDGE_LEFT:   int32 = 2
EDGE_RIGHT:  int32 = 3

MAX_PANELS:  uint64 = 4
MAX_WIDGETS: uint64 = 12               # per panel

# Per-panel config (struct-of-arrays).
p_edge:  Array[4, int32]
p_size:  Array[4, int64]               # thickness in px
p_bold:  Array[4, int32]               # font weight (0 normal, 1 bold)
p_color: Array[40, uint8]              # 4 * 10  "#RRGGBB\0"
p_nwidg: Array[4, uint64]              # widget count per panel
# widget kind grid: panel * MAX_WIDGETS + slot
p_wkind: Array[48, int32]              # 4 * 12
n_panels: uint64 = 0


def p_color_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&p_color[0]) + i * 10)


def _set_pcolor(i: uint64, hx: Ptr[uint8]):
    dp: Ptr[uint8] = p_color_ptr(i)
    k: uint64 = 0
    while hx[k] != 0 and k < 9:
        dp[k] = hx[k]
        k = k + 1
    dp[k] = 0


# Defaults applied when a panel block omits a field.
PANEL_DEF_H: int64 = 26                # default horizontal thickness
PANEL_DEF_V: int64 = 56                # default vertical thickness


def _begin_panel(edge: int32) -> uint64:
    if n_panels >= MAX_PANELS:
        return MAX_PANELS                 # overflow sentinel
    idx: uint64 = n_panels
    p_edge[idx] = edge
    if edge == EDGE_LEFT or edge == EDGE_RIGHT:
        p_size[idx] = PANEL_DEF_V
    else:
        p_size[idx] = PANEL_DEF_H
    p_bold[idx] = 0
    _set_pcolor(idx, cast[Ptr[uint8]]("#d4d0c8"))
    p_nwidg[idx] = 0
    n_panels = n_panels + 1
    return idx


def _add_widget(panel: uint64, kind: int32):
    if panel >= n_panels:
        return
    nw: uint64 = p_nwidg[panel]
    if nw >= MAX_WIDGETS:
        return
    p_wkind[panel * MAX_WIDGETS + nw] = kind
    p_nwidg[panel] = nw + 1


# Insert `kind` into panel `panel` at flow index `at` (0..p_nwidg), shifting
# later widgets up. No-op if the panel is full or indices are out of range.
def _insert_widget(panel: uint64, at: uint64, kind: int32):
    if panel >= n_panels:
        return
    nw: uint64 = p_nwidg[panel]
    if nw >= MAX_WIDGETS:
        return
    if at > nw:
        at = nw
    base: uint64 = panel * MAX_WIDGETS
    j: uint64 = nw
    while j > at:
        p_wkind[base + j] = p_wkind[base + j - 1]
        j = j - 1
    p_wkind[base + at] = kind
    p_nwidg[panel] = nw + 1


# Remove the widget at flow index `at` from panel `panel`, shifting later
# widgets down.
def _remove_widget(panel: uint64, at: uint64):
    if panel >= n_panels:
        return
    nw: uint64 = p_nwidg[panel]
    if at >= nw:
        return
    base: uint64 = panel * MAX_WIDGETS
    j: uint64 = at
    while j + 1 < nw:
        p_wkind[base + j] = p_wkind[base + j + 1]
        j = j + 1
    p_nwidg[panel] = nw - 1


def _default_config():
    # MATE-style two-panel default so multiple edges render out of the box:
    #   TOP    [menu] [tasks ...........] [sysmon] [clock]
    #   BOTTOM [tasks ...................................]
    # The menu+tasks pack from the left; sysmon+clock are emitted after the
    # elastic taskbar so the renderer right-aligns them (clock outermost).
    # The bottom panel is a pure window-list strip (one elastic taskbar).
    # MATE-style two-panel default:
    #   TOP    [menu] [tasks ...] [sysmon] [tray] [session] [clock]
    #   BOTTOM [pager] [tasks ...........................................]
    # The TOP panel now carries the notification-area applet and the session
    # (power) button alongside the system monitor + clock. The BOTTOM panel
    # leads with the virtual-desktop pager (workspace switcher), MATE-style.
    n_panels = 0
    pi: uint64 = _begin_panel(EDGE_TOP)
    _add_widget(pi, WK_MENU)
    _add_widget(pi, WK_TASKS)
    _add_widget(pi, WK_SYSMON)
    _add_widget(pi, WK_TRAY)
    _add_widget(pi, WK_SESSION)
    _add_widget(pi, WK_CLOCK)
    pb: uint64 = _begin_panel(EDGE_BOTTOM)
    _add_widget(pb, WK_PAGER)
    _add_widget(pb, WK_TASKS)


# Match the word at buf[s..e) against a NUL-terminated literal.
def _word_eq(buf: Ptr[uint8], s: uint64, e: uint64, lit: Ptr[uint8]) -> int32:
    ll: uint64 = _slen(lit)
    if e - s != ll:
        return 0
    k: uint64 = 0
    while k < ll:
        if buf[s + k] != lit[k]:
            return 0
        k = k + 1
    return 1


def _widget_kind(buf: Ptr[uint8], s: uint64, e: uint64) -> int32:
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("menu")) != 0:
        return WK_MENU
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("tasks")) != 0:
        return WK_TASKS
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("clock")) != 0:
        return WK_CLOCK
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("sysmon")) != 0:
        return WK_SYSMON
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("spacer")) != 0:
        return WK_SPACER
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("pager")) != 0:
        return WK_PAGER
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("tray")) != 0:
        return WK_TRAY
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("session")) != 0:
        return WK_SESSION
    return -1


def _edge_kind(buf: Ptr[uint8], s: uint64, e: uint64) -> int32:
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("top")) != 0:
        return EDGE_TOP
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("bottom")) != 0:
        return EDGE_BOTTOM
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("left")) != 0:
        return EDGE_LEFT
    if _word_eq(buf, s, e, cast[Ptr[uint8]]("right")) != 0:
        return EDGE_RIGHT
    return -1


# Parse a decimal int from buf[s..e).
def _parse_i64(buf: Ptr[uint8], s: uint64, e: uint64) -> int64:
    v: int64 = 0
    i: uint64 = s
    while i < e and buf[i] >= 48 and buf[i] <= 57:
        v = v * 10 + cast[int64](buf[i]) - 48
        i = i + 1
    return v


# Copy a hex colour token buf[s..e) into a NUL-terminated dest (<=9 chars).
def _copy_color(buf: Ptr[uint8], s: uint64, e: uint64, dst: Ptr[uint8]):
    k: uint64 = 0
    i: uint64 = s
    while i < e and k < 9:
        dst[k] = buf[i]
        k = k + 1
        i = i + 1
    dst[k] = 0


# Legacy single-panel state assembled from bare left/right/position lines.
_legacy_seen: int32 = 0
_legacy_idx:  uint64 = 0
_legacy_edge: int32 = 0


def _legacy_panel() -> uint64:
    # Lazily create (once) the implicit panel that holds bare left/right
    # widgets. Its edge is whatever the most recent `position` line set.
    if _legacy_seen == 0:
        _legacy_idx = _begin_panel(_legacy_edge)
        _legacy_seen = 1
    return _legacy_idx


# The ACTIVE config is the writable runtime override /tmp/hamnix-panel.conf
# (tmpfs — writable from the DE) if it exists, else the shipped read-only
# default /etc/panel.conf. This is the crux of the position/sysmon-toggle
# bug: the sysroot /etc is NOT writable from the running DE, so a Settings
# (or shell) write to /etc/panel.conf was silently dropped and the panel
# never saw a change. Settings now writes the override in /tmp, which the
# panel reads + live-polls. (Mirrors how the wallpaper already lands in /tmp.)
def _open_config() -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/tmp/hamnix-panel.conf"))
    if fd >= 0:
        return fd
    return sys_open(cast[Ptr[char]]("/etc/panel.conf"))


_cfg_buf: Array[2048, uint8]
def _load_config():
    # Parse the active panel config into the panel set. Supports the new
    # `panel ... end` blocks AND the legacy `position`/`left`/`right` bare
    # lines (which build one implicit panel). On ANY failure fall back to the
    # built-in default single top panel.
    n_panels = 0
    _legacy_seen = 0
    _legacy_edge = EDGE_TOP
    cur_panel: uint64 = MAX_PANELS         # MAX_PANELS = "no open block"
    fd: int32 = _open_config()
    if fd < 0:
        _default_config()
        return
    total: uint64 = 0
    while total < 2047:
        r: int64 = sys_read(fd, &_cfg_buf[total], 2047 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    i: uint64 = 0
    while i < total:
        ls: uint64 = i
        while i < total and _cfg_buf[i] != 10:
            i = i + 1
        le: uint64 = i
        if i < total:
            i = i + 1
        p: uint64 = ls
        while p < le and (_cfg_buf[p] == 32 or _cfg_buf[p] == 9):
            p = p + 1
        if p >= le or _cfg_buf[p] == 35:               # blank or '#'
            continue
        w0s: uint64 = p
        while p < le and _cfg_buf[p] != 32 and _cfg_buf[p] != 9:
            p = p + 1
        w0e: uint64 = p
        while p < le and (_cfg_buf[p] == 32 or _cfg_buf[p] == 9):
            p = p + 1
        w1s: uint64 = p
        while p < le and _cfg_buf[p] != 32 and _cfg_buf[p] != 9:
            p = p + 1
        w1e: uint64 = p

        # --- new block form ---------------------------------------
        if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("panel")) != 0:
            cur_panel = _begin_panel(EDGE_TOP)
            continue
        if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("end")) != 0:
            cur_panel = MAX_PANELS
            continue
        if cur_panel < n_panels:
            if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("edge")) != 0:
                ek: int32 = _edge_kind(&_cfg_buf[0], w1s, w1e)
                if ek >= 0:
                    p_edge[cur_panel] = ek
                    # adopt the matching default thickness for the new
                    # orientation unless a size line overrides it later
                    if ek == EDGE_LEFT or ek == EDGE_RIGHT:
                        p_size[cur_panel] = PANEL_DEF_V
                    else:
                        p_size[cur_panel] = PANEL_DEF_H
                continue
            if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("color")) != 0:
                if w1e > w1s:
                    _copy_color(&_cfg_buf[0], w1s, w1e, p_color_ptr(cur_panel))
                continue
            if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("size")) != 0:
                sz: int64 = _parse_i64(&_cfg_buf[0], w1s, w1e)
                if sz > 0:
                    p_size[cur_panel] = sz
                continue
            if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("font")) != 0:
                if _word_eq(&_cfg_buf[0], w1s, w1e, cast[Ptr[uint8]]("bold")) != 0:
                    p_bold[cur_panel] = 1
                else:
                    p_bold[cur_panel] = 0
                continue
            if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("widget")) != 0:
                wk: int32 = _widget_kind(&_cfg_buf[0], w1s, w1e)
                if wk >= 0:
                    _add_widget(cur_panel, wk)
                continue
            # unknown key inside a block: ignore
            continue

        # --- legacy bare lines (outside any block) ----------------
        if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("position")) != 0:
            ek2: int32 = _edge_kind(&_cfg_buf[0], w1s, w1e)
            if ek2 == EDGE_BOTTOM:
                _legacy_edge = EDGE_BOTTOM
            elif ek2 == EDGE_LEFT:
                _legacy_edge = EDGE_LEFT
            elif ek2 == EDGE_RIGHT:
                _legacy_edge = EDGE_RIGHT
            else:
                _legacy_edge = EDGE_TOP
            # if the legacy panel already exists, retro-apply the edge
            if _legacy_seen != 0:
                p_edge[_legacy_idx] = _legacy_edge
                if _legacy_edge == EDGE_LEFT or _legacy_edge == EDGE_RIGHT:
                    p_size[_legacy_idx] = PANEL_DEF_V
                else:
                    p_size[_legacy_idx] = PANEL_DEF_H
            continue
        sidew: int32 = -1
        if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("left")) != 0:
            sidew = 0
        if _word_eq(&_cfg_buf[0], w0s, w0e, cast[Ptr[uint8]]("right")) != 0:
            sidew = 1
        if sidew >= 0 and w1e > w1s:
            wk2: int32 = _widget_kind(&_cfg_buf[0], w1s, w1e)
            if wk2 >= 0:
                lp: uint64 = _legacy_panel()
                if lp < n_panels:
                    # A bare `right <w>` widget that follows the elastic
                    # taskbar packs to the far edge; we encode that by making
                    # the widget order menu/tasks(left) ... sysmon/clock and
                    # relying on the renderer's right-align of trailing fixed
                    # widgets. Insert in source order; `right` widgets simply
                    # come after `left` ones in the list.
                    _add_widget(lp, wk2)
        # unknown bare line: ignore
    if n_panels == 0:
        _default_config()


# Live config re-read (snapshot-compare; no mtime exposed to userland).
_cfg_snap: Array[2048, uint8]
_cfg_snap_len: uint64 = 0xffffffffffffffff
_cfg_scan: Array[2048, uint8]
def _cfg_changed() -> int32:
    fd: int32 = _open_config()
    total: uint64 = 0
    if fd >= 0:
        while total < 2047:
            r: int64 = sys_read(fd, &_cfg_scan[total], 2047 - total)
            if r <= 0:
                break
            total = total + cast[uint64](r)
        sys_close(fd)
    same: int32 = 1
    if total != _cfg_snap_len:
        same = 0
    else:
        i: uint64 = 0
        while i < total:
            if _cfg_scan[i] != _cfg_snap[i]:
                same = 0
                i = total
            else:
                i = i + 1
    if same != 0:
        return 0
    j: uint64 = 0
    while j < total:
        _cfg_snap[j] = _cfg_scan[j]
        j = j + 1
    _cfg_snap_len = total
    return 1


# Edge index -> config keyword.
def _edge_word(e: int32) -> Ptr[uint8]:
    if e == EDGE_BOTTOM:
        return cast[Ptr[uint8]]("bottom")
    if e == EDGE_LEFT:
        return cast[Ptr[uint8]]("left")
    if e == EDGE_RIGHT:
        return cast[Ptr[uint8]]("right")
    return cast[Ptr[uint8]]("top")


# Widget kind -> config keyword.
def _kind_word(k: int32) -> Ptr[uint8]:
    if k == WK_TASKS:
        return cast[Ptr[uint8]]("tasks")
    if k == WK_CLOCK:
        return cast[Ptr[uint8]]("clock")
    if k == WK_SYSMON:
        return cast[Ptr[uint8]]("sysmon")
    if k == WK_SPACER:
        return cast[Ptr[uint8]]("spacer")
    if k == WK_PAGER:
        return cast[Ptr[uint8]]("pager")
    if k == WK_TRAY:
        return cast[Ptr[uint8]]("tray")
    if k == WK_SESSION:
        return cast[Ptr[uint8]]("session")
    return cast[Ptr[uint8]]("menu")


_save_buf: Array[2048, uint8]
def _sb_emit(p: uint64, s: Ptr[uint8]) -> uint64:
    k: uint64 = 0
    while s[k] != 0 and p < 2047:
        _save_buf[p] = s[k]
        p = p + 1
        k = k + 1
    return p


# Serialize the live panel set to /tmp/hamnix-panel.conf in the EXACT
# `panel ... end` block schema _load_config parses. Called after every
# Add / Move / Remove so edits survive a restart. After writing we re-prime
# the live-reload baseline (_cfg_changed) so our OWN write does NOT trip a
# spurious reload on the next tick (which would otherwise rebuild the panel
# set and momentarily flicker).
def _save_config():
    p: uint64 = 0
    p = _sb_emit(p, cast[Ptr[uint8]]("# hamnix panel config (auto-saved by hampanelscene)\n"))
    pi: uint64 = 0
    while pi < n_panels:
        p = _sb_emit(p, cast[Ptr[uint8]]("panel p"))
        p = p + _u64_to_dec(pi, &_save_buf[p])
        _save_buf[p] = 10
        p = p + 1
        p = _sb_emit(p, cast[Ptr[uint8]]("  edge "))
        p = _sb_emit(p, _edge_word(p_edge[pi]))
        _save_buf[p] = 10
        p = p + 1
        p = _sb_emit(p, cast[Ptr[uint8]]("  size "))
        p = p + _u64_to_dec(cast[uint64](p_size[pi]), &_save_buf[p])
        _save_buf[p] = 10
        p = p + 1
        p = _sb_emit(p, cast[Ptr[uint8]]("  color "))
        p = _sb_emit(p, p_color_ptr(pi))
        _save_buf[p] = 10
        p = p + 1
        p = _sb_emit(p, cast[Ptr[uint8]]("  font "))
        if p_bold[pi] != 0:
            p = _sb_emit(p, cast[Ptr[uint8]]("bold"))
        else:
            p = _sb_emit(p, cast[Ptr[uint8]]("normal"))
        _save_buf[p] = 10
        p = p + 1
        nw: uint64 = p_nwidg[pi]
        a: uint64 = 0
        while a < nw:
            p = _sb_emit(p, cast[Ptr[uint8]]("  widget "))
            p = _sb_emit(p, _kind_word(p_wkind[pi * MAX_WIDGETS + a]))
            _save_buf[p] = 10
            p = p + 1
            a = a + 1
        p = _sb_emit(p, cast[Ptr[uint8]]("end\n"))
        pi = pi + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/tmp/hamnix-panel.conf"))
    if fd >= 0:
        sys_write(fd, &_save_buf[0], p)
        sys_close(fd)
    # Re-prime the live-reload baseline so this write doesn't trigger a reload.
    _cfg_changed()


# ====================================================================
# LAYOUT + RENDER (one panel at a time; main() iterates panels)
# ====================================================================

PANEL_H: int64 = 26                  # nominal horizontal bar height (gate)
GLYPH_Y: int64 = 5
MENU_ROW_H: int64 = 22
APP_BTN_W: int64 = 104               # Apps button box (label fully inside)
APP_DIV_X: int64 = 104               # divider line x within the button cell
N_MENU: uint64 = 7
MENU_W: int64 = 136
MENU_H: int64 = 158                  # 7 rows * 22 + 4 pad
SYSMON_W: int64 = 116
CLOCK_W: int64 = 56
TASK_BTN_W: int64 = 132
# Workspace-switcher cell: WS_COUNT cells of PAGER_CELL_W with 2px gaps.
PAGER_CELL_W: int64 = 22
PAGER_W: int64 = 92                   # 4*22 + 3*2 gaps, rounded
TRAY_W: int64 = 24                    # bell glyph cell
SESSION_W: int64 = 24                 # power glyph cell

# ---- per-panel render state (set by _layout_panel for the panel being
# rendered / hit-tested this pass). main() restores per-panel persistent
# fields (menu_open) around each call.
cur_sw: int64 = 0                    # this panel's window content width
cur_sh: int64 = 0                    # this panel's window content height
cur_edge: int32 = 0
cur_bold: int32 = 0
cur_horiz: int32 = 1                 # 1 = top/bottom bar, 0 = left/right
cur_thick: int64 = 26
menu_open: int32 = 0                 # menu state of the panel being processed

# Resolved widget rects for the current panel (window-local). For a
# horizontal panel these are x-ranges at the bar row; for a vertical panel
# they are y-ranges down the bar column.
wx0: Array[12, int64]
wx1: Array[12, int64]
n_widg: uint64 = 0
wkind_cur: Array[12, int32]

menu_slot: int64 = -1                # widget index of the menu, or -1
tasks_slot: int64 = -1
menu_lo: int64 = 0                   # menu widget's start coord (x or y)
tasks_lo: int64 = -1
tasks_hi: int64 = -1

# ---- RIGHT-CLICK CONTEXT MENU (Add to Panel / Move / Remove) -------------
# At most one context menu is open at a time, on exactly one panel. When open
# the owning panel's window GROWS (like the Apps dropdown) so the popup is
# part of that panel's own scene. ctx_kind selects the menu contents:
#   CTXK_ADD    right-click on EMPTY bar space -> add-a-widget list
#   CTXK_WIDGET right-click ON a widget       -> Move / Remove
CTXK_NONE:    int32 = 0
CTXK_ADD:     int32 = 1
CTXK_WIDGET:  int32 = 2
# CTXK_APPMENU: right-click ON the Applications (menu) widget -> a desktop
# shortcut menu (Settings / Add to Panel / About) so the user can reach the
# Settings app by right-clicking the Apps button, not only via the menu tree.
CTXK_APPMENU: int32 = 3

CTX_W: int64 = 150                    # context-menu box width
CTX_ROW_H: int64 = 22

# Add menu rows: Clock, Sysmon, Menu, Tasks, Spacer, Pager, Tray, Session (8).
CTX_ADD_ROWS: int64 = 8
# Widget menu rows: Move, Remove From Panel (2).
CTX_WID_ROWS: int64 = 2
# Apps-button shortcut menu rows: Settings, Add to Panel, About (3).
CTX_APP_ROWS: int64 = 3

ctx_open:   int32 = 0                 # is a context menu currently open?
ctx_panel:  uint64 = 0               # which panel index owns it
ctx_kind:   int32 = 0                 # CTXK_ADD / CTXK_WIDGET
ctx_widget: int64 = -1               # widget slot the click landed on (CTXK_WIDGET)
ctx_insert: int64 = 0                # flow-axis insertion index (CTXK_ADD)
ctx_box_x:  int64 = 0                # window-local origin of the popup box
ctx_box_y:  int64 = 0

# Move-mode: after picking "Move", the next left-click on the bar drops the
# selected widget at a new flow-axis index.
move_active: int32 = 0
move_panel:  uint64 = 0
move_slot:   int64 = -1

# Set by _drain_events from the parsed button bitmap before each
# _handle_button call: 1 if the right button (bit1, value 2) is down.
g_bv_right: int32 = 0

# Number of rows the currently-open context menu has.
def ctx_rows() -> int64:
    if ctx_kind == CTXK_WIDGET:
        return CTX_WID_ROWS
    if ctx_kind == CTXK_APPMENU:
        return CTX_APP_ROWS
    return CTX_ADD_ROWS


def ctx_box_h() -> int64:
    return ctx_rows() * CTX_ROW_H + 4


# Width (horizontal) or height (vertical) a fixed widget occupies in flow.
def _widget_extent(kind: int32) -> int64:
    if cur_horiz != 0:
        if kind == WK_MENU:
            return APP_BTN_W + 8
        if kind == WK_SYSMON:
            return SYSMON_W + 8
        if kind == WK_CLOCK:
            return CLOCK_W + 8
        if kind == WK_PAGER:
            return PAGER_W + 8
        if kind == WK_TRAY:
            return TRAY_W + 8
        if kind == WK_SESSION:
            return SESSION_W + 8
        return 0                     # tasks / spacer = elastic
    # vertical panel: stack rows
    if kind == WK_MENU:
        return 24
    if kind == WK_SYSMON:
        return 28
    if kind == WK_CLOCK:
        return 20
    if kind == WK_PAGER:
        return 24
    if kind == WK_TRAY:
        return 24
    if kind == WK_SESSION:
        return 24
    return 0


# Lay out the current panel's widget list into wx0/wx1 (the flow axis).
# Fixed widgets before the first elastic widget pack from the start; fixed
# widgets after it pack toward the far end; the elastic widget(s) fill the
# slack. (Multiple elastic widgets share equally is overkill; we treat the
# first elastic as the slack-filler and any later spacer/tasks as zero.)
def _layout_panel():
    menu_slot = -1
    tasks_slot = -1
    tasks_lo = -1
    tasks_hi = -1
    span: int64 = cur_sw
    if cur_horiz == 0:
        span = cur_sh
    # find the first elastic widget (tasks or spacer)
    first_elastic: int64 = -1
    a: uint64 = 0
    while a < n_widg:
        k: int32 = wkind_cur[a]
        if (k == WK_TASKS or k == WK_SPACER) and first_elastic < 0:
            first_elastic = cast[int64](a)
        a = a + 1
    lo: int64 = 0
    hi: int64 = span
    # pack leading fixed widgets from start
    b: uint64 = 0
    while b < n_widg:
        k2: int32 = wkind_cur[b]
        if first_elastic >= 0 and cast[int64](b) >= first_elastic:
            b = n_widg
        else:
            ext: int64 = _widget_extent(k2)
            wx0[b] = lo
            wx1[b] = lo + ext
            if k2 == WK_MENU:
                menu_slot = cast[int64](b)
                menu_lo = lo
            lo = lo + ext
            b = b + 1
    # pack trailing fixed widgets (after the elastic) from the far end
    if first_elastic >= 0:
        c: int64 = cast[int64](n_widg) - 1
        while c > first_elastic:
            k3: int32 = wkind_cur[c]
            ext2: int64 = _widget_extent(k3)
            hi = hi - ext2
            wx0[c] = hi + 8
            wx1[c] = span
            c = c - 1
        # the elastic widget itself
        ei: uint64 = cast[uint64](first_elastic)
        ek: int32 = wkind_cur[ei]
        wx0[ei] = lo + 4
        wx1[ei] = hi - 4
        if ek == WK_TASKS:
            tasks_slot = first_elastic
            tasks_lo = wx0[ei]
            tasks_hi = wx1[ei]
        # any further elastic widgets collapse (already covered by trailing
        # pack or empty)


# --- per-widget render ----------------------------------------------
# `bar` = the start coord of the panel bar on the cross axis (window-local).
# For horizontal panels widgets sit at y=bar..bar+thick; for vertical they
# sit at x=bar..bar+thick. `lo` is the widget's start coord on the flow axis.

def _render_menu(lo: int64, bar: int64):
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    if cur_horiz != 0:
        by: int32 = cast[int32](bar)
        if menu_open != 0:
            hamscene_fill(cast[int32](lo), by, cast[int32](APP_BTN_W), 26,
                          cast[Ptr[uint8]]("#c0bcb4"))
        _glyphs(lo + 8, bar + 5, cast[Ptr[uint8]]("Applications"), fg, cur_bold)
        hamscene_fill(cast[int32](lo + APP_DIV_X + 4), by + 4, 1, 18,
                      cast[Ptr[uint8]]("#808080"))
    else:
        # vertical: short "Apps" label centred in its row
        _glyphs(bar + 6, lo + 4, cast[Ptr[uint8]]("Apps"), fg, cur_bold)


def _render_tasks(lo: int64, hi: int64, bar: int64):
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    if cur_horiz != 0:
        by: int32 = cast[int32](bar)
        t: uint64 = 0
        while t < n_tasks:
            bx: int64 = lo + cast[int64](t) * (TASK_BTN_W + 4)
            if bx + TASK_BTN_W > hi:
                t = n_tasks
            else:
                hamscene_rect(cast[int32](bx), by + 3, cast[int32](TASK_BTN_W),
                              20, cast[Ptr[uint8]]("#c8c4bc"))
                lbl: Array[20, uint8]
                nbase: uint64 = t * 64
                nl: uint64 = task_namelen[t]
                if nl > 16:
                    nl = 16
                k: uint64 = 0
                while k < nl:
                    ch: uint8 = task_name[nbase + k]
                    if ch == 34 or ch == 10:
                        ch = 32
                    lbl[k] = ch
                    k = k + 1
                lbl[k] = 0
                _glyphs(bx + 6, bar + 5, &lbl[0], fg, cur_bold)
                t = t + 1
    else:
        # vertical taskbar: one button per window stacked down the column
        t2: uint64 = 0
        while t2 < n_tasks:
            byv: int64 = lo + cast[int64](t2) * 24
            if byv + 22 > hi:
                t2 = n_tasks
            else:
                hamscene_rect(cast[int32](bar + 3), cast[int32](byv),
                              cast[int32](cur_thick - 6), 22,
                              cast[Ptr[uint8]]("#c8c4bc"))
                lbl2: Array[12, uint8]
                nbase2: uint64 = t2 * 64
                nl2: uint64 = task_namelen[t2]
                # Clip the label to the panel CROSS-AXIS width: text begins at
                # bar+6 and must stay inside the bar+3..bar+cur_thick-3 button,
                # so the budget is (cur_thick-9)/8 glyphs (8px advance). This
                # stops names overflowing past the right of a left/right panel.
                vmax: int64 = (cur_thick - 9) / 8
                if vmax < 1:
                    vmax = 1
                if vmax > 11:
                    vmax = 11
                if nl2 > cast[uint64](vmax):
                    nl2 = cast[uint64](vmax)
                k2: uint64 = 0
                while k2 < nl2:
                    ch2: uint8 = task_name[nbase2 + k2]
                    if ch2 == 34 or ch2 == 10:
                        ch2 = 32
                    lbl2[k2] = ch2
                    k2 = k2 + 1
                lbl2[k2] = 0
                _glyphs(bar + 6, byv + 3, &lbl2[0], fg, cur_bold)
                t2 = t2 + 1


def _render_sysmon(lo: int64, bar: int64):
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    cpu: int32 = _cpu_pct()
    mem: int32 = _mem_pct()
    if cur_horiz != 0:
        by: int32 = cast[int32](bar)
        _glyphs(lo, bar + 1, cast[Ptr[uint8]]("C"), fg, cur_bold)
        hamscene_hbar(cast[int32](lo + 12), by + 4, 92, 8, cpu,
                      cast[Ptr[uint8]]("#40c040"))
        _glyphs(lo, bar + 13, cast[Ptr[uint8]]("M"), fg, cur_bold)
        hamscene_hbar(cast[int32](lo + 12), by + 16, 92, 8, mem,
                      cast[Ptr[uint8]]("#4080e0"))
    else:
        _glyphs(bar + 4, lo, cast[Ptr[uint8]]("C"), fg, cur_bold)
        hamscene_hbar(cast[int32](bar + 4), cast[int32](lo + 12),
                      cast[int32](cur_thick - 8), 6, cpu,
                      cast[Ptr[uint8]]("#40c040"))
        hamscene_hbar(cast[int32](bar + 4), cast[int32](lo + 20),
                      cast[int32](cur_thick - 8), 6, mem,
                      cast[Ptr[uint8]]("#4080e0"))


def _render_clock(lo: int64, bar: int64, btime: uint64):
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    sod: uint64 = _now_secs_of_day(btime)
    hh: uint64 = sod / 3600
    mm: uint64 = (sod % 3600) / 60
    txt: Array[8, uint8]
    p: uint64 = 0
    if hh < 10:
        txt[p] = 48
        p = p + 1
    p = p + _u64_to_dec(hh, &txt[p])
    txt[p] = 58
    p = p + 1
    if mm < 10:
        txt[p] = 48
        p = p + 1
    p = p + _u64_to_dec(mm, &txt[p])
    txt[p] = 0
    if cur_horiz != 0:
        _glyphs(lo, bar + 5, &txt[0], fg, cur_bold)
    else:
        _glyphs(bar + 6, lo, &txt[0], fg, cur_bold)


# --- Workspace switcher (pager) -------------------------------------
# Draws WS_COUNT cells. The active workspace cell is lit blue with its 1-based
# number in white; inactive cells are sunken grey with a dark number. The
# whole applet is a real virtual-desktop switcher: clicking a cell calls
# _switch_workspace which drives the compositor's workspace_switch.
def _render_pager(lo: int64, bar: int64):
    actfg: Ptr[uint8] = cast[Ptr[uint8]]("#ffffff")
    inafg: Ptr[uint8] = cast[Ptr[uint8]]("#303030")
    gap: int64 = 2
    if cur_horiz != 0:
        by: int32 = cast[int32](bar)
        w: int64 = 0
        while w < WS_COUNT:
            cx: int64 = lo + w * (PAGER_CELL_W + gap)
            if cx + PAGER_CELL_W > lo + PAGER_W + 2:
                w = WS_COUNT
            else:
                if w == cur_ws:
                    hamscene_fill(cast[int32](cx), by + 4,
                                  cast[int32](PAGER_CELL_W), 18,
                                  cast[Ptr[uint8]]("#4878c0"))
                else:
                    hamscene_fill(cast[int32](cx), by + 4,
                                  cast[int32](PAGER_CELL_W), 18,
                                  cast[Ptr[uint8]]("#b8b4ac"))
                hamscene_stroke(cast[int32](cx), by + 4,
                                cast[int32](PAGER_CELL_W), 18, 1,
                                cast[Ptr[uint8]]("#707070"))
                lab: Array[4, uint8]
                _u64_to_dec(cast[uint64](w + 1), &lab[0])
                lab[1] = 0
                fgc: Ptr[uint8] = inafg
                if w == cur_ws:
                    fgc = actfg
                _glyphs(cx + 8, bar + 6, &lab[0], fgc, cur_bold)
                w = w + 1
    else:
        # vertical: stack cells down the column
        w2: int64 = 0
        while w2 < WS_COUNT:
            cy: int64 = lo + w2 * (PAGER_CELL_W + gap)
            if w2 == cur_ws:
                hamscene_fill(cast[int32](bar + 4), cast[int32](cy),
                              cast[int32](cur_thick - 8), 18,
                              cast[Ptr[uint8]]("#4878c0"))
            else:
                hamscene_fill(cast[int32](bar + 4), cast[int32](cy),
                              cast[int32](cur_thick - 8), 18,
                              cast[Ptr[uint8]]("#b8b4ac"))
            lab2: Array[4, uint8]
            _u64_to_dec(cast[uint64](w2 + 1), &lab2[0])
            lab2[1] = 0
            fgc2: Ptr[uint8] = inafg
            if w2 == cur_ws:
                fgc2 = actfg
            _glyphs(bar + 10, cy + 2, &lab2[0], fgc2, cur_bold)
            w2 = w2 + 1


# --- Notification-area / tray applet --------------------------------
# A bell glyph in a flat cell. When there are unread notifications we paint a
# red badge with the unread COUNT at the bell's top-right. A click spawns
# /bin/haminbox (the scene message-history inbox) and clears the unread count.
def _render_tray(lo: int64, bar: int64):
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    bx: int32 = cast[int32](lo)
    by: int32 = cast[int32](bar)
    # Bell body: a rounded-ish trapezoid faked with two stacked rects + clapper.
    hamscene_fill(bx + 7, by + 6, 8, 9, cast[Ptr[uint8]]("#404040"))
    hamscene_fill(bx + 5, by + 14, 12, 2, cast[Ptr[uint8]]("#404040"))
    hamscene_fill(bx + 9, by + 5, 4, 2, cast[Ptr[uint8]]("#404040"))
    hamscene_fill(bx + 10, by + 16, 2, 2, cast[Ptr[uint8]]("#404040"))
    if notif_unread > 0:
        # Red badge + count digit at the bell's top-right.
        hamscene_fill(bx + 13, by + 2, 9, 9, cast[Ptr[uint8]]("#e03030"))
        cnt: int64 = notif_unread
        if cnt > 9:
            cnt = 9
        cbuf: Array[2, uint8]
        _u64_to_dec(cast[uint64](cnt), &cbuf[0])
        cbuf[1] = 0
        _glyphs(cast[int64](bx) + 14, cast[int64](by) + 2, &cbuf[0],
                cast[Ptr[uint8]]("#ffffff"), 0)


# --- Session / power button applet ----------------------------------
# A power-symbol glyph (ring + stem). A click spawns /bin/hamsessui (the
# Lock / Log Out / Shut Down / Reboot dialog).
def _render_session(lo: int64, bar: int64):
    col: Ptr[uint8] = cast[Ptr[uint8]]("#205020")
    bx: int32 = cast[int32](lo)
    by: int32 = cast[int32](bar)
    # Ring: four short segments forming an open circle.
    hamscene_fill(bx + 6, by + 9, 2, 6, col)        # left
    hamscene_fill(bx + 16, by + 9, 2, 6, col)       # right
    hamscene_fill(bx + 8, by + 16, 8, 2, col)       # bottom
    hamscene_fill(bx + 7, by + 7, 4, 2, col)        # top-left arc
    hamscene_fill(bx + 13, by + 7, 4, 2, col)       # top-right arc
    # Stem (the power-symbol vertical bar through the gap).
    hamscene_fill(bx + 11, by + 5, 2, 7, col)


# The menu dropdown box origin (window-local). For a top panel it opens below
# the bar; bottom opens above; vertical panels open to the inside edge.
menu_box_x: int64 = 0
menu_box_y: int64 = 26


def _compute_menu_box(bar: int64):
    if cur_horiz != 0:
        menu_box_x = menu_lo
        if cur_edge == EDGE_BOTTOM:
            menu_box_y = 0
        else:
            menu_box_y = bar + cur_thick
    else:
        # vertical: open to the inside edge, aligned with the Apps row
        if cur_edge == EDGE_LEFT:
            menu_box_x = bar + cur_thick
        else:
            menu_box_x = bar - MENU_W
        menu_box_y = menu_lo


# Compute the context-menu box origin (window-local). It anchors at the
# right-click flow coordinate (ctx_flow) and opens into the popup band on the
# inside (desktop-facing) edge, mirroring the Apps dropdown geometry. ctx_flow
# is the click's flow-axis coordinate (x for horizontal panels, y for vertical)
# captured when the menu opened.
ctx_flow: int64 = 0
def _compute_ctx_box(bar: int64):
    bh: int64 = ctx_box_h()
    if cur_horiz != 0:
        cx: int64 = ctx_flow
        if cx + CTX_W > cur_sw:
            cx = cur_sw - CTX_W
        if cx < 0:
            cx = 0
        ctx_box_x = cx
        if cur_edge == EDGE_BOTTOM:
            ctx_box_y = bar - bh             # opens above the bar
            if ctx_box_y < 0:
                ctx_box_y = 0
        else:
            ctx_box_y = bar + cur_thick      # opens below the bar
    else:
        cy: int64 = ctx_flow
        if cy + bh > cur_sh:
            cy = cur_sh - bh
        if cy < 0:
            cy = 0
        ctx_box_y = cy
        if cur_edge == EDGE_LEFT:
            ctx_box_x = bar + cur_thick
        else:
            ctx_box_x = bar - CTX_W


def _emit_panel(bar: int64, btime: uint64):
    hamscene_begin()
    # Backdrop fill of the whole (possibly grown) window so no stale pixel
    # reads as the cache's opaque black.
    hamscene_fill(0, 0, cast[int32](cur_sw), cast[int32](cur_sh),
                  cast[Ptr[uint8]]("#205060"))
    # The panel bar itself.
    if cur_horiz != 0:
        hamscene_fill(0, cast[int32](bar), cast[int32](cur_sw),
                      cast[int32](cur_thick), cur_panel_color())
        # hairline along the desktop-facing edge
        if cur_edge == EDGE_BOTTOM:
            hamscene_fill(0, cast[int32](bar), cast[int32](cur_sw), 1,
                          cast[Ptr[uint8]]("#808080"))
        else:
            hamscene_fill(0, cast[int32](bar + cur_thick - 1),
                          cast[int32](cur_sw), 1, cast[Ptr[uint8]]("#808080"))
    else:
        hamscene_fill(cast[int32](bar), 0, cast[int32](cur_thick),
                      cast[int32](cur_sh), cur_panel_color())
        if cur_edge == EDGE_LEFT:
            hamscene_fill(cast[int32](bar + cur_thick - 1), 0, 1,
                          cast[int32](cur_sh), cast[Ptr[uint8]]("#808080"))
        else:
            hamscene_fill(cast[int32](bar), 0, 1, cast[int32](cur_sh),
                          cast[Ptr[uint8]]("#808080"))
    # widgets
    a: uint64 = 0
    while a < n_widg:
        k: int32 = wkind_cur[a]
        if k == WK_MENU:
            _render_menu(wx0[a], bar)
        elif k == WK_TASKS:
            _render_tasks(wx0[a], wx1[a], bar)
        elif k == WK_SYSMON:
            _render_sysmon(wx0[a], bar)
        elif k == WK_CLOCK:
            _render_clock(wx0[a], bar, btime)
        elif k == WK_PAGER:
            _render_pager(wx0[a], bar)
        elif k == WK_TRAY:
            _render_tray(wx0[a], bar)
        elif k == WK_SESSION:
            _render_session(wx0[a], bar)
        a = a + 1
    # dropdown
    if menu_open != 0 and menu_slot >= 0:
        _compute_menu_box(bar)
        mx: int32 = cast[int32](menu_box_x)
        my: int32 = cast[int32](menu_box_y)
        hamscene_fill(mx, my, cast[int32](MENU_W), cast[int32](MENU_H),
                      cast[Ptr[uint8]]("#e8e4dc"))
        hamscene_stroke(mx, my, cast[int32](MENU_W), cast[int32](MENU_H), 1,
                        cast[Ptr[uint8]]("#808080"))
        fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
        _glyphs(menu_box_x + 10, menu_box_y + 5, cast[Ptr[uint8]]("Terminal"), fg, cur_bold)
        _glyphs(menu_box_x + 10, menu_box_y + 27, cast[Ptr[uint8]]("Files"), fg, cur_bold)
        _glyphs(menu_box_x + 10, menu_box_y + 49, cast[Ptr[uint8]]("Calculator"), fg, cur_bold)
        _glyphs(menu_box_x + 10, menu_box_y + 71, cast[Ptr[uint8]]("Editor"), fg, cur_bold)
        _glyphs(menu_box_x + 10, menu_box_y + 93, cast[Ptr[uint8]]("Settings"), fg, cur_bold)
        _glyphs(menu_box_x + 10, menu_box_y + 115, cast[Ptr[uint8]]("System Monitor"), fg, cur_bold)
        _glyphs(menu_box_x + 10, menu_box_y + 137, cast[Ptr[uint8]]("Install Hamnix"), fg, cur_bold)
    # right-click context menu (Add to Panel / Move / Remove)
    if ctx_open != 0 and ctx_panel == cur_panel_idx:
        _compute_ctx_box(bar)
        bh: int64 = ctx_box_h()
        cmx: int32 = cast[int32](ctx_box_x)
        cmy: int32 = cast[int32](ctx_box_y)
        hamscene_fill(cmx, cmy, cast[int32](CTX_W), cast[int32](bh),
                      cast[Ptr[uint8]]("#e8e4dc"))
        hamscene_stroke(cmx, cmy, cast[int32](CTX_W), cast[int32](bh), 1,
                        cast[Ptr[uint8]]("#808080"))
        cfg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
        nr: int64 = ctx_rows()
        ri: int64 = 0
        while ri < nr:
            ry: int64 = ctx_box_y + 5 + ri * CTX_ROW_H
            _glyphs(ctx_box_x + 10, ry, _ctx_row_label(ri), cfg, cur_bold)
            ri = ri + 1


# Label for context-menu row `ri` given the active ctx_kind.
def _ctx_row_label(ri: int64) -> Ptr[uint8]:
    if ctx_kind == CTXK_APPMENU:
        if ri == 0:
            return cast[Ptr[uint8]]("Settings")
        if ri == 1:
            return cast[Ptr[uint8]]("Add to Panel")
        return cast[Ptr[uint8]]("About")
    if ctx_kind == CTXK_WIDGET:
        if ri == 0:
            return cast[Ptr[uint8]]("Move")
        return cast[Ptr[uint8]]("Remove From Panel")
    # CTXK_ADD: Clock, Sysmon, Menu, Tasks, Spacer, Pager, Tray, Session
    if ri == 0:
        return cast[Ptr[uint8]]("Clock")
    if ri == 1:
        return cast[Ptr[uint8]]("Sysmon")
    if ri == 2:
        return cast[Ptr[uint8]]("Menu")
    if ri == 3:
        return cast[Ptr[uint8]]("Tasks")
    if ri == 4:
        return cast[Ptr[uint8]]("Spacer")
    if ri == 5:
        return cast[Ptr[uint8]]("Workspaces")
    if ri == 6:
        return cast[Ptr[uint8]]("Notifications")
    return cast[Ptr[uint8]]("Session")


# Map an Add-menu row index to a widget kind.
def _ctx_add_kind(ri: int64) -> int32:
    if ri == 0:
        return WK_CLOCK
    if ri == 1:
        return WK_SYSMON
    if ri == 2:
        return WK_MENU
    if ri == 3:
        return WK_TASKS
    if ri == 4:
        return WK_SPACER
    if ri == 5:
        return WK_PAGER
    if ri == 6:
        return WK_TRAY
    return WK_SESSION


# the bar fill colour for the current panel: an index into p_color, set by
# _select_panel. (A Ptr[uint8] global can't take a cast initializer, so we
# key by index and resolve through p_color_ptr at use sites.)
cur_panel_idx: uint64 = 0
def cur_panel_color() -> Ptr[uint8]:
    return p_color_ptr(cur_panel_idx)


# Set a window's geometry: origin (x,y) + content size (w,h).
def _set_geometry_xy(ctlpath: Ptr[char], x: int64, y: int64, w: int64, h: int64):
    cfd: int32 = sys_open_write(ctlpath)
    if cfd < 0:
        return
    geo: Array[64, uint8]
    gp: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("geometry ")
    j: uint64 = 0
    while pre[j] != 0:
        geo[gp] = pre[j]
        gp = gp + 1
        j = j + 1
    gp = gp + _u64_to_dec(cast[uint64](x), &geo[gp])
    geo[gp] = 32
    gp = gp + 1
    gp = gp + _u64_to_dec(cast[uint64](y), &geo[gp])
    geo[gp] = 32
    gp = gp + 1
    gp = gp + _u64_to_dec(cast[uint64](w), &geo[gp])
    geo[gp] = 32
    gp = gp + 1
    gp = gp + _u64_to_dec(cast[uint64](h), &geo[gp])
    geo[gp] = 10
    gp = gp + 1
    sys_write(cfd, &geo[0], gp)
    sys_close(cfd)


# Spawn a scene app by absolute path. Detached stdio (-2/-2).
launch_argv: Array[2, uint64]
def _launch(prog: Ptr[char]):
    launch_argv[0] = cast[uint64](prog)
    launch_argv[1] = 0
    pid: int32 = spawn(prog, &launch_argv[0], -2, -2, cast[Ptr[uint64]](0))
    if pid >= 0:
        _writeall(1, cast[Ptr[uint8]]("[panel] launched "))
        _writeall(1, cast[Ptr[uint8]](prog))
        _writeall(1, cast[Ptr[uint8]]("\n"))


def _raise_focus(idx: uint64):
    if idx >= n_tasks:
        return
    w: int32 = task_wid[idx]
    cp: Array[64, uint8]
    _winpath(&cp[0], w, cast[Ptr[uint8]]("/ctl"))
    f1: int32 = sys_open_write(cast[Ptr[char]](&cp[0]))
    if f1 >= 0:
        _writeall(f1, cast[Ptr[uint8]]("raise\n"))
        sys_close(f1)
    f2: int32 = sys_open_write(cast[Ptr[char]](&cp[0]))
    if f2 >= 0:
        _writeall(f2, cast[Ptr[uint8]]("focus\n"))
        sys_close(f2)
    _writeall(1, cast[Ptr[uint8]]("[panel] raise+focus window\n"))


def _launch_menu_row(row: int64):
    if row == 0:
        _launch(cast[Ptr[char]]("/bin/hamtermscene"))
    elif row == 1:
        _launch(cast[Ptr[char]]("/bin/hamfmscene"))
    elif row == 2:
        _launch(cast[Ptr[char]]("/bin/hamcalcscene"))
    elif row == 3:
        _launch(cast[Ptr[char]]("/bin/hameditscene"))
    elif row == 4:
        _launch(cast[Ptr[char]]("/bin/hamsettings"))
    elif row == 5:
        _launch(cast[Ptr[char]]("/bin/hammonscene"))
    elif row == 6:
        _launch(cast[Ptr[char]]("/bin/haminstallui"))


# Find the widget slot (0..n_widg-1) whose flow-axis rect [wx0,wx1) contains
# `flow`, or -1 if the click is in empty bar space. Requires _layout_panel to
# have run for the current panel.
def _widget_at_flow(flow: int64) -> int64:
    a: uint64 = 0
    while a < n_widg:
        if flow >= wx0[a] and flow < wx1[a]:
            return cast[int64](a)
        a = a + 1
    return -1


# Flow-axis insertion index for a drop/add at coordinate `flow`: the index of
# the first widget whose start (wx0) is past `flow`; i.e. insert BEFORE it.
# Returns n_widg to append at the end.
def _insert_index_at_flow(flow: int64) -> int64:
    a: uint64 = 0
    while a < n_widg:
        if flow < wx0[a]:
            return cast[int64](a)
        a = a + 1
    return cast[int64](n_widg)


# Hit-test a window-local click for the current panel. Mutates menu_open +
# may launch/raise. Returns 1 if a redraw is needed. Uses the layout + the
# bar/menu-box coords computed in the last emit.
def _handle_click(x: int64, y: int64, bar: int64) -> int32:
    # dropdown open?
    if menu_open != 0 and menu_slot >= 0:
        _compute_menu_box(bar)
        if x >= menu_box_x and x < menu_box_x + MENU_W \
                and y >= menu_box_y and y < menu_box_y + MENU_H:
            row: int64 = (y - menu_box_y - 2) / MENU_ROW_H
            _launch_menu_row(row)
            menu_open = 0
            return 1
    # on the bar?
    onbar: int32 = 0
    flow: int64 = x
    cross: int64 = y
    if cur_horiz != 0:
        if y >= bar and y < bar + cur_thick:
            onbar = 1
        flow = x
    else:
        if x >= bar and x < bar + cur_thick:
            onbar = 1
        flow = y
    if onbar != 0:
        # Apps button toggles the menu.
        if menu_slot >= 0:
            ms: uint64 = cast[uint64](menu_slot)
            if flow >= wx0[ms] and flow < wx1[ms]:
                if menu_open != 0:
                    menu_open = 0
                else:
                    menu_open = 1
                return 1
        # taskbar buttons
        if tasks_slot >= 0 and flow >= tasks_lo and flow < tasks_hi:
            step: int64 = TASK_BTN_W + 4
            if cur_horiz == 0:
                step = 24
            t: uint64 = 0
            while t < n_tasks:
                bx: int64 = tasks_lo + cast[int64](t) * step
                hit: int32 = 0
                if cur_horiz != 0 and flow >= bx and flow < bx + TASK_BTN_W:
                    hit = 1
                if cur_horiz == 0 and flow >= bx and flow < bx + 22:
                    hit = 1
                if hit != 0:
                    _raise_focus(t)
                    if menu_open != 0:
                        menu_open = 0
                        return 1
                    return 0
                t = t + 1
        # pager / tray / session applets (fixed widgets)
        ai: uint64 = 0
        while ai < n_widg:
            ak: int32 = wkind_cur[ai]
            if ak == WK_PAGER or ak == WK_TRAY or ak == WK_SESSION:
                if flow >= wx0[ai] and flow < wx1[ai]:
                    if ak == WK_PAGER:
                        # which cell?
                        rel: int64 = flow - wx0[ai]
                        step: int64 = PAGER_CELL_W + 2
                        cell: int64 = rel / step
                        if cell >= 0 and cell < WS_COUNT:
                            _switch_workspace(cell)
                        if menu_open != 0:
                            menu_open = 0
                        return 1
                    elif ak == WK_TRAY:
                        # Open the scene notification inbox and mark all read.
                        _launch(cast[Ptr[char]]("/bin/haminbox"))
                        notif_unread = 0
                        if menu_open != 0:
                            menu_open = 0
                        return 1
                    else:
                        # The End-Session modal is a self-opening scene
                        # client (user/hamsessui.ad): spawning it pops the
                        # dialog immediately and it handles its own row
                        # clicks (Lock / Log Out / Shut Down / Reboot).
                        _launch(cast[Ptr[char]]("/bin/hamsessui"))
                        if menu_open != 0:
                            menu_open = 0
                        return 1
            ai = ai + 1
        if menu_open != 0:
            menu_open = 0
            return 1
    return 0


# Is (x,y) on this panel's bar (cross-axis within the bar band)? Returns the
# flow-axis coordinate via the caller reading cur_horiz.
def _on_bar(x: int64, y: int64, bar: int64) -> int32:
    if cur_horiz != 0:
        if y >= bar and y < bar + cur_thick:
            return 1
        return 0
    if x >= bar and x < bar + cur_thick:
        return 1
    return 0


def _flow_of(x: int64, y: int64) -> int64:
    if cur_horiz != 0:
        return x
    return y


# Central button dispatcher: routes left vs right clicks, drives the
# right-click Add / Move / Remove context menus, and the move-mode drop.
# Returns 1 if a redraw is needed. Mutates ctx_*/move_*/menu_open and (on
# Add/Move/Remove) the panel's widget list + persists via _save_config.
# The owning _drain_events re-applies geometry afterwards if a popup toggled.
def _handle_button(x: int64, y: int64, bar: int64, pi: uint64) -> int32:
    # Geometry re-apply (after a popup toggles) is handled by _drain_events;
    # here we only need flow-axis hit-testing within this window.
    bv_right: int32 = g_bv_right
    # 1) A context menu is open on this panel: any click resolves it.
    if ctx_open != 0 and ctx_panel == pi:
        _compute_ctx_box(bar)
        bh: int64 = ctx_box_h()
        if x >= ctx_box_x and x < ctx_box_x + CTX_W \
                and y >= ctx_box_y and y < ctx_box_y + bh:
            row: int64 = (y - ctx_box_y - 2) / CTX_ROW_H
            if row < 0:
                row = 0
            if row >= ctx_rows():
                row = ctx_rows() - 1
            _ctx_select_row(pi, row)
            return 1
        # click outside the menu: dismiss it.
        ctx_open = 0
        ctx_kind = CTXK_NONE
        return 1
    # 2) Move-mode: a left click on the bar drops the carried widget.
    if move_active != 0 and move_panel == pi and bv_right == 0:
        if _on_bar(x, y, bar) != 0:
            flow: int64 = _flow_of(x, y)
            _do_move_drop(pi, flow)
            return 1
        # click off-bar cancels the move
        move_active = 0
        return 1
    # 3) A right-click on the bar opens a context menu.
    if bv_right != 0 and _on_bar(x, y, bar) != 0:
        flow2: int64 = _flow_of(x, y)
        ws: int64 = _widget_at_flow(flow2)
        ctx_open = 1
        ctx_panel = pi
        ctx_flow = flow2
        if ws >= 0:
            # Right-click ON the Applications (menu) widget -> the desktop
            # shortcut menu (Settings / Add to Panel / About). Any other
            # widget -> the per-widget Move / Remove menu.
            if menu_slot >= 0 and ws == menu_slot:
                ctx_kind = CTXK_APPMENU
                ctx_widget = ws
            else:
                ctx_kind = CTXK_WIDGET
                ctx_widget = ws
        else:
            ctx_kind = CTXK_ADD
            ctx_insert = _insert_index_at_flow(flow2)
        # close the apps dropdown if it was open
        menu_open = 0
        return 1
    # 4) Plain left-click: the legacy menu/taskbar behaviour.
    return _handle_click(x, y, bar)


# Apply the chosen context-menu row.
def _ctx_select_row(pi: uint64, row: int64):
    if ctx_kind == CTXK_APPMENU:
        if row == 1:
            # Add to Panel: morph this popup into the add-a-widget kind picker
            # (Clock/Sysmon/Menu/Tasks/Spacer), inserting at the Apps button's
            # flow position. Keep the menu OPEN so the user picks a kind next.
            ctx_kind = CTXK_ADD
            ctx_insert = _insert_index_at_flow(ctx_flow)
            return
        # Settings (row 0) -> the Control Center; About (row 2) -> the
        # dedicated About-this-system scene dialog (/bin/hamabout: OS name,
        # kernel, memory, uptime). MATE's "About This Computer".
        if row == 2:
            _launch(cast[Ptr[char]]("/bin/hamabout"))
        else:
            _launch(cast[Ptr[char]]("/bin/hamsettings"))
        ctx_open = 0
        ctx_kind = CTXK_NONE
        return
    if ctx_kind == CTXK_WIDGET:
        if row == 0:
            # Move: enter move-mode carrying this widget.
            move_active = 1
            move_panel = pi
            move_slot = ctx_widget
        else:
            # Remove From Panel.
            if ctx_widget >= 0:
                _remove_widget(pi, cast[uint64](ctx_widget))
                _save_config()
        ctx_open = 0
        ctx_kind = CTXK_NONE
        return
    # CTXK_ADD: insert the chosen kind at the recorded flow index.
    k: int32 = _ctx_add_kind(row)
    at: uint64 = cast[uint64](ctx_insert)
    if at > p_nwidg[pi]:
        at = p_nwidg[pi]
    _insert_widget(pi, at, k)
    _save_config()
    ctx_open = 0
    ctx_kind = CTXK_NONE


# Drop the carried widget (move_slot) at flow index derived from `flow`.
def _do_move_drop(pi: uint64, flow: int64):
    if move_slot < 0:
        move_active = 0
        return
    src: uint64 = cast[uint64](move_slot)
    if src >= p_nwidg[pi]:
        move_active = 0
        move_slot = -1
        return
    k: int32 = p_wkind[pi * MAX_WIDGETS + src]
    dst: int64 = _insert_index_at_flow(flow)
    # Remove from old index first; if the destination was after it, the
    # removal shifts everything down by one, so decrement dst accordingly.
    _remove_widget(pi, src)
    if dst > cast[int64](src):
        dst = dst - 1
    if dst < 0:
        dst = 0
    _insert_widget(pi, cast[uint64](dst), k)
    move_active = 0
    move_slot = -1
    _save_config()


# ====================================================================
# MULTI-PANEL DRIVER
# ====================================================================

# Per-panel live runtime state (parallel to the config arrays).
pw_wid:   Array[4, int32]
pw_ctl:   Array[256, uint8]          # 4 * 64
pw_ev:    Array[256, uint8]          # 4 * 64
pw_menu:  Array[4, int32]            # menu_open per panel
pw_geoh:  Array[4, int64]            # last applied window cross-axis size
_wait_efds: Array[4, int32]          # per-iter /event fds parked on by sys_waitfds


def pw_ctl_ptr(i: uint64) -> Ptr[char]:
    return cast[Ptr[char]](cast[uint64](&pw_ctl[0]) + i * 64)


def pw_ev_ptr(i: uint64) -> Ptr[char]:
    return cast[Ptr[char]](cast[uint64](&pw_ev[0]) + i * 64)


# Load this panel's config into the cur_* render registers.
# Cross-axis grow (px) a panel's window needs for any open popup: the Apps
# dropdown (when the menu widget exists + is open) and/or the right-click
# context menu (when open on THIS panel). Take the larger so whichever popup
# is showing fits. horiz controls which popup dimension is the cross axis
# (MENU_H/CTX height for horizontal panels, MENU_W/CTX_W for vertical).
def _panel_grow_px(pi: uint64, horiz: int32) -> int64:
    g: int64 = 0
    mopen: int32 = pw_menu[pi]
    has_menu: int32 = 0
    nw: uint64 = p_nwidg[pi]
    b: uint64 = 0
    while b < nw:
        if p_wkind[pi * MAX_WIDGETS + b] == WK_MENU:
            has_menu = 1
        b = b + 1
    if mopen != 0 and has_menu != 0:
        if horiz != 0:
            g = MENU_H
        else:
            g = MENU_W
    if ctx_open != 0 and ctx_panel == pi:
        cg: int64 = 0
        if horiz != 0:
            cg = ctx_box_h()
        else:
            cg = CTX_W
        if cg > g:
            g = cg
    return g


def _select_panel(pi: uint64, sw: int64, sh: int64):
    cur_edge = p_edge[pi]
    cur_bold = p_bold[pi]
    cur_thick = p_size[pi]
    cur_panel_idx = pi
    if cur_edge == EDGE_LEFT or cur_edge == EDGE_RIGHT:
        cur_horiz = 0
    else:
        cur_horiz = 1
    menu_open = pw_menu[pi]
    # copy widget kinds into the working list
    n_widg = p_nwidg[pi]
    a: uint64 = 0
    while a < n_widg:
        wkind_cur[a] = p_wkind[pi * MAX_WIDGETS + a]
        a = a + 1
    # window content size: thick + whatever popup grow this panel needs.
    grow: int64 = _panel_grow_px(pi, cur_horiz)
    if cur_horiz != 0:
        cur_sw = sw
        cur_sh = cur_thick + grow
    else:
        cur_sh = sh
        cur_sw = cur_thick + grow


# Compute the bar's cross-axis offset within the window + the window's
# screen origin; write the geometry ctl only when do_apply != 0 (so a plain
# content redraw can fetch the bar offset WITHOUT a redundant geometry write
# every tick — keeping the flicker gate quiet). Returns the bar offset.
def _panel_geometry(pi: uint64, sw: int64, sh: int64, do_apply: int32) -> int64:
    edge: int32 = p_edge[pi]
    horiz: int32 = 1
    if edge == EDGE_LEFT or edge == EDGE_RIGHT:
        horiz = 0
    thick: int64 = p_size[pi]
    grow: int64 = _panel_grow_px(pi, horiz)
    win_w: int64 = sw
    win_h: int64 = thick
    ox: int64 = 0
    oy: int64 = 0
    bar: int64 = 0
    if horiz != 0:
        win_w = sw
        win_h = thick + grow
        if edge == EDGE_BOTTOM:
            # bar pinned to screen bottom; popups grow upward (above the bar)
            oy = sh - (thick + grow)
            bar = grow                       # bar sits below any popup band
        else:
            oy = 0
            bar = 0
        if oy < 0:
            oy = 0
    else:
        win_w = thick + grow
        win_h = sh
        if edge == EDGE_RIGHT:
            # bar pinned to screen right; popups grow leftward (inside edge)
            ox = sw - (thick + grow)
            bar = grow
        else:
            ox = 0
            bar = 0
        if ox < 0:
            ox = 0
    if do_apply != 0:
        _set_geometry_xy(pw_ctl_ptr(pi), ox, oy, win_w, win_h)
    return bar


# Apply geometry (writes the ctl). Returns bar offset.
def _apply_panel_geometry(pi: uint64, sw: int64, sh: int64) -> int64:
    return _panel_geometry(pi, sw, sh, 1)


# Render + commit one panel. Geometry is applied separately (init / reload /
# menu toggle); here we only fetch the bar offset + emit content so a routine
# tick redraw doesn't write the geometry ctl needlessly.
def _redraw_panel(pi: uint64, sw: int64, sh: int64, btime: uint64):
    bar: int64 = _panel_geometry(pi, sw, sh, 0)
    _select_panel(pi, sw, sh)
    _layout_panel()
    _emit_panel(bar, btime)
    hamscene_commit(pw_wid[pi])


_drain_evbuf: Array[256, uint8]
def _drain_events(pi: uint64, sw: int64, sh: int64) -> int32:
    need_redraw: int32 = 0
    efd: int32 = sys_open(cast[Ptr[char]](pw_ev_ptr(pi)))
    if efd < 0:
        return 0
    r: int64 = sys_read(efd, &_drain_evbuf[0], 255)
    sys_close(efd)
    if r <= 0:
        return 0
    # set up cur_* + layout so hit-test uses this panel's geometry. Record
    # the pre-click menu/ctx state so a toggle below can resize the window.
    pre_menu: int32 = pw_menu[pi]
    pre_ctx_open: int32 = ctx_open
    pre_ctx_h: int64 = 0
    if ctx_open != 0 and ctx_panel == pi:
        pre_ctx_h = ctx_box_h()
    bar: int64 = _panel_geometry(pi, sw, sh, 0)
    _select_panel(pi, sw, sh)
    _layout_panel()
    i: uint64 = 0
    while i < cast[uint64](r):
        if _drain_evbuf[i] == 102 and i + 1 < cast[uint64](r) \
                and _drain_evbuf[i+1] == 32:               # "f "
            if i + 4 < cast[uint64](r) and _drain_evbuf[i+2] == 111 \
                    and _drain_evbuf[i+3] == 117 \
                    and _drain_evbuf[i+4] == 116:          # "out"
                if menu_open != 0:
                    menu_open = 0
                    need_redraw = 1
            while i < cast[uint64](r) and _drain_evbuf[i] != 10:
                i = i + 1
            i = i + 1
            continue
        if _drain_evbuf[i] == 109 and i + 1 < cast[uint64](r) \
                and _drain_evbuf[i+1] == 32:               # "m "
            j: uint64 = i + 2
            xneg: int32 = 0
            if j < cast[uint64](r) and _drain_evbuf[j] == 45:
                xneg = 1
                j = j + 1
            xv: int64 = 0
            while j < cast[uint64](r) and _drain_evbuf[j] >= 48 and _drain_evbuf[j] <= 57:
                xv = xv * 10 + cast[int64](_drain_evbuf[j]) - 48
                j = j + 1
            if xneg != 0:
                xv = 0 - xv
            if j < cast[uint64](r) and _drain_evbuf[j] == 32:
                j = j + 1
            yneg: int32 = 0
            if j < cast[uint64](r) and _drain_evbuf[j] == 45:
                yneg = 1
                j = j + 1
            yv: int64 = 0
            while j < cast[uint64](r) and _drain_evbuf[j] >= 48 and _drain_evbuf[j] <= 57:
                yv = yv * 10 + cast[int64](_drain_evbuf[j]) - 48
                j = j + 1
            if yneg != 0:
                yv = 0 - yv
            if j < cast[uint64](r) and _drain_evbuf[j] == 32:
                j = j + 1
            bv: int64 = 0
            while j < cast[uint64](r) and _drain_evbuf[j] >= 48 and _drain_evbuf[j] <= 57:
                bv = bv * 10 + cast[int64](_drain_evbuf[j]) - 48
                j = j + 1
            if bv != 0:
                if (bv & 2) != 0:
                    g_bv_right = 1
                else:
                    g_bv_right = 0
                if _handle_button(xv, yv, bar, pi) != 0:
                    need_redraw = 1
            i = j
        else:
            i = i + 1
    # persist this panel's menu state; if the menu OR the context menu toggled
    # (or the context menu changed height), the window must grow/shrink —
    # re-apply geometry so the popup room appears / the vacated band is
    # reclaimed before the content redraw.
    pw_menu[pi] = menu_open
    cur_ctx_h: int64 = 0
    if ctx_open != 0 and ctx_panel == pi:
        cur_ctx_h = ctx_box_h()
    if menu_open != pre_menu or ctx_open != pre_ctx_open or cur_ctx_h != pre_ctx_h:
        _apply_panel_geometry(pi, sw, sh)
        need_redraw = 1
    return need_redraw


# Helpers returning uint8* for _winpath (which writes bytes).
def pw_ctl_ptr_u8(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&pw_ctl[0]) + i * 64)


def pw_ev_ptr_u8(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&pw_ev[0]) + i * 64)


# Re-read the config and rebuild the panel set. The window COUNT may change;
# we reuse existing windows 1:1 by index where possible, allocate more on a
# grow, and collapse now-unused windows to a zero-size off-screen geometry on
# a shrink. The common Settings edits (edge / widgets / colour / size / font
# of the SAME panel count) reuse the same windows in place.
_reload_save_wid:  Array[4, int32]
_reload_save_menu: Array[4, int32]
def _reload_panels(sw: int64, sh: int64, btime: uint64):
    old_n: uint64 = n_panels
    k: uint64 = 0
    while k < old_n and k < MAX_PANELS:
        _reload_save_wid[k] = pw_wid[k]
        _reload_save_menu[k] = pw_menu[k]
        k = k + 1
    _load_config()
    pi: uint64 = 0
    while pi < n_panels:
        if pi < old_n:
            pw_wid[pi] = _reload_save_wid[pi]
            pw_menu[pi] = _reload_save_menu[pi]
        else:
            wid: int32 = _newwindow()
            pw_wid[pi] = wid
            pw_menu[pi] = 0
            if wid >= 0:
                _winpath(pw_ctl_ptr_u8(pi), wid, cast[Ptr[uint8]]("/ctl"))
                cfd2: int32 = sys_open_write(pw_ctl_ptr(pi))
                if cfd2 >= 0:
                    _writeall(cfd2, cast[Ptr[uint8]]("decorate 0\n"))
                    sys_close(cfd2)
                cfd3: int32 = sys_open_write(pw_ctl_ptr(pi))
                if cfd3 >= 0:
                    _writeall(cfd3, cast[Ptr[uint8]]("z 100\n"))
                    sys_close(cfd3)
        _winpath(pw_ctl_ptr_u8(pi), pw_wid[pi], cast[Ptr[uint8]]("/ctl"))
        _winpath(pw_ev_ptr_u8(pi), pw_wid[pi], cast[Ptr[uint8]]("/event"))
        _apply_panel_geometry(pi, sw, sh)
        pi = pi + 1
    # Collapse any windows the new config no longer uses (shrink) to a
    # zero-size off-screen geometry so they leave no chrome on screen.
    while pi < old_n and pi < MAX_PANELS:
        hidep: Array[64, uint8]
        _winpath(&hidep[0], _reload_save_wid[pi], cast[Ptr[uint8]]("/ctl"))
        _set_geometry_xy(cast[Ptr[char]](&hidep[0]), 0, 0, 0, 0)
        pi = pi + 1


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    sw: int64 = _screen_width()
    sh: int64 = _screen_height()

    _cfg_changed()
    _load_config()

    btime: uint64 = _read_btime()

    # Allocate a window per panel + set chrome (decorate 0, z 100).
    pi: uint64 = 0
    while pi < n_panels:
        wid: int32 = _newwindow()
        if wid < 0:
            _writeall(1, cast[Ptr[uint8]]("[panel] FAIL newwindow\n"))
            return 1
        pw_wid[pi] = wid
        pw_menu[pi] = 0
        _winpath(pw_ctl_ptr_u8(pi), wid, cast[Ptr[uint8]]("/ctl"))
        _winpath(pw_ev_ptr_u8(pi), wid, cast[Ptr[uint8]]("/event"))
        _apply_panel_geometry(pi, sw, sh)
        cfd2: int32 = sys_open_write(pw_ctl_ptr(pi))
        if cfd2 >= 0:
            _writeall(cfd2, cast[Ptr[uint8]]("decorate 0\n"))
            sys_close(cfd2)
        cfd3: int32 = sys_open_write(pw_ctl_ptr(pi))
        if cfd3 >= 0:
            _writeall(cfd3, cast[Ptr[uint8]]("z 100\n"))
            sys_close(cfd3)
        pi = pi + 1

    _writeall(1, cast[Ptr[uint8]]("[panel] scene windows ready\n"))

    # First frame for every panel.
    _refresh_windows()
    pi = 0
    while pi < n_panels:
        _redraw_panel(pi, sw, sh, btime)
        pi = pi + 1

    last_minute: uint64 = 9999
    last_ntasks: uint64 = 99
    sysmon_tick: uint64 = 0
    SAMPLE_TICKS: uint64 = 20
    cfg_tick: uint64 = 0
    # Poll the panel config EVERY loop iteration (was every 8). A Settings
    # widget Move/Up/Down/Add/Del writes /tmp/hamnix-panel.conf and the panel
    # must reflect it on the very next wake so the reorder is visibly LIVE (no
    # extra click). Combined with the short park timeout below the reload lands
    # within ~one frame of the Settings write.
    CFG_TICKS: uint64 = 1

    while True:
        any_redraw: int32 = 0

        # per-panel input
        pi = 0
        while pi < n_panels:
            if _drain_events(pi, sw, sh) != 0:
                _redraw_panel(pi, sw, sh, btime)
            pi = pi + 1

        # live config reload (re-allocates the panel set if needed)
        cfg_tick = cfg_tick + 1
        if cfg_tick >= CFG_TICKS:
            cfg_tick = 0
            if _cfg_changed() != 0:
                _reload_panels(sw, sh, btime)
                any_redraw = 1

        _refresh_windows()
        if n_tasks != last_ntasks:
            any_redraw = 1

        # Track the live workspace (pager lit cell) and drain the notification
        # bus (/dev/wsys/post): each new record spawns a toast, is logged to
        # the inbox history, and bumps the unread badge. A change in either
        # repaints the panels.
        prev_ws: int64 = cur_ws
        prev_unread: int64 = notif_unread
        _poll_workspace()
        if _drain_notifications() != 0:
            any_redraw = 1
        if cur_ws != prev_ws or notif_unread != prev_unread:
            any_redraw = 1

        sod: uint64 = _now_secs_of_day(btime)
        minute: uint64 = sod / 60
        if minute != last_minute:
            any_redraw = 1

        sysmon_tick = sysmon_tick + 1
        if sysmon_tick >= SAMPLE_TICKS:
            sysmon_tick = 0
            any_redraw = 1

        if any_redraw != 0:
            pi = 0
            while pi < n_panels:
                _redraw_panel(pi, sw, sh, btime)
                pi = pi + 1
            last_minute = minute
            last_ntasks = n_tasks

        # Park (instead of busy-spinning sys_yield) until a panel event
        # arrives or the resample cadence (~30ms) lapses. Opening the
        # /event fds fresh each iteration keeps us robust across a live
        # config reload that re-allocates the panel set (pw_wid changes);
        # the open cost is negligible — it was the SPIN that pegged a core
        # at 100%. sys_waitfds sleeps the task OFF the runqueue: an idle
        # panel now sits at ~0% CPU and still wakes instantly on input
        # (devwsys_event_write -> waitfds_notify) or after the timeout for
        # the once-a-second clock/sysmon refresh.
        nwf: uint64 = 0
        pi = 0
        while pi < n_panels and nwf < 4:
            efd2: int32 = sys_open(pw_ev_ptr(pi))
            if efd2 >= 0:
                _wait_efds[nwf] = efd2
                nwf = nwf + 1
            pi = pi + 1
        if nwf == 0:
            s2: uint64 = sys_get_jiffies()
            while sys_get_jiffies() - s2 < 3:
                sys_yield()
        else:
            # ~16ms timeout: long enough that an idle panel sits near 0% CPU
            # (it still wakes instantly on input via waitfds_notify), short
            # enough that a Settings config write (which doesn't poke our event
            # fds) is picked up by the per-iteration _cfg_changed poll within
            # one frame — so a widget reorder shows on the LIVE panel at once.
            sys_waitfds(&_wait_efds[0], nwf, 16)
            wi: uint64 = 0
            while wi < nwf:
                sys_close(_wait_efds[wi])
                wi = wi + 1
    return 0

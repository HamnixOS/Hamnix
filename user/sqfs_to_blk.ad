# user/sqfs_to_blk.ad
#
# Stream a file out of an in-RAM squashfs onto a block device, entirely
# in the kernel — the installer's "no media read" primitive.
#
# Usage:
#   sqfs_to_blk <sqfs_file> <inner_file> <dst_blockdev>
#   sqfs_to_blk /rootfs.sqfs /rootfs.ext4 /dev/blk/nvme0n1p2
#   sqfs_to_blk /rootfs.sqfs /esp.img     nvme0n1p1
#
# WHY THIS EXISTS. The four-step UEFI installer (etc/install_nvme.hamsh)
# must source its ext4 rootfs + ESP payloads from a squashfs that the
# FIRMWARE loaded into RAM as part of the install-media cpio — NEVER from
# the install media's own block device. On a real NUC the install media
# is a USB stick whose native driver is broken, so any runtime media read
# would defeat the whole in-RAM installer model. dd_blk reads a media
# partition; this tool reads the in-RAM squashfs instead.
#
# Plan-9 native control surface: there is no syscall for squashfs. This
# tool just opens the global /dev/loop/ctl cdev and writes one verb line:
#
#   sqfs_extract <sqfs_file> <inner_file> <dst_name>\n
#
# The kernel (drivers/block/loop.ad::loop_sqfs_extract) does the work:
# loop-attach the squashfs file, sqfs_mount it, look up the inner file,
# and stream sqfs_read -> blk_write_sectors onto the destination. The
# only block READ is from the loop-backed in-RAM squashfs (cpio data in
# RAM); the only block WRITE is to the destination (the NVMe target).
#
# The destination argument is accepted in either form — a bare block name
# (nvme0n1p2) or a /dev/blk/<name> path — and the /dev/blk/ prefix is
# stripped so the kernel's find_blockdev sees the bare name.

extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def _append(dst: Ptr[uint8], at: uint64, src: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while src[i] != 0:
        dst[at] = src[i]
        at = at + 1
        i = i + 1
    return at


def _strip_blk_prefix(s: Ptr[uint8]) -> Ptr[uint8]:
    # If `s` begins with "/dev/blk/", return a pointer past that prefix so
    # the kernel's find_blockdev sees the bare device name (nvme0n1p2).
    prefix: Ptr[uint8] = "/dev/blk/"
    i: uint64 = 0
    while prefix[i] != 0:
        if s[i] != prefix[i]:
            return s
        i = i + 1
    return cast[Ptr[uint8]](cast[uint64](s) + i)


# A verb line is "sqfs_extract <a> <b> <c>\n"; the three tokens are cpio/
# ext4 paths bounded by the path limit, so 1024 bytes is comfortable.
ctl_line: Array[1024, uint8]


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        write_str(2, "sqfs_to_blk: usage: sqfs_to_blk <sqfs_file> "
                     "<inner_file> <dst_blockdev>\n")
        return 1
    sqfs_file:  Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    inner_file: Ptr[uint8] = cast[Ptr[uint8]](argv[2])
    dst_raw:    Ptr[uint8] = cast[Ptr[uint8]](argv[3])
    dst_name:   Ptr[uint8] = _strip_blk_prefix(dst_raw)

    at: uint64 = 0
    at = _append(&ctl_line[0], at, "sqfs_extract ")
    at = _append(&ctl_line[0], at, sqfs_file)
    ctl_line[at] = 32                              # ' '
    at = at + 1
    at = _append(&ctl_line[0], at, inner_file)
    ctl_line[at] = 32                              # ' '
    at = at + 1
    at = _append(&ctl_line[0], at, dst_name)
    ctl_line[at] = 10                              # '\n'
    at = at + 1

    write_str(1, "sqfs_to_blk: extracting ")
    write_str(1, inner_file)
    write_str(1, " from ")
    write_str(1, sqfs_file)
    write_str(1, " -> ")
    write_str(1, dst_raw)
    write_str(1, "\n")

    fd: int32 = sys_open_write("/dev/loop/ctl")
    if fd < 0:
        write_str(2, "sqfs_to_blk: cannot open /dev/loop/ctl\n")
        return 1
    w: int64 = sys_write(fd, &ctl_line[0], at)
    sys_close(fd)
    if w < 0:
        write_str(2, "sqfs_to_blk: extract failed (kernel rejected verb)\n")
        return 1
    write_str(1, "sqfs_to_blk: OK\n")
    return 0

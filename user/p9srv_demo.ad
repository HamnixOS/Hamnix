# user/p9srv_demo.ad
#
# V4 / Phase D demo: minimum-viable userspace 9P2000 file server.
#
# WHAT THIS IS
# ------------
# A tiny test-fixture server that proves the userspace ↔ kernel 9P
# loop closes end-to-end. It is NOT rio. It is NOT a window system.
# It is a 150-line stub that exposes exactly one synthetic file:
#
#   /         QTDIR  qid.path=1   (the root)
#   /hello    QTFILE qid.path=2   →  "p9demo says hi\n"  (15 bytes)
#
# WIRE TRANSPORT
# --------------
# fd 0 (stdin)  : we READ incoming T-messages here.
# fd 1 (stdout) : we WRITE outgoing R-messages here.
# fd 2 (stderr) : diagnostic banners only — never 9P bytes.
#
# The expected launch shape is from tests/test_p9srv_demo.ad:
#
#   sys_pipe(c2s)        # client→server T-msg pipe
#   sys_pipe(s2c)        # server→client R-msg pipe
#   sys_spawn("/bin/p9srv_demo", argv, c2s_rfd, s2c_wfd, envp)
#
# sys_spawn dup's c2s_rfd → child fd 0 and s2c_wfd → child fd 1, so
# this binary reads T-msgs from stdin and emits R-msgs to stdout.
# That is the SAME shape the kernel's 9P client would use if it were
# pointed at a real bidirectional srvfd; we just split it into two
# pipes today because Hamnix has no socketpair yet.
#
# DISPATCH
# --------
# Reads one T-msg per iteration (size[4] header, then the body),
# decodes the type, builds the matching R-msg using lib/9p/9p.ad's
# emitters, and writes it back. Supported types:
#
#   Tversion → Rversion("9P2000", msize=8192)
#   Tattach  → Rattach (root qid, type=DMDIR, vers=0, path=1)
#   Twalk    → Rwalk for the single-component walk "hello" only;
#              anything else surfaces an Rerror.
#   Topen    → Ropen (file qid, iounit=0)
#   Tread    → Rread carrying "p9demo says hi\n" (offset 0); EOF on
#              offset ≥ 15.
#   Tclunk   → Rclunk
#   anything else → Rerror "not implemented"
#
# FID TRACKING
# ------------
# This server is stateless: it doesn't enforce that the fid presented
# at Topen/Tread matches the fid Twalk produced. The test fixture
# only drives one fid at a time so this is fine; a real server would
# need a per-fid table. The brief explicitly says "single-fid root +
# single-fid /hello is enough."
#
# TERMINATION
# -----------
# When the client closes its end of the T-msg pipe, our next pipe_read
# returns 0 (EOF); the loop exits and the program returns. The test
# fixture sequences this by closing c2s_wfd after sending its final
# Tclunk and waiting on the child.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       user/p9srv_demo.ad -o build/user/p9srv_demo.elf
#   scripts/build_user.sh's auto-discovery already lists it.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)

from lib.9p.9p import (
    P9Cursor, p9_cursor_init,
    p9_decode_header,
    p9_decode_tversion, p9_emit_rversion,
    p9_decode_tattach,  p9_emit_rattach,
    p9_decode_twalk,    p9_emit_rwalk,
    p9_decode_topen,    p9_emit_ropen,
    p9_decode_tread,    p9_emit_rread,
    p9_decode_tclunk,   p9_emit_rclunk,
    p9_emit_rerror,
    P9_QTDIR, P9_QTFILE,
    P9_TVERSION, P9_TATTACH, P9_TWALK, P9_TOPEN,
    P9_TREAD, P9_TCLUNK,
)

# 9P scratch buffer. msize=8192 is the codec default; the test fixture
# never asks for anything larger and we don't grow on demand. Top-
# level Array (nested-frame quirk avoidance).
SRV_BUF_CAP: uint64 = 8192
srv_buf: Array[8192, uint8]

# Payload for /hello — "p9demo says hi\n" (15 bytes).
hello_bytes: Array[16, uint8]
hello_len: uint64 = 15

# Twalk decode scratch (top-level — wnames + wlens arrays sized to the
# codec's P9_MAX_WELEM cap of 16). We only honour the single-component
# walk "hello"; longer walks land on Rerror.
walk_wnames: Array[16, Ptr[uint8]]
walk_wlens:  Array[16, uint64]
walk_qtypes: Array[16, uint8]
walk_qvers:  Array[16, uint32]
walk_qpaths: Array[16, uint64]


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def init_hello_payload():
    # "p9demo says hi\n" — written byte-by-byte because Adder has no
    # string concat and we want the array to live at module scope.
    hello_bytes[0]  = 112    # 'p'
    hello_bytes[1]  = 57     # '9'
    hello_bytes[2]  = 100    # 'd'
    hello_bytes[3]  = 101    # 'e'
    hello_bytes[4]  = 109    # 'm'
    hello_bytes[5]  = 111    # 'o'
    hello_bytes[6]  = 32     # ' '
    hello_bytes[7]  = 115    # 's'
    hello_bytes[8]  = 97     # 'a'
    hello_bytes[9]  = 121    # 'y'
    hello_bytes[10] = 115    # 's'
    hello_bytes[11] = 32     # ' '
    hello_bytes[12] = 104    # 'h'
    hello_bytes[13] = 105    # 'i'
    hello_bytes[14] = 10     # '\n'


def _read_exact(fd: int32, buf: Ptr[uint8], want: uint64) -> int64:
    # pipe_read may short-return; loop until we have `want` bytes or
    # see EOF (n == 0) / error (n < 0). Returns total bytes read, 0
    # on a clean EOF before any bytes, or a negative passthrough.
    got: uint64 = 0
    while got < want:
        n: int64 = sys_read(fd, &buf[got], want - got)
        if n < 0:
            return n
        if n == 0:
            return cast[int64](got)
        got = got + cast[uint64](n)
    return cast[int64](got)


def _peek_size(buf: Ptr[uint8]) -> uint32:
    # size[4] is the first 4 bytes, little-endian.
    b0: uint64 = cast[uint64](buf[0])
    b1: uint64 = cast[uint64](buf[1])
    b2: uint64 = cast[uint64](buf[2])
    b3: uint64 = cast[uint64](buf[3])
    return cast[uint32](b0 | (b1 << 8) | (b2 << 16) | (b3 << 24))


def _send_rmsg(n: int32) -> int32:
    if n <= 0:
        return -1
    sent: int64 = sys_write(1, &srv_buf[0], cast[uint64](n))
    if sent != cast[int64](n):
        return -1
    return 0


# --- Tversion → Rversion ----------------------------------------------

def _serve_tversion(in_len: uint64) -> int32:
    tg: uint16 = 0
    ms: uint32 = 0
    ver_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    ver_len: uint64 = 0
    rc: int64 = p9_decode_tversion(&srv_buf[0], in_len,
                                   &tg, &ms, &ver_ptr, &ver_len)
    if rc < cast[int64](0):
        return -1
    reply_ms: uint32 = ms
    if reply_ms > cast[uint32](SRV_BUF_CAP):
        reply_ms = cast[uint32](SRV_BUF_CAP)
    ver: Array[8, uint8]
    ver[0] = 57    # '9'
    ver[1] = 80    # 'P'
    ver[2] = 50    # '2'
    ver[3] = 48    # '0'
    ver[4] = 48
    ver[5] = 48
    c: P9Cursor
    p9_cursor_init(&c, &srv_buf[0], SRV_BUF_CAP)
    n: int32 = p9_emit_rversion(&c, tg, reply_ms, &ver[0], 6)
    if n < 0:
        return -1
    return _send_rmsg(n)


# --- Tattach → Rattach ------------------------------------------------

def _serve_tattach(in_len: uint64) -> int32:
    tg: uint16 = 0
    fid: uint32 = 0
    afid: uint32 = 0
    uname_p: Ptr[uint8] = cast[Ptr[uint8]](0)
    uname_l: uint64 = 0
    aname_p: Ptr[uint8] = cast[Ptr[uint8]](0)
    aname_l: uint64 = 0
    rc: int64 = p9_decode_tattach(&srv_buf[0], in_len,
                                  &tg, &fid, &afid,
                                  &uname_p, &uname_l,
                                  &aname_p, &aname_l)
    if rc < cast[int64](0):
        return -1
    # Root qid: DMDIR, vers=0, path=1.
    c: P9Cursor
    p9_cursor_init(&c, &srv_buf[0], SRV_BUF_CAP)
    n: int32 = p9_emit_rattach(&c, tg, P9_QTDIR, 0, 1)
    if n < 0:
        return -1
    return _send_rmsg(n)


# --- Twalk → Rwalk ----------------------------------------------------

def _serve_twalk(in_len: uint64) -> int32:
    tg: uint16 = 0
    fid: uint32 = 0
    newfid: uint32 = 0
    nwname: uint16 = 0
    rc: int64 = p9_decode_twalk(&srv_buf[0], in_len,
                                &tg, &fid, &newfid,
                                &nwname, &walk_wnames[0], &walk_wlens[0])
    if rc < cast[int64](0):
        return -1
    # Clone walk (nwname == 0): succeed with zero qids — the newfid
    # now references the same node as fid.
    if nwname == 0:
        c: P9Cursor
        p9_cursor_init(&c, &srv_buf[0], SRV_BUF_CAP)
        nout: int32 = p9_emit_rwalk(&c, tg, 0,
                                    &walk_qtypes[0], &walk_qvers[0],
                                    &walk_qpaths[0])
        if nout < 0:
            return -1
        return _send_rmsg(nout)
    # Only the single-component walk "hello" is honoured.
    if nwname != 1:
        return _emit_rerror(tg, "p9demo: unknown path depth")
    name_p: Ptr[uint8] = walk_wnames[0]
    if walk_wlens[0] != 5:
        return _emit_rerror(tg, "p9demo: name not 'hello'")
    if name_p[0] != 104 or name_p[1] != 101 or name_p[2] != 108 \
            or name_p[3] != 108 or name_p[4] != 111:
        return _emit_rerror(tg, "p9demo: name not 'hello'")
    walk_qtypes[0] = P9_QTFILE
    walk_qvers[0]  = 0
    walk_qpaths[0] = 2                       # /hello
    c: P9Cursor
    p9_cursor_init(&c, &srv_buf[0], SRV_BUF_CAP)
    nout: int32 = p9_emit_rwalk(&c, tg, 1,
                                &walk_qtypes[0], &walk_qvers[0],
                                &walk_qpaths[0])
    if nout < 0:
        return -1
    return _send_rmsg(nout)


# --- Topen → Ropen ----------------------------------------------------

def _serve_topen(in_len: uint64) -> int32:
    tg: uint16 = 0
    fid: uint32 = 0
    mode: uint8 = 0
    rc: int64 = p9_decode_topen(&srv_buf[0], in_len,
                                &tg, &fid, &mode)
    if rc < cast[int64](0):
        return -1
    # We don't track which fid was walked to /hello — single-file server,
    # so any open succeeds against the file qid.
    c: P9Cursor
    p9_cursor_init(&c, &srv_buf[0], SRV_BUF_CAP)
    n: int32 = p9_emit_ropen(&c, tg, P9_QTFILE, 0, 2, 0)
    if n < 0:
        return -1
    return _send_rmsg(n)


# --- Tread → Rread ----------------------------------------------------

def _serve_tread(in_len: uint64) -> int32:
    tg: uint16 = 0
    fid: uint32 = 0
    offset: uint64 = 0
    count: uint32 = 0
    rc: int64 = p9_decode_tread(&srv_buf[0], in_len,
                                &tg, &fid, &offset, &count)
    if rc < cast[int64](0):
        return -1
    available: uint32 = 0
    if offset < hello_len:
        available = cast[uint32](hello_len - offset)
    if available > count:
        available = count
    data_ptr: Ptr[uint8] = &hello_bytes[0]
    if offset > 0 and offset < hello_len:
        data_ptr = &hello_bytes[offset]
    c: P9Cursor
    p9_cursor_init(&c, &srv_buf[0], SRV_BUF_CAP)
    n: int32 = p9_emit_rread(&c, tg, data_ptr, available)
    if n < 0:
        return -1
    return _send_rmsg(n)


# --- Tclunk → Rclunk --------------------------------------------------

def _serve_tclunk(in_len: uint64) -> int32:
    tg: uint16 = 0
    fid: uint32 = 0
    rc: int64 = p9_decode_tclunk(&srv_buf[0], in_len, &tg, &fid)
    if rc < cast[int64](0):
        return -1
    c: P9Cursor
    p9_cursor_init(&c, &srv_buf[0], SRV_BUF_CAP)
    n: int32 = p9_emit_rclunk(&c, tg)
    if n < 0:
        return -1
    return _send_rmsg(n)


# --- Rerror -----------------------------------------------------------

def _emit_rerror(tg: uint16, msg: Ptr[uint8]) -> int32:
    mlen: uint64 = 0
    while msg[mlen] != 0:
        mlen = mlen + 1
    c: P9Cursor
    p9_cursor_init(&c, &srv_buf[0], SRV_BUF_CAP)
    n: int32 = p9_emit_rerror(&c, tg, msg, mlen)
    if n < 0:
        return -1
    return _send_rmsg(n)


def _serve_unsupported(in_len: uint64) -> int32:
    # Pull the tag out of the header for the Rerror reply, then surface
    # a generic "not implemented" message.
    sz: uint32 = 0
    ty: uint8 = 0
    tg: uint16 = 0
    rc: int32 = p9_decode_header(&srv_buf[0], in_len, &sz, &ty, &tg)
    if rc != 0:
        return -1
    return _emit_rerror(tg, "p9demo: not implemented")


def _serve_one() -> int32:
    # Returns 1 on a normal serve, 0 on clean EOF on stdin (client
    # disconnected), -1 on any wire / decode error.
    # 1) Read the 7-byte header.
    h: int64 = _read_exact(0, &srv_buf[0], 7)
    if h == cast[int64](0):
        return 0                                   # EOF — peer closed
    if h != cast[int64](7):
        return -1
    sz: uint32 = _peek_size(&srv_buf[0])
    if cast[uint64](sz) < 7 or cast[uint64](sz) > SRV_BUF_CAP:
        return -1
    # 2) Read the body (sz - 7 bytes) right after the header.
    rest: uint64 = cast[uint64](sz) - 7
    if rest > 0:
        b: int64 = _read_exact(0, &srv_buf[7], rest)
        if b != cast[int64](rest):
            return -1
    # 3) Dispatch on type byte.
    in_len: uint64 = cast[uint64](sz)
    t: uint8 = srv_buf[4]
    if t == P9_TVERSION:
        if _serve_tversion(in_len) < 0:
            return -1
        return 1
    if t == P9_TATTACH:
        if _serve_tattach(in_len) < 0:
            return -1
        return 1
    if t == P9_TWALK:
        if _serve_twalk(in_len) < 0:
            return -1
        return 1
    if t == P9_TOPEN:
        if _serve_topen(in_len) < 0:
            return -1
        return 1
    if t == P9_TREAD:
        if _serve_tread(in_len) < 0:
            return -1
        return 1
    if t == P9_TCLUNK:
        if _serve_tclunk(in_len) < 0:
            return -1
        return 1
    if _serve_unsupported(in_len) < 0:
        return -1
    return 1


def main() -> int32:
    init_hello_payload()
    write_str(2, "[p9demo] server starting\n")
    # Serve until the client closes its end. Each iteration handles
    # exactly one T → R round trip. We log a diagnostic on the first
    # successful serve so the test fixture has a marker proving the
    # server got at least one Tversion through.
    served: int32 = 0
    while True:
        rc: int32 = _serve_one()
        if rc == 0:
            write_str(2, "[p9demo] EOF, exiting\n")
            return 0
        if rc < 0:
            write_str(2, "[p9demo] wire error, exiting\n")
            return 1
        if served == 0:
            write_str(2, "[p9demo] served first request\n")
            served = 1
    return 0

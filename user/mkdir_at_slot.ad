# user/mkdir_at_slot.ad
#
# Create a directory (mkdir -p) on a NOT-currently-mounted ext4
# partition via the /dev/blk/<dev>/ctl "mkdir" verb. This is the
# companion to install_file_to_slot for the multi-package installer:
# a package whose payload ships an EMPTY directory (a tar dir entry
# with no regular files under it) has no install_file to carry the
# parent-dir creation, so the directory must be materialised through
# the dedicated mkdir verb.
#
# The kernel side (sys/src/9/port/devblk.ad "mkdir" verb →
# fs/ext4.ad::ext4_mkdir_at_slot) save/restores the live ext4 singleton
# state around the call, so the running FS is unaffected. mkdir is
# idempotent (an already-existing directory is a success) and tolerant
# of a trailing '/' on the path — tar dir entries carry one
# (e.g. "usr/share/foo/").
#
# Usage:
#   /bin/mkdir_at_slot /dev/blk/vdbp2 usr/share/foo
#   /bin/mkdir_at_slot /dev/blk/vdbp2 usr/share/foo/      # trailing '/'
#
# Arguments:
#   argv[1]   target partition cdev (e.g. /dev/blk/vdbp2)
#   argv[2]   directory path on the ext4. May include '/' separators —
#             missing intermediate dirs are mkdir -p'd by the kernel.
#             A leading '/' is stripped (paths are partition-relative);
#             a trailing '/' is tolerated.
#
# Exit status: 0 on success, 1 on any error.

extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def strcpy(dst: Ptr[uint8], src: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while src[i] != 0:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0
    return i


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        write_str(2, "usage: mkdir_at_slot <devpath> <dir_path>\n")
        return 1
    devpath: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    dirpath: Ptr[uint8] = cast[Ptr[uint8]](argv[2])

    path_len: uint64 = strlen_u8(dirpath)
    if path_len == 0 or path_len > 1023:
        write_str(2, "mkdir_at_slot: bad dir path length\n")
        return 1

    # Build the "mkdir <path>\n" ctl message.
    line: Array[1088, uint8]
    pos: uint64 = 0
    pre: Ptr[uint8] = "mkdir "
    pi: uint64 = 0
    while pre[pi] != 0:
        line[pos] = pre[pi]
        pos = pos + 1
        pi = pi + 1
    j: uint64 = 0
    while j < path_len and pos < 1086:
        line[pos] = dirpath[j]
        pos = pos + 1
        j = j + 1
    line[pos] = 10                                # '\n'
    pos = pos + 1

    # Open <devpath>/ctl, single write, close.
    ctl_path: Array[64, uint8]
    dp_n: uint64 = strcpy(&ctl_path[0], devpath)
    suffix: Ptr[uint8] = "/ctl"
    sj: uint64 = 0
    while suffix[sj] != 0 and dp_n + sj < 63:
        ctl_path[dp_n + sj] = suffix[sj]
        sj = sj + 1
    ctl_path[dp_n + sj] = 0
    ctl_fd: int32 = sys_open_write(cast[Ptr[char]](&ctl_path[0]))
    if ctl_fd < 0:
        write_str(2, "mkdir_at_slot: cannot open ")
        write_str(2, &ctl_path[0])
        write_str(2, "\n")
        return 1
    wn: int64 = sys_write(ctl_fd, &line[0], pos)
    sys_close(ctl_fd)
    if wn < 0:
        write_str(2, "mkdir_at_slot: kernel mkdir rejected ")
        write_str(2, dirpath)
        write_str(2, "\n")
        return 1
    write_str(1, "mkdir_at_slot: ")
    write_str(1, devpath)
    write_str(1, " mkdir ")
    write_str(1, dirpath)
    write_str(1, " OK\n")
    return 0

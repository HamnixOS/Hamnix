# user/hamlogscene_host.ad — HOST driver + render harness for the Log Viewer
# scene app (built for x86_64-linux; runs on the dev host, no QEMU).
#
# Drives the SAME core the native app ships (lib/hamlogcore.ad): seeds a
# DETERMINISTIC block of kernel-log lines (a fixed stand-in for one /proc/kmsg
# read), renders the top-of-log page to a PPM a human/agent can LOOK at, then
# feeds scripted pointer clicks (page-down, tail) and re-renders the tailed
# page. Dumps the scene display list and counters for machine assertions.
# Reads argv, writes two PPMs — no sockets, no Plan 9.
#
# USAGE (built to build/host/hamlog_host):
#   hamlog_host TOP.ppm TAIL.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamlogcore import hamlog_clear, hamlog_add_text, hamlog_build_scene, \
    hamlog_click, hamlog_wheel, hamlog_count, hamlog_scroll, \
    ACT_LOG_TAIL, ACT_LOG_DOWN


obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hamlog_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


# A deterministic stand-in for one /proc/kmsg read: 60 numbered log lines so
# the top page and the tailed page render visibly-different content.
seed: Array[4096, uint8]


def _seed_log() -> uint64:
    p: uint64 = 0
    i: uint64 = 0
    while i < 60:
        pre: Ptr[uint8] = cast[Ptr[uint8]]("[    0.")
        k: uint64 = 0
        while pre[k] != 0:
            seed[p] = pre[k]
            p = p + 1
            k = k + 1
        # a 6-digit fractional timestamp derived from i
        d: uint64 = i * 137
        j: int32 = 5
        while j >= 0:
            seed[p + cast[uint64](j)] = cast[uint8](d % 10) + 48
            d = d / 10
            j = j - 1
        p = p + 6
        seed[p] = 93                                     # ']'
        seed[p+1] = 32
        p = p + 2
        lbl: Ptr[uint8] = cast[Ptr[uint8]]("hamnix: subsystem init line #")
        m: uint64 = 0
        while lbl[m] != 0:
            seed[p] = lbl[m]
            p = p + 1
            m = m + 1
        # line number
        if i >= 10:
            seed[p] = cast[uint8](i / 10) + 48
            p = p + 1
        seed[p] = cast[uint8](i % 10) + 48
        p = p + 1
        seed[p] = 10
        p = p + 1
        i = i + 1
    return p


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hamlog_host TOP.ppm TAIL.ppm\n"))
        _o_flush()
        return 2

    W: int32 = 568
    H: int32 = 360
    hamlog_clear()
    slen: uint64 = _seed_log()
    hamlog_add_text(&seed[0], slen)

    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))
    _o_str(cast[Ptr[uint8]]("PRIMS "))
    _o_dec(cast[int64](prims))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("COUNT "))
    _o_dec(cast[int64](hamlog_count()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SCROLL0 "))
    _o_dec(cast[int64](hamlog_scroll()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 4 4 "))
    _o_hexcol(hamui_host_pixel(4, 4))                  # title bar #3a6ea5
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 20 60 "))
    _o_hexcol(hamui_host_pixel(20, 60))                # dark console area
    _o_ch(10)
    _o_flush()
    _o_str(cast[Ptr[uint8]]("SCENE-TOP-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-TOP-END\n"))
    _o_flush()

    # ---- SCRIPTED INPUT: page-down once (BTN_X=536, DN_Y=306, 24x24) ----
    dn: int32 = hamlog_click(548, 316)
    _o_str(cast[Ptr[uint8]]("PAGEDOWN "))
    _o_dec(cast[int64](dn))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SCROLL1 "))
    _o_dec(cast[int64](hamlog_scroll()))
    _o_ch(10)
    # wheel up two notches (dz>0) scrolls toward older -> smaller offset
    hamlog_wheel(2)
    _o_str(cast[Ptr[uint8]]("SCROLL2 "))
    _o_dec(cast[int64](hamlog_scroll()))
    _o_ch(10)
    # tail button (BTN_X=536, TAIL_Y=170, 24x24) -> snap to newest page
    tl: int32 = hamlog_click(548, 182)
    _o_str(cast[Ptr[uint8]]("TAIL "))
    _o_dec(cast[int64](tl))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SCROLL3 "))
    _o_dec(cast[int64](hamlog_scroll()))
    _o_ch(10)

    prims2: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _o_str(cast[Ptr[uint8]]("PRIMS2 "))
    _o_dec(cast[int64](prims2))
    _o_ch(10)
    _o_flush()
    _o_str(cast[Ptr[uint8]]("SCENE-TAIL-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-TAIL-END\n"))
    _o_flush()
    return 0

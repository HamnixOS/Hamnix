# user/which.ad — locate a command on PATH.
#
# Walks the same hardcoded PATH hamsh uses (/bin, /sbin, /usr/bin)
# probing for each name via sys_open. Prints the first match's
# full path; exits 1 if no match for any name. Matches `which`
# from GNU/Linux at the smallest meaningful scope.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


# Same buffer + same dir list hamsh uses. Kept in sync by hand for
# now; a /proc/path-style introspection is the natural follow-up.
candidate: Array[256, uint8]


def _path_dir(i: uint32) -> Ptr[uint8]:
    if i == 0:
        return "/bin/"
    if i == 1:
        return "/sbin/"
    if i == 2:
        return "/usr/bin/"
    return cast[Ptr[uint8]](0)


def find_in_path(name: Ptr[uint8]) -> int32:
    # Try each PATH dir + name; return 1 on first hit. Prints the
    # resolved path on success.
    i: uint32 = 0
    while True:
        prefix: Ptr[uint8] = _path_dir(i)
        if cast[uint64](prefix) == 0:
            return 0
        pi: uint64 = 0
        while prefix[pi] != 0:
            candidate[pi] = prefix[pi]
            pi = pi + 1
        ni: uint64 = 0
        while name[ni] != 0:
            candidate[pi] = name[ni]
            pi = pi + 1
            ni = ni + 1
        candidate[pi] = 0
        fd: int32 = sys_open(cast[Ptr[char]](&candidate[0]))
        if fd >= 0:
            sys_close(fd)
            write_str(1, &candidate[0])
            sys_write(1, "\n", 1)
            return 1
        i = i + 1


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "usage: which NAME...\n")
        return 1
    failed: int32 = 0
    i: int32 = 1
    while i < argc:
        name: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](i)])
        if find_in_path(name) == 0:
            failed = 1
            write_str(2, "which: no ")
            write_str(2, name)
            write_str(2, " in PATH\n")
        i = i + 1
    return failed

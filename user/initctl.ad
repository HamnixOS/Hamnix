# user/initctl.ad — native runlevel-control command (installed as
# /bin/initctl, and aliased as /bin/telinit).
#
#   initctl <N>        request a transition to runlevel N
#   telinit <N>        (alias)
#
# RUNLEVELS
#   0   halt / poweroff   (drives /dev/reboot <- "poweroff")
#   1   single-user / maintenance
#   3   multi-user (the DEFAULT level) — start all enabled services
#   5   graphical (hamUI) bringup
#   6   reboot            (drives /dev/reboot <- "reboot")
#
# HOW IT WORKS
# The runlevel machinery lives in PID 1 (hamsh-as-init): it sources
# /etc/rc.d/rc.<N> in its own namespace so the level's binds/spawns
# persist. A non-PID-1 process can't do that directly, so initctl
# F2 #447 (Plan-9-shape retirement of SYS_SVC_CTL): writes a verb line
# to the in-kernel control file /proc/svc/ctl — same shape as
# /proc/<pid>/ctl `pri` writes. PID 1's supervisor drains the queue on
# its next idle tick. The SYS_SVC_CTL (296) syscall is still in place as
# a deprecated shim for legacy callers; new code uses the ctl file.
#
# When you are AT the PID-1 interactive prompt, hamsh also provides
# `init <N>` / `telinit <N>` as builtins that transition synchronously
# in-process — that path is preferred there. This binary is the
# out-of-process fallback (e.g. invoked from a script run by a child
# shell, or over ssh).

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32

# TODO net-item closure: switch to the shared perror helper so initctl
# surfaces the kernel-side cause (e.g. "ext4: ...", "tmpfs: ...") when
# the /proc/svc/ctl open / write fails, rather than the legacy bare
# "cannot open ..." line that hid the backend.
from lib.perror import perror


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def is_digits(s: Ptr[uint8]) -> int32:
    # 1 iff s is one-or-more decimal digits and nothing else.
    if s[0] == 0:
        return 0
    i: uint64 = 0
    while s[i] != 0:
        if s[i] < 48 or s[i] > 57:
            return 0
        i = i + 1
    return 1


# F2 #447: per-process scratch for the "runlevel <digit>\n" verb. The
# kernel-side svc_ctl_text_apply parser tokenises on whitespace, so we
# render the digit + newline into a small fixed buffer and write once.
initctl_verb_buf: Array[32, uint8]


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "usage: initctl <runlevel 0..6>\n")
        sys_exit(1)
        return 1
    lvl_str: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    if is_digits(lvl_str) == 0:
        write_str(2, "initctl: runlevel must be a single digit 0..6\n")
        sys_exit(1)
        return 1
    # Open the kernel control file. /proc/svc/ctl is write-only — a
    # read returns -1 + "ctl: not readable", per Plan 9 convention.
    fd: int32 = sys_open_write("/proc/svc/ctl")
    if fd < 0:
        perror("initctl: cannot open /proc/svc/ctl")
        sys_exit(1)
        return 1
    # Compose "runlevel <digit>\n" into the verb scratch.
    prefix: Ptr[uint8] = "runlevel "
    i: uint64 = 0
    while prefix[i] != 0:
        initctl_verb_buf[i] = prefix[i]
        i = i + 1
    j: uint64 = 0
    while lvl_str[j] != 0 and i + 1 < 32:
        initctl_verb_buf[i] = lvl_str[j]
        i = i + 1
        j = j + 1
    initctl_verb_buf[i] = 10                           # '\n'
    i = i + 1
    rc: int64 = sys_write(fd, &initctl_verb_buf[0], i)
    sys_close(fd)
    if rc < 0:
        perror("initctl: runlevel write to /proc/svc/ctl failed")
        sys_exit(1)
        return 1
    write_str(1, "initctl: runlevel ")
    write_str(1, lvl_str)
    write_str(1, " requested via /proc/svc/ctl\n")
    return 0

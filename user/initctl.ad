# user/initctl.ad — native runlevel-control command (installed as
# /bin/initctl, and aliased as /bin/telinit).
#
#   initctl <N>        request a transition to runlevel N
#   telinit <N>        (alias)
#
# RUNLEVELS
#   0   halt / poweroff   (drives /dev/reboot <- "poweroff")
#   1   single-user / maintenance
#   3   multi-user (the DEFAULT level) — start all enabled services
#   5   graphical (hamUI) bringup
#   6   reboot            (drives /dev/reboot <- "reboot")
#
# HOW IT WORKS
# The runlevel machinery lives in PID 1 (hamsh-as-init): it sources
# /etc/rc.d/rc.<N> in its own namespace so the level's binds/spawns
# persist. A non-PID-1 process can't do that directly, so initctl
# enqueues a runlevel request through the SYS_SVC_CTL mailbox (verb 6,
# the level digit passed as the name argument). PID 1's supervisor
# drains the queue on its next idle tick and performs the transition.
#
# When you are AT the PID-1 interactive prompt, hamsh also provides
# `init <N>` / `telinit <N>` as builtins that transition synchronously
# in-process — that path is preferred there. This binary is the
# out-of-process fallback (e.g. invoked from a script run by a child
# shell, or over ssh).

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)
extern def sys_svc_ctl(verb: int32, name: Ptr[uint8], cap: uint64) -> int64


CTL_RUNLEVEL: int32 = 6


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def is_digits(s: Ptr[uint8]) -> int32:
    # 1 iff s is one-or-more decimal digits and nothing else.
    if s[0] == 0:
        return 0
    i: uint64 = 0
    while s[i] != 0:
        if s[i] < 48 or s[i] > 57:
            return 0
        i = i + 1
    return 1


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "usage: initctl <runlevel 0..6>\n")
        sys_exit(1)
        return 1
    lvl_str: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    if is_digits(lvl_str) == 0:
        write_str(2, "initctl: runlevel must be a single digit 0..6\n")
        sys_exit(1)
        return 1
    rc: int64 = sys_svc_ctl(CTL_RUNLEVEL, lvl_str, 0)
    if rc < 0:
        write_str(2, "initctl: runlevel request failed\n")
        sys_exit(1)
        return 1
    write_str(1, "initctl: runlevel ")
    write_str(1, lvl_str)
    write_str(1, " requested\n")
    return 0

# user/comm.ad
#
# Hamnix `comm`: compare two SORTED files line by line and produce a
# three-column report:
#   column 1 : lines only in FILE1
#   column 2 : lines only in FILE2
#   column 3 : lines common to both
# Columns 2 and 3 are indented by one TAB per preceding column that is
# being printed (GNU's delimiter convention). Suppress any column with
# -1, -2 or -3 (which also removes the corresponding indentation for
# later columns), exactly like GNU coreutils.
#
# Usage:
#   comm [-1] [-2] [-3] FILE1 FILE2
#
# Both inputs MUST be sorted (`comm` does not sort); behaviour on
# unsorted input mirrors GNU's (it just diffs in lockstep). Each file
# is read fully into a bounded buffer.

# sys_open: the adder-user runtime thunk reads only %rdi (path) and opens
# read-only; the host (x86_64-linux) thunk is a raw open(2) needing
# flags/mode in %rsi/%rdx. Declaring all three args satisfies both — the
# kernel ignores the extras, the host gets O_RDONLY (flags=0, mode=0).
extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


FILE_CAP: uint64 = 16384

buf1: Array[16384, uint8]
buf2: Array[16384, uint8]
len1: uint64 = 0
len2: uint64 = 0
pos1: uint64 = 0
pos2: uint64 = 0

# Suppression flags (1 = suppress that column).
sup1: int32 = 0
sup2: int32 = 0
sup3: int32 = 0


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


# A path of "-" reads standard input (fd 0) instead of opening a file,
# matching GNU comm's stdin operand.
def is_dash(path: Ptr[char]) -> int32:
    p: Ptr[uint8] = cast[Ptr[uint8]](path)
    if p[0] == 45 and p[1] == 0:
        return 1
    return 0


def load_file(b: Ptr[uint8], path: Ptr[char]) -> int64:
    stdin: int32 = is_dash(path)
    fd: int32 = 0
    if stdin == 0:
        fd = sys_open(path, 0, 0)
        if fd < 0:
            write_str(2, "comm: cannot open ")
            write_str(2, cast[Ptr[uint8]](path))
            write_str(2, "\n")
            return -1
    total: uint64 = 0
    while total < FILE_CAP:
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
                                cast[uint64](b) + total),
                            FILE_CAP - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    if stdin == 0:
        sys_close(fd)
    return cast[int64](total)


# Find the end (exclusive of '\n') of the line starting at `pos` in a
# buffer of `len` bytes. Returns the content-end index; the caller
# advances past the newline separately.
def line_end(b: Ptr[uint8], len: uint64, pos: uint64) -> uint64:
    j: uint64 = pos
    while j < len and b[j] != 10:
        j = j + 1
    return j


# Compare two byte ranges. Returns <0, 0, >0 like strcmp (lexicographic
# on the unsigned bytes, shorter-as-prefix sorts first).
def range_cmp(a: Ptr[uint8], as_: uint64, ae: uint64,
              c: Ptr[uint8], cs: uint64, ce: uint64) -> int32:
    i: uint64 = as_
    k: uint64 = cs
    while i < ae and k < ce:
        if a[i] < c[k]:
            return -1
        if a[i] > c[k]:
            return 1
        i = i + 1
        k = k + 1
    alen: uint64 = ae - as_
    clen: uint64 = ce - cs
    if alen < clen:
        return -1
    if alen > clen:
        return 1
    return 0


# Emit one report row. `col` is 1, 2 or 3. `b`/`s`/`e` give the line
# bytes. Honors suppression + leading-TAB indentation.
def emit(col: int32, b: Ptr[uint8], s: uint64, e: uint64):
    if col == 1 and sup1 != 0:
        return
    if col == 2 and sup2 != 0:
        return
    if col == 3 and sup3 != 0:
        return
    # Number of TABs = count of NON-suppressed columns that come before
    # this one.
    tabs: int32 = 0
    if col >= 2 and sup1 == 0:
        tabs = tabs + 1
    if col >= 3 and sup2 == 0:
        tabs = tabs + 1
    t: int32 = 0
    while t < tabs:
        sys_write(1, "\t", 1)
        t = t + 1
    if e > s:
        sys_write(1, cast[Ptr[uint8]](cast[uint64](b) + s), e - s)
    sys_write(1, "\n", 1)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    f1: int32 = 0
    f2: int32 = 0
    ai: int32 = 1
    while ai < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
        if a[0] == 45 and a[1] != 0:
            k: uint64 = 1
            while a[k] != 0:
                c: uint8 = a[k]
                if c == 49:
                    sup1 = 1
                elif c == 50:
                    sup2 = 1
                elif c == 51:
                    sup3 = 1
                else:
                    write_str(2, "comm: unknown flag\n")
                    return 1
                k = k + 1
        else:
            if f1 == 0:
                f1 = ai
            elif f2 == 0:
                f2 = ai
        ai = ai + 1

    if f1 == 0 or f2 == 0:
        write_str(2, "comm: usage: comm [-123] FILE1 FILE2\n")
        return 1

    r1: int64 = load_file(&buf1[0], cast[Ptr[char]](argv[cast[uint64](f1)]))
    r2: int64 = load_file(&buf2[0], cast[Ptr[char]](argv[cast[uint64](f2)]))
    if r1 < 0 or r2 < 0:
        return 1
    len1 = cast[uint64](r1)
    len2 = cast[uint64](r2)

    pos1 = 0
    pos2 = 0
    while pos1 < len1 and pos2 < len2:
        e1: uint64 = line_end(&buf1[0], len1, pos1)
        e2: uint64 = line_end(&buf2[0], len2, pos2)
        cmp: int32 = range_cmp(&buf1[0], pos1, e1, &buf2[0], pos2, e2)
        if cmp < 0:
            emit(1, &buf1[0], pos1, e1)
            pos1 = e1
            if pos1 < len1:
                pos1 = pos1 + 1
        elif cmp > 0:
            emit(2, &buf2[0], pos2, e2)
            pos2 = e2
            if pos2 < len2:
                pos2 = pos2 + 1
        else:
            emit(3, &buf1[0], pos1, e1)
            pos1 = e1
            if pos1 < len1:
                pos1 = pos1 + 1
            pos2 = e2
            if pos2 < len2:
                pos2 = pos2 + 1

    # Drain whatever remains of file1 (column 1) ...
    while pos1 < len1:
        e1: uint64 = line_end(&buf1[0], len1, pos1)
        emit(1, &buf1[0], pos1, e1)
        pos1 = e1
        if pos1 < len1:
            pos1 = pos1 + 1
    # ... and file2 (column 2).
    while pos2 < len2:
        e2: uint64 = line_end(&buf2[0], len2, pos2)
        emit(2, &buf2[0], pos2, e2)
        pos2 = e2
        if pos2 < len2:
            pos2 = pos2 + 1
    return 0

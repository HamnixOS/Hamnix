# user/hamsettings.ad
#
# Scene-file DE Settings / Control-Center (MATE-parity) — a real, working
# settings app drawn as a scene display list (docs/de_scene_file_arch.md).
# It exposes two genuinely-functional preference groups:
#
#   APPEARANCE / WALLPAPER. A row of colour swatches. Clicking one writes a
#   solid-colour PPM (P6) to /tmp/hamnix-wallpaper.ppm and sets it as the
#   desktop wallpaper via the `wallpaper <path>` verb on /dev/wsys/ctl (the
#   compositor's image-backdrop path). The chosen swatch is highlighted.
#
#   PANEL. A Top / Bottom choice that rewrites /etc/panel.conf's `position`
#   line (read by hampanelscene at startup) plus a CPU/mem-monitor on/off
#   toggle (adds/removes the `right sysmon` applet line). A small note tells
#   the user these apply when the panel next starts.
#
# RENDER: a titled window with the two groups + a status line. INPUT (§11):
# pointer on /event hit-tests the swatches + toggles. No keyboard needed.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

from lib.hamui import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_stroke, hamscene_glyphs, hamscene_panel_button, hamscene_commit


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# ====================================================================
# WALLPAPER SWATCHES
# ====================================================================
N_SWATCH: uint64 = 6
# RGB triplets for each swatch (parallel arrays; index*3).
sw_r: Array[6, int32]
sw_g: Array[6, int32]
sw_b: Array[6, int32]
sw_hex: Array[60, uint8]               # 6 * 10 "#RRGGBB\0"


def sw_hex_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&sw_hex[0]) + i * 10)


def _set_swatch(i: uint64, r: int32, g: int32, b: int32, hx: Ptr[uint8]):
    sw_r[i] = r
    sw_g[i] = g
    sw_b[i] = b
    dp: Ptr[uint8] = sw_hex_ptr(i)
    k: uint64 = 0
    while hx[k] != 0:
        dp[k] = hx[k]
        k = k + 1
    dp[k] = 0


def _init_swatches():
    _set_swatch(0, 32, 80, 96, cast[Ptr[uint8]]("#205060"))    # teal (default)
    _set_swatch(1, 40, 44, 52, cast[Ptr[uint8]]("#282c34"))    # slate
    _set_swatch(2, 90, 60, 110, cast[Ptr[uint8]]("#5a3c6e"))   # plum
    _set_swatch(3, 60, 90, 60, cast[Ptr[uint8]]("#3c5a3c"))    # forest
    _set_swatch(4, 120, 80, 40, cast[Ptr[uint8]]("#785028"))   # umber
    _set_swatch(5, 30, 30, 30, cast[Ptr[uint8]]("#1e1e1e"))    # near-black


sel_swatch: int64 = 0


# Write a 64x48 solid-colour P6 PPM to /tmp/hamnix-wallpaper.ppm (the
# compositor tiles/scales the backdrop image; a tiny solid image is enough
# to recolour the whole desktop). Returns 1 on success.
ppm_buf: Array[9300, uint8]            # header + 64*48*3 = 9216 + slack
def _write_wallpaper_ppm(r: int32, g: int32, b: int32) -> int32:
    p: uint64 = 0
    hdr: Ptr[uint8] = cast[Ptr[uint8]]("P6\n64 48\n255\n")
    k: uint64 = 0
    while hdr[k] != 0:
        ppm_buf[p] = hdr[k]
        p = p + 1
        k = k + 1
    px: uint64 = 0
    npx: uint64 = 64 * 48
    while px < npx:
        ppm_buf[p] = cast[uint8](r)
        ppm_buf[p+1] = cast[uint8](g)
        ppm_buf[p+2] = cast[uint8](b)
        p = p + 3
        px = px + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/tmp/hamnix-wallpaper.ppm"))
    if fd < 0:
        return 0
    sys_write(fd, &ppm_buf[0], p)
    sys_close(fd)
    return 1


# Apply a swatch: write the PPM, then set it as wallpaper via /dev/wsys/ctl.
def _apply_wallpaper(i: uint64):
    if _write_wallpaper_ppm(sw_r[i], sw_g[i], sw_b[i]) == 0:
        return
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return
    _writeall(fd, cast[Ptr[uint8]]("wallpaper /tmp/hamnix-wallpaper.ppm\n"))
    sys_close(fd)
    _writeall(1, cast[Ptr[uint8]]("[hamsettings] wallpaper applied\n"))


# ====================================================================
# PANEL MODEL — full MATE-parity multi-panel preferences.
#
# Settings now models up to MAX_PANELS panels, each with its own edge,
# background colour, thickness (size), font weight, and an ORDERED list of
# widgets assigned to it. The user can:
#   * ADD a second (top+bottom) panel and REMOVE panels,
#   * pick each panel's edge / colour / size / font,
#   * ASSIGN each widget to a panel and reorder it (move a widget between
#     panels = MATE "drag widget onto another panel"),
# and Settings writes the whole multi-panel block-form config to the
# writable runtime override /tmp/hamnix-panel.conf, which hampanelscene
# live-reloads (no restart).
# ====================================================================
MAX_PANELS:  uint64 = 4
MAX_WIDGETS: uint64 = 8                 # per panel

# widget kinds (mirror hampanelscene WK_*)
WK_MENU:   int32 = 0
WK_TASKS:  int32 = 1
WK_CLOCK:  int32 = 2
WK_SYSMON: int32 = 3
WK_SPACER: int32 = 4
N_WK:      int32 = 5

# Per-panel model (struct-of-arrays).
pm_edge:  Array[4, int32]               # 0 top 1 bottom 2 left 3 right
pm_size:  Array[4, int32]               # thickness px
pm_bold:  Array[4, int32]               # 0 normal 1 bold
pm_color: Array[4, int32]               # index into the colour palette
pm_nwidg: Array[4, uint64]              # widget count per panel
pm_wkind: Array[32, int32]              # 4 * 8 widget kinds
n_panels: uint64 = 1

# Currently-selected panel in the editor.
sel_panel: int64 = 0
# Currently-selected widget slot within sel_panel (-1 = none).
sel_widget: int64 = -1

# A small panel-colour palette (distinct from the wallpaper swatches so the
# bar colour can be picked independently). Hex strings + an int32 RGB-ish key
# only used as the config token.
PAL_N: uint64 = 6
pal_hex: Array[60, uint8]               # 6 * 10
def pal_hex_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&pal_hex[0]) + i * 10)


def _set_pal(i: uint64, hx: Ptr[uint8]):
    dp: Ptr[uint8] = pal_hex_ptr(i)
    k: uint64 = 0
    while hx[k] != 0:
        dp[k] = hx[k]
        k = k + 1
    dp[k] = 0


def _init_palette():
    _set_pal(0, cast[Ptr[uint8]]("#d4d0c8"))    # classic grey (default)
    _set_pal(1, cast[Ptr[uint8]]("#c0c0c0"))    # silver
    _set_pal(2, cast[Ptr[uint8]]("#3a6ea5"))    # blue
    _set_pal(3, cast[Ptr[uint8]]("#404040"))    # dark
    _set_pal(4, cast[Ptr[uint8]]("#205060"))    # teal
    _set_pal(5, cast[Ptr[uint8]]("#785028"))    # umber


def _wk_name(k: int32) -> Ptr[uint8]:
    if k == WK_MENU:
        return cast[Ptr[uint8]]("menu")
    if k == WK_TASKS:
        return cast[Ptr[uint8]]("tasks")
    if k == WK_CLOCK:
        return cast[Ptr[uint8]]("clock")
    if k == WK_SYSMON:
        return cast[Ptr[uint8]]("sysmon")
    return cast[Ptr[uint8]]("spacer")


# Short 4-glyph add-widget chip labels (so each fits its 44px chip without
# clipping). Distinct from _wk_name (the config token) which stays full-length.
def _wk_addlabel(k: int32) -> Ptr[uint8]:
    if k == WK_MENU:
        return cast[Ptr[uint8]]("menu")
    if k == WK_TASKS:
        return cast[Ptr[uint8]]("task")
    if k == WK_CLOCK:
        return cast[Ptr[uint8]]("clok")
    if k == WK_SYSMON:
        return cast[Ptr[uint8]]("sysm")
    return cast[Ptr[uint8]]("spcr")


def _edge_token(e: int32) -> Ptr[uint8]:
    if e == 1:
        return cast[Ptr[uint8]]("bottom")
    if e == 2:
        return cast[Ptr[uint8]]("left")
    if e == 3:
        return cast[Ptr[uint8]]("right")
    return cast[Ptr[uint8]]("top")


def pm_w(p: uint64, slot: uint64) -> int32:
    return pm_wkind[p * MAX_WIDGETS + slot]


def pm_set_w(p: uint64, slot: uint64, k: int32):
    pm_wkind[p * MAX_WIDGETS + slot] = k


def _init_panel_model():
    # Default: one classic TOP panel [menu][tasks][sysmon][clock].
    n_panels = 1
    pm_edge[0] = 0
    pm_size[0] = 26
    pm_bold[0] = 0
    pm_color[0] = 0
    pm_nwidg[0] = 4
    pm_set_w(0, 0, WK_MENU)
    pm_set_w(0, 1, WK_TASKS)
    pm_set_w(0, 2, WK_SYSMON)
    pm_set_w(0, 3, WK_CLOCK)
    sel_panel = 0
    sel_widget = -1


def _add_panel():
    if n_panels >= MAX_PANELS:
        return
    i: uint64 = n_panels
    # A second panel defaults to the BOTTOM edge (classic MATE top+bottom);
    # further panels alternate so two adds give top+bottom without overlap.
    if i == 1:
        pm_edge[i] = 1                  # bottom
    elif i == 2:
        pm_edge[i] = 2                  # left
    else:
        pm_edge[i] = 3                  # right
    pm_size[i] = 26
    pm_bold[i] = 0
    pm_color[i] = 0
    pm_nwidg[i] = 1
    pm_set_w(i, 0, WK_TASKS)
    n_panels = n_panels + 1
    sel_panel = cast[int64](i)
    sel_widget = -1


def _remove_panel(p: uint64):
    # Never remove the last remaining panel.
    if n_panels <= 1 or p >= n_panels:
        return
    q: uint64 = p
    while q + 1 < n_panels:
        pm_edge[q] = pm_edge[q+1]
        pm_size[q] = pm_size[q+1]
        pm_bold[q] = pm_bold[q+1]
        pm_color[q] = pm_color[q+1]
        pm_nwidg[q] = pm_nwidg[q+1]
        s: uint64 = 0
        while s < MAX_WIDGETS:
            pm_set_w(q, s, pm_w(q+1, s))
            s = s + 1
        q = q + 1
    n_panels = n_panels - 1
    if sel_panel >= cast[int64](n_panels):
        sel_panel = cast[int64](n_panels) - 1
    sel_widget = -1


def _panel_add_widget(p: uint64, k: int32):
    if p >= n_panels:
        return
    nw: uint64 = pm_nwidg[p]
    if nw >= MAX_WIDGETS:
        return
    pm_set_w(p, nw, k)
    pm_nwidg[p] = nw + 1


def _panel_del_widget(p: uint64, slot: uint64):
    if p >= n_panels or slot >= pm_nwidg[p]:
        return
    s: uint64 = slot
    while s + 1 < pm_nwidg[p]:
        pm_set_w(p, s, pm_w(p, s+1))
        s = s + 1
    pm_nwidg[p] = pm_nwidg[p] - 1
    sel_widget = -1


# Move the selected widget from one panel to another (MATE drag-to-panel).
def _widget_move_panel(from_p: uint64, slot: uint64, to_p: uint64):
    if from_p >= n_panels or to_p >= n_panels or slot >= pm_nwidg[from_p]:
        return
    if pm_nwidg[to_p] >= MAX_WIDGETS:
        return
    k: int32 = pm_w(from_p, slot)
    _panel_del_widget(from_p, slot)
    _panel_add_widget(to_p, k)


# Reorder a widget within its panel (move up/down in the flow order).
def _widget_swap(p: uint64, a: uint64, b: uint64):
    if p >= n_panels or a >= pm_nwidg[p] or b >= pm_nwidg[p]:
        return
    t: int32 = pm_w(p, a)
    pm_set_w(p, a, pm_w(p, b))
    pm_set_w(p, b, t)


# Emit the whole multi-panel block-form config to the writable tmpfs override.
pconf_buf: Array[1024, uint8]
pconf_p: uint64 = 0
def _pconf_put(s: Ptr[uint8]):
    k: uint64 = 0
    while s[k] != 0:
        pconf_buf[pconf_p] = s[k]
        pconf_p = pconf_p + 1
        k = k + 1


def _pconf_put_dec(v: int32):
    pconf_p = pconf_p + _u64_to_dec(cast[uint64](v), &pconf_buf[pconf_p])


def _write_panel_conf():
    pconf_p = 0
    _pconf_put(cast[Ptr[uint8]]("# /tmp/hamnix-panel.conf (written by hamsettings)\n"))
    p: uint64 = 0
    while p < n_panels:
        _pconf_put(cast[Ptr[uint8]]("panel p"))
        _pconf_put_dec(cast[int32](p))
        _pconf_put(cast[Ptr[uint8]]("\n  edge "))
        _pconf_put(_edge_token(pm_edge[p]))
        _pconf_put(cast[Ptr[uint8]]("\n  color "))
        _pconf_put(pal_hex_ptr(cast[uint64](pm_color[p])))
        _pconf_put(cast[Ptr[uint8]]("\n  size "))
        _pconf_put_dec(pm_size[p])
        if pm_bold[p] != 0:
            _pconf_put(cast[Ptr[uint8]]("\n  font bold\n"))
        else:
            _pconf_put(cast[Ptr[uint8]]("\n  font normal\n"))
        s: uint64 = 0
        while s < pm_nwidg[p]:
            _pconf_put(cast[Ptr[uint8]]("  widget "))
            _pconf_put(_wk_name(pm_w(p, s)))
            _pconf_put(cast[Ptr[uint8]]("\n"))
            s = s + 1
        _pconf_put(cast[Ptr[uint8]]("end\n"))
        p = p + 1
    n: uint64 = pconf_p
    # Write the WRITABLE runtime override in tmpfs: the sysroot /etc is not
    # writable from the running DE, so a write to /etc/panel.conf is silently
    # dropped. The panel reads /tmp/hamnix-panel.conf in preference and
    # live-polls it, so this applies immediately.
    fd: int32 = sys_open_write(cast[Ptr[char]]("/tmp/hamnix-panel.conf"))
    if fd < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamsettings] WARN cannot write panel.conf\n"))
        return
    sys_write(fd, &pconf_buf[0], n)
    sys_close(fd)
    _writeall(1, cast[Ptr[uint8]]("[hamsettings] panel.conf updated\n"))


# ====================================================================
# LAYOUT + RENDER
# ====================================================================
WIN_W: int32 = 520
WIN_H: int32 = 500

SW_X: int32 = 16
SW_Y: int32 = 56
SW_SZ: int32 = 40
SW_GAP: int32 = 10
BTN_H: int32 = 24

# --- Panel-tab row (one tab per panel + an [+Add] tab) ------------------
TAB_Y: int32 = 130
TAB_W: int32 = 64
TAB_H: int32 = 26
TAB_X0: int32 = 16
TAB_GAP: int32 = 4
ADDTAB_W: int32 = 56
DELTAB_W: int32 = 56

# --- Per-panel edge row -------------------------------------------------
EDGE_BTN_Y: int32 = 188
EDGE_BTN_W: int32 = 64
EDGE_BTN_H: int32 = 24
EDGE_BTN_X0: int32 = 16
EDGE_BTN_GAP: int32 = 6

# --- Per-panel colour palette row ---------------------------------------
PCOL_Y: int32 = 240
PCOL_SZ: int32 = 28
PCOL_GAP: int32 = 8
PCOL_X0: int32 = 16

# --- Per-panel size slider (decrement / value / increment) + font -------
SIZE_Y: int32 = 286
SIZE_DEC_X: int32 = 16
SIZE_INC_X: int32 = 92
SIZE_BTN_W: int32 = 28
FONT_BTN_X: int32 = 200
FONT_BTN_W: int32 = 130

# --- Widget-assignment list (rows) + action buttons --------------------
WL_Y: int32 = 330
WL_ROW_H: int32 = 22
WL_X: int32 = 16
WL_W: int32 = 200
# Action buttons to the right of the widget list. The Up/Down/Del stack sits
# at WACT_X (60px wide); the Move + Add-widget controls live in a SECOND
# sub-column at WADD_X so the add-widget chips never draw on top of the
# move-up/down/del buttons (the old layout overlapped them).
WACT_X: int32 = 230
WADD_X: int32 = 300            # right sub-column: Move >> + Add-widget chips
ADD_CHIP_W: int32 = 36
ADD_CHIP_STEP: int32 = 40


def _tab_x(i: uint64) -> int32:
    return TAB_X0 + cast[int32](i) * (TAB_W + TAB_GAP)


def _edge_btn_x(i: int32) -> int32:
    return EDGE_BTN_X0 + i * (EDGE_BTN_W + EDGE_BTN_GAP)


def _pcol_x(i: uint64) -> int32:
    return PCOL_X0 + cast[int32](i) * (PCOL_SZ + PCOL_GAP)


def _swatch_x(i: uint64) -> int32:
    return SW_X + cast[int32](i) * (SW_SZ + SW_GAP)


def emit_scene(wid: int32):
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    hamscene_begin()
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#d4d0c8"))
    hamscene_fill(0, 0, WIN_W, 28, cast[Ptr[uint8]]("#3a6ea5"))
    hamscene_glyphs(12, 9, cast[Ptr[uint8]]("Settings"),
                    cast[Ptr[uint8]]("#ffffff"))

    # MATE-style etched group separators (dark-over-light 2px bevel) between
    # the Wallpaper / Panel-editor / Widget-list sections for a classic
    # control-centre look.
    hamscene_fill(8, 104, WIN_W - 16, 1, cast[Ptr[uint8]]("#a0a0a0"))
    hamscene_fill(8, 105, WIN_W - 16, 1, cast[Ptr[uint8]]("#ffffff"))
    hamscene_fill(8, 311, WIN_W - 16, 1, cast[Ptr[uint8]]("#a0a0a0"))
    hamscene_fill(8, 312, WIN_W - 16, 1, cast[Ptr[uint8]]("#ffffff"))

    # --- Wallpaper group ---
    hamscene_glyphs(SW_X, 40, cast[Ptr[uint8]]("Desktop wallpaper:"), fg)
    i: uint64 = 0
    while i < N_SWATCH:
        sx: int32 = _swatch_x(i)
        hamscene_fill(sx, SW_Y, SW_SZ, SW_SZ, sw_hex_ptr(i))
        bc: Ptr[uint8] = cast[Ptr[uint8]]("#606060")
        thick: int32 = 1
        if sel_swatch == cast[int64](i):
            bc = cast[Ptr[uint8]]("#ffd040")
            thick = 2
        hamscene_stroke(sx, SW_Y, SW_SZ, SW_SZ, thick, bc)
        i = i + 1

    # --- Panel tabs (select which panel to edit; +Add / Remove) ---
    hamscene_glyphs(TAB_X0, 112, cast[Ptr[uint8]]("Panels:"), fg)
    t: uint64 = 0
    while t < n_panels:
        tx: int32 = _tab_x(t)
        sunk: int32 = 0
        if sel_panel == cast[int64](t):
            sunk = 1
        hamscene_panel_button(tx, TAB_Y, TAB_W, TAB_H, sunk)
        plbl: Array[12, uint8]
        plbl[0] = 80                                 # 'P'
        np: uint64 = _u64_to_dec(t, &plbl[1])
        plbl[1 + np] = 0
        hamscene_glyphs(tx + 8, TAB_Y + 8, &plbl[0], fg)
        t = t + 1
    # [+Add] tab (only if room)
    addx: int32 = _tab_x(n_panels)
    if n_panels < MAX_PANELS:
        hamscene_panel_button(addx, TAB_Y, ADDTAB_W, TAB_H, 0)
        hamscene_glyphs(addx + 6, TAB_Y + 8, cast[Ptr[uint8]]("+Add"), fg)
        addx = addx + ADDTAB_W + TAB_GAP
    # [Del] tab (disabled-looking when only one panel)
    hamscene_panel_button(addx, TAB_Y, DELTAB_W, TAB_H, 0)
    dlc: Ptr[uint8] = cast[Ptr[uint8]]("#a04040")
    if n_panels <= 1:
        dlc = cast[Ptr[uint8]]("#909090")
    hamscene_glyphs(addx + 6, TAB_Y + 8, cast[Ptr[uint8]]("Del"), dlc)

    sp: uint64 = cast[uint64](sel_panel)

    # --- Per-panel edge ---
    hamscene_glyphs(EDGE_BTN_X0, 170, cast[Ptr[uint8]]("Edge:"), fg)
    e: int32 = 0
    while e < 4:
        sunk2: int32 = 0
        if pm_edge[sp] == e:
            sunk2 = 1
        ex: int32 = _edge_btn_x(e)
        hamscene_panel_button(ex, EDGE_BTN_Y, EDGE_BTN_W, EDGE_BTN_H, sunk2)
        elbl: Ptr[uint8] = cast[Ptr[uint8]]("Top")
        if e == 1:
            elbl = cast[Ptr[uint8]]("Bottom")
        elif e == 2:
            elbl = cast[Ptr[uint8]]("Left")
        elif e == 3:
            elbl = cast[Ptr[uint8]]("Right")
        hamscene_glyphs(ex + 8, EDGE_BTN_Y + 8, elbl, fg)
        e = e + 1

    # --- Per-panel colour ---
    hamscene_glyphs(PCOL_X0, 224, cast[Ptr[uint8]]("Panel colour:"), fg)
    c: uint64 = 0
    while c < PAL_N:
        cx: int32 = _pcol_x(c)
        hamscene_fill(cx, PCOL_Y, PCOL_SZ, PCOL_SZ, pal_hex_ptr(c))
        cbc: Ptr[uint8] = cast[Ptr[uint8]]("#606060")
        ct: int32 = 1
        if pm_color[sp] == cast[int32](c):
            cbc = cast[Ptr[uint8]]("#ffd040")
            ct = 2
        hamscene_stroke(cx, PCOL_Y, PCOL_SZ, PCOL_SZ, ct, cbc)
        c = c + 1

    # --- Per-panel size +/- and font weight ---
    hamscene_glyphs(SIZE_DEC_X, 270, cast[Ptr[uint8]]("Size:"), fg)
    hamscene_panel_button(SIZE_DEC_X, SIZE_Y, SIZE_BTN_W, BTN_H, 0)
    hamscene_glyphs(SIZE_DEC_X + 9, SIZE_Y + 7, cast[Ptr[uint8]]("-"), fg)
    szlbl: Array[8, uint8]
    szn: uint64 = _u64_to_dec(cast[uint64](pm_size[sp]), &szlbl[0])
    szlbl[szn] = 0
    hamscene_glyphs(SIZE_DEC_X + 40, SIZE_Y + 7, &szlbl[0], fg)
    hamscene_panel_button(SIZE_INC_X, SIZE_Y, SIZE_BTN_W, BTN_H, 0)
    hamscene_glyphs(SIZE_INC_X + 9, SIZE_Y + 7, cast[Ptr[uint8]]("+"), fg)
    hamscene_panel_button(FONT_BTN_X, SIZE_Y, FONT_BTN_W, BTN_H, pm_bold[sp])
    flbl: Ptr[uint8] = cast[Ptr[uint8]]("Font: Normal")
    if pm_bold[sp] != 0:
        flbl = cast[Ptr[uint8]]("Font: Bold")
    hamscene_glyphs(FONT_BTN_X + 10, SIZE_Y + 7, flbl, fg)

    # --- Widget assignment list for the selected panel ---
    hamscene_glyphs(WL_X, 314, cast[Ptr[uint8]]("Widgets (click to select):"), fg)
    s2: uint64 = 0
    while s2 < pm_nwidg[sp]:
        ry: int32 = WL_Y + cast[int32](s2) * WL_ROW_H
        rc: Ptr[uint8] = cast[Ptr[uint8]]("#c8c4bc")
        if sel_widget == cast[int64](s2):
            rc = cast[Ptr[uint8]]("#ffe070")
        hamscene_fill(WL_X, ry, WL_W, WL_ROW_H - 2, rc)
        hamscene_stroke(WL_X, ry, WL_W, WL_ROW_H - 2, 1,
                        cast[Ptr[uint8]]("#808080"))
        hamscene_glyphs(WL_X + 8, ry + 4, _wk_name(pm_w(sp, s2)), fg)
        s2 = s2 + 1

    # --- Widget action buttons (right of the list) ---
    # Up / Down reorder, Del, Move-to-next-panel, and Add-widget.
    hamscene_panel_button(WACT_X, WL_Y, 60, BTN_H, 0)
    hamscene_glyphs(WACT_X + 14, WL_Y + 7, cast[Ptr[uint8]]("Up"), fg)
    hamscene_panel_button(WACT_X, WL_Y + 28, 60, BTN_H, 0)
    hamscene_glyphs(WACT_X + 8, WL_Y + 35, cast[Ptr[uint8]]("Down"), fg)
    hamscene_panel_button(WACT_X, WL_Y + 56, 60, BTN_H, 0)
    hamscene_glyphs(WACT_X + 12, WL_Y + 63, cast[Ptr[uint8]]("Del"), fg)
    # "Move →" sends the selected widget to the next panel. Short label so
    # it sits comfortably inside its 110px button (was "Move to next panel",
    # 18 glyphs ~144px, which overran the 130px box).
    hamscene_panel_button(WADD_X, WL_Y, 110, BTN_H, 0)
    hamscene_glyphs(WADD_X + 10, WL_Y + 7, cast[Ptr[uint8]]("Move >>"), fg)
    # Add-widget row: one chip per widget kind, in the WADD_X sub-column BELOW
    # the Move button — clear of the Up/Down/Del stack at WACT_X (the old
    # layout drew this row starting at WACT_X, painting the chips + label right
    # on top of the move-down / delete buttons). 5 chips * 40px step = 200px,
    # so WADD_X(300)..500 stays inside the 520px window.
    hamscene_glyphs(WADD_X, WL_Y + 30, cast[Ptr[uint8]]("Add widget:"), fg)
    k: int32 = 0
    while k < N_WK:
        bx: int32 = WADD_X + cast[int32](k) * ADD_CHIP_STEP
        hamscene_panel_button(bx, WL_Y + 48, ADD_CHIP_W, BTN_H, 0)
        nm: Ptr[uint8] = _wk_addlabel(k)
        hamscene_glyphs(bx + 4, WL_Y + 55, nm, fg)
        k = k + 1

    # --- note ---
    hamscene_glyphs(SW_X, WIN_H - 18,
                    cast[Ptr[uint8]]("Panel prefs apply live (no restart). 2 panels = top+bottom."),
                    cast[Ptr[uint8]]("#606060"))
    hamscene_commit(wid)


# ====================================================================
# INPUT
# ====================================================================
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                             # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc = acc * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc = 0 - acc
        vals[v] = acc
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1


def _in(x: int64, y: int64, bx: int32, by: int32, bw: int32, bh: int32) -> int32:
    if x >= cast[int64](bx) and x < cast[int64](bx + bw) \
            and y >= cast[int64](by) and y < cast[int64](by + bh):
        return 1
    return 0


btn_down: int32 = 0
def _handle_click(x: int64, y: int64) -> int32:
    sp: uint64 = cast[uint64](sel_panel)
    # --- Wallpaper swatches ---
    if y >= cast[int64](SW_Y) and y < cast[int64](SW_Y + SW_SZ):
        i: uint64 = 0
        while i < N_SWATCH:
            sx: int64 = cast[int64](_swatch_x(i))
            if x >= sx and x < sx + cast[int64](SW_SZ):
                sel_swatch = cast[int64](i)
                _apply_wallpaper(i)
                return 1
            i = i + 1

    # --- Panel tabs / +Add / Del ---
    if y >= cast[int64](TAB_Y) and y < cast[int64](TAB_Y + TAB_H):
        t: uint64 = 0
        while t < n_panels:
            if _in(x, y, _tab_x(t), TAB_Y, TAB_W, TAB_H) != 0:
                sel_panel = cast[int64](t)
                sel_widget = -1
                return 1
            t = t + 1
        addx: int32 = _tab_x(n_panels)
        if n_panels < MAX_PANELS:
            if _in(x, y, addx, TAB_Y, ADDTAB_W, TAB_H) != 0:
                _add_panel()
                _write_panel_conf()
                return 1
            addx = addx + ADDTAB_W + TAB_GAP
        if _in(x, y, addx, TAB_Y, DELTAB_W, TAB_H) != 0:
            if n_panels > 1:
                _remove_panel(sp)
                _write_panel_conf()
            return 1

    # --- Per-panel edge ---
    if y >= cast[int64](EDGE_BTN_Y) and y < cast[int64](EDGE_BTN_Y + EDGE_BTN_H):
        e: int32 = 0
        while e < 4:
            ex: int64 = cast[int64](_edge_btn_x(e))
            if x >= ex and x < ex + cast[int64](EDGE_BTN_W):
                # Keep every panel on a DISTINCT edge so all four (top / bottom
                # / left / right) can coexist without stacking on the same
                # screen edge. If another panel already occupies edge `e`, swap
                # it onto this panel's old edge rather than silently overlapping.
                old_e: int32 = pm_edge[sp]
                if e != old_e:
                    pp: uint64 = 0
                    while pp < n_panels:
                        if pp != sp and pm_edge[pp] == e:
                            pm_edge[pp] = old_e
                        pp = pp + 1
                pm_edge[sp] = e
                _write_panel_conf()
                return 1
            e = e + 1

    # --- Per-panel colour palette ---
    if y >= cast[int64](PCOL_Y) and y < cast[int64](PCOL_Y + PCOL_SZ):
        c: uint64 = 0
        while c < PAL_N:
            cx: int64 = cast[int64](_pcol_x(c))
            if x >= cx and x < cx + cast[int64](PCOL_SZ):
                pm_color[sp] = cast[int32](c)
                _write_panel_conf()
                return 1
            c = c + 1

    # --- Per-panel size +/- and font ---
    if _in(x, y, SIZE_DEC_X, SIZE_Y, SIZE_BTN_W, BTN_H) != 0:
        if pm_size[sp] > 16:
            pm_size[sp] = pm_size[sp] - 4
        _write_panel_conf()
        return 1
    if _in(x, y, SIZE_INC_X, SIZE_Y, SIZE_BTN_W, BTN_H) != 0:
        if pm_size[sp] < 96:
            pm_size[sp] = pm_size[sp] + 4
        _write_panel_conf()
        return 1
    if _in(x, y, FONT_BTN_X, SIZE_Y, FONT_BTN_W, BTN_H) != 0:
        if pm_bold[sp] != 0:
            pm_bold[sp] = 0
        else:
            pm_bold[sp] = 1
        _write_panel_conf()
        return 1

    # --- Widget list rows (select) ---
    s2: uint64 = 0
    while s2 < pm_nwidg[sp]:
        ry: int32 = WL_Y + cast[int32](s2) * WL_ROW_H
        if _in(x, y, WL_X, ry, WL_W, WL_ROW_H - 2) != 0:
            sel_widget = cast[int64](s2)
            return 1
        s2 = s2 + 1

    # --- Widget action buttons ---
    if sel_widget >= 0 and cast[uint64](sel_widget) < pm_nwidg[sp]:
        sw: uint64 = cast[uint64](sel_widget)
        if _in(x, y, WACT_X, WL_Y, 60, BTN_H) != 0:           # Up
            if sw > 0:
                _widget_swap(sp, sw, sw - 1)
                sel_widget = sel_widget - 1
                _write_panel_conf()
            return 1
        if _in(x, y, WACT_X, WL_Y + 28, 60, BTN_H) != 0:      # Down
            if sw + 1 < pm_nwidg[sp]:
                _widget_swap(sp, sw, sw + 1)
                sel_widget = sel_widget + 1
                _write_panel_conf()
            return 1
        if _in(x, y, WACT_X, WL_Y + 56, 60, BTN_H) != 0:      # Del
            _panel_del_widget(sp, sw)
            _write_panel_conf()
            return 1
        if _in(x, y, WADD_X, WL_Y, 110, BTN_H) != 0:          # Move >> (next panel)
            if n_panels > 1:
                to_p: uint64 = (sp + 1) % n_panels
                _widget_move_panel(sp, sw, to_p)
                _write_panel_conf()
            return 1

    # --- Add-widget kind buttons (WADD_X sub-column, clear of Up/Down/Del) ---
    k: int32 = 0
    while k < N_WK:
        bx: int32 = WADD_X + k * ADD_CHIP_STEP
        if _in(x, y, bx, WL_Y + 48, ADD_CHIP_W, BTN_H) != 0:
            _panel_add_widget(sp, k)
            _write_panel_conf()
            return 1
        k = k + 1
    return 0


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamsettings] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        geo: Array[64, uint8]
        gp: uint64 = 0
        pre: Ptr[uint8] = cast[Ptr[uint8]]("geometry 240 120 ")
        a: uint64 = 0
        while pre[a] != 0:
            geo[gp] = pre[a]
            gp = gp + 1
            a = a + 1
        gp = gp + _u64_to_dec(cast[uint64](WIN_W), &geo[gp])
        geo[gp] = 32
        gp = gp + 1
        gp = gp + _u64_to_dec(cast[uint64](WIN_H), &geo[gp])
        geo[gp] = 10
        gp = gp + 1
        sys_write(cfd, &geo[0], gp)
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("title Settings\n"))
        sys_close(cfd3)
    cfd4: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd4 >= 0:
        _writeall(cfd4, cast[Ptr[uint8]]("z 7\n"))
        sys_close(cfd4)

    _init_swatches()
    _init_palette()
    _init_panel_model()
    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hamsettings] scene window ready\n"))

    evbuf: Array[256, uint8]
    while True:
        changed: int32 = 0
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            r: int64 = sys_read(efd, &evbuf[0], 255)
            sys_close(efd)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            bx: int64 = 0
                            by: int64 = 0
                            bbtn: int64 = 0
                            if parse_pointer(&evbuf[ls], i - ls, &bx, &by,
                                             &bbtn) == 1:
                                nd: int32 = 0
                                if (bbtn & 1) != 0:
                                    nd = 1
                                if nd == 1 and btn_down == 0:
                                    if _handle_click(bx, by) == 1:
                                        changed = 1
                                btn_down = nd
                        ls = i + 1
                    i = i + 1
        if changed != 0:
            emit_scene(wid)
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 3:
            sys_yield()
    return 0

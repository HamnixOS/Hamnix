# user/hamtetrisscene_host.ad — HOST driver + render harness for the Tetris
# scene app (built for the x86_64-linux Adder target; runs directly on the dev
# host, no QEMU).
#
# It drives the SAME core the native app ships (lib/hamtetriscore.ad): resets +
# lays out the well, builds the scene display list, and RASTERIZES it with
# lib/hamui_host.ad's parser+font rasterizer into an RGB framebuffer written
# out as a binary PPM a human/agent can LOOK at (scripts/test_hamtetris_host.sh
# converts it to PNG). Then it feeds SCRIPTED input (keyboard "d <code>" lines +
# explicit ticks + a forced line-clear) through the core's pure handlers and
# asserts the game state evolved: the piece MOVES/ROTATES/DROPS, a full row
# CLEARS + scores, spawning into a blocked top is GAME OVER, and New restarts.
# It also dumps the raw scene display list + sampled pixel colours to stdout so
# the gate can assert on layout/colour.
#
# USAGE (built to build/host/hamtetris_host):
#   hamtetris_host BEFORE.ppm AFTER.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamtetriscore import httetris_reset, httetris_build_scene, \
    httetris_draw_overlay, httetris_tick, httetris_gameover, \
    httetris_score, httetris_lines, httetris_level, \
    httetris_cur_piece, httetris_cur_rot, httetris_cur_x, httetris_cur_y, \
    httetris_cell, httetris_move, httetris_rotate, httetris_harddrop, \
    httetris_key_line, httetris_btn_at, httetris_ctrl_press, \
    httetris_test_setcell, httetris_test_setpiece, httetris_test_spawn


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)                                          # '#'
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


def _kv(k: Ptr[uint8], v: int64):
    _o_str(k)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    # O_WRONLY|O_CREAT|O_TRUNC = 577, mode 0644 = 420.
    fd: int32 = sys_open(path, 577, 420)
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    httetris_build_scene()
    httetris_draw_overlay()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


# Feed one keyboard press for ASCII byte `code` through the core's key-line
# parser (constructs the "d <code>" wire line the compositor delivers).
kl: Array[16, uint8]


def _press(code: int32) -> int32:
    kl[0] = 100                                        # 'd'
    kl[1] = 32
    p: uint64 = 2
    if code >= 100:
        kl[p] = cast[uint8](code / 100) + 48
        p = p + 1
    if code >= 10:
        kl[p] = cast[uint8]((code / 10) % 10) + 48
        p = p + 1
    kl[p] = cast[uint8](code % 10) + 48
    p = p + 1
    return httetris_key_line(&kl[0], p)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hamtetris_host BEFORE.ppm AFTER.ppm\n"))
        _o_flush()
        return 2

    W: int32 = 360
    H: int32 = 470

    # DETERMINISTIC: fresh game, then FORCE the falling piece + a locked block
    # so the render is byte-reproducible (no clock seed).
    httetris_reset()
    httetris_test_setpiece(0, 0, 3, 0)                 # I piece, spawn rotation
    httetris_test_setcell(0, 19, 5)                    # locked Z-red block (val 5)

    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))

    # Summary + sampled pixels (proves the RASTERIZER, not just the builder).
    _kv(cast[Ptr[uint8]]("PRIMS"), cast[int64](prims))
    _kv(cast[Ptr[uint8]]("CURPIECE0"), cast[int64](httetris_cur_piece()))
    _kv(cast[Ptr[uint8]]("CURX0"), cast[int64](httetris_cur_x()))
    _kv(cast[Ptr[uint8]]("CURY0"), cast[int64](httetris_cur_y()))
    _kv(cast[Ptr[uint8]]("SCORE0"), cast[int64](httetris_score()))
    _kv(cast[Ptr[uint8]]("LINES0"), cast[int64](httetris_lines()))
    _kv(cast[Ptr[uint8]]("GAMEOVER0"), cast[int64](httetris_gameover()))
    # Backdrop pixel (top-left) = window navy #1b1b2e.
    _o_str(cast[Ptr[uint8]]("PIX 4 4 "))
    _o_hexcol(hamui_host_pixel(4, 4))
    _o_ch(10)
    # Empty well cell (0,10): _cell_x(0)=90 _cell_y(10)=236 -> sample 95,241.
    _o_str(cast[Ptr[uint8]]("PIX 95 241 "))
    _o_hexcol(hamui_host_pixel(95, 241))
    _o_ch(10)
    # Locked Z-red block at (0,19): _cell_x(0)=90 _cell_y(19)=398 inset+1 ->
    # 91,399; sample interior 95,403 == #ff5252.
    _o_str(cast[Ptr[uint8]]("PIX 95 403 "))
    _o_hexcol(hamui_host_pixel(95, 403))
    _o_ch(10)
    # Falling I piece cell (3,1): _cell_x(3)=144 _cell_y(1)=74 inset+1 ->
    # 145,75; sample 149,79 == cyan #23d6d6.
    _o_str(cast[Ptr[uint8]]("PIX 149 79 "))
    _o_hexcol(hamui_host_pixel(149, 79))
    _o_ch(10)
    _o_flush()

    # Dump the raw scene display list so the gate can assert layout/colour.
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()

    # ---- SCRIPTED INPUT -------------------------------------------------
    # 1) On-screen pointer: a press in the control row must hit-test a button.
    #    _btn_x(2)=156, BTN_W=62 -> x=180 lands on the Rot button; CTRL_Y=430.
    b: int64 = httetris_btn_at(180, 440)
    _kv(cast[Ptr[uint8]]("BTNAT_180_440"), b)

    # 2) MOVE: shift the falling I piece left one column via keyboard 'a'.
    ky: int32 = _press(97)                             # 'a' = left
    _kv(cast[Ptr[uint8]]("KEYMOVE"), cast[int64](ky))
    _kv(cast[Ptr[uint8]]("CURX1"), cast[int64](httetris_cur_x()))

    # 3) ROTATE: rotate the I piece (spawn->rot1 is a legal in-well kick).
    rr: int32 = httetris_rotate()
    _kv(cast[Ptr[uint8]]("ROT"), cast[int64](rr))
    _kv(cast[Ptr[uint8]]("CURROT1"), cast[int64](httetris_cur_rot()))

    # 4) GRAVITY: a tick drops the piece one row.
    y0: int32 = httetris_cur_y()
    httetris_tick()
    _kv(cast[Ptr[uint8]]("CURY_AFTER_TICK"), cast[int64](httetris_cur_y()))
    _kv(cast[Ptr[uint8]]("DROPPED_ONE"), cast[int64](httetris_cur_y() - y0))

    # ---- LINE CLEAR: build a bottom row missing only column 9, drop a
    # vertical I piece down column 9 to complete + clear it. ----------------
    httetris_reset()
    fillc: int32 = 0
    while fillc < 9:
        httetris_test_setcell(fillc, 19, 4)            # cols 0..8 of row 19
        fillc = fillc + 1
    # I piece rotation 1 is a single column at box-column 2; origin x=7 puts
    # that column at well x=9. Drop it: only the lowest cell reaches row 19.
    httetris_test_setpiece(0, 1, 7, 0)
    fell: int32 = httetris_harddrop()
    _kv(cast[Ptr[uint8]]("HARDDROP_FELL"), cast[int64](fell))
    _kv(cast[Ptr[uint8]]("CLR_LINES"), cast[int64](httetris_lines()))
    _kv(cast[Ptr[uint8]]("CLR_SCORE"), cast[int64](httetris_score()))
    # Row 19 must no longer be a full solid wall of the old colour: cell (0,19)
    # was cleared then back-filled by the shift, so it is now empty (0).
    _kv(cast[Ptr[uint8]]("CELL_0_19_AFTER"), cast[int64](httetris_cell(0, 19)))

    # Render the AFTER frame: fresh game with the cleared/scored state visible.
    httetris_test_setpiece(2, 0, 3, 0)                 # a T piece for variety
    prims2: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _kv(cast[Ptr[uint8]]("PRIMS2"), cast[int64](prims2))
    _o_flush()

    # ---- GAME OVER: fill columns 0..8 to the very top (no full row, since
    # column 9 stays empty), then force a spawn — it must be blocked. --------
    httetris_reset()
    gy: int32 = 0
    while gy < 20:
        gx: int32 = 0
        while gx < 9:
            httetris_test_setcell(gx, gy, 6)
            gx = gx + 1
        gy = gy + 1
    go: int32 = httetris_test_spawn()
    _kv(cast[Ptr[uint8]]("SPAWN_BLOCKED_GAMEOVER"), cast[int64](go))

    # A tick while dead is a no-op (returns 0).
    dead_tick: int32 = httetris_tick()
    _kv(cast[Ptr[uint8]]("DEAD_TICK"), cast[int64](dead_tick))

    # ---- RESTART via the New button clears game over. --------------------
    httetris_ctrl_press(0)                             # New
    _kv(cast[Ptr[uint8]]("NEW_GAMEOVER"), cast[int64](httetris_gameover()))
    _kv(cast[Ptr[uint8]]("NEW_SCORE"), cast[int64](httetris_score()))
    _kv(cast[Ptr[uint8]]("NEW_LINES"), cast[int64](httetris_lines()))
    _o_flush()
    return 0

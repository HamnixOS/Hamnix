# user/scenetest.ad
#
# Scene-file DE gate driver (docs/de_scene_file_arch.md, build order §9).
#
# Exercises the scene server end-to-end from userland:
#   1. `newwindow` on /dev/wsys/ctl, read back the assigned wid.
#   2. set geometry, write a KNOWN scene (fill + rect + glyphs), commit.
#   3. a SECOND overlapping window at higher z with a different fill.
#   4. write the cursor scene and "move" it.
#
# Prints serial markers the host harness syncs screendumps on:
#   [scene_gate] win=<wid> committed
#   [scene_gate] win2=<wid> committed
#   [scene_gate] cursor committed
#   [scene_gate] done
#
# The kernel compositor (devwsys.ad) z-blits the scene caches to /dev/fb
# on each commit, so after this runs the framebuffer shows both windows
# (the higher-z one winning the overlap) plus the cursor sprite.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(s: Ptr[uint8]):
    sys_write(1, s, _slen(s))


def _putdec(v: int32):
    if v < 0:
        neg: Array[2, uint8]
        neg[0] = 45                                # '-'
        sys_write(1, &neg[0], 1)
        _putdec(-v)
        return
    if v == 0:
        buf0: Array[2, uint8]
        buf0[0] = 48
        sys_write(1, &buf0[0], 1)
        return
    digs: Array[16, uint8]
    n: uint64 = 0
    x: int32 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    out: Array[16, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    sys_write(1, &out[0], i)


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


# Create a window: write newwindow, read back wid as decimal. Returns the
# wid, or -1 on failure. Uses ONE fd so the alloc-response slot is read
# back by the same chan.
def _newwindow() -> int32:
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return -1
    nw: Ptr[uint8] = cast[Ptr[uint8]]("newwindow\n")
    if sys_write(fd, nw, 10) < 0:
        sys_close(fd)
        return -1
    sys_close(fd)
    # Re-open ctl for READ to fetch the wid (a write-only fd is not
    # reliably readable; devwsys_ctl_read renders wsys_last_alloc_wid).
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


# Build "/dev/wsys/<wid>/<leaf>" into out, NUL-terminated.
def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    # wid decimal
    if wid == 0:
        out[p] = 48
        p = p + 1
    else:
        digs: Array[16, uint8]
        n: uint64 = 0
        x: int32 = wid
        while x > 0:
            digs[n] = cast[uint8](x % 10) + 48
            x = x / 10
            n = n + 1
        while n > 0:
            n = n - 1
            out[p] = digs[n]
            p = p + 1
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


def _setup_window(wid: int32, geo: Ptr[uint8], scene: Ptr[uint8]):
    path: Array[64, uint8]
    # ctl: geometry
    _winpath(&path[0], wid, cast[Ptr[uint8]]("/ctl"))
    cfd: int32 = sys_open_write(cast[Ptr[char]](&path[0]))
    if cfd >= 0:
        _writeall(cfd, geo)
        sys_close(cfd)
    # scene
    _winpath(&path[0], wid, cast[Ptr[uint8]]("/scene"))
    sfd: int32 = sys_open_write(cast[Ptr[char]](&path[0]))
    if sfd >= 0:
        _writeall(sfd, scene)
        sys_close(sfd)
    # commit
    _winpath(&path[0], wid, cast[Ptr[uint8]]("/ctl"))
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&path[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("commit\n"))
        sys_close(cfd2)


def main() -> int32:
    w1ctl: Array[64, uint8]
    w2ctl: Array[64, uint8]
    # Ensure the device server is bound at /dev in OUR namespace (a
    # spawned binary may not inherit the login shell's `bind '#c' /dev`).
    # Without it, /dev/wsys/... falls through to a tmpfs file instead of
    # the wsys file server. Idempotent if already bound.
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    # --- cursor FIRST: it has no ownership gate and does NOT rebind this
    # process's wid, so writing it before newwindow keeps our stdout on
    # the serial console and proves basic /dev/wsys file I/O works. ----
    curfd0: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/cursor/scene"))
    if curfd0 < 0:
        _puts("[scene_gate] FAIL open cursor/scene\n")
        return 1
    _writeall(curfd0, cast[Ptr[uint8]]("fill 300 200 12 12 #ff0000\n"))
    sys_close(curfd0)
    # Self-verify the readback (flood-immune: report via serial BEFORE the
    # newwindow rebind). Re-open for read and report how many bytes the
    # kernel scene slot holds back.
    rbfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/cursor/scene"))
    rbbuf: Array[128, uint8]
    rbn: int64 = -1
    if rbfd >= 0:
        rbn = sys_read(rbfd, &rbbuf[0], 127)
        sys_close(rbfd)
    _puts("[scene_gate] cursor readback bytes=")
    _putdec(cast[int32](rbn))
    _puts("\n")
    _puts("[scene_gate] cursor seeded\n")

    # --- window 1: z=0, blue field with a yellow box + white text -----
    w1: int32 = _newwindow()
    if w1 < 0:
        _puts("[scene_gate] FAIL newwindow w1\n")
        return 1
    _winpath(&w1ctl[0], w1, cast[Ptr[uint8]]("/ctl"))
    _setup_window(w1,
        cast[Ptr[uint8]]("geometry 40 40 200 160\n"),
        cast[Ptr[uint8]]("# scene v1\nfill 0 0 200 160 #2040c0\nrect 20 20 100 60 #ffd000\nglyphs 30 90 \"HELLO\" #ffffff\n"))
    _puts("[scene_gate] win=")
    _putdec(w1)
    _puts(" committed\n")

    # --- window 2: z=1, overlapping w1, solid green ------------------
    w2: int32 = _newwindow()
    if w2 < 0:
        _puts("[scene_gate] FAIL newwindow w2\n")
        return 1
    _winpath(&w2ctl[0], w2, cast[Ptr[uint8]]("/ctl"))
    _setup_window(w2,
        cast[Ptr[uint8]]("z 1\n"),
        cast[Ptr[uint8]]("# scene v1\nfill 0 0 160 120 #00c000\n"))
    # z 1 must be a separate ctl write (geometry verb path differs); also
    # set its origin so it overlaps w1's region.
    path: Array[64, uint8]
    _winpath(&path[0], w2, cast[Ptr[uint8]]("/ctl"))
    gfd: int32 = sys_open_write(cast[Ptr[char]](&path[0]))
    if gfd >= 0:
        _writeall(gfd, cast[Ptr[uint8]]("geometry 120 100 160 120\n"))
        sys_close(gfd)
    # re-commit so the new geometry takes effect on screen
    _winpath(&path[0], w2, cast[Ptr[uint8]]("/ctl"))
    cfd: int32 = sys_open_write(cast[Ptr[char]](&path[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("z 1\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&path[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("commit\n"))
        sys_close(cfd2)
    _puts("[scene_gate] win2=")
    _putdec(w2)
    _puts(" committed\n")

    # --- cursor: a small red square at (300,200) ---------------------
    curfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/cursor/scene"))
    if curfd >= 0:
        _writeall(curfd, cast[Ptr[uint8]]("fill 300 200 12 12 #ff0000\n"))
        sys_close(curfd)
    _puts("[scene_gate] cursor committed\n")

    # --- cursor move: re-write at a new origin -----------------------
    curfd2: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/cursor/scene"))
    if curfd2 >= 0:
        _writeall(curfd2, cast[Ptr[uint8]]("fill 340 230 12 12 #ff0000\n"))
        sys_close(curfd2)
    _puts("[scene_gate] cursor moved\n")

    _puts("[scene_gate] done\n")

    # Keep the windows ALIVE so the gate can read /dev/wsys/<wid>/scene
    # back as text and screendump the composited frame. A task's wids are
    # freed on exit, so without this hold the scene files vanish before the
    # gate inspects them. Spin ~25s against the 100Hz jiffies counter.
    start: uint64 = sys_get_jiffies()
    while sys_get_jiffies() - start < 2500:
        # Re-commit periodically so the kernel compositor keeps presenting
        # our windows on top of the legacy DE's continuous repaint (this
        # wave runs ALONGSIDE the legacy compositor, which owns the fb).
        rfd: int32 = sys_open_write(cast[Ptr[char]](&w1ctl[0]))
        if rfd >= 0:
            _writeall(rfd, cast[Ptr[uint8]]("commit\n"))
            sys_close(rfd)
        rfd2: int32 = sys_open_write(cast[Ptr[char]](&w2ctl[0]))
        if rfd2 >= 0:
            _writeall(rfd2, cast[Ptr[uint8]]("commit\n"))
            sys_close(rfd2)
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 20:
            pass
    return 0

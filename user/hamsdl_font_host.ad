# user/hamsdl_font_host.ad — HOST render+drive harness for the hamSDL/hamGame
# TEXT renderer (the pygame.font.Font(...).render gap): rasterize a STRING from
# the embedded 8x16 glyph table into a Surface (lib/hamfont.ad + hamgame's
# game_render_text), blit it onto a display Surface at a known offset, rasterize
# the frame to a PPM a human/agent can LOOK at, and dump sampled counts/positions
# so scripts/test_hamsdl_font_host.sh can ASSERT the string -> Surface -> blit ->
# PNG path WITHOUT eyeballing individual glyph shapes.
#
# It proves the things a text renderer has to get right:
#   1. FOREGROUND — glyph strokes appear in the requested colour.
#   2. TRANSPARENCY — the background shows through between/around glyphs
#                     (the render is fg-on-transparent, not a filled block).
#   3. OFFSET — the text lands at the requested (x,y), nothing above/left of it.
#   4. COLOUR — a second string in a different colour renders distinctly.
#
# USAGE (built to build/host/hamsdl_font_host):
#   hamsdl_font_host OUT.ppm

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

from lib.hamgame import game_reset, game_display_new, game_surface_fill, \
    game_surface_w, game_surface_h, game_surface_blit, game_flip_scene, \
    game_rgb, game_render_text, game_surface_draw_text
from lib.hamgame_host import game_host_present, game_host_write_ppm, \
    game_host_pixel


DW: int32 = 96
DH: int32 = 48
TX: int32 = 8                            # green "Hi 42" blit offset
TY: int32 = 8
TW: int32 = 40                           # 8x16 glyphs * 5 chars = 40x16
TH: int32 = 16
BX: int32 = 8                            # blue "42" blit offset
BY: int32 = 28


# ---- stdout helpers (mirrors user/hamsdl_image_host.ad) ------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


def _o_kv(k: Ptr[uint8], v: int64):
    _o_str(k)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)


# ---- framebuffer pixel classifiers (game_host_pixel -> 0x00RRGGBB) --------
def _fb_r(x: int32, y: int32) -> int32:
    return cast[int32]((game_host_pixel(x, y) >> 16) & 255)


def _fb_g(x: int32, y: int32) -> int32:
    return cast[int32]((game_host_pixel(x, y) >> 8) & 255)


def _fb_b(x: int32, y: int32) -> int32:
    return cast[int32](game_host_pixel(x, y) & 255)


def _is_green(x: int32, y: int32) -> int32:
    if _fb_g(x, y) > 180 and _fb_r(x, y) < 80 and _fb_b(x, y) < 80:
        return 1
    return 0


def _is_blue(x: int32, y: int32) -> int32:
    if _fb_b(x, y) > 180 and _fb_r(x, y) < 80 and _fb_g(x, y) < 80:
        return 1
    return 0


def _is_red(x: int32, y: int32) -> int32:
    if _fb_r(x, y) > 180 and _fb_g(x, y) < 80 and _fb_b(x, y) < 80:
        return 1
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        _o_str(cast[Ptr[uint8]]("usage: hamsdl_font_host OUT.ppm\n"))
        _o_flush()
        return 2

    game_reset()

    # ---- 1. Render "Hi 42" in GREEN into a text Surface -----------------
    txt: int32 = game_render_text(cast[Ptr[uint8]]("Hi 42"), 0, 255, 0)
    _o_kv(cast[Ptr[uint8]]("TXT"), cast[int64](txt))
    if txt < 0:
        _o_flush()
        return 1
    _o_kv(cast[Ptr[uint8]]("TXTW"), cast[int64](game_surface_w(txt)))
    _o_kv(cast[Ptr[uint8]]("TXTH"), cast[int64](game_surface_h(txt)))

    # ---- 2. Compose: red backdrop + green text; blue text via convenience --
    disp: int32 = game_display_new(DW, DH)
    game_surface_fill(disp, game_rgb(255, 0, 0))         # opaque red backdrop
    game_surface_blit(disp, txt, TX, TY)                 # render()->blit path
    # One-call convenience path, distinct colour + string.
    game_surface_draw_text(disp, cast[Ptr[uint8]]("42"), BX, BY,
                           game_rgb(0, 0, 255))

    # ---- 3. Rasterize to a PPM + scan sampled pixel populations ----------
    game_flip_scene(disp)
    prims: int32 = game_host_present(disp)
    game_host_write_ppm(cast[Ptr[char]](argv[1]))
    _o_kv(cast[Ptr[uint8]]("PRIMS"), cast[int64](prims))

    # Scan the green text bounding box [TX,TX+TW) x [TY,TY+TH):
    #   green strokes, red gaps between them, and the min stroke position.
    green_n: int32 = 0
    red_in_box: int32 = 0
    gminx: int32 = 9999
    gminy: int32 = 9999
    yy: int32 = TY
    while yy < TY + TH:
        xx: int32 = TX
        while xx < TX + TW:
            if _is_green(xx, yy) == 1:
                green_n = green_n + 1
                if xx < gminx:
                    gminx = xx
                if yy < gminy:
                    gminy = yy
            if _is_red(xx, yy) == 1:
                red_in_box = red_in_box + 1
            xx = xx + 1
        yy = yy + 1
    _o_kv(cast[Ptr[uint8]]("GREEN_N"), cast[int64](green_n))
    _o_kv(cast[Ptr[uint8]]("RED_IN_BOX"), cast[int64](red_in_box))
    _o_kv(cast[Ptr[uint8]]("GREEN_MINX"), cast[int64](gminx))
    _o_kv(cast[Ptr[uint8]]("GREEN_MINY"), cast[int64](gminy))

    # OFFSET proof: nothing rendered ABOVE the text (rows y<TY) or LEFT of it
    # (x<TX within the text rows) — count non-red pixels there (expect 0).
    above_nonred: int32 = 0
    ay: int32 = 0
    while ay < TY:
        ax: int32 = 0
        while ax < DW:
            if _is_red(ax, ay) == 0:
                above_nonred = above_nonred + 1
            ax = ax + 1
        ay = ay + 1
    _o_kv(cast[Ptr[uint8]]("ABOVE_NONRED"), cast[int64](above_nonred))

    left_nonred: int32 = 0
    ly: int32 = TY
    while ly < TY + TH:
        lx: int32 = 0
        while lx < TX:
            if _is_red(lx, ly) == 0:
                left_nonred = left_nonred + 1
            lx = lx + 1
        ly = ly + 1
    _o_kv(cast[Ptr[uint8]]("LEFT_NONRED"), cast[int64](left_nonred))

    # COLOUR proof: the second string is BLUE and is NOT green; the green
    # string's box carries NO blue. Scan the blue text box [BX,BX+16)x[BY,BY+TH)
    # ("42" = 2 glyphs = 16 wide).
    blue_n: int32 = 0
    green_in_bluebox: int32 = 0
    by2: int32 = BY
    while by2 < BY + TH:
        bx2: int32 = BX
        while bx2 < BX + 16:
            if _is_blue(bx2, by2) == 1:
                blue_n = blue_n + 1
            if _is_green(bx2, by2) == 1:
                green_in_bluebox = green_in_bluebox + 1
            bx2 = bx2 + 1
        by2 = by2 + 1
    _o_kv(cast[Ptr[uint8]]("BLUE_N"), cast[int64](blue_n))
    _o_kv(cast[Ptr[uint8]]("GREEN_IN_BLUEBOX"), cast[int64](green_in_bluebox))

    # And no BLUE bled into the green box.
    blue_in_greenbox: int32 = 0
    gy: int32 = TY
    while gy < TY + TH:
        gx: int32 = TX
        while gx < TX + TW:
            if _is_blue(gx, gy) == 1:
                blue_in_greenbox = blue_in_greenbox + 1
            gx = gx + 1
        gy = gy + 1
    _o_kv(cast[Ptr[uint8]]("BLUE_IN_GREENBOX"), cast[int64](blue_in_greenbox))

    _o_flush()
    return 0

# user/nsbindprobe.ad
#
# HAMSH §18 stage-5 test helper — an EXTERNAL command that mutates its
# namespace. It does `bind /extbind /tmp` in its own process, prints a
# marker line, then exits.
#
# §9 share-vs-copy: an external command gets a copy-on-write PRIVATE
# copy of the ambient namespace — its binds evaporate on exit and can
# never corrupt the shell's view. The stage-5 acceptance test runs
# this probe, then reads the shell's /proc/self/ns and asserts the
# `/extbind` entry is ABSENT — proving the COW isolation.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char],
                    flag: int32) -> int32


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(s: Ptr[uint8]):
    sys_write(1, s, _slen(s))


def main() -> int32:
    # Bind a uniquely-named path into THIS process's namespace.
    rc: int32 = sys_bind(cast[Ptr[char]]("/extbind_probe"),
                         cast[Ptr[char]]("/tmp"), 0)
    if rc < 0:
        _puts("NSBINDPROBE bind failed\n")
        return 1
    _puts("NSBINDPROBE bind done\n")
    return 0

# user/preempt_hog.ad
#
# Preemption-test fixture: a CPU hog. After _start hands control to
# main(), this task NEVER issues a syscall again — it just spins in a
# tight infinite loop incrementing a counter. Under the pre-preemption
# (cooperative-only) scheduler, once this task is on a CPU it would
# monopolise it forever: a cooperative kernel only ever switches tasks
# inside a *blocking* syscall, and this loop makes none.
#
# It is launched by user/preempt_demo.ad via SYS_SPAWN. The companion
# parent (preempt_demo) then runs its own bounded CPU loop and, if the
# timer-driven preemptive scheduler is working, still reaches its
# `[preempt] PASS` print despite this sibling never yielding.
#
# A single sys_write announces the hog is alive (so the test log shows
# both tasks existed); everything after that point is pure computation
# with zero kernel entry. The `volatile`-style accumulator write to a
# global keeps the optimiser (such as it is) from eliding the loop.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


spin_accum: uint64 = 0


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def main() -> int32:
    msg: Ptr[uint8] = cast[Ptr[uint8]]("[preempt] hog: running tight CPU loop, no syscalls\n")
    sys_write(1, msg, strlen_u8(msg))
    # Infinite, syscall-free busy loop. The store to the global each
    # iteration is a real memory write so the loop body cannot be
    # optimised away. This never returns.
    i: uint64 = 0
    while True:
        i = i + 1
        spin_accum = spin_accum + i
    return 0

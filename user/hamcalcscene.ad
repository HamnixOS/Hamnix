# user/hamcalcscene.ad
#
# Scene-file DE calculator — a real, working integer calculator drawn
# entirely as a scene display list (docs/de_scene_file_arch.md). It is the
# scene-DE port of user/hamcalc.ad: the arithmetic / keypad STATE MACHINE
# (acc / operand / pending op / '=' / 'C' / div-by-zero ERR) is carried over
# verbatim; only the render + input layers change.
#
# RENDER (§4 Widget tier): a display bar across the top showing the current
# operand (while typing) or the running result, then a 4-column button grid
# (7 8 9 /, 4 5 6 *, 1 2 3 -, C 0 = +). Each key is a hamscene_panel_button
# face + a centered glyph label. Emitted via the lib/hamui.ad hamscene_*
# helpers and committed to /dev/wsys/<wid>/scene.
#
# INPUT (§11): the app reads its own /dev/wsys/<wid>/event file. A pointer
# press ("m <x> <y> <buttons> ...") in window-local coords hit-tests which
# key was clicked, drives the state machine, and re-emits the scene on
# change. It BLOCKS on /event (event-driven, like hamfmscene), no busy-spin.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

from lib.hamui import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_glyphs, hamscene_stroke, hamscene_panel_button, hamscene_commit


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# ====================================================================
# CALCULATOR STATE (carried over from user/hamcalc.ad)
# ====================================================================
acc:      int64 = 0
operand:  int64 = 0
pending:  int32 = 0           # 0=none 1='+' 2='-' 3='*' 4='/'
entering: int32 = 0
err:      int32 = 0
show_res: int32 = 0
opdigits: int32 = 0
MAXDIGITS: int32 = 15

disp_buf: Array[32, uint8]


# int64 -> decimal into disp_buf, NUL-terminated. "ERR" while latched.
def _c_render(v: int64):
    if err != 0:
        disp_buf[0] = 69                # 'E'
        disp_buf[1] = 82                # 'R'
        disp_buf[2] = 82                # 'R'
        disp_buf[3] = 0
        return
    if v == 0:
        disp_buf[0] = 48                # '0'
        disp_buf[1] = 0
        return
    neg: int32 = 0
    uv: uint64 = 0
    if v < 0:
        neg = 1
        uv = cast[uint64](0 - v)
    else:
        uv = cast[uint64](v)
    tmp: Array[24, uint8]
    t: uint64 = 0
    while uv != 0:
        tmp[t] = cast[uint8](uv % 10) + 48
        uv = uv / 10
        t = t + 1
    p: uint64 = 0
    if neg != 0:
        disp_buf[p] = 45                # '-'
        p = p + 1
    while t > 0:
        t = t - 1
        disp_buf[p] = tmp[t]
        p = p + 1
    disp_buf[p] = 0


# Refresh disp_buf to the currently-shown value (result vs live operand).
def _c_refresh():
    if show_res != 0 or entering == 0:
        _c_render(acc)
    else:
        _c_render(operand)


def _c_clear():
    acc = 0
    operand = 0
    pending = 0
    entering = 0
    err = 0
    show_res = 1
    opdigits = 0


def _c_digit(d: int32):
    if err != 0:
        return
    if entering == 0:
        operand = 0
        opdigits = 0
        entering = 1
        show_res = 0
    if opdigits >= MAXDIGITS:
        return
    operand = operand * 10 + cast[int64](d)
    opdigits = opdigits + 1


def _c_apply():
    if pending == 0:
        acc = operand
        return
    if pending == 1:
        acc = acc + operand
    elif pending == 2:
        acc = acc - operand
    elif pending == 3:
        acc = acc * operand
    elif pending == 4:
        if operand == 0:
            err = 1
            return
        acc = acc / operand


def _c_operator(op: int32):
    if err != 0:
        return
    if entering != 0:
        _c_apply()
    pending = op
    entering = 0
    show_res = 1
    operand = 0
    opdigits = 0


def _c_equals():
    if err != 0:
        return
    if entering != 0:
        _c_apply()
    pending = 0
    entering = 0
    show_res = 1
    operand = 0
    opdigits = 0


# ====================================================================
# LAYOUT + RENDER
# ====================================================================
# BUG 3 (calc full-screen rendered only top-left, rest BLACK): the layout
# used FIXED 188x248 dims, so a maximized window left the rest of the
# content black. The calculator is now RESIZE-AWARE: calc_w/calc_h track
# the current content size (recomputed from the "r <w> <h>" event on
# /event), and the display bar + 4x4 keypad are scaled/centered to FILL
# that area — never leaving black quadrants.
CALC_W: int32 = 188              # initial default width
CALC_H: int32 = 248              # initial default height
calc_w: int32 = 188              # current content width  (resize-derived)
calc_h: int32 = 248              # current content height (resize-derived)

# Derived layout (recomputed by _calc_layout from calc_w/calc_h).
DISP_X: int32 = 8
DISP_Y: int32 = 8
DISP_W: int32 = 172
DISP_H: int32 = 40
GRID_X: int32 = 8
GRID_Y: int32 = 56
KEY_W: int32 = 40
KEY_H: int32 = 40
KEY_GAP: int32 = 4


def _calc_layout():
    # Recompute the display-bar + keypad geometry to FILL the current
    # content area (calc_w x calc_h). The grid is 4 columns x 4 rows with a
    # gap; the display bar spans the full width above it. Everything is
    # centered so a maximized calculator has no black quadrants.
    pad: int32 = 8
    gap: int32 = 4
    # Display bar takes a fixed-ish slice of the top; keypad gets the rest.
    disp_h: int32 = calc_h / 6
    if disp_h < 32:
        disp_h = 32
    if disp_h > 120:
        disp_h = 120
    DISP_X = pad
    DISP_Y = pad
    DISP_W = calc_w - pad * 2
    if DISP_W < 16:
        DISP_W = 16
    DISP_H = disp_h
    # Keypad area: below the display bar, filling the remainder.
    grid_top: int32 = DISP_Y + DISP_H + pad
    avail_w: int32 = calc_w - pad * 2
    avail_h: int32 = calc_h - grid_top - pad
    if avail_w < 16:
        avail_w = 16
    if avail_h < 16:
        avail_h = 16
    KEY_GAP = gap
    kw: int32 = (avail_w - gap * 3) / 4
    kh: int32 = (avail_h - gap * 3) / 4
    if kw < 8:
        kw = 8
    if kh < 8:
        kh = 8
    KEY_W = kw
    KEY_H = kh
    # Center the 4x4 grid within the available area.
    grid_w: int32 = kw * 4 + gap * 3
    grid_h: int32 = kh * 4 + gap * 3
    GRID_X = pad + (avail_w - grid_w) / 2
    GRID_Y = grid_top + (avail_h - grid_h) / 2


# BUG 3: resize event reader. Recompute the layout to fill the new size.
def _calc_apply_resize(nw: int64, nh: int64) -> int32:
    if nw < 80:
        nw = 80
    if nh < 100:
        nh = 100
    if cast[int32](nw) == calc_w and cast[int32](nh) == calc_h:
        return 0
    calc_w = cast[int32](nw)
    calc_h = cast[int32](nh)
    _calc_layout()
    return 1


# Non-blocking /event poll for "r <w> <h>" resize lines. Returns 1 if a
# resize was applied. Pointer 'm' lines are handled by the main loop's
# separate (blocking) /event read; here we only mine resize lines that may
# arrive interleaved. (We share ONE /event fd in the main loop, so this
# resize parsing actually happens inline there — see main.)

# Transient pressed-key highlight (so a click visibly "sinks" the button).
press_key: int32 = -1

# Previous pointer button-1 state, for EDGE detection. The /event stream
# reports the button as a LEVEL on every "m <x> <y> <buttons>" line — and the
# compositor emits many such lines while button-1 is held (motion / repeats).
# Acting on the LEVEL re-ran the state machine (re-applying the digit/op) and
# re-committed the scene on every one of those lines: that is the flicker the
# user saw. We now act only on the press EDGE (up->down once per physical
# click) and the release edge, so a click commits exactly twice (sink, then
# un-sink) — never per-motion, never re-applying the key.
btn_down: int32 = 0

# Key model: 16 keys in a 4x4 grid. label[] is the glyph; kind/value drive
# the state machine. kind: 0=digit 1=op 2=equals 3=clear.
#   row0: 7 8 9 /
#   row1: 4 5 6 *
#   row2: 1 2 3 -
#   row3: C 0 = +
key_label: Array[16, uint8]            # one ASCII glyph per key
key_kind:  Array[16, int32]
key_val:   Array[16, int32]            # digit value, or op code


def _set_key(i: int32, glyph: uint8, kind: int32, val: int32):
    key_label[i] = glyph
    key_kind[i] = kind
    key_val[i] = val


def _init_keys():
    # digit glyph = '0'+d. op codes: '+'=1 '-'=2 '*'=3 '/'=4.
    _set_key(0, 55, 0, 7)              # '7'
    _set_key(1, 56, 0, 8)
    _set_key(2, 57, 0, 9)
    _set_key(3, 47, 1, 4)             # '/'
    _set_key(4, 52, 0, 4)
    _set_key(5, 53, 0, 5)
    _set_key(6, 54, 0, 6)
    _set_key(7, 42, 1, 3)             # '*'
    _set_key(8, 49, 0, 1)
    _set_key(9, 50, 0, 2)
    _set_key(10, 51, 0, 3)
    _set_key(11, 45, 1, 2)            # '-'
    _set_key(12, 67, 3, 0)            # 'C'
    _set_key(13, 48, 0, 0)            # '0'
    _set_key(14, 61, 2, 0)           # '='
    _set_key(15, 43, 1, 1)           # '+'


# Top-left of key i within the content area.
def _key_x(i: int32) -> int32:
    col: int32 = i % 4
    return GRID_X + col * (KEY_W + KEY_GAP)


def _key_y(i: int32) -> int32:
    row: int32 = i / 4
    return GRID_Y + row * (KEY_H + KEY_GAP)


# Which key index is at window-local (lx,ly), or -1.
def _key_at(lx: int64, ly: int64) -> int64:
    i: int32 = 0
    while i < 16:
        kx: int64 = cast[int64](_key_x(i))
        ky: int64 = cast[int64](_key_y(i))
        if lx >= kx and lx < kx + cast[int64](KEY_W) and \
           ly >= ky and ly < ky + cast[int64](KEY_H):
            return cast[int64](i)
        i = i + 1
    return -1


def emit_scene(wid: int32):
    hamscene_begin()
    # Body background (calculator case).
    hamscene_fill(0, 0, CALC_W, CALC_H, cast[Ptr[uint8]]("#2b2f36"))
    # Display bar: a sunken dark LCD with the value right-justified-ish.
    hamscene_fill(DISP_X, DISP_Y, DISP_W, DISP_H, cast[Ptr[uint8]]("#0d1410"))
    hamscene_stroke(DISP_X, DISP_Y, DISP_W, DISP_H, 1,
                    cast[Ptr[uint8]]("#5a6a5a"))
    # Right-align the display string within the LCD (8px monospace cells).
    _c_refresh()
    dl: uint64 = _slen(&disp_buf[0])
    tx: int32 = DISP_X + DISP_W - 8 - cast[int32](dl) * 8
    if tx < DISP_X + 6:
        tx = DISP_X + 6
    hamscene_glyphs(tx, DISP_Y + 14, &disp_buf[0],
                    cast[Ptr[uint8]]("#9ff09f"))
    # Button grid.
    i: int32 = 0
    while i < 16:
        kx: int32 = _key_x(i)
        ky: int32 = _key_y(i)
        sunk: int32 = 0
        if i == press_key:
            sunk = 1
        hamscene_panel_button(kx, ky, KEY_W, KEY_H, sunk)
        # Centered single-glyph label.
        lbl: Array[2, uint8]
        lbl[0] = key_label[i]
        lbl[1] = 0
        gx: int32 = kx + (KEY_W - 8) / 2
        gy: int32 = ky + (KEY_H - 8) / 2
        col: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
        if key_kind[i] == 1 or key_kind[i] == 2:
            col = cast[Ptr[uint8]]("#7a2a00")          # ops/= in dark orange
        if key_kind[i] == 3:
            col = cast[Ptr[uint8]]("#7a0000")          # clear in red
        hamscene_glyphs(gx, gy, &lbl[0], col)
        i = i + 1
    hamscene_commit(wid)


# Apply key index `k` to the state machine.
def _press(k: int64):
    kind: int32 = key_kind[k]
    val: int32 = key_val[k]
    if kind == 0:
        _c_digit(val)
    elif kind == 1:
        _c_operator(val)
    elif kind == 2:
        _c_equals()
    elif kind == 3:
        _c_clear()


# Parse "m <x> <y> <buttons> ..." → 1 + fills bx/by/bbtn; else 0.
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                            # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc2: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc2 = acc2 * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc2 = 0 - acc2
        vals[v] = acc2
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamcalc] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("geometry 610 130 188 248\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 6\n"))
        sys_close(cfd3)
    cfdt: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfdt >= 0:
        _writeall(cfdt, cast[Ptr[uint8]]("title Calculator\n"))
        sys_close(cfdt)

    _init_keys()
    _c_clear()
    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hamcalc] scene window ready\n"))

    evbuf: Array[256, uint8]
    while True:
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        changed: int32 = 0
        if efd >= 0:
            r: int64 = sys_read(efd, &evbuf[0], 255)
            sys_close(efd)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            bx: int64 = 0
                            by: int64 = 0
                            bbtn: int64 = 0
                            if parse_pointer(&evbuf[ls], i - ls, &bx, &by,
                                             &bbtn) == 1:
                                now_down: int32 = 0
                                if (bbtn & 1) != 0:
                                    now_down = 1
                                if now_down != 0 and btn_down == 0:
                                    # PRESS EDGE: apply the clicked key once.
                                    k: int64 = _key_at(bx, by)
                                    if k >= 0:
                                        _press(k)
                                        press_key = cast[int32](k)
                                        changed = 1
                                elif now_down == 0 and btn_down != 0:
                                    # RELEASE EDGE: clear the sink once.
                                    if press_key >= 0:
                                        press_key = -1
                                        changed = 1
                                # else: button held (motion) or still up —
                                # a LEVEL with no edge. Do NOTHING, do NOT
                                # re-commit: this is what kills the flicker.
                                btn_down = now_down
                        ls = i + 1
                    i = i + 1
        if changed != 0:
            emit_scene(wid)
        # cooperative yield window (matches hamfmscene); /event read blocks.
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 3:
            sys_yield()
    return 0

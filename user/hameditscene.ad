# user/hameditscene.ad
#
# Scene-file DE text editor — a minimal but real editor drawn entirely as a
# scene display list (docs/de_scene_file_arch.md). It is the scene-DE port
# of user/hamedit.ad: the on-box file I/O (open a path, read it into a
# buffer; Ctrl-S writes it back) is carried over; the render + input layers
# are scene-native.
#
# RENDER (§4 Widget/terminal tier): a title bar showing the filename, then a
# scrollable text area that renders the editable buffer as one `glyphs` line
# per visible row with a solid block CURSOR drawn at the caret cell.
#
# INPUT (§11): KEY events arrive on /dev/wsys/<wid>/keys as "<type> <code>\n"
# lines ('d' = press). Printable bytes insert at the caret, Backspace
# deletes, Enter inserts a newline, the arrow keys (ESC [ A/B/C/D, decoded
# from the key stream) move the caret, and Ctrl-S (code 19) saves back to
# the file. The editor POLLS /keys (non-blocking) and /event each iteration,
# cooperatively sleeping one jiffy only when both are idle — no busy-spin.
# Mouse-wheel notches arrive on /event (the kernel pointer router pushes
# "m ... <dz>" there) and scroll the text viewport (top_line).

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_yield() -> int32
extern def sys_waitfds(fds: Ptr[int32], nfds: uint64,
                       timeout_ms: int64) -> int64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

from lib.hamui import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_glyphs, hamscene_line, hamscene_commit
# Shared file-picker SERVICE (the real file-manager browse UI). The editor's
# bespoke in-window Save-As chooser was factored out into lib/filepick.ad so
# other apps reuse the same pathway; Ctrl-O/Ctrl-S(no path)/Ctrl-W pop it.
from lib.filepick import filepick_open, filepick_active, \
    filepick_handle_code, filepick_emit, filepick_take_result, \
    filepick_result_path, filepick_result_mode, filepick_click, \
    FILEPICK_OPEN, FILEPICK_SAVE


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# ====================================================================
# DOCUMENT MODEL — a flat byte buffer with a caret offset. Newlines in the
# buffer split it into rendered lines. (Carried from user/hamedit.ad's flat
# doc_buf; insert/delete/move are scene-native.)
# ====================================================================
DOC_CAP:  uint64 = 8192
READ_CHUNK: uint64 = 512

doc_buf:  Array[8192, uint8]
doc_len:  uint64 = 0
caret:    uint64 = 0            # byte offset of the insertion point [0..doc_len]
read_buf: Array[512, uint8]

fname_buf: Array[128, uint8]    # current filename (NUL-term), or empty
has_file:  int32 = 0
status_buf: Array[64, uint8]    # transient status (e.g. "saved 123 bytes")
status_len: uint64 = 0
top_line:  uint64 = 0          # first visible buffer line (vertical scroll)

def _set_status(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 63:
        status_buf[i] = s[i]
        i = i + 1
    status_buf[i] = 0
    status_len = i


def _set_status_num(prefix: Ptr[uint8], v: uint64):
    p: uint64 = 0
    while prefix[p] != 0 and p < 50:
        status_buf[p] = prefix[p]
        p = p + 1
    p = p + _u64_to_dec(v, &status_buf[p])
    status_buf[p] = 0
    status_len = p


# Insert one byte at the caret (shifting the tail right).
def _insert(c: uint8):
    if doc_len >= DOC_CAP - 1:
        return
    j: uint64 = doc_len
    while j > caret:
        doc_buf[j] = doc_buf[j - 1]
        j = j - 1
    doc_buf[caret] = c
    doc_len = doc_len + 1
    caret = caret + 1


# Delete the byte before the caret (Backspace).
def _backspace():
    if caret == 0:
        return
    j: uint64 = caret - 1
    while j + 1 < doc_len:
        doc_buf[j] = doc_buf[j + 1]
        j = j + 1
    doc_len = doc_len - 1
    caret = caret - 1


def _move_left():
    if caret > 0:
        caret = caret - 1


def _move_right():
    if caret < doc_len:
        caret = caret + 1


# Start-of-line offset for the byte offset `off` (scan back to prev '\n'+1).
def _line_start(off: uint64) -> uint64:
    i: uint64 = off
    while i > 0 and doc_buf[i - 1] != 10:
        i = i - 1
    return i


# End-of-line offset (the '\n' or doc_len) for offset `off`.
def _line_end(off: uint64) -> uint64:
    i: uint64 = off
    while i < doc_len and doc_buf[i] != 10:
        i = i + 1
    return i


def _move_up():
    ls: uint64 = _line_start(caret)
    if ls == 0:
        caret = 0
        return
    col: uint64 = caret - ls
    prev_end: uint64 = ls - 1                # the '\n' ending the prev line
    prev_start: uint64 = _line_start(prev_end)
    plen: uint64 = prev_end - prev_start
    if col > plen:
        col = plen
    caret = prev_start + col


def _move_down():
    le: uint64 = _line_end(caret)
    if le >= doc_len:
        caret = doc_len
        return
    ls: uint64 = _line_start(caret)
    col: uint64 = caret - ls
    next_start: uint64 = le + 1              # past the '\n'
    next_end: uint64 = _line_end(next_start)
    nlen: uint64 = next_end - next_start
    if col > nlen:
        col = nlen
    caret = next_start + col


# ====================================================================
# FILE I/O (carried from user/hamedit.ad)
# ====================================================================
def _do_open(path: Ptr[char]) -> int64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    doc_len = 0
    while doc_len < DOC_CAP - 1:
        n: int64 = sys_read(fd, &read_buf[0], READ_CHUNK)
        if n <= 0:
            break
        i: uint64 = 0
        while i < cast[uint64](n) and doc_len < DOC_CAP - 1:
            doc_buf[doc_len] = read_buf[i]
            doc_len = doc_len + 1
            i = i + 1
    sys_close(fd)
    caret = 0
    return cast[int64](doc_len)


def _do_save() -> int64:
    if has_file == 0:
        _set_status(cast[Ptr[uint8]]("no filename"))
        return -1
    # sys_open_write does open-or-create + O_TRUNC, so a SHORTER edit
    # leaves no stale tail bytes. A read-only backing (a synthetic device
    # such as /version) lets the OPEN succeed but the WRITE returns -1 —
    # we surface that honestly instead of flashing "saved" on a write that
    # never persisted (the user-reported bug: edit /version, "save", reopen
    # shows the original because the bytes were silently dropped).
    fd: int32 = sys_open_write(cast[Ptr[char]](&fname_buf[0]))
    if fd < 0:
        _set_status(cast[Ptr[uint8]]("save FAILED: cannot open for write"))
        return -1
    w: int64 = sys_write(fd, &doc_buf[0], doc_len)
    sys_close(fd)
    if w < 0:
        # Backing rejected the write (read-only device / EROFS): the file
        # was NOT changed. Say so rather than pretending success.
        _set_status(cast[Ptr[uint8]]("save FAILED: read-only (not written)"))
        return -1
    if cast[uint64](w) != doc_len:
        # Short write: only part of the buffer reached the file. Report it
        # as a failure so the user knows the on-disk copy is incomplete.
        _set_status(cast[Ptr[uint8]]("save FAILED: short write (incomplete)"))
        return -1
    _set_status_num(cast[Ptr[uint8]]("saved "), doc_len)
    return w


# ====================================================================
# FILE-PICKER — now the shared lib/filepick.ad SERVICE (the real file-
# manager browse UI). The editor's old bespoke in-window chooser lived
# here; it was extracted so OTHER apps reuse the same pathway. The editor
# only POPS the picker and, on commit, performs its own open/save on the
# returned path (the picker does no file I/O itself).
# --------------------------------------------------------------------
# Compute a sensible start directory for the picker (the dir of the
# current file if it has one, else the picker's own /home default).
def _ed_start_dir(out: Ptr[uint8]) -> int32:
    if has_file == 0:
        out[0] = 0
        return 0
    last: int64 = -1
    k: uint64 = 0
    while fname_buf[k] != 0:
        if fname_buf[k] == 47:
            last = cast[int64](k)
        k = k + 1
    if last <= 0:
        out[0] = 0
        return 0
    kk: uint64 = 0
    while kk < cast[uint64](last):
        out[kk] = fname_buf[kk]
        kk = kk + 1
    out[kk] = 0
    return 1


# The basename of the current file (for the SAVE field seed), or empty.
def _ed_basename(out: Ptr[uint8]):
    out[0] = 0
    if has_file == 0:
        return
    last: int64 = -1
    k: uint64 = 0
    while fname_buf[k] != 0:
        if fname_buf[k] == 47:
            last = cast[int64](k)
        k = k + 1
    b: uint64 = 0
    if last >= 0:
        b = cast[uint64](last) + 1
    o: uint64 = 0
    while fname_buf[b] != 0 and o < 126:
        out[o] = fname_buf[b]
        o = o + 1
        b = b + 1
    out[o] = 0


# Pop the shared picker in OPEN or SAVE mode, seeded from the current file.
def _ed_pop_picker(mode: int32):
    start: Array[512, uint8]
    _ed_start_dir(&start[0])
    if mode == FILEPICK_SAVE:
        seed: Array[128, uint8]
        _ed_basename(&seed[0])
        filepick_open(mode, &start[0], &seed[0])
    else:
        filepick_open(mode, &start[0], cast[Ptr[uint8]](0))


# Apply a committed pick (called from the main loop after a commit). For
# OPEN, load the path into the buffer; for SAVE, record it + write.
def _ed_apply_pick():
    path: Ptr[uint8] = filepick_result_path()
    # Record the chosen path as the current filename.
    k: uint64 = 0
    while path[k] != 0 and k < 127:
        fname_buf[k] = path[k]
        k = k + 1
    fname_buf[k] = 0
    has_file = 1
    if filepick_result_mode() == FILEPICK_OPEN:
        n: int64 = _do_open(cast[Ptr[char]](&fname_buf[0]))
        if n >= 0:
            _set_status_num(cast[Ptr[uint8]]("opened "), cast[uint64](n))
        else:
            _set_status(cast[Ptr[uint8]]("open failed"))
        top_line = 0
    else:
        _do_save()


# ====================================================================
# LAYOUT + RENDER
# ====================================================================
# BUG 1b: RESIZE-AWARE. ed_w/ed_h are the current content size, recomputed
# from the "r <w> <h>" resize event on /event; VIS_ROWS/VIS_COLS (the text
# viewport) are derived from them so a maximized editor shows more text.
ED_W: int32 = 400             # initial default width
ED_H: int32 = 260             # initial default height
ed_w: int32 = 400             # current content width
ed_h: int32 = 260             # current content height
TITLE_H: int32 = 18
TEXT_X: int32 = 6
TEXT_Y: int32 = 22
LINE_H: int32 = 16
CELL_W: int32 = 8
VIS_ROWS: uint64 = 13         # visible text rows    (runtime, resize-derived)
VIS_COLS: uint64 = 48         # visible columns      (runtime, resize-derived)
ED_MAX_ROWS: uint64 = 48      # clamp (800px / 16px line)
ED_MAX_COLS: uint64 = 158     # clamp (1280px / 8px cell)


def _ed_apply_resize(nw: int64, nh: int64) -> int32:
    # Recompute the editor content size + text viewport from a resize event.
    # Returns 1 if anything changed.
    if nw < CELL_W * 8:
        nw = CELL_W * 8
    if nh < TEXT_Y + LINE_H:
        nh = TEXT_Y + LINE_H
    if cast[int32](nw) == ed_w and cast[int32](nh) == ed_h:
        return 0
    ed_w = cast[int32](nw)
    ed_h = cast[int32](nh)
    nc: uint64 = cast[uint64]((ed_w - TEXT_X - GUTTER_W - 2) / CELL_W)
    if nc < 8:
        nc = 8
    if nc > ED_MAX_COLS:
        nc = ED_MAX_COLS
    nr: uint64 = cast[uint64]((ed_h - TEXT_Y) / LINE_H)
    if nr < 2:
        nr = 2
    if nr > ED_MAX_ROWS:
        nr = ED_MAX_ROWS
    VIS_COLS = nc
    VIS_ROWS = nr
    return 1


# Non-blocking /event poll for "r <w> <h>" resize lines AND "m <x> <y>
# <buttons> <dz>" pointer/wheel lines. Returns 1 if the visible viewport
# changed (resize re-layout OR a mouse-wheel scroll). evbuf/evcarry carry
# partial lines across reads.
ed_evbuf:   Array[256, uint8]
ed_evcarry: uint64 = 0
# One-shot wheel-marker guard (see hamtermscene): emit the gate's delivery
# proof once, not on every notch, so live scrolling doesn't flood the console.
ed_wheel_marked: uint64 = 0


def _ed_scroll_by(notches: int64):
    # Mouse-wheel vertical scroll of the visual-row viewport. dz>0 (wheel up)
    # scrolls TOWARD the top of the document (smaller top_line, reveals lines
    # above); dz<0 (wheel down) scrolls toward the bottom. top_line is clamped
    # to [0, last visual row] so we cannot scroll past the document ends.
    if notches > 0:
        sub: uint64 = cast[uint64](notches)
        if sub > top_line:
            top_line = 0
        else:
            top_line = top_line - sub
    elif notches < 0:
        add: uint64 = cast[uint64](0 - notches)
        last_vr: uint64 = _visual_row_of(doc_len)
        nt: uint64 = top_line + add
        if nt > last_vr:
            nt = last_vr
        top_line = nt


def _ed_poll_events(efd: int32) -> int32:
    if efd < 0:
        return 0
    changed: int32 = 0
    passes: int32 = 0
    while passes < 4:
        room: uint64 = 256 - ed_evcarry
        if room == 0:
            ed_evcarry = 0
            room = 256
        en: int64 = sys_read_nb(efd, &ed_evbuf[ed_evcarry], room)
        if en <= 0:
            break
        total: uint64 = ed_evcarry + cast[uint64](en)
        i: uint64 = 0
        ls: uint64 = 0
        while i < total:
            if ed_evbuf[i] == 10:
                if i > ls and ed_evbuf[ls] == 114:        # 'r'
                    p: uint64 = ls + 1
                    while p < i and ed_evbuf[p] == 32:
                        p = p + 1
                    wv: int64 = 0
                    while p < i and ed_evbuf[p] >= 48 and ed_evbuf[p] <= 57:
                        wv = wv * 10 + cast[int64](ed_evbuf[p]) - 48
                        p = p + 1
                    while p < i and ed_evbuf[p] == 32:
                        p = p + 1
                    hv: int64 = 0
                    while p < i and ed_evbuf[p] >= 48 and ed_evbuf[p] <= 57:
                        hv = hv * 10 + cast[int64](ed_evbuf[p]) - 48
                        p = p + 1
                    if wv > 0 and hv > 0:
                        if _ed_apply_resize(wv, hv) != 0:
                            changed = 1
                elif i > ls and ed_evbuf[ls] == 109:      # 'm' pointer/wheel
                    # When the FILE-PICKER is open, a button-1 press is a cell
                    # click: forward x/y to the shared picker (single click
                    # selects; a click on the already-selected cell or any dir
                    # navigates / opens). This makes the picker pointer-driven
                    # on top of its key navigation — same icon grid, real
                    # clicks. Parse the first three numeric fields (x y buttons).
                    if filepick_active() != 0:
                        cp: uint64 = ls + 1
                        cv: Array[3, int64]
                        cf: uint64 = 0
                        while cf < 3:
                            while cp < i and ed_evbuf[cp] == 32:
                                cp = cp + 1
                            cneg: int32 = 0
                            if cp < i and ed_evbuf[cp] == 45:
                                cneg = 1
                                cp = cp + 1
                            acc: int64 = 0
                            cg: int32 = 0
                            while cp < i and ed_evbuf[cp] >= 48 and \
                                  ed_evbuf[cp] <= 57:
                                acc = acc * 10 + cast[int64](ed_evbuf[cp]) - 48
                                cp = cp + 1
                                cg = 1
                            if cneg != 0:
                                acc = 0 - acc
                            cv[cf] = acc
                            if cg == 0:
                                cf = 3
                            else:
                                cf = cf + 1
                        if (cv[2] & 1) != 0:
                            if filepick_click(cv[0], cv[1]) != 0:
                                changed = 1
                    # Mine the dz (5th) field; x/y/buttons are pointer noise
                    # the editor does not type. Wheel notches scroll the view.
                    mp: uint64 = ls
                    field: int32 = 0
                    while field < 4:          # walk past type,x,y,buttons
                        while mp < i and ed_evbuf[mp] != 32:
                            mp = mp + 1
                        while mp < i and ed_evbuf[mp] == 32:
                            mp = mp + 1
                        field = field + 1
                    neg: int32 = 0
                    if mp < i and ed_evbuf[mp] == 45:     # '-'
                        neg = 1
                        mp = mp + 1
                    dz: int64 = 0
                    have: int32 = 0
                    while mp < i and ed_evbuf[mp] >= 48 and ed_evbuf[mp] <= 57:
                        dz = dz * 10 + cast[int64](ed_evbuf[mp]) - 48
                        mp = mp + 1
                        have = 1
                    if have != 0 and dz != 0:
                        if neg != 0:
                            dz = 0 - dz
                        prev_top: uint64 = top_line
                        _ed_scroll_by(dz)
                        if top_line != prev_top:
                            changed = 1
                            # End-to-end delivery proof (boot console): a wheel
                            # notch reached /event and moved the text viewport.
                            # Emitted ONCE so live scrolling doesn't flood.
                            if ed_wheel_marked == 0:
                                ed_wheel_marked = 1
                                _writeall(1,
                                    cast[Ptr[uint8]]("[hamedit] WHEEL dz applied\n"))
                ls = i + 1
            i = i + 1
        # Carry any trailing partial line.
        leftover: uint64 = total - ls
        m: uint64 = 0
        while m < leftover:
            ed_evbuf[m] = ed_evbuf[ls + m]
            m = m + 1
        ed_evcarry = leftover
        passes = passes + 1
    return changed


# BUG #6 (soft-wrap): the editor wraps long logical lines at VIS_COLS into
# multiple VISUAL rows. _visual_row_of(off) returns the visual-row index of
# byte offset `off` from the top of the document (counting wrapped segments),
# so scroll-follow and the caret render in visual-row space, not logical-line
# space. A logical line of length L occupies ceil((L+1)/VIS_COLS) visual rows
# when empty-or-exact (the +0/+1 handles the end-of-line caret cell), but for
# scrolling we only need the START visual row of each char, so we advance a
# visual column per char and wrap to a new visual row at VIS_COLS or '\n'.
def _visual_row_of(off: uint64) -> uint64:
    vr: uint64 = 0
    vc: uint64 = 0
    i: uint64 = 0
    while i < off:
        if doc_buf[i] == 10:
            vr = vr + 1
            vc = 0
        else:
            vc = vc + 1
            if vc >= VIS_COLS:
                vr = vr + 1
                vc = 0
        i = i + 1
    return vr


# Ensure top_line keeps the caret's VISUAL row visible (wrap-aware scroll).
def _scroll_follow():
    cl: uint64 = _visual_row_of(caret)
    if cl < top_line:
        top_line = cl
    if cl >= top_line + VIS_ROWS:
        top_line = cl - VIS_ROWS + 1


# Compute the 1-based (line, col) of the caret for the Kate-style status.
def _caret_line_col(line_p: Ptr[uint64], col_p: Ptr[uint64]):
    ln: uint64 = 1
    cl: uint64 = 1
    i: uint64 = 0
    while i < caret:
        if doc_buf[i] == 10:
            ln = ln + 1
            cl = 1
        else:
            cl = cl + 1
        i = i + 1
    line_p[0] = ln
    col_p[0] = cl


# Number of logical lines in the document (for the gutter width estimate).
def _total_lines() -> uint64:
    n: uint64 = 1
    i: uint64 = 0
    while i < doc_len:
        if doc_buf[i] == 10:
            n = n + 1
        i = i + 1
    return n


GUTTER_W: int32 = 30          # line-number gutter width (px)


def emit_scene(wid: int32):
    hamscene_begin()
    # FILE-PICKER overlay takes the whole window when open. Draw it and
    # commit — the editor body underneath is not drawn (modal).
    if filepick_active() != 0:
        filepick_emit(ed_w, ed_h)
        hamscene_commit(wid)
        return
    # Editor canvas.
    hamscene_fill(0, 0, ed_w, ed_h, cast[Ptr[uint8]]("#fbfbf7"))
    # Kate-style line-number gutter band.
    hamscene_fill(0, TITLE_H, GUTTER_W, ed_h - TITLE_H,
                  cast[Ptr[uint8]]("#eceae2"))
    hamscene_line(GUTTER_W, TITLE_H, GUTTER_W, ed_h, 1,
                  cast[Ptr[uint8]]("#d2cfc4"))
    # Title bar with filename.
    hamscene_rect(0, 0, ed_w, TITLE_H, cast[Ptr[uint8]]("#3a6ea5"))
    tbuf: Array[80, uint8]
    tp: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("hamedit: ")
    a: uint64 = 0
    while pre[a] != 0:
        tbuf[tp] = pre[a]
        tp = tp + 1
        a = a + 1
    if has_file != 0:
        b: uint64 = 0
        while fname_buf[b] != 0 and tp < 70:
            tbuf[tp] = fname_buf[b]
            tp = tp + 1
            b = b + 1
    else:
        nn: Ptr[uint8] = cast[Ptr[uint8]]("(unnamed)")
        c: uint64 = 0
        while nn[c] != 0:
            tbuf[tp] = nn[c]
            tp = tp + 1
            c = c + 1
    tbuf[tp] = 0
    hamscene_glyphs(4, 4, &tbuf[0], cast[Ptr[uint8]]("#ffffff"))

    # BUG #6 (soft-wrap): walk the whole document in VISUAL rows, wrapping each
    # logical line at VIS_COLS, and render the window of [top_line,
    # top_line+VIS_ROWS) visual rows. A visual row is flushed as one `glyphs`
    # line; the caret (a block behind its cell) is placed by the visual (row,
    # col) of the caret byte offset. We accumulate the current visual row into
    # rowbuf and emit it whenever it wraps (hits VIS_COLS), hits a '\n', or the
    # document ends.
    _scroll_follow()
    # Kate-style: which logical line holds the caret (1-based), for the
    # current-line highlight + the line:col status.
    cur_ln: uint64 = 0
    cur_col: uint64 = 0
    _caret_line_col(&cur_ln, &cur_col)
    rowbuf: Array[160, uint8]                     # >= ED_MAX_COLS + 1
    rl: uint64 = 0                                # chars in the current vrow
    vrow: uint64 = 0                              # current visual-row index
    rendered: uint64 = 0                          # vrows emitted into the window
    caret_col_in_vrow: int64 = -1                 # caret col if it's on this vrow
    logline: uint64 = 1                           # logical line of THIS vrow (1-based)
    line_head: int32 = 1                          # 1 if vrow is the 1st seg of its logical line
    off: uint64 = 0
    while off <= doc_len and rendered < VIS_ROWS:
        # Is the caret at THIS byte position, and is this vrow visible? At a
        # wrap boundary (rl == VIS_COLS) the caret belongs at col 0 of the NEXT
        # visual row, so skip it here and let the re-entered iteration (same
        # off, fresh vrow) place it — avoids a double caret block.
        if off == caret and vrow >= top_line and rl < VIS_COLS:
            caret_col_in_vrow = cast[int64](rl)
        # End-of-vrow conditions: a '\n', a wrap at VIS_COLS, or end-of-doc.
        atnl: int32 = 0
        if off < doc_len and doc_buf[off] == 10:
            atnl = 1
        ateof: int32 = 0
        if off >= doc_len:
            ateof = 1
        if atnl == 0 and ateof == 0 and rl < VIS_COLS:
            # Accumulate one rendered glyph (tabs shown as a space).
            ch: uint8 = doc_buf[off]
            if ch == 9:
                ch = 32
            rowbuf[rl] = ch
            rl = rl + 1
            off = off + 1
            continue
        # Flush the current visual row (if it is within the viewport).
        if vrow >= top_line:
            rowbuf[rl] = 0
            yy: int32 = TEXT_Y + cast[int32](rendered) * LINE_H
            txt_x: int32 = TEXT_X + GUTTER_W      # text starts past the gutter
            # Kate-style current-line highlight: tint the whole text-area
            # row band when this visual row belongs to the caret's logical
            # line. Drawn UNDER the glyphs (and under the caret block).
            if logline == cur_ln:
                hamscene_fill(GUTTER_W + 1, yy, ed_w - GUTTER_W - 1, LINE_H,
                              cast[Ptr[uint8]]("#eef3fb"))
            # Line-number gutter: only on the FIRST visual segment of a
            # logical line (wrapped continuation rows get no number).
            if line_head != 0:
                gnum: Array[12, uint8]
                gn: uint64 = _u64_to_dec(logline, &gnum[0])
                gnum[gn] = 0
                # Right-align within the gutter (8 px/glyph).
                gx: int32 = GUTTER_W - 4 - cast[int32](gn) * CELL_W
                if gx < 2:
                    gx = 2
                hamscene_glyphs(gx, yy + 2, &gnum[0],
                                cast[Ptr[uint8]]("#909088"))
            if caret_col_in_vrow >= 0:
                cxp: int32 = txt_x + cast[int32](caret_col_in_vrow) * CELL_W
                hamscene_fill(cxp, yy, CELL_W, LINE_H - 2,
                              cast[Ptr[uint8]]("#2a64c8"))
            if rl > 0:
                hamscene_glyphs(txt_x, yy + 2, &rowbuf[0],
                                cast[Ptr[uint8]]("#101010"))
            rendered = rendered + 1
        # Advance to the next visual row.
        caret_col_in_vrow = -1
        rl = 0
        if ateof != 0:
            break
        if atnl != 0:
            off = off + 1                         # consume the '\n'
            logline = logline + 1                 # new logical line
            line_head = 1                         # its first seg
        else:
            line_head = 0                         # a soft-wrap continuation
        vrow = vrow + 1
    # (The old bespoke bottom-line "Save As:" prompt was replaced by the
    # shared lib/filepick.ad overlay, drawn above when filepick_active().)
    if True:
        # Status line along the bottom.
        if status_len > 0:
            hamscene_glyphs(6, ed_h - 14, &status_buf[0],
                            cast[Ptr[uint8]]("#207020"))
        # Kate-style line:col indicator, right-aligned on the status row.
        lcbuf: Array[40, uint8]
        lp: uint64 = 0
        pfx: Ptr[uint8] = cast[Ptr[uint8]]("Ln ")
        a3: uint64 = 0
        while pfx[a3] != 0:
            lcbuf[lp] = pfx[a3]
            lp = lp + 1
            a3 = a3 + 1
        lp = lp + _u64_to_dec(cur_ln, &lcbuf[lp])
        com: Ptr[uint8] = cast[Ptr[uint8]](", Col ")
        a3 = 0
        while com[a3] != 0:
            lcbuf[lp] = com[a3]
            lp = lp + 1
            a3 = a3 + 1
        lp = lp + _u64_to_dec(cur_col, &lcbuf[lp])
        lcbuf[lp] = 0
        lcx: int32 = ed_w - cast[int32](lp) * CELL_W - 6
        if lcx < 6:
            lcx = 6
        hamscene_glyphs(lcx, ed_h - 14, &lcbuf[0],
                        cast[Ptr[uint8]]("#707068"))
    hamscene_commit(wid)


# ====================================================================
# KEY INPUT — parse "<type> <code>\n" lines; decode ESC [ A/B/C/D arrows.
# ====================================================================
# Arrow-key decode state: 0 = ground, 1 = saw ESC(27), 2 = saw ESC '['.
esc_st: int32 = 0


# Handle one decoded key code. Returns 1 if the document/caret changed.
def _handle_code(code: int32) -> int32:
    # FILE-PICKER modal (shared lib/filepick.ad): while open, ALL keys drive
    # the picker (folder navigation + filename entry). Document editing is
    # frozen. The committed pick is applied by the main loop via
    # filepick_take_result()/_ed_apply_pick().
    if filepick_active() != 0:
        return filepick_handle_code(code)
    # Arrow CSI decode.
    if esc_st == 1:
        if code == 91:                          # '['
            esc_st = 2
            return 0
        esc_st = 0
        # fallthrough: treat as a normal key below
    elif esc_st == 2:
        esc_st = 0
        if code == 65:                          # 'A' up
            _move_up()
            return 1
        if code == 66:                          # 'B' down
            _move_down()
            return 1
        if code == 67:                          # 'C' right
            _move_right()
            return 1
        if code == 68:                          # 'D' left
            _move_left()
            return 1
        return 0
    if code == 27:                              # ESC -> begin CSI
        esc_st = 1
        return 0
    if code == 15:                              # Ctrl-O -> Open picker
        _ed_pop_picker(FILEPICK_OPEN)
        _set_status(cast[Ptr[uint8]]("Open: pick a file"))
        return 1
    if code == 19:                              # Ctrl-S -> save
        if has_file == 0:
            # No filename yet -> pop the shared file-PICKER in SAVE mode so
            # the user navigates to a FOLDER and names the file (the real
            # file-manager browse UI, not a bespoke bottom-line prompt).
            _ed_pop_picker(FILEPICK_SAVE)
            _set_status(cast[Ptr[uint8]]("Save As: pick a folder + name"))
            return 1
        _do_save()
        return 1
    if code == 23:                              # Ctrl-W -> Save As (pick)
        # Always-available "Save As": pop the SAVE picker even when the
        # buffer already has a name, so the user can choose a new folder.
        _ed_pop_picker(FILEPICK_SAVE)
        _set_status(cast[Ptr[uint8]]("Save As: pick a folder + name"))
        return 1
    if code == 13 or code == 10:                # Enter -> newline
        _insert(10)
        status_len = 0
        return 1
    if code == 8 or code == 127:                # Backspace / DEL
        _backspace()
        status_len = 0
        return 1
    if code >= 32 and code < 127:               # printable -> insert
        _insert(cast[uint8](code))
        status_len = 0
        return 1
    return 0


kev_buf: Array[512, uint8]
kev_carry: uint64 = 0


# Parse complete "<type> <code>\n" lines out of kev_buf[0..n). Returns bytes
# consumed (offset past the last '\n'); any partial trailing line is carried.
# Sets *changed_p to 1 if any key mutated the doc/caret.
def _drain_keys_chunk(n: uint64, changed_p: Ptr[int32]) -> uint64:
    i: uint64 = 0
    consumed: uint64 = 0
    while i < n:
        t: uint8 = kev_buf[i]
        i = i + 1
        if i < n and kev_buf[i] == 32:
            i = i + 1
        code: int32 = 0
        have: int32 = 0
        neg: int32 = 0
        if i < n and kev_buf[i] == 45:
            neg = 1
            i = i + 1
        while i < n and kev_buf[i] >= 48 and kev_buf[i] <= 57:
            code = code * 10 + cast[int32](kev_buf[i]) - 48
            i = i + 1
            have = 1
        while i < n and kev_buf[i] != 10:
            i = i + 1
        if i >= n:
            # incomplete line — carry it forward.
            return consumed
        i = i + 1                               # consume '\n'
        consumed = i
        if neg != 0:
            code = 0 - code
        # Only press events ('d', 100) with a real code drive editing.
        if t != 100 or have == 0:
            continue
        if _handle_code(code) != 0:
            changed_p[0] = 1
    return consumed


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamedit] FAIL newwindow\n"))
        return 1

    # Publish our window id to a fixed tmpfs path so a scripted driver
    # (e.g. scripts/test_hamedit_save.sh) can inject keys to exactly THIS
    # window's /keys ring without guessing the wid. Best-effort; harmless
    # if /tmp is absent.
    widf: int32 = sys_open_write(cast[Ptr[char]]("/tmp/.hamedit_wid"))
    if widf >= 0:
        widtxt: Array[24, uint8]
        wl: uint64 = _u64_to_dec(cast[uint64](wid), &widtxt[0])
        widtxt[wl] = 10
        sys_write(widf, &widtxt[0], wl + 1)
        sys_close(widf)

    ctlp: Array[64, uint8]
    keysp: Array[64, uint8]
    evtp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))
    _winpath(&evtp[0], wid, cast[Ptr[uint8]]("/event"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("geometry 180 120 400 260\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 6\n"))
        sys_close(cfd3)
    cfdt: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfdt >= 0:
        _writeall(cfdt, cast[Ptr[uint8]]("title Editor\n"))
        sys_close(cfdt)

    # Preload a file if a path was passed as argv[1].
    doc_len = 0
    caret = 0
    has_file = 0
    if argc >= 2 and argv != cast[Ptr[uint64]](0):
        path: Ptr[char] = cast[Ptr[char]](argv[1])
        # Record the filename.
        pb: Ptr[uint8] = cast[Ptr[uint8]](path)
        k: uint64 = 0
        while pb[k] != 0 and k < 127:
            fname_buf[k] = pb[k]
            k = k + 1
        fname_buf[k] = 0
        has_file = 1
        n: int64 = _do_open(path)
        if n >= 0:
            _set_status_num(cast[Ptr[uint8]]("opened "), cast[uint64](n))
        else:
            _set_status(cast[Ptr[uint8]]("new file"))
    else:
        _set_status(cast[Ptr[uint8]]("Ctrl-S saves; arrows move"))

    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hamedit] scene window ready\n"))

    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))
    efd: int32 = sys_open(cast[Ptr[char]](&evtp[0]))   # BUG 1b: resize events
    if kfd < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamedit] FAIL open keys\n"))
        # Still show the window; just idle.
        while True:
            sys_yield()
        return 1

    # EVENT-DRIVEN loop. Keystrokes drive instant edits; mouse-wheel notches
    # arrive on /event (the in-kernel pointer router pushes "m <x> <y> <btn>
    # <dz>" onto the EVENT ring, NOT a separate /pointer file). devwsys's
    # event fd is a non-blocking snapshot read with no waitfds wake hook, so a
    # wheel notch can't wake us through it — but /keys IS waitfds-wake-wired
    # (wsys_route_key -> waitfds_notify). So each iteration we do a NON-BLOCKING
    # /keys read + an /event drain; when both are idle we BLOCK in sys_waitfds
    # on /keys with a short timeout. A keystroke wakes us in ~0 ms (no typing
    # regression vs the old blocking read); the timeout only bounds the /event
    # re-poll so an idle-time wheel notch scrolls within one tick. No busy-spin.
    EDIT_IDLE_WAIT_MS: int64 = 10             # /event re-poll cap (1 jiffy)
    while True:
        room: uint64 = 512 - kev_carry
        if room == 0:
            kev_carry = 0
            room = 512
        # NON-BLOCKING keys read so the /event poll below always runs.
        kn: int64 = sys_read_nb(kfd, &kev_buf[kev_carry], room)
        did_work: int32 = 0
        # BUG 1b + mouse-wheel: poll /event for resize re-layout AND wheel
        # scroll; either re-emits the scene.
        if _ed_poll_events(efd) != 0:
            emit_scene(wid)
            did_work = 1
        if kn > 0:
            total: uint64 = kev_carry + cast[uint64](kn)
            changed: int32 = 0
            done: uint64 = _drain_keys_chunk(total, &changed)
            leftover: uint64 = total - done
            m: uint64 = 0
            while m < leftover:
                kev_buf[m] = kev_buf[done + m]
                m = m + 1
            kev_carry = leftover
            if changed != 0:
                emit_scene(wid)
            did_work = 1
        # Apply a committed file-picker result (the picker only RESOLVES a
        # path; the editor performs its own open/save). Re-emit so the
        # editor canvas (or new buffer) repaints after the modal closes.
        if filepick_take_result() != 0:
            _ed_apply_pick()
            emit_scene(wid)
            did_work = 1
        # Block ONLY when this iteration was fully idle. Wake instantly on a
        # keystroke (waitfds-wake-wired); the timeout bounds the /event re-poll.
        if did_work == 0:
            wfds: Array[1, int32]
            wfds[0] = kfd
            sys_waitfds(&wfds[0], 1, EDIT_IDLE_WAIT_MS)
    return 0

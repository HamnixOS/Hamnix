# user/hameditscene.ad
#
# Scene-file DE text editor — a minimal but real editor drawn entirely as a
# scene display list (docs/de_scene_file_arch.md). It is the scene-DE port
# of user/hamedit.ad: the on-box file I/O (open a path, read it into a
# buffer; Ctrl-S writes it back) is carried over; the render + input layers
# are scene-native.
#
# RENDER (§4 Widget/terminal tier): a title bar showing the filename, then a
# scrollable text area that renders the editable buffer as one `glyphs` line
# per visible row with a solid block CURSOR drawn at the caret cell.
#
# INPUT (§11): KEY events arrive on /dev/wsys/<wid>/keys as "<type> <code>\n"
# lines ('d' = press). Printable bytes insert at the caret, Backspace
# deletes, Enter inserts a newline, the arrow keys (ESC [ A/B/C/D, decoded
# from the key stream) move the caret, and Ctrl-S (code 19) saves back to
# the file. The editor BLOCKS on /keys (event-driven, like hamtermscene),
# no busy-spin. POINTER events live on a separate /event file we never open.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

from lib.p9 import p9_listdir, p9_chan_dir_mode, p9_dir_decode_at, \
    DIR_CUR_QTYPE, DIR_CUR_NAME, DIR_CUR_NAME_LEN, P9_QTDIR
from lib.hamui import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_glyphs, hamscene_stroke, hamscene_line, hamscene_commit


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# ====================================================================
# DOCUMENT MODEL — a flat byte buffer with a caret offset. Newlines in the
# buffer split it into rendered lines. (Carried from user/hamedit.ad's flat
# doc_buf; insert/delete/move are scene-native.)
# ====================================================================
DOC_CAP:  uint64 = 8192
READ_CHUNK: uint64 = 512

doc_buf:  Array[8192, uint8]
doc_len:  uint64 = 0
caret:    uint64 = 0            # byte offset of the insertion point [0..doc_len]
read_buf: Array[512, uint8]

fname_buf: Array[128, uint8]    # current filename (NUL-term), or empty
has_file:  int32 = 0
status_buf: Array[64, uint8]    # transient status (e.g. "saved 123 bytes")
status_len: uint64 = 0
top_line:  uint64 = 0          # first visible buffer line (vertical scroll)

# BUG #8 (Ctrl-S Save-As): when Ctrl-S is pressed with no filename, the editor
# enters a modal "Save As:" prompt — an in-window text-input field along the
# bottom status row. While prompting != 0 all printable keys edit prompt_buf
# (the target path), Enter commits the save to that path, Esc/Ctrl-C cancels.
# Document editing keys are suppressed during the prompt so typing the path
# never mutates the buffer.
prompting:   int32 = 0
prompt_buf:  Array[128, uint8]
prompt_len:  uint64 = 0


def _set_status(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 63:
        status_buf[i] = s[i]
        i = i + 1
    status_buf[i] = 0
    status_len = i


def _set_status_num(prefix: Ptr[uint8], v: uint64):
    p: uint64 = 0
    while prefix[p] != 0 and p < 50:
        status_buf[p] = prefix[p]
        p = p + 1
    p = p + _u64_to_dec(v, &status_buf[p])
    status_buf[p] = 0
    status_len = p


# Insert one byte at the caret (shifting the tail right).
def _insert(c: uint8):
    if doc_len >= DOC_CAP - 1:
        return
    j: uint64 = doc_len
    while j > caret:
        doc_buf[j] = doc_buf[j - 1]
        j = j - 1
    doc_buf[caret] = c
    doc_len = doc_len + 1
    caret = caret + 1


# Delete the byte before the caret (Backspace).
def _backspace():
    if caret == 0:
        return
    j: uint64 = caret - 1
    while j + 1 < doc_len:
        doc_buf[j] = doc_buf[j + 1]
        j = j + 1
    doc_len = doc_len - 1
    caret = caret - 1


def _move_left():
    if caret > 0:
        caret = caret - 1


def _move_right():
    if caret < doc_len:
        caret = caret + 1


# Start-of-line offset for the byte offset `off` (scan back to prev '\n'+1).
def _line_start(off: uint64) -> uint64:
    i: uint64 = off
    while i > 0 and doc_buf[i - 1] != 10:
        i = i - 1
    return i


# End-of-line offset (the '\n' or doc_len) for offset `off`.
def _line_end(off: uint64) -> uint64:
    i: uint64 = off
    while i < doc_len and doc_buf[i] != 10:
        i = i + 1
    return i


def _move_up():
    ls: uint64 = _line_start(caret)
    if ls == 0:
        caret = 0
        return
    col: uint64 = caret - ls
    prev_end: uint64 = ls - 1                # the '\n' ending the prev line
    prev_start: uint64 = _line_start(prev_end)
    plen: uint64 = prev_end - prev_start
    if col > plen:
        col = plen
    caret = prev_start + col


def _move_down():
    le: uint64 = _line_end(caret)
    if le >= doc_len:
        caret = doc_len
        return
    ls: uint64 = _line_start(caret)
    col: uint64 = caret - ls
    next_start: uint64 = le + 1              # past the '\n'
    next_end: uint64 = _line_end(next_start)
    nlen: uint64 = next_end - next_start
    if col > nlen:
        col = nlen
    caret = next_start + col


# ====================================================================
# FILE I/O (carried from user/hamedit.ad)
# ====================================================================
def _do_open(path: Ptr[char]) -> int64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    doc_len = 0
    while doc_len < DOC_CAP - 1:
        n: int64 = sys_read(fd, &read_buf[0], READ_CHUNK)
        if n <= 0:
            break
        i: uint64 = 0
        while i < cast[uint64](n) and doc_len < DOC_CAP - 1:
            doc_buf[doc_len] = read_buf[i]
            doc_len = doc_len + 1
            i = i + 1
    sys_close(fd)
    caret = 0
    return cast[int64](doc_len)


def _do_save() -> int64:
    if has_file == 0:
        _set_status(cast[Ptr[uint8]]("no filename"))
        return -1
    fd: int32 = sys_open_write(cast[Ptr[char]](&fname_buf[0]))
    if fd < 0:
        _set_status(cast[Ptr[uint8]]("save failed"))
        return -1
    w: int64 = sys_write(fd, &doc_buf[0], doc_len)
    sys_close(fd)
    if w < 0:
        _set_status(cast[Ptr[uint8]]("save failed"))
        return -1
    _set_status_num(cast[Ptr[uint8]]("saved "), doc_len)
    return w


# BUG #8: commit the Save-As prompt. Copy prompt_buf -> fname_buf, mark the
# file named, leave prompt mode, and write the buffer to that path.
def _commit_save_as() -> int64:
    if prompt_len == 0:
        _set_status(cast[Ptr[uint8]]("save cancelled (empty name)"))
        prompting = 0
        return -1
    k: uint64 = 0
    while k < prompt_len and k < 127:
        fname_buf[k] = prompt_buf[k]
        k = k + 1
    fname_buf[k] = 0
    has_file = 1
    prompting = 0
    return _do_save()


# ====================================================================
# FILE-PICKER (Kate-style Open / Save-As browser) — SELF-CONTAINED
# --------------------------------------------------------------------
# A modal file browser drawn as an overlay over the editor canvas. It
# navigates directories (enter a dir, ".." to go up), lists subdirs +
# files (one glyphs row each), lets the user pick a file to OPEN, and —
# in SAVE mode — type a filename into a bottom field and save at the
# chosen <dir>/<name>. The directory enumeration mirrors hamfmscene's
# load_dir (Dir-record mode, with a plain name-stream fallback) but the
# code is copied here so hameditscene stays self-contained.
#
# pk_mode: 0 = closed, 1 = OPEN picker, 2 = SAVE picker.
# Input is routed via _handle_code (the existing /keys path) — while the
# picker is open ALL keys drive the picker, document editing is frozen,
# so the editor's fast-type / soft-wrap path is untouched when closed.
# ====================================================================
PK_MAX:       uint64 = 256
PK_NAME_CAP:  uint64 = 48
PK_LIST_CAP:  uint64 = 32768
PK_PATH_CAP:  uint64 = 512

pk_mode:      int32 = 0          # 0 closed, 1 OPEN, 2 SAVE
pk_dir:       Array[512, uint8]  # current directory (NUL-term)
pk_dir_len:   uint64 = 0
pk_list:      Array[32768, uint8]
pk_names:     Array[12288, uint8]   # PK_MAX * PK_NAME_CAP
pk_name_len:  Array[256, uint64]
pk_is_dir:    Array[256, int32]
pk_n:         uint64 = 0          # entry count
pk_has_up:    int32 = 0           # row 0 is a synthetic ".."
pk_sel:       int64 = 0           # highlighted row
pk_top:       uint64 = 0          # first visible row (scroll)
pk_full:      Array[576, uint8]   # scratch full path
pk_save_name: Array[128, uint8]   # SAVE-mode typed filename
pk_save_len:  uint64 = 0
PK_ROW_H:     int32 = 14          # picker list row height
PK_VIS:       uint64 = 9          # default visible rows (resize-derived)


def pk_name_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&pk_names[0]) + i * PK_NAME_CAP)


def _pk_set_dir(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < PK_PATH_CAP - 1:
        pk_dir[i] = s[i]
        i = i + 1
    if i == 0:
        pk_dir[0] = 47                             # '/'
        i = 1
    pk_dir[i] = 0
    pk_dir_len = i


def _pk_store(src: Ptr[uint8], nl: uint64, dir_flag: int32):
    if pk_n >= PK_MAX:
        return
    store: uint64 = nl
    if store > PK_NAME_CAP - 1:
        store = PK_NAME_CAP - 1
    dst: Ptr[uint8] = pk_name_ptr(pk_n)
    k: uint64 = 0
    while k < store:
        dst[k] = src[k]
        k = k + 1
    dst[store] = 0
    pk_name_len[pk_n] = store
    pk_is_dir[pk_n] = dir_flag
    pk_n = pk_n + 1


def _pk_maybe_store(src: Ptr[uint8], nl: uint64, dir_flag: int32):
    if nl == 0:
        return
    if nl == 1 and src[0] == 46:                   # "."
        return
    if nl == 2 and src[0] == 46 and src[1] == 46:  # ".."
        return
    _pk_store(src, nl, dir_flag)


# Build <pk_dir>/<entry i> into pk_full (NUL-term).
def _pk_build_full(i: uint64):
    j: uint64 = 0
    while j < pk_dir_len and j < PK_PATH_CAP:
        pk_full[j] = pk_dir[j]
        j = j + 1
    if j == 0 or pk_full[j - 1] != 47:
        pk_full[j] = 47
        j = j + 1
    nl: uint64 = pk_name_len[i]
    p: Ptr[uint8] = pk_name_ptr(i)
    k: uint64 = 0
    while k < nl and j < 575:
        pk_full[j] = p[k]
        j = j + 1
        k = k + 1
    pk_full[j] = 0


# Open-probe directory test (same trick as hamfmscene: flip the fd into
# Dir-record mode; only a real directory succeeds). Needed because the
# cpio rootfs stats every entry as a regular file.
def _pk_probe_is_dir(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path)
    if fd < 0:
        return 0
    rc: int32 = p9_chan_dir_mode(fd, 1, path)
    sys_close(fd)
    if rc == 0:
        return 1
    return 0


def _pk_classify():
    r: uint64 = 0
    if pk_has_up != 0:
        r = 1
    while r < pk_n:
        _pk_build_full(r)
        pk_is_dir[r] = _pk_probe_is_dir(cast[Ptr[char]](&pk_full[0]))
        r = r + 1


def _pk_load_namestream():
    n: int64 = p9_listdir(cast[Ptr[char]](&pk_dir[0]), &pk_list[0], PK_LIST_CAP)
    if n < 0:
        return
    nu: uint64 = cast[uint64](n)
    i: uint64 = 0
    while i < nu:
        c: uint8 = pk_list[i]
        if c == 10 or c == 0:
            i = i + 1
            continue
        j: uint64 = i
        while j < nu:
            d: uint8 = pk_list[j]
            if d == 10 or d == 0:
                break
            j = j + 1
        _pk_maybe_store(&pk_list[i], j - i, 0)
        i = j + 1
    _pk_classify()


# List pk_dir into the pk_* tables. Row 0 is a synthetic ".." unless we
# are at the filesystem root.
def _pk_load():
    pk_n = 0
    pk_has_up = 0
    pk_sel = 0
    pk_top = 0
    if pk_dir_len > 1:
        _pk_store(cast[Ptr[uint8]](".."), 2, 1)
        pk_has_up = 1
    fd: int32 = sys_open(cast[Ptr[char]](&pk_dir[0]))
    if fd < 0:
        return
    if p9_chan_dir_mode(fd, 1, cast[Ptr[char]](&pk_dir[0])) != 0:
        sys_close(fd)
        _pk_load_namestream()
        return
    total: uint64 = 0
    while total < PK_LIST_CAP:
        slice_ptr: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](&pk_list[0]) + total)
        n: int64 = sys_read(fd, slice_ptr, PK_LIST_CAP - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    off: uint64 = 0
    while off < total:
        rl: uint64 = p9_dir_decode_at(&pk_list[0], off, total)
        if rl == 0:
            break
        df: int32 = 0
        if (DIR_CUR_QTYPE & P9_QTDIR) != 0:
            df = 1
        _pk_maybe_store(&DIR_CUR_NAME[0], DIR_CUR_NAME_LEN, df)
        off = off + rl
    _pk_classify()


# Descend into entry i (a directory): pk_dir <- pk_full, re-list.
def _pk_enter(i: uint64):
    _pk_build_full(i)
    _pk_set_dir(&pk_full[0])
    _pk_load()


def _pk_go_parent():
    if pk_dir_len <= 1:
        return
    n: uint64 = pk_dir_len
    if pk_dir[n - 1] == 47:
        n = n - 1
    while n > 1 and pk_dir[n - 1] != 47:
        n = n - 1
    if n > 1:
        n = n - 1
    if n == 0:
        n = 1
    pk_dir[n] = 0
    pk_dir_len = n
    _pk_load()


# Open the picker. mode 1 = OPEN, 2 = SAVE. Start dir = the directory of
# the current file if it has one, else $HOME-ish (/home/live), falling
# back to "/" if that can't be listed.
def _pk_open(mode: int32):
    pk_mode = mode
    pk_save_len = 0
    pk_save_name[0] = 0
    # Pick a sensible start directory.
    start: Array[512, uint8]
    sl: uint64 = 0
    if has_file != 0:
        # Use the directory component of the current filename.
        last: int64 = -1
        k: uint64 = 0
        while fname_buf[k] != 0:
            if fname_buf[k] == 47:
                last = cast[int64](k)
            k = k + 1
        if last > 0:
            kk: uint64 = 0
            while kk < cast[uint64](last):
                start[sl] = fname_buf[kk]
                sl = sl + 1
                kk = kk + 1
            # In SAVE mode, seed the filename field with the basename.
            if mode == 2:
                b: uint64 = cast[uint64](last) + 1
                while fname_buf[b] != 0 and pk_save_len < 126:
                    pk_save_name[pk_save_len] = fname_buf[b]
                    pk_save_len = pk_save_len + 1
                    b = b + 1
                pk_save_name[pk_save_len] = 0
    if sl == 0:
        hm: Ptr[uint8] = cast[Ptr[uint8]]("/home/live/Documents")
        while hm[sl] != 0:
            start[sl] = hm[sl]
            sl = sl + 1
    start[sl] = 0
    _pk_set_dir(&start[0])
    _pk_load()
    # If the chosen start dir has no entries (couldn't be opened/listed),
    # climb to /home, then /, so the picker always shows something.
    if pk_n == 0 and pk_has_up == 0:
        _pk_set_dir(cast[Ptr[uint8]]("/home"))
        _pk_load()
    if pk_n == 0 and pk_has_up == 0:
        _pk_set_dir(cast[Ptr[uint8]]("/"))
        _pk_load()


# Commit a SAVE from the picker: write the buffer to <pk_dir>/<typed>.
def _pk_commit_save() -> int32:
    if pk_save_len == 0:
        _set_status(cast[Ptr[uint8]]("save: type a filename first"))
        return 0
    # Compose pk_dir + '/' + pk_save_name into fname_buf.
    p: uint64 = 0
    while p < pk_dir_len and p < 120:
        fname_buf[p] = pk_dir[p]
        p = p + 1
    if p == 0 or fname_buf[p - 1] != 47:
        fname_buf[p] = 47
        p = p + 1
    k: uint64 = 0
    while k < pk_save_len and p < 127:
        fname_buf[p] = pk_save_name[k]
        p = p + 1
        k = k + 1
    fname_buf[p] = 0
    has_file = 1
    pk_mode = 0
    _do_save()
    return 1


# Commit an OPEN from the picker: load <pk_dir>/<entry pk_sel>.
def _pk_commit_open(i: uint64) -> int32:
    _pk_build_full(i)
    # Record the filename.
    k: uint64 = 0
    while pk_full[k] != 0 and k < 127:
        fname_buf[k] = pk_full[k]
        k = k + 1
    fname_buf[k] = 0
    has_file = 1
    pk_mode = 0
    n: int64 = _do_open(cast[Ptr[char]](&pk_full[0]))
    if n >= 0:
        _set_status_num(cast[Ptr[uint8]]("opened "), cast[uint64](n))
    else:
        _set_status(cast[Ptr[uint8]]("open failed"))
    top_line = 0
    return 1


# Activate the current selection (Enter / double-purpose). A directory
# (or the ".." row) navigates; a file OPENs (mode 1) or — in SAVE mode —
# seeds the filename field from the picked file.
def _pk_activate():
    if pk_n == 0:
        return
    u: uint64 = cast[uint64](pk_sel)
    if u >= pk_n:
        return
    if pk_has_up != 0 and u == 0:
        _pk_go_parent()
        return
    if pk_is_dir[u] != 0:
        _pk_enter(u)
        return
    # A regular file.
    if pk_mode == 1:
        _pk_commit_open(u)
    else:
        # SAVE mode: copy the picked name into the filename field.
        pk_save_len = 0
        nl: uint64 = pk_name_len[u]
        src: Ptr[uint8] = pk_name_ptr(u)
        kk: uint64 = 0
        while kk < nl and pk_save_len < 126:
            pk_save_name[pk_save_len] = src[kk]
            pk_save_len = pk_save_len + 1
            kk = kk + 1
        pk_save_name[pk_save_len] = 0


# Visible picker rows for the current window height (resize-derived).
def _pk_vis_rows() -> uint64:
    # Geometry: header strip (TITLE_H) + list, leaving a bottom row for
    # the filename field (SAVE) / hint (OPEN).
    avail: int32 = ed_h - TITLE_H - 20
    rows: int32 = avail / PK_ROW_H
    if rows < 2:
        rows = 2
    return cast[uint64](rows)


def _pk_scroll_follow():
    vis: uint64 = _pk_vis_rows()
    s: uint64 = cast[uint64](pk_sel)
    if s < pk_top:
        pk_top = s
    if s >= pk_top + vis:
        pk_top = s - vis + 1


# Render the picker overlay over the whole editor canvas.
def _pk_emit():
    hamscene_fill(0, 0, ed_w, ed_h, cast[Ptr[uint8]]("#f3f3ee"))
    # Title bar: mode + current directory.
    hamscene_rect(0, 0, ed_w, TITLE_H, cast[Ptr[uint8]]("#2d5a87"))
    tbuf: Array[96, uint8]
    tp: uint64 = 0
    lbl: Ptr[uint8] = cast[Ptr[uint8]]("Open: ")
    if pk_mode == 2:
        lbl = cast[Ptr[uint8]]("Save in: ")
    a: uint64 = 0
    while lbl[a] != 0:
        tbuf[tp] = lbl[a]
        tp = tp + 1
        a = a + 1
    dn: uint64 = pk_dir_len
    if dn > 80:
        dn = 80
    b: uint64 = 0
    while b < dn:
        tbuf[tp] = pk_dir[b]
        tp = tp + 1
        b = b + 1
    tbuf[tp] = 0
    hamscene_glyphs(4, 4, &tbuf[0], cast[Ptr[uint8]]("#ffffff"))
    # Entry list.
    _pk_scroll_follow()
    vis: uint64 = _pk_vis_rows()
    r: uint64 = pk_top
    drawn: uint64 = 0
    rowbuf: Array[80, uint8]
    while r < pk_n and drawn < vis:
        yy: int32 = TITLE_H + 2 + cast[int32](drawn) * PK_ROW_H
        if cast[int64](r) == pk_sel:
            hamscene_fill(0, yy, ed_w, PK_ROW_H, cast[Ptr[uint8]]("#cfe0f4"))
        # Compose "[D] name" / "    name".
        rp: uint64 = 0
        if pk_is_dir[r] != 0:
            rowbuf[rp] = 91                            # '['
            rowbuf[rp + 1] = 68                        # 'D'
            rowbuf[rp + 2] = 93                        # ']'
            rowbuf[rp + 3] = 32
            rp = 4
        else:
            rowbuf[rp] = 32
            rowbuf[rp + 1] = 32
            rowbuf[rp + 2] = 32
            rowbuf[rp + 3] = 32
            rp = 4
        nl: uint64 = pk_name_len[r]
        src: Ptr[uint8] = pk_name_ptr(r)
        k: uint64 = 0
        while k < nl and rp < 74:
            rowbuf[rp] = src[k]
            rp = rp + 1
            k = k + 1
        rowbuf[rp] = 0
        col: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
        if pk_is_dir[r] != 0:
            col = cast[Ptr[uint8]]("#1a4a8a")
        hamscene_glyphs(6, yy + 2, &rowbuf[0], col)
        r = r + 1
        drawn = drawn + 1
    # Bottom field: SAVE = the typed filename; OPEN = a key hint.
    fy: int32 = ed_h - 18
    hamscene_fill(0, fy - 2, ed_w, 18, cast[Ptr[uint8]]("#e8e8d8"))
    hamscene_stroke(2, fy - 1, ed_w - 4, 16, 1, cast[Ptr[uint8]]("#808060"))
    fbuf: Array[160, uint8]
    fp: uint64 = 0
    if pk_mode == 2:
        nm: Ptr[uint8] = cast[Ptr[uint8]]("Name: ")
        a2: uint64 = 0
        while nm[a2] != 0:
            fbuf[fp] = nm[a2]
            fp = fp + 1
            a2 = a2 + 1
        k2: uint64 = 0
        while k2 < pk_save_len and fp < 150:
            fbuf[fp] = pk_save_name[k2]
            fp = fp + 1
            k2 = k2 + 1
        fbuf[fp] = 95                                 # '_' caret
        fp = fp + 1
    else:
        h2: Ptr[uint8] = cast[Ptr[uint8]](
            "Up/Dn=move Enter=open/cd Esc=cancel")
        a2: uint64 = 0
        while h2[a2] != 0 and fp < 150:
            fbuf[fp] = h2[a2]
            fp = fp + 1
            a2 = a2 + 1
    fbuf[fp] = 0
    hamscene_glyphs(6, fy + 2, &fbuf[0], cast[Ptr[uint8]]("#202020"))


# Handle a key while the picker is open. Returns 1 if the scene changed.
# Arrow keys arrive as ESC '[' A/B; we decode them with the shared esc_st.
def _pk_handle_code(code: int32) -> int32:
    # Arrow CSI decode (shares esc_st with the editor).
    if esc_st == 1:
        if code == 91:                              # '['
            esc_st = 2
            return 0
        esc_st = 0
    elif esc_st == 2:
        esc_st = 0
        if code == 65:                              # up
            if pk_sel > 0:
                pk_sel = pk_sel - 1
            return 1
        if code == 66:                              # down
            if cast[uint64](pk_sel) + 1 < pk_n:
                pk_sel = pk_sel + 1
            return 1
        return 0
    if code == 27:                                  # bare ESC -> cancel
        pk_mode = 0
        _set_status(cast[Ptr[uint8]]("cancelled"))
        return 1
    if code == 3:                                   # Ctrl-C -> cancel
        pk_mode = 0
        _set_status(cast[Ptr[uint8]]("cancelled"))
        return 1
    if code == 13 or code == 10:                    # Enter
        # In SAVE mode with a typed name and Ctrl-not-needed: commit save
        # if the highlighted row is NOT a directory action the user wants.
        # Convention: Enter on a directory/".." navigates; Enter elsewhere
        # in SAVE mode with a non-empty name commits the save.
        if pk_mode == 2:
            u: uint64 = cast[uint64](pk_sel)
            on_dir: int32 = 0
            if pk_n > 0 and u < pk_n and pk_is_dir[u] != 0:
                on_dir = 1
            if on_dir != 0:
                _pk_activate()                      # navigate
            else:
                _pk_commit_save()
        else:
            _pk_activate()
        return 1
    if pk_mode == 2:
        # SAVE mode: printable keys edit the filename field.
        if code == 8 or code == 127:                # Backspace
            if pk_save_len > 0:
                pk_save_len = pk_save_len - 1
                pk_save_name[pk_save_len] = 0
            return 1
        if code >= 32 and code < 127:
            if pk_save_len < 126:
                pk_save_name[pk_save_len] = cast[uint8](code)
                pk_save_len = pk_save_len + 1
                pk_save_name[pk_save_len] = 0
            return 1
    return 0


# ====================================================================
# LAYOUT + RENDER
# ====================================================================
# BUG 1b: RESIZE-AWARE. ed_w/ed_h are the current content size, recomputed
# from the "r <w> <h>" resize event on /event; VIS_ROWS/VIS_COLS (the text
# viewport) are derived from them so a maximized editor shows more text.
ED_W: int32 = 400             # initial default width
ED_H: int32 = 260             # initial default height
ed_w: int32 = 400             # current content width
ed_h: int32 = 260             # current content height
TITLE_H: int32 = 18
TEXT_X: int32 = 6
TEXT_Y: int32 = 22
LINE_H: int32 = 16
CELL_W: int32 = 8
VIS_ROWS: uint64 = 13         # visible text rows    (runtime, resize-derived)
VIS_COLS: uint64 = 48         # visible columns      (runtime, resize-derived)
ED_MAX_ROWS: uint64 = 48      # clamp (800px / 16px line)
ED_MAX_COLS: uint64 = 158     # clamp (1280px / 8px cell)


def _ed_apply_resize(nw: int64, nh: int64) -> int32:
    # Recompute the editor content size + text viewport from a resize event.
    # Returns 1 if anything changed.
    if nw < CELL_W * 8:
        nw = CELL_W * 8
    if nh < TEXT_Y + LINE_H:
        nh = TEXT_Y + LINE_H
    if cast[int32](nw) == ed_w and cast[int32](nh) == ed_h:
        return 0
    ed_w = cast[int32](nw)
    ed_h = cast[int32](nh)
    nc: uint64 = cast[uint64]((ed_w - TEXT_X - GUTTER_W - 2) / CELL_W)
    if nc < 8:
        nc = 8
    if nc > ED_MAX_COLS:
        nc = ED_MAX_COLS
    nr: uint64 = cast[uint64]((ed_h - TEXT_Y) / LINE_H)
    if nr < 2:
        nr = 2
    if nr > ED_MAX_ROWS:
        nr = ED_MAX_ROWS
    VIS_COLS = nc
    VIS_ROWS = nr
    return 1


# Non-blocking /event poll for "r <w> <h>" resize lines. Returns 1 if a
# resize was applied. evbuf/evcarry carry partial lines across reads.
ed_evbuf:   Array[256, uint8]
ed_evcarry: uint64 = 0


def _ed_poll_events(efd: int32) -> int32:
    if efd < 0:
        return 0
    changed: int32 = 0
    passes: int32 = 0
    while passes < 4:
        room: uint64 = 256 - ed_evcarry
        if room == 0:
            ed_evcarry = 0
            room = 256
        en: int64 = sys_read_nb(efd, &ed_evbuf[ed_evcarry], room)
        if en <= 0:
            break
        total: uint64 = ed_evcarry + cast[uint64](en)
        i: uint64 = 0
        ls: uint64 = 0
        while i < total:
            if ed_evbuf[i] == 10:
                if i > ls and ed_evbuf[ls] == 114:        # 'r'
                    p: uint64 = ls + 1
                    while p < i and ed_evbuf[p] == 32:
                        p = p + 1
                    wv: int64 = 0
                    while p < i and ed_evbuf[p] >= 48 and ed_evbuf[p] <= 57:
                        wv = wv * 10 + cast[int64](ed_evbuf[p]) - 48
                        p = p + 1
                    while p < i and ed_evbuf[p] == 32:
                        p = p + 1
                    hv: int64 = 0
                    while p < i and ed_evbuf[p] >= 48 and ed_evbuf[p] <= 57:
                        hv = hv * 10 + cast[int64](ed_evbuf[p]) - 48
                        p = p + 1
                    if wv > 0 and hv > 0:
                        if _ed_apply_resize(wv, hv) != 0:
                            changed = 1
                ls = i + 1
            i = i + 1
        # Carry any trailing partial line.
        leftover: uint64 = total - ls
        m: uint64 = 0
        while m < leftover:
            ed_evbuf[m] = ed_evbuf[ls + m]
            m = m + 1
        ed_evcarry = leftover
        passes = passes + 1
    return changed


# BUG #6 (soft-wrap): the editor wraps long logical lines at VIS_COLS into
# multiple VISUAL rows. _visual_row_of(off) returns the visual-row index of
# byte offset `off` from the top of the document (counting wrapped segments),
# so scroll-follow and the caret render in visual-row space, not logical-line
# space. A logical line of length L occupies ceil((L+1)/VIS_COLS) visual rows
# when empty-or-exact (the +0/+1 handles the end-of-line caret cell), but for
# scrolling we only need the START visual row of each char, so we advance a
# visual column per char and wrap to a new visual row at VIS_COLS or '\n'.
def _visual_row_of(off: uint64) -> uint64:
    vr: uint64 = 0
    vc: uint64 = 0
    i: uint64 = 0
    while i < off:
        if doc_buf[i] == 10:
            vr = vr + 1
            vc = 0
        else:
            vc = vc + 1
            if vc >= VIS_COLS:
                vr = vr + 1
                vc = 0
        i = i + 1
    return vr


# Ensure top_line keeps the caret's VISUAL row visible (wrap-aware scroll).
def _scroll_follow():
    cl: uint64 = _visual_row_of(caret)
    if cl < top_line:
        top_line = cl
    if cl >= top_line + VIS_ROWS:
        top_line = cl - VIS_ROWS + 1


# Compute the 1-based (line, col) of the caret for the Kate-style status.
def _caret_line_col(line_p: Ptr[uint64], col_p: Ptr[uint64]):
    ln: uint64 = 1
    cl: uint64 = 1
    i: uint64 = 0
    while i < caret:
        if doc_buf[i] == 10:
            ln = ln + 1
            cl = 1
        else:
            cl = cl + 1
        i = i + 1
    line_p[0] = ln
    col_p[0] = cl


# Number of logical lines in the document (for the gutter width estimate).
def _total_lines() -> uint64:
    n: uint64 = 1
    i: uint64 = 0
    while i < doc_len:
        if doc_buf[i] == 10:
            n = n + 1
        i = i + 1
    return n


GUTTER_W: int32 = 30          # line-number gutter width (px)


def emit_scene(wid: int32):
    hamscene_begin()
    # FILE-PICKER overlay takes the whole window when open. Draw it and
    # commit — the editor body underneath is not drawn (modal).
    if pk_mode != 0:
        _pk_emit()
        hamscene_commit(wid)
        return
    # Editor canvas.
    hamscene_fill(0, 0, ed_w, ed_h, cast[Ptr[uint8]]("#fbfbf7"))
    # Kate-style line-number gutter band.
    hamscene_fill(0, TITLE_H, GUTTER_W, ed_h - TITLE_H,
                  cast[Ptr[uint8]]("#eceae2"))
    hamscene_line(GUTTER_W, TITLE_H, GUTTER_W, ed_h, 1,
                  cast[Ptr[uint8]]("#d2cfc4"))
    # Title bar with filename.
    hamscene_rect(0, 0, ed_w, TITLE_H, cast[Ptr[uint8]]("#3a6ea5"))
    tbuf: Array[80, uint8]
    tp: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("hamedit: ")
    a: uint64 = 0
    while pre[a] != 0:
        tbuf[tp] = pre[a]
        tp = tp + 1
        a = a + 1
    if has_file != 0:
        b: uint64 = 0
        while fname_buf[b] != 0 and tp < 70:
            tbuf[tp] = fname_buf[b]
            tp = tp + 1
            b = b + 1
    else:
        nn: Ptr[uint8] = cast[Ptr[uint8]]("(unnamed)")
        c: uint64 = 0
        while nn[c] != 0:
            tbuf[tp] = nn[c]
            tp = tp + 1
            c = c + 1
    tbuf[tp] = 0
    hamscene_glyphs(4, 4, &tbuf[0], cast[Ptr[uint8]]("#ffffff"))

    # BUG #6 (soft-wrap): walk the whole document in VISUAL rows, wrapping each
    # logical line at VIS_COLS, and render the window of [top_line,
    # top_line+VIS_ROWS) visual rows. A visual row is flushed as one `glyphs`
    # line; the caret (a block behind its cell) is placed by the visual (row,
    # col) of the caret byte offset. We accumulate the current visual row into
    # rowbuf and emit it whenever it wraps (hits VIS_COLS), hits a '\n', or the
    # document ends.
    _scroll_follow()
    # Kate-style: which logical line holds the caret (1-based), for the
    # current-line highlight + the line:col status.
    cur_ln: uint64 = 0
    cur_col: uint64 = 0
    _caret_line_col(&cur_ln, &cur_col)
    rowbuf: Array[160, uint8]                     # >= ED_MAX_COLS + 1
    rl: uint64 = 0                                # chars in the current vrow
    vrow: uint64 = 0                              # current visual-row index
    rendered: uint64 = 0                          # vrows emitted into the window
    caret_col_in_vrow: int64 = -1                 # caret col if it's on this vrow
    logline: uint64 = 1                           # logical line of THIS vrow (1-based)
    line_head: int32 = 1                          # 1 if vrow is the 1st seg of its logical line
    off: uint64 = 0
    while off <= doc_len and rendered < VIS_ROWS:
        # Is the caret at THIS byte position, and is this vrow visible? At a
        # wrap boundary (rl == VIS_COLS) the caret belongs at col 0 of the NEXT
        # visual row, so skip it here and let the re-entered iteration (same
        # off, fresh vrow) place it — avoids a double caret block.
        if off == caret and vrow >= top_line and rl < VIS_COLS:
            caret_col_in_vrow = cast[int64](rl)
        # End-of-vrow conditions: a '\n', a wrap at VIS_COLS, or end-of-doc.
        atnl: int32 = 0
        if off < doc_len and doc_buf[off] == 10:
            atnl = 1
        ateof: int32 = 0
        if off >= doc_len:
            ateof = 1
        if atnl == 0 and ateof == 0 and rl < VIS_COLS:
            # Accumulate one rendered glyph (tabs shown as a space).
            ch: uint8 = doc_buf[off]
            if ch == 9:
                ch = 32
            rowbuf[rl] = ch
            rl = rl + 1
            off = off + 1
            continue
        # Flush the current visual row (if it is within the viewport).
        if vrow >= top_line:
            rowbuf[rl] = 0
            yy: int32 = TEXT_Y + cast[int32](rendered) * LINE_H
            txt_x: int32 = TEXT_X + GUTTER_W      # text starts past the gutter
            # Kate-style current-line highlight: tint the whole text-area
            # row band when this visual row belongs to the caret's logical
            # line. Drawn UNDER the glyphs (and under the caret block).
            if logline == cur_ln:
                hamscene_fill(GUTTER_W + 1, yy, ed_w - GUTTER_W - 1, LINE_H,
                              cast[Ptr[uint8]]("#eef3fb"))
            # Line-number gutter: only on the FIRST visual segment of a
            # logical line (wrapped continuation rows get no number).
            if line_head != 0:
                gnum: Array[12, uint8]
                gn: uint64 = _u64_to_dec(logline, &gnum[0])
                gnum[gn] = 0
                # Right-align within the gutter (8 px/glyph).
                gx: int32 = GUTTER_W - 4 - cast[int32](gn) * CELL_W
                if gx < 2:
                    gx = 2
                hamscene_glyphs(gx, yy + 2, &gnum[0],
                                cast[Ptr[uint8]]("#909088"))
            if caret_col_in_vrow >= 0:
                cxp: int32 = txt_x + cast[int32](caret_col_in_vrow) * CELL_W
                hamscene_fill(cxp, yy, CELL_W, LINE_H - 2,
                              cast[Ptr[uint8]]("#2a64c8"))
            if rl > 0:
                hamscene_glyphs(txt_x, yy + 2, &rowbuf[0],
                                cast[Ptr[uint8]]("#101010"))
            rendered = rendered + 1
        # Advance to the next visual row.
        caret_col_in_vrow = -1
        rl = 0
        if ateof != 0:
            break
        if atnl != 0:
            off = off + 1                         # consume the '\n'
            logline = logline + 1                 # new logical line
            line_head = 1                         # its first seg
        else:
            line_head = 0                         # a soft-wrap continuation
        vrow = vrow + 1
    # BUG #8: Save-As prompt field along the bottom (a sunken input box with
    # "Save As:" + the typed path + a block caret). Takes the bottom rows so a
    # path can't be mistaken for document text. Drawn instead of the status.
    if prompting != 0:
        py: int32 = ed_h - 18
        hamscene_fill(0, py - 2, ed_w, 18, cast[Ptr[uint8]]("#e8e8d8"))
        hamscene_stroke(2, py - 1, ed_w - 4, 16, 1,
                        cast[Ptr[uint8]]("#808060"))
        pbuf: Array[160, uint8]
        pp: uint64 = 0
        lbl: Ptr[uint8] = cast[Ptr[uint8]]("Save As: ")
        a2: uint64 = 0
        while lbl[a2] != 0:
            pbuf[pp] = lbl[a2]
            pp = pp + 1
            a2 = a2 + 1
        k3: uint64 = 0
        while k3 < prompt_len and pp < 150:
            pbuf[pp] = prompt_buf[k3]
            pp = pp + 1
            k3 = k3 + 1
        pbuf[pp] = 95                             # '_' caret
        pp = pp + 1
        pbuf[pp] = 0
        hamscene_glyphs(6, py + 2, &pbuf[0], cast[Ptr[uint8]]("#202020"))
    else:
        # Status line along the bottom.
        if status_len > 0:
            hamscene_glyphs(6, ed_h - 14, &status_buf[0],
                            cast[Ptr[uint8]]("#207020"))
        # Kate-style line:col indicator, right-aligned on the status row.
        lcbuf: Array[40, uint8]
        lp: uint64 = 0
        pfx: Ptr[uint8] = cast[Ptr[uint8]]("Ln ")
        a3: uint64 = 0
        while pfx[a3] != 0:
            lcbuf[lp] = pfx[a3]
            lp = lp + 1
            a3 = a3 + 1
        lp = lp + _u64_to_dec(cur_ln, &lcbuf[lp])
        com: Ptr[uint8] = cast[Ptr[uint8]](", Col ")
        a3 = 0
        while com[a3] != 0:
            lcbuf[lp] = com[a3]
            lp = lp + 1
            a3 = a3 + 1
        lp = lp + _u64_to_dec(cur_col, &lcbuf[lp])
        lcbuf[lp] = 0
        lcx: int32 = ed_w - cast[int32](lp) * CELL_W - 6
        if lcx < 6:
            lcx = 6
        hamscene_glyphs(lcx, ed_h - 14, &lcbuf[0],
                        cast[Ptr[uint8]]("#707068"))
    hamscene_commit(wid)


# ====================================================================
# KEY INPUT — parse "<type> <code>\n" lines; decode ESC [ A/B/C/D arrows.
# ====================================================================
# Arrow-key decode state: 0 = ground, 1 = saw ESC(27), 2 = saw ESC '['.
esc_st: int32 = 0


# BUG #8: handle a key while the Save-As prompt is active. Returns 1 if the
# prompt/scene changed. Printable bytes append to the path, Backspace edits,
# Enter commits the save, Esc / Ctrl-C cancels.
def _handle_prompt_code(code: int32) -> int32:
    if code == 27 or code == 3:                 # Esc / Ctrl-C -> cancel
        prompting = 0
        _set_status(cast[Ptr[uint8]]("save cancelled"))
        return 1
    if code == 13 or code == 10:                # Enter -> commit
        _commit_save_as()
        return 1
    if code == 8 or code == 127:                # Backspace
        if prompt_len > 0:
            prompt_len = prompt_len - 1
            prompt_buf[prompt_len] = 0
        return 1
    if code >= 32 and code < 127:               # printable path char
        if prompt_len < 126:
            prompt_buf[prompt_len] = cast[uint8](code)
            prompt_len = prompt_len + 1
            prompt_buf[prompt_len] = 0
        return 1
    return 0


# Handle one decoded key code. Returns 1 if the document/caret changed.
def _handle_code(code: int32) -> int32:
    # BUG #8: while the Save-As prompt is open, all keys edit the path field
    # (document editing is suppressed). Note: the ESC byte that opens an arrow
    # CSI also doubles as the prompt's cancel — in prompt mode we treat a bare
    # ESC as cancel directly (no arrow movement while naming a file).
    if prompting != 0:
        return _handle_prompt_code(code)
    # FILE-PICKER modal: while open, all keys drive the picker (folder
    # navigation + filename entry). Document editing is frozen.
    if pk_mode != 0:
        return _pk_handle_code(code)
    # Arrow CSI decode.
    if esc_st == 1:
        if code == 91:                          # '['
            esc_st = 2
            return 0
        esc_st = 0
        # fallthrough: treat as a normal key below
    elif esc_st == 2:
        esc_st = 0
        if code == 65:                          # 'A' up
            _move_up()
            return 1
        if code == 66:                          # 'B' down
            _move_down()
            return 1
        if code == 67:                          # 'C' right
            _move_right()
            return 1
        if code == 68:                          # 'D' left
            _move_left()
            return 1
        return 0
    if code == 27:                              # ESC -> begin CSI
        esc_st = 1
        return 0
    if code == 15:                              # Ctrl-O -> Open picker
        _pk_open(1)
        _set_status(cast[Ptr[uint8]]("Open: pick a file"))
        return 1
    if code == 19:                              # Ctrl-S -> save
        if has_file == 0:
            # No filename yet -> open the modal file-PICKER in SAVE mode so
            # the user can navigate to a FOLDER and name the file (replaces
            # the old bottom-line bare-filename Save-As prompt).
            _pk_open(2)
            _set_status(cast[Ptr[uint8]]("Save As: pick a folder + name"))
            return 1
        _do_save()
        return 1
    if code == 23:                              # Ctrl-W -> Save As (pick)
        # Always-available "Save As": open the SAVE picker even when the
        # buffer already has a name, so the user can choose a new folder.
        _pk_open(2)
        _set_status(cast[Ptr[uint8]]("Save As: pick a folder + name"))
        return 1
    if code == 13 or code == 10:                # Enter -> newline
        _insert(10)
        status_len = 0
        return 1
    if code == 8 or code == 127:                # Backspace / DEL
        _backspace()
        status_len = 0
        return 1
    if code >= 32 and code < 127:               # printable -> insert
        _insert(cast[uint8](code))
        status_len = 0
        return 1
    return 0


kev_buf: Array[512, uint8]
kev_carry: uint64 = 0


# Parse complete "<type> <code>\n" lines out of kev_buf[0..n). Returns bytes
# consumed (offset past the last '\n'); any partial trailing line is carried.
# Sets *changed_p to 1 if any key mutated the doc/caret.
def _drain_keys_chunk(n: uint64, changed_p: Ptr[int32]) -> uint64:
    i: uint64 = 0
    consumed: uint64 = 0
    while i < n:
        t: uint8 = kev_buf[i]
        i = i + 1
        if i < n and kev_buf[i] == 32:
            i = i + 1
        code: int32 = 0
        have: int32 = 0
        neg: int32 = 0
        if i < n and kev_buf[i] == 45:
            neg = 1
            i = i + 1
        while i < n and kev_buf[i] >= 48 and kev_buf[i] <= 57:
            code = code * 10 + cast[int32](kev_buf[i]) - 48
            i = i + 1
            have = 1
        while i < n and kev_buf[i] != 10:
            i = i + 1
        if i >= n:
            # incomplete line — carry it forward.
            return consumed
        i = i + 1                               # consume '\n'
        consumed = i
        if neg != 0:
            code = 0 - code
        # Only press events ('d', 100) with a real code drive editing.
        if t != 100 or have == 0:
            continue
        if _handle_code(code) != 0:
            changed_p[0] = 1
    return consumed


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamedit] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    keysp: Array[64, uint8]
    evtp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))
    _winpath(&evtp[0], wid, cast[Ptr[uint8]]("/event"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("geometry 180 120 400 260\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 6\n"))
        sys_close(cfd3)
    cfdt: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfdt >= 0:
        _writeall(cfdt, cast[Ptr[uint8]]("title Editor\n"))
        sys_close(cfdt)

    # Preload a file if a path was passed as argv[1].
    doc_len = 0
    caret = 0
    has_file = 0
    if argc >= 2 and argv != cast[Ptr[uint64]](0):
        path: Ptr[char] = cast[Ptr[char]](argv[1])
        # Record the filename.
        pb: Ptr[uint8] = cast[Ptr[uint8]](path)
        k: uint64 = 0
        while pb[k] != 0 and k < 127:
            fname_buf[k] = pb[k]
            k = k + 1
        fname_buf[k] = 0
        has_file = 1
        n: int64 = _do_open(path)
        if n >= 0:
            _set_status_num(cast[Ptr[uint8]]("opened "), cast[uint64](n))
        else:
            _set_status(cast[Ptr[uint8]]("new file"))
    else:
        _set_status(cast[Ptr[uint8]]("Ctrl-S saves; arrows move"))

    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hamedit] scene window ready\n"))

    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))
    efd: int32 = sys_open(cast[Ptr[char]](&evtp[0]))   # BUG 1b: resize events
    if kfd < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamedit] FAIL open keys\n"))
        # Still show the window; just idle.
        while True:
            sys_yield()
        return 1

    # EVENT-DRIVEN loop: BLOCK on /keys; on each wake parse keystrokes, apply
    # them, and re-emit the scene if anything changed.
    while True:
        room: uint64 = 512 - kev_carry
        if room == 0:
            kev_carry = 0
            room = 512
        kn: int64 = sys_read(kfd, &kev_buf[kev_carry], room)
        # BUG 1b: poll for resize events and re-layout the text viewport.
        if _ed_poll_events(efd) != 0:
            emit_scene(wid)
        if kn <= 0:
            sys_yield()
            continue
        total: uint64 = kev_carry + cast[uint64](kn)
        changed: int32 = 0
        done: uint64 = _drain_keys_chunk(total, &changed)
        leftover: uint64 = total - done
        m: uint64 = 0
        while m < leftover:
            kev_buf[m] = kev_buf[done + m]
            m = m + 1
        kev_carry = leftover
        if changed != 0:
            emit_scene(wid)
    return 0

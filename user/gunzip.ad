# user/gunzip.ad
#
# Hamnix native `gunzip`: gzip DECOMPRESSOR. Survival primitive for the
# native namespace — SEPARATE from any Debian/Linux gunzip.
#
# Usage:
#   gunzip FILE.gz       # FILE.gz -> FILE, remove FILE.gz (GNU-style)
#   gunzip -k FILE.gz    # keep FILE.gz
#   gunzip -c FILE.gz    # decompress to stdout (implies keep)
#
# This is the read side of the round-trip and the whole point of the
# tool: it must handle REAL-WORLD .gz produced anywhere (GNU gzip, zlib,
# python, ...), so it drives lib/zlib/inflate.ad's full INFLATE which
# implements all three DEFLATE block types — stored (BTYPE=00),
# fixed-Huffman (BTYPE=01) and dynamic-Huffman (BTYPE=10) — with the
# 32 KiB LZ77 sliding window and CRC32 + ISIZE trailer validation
# (RFC 1951 / RFC 1952). `gzip -d` is the same code path.

from lib.zlib.inflate import (
    InflateState,
    inflate_init,
    inflate_feed,
)

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_unlink(path: Ptr[char]) -> int32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


INF_IN:  uint64 = 65536
INF_OUT: uint64 = 65536
gz_in:   Array[65536, uint8]
gz_out:  Array[65536, uint8]
inf_state: InflateState


def write_all(fd: int32, buf: Ptr[uint8], len: uint64) -> int32:
    wrote: uint64 = 0
    while wrote < len:
        wr: int64 = sys_write(fd,
                              cast[Ptr[uint8]](cast[uint64](buf) + wrote),
                              len - wrote)
        if wr <= 0:
            return -1
        wrote = wrote + cast[uint64](wr)
    return 0


# Stream-decompress in_fd -> out_fd. Refills a 64 KiB input window from
# the file and drains a 64 KiB output window per inflate_feed call.
# inflate_feed resumes across both input-starve and out-buf-full yields,
# so arbitrarily large members decompress through these fixed buffers.
def decompress(in_fd: int32, out_fd: int32) -> int32:
    inflate_init(&inf_state)
    in_have: uint64 = 0
    in_pos:  uint64 = 0
    eof_in:  int32 = 0
    done:    int32 = 0
    while done == 0:
        if in_pos >= in_have and eof_in == 0:
            n: int64 = sys_read(in_fd, &gz_in[0], INF_IN)
            if n < 0:
                write_str(2, "gunzip: read error\n")
                return -1
            if n == 0:
                eof_in = 1
                in_have = 0
                in_pos = 0
            else:
                in_have = cast[uint64](n)
                in_pos = 0
        avail: uint64 = in_have - in_pos
        out_consumed: uint64 = 0
        in_consumed: uint64 = 0
        rc: int32 = inflate_feed(&inf_state,
                                 cast[Ptr[uint8]](cast[uint64](&gz_in[0]) + in_pos),
                                 avail,
                                 &gz_out[0], INF_OUT,
                                 &out_consumed, &in_consumed, &done)
        if rc < 0:
            write_str(2, "gunzip: invalid or corrupt gzip stream\n")
            return -1
        if out_consumed > 0:
            if write_all(out_fd, &gz_out[0], out_consumed) != 0:
                return -1
        in_pos = in_pos + in_consumed
        if rc == 1:
            break
        if in_consumed == 0 and out_consumed == 0:
            if eof_in != 0 and in_pos >= in_have:
                write_str(2, "gunzip: unexpected end of file\n")
                return -1
    return 0


# Strip ".gz" from `name` -> `out` (NUL-terminated). If no .gz suffix,
# append ".out" so the input is never clobbered. Returns 1 / 0.
def strip_gz(name: Ptr[uint8], out: Ptr[uint8]) -> int32:
    n: uint64 = strlen_u8(name)
    if n > 3 and name[n - 3] == 46 and name[n - 2] == 103 and name[n - 1] == 122:
        i: uint64 = 0
        while i < n - 3:
            out[i] = name[i]
            i = i + 1
        out[n - 3] = 0
        return 1
    i2: uint64 = 0
    while i2 < n:
        out[i2] = name[i2]
        i2 = i2 + 1
    out[n] = 46
    out[n + 1] = 111
    out[n + 2] = 117
    out[n + 3] = 116
    out[n + 4] = 0
    return 0


out_name: Array[300, uint8]


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    keep: int32 = 0
    to_stdout: int32 = 0
    file_idx: int32 = -1

    i: int32 = 1
    while i < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](i)])
        if a[0] == 45 and a[1] != 0:
            j: uint64 = 1
            while a[j] != 0:
                c: uint8 = a[j]
                if c == 107:                     # 'k'
                    keep = 1
                elif c == 99:                    # 'c'
                    to_stdout = 1
                    keep = 1
                elif c == 100:                   # 'd' (accepted, no-op)
                    keep = keep
                else:
                    write_str(2, "gunzip: unknown flag\n")
                    return 1
                j = j + 1
            i = i + 1
            continue
        file_idx = i
        break

    if file_idx < 0:
        write_str(2, "gunzip: usage: gunzip [-k] [-c] FILE.gz\n")
        return 1

    in_name: Ptr[char] = cast[Ptr[char]](argv[cast[uint64](file_idx)])
    in_fd: int32 = sys_open(in_name)
    if in_fd < 0:
        write_str(2, "gunzip: cannot open ")
        write_str(2, cast[Ptr[uint8]](in_name))
        write_str(2, "\n")
        return 1

    strip_gz(cast[Ptr[uint8]](in_name), &out_name[0])

    out_fd: int32 = 1
    if to_stdout == 0:
        out_fd = sys_open_write(cast[Ptr[char]](&out_name[0]))
        if out_fd < 0:
            write_str(2, "gunzip: cannot create ")
            write_str(2, &out_name[0])
            write_str(2, "\n")
            sys_close(in_fd)
            return 1

    rc: int32 = decompress(in_fd, out_fd)

    sys_close(in_fd)
    if to_stdout == 0:
        sys_close(out_fd)

    if rc != 0:
        return 1

    if keep == 0 and to_stdout == 0:
        sys_unlink(in_name)
    return 0

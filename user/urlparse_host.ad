# user/urlparse_host.ad — HOST unit test for user/http9.http_parse_url.
#
# Built for the `x86_64-linux` Adder target: a freestanding ELF that runs
# DIRECTLY on the host (no QEMU). It asserts the URL parser accepts the
# forms curl/wget/hpm feed it — in particular a SCHEME-LESS bare host
# (e.g. "google.com"), which must default to http:// exactly like real
# curl, rather than failing "malformed or unsupported URL".
#
# http9.ad pulls in user/net9.ad's /net syscalls. The parser itself is
# pure — it only fills the h9_* globals and never touches the transport —
# and every /net syscall wrapper (read/write/open/close, plus the
# host-stub sys_resolve) is provided by user/linux-runtime.S, so the
# harness links cleanly for the host without any parse-path syscalls
# actually running.
#
# Driven by scripts/test_urlparse_host.sh. Emits one "[urlparse] PASS/FAIL"
# line per case and a final "[urlparse] RESULT: PASS|FAIL".

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: int32) -> int32

from user.http9 import http_parse_url, http_parsed_scheme, \
    http_parsed_port, http_parsed_host, http_parsed_path, \
    http_compose_post_preview, http_request_bytes


fails: int32 = 0
npass: int32 = 0


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(s: Ptr[uint8]):
    sys_write(1, s, _slen(s))


def _streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] == b[i]:
        return 1
    return 0


# Assert http_parse_url(url) == 0 and the parse fields match.
def _check(label: Ptr[uint8], url: Ptr[uint8],
           want_scheme: int32, want_port: int64,
           want_host: Ptr[uint8], want_path: Ptr[uint8]):
    rc: int32 = http_parse_url(url)
    ok: int32 = 1
    if rc != 0:
        ok = 0
    elif http_parsed_scheme() != want_scheme:
        ok = 0
    elif http_parsed_port() != want_port:
        ok = 0
    elif _streq(http_parsed_host(), want_host) == 0:
        ok = 0
    elif _streq(http_parsed_path(), want_path) == 0:
        ok = 0
    if ok != 0:
        npass = npass + 1
        _writeall("[urlparse] PASS ")
        _writeall(label)
        _writeall("\n")
    else:
        fails = fails + 1
        _writeall("[urlparse] FAIL ")
        _writeall(label)
        _writeall(" url=")
        _writeall(url)
        _writeall("\n")


# Assert http_parse_url(url) rejects the input (non-zero).
def _check_reject(label: Ptr[uint8], url: Ptr[uint8]):
    rc: int32 = http_parse_url(url)
    if rc != 0:
        npass = npass + 1
        _writeall("[urlparse] PASS ")
        _writeall(label)
        _writeall("\n")
    else:
        fails = fails + 1
        _writeall("[urlparse] FAIL ")
        _writeall(label)
        _writeall(" (accepted a URL it should reject)\n")


# True if haystack[0..hlen) contains the NUL-terminated needle.
def _contains(hay: Ptr[uint8], hlen: uint64, needle: Ptr[uint8]) -> int32:
    nn: uint64 = 0
    while needle[nn] != 0:
        nn = nn + 1
    if nn == 0:
        return 1
    i: uint64 = 0
    while i + nn <= hlen:
        j: uint64 = 0
        while j < nn and hay[i + j] == needle[j]:
            j = j + 1
        if j == nn:
            return 1
        i = i + 1
    return 0


# Compose a POST request head for `url` (body_len / content_type) and assert the
# emitted bytes contain the expected request line + header.
def _check_post(label: Ptr[uint8], url: Ptr[uint8], body_len: uint64,
                content_type: Ptr[uint8], want: Ptr[uint8]):
    n: int64 = http_compose_post_preview(url, body_len, content_type)
    ok: int32 = 1
    if n <= 0:
        ok = 0
    elif _contains(http_request_bytes(), cast[uint64](n), want) == 0:
        ok = 0
    if ok != 0:
        npass = npass + 1
        _writeall("[urlparse] PASS ")
        _writeall(label)
        _writeall("\n")
    else:
        fails = fails + 1
        _writeall("[urlparse] FAIL ")
        _writeall(label)
        _writeall(" (want substring in composed request)\n")


def main() -> int32:
    # The USER BUG: a bare host must parse as http://host/ (curl default).
    _check("schemeless-bare-host", "google.com", 0, 80, "google.com", "/")
    _check("schemeless-with-path", "example.com/main/index.json",
           0, 80, "example.com", "/main/index.json")
    _check("schemeless-with-port", "example.com:8080/x",
           0, 8080, "example.com", "/x")
    # Explicit schemes must keep working exactly as before.
    _check("explicit-http", "http://255.one/main/index.json",
           0, 80, "255.one", "/main/index.json")
    _check("explicit-https", "https://255.one/main/index.json",
           1, 443, "255.one", "/main/index.json")
    _check("explicit-http-port", "http://host.example:81/p",
           0, 81, "host.example", "/p")
    # Empty host is still malformed.
    _check_reject("reject-empty", "")
    _check_reject("reject-scheme-only", "http://")

    # POST request-builder: the exact wire request line + headers http_post emits.
    _check_post("post-request-line", "http://api.test/submit", 7,
                "application/json", "POST /submit HTTP/1.0\r\n")
    _check_post("post-host-header", "http://api.test/submit", 7,
                "application/json", "\r\nHost: api.test\r\n")
    _check_post("post-content-type", "http://api.test/submit", 7,
                "application/json", "\r\nContent-Type: application/json\r\n")
    _check_post("post-content-length", "http://api.test/submit", 7,
                "application/json", "\r\nContent-Length: 7\r\n")
    # An empty content-type falls back to the Fetch string-body default.
    _check_post("post-default-ctype", "http://api.test/submit", 4,
                "", "\r\nContent-Type: text/plain;charset=UTF-8\r\n")

    if fails == 0:
        _writeall("[urlparse] RESULT: PASS\n")
        sys_exit(0)
    _writeall("[urlparse] RESULT: FAIL\n")
    sys_exit(1)
    return 0

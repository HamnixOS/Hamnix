# user/js_strptr_probe.ad — HOST probe for the js_str_ptr() scratch ring.
#
# Regression driver for the bug where js_str_ptr() returned a SINGLE shared
# scratch buffer, so an embedder reading two JS strings back-to-back
# (`pa = js_str_ptr(a); pb = js_str_ptr(b)`) had `pa` silently clobbered by the
# second call. This driver builds several distinct string values, takes their
# js_str_ptr() pointers WITHOUT copying, then verifies each pointer still holds
# its own bytes — exactly the pattern lib/web/dom uses (canvas.ad reads a key
# name + key value, or two adjacent attributes, back-to-back).
#
# Prints "OK" iff every earlier pointer survived the later calls; else "BAD:<n>".
# Built for x86_64-linux (scripts/test_jsengine_strptr_host.sh).

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

from lib.jsengine import js_init, js_new_string, js_str_ptr


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(s: Ptr[uint8]):
    sys_write(1, s, _slen(s))


# byte-compare a C string against p[0..n) then a NUL
def _streq(p: Ptr[uint8], s: Ptr[uint8]) -> int32:
    i: int32 = 0
    while s[i] != 0:
        if p[i] != s[i]:
            return 0
        i = i + 1
    if p[i] != 0:
        return 0
    return 1


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    js_init()

    sa: Ptr[uint8] = cast[Ptr[uint8]]("alpha-AAAAA")
    sb: Ptr[uint8] = cast[Ptr[uint8]]("bravo-BBBBB")
    sc: Ptr[uint8] = cast[Ptr[uint8]]("charlie-CCCCC")
    sd: Ptr[uint8] = cast[Ptr[uint8]]("delta-DDDDD")

    a: int32 = js_new_string(sa, _slen(sa))
    b: int32 = js_new_string(sb, _slen(sb))
    c: int32 = js_new_string(sc, _slen(sc))
    d: int32 = js_new_string(sd, _slen(sd))

    # Take all four pointers back-to-back WITHOUT copying — the exact pattern
    # that corrupted under the single-buffer implementation.
    pa: Ptr[uint8] = js_str_ptr(a)
    pb: Ptr[uint8] = js_str_ptr(b)
    pc: Ptr[uint8] = js_str_ptr(c)
    pd: Ptr[uint8] = js_str_ptr(d)

    bad: int32 = 0
    if _streq(pa, sa) == 0:
        bad = 1
    elif _streq(pb, sb) == 0:
        bad = 2
    elif _streq(pc, sc) == 0:
        bad = 3
    elif _streq(pd, sd) == 0:
        bad = 4

    if bad == 0:
        _puts(cast[Ptr[uint8]]("OK\n"))
        return 0
    if bad == 1:
        _puts(cast[Ptr[uint8]]("BAD:1\n"))
    if bad == 2:
        _puts(cast[Ptr[uint8]]("BAD:2\n"))
    if bad == 3:
        _puts(cast[Ptr[uint8]]("BAD:3\n"))
    if bad == 4:
        _puts(cast[Ptr[uint8]]("BAD:4\n"))
    return 1

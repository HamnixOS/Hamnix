# user/chvt.ad
#
# chvt — change the active virtual terminal.
#
# Usage: chvt <N>    where N is 1..4
#
# Writes the VT number digit to /dev/vt/ctl.  The kernel VT multiplexer
# (kernel/vt/vt.ad) interprets the digit and calls vt_switch(N-1).
#
# Equivalent to Linux's chvt(1) which writes to /dev/tty0.

extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "chvt: usage: chvt <1|2|3|4>\n")
        return 1

    vtstr: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    if vtstr[0] == 0 or vtstr[1] != 0:
        write_str(2, "chvt: VT number must be a single digit 1-4\n")
        return 1

    c: uint8 = vtstr[0]
    if c < 49 or c > 52:            # '1'..'4'
        write_str(2, "chvt: VT number must be 1..4\n")
        return 1

    # Open /dev/vt/ctl for writing and write the digit.
    fd: int32 = sys_open_write("/dev/vt/ctl")
    if fd < 0:
        write_str(2, "chvt: cannot open /dev/vt/ctl\n")
        return 1

    digit: Array[1, uint8]
    digit[0] = c
    sys_write(fd, &digit[0], 1)
    sys_close(fd)
    return 0

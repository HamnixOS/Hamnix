# user/awk.ad
#
# Minimal Hamnix `awk '{print $N}'`. Reads stdin a line at a time;
# splits each line on whitespace; prints the Nth field (1-based).
# Only the literal `{print $N}` program form is recognized — no
# patterns, no BEGIN/END, no functions, no arithmetic, no $0.
# The single argv must be exactly `{print $<digits>}`.
#
#   /cat /proc/tasks | /awk '{print $1}'
#
# Returns 1 on parse error, 0 on EOF.

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def parse_program(prog: Ptr[uint8]) -> int32:
    # Expect exactly: {print $<digits>} with optional spaces between
    # tokens. Returns the field index (1-based), or -1 on parse error.
    i: uint64 = 0
    if prog[i] != 123:                          # '{'
        return -1
    i = i + 1
    while prog[i] == 32:
        i = i + 1
    # "print"
    if prog[i] != 112 or prog[i + 1] != 114 or prog[i + 2] != 105 \
            or prog[i + 3] != 110 or prog[i + 4] != 116:
        return -1
    i = i + 5
    while prog[i] == 32:
        i = i + 1
    if prog[i] != 36:                           # '$'
        return -1
    i = i + 1
    n: int32 = 0
    have_digit: int32 = 0
    while prog[i] >= 48 and prog[i] <= 57:
        n = n * 10 + cast[int32](prog[i] - 48)
        have_digit = 1
        i = i + 1
    if have_digit == 0:
        return -1
    while prog[i] == 32:
        i = i + 1
    if prog[i] != 125:                          # '}'
        return -1
    if n < 1:
        return -1
    return n


# Per-line accumulator. 1 KiB matches our other line tools.
line: Array[1024, uint8]


def emit_field(line_len: uint64, field_n: int32):
    # Walk fields by skipping spaces/tabs, then taking a run of
    # non-whitespace, until we've reached field_n.
    i: uint64 = 0
    f: int32 = 0
    while i < line_len:
        while i < line_len and (line[i] == 32 or line[i] == 9):
            i = i + 1
        if i >= line_len:
            return
        f = f + 1
        start: uint64 = i
        while i < line_len and line[i] != 32 and line[i] != 9:
            i = i + 1
        if f == field_n:
            sys_write(1, &line[start], i - start)
            sys_write(1, "\n", 1)
            return


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "awk: usage: awk '{print $N}'\n")
        return 1
    field_n: int32 = parse_program(cast[Ptr[uint8]](argv[1]))
    if field_n < 0:
        write_str(2, "awk: only {print $N} supported\n")
        return 1

    chunk: Array[256, uint8]
    line_pos: uint64 = 0
    while True:
        n: int64 = sys_read(0, &chunk[0], 256)
        if n <= 0:
            break
        nu: uint64 = cast[uint64](n)
        i: uint64 = 0
        while i < nu:
            c: uint8 = chunk[i]
            if c == 10:
                emit_field(line_pos, field_n)
                line_pos = 0
            else:
                if line_pos + 1 < 1024:
                    line[line_pos] = c
                    line_pos = line_pos + 1
            i = i + 1
    if line_pos > 0:
        emit_field(line_pos, field_n)
    return 0

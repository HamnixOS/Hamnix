# user/tty.ad
#
# Hamnix `tty`: print the file name of the terminal connected to
# stdin, mirroring POSIX `tty(1)`. A process's standard streams are
# NAMES in its per-process namespace — /fd/0 is the stdin binding
# (sys/src/9/port/devfd.ad). We query what kind of channel is bound
# at /fd/0 via sys_fdslot_kind(0, 0) (pid 0 == self):
#
#   * DEVFD_CONS  -> stdin is the console; print "/dev/cons", exit 0.
#   * anything else (pipe end, on-disk file, nothing) -> "not a tty",
#     exit 1.
#
# This matches GNU `tty`'s exit-status contract: 0 when stdin is a
# terminal, 1 otherwise (and we print the diagnostic to stdout, as
# coreutils does). Hamnix has a single console device, so the printed
# name is always "/dev/cons" when stdin is interactive — there is no
# pty-path multiplexing in the native namespace yet.

extern def sys_fdslot_kind(pid: int32, fdnum: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


# Must match DEVFD_CONS in sys/src/9/port/devfd.ad / user/hamsh.ad.
DEVFD_CONS: int32 = 1


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main() -> int32:
    kind: int32 = sys_fdslot_kind(0, 0)
    if kind == DEVFD_CONS:
        write_str(1, "/dev/cons\n")
        return 0
    write_str(1, "not a tty\n")
    return 1

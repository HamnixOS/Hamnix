# user/hamsdl_audio_host.ad — HOST harness for the hamSDL audio API.
#
# Driven by scripts/test_hamsdl_audio_host.sh with NO QEMU. It exercises the
# SDL_mixer/pygame-style verbs through the HOST backend (lib/hamsdl_audio_host.ad
# — real decode, no-op DAC) and dumps machine-checkable fields so the gate can
# assert the API wired to the verified decode + registry stack:
#   * sdl_load_sound decoded the shipped .wav to the EXACT format Python `wave`
#     reports (rate/channels/bits/PCM length);
#   * sdl_play_sound targeted the loaded sound (and rejects an unknown name);
#   * sdl_set_volume / sdl_audio_volume round-trip + clamp;
#   * sdl_play_music decoded + registered the .mp3 clip and latched the loop.
#
# argv: 1=path to a .wav, 2=path to a .mp3.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

from lib.hamsdl_audio import sdl_audio_find, sdl_audio_len, sdl_audio_rate, \
    sdl_audio_channels, sdl_audio_bits, sdl_audio_count, sdl_audio_last_play, \
    sdl_audio_music_slot, sdl_audio_music_loop, sdl_set_volume, sdl_audio_volume
from lib.hamsdl_audio_host import sdl_audio_init, sdl_load_sound, \
    sdl_play_sound, sdl_play_music, sdl_stop_music, sdl_music_stopped


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(s: Ptr[uint8]):
    sys_write(1, s, _slen(s))


_numbuf: Array[24, uint8]


# Print "<label> <value>\n".
def _kv(label: Ptr[uint8], v: int64):
    _puts(label)
    sys_write(1, cast[Ptr[uint8]](" "), 1)
    neg: int32 = 0
    u: uint64 = 0
    if v < 0:
        neg = 1
        u = cast[uint64](0 - v)
    else:
        u = cast[uint64](v)
    if u == 0:
        _numbuf[0] = 48
        sys_write(1, &_numbuf[0], 1)
    else:
        tmp: Array[24, uint8]
        n: uint64 = 0
        while u > 0:
            tmp[n] = cast[uint8](u % 10) + 48
            u = u / 10
            n = n + 1
        p: uint64 = 0
        if neg == 1:
            _numbuf[p] = 45
            p = p + 1
        i: uint64 = 0
        while i < n:
            _numbuf[p] = tmp[n - 1 - i]
            p = p + 1
            i = i + 1
        sys_write(1, &_numbuf[0], p)
    sys_write(1, cast[Ptr[uint8]]("\n"), 1)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _puts(cast[Ptr[uint8]]("usage: hamsdl_audio_host <wav> <mp3>\n"))
        return 2
    wav: Ptr[char] = cast[Ptr[char]](argv[1])
    mp3: Ptr[char] = cast[Ptr[char]](argv[2])

    _kv(cast[Ptr[uint8]]("INIT"), cast[int64](sdl_audio_init()))

    # --- load + inspect the decoded WAV ---
    wslot: int32 = sdl_load_sound(cast[Ptr[uint8]]("blip"), wav)
    _kv(cast[Ptr[uint8]]("LOAD_SLOT"), cast[int64](wslot))
    if wslot >= 0:
        _kv(cast[Ptr[uint8]]("RATE"), cast[int64](sdl_audio_rate(wslot)))
        _kv(cast[Ptr[uint8]]("CHANNELS"), cast[int64](sdl_audio_channels(wslot)))
        _kv(cast[Ptr[uint8]]("BITS"), cast[int64](sdl_audio_bits(wslot)))
        _kv(cast[Ptr[uint8]]("DATALEN"), cast[int64](sdl_audio_len(wslot)))

    # --- play the loaded sound; confirm it targeted the right slot ---
    _kv(cast[Ptr[uint8]]("PLAY_OK"),
        cast[int64](sdl_play_sound(cast[Ptr[uint8]]("blip"))))
    _kv(cast[Ptr[uint8]]("LAST_PLAY"), cast[int64](sdl_audio_last_play()))
    # An unknown sound must be rejected.
    _kv(cast[Ptr[uint8]]("PLAY_MISSING"),
        cast[int64](sdl_play_sound(cast[Ptr[uint8]]("nope"))))

    # --- volume round-trip + clamp ---
    sdl_set_volume(64)
    _kv(cast[Ptr[uint8]]("VOL_GET"), cast[int64](sdl_audio_volume()))
    sdl_set_volume(9000)
    _kv(cast[Ptr[uint8]]("VOL_CLAMP_HI"), cast[int64](sdl_audio_volume()))
    sdl_set_volume(0 - 5)
    _kv(cast[Ptr[uint8]]("VOL_CLAMP_LO"), cast[int64](sdl_audio_volume()))

    # --- music: decode+register the mp3, latch the loop ---
    _kv(cast[Ptr[uint8]]("MUSIC_OK"),
        cast[int64](sdl_play_music(mp3, 1)))
    mslot: int32 = sdl_audio_music_slot()
    _kv(cast[Ptr[uint8]]("MUSIC_SLOT"), cast[int64](mslot))
    _kv(cast[Ptr[uint8]]("MUSIC_LOOP"), cast[int64](sdl_audio_music_loop()))
    if mslot >= 0:
        _kv(cast[Ptr[uint8]]("MUSIC_RATE"), cast[int64](sdl_audio_rate(mslot)))
        _kv(cast[Ptr[uint8]]("MUSIC_DATALEN"),
            cast[int64](sdl_audio_len(mslot)))
    sdl_stop_music()
    _kv(cast[Ptr[uint8]]("MUSIC_STOPPED"), cast[int64](sdl_music_stopped()))

    # Registry holds the SFX + the reserved music slot.
    _kv(cast[Ptr[uint8]]("COUNT"), cast[int64](sdl_audio_count()))
    _puts(cast[Ptr[uint8]]("RESULT ok\n"))
    return 0

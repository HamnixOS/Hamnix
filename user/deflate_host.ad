# user/deflate_host.ad — HOST driver for lib/zlib/deflate.ad (built for
# the x86_64-linux Adder target; runs directly on the dev host, no QEMU).
#
# It reads an input file whole, gzip-compresses it through the SAME
# fixed-Huffman + LZ77 encoder the native `gzip`/`tar -czf` ship
# (lib/zlib/deflate.ad), and writes the .gz to an output file. The gate
# scripts/test_deflate_roundtrip_host.sh then decompresses that .gz with
# the REAL system gunzip/python gzip and byte-compares against the input
# — a fast, deterministic, QEMU-free proof that Hamnix-produced gzip is
# interoperable with Linux.
#
# USAGE (built to build/host/deflate_host):
#   deflate_host INFILE OUTFILE.gz
#
# No sockets, no Plan 9: it only reads argv + read/writes two files.

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.zlib.deflate import (
    Deflater,
    deflate_init,
    deflate_gzip_header,
    deflate_block,
    deflate_finish,
    deflate_reset_out,
)


IN_CAP:  uint64 = 4194304        # 4 MiB whole-file input buffer
OUT_CAP: uint64 = 65536          # per-block output staging
BLOCK:   uint64 = 32768

in_buf:  Array[4194304, uint8]
out_buf: Array[65536, uint8]
dfl:     Deflater


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_all(fd: int32, buf: Ptr[uint8], length: uint64) -> int32:
    wrote: uint64 = 0
    while wrote < length:
        wr: int64 = sys_write(fd,
                              cast[Ptr[uint8]](cast[uint64](buf) + wrote),
                              length - wrote)
        if wr <= 0:
            return -1
        wrote = wrote + cast[uint64](wr)
    return 0


def drain(out_fd: int32) -> int32:
    rc: int32 = write_all(out_fd, &out_buf[0], dfl.pos)
    deflate_reset_out(&dfl)
    return rc


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        return 2
    in_name:  Ptr[char] = cast[Ptr[char]](argv[1])
    out_name: Ptr[char] = cast[Ptr[char]](argv[2])

    in_fd: int32 = sys_open(in_name, 0, 0)          # O_RDONLY
    if in_fd < 0:
        return 1
    total: uint64 = 0
    while total < IN_CAP:
        n: int64 = sys_read(in_fd,
                            cast[Ptr[uint8]](cast[uint64](&in_buf[0]) + total),
                            IN_CAP - total)
        if n < 0:
            sys_close(in_fd)
            return 1
        if n == 0:
            break
        total = total + cast[uint64](n)
    sys_close(in_fd)

    out_fd: int32 = sys_open(out_name, 577, 420)    # O_WRONLY|O_CREAT|O_TRUNC
    if out_fd < 0:
        return 1

    deflate_init(&dfl, &out_buf[0], OUT_CAP)
    deflate_gzip_header(&dfl)
    if drain(out_fd) != 0:
        sys_close(out_fd)
        return 1

    off: uint64 = 0
    if total == 0:
        # Empty input: a single empty final block.
        deflate_block(&dfl, &in_buf[0], 0, 1)
        if drain(out_fd) != 0:
            sys_close(out_fd)
            return 1
    while off < total:
        chunk: uint64 = BLOCK
        if chunk > total - off:
            chunk = total - off
        is_final: int32 = 0
        if off + chunk >= total:
            is_final = 1
        deflate_block(&dfl,
                      cast[Ptr[uint8]](cast[uint64](&in_buf[0]) + off),
                      chunk, is_final)
        if drain(out_fd) != 0:
            sys_close(out_fd)
            return 1
        off = off + chunk

    deflate_finish(&dfl)
    if drain(out_fd) != 0:
        sys_close(out_fd)
        return 1
    if dfl.overflow != 0:
        sys_close(out_fd)
        return 1
    sys_close(out_fd)
    return 0

# user/hamminescene_host.ad — HOST driver + render harness for the Minesweeper
# scene app (built for the x86_64-linux Adder target; runs directly on the dev
# host, no QEMU).
#
# It drives the SAME core the native app ships (lib/hamminescore.ad): builds a
# DETERMINISTIC field (mines placed via the test setters, so no RNG), reveals a
# numbered cell + flags a corner, builds the scene display list, and RASTERIZES
# it with lib/hamui_host.ad's parser+font rasterizer into an RGB framebuffer
# written out as a binary PPM a human/agent can LOOK at
# (scripts/test_hammine_host.sh converts it to PNG). Then it feeds SCRIPTED
# input through the core's pure handlers and asserts the RULES: revealing a
# 0-count cell FLOOD-FILLS, revealing a mine is a LOSS, uncovering every
# non-mine is a WIN, and New restarts. It also dumps the raw scene display list
# + sampled pixel colours to stdout so the gate can assert on layout/colour.
#
# USAGE (built to build/host/hammine_host):
#   hammine_host BEFORE.ppm AFTER.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamminescore import hammine_build_scene, \
    hammine_draw_overlay, hammine_reveal, hammine_flag, \
    hammine_gameover, hammine_won, hammine_mines_left, hammine_revealed, \
    hammine_cell_state, hammine_cell_count, hammine_cell_mine, \
    hammine_ctrl_press, hammine_btn_at, \
    hammine_test_clear, hammine_test_setmine, hammine_test_recount


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)                                          # '#'
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


def _kv(k: Ptr[uint8], v: int64):
    _o_str(k)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    # O_WRONLY|O_CREAT|O_TRUNC = 577, mode 0644 = 420.
    fd: int32 = sys_open(path, 577, 420)
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hammine_build_scene()
    hammine_draw_overlay()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


def _pix(x: int32, y: int32, label: Ptr[uint8]):
    _o_str(cast[Ptr[uint8]]("PIX "))
    _o_dec(cast[int64](x))
    _o_ch(32)
    _o_dec(cast[int64](y))
    _o_ch(32)
    _o_hexcol(hamui_host_pixel(x, y))
    _o_ch(32)
    _o_str(label)
    _o_ch(10)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hammine_host BEFORE.ppm AFTER.ppm\n"))
        _o_flush()
        return 2

    W: int32 = 360
    H: int32 = 470

    # ---- BEFORE frame: DETERMINISTIC board -----------------------------
    # 3 mines around cell (4,4) so it has a neighbour count of exactly 3 (a
    # RED number in the classic palette). test_setmine disables the RNG
    # re-scatter, so the board is byte-reproducible.
    hammine_test_clear()
    hammine_test_setmine(3, 3, 1)
    hammine_test_setmine(4, 3, 1)
    hammine_test_setmine(5, 3, 1)
    hammine_test_recount()
    r44: int32 = hammine_reveal(4, 4)                  # count 3 -> just this cell
    hammine_flag(0, 0)                                 # flag the corner

    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))

    _kv(cast[Ptr[uint8]]("PRIMS"), cast[int64](prims))
    _kv(cast[Ptr[uint8]]("REVEAL_44"), cast[int64](r44))
    _kv(cast[Ptr[uint8]]("STATE_44"), cast[int64](hammine_cell_state(4, 4)))
    _kv(cast[Ptr[uint8]]("COUNT_44"), cast[int64](hammine_cell_count(4, 4)))
    _kv(cast[Ptr[uint8]]("STATE_00"), cast[int64](hammine_cell_state(0, 0)))
    _kv(cast[Ptr[uint8]]("MINES_LEFT"), cast[int64](hammine_mines_left()))
    _kv(cast[Ptr[uint8]]("GAMEOVER0"), cast[int64](hammine_gameover()))

    # Sampled pixels (proves the RASTERIZER, not just the builder).
    _pix(4, 4, cast[Ptr[uint8]]("backdrop"))           # #1b1b2e
    _pix(84, 80, cast[Ptr[uint8]]("covered"))          # covered face #7f8fb0
    _pix(167, 195, cast[Ptr[uint8]]("revealed"))       # revealed face #c8ccd8
    _pix(52, 80, cast[Ptr[uint8]]("flag"))             # flag marker #e02a2a
    _o_flush()

    # Dump the raw scene display list so the gate can assert layout/colour.
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()

    # ---- RULE: FLOOD FILL ----------------------------------------------
    # An L-shaped mine wall (column 4 rows 0..4 + row 4 cols 0..4) walls off the
    # top-left block. Revealing (0,0) — a 0-count cell — must flood-fill that
    # whole block in ONE click, while cells BEYOND the wall stay covered (so the
    # game does NOT end and it is NOT a win).
    hammine_test_clear()
    wc: int32 = 0
    while wc <= 4:
        hammine_test_setmine(4, wc, 1)                 # column 4, rows 0..4
        hammine_test_setmine(wc, 4, 1)                 # row 4, cols 0..4
        wc = wc + 1
    hammine_test_recount()
    hammine_reveal(0, 0)
    _kv(cast[Ptr[uint8]]("FLOOD_REVEALED"), cast[int64](hammine_revealed()))
    _kv(cast[Ptr[uint8]]("FLOOD_CELL_3_3"), cast[int64](hammine_cell_state(3, 3)))
    _kv(cast[Ptr[uint8]]("FLOOD_CELL_8_8"), cast[int64](hammine_cell_state(8, 8)))
    _kv(cast[Ptr[uint8]]("FLOOD_GAMEOVER"), cast[int64](hammine_gameover()))

    # ---- RULE: REVEAL A MINE = LOSS ------------------------------------
    hammine_test_clear()
    hammine_test_setmine(2, 2, 1)
    hammine_test_recount()
    hammine_reveal(2, 2)
    _kv(cast[Ptr[uint8]]("LOSS_GAMEOVER"), cast[int64](hammine_gameover()))
    _kv(cast[Ptr[uint8]]("LOSS_WON"), cast[int64](hammine_won()))

    # A reveal after death is a no-op.
    dead: int32 = hammine_reveal(5, 5)
    _kv(cast[Ptr[uint8]]("DEAD_REVEAL"), cast[int64](dead))

    # ---- RULE: ALL-SAFE-REVEALED = WIN ---------------------------------
    hammine_test_clear()
    hammine_test_setmine(8, 8, 1)
    hammine_test_recount()
    gy: int32 = 0
    while gy < 9:
        gx: int32 = 0
        while gx < 9:
            if hammine_cell_mine(gx, gy) == 0:
                hammine_reveal(gx, gy)
            gx = gx + 1
        gy = gy + 1
    _kv(cast[Ptr[uint8]]("WIN_GAMEOVER"), cast[int64](hammine_gameover()))
    _kv(cast[Ptr[uint8]]("WIN_WON"), cast[int64](hammine_won()))
    _kv(cast[Ptr[uint8]]("WIN_MINE_HIDDEN"),
        cast[int64](hammine_cell_state(8, 8)))

    # Render the AFTER frame: the solved board + YOU WIN overlay.
    prims2: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _kv(cast[Ptr[uint8]]("PRIMS2"), cast[int64](prims2))

    # ---- Control button hit-test ---------------------------------------
    # _btn_x(0)=12, BTN_W=100 -> x=50 lands on New; CTRL_Y=430.
    b0: int64 = hammine_btn_at(50, 440)
    _kv(cast[Ptr[uint8]]("BTNAT_50_440"), b0)
    # _btn_x(1)=122 -> x=150 lands on the Flag-mode button.
    b1: int64 = hammine_btn_at(150, 440)
    _kv(cast[Ptr[uint8]]("BTNAT_150_440"), b1)

    # ---- RESTART via the New button clears the game -------------------
    hammine_ctrl_press(0)                              # New
    _kv(cast[Ptr[uint8]]("NEW_GAMEOVER"), cast[int64](hammine_gameover()))
    _kv(cast[Ptr[uint8]]("NEW_MINES_LEFT"), cast[int64](hammine_mines_left()))
    _kv(cast[Ptr[uint8]]("NEW_REVEALED"), cast[int64](hammine_revealed()))
    _o_flush()
    return 0

# user/hamgamedemo.ad — "Coin Dash", the hamGame demo, DEVICE build.
#
# A thin driver: it wires the hamGame device backend (lib/hamgame_dev.ad) to the
# shared, target-agnostic game in lib/hamgamedemo.ad. All drawing, input, timing
# and collision go through the PUBLIC hamGame API — this file has NO game logic
# and NO raw transport of its own, proving the library is a complete pygame-shaped
# game surface. The HOST render gate (user/hamgamedemo_host.ad) drives the SAME
# lib/hamgamedemo.ad.

from lib.hamgame import game_poll_event, game_set_fps, game_frame_ms, \
    game_clock_tick, game_flip_scene, game_draw_text_bold, game_draw_int, \
    game_rgb, GAME_QUIT, GAME_KEYDOWN
from lib.hamgame_dev import game_dev_init, game_dev_pump, game_dev_present, \
    game_dev_ticks, game_dev_delay
from lib.hamgamedemo import gd_init, gd_key, gd_update, gd_render, \
    gd_display_surf, gd_get_score


GDW: int32 = 240
GDH: int32 = 240


def main() -> int32:
    wid: int32 = game_dev_init(cast[Ptr[uint8]]("Coin Dash"),
                               280, 140, GDW, GDH)
    if wid < 0:
        return 1
    gd_init(GDW, GDH)
    game_set_fps(30)

    kind: int32 = 0
    key: int32 = 0
    ex: int32 = 0
    ey: int32 = 0
    ebtn: int32 = 0
    while True:
        game_dev_pump()
        while game_poll_event(&kind, &key, &ex, &ey, &ebtn) == 1:
            if kind == GAME_QUIT:
                return 0
            if kind == GAME_KEYDOWN:
                gd_key(key)
        dt: uint64 = game_clock_tick(game_dev_ticks())
        gd_update(cast[int32](dt))
        gd_render()
        game_flip_scene(gd_display_surf())
        game_draw_text_bold(8, 6, cast[Ptr[uint8]]("Coin Dash"),
                            game_rgb(230, 236, 245))
        game_draw_int(GDW - 28, 6, gd_get_score(), game_rgb(240, 210, 90))
        game_dev_present(gd_display_surf())
        game_dev_delay(cast[uint64](game_frame_ms()))
    return 0

# user/svg_probe.ad — host test shim for lib/svg.ad. Reads an SVG file, renders
# it, and prints "RC rc", "DIM w h", and "PIX x y r g b a" for each (x,y) pair in
# argv, so a gate can assert render dimensions + per-pixel colours + alpha.
extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.svg import svg_decode, svg_width, svg_height, svg_pixel, svg_sniff

FILE_CAP: uint64 = 1048576
fbuf: Array[1048576, uint8]
pbuf: Array[4000000, uint8]                # PPM scratch (scaled RGB over white)

obuf: Array[256, uint8]
obn: uint64 = 0


def _oc(c: uint8):
    if obn < 255:
        obuf[obn] = c
        obn = obn + 1


def _os(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _oc(s[i])
        i = i + 1


def _od(v: int64):
    if v < 0:
        _oc(45)
        v = 0 - v
    if v == 0:
        _oc(48)
        return
    d: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        d[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _oc(d[n])


def _flush():
    sys_write(1, &obuf[0], obn)
    obn = 0


# Write the decoded RGBA (composited over white, integer-scaled) as a binary P6
# PPM to `path`, so a gate can render a human-viewable PNG. Returns 0 on success.
def _dump_ppm(path: Ptr[char], scale: int32) -> int32:
    w: int32 = svg_width()
    h: int32 = svg_height()
    if w <= 0 or h <= 0 or scale <= 0:
        return -1
    ow: int32 = w * scale
    oh: int32 = h * scale
    n: uint64 = 0
    # header: "P6\n<ow> <oh>\n255\n"
    pbuf[n] = 80
    n = n + 1
    pbuf[n] = 54
    n = n + 1
    pbuf[n] = 10
    n = n + 1
    n = _emit_dec(n, cast[int64](ow))
    pbuf[n] = 32
    n = n + 1
    n = _emit_dec(n, cast[int64](oh))
    pbuf[n] = 10
    n = n + 1
    n = _emit_dec(n, 255)
    pbuf[n] = 10
    n = n + 1
    oy: int32 = 0
    while oy < oh:
        sy: int32 = oy / scale
        ox: int32 = 0
        while ox < ow:
            sx: int32 = ox / scale
            px: uint32 = svg_pixel(sx, sy)
            a: int32 = cast[int32]((px >> 24) & 255)
            r: int32 = cast[int32]((px >> 16) & 255)
            g: int32 = cast[int32]((px >> 8) & 255)
            b: int32 = cast[int32](px & 255)
            # straight-alpha over white
            orr: int32 = (r * a + 255 * (255 - a)) / 255
            og: int32 = (g * a + 255 * (255 - a)) / 255
            ob: int32 = (b * a + 255 * (255 - a)) / 255
            if n + 3 < 4000000:
                pbuf[n] = cast[uint8](orr)
                pbuf[n + 1] = cast[uint8](og)
                pbuf[n + 2] = cast[uint8](ob)
                n = n + 3
            ox = ox + 1
        oy = oy + 1
    fd: int32 = sys_open(path, 577, 420)           # O_WRONLY|O_CREAT|O_TRUNC, 0644
    if fd < 0:
        return -1
    sys_write(fd, &pbuf[0], n)
    sys_close(fd)
    return 0


def _emit_dec(at: uint64, v: int64) -> uint64:
    if v == 0:
        pbuf[at] = 48
        return at + 1
    d: Array[24, uint8]
    m: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        d[m] = cast[uint8](x % 10) + 48
        x = x / 10
        m = m + 1
    n: uint64 = at
    while m > 0:
        m = m - 1
        pbuf[n] = d[m]
        n = n + 1
    return n


def _atoi(s: Ptr[char]) -> int64:
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    v: int64 = 0
    i: uint64 = 0
    while p[i] != 0:
        v = v * 10 + cast[int64](p[i] - 48)
        i = i + 1
    return v


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        sys_write(2, cast[Ptr[uint8]]("usage: svg_probe FILE.svg [x y ...]\n"), 36)
        return 2
    path: Ptr[char] = cast[Ptr[char]](argv[1])
    fd: int32 = sys_open(path, 0, 0)
    if fd < 0:
        sys_write(2, cast[Ptr[uint8]]("open failed\n"), 12)
        return 1
    got: int64 = 0
    while got < cast[int64](FILE_CAP):
        n: int64 = sys_read(fd, &fbuf[got], FILE_CAP - cast[uint64](got))
        if n <= 0:
            break
        got = got + n
    sys_close(fd)
    _os(cast[Ptr[uint8]]("SNIFF "))
    _od(cast[int64](svg_sniff(&fbuf[0], cast[uint64](got))))
    _oc(10)
    rc: int32 = svg_decode(&fbuf[0], cast[uint64](got))
    _os(cast[Ptr[uint8]]("RC "))
    _od(cast[int64](rc))
    _oc(10)
    if rc == 0:
        _os(cast[Ptr[uint8]]("DIM "))
        _od(cast[int64](svg_width()))
        _oc(32)
        _od(cast[int64](svg_height()))
        _oc(10)
    _flush()
    if rc != 0:
        return 0
    # optional PPM dump mode: svg_probe FILE.svg --ppm OUT.ppm [scale]
    if argc >= 4:
        arg2: Ptr[uint8] = cast[Ptr[uint8]](argv[2])
        if arg2[0] == 45 and arg2[1] == 45 and arg2[2] == 112:   # "--p"
            scale: int32 = 1
            if argc >= 5:
                scale = cast[int32](_atoi(cast[Ptr[char]](argv[4])))
            if scale < 1:
                scale = 1
            _dump_ppm(cast[Ptr[char]](argv[3]), scale)
            return 0
    a: int32 = 2
    while a + 1 < argc:
        x: int32 = cast[int32](_atoi(cast[Ptr[char]](argv[a])))
        y: int32 = cast[int32](_atoi(cast[Ptr[char]](argv[a + 1])))
        px: uint32 = svg_pixel(x, y)
        _os(cast[Ptr[uint8]]("PIX "))
        _od(cast[int64](x))
        _oc(32)
        _od(cast[int64](y))
        _oc(32)
        _od(cast[int64]((px >> 16) & 255))
        _oc(32)
        _od(cast[int64]((px >> 8) & 255))
        _oc(32)
        _od(cast[int64](px & 255))
        _oc(32)
        _od(cast[int64]((px >> 24) & 255))
        _oc(10)
        _flush()
        a = a + 2
    return 0

# user/hambrowse_host_gfx.ad — HOST driver that renders an HTML page to a REAL
# PIXEL PNG through the new graphical backend (lib/htmlpaint + lib/htmlpage),
# proving the browser is no longer a monospace character grid.
#
# Built for the x86_64-linux Adder target: it runs directly on the dev host
# (no QEMU). It reads a local HTML file + the three bundled BDF fonts, drives
# the SAME parse/CSS/JS engine the native browser uses (lib/htmlengine.ad),
# then lays out + paints the segments onto an RGB canvas with PROPORTIONAL
# fonts and a heading hierarchy, and writes the framebuffer as a binary PPM
# (scripts/run_hambrowse_gfx.sh converts it to PNG for eyeballing). It also
# dumps deterministic geometry (canvas size, per-row pixel tops/heights,
# proportional advance widths, sampled pixels) to stdout so a gate can assert
# the layout rigorously.
#
# No sockets, no Plan 9: it only reads argv + font/HTML files and writes one
# PPM. This is a TEST/iteration shim; the native window transport stays in
# user/hambrowse.ad.
#
# USAGE (built to build/host/hambrowse_gfx):
#   hambrowse_gfx FILE.html OUT.ppm [WIDTH]

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.htmlengine import he_layout
from lib.htmlpaint import htmlpaint_load_face, htmlpaint_width, \
    htmlpaint_height, htmlpaint_fb_ptr, htmlpaint_fb_bytes, htmlpaint_pixel, \
    htmlpaint_ppm_header, htmlpaint_measure, FACE_SANS, FACE_MONO, FACE_SERIF
from lib.htmlpage import htmlpage_render, htmlpage_row_top, \
    htmlpage_row_height, htmlpage_row_baseline


# ---- stdout helpers -------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)                                          # '#'
    hexd: Ptr[uint8] = cast[Ptr[uint8]]("0123456789abcdef")
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        _o_ch(hexd[nyb])
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- file slurp -----------------------------------------------------
FILE_CAP: uint64 = 262144
html_buf: Array[262144, uint8]
html_len: uint64 = 0

FONT_CAP: uint64 = 262144
sans_buf: Array[262144, uint8]
mono_buf: Array[262144, uint8]
serif_buf: Array[262144, uint8]


def _slurp(path: Ptr[char], dst: Ptr[uint8], cap: uint64) -> int64:
    fd: int32 = sys_open(path, 0, 0)                   # O_RDONLY
    if fd < 0:
        return -1
    got: uint64 = 0
    while got < cap - 1:
        n: int64 = sys_read(fd, &dst[got], cap - 1 - got)
        if n <= 0:
            break
        got = got + cast[uint64](n)
    sys_close(fd)
    return cast[int64](got)


def _atoi(s: Ptr[uint8]) -> int32:
    v: int32 = 0
    i: uint64 = 0
    while s[i] >= 48 and s[i] <= 57:
        v = v * 10 + cast[int32](s[i]) - 48
        i = i + 1
    return v


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    # O_WRONLY|O_CREAT|O_TRUNC=0x241=577, mode 0644=420.
    fd: int32 = sys_open(path, 577, 420)
    if fd < 0:
        return -1
    hlen: uint64 = htmlpaint_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, htmlpaint_fb_ptr(), htmlpaint_fb_bytes())
    sys_close(fd)
    return 0


# Sample a pixel and print "PIX x y #rrggbb".
def _sample(x: int32, y: int32):
    _o_str(cast[Ptr[uint8]]("PIX "))
    _o_dec(cast[int64](x))
    _o_ch(32)
    _o_dec(cast[int64](y))
    _o_ch(32)
    _o_hexcol(htmlpaint_pixel(x, y))
    _o_ch(10)
    _o_flush()


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        sys_write(2, cast[Ptr[uint8]]("usage: hambrowse_gfx FILE.html OUT.ppm [WIDTH]\n"), 46)
        return 2
    htmlp: Ptr[char] = cast[Ptr[char]](argv[1])
    outp: Ptr[char] = cast[Ptr[char]](argv[2])

    # Load the three bundled BDF faces (paths relative to repo root).
    sn: int64 = _slurp(cast[Ptr[char]]("fonts/hamnix-sans-6x10.bdf"), &sans_buf[0], FONT_CAP)
    mn: int64 = _slurp(cast[Ptr[char]]("fonts/hamnix-mono-8x16.bdf"), &mono_buf[0], FONT_CAP)
    sf: int64 = _slurp(cast[Ptr[char]]("fonts/hamnix-serif-6x12.bdf"), &serif_buf[0], FONT_CAP)
    if sn <= 0 or mn <= 0 or sf <= 0:
        sys_write(2, cast[Ptr[uint8]]("hambrowse_gfx: cannot read fonts/*.bdf\n"), 39)
        return 1
    gs: int64 = htmlpaint_load_face(FACE_SANS, &sans_buf[0], cast[uint64](sn))
    gm: int64 = htmlpaint_load_face(FACE_MONO, &mono_buf[0], cast[uint64](mn))
    htmlpaint_load_face(FACE_SERIF, &serif_buf[0], cast[uint64](sf))
    _o_str(cast[Ptr[uint8]]("FONTS sans="))
    _o_dec(gs)
    _o_str(cast[Ptr[uint8]](" mono="))
    _o_dec(gm)
    _o_ch(10)
    _o_flush()

    # Read the HTML.
    hn: int64 = _slurp(htmlp, &html_buf[0], FILE_CAP)
    if hn < 0:
        sys_write(2, cast[Ptr[uint8]]("hambrowse_gfx: cannot open HTML\n"), 32)
        return 1
    html_len = cast[uint64](hn)

    # Optional page width.
    if argc >= 4:
        w: int32 = _atoi(cast[Ptr[uint8]](argv[3]))
        if w >= 120:
            bw = w

    # Drive the SHARED engine, then the pixel paint.
    src_ptr = &html_buf[0]
    src_len = html_len
    he_layout()
    total_h: int32 = htmlpage_render()

    # ---- deterministic geometry dump ----
    _o_str(cast[Ptr[uint8]]("CANVAS "))
    _o_dec(cast[int64](htmlpaint_width()))
    _o_ch(32)
    _o_dec(cast[int64](htmlpaint_height()))
    _o_ch(10)
    _o_flush()

    # Per-row pixel geometry for the first 12 rows (top/height/baseline).
    r: uint64 = 0
    while r < 12 and r < total_rows:
        _o_str(cast[Ptr[uint8]]("ROW "))
        _o_dec(cast[int64](r))
        _o_str(cast[Ptr[uint8]](" top "))
        _o_dec(cast[int64](htmlpage_row_top(r)))
        _o_str(cast[Ptr[uint8]](" h "))
        _o_dec(cast[int64](htmlpage_row_height(r)))
        _o_str(cast[Ptr[uint8]](" base "))
        _o_dec(cast[int64](htmlpage_row_baseline(r)))
        _o_ch(10)
        _o_flush()
        r = r + 1

    # PROPORTIONALITY proof: narrow vs wide runs measure differently in the
    # same face/scale — impossible on a fixed 8px grid.
    narrow: Ptr[uint8] = "iiii"
    wide: Ptr[uint8] = "WWWW"
    _o_str(cast[Ptr[uint8]]("ADV sans iiii="))
    _o_dec(cast[int64](htmlpaint_measure(FACE_SANS, 1, 0, narrow, 4)))
    _o_str(cast[Ptr[uint8]](" WWWW="))
    _o_dec(cast[int64](htmlpaint_measure(FACE_SANS, 1, 0, wide, 4)))
    _o_str(cast[Ptr[uint8]](" mono_iiii="))
    _o_dec(cast[int64](htmlpaint_measure(FACE_MONO, 1, 0, narrow, 4)))
    _o_str(cast[Ptr[uint8]](" mono_WWWW="))
    _o_dec(cast[int64](htmlpaint_measure(FACE_MONO, 1, 0, wide, 4)))
    _o_ch(10)
    _o_flush()

    # Write the PPM.
    if _write_ppm(outp) != 0:
        sys_write(2, cast[Ptr[uint8]]("hambrowse_gfx: cannot write PPM\n"), 32)
        return 1
    _o_str(cast[Ptr[uint8]]("WROTE "))
    _o_dec(cast[int64](htmlpaint_fb_bytes()))
    _o_ch(10)
    _o_flush()

    # A few sample pixels (top-left should be white paper).
    _sample(0, 0)
    return 0

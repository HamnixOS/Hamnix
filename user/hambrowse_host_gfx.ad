# user/hambrowse_host_gfx.ad — HOST driver that renders an HTML page to a REAL
# PIXEL PNG through the new graphical backend (lib/htmlpaint + lib/htmlpage),
# proving the browser is no longer a monospace character grid.
#
# Built for the x86_64-linux Adder target: it runs directly on the dev host
# (no QEMU). It reads a local HTML file + the three bundled BDF fonts, drives
# the SAME parse/CSS/JS engine the native browser uses (lib/htmlengine.ad),
# then lays out + paints the segments onto an RGB canvas with PROPORTIONAL
# fonts and a heading hierarchy, and writes the framebuffer as a binary PPM
# (scripts/run_hambrowse_gfx.sh converts it to PNG for eyeballing). It also
# dumps deterministic geometry (canvas size, per-row pixel tops/heights,
# proportional advance widths, sampled pixels) to stdout so a gate can assert
# the layout rigorously.
#
# No sockets, no Plan 9: it only reads argv + font/HTML files and writes one
# PPM. This is a TEST/iteration shim; the native window transport stays in
# user/hambrowse.ad.
#
# USAGE (built to build/host/hambrowse_gfx):
#   hambrowse_gfx FILE.html OUT.ppm [WIDTH]

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.htmlengine import he_layout, he_n_images, he_img_name_ptr, \
    he_img_name_len, he_n_segs, he_seg_img, he_seg_imgw, he_seg_imgh, \
    he_seg_x, he_seg_line, he_page_width, he_seg_gridx, \
    he_seg_marker, he_seg_indjump, he_seg_uline, he_seg_link, \
    he_seg_yoff, he_seg_strike, he_seg_bg, he_seg_face, he_seg_pxsize, \
    he_seg_bold, he_seg_text_ptr, he_seg_off, he_seg_len, \
    he_n_bfills, he_bfill_lx, he_bfill_rx, he_bfill_top, he_bfill_bot, \
    he_bfill_rgb, he_bfill_z, \
    he_dom_set_value, he_dom_click, he_dom_set_checked, he_dom_submit
from lib.jsengine import js_set_drain
from lib.htmlpaint import htmlpaint_load_face, htmlpaint_width, \
    htmlpaint_height, htmlpaint_fb_ptr, htmlpaint_fb_bytes, htmlpaint_pixel, \
    htmlpaint_ppm_header, htmlpaint_measure, htmlpaint_load_ttf, \
    htmlpaint_ttf_ok, htmlpaint_measure_ttf, FACE_SANS, FACE_MONO, FACE_SERIF
from lib.htmlpage import htmlpage_render, htmlpage_row_top, \
    htmlpage_row_height, htmlpage_row_baseline, htmlpage_install_reflow, \
    htmlpage_seg_px_x0, htmlpage_seg_px_x1, htmlpage_n_borders, \
    htmlpage_border_x0, \
    htmlpage_border_y0, htmlpage_border_x1, htmlpage_border_y1
from lib.png import png_decode, png_width, png_height, png_rgba_ptr
from lib.jpeg import jpeg_decode, jpeg_width, jpeg_height, jpeg_rgba_ptr
from lib.gif import gif_decode, gif_width, gif_height, gif_rgba_ptr
from lib.svg import svg_decode, svg_width, svg_height, svg_rgba_ptr, svg_sniff
from lib.htmlimg import htmlimg_reset, htmlimg_add
from lib.font_ttf import FACE_TT_SANS, FACE_TT_SANS_BOLD, FACE_TT_SERIF, \
    FACE_TT_MONO


# ---- stdout helpers -------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)                                          # '#'
    hexd: Ptr[uint8] = cast[Ptr[uint8]]("0123456789abcdef")
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        _o_ch(hexd[nyb])
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- file slurp -----------------------------------------------------
FILE_CAP: uint64 = 262144
html_buf: Array[262144, uint8]
html_len: uint64 = 0

FONT_CAP: uint64 = 262144
sans_buf: Array[262144, uint8]
mono_buf: Array[262144, uint8]
serif_buf: Array[262144, uint8]
# TrueType faces for the scalable, anti-aliased renderer.
ttsans_buf: Array[262144, uint8]
ttsansb_buf: Array[262144, uint8]
ttserif_buf: Array[262144, uint8]
ttmono_buf: Array[262144, uint8]


def _slurp(path: Ptr[char], dst: Ptr[uint8], cap: uint64) -> int64:
    fd: int32 = sys_open(path, 0, 0)                   # O_RDONLY
    if fd < 0:
        return -1
    got: uint64 = 0
    while got < cap - 1:
        n: int64 = sys_read(fd, &dst[got], cap - 1 - got)
        if n <= 0:
            break
        got = got + cast[uint64](n)
    sys_close(fd)
    return cast[int64](got)


def _atoi(s: Ptr[uint8]) -> int32:
    v: int32 = 0
    i: uint64 = 0
    while s[i] >= 48 and s[i] <= 57:
        v = v * 10 + cast[int32](s[i]) - 48
        i = i + 1
    return v


def _slen(s: Ptr[uint8]) -> int32:
    i: int32 = 0
    while s[i] != 0:
        i = i + 1
    return i


def _streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: int32 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] == b[i]:
        return 1
    return 0


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    # O_WRONLY|O_CREAT|O_TRUNC=0x241=577, mode 0644=420.
    fd: int32 = sys_open(path, 577, 420)
    if fd < 0:
        return -1
    hlen: uint64 = htmlpaint_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, htmlpaint_fb_ptr(), htmlpaint_fb_bytes())
    sys_close(fd)
    return 0


# Sample a pixel and print "PIX x y #rrggbb".
def _sample(x: int32, y: int32):
    _o_str(cast[Ptr[uint8]]("PIX "))
    _o_dec(cast[int64](x))
    _o_ch(32)
    _o_dec(cast[int64](y))
    _o_ch(32)
    _o_hexcol(htmlpaint_pixel(x, y))
    _o_ch(10)
    _o_flush()


# ---- image decode plumbing ------------------------------------------
png_file_buf: Array[262144, uint8]
img_path: Array[1024, uint8]


# Resolve an <img src> against the HTML file's directory: an absolute src
# ('/...') is used verbatim; otherwise it is joined onto the dir of `htmlpath`.
# A leading "file://" is stripped. Writes a NUL-terminated path into img_path.
def _resolve_img_path(htmlpath: Ptr[char], src: Ptr[uint8], slen: uint64):
    # strip a "file://" scheme prefix from src.
    soff: uint64 = 0
    if slen >= 7 and src[0] == 102 and src[1] == 105 and src[2] == 108 and \
       src[3] == 101 and src[4] == 58 and src[5] == 47 and src[6] == 47:
        soff = 7
    p: uint64 = 0
    if slen > soff and src[soff] == 47:
        # absolute path — ignore the html dir.
        j: uint64 = soff
        while j < slen and p < 1023:
            img_path[p] = src[j]
            p = p + 1
            j = j + 1
    else:
        # copy htmlpath up to and including its last '/'.
        hp: Ptr[uint8] = cast[Ptr[uint8]](htmlpath)
        i: uint64 = 0
        last_slash: int64 = -1
        while hp[i] != 0:
            if hp[i] == 47:
                last_slash = cast[int64](i)
            i = i + 1
        k: uint64 = 0
        while cast[int64](k) <= last_slash and p < 1023:
            img_path[p] = hp[k]
            p = p + 1
            k = k + 1
        j: uint64 = soff
        while j < slen and p < 1023:
            img_path[p] = src[j]
            p = p + 1
            j = j + 1
    img_path[p] = 0


# Decode every <img src> the last layout recorded and register it in htmlimg.
# Prints one "IMGDEC name rc w h" line per image.
def _decode_images(htmlpath: Ptr[char]):
    htmlimg_reset()
    ni: uint64 = he_n_images()
    idx: uint64 = 0
    while idx < ni:
        nm: Ptr[uint8] = he_img_name_ptr(idx)
        nl: uint64 = he_img_name_len(idx)
        _resolve_img_path(htmlpath, nm, nl)
        got: int64 = _slurp(cast[Ptr[char]](&img_path[0]), &png_file_buf[0], FILE_CAP)
        # Dispatch by magic: PNG signature vs JPEG SOI. Both decoders expose a
        # parallel width/height/rgba-ptr API, so the RGBA -> htmlimg flow below
        # is format-agnostic. An unknown magic (or a decode failure) leaves
        # rc<0 -> the caller draws the broken-image placeholder.
        rc: int32 = -1
        iw: int32 = 0
        ih: int32 = 0
        rp: Ptr[uint8] = cast[Ptr[uint8]](0)
        if got >= 2:
            if png_file_buf[0] == 137 and png_file_buf[1] == 80:
                rc = png_decode(&png_file_buf[0], cast[uint64](got))
                if rc == 0:
                    iw = png_width()
                    ih = png_height()
                    rp = png_rgba_ptr()
            elif png_file_buf[0] == 255 and png_file_buf[1] == 216:
                rc = jpeg_decode(&png_file_buf[0], cast[uint64](got))
                if rc == 0:
                    iw = jpeg_width()
                    ih = jpeg_height()
                    rp = jpeg_rgba_ptr()
            elif png_file_buf[0] == 71 and png_file_buf[1] == 73 and \
                 png_file_buf[2] == 70 and png_file_buf[3] == 56:
                rc = gif_decode(&png_file_buf[0], cast[uint64](got))
                if rc == 0:
                    iw = gif_width()
                    ih = gif_height()
                    rp = gif_rgba_ptr()
            elif svg_sniff(&png_file_buf[0], cast[uint64](got)) != 0:
                # SVG has no binary magic — dispatch by CONTENT (XML text).
                rc = svg_decode(&png_file_buf[0], cast[uint64](got))
                if rc == 0:
                    iw = svg_width()
                    ih = svg_height()
                    rp = svg_rgba_ptr()
        _o_str(cast[Ptr[uint8]]("IMGDEC "))
        _o_ch(34)
        kk: uint64 = 0
        while kk < nl:
            _o_ch(nm[kk])
            kk = kk + 1
        _o_ch(34)
        _o_ch(32)
        _o_dec(cast[int64](rc))
        if rc == 0:
            _o_ch(32)
            _o_dec(cast[int64](iw))
            _o_ch(32)
            _o_dec(cast[int64](ih))
            htmlimg_add(nm, nl, iw, ih, rp)
        _o_ch(10)
        _o_flush()
        idx = idx + 1


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        sys_write(2, cast[Ptr[uint8]]("usage: hambrowse_gfx FILE.html OUT.ppm [WIDTH]\n"), 46)
        return 2
    htmlp: Ptr[char] = cast[Ptr[char]](argv[1])
    outp: Ptr[char] = cast[Ptr[char]](argv[2])

    # Load the three bundled BDF faces (paths relative to repo root).
    sn: int64 = _slurp(cast[Ptr[char]]("fonts/hamnix-sans-6x10.bdf"), &sans_buf[0], FONT_CAP)
    mn: int64 = _slurp(cast[Ptr[char]]("fonts/hamnix-mono-8x16.bdf"), &mono_buf[0], FONT_CAP)
    sf: int64 = _slurp(cast[Ptr[char]]("fonts/hamnix-serif-6x12.bdf"), &serif_buf[0], FONT_CAP)
    if sn <= 0 or mn <= 0 or sf <= 0:
        sys_write(2, cast[Ptr[uint8]]("hambrowse_gfx: cannot read fonts/*.bdf\n"), 39)
        return 1
    gs: int64 = htmlpaint_load_face(FACE_SANS, &sans_buf[0], cast[uint64](sn))
    gm: int64 = htmlpaint_load_face(FACE_MONO, &mono_buf[0], cast[uint64](mn))
    htmlpaint_load_face(FACE_SERIF, &serif_buf[0], cast[uint64](sf))
    _o_str(cast[Ptr[uint8]]("FONTS sans="))
    _o_dec(gs)
    _o_str(cast[Ptr[uint8]](" mono="))
    _o_dec(gm)
    _o_ch(10)
    _o_flush()

    # Load the scalable TrueType faces used by the pixel renderer.
    ts: int64 = _slurp(cast[Ptr[char]]("fonts/dejavu-sans.ttf"), &ttsans_buf[0], FONT_CAP)
    tb: int64 = _slurp(cast[Ptr[char]]("fonts/dejavu-sans-bold.ttf"), &ttsansb_buf[0], FONT_CAP)
    tr: int64 = _slurp(cast[Ptr[char]]("fonts/dejavu-serif.ttf"), &ttserif_buf[0], FONT_CAP)
    tm: int64 = _slurp(cast[Ptr[char]]("fonts/dejavu-mono.ttf"), &ttmono_buf[0], FONT_CAP)
    if ts <= 0 or tb <= 0 or tr <= 0 or tm <= 0:
        sys_write(2, cast[Ptr[uint8]]("hambrowse_gfx: cannot read fonts/*.ttf\n"), 40)
        return 1
    rs: int32 = htmlpaint_load_ttf(FACE_TT_SANS, &ttsans_buf[0], cast[uint64](ts))
    rb: int32 = htmlpaint_load_ttf(FACE_TT_SANS_BOLD, &ttsansb_buf[0], cast[uint64](tb))
    htmlpaint_load_ttf(FACE_TT_SERIF, &ttserif_buf[0], cast[uint64](tr))
    rm: int32 = htmlpaint_load_ttf(FACE_TT_MONO, &ttmono_buf[0], cast[uint64](tm))
    _o_str(cast[Ptr[uint8]]("TTF sans_rc="))
    _o_dec(cast[int64](rs))
    _o_str(cast[Ptr[uint8]](" bold_rc="))
    _o_dec(cast[int64](rb))
    _o_str(cast[Ptr[uint8]](" mono_rc="))
    _o_dec(cast[int64](rm))
    _o_str(cast[Ptr[uint8]](" ok="))
    _o_dec(cast[int64](htmlpaint_ttf_ok(FACE_TT_SANS)))
    _o_ch(10)
    _o_flush()

    # Read the HTML.
    hn: int64 = _slurp(htmlp, &html_buf[0], FILE_CAP)
    if hn < 0:
        sys_write(2, cast[Ptr[uint8]]("hambrowse_gfx: cannot open HTML\n"), 32)
        return 1
    html_len = cast[uint64](hn)

    # Optional page width.
    if argc >= 4:
        w: int32 = _atoi(cast[Ptr[uint8]](argv[3]))
        if w >= 120:
            bw = w

    # Drive the SHARED engine, then the pixel paint. IMAGES need two layout
    # passes: the FIRST records every <img src>; we then slurp+decode each PNG
    # into the htmlimg store; the SECOND lays out again so <img> boxes without
    # explicit width/height take the decoded image's NATURAL size.
    src_ptr = &html_buf[0]
    src_len = html_len
    # TRUE reflow: measure candidate lines in real TrueType advances so prose
    # wraps to the window width instead of growing the canvas sideways. Must be
    # installed after the faces load and before the first he_layout().
    htmlpage_install_reflow()
    # CONTROL knob: if any argv token is "nodrain", disable the JS engine's
    # end-of-turn microtask/timer drain so Promise/setTimeout/fetch callbacks
    # never run. Renders the PRE-drain DOM (synchronous placeholders survive),
    # proving the async DOM mutations in the normal render are drain-dependent.
    ai: int32 = 4
    while ai < argc:
        if _streq(cast[Ptr[uint8]](argv[ai]), cast[Ptr[uint8]]("nodrain")) != 0:
            js_set_drain(0)
        ai = ai + 1
    he_layout()
    _decode_images(htmlp)
    he_layout()

    # Optional post-load interaction so the rendered PNG shows a JS-driven DOM
    # update (the pointer-free equivalent of a user typing / clicking):
    #   FILE OUT.ppm WIDTH setval ID VALUE   — fire ID's oninput/onchange
    #   FILE OUT.ppm WIDTH click  ID         — fire ID's onclick
    # he_dom_set_value / he_dom_click re-lay-out internally; the paint below
    # then repaints the mutated DOM.
    acted: int32 = 0
    if argc >= 5:
        verb: Ptr[uint8] = cast[Ptr[uint8]](argv[4])
        if _streq(verb, cast[Ptr[uint8]]("setval")) != 0 and argc >= 7:
            id_p: Ptr[uint8] = cast[Ptr[uint8]](argv[5])
            val_p: Ptr[uint8] = cast[Ptr[uint8]](argv[6])
            he_dom_set_value(id_p, _slen(id_p), val_p, _slen(val_p))
            acted = 1
        elif _streq(verb, cast[Ptr[uint8]]("click")) != 0 and argc >= 6:
            cid_p: Ptr[uint8] = cast[Ptr[uint8]](argv[5])
            he_dom_click(cid_p, _slen(cid_p))
            acted = 1
        elif _streq(verb, cast[Ptr[uint8]]("check")) != 0 and argc >= 7:
            ck_id: Ptr[uint8] = cast[Ptr[uint8]](argv[5])
            ck_v: int32 = _atoi(cast[Ptr[uint8]](argv[6]))
            he_dom_set_checked(ck_id, _slen(ck_id), ck_v)
            acted = 1
        elif _streq(verb, cast[Ptr[uint8]]("submit")) != 0 and argc >= 6:
            sub_id: Ptr[uint8] = cast[Ptr[uint8]](argv[5])
            he_dom_submit(sub_id, _slen(sub_id))
            acted = 1

    total_h: int32 = htmlpage_render()

    # Image-segment geometry (slot, box w/h, x, row-top px) for the gate.
    ns: uint64 = he_n_segs()
    si: uint64 = 0
    while si < ns:
        if he_seg_img(si) != -1:
            _o_str(cast[Ptr[uint8]]("IMGSEG slot "))
            _o_dec(cast[int64](he_seg_img(si)))
            _o_str(cast[Ptr[uint8]](" w "))
            _o_dec(cast[int64](he_seg_imgw(si)))
            _o_str(cast[Ptr[uint8]](" h "))
            _o_dec(cast[int64](he_seg_imgh(si)))
            _o_str(cast[Ptr[uint8]](" x "))
            _o_dec(cast[int64](he_seg_x(si)))
            _o_str(cast[Ptr[uint8]](" top "))
            _o_dec(cast[int64](htmlpage_row_top(cast[uint64](he_seg_line(si)))))
            _o_ch(10)
            _o_flush()
        si = si + 1

    # ---- rendered-text dump: one "SEGTXT <bytes>" line per laid-out text run,
    # so a gate can assert the exact CONTENT the browser painted (e.g. that a
    # DOM mutation made by an async setTimeout/Promise/fetch callback survived
    # the microtask drain and reached the segment list). Non-printable bytes are
    # emitted verbatim; each seg is one line.
    tp: Ptr[uint8] = he_seg_text_ptr()
    ti: uint64 = 0
    while ti < ns:
        toff: int32 = he_seg_off(ti)
        tlen: int32 = he_seg_len(ti)
        if tlen > 0:
            _o_str(cast[Ptr[uint8]]("SEGTXT "))
            k: int32 = 0
            while k < tlen:
                c: uint8 = tp[toff + k]
                if c == 10 or c == 13:
                    c = 32
                _o_ch(c)
                k = k + 1
            _o_ch(10)
            _o_flush()
        ti = ti + 1

    # ---- deterministic geometry dump ----
    _o_str(cast[Ptr[uint8]]("CANVAS "))
    _o_dec(cast[int64](htmlpaint_width()))
    _o_ch(32)
    _o_dec(cast[int64](htmlpaint_height()))
    _o_ch(10)
    _o_flush()

    # ---- CSS POSITION proof: one POSFILL line per block background box, giving
    # its PAINTED pixel rect (x0/y0 top-left, x1/y1 bottom-right via row_top +
    # row_height), its stacking z, its declared colour, and the colour actually
    # SAMPLED a few px inside its top-left corner (a stable fill pixel, clear of
    # the centred glyph ink). A `position:relative`/`absolute` box's rect shows
    # the applied offset; where two positioned boxes overlap the sampled pixel is
    # the higher-z box's colour, proving the z-index paint sort.
    nposf: int32 = he_n_bfills()
    pfi: int32 = 0
    while pfi < nposf:
        pflx: int32 = he_bfill_lx(pfi)
        if pflx < 0:
            pflx = 0
        pfrx: int32 = he_bfill_rx(pfi)
        pftop: int32 = he_bfill_top(pfi)
        pfbot: int32 = he_bfill_bot(pfi)
        py0: int32 = htmlpage_row_top(cast[uint64](pftop))
        py1: int32 = py0
        if pfbot > pftop:
            lastr: int32 = pfbot - 1
            py1 = htmlpage_row_top(cast[uint64](lastr)) + \
                  htmlpage_row_height(cast[uint64](lastr))
        smpx: int32 = pflx + 3
        smpy: int32 = py0 + 3
        _o_str(cast[Ptr[uint8]]("POSFILL "))
        _o_dec(cast[int64](pfi))
        _o_str(cast[Ptr[uint8]](" z "))
        _o_dec(cast[int64](he_bfill_z(pfi)))
        _o_str(cast[Ptr[uint8]](" x0 "))
        _o_dec(cast[int64](pflx))
        _o_str(cast[Ptr[uint8]](" y0 "))
        _o_dec(cast[int64](py0))
        _o_str(cast[Ptr[uint8]](" x1 "))
        _o_dec(cast[int64](pfrx))
        _o_str(cast[Ptr[uint8]](" y1 "))
        _o_dec(cast[int64](py1))
        _o_str(cast[Ptr[uint8]](" col "))
        _o_hexcol(cast[uint32](he_bfill_rgb(pfi)))
        _o_str(cast[Ptr[uint8]](" pix "))
        _o_hexcol(htmlpaint_pixel(smpx, smpy))
        _o_ch(10)
        _o_flush()
        pfi = pfi + 1

    # ---- CSS BORDER proof: each bordered box is a REAL stroked 1px rectangle,
    # not the old ASCII '+---+'/'|' glyphs. For every registered border we print
    # its outer rect, then SAMPLE the framebuffer: a pixel ON the top edge must
    # be dark (the stroke) and a pixel a few px BELOW-INSIDE must be white
    # (padding, no glyph fill). "BORDER n <N>" then one "BORDER i ... edge #rgb
    # inside #rgb" line per box.
    nbord: int32 = htmlpage_n_borders()
    _o_str(cast[Ptr[uint8]]("BORDER n "))
    _o_dec(cast[int64](nbord))
    _o_ch(10)
    _o_flush()
    bidx: int32 = 0
    while bidx < nbord:
        bx0: int32 = htmlpage_border_x0(bidx)
        by0: int32 = htmlpage_border_y0(bidx)
        bx1: int32 = htmlpage_border_x1(bidx)
        by1: int32 = htmlpage_border_y1(bidx)
        mx: int32 = (bx0 + bx1) / 2                    # top-edge midpoint x
        edge: int32 = htmlpaint_pixel(mx, by0)         # on the top stroke
        inside: int32 = htmlpaint_pixel(mx, by0 + 6)   # padding just inside
        _o_str(cast[Ptr[uint8]]("BORDER "))
        _o_dec(cast[int64](bidx))
        _o_str(cast[Ptr[uint8]](" x0 "))
        _o_dec(cast[int64](bx0))
        _o_str(cast[Ptr[uint8]](" y0 "))
        _o_dec(cast[int64](by0))
        _o_str(cast[Ptr[uint8]](" x1 "))
        _o_dec(cast[int64](bx1))
        _o_str(cast[Ptr[uint8]](" y1 "))
        _o_dec(cast[int64](by1))
        _o_str(cast[Ptr[uint8]](" edge "))
        _o_hexcol(edge)
        _o_str(cast[Ptr[uint8]](" inside "))
        _o_hexcol(inside)
        _o_ch(10)
        _o_flush()
        bidx = bidx + 1

    # ---- LIST proof: an unordered <li> gets a real round bullet DISC in the
    # gutter, and its item text HANGS at an indent (the marker gutter survives
    # the proportional reflow, instead of the '-' gluing to the text). We count
    # bullet-marker segs, sample the first disc's centre pixel (must be inked,
    # not white paper), and report the first item text's painted left x (must be
    # indented well past the left pad).
    nmark: int32 = 0
    discpix: int32 = 16777215                           # default white
    itemx: int32 = -1
    li: uint64 = 0
    while li < ns:
        if he_seg_marker(li) != 0:
            if nmark == 0:
                mcx: int32 = (htmlpage_seg_px_x0(li) + htmlpage_seg_px_x1(li)) / 2
                mrow: int32 = he_seg_line(li)
                mby: int32 = htmlpage_row_baseline(cast[uint64](mrow))
                discpix = htmlpaint_pixel(mcx, mby - 5)
            nmark = nmark + 1
        if he_seg_indjump(li) != 0 and itemx < 0:
            itemx = htmlpage_seg_px_x0(li)
        li = li + 1
    _o_str(cast[Ptr[uint8]]("LIST markers "))
    _o_dec(cast[int64](nmark))
    _o_str(cast[Ptr[uint8]](" discpix "))
    _o_hexcol(discpix)
    _o_str(cast[Ptr[uint8]](" itemx "))
    _o_dec(cast[int64](itemx))
    _o_ch(10)
    _o_flush()

    # ---- UNDERLINE proof: CSS text-decoration:underline paints a real 1px rule
    # under NON-link text, and text-decoration:none strips a link's default
    # underline. We count underlined non-link segs (cssn), underlined link segs
    # (linkul) and plain (un-underlined) link segs (linkplain), then SAMPLE the
    # framebuffer just below the first CSS-underlined non-link seg's baseline:
    # that pixel must be inked (the rule), proving the flag reached the paint.
    cssn: int32 = 0
    linkul: int32 = 0
    linkplain: int32 = 0
    rulepix: int32 = 16777215                            # default white paper
    ui: uint64 = 0
    while ui < ns:
        if he_seg_uline(ui) != 0:
            if he_seg_link(ui) >= 0:
                linkul = linkul + 1
            else:
                if cssn == 0:
                    ucx: int32 = (htmlpage_seg_px_x0(ui) + htmlpage_seg_px_x1(ui)) / 2
                    urow: int32 = he_seg_line(ui)
                    uby: int32 = htmlpage_row_baseline(cast[uint64](urow))
                    rulepix = htmlpaint_pixel(ucx, uby + 2)
                cssn = cssn + 1
        else:
            if he_seg_link(ui) >= 0:
                linkplain = linkplain + 1
        ui = ui + 1
    _o_str(cast[Ptr[uint8]]("ULINE cssn "))
    _o_dec(cast[int64](cssn))
    _o_str(cast[Ptr[uint8]](" linkul "))
    _o_dec(cast[int64](linkul))
    _o_str(cast[Ptr[uint8]](" linkplain "))
    _o_dec(cast[int64](linkplain))
    _o_str(cast[Ptr[uint8]](" rulepix "))
    _o_hexcol(rulepix)
    _o_ch(10)
    _o_flush()

    # ---- UA-DEFAULT ELEMENT proof: the low-frequency common tags now carry a
    # sensible built-in appearance. We aggregate over the laid-out segments:
    #   sub   = segs LOWERED   (seg_yoff > 0)  -> <sub>
    #   sup   = segs RAISED    (seg_yoff < 0)  -> <sup>
    #   strike= segs struck    (seg_strike)    -> <s>/<del>/<strike>
    #   mono  = segs mono face (seg_face == 1) -> <kbd>/<samp>/<var>/<code>/<pre>
    #   mark  = segs with a highlight bg       -> <mark> (markbg = its colour)
    #   minpx = smallest positive CSS px       -> <small>/<sub>/<sup> shrank text
    ue_sub: int32 = 0
    ue_sup: int32 = 0
    ue_strike: int32 = 0
    ue_mono: int32 = 0
    ue_mark: int32 = 0
    ue_markbg: int32 = -1
    ue_minpx: int32 = 100000
    ue_ddx: int32 = 0                                    # max block left indent (px)
    ue_prow: int32 = -1                                  # previous row seen
    uei: uint64 = 0
    while uei < ns:
        # A block's left indent = the x of the FIRST (row-start) flowed segment
        # on a fresh row. <dd> starts its rows at ~48px vs body at ~8px, so the
        # maximum row-start x proves an element was indented.
        if he_seg_img(uei) == -1 and he_seg_gridx(uei) == 0:
            row_now: int32 = he_seg_line(uei)
            if row_now != ue_prow:
                sxv: int32 = he_seg_x(uei)
                if sxv > ue_ddx:
                    ue_ddx = sxv
                ue_prow = row_now
        yo: int32 = he_seg_yoff(uei)
        if yo > 0:
            ue_sub = ue_sub + 1
        if yo < 0:
            ue_sup = ue_sup + 1
        if he_seg_strike(uei) != 0:
            ue_strike = ue_strike + 1
        if he_seg_face(uei) == 1:
            ue_mono = ue_mono + 1
        bgv: int32 = he_seg_bg(uei)
        if bgv >= 0:
            ue_mark = ue_mark + 1
            if ue_markbg < 0:
                ue_markbg = bgv
        pxv: int32 = he_seg_pxsize(uei)
        if pxv > 0 and pxv < ue_minpx:
            ue_minpx = pxv
        uei = uei + 1
    if ue_minpx == 100000:
        ue_minpx = 0
    _o_str(cast[Ptr[uint8]]("UAELEM sub "))
    _o_dec(cast[int64](ue_sub))
    _o_str(cast[Ptr[uint8]](" sup "))
    _o_dec(cast[int64](ue_sup))
    _o_str(cast[Ptr[uint8]](" strike "))
    _o_dec(cast[int64](ue_strike))
    _o_str(cast[Ptr[uint8]](" mono "))
    _o_dec(cast[int64](ue_mono))
    _o_str(cast[Ptr[uint8]](" mark "))
    _o_dec(cast[int64](ue_mark))
    _o_str(cast[Ptr[uint8]](" markbg "))
    if ue_markbg >= 0:
        _o_hexcol(cast[uint32](ue_markbg))
    else:
        _o_str(cast[Ptr[uint8]]("none"))
    _o_str(cast[Ptr[uint8]](" minpx "))
    _o_dec(cast[int64](ue_minpx))
    _o_str(cast[Ptr[uint8]](" ddx "))
    _o_dec(cast[int64](ue_ddx))
    _o_ch(10)
    _o_flush()

    # ---- HEADING HIERARCHY proof: the first segment of each heading face 2..7
    # (h1..h6) reports its ROW HEIGHT (physical px, driven by the face's em size)
    # and its bold flag. A gate asserts h3 > h4 > body and h4 is bold, proving
    # h4/h5/h6 are sized below h3 (not left at body size) and rendered bold.
    hf: int32 = 2
    while hf <= 7:
        hidx: int64 = -1
        hi: uint64 = 0
        while hi < ns:
            if cast[int32](he_seg_face(hi)) == hf and hidx < 0:
                hidx = cast[int64](hi)
            hi = hi + 1
        if hidx >= 0:
            hrow: int32 = he_seg_line(cast[uint64](hidx))
            _o_str(cast[Ptr[uint8]]("HFACE "))
            _o_dec(cast[int64](hf))
            _o_str(cast[Ptr[uint8]](" h "))
            _o_dec(cast[int64](htmlpage_row_height(cast[uint64](hrow))))
            _o_str(cast[Ptr[uint8]](" bold "))
            _o_dec(cast[int64](he_seg_bold(cast[uint64](hidx))))
            _o_ch(10)
            _o_flush()
        hf = hf + 1

    # ---- REFLOW proof: prose wraps to the window at the real pixel measure ----
    # Walk the PAINTED per-segment extents. maxx = rightmost inked x over all
    # flowed PROSE segments (skip images + grid-positioned table/<pre> runs,
    # which are absolute by design); overflow = prose segments painted past the
    # viewport width pw (must be 0 — no clipping / no sideways growth); trows =
    # distinct visual rows carrying prose (a long paragraph must occupy MANY).
    pw2: int32 = he_page_width()
    maxx: int32 = 0
    overflow: int32 = 0
    trows: int32 = 0
    lastrow: int32 = -1
    ri2: uint64 = 0
    while ri2 < ns:
        if he_seg_img(ri2) == -1 and he_seg_gridx(ri2) == 0:
            x1: int32 = htmlpage_seg_px_x1(ri2)
            if x1 > 0:
                if x1 > maxx:
                    maxx = x1
                if x1 > pw2:
                    overflow = overflow + 1
                rw: int32 = he_seg_line(ri2)
                if rw != lastrow:
                    trows = trows + 1
                    lastrow = rw
        ri2 = ri2 + 1
    _o_str(cast[Ptr[uint8]]("REFLOW pw "))
    _o_dec(cast[int64](pw2))
    _o_str(cast[Ptr[uint8]](" maxx "))
    _o_dec(cast[int64](maxx))
    _o_str(cast[Ptr[uint8]](" overflow "))
    _o_dec(cast[int64](overflow))
    _o_str(cast[Ptr[uint8]](" textrows "))
    _o_dec(cast[int64](trows))
    _o_ch(10)
    _o_flush()

    # Per-row pixel geometry for the first 12 rows (top/height/baseline).
    r: uint64 = 0
    while r < 12 and r < total_rows:
        _o_str(cast[Ptr[uint8]]("ROW "))
        _o_dec(cast[int64](r))
        _o_str(cast[Ptr[uint8]](" top "))
        _o_dec(cast[int64](htmlpage_row_top(r)))
        _o_str(cast[Ptr[uint8]](" h "))
        _o_dec(cast[int64](htmlpage_row_height(r)))
        _o_str(cast[Ptr[uint8]](" base "))
        _o_dec(cast[int64](htmlpage_row_baseline(r)))
        _o_ch(10)
        _o_flush()
        r = r + 1

    # PROPORTIONALITY proof (BDF store, unchanged): narrow vs wide runs measure
    # differently in the same face — impossible on a fixed 8px grid.
    narrow: Ptr[uint8] = "iiii"
    wide: Ptr[uint8] = "WWWW"
    _o_str(cast[Ptr[uint8]]("ADV sans iiii="))
    _o_dec(cast[int64](htmlpaint_measure(FACE_SANS, 1, 0, narrow, 4)))
    _o_str(cast[Ptr[uint8]](" WWWW="))
    _o_dec(cast[int64](htmlpaint_measure(FACE_SANS, 1, 0, wide, 4)))
    _o_str(cast[Ptr[uint8]](" mono_iiii="))
    _o_dec(cast[int64](htmlpaint_measure(FACE_MONO, 1, 0, narrow, 4)))
    _o_str(cast[Ptr[uint8]](" mono_WWWW="))
    _o_dec(cast[int64](htmlpaint_measure(FACE_MONO, 1, 0, wide, 4)))
    _o_ch(10)
    _o_flush()

    # CONTINUOUS FONT-SIZE proof: the SAME string in the SAME TrueType face
    # measures proportionally WIDER as the em px grows — true scalable type, not
    # 3 discrete bitmap steps. (12 < 16 < 18 < 24 px.)
    ssz: Ptr[uint8] = "Hamnix"
    _o_str(cast[Ptr[uint8]]("TTFADV Hamnix 12="))
    _o_dec(cast[int64](htmlpaint_measure_ttf(FACE_TT_SANS, 12, ssz, 6)))
    _o_str(cast[Ptr[uint8]](" 16="))
    _o_dec(cast[int64](htmlpaint_measure_ttf(FACE_TT_SANS, 16, ssz, 6)))
    _o_str(cast[Ptr[uint8]](" 18="))
    _o_dec(cast[int64](htmlpaint_measure_ttf(FACE_TT_SANS, 18, ssz, 6)))
    _o_str(cast[Ptr[uint8]](" 24="))
    _o_dec(cast[int64](htmlpaint_measure_ttf(FACE_TT_SANS, 24, ssz, 6)))
    _o_ch(10)
    _o_flush()

    # ANTI-ALIASING proof: scan the rendered canvas for INTERMEDIATE gray
    # pixels (neither pure white paper nor pure black ink) — grayscale edge
    # coverage that a 1-bit bitmap font can never produce. Count them.
    aa: int64 = 0
    w: int32 = htmlpaint_width()
    h: int32 = htmlpaint_height()
    yy: int32 = 0
    while yy < h:
        xx: int32 = 0
        while xx < w:
            p: uint32 = htmlpaint_pixel(xx, yy)
            rr8: uint32 = (p >> 16) & 255
            gg8: uint32 = (p >> 8) & 255
            bb8: uint32 = p & 255
            # gray = all channels equal, strictly between 0 and 255
            if rr8 == gg8 and gg8 == bb8 and rr8 > 8 and rr8 < 247:
                aa = aa + 1
            xx = xx + 1
        yy = yy + 1
    _o_str(cast[Ptr[uint8]]("AAGRAY "))
    _o_dec(aa)
    _o_ch(10)
    _o_flush()

    # Write the PPM.
    if _write_ppm(outp) != 0:
        sys_write(2, cast[Ptr[uint8]]("hambrowse_gfx: cannot write PPM\n"), 32)
        return 1
    _o_str(cast[Ptr[uint8]]("WROTE "))
    _o_dec(cast[int64](htmlpaint_fb_bytes()))
    _o_ch(10)
    _o_flush()

    # A few sample pixels (top-left should be white paper).
    _sample(0, 0)
    # Extra CLI-driven samples: argv[4], argv[5], ... are x y x y ... pairs so a
    # gate can assert exact pixel colours inside a rendered image box.
    ai: int32 = 4
    if acted != 0:
        ai = argc                                            # verb consumed argv[4..]
    while ai + 1 < argc:
        sx: int32 = _atoi(cast[Ptr[uint8]](argv[ai]))
        sy: int32 = _atoi(cast[Ptr[uint8]](argv[ai + 1]))
        _sample(sx, sy)
        ai = ai + 2
    return 0

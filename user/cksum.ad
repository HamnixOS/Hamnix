# user/cksum.ad
#
# Hamnix `cksum`: POSIX CRC checksum + byte count of stdin. Implements
# the exact algorithm POSIX/coreutils `cksum` uses: a CRC-32 with the
# polynomial 0x04C11DB7 processed MSB-first, the total byte length fed
# through the CRC as a trailing little-tail of length bytes, and a
# final ones-complement. Output: "<crc> <bytes>\n", matching GNU
# coreutils. Reads only stdin (the common `... | cksum` pipeline).
#
# The CRC is computed bit-by-bit (no 256-entry table) to keep the
# binary self-contained; throughput is fine for the byte volumes a
# CLI checksum sees.

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

POLY: uint32 = 0x04C11DB7


def crc_byte(crc: uint32, b: uint8) -> uint32:
    # Feed the 8 bits of b MSB-first into the running CRC.
    c: uint32 = crc ^ (cast[uint32](b) << 24)
    k: int32 = 0
    while k < 8:
        if (c & 0x80000000) != 0:
            c = (c << 1) ^ POLY
        else:
            c = c << 1
        k = k + 1
    return c


def main() -> int32:
    crc: uint32 = 0
    total: uint64 = 0
    chunk: Array[1024, uint8]
    while True:
        n: int64 = sys_read(0, &chunk[0], 1024)
        if n <= 0:
            break
        i: uint64 = 0
        while i < cast[uint64](n):
            crc = crc_byte(crc, chunk[i])
            i = i + 1
        total = total + cast[uint64](n)

    # POSIX: fold the length into the CRC, low byte first, only the
    # significant bytes (stop once the remaining length is zero).
    len_left: uint64 = total
    while len_left != 0:
        crc = crc_byte(crc, cast[uint8](len_left & 0xFF))
        len_left = len_left >> 8

    crc = ~crc

    # Render "<crc> <bytes>\n".
    out: Array[64, uint8]
    p: uint64 = 0

    # crc as decimal.
    if crc == 0:
        out[p] = 48
        p = p + 1
    else:
        tmp: Array[16, uint8]
        ti: uint64 = 0
        v: uint32 = crc
        while v != 0:
            tmp[ti] = cast[uint8](v % 10) + 48
            v = v / 10
            ti = ti + 1
        j: uint64 = 0
        while j < ti:
            out[p] = tmp[ti - 1 - j]
            p = p + 1
            j = j + 1

    out[p] = 32
    p = p + 1

    # byte count as decimal.
    if total == 0:
        out[p] = 48
        p = p + 1
    else:
        tmp2: Array[24, uint8]
        ti2: uint64 = 0
        v2: uint64 = total
        while v2 != 0:
            tmp2[ti2] = cast[uint8](v2 % 10) + 48
            v2 = v2 / 10
            ti2 = ti2 + 1
        j2: uint64 = 0
        while j2 < ti2:
            out[p] = tmp2[ti2 - 1 - j2]
            p = p + 1
            j2 = j2 + 1

    out[p] = 10
    p = p + 1
    sys_write(1, &out[0], p)
    return 0

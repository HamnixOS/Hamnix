# user/scene_raster_host.ad — HOST helper: read a hamscene display-list file
# (as dumped by hamdesktop/hampanelscene's --scene-dump hook), load it into the
# lib/hamscene buffer and rasterize it to a PPM via the same lib/hamui_host
# raster path the kernel compositor uses. QEMU-free. Used by
# scripts/test_de_scene_opt_host.sh to VIEW that the DE scene renders NON-BLANK
# under --opt (the "scene-DE-blank" regression guard).
#
#   scene_raster_host <in.dl> <out.ppm>

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_load
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes

dlbuf: Array[16384, uint8]
ppm_hdr: Array[64, uint8]


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        return 2
    fd: int32 = sys_open(cast[Ptr[char]](argv[1]), 0, 0)
    if fd < 0:
        return 1
    total: uint64 = 0
    while total < 16384:
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
            cast[uint64](&dlbuf[0]) + total), 16384 - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)

    hamscene_load(&dlbuf[0], total)
    hamui_host_begin(800, 600)
    hamui_host_rasterize()

    ofd: int32 = sys_open(cast[Ptr[char]](argv[2]), 577, 420)
    if ofd < 0:
        return 1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(ofd, &ppm_hdr[0], hlen)
    sys_write(ofd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(ofd)
    return 0

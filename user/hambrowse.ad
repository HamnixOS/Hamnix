# user/hambrowse.ad — the NATIVE graphical web browser front-end.
#
# hambrowse FETCHES a page over HTTP (reusing user/http9.ad — the proven
# Plan 9-shape /net client that /bin/wget and /bin/curl use), hands the HTML
# to the shared parse+layout engine in lib/htmlengine.ad, and RENDERS the
# resulting display list as a scene in its own DE window (built on lib/hamui's
# hamscene_* helpers, like /bin/hameditscene).
#
# The parse/layout/colour ENGINE now lives in lib/htmlengine.ad — a PURE,
# I/O-free, UI-free module. This file is the native front-end: the Plan 9
# fetch path, the hamUI render, and the window/event loop. The SAME engine is
# also driven by user/hambrowse_host.ad (the x86_64-linux host test harness),
# so rendering can be iterated on the dev host with no QEMU boot.
#
# USAGE
#   hambrowse                 render the built-in demo page (no network)
#   hambrowse --demo          same as above (explicit)
#   hambrowse http://host/pg  GET the URL and render it
#   hambrowse --url <URL>     explicit address (bare host -> http://)
#   hambrowse /path/file.html  read + render a local file
#
# ADDRESS BAR: an editable URL strip runs across the top of the window under
# the title. CLICK it to focus (border turns blue + a caret appears), TYPE a
# destination, then press Enter — or click "Go" — to navigate. A bare host is
# fetched over http://; http:// https:// file:// and local "/paths" are
# honored as typed. Fetch errors show in the status bar.
#
# HTML SUBSET + colour: see lib/htmlengine.ad. Handles a tolerant subset —
# h1-h6, p/div/br/hr/blockquote, b/i, a, ul/ol/li, pre, span/font, CSS text +
# background colour, tables (two-pass columns), and <img> alt-text
# placeholders. NOT handled: JavaScript, forms, real image decode (honest
# scope).
#
# MEMORY DISCIPLINE (memory/feedback_compiler_quirks.md U9): every sizable
# buffer is a top-level BSS Array, NEVER a stack local — the native user
# stack is a single 4 KiB page. No malloc.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_yield() -> int32
extern def sys_waitfds(fds: Ptr[int32], nfds: uint64, timeout_ms: int64) -> int64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

# The compositor v2 blit protocol: a client rasterises into a private RGBA
# backbuffer and the compositor is a pure blitter for the window. The browser
# renders its PIXEL page canvas (proportional AA text + decoded PNGs) into that
# backbuffer, so on device it shows the SAME graphics the host pixel engine
# produces — not the old VGA-font scene display list.
from lib.hamui import hamui_window_on, hamui_set_protocol_v2_dims, \
    hamui_v2_is_active, hamui_v2_fill_rect, hamui_v2_commit_rect, \
    hamui_v2_bb_ptr, hamui_v2_bb_w, hamui_v2_bb_h
from user.http9 import http_get, http_effective_url
# Shared parse + block/inline layout + colour engine. Geometry globals
# (bw, bh, CONTENT_X, ...), the segment arrays (seg_*, n_segs, ...), the
# link tables, src_ptr/src_len, top_line/total_rows and row_rule are all
# module-global in lib/htmlengine.ad and shared here post-merge.
from lib.htmlengine import he_layout, \
    he_js_console_ptr, he_js_console_len, he_js_error, \
    he_set_click_links, he_link_evt_index, he_dom_click_index, \
    he_n_images, he_img_name_ptr, he_img_name_len
# The PIXEL engine: proportional AA-text + PNG-image page renderer (the SAME
# modules the host gfx driver drives), now presented on device.
from lib.htmlpage import htmlpage_render, htmlpage_doc_width, \
    htmlpage_doc_height, htmlpage_hit_link, htmlpage_install_reflow
from lib.browserwin import browserwin_paint
from lib.png import png_decode, png_width, png_height, png_rgba_ptr
from lib.jpeg import jpeg_decode, jpeg_width, jpeg_height, jpeg_rgba_ptr
from lib.gif import gif_decode, gif_width, gif_height, gif_rgba_ptr
from lib.htmlimg import htmlimg_reset, htmlimg_add, htmlimg_count
from lib.browserfonts import browserfonts_load
from lib.font_ttf import font_ttf_loaded, FACE_TT_SANS, FACE_TT_SANS_BOLD, \
    FACE_TT_SERIF, FACE_TT_MONO


# ====================================================================
# Tiny libc-free helpers (front-end only; the engine has its own).
# ====================================================================
def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


# Append a NUL-terminated string into dst at pos; return the new position. Used
# to compose a whole diagnostic line into ONE buffer so it can be emitted with a
# SINGLE sys_write — the serial console interleaves concurrent DE writers, so a
# line built from many small writes gets torn apart (a gate grepping for the
# contiguous line then false-fails). One write per line keeps it atomic.
def _sapp(dst: Ptr[uint8], pos: uint64, s: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while s[i] != 0:
        dst[pos] = s[i]
        pos = pos + 1
        i = i + 1
    return pos


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


# ====================================================================
# FRONT-END I/O + UI state (the engine owns geometry + the layout model).
#
# resp_buf holds an HTTP response; html_buf holds a local file / the built-in
# demo / an error page.  src_ptr/src_len (in the engine) point at the HTML to
# parse (either &resp_buf[body_off] or &html_buf[0]).
# ====================================================================
RESP_CAP: uint64 = 262144
HTML_CAP: uint64 = 65536
resp_buf: Array[262144, uint8]
html_buf: Array[65536, uint8]
html_len: uint64 = 0

cur_url:  Array[1024, uint8]     # current URL / path (base for link resolve)
status_buf: Array[160, uint8]
status_len: uint64 = 0

# ADDRESS BAR — an editable text buffer shown across the top of the window.
addr_buf:   Array[1024, uint8]
addr_len:   uint64 = 0
addr_focus: int32 = 0


# ====================================================================
# RENDER — the browser now presents the PIXEL engine (lib/htmlpage +
# lib/htmlpaint): the laid-out page is rasterised to a tall RGB document canvas
# (proportional AA text + decoded PNG <img>), then a scrolled viewport of it is
# blitted into the compositor v2 backbuffer alongside the chrome.
# ====================================================================
# PIXEL scroll state (replaces the old row-based scroll). scroll_px is the
# document-space y of the top of the content viewport; doc_*_px cache the last
# render's canvas size so scrolling re-blits without re-rendering.
scroll_px: int32 = 0
doc_w_px:  int32 = 0
doc_h_px:  int32 = 0
SCROLL_LINE: int32 = 40          # px per line-scroll (arrow / j / k / wheel)


def _content_h() -> int32:
    ch: int32 = bh - CONTENT_Y - STATUS_H
    if ch < 0:
        return 0
    return ch


def _max_scroll() -> int32:
    m: int32 = doc_h_px - _content_h()
    if m < 0:
        return 0
    return m


def _clamp_scroll():
    if scroll_px < 0:
        scroll_px = 0
    ms: int32 = _max_scroll()
    if scroll_px > ms:
        scroll_px = ms


# Rasterise the current engine layout to the pixel document canvas and cache its
# size. he_layout() must have run first. Clamps the scroll to the new height.
def _render_doc():
    doc_h_px = htmlpage_render()
    doc_w_px = htmlpage_doc_width()
    _clamp_scroll()


# ---- <img> decode (native): resolve + slurp/fetch + PNG-decode into the
# shared htmlimg store, mirroring the host driver's two-pass image flow so the
# pixel renderer blits real bitmaps. Also decodes the embedded demo image.
png_file_buf: Array[262144, uint8]
img_path: Array[1024, uint8]


# Resolve an <img src> (src,slen) against cur_url into img_path (NUL-terminated).
# Absolute URLs and root-relative/document-relative refs reuse the exact same
# rules as link navigation (_resolve builds nav_buf); here we build img_path.
def _resolve_img(src: Ptr[uint8], slen: uint64):
    p: uint64 = 0
    # absolute http(s):// or file:// or "/abs" -> hand to _fetch-style open.
    # For simplicity resolve like a link: copy verbatim if it has a scheme or is
    # root/relative against cur_url's dir.
    if slen >= 7 and src[0] == 104 and src[1] == 116 and src[2] == 116 and \
       src[3] == 112:
        k: uint64 = 0
        while k < slen and p < 1023:
            img_path[p] = src[k]
            p = p + 1
            k = k + 1
        img_path[p] = 0
        return
    if slen > 0 and src[0] == 47:                    # root-relative "/x"
        alen: uint64 = _authority_len()
        j: uint64 = 0
        while j < alen and p < 1023:
            img_path[p] = cur_url[j]
            p = p + 1
            j = j + 1
        k2: uint64 = 0
        while k2 < slen and p < 1023:
            img_path[p] = src[k2]
            p = p + 1
            k2 = k2 + 1
        img_path[p] = 0
        return
    # document-relative: cur_url dir + src (strip a file:// on the way).
    dlen: uint64 = _dir_len()
    j2: uint64 = 0
    while j2 < dlen and p < 1023:
        img_path[p] = cur_url[j2]
        p = p + 1
        j2 = j2 + 1
    soff: uint64 = 0
    if slen >= 7 and src[0] == 102 and src[1] == 105 and src[2] == 108 and \
       src[3] == 101 and src[4] == 58 and src[5] == 47 and src[6] == 47:
        soff = 7
    k3: uint64 = soff
    while k3 < slen and p < 1023:
        img_path[p] = src[k3]
        p = p + 1
        k3 = k3 + 1
    img_path[p] = 0


# Slurp img_path into png_file_buf. Handles http(s):// via http_get, otherwise a
# local file / file:// path. Returns byte count or -1.
def _slurp_img() -> int64:
    if _starts(&img_path[0], cast[Ptr[uint8]]("http://")) != 0 or \
       _starts(&img_path[0], cast[Ptr[uint8]]("https://")) != 0:
        st: Array[1, int64]
        bo: Array[1, uint64]
        bl: Array[1, uint64]
        st[0] = 0
        bo[0] = 0
        bl[0] = 0
        rc: int64 = http_get(&img_path[0], &png_file_buf[0], 262144,
                             &st[0], &bo[0], &bl[0])
        if rc < 0 or bl[0] == 0:
            return -1
        # Move the body to the front of png_file_buf so png_decode sees it at [0].
        m: uint64 = 0
        while m < bl[0]:
            png_file_buf[m] = png_file_buf[bo[0] + m]
            m = m + 1
        return cast[int64](bl[0])
    path: Ptr[uint8] = &img_path[0]
    if _starts(&img_path[0], cast[Ptr[uint8]]("file://")) != 0:
        path = cast[Ptr[uint8]](cast[uint64](&img_path[0]) + 7)
    fd: int32 = sys_open(cast[Ptr[char]](path))
    if fd < 0:
        return -1
    got: uint64 = 0
    while got < 262143:
        n: int64 = sys_read(fd, &png_file_buf[got], 262144 - 1 - got)
        if n <= 0:
            break
        got = got + cast[uint64](n)
    sys_close(fd)
    return cast[int64](got)


# Decode every <img src> the last he_layout() recorded, registering each in the
# htmlimg store so a second he_layout() sizes the boxes and htmlpage blits them.
def _decode_images():
    htmlimg_reset()
    _register_demo_image()
    ni: uint64 = he_n_images()
    idx: uint64 = 0
    while idx < ni:
        nm: Ptr[uint8] = he_img_name_ptr(idx)
        nl: uint64 = he_img_name_len(idx)
        _resolve_img(nm, nl)
        got: int64 = _slurp_img()
        # Dispatch by magic: PNG signature (89 50) vs JPEG SOI (FF D8). Both
        # decoders expose a parallel width/height/rgba-ptr API.
        if got >= 2:
            if png_file_buf[0] == 137 and png_file_buf[1] == 80:
                if png_decode(&png_file_buf[0], cast[uint64](got)) == 0:
                    htmlimg_add(nm, nl, png_width(), png_height(), png_rgba_ptr())
            elif png_file_buf[0] == 255 and png_file_buf[1] == 216:
                if jpeg_decode(&png_file_buf[0], cast[uint64](got)) == 0:
                    htmlimg_add(nm, nl, jpeg_width(), jpeg_height(), jpeg_rgba_ptr())
            elif png_file_buf[0] == 71 and png_file_buf[1] == 73 and \
                 png_file_buf[2] == 70 and png_file_buf[3] == 56:
                if gif_decode(&png_file_buf[0], cast[uint64](got)) == 0:
                    htmlimg_add(nm, nl, gif_width(), gif_height(), gif_rgba_ptr())
        idx = idx + 1


# Embedded demo image (the 48x32 checked-in sample PNG, 130 bytes as ASCII-hex)
# so the built-in demo page proves REAL PNG decode+blit on device with no file
# or network. Registered under "demo.png" (the demo's <img src>).
_DEMO_PNG_HEX: Array[261, uint8] = "89504e470d0a1a0a0000000d494844520000003000000020080600000054d4fb1c000000494944415478daedcf311100211004b09573f5d728410df25e045ec00333d7a5888064579d4ef58f561110101010101010101010780e7c739f4e49562b010101010101010101018157175b24dc177c32a80e0000000049454e44ae426082"


def _hexnib(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return cast[int32](c) - 48
    if c >= 97 and c <= 102:
        return cast[int32](c) - 97 + 10
    return 0


# Set to 1 once the embedded demo PNG decodes + registers (for the loud
# on-device asset diagnostic printed before the window rebinds stdout).
demo_img_decoded: int32 = 0


def _register_demo_image():
    # Decode the embedded hex -> png_file_buf, PNG-decode, register "demo.png".
    n: uint64 = 0
    while _DEMO_PNG_HEX[n * 2] != 0:
        hi: int32 = _hexnib(_DEMO_PNG_HEX[n * 2])
        lo: int32 = _hexnib(_DEMO_PNG_HEX[n * 2 + 1])
        png_file_buf[n] = cast[uint8](hi * 16 + lo)
        n = n + 1
    if png_decode(&png_file_buf[0], n) == 0:
        htmlimg_add(cast[Ptr[uint8]]("demo.png"), 8,
                    png_width(), png_height(), png_rgba_ptr())
        demo_img_decoded = 1


# Full re-layout after src_ptr/src_len point at new HTML: two engine passes
# around image decode (pass 1 records <img src>, decode fills htmlimg, pass 2
# sizes the boxes), then rasterise the pixel canvas + surface any JS output.
def _reload_layout():
    he_layout()
    _decode_images()
    he_layout()
    scroll_px = 0
    _render_doc()
    _surface_js()


render_tmp: Array[1024, uint8]
seg_hex: Array[8, uint8]
bg_hex: Array[8, uint8]


def _set_status(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 159:
        status_buf[i] = s[i]
        i = i + 1
    status_buf[i] = 0
    status_len = i


# Surface any JS run by the just-completed he_layout() in the status bar: the
# first console.log line (prefixed "JS: "), or a "JS error" note. Called after
# each he_layout() so a page's <script> output is visible on the native path.
# Pages without a <script> leave the fetch status untouched.
def _surface_js():
    if he_js_error() != 0:
        _set_status(cast[Ptr[uint8]]("JS error (see script)"))
        return
    n: uint64 = he_js_console_len()
    if n == 0:
        return
    cp: Ptr[uint8] = he_js_console_ptr()
    p: uint64 = 4
    status_buf[0] = 74                                # 'J'
    status_buf[1] = 83                                # 'S'
    status_buf[2] = 58                                # ':'
    status_buf[3] = 32                                # ' '
    i: uint64 = 0
    while i < n and cp[i] != 10 and p < 159:          # first console line only
        status_buf[p] = cp[i]
        p = p + 1
        i = i + 1
    status_buf[p] = 0
    status_len = p


# Tell the SCENE-FILE DE to composite our v2 backbuffer. The kernel scene
# compositor (which owns /dev/fb at runlevel 5) only z-blits windows whose
# SCENE is non-empty, and the only scene verb that carries pixels is
# `buffer <x> <y> <w> <h>` — it copies the window's kernel-side v2 backbuffer
# (populated by our 'B' blit) into the window's scene cache. So after each
# commit we write a one-line scene with that verb; without it a pure-v2 window
# is invisible under the scene compositor (hamUId's v2 path only serves its own
# overlay slots). Replaces the scene each frame (full-window present).
scene_line: Array[80, uint8]


def _present_buffer(wid: int32, w: int32, h: int32):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("buffer 0 0 ")
    a: uint64 = 0
    while pre[a] != 0:
        scene_line[p] = pre[a]
        p = p + 1
        a = a + 1
    p = p + _u64_to_dec(cast[uint64](w), &scene_line[p])
    scene_line[p] = 32
    p = p + 1
    p = p + _u64_to_dec(cast[uint64](h), &scene_line[p])
    scene_line[p] = 10
    p = p + 1
    scenep: Array[64, uint8]
    _winpath(&scenep[0], wid, cast[Ptr[uint8]]("/scene"))
    fd: int32 = sys_open_write(cast[Ptr[char]](&scenep[0]))
    if fd >= 0:
        sys_write(fd, &scene_line[0], p)
        sys_close(fd)
    # Poke `commit` on the window ctl: presents the scene (compositing our
    # backbuffer) AND resets the scene write cursor so the next frame is fresh.
    cp: Array[64, uint8]
    _winpath(&cp[0], wid, cast[Ptr[uint8]]("/ctl"))
    cfd: int32 = sys_open_write(cast[Ptr[char]](&cp[0]))
    if cfd >= 0:
        sys_write(cfd, cast[Ptr[uint8]]("commit\n"), 7)
        sys_close(cfd)


# Present one frame: paint the SHARED window compositor (lib/browserwin.ad —
# identical code to the host parity render) into our v2 backbuffer, blit it to
# the kernel backbuffer, then emit the `buffer` scene verb so the scene-file
# compositor puts our pixels on screen.
def emit(wid: int32):
    if hamui_v2_is_active() == 0:
        return
    bb: Ptr[uint8] = hamui_v2_bb_ptr()
    bbw: int32 = hamui_v2_bb_w()
    bbh: int32 = hamui_v2_bb_h()
    if cast[uint64](bb) == 0 or bbw <= 0 or bbh <= 0:
        return
    w: int32 = bw
    h: int32 = bh
    if w > bbw:
        w = bbw
    if h > bbh:
        h = bbh
    browserwin_paint(bb, bbw, bbh, w, h, scroll_px, doc_h_px,
                     &addr_buf[0], addr_len, addr_focus,
                     &status_buf[0], status_len)
    hamui_v2_commit_rect(0, 0, w, h)
    _present_buffer(wid, w, h)


# ====================================================================
# FETCH — HTTP via http9 (the wget/curl path) or a local file.
# ====================================================================
def _app(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and html_len < HTML_CAP - 1:
        html_buf[html_len] = s[i]
        html_len = html_len + 1
        i = i + 1


def _build_error(msg: Ptr[uint8], detail: Ptr[uint8]):
    # Compose a tiny HTML error page in html_buf and point src at it.
    html_len = 0
    _app(cast[Ptr[uint8]]("<h1>"))
    _app(msg)
    _app(cast[Ptr[uint8]]("</h1><p>"))
    _app(detail)
    _app(cast[Ptr[uint8]]("</p>"))
    src_ptr = &html_buf[0]
    src_len = html_len


def _starts(s: Ptr[uint8], pfx: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while pfx[i] != 0:
        if s[i] != pfx[i]:
            return 0
        i = i + 1
    return 1


# Copy cur_url into the (unfocused) address-bar buffer so the bar reflects
# wherever we actually navigated.
def _sync_addr_from_url():
    i: uint64 = 0
    while cur_url[i] != 0 and i < 1023:
        addr_buf[i] = cur_url[i]
        i = i + 1
    addr_buf[i] = 0
    addr_len = i


def _set_cur_url(u: Ptr[uint8]):
    i: uint64 = 0
    while u[i] != 0 and i < 1023:
        cur_url[i] = u[i]
        i = i + 1
    cur_url[i] = 0
    _sync_addr_from_url()


# Fetch `url` into src_ptr/src_len. Sets the status line. cur_url must be set.
def _fetch(url: Ptr[uint8]):
    if _starts(url, cast[Ptr[uint8]]("http://")) != 0 or \
       _starts(url, cast[Ptr[uint8]]("https://")) != 0:
        st: Array[1, int64]
        bo: Array[1, uint64]
        bl: Array[1, uint64]
        st[0] = 0
        bo[0] = 0
        bl[0] = 0
        rc: int64 = http_get(url, &resp_buf[0], RESP_CAP,
                             &st[0], &bo[0], &bl[0])
        if rc < 0:
            _build_error(cast[Ptr[uint8]]("Fetch failed"), url)
            _set_status(cast[Ptr[uint8]]("transport error (DNS/connect/TLS)"))
            # LOUD serial diagnostic (printed BEFORE newwindow rebinds stdout):
            # capture the exact transport failure so a network gate can see the
            # WALL (connect refused / chunked / cap) instead of a silent blank.
            fl: Array[96, uint8]
            fp: uint64 = _sapp(&fl[0], 0,
                cast[Ptr[uint8]]("[hambrowse] fetch FAILED rc=-"))
            fp = fp + _u64_to_dec(cast[uint64](0 - rc), &fl[fp])
            fl[fp] = 10
            fp = fp + 1
            sys_write(1, &fl[0], fp)
            return
        src_ptr = cast[Ptr[uint8]](cast[uint64](&resp_buf[0]) + bo[0])
        src_len = bl[0]
        # http_get may have followed 3xx redirects; adopt the FINAL URL so
        # relative links + the address bar resolve against where we landed.
        _set_cur_url(http_effective_url())
        sb: Array[64, uint8]
        sp: uint64 = 0
        pf: Ptr[uint8] = cast[Ptr[uint8]]("HTTP ")
        a: uint64 = 0
        while pf[a] != 0:
            sb[sp] = pf[a]
            sp = sp + 1
            a = a + 1
        sp = sp + _u64_to_dec(cast[uint64](st[0]), &sb[sp])
        pf2: Ptr[uint8] = cast[Ptr[uint8]]("  bytes ")
        a = 0
        while pf2[a] != 0:
            sb[sp] = pf2[a]
            sp = sp + 1
            a = a + 1
        sp = sp + _u64_to_dec(bl[0], &sb[sp])
        sb[sp] = 0
        _set_status(&sb[0])
        # LOUD serial diagnostic (printed BEFORE newwindow rebinds stdout off
        # serial): proves hambrowse completed a NETWORK fetch and how many body
        # bytes it will lay out. A network gate asserts on this byte count +
        # HTTP status to distinguish a genuine served-page render from the
        # built-in demo / a local file / an error page.
        dl: Array[96, uint8]
        dp: uint64 = _sapp(&dl[0], 0,
            cast[Ptr[uint8]]("[hambrowse] fetched http status="))
        dp = dp + _u64_to_dec(cast[uint64](st[0]), &dl[dp])
        dp = _sapp(&dl[0], dp, cast[Ptr[uint8]](" bytes="))
        dp = dp + _u64_to_dec(bl[0], &dl[dp])
        dl[dp] = 10
        dp = dp + 1
        sys_write(1, &dl[0], dp)
        return
    # Local file path (strip a file:// prefix if present).
    path: Ptr[uint8] = url
    if _starts(url, cast[Ptr[uint8]]("file://")) != 0:
        path = cast[Ptr[uint8]](cast[uint64](url) + 7)
    fd: int32 = sys_open(cast[Ptr[char]](path))
    if fd < 0:
        _build_error(cast[Ptr[uint8]]("Cannot open file"), url)
        _set_status(cast[Ptr[uint8]]("open failed"))
        return
    html_len = 0
    while html_len < HTML_CAP - 1:
        n: int64 = sys_read(fd, &html_buf[html_len], HTML_CAP - 1 - html_len)
        if n <= 0:
            break
        html_len = html_len + cast[uint64](n)
    sys_close(fd)
    src_ptr = &html_buf[0]
    src_len = html_len
    sb2: Array[48, uint8]
    sp2: uint64 = 0
    pf3: Ptr[uint8] = cast[Ptr[uint8]]("file  ")
    a2: uint64 = 0
    while pf3[a2] != 0:
        sb2[sp2] = pf3[a2]
        sp2 = sp2 + 1
        a2 = a2 + 1
    sp2 = sp2 + _u64_to_dec(html_len, &sb2[sp2])
    pf4: Ptr[uint8] = cast[Ptr[uint8]](" bytes")
    a2 = 0
    while pf4[a2] != 0:
        sb2[sp2] = pf4[a2]
        sp2 = sp2 + 1
        a2 = a2 + 1
    sb2[sp2] = 0
    _set_status(&sb2[0])


# Built-in demo page (no network) — exercises every supported feature.
def _load_demo():
    html_len = 0
    _app(cast[Ptr[uint8]]("<html><head><title>ignored</title>"))
    _app(cast[Ptr[uint8]]("<style>body{color:red}</style></head><body>"))
    _app(cast[Ptr[uint8]]("<h1>Hamnix Web</h1>"))
    _app(cast[Ptr[uint8]]("<p>Welcome to <b>hambrowse</b>, the native "))
    _app(cast[Ptr[uint8]]("<i>scene-DE</i> web browser. It fetches a page "))
    _app(cast[Ptr[uint8]]("over HTTP and renders a tolerant subset of HTML "))
    _app(cast[Ptr[uint8]]("&mdash; now with <span style=\"color:#c00000\">"))
    _app(cast[Ptr[uint8]]("basic CSS colour</span>.</p>"))
    _app(cast[Ptr[uint8]]("<p><img src=\"demo.png\" width=\"96\" height=\"64\"> "))
    _app(cast[Ptr[uint8]]("a real decoded PNG, blitted at 2x.</p>"))
    _app(cast[Ptr[uint8]]("<h2>Features</h2>"))
    _app(cast[Ptr[uint8]]("<ul>"))
    _app(cast[Ptr[uint8]]("<li>Headings h1&#45;h3, paragraphs and "))
    _app(cast[Ptr[uint8]]("line<br>breaks</li>"))
    _app(cast[Ptr[uint8]]("<li>Bold, lists, and <b>nested <i>inline</i> "))
    _app(cast[Ptr[uint8]]("markup</b></li>"))
    _app(cast[Ptr[uint8]]("<li><font color=\"green\">Coloured</font> text via "))
    _app(cast[Ptr[uint8]]("<font color=\"blue\">font</font> and "))
    _app(cast[Ptr[uint8]]("<span style=\"color:purple\">span</span></li>"))
    _app(cast[Ptr[uint8]]("<li>Hyperlinks that "))
    _app(cast[Ptr[uint8]]("<a href=\"http://example.com/\">navigate</a> "))
    _app(cast[Ptr[uint8]]("when clicked</li>"))
    _app(cast[Ptr[uint8]]("<li>Word wrapping to the window width</li>"))
    _app(cast[Ptr[uint8]]("</ul>"))
    _app(cast[Ptr[uint8]]("<h3>Preformatted</h3>"))
    _app(cast[Ptr[uint8]]("<pre>  fn main() {\n"))
    _app(cast[Ptr[uint8]]("      print(\"hello, hamnix\");\n  }</pre>"))
    _app(cast[Ptr[uint8]]("<p>Entities work too: 1 &lt; 2 &amp;&amp; 3 "))
    _app(cast[Ptr[uint8]]("&gt; 2, &quot;quoted&quot;, and &#72;&#105;.</p>"))
    _app(cast[Ptr[uint8]]("<p>Visit "))
    _app(cast[Ptr[uint8]]("<a href=\"http://127.0.0.1/index.html\">the "))
    _app(cast[Ptr[uint8]]("local server</a> or scroll for more. "))
    _app(cast[Ptr[uint8]]("This paragraph is intentionally long so that "))
    _app(cast[Ptr[uint8]]("the layout engine has to wrap it across several "))
    _app(cast[Ptr[uint8]]("lines inside the content area, demonstrating "))
    _app(cast[Ptr[uint8]]("the inline flow and right margin handling of "))
    _app(cast[Ptr[uint8]]("the renderer in a real window.</p>"))
    _app(cast[Ptr[uint8]]("</body></html>"))
    src_ptr = &html_buf[0]
    src_len = html_len
    sb: Array[40, uint8]
    sp: uint64 = 0
    df: Ptr[uint8] = cast[Ptr[uint8]]("demo page  ")
    a: uint64 = 0
    while df[a] != 0:
        sb[sp] = df[a]
        sp = sp + 1
        a = a + 1
    sp = sp + _u64_to_dec(html_len, &sb[sp])
    sb[sp] = 0
    _set_status(&sb[0])


# ====================================================================
# LINK NAVIGATION.
# ====================================================================
nav_buf: Array[1024, uint8]


def _href_starts(ho: uint64, hl: uint64, pfx: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while pfx[i] != 0:
        if i >= hl:
            return 0
        if link_href_buf[ho + i] != pfx[i]:
            return 0
        i = i + 1
    return 1


# Length of "scheme://authority" in cur_url (up to the first '/' after "://").
def _authority_len() -> uint64:
    n: uint64 = _slen(&cur_url[0])
    i: uint64 = 0
    while i + 2 < n:
        if cur_url[i] == 58 and cur_url[i + 1] == 47 and cur_url[i + 2] == 47:
            j: uint64 = i + 3
            while j < n and cur_url[j] != 47:
                j = j + 1
            return j
        i = i + 1
    return 0


# Length of cur_url up to and including the last '/' (the "directory").
def _dir_len() -> uint64:
    n: uint64 = _slen(&cur_url[0])
    last: int64 = -1
    al: uint64 = _authority_len()
    i: uint64 = al
    while i < n:
        if cur_url[i] == 47:
            last = cast[int64](i)
        i = i + 1
    if last < 0:
        return n                                      # no path slash: append
    return cast[uint64](last) + 1


# Resolve href (link id) against cur_url into nav_buf. Returns 1 if usable.
def _resolve(lid: int32) -> int32:
    if lid < 0 or cast[uint64](lid) >= n_links:
        return 0
    ho: uint64 = cast[uint64](link_off[lid])
    hl: uint64 = cast[uint64](link_len[lid])
    # in-page anchor: ignore
    if hl > 0 and link_href_buf[ho] == 35:           # '#'
        return 0
    # absolute URL
    if hl >= 7:
        if _href_starts(ho, hl, cast[Ptr[uint8]]("http://")) != 0 or \
           _href_starts(ho, hl, cast[Ptr[uint8]]("https://")) != 0:
            k: uint64 = 0
            while k < hl and k < 1023:
                nav_buf[k] = link_href_buf[ho + k]
                k = k + 1
            nav_buf[k] = 0
            return 1
    # root-relative ("/path"): scheme://authority + href
    if hl > 0 and link_href_buf[ho] == 47:
        alen: uint64 = _authority_len()
        if alen == 0:
            return 0
        p: uint64 = 0
        while p < alen and p < 1023:
            nav_buf[p] = cur_url[p]
            p = p + 1
        k2: uint64 = 0
        while k2 < hl and p < 1023:
            nav_buf[p] = link_href_buf[ho + k2]
            p = p + 1
            k2 = k2 + 1
        nav_buf[p] = 0
        return 1
    # document-relative: cur_url up to last '/' + href
    dlen: uint64 = _dir_len()
    p2: uint64 = 0
    while p2 < dlen and p2 < 1023:
        nav_buf[p2] = cur_url[p2]
        p2 = p2 + 1
    k3: uint64 = 0
    while k3 < hl and p2 < 1023:
        nav_buf[p2] = link_href_buf[ho + k3]
        p2 = p2 + 1
        k3 = k3 + 1
    nav_buf[p2] = 0
    return 1


def _navigate(lid: int32) -> int32:
    if _resolve(lid) == 0:
        return 0
    _set_cur_url(&nav_buf[0])
    _fetch(&nav_buf[0])
    _reload_layout()
    return 1


# Build the effective URL for a user-typed address into nav_buf, defaulting a
# scheme: http:// https:// file:// pass through; an absolute path ("/x") or an
# "about:" pseudo-URL passes through (handled by _fetch/demo); anything else is
# treated as a bare host and gets an "http://" prefix.
def _apply_scheme(url: Ptr[uint8]):
    passthru: int32 = 0
    if _starts(url, cast[Ptr[uint8]]("http://")) != 0 or \
       _starts(url, cast[Ptr[uint8]]("https://")) != 0 or \
       _starts(url, cast[Ptr[uint8]]("file://")) != 0 or \
       _starts(url, cast[Ptr[uint8]]("about:")) != 0:
        passthru = 1
    if url[0] == 47:                                 # '/' absolute local path
        passthru = 1
    p: uint64 = 0
    if passthru == 0:
        pre: Ptr[uint8] = cast[Ptr[uint8]]("http://")
        a: uint64 = 0
        while pre[a] != 0 and p < 1023:
            nav_buf[p] = pre[a]
            p = p + 1
            a = a + 1
    i: uint64 = 0
    while url[i] != 0 and p < 1023:
        nav_buf[p] = url[i]
        p = p + 1
        i = i + 1
    nav_buf[p] = 0


# Navigate to a user-typed URL string (address bar Enter / "Go" / --url arg).
def _navigate_url(url: Ptr[uint8]) -> int32:
    if url[0] == 0:
        return 0
    _apply_scheme(url)
    _set_cur_url(&nav_buf[0])
    _fetch(&nav_buf[0])
    _reload_layout()
    return 1


# Map a window-local click to a link id (or -1) in the PIXEL document via the
# proportional per-segment extents htmlpage recorded (window x maps directly to
# doc x; doc y adds the scroll offset).
def _hit_link(x: int32, y: int32) -> int32:
    if y < CONTENT_Y or y >= bh - STATUS_H:
        return -1
    doc_y: int32 = scroll_px + (y - CONTENT_Y)
    return htmlpage_hit_link(x, doc_y)


# ====================================================================
# WINDOW + EVENT plumbing.
# ====================================================================
def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        _writeall(1, cast[Ptr[uint8]]("[hambrowse] cannot open /dev/wsys/ctl for write (no window server in namespace, or permission denied)\n"))
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        _writeall(1, cast[Ptr[uint8]]("[hambrowse] cannot reopen /dev/wsys/ctl to read back wid\n"))
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        _writeall(1, cast[Ptr[uint8]]("[hambrowse] /dev/wsys/ctl returned no wid (newwindow rejected: table full?)\n"))
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


def _ctl_write(ctlp: Ptr[uint8], s: Ptr[uint8]):
    fd: int32 = sys_open_write(cast[Ptr[char]](ctlp))
    if fd >= 0:
        _writeall(fd, s)
        sys_close(fd)


# ---- /keys decode: arrows + scroll keys -----------------------------
kev_buf: Array[256, uint8]
kev_carry: uint64 = 0
esc_st: int32 = 0


# Address-bar key handling (active only while addr_focus != 0).
# Returns 1 = bar changed (redraw), 2 = navigation happened, 0 = nothing.
def _addr_key(code: int32) -> int32:
    if code == 27:                                   # ESC -> cancel edit
        addr_focus = 0
        _sync_addr_from_url()
        return 1
    if code == 13 or code == 10:                     # Enter -> navigate
        addr_buf[addr_len] = 0
        addr_focus = 0
        if _navigate_url(&addr_buf[0]) != 0:
            return 2
        _sync_addr_from_url()
        return 1
    if code == 8 or code == 127:                     # Backspace / DEL
        if addr_len > 0:
            addr_len = addr_len - 1
            addr_buf[addr_len] = 0
        return 1
    if code >= 32 and code < 127:                    # printable -> append
        if addr_len < 1023:
            addr_buf[addr_len] = cast[uint8](code)
            addr_len = addr_len + 1
            addr_buf[addr_len] = 0
        return 1
    return 0


# Returns 1 if the view changed, 2 if a navigation happened (full redraw).
def _handle_code(code: int32) -> int32:
    if addr_focus != 0:
        return _addr_key(code)
    if esc_st == 1:
        if code == 91:                              # '['
            esc_st = 2
            return 0
        esc_st = 0
    elif esc_st == 2:
        esc_st = 0
        if code == 65:                              # up
            scroll_px = scroll_px - SCROLL_LINE
            _clamp_scroll()
            return 1
        if code == 66:                              # down
            scroll_px = scroll_px + SCROLL_LINE
            _clamp_scroll()
            return 1
        return 0
    if code == 27:
        esc_st = 1
        return 0
    if code == 106:                                 # 'j'
        scroll_px = scroll_px + SCROLL_LINE
        _clamp_scroll()
        return 1
    if code == 107:                                 # 'k'
        scroll_px = scroll_px - SCROLL_LINE
        _clamp_scroll()
        return 1
    if code == 32 or code == 102:                   # space / 'f' page down
        scroll_px = scroll_px + _content_h() - SCROLL_LINE
        _clamp_scroll()
        return 1
    if code == 98:                                  # 'b' page up
        scroll_px = scroll_px - _content_h() + SCROLL_LINE
        _clamp_scroll()
        return 1
    if code == 103:                                 # 'g' top
        scroll_px = 0
        return 1
    if code == 71:                                  # 'G' bottom
        scroll_px = _max_scroll()
        return 1
    return 0


def _drain_keys(n: uint64, vp: Ptr[int32]) -> uint64:
    i: uint64 = 0
    consumed: uint64 = 0
    while i < n:
        t: uint8 = kev_buf[i]
        i = i + 1
        if i < n and kev_buf[i] == 32:
            i = i + 1
        code: int32 = 0
        have: int32 = 0
        neg: int32 = 0
        if i < n and kev_buf[i] == 45:
            neg = 1
            i = i + 1
        while i < n and kev_buf[i] >= 48 and kev_buf[i] <= 57:
            code = code * 10 + cast[int32](kev_buf[i]) - 48
            i = i + 1
            have = 1
        while i < n and kev_buf[i] != 10:
            i = i + 1
        if i >= n:
            return consumed
        i = i + 1
        consumed = i
        if neg != 0:
            code = 0 - code
        if t != 100 or have == 0:                    # only press ('d'=100)
            continue
        rc: int32 = _handle_code(code)
        if rc != 0 and vp[0] < rc:
            vp[0] = rc
    return consumed


# ---- /event poll: resize ('r w h'), wheel + click ('m x y btn dz') --
ev_buf: Array[256, uint8]
ev_carry: uint64 = 0


def _parse_ints(ls: uint64, le: uint64, out: Ptr[int64], maxf: int32) -> int32:
    # parse up to maxf signed ints from ev_buf[ls..le) skipping the leading
    # type token; returns count parsed.
    p: uint64 = ls
    # skip first token (type char) + spaces
    while p < le and ev_buf[p] != 32:
        p = p + 1
    cnt: int32 = 0
    while cnt < maxf:
        while p < le and ev_buf[p] == 32:
            p = p + 1
        if p >= le:
            break
        neg: int32 = 0
        if ev_buf[p] == 45:
            neg = 1
            p = p + 1
        v: int64 = 0
        d: int32 = 0
        while p < le and ev_buf[p] >= 48 and ev_buf[p] <= 57:
            v = v * 10 + cast[int64](ev_buf[p]) - 48
            p = p + 1
            d = 1
        if d == 0:
            break
        if neg != 0:
            v = 0 - v
        out[cnt] = v
        cnt = cnt + 1
    return cnt


def _poll_events(efd: int32, vp: Ptr[int32]) -> int32:
    if efd < 0:
        return 0
    changed: int32 = 0
    passes: int32 = 0
    while passes < 4:
        room: uint64 = 256 - ev_carry
        if room == 0:
            ev_carry = 0
            room = 256
        en: int64 = sys_read_nb(efd, &ev_buf[ev_carry], room)
        if en <= 0:
            break
        total: uint64 = ev_carry + cast[uint64](en)
        i: uint64 = 0
        ls: uint64 = 0
        while i < total:
            if ev_buf[i] == 10:
                if i > ls and ev_buf[ls] == 114:     # 'r' resize
                    f: Array[2, int64]
                    if _parse_ints(ls, i, &f[0], 2) == 2:
                        if f[0] > 80 and f[1] > 80:
                            if cast[int32](f[0]) != bw or cast[int32](f[1]) != bh:
                                bw = cast[int32](f[0])
                                bh = cast[int32](f[1])
                                # Grow the v2 backbuffer if the window enlarged.
                                hamui_set_protocol_v2_dims(bw, bh)
                                he_layout()
                                _render_doc()
                                if vp[0] < 1:
                                    vp[0] = 1
                                changed = 1
                elif i > ls and ev_buf[ls] == 109:   # 'm' pointer
                    f2: Array[4, int64]
                    nf: int32 = _parse_ints(ls, i, &f2[0], 4)
                    if nf >= 4 and f2[3] != 0:        # wheel dz
                        prev: int32 = scroll_px
                        scroll_px = scroll_px - cast[int32](f2[3]) * SCROLL_LINE
                        _clamp_scroll()
                        if scroll_px != prev:
                            if vp[0] < 1:
                                vp[0] = 1
                            changed = 1
                    elif nf >= 3 and (f2[2] & 1) != 0:   # button-1 click
                        cx: int32 = cast[int32](f2[0])
                        cy: int32 = cast[int32](f2[1])
                        if cy >= ADDR_Y and cy < ADDR_Y + ADDR_H:
                            # Click landed in the address bar.
                            if cx >= bw - GO_W:          # "Go" button
                                addr_buf[addr_len] = 0
                                if _navigate_url(&addr_buf[0]) != 0:
                                    if vp[0] < 2:
                                        vp[0] = 2
                                    changed = 1
                            else:                        # focus + edit
                                addr_focus = 1
                                if vp[0] < 1:
                                    vp[0] = 1
                                changed = 1
                        else:
                            if addr_focus != 0:
                                addr_focus = 0           # click away = defocus
                                if vp[0] < 1:
                                    vp[0] = 1
                                changed = 1
                            lid: int32 = _hit_link(cx, cy)
                            if lid >= 0:
                                # A click-handler element is wrapped by the engine
                                # in a synthetic "#__evt_N" link (he_set_click_links
                                # is enabled at startup). Route those to the JS
                                # handler via he_dom_click_index instead of
                                # navigating; real hrefs still navigate.
                                evi: int32 = he_link_evt_index(lid)
                                if evi >= 0:
                                    if he_dom_click_index(evi) != 0:
                                        _surface_js()
                                        _render_doc()
                                        if vp[0] < 2:
                                            vp[0] = 2
                                        changed = 1
                                elif _navigate(lid) != 0:
                                    if vp[0] < 2:
                                        vp[0] = 2
                                    changed = 1
                            # NOTE(js-click): the click->element hit test reuses the
                            # existing pointer link hit-test — the engine wraps
                            # handler elements in "#__evt_N" links, so a pointer
                            # click resolves to a DOM record and he_dom_click_index
                            # runs the stored handler in the live JS context, then
                            # re-lays-out. Caveat: this styles clickable elements
                            # like links (blue/underlined). Native JS itself is
                            # still gated by the float-div #DE (task #51), so a
                            # handler doing float division may #DE until that lands.
                ls = i + 1
            i = i + 1
        leftover: uint64 = total - ls
        m: uint64 = 0
        while m < leftover:
            ev_buf[m] = ev_buf[ls + m]
            m = m + 1
        ev_carry = leftover
        passes = passes + 1
    return changed


# ====================================================================
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)

    # Route pointer clicks on JS click-handler elements to their handlers: the
    # engine wraps such elements in synthetic "#__evt_N" links reusing the link
    # hit-test. (Host harness leaves this off so its render stays stable.)
    he_set_click_links(1)

    # Resolve the page to load.
    is_demo: int32 = 0
    target: Ptr[uint8] = cast[Ptr[uint8]](0)
    if argc >= 2 and argv != cast[Ptr[uint64]](0):
        a1: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        if _starts(a1, cast[Ptr[uint8]]("--demo")) != 0:
            is_demo = 1
        elif _starts(a1, cast[Ptr[uint8]]("--url")) != 0:
            # `hambrowse --url <URL>` — explicit address (bare host allowed).
            if argc >= 3:
                target = cast[Ptr[uint8]](argv[2])
            else:
                is_demo = 1
        else:
            target = a1
    else:
        is_demo = 1

    # FETCH + PARSE + LAYOUT first, while stdout is still the serial console
    # (a scene client's stdout is REBOUND away from serial by `newwindow`),
    # so the render summary below reaches a host harness watching the log.
    if is_demo != 0:
        _set_cur_url(cast[Ptr[uint8]]("about:demo"))
        _load_demo()
    else:
        _apply_scheme(target)                 # scheme-default a bare host
        _set_cur_url(&nav_buf[0])
        _fetch(&nav_buf[0])
    # Load the embedded TrueType faces, then lay out + rasterise the pixel page.
    browserfonts_load()
    # TRUE reflow: wrap prose to the window in real TrueType advances (not the
    # 8px char grid). Installed after the faces load, before the first layout;
    # every later resize re-lays-out through the same hook.
    htmlpage_install_reflow()
    _reload_layout()

    # Compose each diagnostic line into ONE buffer + a SINGLE write so it stays
    # atomic on the shared serial console (see _sapp).
    line: Array[192, uint8]
    lp: uint64 = _sapp(&line[0], 0, cast[Ptr[uint8]]("[hambrowse] rendered segs="))
    lp = lp + _u64_to_dec(n_segs, &line[lp])
    lp = _sapp(&line[0], lp, cast[Ptr[uint8]](" rows="))
    lp = lp + _u64_to_dec(total_rows, &line[lp])
    lp = _sapp(&line[0], lp, cast[Ptr[uint8]](" links="))
    lp = lp + _u64_to_dec(n_links, &line[lp])
    line[lp] = 10
    lp = lp + 1
    sys_write(1, &line[0], lp)

    # LOUD asset-load diagnostics (printed BEFORE newwindow rebinds stdout off
    # the serial console). If the embedded TTF faces or the demo PNG fail to
    # decode, this line makes it VISIBLE in the boot log instead of silently
    # degrading to blank/blocky text + an empty image box (see #79).
    nfaces: int32 = font_ttf_loaded(FACE_TT_SANS) + \
                    font_ttf_loaded(FACE_TT_SANS_BOLD) + \
                    font_ttf_loaded(FACE_TT_SERIF) + \
                    font_ttf_loaded(FACE_TT_MONO)
    lp = _sapp(&line[0], 0, cast[Ptr[uint8]]("[hambrowse] assets: ttf_faces="))
    lp = lp + _u64_to_dec(cast[uint64](nfaces), &line[lp])
    lp = _sapp(&line[0], lp, cast[Ptr[uint8]]("/4 demo_img="))
    lp = lp + _u64_to_dec(cast[uint64](demo_img_decoded), &line[lp])
    lp = _sapp(&line[0], lp, cast[Ptr[uint8]](" images="))
    lp = lp + _u64_to_dec(htmlimg_count(), &line[lp])
    if nfaces < 4 or demo_img_decoded == 0:
        lp = _sapp(&line[0], lp, cast[Ptr[uint8]](" DEGRADED"))
    line[lp] = 10
    lp = lp + 1
    sys_write(1, &line[0], lp)
    _writeall(1, cast[Ptr[uint8]]("[hambrowse] opening scene window\n"))

    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hambrowse] FAIL newwindow\n"))
        return 1

    # Publish wid for scripted key/pointer injection.
    widf: int32 = sys_open_write(cast[Ptr[char]]("/tmp/.hambrowse_wid"))
    if widf >= 0:
        wt: Array[24, uint8]
        wl: uint64 = _u64_to_dec(cast[uint64](wid), &wt[0])
        wt[wl] = 10
        sys_write(widf, &wt[0], wl + 1)
        sys_close(widf)

    ctlp: Array[64, uint8]
    keysp: Array[64, uint8]
    evtp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))
    _winpath(&evtp[0], wid, cast[Ptr[uint8]]("/event"))

    # A wider default window lets the engine's readable-measure default centre
    # the text column (see MEASURE_MAX in lib/htmlengine.ad) instead of stretching
    # body text edge-to-edge — the page reads as a document, not a terminal dump.
    _ctl_write(&ctlp[0], cast[Ptr[uint8]]("geometry 50 40 880 600\n"))
    _ctl_write(&ctlp[0], cast[Ptr[uint8]]("decorate 1\n"))
    _ctl_write(&ctlp[0], cast[Ptr[uint8]]("z 12\n"))
    _ctl_write(&ctlp[0], cast[Ptr[uint8]]("title Browser\n"))

    # Bind the hamui toolkit to our window and negotiate the v2 blit protocol
    # so a kernel-side RGBA backbuffer exists; emit() then blits the pixel page
    # into it and publishes it through the scene-file `buffer` verb (see emit).
    hamui_window_on(0, wid)
    hamui_set_protocol_v2_dims(bw, bh)

    emit(wid)

    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))
    efd: int32 = sys_open(cast[Ptr[char]](&evtp[0]))
    if kfd < 0:
        while True:
            sys_yield()
        return 1

    IDLE_MS: int64 = 12
    while True:
        room: uint64 = 256 - kev_carry
        if room == 0:
            kev_carry = 0
            room = 256
        kn: int64 = sys_read_nb(kfd, &kev_buf[kev_carry], room)
        vchg: Array[1, int32]
        vchg[0] = 0
        _poll_events(efd, &vchg[0])
        if kn > 0:
            total: uint64 = kev_carry + cast[uint64](kn)
            done: uint64 = _drain_keys(total, &vchg[0])
            leftover: uint64 = total - done
            m: uint64 = 0
            while m < leftover:
                kev_buf[m] = kev_buf[done + m]
                m = m + 1
            kev_carry = leftover
        if vchg[0] != 0:
            emit(wid)
        else:
            wfds: Array[1, int32]
            wfds[0] = kfd
            sys_waitfds(&wfds[0], 1, IDLE_MS)
    return 0

# user/hamclock_host.ad — HOST driver + render harness for HamClock, the
# clock / calendar / timer utility (built for x86_64-linux; runs on the dev
# host, no QEMU).
#
# Drives the SAME core the native app ships (lib/hamclockcore.ad) with a KNOWN,
# INJECTED wall-clock time (a fixed unix epoch) so the gate is deterministic. It
# asserts: the digital HH:MM:SS string, the broken-down Y/M/D + weekday decoded
# from the epoch, the analog hand angles for two known times, the calendar
# first-of-month weekday + days-in-month (leap AND non-leap February, plus the
# 400/100-year century rules), and the stopwatch start/elapsed/stop/reset
# transitions off an injected MONOTONIC counter. It renders the CLOCK, CALENDAR
# and TIMER views to three PPMs for a human/agent to LOOK at.
#
# USAGE (built to build/host/hamclock_host):
#   hamclock_host CLOCK.ppm CALENDAR.ppm TIMER.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamclockcore import hamclock_init, hamclock_build_scene, \
    hamclock_set_time, hamclock_key_line, hamclock_view, hamclock_set_view, \
    hamclock_digital, hamclock_year, hamclock_month, hamclock_day, \
    hamclock_weekday, hamclock_hand_angle, hamclock_days_in_month, \
    hamclock_first_weekday, hamclock_timer_elapsed, hamclock_timer_running


obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hamclock_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


# Feed one keypress via the "d <code>" wire line.
kl: Array[16, uint8]


def _press(code: int32):
    kl[0] = 100                                        # 'd'
    kl[1] = 32
    p: uint64 = 2
    if code >= 100:
        kl[p] = cast[uint8](code / 100) + 48
        p = p + 1
    if code >= 10:
        kl[p] = cast[uint8]((code / 10) % 10) + 48
        p = p + 1
    kl[p] = cast[uint8](code % 10) + 48
    p = p + 1
    hamclock_key_line(&kl[0], p)


dbuf: Array[12, uint8]


def _dump_digital(tag: Ptr[uint8]):
    _o_str(tag)
    _o_ch(32)
    hamclock_digital(&dbuf[0])
    i: uint64 = 0
    while dbuf[i] != 0:
        _o_ch(dbuf[i])
        i = i + 1
    _o_ch(10)


def _kv(tag: Ptr[uint8], v: int64):
    _o_str(tag)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        _o_str(cast[Ptr[uint8]](
            "usage: hamclock_host CLOCK.ppm CALENDAR.ppm TIMER.ppm\n"))
        _o_flush()
        return 2

    W: int32 = 420
    H: int32 = 470
    hamclock_init()

    # ---- (1) inject a KNOWN wall clock: 2026-03-14 03:00:00 UTC (Saturday)
    # epoch 1773457200. 03:00:00 -> hour hand at 90 deg, minute+second at 0.
    hamclock_set_time(1773457200, 5000, 1)
    _dump_digital(cast[Ptr[uint8]]("DIGITAL"))          # 03:00:00
    _kv(cast[Ptr[uint8]]("YEAR"), cast[int64](hamclock_year()))    # 2026
    _kv(cast[Ptr[uint8]]("MONTH"), cast[int64](hamclock_month()))  # 3
    _kv(cast[Ptr[uint8]]("DAY"), cast[int64](hamclock_day()))      # 14
    _kv(cast[Ptr[uint8]]("WDAY"), cast[int64](hamclock_weekday())) # 6 = Sat
    _kv(cast[Ptr[uint8]]("HOUR_ANGLE"), cast[int64](hamclock_hand_angle(0)))  # 90
    _kv(cast[Ptr[uint8]]("MIN_ANGLE"), cast[int64](hamclock_hand_angle(1)))   # 0
    _kv(cast[Ptr[uint8]]("SEC_ANGLE"), cast[int64](hamclock_hand_angle(2)))   # 0

    # ---- (2) calendar correctness: days-in-month + first weekday ----------
    _kv(cast[Ptr[uint8]]("DIM_2024_02"),
        cast[int64](hamclock_days_in_month(2024, 2)))  # 29 leap
    _kv(cast[Ptr[uint8]]("DIM_2023_02"),
        cast[int64](hamclock_days_in_month(2023, 2)))  # 28
    _kv(cast[Ptr[uint8]]("DIM_2025_02"),
        cast[int64](hamclock_days_in_month(2025, 2)))  # 28
    _kv(cast[Ptr[uint8]]("DIM_2000_02"),
        cast[int64](hamclock_days_in_month(2000, 2)))  # 29 (÷400)
    _kv(cast[Ptr[uint8]]("DIM_2100_02"),
        cast[int64](hamclock_days_in_month(2100, 2)))  # 28 (÷100 not ÷400)
    _kv(cast[Ptr[uint8]]("DIM_2026_03"),
        cast[int64](hamclock_days_in_month(2026, 3)))  # 31
    _kv(cast[Ptr[uint8]]("FW_2026_03"),
        cast[int64](hamclock_first_weekday(2026, 3)))  # 0 = Sun
    _kv(cast[Ptr[uint8]]("FW_2024_02"),
        cast[int64](hamclock_first_weekday(2024, 2)))  # 4 = Thu
    _o_flush()

    # ---- (3) render the CLOCK view ----------------------------------------
    hamclock_set_view(0)
    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))
    _kv(cast[Ptr[uint8]]("CLOCK_PRIMS"), cast[int64](prims))
    _kv(cast[Ptr[uint8]]("CLOCK_VIEW"), cast[int64](hamclock_view()))       # 0
    _kv(cast[Ptr[uint8]]("PIX_TITLEBAR"), cast[int64](hamui_host_pixel(4, 4)))
    _o_flush()

    # ---- (4) render the CALENDAR view (March 2026, today=14 highlighted) --
    _press(50)                                          # '2' -> calendar
    _kv(cast[Ptr[uint8]]("CAL_VIEW"), cast[int64](hamclock_view()))         # 1
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    # dump the scene so the gate can prove the today cell fill lands on the
    # correct weekday column (March 1 2026 is Sunday -> the 14th is row1,col6).
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()

    # ---- (5) second known time for hand angles: 2026-07-19 06:15:30 -------
    # hour hand 6*30 + 15/2 = 187, minute 90, second 180.
    hamclock_set_time(1784441730, 5000, 1)
    _dump_digital(cast[Ptr[uint8]]("DIGITAL2"))         # 06:15:30
    _kv(cast[Ptr[uint8]]("HOUR_ANGLE2"), cast[int64](hamclock_hand_angle(0)))  # 187
    _kv(cast[Ptr[uint8]]("MIN_ANGLE2"), cast[int64](hamclock_hand_angle(1)))   # 90
    _kv(cast[Ptr[uint8]]("SEC_ANGLE2"), cast[int64](hamclock_hand_angle(2)))   # 180
    _o_flush()

    # ---- (6) STOPWATCH: start / elapse / stop / reset ---------------------
    _press(51)                                          # '3' -> timer view
    _kv(cast[Ptr[uint8]]("TIMER_VIEW"), cast[int64](hamclock_view()))      # 2
    hamclock_set_time(1784441730, 1000, 1)              # mono baseline
    _kv(cast[Ptr[uint8]]("T_RUN0"), cast[int64](hamclock_timer_running()))  # 0
    _kv(cast[Ptr[uint8]]("T_EL0"), cast[int64](hamclock_timer_elapsed()))   # 0
    _press(32)                                          # Space -> start
    _kv(cast[Ptr[uint8]]("T_RUN1"), cast[int64](hamclock_timer_running()))  # 1
    hamclock_set_time(1784441730, 1075, 1)              # +75 s monotonic
    _kv(cast[Ptr[uint8]]("T_EL75"), cast[int64](hamclock_timer_elapsed()))  # 75
    _render(W, H)                                       # render RUNNING 01:15
    _write_ppm(cast[Ptr[char]](argv[3]))
    _press(32)                                          # Space -> stop
    _kv(cast[Ptr[uint8]]("T_RUN2"), cast[int64](hamclock_timer_running()))  # 0
    hamclock_set_time(1784441730, 2000, 1)              # time passes, stopped
    _kv(cast[Ptr[uint8]]("T_EL_HOLD"), cast[int64](hamclock_timer_elapsed())) # 75
    _press(114)                                         # 'r' -> reset
    _kv(cast[Ptr[uint8]]("T_EL_RST"), cast[int64](hamclock_timer_elapsed())) # 0
    _kv(cast[Ptr[uint8]]("T_RUN3"), cast[int64](hamclock_timer_running()))   # 0
    _o_flush()
    return 0

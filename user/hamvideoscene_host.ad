# user/hamvideoscene_host.ad — HOST driver + render harness for the hamvideo
# player scene app (built for the x86_64-linux Adder target; runs on the dev
# host, NO QEMU).
#
# It drives the SAME code the native player ships:
#   * lib/mjpegdemux.ad DEMUXES a real .hmjv Motion-JPEG file passed on argv,
#     and lib/jpeg.ad DECODES every frame — the harness reads the file, walks
#     the frame index, decodes each baseline JPEG to RGBA, and DUMPS a per-frame
#     checksum + a non-blank verdict. scripts/test_hamvideo_host.sh checks the
#     frame count + geometry against a Python reference over the SAME file and
#     asserts EVERY frame decoded non-blank — a deterministic correctness signal
#     for the whole video decode path, no display hardware needed.
#   * lib/hamvideocore.ad LAYS OUT + BUILDS the player scene (referencing the
#     decoded frame as the named "frame" image, registered into the host
#     compositor twin), which is RASTERIZED by lib/hamui_host.ad into a PPM a
#     human/agent can LOOK at (before = frame 0 paused, after = a mid-clip frame
#     playing). Scripted pointer/keyboard input is driven through the pure input
#     handlers and the resulting command queue is asserted.
#
# USAGE (built to build/host/hamvideo_host):
#   hamvideo_host FILE.hmjv BEFORE.ppm AFTER.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel, hamui_host_register_image
from lib.mjpegdemux import mjv_parse, mjv_ok, mjv_width, mjv_height, mjv_fps, \
    mjv_frame_count, mjv_frame_ptr, mjv_frame_len
from lib.jpeg import jpeg_decode, jpeg_width, jpeg_height, jpeg_rgba_ptr
from lib.hamvideocore import hamvideo_init, hamvideo_set_name, \
    hamvideo_set_meta, hamvideo_set_frame, hamvideo_set_playing, \
    hamvideo_build_scene, hamvideo_layout, hamvideo_press_at, \
    hamvideo_key_line, hamvideo_take_command, hamvideo_seek_frame, \
    HAMVIDEO_CMD_PLAYPAUSE, HAMVIDEO_CMD_STOP, HAMVIDEO_CMD_SEEK

WIN_W: int32 = 288
WIN_H: int32 = 360

FILE_CAP: uint64 = 262144
filebuf: Array[262144, uint8]
filelen: uint64 = 0

# ---- stdout helpers ------------------------------------------------------
obuf: Array[1024, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 1023:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- file slurp ----------------------------------------------------------
def _slurp(path: Ptr[char]) -> int64:
    fd: int32 = sys_open(path, 0, 0)                    # O_RDONLY
    if fd < 0:
        return -1
    total: int64 = 0
    while cast[uint64](total) < FILE_CAP:
        r: int64 = sys_read(fd, &filebuf[total],
                            FILE_CAP - cast[uint64](total))
        if r <= 0:
            sys_close(fd)
            return total
        total = total + r
    sys_close(fd)
    return total


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


# Decode frame `idx` into lib/jpeg's RGBA store. Returns 1 on success.
def _decode_frame(idx: int32) -> int32:
    p: Ptr[uint8] = mjv_frame_ptr(idx)
    ln: uint64 = mjv_frame_len(idx)
    rc: int32 = jpeg_decode(p, ln)
    if rc < 0:
        return 0
    return 1


# Additive checksum over the decoded RGBA + a non-blank verdict (max-min of the
# red channel > 0 means the frame carries real, varied content, not one colour).
def _frame_stats(idx: int32) -> int32:
    if _decode_frame(idx) == 0:
        _o_str(cast[Ptr[uint8]]("FRAME "))
        _o_dec(cast[int64](idx))
        _o_str(cast[Ptr[uint8]](" DECODE_FAIL\n"))
        return 0
    w: int32 = jpeg_width()
    h: int32 = jpeg_height()
    rgba: Ptr[uint8] = jpeg_rgba_ptr()
    npx: uint64 = cast[uint64](w) * cast[uint64](h)
    csum: uint64 = 0
    rmin: int32 = 255
    rmax: int32 = 0
    i: uint64 = 0
    while i < npx:
        rr: int32 = cast[int32](rgba[i * 4])
        gg: int32 = cast[int32](rgba[i * 4 + 1])
        bb: int32 = cast[int32](rgba[i * 4 + 2])
        csum = (csum + cast[uint64](rr) + cast[uint64](gg)
                + cast[uint64](bb)) & 4294967295
        if rr < rmin:
            rmin = rr
        if rr > rmax:
            rmax = rr
        i = i + 1
    nonblank: int32 = 0
    if rmax > rmin:
        nonblank = 1
    _o_str(cast[Ptr[uint8]]("FRAME "))
    _o_dec(cast[int64](idx))
    _o_str(cast[Ptr[uint8]](" crc "))
    _o_dec(cast[int64](cast[int64](csum)))
    _o_str(cast[Ptr[uint8]](" nonblank "))
    _o_dec(cast[int64](nonblank))
    _o_ch(10)
    return nonblank


def _render(idx: int32, playing: int32, path: Ptr[char]):
    _decode_frame(idx)
    hamui_host_register_image(cast[Ptr[uint8]]("frame"), jpeg_width(),
                              jpeg_height(), jpeg_rgba_ptr())
    hamvideo_set_frame(idx)
    hamvideo_set_playing(playing)
    hamvideo_build_scene()
    hamui_host_begin(WIN_W, WIN_H)
    hamui_host_rasterize()
    _write_ppm(path)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        _o_str(cast[Ptr[uint8]]("usage: hamvideo_host FILE.hmjv BEFORE.ppm AFTER.ppm\n"))
        _o_flush()
        return 2

    n: int64 = _slurp(cast[Ptr[char]](argv[1]))
    if n <= 0:
        _o_str(cast[Ptr[uint8]]("FAIL slurp\n"))
        _o_flush()
        return 3

    if mjv_parse(&filebuf[0], cast[uint64](n)) == 0:
        _o_str(cast[Ptr[uint8]]("FAIL demux\n"))
        _o_flush()
        return 4

    _o_str(cast[Ptr[uint8]]("DEMUX_OK 1\n"))
    _o_str(cast[Ptr[uint8]]("WIDTH "))
    _o_dec(cast[int64](mjv_width()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("HEIGHT "))
    _o_dec(cast[int64](mjv_height()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("FPS "))
    _o_dec(cast[int64](mjv_fps()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("NFRAMES "))
    _o_dec(cast[int64](mjv_frame_count()))
    _o_ch(10)

    hamvideo_init()
    hamvideo_set_name(cast[Ptr[uint8]]("test.hmjv"))
    hamvideo_set_meta(mjv_width(), mjv_height(), mjv_fps(), mjv_frame_count())

    # Decode + stat EVERY frame — the decoder correctness proof.
    nf: int32 = mjv_frame_count()
    nonblank_total: int32 = 0
    i: int32 = 0
    while i < nf:
        nonblank_total = nonblank_total + _frame_stats(i)
        _o_flush()                       # keep the 1 KiB obuf from overflowing
        i = i + 1
    _o_str(cast[Ptr[uint8]]("NONBLANK_TOTAL "))
    _o_dec(cast[int64](nonblank_total))
    _o_ch(10)

    # --- INPUT command queue (pure handlers) ------------------------------
    # Space toggles play/pause.
    hamvideo_key_line(cast[Ptr[uint8]]("d 32"), 4)
    _o_str(cast[Ptr[uint8]]("CMD_SPACE "))
    _o_dec(cast[int64](hamvideo_take_command()))
    _o_ch(10)
    # A click on the centre of the scrub bar enqueues a SEEK to ~mid frame.
    # With 256x192 meta the bar sits at y=254 (vid_y 36 + vid_h 204 + 14),
    # spanning x[16 .. 272]; centre x = WIN_W/2 lands mid-bar.
    hamvideo_press_at(cast[int64](WIN_W / 2), cast[int64](260))
    _o_str(cast[Ptr[uint8]]("CMD_SEEK "))
    _o_dec(cast[int64](hamvideo_take_command()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SEEK_FRAME "))
    _o_dec(cast[int64](hamvideo_seek_frame()))
    _o_ch(10)

    # --- RENDER before (frame 0, paused) + after (mid frame, playing) -----
    mid: int32 = nf / 2
    _render(0, 0, cast[Ptr[char]](argv[2]))
    _render(mid, 1, cast[Ptr[char]](argv[3]))

    # Echo the AFTER display list so the gate can assert the `image "frame"`
    # verb + the transport chrome are present.
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())

    # Sample framebuffer pixels from the AFTER (mid-frame, playing) render:
    # a spread inside the video rect (8,36)-(8+272,36+204) proves real decoded
    # frame pixels reached the compositor, not a black letterbox.
    _o_ch(10)
    vy: int32 = 0
    while vy < 5:
        vx: int32 = 0
        while vx < 5:
            sx: int32 = 24 + vx * 56
            sy: int32 = 52 + vy * 38
            _o_str(cast[Ptr[uint8]]("VIDPIX "))
            _o_dec(cast[int64](sx))
            _o_ch(32)
            _o_dec(cast[int64](sy))
            _o_ch(32)
            _o_dec(cast[int64](cast[int64](hamui_host_pixel(sx, sy))))
            _o_ch(10)
            vx = vx + 1
        vy = vy + 1
    _o_str(cast[Ptr[uint8]]("OK\n"))
    _o_flush()
    return 0

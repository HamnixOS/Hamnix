# user/hamaudioscene.ad — NATIVE driver for the hamaudio player scene app.
#
# The player's UI STATE, LAYOUT, scene DISPLAY-LIST builder and pure input
# handlers live in lib/hamaudiocore.ad (extern-free, dual-target) so they can
# ALSO be rendered on the dev host (user/hamaudioscene_host.ad +
# scripts/test_hamaudio_host.sh). The .wav CONTAINER parse lives in the equally
# pure lib/wavdecode.ad. This file keeps ONLY the Hamnix-only side:
#   * open a wsys window, read its /keys + /event, commit the scene;
#   * READ the .wav file into memory and decode its header (lib/wavdecode);
#   * STREAM the decoded PCM to the native HDA sink — set rate/channels/format
#     by echoing verbs to /dev/audioctl, stage the sample bytes to /dev/audio,
#     and `start` — the SAME Plan-9 file path aplay/playtone use (no ioctls,
#     no sockets, just file writes). Playback position is tracked against the
#     100 Hz jiffies clock; the level meter reads the PCM around the cursor.
#
# USAGE:  hamaudioscene [file.wav|file.mp3 ...]  (defaults to the shipped
#         "Hamnix Music Demo" at /usr/share/music/hamnix-music-demo.mp3, with
#         the other preloaded clips seeded as extra playlist rows). Every argv
#         entry becomes a playlist track. A ".mp3" path is decoded to PCM by
#         lib/mp3decode (MPEG-1 Layer III) and streamed through the same sink.
#         The player is a VLC-style transport: playlist with Prev/Next, a seek
#         bar, Play/Pause/Stop, a volume slider, and Repeat/Shuffle toggles.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

from lib.hamsceneloop import hamscene_park, HAMSCENE_IDLE_MS
from lib.hamui import hamscene_commit
from lib.wavdecode import wavdecode_parse, wavdecode_ok, wavdecode_rate, \
    wavdecode_channels, wavdecode_bits, wavdecode_data_off, wavdecode_data_len, \
    wavdecode_frame_bytes, wavdecode_duration_ms, wavdecode_peak
from lib.mp3decode import mp3decode_parse, mp3decode_ok, mp3decode_rate, \
    mp3decode_channels, mp3decode_data_len, mp3decode_duration_ms, \
    mp3decode_pcm_ptr, mp3decode_peak
from lib.hamaudiocore import hamaudio_init, hamaudio_set_name, \
    hamaudio_set_format, hamaudio_set_duration_ms, hamaudio_set_position_ms, \
    hamaudio_set_level, hamaudio_set_playing, hamaudio_is_playing, \
    hamaudio_duration_ms, hamaudio_take_command, hamaudio_seek_ms, \
    hamaudio_key_line, hamaudio_press_at, hamaudio_release, \
    hamaudio_handle_pointer_line, \
    hamaudio_build_scene, hamaudio_layout, \
    hamaudio_playlist_clear, hamaudio_playlist_add, hamaudio_track_count, \
    hamaudio_set_selected_track, hamaudio_select_index, hamaudio_selected_track, \
    hamaudio_volume, hamaudio_repeat, hamaudio_shuffle, \
    HAMAUDIO_CMD_PLAYPAUSE, HAMAUDIO_CMD_STOP, HAMAUDIO_CMD_SEEK, \
    HAMAUDIO_CMD_SELECT, HAMAUDIO_CMD_PREV, HAMAUDIO_CMD_NEXT, \
    HAMAUDIO_CMD_VOLUME

# The whole file, read into memory (bounded). 320 KiB covers the shipped
# fixture (~105 KiB) with headroom; the HDA DMA buffer caps a single stage at
# 256 KiB, so anything past that is truncated for v1 (see the MP3/streaming
# follow-up in docs/audio_media_track.md).
FILE_CAP: uint64 = 327680
au_filebuf: Array[327680, uint8]
au_filelen: uint64 = 0

HDA_CAP: uint64 = 262144                    # HDA stream DMA buffer capacity

# Playback timing anchors (jiffies clock, HZ=100 => 10 ms/tick).
play_start_j: uint64 = 0
play_base_ms: uint64 = 0

ctlfd_g: int32 = -1

# 0 = WAV (raw PCM streamed straight from au_filebuf), 1 = MP3 (PCM decoded by
# lib/mp3decode into its own buffer). The source-accessor helpers below hide the
# difference so the transport/streaming code is format-agnostic.
src_is_mp3: int32 = 0

# ---- playlist: file paths of every track passed on argv (default = 1) -----
# The core (lib/hamaudiocore) holds the DISPLAY names + active row; the driver
# keeps the real paths and does the load on a SELECT command.
track_paths: Array[8, uint64]
ntrack: int32 = 0


# ---- format-agnostic PCM source accessors --------------------------------
def _src_base() -> Ptr[uint8]:
    if src_is_mp3 != 0:
        return mp3decode_pcm_ptr()
    return &au_filebuf[0]


def _src_off() -> uint64:
    if src_is_mp3 != 0:
        return 0
    return wavdecode_data_off()


def _src_len() -> uint64:
    if src_is_mp3 != 0:
        return mp3decode_data_len()
    return wavdecode_data_len()


def _src_rate() -> uint32:
    if src_is_mp3 != 0:
        return mp3decode_rate()
    return wavdecode_rate()


def _src_channels() -> uint32:
    if src_is_mp3 != 0:
        return mp3decode_channels()
    return wavdecode_channels()


def _src_bits() -> uint32:
    if src_is_mp3 != 0:
        return 16
    return wavdecode_bits()


def _src_frame_bytes() -> uint64:
    return cast[uint64](_src_channels()) * (cast[uint64](_src_bits()) / 8)


def _src_duration_ms() -> uint64:
    if src_is_mp3 != 0:
        return mp3decode_duration_ms()
    return wavdecode_duration_ms()


# Peak |sample| over PCM data span [dataoff, dataoff+n) (offsets are relative to
# the START of the PCM payload, not the file).
def _src_peak(dataoff: uint64, n: uint64) -> uint32:
    if src_is_mp3 != 0:
        return mp3decode_peak(dataoff, n)
    return wavdecode_peak(&au_filebuf[0], wavdecode_data_off() + dataoff, n)


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(value: uint64, out: Ptr[uint8]) -> uint64:
    if value == 0:
        out[0] = 48
        out[1] = 0
        return 1
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    out[written] = 0
    return written


# ---- wsys window transport (mirrors user/hamcalcscene.ad) ----------------
def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


def emit_scene(wid: int32):
    hamaudio_build_scene()
    hamscene_commit(wid)


# ---- HDA control -----------------------------------------------------
def _ctl_verb(verb: Ptr[uint8], value: uint64):
    if ctlfd_g < 0:
        return
    line: Array[48, uint8]
    p: uint64 = 0
    j: uint64 = 0
    while verb[j] != 0:
        line[p] = verb[j]
        p = p + 1
        j = j + 1
    line[p] = 32
    p = p + 1
    p = p + _u64_to_dec(value, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(ctlfd_g, &line[0], p)


def _ctl_word(s: Ptr[uint8]):
    if ctlfd_g >= 0:
        _writeall(ctlfd_g, s)


# Stage PCM from `from_byte` (a byte offset into the PCM payload) into the
# HDA DMA buffer starting at buffer offset 0, then START DMA. Returns the
# byte where staging stopped. Reopens /dev/audio so the file offset is 0.
def _stage_and_start(from_byte: uint64):
    data_len: uint64 = _src_len()
    if from_byte >= data_len:
        return
    # Reset any previously-staged PCM.
    _ctl_word(cast[Ptr[uint8]]("reset\n"))
    audfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/audio"))
    if audfd < 0:
        return
    span: uint64 = data_len - from_byte
    if span > HDA_CAP:
        span = HDA_CAP
    # Frame-align the span so DMA gets whole sample-frames.
    fb: uint64 = _src_frame_bytes()
    if fb > 0:
        span = (span / fb) * fb
    base: uint64 = cast[uint64](_src_base()) + _src_off() + from_byte
    written: uint64 = 0
    while written < span:
        chunk: uint64 = span - written
        if chunk > 4096:
            chunk = 4096
        sys_write(audfd, cast[Ptr[uint8]](base + written), chunk)
        written = written + chunk
    sys_close(audfd)
    _ctl_word(cast[Ptr[uint8]]("start\n"))


# Peak-level sample of the PCM window around the current byte cursor, fed to
# the level meter. Reads straight from the in-memory file buffer.
def _level_at(cur_byte: uint64) -> uint32:
    data_len: uint64 = _src_len()
    if cur_byte >= data_len:
        return 0
    win: uint64 = 2048
    if cur_byte + win > data_len:
        win = data_len - cur_byte
    return _src_peak(cur_byte, win)


def _ms_to_bytes(ms: uint64) -> uint64:
    # bytes = ms/1000 * rate * frame_bytes
    rate: uint64 = cast[uint64](_src_rate())
    fb: uint64 = _src_frame_bytes()
    return ms * rate * fb / 1000


# Basename (past the last '/') of a NUL-terminated path.
def _basename(path: Ptr[char]) -> Ptr[uint8]:
    nm: Ptr[uint8] = cast[Ptr[uint8]](path)
    base: Ptr[uint8] = nm
    z: uint64 = 0
    while nm[z] != 0:
        if nm[z] == 47:
            base = &nm[z + 1]
        z = z + 1
    return base


# Read `path` into au_filebuf and decode it (.mp3 -> lib/mp3decode, else WAV).
# Sets src_is_mp3 + the core format/duration/name. Returns 1 on success.
def _load_and_decode(path: Ptr[char]) -> int32:
    au_filelen = 0
    infd: int32 = sys_open(path)
    if infd >= 0:
        while au_filelen < FILE_CAP:
            r: int64 = sys_read(infd, &au_filebuf[au_filelen],
                                FILE_CAP - au_filelen)
            if r <= 0:
                break
            au_filelen = au_filelen + cast[uint64](r)
        sys_close(infd)

    src_is_mp3 = 0
    plen: uint64 = 0
    while cast[Ptr[uint8]](path)[plen] != 0:
        plen = plen + 1
    if plen >= 4:
        e0: uint8 = cast[Ptr[uint8]](path)[plen - 3]
        e1: uint8 = cast[Ptr[uint8]](path)[plen - 2]
        e2: uint8 = cast[Ptr[uint8]](path)[plen - 1]
        if (e0 == 109 or e0 == 77) and (e1 == 112 or e1 == 80) and e2 == 51:
            src_is_mp3 = 1

    ok: int32 = 0
    if src_is_mp3 != 0:
        ok = mp3decode_parse(&au_filebuf[0], au_filelen)
    elif au_filelen >= 44:
        ok = wavdecode_parse(&au_filebuf[0], au_filelen)
    if ok != 0:
        hamaudio_set_format(_src_rate(), _src_channels())
        hamaudio_set_duration_ms(_src_duration_ms())
        hamaudio_set_name(_basename(path))
    else:
        hamaudio_set_name(cast[Ptr[uint8]]("(unreadable audio)"))
    return ok


# Push the current source's rate/channels/format to /dev/audioctl.
def _configure_format():
    if ctlfd_g < 0:
        return
    _ctl_verb(cast[Ptr[uint8]]("rate"), cast[uint64](_src_rate()))
    _ctl_verb(cast[Ptr[uint8]]("channels"), cast[uint64](_src_channels()))
    if _src_bits() == 8:
        _ctl_word(cast[Ptr[uint8]]("format u8\n"))
    else:
        _ctl_word(cast[Ptr[uint8]]("format s16le\n"))


# Push the UI volume (0..100) to the HDA software mixer's master control. The
# `master <pct>` ctl verb is handled by drivers/audio/audio_cdev.ad.
def _push_volume():
    if ctlfd_g < 0:
        return
    _ctl_verb(cast[Ptr[uint8]]("master"), cast[uint64](hamaudio_volume()))


# ---- shuffle PRNG (xorshift64, lazily seeded from the jiffies clock) ------
rng_state: uint64 = 0


def _rand_u64() -> uint64:
    if rng_state == 0:
        rng_state = sys_get_jiffies() | 1
    x: uint64 = rng_state
    x = x ^ (x << 13)
    x = x ^ (x >> 7)
    x = x ^ (x << 17)
    rng_state = x
    return x


# A random track index != cur (falls back to cur when the list has <2 tracks).
def _rand_other(cur: int32) -> int32:
    if ntrack <= 1:
        return cur
    r: int32 = cast[int32](_rand_u64() % cast[uint64](ntrack))
    if r == cur:
        r = r + 1
        if r >= ntrack:
            r = 0
    return r


# Next/previous track index honouring the shuffle toggle (wraps at the ends).
def _next_index(cur: int32) -> int32:
    if ntrack <= 1:
        return cur
    if hamaudio_shuffle() != 0:
        return _rand_other(cur)
    n: int32 = cur + 1
    if n >= ntrack:
        n = 0
    return n


def _prev_index(cur: int32) -> int32:
    if ntrack <= 1:
        return cur
    if hamaudio_shuffle() != 0:
        return _rand_other(cur)
    p: int32 = cur - 1
    if p < 0:
        p = ntrack - 1
    return p


# Stop the current stream, load+decode track `sel`, reconfigure the HDA stream
# format + volume, and autoplay it from the top. Resets the play anchors. The
# caller is responsible for resetting its own byte cursor to 0. Returns 1 if
# `sel` was a valid row (whether or not the file decoded).
def _switch_to(sel: int32) -> int32:
    if sel < 0 or sel >= ntrack:
        return 0
    _ctl_word(cast[Ptr[uint8]]("stop\n"))
    _ctl_word(cast[Ptr[uint8]]("reset\n"))
    okk: int32 = _load_and_decode(cast[Ptr[char]](track_paths[sel]))
    hamaudio_set_selected_track(sel)
    play_base_ms = 0
    hamaudio_set_position_ms(0)
    hamaudio_set_level(0)
    if okk != 0:
        _configure_format()
        _push_volume()
        _stage_and_start(0)
        play_start_j = sys_get_jiffies()
        hamaudio_set_playing(1)
    else:
        hamaudio_set_playing(0)
    return 1


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)

    hamaudio_init()

    # --- build the playlist from argv (each arg is a track); default to the
    # shipped clip when launched bare. The core keeps display names; we keep the
    # real paths. The first track is the one that autoplays. ---
    hamaudio_playlist_clear()
    if argc >= 2:
        ai: int32 = 1
        while ai < argc and ntrack < 8:
            p: Ptr[char] = cast[Ptr[char]](argv[ai])
            track_paths[ntrack] = cast[uint64](p)
            hamaudio_playlist_add(_basename(p))
            ntrack = ntrack + 1
            ai = ai + 1
    else:
        # Bare launch: DEFAULT to the shipped "Hamnix Music Demo" (48 kHz
        # MPEG-1 Layer III at /usr/share/music/hamnix-music-demo.mp3, installed
        # by scripts/build_packages.py). It is track 0 and autoplays — no more
        # test.wav as the default open. The other preloaded clips are seeded as
        # additional playlist rows so Prev/Next have somewhere to go out of the
        # box; _load_and_decode() falls back gracefully if any is absent.
        track_paths[0] = cast[uint64](cast[Ptr[char]]("/usr/share/music/hamnix-music-demo.mp3"))
        hamaudio_playlist_add(cast[Ptr[uint8]]("hamnix-music-demo.mp3"))
        track_paths[1] = cast[uint64](cast[Ptr[char]]("/usr/share/sounds/test.wav"))
        hamaudio_playlist_add(cast[Ptr[uint8]]("test.wav"))
        track_paths[2] = cast[uint64](cast[Ptr[char]]("/usr/share/sounds/test.mp3"))
        hamaudio_playlist_add(cast[Ptr[uint8]]("test.mp3"))
        ntrack = 3

    # --- load + decode the first track ---
    path: Ptr[char] = cast[Ptr[char]](track_paths[0])
    ok: int32 = _load_and_decode(path)
    hamaudio_set_selected_track(0)

    # --- window ---
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamaudio] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp: Array[64, uint8]
    keysp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))

    # A multi-track playlist needs a taller window to show the track panel;
    # a single bare clip keeps the original compact 220 px window.
    lay_h: int32 = 200
    wcfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if wcfd >= 0:
        if ntrack > 1:
            _writeall(wcfd, cast[Ptr[uint8]]("geometry 480 160 360 360\n"))
            lay_h = 340
        else:
            _writeall(wcfd, cast[Ptr[uint8]]("geometry 480 200 360 220\n"))
        _writeall(wcfd, cast[Ptr[uint8]]("decorate 1\n"))
        _writeall(wcfd, cast[Ptr[uint8]]("z 6\n"))
        _writeall(wcfd, cast[Ptr[uint8]]("title Audio Player\n"))
        sys_close(wcfd)

    hamaudio_layout(360, lay_h)

    # --- HDA control fd; configure the stream format ---
    ctlfd_g = sys_open_write(cast[Ptr[char]]("/dev/audioctl"))
    if ctlfd_g >= 0 and ok != 0:
        _configure_format()
        _push_volume()

    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hamaudio] scene window ready\n"))

    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))

    # Autoplay the loaded clip on start so a bare launch produces sound (the
    # on-device gate opens the window and immediately hears playback).
    cur_byte: uint64 = 0
    if ok != 0:
        _stage_and_start(0)
        play_start_j = sys_get_jiffies()
        play_base_ms = 0
        hamaudio_set_playing(1)
        _writeall(1, cast[Ptr[uint8]]("[hamaudio] playing\n"))
        emit_scene(wid)

    evbuf: Array[256, uint8]
    kbuf: Array[256, uint8]
    while True:
        changed: int32 = 0

        # --- KEYBOARD ---
        if kfd >= 0:
            kr: int64 = sys_read_nb(kfd, &kbuf[0], 255)
            if kr > 0:
                kls: uint64 = 0
                ki: uint64 = 0
                while ki <= cast[uint64](kr):
                    katend: int32 = 0
                    if ki == cast[uint64](kr):
                        katend = 1
                    if katend == 1 or kbuf[ki] == 10:
                        if ki > kls:
                            if hamaudio_key_line(&kbuf[kls], ki - kls) == 1:
                                changed = 1
                        kls = ki + 1
                    ki = ki + 1

        # --- POINTER (non-blocking drain of /event) ---
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            r2: int64 = sys_read_nb(efd, &evbuf[0], 255)
            sys_close(efd)
            if r2 > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r2):
                    atend: int32 = 0
                    if i == cast[uint64](r2):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            if _handle_pointer(&evbuf[ls], i - ls) == 1:
                                changed = 1
                        ls = i + 1
                    i = i + 1

        # --- drain any queued command from the input handlers ---
        cmd: int32 = hamaudio_take_command()
        if cmd == HAMAUDIO_CMD_PLAYPAUSE:
            if hamaudio_is_playing() != 0:
                # Pause: freeze position, stop DMA.
                play_base_ms = play_base_ms + \
                    (sys_get_jiffies() - play_start_j) * 10
                _ctl_word(cast[Ptr[uint8]]("stop\n"))
                hamaudio_set_playing(0)
            else:
                cur_byte = _ms_to_bytes(play_base_ms)
                _stage_and_start(cur_byte)
                play_start_j = sys_get_jiffies()
                hamaudio_set_playing(1)
            changed = 1
        elif cmd == HAMAUDIO_CMD_STOP:
            _ctl_word(cast[Ptr[uint8]]("stop\n"))
            _ctl_word(cast[Ptr[uint8]]("reset\n"))
            hamaudio_set_playing(0)
            play_base_ms = 0
            cur_byte = 0
            hamaudio_set_position_ms(0)
            hamaudio_set_level(0)
            changed = 1
        elif cmd == HAMAUDIO_CMD_SEEK:
            play_base_ms = hamaudio_seek_ms()
            cur_byte = _ms_to_bytes(play_base_ms)
            if hamaudio_is_playing() != 0:
                _stage_and_start(cur_byte)
                play_start_j = sys_get_jiffies()
            hamaudio_set_position_ms(play_base_ms)
            hamaudio_set_level(_level_at(cur_byte))
            changed = 1
        elif cmd == HAMAUDIO_CMD_SELECT:
            # A playlist-row click: switch straight to that track.
            if _switch_to(hamaudio_select_index()) != 0:
                cur_byte = 0
            changed = 1
        elif cmd == HAMAUDIO_CMD_NEXT:
            if _switch_to(_next_index(hamaudio_selected_track())) != 0:
                cur_byte = 0
            changed = 1
        elif cmd == HAMAUDIO_CMD_PREV:
            if _switch_to(_prev_index(hamaudio_selected_track())) != 0:
                cur_byte = 0
            changed = 1
        elif cmd == HAMAUDIO_CMD_VOLUME:
            # The slider moved: push the new master volume to the HDA mixer.
            _push_volume()
            changed = 1

        # --- advance the play position while playing ---
        if hamaudio_is_playing() != 0:
            now_ms: uint64 = play_base_ms + \
                (sys_get_jiffies() - play_start_j) * 10
            dur: uint64 = hamaudio_duration_ms()
            if dur > 0 and now_ms >= dur:
                # Reached the end. VLC-style follow-on, driven by the transport
                # toggles:
                #   * repeat-one         -> restage the SAME track from 0.
                #   * shuffle / more     -> auto-advance to the next track.
                #     tracks remain,        (sequential wraps only under
                #                            repeat-all; the last track stops
                #                            when repeat is off).
                #   * otherwise          -> stop + REWIND to 0 so the very next
                #                            Play restages from the top (the old
                #                            "stuck at the end" bug: settling at
                #                            play_base_ms == dur made _ms_to_bytes
                #                            land past data_len, so the next Play
                #                            hit the early-return and did nothing).
                rep: int32 = hamaudio_repeat()
                cursel: int32 = hamaudio_selected_track()
                advance: int32 = 0
                target: int32 = cursel
                if rep == 2:
                    # repeat-one: restage current track.
                    advance = 1
                    target = cursel
                elif ntrack > 1:
                    if hamaudio_shuffle() != 0:
                        advance = 1
                        target = _rand_other(cursel)
                    elif cursel < ntrack - 1:
                        advance = 1
                        target = cursel + 1
                    elif rep == 1:
                        advance = 1                 # repeat-all wraps to 0
                        target = 0
                elif rep == 1:
                    advance = 1                     # single track, repeat-all
                    target = cursel

                if advance != 0:
                    _switch_to(target)
                    cur_byte = 0
                    changed = 1
                    _writeall(1, cast[Ptr[uint8]]("[hamaudio] EOF -> next\n"))
                else:
                    _ctl_word(cast[Ptr[uint8]]("stop\n"))
                    _ctl_word(cast[Ptr[uint8]]("reset\n"))
                    hamaudio_set_playing(0)
                    play_base_ms = 0
                    cur_byte = 0
                    hamaudio_set_position_ms(0)
                    hamaudio_set_level(0)
                    changed = 1
                    _writeall(1, cast[Ptr[uint8]]("[hamaudio] EOF -> idle (rewound)\n"))
            else:
                hamaudio_set_position_ms(now_ms)
                cur_byte = _ms_to_bytes(now_ms)
                hamaudio_set_level(_level_at(cur_byte))
                changed = 1

        if changed != 0:
            emit_scene(wid)
        hamscene_park(kfd, HAMSCENE_IDLE_MS)
    return 0


# Parse one /event pointer line and drive press/release edges. Delegates to the
# shared lib/hamaudiocore.ad handler (single source of truth, host-gated) which
# takes the FIRST THREE ints after the leading 'm' as x, y, buttons and ignores
# the trailing dz — the old inline copy took the LAST THREE, so buttons always
# read as dz==0 and no mouse transport ever fired.
def _handle_pointer(line: Ptr[uint8], n: uint64) -> int32:
    return hamaudio_handle_pointer_line(line, n)

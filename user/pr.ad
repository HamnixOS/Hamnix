# user/pr.ad
#
# Hamnix `pr`: paginate text for printing. Reads stdin (or a FILE) and
# writes it in fixed-length pages with a header and trailer.
#
#   -h TEXT    header text (default: empty; GNU uses the file name)
#   -l N       page length in lines (default 66)
#   -w N       page width / line truncation (default 72)
#   -t         omit the 5-line page header and trailer
#   -n[SEP[W]] number lines; default width 5, separator TAB. We support
#              the common bare "-n" (5-wide number + TAB).
#   -COLUMN    arrange output in COLUMN columns (e.g. -2, -3)
#   -a         with -COLUMN, fill columns across (row-major) rather than
#              down each column.
#
# Header layout (GNU default, 5 lines per page): two blank lines, the
# header line ("<date>  <header>  Page N" — we emit a simplified
# "  <header>  Page N"), then two blank lines. Trailer = 5 blank lines.
# With -t the body is emitted with no header/trailer padding.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


INPUT_MAX: uint64 = 32768
INDEX_MAX: uint64 = 4096

input_buf:   Array[32768, uint8]
line_starts: Array[4096, uint32]
line_ends:   Array[4096, uint32]
nlines: uint64 = 0

# Options.
page_len: int64 = 66
page_width: int64 = 72
header_off: int32 = 0       # -t
number: int32 = 0           # -n
columns: int64 = 1
across: int32 = 0           # -a
header_text: Ptr[uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def parse_int(s: Ptr[uint8]) -> int64:
    n: int64 = 0
    i: uint64 = 0
    if s[0] == 0:
        return -1
    while s[i] != 0:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            return -1
        n = n * 10 + cast[int64](c - 48)
        i = i + 1
    return n


numscratch: Array[24, uint8]


# Write n right-justified in a `width`-wide field followed by a TAB.
def emit_number(n: uint64, width: uint64):
    i: uint64 = 0
    if n == 0:
        numscratch[0] = 48
        i = 1
    else:
        v: uint64 = n
        while v != 0:
            numscratch[i] = cast[uint8](v % 10) + 48
            v = v / 10
            i = i + 1
    pad: uint64 = 0
    if i < width:
        pad = width - i
    p: uint64 = 0
    while p < pad:
        sys_write(1, " ", 1)
        p = p + 1
    j: uint64 = 0
    while j < i:
        sys_write(1, &numscratch[i - 1 - j], 1)
        j = j + 1
    sys_write(1, "\t", 1)


# Emit the 5-line page header (GNU layout, simplified).
def emit_header(page: uint64):
    sys_write(1, "\n\n", 2)
    write_str(1, "  ")
    if header_text != cast[Ptr[uint8]](0):
        write_str(1, header_text)
    write_str(1, "  Page ")
    # Render page number.
    i: uint64 = 0
    if page == 0:
        numscratch[0] = 48
        i = 1
    else:
        v: uint64 = page
        while v != 0:
            numscratch[i] = cast[uint8](v % 10) + 48
            v = v / 10
            i = i + 1
    j: uint64 = 0
    while j < i:
        sys_write(1, &numscratch[i - 1 - j], 1)
        j = j + 1
    sys_write(1, "\n\n\n", 3)


# Emit one body line (index `idx`), truncated to page_width, optionally
# prefixed with its 1-based line number.
def emit_body_line(idx: uint64):
    if number != 0:
        emit_number(idx + 1, 5)
    s: uint32 = line_starts[idx]
    e: uint32 = line_ends[idx]
    llen: uint64 = cast[uint64](e - s)
    if cast[int64](llen) > page_width:
        llen = cast[uint64](page_width)
    if llen > 0:
        sys_write(1, &input_buf[s], llen)
    sys_write(1, "\n", 1)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    in_fd: int32 = 0
    in_path: Ptr[char] = cast[Ptr[char]](0)

    ai: int32 = 1
    while ai < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
        if a[0] == 45 and a[1] != 0:
            c1: uint8 = a[1]
            if c1 == 116:                                  # -t
                header_off = 1
            elif c1 == 110:                                # -n
                number = 1
            elif c1 == 97:                                 # -a
                across = 1
            elif c1 == 104:                                # -h TEXT
                if a[2] != 0:
                    header_text = cast[Ptr[uint8]](cast[uint64](a) + 2)
                else:
                    if ai + 1 >= argc:
                        write_str(2, "pr: -h needs an argument\n")
                        return 1
                    ai = ai + 1
                    header_text = cast[Ptr[uint8]](argv[cast[uint64](ai)])
            elif c1 == 108:                                # -l N
                src: Ptr[uint8] = cast[Ptr[uint8]](0)
                if a[2] != 0:
                    src = cast[Ptr[uint8]](cast[uint64](a) + 2)
                else:
                    if ai + 1 >= argc:
                        write_str(2, "pr: -l needs an argument\n")
                        return 1
                    ai = ai + 1
                    src = cast[Ptr[uint8]](argv[cast[uint64](ai)])
                v: int64 = parse_int(src)
                if v <= 0:
                    write_str(2, "pr: bad page length\n")
                    return 1
                page_len = v
            elif c1 == 119:                                # -w N
                src: Ptr[uint8] = cast[Ptr[uint8]](0)
                if a[2] != 0:
                    src = cast[Ptr[uint8]](cast[uint64](a) + 2)
                else:
                    if ai + 1 >= argc:
                        write_str(2, "pr: -w needs an argument\n")
                        return 1
                    ai = ai + 1
                    src = cast[Ptr[uint8]](argv[cast[uint64](ai)])
                v: int64 = parse_int(src)
                if v <= 0:
                    write_str(2, "pr: bad page width\n")
                    return 1
                page_width = v
            elif c1 >= 48 and c1 <= 57:                    # -COLUMN
                v: int64 = parse_int(cast[Ptr[uint8]](cast[uint64](a) + 1))
                if v <= 0:
                    write_str(2, "pr: bad column count\n")
                    return 1
                columns = v
            else:
                write_str(2, "pr: unknown flag\n")
                return 1
        else:
            in_path = cast[Ptr[char]](a)
        ai = ai + 1

    if in_path != cast[Ptr[char]](0):
        in_fd = sys_open(in_path)
        if in_fd < 0:
            write_str(2, "pr: cannot open input\n")
            return 1
        if header_text == cast[Ptr[uint8]](0):
            header_text = cast[Ptr[uint8]](in_path)

    # Slurp input.
    total: uint64 = 0
    while total < INPUT_MAX:
        n: int64 = sys_read(in_fd, &input_buf[total], INPUT_MAX - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    if in_fd != 0:
        sys_close(in_fd)

    # Index lines (content bounds, excluding the newline).
    start: uint64 = 0
    i: uint64 = 0
    while i < total and nlines < INDEX_MAX:
        if input_buf[i] == 10:
            line_starts[nlines] = cast[uint32](start)
            line_ends[nlines] = cast[uint32](i)
            nlines = nlines + 1
            start = i + 1
        i = i + 1
    if nlines < INDEX_MAX and start < total:
        line_starts[nlines] = cast[uint32](start)
        line_ends[nlines] = cast[uint32](total)
        nlines = nlines + 1

    # Multi-column mode: lay out `columns` columns separated by 2 spaces,
    # each column field truncated. We implement the simple down-then-across
    # default and the -a across mode. Header/trailer follow the same rule.
    if columns > 1:
        cols: uint64 = cast[uint64](columns)
        # Lines per column = ceil(nlines / cols).
        per: uint64 = (nlines + cols - 1) / cols
        if per == 0:
            per = 1
        r: uint64 = 0
        while r < per:
            ci: uint64 = 0
            while ci < cols:
                idx: uint64 = 0
                present: int32 = 0
                if across != 0:
                    idx = r * cols + ci
                    if idx < nlines:
                        present = 1
                else:
                    idx = ci * per + r
                    if idx < nlines:
                        present = 1
                if present != 0:
                    s: uint32 = line_starts[idx]
                    e: uint32 = line_ends[idx]
                    llen: uint64 = cast[uint64](e - s)
                    if llen > 0:
                        sys_write(1, &input_buf[s], llen)
                if ci + 1 < cols:
                    sys_write(1, "  ", 2)
                ci = ci + 1
            sys_write(1, "\n", 1)
            r = r + 1
        return 0

    # Single-column pagination.
    body_per_page: int64 = page_len
    if header_off == 0:
        # 5 header + 5 trailer lines consumed per page.
        body_per_page = page_len - 10
        if body_per_page <= 0:
            body_per_page = 1

    li: uint64 = 0
    page: uint64 = 1
    while li < nlines:
        if header_off == 0:
            emit_header(page)
        emitted: int64 = 0
        while li < nlines and emitted < body_per_page:
            emit_body_line(li)
            li = li + 1
            emitted = emitted + 1
        if header_off == 0:
            sys_write(1, "\n\n\n\n\n", 5)        # 5-line trailer
        page = page + 1
    return 0

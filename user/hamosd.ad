# user/hamosd.ad
#
# hamosd — DE pivot wave 6: workspace-switch / volume / brightness OSD
# popup extracted from daemon_pixel into a v2 client.

from lib.hamui import (
    hamui_init, hamui_window_on, hamui_set_protocol_v2, hamui_set_protocol_v2_dims,
    hamui_v2_clear, hamui_v2_clear_transparent, hamui_v2_fill_rect, hamui_v2_commit_rect,
    hamui_v2_is_active,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield()
extern def sys_exit(code: int32)


_ho_active: int32 = 0
_ho_kind:   int32 = 0
_ho_ws:     int32 = 0
_ho_pct:    int32 = 0
_ho_gen:    uint64 = 0
_ho_show_serial:      uint64 = 0
_ho_last_show_serial: uint64 = 0xffffffffffffffff
_ho_last_gen:         uint64 = 0xffffffffffffffff


_ho_WIN_W: int32 = 160
_ho_WIN_H: int32 = 40
_ho_SLIDER_W: int32 = 120
_ho_SLIDER_H: int32 = 10


_ho_snap_buf: Array[256, uint8]


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


def _read_snap() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/osd"))
    if fd < 0:
        return -1
    n: int64 = sys_read(fd, &_ho_snap_buf[0], 256)
    sys_close(fd)
    return n


def _parse_u64(pos: Ptr[uint64], end: uint64) -> uint64:
    p: uint64 = pos[0]
    v: uint64 = 0
    while p < end and _ho_snap_buf[p] >= 48 and _ho_snap_buf[p] <= 57:
        v = v * 10 + cast[uint64](_ho_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    return v


def _skip_ws(pos: uint64, end: uint64) -> uint64:
    p: uint64 = pos
    while p < end and (_ho_snap_buf[p] == 32 or _ho_snap_buf[p] == 9):
        p = p + 1
    return p


def _parse_snapshot(n: uint64) -> int32:
    if n == 0:
        return 0
    pos: Array[1, uint64]
    pos[0] = 0
    show_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    a_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    k_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    ws_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    pct_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    gen_v: uint64 = _parse_u64(&pos[0], n)
    _ho_show_serial = show_v
    _ho_active = cast[int32](a_v)
    _ho_kind = cast[int32](k_v)
    _ho_ws = cast[int32](ws_v)
    _ho_pct = cast[int32](pct_v)
    _ho_gen = gen_v
    changed: int32 = 0
    if _ho_show_serial != _ho_last_show_serial:
        changed = 1
    if _ho_gen != _ho_last_gen:
        changed = 1
    _ho_last_show_serial = _ho_show_serial
    _ho_last_gen = _ho_gen
    return changed


def _paint():
    hamui_v2_clear_transparent()
    if _ho_active == 0:
        hamui_v2_commit_rect(0, 0, _ho_WIN_W, _ho_WIN_H)
        return
    # Dark rounded slab.
    hamui_v2_fill_rect(0, 0, _ho_WIN_W, _ho_WIN_H, 30, 34, 46)
    # Accent border.
    hamui_v2_fill_rect(0, 0, _ho_WIN_W, 1, 110, 140, 200)
    hamui_v2_fill_rect(0, _ho_WIN_H - 1, _ho_WIN_W, 1, 110, 140, 200)
    hamui_v2_fill_rect(0, 0, 1, _ho_WIN_H, 110, 140, 200)
    hamui_v2_fill_rect(_ho_WIN_W - 1, 0, 1, _ho_WIN_H, 110, 140, 200)
    if _ho_kind != 0:
        # Volume/brightness slider.
        tx0: int32 = (_ho_WIN_W - _ho_SLIDER_W) / 2
        ty0: int32 = _ho_WIN_H - _ho_SLIDER_H - 8
        hamui_v2_fill_rect(tx0, ty0, _ho_SLIDER_W, _ho_SLIDER_H, 60, 66, 80)
        fill_w: int32 = _ho_SLIDER_W * _ho_pct / 100
        if fill_w < 0:
            fill_w = 0
        if fill_w > _ho_SLIDER_W:
            fill_w = _ho_SLIDER_W
        hamui_v2_fill_rect(tx0, ty0, fill_w, _ho_SLIDER_H, 200, 220, 250)
        # Kind tag at top-left (V or B placeholder block).
        if _ho_kind == 1:
            hamui_v2_fill_rect(8, 6, 4, 8, 220, 230, 248)
        else:
            hamui_v2_fill_rect(8, 6, 4, 8, 250, 200, 110)
    else:
        # Workspace label: just N highlighted bars (one per workspace,
        # current ws bright).
        i: int32 = 0
        bw: int32 = 12
        bg: int32 = 4
        total: int32 = (bw + bg) * 4
        x0: int32 = (_ho_WIN_W - total) / 2
        while i < 4:
            cx: int32 = x0 + i * (bw + bg)
            cy: int32 = (_ho_WIN_H - 10) / 2
            r: uint8 = 80
            g: uint8 = 90
            b: uint8 = 110
            if i == _ho_ws:
                r = 220
                g = 230
                b = 248
            hamui_v2_fill_rect(cx, cy, bw, 10, r, g, b)
            i = i + 1
    hamui_v2_commit_rect(0, 0, _ho_WIN_W, _ho_WIN_H)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()
    wid: int32 = 1
    sfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/self"))
    if sfd >= 0:
        sbuf: Array[16, uint8]
        sn: int64 = sys_read_nb(sfd, &sbuf[0], 16)
        sys_close(sfd)
        if sn > 0:
            v: int32 = 0
            i: uint64 = 0
            while i < cast[uint64](sn) and sbuf[i] >= 48 and sbuf[i] <= 57:
                v = v * 10 + cast[int32](sbuf[i]) - 48
                i = i + 1
            if v >= 2:
                wid = v
    if argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        v2: int32 = 0
        i2: uint64 = 0
        while ap[i2] >= 48 and ap[i2] <= 57:
            v2 = v2 * 10 + cast[int32](ap[i2]) - 48
            i2 = i2 + 1
        if v2 >= 1:
            wid = v2

    bound: int32 = hamui_window_on(0, wid)
    if bound < 0:
        _puts(2, "hamosd: could not bind window\n")
        return 1
    if hamui_set_protocol_v2_dims(_ho_WIN_W, _ho_WIN_H) < 0:
        _puts(2, "hamosd: v2 negotiate failed\n")
        return 1

    n0: int64 = _read_snap()
    if n0 > 0:
        _parse_snapshot(cast[uint64](n0))
    _paint()
    rdy: Ptr[uint8] = "HAMOSD ready\n"
    sys_write(1, rdy, _strlen(rdy))

    while True:
        n: int64 = _read_snap()
        if n > 0:
            if _parse_snapshot(cast[uint64](n)) != 0:
                _paint()
        sys_yield()

    return 0

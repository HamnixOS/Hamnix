# user/nproc.ad
#
# Hamnix `nproc`: print the number of online CPUs, mirroring
# coreutils' `nproc`. The kernel exposes the SMP count through
# /proc/cpuinfo as a "cpus_online: N" line (see
# sys/src/9/port/devcpuinfo.ad). We read that file, find the
# "cpus_online:" label, parse the integer that follows, and print
# it on its own line. If the field can't be found we fall back to
# 1 — a running system always has at least one online CPU.
#
# No --all / --ignore flags: coreutils distinguishes "configured"
# vs "online" CPUs, but Hamnix only tracks online CPUs, so the two
# counts coincide and the bare form is the whole contract.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


CPUINFO_CAP: uint64 = 512
cpuinfo_buf: Array[512, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def write_dec(v: uint64):
    if v == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    i: uint64 = 0
    while v != 0:
        digits[i] = cast[uint8](v % 10) + 48
        v = v / 10
        i = i + 1
    out: Array[24, uint8]
    j: uint64 = 0
    while j < i:
        out[j] = digits[i - 1 - j]
        j = j + 1
    sys_write(1, &out[0], i)


# True if cpuinfo_buf[at..] begins with the literal "cpus_online:".
def matches_label(buf: Ptr[uint8], n: uint64, at: uint64) -> int32:
    label: Ptr[uint8] = "cpus_online:"
    k: uint64 = 0
    while label[k] != 0:
        if at + k >= n:
            return 0
        if buf[at + k] != label[k]:
            return 0
        k = k + 1
    return 1


def main() -> int32:
    fd: int32 = sys_open("/proc/cpuinfo")
    if fd < 0:
        # No /proc/cpuinfo — still a valid single-CPU answer.
        write_str(1, "1\n")
        return 0
    total: uint64 = 0
    while total < CPUINFO_CAP:
        r: int64 = sys_read(fd, cast[Ptr[uint8]](
                                cast[uint64](&cpuinfo_buf[0]) + total),
                            CPUINFO_CAP - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)

    # Scan for the "cpus_online:" label, then read the integer after it.
    i: uint64 = 0
    found: int32 = 0
    count: uint64 = 1
    while i < total:
        if matches_label(&cpuinfo_buf[0], total, i) != 0:
            j: uint64 = i + 12                       # past "cpus_online:"
            # skip spaces
            while j < total and cpuinfo_buf[j] == 32:
                j = j + 1
            v: uint64 = 0
            saw: int32 = 0
            while j < total and cpuinfo_buf[j] >= 48 and cpuinfo_buf[j] <= 57:
                v = v * 10 + cast[uint64](cpuinfo_buf[j] - 48)
                saw = 1
                j = j + 1
            if saw != 0 and v > 0:
                count = v
                found = 1
            break
        i = i + 1

    if found == 0:
        count = 1
    write_dec(count)
    sys_write(1, "\n", 1)
    return 0

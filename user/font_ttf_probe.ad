# user/font_ttf_probe.ad — standalone host probe for lib/font_ttf.ad. Loads a
# .ttf, rasterises a few glyphs at several px sizes, and dumps geometry +
# coverage stats so a gate can prove: (1) continuous sizing (18px glyph taller
# than 12px), (2) grayscale AA (intermediate coverage values, not just 0/255).
# Also renders one glyph as ASCII art for eyeballing. x86_64-linux target.

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.font_ttf import font_ttf_load, font_ttf_render, font_ttf_loaded, \
    glyph_bw, glyph_bh, glyph_xoff, glyph_ytop, glyph_adv, glyph_blank, \
    glyph_cov, font_ttf_ascent_px, font_ttf_descent_px, FACE_TT_SANS

obuf: Array[4096, uint8]
obuf_n: uint64 = 0

def _o_ch(c: uint8):
    if obuf_n < 4095:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1

def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1

def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])

def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0

font_buf: Array[262144, uint8]

def _slurp(path: Ptr[char], dst: Ptr[uint8], cap: uint64) -> int64:
    fd: int32 = sys_open(path, 0, 0)
    if fd < 0:
        return -1
    got: uint64 = 0
    while got < cap - 1:
        n: int64 = sys_read(fd, &dst[got], cap - 1 - got)
        if n <= 0:
            break
        got = got + cast[uint64](n)
    sys_close(fd)
    return cast[int64](got)


# Report the coverage histogram + bbox for one glyph render.
def _probe(cp: int32, px: int32):
    r: int32 = font_ttf_render(FACE_TT_SANS, cp, px)
    _o_str(cast[Ptr[uint8]]("GLYPH cp="))
    _o_dec(cast[int64](cp))
    _o_str(cast[Ptr[uint8]](" px="))
    _o_dec(cast[int64](px))
    _o_str(cast[Ptr[uint8]](" bw="))
    _o_dec(cast[int64](glyph_bw()))
    _o_str(cast[Ptr[uint8]](" bh="))
    _o_dec(cast[int64](glyph_bh()))
    _o_str(cast[Ptr[uint8]](" adv="))
    _o_dec(cast[int64](glyph_adv()))
    _o_str(cast[Ptr[uint8]](" ytop="))
    _o_dec(cast[int64](glyph_ytop()))
    # coverage histogram buckets: zero, mid (1..254), full (255)
    nz: int64 = 0
    nmid: int64 = 0
    nfull: int64 = 0
    row: int32 = 0
    while row < glyph_bh():
        col: int32 = 0
        while col < glyph_bw():
            v: uint8 = glyph_cov(col, row)
            if v == 0:
                nz = nz + 1
            elif v == 255:
                nfull = nfull + 1
            else:
                nmid = nmid + 1
            col = col + 1
        row = row + 1
    _o_str(cast[Ptr[uint8]](" zero="))
    _o_dec(nz)
    _o_str(cast[Ptr[uint8]](" mid="))
    _o_dec(nmid)
    _o_str(cast[Ptr[uint8]](" full="))
    _o_dec(nfull)
    _o_ch(10)
    _o_flush()


def _art(cp: int32, px: int32):
    font_ttf_render(FACE_TT_SANS, cp, px)
    _o_str(cast[Ptr[uint8]]("--- ascii art cp="))
    _o_dec(cast[int64](cp))
    _o_str(cast[Ptr[uint8]](" px="))
    _o_dec(cast[int64](px))
    _o_ch(10)
    row: int32 = 0
    while row < glyph_bh():
        col: int32 = 0
        while col < glyph_bw():
            v: uint8 = glyph_cov(col, row)
            ch: uint8 = 32
            if v > 200:
                ch = 64                       # '@'
            elif v > 128:
                ch = 111                      # 'o'
            elif v > 64:
                ch = 58                       # ':'
            elif v > 0:
                ch = 46                       # '.'
            _o_ch(ch)
            col = col + 1
        _o_ch(10)
        row = row + 1
    _o_flush()


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    path: Ptr[char] = cast[Ptr[char]]("fonts/dejavu-sans.ttf")
    if argc >= 2:
        path = cast[Ptr[char]](argv[1])
    n: int64 = _slurp(path, &font_buf[0], 262144)
    if n <= 0:
        sys_write(2, cast[Ptr[uint8]]("probe: cannot read font\n"), 24)
        return 1
    rc: int32 = font_ttf_load(FACE_TT_SANS, &font_buf[0], cast[uint64](n))
    _o_str(cast[Ptr[uint8]]("LOAD rc="))
    _o_dec(cast[int64](rc))
    _o_str(cast[Ptr[uint8]](" loaded="))
    _o_dec(cast[int64](font_ttf_loaded(FACE_TT_SANS)))
    _o_ch(10)
    _o_flush()
    if rc != 0:
        return 1
    _o_str(cast[Ptr[uint8]]("ASCENT12="))
    _o_dec(cast[int64](font_ttf_ascent_px(FACE_TT_SANS, 12)))
    _o_str(cast[Ptr[uint8]](" DESCENT12="))
    _o_dec(cast[int64](font_ttf_descent_px(FACE_TT_SANS, 12)))
    _o_ch(10)
    _o_flush()
    # 'A' at increasing sizes -> proves continuous scaling
    _probe(65, 12)
    _probe(65, 16)
    _probe(65, 18)
    _probe(65, 24)
    _probe(65, 32)
    _probe(97, 16)                # 'a'
    _probe(103, 16)              # 'g' (descender)
    _art(65, 24)                # eyeball 'A'
    _art(97, 20)                # eyeball 'a'
    return 0

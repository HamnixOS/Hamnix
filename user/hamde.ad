# user/hamde.ad
#
# hamde — the Hamnix Desktop Environment shell, rebuilt on the hamui
# widget toolkit (lib/hamui.ad). It is the demonstrator that a real DE
# panel is now just an ordinary hamui consumer: build a widget tree, bind
# a window, run a pull-based event loop. NONE of the panel chrome is
# hand-rolled hamML — every pixel comes from toolkit widgets.
#
# WHAT IT IS
# ----------
# A classic GNOME2 / MATE-style top panel built entirely from hamui:
#   * a menubar at the left with an "Applications" menu (a real
#     hamui_menu + hamui_menu_add items) that launches the shipped GUI
#     apps via spawn;
#   * a live clock label at the right, refreshed from /proc/realtime
#     (HH:MM), falling back to a jiffies uptime counter when the realtime
#     clock has not been set;
#   * a taskbar/window-list strip in the middle — a hamui listbox that
#     records each app this panel has launched (name + pid), rebuilt in
#     place via the toolkit's new hamui_list_clear so it never exhausts
#     the row pool.
#
# REAL INPUT
# ----------
# The panel takes genuine mouse + keyboard through the toolkit's wired
# /dev/wsys/<wid>/{pointer,keys} path (lib/hamui.ad::_h_poll_pointer /
# _h_poll_keys). Clicking "Applications" drops the menu; clicking an item
# fires that item's signal, which we turn into a spawn of the real
# program. This is the payoff of the compositor's per-window event
# routing: the DE shell is just another input-driven hamui client.
#
# WINDOWING
# ---------
# A hamui client never self-allocates a wid (SYS_WSYS_ALLOC is
# hostowner-only — see lib/hamui.ad::hamui_window_on). The compositor
# hands the panel its wid as argv[1] when it spawns it at runlevel 5; if
# no argv[1] is supplied (the standalone / headless-render case) we bind
# the foreground window wid 1, exactly like the other hamui apps and the
# headless render test.
#
# LAYOUT NOTE (headless probe): like user/hamui_demo.ad the root is a
# FIXED container so the offline `hamUId render <wid>` grid can sample
# known pixels. The Applications menubar sits at (0,0); its open popdown
# and the launched-app list rasterise as #4a6da7 selection / #252525 menu
# fills, which the render gate asserts.

from lib.hamui import (
    hamui_init, hamui_fixed, hamui_label, hamui_menubar, hamui_menu,
    hamui_menu_add, hamui_list, hamui_list_add, hamui_list_clear,
    hamui_add, hamui_set_size, hamui_fixed_place, hamui_set_text,
    hamui_window_on, hamui_render, hamui_step, hamui_take_event,
    hamui_window_wid
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield()


# --- module-scope buffers (no malloc; fixed arrays only) -------------
# argv staging for a launched app: [ "/bin/xxx", NULL ].
launch_argv: Array[4, uint64]

# /proc/realtime read scratch + the composed clock string ("HH:MM").
rt_buf:    Array[128, uint8]
clock_str: Array[16, uint8]

# A taskbar row string ("name  pid=N").
task_buf:  Array[80, uint8]

# How many apps this panel has launched (drives the taskbar list).
launched: uint64 = 0

# Last minute we painted the clock for (avoid pointless repaints).
last_clock_min: int32 = -1
# Jiffies-fallback: the last whole second we rendered.
last_uptime_s:  uint64 = 0xffffffffffffffff


from lib.p9 import spawn

def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


# Two ASCII digits of v (00..99) into out[off..off+1].
def _two_digits(out: Ptr[uint8], off: uint64, v: uint64):
    out[off] = cast[uint8](v / 10) + 48
    out[off + 1] = cast[uint8](v % 10) + 48


# Parse two decimal digits at rt_buf[off..off+1].
def _rt_two(off: uint64) -> uint64:
    hi: uint8 = rt_buf[off]
    lo: uint8 = rt_buf[off + 1]
    return cast[uint64](hi - 48) * 10 + cast[uint64](lo - 48)


# Refresh clock_str. Returns 1 if the displayed value changed (so the
# caller repaints), else 0.
#
# Primary source: /proc/realtime line "YYYY-MM-DDTHH:MM:SSZ ..." with the
# hour at offset 11-12 and the minute at 14-15 (byte-exact with
# fs/procfs.ad::render_realtime, as user/crond.ad and user/date.ad read
# it). If the realtime clock is unset (leading 'u' = "unavailable", or no
# 'T' at offset 10) we fall back to a boot-uptime clock derived from
# sys_get_jiffies (100 Hz) formatted as "up MM:SS".
def update_clock() -> int32:
    fd: int32 = sys_open("/proc/realtime")
    if fd >= 0:
        n: int64 = sys_read(fd, &rt_buf[0], 128)
        sys_close(fd)
        if n >= 20 and rt_buf[0] != 117 and rt_buf[10] == 84:
            hh: uint64 = _rt_two(11)
            mm: uint64 = _rt_two(14)
            min_id: int32 = cast[int32](hh) * 60 + cast[int32](mm)
            if min_id == last_clock_min:
                return 0
            last_clock_min = min_id
            _two_digits(&clock_str[0], 0, hh)
            clock_str[2] = 58                         # ':'
            _two_digits(&clock_str[0], 3, mm)
            clock_str[5] = 0
            return 1
    # --- jiffies fallback: "up MM:SS" since boot --------------------
    j: uint64 = sys_get_jiffies()
    s: uint64 = j / 100
    if s == last_uptime_s:
        return 0
    last_uptime_s = s
    last_clock_min = -1                               # invalidate realtime cache
    mins: uint64 = (s / 60) % 100
    secs: uint64 = s % 60
    clock_str[0] = 117                                # 'u'
    clock_str[1] = 112                                # 'p'
    clock_str[2] = 32                                 # ' '
    _two_digits(&clock_str[0], 3, mins)
    clock_str[5] = 58                                 # ':'
    _two_digits(&clock_str[0], 6, secs)
    clock_str[8] = 0
    return 1


# Build "name  pid=N" into task_buf for the taskbar list.
def make_task_row(name: Ptr[uint8], pid: int32):
    j: uint64 = 0
    while name[j] != 0 and j < 48:
        task_buf[j] = name[j]
        j = j + 1
    task_buf[j] = 32
    j = j + 1
    task_buf[j] = 112          # 'p'
    task_buf[j + 1] = 105      # 'i'
    task_buf[j + 2] = 100      # 'd'
    task_buf[j + 3] = 61       # '='
    j = j + 4
    # Decimal of pid (>=0 here; spawn failures aren't recorded).
    v: uint32 = cast[uint32](pid)
    if v == 0:
        task_buf[j] = 48
        j = j + 1
    else:
        tmp: Array[12, uint8]
        t: uint64 = 0
        while v != 0:
            tmp[t] = cast[uint8](v % 10) + 48
            v = v / 10
            t = t + 1
        while t > 0:
            t = t - 1
            task_buf[j] = tmp[t]
            j = j + 1
    task_buf[j] = 0


# Launch one program by absolute path, recording it on the taskbar list.
# Returns the child pid (>=0) or -1.
def launch(tasklist: int32, prog: Ptr[char], name: Ptr[uint8]) -> int32:
    launch_argv[0] = cast[uint64](prog)
    launch_argv[1] = 0
    # Detached stdio (-2/-2): the compositor allocates the child's window
    # and wires its stdio when it owns the spawn; a panel-launched GUI app
    # does not share the panel's pipes. (Mirrors the daemon's own launch.)
    pid: int32 = spawn(prog, &launch_argv[0], -2, -2,
                           cast[Ptr[uint64]](0))
    if pid >= 0:
        make_task_row(name, pid)
        hamui_list_add(tasklist, &task_buf[0])
        launched = launched + 1
        _puts(1, "HAMDE launch ")
        _puts(1, name)
        _puts(1, "\n")
    return pid


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()

    # --- panel widget tree (a top bar across a 640x480 window) -------
    root: int32 = hamui_fixed()

    # Applications menu (a real hamui menubar + popdown). Items launch the
    # shipped GUI apps. The menubar paints the bar; clicking the title
    # opens the popdown; clicking an item fires its signal + closes it.
    mbar: int32 = hamui_menubar()
    hamui_set_size(mbar, 200, 24)
    hamui_fixed_place(mbar, 0, 0)
    hamui_add(root, mbar)

    apps: int32 = hamui_menu("Applications")
    hamui_add(mbar, apps)
    mi_term:  int32 = hamui_menu_add(apps, "Terminal")
    mi_files: int32 = hamui_menu_add(apps, "Files")
    mi_edit:  int32 = hamui_menu_add(apps, "Text Editor")
    mi_snake: int32 = hamui_menu_add(apps, "Snake")
    mi_2048:  int32 = hamui_menu_add(apps, "2048")

    # Clock at the right end of the bar.
    clock: int32 = hamui_label("--:--")
    hamui_set_size(clock, 80, 16)
    hamui_fixed_place(clock, 560, 4)
    hamui_add(root, clock)

    # Taskbar caption + the launched-window list below the bar.
    cap: int32 = hamui_label("Windows:")
    hamui_fixed_place(cap, 8, 30)
    hamui_add(root, cap)

    tasklist: int32 = hamui_list()
    hamui_set_size(tasklist, 300, 360)
    hamui_fixed_place(tasklist, 8, 50)
    hamui_add(root, tasklist)

    # Seed the clock before the first paint.
    update_clock()
    hamui_set_text(clock, &clock_str[0])

    # --- bind a window -------------------------------------------------
    # The compositor passes our wid as argv[1]; default to wid 1 (the
    # foreground window) for the standalone / headless-render path.
    wid: int32 = 1
    if argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        v: int32 = 0
        i: uint64 = 0
        while ap[i] >= 48 and ap[i] <= 57:
            v = v * 10 + cast[int32](ap[i]) - 48
            i = i + 1
        if v >= 1:
            wid = v

    bound: int32 = hamui_window_on(root, wid)
    if bound < 0:
        _puts(2, "hamde: could not bind panel window\n")
        return 1
    _puts(1, "HAMDE ready\n")

    # First layout + paint.
    hamui_render()

    # --- event loop ----------------------------------------------------
    running: int32 = 1
    poll: uint64 = 0
    while running != 0:
        # hamui_step() polls /dev/wsys/<wid>/{pointer,keys}, dispatches
        # clicks/keys into the widget tree, and repaints on change.
        hamui_step()

        ev: int32 = hamui_take_event()
        while ev >= 0:
            if ev == mi_term:
                launch(tasklist, cast[Ptr[char]]("/bin/hamterm"), "Terminal")
            elif ev == mi_files:
                launch(tasklist, cast[Ptr[char]]("/bin/hamfiles"), "Files")
            elif ev == mi_edit:
                launch(tasklist, cast[Ptr[char]]("/bin/hamedit"), "Editor")
            elif ev == mi_snake:
                launch(tasklist, cast[Ptr[char]]("/bin/hamsnake"), "Snake")
            elif ev == mi_2048:
                launch(tasklist, cast[Ptr[char]]("/bin/ham2048"), "2048")
            ev = hamui_take_event()

        # Refresh the clock roughly once a second (the loop yields, so we
        # gate on a poll counter rather than busy-reading /proc each turn).
        poll = poll + 1
        if poll >= 50:
            poll = 0
            if update_clock() != 0:
                hamui_set_text(clock, &clock_str[0])

        sys_yield()

    return 0

# user/httpchunk_host.ad — HOST unit test for lib/httpchunk.http_dechunk.
#
# Built for the `x86_64-linux` Adder target: a freestanding ELF that runs
# DIRECTLY on the host (no QEMU). It exercises the chunked decoder that
# user/http9.ad uses on-device, asserting the security-critical bounds
# behaviour (oversized chunk-size clamped, dst-cap clamp, in-place decode)
# that is hard to observe from inside a full browser boot.
#
# Driven by scripts/test_httpchunk_host.sh. Emits one "[dechunk] PASS/FAIL"
# line per case and a final "[dechunk] RESULT: PASS|FAIL".

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: int32) -> int32

from lib.httpchunk import http_dechunk


in_buf:  Array[4096, uint8]
out_buf: Array[4096, uint8]
fails:   int32 = 0
npass:   int32 = 0


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(s: Ptr[uint8]):
    sys_write(1, s, _slen(s))


# Copy NUL-terminated literal `s` into in_buf; returns its length.
def _load(s: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while s[i] != 0 and i < 4096:
        in_buf[i] = s[i]
        i = i + 1
    return i


# Assert decode(in_buf[0..in_len)) == expected (NUL-terminated) with the
# given return code. `label` names the case for the log.
def _check(label: Ptr[uint8], in_len: uint64,
           want_rc: int32, expected: Ptr[uint8]):
    ol: Array[1, uint64]
    ol[0] = 0
    rc: int32 = http_dechunk(&in_buf[0], in_len, &out_buf[0], 4096, &ol[0])
    ok: int32 = 1
    if rc != want_rc:
        ok = 0
    elen: uint64 = _slen(expected)
    if ol[0] != elen:
        ok = 0
    if ok != 0:
        k: uint64 = 0
        while k < elen:
            if out_buf[k] != expected[k]:
                ok = 0
                break
            k = k + 1
    if ok != 0:
        _writeall("[dechunk] PASS ")
        npass = npass + 1
    else:
        _writeall("[dechunk] FAIL ")
        fails = fails + 1
    _writeall(label)
    _writeall("\n")


# Assert only the decoded LENGTH and rc (used where we just prove a clamp
# produced a bounded byte count without an OOB, not the exact content).
def _check_len(label: Ptr[uint8], in_len: uint64, dst_cap: uint64,
               want_rc: int32, want_len: uint64):
    ol: Array[1, uint64]
    ol[0] = 0
    rc: int32 = http_dechunk(&in_buf[0], in_len, &out_buf[0], dst_cap, &ol[0])
    ok: int32 = 1
    if rc != want_rc:
        ok = 0
    if ol[0] != want_len:
        ok = 0
    if ok != 0:
        _writeall("[dechunk] PASS ")
        npass = npass + 1
    else:
        _writeall("[dechunk] FAIL ")
        fails = fails + 1
    _writeall(label)
    _writeall("\n")


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # 1) Multi-chunk body decodes to the exact concatenation, 0-terminated.
    n1: uint64 = _load("4\r\nWiki\r\n5\r\npedia\r\n0\r\n\r\n")
    _check("multichunk", n1, 0, "Wikipedia")

    # 2) A lone terminating chunk -> empty body.
    n2: uint64 = _load("0\r\n\r\n")
    _check("terminator-only", n2, 0, "")

    # 3) Uppercase hex size (0x0A = 10 bytes).
    n3: uint64 = _load("A\r\n0123456789\r\n0\r\n\r\n")
    _check("hex-len", n3, 0, "0123456789")

    # 4) Two-digit hex size 0x1A = 26 bytes.
    n4: uint64 = _load("1A\r\nABCDEFGHIJKLMNOPQRSTUVWXYZ\r\n0\r\n\r\n")
    _check("two-digit-hex", n4, 0, "ABCDEFGHIJKLMNOPQRSTUVWXYZ")

    # 5) Chunk extensions after the size are ignored.
    n5: uint64 = _load("4;name=val\r\nWiki\r\n0\r\n\r\n")
    _check("chunk-ext", n5, 0, "Wiki")

    # 6) SECURITY: an oversized chunk-size (claims 0xFF=255 bytes but only
    #    3 are present, no terminator) must CLAMP to the available bytes
    #    (rc=1) and NOT read out of bounds.
    n6: uint64 = _load("FF\r\nabc")
    _check("oversize-src-clamp", n6, 1, "abc")

    # 7) SECURITY: a chunk larger than dst_cap must CLAMP to dst_cap (rc=1)
    #    and NOT write out of bounds. 8 body bytes, dst_cap=4 -> 4 written.
    n7: uint64 = _load("8\r\nABCDEFGH\r\n0\r\n\r\n")
    _check_len("dstcap-clamp", n7, 4, 1, 4)

    # 8) Malformed: a non-hex, non-empty size line mid-stream -> rc=-1.
    n8: uint64 = _load("zz\r\nfoo\r\n0\r\n\r\n")
    _check_len("malformed-size", n8, 4096, -1, 0)

    # 9) IN-PLACE decode (src==dst): the same-pointer path http9 uses.
    ip: uint64 = _load("3\r\nfoo\r\n3\r\nbar\r\n0\r\n\r\n")
    ol9: Array[1, uint64]
    ol9[0] = 0
    rc9: int32 = http_dechunk(&in_buf[0], ip, &in_buf[0], 4096, &ol9[0])
    okp: int32 = 1
    if rc9 != 0:
        okp = 0
    if ol9[0] != 6:
        okp = 0
    exp9: Ptr[uint8] = "foobar"
    if okp != 0:
        kk: uint64 = 0
        while kk < 6:
            if in_buf[kk] != exp9[kk]:
                okp = 0
                break
            kk = kk + 1
    if okp != 0:
        _writeall("[dechunk] PASS in-place\n")
        npass = npass + 1
    else:
        _writeall("[dechunk] FAIL in-place\n")
        fails = fails + 1

    if fails == 0:
        _writeall("[dechunk] RESULT: PASS\n")
        return 0
    _writeall("[dechunk] RESULT: FAIL\n")
    return 1

# user/hamfmscene_host.ad — HOST driver + render harness for the file-manager
# right-click CONTEXT MENU and the "New File" action (built for the
# x86_64-linux Adder target; runs on the dev host, no QEMU).
#
# It renders the SAME empty-space context menu the native app draws — the rows
# and labels come from the shared browse core (lib/hamfmcore.ad
# fmc_menu_empty_rows / fmc_menu_label), NOT a duplicated table — and rasterizes
# it with lib/hamui_host.ad into a PPM a human/agent can LOOK at. It renders a
# "before" menu (New Folder only, the OLD layout) and an "after" menu (New
# Folder + New File, the shipped layout) so the visual addition is obvious.
#
# It then DRIVES the real New-File action: fmc_set_cur_path(<scratch dir>) +
# fmc_touch(fmc_new_file_default()) — the exact native creation primitive — and
# reports whether it created a real 0-byte file, so the gate asserts the file
# was created without QEMU. The scratch dir path is argv[3].
#
# No sockets, no Plan 9: reads argv, writes two PPMs + one file. TEST shim only.
#
# USAGE (built to build/host/hamfm_host):
#   hamfm_host BEFORE.ppm AFTER.ppm SCRATCH_DIR

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_glyphs, hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes
from lib.hamfmcore import fmc_set_cur_path, fmc_touch, fmc_menu_empty_rows, \
    fmc_menu_label, fmc_new_file_default, FM_ACT_NEWFOLDER, \
    fmc_set_geometry, fmc_set_header, fmc_model_reset, fmc_add_entry, \
    fmc_sort_entries, fmc_paint, fmc_num_entries, fmc_item_count, \
    fmc_entry_is_dir, fmc_entry_is_exec, fmc_entry_name_copy


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


# ---- menu render ----------------------------------------------------------
# Geometry mirrors user/hamfmscene.ad's overlay (MENU_ITEM_H=18, box @ mx,my).
MENU_ITEM_H: int32 = 18
MENU_W: int32 = 110
MX: int32 = 40
MY: int32 = 40


# Draw one context-menu box with `nrows` action codes from rows[] over a plain
# window backdrop, exactly like the app's _paint_overlays menu block.
def _draw_menu(rows: Ptr[int32], nrows: int32):
    hamscene_begin()
    # Window backdrop so the PNG isn't bare.
    hamscene_fill(0, 0, 200, 160, cast[Ptr[uint8]]("#2c3040"))
    mh: int32 = nrows * MENU_ITEM_H + 2
    hamscene_fill(MX, MY, MENU_W, mh, cast[Ptr[uint8]]("#1b2130"))
    hamscene_rect(MX, MY, MENU_W, mh, cast[Ptr[uint8]]("#4a5468"))
    i: int32 = 0
    while i < nrows:
        iy: int32 = MY + 1 + i * MENU_ITEM_H
        hamscene_glyphs(MX + 8, iy + 5, fmc_menu_label(rows[i]),
                        cast[Ptr[uint8]]("#e8ecf6"))
        i = i + 1


def _dump_scene():
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()


# ---- directory-listing render -------------------------------------------
# Directory enumeration is a kernel path the dev host cannot run, so we build a
# REPRESENTATIVE model directly (fmc_model_reset/fmc_add_entry — the same
# records fmc_load_dir produces on-device) and render it through the REAL
# fmc_paint. This exercises the new dirs-first SORT, the executable BADGE/tint
# and the entry-count HUD exactly as they appear on-device. The pre-sort input
# is deliberately shuffled (files before dirs, mixed case) so the rendered
# order proves the sort ran.
LW: int32 = 320
LH: int32 = 260


def _emit_added(name: Ptr[uint8], is_dir: int32, is_exec: int32):
    fmc_add_entry(name, is_dir, is_exec)


# Print the post-sort model as "ENTRY <i> <D|F> <X|-> <name>" lines so the gate
# can assert dirs-first ordering and the exec flag WITHOUT reading pixels.
def _dump_model():
    i: uint64 = 0
    n: uint64 = fmc_num_entries()
    while i < n:
        _o_str(cast[Ptr[uint8]]("ENTRY "))
        _o_dec(cast[int64](i))
        _o_ch(32)
        if fmc_entry_is_dir(i) != 0:
            _o_ch(68)                                  # 'D'
        else:
            _o_ch(70)                                  # 'F'
        _o_ch(32)
        if fmc_entry_is_exec(i) != 0:
            _o_ch(88)                                  # 'X'
        else:
            _o_ch(45)                                  # '-'
        _o_ch(32)
        nm: Array[64, uint8]
        fmc_entry_name_copy(i, &nm[0], 64)
        _o_str(&nm[0])
        _o_ch(10)
        i = i + 1
    _o_flush()


# Build the shuffled listing, sort it, render the grid to `path`, and dump the
# post-sort model. Returns the item count (excludes "..").
def _render_listing(path: Ptr[char]) -> uint64:
    fmc_set_geometry(cast[int64](LW), cast[int64](LH), 0)
    fmc_set_header(cast[Ptr[uint8]]("hamfm: "))
    # cur_path deeper than root so a synthetic ".." row is present + pinned.
    fmc_set_cur_path(cast[Ptr[uint8]]("/home/live"))
    fmc_model_reset()
    # Shuffled input: a file, then dirs out of order, an exec, more files.
    _emit_added(cast[Ptr[uint8]]("zebra.txt"), 0, 0)
    _emit_added(cast[Ptr[uint8]]("Music"), 1, 0)
    _emit_added(cast[Ptr[uint8]]("run.sh"), 0, 1)         # executable
    _emit_added(cast[Ptr[uint8]]("apple.md"), 0, 0)
    _emit_added(cast[Ptr[uint8]]("Documents"), 1, 0)
    _emit_added(cast[Ptr[uint8]]("hello"), 0, 1)          # executable, no ext
    _emit_added(cast[Ptr[uint8]]("photo.png"), 0, 0)
    _emit_added(cast[Ptr[uint8]]("build"), 1, 0)
    fmc_sort_entries()
    hamscene_begin()
    fmc_paint()
    hamui_host_begin(LW, LH)
    hamui_host_rasterize()
    _write_ppm(path)
    _dump_model()
    return fmc_item_count()


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 5:
        _o_str(cast[Ptr[uint8]]("usage: hamfm_host BEFORE.ppm AFTER.ppm SCRATCH_DIR LISTING.ppm\n"))
        _o_flush()
        return 2

    W: int32 = 200
    H: int32 = 160

    # ---- BEFORE: the OLD empty-space menu (New Folder only) ----------------
    before_rows: Array[2, int32]
    before_rows[0] = FM_ACT_NEWFOLDER
    _draw_menu(&before_rows[0], 1)
    hamui_host_begin(W, H)
    hamui_host_rasterize()
    _write_ppm(cast[Ptr[char]](argv[1]))
    _o_str(cast[Ptr[uint8]]("BEFORE-ROWS 1\n"))
    _o_flush()

    # ---- AFTER: the shipped empty-space menu (via the shared core) ---------
    after_rows: Array[4, int32]
    nrows: int32 = fmc_menu_empty_rows(&after_rows[0], 4)
    _draw_menu(&after_rows[0], nrows)
    hamui_host_begin(W, H)
    hamui_host_rasterize()
    _write_ppm(cast[Ptr[char]](argv[2]))
    _o_str(cast[Ptr[uint8]]("AFTER-ROWS "))
    _o_dec(cast[int64](nrows))
    _o_ch(10)
    _o_flush()
    # Dump the AFTER scene display list so the gate can assert BOTH labels.
    _dump_scene()

    # ---- DRIVE the real New-File action against the scratch dir ------------
    fmc_set_cur_path(cast[Ptr[uint8]](argv[3]))
    dflt: Ptr[uint8] = fmc_new_file_default()
    _o_str(cast[Ptr[uint8]]("NEWFILE-NAME "))
    _o_str(dflt)
    _o_ch(10)
    rc: int32 = fmc_touch(dflt)
    _o_str(cast[Ptr[uint8]]("NEWFILE-RC "))
    _o_dec(cast[int64](rc))
    _o_ch(10)
    _o_flush()

    # ---- RENDER a real directory listing (sort + exec badge + count HUD) ----
    cnt: uint64 = _render_listing(cast[Ptr[char]](argv[4]))
    _o_str(cast[Ptr[uint8]]("LISTING-COUNT "))
    _o_dec(cast[int64](cnt))
    _o_ch(10)
    _o_flush()
    # Dump the listing scene so the gate can assert the count HUD text + the
    # sorted labels render as real glyphs.
    _dump_scene()

    if rc != 0:
        return 0
    return 1

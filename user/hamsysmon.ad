# user/hamsysmon.ad
#
# hamsysmon — DE pivot wave 2: the desktop system-monitor applet (CPU +
# MEM bars) extracted from daemon_pixel's dpix_root_dmon into a v2 client.

from lib.hamui import (
    hamui_init, hamui_window_on, hamui_set_protocol_v2, hamui_set_protocol_v2_dims,
    hamui_v2_clear, hamui_v2_fill_rect, hamui_v2_commit_rect,
    hamui_v2_is_active,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield()
extern def sys_exit(code: int32)


_hm_cpu: int32 = 0
_hm_mem: int32 = 0
_hm_gen: uint64 = 0
_hm_show_serial:      uint64 = 0
_hm_last_show_serial: uint64 = 0xffffffffffffffff
_hm_last_gen:         uint64 = 0xffffffffffffffff


_hm_WIN_W: int32 = 60
_hm_WIN_H: int32 = 50
_hm_BAND_H: int32 = 22

_hm_snap_buf: Array[256, uint8]

# Rolling history rings (MATE-style): the applet used to paint a single
# instantaneous CPU/MEM bar; it now keeps a scrolling history of recent
# samples and draws two mini history graphs (CPU on top, MEM below). One
# column per live sample, newest at the right, scrolling left as it fills.
_hm_HIST: uint64 = 52
_hm_cpu_hist: Array[52, uint8]
_hm_mem_hist: Array[52, uint8]
_hm_hist_n:   uint64 = 0


def _hm_ring_push(ring: Ptr[uint8], v: int32):
    vv: int32 = v
    if vv < 0:
        vv = 0
    if vv > 100:
        vv = 100
    if _hm_hist_n < _hm_HIST:
        ring[_hm_hist_n] = cast[uint8](vv)
        return
    i: uint64 = 0
    while i + 1 < _hm_HIST:
        ring[i] = ring[i + 1]
        i = i + 1
    ring[_hm_HIST - 1] = cast[uint8](vv)


# Push the current (cpu, mem) into the rings. Advances the shared count once.
def _hm_push_sample():
    _hm_ring_push(&_hm_cpu_hist[0], _hm_cpu)
    _hm_ring_push(&_hm_mem_hist[0], _hm_mem)
    if _hm_hist_n < _hm_HIST:
        _hm_hist_n = _hm_hist_n + 1


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


def _read_sysmon_snapshot() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/sysmon"))
    if fd < 0:
        return -1
    n: int64 = sys_read(fd, &_hm_snap_buf[0], 256)
    sys_close(fd)
    return n


def _parse_u64(pos: Ptr[uint64], end: uint64) -> uint64:
    p: uint64 = pos[0]
    v: uint64 = 0
    while p < end and _hm_snap_buf[p] >= 48 and _hm_snap_buf[p] <= 57:
        v = v * 10 + cast[uint64](_hm_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    return v


def _skip_ws(pos: uint64, end: uint64) -> uint64:
    p: uint64 = pos
    while p < end and (_hm_snap_buf[p] == 32 or _hm_snap_buf[p] == 9):
        p = p + 1
    return p


def _parse_snapshot(n: uint64) -> int32:
    if n == 0:
        return 0
    pos: Array[1, uint64]
    pos[0] = 0
    show_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    cpu_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    mem_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    gen_v: uint64 = _parse_u64(&pos[0], n)
    _hm_show_serial = show_v
    _hm_cpu = cast[int32](cpu_v)
    _hm_mem = cast[int32](mem_v)
    _hm_gen = gen_v
    changed: int32 = 0
    if _hm_show_serial != _hm_last_show_serial:
        changed = 1
    if _hm_gen != _hm_last_gen:
        changed = 1
    _hm_last_show_serial = _hm_show_serial
    _hm_last_gen = _hm_gen
    return changed


# Draw one rolling history graph (per-sample columns) of `ring` into the band
# [bx, by, bw, bh], troughed dark with columns in (r,g,b).
def _hm_graph(ring: Ptr[uint8], bx: int32, by: int32, bw: int32, bh: int32,
              r: uint8, g: uint8, b: uint8):
    hamui_v2_fill_rect(bx, by, bw, bh, 24, 30, 40)       # trough
    if _hm_hist_n == 0:
        return
    colw: int32 = bw / cast[int32](_hm_HIST)
    if colw < 1:
        colw = 1
    i: uint64 = 0
    while i < _hm_hist_n:
        v: int32 = cast[int32](ring[i])
        ch: int32 = v * bh / 100
        if ch > bh:
            ch = bh
        cx: int32 = bx + (bw - colw) * cast[int32](i) / cast[int32](_hm_HIST)
        if ch > 0:
            hamui_v2_fill_rect(cx, by + bh - ch, colw, ch, r, g, b)
        i = i + 1


def _paint():
    hamui_v2_clear(12, 14, 18)
    # Frame.
    hamui_v2_fill_rect(0, 0, _hm_WIN_W, 1, 90, 110, 150)
    hamui_v2_fill_rect(0, _hm_WIN_H - 1, _hm_WIN_W, 1, 90, 110, 150)
    hamui_v2_fill_rect(0, 0, 1, _hm_WIN_H, 90, 110, 150)
    hamui_v2_fill_rect(_hm_WIN_W - 1, 0, 1, _hm_WIN_H, 90, 110, 150)
    # CPU history graph (top band, green) + MEM history graph (bottom, amber).
    _hm_graph(&_hm_cpu_hist[0], 4, 4, _hm_WIN_W - 8, 20, 87, 187, 110)
    _hm_graph(&_hm_mem_hist[0], 4, 26, _hm_WIN_W - 8, 20, 250, 170, 110)
    hamui_v2_commit_rect(0, 0, _hm_WIN_W, _hm_WIN_H)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()
    wid: int32 = 1
    sfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/self"))
    if sfd >= 0:
        sbuf: Array[16, uint8]
        sn: int64 = sys_read_nb(sfd, &sbuf[0], 16)
        sys_close(sfd)
        if sn > 0:
            v: int32 = 0
            i: uint64 = 0
            while i < cast[uint64](sn) and sbuf[i] >= 48 and sbuf[i] <= 57:
                v = v * 10 + cast[int32](sbuf[i]) - 48
                i = i + 1
            if v >= 2:
                wid = v
    if argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        v2: int32 = 0
        i2: uint64 = 0
        while ap[i2] >= 48 and ap[i2] <= 57:
            v2 = v2 * 10 + cast[int32](ap[i2]) - 48
            i2 = i2 + 1
        if v2 >= 1:
            wid = v2

    bound: int32 = hamui_window_on(0, wid)
    if bound < 0:
        _puts(2, "hamsysmon: could not bind window\n")
        return 1
    if hamui_set_protocol_v2_dims(_hm_WIN_W, _hm_WIN_H) < 0:
        _puts(2, "hamsysmon: v2 negotiate failed\n")
        return 1

    n0: int64 = _read_sysmon_snapshot()
    if n0 > 0:
        _parse_snapshot(cast[uint64](n0))
    _hm_push_sample()
    _paint()
    rdy: Ptr[uint8] = "HAMSYSMON ready\n"
    sys_write(1, rdy, _strlen(rdy))

    while True:
        n: int64 = _read_sysmon_snapshot()
        if n > 0:
            if _parse_snapshot(cast[uint64](n)) != 0:
                _hm_push_sample()
                _paint()
        sys_yield()

    return 0

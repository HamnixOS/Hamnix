# user/ls.ad
#
# Minimal Hamnix `ls`. Two modes:
#
#   ls [path]           — fast path: p9_listdir reads the directory's
#                         NAME\n line stream (the legacy DEV_DIR_FILE
#                         backing) and we dump it straight to stdout.
#                         No per-entry stat, no extra syscalls. The
#                         "default" mode every other caller (du
#                         pre-migration, getdents64, sh's tab-complete)
#                         still relies on.
#
#   ls -l [path]        — F10-6 followup: open the directory, flip its
#                         Chan into Dir-record mode via SYS_CHAN_DIR_MODE
#                         (319), then read Plan-9 Dir records back with
#                         sys_read into a buffer and decode them with
#                         p9_dir_decode_at. Per-entry mode + size + uid
#                         come from the kernel-side stat ladder
#                         (vfs_dir_xform_to_records) — no per-leaf
#                         re-stat from userland. Output format:
#                             <mode-string> <uid> <size>\t<name>
#                         where <mode-string> renders the perm-bits + a
#                         leading 'd' for QTDIR.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_getcwd(buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
from lib.p9 import (
    p9_listdir, p9_chan_dir_mode, p9_dir_decode_at,
    DIR_CUR_NAME, DIR_CUR_NAME_LEN,
    DIR_CUR_UID, DIR_CUR_UID_LEN,
    DIR_CUR_MODE, DIR_CUR_LENGTH, DIR_CUR_QTYPE,
)
from lib.p9dir import P9_DMDIR
from lib.9p.9p import P9_QTDIR


LISTBUF:  uint64 = 4096


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def write_dec(fd: int32, v: uint64):
    if v == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[20, uint8]
    di: uint64 = 0
    while v > 0:
        digits[di] = cast[uint8]((v % 10) + 48)
        v = v / 10
        di = di + 1
    while di > 0:
        di = di - 1
        sys_write(fd, &digits[di], 1)


# BSS scratch buffers — Adder quirks: module-scope BSS only.
ls_buf: Array[4096, uint8]
ls_modebuf: Array[12, uint8]


def render_mode(qtype: uint8, mode: uint32, out: Ptr[uint8]):
    # Render "drwxr-xr-x" / "-rw-r--r--" / etc. into `out` (10 bytes,
    # NUL-terminated at index 10). Type char + 9 perm chars. Honours the
    # DMDIR bit in `mode` AND the qtype byte — either marks a directory.
    if qtype == P9_QTDIR or (mode & P9_DMDIR) != 0:
        out[0] = 100                                    # 'd'
    else:
        out[0] = 45                                     # '-'
    # 9 perm bits: rwxrwxrwx, mask 0777.
    perms: uint32 = mode & 0x1FF
    bits: Array[9, uint32]
    bits[0] = 0x100
    bits[1] = 0x080
    bits[2] = 0x040
    bits[3] = 0x020
    bits[4] = 0x010
    bits[5] = 0x008
    bits[6] = 0x004
    bits[7] = 0x002
    bits[8] = 0x001
    chars: Array[9, uint8]
    chars[0] = 114                                      # 'r'
    chars[1] = 119                                      # 'w'
    chars[2] = 120                                      # 'x'
    chars[3] = 114
    chars[4] = 119
    chars[5] = 120
    chars[6] = 114
    chars[7] = 119
    chars[8] = 120
    i: uint64 = 0
    while i < 9:
        if (perms & bits[i]) != 0:
            out[1 + i] = chars[i]
        else:
            out[1 + i] = 45                              # '-'
        i = i + 1
    out[10] = 0


def ls_long(target: Ptr[char]) -> int32:
    # F10-6 followup: open the directory, flip into Dir-record mode,
    # read records back via sys_read. The dir-fd's read backing carries
    # the Dir-record buffer (post-transform) so a single sys_read draws
    # all records; we then walk them with p9_dir_decode_at.
    fd: int32 = sys_open(target)
    if fd < 0:
        write_str(2, "ls: open failed: ")
        write_str(2, cast[Ptr[uint8]](target))
        write_str(2, "\n")
        return 1
    if p9_chan_dir_mode(fd, 1, target) != 0:
        # Backing doesn't support Dir-record mode yet. Fall back to the
        # cheap line-stream path (which is the legacy ls behaviour).
        sys_close(fd)
        n_fb: int64 = p9_listdir(target, &ls_buf[0], LISTBUF)
        if n_fb < 0:
            write_str(2, "ls: listdir failed\n")
            return 1
        sys_write(1, &ls_buf[0], cast[uint64](n_fb))
        return 0
    # Drain the Dir-record stream into ls_buf.
    total: uint64 = 0
    while total < LISTBUF:
        slice_ptr: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](&ls_buf[0]) + total)
        n: int64 = sys_read(fd, slice_ptr, LISTBUF - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    # Walk records.
    off: uint64 = 0
    while off < total:
        rl: uint64 = p9_dir_decode_at(&ls_buf[0], off, total)
        if rl == 0:
            break
        render_mode(DIR_CUR_QTYPE, DIR_CUR_MODE,
                    cast[Ptr[uint8]](&ls_modebuf[0]))
        sys_write(1, &ls_modebuf[0], 10)
        sys_write(1, " ", 1)
        if DIR_CUR_UID_LEN > 0:
            sys_write(1, &DIR_CUR_UID[0], DIR_CUR_UID_LEN)
        else:
            sys_write(1, "-", 1)
        sys_write(1, " ", 1)
        write_dec(1, DIR_CUR_LENGTH)
        sys_write(1, "\t", 1)
        sys_write(1, &DIR_CUR_NAME[0], DIR_CUR_NAME_LEN)
        sys_write(1, "\n", 1)
        off = off + rl
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # Args: optionally "-l", followed by an optional target path.
    long_mode: int32 = 0
    cwd_buf: Array[256, uint8]
    target: Ptr[char] = cast[Ptr[char]]("/")
    i: int32 = 1
    have_target: int32 = 0
    while i < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[i])
        if a[0] == 45 and a[1] == 108 and a[2] == 0:        # "-l"
            long_mode = 1
        else:
            target = cast[Ptr[char]](argv[i])
            have_target = 1
        i = i + 1
    if have_target == 0:
        cn: int64 = sys_getcwd(&cwd_buf[0], 256)
        if cn > 0:
            target = cast[Ptr[char]](&cwd_buf[0])
    if long_mode != 0:
        return ls_long(target)
    # Plain ls: line-stream path, unchanged.
    n: int64 = p9_listdir(target, &ls_buf[0], LISTBUF)
    if n < 0:
        write_str(2, "ls: listdir failed: ")
        write_str(2, cast[Ptr[uint8]](target))
        write_str(2, "\n")
        return 1
    sys_write(1, &ls_buf[0], cast[uint64](n))
    return 0

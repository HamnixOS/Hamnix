# user/hamsdl_jpeg_host.ad — HOST render+drive harness for the hamSDL/hamGame
# IMAGE LOADER's JPEG path (the last common pygame.image.load format after
# BMP + PNG). It loads a BASELINE JPEG sprite FILE off disk through the exact
# format-sniff dispatch a pygame game hits (game_host_load_image ->
# game_load_image -> FF D8 FF -> game_load_jpeg -> lib/jpeg.ad), blits the
# decoded Surface onto a red display Surface, rasterizes the frame to a PPM a
# human/agent can LOOK at, and dumps sampled pixels so
# scripts/test_hamsdl_jpeg_host.sh can ASSERT the file -> Surface -> blit -> PNG
# path is colour-correct WITHOUT eyeballing.
#
# JPEG is LOSSY, so the gate asserts each channel within a tolerance of the
# source colour (not exact equality). The fixture is a 16x16 two-region image
# (left half teal, right half orange) so a sample nails BOTH the colour AND the
# spatial position after a real DCT/Huffman/YCbCr decode.
#
# USAGE (built to build/host/hamsdl_jpeg_host):
#   hamsdl_jpeg_host FIXTURE.jpg OUT.ppm

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

from lib.hamgame import game_reset, game_display_new, game_surface_fill, \
    game_surface_get_pixel, game_surface_w, game_surface_h, \
    game_surface_blit, game_flip_scene, game_rgb
from lib.hamgame_host import game_host_present, game_host_write_ppm, \
    game_host_pixel, game_host_load_image


DW: int32 = 64
DH: int32 = 64
SX: int32 = 8                            # where the JPEG sprite is blitted
SY: int32 = 8


# ---- stdout helpers (mirrors user/hamsdl_image_host.ad) ------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# Dump a surface pixel as label + R G B (decimal channels, tolerance-checked).
def _o_surfrgb(label: Ptr[uint8], s: int32, x: int32, y: int32):
    px: uint32 = game_surface_get_pixel(s, x, y)              # 0xRRGGBBAA
    _o_str(label)
    _o_dec(cast[int64]((px >> 24) & 255))
    _o_ch(32)
    _o_dec(cast[int64]((px >> 16) & 255))
    _o_ch(32)
    _o_dec(cast[int64]((px >> 8) & 255))
    _o_ch(10)


# Dump a rasterized framebuffer pixel as label + R G B (0x00RRGGBB).
def _o_fbrgb(label: Ptr[uint8], x: int32, y: int32):
    px: uint32 = game_host_pixel(x, y)
    _o_str(label)
    _o_dec(cast[int64]((px >> 16) & 255))
    _o_ch(32)
    _o_dec(cast[int64]((px >> 8) & 255))
    _o_ch(32)
    _o_dec(cast[int64](px & 255))
    _o_ch(10)


def _o_kv(k: Ptr[uint8], v: int64):
    _o_str(k)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hamsdl_jpeg_host FIX.jpg OUT.ppm\n"))
        _o_flush()
        return 2

    game_reset()

    # ---- 1. Load the baseline JPEG FILE through the format sniff ---------
    sj: int32 = game_host_load_image(cast[Ptr[char]](argv[1]))
    _o_kv(cast[Ptr[uint8]]("SJ"), cast[int64](sj))
    if sj < 0:
        _o_flush()
        return 1
    _o_kv(cast[Ptr[uint8]]("SJW"), cast[int64](game_surface_w(sj)))
    _o_kv(cast[Ptr[uint8]]("SJH"), cast[int64](game_surface_h(sj)))
    # Decode correctness straight off the Surface (no raster yet). Fixture:
    #   left half  (x<8) teal   (0,160,160); right half (x>=8) orange (230,120,20).
    _o_surfrgb(cast[Ptr[uint8]]("SJ_L "), sj, 2, 2)      # ~ 0 160 160
    _o_surfrgb(cast[Ptr[uint8]]("SJ_L2 "), sj, 4, 8)     # ~ 0 160 160
    _o_surfrgb(cast[Ptr[uint8]]("SJ_R "), sj, 12, 4)     # ~ 230 120 20
    _o_surfrgb(cast[Ptr[uint8]]("SJ_R2 "), sj, 13, 13)   # ~ 230 120 20

    # ---- 2. Compose: red background + the decoded sprite ----------------
    disp: int32 = game_display_new(DW, DH)
    game_surface_fill(disp, game_rgb(255, 0, 0))         # opaque red backdrop
    game_surface_blit(disp, sj, SX, SY)

    # ---- 3. Rasterize the frame to a PPM + sample the framebuffer -------
    game_flip_scene(disp)
    prims: int32 = game_host_present(disp)
    game_host_write_ppm(cast[Ptr[char]](argv[2]))
    _o_kv(cast[Ptr[uint8]]("PRIMS"), cast[int64](prims))

    # Background stays pure red where nothing was blitted.
    _o_fbrgb(cast[Ptr[uint8]]("FB_BG "), 2, 2)                     # 255 0 0
    # JPEG sprite corners land at the blit offset (opaque -> ~source colours).
    _o_fbrgb(cast[Ptr[uint8]]("FB_L "), SX + 2, SY + 2)           # ~ 0 160 160
    _o_fbrgb(cast[Ptr[uint8]]("FB_R "), SX + 12, SY + 4)          # ~ 230 120 20
    _o_flush()
    return 0

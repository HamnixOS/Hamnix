# user/hamgamechess.ad — "Chess", the hamGame board game, DEVICE build.
#
# A thin driver: it wires the hamGame device backend (lib/hamgame_dev.ad) to the
# shared, target-agnostic game in lib/hamgamechess.ad. All drawing, input and
# timing go through the PUBLIC hamGame API — this file has NO game logic and NO
# raw transport of its own. The HOST render gate (user/hamgamechess_host.ad)
# drives the SAME lib/hamgamechess.ad.
#
# INPUT MODEL: the board is driven by mouse clicks — click a piece to select its
# square, click a destination to attempt the move (chess_move validates it). A
# right-click / re-click clears the selection.

from lib.hamgame import game_poll_event, game_set_fps, game_frame_ms, \
    game_clock_tick, game_flip_scene, \
    GAME_QUIT, GAME_MOUSEDOWN
from lib.hamgame_dev import game_dev_init, game_dev_pump, game_dev_present, \
    game_dev_ticks, game_dev_delay
from lib.hamgamechess import ch_init, ch_render, ch_display_surf, chess_move, \
    ch_cell_px_x, ch_cell_px_y, CH_CELL, CH_N, CH_HUD, CH_MARGIN


CHW: int32 = 208                                         # MARGIN + N*CELL
CHH: int32 = 232                                         # HUD + N*CELL + BOTTOM

sel_sq: int32 = -1                                       # selected source square


# Map a pixel (x,y) to a board square, or -1 if outside the board.
def _pick_square(x: int32, y: int32) -> int32:
    if x < CH_MARGIN or y < CH_HUD:
        return -1
    col: int32 = (x - CH_MARGIN) / CH_CELL
    row: int32 = (y - CH_HUD) / CH_CELL
    if col < 0 or col >= CH_N or row < 0 or row >= CH_N:
        return -1
    return row * 8 + col


def _on_click(x: int32, y: int32):
    sq: int32 = _pick_square(x, y)
    if sq < 0:
        sel_sq = -1
        return
    if sel_sq < 0:
        sel_sq = sq
        return
    chess_move(sel_sq, sq)                               # validated internally
    sel_sq = -1


def main() -> int32:
    wid: int32 = game_dev_init(cast[Ptr[uint8]]("Chess"),
                               260, 120, CHW, CHH)
    if wid < 0:
        return 1
    ch_init(CHW, CHH)
    game_set_fps(30)

    kind: int32 = 0
    key: int32 = 0
    ex: int32 = 0
    ey: int32 = 0
    ebtn: int32 = 0
    while True:
        game_dev_pump()
        while game_poll_event(&kind, &key, &ex, &ey, &ebtn) == 1:
            if kind == GAME_QUIT:
                return 0
            if kind == GAME_MOUSEDOWN:
                _on_click(ex, ey)
        game_clock_tick(game_dev_ticks())
        ch_render()
        game_flip_scene(ch_display_surf())
        game_dev_present(ch_display_surf())
        game_dev_delay(cast[uint64](game_frame_ms()))
    return 0

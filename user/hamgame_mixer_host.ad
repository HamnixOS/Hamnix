# user/hamgame_mixer_host.ad — HOST harness for the hamGame MIXER (pygame.mixer
# shaped tone synthesis + multi-voice software mixing over lib/hammixer.ad, wired
# through lib/hamgame.ad). Driven by scripts/test_hamsdl_mixer_host.sh with NO
# QEMU and NO audio hardware.
#
# It proves, on the raw PCM the mixer produces (the buffer a device would stream
# to /dev/audio):
#   * game_synth_tone renders a 440 Hz square, 50 ms, vol 128 at 22050 Hz to the
#     RIGHT length (rate*dur = 1102 frames) with the RIGHT period — 44 sign
#     changes == 2*freq*dur_s zero crossings — and full amplitude (32767);
#   * halving the volume halves the amplitude (16383) — linear volume scaling;
#   * MIXING two in-phase full-scale tones SATURATES: the summed sample is a
#     POSITIVE 32767 (a wrap-on-overflow would flip it negative), and the mix
#     peak is exactly the s16 ceiling — teeth that catch a missing clamp;
#   * the mixer tracks concurrent VOICES and drains them;
#   * game_load_sound decodes a 16-bit WAV buffer (lib/wavdecode) to a Sound.
#
# argv: 1 = path to a 16-bit mono WAV fixture.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamgame import game_mixer_init, game_mixer_rate, game_synth_tone, \
    game_play_tone, game_load_sound, game_sound_samples, game_sound_rate, \
    game_play_sound, game_mixer_voices, game_mixer_render, game_stop_all_sounds


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(s: Ptr[uint8]):
    sys_write(1, s, _slen(s))


_numbuf: Array[24, uint8]


def _kv(label: Ptr[uint8], v: int64):
    _puts(label)
    sys_write(1, cast[Ptr[uint8]](" "), 1)
    neg: int32 = 0
    u: uint64 = 0
    if v < 0:
        neg = 1
        u = cast[uint64](0 - v)
    else:
        u = cast[uint64](v)
    if u == 0:
        _numbuf[0] = 48
        sys_write(1, &_numbuf[0], 1)
    else:
        tmp: Array[24, uint8]
        n: uint64 = 0
        while u > 0:
            tmp[n] = cast[uint8](u % 10) + 48
            u = u / 10
            n = n + 1
        p: uint64 = 0
        if neg == 1:
            _numbuf[p] = 45
            p = p + 1
        i: uint64 = 0
        while i < n:
            _numbuf[p] = tmp[n - 1 - i]
            p = p + 1
            i = i + 1
        sys_write(1, &_numbuf[0], p)
    sys_write(1, cast[Ptr[uint8]]("\n"), 1)


# ---- s16le read + buffer stats ------------------------------------------
def _rd16(buf: Ptr[uint8], i: uint64) -> int32:
    raw: uint32 = cast[uint32](buf[i]) | (cast[uint32](buf[i + 1]) << 8)
    s: int32 = cast[int32](raw)
    if s >= 32768:
        s = s - 65536
    return s


def _iabs(v: int32) -> int32:
    if v < 0:
        return 0 - v
    return v


# Count sign changes (zero crossings) across a mono s16le buffer of `frames`.
def _sign_changes(buf: Ptr[uint8], frames: uint64) -> int32:
    if frames < 2:
        return 0
    n: int32 = 0
    prev: int32 = _rd16(buf, 0)
    i: uint64 = 1
    while i < frames:
        cur: int32 = _rd16(buf, i * 2)
        ppos: int32 = 0
        if prev > 0:
            ppos = 1
        cpos: int32 = 0
        if cur > 0:
            cpos = 1
        if cur != 0 and ppos != cpos:
            n = n + 1
        if cur != 0:
            prev = cur
        i = i + 1
    return n


def _peak(buf: Ptr[uint8], frames: uint64) -> int32:
    pk: int32 = 0
    i: uint64 = 0
    while i < frames:
        a: int32 = _iabs(_rd16(buf, i * 2))
        if a > pk:
            pk = a
        i = i + 1
    return pk


def _min_sample(buf: Ptr[uint8], frames: uint64) -> int32:
    mn: int32 = 32767
    i: uint64 = 0
    while i < frames:
        s: int32 = _rd16(buf, i * 2)
        if s < mn:
            mn = s
        i = i + 1
    return mn


def _max_sample(buf: Ptr[uint8], frames: uint64) -> int32:
    mx: int32 = 0 - 32768
    i: uint64 = 0
    while i < frames:
        s: int32 = _rd16(buf, i * 2)
        if s > mx:
            mx = s
        i = i + 1
    return mx


TONE_CAP: uint64 = 16384                     # 8192 frames of scratch
_tone: Array[16384, uint8]
_mix:  Array[16384, uint8]
_filebuf: Array[262144, uint8]


def _read_file(path: Ptr[char]) -> int64:
    fd: int32 = sys_open(path, 0, 0)
    if fd < 0:
        return -1
    n: uint64 = 0
    while n < 262144:
        r: int64 = sys_read(fd, &_filebuf[n], 262144 - n)
        if r <= 0:
            break
        n = n + cast[uint64](r)
    sys_close(fd)
    return cast[int64](n)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    game_mixer_init(22050)
    _kv(cast[Ptr[uint8]]("RATE"), cast[int64](game_mixer_rate()))

    # --- 1. synthesize a 440 Hz square, 50 ms, full volume -----------------
    bytes: uint64 = game_synth_tone(&_tone[0], TONE_CAP, 440, 50, 128)
    frames: uint64 = bytes / 2
    _kv(cast[Ptr[uint8]]("TONE_BYTES"), cast[int64](bytes))
    _kv(cast[Ptr[uint8]]("TONE_FRAMES"), cast[int64](frames))
    _kv(cast[Ptr[uint8]]("TONE_ZC"),
        cast[int64](_sign_changes(&_tone[0], frames)))
    _kv(cast[Ptr[uint8]]("TONE_PEAK"), cast[int64](_peak(&_tone[0], frames)))

    # --- 2. half volume -> half amplitude (linear scaling) -----------------
    hbytes: uint64 = game_synth_tone(&_tone[0], TONE_CAP, 440, 50, 64)
    _kv(cast[Ptr[uint8]]("TONE_PEAK_HALF"),
        cast[int64](_peak(&_tone[0], hbytes / 2)))

    # --- 3. mix two in-phase full-scale tones -> SATURATION ----------------
    game_stop_all_sounds()
    v0: int32 = game_play_tone(440, 50, 128)
    v1: int32 = game_play_tone(440, 50, 128)
    _kv(cast[Ptr[uint8]]("PLAY_V0"), cast[int64](v0))
    _kv(cast[Ptr[uint8]]("PLAY_V1"), cast[int64](v1))
    _kv(cast[Ptr[uint8]]("VOICES_BEFORE"), cast[int64](game_mixer_voices()))
    mbytes: uint64 = game_mixer_render(&_mix[0], 1102)
    mframes: uint64 = mbytes / 2
    # First sample: both voices in the HIGH half -> +32767 + +32767 = 65534,
    # which MUST clamp to +32767 (an unclamped s16 store would wrap to -2).
    _kv(cast[Ptr[uint8]]("MIX_FIRST"), cast[int64](_rd16(&_mix[0], 0)))
    _kv(cast[Ptr[uint8]]("MIX_PEAK"), cast[int64](_max_sample(&_mix[0], mframes)))
    _kv(cast[Ptr[uint8]]("MIX_MIN"), cast[int64](_min_sample(&_mix[0], mframes)))
    _kv(cast[Ptr[uint8]]("VOICES_AFTER"), cast[int64](game_mixer_voices()))

    # --- 4. load a 16-bit WAV buffer into a Sound --------------------------
    if argc >= 2:
        path: Ptr[char] = cast[Ptr[char]](argv[1])
        got: int64 = _read_file(path)
        _kv(cast[Ptr[uint8]]("WAV_BYTES"), got)
        if got > 0:
            snd: int32 = game_load_sound(&_filebuf[0], cast[uint64](got))
            _kv(cast[Ptr[uint8]]("SND_SLOT"), cast[int64](snd))
            if snd >= 0:
                _kv(cast[Ptr[uint8]]("SND_RATE"),
                    cast[int64](game_sound_rate(snd)))
                _kv(cast[Ptr[uint8]]("SND_SAMPLES"),
                    cast[int64](game_sound_samples(snd)))
                pv: int32 = game_play_sound(snd)
                _kv(cast[Ptr[uint8]]("SND_PLAY_V"), cast[int64](pv))

    _puts(cast[Ptr[uint8]]("RESULT ok\n"))
    return 0

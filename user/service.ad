# user/service.ad — native service-management command.
#
#   service <name> start | stop | restart | status
#   service <name> enable | disable
#   service status                 # list all services
#   service list                   # alias for `service status`
#
# WHY A NATIVE COMMAND TALKING TO PID 1
# -------------------------------------
# The real service supervisor lives in PID 1 (hamsh) — it owns the live
# registry, the spawn-into-namespace path, the reap/restart loop, and
# the per-service log capture. A separate process therefore can't touch
# that table directly. Two kernel rendezvous bridge the gap:
#
#   * READ  — /proc/svc/<name> is a kernel mirror the supervisor keeps
#             up to date via SYS_SVC_PUBLISH. `service status` just
#             cats it, so status works from ANY process.
#   * WRITE — SYS_SVC_CTL is a small control mailbox. `service <name>
#             start|stop|restart|enable|disable` enqueues a request;
#             PID 1's supervisor drains the queue on its next tick and
#             dispatches. The action is asynchronous from the caller's
#             point of view (it returns as soon as the request is
#             queued); `service <name> status` afterwards reflects the
#             result once the supervisor has acted.
#
# This keeps ONE supervisor (no duplicate state) while giving a sysadmin
# the familiar `service nginx restart` ergonomics as a real binary.
#
# DECLARATIVE, USER-ADDABLE SERVICE DEFINITIONS
# ---------------------------------------------
# A service is added by dropping a text file at
#   /etc/services.d/<name>.svc
# No recompilation, no code — the supervisor parses it the first time
# the service is referenced (`service <name> start`, or autostart at the
# service's runlevel). The grammar is `key: value`, one per line, `#` to
# end-of-line is a comment, blank lines ignored:
#
#   name:           <service name>                 (required)
#   exec:           /path/to/binary [args...]       (required)
#   ns:             init | <captured-namespace>     (required; usually init)
#   description:    free text                        (optional)
#   restart:        always | on-failure | never      (optional; on-failure)
#   backoff_ms:     <initial restart backoff ms>      (optional; 1000)
#   backoff_max_ms: <restart backoff ceiling ms>       (optional; 30000)
#   uid:            <numeric uid to run as>             (optional; 1)
#   enabled:        yes | no                            (optional; yes)
#   runlevel:       <space/comma-separated digits>       (optional; 3)
#
# Example /etc/services.d/myweb.svc:
#   name: myweb
#   exec: /bin/httpd
#   ns: init
#   description: my static web server
#   restart: on-failure
#   enabled: yes
#   runlevel: 3 5
#
# `enabled` + `runlevel` are the init-system layer: an enabled service
# whose runlevel mask includes the current runlevel is started when that
# runlevel is entered (see user/initctl.ad and /etc/rc.d/rc.*).

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)
# Service-control mailbox RPC (verbs 1..6 enqueue from any process):
#   1 start  2 stop  3 restart  4 enable  5 disable  6 runlevel
extern def sys_svc_ctl(verb: int32, name: Ptr[uint8], cap: uint64) -> int64


CTL_START:   int32 = 1
CTL_STOP:    int32 = 2
CTL_RESTART: int32 = 3
CTL_ENABLE:  int32 = 4
CTL_DISABLE: int32 = 5


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def cstr_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while True:
        if a[i] != b[i]:
            return 0
        if a[i] == 0:
            return 1
        i = i + 1


def cat_path(path: Ptr[char]) -> int32:
    # Stream a file to stdout. Returns 0 on success, -1 if it can't be
    # opened. Used to surface /proc/svc[/<name>].
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    buf: Array[256, uint8]
    while True:
        n: int64 = sys_read(fd, &buf[0], 256)
        if n <= 0:
            break
        sys_write(1, &buf[0], cast[uint64](n))
    sys_close(fd)
    return 0


# /proc/svc/<name> path builder.
svc_proc_path: Array[64, uint8]


def build_proc_path(name: Ptr[uint8]):
    prefix: Ptr[uint8] = "/proc/svc/"
    i: uint64 = 0
    while prefix[i] != 0:
        svc_proc_path[i] = prefix[i]
        i = i + 1
    j: uint64 = 0
    while name[j] != 0 and i + 1 < 64:
        svc_proc_path[i] = name[j]
        i = i + 1
        j = j + 1
    svc_proc_path[i] = 0


def do_status(name: Ptr[uint8]):
    # `service status` (no name) -> whole list; `service <name> status`
    # -> single entry. Both render the kernel mirror at /proc/svc.
    if cast[uint64](name) == 0:
        if cat_path("/proc/svc") < 0:
            write_str(2, "service: /proc/svc unavailable\n")
        return
    build_proc_path(name)
    if cat_path(cast[Ptr[char]](&svc_proc_path[0])) < 0:
        write_str(2, "service: /proc/svc unavailable\n")


def do_ctl(verb: int32, name: Ptr[uint8], action: Ptr[uint8]) -> int32:
    # Enqueue a control request for PID 1's supervisor. Returns 0; the
    # action is applied asynchronously by the supervisor tick.
    rc: int64 = sys_svc_ctl(verb, name, 0)
    if rc < 0:
        write_str(2, "service: control request failed\n")
        return 1
    write_str(1, "service: ")
    write_str(1, name)
    write_str(1, " ")
    write_str(1, action)
    write_str(1, " requested\n")
    return 0


def usage():
    write_str(2, "usage: service <name> start|stop|restart|status|")
    write_str(2, "enable|disable\n")
    write_str(2, "       service status            # list all\n")


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # Forms:
    #   service                       -> list
    #   service status                -> list
    #   service list                  -> list
    #   service <name> <verb>         -> control / status one
    #   service <name>                -> status one
    if argc < 2:
        do_status(cast[Ptr[uint8]](0))
        return 0
    a1: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    if cstr_eq(a1, "status") != 0 or cstr_eq(a1, "list") != 0:
        # `service status [<name>]`
        if argc >= 3:
            do_status(cast[Ptr[uint8]](argv[2]))
        else:
            do_status(cast[Ptr[uint8]](0))
        return 0
    # First arg is a service name.
    name: Ptr[uint8] = a1
    if argc < 3:
        # `service <name>` with no verb -> status of that service.
        do_status(name)
        return 0
    verb: Ptr[uint8] = cast[Ptr[uint8]](argv[2])
    if cstr_eq(verb, "status") != 0:
        do_status(name)
        return 0
    if cstr_eq(verb, "start") != 0:
        return do_ctl(CTL_START, name, "start")
    if cstr_eq(verb, "stop") != 0:
        return do_ctl(CTL_STOP, name, "stop")
    if cstr_eq(verb, "restart") != 0:
        return do_ctl(CTL_RESTART, name, "restart")
    if cstr_eq(verb, "enable") != 0:
        return do_ctl(CTL_ENABLE, name, "enable")
    if cstr_eq(verb, "disable") != 0:
        return do_ctl(CTL_DISABLE, name, "disable")
    usage()
    return 1

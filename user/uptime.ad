# user/uptime.ad
#
# Hamnix `uptime`: reads /proc/uptime and emits "up N seconds\n".
#
# TWO renderers can back /proc/uptime and they use DIFFERENT units — this
# command silently reported uptime/100 (e.g. "up 1 seconds" at 100 s) until
# it learned to tell them apart:
#
#   * `#c/uptime` (sys/src/9/port/devuptime.ad) — what the root namespace
#     actually binds today (see chan.ad's "/proc/uptime -> #c/uptime").
#     Linux-shaped: "<seconds>.<CC> <idle>.<CC>\n". Leading digits = SECONDS.
#   * fs/procfs.ad's render_uptime (legacy arm, still reachable) —
#     "<cs> cs (<j> jiffies)\n". Leading digits = CENTISECONDS.
#
# Discriminate on the character that terminates the leading digit run: a '.'
# means the fractional Linux form, so the digits are already seconds; anything
# else means the legacy centisecond form, so divide by 100.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def write_dec(v: uint64):
    if v == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    i: uint64 = 0
    while v != 0:
        digits[i] = cast[uint8](v % 10) + 48
        v = v / 10
        i = i + 1
    out: Array[24, uint8]
    j: uint64 = 0
    while j < i:
        out[j] = digits[i - 1 - j]
        j = j + 1
    sys_write(1, &out[0], i)


def main() -> int32:
    fd: int32 = sys_open("/proc/uptime")
    if fd < 0:
        sys_write(2, "uptime: cannot open /proc/uptime\n", 33)
        return 1
    buf: Array[64, uint8]
    n: int64 = sys_read(fd, &buf[0], 64)
    sys_close(fd)
    if n <= 0:
        return 1
    lead: uint64 = 0
    i: uint64 = 0
    nu: uint64 = cast[uint64](n)
    while i < nu and buf[i] >= 48 and buf[i] <= 57:
        lead = lead * 10 + cast[uint64](buf[i] - 48)
        i = i + 1
    # '.' (46) terminating the digits => Linux form, `lead` is already seconds.
    # Otherwise => legacy "<cs> cs" form, `lead` is centiseconds.
    secs: uint64 = lead
    if i >= nu or buf[i] != 46:
        secs = lead / 100
    sys_write(1, "up ", 3)
    write_dec(secs)
    sys_write(1, " seconds\n", 9)
    return 0

# user/hamcalscene_host.ad — HOST driver + render harness for the Calendar
# scene app (built for x86_64-linux; runs on the dev host, no QEMU).
#
# Drives the SAME core the native app ships (lib/hamcalcore.ad): seeds a
# DETERMINISTIC "today" (2026-07-12), builds the month grid, rasterizes it to
# a PPM a human/agent can LOOK at, then feeds a scripted prev-month pointer
# click and re-renders an "after" PPM. Dumps the scene display list, sampled
# pixels and the visible month for machine assertions. Reads argv, writes two
# files — no sockets, no Plan 9.
#
# USAGE (built to build/host/hamcal_host):
#   hamcal_host BEFORE.ppm AFTER.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamcalcore import hamcal_set_today, hamcal_set_now, hamcal_set_uptime, \
    hamcal_build_scene, hamcal_click, hamcal_key, hamcal_month, hamcal_year, \
    hamcal_sel_day, hamcal_sw_running


obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hamcal_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


def _dump_scene(tag: Ptr[uint8]):
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN "))
    _o_str(tag)
    _o_ch(10)
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()


# Feed one CSI arrow: ESC '[' <final>. finals: A=Up B=Down C=Right D=Left.
def _arrow(final: int32):
    hamcal_key(27)
    hamcal_key(91)
    hamcal_key(final)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hamcal_host BEFORE.ppm AFTER.ppm\n"))
        _o_flush()
        return 2

    W: int32 = 236
    H: int32 = 366
    # Deterministic "today": 2026-07-12. Selection defaults to today.
    hamcal_set_today(2026, 7, 12)
    hamcal_set_now(0)
    # Deterministic uptime: 1h 02m 03s since boot -> "1:02:03".
    hamcal_set_uptime(3723000000000)

    # ---- STAGE A: initial view (today selected, stopwatch idle) ----------
    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))
    _o_str(cast[Ptr[uint8]]("PRIMS "))
    _o_dec(cast[int64](prims))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("MONTH0 "))
    _o_dec(cast[int64](hamcal_month()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("YEAR0 "))
    _o_dec(cast[int64](hamcal_year()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SEL0 "))
    _o_dec(cast[int64](hamcal_sel_day()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 2 40 "))
    _o_hexcol(hamui_host_pixel(2, 40))                 # window bg #d4d0c8
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 4 4 "))
    _o_hexcol(hamui_host_pixel(4, 4))                  # title bar #3a6ea5
    _o_ch(10)
    _o_flush()
    _dump_scene(cast[Ptr[uint8]]("A"))                 # expect "today"

    # ---- STAGE B: click day 5 (July 5 2026 = row1 col0 -> centre 22,115) --
    #      2026-07-05 is 7 days before today (the 12th) -> "7 days ago".
    ch: int32 = hamcal_click(22, 115)
    _o_str(cast[Ptr[uint8]]("DAYCLICK "))
    _o_dec(cast[int64](ch))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SELDAY "))
    _o_dec(cast[int64](hamcal_sel_day()))
    _o_ch(10)
    _o_flush()
    _render(W, H)
    _dump_scene(cast[Ptr[uint8]]("B"))                 # expect "7 days ago"

    # ---- STAGE C: arrow keys. Right x3 (5->8), Down (8->15). 15-12=3 -> "in
    #      3 days".
    _arrow(67)
    _arrow(67)
    _arrow(67)
    _o_str(cast[Ptr[uint8]]("SELDAY_R "))
    _o_dec(cast[int64](hamcal_sel_day()))
    _o_ch(10)
    _arrow(66)
    _o_str(cast[Ptr[uint8]]("SELDAY_D "))
    _o_dec(cast[int64](hamcal_sel_day()))
    _o_ch(10)
    _o_flush()

    # ---- STAGE D: stopwatch. Start, advance 250 jiffies (2.50s) ----------
    hamcal_set_now(0)
    hamcal_click(42, 319)                              # Start button centre
    _o_str(cast[Ptr[uint8]]("SWRUN "))
    _o_dec(cast[int64](hamcal_sw_running()))
    _o_ch(10)
    hamcal_set_now(250)
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))               # AFTER: sel + running SW
    _dump_scene(cast[Ptr[uint8]]("D"))                 # expect "00:02.50","in 3 days"
    _o_flush()

    # ---- STAGE E: Stop freezes elapsed; further time does NOT advance -----
    hamcal_click(118, 319)                             # Stop button centre
    hamcal_set_now(999)
    _o_str(cast[Ptr[uint8]]("SWRUN2 "))
    _o_dec(cast[int64](hamcal_sw_running()))
    _o_ch(10)
    _render(W, H)
    _dump_scene(cast[Ptr[uint8]]("E"))                 # still "00:02.50"

    # ---- STAGE F: Reset zeroes it ----------------------------------------
    hamcal_click(194, 319)                             # Reset button centre
    _render(W, H)
    _dump_scene(cast[Ptr[uint8]]("F"))                 # "00:00.00"

    # ---- STAGE G: month nav. Next-month arrow (NEXT_X=204 -> centre 216,45).
    hamcal_click(216, 45)
    _o_str(cast[Ptr[uint8]]("MONTH1 "))
    _o_dec(cast[int64](hamcal_month()))
    _o_ch(10)
    _o_flush()

    # ---- STAGE H: adjacent-month spill click. Jump back to today (July via the
    #      "Today" button), then click the LEADING grey cell (col0,row0 = the
    #      previous month's June 28). Expect the view to flip to June (6) and
    #      select the 28th.
    hamcal_click(194, 246)                             # "Today" button -> July
    hamcal_click(22, 89)                               # leading spill cell
    _o_str(cast[Ptr[uint8]]("SPILL_M "))
    _o_dec(cast[int64](hamcal_month()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SPILL_D "))
    _o_dec(cast[int64](hamcal_sel_day()))
    _o_ch(10)
    _o_flush()
    return 0

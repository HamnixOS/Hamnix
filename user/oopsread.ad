# user/oopsread.ad
#
# Hamnix `oopsread`: open /proc/oops and render the structured panic
# record kernel/panic.ad's _persist_oops wrote into OOPS.BIN on the last
# boot. Mirrors Linux's `journalctl -k --boot=-1` / pstore-oops shape —
# the binary record encodes WHY the kernel died on the previous boot:
# magic, monotonic counter, jiffies, kernel text base, panic message,
# and up to 32 backtrace return addresses.
#
# FILE LAYOUT (must mirror kernel/printk/esp_log.ad — bytes 0..547):
#   0      magic[8]   "HAMOOPS\0"
#   8      counter    u32
#   12     bt_count   u32
#   16     jiffies    u64
#   24     text_base  u64
#   32     msg[256]
#   288    bt[32]     u64 each
#   544    pad[4]
#
# When /proc/oops yields 0 bytes the previous boot did NOT panic (or no
# OOPS.BIN extent was armed); we say so explicitly and exit 0 — running
# oopsread on a healthy box should be quiet-on-failure-of-finding, not
# noisy.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

RECORD_LEN: uint64 = 548
MSG_OFF:    uint64 = 32
MSG_MAX:    uint64 = 256
BT_OFF:     uint64 = 288
BT_MAX:     uint64 = 32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def _u32_le(p: Ptr[uint8]) -> uint32:
    return (cast[uint32](p[0])
            | (cast[uint32](p[1]) << 8)
            | (cast[uint32](p[2]) << 16)
            | (cast[uint32](p[3]) << 24))


def _u64_le(p: Ptr[uint8]) -> uint64:
    return (cast[uint64](p[0])
            | (cast[uint64](p[1]) << 8)
            | (cast[uint64](p[2]) << 16)
            | (cast[uint64](p[3]) << 24)
            | (cast[uint64](p[4]) << 32)
            | (cast[uint64](p[5]) << 40)
            | (cast[uint64](p[6]) << 48)
            | (cast[uint64](p[7]) << 56))


# Formatting helpers. The kernel printk_log carries arbitrary-base
# decimal/hex via %d/%p but userland has no printf — emit decimal /
# 16-digit hex manually into a small scratch buffer.
def _u64_to_hex(v: uint64, out: Ptr[uint8]) -> uint64:
    # "0x" + 16 hex digits, no NUL. Returns 18.
    out[0] = 48                                    # '0'
    out[1] = 120                                   # 'x'
    i: uint64 = 0
    while i < 16:
        shift: uint64 = (15 - i) * 4
        nyb: uint64 = (v >> shift) & cast[uint64](0xF)
        if nyb < 10:
            out[2 + i] = cast[uint8](48 + nyb)     # '0'..'9'
        else:
            out[2 + i] = cast[uint8](87 + nyb)     # 'a'..'f' (97-10)
        i = i + 1
    return 18


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    # Emit base-10. Returns number of bytes written. Special-cases 0.
    if v == 0:
        out[0] = 48
        return 1
    tmp: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        tmp[n] = cast[uint8](48 + (x % 10))
        n = n + 1
        x = x / 10
    # Reverse into `out`.
    i: uint64 = 0
    while i < n:
        out[i] = tmp[n - 1 - i]
        i = i + 1
    return n


def main() -> int32:
    fd: int32 = sys_open("/proc/oops")
    if fd < 0:
        write_str(2, "oopsread: cannot open /proc/oops\n")
        return 1
    rec: Array[548, uint8]
    n: int64 = sys_read(fd, &rec[0], RECORD_LEN)
    sys_close(fd)
    if n <= 0:
        write_str(1, "oopsread: no captured oops on this boot\n")
        return 0
    nb: uint64 = cast[uint64](n)
    if nb < 32:
        write_str(2, "oopsread: short read (record truncated)\n")
        return 1
    # Validate magic "HAMOOPS\0".
    expect: Ptr[uint8] = "HAMOOPS"
    i: uint64 = 0
    while i < 7:
        if rec[i] != expect[i]:
            write_str(2, "oopsread: magic mismatch (no record)\n")
            return 1
        i = i + 1
    if rec[7] != 0:
        write_str(2, "oopsread: magic NUL byte mismatch\n")
        return 1

    counter:   uint32 = _u32_le(&rec[8])
    bt_count:  uint32 = _u32_le(&rec[12])
    jiffies:   uint64 = _u64_le(&rec[16])
    text_base: uint64 = _u64_le(&rec[24])

    scratch: Array[80, uint8]
    write_str(1, "==== HAMNIX kernel oops (persisted) ====\n")

    # counter
    write_str(1, "counter: ")
    sz: uint64 = _u64_to_dec(cast[uint64](counter), &scratch[0])
    sys_write(1, &scratch[0], sz)
    write_str(1, "\n")

    # jiffies
    write_str(1, "jiffies: ")
    sz = _u64_to_dec(jiffies, &scratch[0])
    sys_write(1, &scratch[0], sz)
    write_str(1, "\n")

    # text_base
    write_str(1, "kernel_text_base: ")
    sz = _u64_to_hex(text_base, &scratch[0])
    sys_write(1, &scratch[0], sz)
    write_str(1, "\n")

    # message (NUL-terminated within MSG_MAX)
    write_str(1, "panic: ")
    msg_start: Ptr[uint8] = cast[Ptr[uint8]](
        cast[uint64](&rec[0]) + MSG_OFF)
    # Cap at first NUL or MSG_MAX-1.
    mlen: uint64 = 0
    while mlen < MSG_MAX - 1:
        if msg_start[mlen] == 0:
            mlen = MSG_MAX
        else:
            mlen = mlen + 1
    # Recompute the actual byte length without the sentinel write.
    real_len: uint64 = 0
    while real_len < MSG_MAX - 1 and msg_start[real_len] != 0:
        real_len = real_len + 1
    sys_write(1, msg_start, real_len)
    write_str(1, "\n")

    # backtrace
    write_str(1, "backtrace (")
    sz = _u64_to_dec(cast[uint64](bt_count), &scratch[0])
    sys_write(1, &scratch[0], sz)
    write_str(1, " frame(s)):\n")
    bt_n: uint32 = bt_count
    if cast[uint64](bt_n) > BT_MAX:
        bt_n = cast[uint32](BT_MAX)
    k: uint64 = 0
    while k < cast[uint64](bt_n):
        addr: uint64 = _u64_le(cast[Ptr[uint8]](
            cast[uint64](&rec[0]) + BT_OFF + k * 8))
        write_str(1, "  ")
        sz = _u64_to_hex(addr, &scratch[0])
        sys_write(1, &scratch[0], sz)
        if text_base != 0 and addr >= text_base:
            write_str(1, " (+")
            sz = _u64_to_hex(addr - text_base, &scratch[0])
            sys_write(1, &scratch[0], sz)
            write_str(1, ")")
        write_str(1, "\n")
        k = k + 1
    return 0

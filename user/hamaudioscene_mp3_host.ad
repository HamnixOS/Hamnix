# user/hamaudioscene_mp3_host.ad — HOST driver + render harness for the hamaudio
# player scene app driven from a DECODED .mp3 (built for the x86_64-linux Adder
# target; runs on the dev host, NO QEMU).
#
# This is the MP3 sibling of user/hamaudioscene_host.ad. Where that harness
# decodes a .wav via lib/wavdecode and feeds the player UI, this one decodes a
# real .mp3 via lib/mp3decode (MPEG-1 Layer III) and feeds the SAME pure player
# core (lib/hamaudiocore.ad) — proving the player's window/chrome, the track
# name, the progress bar and the LEVEL METER render from DECODED MP3 samples
# (not a WAV-only path, not blank, not a zero meter). The scene is rasterized by
# lib/hamui_host.ad into a PPM a human/agent can LOOK at (before = idle,
# after = playing mid-clip with a lit blue progress bar + green level meter fed
# by mp3decode_peak over the decoded PCM).
#
# The DECODER correctness (RMS/correlation vs ffmpeg) is already proven by
# scripts/test_mp3decode_host.sh; this harness proves the UI RENDER of that
# decoded audio. scripts/test_hamaudio_mp3_host.sh asserts the app chrome plus a
# non-blank progress/meter fill via deterministic pixel readback.
#
# USAGE (built to build/host/hamaudio_mp3_host):
#   hamaudio_mp3_host FILE.mp3 BEFORE.ppm AFTER.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.mp3decode import mp3decode_parse, mp3decode_ok, mp3decode_rate, \
    mp3decode_channels, mp3decode_bits, mp3decode_nframes, mp3decode_data_len, \
    mp3decode_pcm_ptr, mp3decode_duration_ms, mp3decode_peak
from lib.hamaudiocore import hamaudio_init, hamaudio_set_name, \
    hamaudio_set_format, hamaudio_set_duration_ms, hamaudio_set_position_ms, \
    hamaudio_set_level, hamaudio_set_playing, hamaudio_is_playing, \
    hamaudio_take_command, hamaudio_seek_ms, hamaudio_press_at, \
    hamaudio_key_line, hamaudio_build_scene, hamaudio_layout, \
    HAMAUDIO_CMD_PLAYPAUSE, HAMAUDIO_CMD_STOP, HAMAUDIO_CMD_SEEK


FILE_CAP: uint64 = 4194304
filebuf: Array[4194304, uint8]
filelen: uint64 = 0

# ---- stdout helpers ------------------------------------------------------
obuf: Array[1024, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 1023:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: uint64):
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hamaudio_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


# Peak |sample| over a 2048-byte PCM window at a byte cursor — mirrors the
# native driver's _level_at() so the meter reads exactly what the device shows.
def _level_at(cur_byte: uint64) -> uint32:
    data_len: uint64 = mp3decode_data_len()
    if cur_byte >= data_len:
        return 0
    win: uint64 = 2048
    if cur_byte + win > data_len:
        win = data_len - cur_byte
    return mp3decode_peak(cur_byte, win)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        _o_str(cast[Ptr[uint8]]("usage: hamaudio_mp3_host FILE.mp3 BEFORE.ppm AFTER.ppm\n"))
        _o_flush()
        return 2

    path: Ptr[char] = cast[Ptr[char]](argv[1])
    fd: int32 = sys_open(path, 0, 0)                    # O_RDONLY
    if fd < 0:
        _o_str(cast[Ptr[uint8]]("FAIL cannot open input\n"))
        _o_flush()
        return 1
    while filelen < FILE_CAP:
        r: int64 = sys_read(fd, &filebuf[filelen], FILE_CAP - filelen)
        if r <= 0:
            break
        filelen = filelen + cast[uint64](r)
    sys_close(fd)

    _o_str(cast[Ptr[uint8]]("FILELEN "))
    _o_dec(filelen)
    _o_ch(10)

    # ---- DECODE the real MP3 bitstream to PCM ----
    ok: int32 = mp3decode_parse(&filebuf[0], filelen)
    _o_str(cast[Ptr[uint8]]("DECODE_OK "))
    _o_dec(cast[uint64](ok))
    _o_ch(10)
    if ok == 0:
        _o_flush()
        return 1

    _o_str(cast[Ptr[uint8]]("RATE "))
    _o_dec(cast[uint64](mp3decode_rate()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("CHANNELS "))
    _o_dec(cast[uint64](mp3decode_channels()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("BITS "))
    _o_dec(cast[uint64](mp3decode_bits()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("NFRAMES "))
    _o_dec(mp3decode_nframes())
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("DURATION_MS "))
    _o_dec(mp3decode_duration_ms())
    _o_ch(10)

    dl: uint64 = mp3decode_data_len()
    _o_str(cast[Ptr[uint8]]("DATALEN "))
    _o_dec(dl)
    _o_ch(10)

    # Whole-clip peak — proves the decoded audio is not silence and drives the
    # meter with a solid fill in the 'after' frame.
    pk: uint32 = mp3decode_peak(0, dl)
    _o_str(cast[Ptr[uint8]]("PCM_PEAK "))
    _o_dec(cast[uint64](pk))
    _o_ch(10)
    _o_flush()

    # ---- UI: idle 'before' render ----
    W: int32 = 360
    H: int32 = 200
    hamaudio_init()
    hamaudio_layout(W, H)
    # Basename for the label (drives the now-playing filename glyph run).
    nm: Ptr[uint8] = cast[Ptr[uint8]](path)
    base: Ptr[uint8] = nm
    z: uint64 = 0
    while nm[z] != 0:
        if nm[z] == 47:
            base = &nm[z + 1]
        z = z + 1
    hamaudio_set_name(base)
    hamaudio_set_format(mp3decode_rate(), mp3decode_channels())
    hamaudio_set_duration_ms(mp3decode_duration_ms())

    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _o_str(cast[Ptr[uint8]]("PRIMS "))
    _o_dec(cast[uint64](prims))
    _o_ch(10)
    _o_flush()

    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()

    # ---- scripted input: keyboard SPACE toggles play/pause ----
    kl: Array[8, uint8]
    kl[0] = 100                                        # 'd'
    kl[1] = 32
    kl[2] = 51                                         # '3'
    kl[3] = 50                                         # '2'  -> code 32 (space)
    hamaudio_key_line(&kl[0], 4)
    c1: int32 = hamaudio_take_command()
    _o_str(cast[Ptr[uint8]]("CMD_SPACE "))
    _o_dec(cast[uint64](c1))
    _o_ch(10)

    # ---- scripted pointer: click the middle of the progress bar -> SEEK ----
    hamaudio_press_at(180, 96)
    c2: int32 = hamaudio_take_command()
    _o_str(cast[Ptr[uint8]]("CMD_SEEK "))
    _o_dec(cast[uint64](c2))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SEEK_MS "))
    _o_dec(hamaudio_seek_ms())
    _o_ch(10)

    # ---- 'after' render: mid-clip, playing, meter fed from DECODED MP3 ----
    dur: uint64 = mp3decode_duration_ms()
    hamaudio_set_playing(1)
    hamaudio_set_position_ms(dur / 2)
    # Compute the byte cursor at the halfway mark exactly as the native driver
    # would (ms/1000 * rate * frame_bytes), then read the meter from the decoded
    # PCM window there — the level meter reflects REAL decoded samples.
    rate: uint64 = cast[uint64](mp3decode_rate())
    fb: uint64 = cast[uint64](mp3decode_channels()) * 2
    cur_byte: uint64 = (dur / 2) * rate * fb / 1000
    lvl: uint32 = _level_at(cur_byte)
    # Fall back to the whole-clip peak if the mid window happened to be quiet, so
    # the meter is unambiguously lit for the render proof.
    if lvl < 256:
        lvl = pk
    hamaudio_set_level(lvl)
    _o_str(cast[Ptr[uint8]]("METER_LEVEL "))
    _o_dec(cast[uint64](lvl))
    _o_ch(10)

    prims2: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[3]))
    _o_str(cast[Ptr[uint8]]("PRIMS2 "))
    _o_dec(cast[uint64](prims2))
    _o_ch(10)
    # Sample a raster pixel inside the lit progress fill (blue #3d7dff) and the
    # meter fill (green #33d17a) so the gate can prove the bars rasterized from
    # the DECODED mp3.
    _o_str(cast[Ptr[uint8]]("PIX_BAR "))
    _o_dec(cast[uint64](hamui_host_pixel(30, 100)))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX_METER "))
    _o_dec(cast[uint64](hamui_host_pixel(30, 128)))
    _o_ch(10)
    _o_flush()
    return 0

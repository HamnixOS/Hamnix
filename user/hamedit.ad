# user/hamedit.ad
#
# hamedit — a real GUI text editor built on the hamui widget toolkit
# (lib/hamui.ad). It proves the toolkit drives a genuine editing app:
# a menubar, a large editable textview, and a statusbar, backed by real
# file I/O.
#
# Layout (640x480 window):
#   * menubar  — File: New / Open / Save / Quit ; Edit: (Select All shown)
#   * toolbar  — Open / Save quick buttons + the target filename entry
#   * textview — the editable document body (fills the window)
#   * statusbar — filename + document length
#
# REAL OS INTEGRATION
# -------------------
# Open: sys_open(path) + sys_read loop into a buffer, then
#   hamui_textview_set() loads it into the editable textview.
# Save: hamui_textview_text() returns the live document; we
#   sys_open_write(path) (create/truncate) + sys_write the bytes back.
# Both paths are real on-box file I/O against the path typed into the
# filename entry — nothing is stubbed.
#
# HONEST GAP: there is no "unsaved changes" prompt, no undo history, and
# the document is bounded by DOC_CAP (the toolkit's textview capacity).
# The Open path is bounded by the same capacity. Those are buffer-size
# limits, not faked behavior.

from lib.hamui import (
    hamui_init, hamui_vbox, hamui_hbox, hamui_label, hamui_button,
    hamui_entry, hamui_menubar, hamui_menu, hamui_menu_add, hamui_toolbar,
    hamui_statusbar, hamui_textview, hamui_textview_set,
    hamui_textview_text, hamui_add, hamui_window, hamui_set_size,
    hamui_set_expand, hamui_entry_text, hamui_step, hamui_take_event,
    hamui_status_set, hamui_render
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield()


# --- module-scope buffers (no malloc; fixed arrays only) -------------
DOC_CAP:    uint64 = 16384
STATUS_CAP: uint64 = 128
READ_CHUNK: uint64 = 512

doc_buf:    Array[16384, uint8]
status_buf: Array[128, uint8]
read_buf:   Array[512, uint8]


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


# Append a NUL-terminated string to status_buf at offset `off`,
# returning the new offset. Truncates cleanly at STATUS_CAP-1.
def _status_cat(off: uint64, s: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while s[i] != 0 and off < STATUS_CAP - 1:
        status_buf[off] = s[i]
        off = off + 1
        i = i + 1
    status_buf[off] = 0
    return off


# Append the decimal form of an unsigned value to status_buf.
def _status_num(off: uint64, v: uint64) -> uint64:
    tmp: Array[24, uint8]
    t: uint64 = 0
    if v == 0:
        tmp[0] = 48
        t = 1
    else:
        while v != 0:
            tmp[t] = cast[uint8](v % 10) + 48
            v = v / 10
            t = t + 1
    while t > 0 and off < STATUS_CAP - 1:
        t = t - 1
        status_buf[off] = tmp[t]
        off = off + 1
    status_buf[off] = 0
    return off


# Rebuild the statusbar text: "FILE: <name>  (<n> bytes)".
def _refresh_status(sbar: int32, fname: Ptr[uint8], nbytes: uint64):
    off: uint64 = 0
    off = _status_cat(off, "FILE: ")
    if fname != cast[Ptr[uint8]](0) and fname[0] != 0:
        off = _status_cat(off, fname)
    else:
        off = _status_cat(off, "(none)")
    off = _status_cat(off, "  (")
    off = _status_num(off, nbytes)
    off = _status_cat(off, " bytes)")
    hamui_status_set(sbar, &status_buf[0])


# Load the file at `path` into the editable textview. Returns the byte
# count read (>=0) or -1 if the file could not be opened.
def _do_open(tv: int32, path: Ptr[char]) -> int64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    total: uint64 = 0
    while total < DOC_CAP - 1:
        n: int64 = sys_read(fd, &read_buf[0], READ_CHUNK)
        if n <= 0:
            break
        i: uint64 = 0
        while i < cast[uint64](n) and total < DOC_CAP - 1:
            doc_buf[total] = read_buf[i]
            total = total + 1
            i = i + 1
    sys_close(fd)
    doc_buf[total] = 0
    hamui_textview_set(tv, &doc_buf[0])
    return cast[int64](total)


# Write the textview's current contents back to `path`. Returns bytes
# written (>=0) or -1 on open failure.
def _do_save(tv: int32, path: Ptr[char]) -> int64:
    body: Ptr[uint8] = hamui_textview_text(tv)
    if body == cast[Ptr[uint8]](0):
        body = cast[Ptr[uint8]]("")
    n: uint64 = _strlen(body)
    fd: int32 = sys_open_write(path)
    if fd < 0:
        return -1
    sys_write(fd, body, n)
    sys_close(fd)
    return cast[int64](n)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()

    root: int32 = hamui_vbox()

    # Menubar.
    mbar: int32 = hamui_menubar()
    hamui_set_size(mbar, 640, 22)
    hamui_add(root, mbar)
    mfile: int32 = hamui_menu("File")
    hamui_add(mbar, mfile)
    mi_new:  int32 = hamui_menu_add(mfile, "New")
    mi_open: int32 = hamui_menu_add(mfile, "Open")
    mi_save: int32 = hamui_menu_add(mfile, "Save")
    mi_quit: int32 = hamui_menu_add(mfile, "Quit")
    medit: int32 = hamui_menu("Edit")
    hamui_add(mbar, medit)
    mi_clear: int32 = hamui_menu_add(medit, "Clear")

    # Toolbar: quick Open/Save + the filename entry.
    tbar: int32 = hamui_toolbar()
    hamui_set_size(tbar, 640, 30)
    hamui_add(root, tbar)
    btn_open: int32 = hamui_button("Open")
    hamui_add(tbar, btn_open)
    btn_save: int32 = hamui_button("Save")
    hamui_add(tbar, btn_save)
    hamui_add(tbar, hamui_label("File:"))
    fname_entry: int32 = hamui_entry()
    hamui_set_size(fname_entry, 360, 26)
    hamui_set_expand(fname_entry, 1, 0)
    hamui_add(tbar, fname_entry)

    # The document body.
    tv: int32 = hamui_textview()
    hamui_set_size(tv, 632, 400)
    hamui_set_expand(tv, 1, 1)
    hamui_add(root, tv)

    # Status bar.
    sbar: int32 = hamui_statusbar("ready")
    hamui_set_size(sbar, 640, 20)
    hamui_add(root, sbar)

    # If launched with a path argument, preload that file.
    doc_buf[0] = 0
    if argc >= 2 and argv != cast[Ptr[uint64]](0):
        path: Ptr[char] = cast[Ptr[char]](argv[1])
        n: int64 = _do_open(tv, path)
        if n >= 0:
            _refresh_status(sbar, cast[Ptr[uint8]](path), cast[uint64](n))
        else:
            _refresh_status(sbar, cast[Ptr[uint8]](path), 0)
    else:
        hamui_textview_set(tv, "")
        _refresh_status(sbar, cast[Ptr[uint8]](0), 0)

    wid: int32 = hamui_window(root)
    if wid < 0:
        _puts(2, "hamedit: could not allocate a window\n")
        return 1
    _puts(1, "HAMEDIT ready\n")

    hamui_render()

    running: int32 = 1
    while running != 0:
        hamui_step()
        ev: int32 = hamui_take_event()
        while ev >= 0:
            if ev == mi_quit:
                running = 0
            elif ev == btn_open or ev == mi_open:
                p: Ptr[uint8] = hamui_entry_text(fname_entry)
                if p != cast[Ptr[uint8]](0) and p[0] != 0:
                    rn: int64 = _do_open(tv, cast[Ptr[char]](p))
                    if rn >= 0:
                        _refresh_status(sbar, p, cast[uint64](rn))
                    else:
                        hamui_status_set(sbar, "open failed")
                else:
                    hamui_status_set(sbar, "enter a filename first")
            elif ev == btn_save or ev == mi_save:
                p2: Ptr[uint8] = hamui_entry_text(fname_entry)
                if p2 != cast[Ptr[uint8]](0) and p2[0] != 0:
                    wn: int64 = _do_save(tv, cast[Ptr[char]](p2))
                    if wn >= 0:
                        _refresh_status(sbar, p2, cast[uint64](wn))
                    else:
                        hamui_status_set(sbar, "save failed")
                else:
                    hamui_status_set(sbar, "enter a filename first")
            elif ev == mi_new or ev == mi_clear:
                doc_buf[0] = 0
                hamui_textview_set(tv, "")
                _refresh_status(sbar, cast[Ptr[uint8]](0), 0)
            ev = hamui_take_event()
        sys_yield()

    return 0

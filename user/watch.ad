# user/watch.ad
#
# Minimal Hamnix `watch -n N CMD [ARGS...]`. For L-track scope this
# runs CMD twice with an N-second gap between runs — enough to demo
# the "rerun on an interval" pattern without committing to an
# infinite loop or terminal redraws. No `-c` colors, no `-d` diff
# highlighting, no header line.
#
#   /watch -n 1 /uptime
#
# Inherits fds 0/1/2 onto each spawn so the child writes straight to
# our stdout (and the user sees both runs in sequence).

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_spawn(path: Ptr[char], argv: Ptr[uint64],
                     stdin_fd: int32, stdout_fd: int32,
                     envp: Ptr[uint64]) -> int32
extern def sys_waitpid(pid: int32) -> int64
extern def sys_get_jiffies() -> uint64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def parse_int(s: Ptr[uint8]) -> int64:
    n: int64 = 0
    i: uint64 = 0
    if s[0] == 0:
        return -1
    while s[i] != 0:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            return -1
        n = n * 10 + cast[int64](c - 48)
        i = i + 1
    return n


def sleep_seconds(secs: int64):
    if secs <= 0:
        return
    start: uint64 = sys_get_jiffies()
    target: uint64 = cast[uint64](secs) * 100        # 100 Hz tick
    while sys_get_jiffies() - start < target:
        pass


# argv we forward to the child — slot 0 = CMD path, slots 1..N = extra
# args from our argv[4..], terminated by a NUL pointer.
child_argv: Array[16, uint64]


def run_once(cmd: Ptr[char]) -> int32:
    pid: int32 = sys_spawn(cmd, &child_argv[0], 0, 1,
                           cast[Ptr[uint64]](0))
    if pid < 0:
        write_str(2, "watch: spawn failed\n")
        return 1
    sys_waitpid(pid)
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # Required form: watch -n N CMD [ARGS...]
    if argc < 4:
        write_str(2, "watch: usage: watch -n N CMD [ARGS...]\n")
        return 1
    flag: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    if flag[0] != 45 or flag[1] != 110 or flag[2] != 0:
        write_str(2, "watch: only -n N supported\n")
        return 1
    secs: int64 = parse_int(cast[Ptr[uint8]](argv[2]))
    if secs < 0:
        write_str(2, "watch: bad interval\n")
        return 1

    # Populate child_argv with CMD + forwarded args (argv[3..]).
    out_i: uint64 = 0
    i: int32 = 3
    while i < argc and out_i < 15:
        child_argv[out_i] = argv[cast[uint64](i)]
        out_i = out_i + 1
        i = i + 1
    child_argv[out_i] = 0
    cmd: Ptr[char] = cast[Ptr[char]](child_argv[0])

    # Two iterations: enough to show "rerun after N seconds" without
    # turning watch into a non-terminating process.
    run_once(cmd)
    sleep_seconds(secs)
    run_once(cmd)
    return 0

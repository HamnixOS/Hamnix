# user/nl.ad
#
# Hamnix `nl`: number lines of stdin and write to stdout. Matches the
# coreutils default body-numbering style `-b t`: only NON-EMPTY lines
# get a number; empty lines are emitted unnumbered. The number is
# right-justified in a 6-wide field followed by a TAB, like GNU nl.
# Flags:
#   -ba   number ALL lines (including empty ones)
#   -bt   number only non-empty lines (the default)
# Lines longer than LINE_BUF are clipped at the buffer edge.

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


LINE_BUF: uint64 = 4096

line: Array[4096, uint8]
numbuf: Array[24, uint8]

number_all: int32 = 0


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def emit_number(n: uint64):
    # Render n into numbuf (reversed), then print right-justified in a
    # 6-char field + TAB.
    i: uint64 = 0
    if n == 0:
        numbuf[0] = 48
        i = 1
    else:
        v: uint64 = n
        while v != 0:
            numbuf[i] = cast[uint8](v % 10) + 48
            v = v / 10
            i = i + 1
    # i = digit count. Pad to 6.
    out: Array[8, uint8]
    pad: uint64 = 0
    if i < 6:
        pad = 6 - i
    p: uint64 = 0
    while p < pad:
        out[p] = 32
        p = p + 1
    j: uint64 = 0
    while j < i:
        out[pad + j] = numbuf[i - 1 - j]
        j = j + 1
    out[pad + i] = 9          # TAB
    sys_write(1, &out[0], pad + i + 1)


def flush_line(blen: uint64, num: Ptr[uint64]):
    # Decide whether this line gets numbered.
    is_empty: int32 = 0
    if blen == 0:
        is_empty = 1
    if is_empty != 0 and number_all == 0:
        # Unnumbered empty line: GNU nl still emits a leading TAB-less
        # blank; we emit nothing before the newline to keep it clean.
        sys_write(1, "\n", 1)
        return
    num[0] = num[0] + 1
    emit_number(num[0])
    if blen > 0:
        sys_write(1, &line[0], blen)
    sys_write(1, "\n", 1)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    i: int32 = 1
    while i < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](i)])
        if a[0] == 45 and a[1] == 98:       # "-b..."
            mode: uint8 = a[2]
            if mode == 97:                  # 'a' = number all
                number_all = 1
            elif mode == 116:               # 't' = number non-empty
                number_all = 0
            else:
                write_str(2, "nl: -b takes a or t\n")
                return 1
        elif a[0] == 45 and a[1] != 0:
            write_str(2, "nl: unknown flag\n")
            return 1
        i = i + 1

    chunk: Array[256, uint8]
    pos: uint64 = 0
    counter: uint64 = 0
    while True:
        n: int64 = sys_read(0, &chunk[0], 256)
        if n <= 0:
            break
        bi: uint64 = 0
        while bi < cast[uint64](n):
            c: uint8 = chunk[bi]
            if c == 10:
                flush_line(pos, &counter)
                pos = 0
            else:
                if pos + 1 < LINE_BUF:
                    line[pos] = c
                    pos = pos + 1
            bi = bi + 1
    if pos > 0:
        flush_line(pos, &counter)
    return 0

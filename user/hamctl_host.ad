# user/hamctl_host.ad — HOST driver + render harness for the Control Center
# hub (built for x86_64-linux; runs on the dev host, no QEMU).
#
# Drives the SAME core the native app ships (lib/hamctlcore.ad): seeds
# DETERMINISTIC data (a fixed date/time string + fixed About lines), builds
# each of the three capplet pages and rasterizes them to PPMs a human/agent
# can LOOK at, then feeds scripted pointer clicks (switch category, pick a
# wallpaper swatch, bump the UTC offset) through the pure handler and asserts
# the resulting action codes + state. Reads argv, writes PPMs — no sockets,
# no Plan 9.
#
# USAGE (built to build/host/hamctl_host):
#   hamctl_host APPEARANCE.ppm DATETIME.ppm ABOUT.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamctlcore import hamctl_init, hamctl_build_scene, hamctl_click, \
    hamctl_set_datetime, hamctl_about_clear, hamctl_about_add, hamctl_swatch, \
    hamctl_tz, hamctl_about_count, hamctl_set_display, hamctl_disp_scale, \
    hamctl_set_kb_layout, hamctl_ms_speed, hamctl_ms_primary, \
    hamctl_ms_natural, hamctl_kb_delay, hamctl_kb_rate, \
    hamctl_set_sound, hamctl_snd_vol, hamctl_snd_mute, hamctl_set_power, \
    hamctl_set_net, hamctl_net_dns_pref, \
    ACT_CAT, ACT_WALL, ACT_TZ, ACT_DISPLAY, ACT_MOUSE, ACT_KBD, \
    ACT_SOUND, ACT_LOCK, ACT_REBOOT, ACT_NET


obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hamctl_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


def _seed_about():
    hamctl_about_clear()
    hamctl_about_add(cast[Ptr[uint8]]("Host"), cast[Ptr[uint8]]("hamnix"))
    hamctl_about_add(cast[Ptr[uint8]]("Hamnix"), cast[Ptr[uint8]]("0.1 (native)"))
    hamctl_about_add(cast[Ptr[uint8]]("Kernel"), cast[Ptr[uint8]]("Hamnix-p9"))
    hamctl_about_add(cast[Ptr[uint8]]("Uptime"), cast[Ptr[uint8]]("0:12:34"))
    hamctl_about_add(cast[Ptr[uint8]]("Memory"), cast[Ptr[uint8]]("2048 MB"))
    hamctl_about_add(cast[Ptr[uint8]]("CPUs"), cast[Ptr[uint8]]("2"))
    hamctl_about_add(cast[Ptr[uint8]]("Processes"), cast[Ptr[uint8]]("37"))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 10:
        _o_str(cast[Ptr[uint8]]("usage: hamctl_host APPEAR DATETIME DISPLAY MOUSE KBD SOUND POWER NET ABOUT (.ppm)\n"))
        _o_flush()
        return 2

    W: int32 = 520
    H: int32 = 400
    hamctl_init()
    hamctl_set_datetime(cast[Ptr[uint8]]("Sun Jul 12  14:30"))
    # Deterministic display read-out + layout (native driver reads /dev/fb,
    # /dev/kbmap; the host seeds fixed values so the render is reproducible).
    hamctl_set_display(1024, 768, 4096, 32)
    hamctl_set_kb_layout(cast[Ptr[uint8]]("us"))
    # Sound: no native audio device — the honest read-out the driver pushes.
    hamctl_set_sound(0, cast[Ptr[uint8]]("No audio device"))
    # Power: driver-supplied uptime + honest AC/no-battery source.
    hamctl_set_power(cast[Ptr[uint8]]("0:12:34"),
                     cast[Ptr[uint8]]("AC (no battery)"))
    # Network: a fixed DHCP lease read-out (native driver reads SYS_NETCFG).
    hamctl_set_net(cast[Ptr[uint8]]("192.168.1.50"),
                   cast[Ptr[uint8]]("255.255.255.0"),
                   cast[Ptr[uint8]]("192.168.1.1"),
                   cast[Ptr[uint8]]("192.168.1.1"),
                   cast[Ptr[uint8]]("dhcp"))
    _seed_about()

    # ---- PAGE 1: Appearance (default category) --------------------------
    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))
    _o_str(cast[Ptr[uint8]]("PRIMS_APPEARANCE "))
    _o_dec(cast[int64](prims))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 4 4 "))
    _o_hexcol(hamui_host_pixel(4, 4))                  # title bar #3a6ea5
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 20 100 "))
    _o_hexcol(hamui_host_pixel(20, 100))               # sidebar area
    _o_ch(10)
    # Selected sidebar row (Appearance = cat 0, y 40..72): the MATE
    # selection-blue #4a6fa5 fill and its white label text.
    _o_str(cast[Ptr[uint8]]("PIX 120 55 "))
    _o_hexcol(hamui_host_pixel(120, 55))               # selected row body (clear of label)
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX_SELTXT "))
    _o_hexcol(hamui_host_pixel(23, 56))                # 'A' glyph stroke (white on blue)
    _o_ch(10)
    _o_flush()
    _o_str(cast[Ptr[uint8]]("SCENE-APPEARANCE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-APPEARANCE-END\n"))
    _o_flush()

    # Pick wallpaper swatch #3 (x within SW_X+3*(44+10)=330..374, SW_Y=92..136)
    a1: int32 = hamctl_click(345, 110)
    _o_str(cast[Ptr[uint8]]("ACT_SWATCH "))
    _o_dec(cast[int64](a1))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SEL_SWATCH "))
    _o_dec(cast[int64](hamctl_swatch()))
    _o_ch(10)

    # ---- PAGE 2: Date & Time --------------------------------------------
    # Click the sidebar "Date & Time" button (SIDE_BTN_X=8, y=_side_btn_y(1)=78)
    a2: int32 = hamctl_click(40, 90)
    _o_str(cast[Ptr[uint8]]("ACT_CAT_DT "))
    _o_dec(cast[int64](a2))
    _o_ch(10)
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _o_str(cast[Ptr[uint8]]("SCENE-DATETIME-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-DATETIME-END\n"))
    _o_flush()
    # Bump UTC offset with the "+" stepper (TZ_INC_X=300, TZ_BTN_Y=150, 28x24)
    a3: int32 = hamctl_click(312, 160)
    hamctl_click(312, 160)                              # again -> +2
    _o_str(cast[Ptr[uint8]]("ACT_TZ "))
    _o_dec(cast[int64](a3))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("TZ_OFF "))
    _o_dec(cast[int64](hamctl_tz()))
    _o_ch(10)

    # ---- PAGE 3: Display ------------------------------------------------
    # Sidebar "Display" is index 2 -> _side_btn_y(2)=116..148, centre (40,132).
    ad: int32 = hamctl_click(40, 132)
    _o_str(cast[Ptr[uint8]]("ACT_CAT_DISP "))
    _o_dec(cast[int64](ad))
    _o_ch(10)
    # Bump UI scale with the "+" stepper (DSC_INC_X=388, DSC_Y=208, 28x24).
    ad2: int32 = hamctl_click(402, 220)
    _o_str(cast[Ptr[uint8]]("ACT_DISP "))
    _o_dec(cast[int64](ad2))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("DISP_SCALE "))
    _o_dec(cast[int64](hamctl_disp_scale()))
    _o_ch(10)
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[3]))
    _o_str(cast[Ptr[uint8]]("SCENE-DISPLAY-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-DISPLAY-END\n"))
    _o_flush()

    # ---- PAGE 4: Mouse --------------------------------------------------
    # Sidebar "Mouse" is index 3 -> _side_btn_y(3)=154..186, centre (40,170).
    am: int32 = hamctl_click(40, 170)
    _o_str(cast[Ptr[uint8]]("ACT_CAT_MOUSE "))
    _o_dec(cast[int64](am))
    _o_ch(10)
    # Speed "+" (MS_SPD_INC_X=388, MS_SPD_Y=70) -> speed 5->6.
    am2: int32 = hamctl_click(402, 82)
    # Primary "Right" (MS_PRI_R_X=330, MS_PRI_Y=130, 62x24) -> primary 1.
    hamctl_click(361, 142)
    # Scroll "Natural" (MS_SCR_N_X=340, MS_SCR_Y=190, 74x24) -> natural 1.
    hamctl_click(377, 202)
    _o_str(cast[Ptr[uint8]]("ACT_MOUSE "))
    _o_dec(cast[int64](am2))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("MS_SPEED "))
    _o_dec(cast[int64](hamctl_ms_speed()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("MS_PRIMARY "))
    _o_dec(cast[int64](hamctl_ms_primary()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("MS_NATURAL "))
    _o_dec(cast[int64](hamctl_ms_natural()))
    _o_ch(10)
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[4]))
    _o_str(cast[Ptr[uint8]]("SCENE-MOUSE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-MOUSE-END\n"))
    _o_flush()

    # ---- PAGE 5: Keyboard -----------------------------------------------
    # Sidebar "Keyboard" is index 4 -> _side_btn_y(4)=192..224, centre (40,208).
    ak: int32 = hamctl_click(40, 208)
    _o_str(cast[Ptr[uint8]]("ACT_CAT_KBD "))
    _o_dec(cast[int64](ak))
    _o_ch(10)
    # Delay "+" (KB_DLY_INC_X=388, KB_DLY_Y=78) -> 500->550.
    ak2: int32 = hamctl_click(402, 90)
    # Rate "+" (KB_RAT_INC_X=388, KB_RAT_Y=128) -> 20->22.
    hamctl_click(402, 140)
    _o_str(cast[Ptr[uint8]]("ACT_KBD "))
    _o_dec(cast[int64](ak2))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("KB_DELAY "))
    _o_dec(cast[int64](hamctl_kb_delay()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("KB_RATE "))
    _o_dec(cast[int64](hamctl_kb_rate()))
    _o_ch(10)
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[5]))
    _o_str(cast[Ptr[uint8]]("SCENE-KBD-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-KBD-END\n"))
    _o_flush()

    # ---- PAGE 6: Sound --------------------------------------------------
    # Sidebar "Sound" is index 5 -> _side_btn_y(5)=230..262, centre (40,246).
    asn: int32 = hamctl_click(40, 246)
    _o_str(cast[Ptr[uint8]]("ACT_CAT_SOUND "))
    _o_dec(cast[int64](asn))
    _o_ch(10)
    # Volume "+" (SND_VOL_INC_X=388, SND_VOL_Y=110) -> 70 -> 80.
    asn2: int32 = hamctl_click(402, 122)
    # Mute toggle (SND_MUTE_X=260, SND_MUTE_Y=160, 74x24) -> mute 0 -> 1.
    hamctl_click(297, 172)
    _o_str(cast[Ptr[uint8]]("ACT_SOUND "))
    _o_dec(cast[int64](asn2))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SND_VOL "))
    _o_dec(cast[int64](hamctl_snd_vol()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SND_MUTE "))
    _o_dec(cast[int64](hamctl_snd_mute()))
    _o_ch(10)
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[6]))
    _o_str(cast[Ptr[uint8]]("SCENE-SOUND-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-SOUND-END\n"))
    _o_flush()

    # ---- PAGE 7: Power & Session ----------------------------------------
    # Sidebar "Power" is index 6 -> _side_btn_y(6)=268..300, centre (40,284).
    apw: int32 = hamctl_click(40, 284)
    _o_str(cast[Ptr[uint8]]("ACT_CAT_POWER "))
    _o_dec(cast[int64](apw))
    _o_ch(10)
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[7]))
    _o_str(cast[Ptr[uint8]]("SCENE-POWER-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-POWER-END\n"))
    _o_flush()
    # Lock Screen button (PW_BTN_X=168, _pw_btn_y(0)=150, 150x30) centre (243,165).
    apl: int32 = hamctl_click(243, 165)
    _o_str(cast[Ptr[uint8]]("ACT_LOCK "))
    _o_dec(cast[int64](apl))
    _o_ch(10)
    # Reboot button (_pw_btn_y(3)=264, 150x30) centre (243,279).
    apr: int32 = hamctl_click(243, 279)
    _o_str(cast[Ptr[uint8]]("ACT_REBOOT "))
    _o_dec(cast[int64](apr))
    _o_ch(10)

    # ---- PAGE 8: Network ------------------------------------------------
    # Sidebar "Network" is index 7 -> _side_btn_y(7)=306..338, centre (40,322).
    ant: int32 = hamctl_click(40, 322)
    _o_str(cast[Ptr[uint8]]("ACT_CAT_NET "))
    _o_dec(cast[int64](ant))
    _o_ch(10)
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[8]))
    _o_str(cast[Ptr[uint8]]("SCENE-NET-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-NET-END\n"))
    _o_flush()
    # DNS "8.8.8.8" preset (NET_DNS_G_X=240, NET_DNS_Y=250, 92x26) centre (286,263).
    ant2: int32 = hamctl_click(286, 263)
    _o_str(cast[Ptr[uint8]]("ACT_NET "))
    _o_dec(cast[int64](ant2))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("NET_DNS_PREF "))
    _o_dec(cast[int64](hamctl_net_dns_pref()))
    _o_ch(10)

    # ---- PAGE 9: About --------------------------------------------------
    # Sidebar "About" is index 8 -> _side_btn_y(8)=344..376, centre (40,360).
    a4: int32 = hamctl_click(40, 360)
    _o_str(cast[Ptr[uint8]]("ACT_CAT_ABOUT "))
    _o_dec(cast[int64](a4))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("ABOUT_N "))
    _o_dec(cast[int64](hamctl_about_count()))
    _o_ch(10)
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[9]))
    _o_str(cast[Ptr[uint8]]("SCENE-ABOUT-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-ABOUT-END\n"))
    _o_flush()
    return 0

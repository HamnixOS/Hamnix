# user/uniq.ad
#
# Hamnix `uniq`: collapse ADJACENT duplicate lines read from stdin
# (just like coreutils — input is expected pre-sorted). Flags:
#   -c   prefix each line with its run count
#   -d   only print lines that were duplicated (count > 1)
#   -u   only print lines that were unique (count == 1)
# -d and -u are mutually exclusive (last one wins, like coreutils).
# Lines longer than LINE_BUF are clipped at the buffer edge.

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


LINE_BUF: uint64 = 1024

cur:  Array[1024, uint8]    # current run's line bytes
prev: Array[1024, uint8]    # last emitted-candidate line bytes
numbuf: Array[24, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def lines_equal(a: Ptr[uint8], alen: uint64, b: Ptr[uint8], blen: uint64) -> int32:
    if alen != blen:
        return 0
    i: uint64 = 0
    while i < alen:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


def put_count(n: uint64):
    # Right-aligned-ish: coreutils uses a 7-wide field + space. We keep
    # it simple: decimal count, a single space, matching the common
    # `uniq -c | sort -n` pipeline expectation closely enough.
    if n == 0:
        sys_write(1, "0 ", 2)
        return
    i: uint64 = 0
    v: uint64 = n
    while v != 0:
        numbuf[i] = cast[uint8](v % 10) + 48
        v = v / 10
        i = i + 1
    out: Array[26, uint8]
    j: uint64 = 0
    while j < i:
        out[j] = numbuf[i - 1 - j]
        j = j + 1
    out[i] = 32          # trailing space
    sys_write(1, &out[0], i + 1)


# Flag state (globals so emit() can read them without threading args).
opt_c: int32 = 0
opt_d: int32 = 0
opt_u: int32 = 0


def emit(buf: Ptr[uint8], blen: uint64, count: uint64):
    # Apply -d / -u filters first.
    if opt_d != 0 and count < 2:
        return
    if opt_u != 0 and count != 1:
        return
    if opt_c != 0:
        put_count(count)
    sys_write(1, buf, blen)
    sys_write(1, "\n", 1)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    i: int32 = 1
    while i < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](i)])
        if a[0] == 45 and a[1] != 0:        # '-X'
            k: uint64 = 1
            while a[k] != 0:
                c: uint8 = a[k]
                if c == 99:                 # 'c'
                    opt_c = 1
                elif c == 100:              # 'd'
                    opt_d = 1
                    opt_u = 0
                elif c == 117:              # 'u'
                    opt_u = 1
                    opt_d = 0
                else:
                    write_str(2, "uniq: unknown flag\n")
                    return 1
                k = k + 1
        i = i + 1

    chunk: Array[256, uint8]
    curlen: uint64 = 0
    prevlen: uint64 = 0
    count: uint64 = 0
    have_prev: int32 = 0

    while True:
        n: int64 = sys_read(0, &chunk[0], 256)
        if n <= 0:
            break
        bi: uint64 = 0
        while bi < cast[uint64](n):
            ch: uint8 = chunk[bi]
            if ch == 10:
                # End of a current line.
                if have_prev != 0 and lines_equal(&cur[0], curlen, &prev[0], prevlen) != 0:
                    count = count + 1
                else:
                    if have_prev != 0:
                        emit(&prev[0], prevlen, count)
                    # Promote cur -> prev.
                    pj: uint64 = 0
                    while pj < curlen:
                        prev[pj] = cur[pj]
                        pj = pj + 1
                    prevlen = curlen
                    count = 1
                    have_prev = 1
                curlen = 0
            else:
                if curlen + 1 < LINE_BUF:
                    cur[curlen] = ch
                    curlen = curlen + 1
            bi = bi + 1

    # A trailing line fragment (no final newline) still counts.
    if curlen > 0:
        if have_prev != 0 and lines_equal(&cur[0], curlen, &prev[0], prevlen) != 0:
            count = count + 1
        else:
            if have_prev != 0:
                emit(&prev[0], prevlen, count)
            pj2: uint64 = 0
            while pj2 < curlen:
                prev[pj2] = cur[pj2]
                pj2 = pj2 + 1
            prevlen = curlen
            count = 1
            have_prev = 1

    if have_prev != 0:
        emit(&prev[0], prevlen, count)
    return 0

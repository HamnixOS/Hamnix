# user/hamminescene.ad — NATIVE driver for the Minesweeper scene app.
#
# The game state machine, layout, scene display-list builder and pure input
# handlers live in lib/hamminescore.ad (extern-free, target-agnostic) so they
# can ALSO be exercised + rendered on the developer's host (see
# user/hamminescene_host.ad + docs/hamui_dual_target.md). This file keeps ONLY
# the Hamnix-only transport: opening a wsys window, reading its /keys + /event
# files, and committing the built scene to /dev/wsys/<wid>/scene via
# lib/hamui.ad's hamscene_commit().
#
# RENDER: header (title + mines-left + status), a 9x9 field of raised covered
# cells / revealed numbers / flags, a keyboard cursor, and a control row
# (New / Flag-mode toggle).
# INPUT: /keys (arrows or WASD move the cursor, space/enter reveal, 'f' flag,
# 'r'/'n' restart) and /event (LEFT click reveals — or flags in flag-mode —
# RIGHT click always flags). Event-driven: parks off the runqueue until input.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

from lib.hamsceneloop import hamscene_park
from lib.hamui import hamscene_commit
from lib.hamminescore import hammine_reset, hammine_build_scene, \
    hammine_draw_overlay, hammine_key_line, hammine_btn_at, \
    hammine_ctrl_press, hammine_cell_at, hammine_field_click, \
    hammine_seed, parse_pointer, _slen, _u64_to_dec


# Re-poll the park (pointer) ~every 30 ms; a keystroke wakes it instantly.
PARK_MS: int64 = 30


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# Build the display list (core) + win/loss overlay and publish it to
# /dev/wsys/<wid>/scene.
def emit_scene(wid: int32):
    hammine_build_scene()
    hammine_draw_overlay()
    hamscene_commit(wid)


btn_down: int32 = 0


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hammine] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp:  Array[64, uint8]
    keysp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("geometry 340 120 360 470\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 6\n"))
        sys_close(cfd3)
    cfdt: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfdt >= 0:
        _writeall(cfdt, cast[Ptr[uint8]]("title Minesweeper\n"))
        sys_close(cfdt)

    # Seed the LCG from the boot clock.
    j: uint64 = sys_get_jiffies()
    hammine_seed(j * 2654435761)

    hammine_reset()
    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hammine] scene window ready\n"))

    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))
    evbuf: Array[256, uint8]
    kbuf:  Array[256, uint8]
    while True:
        changed: int32 = 0
        # --- KEYBOARD: non-blocking drain of /keys, apply press lines.
        if kfd >= 0:
            kr: int64 = sys_read_nb(kfd, &kbuf[0], 255)
            if kr > 0:
                kls: uint64 = 0
                ki: uint64 = 0
                while ki <= cast[uint64](kr):
                    katend: int32 = 0
                    if ki == cast[uint64](kr):
                        katend = 1
                    if katend == 1 or kbuf[ki] == 10:
                        if ki > kls:
                            if hammine_key_line(&kbuf[kls], ki - kls) == 1:
                                changed = 1
                        kls = ki + 1
                    ki = ki + 1
        # --- POINTER: NON-BLOCKING drain of /event, hit-test buttons + field.
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            r: int64 = sys_read_nb(efd, &evbuf[0], 255)
            sys_close(efd)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            bx: int64 = 0
                            by: int64 = 0
                            bbtn: int64 = 0
                            if parse_pointer(&evbuf[ls], i - ls, &bx, &by,
                                             &bbtn) == 1:
                                now_down: int32 = 0
                                right: int32 = 0
                                if (bbtn & 1) != 0:
                                    now_down = 1
                                if (bbtn & 2) != 0 or (bbtn & 4) != 0:
                                    now_down = 1
                                    right = 1
                                if now_down != 0 and btn_down == 0:
                                    b: int64 = hammine_btn_at(bx, by)
                                    if b >= 0:
                                        hammine_ctrl_press(b)
                                        changed = 1
                                    else:
                                        cx: int32 = 0
                                        cy: int32 = 0
                                        if hammine_cell_at(bx, by, &cx, &cy) == 1:
                                            if hammine_field_click(cx, cy,
                                                                   right) == 1:
                                                changed = 1
                                btn_down = now_down
                        ls = i + 1
                    i = i + 1
        if changed != 0:
            emit_scene(wid)
        # Park OFF the runqueue: a keystroke wakes us instantly, the timeout
        # bounds the pointer re-poll.
        hamscene_park(kfd, PARK_MS)
    return 0

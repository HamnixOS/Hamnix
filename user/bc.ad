# user/bc.ad
#
# Hamnix `bc`: a native infix arithmetic calculator (integer POSIX
# subset). Reads expressions — one per line — from stdin, or from the
# FILE operands when given, and prints each result on its own line.
#
#   echo "2 + 3 * 4" | bc        -> 14
#   echo "(2 + 3) * 4" | bc      ->  20
#   printf 'x = 5\nx * x\n' | bc -> 25
#   echo "2 ^ 10" | bc          -> 1024
#   echo "7 % 3" | bc           ->  1
#   echo "3 < 5" | bc           ->  1   (relational -> 1/0, like bc)
#
# Grammar (lowest → highest precedence):
#   stmt   := IDENT '=' rel | rel
#   rel    := add (('<'|'<='|'>'|'>='|'=='|'!=') add)*
#   add    := term (('+'|'-') term)*
#   term   := unary (('*'|'/'|'%') unary)*
#   unary  := '-' unary | power
#   power  := primary ('^' unary)?          # ^ binds tighter than unary
#   primary:= NUMBER | IDENT | '(' rel ')'
#
# This is the calculator a sysadmin reaches for daily (byte math, ratios,
# powers of two). Integer-only — no `scale`/fractionals yet — which is
# the common case for shell arithmetic. Blank lines and everything after
# a '#' are ignored. A syntax error prints "bc: parse error" to stderr,
# skips that line, and continues (exit 2 if any line failed).

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def put_i64(n: int64):
    if n == 0:
        sys_write(1, "0\n", 2)
        return
    out: Array[32, uint8]
    i: uint64 = 0
    neg: int32 = 0
    v: uint64 = 0
    if n < 0:
        neg = 1
        v = cast[uint64](-n)
    else:
        v = cast[uint64](n)
    digits: Array[24, uint8]
    d: uint64 = 0
    while v != 0:
        digits[d] = cast[uint8](v % 10) + 48
        v = v / 10
        d = d + 1
    if neg != 0:
        out[i] = 45
        i = i + 1
    j: uint64 = 0
    while j < d:
        out[i] = digits[d - 1 - j]
        i = i + 1
        j = j + 1
    out[i] = 10
    i = i + 1
    sys_write(1, &out[0], i)


# ---- parser state (globals so the recursive descent stays off the
# kernel stack and shares one cursor) ----
LINE: Array[1024, uint8]      # current statement text (NUL-terminated)
POS: uint64 = 0               # cursor into LINE
PERR: int32 = 0               # set when a parse rule fails

# variable table: names are single tokens up to 15 bytes, 64 slots.
VNAMES: Array[1024, uint8]    # 64 * 16
VVALS: Array[64, int64]
NVARS: uint64 = 0


def is_space(c: uint8) -> int32:
    if c == 32 or c == 9:
        return 1
    return 0


def is_digit(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return 1
    return 0


def is_alpha(c: uint8) -> int32:
    if c >= 97 and c <= 122:
        return 1
    if c >= 65 and c <= 90:
        return 1
    if c == 95:
        return 1
    return 0


def skip_ws():
    while LINE[POS] != 0 and is_space(LINE[POS]) != 0:
        POS = POS + 1


def peek() -> uint8:
    return LINE[POS]


# look up / create a variable slot; returns its index, or 64 on overflow.
def var_slot(name: Ptr[uint8], nlen: uint64) -> uint64:
    i: uint64 = 0
    while i < NVARS:
        base: uint64 = i * 16
        same: int32 = 1
        k: uint64 = 0
        while k < nlen:
            if VNAMES[base + k] != name[k]:
                same = 0
                break
            k = k + 1
        if same != 0 and VNAMES[base + nlen] == 0:
            return i
        i = i + 1
    if NVARS >= 64:
        return 64
    if nlen > 15:
        nlen = 15
    base2: uint64 = NVARS * 16
    k2: uint64 = 0
    while k2 < nlen:
        VNAMES[base2 + k2] = name[k2]
        k2 = k2 + 1
    VNAMES[base2 + nlen] = 0
    VVALS[NVARS] = 0
    slot: uint64 = NVARS
    NVARS = NVARS + 1
    return slot


def parse_primary() -> int64:
    skip_ws()
    c: uint8 = peek()
    if c == 40:                       # '('
        POS = POS + 1
        v: int64 = parse_rel()
        skip_ws()
        if peek() == 41:              # ')'
            POS = POS + 1
        else:
            PERR = 1
        return v
    if is_digit(c) != 0:
        n: int64 = 0
        while is_digit(peek()) != 0:
            n = n * 10 + cast[int64](peek() - 48)
            POS = POS + 1
        return n
    if is_alpha(c) != 0:
        name: Array[16, uint8]
        nlen: uint64 = 0
        while (is_alpha(peek()) != 0 or is_digit(peek()) != 0) and nlen < 15:
            name[nlen] = peek()
            nlen = nlen + 1
            POS = POS + 1
        slot: uint64 = var_slot(&name[0], nlen)
        if slot >= 64:
            PERR = 1
            return 0
        return VVALS[slot]
    PERR = 1
    return 0


def parse_power() -> int64:
    base: int64 = parse_primary()
    skip_ws()
    if peek() == 94:                  # '^'
        POS = POS + 1
        exp: int64 = parse_unary()
        if exp < 0:
            if base == 1:
                return 1
            if base == 0-1:
                if (0 - exp) % 2 == 0:
                    return 1
                return 0 - 1
            return 0
        r: int64 = 1
        e: int64 = exp
        while e > 0:
            r = r * base
            e = e - 1
        return r
    return base


def parse_unary() -> int64:
    skip_ws()
    if peek() == 45:                  # unary '-'
        POS = POS + 1
        return 0 - parse_unary()
    if peek() == 43:                  # unary '+'
        POS = POS + 1
        return parse_unary()
    return parse_power()


def parse_term() -> int64:
    v: int64 = parse_unary()
    while True:
        skip_ws()
        op: uint8 = peek()
        if op == 42:                  # '*'
            POS = POS + 1
            v = v * parse_unary()
        elif op == 47:                # '/'
            POS = POS + 1
            d: int64 = parse_unary()
            if d == 0:
                PERR = 1
                return 0
            v = v / d
        elif op == 37:                # '%'
            POS = POS + 1
            m: int64 = parse_unary()
            if m == 0:
                PERR = 1
                return 0
            v = v % m
        else:
            break
    return v


def parse_add() -> int64:
    v: int64 = parse_term()
    while True:
        skip_ws()
        op: uint8 = peek()
        if op == 43:                  # '+'
            POS = POS + 1
            v = v + parse_term()
        elif op == 45:                # '-'
            POS = POS + 1
            v = v - parse_term()
        else:
            break
    return v


def bool01(b: int32) -> int64:
    if b != 0:
        return 1
    return 0


def parse_rel() -> int64:
    v: int64 = parse_add()
    while True:
        skip_ws()
        a: uint8 = peek()
        if a == 60:                   # '<'  '<='
            POS = POS + 1
            if peek() == 61:
                POS = POS + 1
                r: int64 = parse_add()
                v = bool01(v <= r)
            else:
                r2: int64 = parse_add()
                v = bool01(v < r2)
        elif a == 62:                 # '>'  '>='
            POS = POS + 1
            if peek() == 61:
                POS = POS + 1
                r3: int64 = parse_add()
                v = bool01(v >= r3)
            else:
                r4: int64 = parse_add()
                v = bool01(v > r4)
        elif a == 61:                 # '=='  (single '=' is stmt-level assign)
            if LINE[POS + 1] == 61:
                POS = POS + 2
                r5: int64 = parse_add()
                v = bool01(v == r5)
            else:
                break
        elif a == 33:                 # '!='
            if LINE[POS + 1] == 61:
                POS = POS + 2
                r6: int64 = parse_add()
                v = bool01(v != r6)
            else:
                break
        else:
            break
    return v


# Evaluate one statement line. Returns 0 ok, 1 on parse error, 2 on a
# blank/comment (no output).
def eval_line() -> int32:
    POS = 0
    PERR = 0
    skip_ws()
    if peek() == 0 or peek() == 35:   # blank or leading '#'
        return 2

    # Assignment?  IDENT '=' rel   (but not '==').
    save: uint64 = POS
    if is_alpha(peek()) != 0:
        name: Array[16, uint8]
        nlen: uint64 = 0
        while (is_alpha(peek()) != 0 or is_digit(peek()) != 0) and nlen < 15:
            name[nlen] = peek()
            nlen = nlen + 1
            POS = POS + 1
        skip_ws()
        if peek() == 61 and LINE[POS + 1] != 61:
            POS = POS + 1
            val: int64 = parse_rel()
            skip_ws()
            if PERR != 0 or peek() != 0:
                write_str(2, "bc: parse error\n")
                return 1
            slot: uint64 = var_slot(&name[0], nlen)
            if slot >= 64:
                write_str(2, "bc: too many variables\n")
                return 1
            VVALS[slot] = val
            return 2                   # assignment prints nothing (like bc)
        POS = save                     # not an assignment; re-parse as expr

    r: int64 = parse_rel()
    skip_ws()
    if PERR != 0 or peek() != 0:
        write_str(2, "bc: parse error\n")
        return 1
    put_i64(r)
    return 0


# Feed a NUL-terminated buffer to the evaluator, splitting on newlines.
# Returns nonzero if any line had a parse error.
def run_buffer(buf: Ptr[uint8], blen: uint64) -> int32:
    had_err: int32 = 0
    i: uint64 = 0
    while i < blen:
        # copy one line (up to newline) into LINE
        j: uint64 = 0
        while i < blen and buf[i] != 10 and j < 1023:
            LINE[j] = buf[i]
            j = j + 1
            i = i + 1
        LINE[j] = 0
        # skip to end of this source line
        while i < blen and buf[i] != 10:
            i = i + 1
        if i < blen:
            i = i + 1                  # consume the newline
        rc: int32 = eval_line()
        if rc == 1:
            had_err = 1
    return had_err


INBUF: Array[8192, uint8]


def read_all_fd(fd: int32) -> uint64:
    total: uint64 = 0
    while total < 8191:
        n: int64 = sys_read(fd, &INBUF[total], 8191 - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    INBUF[total] = 0
    return total


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    had_err: int32 = 0

    if argc < 2:
        blen: uint64 = read_all_fd(0)
        had_err = run_buffer(&INBUF[0], blen)
    else:
        ai: int32 = 1
        while ai < argc:
            path: Ptr[char] = cast[Ptr[char]](argv[ai])
            fd: int32 = sys_open(path)
            if fd < 0:
                write_str(2, "bc: cannot open ")
                write_str(2, cast[Ptr[uint8]](path))
                write_str(2, "\n")
                had_err = 1
            else:
                blen2: uint64 = read_all_fd(fd)
                if run_buffer(&INBUF[0], blen2) != 0:
                    had_err = 1
                sys_close(fd)
            ai = ai + 1

    if had_err != 0:
        return 2
    return 0

# user/numfmt.ad
#
# Hamnix `numfmt`: convert numbers to/from human-readable forms.
#
#   --from=auto|si|iec     parse a scaled input number (K/M/G... suffix)
#   --to=si|iec|iec-i      scale a number to a 1-3 digit + suffix form
#   --suffix=STR           append/strip STR (e.g. "B") after the number
#   --padding=N            right-justify the result in a field of N
#                          (negative N left-justifies)
#   --from-unit / --to-unit are NOT supported (uncommon).
#
# Numbers come from argv (after the options) or, with no number args,
# from stdin one token per line (the whole line is the number field —
# field splitting/`--field` is not implemented; the common pipe case is
# one number per line).
#
# Scaling matches GNU:
#   si  : 1000-base, suffixes K M G T P E
#   iec : 1024-base, suffixes K M G T P E
#   iec-i: 1024-base, suffixes Ki Mi Gi Ti Pi Ei
# Human rounding shows one decimal when the scaled value < 10
# (e.g. 1024 --to=iec -> "1.0K"), otherwise rounds UP to a whole number
# (GNU rounds toward +inf), e.g. 1025 --to=si -> "1.1K".

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


# Option state.
from_mode: int32 = 0      # 0 none, 1 auto, 2 si, 3 iec
to_mode: int32 = 0        # 0 none, 1 si, 2 iec, 3 iec-i
suffix: Ptr[uint8]
suffix_len: uint64 = 0
padding: int64 = 0

outbuf: Array[64, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


# Does string s start with prefix p?  Returns the index after p on a
# match, else 0.
def starts_with(s: Ptr[uint8], p: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while p[i] != 0:
        if s[i] != p[i]:
            return 0
        i = i + 1
    return i


# Render decimal v into out[at..], return new index.
def put_u64_at(v: uint64, out: Ptr[uint8], at: uint64) -> uint64:
    if v == 0:
        out[at] = 48
        return at + 1
    tmp: Array[24, uint8]
    i: uint64 = 0
    while v != 0:
        tmp[i] = cast[uint8](v % 10) + 48
        v = v / 10
        i = i + 1
    j: uint64 = 0
    while j < i:
        out[at + j] = tmp[i - 1 - j]
        j = j + 1
    return at + i


# Suffix letter -> power index (K=1..E=6), or 0 if not a scale letter.
def scale_index(c: uint8) -> int64:
    if c == 75 or c == 107:    # K k
        return 1
    if c == 77:                # M
        return 2
    if c == 71:                # G
        return 3
    if c == 84:                # T
        return 4
    if c == 80:                # P
        return 5
    if c == 69:                # E
        return 6
    return 0


# Parse a (possibly scaled) input number into an integer value.
# Honours from_mode: auto detects K(1000) vs Ki(1024); si forces 1000;
# iec forces 1024. Returns 0 ok (value in *out), -1 on parse error.
def parse_number(s: Ptr[uint8], slen: uint64, out: Ptr[uint64]) -> int32:
    if slen == 0:
        return -1
    v: uint64 = 0
    i: uint64 = 0
    while i < slen:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[uint64](c - 48)
        i = i + 1
    if i == 0:
        return -1
    # Optional scale suffix.
    if i < slen:
        idx: int64 = scale_index(s[i])
        if idx == 0:
            return -1
        base: uint64 = 1000
        if from_mode == 3:
            base = 1024
        elif from_mode == 1:
            # auto: a trailing 'i' (or implicit) means 1024.
            if i + 1 < slen and s[i + 1] == 105:    # 'i'
                base = 1024
            else:
                base = 1000
        k: int64 = 0
        while k < idx:
            v = v * base
            k = k + 1
    out[0] = v
    return 0


# Scale value v into a human string per to_mode, writing into out at
# `at`, returning the new index.
def format_scaled(v: uint64, out: Ptr[uint8], at: uint64) -> uint64:
    base: uint64 = 1000
    if to_mode == 2 or to_mode == 3:
        base = 1024
    # Find the largest power such that v / base^p still >= 1 (and < base
    # at that level for the digit form). We carry a remainder to round.
    p: int64 = 0
    val: uint64 = v
    while val >= base and p < 6:
        # Only advance if the next level keeps it readable (val>=base).
        val = val / base
        p = p + 1
    # val is now the integer part at level p; recover a fractional digit
    # by recomputing the scaled quotient with one decimal of precision.
    pos: uint64 = at
    if p == 0:
        pos = put_u64_at(v, out, pos)
    else:
        # divisor = base^p
        divisor: uint64 = 1
        q: int64 = 0
        while q < p:
            divisor = divisor * base
            q = q + 1
        whole: uint64 = v / divisor
        rem: uint64 = v - whole * divisor
        if whole < 10:
            # One decimal place, rounded UP (toward +inf) like GNU.
            # tenths = ceil(rem*10 / divisor)
            num: uint64 = rem * 10
            tenths: uint64 = num / divisor
            if tenths * divisor < num:
                tenths = tenths + 1
            if tenths >= 10:
                whole = whole + 1
                tenths = 0
            pos = put_u64_at(whole, out, pos)
            out[pos] = 46                       # '.'
            pos = pos + 1
            out[pos] = cast[uint8](tenths) + 48
            pos = pos + 1
        else:
            # No decimal; round the whole part UP if there's a remainder.
            if rem != 0:
                whole = whole + 1
            pos = put_u64_at(whole, out, pos)
        # Suffix letter.
        letters: Ptr[uint8] = cast[Ptr[uint8]]("0KMGTPE")
        out[pos] = letters[cast[uint64](p)]
        pos = pos + 1
        if to_mode == 3:                        # iec-i: add 'i'
            out[pos] = 105
            pos = pos + 1
    return pos


# Process one number string and emit the (formatted) result + newline.
def process(s: Ptr[uint8], slen: uint64) -> int32:
    # Strip a trailing --suffix from the input if present (GNU does).
    eff_len: uint64 = slen
    if suffix != cast[Ptr[uint8]](0) and suffix_len > 0 and slen >= suffix_len:
        matched: int32 = 1
        k: uint64 = 0
        while k < suffix_len:
            if s[slen - suffix_len + k] != suffix[k]:
                matched = 0
                break
            k = k + 1
        if matched != 0:
            eff_len = slen - suffix_len

    v: uint64 = 0
    if from_mode != 0:
        if parse_number(s, eff_len, &v) != 0:
            write_str(2, "numfmt: invalid number\n")
            return 1
    else:
        # Plain decimal parse.
        if parse_number(s, eff_len, &v) != 0:
            write_str(2, "numfmt: invalid number\n")
            return 1

    pos: uint64 = 0
    if to_mode != 0:
        pos = format_scaled(v, &outbuf[0], 0)
    else:
        pos = put_u64_at(v, &outbuf[0], 0)
    # Append the suffix on output.
    if suffix != cast[Ptr[uint8]](0):
        si: uint64 = 0
        while si < suffix_len:
            outbuf[pos] = suffix[si]
            pos = pos + 1
            si = si + 1

    # Padding: right-justify in |padding|, or left-justify if negative.
    width: uint64 = 0
    left: int32 = 0
    if padding > 0:
        width = cast[uint64](padding)
    elif padding < 0:
        width = cast[uint64](-padding)
        left = 1
    if width > pos:
        pad: uint64 = width - pos
        if left == 0:
            sp: uint64 = 0
            while sp < pad:
                sys_write(1, " ", 1)
                sp = sp + 1
            sys_write(1, &outbuf[0], pos)
        else:
            sys_write(1, &outbuf[0], pos)
            sp: uint64 = 0
            while sp < pad:
                sys_write(1, " ", 1)
                sp = sp + 1
    else:
        sys_write(1, &outbuf[0], pos)
    sys_write(1, "\n", 1)
    return 0


inbuf: Array[4096, uint8]


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    first_num: int32 = 0
    ai: int32 = 1
    while ai < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
        if a[0] == 45 and a[1] == 45:                 # "--..."
            rest: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](a) + 2)
            adv: uint64 = starts_with(rest, "from=")
            if adv != 0:
                val: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](rest) + adv)
                if starts_with(val, "auto") != 0:
                    from_mode = 1
                elif starts_with(val, "iec") != 0:
                    from_mode = 3
                elif starts_with(val, "si") != 0:
                    from_mode = 2
                else:
                    write_str(2, "numfmt: bad --from\n")
                    return 1
                ai = ai + 1
                continue
            adv = starts_with(rest, "to=")
            if adv != 0:
                val: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](rest) + adv)
                if starts_with(val, "iec-i") != 0:
                    to_mode = 3
                elif starts_with(val, "iec") != 0:
                    to_mode = 2
                elif starts_with(val, "si") != 0:
                    to_mode = 1
                else:
                    write_str(2, "numfmt: bad --to\n")
                    return 1
                ai = ai + 1
                continue
            adv = starts_with(rest, "suffix=")
            if adv != 0:
                suffix = cast[Ptr[uint8]](cast[uint64](rest) + adv)
                suffix_len = strlen_u8(suffix)
                ai = ai + 1
                continue
            adv = starts_with(rest, "padding=")
            if adv != 0:
                pv: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](rest) + adv)
                neg: int32 = 0
                pi: uint64 = 0
                if pv[0] == 45:
                    neg = 1
                    pi = 1
                pval: int64 = 0
                while pv[pi] != 0:
                    c: uint8 = pv[pi]
                    if c < 48 or c > 57:
                        write_str(2, "numfmt: bad --padding\n")
                        return 1
                    pval = pval * 10 + cast[int64](c - 48)
                    pi = pi + 1
                if neg != 0:
                    pval = -pval
                padding = pval
                ai = ai + 1
                continue
            write_str(2, "numfmt: unknown option\n")
            return 1
        elif a[0] == 45 and a[1] != 0:
            write_str(2, "numfmt: unknown option\n")
            return 1
        else:
            # First non-option is a number to process.
            if process(a, strlen_u8(a)) != 0:
                return 1
            first_num = 1
        ai = ai + 1

    if first_num != 0:
        return 0

    # No number args: read stdin, one number per line.
    total: uint64 = 0
    while total < 4096:
        n: int64 = sys_read(0, &inbuf[total], 4096 - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    i: uint64 = 0
    while i < total:
        # Skip leading blanks.
        while i < total and (inbuf[i] == 32 or inbuf[i] == 9):
            i = i + 1
        start: uint64 = i
        while i < total and inbuf[i] != 10:
            i = i + 1
        end: uint64 = i
        # Trim trailing blanks/CR.
        while end > start and (inbuf[end - 1] == 32 or inbuf[end - 1] == 9 or inbuf[end - 1] == 13):
            end = end - 1
        if end > start:
            if process(cast[Ptr[uint8]](cast[uint64](&inbuf[0]) + start),
                       end - start) != 0:
                return 1
        if i < total:
            i = i + 1
    return 0

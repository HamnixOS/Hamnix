# user/browserhist_host.ad — HOST unit-test harness for lib/browserhistory.ad.
#
# Drives the Back/Forward session-history model directly (no browser, no fetch,
# no QEMU) and prints a trace so a gate can assert the classic browser history
# semantics: push discards forward entries, back()/forward() walk the cursor
# without pushing, and can_back/can_fwd gate the buttons. Built for x86_64-linux.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

from lib.browserhistory import browserhist_reset, browserhist_push, \
    browserhist_back, browserhist_fwd, browserhist_can_back, \
    browserhist_can_fwd, browserhist_cur_ptr, browserhist_count, \
    browserhist_index


obuf: Array[512, uint8]
obn: uint64 = 0


def _o_ch(c: uint8):
    obuf[obn] = c
    obn = obn + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    d: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        d[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(d[n])


def _flush():
    if obn > 0:
        sys_write(1, &obuf[0], obn)
        obn = 0


# Emit "STATE <tag> cur=<url|-> idx=<i> count=<n> back=<0|1> fwd=<0|1>".
def _state(tag: Ptr[uint8]):
    _o_str(cast[Ptr[uint8]]("STATE "))
    _o_str(tag)
    _o_str(cast[Ptr[uint8]](" cur="))
    p: Ptr[uint8] = browserhist_cur_ptr()
    if cast[uint64](p) == 0:
        _o_ch(45)
    else:
        _o_str(p)
    _o_str(cast[Ptr[uint8]](" idx="))
    _o_dec(cast[int64](browserhist_index()))
    _o_str(cast[Ptr[uint8]](" count="))
    _o_dec(cast[int64](browserhist_count()))
    _o_str(cast[Ptr[uint8]](" back="))
    _o_dec(cast[int64](browserhist_can_back()))
    _o_str(cast[Ptr[uint8]](" fwd="))
    _o_dec(cast[int64](browserhist_can_fwd()))
    _o_ch(10)
    _flush()


def _push(u: Ptr[uint8]):
    n: uint64 = 0
    while u[n] != 0:
        n = n + 1
    browserhist_push(u, n)


# Move back and report whether a URL came back (BACK ok=<0|1>), then the state.
def _back():
    r: Ptr[uint8] = browserhist_back()
    _o_str(cast[Ptr[uint8]]("BACK ok="))
    if cast[uint64](r) == 0:
        _o_ch(48)
    else:
        _o_ch(49)
    _o_ch(10)
    _flush()
    _state(cast[Ptr[uint8]]("after_back"))


def _fwd():
    r: Ptr[uint8] = browserhist_fwd()
    _o_str(cast[Ptr[uint8]]("FWD ok="))
    if cast[uint64](r) == 0:
        _o_ch(48)
    else:
        _o_ch(49)
    _o_ch(10)
    _flush()
    _state(cast[Ptr[uint8]]("after_fwd"))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    browserhist_reset()
    _state(cast[Ptr[uint8]]("empty"))

    # Visit A, B, C.
    _push(cast[Ptr[uint8]]("http://a/"))
    _push(cast[Ptr[uint8]]("http://b/"))
    _push(cast[Ptr[uint8]]("http://c/"))
    _state(cast[Ptr[uint8]]("visited_abc"))

    # Reload C — a push equal to the current entry is a no-op (count stays 3).
    _push(cast[Ptr[uint8]]("http://c/"))
    _state(cast[Ptr[uint8]]("reload_c"))

    # Back C->B->A; a third back is refused (already at the oldest).
    _back()          # -> B
    _back()          # -> A
    _back()          # refused (at oldest)

    # Forward A->B.
    _fwd()           # -> B

    # From B, visit D: forward history (C) is discarded, D becomes the tip.
    _push(cast[Ptr[uint8]]("http://d/"))
    _state(cast[Ptr[uint8]]("branch_d"))

    # Forward from the tip is refused (C is gone).
    _fwd()           # refused

    return 0

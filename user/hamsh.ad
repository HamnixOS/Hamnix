# user/hamsh.ad
#
# Hamnix shell — the first interactive user program in Hamnix. Reads
# a line from stdin, tokenises on whitespace, dispatches to a builtin
# (exit / help) or spawns the named external command from the cpio
# initramfs via SYS_SPAWN + SYS_WAITPID. Mirrors a stripped-down bash
# main loop:
#
#   while read line:
#       argv = tokenize(line)
#       if argv[0] in builtins: run it inline
#       else: pid = spawn(argv[0], argv); waitpid(pid)
#
# Constraints baked into M16.34 / M16.35:
#   - 16550 RX has no kernel-side software buffer; piped input loses
#     bytes past ~16 chars during boot. Interactive typing is fine.
#   - sys_spawn looks up the path in the cpio archive verbatim — there
#     is no PATH search, so commands must start with '/'.
#   - argv is passed as a NULL-terminated Ptr[uint64] (each slot is a
#     Ptr[char] cast to uint64). The kernel copies the strings onto
#     the new task's user stack and stages argc/argv in %rdi/%rsi for
#     _start; main() picks them up as ordinary SysV first-two args.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       user/hamsh.ad -o build/user/hamsh.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_spawn(path: Ptr[char], argv: Ptr[uint64],
                     stdin_fd: int32, stdout_fd: int32,
                     envp: Ptr[uint64]) -> int32
extern def sys_waitpid(pid: int32) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_pipe(fds: Ptr[int32]) -> int32
extern def sys_chdir(path: Ptr[char]) -> int32
extern def sys_getcwd(buf: Ptr[uint8], count: uint64) -> int64
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32
extern def sys_exit(code: uint64)


LINE_MAX:    uint64 = 128
ARGV_MAX:    uint64 = 16
PIPE_MAX:    uint64 = 4              # max stages = PIPE_MAX + 1

# Single global line + argv buffer. The argv pointer array is handed
# straight to sys_spawn; the kernel reads it before the child runs so
# overwriting it on the next iteration is safe.
line_buf: Array[128, uint8]
argv_buf: Array[16, uint64]
# Per-stage state for an N-stage pipeline: seg_start[i] is the index
# into argv_buf where stage i's argv begins. Stages are NUL-terminated
# in argv_buf so each &argv_buf[seg_start[i]] is a valid SYS_SPAWN
# argv pointer. seg_pid[i] holds the spawned pid for waitpid'ing
# after every stage has launched.
seg_start: Array[5, uint64]
seg_pid:   Array[5, int32]
# 2 fds per pipe (rfd, wfd) stored back-to-back.
pipe_fds:  Array[8, int32]

# Last command's exit status — exposed to user input as `$?` and
# returned as our own exit code on the natural `exit` builtin.
# 0 by default so a fresh shell's `$?` reads as success.
last_exit_code: int32 = 0

# Backing storage for $? expansion. Holds the ASCII decimal of
# last_exit_code with a NUL terminator. tokenize substitutes the
# `$?` literal token with a pointer into this buffer.
exit_str_buf: Array[8, uint8]

# M16.x: scratch arena for in-token `$VAR` / `$?` substitution.
# Tokens like `X=$Y` or `prefix-$ID` get rewritten into expand_buf
# (NUL-terminated) and the corresponding argv_buf slot is repointed
# at the new bytes. `expand_cursor` is the next free byte; reset at
# the top of process_line's expansion pass. Sized 1024 — enough for
# ARGV_MAX (16) tokens each up to ~60 bytes of expanded text.
EXPAND_BUF_MAX: uint64 = 1024
expand_buf:    Array[1024, uint8]
expand_cursor: uint64 = 0
# Sticky flag so the "expand_buf full" warning fires only once per
# shell run. Set the first time _expand_token has to bail out.
expand_overflow_warned: uint32 = 0
# Scratch identifier buffer used by _expand_token to build the
# NUL-terminated NAME before var_get. Hoisted to BSS to dodge the
# Array-in-nested-frames compiler bug (U9). 24 bytes covers
# VAR_NAME_MAX (16) plus slack.
expand_name_tmp: Array[24, uint8]

# M16.76: shell variables. Flat table — 8 slots, fixed-size
# name + value. NAME=VALUE assignment is recognized when a token
# matches that shape (first '=' splits). $NAME substitutes if the
# variable exists; otherwise the token stays literal so the user
# can see they fat-fingered.
VAR_MAX:    uint64 = 8
VAR_NAME_MAX:  uint64 = 16
VAR_VALUE_MAX: uint64 = 48

class ShellVar:
    used:  uint32
    pad:   uint32
    name:  Array[16, uint8]
    value: Array[48, uint8]

var_table: Array[8, ShellVar]


def var_name_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while True:
        ca: uint8 = a[i]
        cb: uint8 = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1


def var_get(name: Ptr[uint8]) -> Ptr[uint8]:
    # Returns pointer to value bytes (NUL-terminated) or nullptr on
    # miss. The returned pointer aliases into var_table; valid until
    # the next var_set on the same slot.
    i: uint64 = 0
    while i < VAR_MAX:
        if var_table[i].used != 0:
            if var_name_eq(&var_table[i].name[0], name) != 0:
                return &var_table[i].value[0]
        i = i + 1
    return cast[Ptr[uint8]](0)


def var_set(name: Ptr[uint8], value: Ptr[uint8]) -> int32:
    # Find existing slot or first free. NAME / VALUE longer than the
    # static caps get clipped (no error — keeps the parser stuck
    # responses to a minimum). Returns 1 on store, 0 on table-full.
    free: int64 = -1
    i: uint64 = 0
    while i < VAR_MAX:
        if var_table[i].used != 0:
            if var_name_eq(&var_table[i].name[0], name) != 0:
                free = cast[int64](i)
                break
        else:
            if free < 0:
                free = cast[int64](i)
        i = i + 1
    if free < 0:
        return 0
    slot: uint64 = cast[uint64](free)
    # Copy name (clipped).
    j: uint64 = 0
    while j + 1 < VAR_NAME_MAX and name[j] != 0:
        var_table[slot].name[j] = name[j]
        j = j + 1
    var_table[slot].name[j] = 0
    # Copy value (clipped).
    k: uint64 = 0
    while k + 1 < VAR_VALUE_MAX and value[k] != 0:
        var_table[slot].value[k] = value[k]
        k = k + 1
    var_table[slot].value[k] = 0
    var_table[slot].used = 1
    return 1


def _render_exit_code(v: int32):
    # Populate exit_str_buf with the decimal ASCII of `v` + NUL.
    # Handles negatives via a leading '-' (waitpid signals etc).
    n: uint32 = 0
    if v < 0:
        exit_str_buf[0] = 45                       # '-'
        n = cast[uint32](-v)
        # Convert n to decimal at positions [1..].
        if n == 0:
            exit_str_buf[1] = 48                   # '0'
            exit_str_buf[2] = 0
            return
        # Determine length: simple digit counter.
        digits: Array[8, uint8]
        di: uint32 = 0
        while n > 0:
            digits[di] = cast[uint8]((n % 10) + 48)
            n = n / 10
            di = di + 1
        # Reverse-copy into output starting at index 1.
        oi: uint32 = 1
        while di > 0:
            di = di - 1
            exit_str_buf[oi] = digits[di]
            oi = oi + 1
        exit_str_buf[oi] = 0
        return
    n = cast[uint32](v)
    if n == 0:
        exit_str_buf[0] = 48
        exit_str_buf[1] = 0
        return
    digits: Array[8, uint8]
    di: uint32 = 0
    while n > 0:
        digits[di] = cast[uint8]((n % 10) + 48)
        n = n / 10
        di = di + 1
    oi: uint32 = 0
    while di > 0:
        di = di - 1
        exit_str_buf[oi] = digits[di]
        oi = oi + 1
    exit_str_buf[oi] = 0


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    # Byte-exact equality of two NUL-terminated strings. Returns 1
    # on match, 0 on mismatch — opposite sense to libc's strcmp but
    # easier to read at call sites.
    i: uint64 = 0
    while True:
        ca: uint8 = a[i]
        cb: uint8 = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1


def is_space(c: uint8) -> int32:
    # Treat ASCII space, tab, LF, CR as token separators. fs/vfs.ad
    # already maps incoming CR → LF on the stdin path, but we accept
    # both to keep tokenise robust against future shell-pipe inputs.
    if c == 32:
        return 1
    if c == 9:
        return 1
    if c == 10:
        return 1
    if c == 13:
        return 1
    return 0


def _is_name_start(c: uint8) -> int32:
    # First character of a bash identifier: [A-Za-z_].
    if c >= 65 and c <= 90:
        return 1
    if c >= 97 and c <= 122:
        return 1
    if c == 95:
        return 1
    return 0


def _is_name_cont(c: uint8) -> int32:
    # Subsequent characters of a bash identifier: [A-Za-z_0-9].
    if _is_name_start(c) != 0:
        return 1
    if c >= 48 and c <= 57:
        return 1
    return 0


def _token_has_dollar(tok: Ptr[uint8]) -> int32:
    # Cheap pre-filter: skip the expansion-write pass entirely for
    # tokens with no '$' byte (the common case after tokenize).
    i: uint64 = 0
    while tok[i] != 0:
        if tok[i] == 36:                                # '$'
            return 1
        i = i + 1
    return 0


def _expand_token(tok: Ptr[uint8]) -> Ptr[uint8]:
    # Walk `tok` once, copying literal bytes into expand_buf and
    # substituting `$?` / `$NAME` as we find them. Identifier match
    # is greedy: [A-Za-z_][A-Za-z_0-9]*. A `$` followed by anything
    # else (digit, symbol, EOS) is copied through literally — same
    # behavior as bash for unsupported V0 forms ($5, $!, $$, …).
    # Returns a pointer to the start of the expansion in expand_buf
    # (NUL-terminated), or nullptr if the buffer would overflow.
    start: uint64 = expand_cursor
    i: uint64 = 0
    while tok[i] != 0:
        c: uint8 = tok[i]
        if c == 36:                                     # '$'
            nxt: uint8 = tok[i + 1]
            if nxt == 63:                               # '$?'
                # Copy exit_str_buf bytes (pre-rendered by caller).
                j: uint64 = 0
                while exit_str_buf[j] != 0:
                    if expand_cursor + 1 >= EXPAND_BUF_MAX:
                        if expand_overflow_warned == 0:
                            write_str(2, "hamsh: expand_buf full\n")
                            expand_overflow_warned = 1
                        return cast[Ptr[uint8]](0)
                    expand_buf[expand_cursor] = exit_str_buf[j]
                    expand_cursor = expand_cursor + 1
                    j = j + 1
                i = i + 2
            elif _is_name_start(nxt) != 0:
                # Greedy identifier: NAME = [A-Za-z_][A-Za-z_0-9]*.
                name_start: uint64 = i + 1
                name_end:   uint64 = name_start + 1
                while _is_name_cont(tok[name_end]) != 0:
                    name_end = name_end + 1
                # Build NUL-terminated NAME in the BSS scratch buf
                # (16-byte cap matches VAR_NAME_MAX; longer names
                # won't var_get anyway and will fall through to the
                # literal path).
                nlen: uint64 = name_end - name_start
                if nlen >= 24:
                    nlen = 23
                ni: uint64 = 0
                while ni < nlen:
                    expand_name_tmp[ni] = tok[name_start + ni]
                    ni = ni + 1
                expand_name_tmp[nlen] = 0
                v: Ptr[uint8] = var_get(&expand_name_tmp[0])
                if cast[uint64](v) != 0:
                    # Hit — copy value bytes.
                    k: uint64 = 0
                    while v[k] != 0:
                        if expand_cursor + 1 >= EXPAND_BUF_MAX:
                            if expand_overflow_warned == 0:
                                write_str(2,
                                    "hamsh: expand_buf full\n")
                                expand_overflow_warned = 1
                            return cast[Ptr[uint8]](0)
                        expand_buf[expand_cursor] = v[k]
                        expand_cursor = expand_cursor + 1
                        k = k + 1
                else:
                    # Miss — copy literal `$NAME` so typos surface.
                    li: uint64 = i
                    while li < name_end:
                        if expand_cursor + 1 >= EXPAND_BUF_MAX:
                            if expand_overflow_warned == 0:
                                write_str(2,
                                    "hamsh: expand_buf full\n")
                                expand_overflow_warned = 1
                            return cast[Ptr[uint8]](0)
                        expand_buf[expand_cursor] = tok[li]
                        expand_cursor = expand_cursor + 1
                        li = li + 1
                i = name_end
            else:
                # `$` followed by digit / symbol / NUL — copy literal
                # `$`, advance one. NUL case is harmless: outer loop
                # exits next iteration.
                if expand_cursor + 1 >= EXPAND_BUF_MAX:
                    if expand_overflow_warned == 0:
                        write_str(2, "hamsh: expand_buf full\n")
                        expand_overflow_warned = 1
                    return cast[Ptr[uint8]](0)
                expand_buf[expand_cursor] = 36
                expand_cursor = expand_cursor + 1
                i = i + 1
        else:
            if expand_cursor + 1 >= EXPAND_BUF_MAX:
                if expand_overflow_warned == 0:
                    write_str(2, "hamsh: expand_buf full\n")
                    expand_overflow_warned = 1
                return cast[Ptr[uint8]](0)
            expand_buf[expand_cursor] = c
            expand_cursor = expand_cursor + 1
            i = i + 1
    # NUL-terminate the expanded token, advance past the NUL.
    if expand_cursor >= EXPAND_BUF_MAX:
        if expand_overflow_warned == 0:
            write_str(2, "hamsh: expand_buf full\n")
            expand_overflow_warned = 1
        return cast[Ptr[uint8]](0)
    expand_buf[expand_cursor] = 0
    expand_cursor = expand_cursor + 1
    return &expand_buf[start]


def tokenize(line: Ptr[uint8], n: uint64,
             argv: Ptr[uint64], argv_max: uint64) -> uint64:
    # In-place whitespace tokenizer with double-quote support.
    # Builds a tokenized line by writing back into the SAME buffer:
    # a `read` cursor `i` scans forward, a `write` cursor `w` lays
    # down NUL-terminated spans. Double quotes around a region let
    # whitespace through to the same token (matches sh's "..." form).
    # Single quotes and backslash escapes aren't supported yet.
    argc: uint64 = 0
    i:    uint64 = 0
    w:    uint64 = 0
    while i < n:
        # Skip whitespace AND our own NULs (left behind as terminators
        # for previously-emitted tokens). The write cursor advances
        # ahead of `i` when we strip quote characters, so the byte at
        # line[i] after the previous token may be either the original
        # separator or a stale NUL — both should be skipped.
        while i < n and (is_space(line[i]) != 0 or line[i] == 0):
            i = i + 1
        if i >= n:
            break
        if argc + 1 < argv_max:
            argv[argc] = cast[uint64](&line[w])
            argc = argc + 1
        # Consume one token. `in_quote` tracks whether we're inside
        # a "..." span; while quoted, whitespace counts as content.
        in_quote: int32 = 0
        while i < n:
            c: uint8 = line[i]
            if in_quote == 0 and is_space(c) != 0:
                break
            if c == 34:                              # '"'
                in_quote = 1 - in_quote
                i = i + 1
                continue
            line[w] = c
            w = w + 1
            i = i + 1
        line[w] = 0                                  # terminate this token
        w = w + 1
    argv[argc] = 0
    return argc


def find_token(argv: Ptr[uint64], argc: uint64, tok: uint8) -> uint64:
    # Walk argv looking for the single-char token `tok`. Returns the
    # LAST occurrence's index, or argc if not found. Used by `>` —
    # bash-compat for the simple cases we care about.
    found: uint64 = argc
    i: uint64 = 0
    while i < argc:
        s: Ptr[uint8] = cast[Ptr[uint8]](argv[i])
        if s[0] == tok and s[1] == 0:
            found = i
        i = i + 1
    return found


def split_segments(argv: Ptr[uint64], argc: uint64,
                   starts: Ptr[uint64], max_segs: uint64) -> uint64:
    # Slice argv at every "|" boundary. starts[i] is the index in
    # argv where segment i begins; NULs the "|" token in place so
    # each &argv[starts[i]] is a valid NUL-terminated argv for
    # SYS_SPAWN. Returns the segment count, capped at max_segs.
    # An empty segment (consecutive pipes or leading/trailing "|")
    # surfaces as a zero-length segment and is the caller's problem.
    starts[0] = 0
    nseg: uint64 = 1
    i: uint64 = 0
    while i < argc and nseg < max_segs:
        s: Ptr[uint8] = cast[Ptr[uint8]](argv[i])
        if s[0] == 124 and s[1] == 0:                # '|'
            argv[i] = 0                              # terminate prior seg
            starts[nseg] = i + 1
            nseg = nseg + 1
        i = i + 1
    return nseg


def print_prompt():
    # Show the cwd in the prompt so `cd` feedback is immediate.
    # Without this users have no visual confirmation that cd worked
    # (or didn't) and accumulate junk paths via `cd nope/nope/nope`.
    cwd: Array[256, uint8]
    n: int64 = sys_getcwd(&cwd[0], 256)
    if n > 0:
        # sys_getcwd writes a NUL-terminated string; n includes the NUL.
        # Skip the trailing NUL when writing to stdout.
        nlen: uint64 = cast[uint64](n)
        if nlen > 0 and cwd[nlen - 1] == 0:
            nlen = nlen - 1
        sys_write(1, &cwd[0], nlen)
    sys_write(1, "$ ", 2)


# M16.x: small history ring. Stores up to HISTORY_MAX completed
# lines; arrow-Up walks backward through them, arrow-Down walks
# forward. Each slot is sized to the same 128-byte line cap as
# line_buf so we can memcpy snapshots in either direction. The
# `history_count` field is the TOTAL number of lines ever pushed
# (mod arithmetic on HISTORY_MAX picks the slot); we keep the
# absolute count so first-time arrow-Up reliably hits the most
# recent entry even after the ring wraps.
HISTORY_MAX:  uint64 = 16
HISTORY_LINE: uint64 = 128
history_buf:   Array[2048, uint8]               # 16 * 128
history_count: uint64 = 0


def _history_store(buf: Ptr[uint8], n: uint64):
    # Copy `buf[0..n)` into the next history slot; NUL-terminate.
    # Skip a blank or single-newline entry — those would push real
    # history out of the ring with nothing useful.
    if n == 0:
        return
    if n == 1 and (buf[0] == 0x0A or buf[0] == 0x0D):
        return
    slot: uint64 = history_count % HISTORY_MAX
    base: uint64 = slot * HISTORY_LINE
    copy_len: uint64 = n
    if copy_len >= HISTORY_LINE:
        copy_len = HISTORY_LINE - 1
    # Trim trailing CR/LF — history entries store the raw command,
    # not the keystroke that terminated it.
    while copy_len > 0 \
            and (buf[copy_len - 1] == 0x0A \
                 or buf[copy_len - 1] == 0x0D):
        copy_len = copy_len - 1
    i: uint64 = 0
    while i < copy_len:
        history_buf[base + i] = buf[i]
        i = i + 1
    history_buf[base + i] = 0
    history_count = history_count + 1


def _history_load(idx_back: uint64, out: Ptr[uint8], cap: uint64) -> uint64:
    # Load history entry `idx_back` slots back from the most recent
    # (idx_back=0 → most recent, 1 → second-most-recent, ...). Writes
    # NUL-terminated bytes into `out`; returns the length (excluding
    # NUL). Returns 0 if no such entry exists.
    if history_count == 0:
        return 0
    if idx_back >= history_count or idx_back >= HISTORY_MAX:
        return 0
    slot: uint64 = (history_count - 1 - idx_back) % HISTORY_MAX
    base: uint64 = slot * HISTORY_LINE
    j: uint64 = 0
    while j + 1 < cap and history_buf[base + j] != 0:
        out[j] = history_buf[base + j]
        j = j + 1
    out[j] = 0
    return j


def _erase_n(n: uint64):
    # Emit `\b \b` n times to wipe n characters from the terminal.
    # Each iteration sends 3 bytes; cheap enough at LINE_MAX=128.
    i: uint64 = 0
    while i < n:
        sys_write(1, "\x08 \x08", 3)
        i = i + 1


# Character-at-a-time line reader with local echo. On real hardware
# the PS/2 keyboard feeds /dev/cons one byte per keystroke; sys_read
# returns immediately on the first byte, so the previous "read up to
# LINE_MAX into line_buf and treat as a line" pattern processed every
# keystroke as its own empty line. This loop accumulates bytes until
# a newline (or Enter, mapped to LF by the kbd driver), echoes each
# byte back so the user sees what they typed, and handles backspace
# (DEL = 0x7f, M16.100 atkbd convention) by erasing the previous
# character on screen.
#
# M16.x: also handles VT220-style escape sequences emitted by the
# atkbd driver (M16.100) — arrow keys, Delete, F1..F4. ESC [ A / B
# walk history backwards/forwards (rewrites the visible line + the
# in-progress buf). ESC [ C / D (Right/Left arrows) are swallowed
# silently — we don't support intra-line cursor movement yet, but
# we MUST consume the bytes so they don't appear on screen as
# garbage. ESC [ 3 ~ (Delete) acts as Backspace on the trailing
# char (best effort given no cursor model). ESC O P..S (F1..F4)
# are swallowed entirely.
def read_line(buf: Ptr[uint8], cap: uint64) -> int64:
    pos: uint64 = 0
    one: Array[1, uint8]
    # `hist_idx` tracks how many entries back from the freshest we're
    # currently showing. 0 = "no history substitution active, what's
    # in buf is what the user typed". Each Up arrow bumps it; Down
    # decrements until it hits 0 (then leaves buf empty).
    hist_idx: uint64 = 0
    while pos < cap - 1:
        n: int64 = sys_read(0, &one[0], 1)
        if n <= 0:
            # EOF / error on stdin — bail out preserving what we have
            # so far; caller treats this as exit if pos==0.
            if pos == 0:
                return n
            buf[pos] = cast[uint8](0x0A)    # synthesise a LF
            pos = pos + 1
            return cast[int64](pos)
        c: uint8 = one[0]
        if c == 0x1B:
            # Escape sequence. Look at the next byte to decide what
            # to do. The atkbd driver (M16.100) emits the standard
            # VT220 forms; sequences are at most 5 bytes (e.g.
            # ESC [ 1 5 ~ for F5).
            nb: Array[1, uint8]
            r2: int64 = sys_read(0, &nb[0], 1)
            if r2 <= 0:
                # Bare ESC at EOF — swallow.
                continue
            c2: uint8 = nb[0]
            if c2 == 0x5B:                          # '[' — CSI sequence
                r3: int64 = sys_read(0, &nb[0], 1)
                if r3 <= 0:
                    continue
                c3: uint8 = nb[0]
                if c3 == 0x41:                      # 'A' — Up arrow
                    # Replace the line in-progress with the next
                    # older history entry. Erase what's on screen
                    # first, then print + load the history line.
                    new_idx: uint64 = hist_idx + 1
                    out_tmp: Array[128, uint8]
                    new_len: uint64 = _history_load(
                        new_idx - 1, &out_tmp[0], HISTORY_LINE)
                    if new_len > 0:
                        _erase_n(pos)
                        pos = 0
                        sys_write(1, &out_tmp[0], new_len)
                        ii: uint64 = 0
                        while ii < new_len and pos < cap - 1:
                            buf[pos] = out_tmp[ii]
                            pos = pos + 1
                            ii = ii + 1
                        hist_idx = new_idx
                    continue
                if c3 == 0x42:                      # 'B' — Down arrow
                    if hist_idx > 1:
                        new_idx2: uint64 = hist_idx - 1
                        out_tmp2: Array[128, uint8]
                        new_len2: uint64 = _history_load(
                            new_idx2 - 1, &out_tmp2[0], HISTORY_LINE)
                        _erase_n(pos)
                        pos = 0
                        sys_write(1, &out_tmp2[0], new_len2)
                        jj: uint64 = 0
                        while jj < new_len2 and pos < cap - 1:
                            buf[pos] = out_tmp2[jj]
                            pos = pos + 1
                            jj = jj + 1
                        hist_idx = new_idx2
                    elif hist_idx == 1:
                        # Going forward past the freshest entry —
                        # land on an empty line.
                        _erase_n(pos)
                        pos = 0
                        hist_idx = 0
                    continue
                if c3 == 0x43 or c3 == 0x44:        # 'C'/'D' — Right/Left
                    # No intra-line cursor model yet. Swallow the
                    # bytes so the user doesn't see ^[[C / ^[[D.
                    continue
                if c3 == 0x33:                      # '3' — likely Delete
                    # Standard form is ESC [ 3 ~ . Consume one more
                    # byte to eat the trailing '~' (or any digit /
                    # ';' for the 4-byte variants). Treat as a
                    # best-effort Backspace on the trailing char.
                    tilde: Array[1, uint8]
                    sys_read(0, &tilde[0], 1)
                    if pos > 0:
                        pos = pos - 1
                        sys_write(1, "\x08 \x08", 3)
                    continue
                # Unknown CSI sequence — consume up to one more byte
                # if the third byte is a digit (parametrised forms
                # like ESC [ 1 5 ~). Either way, swallow silently.
                if c3 >= 0x30 and c3 <= 0x39:
                    tail: Array[1, uint8]
                    while True:
                        rt: int64 = sys_read(0, &tail[0], 1)
                        if rt <= 0:
                            break
                        tc: uint8 = tail[0]
                        # Final byte of a CSI is in 0x40..0x7E.
                        if tc >= 0x40 and tc <= 0x7E:
                            break
                continue
            if c2 == 0x4F:                          # 'O' — F1..F4 prefix
                # Consume one more byte (P/Q/R/S) and swallow.
                tail2: Array[1, uint8]
                sys_read(0, &tail2[0], 1)
                continue
            # Lone ESC + something else — swallow both bytes silently.
            continue
        if c == 0x7F or c == 0x08:
            # DEL / Backspace — erase last char from buffer + screen.
            if pos > 0:
                pos = pos - 1
                # `\b \b` — back up, overwrite with space, back up again.
                sys_write(1, "\x08 \x08", 3)
            continue
        # Echo the byte back to stdout.
        sys_write(1, &one[0], 1)
        buf[pos] = c
        pos = pos + 1
        if c == 0x0A or c == 0x0D:
            # CR or LF terminates the line. atkbd emits LF for Enter;
            # serial input gives us CR. Either way, return now.
            _history_store(buf, pos)
            return cast[int64](pos)
    return cast[int64](pos)


def builtin_help():
    write_str(1, "hamsh builtins: exit, help, cd\n")
    write_str(1, "external commands are read from the cpio initramfs;\n")
    write_str(1, "  e.g. type '/hello' to run /hello.\n")
    write_str(1, "redirect stdout with '>' onto any /tmp/ path, pipe\n")
    write_str(1, "two commands with '|':\n")
    write_str(1, "  /echo hi > /tmp/x\n")
    write_str(1, "  /cat /tmp/x\n")
    write_str(1, "  /echo two words | /cat\n")


# PATH lookup buffer. spawn_cmd builds resolved paths here when a
# bare command name (no leading /) needs disambiguation. Sized for
# the longest legal path we might construct — PATH dir + name.
path_buf: Array[256, uint8]

# U17: envp staging for sys_spawn. The kernel deep-copies these
# bytes onto the child's user stack before the child runs, so it's
# safe to reuse these buffers across spawn calls.
#
# Layout per slot in envp_str_buf: "NAME=VALUE\0" — at most
# VAR_NAME_MAX (16) + 1 ('=') + VAR_VALUE_MAX (48) + 1 (NUL) = 66
# bytes. We size to 72 for round-number alignment. The pointer
# array has VAR_MAX entries plus one NUL terminator (9 total).
ENVP_STR_STRIDE: uint64 = 72
envp_str_buf: Array[576, uint8]   # 8 * 72
envp_ptrs:    Array[9, uint64]    # VAR_MAX (8) + NUL terminator


def _build_envp_block() -> Ptr[uint64]:
    # Walk the shell's var_table and serialize each live slot as
    # "NAME=VALUE\0" into envp_str_buf, with envp_ptrs[i] pointing
    # at the start of that string. Pointer array is NULL-terminated
    # so the kernel's _envp_count can walk it without a separate
    # length. Returns the address of envp_ptrs (the array of
    # cstring pointers musl reads at process start).
    n: uint64 = 0
    si: uint64 = 0
    i: uint64 = 0
    while i < VAR_MAX:
        if var_table[i].used != 0:
            base: uint64 = si * ENVP_STR_STRIDE
            envp_ptrs[n] = cast[uint64](&envp_str_buf[base])
            # Copy NAME.
            off: uint64 = 0
            j: uint64 = 0
            while var_table[i].name[j] != 0 and \
                    off + 1 < ENVP_STR_STRIDE:
                envp_str_buf[base + off] = var_table[i].name[j]
                off = off + 1
                j = j + 1
            # '=' separator.
            if off + 1 < ENVP_STR_STRIDE:
                envp_str_buf[base + off] = 61            # '='
                off = off + 1
            # Copy VALUE.
            k: uint64 = 0
            while var_table[i].value[k] != 0 and \
                    off + 1 < ENVP_STR_STRIDE:
                envp_str_buf[base + off] = var_table[i].value[k]
                off = off + 1
                k = k + 1
            envp_str_buf[base + off] = 0                 # NUL
            n = n + 1
            si = si + 1
        i = i + 1
    envp_ptrs[n] = 0                                     # NULL terminator
    return cast[Ptr[uint64]](&envp_ptrs[0])

# Hardcoded PATH. Real shells get this from the env; we don't have
# env yet, so the search list lives here. Order matters — first
# match wins. /bin is the canonical user-bin location, /sbin is
# kept for future system-admin tools.
def _path_dir(i: uint32) -> Ptr[uint8]:
    if i == 0:
        return "/bin/"
    if i == 1:
        return "/sbin/"
    if i == 2:
        return "/usr/bin/"
    return cast[Ptr[uint8]](0)


def _concat_path(prefix: Ptr[uint8], name: Ptr[uint8]) -> uint64:
    # Write prefix + name + NUL into path_buf. Returns the
    # length written (excluding the NUL). Caller has already
    # checked path_buf can fit.
    pi: uint64 = 0
    while prefix[pi] != 0:
        path_buf[pi] = prefix[pi]
        pi = pi + 1
    ni: uint64 = 0
    while name[ni] != 0:
        path_buf[pi] = name[ni]
        pi = pi + 1
        ni = ni + 1
    path_buf[pi] = 0
    return pi


def _try_spawn_with_prefix(prefix_start: Ptr[uint8],
                            prefix_len: uint64,
                            cmd: Ptr[uint8],
                            argv: Ptr[uint64],
                            stdin_fd: int32,
                            stdout_fd: int32,
                            envp: Ptr[uint64]) -> int32:
    # Build path_buf = prefix + '/' + cmd + NUL, then sys_spawn it.
    # `prefix_len == 0` means the prefix is empty (don't prepend
    # anything — used for the CWD-style "." segment in PATH).
    pi: uint64 = 0
    j: uint64 = 0
    while j < prefix_len:
        path_buf[pi] = prefix_start[j]
        pi = pi + 1
        j = j + 1
    # Insert '/' between prefix and cmd unless the prefix already
    # ended with one (avoid "/bin//ls" — cosmetic only, but matches
    # bash's PATH-resolver shape).
    if pi == 0 or path_buf[pi - 1] != 47:
        path_buf[pi] = 47                           # '/'
        pi = pi + 1
    ni: uint64 = 0
    while cmd[ni] != 0:
        path_buf[pi] = cmd[ni]
        pi = pi + 1
        ni = ni + 1
    path_buf[pi] = 0
    argv[0] = cast[uint64](&path_buf[0])
    return sys_spawn(cast[Ptr[char]](&path_buf[0]),
                     argv, stdin_fd, stdout_fd, envp)


def spawn_cmd(argv: Ptr[uint64], stdin_fd: int32, stdout_fd: int32) -> int32:
    cmd: Ptr[uint8] = cast[Ptr[uint8]](argv[0])
    # U17: build envp from the shell's variable table ONCE per
    # spawn. Every var_table slot is exported — hamsh has no
    # export/local distinction yet, so the shell's view of
    # variables is exactly what the child sees.
    envp: Ptr[uint64] = _build_envp_block()
    # Absolute path → spawn as-is, no PATH walk.
    if cmd[0] == 47:                                # '/'
        pid: int32 = sys_spawn(cast[Ptr[char]](cmd), argv,
                               stdin_fd, stdout_fd, envp)
        if pid < 0:
            write_str(2, "hamsh: not found: ")
            write_str(2, cmd)
            write_str(2, "\n")
        return pid

    saved_argv0: uint64 = argv[0]

    # M16.79: prefer the user-set PATH variable. If $PATH is set,
    # split on ':' and try each segment. Empty segments mean CWD
    # (the same semantic bash uses). If $PATH is unset, fall back
    # to the M16.72 hardcoded list (/bin, /sbin, /usr/bin).
    path_var: Ptr[uint8] = var_get("PATH")
    if cast[uint64](path_var) != 0:
        i: uint64 = 0
        while True:
            # Find the next ':' (or end-of-string).
            seg_start: uint64 = i
            while path_var[i] != 0 and path_var[i] != 58:
                i = i + 1
            seg_len: uint64 = i - seg_start
            pid: int32 = _try_spawn_with_prefix(
                cast[Ptr[uint8]](cast[uint64](path_var) + seg_start),
                seg_len, cmd, argv, stdin_fd, stdout_fd, envp)
            if pid >= 0:
                return pid
            if path_var[i] == 0:
                break
            i = i + 1                              # skip the ':'
    else:
        i: uint32 = 0
        while True:
            prefix: Ptr[uint8] = _path_dir(i)
            if cast[uint64](prefix) == 0:
                break
            # Hardcoded prefixes already end in '/' — trim it so
            # _try_spawn_with_prefix's auto-slash doesn't duplicate.
            plen: uint64 = 0
            while prefix[plen] != 0:
                plen = plen + 1
            if plen > 0 and prefix[plen - 1] == 47:
                plen = plen - 1
            pid: int32 = _try_spawn_with_prefix(
                prefix, plen, cmd, argv, stdin_fd, stdout_fd, envp)
            if pid >= 0:
                return pid
            i = i + 1

    # Nothing matched — restore argv[0] for any caller inspection
    # and report the failure against the original bare name.
    argv[0] = saved_argv0
    write_str(2, "hamsh: not found: ")
    write_str(2, cmd)
    write_str(2, "\n")
    return -1


# M16.71: sub-command splitting on `;`, `&&`, `||`. Per-iteration
# tracking arrays sized for up to 8 sub-commands per line.
SUB_MAX: uint64 = 8
SUB_CONJ_NONE: uint32 = 0
SUB_CONJ_AND:  uint32 = 1
SUB_CONJ_OR:   uint32 = 2
SUB_CONJ_SEQ:  uint32 = 3
sub_starts: Array[8, uint64]
sub_conj:   Array[8, uint32]

# Sentinel for run_subcmd return value: shell wants to exit. -2 is
# distinct from any real exit code we'd ever capture (those range
# 0..255 in practice + small negatives for kernel errors).
SHELL_EXIT: int32 = -2


def run_subcmd(argv: Ptr[uint64], argc: uint64) -> int32:
    # Runs ONE sub-command (no &&/||/;) — handles `>` redirect,
    # `|` pipeline split, builtin dispatch, spawn, wait. Returns
    # the last stage's exit code, or SHELL_EXIT if the user typed
    # the `exit` builtin.
    if argc == 0:
        return 0

    # M16.76: `NAME=VALUE` standalone — shell variable assignment.
    # Only fires when this is the ENTIRE sub-command (no other args),
    # matching the simplest sh form. argv[0] is split on the first
    # '=' if and only if it contains one + the lhs is a valid name.
    # No env-export yet; the variable is shell-internal.
    if argc == 1:
        first: Ptr[uint8] = cast[Ptr[uint8]](argv[0])
        eq_pos: int64 = -1
        ii: uint64 = 0
        while first[ii] != 0:
            if first[ii] == 61:                    # '='
                eq_pos = cast[int64](ii)
                break
            ii = ii + 1
        if eq_pos > 0:
            # Valid LHS: letters/digits/underscore, starts non-digit.
            c0: uint8 = first[0]
            is_name: int32 = 0
            if (c0 >= 65 and c0 <= 90) \
                    or (c0 >= 97 and c0 <= 122) or c0 == 95:
                is_name = 1
            ni: uint64 = 1
            while is_name != 0 and ni < cast[uint64](eq_pos):
                cn: uint8 = first[ni]
                if not ((cn >= 65 and cn <= 90) \
                        or (cn >= 97 and cn <= 122) \
                        or (cn >= 48 and cn <= 57) or cn == 95):
                    is_name = 0
                ni = ni + 1
            if is_name != 0:
                # Split: NUL out '=' in place, then var_set lhs+rhs.
                first[cast[uint64](eq_pos)] = 0
                value_p: Ptr[uint8] = cast[Ptr[uint8]](
                    cast[uint64](first) + cast[uint64](eq_pos) + 1)
                var_set(first, value_p)
                return 0

    # Parse '> file' redirect (last ">" wins, bash-style). Open
    # the target up-front so a bad redirect is reported before any
    # spawn happens.
    redirect_idx: uint64 = find_token(argv, argc, 62)  # '>'
    out_fd: int32 = -1
    if redirect_idx < argc:
        if redirect_idx + 1 >= argc:
            write_str(2, "hamsh: syntax: '>' needs a target\n")
            return 2
        rtarget: Ptr[char] = cast[Ptr[char]](argv[redirect_idx + 1])
        out_fd = sys_open_write(rtarget)
        if out_fd < 0:
            write_str(2, "hamsh: open failed: ")
            write_str(2, cast[Ptr[uint8]](rtarget))
            write_str(2, "\n")
            return 2
        argv[redirect_idx] = 0
        argc = redirect_idx

    if argc == 0:
        write_str(2, "hamsh: syntax: no command before '>'\n")
        if out_fd >= 0:
            sys_close(out_fd)
        return 2

    # Slice argv into stages on every '|'.
    nseg: uint64 = split_segments(argv, argc,
                                   &seg_start[0], PIPE_MAX + 1)

    first_cmd: Ptr[uint8] = cast[Ptr[uint8]](argv[seg_start[0]])
    if nseg == 1:
        if streq(first_cmd, "exit") != 0:
            if out_fd >= 0:
                sys_close(out_fd)
            write_str(1, "[hamsh] bye.\n")
            return SHELL_EXIT
        if streq(first_cmd, "help") != 0:
            builtin_help()
            if out_fd >= 0:
                sys_close(out_fd)
            return 0
        if streq(first_cmd, "cd") != 0:
            cd_rc: int32 = 0
            if argc < 2:
                write_str(2, "cd: usage: cd <abs-path>\n")
                cd_rc = 1
            else:
                ctarget: Ptr[char] = cast[Ptr[char]](argv[1])
                if sys_chdir(ctarget) < 0:
                    # M16.x: surface the kernel's per-process error
                    # string instead of the historical fixed "path
                    # too long" message. SYS_CHDIR sets errstr to
                    # "chdir: no such directory" / "chdir: not a
                    # directory" / "chdir: path too long" (see
                    # arch/x86/kernel/syscall.ad SYS_CHDIR branch,
                    # M16.116). Empty errstr → fall back to a
                    # generic message so the user always sees
                    # something diagnostic.
                    ebuf: Array[128, uint8]
                    ebuf[0] = 0
                    sys_errstr(&ebuf[0], 128)
                    if ebuf[0] != 0:
                        write_str(2, "cd: ")
                        write_str(2, &ebuf[0])
                        write_str(2, "\n")
                    else:
                        write_str(2, "cd: failed\n")
                    cd_rc = 1
            if out_fd >= 0:
                sys_close(out_fd)
            return cd_rc
        if streq(first_cmd, "env") != 0:
            # Dump every defined shell variable as KEY=VALUE\n.
            # U17: every variable is exported to spawned children
            # verbatim — hamsh still has no export-vs-local
            # distinction, so `env` and the child's environment
            # show the same set.
            ei: uint64 = 0
            while ei < VAR_MAX:
                if var_table[ei].used != 0:
                    write_str(1, &var_table[ei].name[0])
                    sys_write(1, "=", 1)
                    write_str(1, &var_table[ei].value[0])
                    sys_write(1, "\n", 1)
                ei = ei + 1
            if out_fd >= 0:
                sys_close(out_fd)
            return 0
        if streq(first_cmd, "unset") != 0:
            # `unset NAME [NAME...]` clears variables. No error
            # if the name doesn't exist (matches sh).
            ui: uint64 = 1
            while ui < argc:
                target: Ptr[uint8] = cast[Ptr[uint8]](argv[ui])
                tj: uint64 = 0
                while tj < VAR_MAX:
                    if var_table[tj].used != 0 \
                            and var_name_eq(&var_table[tj].name[0],
                                            target) != 0:
                        var_table[tj].used = 0
                    tj = tj + 1
                ui = ui + 1
            if out_fd >= 0:
                sys_close(out_fd)
            return 0
    else:
        if streq(first_cmd, "exit") != 0 or \
                streq(first_cmd, "help") != 0 or \
                streq(first_cmd, "cd") != 0 or \
                streq(first_cmd, "env") != 0 or \
                streq(first_cmd, "unset") != 0:
            write_str(2, "hamsh: builtins can't pipe\n")
            if out_fd >= 0:
                sys_close(out_fd)
            return 2

    # Validate: no empty segments (consecutive or leading pipes).
    bad: int32 = 0
    si: uint64 = 0
    while si < nseg:
        head: Ptr[uint64] = &argv[seg_start[si]]
        if head[0] == 0:
            bad = 1
        si = si + 1
    if bad != 0:
        write_str(2, "hamsh: syntax: empty pipeline stage\n")
        if out_fd >= 0:
            sys_close(out_fd)
        return 2

    # Open nseg-1 pipes.
    npipe: uint64 = nseg - 1
    pi: uint64 = 0
    pipe_ok: int32 = 1
    while pi < npipe:
        pair: Array[2, int32]
        if sys_pipe(&pair[0]) < 0:
            write_str(2, "hamsh: pipe failed\n")
            pipe_ok = 0
            j: uint64 = 0
            while j < pi:
                sys_close(pipe_fds[2 * j + 0])
                sys_close(pipe_fds[2 * j + 1])
                j = j + 1
            break
        pipe_fds[2 * pi + 0] = pair[0]
        pipe_fds[2 * pi + 1] = pair[1]
        pi = pi + 1
    if pipe_ok == 0:
        if out_fd >= 0:
            sys_close(out_fd)
        return 2

    # Spawn each stage with the right stdin / stdout fds.
    si = 0
    while si < nseg:
        stdin_fd:  int32 = -1
        stdout_fd: int32 = -1
        if si > 0:
            stdin_fd = pipe_fds[2 * (si - 1) + 0]
        if si + 1 < nseg:
            stdout_fd = pipe_fds[2 * si + 1]
        else:
            stdout_fd = out_fd               # last stage gets `>`
        seg_argv: Ptr[uint64] = &argv[seg_start[si]]
        seg_pid[si] = spawn_cmd(seg_argv, stdin_fd, stdout_fd)
        si = si + 1

    # Close all our copies of the pipe fds + the redirect target.
    pi = 0
    while pi < npipe:
        sys_close(pipe_fds[2 * pi + 0])
        sys_close(pipe_fds[2 * pi + 1])
        pi = pi + 1
    if out_fd >= 0:
        sys_close(out_fd)

    # Wait for every spawned child. Capture the LAST stage's exit
    # code (sh convention) into a local and return it.
    result: int32 = 0
    si = 0
    while si < nseg:
        if seg_pid[si] >= 0:
            code: int64 = sys_waitpid(seg_pid[si])
            if si + 1 == nseg:
                result = cast[int32](code)
        si = si + 1
    return result


# M16.83: `if cmd; then cmd-list; fi` support.
#
# Single-line form only — no nested `if`, no `else`, no `elif`. The
# detection runs AFTER tokenize() so `if`/`then`/`fi` are just argv
# tokens. When argv[0] == "if", we slice the argv stream into a
# condition span (between "if" and the FIRST "then") and a body span
# (between that "then" and "fi"), serialize each back to ASCII into a
# scratch buffer, and recurse into process_line on each in turn.
#
# Limits baked in:
#   - Only ONE if-stage per line (the outermost call). Nested ifs
#     inside the body work via recursion BUT share the scratch buffer
#     and `argv_buf`, so we cap recursion at IF_DEPTH_MAX.
#   - Condition + body must fit in IF_LINE_MAX bytes each after
#     serialization (tokens re-joined with single spaces).
IF_DEPTH_MAX: uint32 = 4
IF_LINE_MAX:  uint64 = 128

# Per-depth scratch buffer for the recursive process_line call.
# Two buffers per level (condition + body) so we can build the body
# string while the condition recursion is still running its own copy.
if_scratch: Array[1024, uint8]              # 4 depths * 2 bufs * 128
if_depth:   uint32 = 0

# M16.85: separate snapshot arena for `while`. Each iteration of a
# `while` loop needs to re-run the SAME cond+body strings, but
# process_line tokenizes its buffer in place, mutating spaces into
# NULs. We keep a pristine snapshot here and memcpy it into the
# working `if_scratch` slot at the top of every iteration. 4 depths
# * 2 bufs * 128 bytes per buf = 1024 bytes — same shape as
# if_scratch above, indexed by if_depth.
while_snap: Array[1024, uint8]


def _tok_eq_lit(tok: Ptr[uint8], lit: Ptr[uint8]) -> int32:
    # Like streq but inlined to avoid sharing the helper with code
    # paths that might be in motion when we're called from the if
    # detection path. Returns 1 on match.
    i: uint64 = 0
    while True:
        a: uint8 = tok[i]
        b: uint8 = lit[i]
        if a != b:
            return 0
        if a == 0:
            return 1
        i = i + 1


def _serialize_range(start: uint64, end: uint64,
                     out: Ptr[uint8], out_max: uint64) -> uint64:
    # Walk argv_buf[start..end), concatenate each token's bytes with
    # a single ' ' separator into `out`, NUL-terminate, and return
    # the byte count written (excluding the NUL). Tokens that are
    # already 0 (NULed by sub-command splitter etc) are skipped — we
    # call this BEFORE the sub-command splitter runs so that should
    # never happen, but it costs nothing to be safe.
    #
    # Special case: if a token ENDS in ';' (e.g. "true;" from
    # `if true; then ...`), emit the body up to but not including the
    # ';', then emit " ;" as a standalone token. That way the
    # downstream tokenize() + sub-command splitter sees a proper
    # `<cmd> ; <next>` sequence with the ';' as its own argv entry.
    w: uint64 = 0
    i: uint64 = start
    first: int32 = 1
    while i < end:
        t: uint64 = argv_buf[i]
        if t != 0:
            s: Ptr[uint8] = cast[Ptr[uint8]](t)
            # Measure length so we can detect a trailing ';'.
            tlen: uint64 = 0
            while s[tlen] != 0:
                tlen = tlen + 1
            body_len: uint64 = tlen
            trail_semi: int32 = 0
            if tlen > 1 and s[tlen - 1] == 59:
                body_len = tlen - 1
                trail_semi = 1
            if body_len > 0:
                if first == 0:
                    if w + 1 < out_max:
                        out[w] = 32                # ' '
                        w = w + 1
                first = 0
                j: uint64 = 0
                while j < body_len and w + 1 < out_max:
                    out[w] = s[j]
                    w = w + 1
                    j = j + 1
            if trail_semi != 0:
                if first == 0:
                    if w + 1 < out_max:
                        out[w] = 32                # ' '
                        w = w + 1
                if w + 1 < out_max:
                    out[w] = 59                    # ';'
                    w = w + 1
                first = 0
        i = i + 1
    if w < out_max:
        out[w] = 0
    return w


def process_line(buf: Ptr[uint8], nu: uint64) -> int32:
    # Parse + execute ONE line of shell input. Used by both the
    # interactive main loop and the M16.73 /etc/rc reader so script
    # input and prompt input share semantics. Returns SHELL_EXIT if
    # the line ran the `exit` builtin, 0 otherwise.
    buf[nu] = 0

    # `#` comment lines (after leading whitespace) are no-ops.
    scan: uint64 = 0
    while scan < nu and is_space(buf[scan]) != 0:
        scan = scan + 1
    if scan < nu and buf[scan] == 35:
        return 0

    argc: uint64 = tokenize(buf, nu, &argv_buf[0], ARGV_MAX)
    if argc == 0:
        return 0

    # M16.83: `if COND ; then BODY ; fi` (single-line). Detect here,
    # BEFORE the `;`/`&&`/`||` splitter runs, so the condition and
    # body each get their own clean process_line invocation. The "if"
    # / "then" / "fi" tokens are matched LITERALLY — they're not
    # Adder reserved words, just byte sequences we compare against.
    first_tok: Ptr[uint8] = cast[Ptr[uint8]](argv_buf[0])
    if _tok_eq_lit(first_tok, "if") != 0:
        if if_depth >= IF_DEPTH_MAX:
            write_str(2, "shell: nesting too deep\n")
            last_exit_code = 2
            return 0
        # Find "then", "else", "fi" indices. `else` is optional; if
        # found, it splits BODY into THEN-body (then..else) and
        # ELSE-body (else..fi). We pick the FIRST `then`, FIRST `else`
        # (only when it sits between then and fi), and LAST `fi` —
        # mirroring the loose nesting rules used by the if/then/fi
        # parser before this commit.
        then_idx: uint64 = argc
        else_idx: uint64 = argc
        fi_idx:   uint64 = argc
        ti: uint64 = 1
        while ti < argc:
            tk: Ptr[uint8] = cast[Ptr[uint8]](argv_buf[ti])
            if then_idx == argc and _tok_eq_lit(tk, "then") != 0:
                then_idx = ti
            elif else_idx == argc and then_idx < argc \
                    and _tok_eq_lit(tk, "else") != 0:
                else_idx = ti
            elif _tok_eq_lit(tk, "fi") != 0:
                fi_idx = ti
            ti = ti + 1
        if then_idx == argc or fi_idx == argc or then_idx >= fi_idx:
            write_str(2, "hamsh: if: missing then/fi\n")
            last_exit_code = 2
            return 0
        # If `else` showed up after `fi` (stray token) ignore it.
        if else_idx >= fi_idx:
            else_idx = argc
        # Condition spans (1 .. then_idx). Trim a trailing ';' token
        # so `if true; then ...` works (the ';' is just a separator
        # for the human, not part of the condition command).
        cond_end: uint64 = then_idx
        if cond_end > 1:
            last_cond: Ptr[uint8] = cast[Ptr[uint8]](
                argv_buf[cond_end - 1])
            if last_cond[0] == 59 and last_cond[1] == 0:
                cond_end = cond_end - 1
        # THEN-body spans (then_idx+1 .. then_end), where then_end is
        # either else_idx (if `else` present) or fi_idx otherwise.
        # ELSE-body spans (else_idx+1 .. fi_idx) when `else` exists.
        # Trim a trailing ';' token off each (same reason as cond).
        then_end: uint64 = fi_idx
        if else_idx < argc:
            then_end = else_idx
        if then_end > then_idx + 1:
            last_then: Ptr[uint8] = cast[Ptr[uint8]](
                argv_buf[then_end - 1])
            if last_then[0] == 59 and last_then[1] == 0:
                then_end = then_end - 1
        else_end: uint64 = fi_idx
        else_start: uint64 = fi_idx               # "no else" sentinel
        if else_idx < argc:
            else_start = else_idx + 1
            if else_end > else_start:
                last_else: Ptr[uint8] = cast[Ptr[uint8]](
                    argv_buf[else_end - 1])
                if last_else[0] == 59 and last_else[1] == 0:
                    else_end = else_end - 1
        # Pick scratch slots based on recursion depth. Each level
        # owns 2 * IF_LINE_MAX = 256 bytes of the scratch arena. We
        # only ever execute ONE of THEN-body / ELSE-body per call, so
        # the second 128 bytes hosts whichever body we branch into.
        # ALL serialization must happen BEFORE the cond recursion,
        # because process_line tokenizes argv_buf in place and would
        # otherwise destroy our token pointers for the else branch.
        base: uint64 = cast[uint64](if_depth) * (IF_LINE_MAX * 2)
        cond_buf_p: Ptr[uint8] = &if_scratch[base]
        body_buf_p: Ptr[uint8] = &if_scratch[base + IF_LINE_MAX]
        # Use the per-depth while_snap arena as auxiliary storage for
        # the ELSE-body string, so THEN-body can live in body_buf_p
        # while we still have ELSE-body around in case cond fails.
        else_buf_p: Ptr[uint8] = &while_snap[base]
        cond_len: uint64 = _serialize_range(1, cond_end,
                                            cond_buf_p, IF_LINE_MAX)
        then_body_len: uint64 = _serialize_range(then_idx + 1, then_end,
                                                  body_buf_p, IF_LINE_MAX)
        else_body_len: uint64 = 0
        if else_idx < argc:
            else_body_len = _serialize_range(else_start, else_end,
                                              else_buf_p, IF_LINE_MAX)
        # Strip a trailing " ;" (and/or stray spaces) from each
        # serialized line. _serialize_range emits "<cmd> ;" for any
        # token that ended in ';' — fine in the middle of the body
        # where it separates commands, but at the very END it would
        # spawn an empty sub-command that resets last_exit_code to 0.
        # That would clobber our branch signal for the condition path
        # AND any && / || chain inside the body, so trim every
        # trailing space/';' byte.
        while cond_len > 0 \
                and (cond_buf_p[cond_len - 1] == 59 \
                     or cond_buf_p[cond_len - 1] == 32):
            cond_len = cond_len - 1
            cond_buf_p[cond_len] = 0
        while then_body_len > 0 \
                and (body_buf_p[then_body_len - 1] == 59 \
                     or body_buf_p[then_body_len - 1] == 32):
            then_body_len = then_body_len - 1
            body_buf_p[then_body_len] = 0
        while else_body_len > 0 \
                and (else_buf_p[else_body_len - 1] == 59 \
                     or else_buf_p[else_body_len - 1] == 32):
            else_body_len = else_body_len - 1
            else_buf_p[else_body_len] = 0
        if_depth = if_depth + 1
        # Run the condition; its last_exit_code is what we branch on.
        rc_cond: int32 = process_line(cond_buf_p, cond_len)
        if rc_cond == SHELL_EXIT:
            if_depth = if_depth - 1
            return SHELL_EXIT
        if last_exit_code == 0:
            if then_body_len > 0:
                rc_body: int32 = process_line(body_buf_p, then_body_len)
                if rc_body == SHELL_EXIT:
                    if_depth = if_depth - 1
                    return SHELL_EXIT
        else:
            if else_body_len > 0:
                rc_body: int32 = process_line(else_buf_p, else_body_len)
                if rc_body == SHELL_EXIT:
                    if_depth = if_depth - 1
                    return SHELL_EXIT
        if_depth = if_depth - 1
        return 0

    # M16.85: `while COND ; do BODY ; done` (single-line). Analogous
    # to if/then/fi, but loops: re-execute the condition after each
    # body iteration and keep going while last_exit_code stays 0.
    # Hard cap at WHILE_ITER_MAX iterations so a runaway loop (the
    # condition keeps succeeding) is bounded and the shell stays
    # interactive instead of hanging.
    if _tok_eq_lit(first_tok, "while") != 0:
        if if_depth >= IF_DEPTH_MAX:
            write_str(2, "shell: nesting too deep\n")
            last_exit_code = 2
            return 0
        # Find "do" (first) and "done" (last) indices.
        do_idx:   uint64 = argc
        done_idx: uint64 = argc
        ti: uint64 = 1
        while ti < argc:
            tk: Ptr[uint8] = cast[Ptr[uint8]](argv_buf[ti])
            if do_idx == argc and _tok_eq_lit(tk, "do") != 0:
                do_idx = ti
            elif _tok_eq_lit(tk, "done") != 0:
                done_idx = ti
            ti = ti + 1
        if do_idx == argc or done_idx == argc or do_idx >= done_idx:
            write_str(2, "hamsh: while: missing do/done\n")
            last_exit_code = 2
            return 0
        # Condition spans (1 .. do_idx); body spans (do_idx+1 .. done_idx).
        # Trim trailing ';' off each (same reasoning as the if-block).
        cond_end: uint64 = do_idx
        if cond_end > 1:
            last_cond: Ptr[uint8] = cast[Ptr[uint8]](
                argv_buf[cond_end - 1])
            if last_cond[0] == 59 and last_cond[1] == 0:
                cond_end = cond_end - 1
        body_end: uint64 = done_idx
        if body_end > do_idx + 1:
            last_body: Ptr[uint8] = cast[Ptr[uint8]](
                argv_buf[body_end - 1])
            if last_body[0] == 59 and last_body[1] == 0:
                body_end = body_end - 1
        base: uint64 = cast[uint64](if_depth) * (IF_LINE_MAX * 2)
        cond_snap_p: Ptr[uint8] = &while_snap[base]
        body_snap_p: Ptr[uint8] = &while_snap[base + IF_LINE_MAX]
        cond_work_p: Ptr[uint8] = &if_scratch[base]
        body_work_p: Ptr[uint8] = &if_scratch[base + IF_LINE_MAX]
        # Serialize cond + body into the snapshot arena ONCE, BEFORE
        # the first recursive process_line call clobbers argv_buf.
        # process_line tokenizes its argument buffer in place, so we
        # then memcpy snapshot → working buffer at the top of each
        # iteration. The working buffer gets eaten by process_line,
        # the snapshot stays clean for the next iteration.
        cond_snap_len: uint64 = _serialize_range(1, cond_end,
                                                  cond_snap_p, IF_LINE_MAX)
        body_snap_len: uint64 = _serialize_range(do_idx + 1, body_end,
                                                  body_snap_p, IF_LINE_MAX)
        # Trim trailing " ;" off the snapshots so a recursion at end of
        # cond/body doesn't spawn an empty sub-command that resets
        # last_exit_code. Same logic as the if-block path.
        while cond_snap_len > 0 \
                and (cond_snap_p[cond_snap_len - 1] == 59 \
                     or cond_snap_p[cond_snap_len - 1] == 32):
            cond_snap_len = cond_snap_len - 1
            cond_snap_p[cond_snap_len] = 0
        while body_snap_len > 0 \
                and (body_snap_p[body_snap_len - 1] == 59 \
                     or body_snap_p[body_snap_len - 1] == 32):
            body_snap_len = body_snap_len - 1
            body_snap_p[body_snap_len] = 0
        if_depth = if_depth + 1
        iter_count: uint32 = 0
        WHILE_ITER_MAX: uint32 = 1000
        while True:
            if iter_count >= WHILE_ITER_MAX:
                write_str(2, "while: max iterations\n")
                break
            # Restore cond from snapshot into the working buffer.
            ci: uint64 = 0
            while ci <= cond_snap_len:
                cond_work_p[ci] = cond_snap_p[ci]
                ci = ci + 1
            rc_cond: int32 = process_line(cond_work_p, cond_snap_len)
            if rc_cond == SHELL_EXIT:
                if_depth = if_depth - 1
                return SHELL_EXIT
            if last_exit_code != 0:
                break
            if body_snap_len > 0:
                bi: uint64 = 0
                while bi <= body_snap_len:
                    body_work_p[bi] = body_snap_p[bi]
                    bi = bi + 1
                rc_body: int32 = process_line(body_work_p, body_snap_len)
                if rc_body == SHELL_EXIT:
                    if_depth = if_depth - 1
                    return SHELL_EXIT
            iter_count = iter_count + 1
        if_depth = if_depth - 1
        return 0

    # `$?` and `$NAME` substitution. The expansion pass is now
    # per-character (not per-token-start) so in-token references
    # like `X=$Y`, `prefix-$ID`, and `$A$B` all work. The special
    # name `?` resolves to the last exit code (via the pre-rendered
    # exit_str_buf); anything else falls through to the
    # shell-variable table. A miss leaves the `$NAME` segment
    # literal — typos surface as "hamsh: not found: $TYPOED" rather
    # than silent empty expansion. V0 limits: no ${VAR}, $(...),
    # $$, positional params, or single-quote literal preservation.
    _render_exit_code(last_exit_code)
    expand_cursor = 0
    ai: uint64 = 0
    while ai < argc:
        tok: Ptr[uint8] = cast[Ptr[uint8]](argv_buf[ai])
        if _token_has_dollar(tok) != 0:
            new_ptr: Ptr[uint8] = _expand_token(tok)
            if cast[uint64](new_ptr) != 0:
                argv_buf[ai] = cast[uint64](new_ptr)
        ai = ai + 1

    # Split argv on ';', '&&', '||' separators.
    n_subs: uint64 = 1
    sub_starts[0] = 0
    sub_conj[0] = SUB_CONJ_NONE
    ti: uint64 = 0
    while ti < argc:
        t: uint64 = argv_buf[ti]
        if t != 0:
            s: Ptr[uint8] = cast[Ptr[uint8]](t)
            c0: uint8 = s[0]
            matched: int32 = 0
            cj: uint32 = SUB_CONJ_NONE
            if c0 == 38 and s[1] == 38 and s[2] == 0:
                matched = 1
                cj = SUB_CONJ_AND
            elif c0 == 124 and s[1] == 124 and s[2] == 0:
                matched = 1
                cj = SUB_CONJ_OR
            elif c0 == 59 and s[1] == 0:
                matched = 1
                cj = SUB_CONJ_SEQ
            if matched != 0:
                argv_buf[ti] = 0
                if n_subs < SUB_MAX:
                    sub_starts[n_subs] = ti + 1
                    sub_conj[n_subs] = cj
                    n_subs = n_subs + 1
        ti = ti + 1

    # Run each sub-command with the conjunction check.
    sub_i: uint64 = 0
    while sub_i < n_subs:
        cj: uint32 = sub_conj[sub_i]
        skip: int32 = 0
        if cj == SUB_CONJ_AND and last_exit_code != 0:
            skip = 1
        if cj == SUB_CONJ_OR and last_exit_code == 0:
            skip = 1
        if skip == 0:
            start: uint64 = sub_starts[sub_i]
            end: uint64 = argc
            if sub_i + 1 < n_subs:
                end = sub_starts[sub_i + 1] - 1
            sub_argv: Ptr[uint64] = &argv_buf[start]
            sub_argc: uint64 = end - start
            rc: int32 = run_subcmd(sub_argv, sub_argc)
            if rc == SHELL_EXIT:
                return SHELL_EXIT
            last_exit_code = rc
        sub_i = sub_i + 1
    return 0


# /etc/rc reader (M16.73). Bounded at 4 KiB which fits comfortably in
# a one-block-per-file ext4/tmpfs/cpio entry. Lines past LINE_MAX get
# truncated rather than rejected — mirror's bash's "long line" handling.
RC_BUF_MAX: uint64 = 4096
rc_buf: Array[4096, uint8]


def run_rc_file(path: Ptr[char]):
    # Open `path` (cpio /etc/rc by default). Read up to RC_BUF_MAX
    # bytes. Walk \n-separated lines, processing each through
    # process_line. Silent miss if the file doesn't exist — boot still
    # proceeds. SHELL_EXIT from a script line is honored: hamsh exits.
    fd: int32 = sys_open(path)
    if fd < 0:
        return
    total: uint64 = 0
    while total < RC_BUF_MAX:
        n: int64 = sys_read(fd, &rc_buf[total], RC_BUF_MAX - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)

    pos: uint64 = 0
    while pos < total:
        # Find end of this line.
        end: uint64 = pos
        while end < total and rc_buf[end] != 10:
            end = end + 1
        # Copy line into line_buf (so process_line's NUL terminate
        # doesn't trample rc_buf). Clip oversized lines.
        line_len: uint64 = end - pos
        if line_len >= LINE_MAX:
            line_len = LINE_MAX - 1
        i: uint64 = 0
        while i < line_len:
            line_buf[i] = rc_buf[pos + i]
            i = i + 1
        rc2: int32 = process_line(&line_buf[0], line_len)
        if rc2 == SHELL_EXIT:
            return
        pos = end + 1


def main() -> int32:
    # Keep this EXACT banner line — the BIOS/UEFI boot tests grep the
    # serial log for "[hamsh] M16.35 shell ready". It is emitted FIRST
    # so it lands in the serial stream before the screen-clear escape;
    # the framebuffer will wipe it a moment later when we clear, but
    # the serial stream (a stream, not a screen) keeps every byte.
    write_str(1, "[hamsh] M16.35 shell ready. Type 'help' or '/hello'.\n")
    # M16.73: source /etc/rc if it exists — equivalent of /etc/rc.d
    # on a real Linux. Lets the system print a motd, set a hostname,
    # warm caches, etc, all without baking strings into hamsh itself.
    run_rc_file("/etc/rc")
    # Clean-terminal startup: wipe the framebuffer of boot/diagnostic
    # spam and home the cursor, then show a concise banner so the user
    # is greeted by a clean prompt instead of a wall of kernel text.
    #   ESC [ 2 J  — clear entire screen
    #   ESC [ H    — cursor to top-left (0,0)
    # On the serial console these bytes pass through harmlessly (a
    # serial terminal that understands ANSI clears too; a raw log just
    # carries the escape bytes inline and earlier lines are untouched).
    write_str(1, "\x1B[2J\x1B[H")
    write_str(1, "Hamnix hamsh - type 'help' or '/hello'\n")
    while True:
        print_prompt()
        n: int64 = read_line(&line_buf[0], LINE_MAX)
        if n <= 0:
            # EOF / error on stdin — bail so the kernel halts when
            # we exit instead of busy-looping on a dead UART.
            write_str(1, "[hamsh] stdin closed, exiting.\n")
            return 0
        nu: uint64 = cast[uint64](n)
        if nu >= LINE_MAX:
            nu = LINE_MAX - 1
        if process_line(&line_buf[0], nu) == SHELL_EXIT:
            return 0
    return 0

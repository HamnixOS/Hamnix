# user/hamsh.ad
#
# hamsh — the Hamnix shell. Clean-sheet rewrite per docs/HAMSH_SPEC.md.
#
# hamsh is ONE language: a Python-flavored syntax with C-style `{ }`
# blocks, its OWN small dynamically-typed tree-walking evaluator. It is
# NOT Adder — it shares no grammar, type system, or evaluator with the
# Adder compiler. There is no compile step, no separate expression mode.
#
# Statement dispatch is deterministic from the first token of a
# top-level line (HAMSH_SPEC §2):
#   1. control construct  — first token a statement keyword
#                           (if while for def return break continue
#                            try ns enter spawn)
#   2. assignment         — IDENT (= += -= ...) ... at top level
#   3. command            — first token is the command word; bare
#                           words are literal strings.
#
# The one idea everything reduces to (§0): a named channel in a scoped
# namespace. Stdio, pipes, redirects, dup are all "bind a Chan at an
# /fd/N name". The shell is the UI for Phase D's chan/namespace model.
#
# Architecture (no malloc in Hamnix userland — module-scope arenas):
#   * lexer      — tok_*  arrays: a flat token stream for one line.
#   * parser     — nd_*   arrays: an AST node arena (recursive descent).
#   * evaluator  — val_*  arrays: a dynamically-typed value heap, plus
#                  a small variable-binding scope stack.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       user/hamsh.ad -o build/user/hamsh.elf

# --- syscalls -------------------------------------------------------
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
# #450 F6: SYS_SPAWN is retired. spawn() is the Plan-9 rfork+exec
# userland wrapper from lib/p9.ad — exact same signature so call sites
# keep their integer-fd / SPAWN_STDIO_NS sentinels (-2 / -1 / 0..15).
from lib.p9 import (
    spawn, p9_note, p9_listdir,
    spawn_pipeline_stage, p9_pipe_pins_release,
    P9_PIPE_PIN_W, P9_PIPE_PIN_R, P9_PIPE_PIN_RA, P9_PIPE_PIN_RB,
)
extern def sys_waitpid(pid: int32) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_pipe(fds: Ptr[int32]) -> int32
# §15: open a 9P server posted on the kernel /srv table. `mount` of a
# `/srv/<name>` path resolves the name through this to a fresh srvfd,
# then hands that to sys_mount — mount only ever consumes a srvfd.
extern def sys_srv_open(name: Ptr[char]) -> int32
extern def sys_dup(oldfd: int32) -> int32
extern def sys_dup2(oldfd: int32, newfd: int32) -> int32
extern def sys_chdir(path: Ptr[char]) -> int32
extern def sys_getcwd(buf: Ptr[uint8], count: uint64) -> int64
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32
extern def sys_rfork(flags: int32) -> int32
extern def sys_bind(new: Ptr[char], old: Ptr[char], flag: int32) -> int32
extern def sys_unmount(new: Ptr[char], old: Ptr[char]) -> int32
# #450 F6: SYS_KILL's positive-pid drift arm is retired — `kill <pid>`
# is now `write("kill\n") > /proc/<pid>/note` via p9_note(pid, msg)
# from lib/p9.ad (imported above). sys_pgrp_kill is the job-control
# negative-pid path (kill(-pgid, sig) — Unix process-group broadcast);
# it survives the F6 cut because F2 explicitly left the job-control
# family (SETPGID / TCSETPGRP / WAITPID_JC) as a follow-up scope and
# Unix process-group signalling is part of that surface. The kernel
# arm for SYS_KILL now accepts NEGATIVE pids only.
extern def sys_pgrp_kill(pgid: uint32, sig: int32) -> int32
# Job control. sys_setpgid places a child in a process group (the shell
# uses it to start a backgrounded pipeline in its own group). A NEGATIVE
# pid to sys_pgrp_kill targets a whole process group (kill(-pgid, sig)).
# sys_tcsetpgrp installs the terminal's foreground group so Ctrl-C /
# Ctrl-Z route only to the foreground job. sys_waitpid_jc is a
# non-blocking job-control wait: it returns the pid and writes a status
# word distinguishing EXITED / STOPPED / CONTINUED (see the job-control
# section below for the encoding), or 0 when there is nothing new.
extern def sys_setpgid(pid: int32, pgid: int32) -> int32
extern def sys_tcsetpgrp(pgid: int32) -> int32
extern def sys_waitpid_jc(pid: int32, status: Ptr[int64]) -> int64
extern def sys_exit(code: uint64)
# HAMSH §7: the `#d`-fd-device namespace primitives. /fd/N is a NAME
# in a process's Pgrp; pipe / redirect / dup all reduce to "bind a
# Chan at /fd/N" — sys_fdbind is THE one operation. sys_pipechan
# creates a local pipe Chan pair and returns its slot id (not fds).
extern def sys_fdbind(pid: int32, fdnum: int32, kind: int32,
                      arg: int32) -> int32
# HAMSH §7: read-only query for /fd/<fdnum>'s currently-bound DEVFD_* kind
# in pid's Pgrp (pid 0 = self). Returns DEVFD_NONE (0) if nothing is
# bound. _setup_fd_namespace uses this to skip its default cons-bind
# when the kernel-side legacy-fd SYS_SPAWN path has already pre-bound
# /fd/0,1,2 from the parent's integer-fd backings (the SSH-pipe case
# for an sshd-spawned hamsh).
extern def sys_fdslot_kind(pid: int32, fdnum: int32) -> int32
extern def sys_fdslot_arg(pid: int32, fdnum: int32) -> int32
extern def sys_pipechan() -> int32
extern def sys_openchan(path: Ptr[char], write: int32) -> int32
# HAMSH §13: an opaque per-Pgrp namespace identity. A live handle
# records the nsid it was created under; using it where sys_nsid()
# now differs is the cross-namespace-handle error.
extern def sys_nsid() -> uint64
extern def sys_mount(srvfd: int32, afd: int32, old: Ptr[char],
                     flag: int32, spec: Ptr[char]) -> int32
# HAMSH §14: mount handles. op=0 stamps `label` onto the mount at
# (to_path[, from_path]); op=1 unmounts the entry carrying `label`.
extern def sys_nslabel(op: int32, label: Ptr[char], to_path: Ptr[char],
                       from_path: Ptr[char]) -> int32

# TEMP_DEBUG_HEARTBEAT — see ed_readline below. The interactive idle
# loop emits a periodic alive-tick during real-hardware bring-up so a
# screen photo distinguishes "shell wedged" from "shell alive, keyboard
# starved". Needs the kernel jiffies counter (100 Hz) for cadence and
# sys_yield to cooperate-multitask while polling stdin. Remove once
# real-hardware keyboard input works on the Asus + Nook.
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32

# docs/security.md: Plan-9-shape identity syscalls. SYS_GETUID/GETGID
# return current task's uid/gid. SYS_SETUID is privileged — only
# hostowner (uid 1) can call it (the kernel rejects with -EPERM
# otherwise). `newshell` is the only userland caller; it reaches
# SYS_SETUID from inside an rfork'd child after authenticating against
# /etc/shadow.
extern def sys_getuid() -> uint32
extern def sys_getgid() -> uint32
extern def sys_setuid(uid: uint32) -> int32
# docs/security.md Phase 4: /dev/auth-mediated identity change. a0 = an
# open /dev/auth fd that has SUCCESSFULLY verified a (user,pass) pair;
# the kernel recovers the fd's verified-uid slot and sets THIS task's
# uid/gid to it — the gate is the PASSWORD PROOF in the slot, NOT the
# caller's prior uid. This is what lets `newshell <user>` (and su/login)
# elevate a REGULAR user after authentication. Returns the new uid (>=0)
# or -1.
extern def sys_setuid_auth(authfd: int32) -> int32

# /proc/svc Phase 6: publish one entry of the service registry into
# the kernel-side mirror that backs `/proc/svc/<name>` reads. a0 =
# name (NUL-terminated), a1 = 400-byte packed payload (or 0/NULL to
# unpublish). Hostowner-only, but hamsh IS PID 1 so the gate never
# bites the legitimate path. Returns 0 on success, -1 on failure
# (mirror full / not hostowner). See fs/procfs.ad for the payload
# layout and arch/x86/kernel/syscall.ad's SYS_SVC_PUBLISH arm.
extern def sys_svc_publish(name: Ptr[uint8], payload: Ptr[uint8]) -> int32
# Service-control mailbox RPC. verb 1..6 enqueue a request from any
# process (start/stop/restart/enable/disable/runlevel); the PID-1
# supervisor drains it with verb 0 (poll -> returns the request verb)
# and verb 7 (read-out the dequeued name). See arch/x86/kernel/syscall.ad.
extern def sys_svc_ctl(verb: int32, name: Ptr[uint8], cap: uint64) -> int64


# DEVFD_* — the channel-kind selector for sys_fdbind, matching
# sys/src/9/port/devfd.ad. dup is kind DEVFD_DUP with arg = the
# source /fd slot — there is no separate dup primitive.
DEVFD_NONE:   int32 = 0     # nothing bound at this /fd/N
DEVFD_CONS:   int32 = 1     # the console device
DEVFD_PIPE_R: int32 = 2     # a pipe read end (arg = pipe slot)
DEVFD_PIPE_W: int32 = 3     # a pipe write end (arg = pipe slot)
DEVFD_FILE:   int32 = 4     # an on-disk file (arg = kernel fd)
DEVFD_DUP:    int32 = 5     # the Chan at /fd/<arg> (dup-as-bind)
# DEVFD_FILE_APPEND — same as DEVFD_FILE but every write lands at
# the file's current EOF (write-at-EOF, POSIX O_APPEND-shape). The
# svc supervisor binds this kind to /fd/1 + /fd/2 of each managed
# service so /var/log/svc/<name>.log captures both streams without
# either overwriting the other and so `svc restart` appends rather
# than truncating the boot's accumulated output.
DEVFD_FILE_APPEND: int32 = 6
# DEVFD_CHAN — a namec DEVICE-cdev redirect target (arg = an inline
# namec chan id). sys_openchan returns such an id (tagged with
# CHAN_INLINE_TAG) when the redirect target is a device file rather than
# a tmpfs file — e.g. `cmd > /dev/wsys/<wid>/keys`. See sys/.../devfd.ad.
DEVFD_CHAN:   int32 = 7

# The tag bit sys_openchan sets on an inline device chan id (matches
# namec.ad's CHAN_INLINE_TAG). A returned slot with this bit set is a
# device chan (bind DEVFD_CHAN); otherwise it is a small tmpfs slot
# (bind DEVFD_FILE / DEVFD_FILE_APPEND).
CHAN_INLINE_TAG: int32 = 0x40000000

# sys_openchan mode selectors, matching OPENCHAN_* in syschan.ad.
OPENCHAN_READ:   int32 = 0
OPENCHAN_TRUNC:  int32 = 1
OPENCHAN_APPEND: int32 = 2

# spawn() stdio sentinel: the child's standard streams are NAMES in
# its namespace (/fd/0,1,2 via `#d`), wired by the shell with
# sys_fdbind — NOT dup'd integer fds. Matches SPAWN_STDIO_NS in
# arch/x86/kernel/syscall.ad.
SPAWN_STDIO_NS: int32 = -2

# Mount flags. MREPL replaces any binding at the name; MBEFORE / MAFTER
# request union semantics — the new mount stacks before / after any
# existing binding at that path (§14, `mount -b` / `mount -a`).
MREPL_FLAG:   int32 = 0
MBEFORE_FLAG: int32 = 1
MAFTER_FLAG:  int32 = 2
# MCREATE bit (Plan 9 MCREATE): OR'd into a union flag so a CREATE at a
# shared name lands in THIS union member. Needed for the writable
# overlay recipe: `bind -bc '#t/usr' /usr` stacks the writable tmpfs
# MBEFORE the read-only cpio AND claims creates. Mirrors MCREATE_BIT in
# sys/src/9/port/chan.ad. `-bc` / `-ac` are the flag words that set it.
MCREATE_FLAG: int32 = 4
# MRDONLY bit (task #69, kernel-enforced read-only VIEW): OR'd into a
# bind flag so the binding is IMMUTABLE through the view — reads / stat
# / ls resolve normally but create / write / truncate / remove / rename
# through the binding are denied with EROFS. Mirrors MRDONLY_BIT in
# sys/src/9/port/chan.ad. The `-r` flag word sets it (`-br` / `-ar` for
# a read-only union member). Protects the VIEW, not the server: the
# bound server's OWN writes (a direct `#src/...` open) are unaffected.
MRDONLY_FLAG: int32 = 16


# --- arena sizes ----------------------------------------------------
# The node and value arenas are append-only ACROSS a session, not
# per-line: a `def`'d function keeps its body AST live, and a variable
# keeps its value cell live, after the line that created it returns.
# They are sized generously; a soft overflow degrades gracefully (the
# allocator returns the null cell) and the line driver recycles the
# arenas back to a baseline when it is provably safe (no live defs and
# no variables referencing high cells — see _maybe_recycle_arenas).
LINE_MAX:      uint64 = 2048     # one logical input line (multi-line)
# tokens per logical input. The rc/init path (_run_rc_path) reads a
# whole multi-line script into a 16 KiB buffer and lexes it in ONE
# pass, so this must comfortably exceed the token count of the largest
# sourced script (etc/rc.d/rc.5 lexes to ~600 tokens incl. one
# TK_NEWLINE per line). A too-small value used to make _emit_tok
# SILENTLY drop the script's tail — including its closing `}` and the
# trailing TK_EOF — so the parser ran into zeroed token slots mid-block
# and aborted the whole script with a spurious "empty command". Sized
# generously now, and lex_line raises a clean "token-limit exceeded"
# instead of truncating (see _emit_tok / lex_error).
TOK_MAX:       uint64 = 4096     # tokens per logical input
NODE_MAX:      uint64 = 16384    # AST node arena (session-lifetime)
STR_ARENA_MAX: uint64 = 32768    # interned string bytes (session)
VAL_MAX:       uint64 = 16384    # value cells (session-lifetime)
SCOPE_MAX:     uint64 = 128      # variable bindings (one flat table)
ARGV_MAX:      uint64 = 64       # argv slots for an external command
LISTELEM_MAX:  uint64 = 16384    # list/dict element slots (shared pool)


# ====================================================================
# String arena
# ====================================================================
# hamsh strings are NUL-terminated byte runs interned into one arena.
# A "string ref" is the byte offset of the first char. Offset 0 is the
# empty string (a single NUL planted at init).

str_arena:  Array[32768, uint8]
str_cursor: uint64 = 1            # 0 reserved for ""


def str_arena_init():
    str_arena[0] = 0
    str_cursor = 1


def str_intern_n(src: Ptr[uint8], n: uint64) -> uint64:
    # Copy n bytes + NUL into the arena; return the offset. On overflow
    # return 0 (the empty string) — a soft failure that never corrupts.
    if str_cursor + n + 1 >= STR_ARENA_MAX:
        return 0
    off: uint64 = str_cursor
    i: uint64 = 0
    while i < n:
        str_arena[off + i] = src[i]
        i = i + 1
    str_arena[off + n] = 0
    str_cursor = off + n + 1
    return off


def str_intern_cstr(src: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while src[n] != 0:
        n = n + 1
    return str_intern_n(src, n)


def str_ptr(off: uint64) -> Ptr[uint8]:
    return &str_arena[off]


def str_len(off: uint64) -> uint64:
    n: uint64 = 0
    while str_arena[off + n] != 0:
        n = n + 1
    return n


def cstr_len(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def cstr_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while True:
        ca: uint8 = a[i]
        cb: uint8 = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, cstr_len(s))


def write_cstr1(s: Ptr[uint8]):
    sys_write(1, s, cstr_len(s))


# --- DE-terminal local-echo control -----------------------------------------
# The DE scene terminal (user/hamtermscene.ad) owns LOCAL line editing + LOCAL
# per-keystroke echo (zero-lag editing; the inner shell runs --no-echo). That
# local echo would render a typed password in clear text, because a raw fd-0
# password read never round-trips through anything the terminal can inspect.
# So the shell signals the terminal out-of-band: a private CSI written to
# stdout (which the terminal drains + interprets) that toggles its local echo.
# hamtermscene swallows unknown escape sequences, and a real xterm/serial front
# end ignores this unknown private mode too, so it is harmless everywhere else.
#   ESC [ ? 7767 l  -> local echo OFF (suppress keystroke rendering)
#   ESC [ ? 7767 h  -> local echo ON  (resume)
# The kernel console already does NOT echo raw fd-0 reads, so serial/SSH
# password entry was silent already; this closes the DE-terminal gap.
def de_echo_off():
    sys_write(1, "\x1b[?7767l", 8)


def de_echo_on():
    sys_write(1, "\x1b[?7767h", 8)


# Decimal rendering scratch. Shared — render then immediately consume.
num_buf: Array[24, uint8]


def render_int(v: int64) -> Ptr[uint8]:
    # Render v into num_buf as NUL-terminated decimal. Returns &num_buf.
    neg: int32 = 0
    uv: uint64 = 0
    if v < 0:
        neg = 1
        uv = cast[uint64](-v)
    else:
        uv = cast[uint64](v)
    digs: Array[24, uint8]
    di: uint64 = 0
    if uv == 0:
        digs[0] = 48
        di = 1
    else:
        while uv > 0:
            digs[di] = cast[uint8]((uv % 10) + 48)
            uv = uv / 10
            di = di + 1
    oi: uint64 = 0
    if neg != 0:
        num_buf[0] = 45
        oi = 1
    while di > 0:
        di = di - 1
        num_buf[oi] = digs[di]
        oi = oi + 1
    num_buf[oi] = 0
    return &num_buf[0]


# ====================================================================
# Lexer
# ====================================================================
# Token kinds. The lexer is line-structure aware; it does NOT decide
# command-vs-assignment-vs-control — that is the parser's first-token
# dispatch (§2).

TK_EOF:     int32 = 0
TK_WORD:    int32 = 1     # bare word / identifier (str ref in tok_str)
TK_STR:     int32 = 2     # quoted string literal (str ref)
TK_INT:     int32 = 3     # integer literal (tok_int)
TK_DOLLAR:  int32 = 4     # $name        (name str ref in tok_str)
TK_DOLEXPR: int32 = 5     # ${ ... }     spans nested tokens
TK_BACKEXP: int32 = 6     # `{ ... }     command substitution
TK_OP:      int32 = 7     # operator / punctuation (tok_int = op code)
TK_NEWLINE: int32 = 8     # statement separator
# Python-style significant-indentation tokens. The lexer emits a
# TK_INDENT when a logical line's leading-whitespace column exceeds the
# top of an indent stack, and one TK_DEDENT per stack level popped when
# it falls below. A colon-suite (`if COND:` + newline) parses its body
# between a matched INDENT..DEDENT; every other context treats a stray
# INDENT/DEDENT as an ignorable separator (see _skip_seps). Emission is
# suppressed inside ( ) / [ ] where line breaks are insignificant.
TK_INDENT:  int32 = 9     # start of a more-indented logical line
TK_DEDENT:  int32 = 10    # end of an indentation level
TK_FLOAT:   int32 = 11    # float literal; tok_str = source slice, parsed
                          # to a double at eval (ND_FLOAT). §Float.
TK_FSTR:    int32 = 12    # f"..." string; tok_str = body, `{expr}`
                          # interpolated at eval (ND_FSTR). §f-string.

# Operator codes for TK_OP.
OP_ASSIGN:   int32 = 1    # =
OP_PLUSEQ:   int32 = 2    # +=
OP_MINUSEQ:  int32 = 3    # -=
OP_LBRACE:   int32 = 4    # {
OP_RBRACE:   int32 = 5    # }
OP_LPAREN:   int32 = 6    # (
OP_RPAREN:   int32 = 7    # )
OP_LBRACKET: int32 = 8    # [
OP_RBRACKET: int32 = 9    # ]
OP_COMMA:    int32 = 10   # ,
OP_PIPE:     int32 = 11   # |
OP_GT:       int32 = 12   # >
OP_LT:       int32 = 13   # <
OP_GE:       int32 = 14   # >=
OP_LE:       int32 = 15   # <=
OP_EQEQ:     int32 = 16   # ==
OP_NE:       int32 = 17   # !=
OP_PLUS:     int32 = 18   # +
OP_MINUS:    int32 = 19   # -
OP_STAR:     int32 = 20   # *
OP_SLASH:    int32 = 21   # /
OP_PERCENT:  int32 = 22   # %
OP_AND:      int32 = 23   # &&
OP_OR:       int32 = 24   # ||
OP_NOT:      int32 = 25   # !
OP_COLON:    int32 = 26   # :
OP_DOT:      int32 = 27   # .
OP_REDIR2:   int32 = 28   # 2>   (stderr redirect)
OP_DUP21:    int32 = 29   # 2>&1 (stderr->stdout dup)
OP_AMP:      int32 = 30   # &    (background)
OP_DGT:      int32 = 31   # >>   (append redirect)
OP_ASSIGN_LIT: int32 = 32 # =    but GLUED to the LHS name (POSIX
                          # `VAR=value`): the RHS is a LITERAL word,
                          # not an arithmetic expression. A spaced `=`
                          # (`x = a + b`) stays OP_ASSIGN (expression).
# Membership operators. These have NO punctuation token — they are
# spelled with the reserved words `in` / `not in` and are synthesised
# into ND_BINOP by parse_cmp (see _peek_membership). They evaluate to a
# bool: `x in <list>` (element equality), `x in <dict>` (key present),
# `sub in <str>` (substring). `not in` is the negation.
OP_IN:       int32 = 33   # x in container
OP_NOTIN:    int32 = 34   # x not in container
# §Floor-division: `a // b` (spaced, Python floor semantics). Emitted
# only by the lexer's spaced-`/` site when TWO slashes are seen, so a
# path like `a//b` (glued, no value on the left) is still a word.
OP_FLOORDIV: int32 = 35   # //  (floor division)

# Parallel token arrays. tok_kind drives, the other two carry payload.
tok_kind: Array[4096, int32]
tok_str:  Array[4096, uint64]   # str-arena offset for WORD/STR/DOLLAR
tok_int:  Array[4096, int64]    # int literal / op code / sub-span end
# QA-N20: tok_glued[i]=1 iff token i abuts the PREVIOUS token with NO
# whitespace/separator between them (`Kpre$s`, `$s.txt`, `p/$a/$b`).
# The parser fuses a run of glued word-continuation tokens into ONE
# argv word (ND_ARGCAT) — the `$`-adjacency analog of QA-N7 `=`-fusion.
tok_glued: Array[4096, int32]
# tok_line[i] = the 1-based source line number token i was lexed on.
# Fuels line-numbered parse errors (ps_set_err reads tok_line[ps_pos]).
tok_line:  Array[4096, int32]
tok_count: uint64 = 0

# --- significant-indentation lexer state ----------------------------
# The indent stack holds the column of each currently-open indentation
# level (base level 0 always at the bottom). _at_line_start is set at
# every logical-line boundary so the next non-blank line's leading
# column is measured exactly once. _paren_depth suppresses INDENT/DEDENT
# inside ( ) / [ ] (Python's implicit line-join rule). _lex_line_no is
# the running 1-based line counter stamped onto every emitted token.
IND_STACK_MAX: uint64 = 64
_ind_stack:   Array[64, int32]
_ind_sp:      uint64 = 1
_at_line_start: int32 = 1
_paren_depth: int32 = 0
_lex_line_no: int32 = 1
# Set to 1 whenever the lexer consumes whitespace / a comment / a
# statement separator; _emit_tok reads it to compute the next token's
# glued flag, then clears it.
_lex_saw_sep: int32 = 1

# For TK_DOLEXPR / TK_BACKEXP the token carries a *sub-token span*:
# tok_str = start index into a separate sub-token stream is overkill;
# instead we store the raw source slice as a string ref and re-lex it
# lazily at eval time. tok_str holds that interned source slice.


def _is_digit(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return 1
    return 0


def _is_ident_start(c: uint8) -> int32:
    if c >= 65 and c <= 90:
        return 1
    if c >= 97 and c <= 122:
        return 1
    if c == 95:                              # _
        return 1
    return 0


def _is_ident(c: uint8) -> int32:
    if _is_ident_start(c) != 0:
        return 1
    if _is_digit(c) != 0:
        return 1
    return 0


def _is_space(c: uint8) -> int32:
    if c == 32 or c == 9:                    # space, tab
        return 1
    return 0


def _is_word_char(c: uint8) -> int32:
    # The generous bare-word character class (ident + path/glob chars).
    # Used to decide whether a glued ':' joins a bare word (URLs,
    # host:port, PATH lists) — see the lexer's bare-word scan.
    if _is_ident(c) != 0 or c == 47 or c == 46 or c == 45 or \
            c == 42 or c == 63 or c == 91 or c == 93:
        return 1
    return 0


# Lexer error flag. Set on an unterminated quote / brace-substitution,
# or on token-array overflow (a too-large logical input). Declared
# before _emit_tok so the overflow store below resolves cleanly.
lex_error: int32 = 0


def _prev_tok_is_value() -> int32:
    # §Float division: 1 iff the LAST emitted token produces a value that a
    # binary `/` could divide — a number, a $-interpolation, a `` `{} ``
    # capture, or a closing `)` / `]`. Used so a SPACE-surrounded `/` after
    # such a token lexes as OP_SLASH (division), while a `/` after a command
    # word (`ls /`) or at line start stays a literal path. Command position
    # therefore keeps `/` = root; expression position gets true division.
    if tok_count == 0:
        return 0
    pk: int32 = tok_kind[tok_count - 1]
    if pk == TK_INT or pk == TK_FLOAT or pk == TK_DOLLAR \
            or pk == TK_DOLEXPR or pk == TK_BACKEXP:
        return 1
    if pk == TK_OP:
        op: int64 = tok_int[tok_count - 1]
        if op == cast[int64](OP_RPAREN) or op == cast[int64](OP_RBRACKET):
            return 1
    return 0


def _emit_tok(kind: int32, sref: uint64, ival: int64):
    if tok_count >= TOK_MAX:
        # Overflow: flag a clean lexical error rather than SILENTLY
        # dropping the tail of the input (which used to truncate the
        # closing `}` / TK_EOF of a large sourced script and abort it
        # with a spurious "empty command"). lex_line surfaces this.
        lex_error = 1
        return
    tok_kind[tok_count] = kind
    tok_str[tok_count]  = sref
    tok_int[tok_count]  = ival
    tok_line[tok_count] = _lex_line_no
    tok_glued[tok_count] = 0
    if _lex_saw_sep == 0:
        tok_glued[tok_count] = 1        # abuts previous token (no space)
    tok_count = tok_count + 1
    _lex_saw_sep = 0


# Scratch for assembling a word/string before interning.
lex_word: Array[1024, uint8]


def _scan_balanced(buf: Ptr[uint8], n: uint64, start: uint64,
                   openc: uint8, closec: uint8) -> uint64:
    # Given buf[start] == openc, return the index of the matching
    # closec (depth-aware), or n on "unterminated".
    depth: int32 = 0
    p: uint64 = start
    while p < n:
        c: uint8 = buf[p]
        if c == openc:
            depth = depth + 1
        elif c == closec:
            depth = depth - 1
            if depth == 0:
                return p
        p = p + 1
    return n


def _emit_indent_for_col(col: int32):
    # At a fresh non-blank logical line whose leading column is `col`,
    # emit INDENT / DEDENT tokens relative to the indent stack. A deeper
    # column pushes a level (one INDENT); a shallower column pops every
    # level above it (one DEDENT each). Equal column emits nothing. A
    # dedent that lands between two open levels is tolerated (it snaps to
    # the nearest enclosing level) rather than raising — the parser's
    # colon-suite handling is forgiving so an odd indent never wedges.
    top: int32 = _ind_stack[_ind_sp - 1]
    if col > top:
        if _ind_sp < IND_STACK_MAX:
            _ind_stack[_ind_sp] = col
            _ind_sp = _ind_sp + 1
        _emit_tok(TK_INDENT, 0, 0)
    elif col < top:
        while _ind_sp > 1 and _ind_stack[_ind_sp - 1] > col:
            _ind_sp = _ind_sp - 1
            _emit_tok(TK_DEDENT, 0, 0)


def lex_line(buf: Ptr[uint8], n: uint64) -> int32:
    # Tokenize buf[0..n) into the tok_* arrays. Returns 0 on success,
    # -1 on a lexical error (unterminated quote/brace). A trailing
    # TK_EOF is always appended.
    tok_count = 0
    lex_error = 0
    _lex_saw_sep = 1                          # first token is never "glued"
    _ind_sp = 1                               # reset the indent stack
    _ind_stack[0] = 0
    _at_line_start = 1                        # measure the first line's indent
    _paren_depth = 0
    _lex_line_no = 1
    p: uint64 = 0
    while p < n:
        # Significant-indentation bookkeeping. At the very start of a
        # logical line, measure the leading-whitespace column and emit
        # INDENT/DEDENT before the line's first real token. Blank lines
        # and comment-only lines carry NO indentation (Python rule) — we
        # leave them to the normal whitespace/comment/newline handling.
        # Suppressed inside ( ) / [ ] where line breaks don't matter.
        if _at_line_start != 0:
            _at_line_start = 0
            if _paren_depth == 0:
                col: int32 = 0
                q: uint64 = p
                while q < n and (buf[q] == 32 or buf[q] == 9):
                    col = col + 1
                    q = q + 1
                # Only a line with real content sets indentation; a blank
                # or comment-only line is skipped so it can't spuriously
                # dedent an open suite.
                if q < n and buf[q] != 10 and buf[q] != 35:
                    _emit_indent_for_col(col)
                    _lex_saw_sep = 1
                    p = q
                    continue
        c: uint8 = buf[p]
        # whitespace
        if _is_space(c) != 0:
            _lex_saw_sep = 1
            p = p + 1
            continue
        # comment to end of line
        if c == 35:                          # '#'
            _lex_saw_sep = 1
            while p < n and buf[p] != 10:
                p = p + 1
            continue
        # newline / semicolon -> statement separator
        if c == 10 or c == 59:               # '\n' ';'
            _emit_tok(TK_NEWLINE, 0, 0)
            _lex_saw_sep = 1                  # next token not glued across sep
            if c == 10:
                _lex_line_no = _lex_line_no + 1
                # A real newline begins a fresh logical line: re-measure
                # its indentation on the next iteration. (A ';' separates
                # statements WITHIN a physical line — no re-measure.)
                _at_line_start = 1
            p = p + 1
            continue
        # §Float division: a SPACE-surrounded `/` right after a value token
        # (`1 / 2`, `$x / $y`, `f(...) / 2`, `a[i] / n`) is the division
        # OPERATOR. It must be flanked by whitespace/EOL on the right (a
        # glued `/` like `a/b`, `/dev/cons`, `1/2` is still a path) and the
        # previous token must be value-producing (so `ls /` keeps `/` = root
        # in command position). This is the ONLY site that emits OP_SLASH —
        # without it, parse_mul's `/` arm was unreachable (dead code).
        # §Floor-division: a SPACE-surrounded `//` right after a value
        # token (`7 // 2`, `$x // $y`) is the floor-division OPERATOR.
        # Checked BEFORE single `/` so the second slash is consumed here,
        # not left to lex as a second OP_SLASH (or a path root).
        if c == 47 and p + 1 < n and buf[p + 1] == 47 \
                and _prev_tok_is_value() != 0 \
                and (p + 2 >= n or _is_space(buf[p + 2]) != 0 \
                     or buf[p + 2] == 10 or buf[p + 2] == 59):
            _emit_tok(TK_OP, 0, cast[int64](OP_FLOORDIV))
            p = p + 2
            continue
        if c == 47 and _prev_tok_is_value() != 0 \
                and (p + 1 >= n or _is_space(buf[p + 1]) != 0 \
                     or buf[p + 1] == 10 or buf[p + 1] == 59):
            _emit_tok(TK_OP, 0, cast[int64](OP_SLASH))
            p = p + 1
            continue
        # integer literal
        if _is_digit(c) != 0:
            # Could be `2>` / `2>&1` — handle the 2-redirect specially.
            if c == 50 and p + 1 < n and buf[p + 1] == 62:   # '2>'
                if p + 3 < n and buf[p + 2] == 38 and \
                        buf[p + 3] == 49:                    # '2>&1'
                    _emit_tok(TK_OP, 0, cast[int64](OP_DUP21))
                    p = p + 4
                    continue
                _emit_tok(TK_OP, 0, cast[int64](OP_REDIR2))
                p = p + 2
                continue
            # Peek at the digit run: if it's followed by '.<digit>' (a
            # dotted-numeric literal — IPv4, version numbers like
            # `1.2.3`, etc.) lex the whole run as a TK_WORD so the
            # argv reaches the spawned command intact. Without this
            # `ping 10.0.2.2` becomes argv = [..., "-c", "3", "10",
            # ".0.2.2"]. Plain `123` keeps the existing TK_INT path.
            #
            # NB: this is a one-char peek; an integer followed by a
            # space-then-`.` (e.g. `ls .`) is unaffected — `.` is
            # only word-glued when it ABUTS a digit.
            q: uint64 = p
            while q < n and _is_digit(buf[q]) != 0:
                q = q + 1
            # §Float: a float literal is <digits>.<digits>[e[±]<digits>]
            # or <digits>e[±]<digits>. It is DISTINGUISHED from an IPv4 /
            # version word (`1.2.3`) by having AT MOST ONE dot and no
            # trailing word char. `10.0.2.2` (a second dot) still lexes as
            # a word; `3.14`, `1.5e3`, `2e10` lex as TK_FLOAT.
            fe: uint64 = q
            isf: int32 = 0
            if fe < n and buf[fe] == 46 and fe + 1 < n \
                    and _is_digit(buf[fe + 1]) != 0:
                fe = fe + 1
                while fe < n and _is_digit(buf[fe]) != 0:
                    fe = fe + 1
                isf = 1
                if fe < n and buf[fe] == 46:        # 2nd dot -> version/IP
                    isf = 0
            if (isf != 0 or fe == q) and fe < n \
                    and (buf[fe] == 101 or buf[fe] == 69):     # e / E
                ec: uint64 = fe + 1
                if ec < n and (buf[ec] == 43 or buf[ec] == 45):
                    ec = ec + 1
                if ec < n and _is_digit(buf[ec]) != 0:
                    while ec < n and _is_digit(buf[ec]) != 0:
                        ec = ec + 1
                    fe = ec
                    isf = 1
            # Disqualify a float glued to an IDENTIFIER char (e.g. `3.0x`) —
            # that is a bare word, not a number. Only a trailing LETTER / `_`
            # disqualifies (all digits are already consumed); a following
            # `]` `)` `,` `*` etc. is a legitimate float boundary inside a
            # list / index / call (`[1.5, 2.5]`, `xs[2.0]`).
            if isf != 0 and fe < n and _is_ident(buf[fe]) != 0:
                isf = 0
            if isf != 0:
                fref: uint64 = str_intern_n(
                    cast[Ptr[uint8]](cast[uint64](buf) + p), fe - p)
                _emit_tok(TK_FLOAT, fref, 0)
                p = fe
                continue
            if q + 1 < n and buf[q] == 46 \
                    and _is_digit(buf[q + 1]) != 0:
                wl: uint64 = 0
                while p < n:
                    wc: uint8 = buf[p]
                    if _is_word_char(wc) != 0:
                        if wl + 1 < LINE_MAX:
                            lex_word[wl] = wc
                            wl = wl + 1
                        p = p + 1
                    else:
                        break
                sref: uint64 = str_intern_n(&lex_word[0], wl)
                _emit_tok(TK_WORD, sref, 0)
                continue
            v: int64 = 0
            while p < n and _is_digit(buf[p]) != 0:
                v = v * 10 + cast[int64](buf[p] - 48)
                p = p + 1
            _emit_tok(TK_INT, 0, v)
            continue
        # identifier / bare word starting with a letter or '_'
        # — a "bare word" can also contain '/', '.', '-', '*' '?'
        #   '[' ']' etc., for paths and globs. We accept a generous
        #   word-char set so /dev/cons, *.ad, ./x all lex as ONE word.
        # A ':' joins a bare word ONLY when GLUED — preceded AND
        #   followed by a word-class char — so URLs (http://h:8080),
        #   host:port, and PATH lists (/bin:/sbin) lex as ONE word,
        #   while a dict's `key: value` (':' followed by whitespace)
        #   still tokenizes ':' as OP_COLON.
        # A '-' may START a word when immediately followed by a
        #   LETTER / '_' or another '-' — so OPTION words (`-la`,
        #   `-b`, `--all`) lex as ONE literal word in command position
        #   (§4). It deliberately does NOT start a word before a digit,
        #   so a negative literal (`-5`) still lexes as OP_MINUS + INT
        #   and unary negation keeps working. Arithmetic must be
        #   written with spaces (`a - b`), never glued (`a-opt`).
        # '~' / '~/...' at a word boundary -> tilde expansion to $HOME.
        # Only a LEADING bare `~` (alone or followed by '/') expands;
        # `~user` is not supported, so `~` glued before a word char is
        # left for the generic word scan. The expansion happens at lex
        # time so the result flows through globbing/redirection like any
        # other path word. With HOME unset/empty the literal '~' tail is
        # kept (matches POSIX "no expansion when HOME is unset").
        if c == 126 and (p + 1 >= n or buf[p + 1] == 47 \
                or _is_word_char(buf[p + 1]) == 0):
            twl: uint64 = 0
            hp: Ptr[uint8] = env_get(cast[Ptr[uint8]]("HOME"))
            if cast[uint64](hp) != 0 and hp[0] != 0:
                hi: uint64 = 0
                while hp[hi] != 0 and twl + 1 < LINE_MAX:
                    lex_word[twl] = hp[hi]
                    twl = twl + 1
                    hi = hi + 1
            else:
                lex_word[twl] = 126                # keep literal '~'
                twl = twl + 1
            p = p + 1                              # consume '~'
            # Append the path tail (the '/...' part) as a normal word.
            while p < n:
                twc: uint8 = buf[p]
                if _is_word_char(twc) != 0:
                    if twl + 1 < LINE_MAX:
                        lex_word[twl] = twc
                        twl = twl + 1
                    p = p + 1
                elif twc == 58 and twl > 0 and p + 1 < n and \
                        _is_word_char(buf[p + 1]) != 0:    # glued ':'
                    if twl + 1 < LINE_MAX:
                        lex_word[twl] = twc
                        twl = twl + 1
                    p = p + 1
                else:
                    break
            sref: uint64 = str_intern_n(&lex_word[0], twl)
            _emit_tok(TK_WORD, sref, 0)
            continue
        # §f-string: `f"..."` — a Python-style formatted string. Detected
        # BEFORE the generic word scan (`f` is an ident char, so the word
        # scan would otherwise swallow the `f`). The body is captured raw
        # (with \n / \t escapes honoured like a normal double-quoted
        # string); `{expr}` interpolation happens at eval (eval_fstring).
        if c == 102 and p + 1 < n and buf[p + 1] == 34:      # f"
            wl: uint64 = 0
            p = p + 2                                        # skip f"
            fterm: int32 = 0
            while p < n:
                fc: uint8 = buf[p]
                if fc == 34:
                    fterm = 1
                    p = p + 1
                    break
                if fc == 92 and p + 1 < n:                   # backslash esc
                    fnc: uint8 = buf[p + 1]
                    if fnc == 110:
                        fc = 10
                    elif fnc == 116:
                        fc = 9
                    else:
                        fc = fnc
                    p = p + 1
                if wl + 1 < LINE_MAX:
                    lex_word[wl] = fc
                    wl = wl + 1
                p = p + 1
            if fterm == 0:
                lex_error = 1
            fsref: uint64 = str_intern_n(&lex_word[0], wl)
            _emit_tok(TK_FSTR, fsref, 0)
            continue
        opt_start: int32 = 0
        if c == 45 and p + 1 < n and \
                (_is_ident_start(buf[p + 1]) != 0 or buf[p + 1] == 45):
            opt_start = 1
        if _is_ident_start(c) != 0 or c == 47 or c == 46 \
                or opt_start != 0:                # ident / '/' '.' / '-opt'
            wl: uint64 = 0
            while p < n:
                wc: uint8 = buf[p]
                if _is_word_char(wc) != 0:
                    if wl + 1 < LINE_MAX:
                        lex_word[wl] = wc
                        wl = wl + 1
                    p = p + 1
                elif wc == 58 and wl > 0 and p + 1 < n and \
                        _is_word_char(buf[p + 1]) != 0:    # glued ':'
                    if wl + 1 < LINE_MAX:
                        lex_word[wl] = wc
                        wl = wl + 1
                    p = p + 1
                elif wc == 61 and wl > 0:                  # trailing '='
                    # QA-N16: a glued `=`-run with WORD content BEFORE it
                    # and a TERMINATOR (whitespace / EOL / `;` / operator /
                    # end-of-input) AFTER the whole run is LITERAL text on
                    # this word, not an operator: `echo abc===` -> `abc===`,
                    # `echo foo==` -> `foo==`. A `=`-run FOLLOWED by a
                    # value-continuation char stays a `name=value` boundary
                    # (we break so the `=` lexes as OP_ASSIGN_LIT), keeping
                    # assignment semantics and QA-N7 arg fusion intact:
                    # `x=y=z`, leading `V=/x/y`, `p=$V`, `Q="..."`,
                    # `L='...'`. Continuation chars = word chars plus the
                    # RHS openers `$` `"` `'` and backtick.
                    er: uint64 = p
                    while er < n and buf[er] == 61:
                        er = er + 1
                    if er < n:
                        nc: uint8 = buf[er]
                        if _is_word_char(nc) != 0 or nc == 36 or \
                                nc == 34 or nc == 39 or nc == 96:
                            break                # `name=value` boundary
                    while p < er:
                        if wl + 1 < LINE_MAX:
                            lex_word[wl] = 61
                            wl = wl + 1
                        p = p + 1
                    break
                else:
                    break
            sref: uint64 = str_intern_n(&lex_word[0], wl)
            _emit_tok(TK_WORD, sref, 0)
            continue
        # double-quoted string (interpolating handled at eval)
        if c == 34:                          # '"'
            wl: uint64 = 0
            p = p + 1
            term: int32 = 0
            while p < n:
                qc: uint8 = buf[p]
                if qc == 34:
                    term = 1
                    p = p + 1
                    break
                if qc == 92 and p + 1 < n:   # backslash escape
                    nc: uint8 = buf[p + 1]
                    if nc == 110:            # \n
                        qc = 10
                    elif nc == 116:          # \t
                        qc = 9
                    else:
                        qc = nc
                    p = p + 1
                if wl + 1 < LINE_MAX:
                    lex_word[wl] = qc
                    wl = wl + 1
                p = p + 1
            if term == 0:
                lex_error = 1
            sref: uint64 = str_intern_n(&lex_word[0], wl)
            # TK_STR with tok_int=1 means "interpolating" (double quote)
            _emit_tok(TK_STR, sref, 1)
            continue
        # single-quoted string (literal, no interpolation)
        if c == 39:                          # '\''
            wl: uint64 = 0
            p = p + 1
            term: int32 = 0
            while p < n:
                qc: uint8 = buf[p]
                if qc == 39:
                    term = 1
                    p = p + 1
                    break
                if wl + 1 < LINE_MAX:
                    lex_word[wl] = qc
                    wl = wl + 1
                p = p + 1
            if term == 0:
                lex_error = 1
            sref: uint64 = str_intern_n(&lex_word[0], wl)
            _emit_tok(TK_STR, sref, 0)       # tok_int=0: non-interpolating
            continue
        # $name  /  ${ expr }
        if c == 36:                          # '$'
            if p + 1 < n and buf[p + 1] == 123:        # '${'
                close: uint64 = _scan_balanced(buf, n, p + 1, 123, 125)
                if close >= n:
                    lex_error = 1
                    p = n
                    continue
                # interned slice = chars between { and }
                inner: uint64 = p + 2
                ilen: uint64 = close - inner
                sref: uint64 = str_intern_n(
                    cast[Ptr[uint8]](cast[uint64](buf) + inner), ilen)
                _emit_tok(TK_DOLEXPR, sref, 0)
                p = close + 1
                continue
            # $name
            p = p + 1
            wl: uint64 = 0
            while p < n and _is_ident(buf[p]) != 0:
                if wl + 1 < LINE_MAX:
                    lex_word[wl] = buf[p]
                    wl = wl + 1
                p = p + 1
            sref: uint64 = str_intern_n(&lex_word[0], wl)
            _emit_tok(TK_DOLLAR, sref, 0)
            continue
        # `{ command substitution }`
        if c == 96:                          # '`'
            if p + 1 < n and buf[p + 1] == 123:
                close: uint64 = _scan_balanced(buf, n, p + 1, 123, 125)
                if close >= n:
                    lex_error = 1
                    p = n
                    continue
                inner: uint64 = p + 2
                ilen: uint64 = close - inner
                sref: uint64 = str_intern_n(
                    cast[Ptr[uint8]](cast[uint64](buf) + inner), ilen)
                _emit_tok(TK_BACKEXP, sref, 0)
                p = close + 1
                continue
            # bare backtick — treat as a literal char word
            lex_word[0] = 96
            sref: uint64 = str_intern_n(&lex_word[0], 1)
            _emit_tok(TK_WORD, sref, 0)
            p = p + 1
            continue
        # A word BEGINNING with '=' (empty left-hand side) is NOT an
        # assignment — there is no name before the '='. POSIX treats it
        # as an ordinary literal word: `echo =x` prints `=x`, `echo
        # ===x` prints `===x`, `echo =a=b` prints `=a=b`. We take this
        # path only when the '=' is at a word boundary (start of input,
        # or preceded by a non-word char — so a glued `name=val` still
        # lexes as name + OP_ASSIGN_LIT) AND the leading '=' run is GLUED
        # to following word content (a word char immediately after the
        # run). That glue requirement is what distinguishes an empty-LHS
        # literal word from a spaced assignment `x = 5` (OP_ASSIGN) or a
        # spaced comparison `a == b` (OP_EQEQ): those have whitespace
        # after the '='/'==', not a word char, so they fall through to
        # the operator dispatch below unchanged.
        if c == 61 and (p == 0 or _is_word_char(buf[p - 1]) == 0):
            q: uint64 = p
            while q < n and buf[q] == 61:
                q = q + 1
            if q < n and _is_word_char(buf[q]) != 0:
                wl: uint64 = 0
                while p < n:
                    wc: uint8 = buf[p]
                    if wc == 61 or _is_word_char(wc) != 0:
                        if wl + 1 < LINE_MAX:
                            lex_word[wl] = wc
                            wl = wl + 1
                        p = p + 1
                    else:
                        break
                sref: uint64 = str_intern_n(&lex_word[0], wl)
                _emit_tok(TK_WORD, sref, 0)
                continue
        # operators / punctuation
        op: int32 = 0
        adv: uint64 = 1
        if c == 61:                          # '='
            if p + 1 < n and buf[p + 1] == 61:
                op = OP_EQEQ
                adv = 2
            else:
                op = OP_ASSIGN
                # POSIX assignment: a `=` GLUED to the preceding name
                # (no intervening space, e.g. `HOME=/home/live`) makes
                # the RHS a LITERAL word rather than an arithmetic
                # expression. A spaced `=` (`x = a + b`) keeps the
                # expression semantics. The preceding token is a bare
                # name iff the char just before the `=` is a word char.
                if p > 0 and _is_word_char(buf[p - 1]) != 0:
                    op = OP_ASSIGN_LIT
        elif c == 43:                        # '+'
            if p + 1 < n and buf[p + 1] == 61:
                op = OP_PLUSEQ
                adv = 2
            else:
                op = OP_PLUS
        elif c == 45:                        # '-'
            if p + 1 < n and buf[p + 1] == 61:
                op = OP_MINUSEQ
                adv = 2
            else:
                op = OP_MINUS
        elif c == 123:
            op = OP_LBRACE
        elif c == 125:
            op = OP_RBRACE
        elif c == 40:
            op = OP_LPAREN
        elif c == 41:
            op = OP_RPAREN
        elif c == 91:
            op = OP_LBRACKET
        elif c == 93:
            op = OP_RBRACKET
        elif c == 44:
            op = OP_COMMA
        elif c == 124:                       # '|'
            if p + 1 < n and buf[p + 1] == 124:
                op = OP_OR
                adv = 2
            else:
                op = OP_PIPE
        elif c == 38:                        # '&'
            if p + 1 < n and buf[p + 1] == 38:
                op = OP_AND
                adv = 2
            else:
                op = OP_AMP
        elif c == 62:                        # '>'
            if p + 1 < n and buf[p + 1] == 61:
                op = OP_GE
                adv = 2
            elif p + 1 < n and buf[p + 1] == 62:
                op = OP_DGT
                adv = 2
            else:
                op = OP_GT
        elif c == 60:                        # '<'
            if p + 1 < n and buf[p + 1] == 61:
                op = OP_LE
                adv = 2
            else:
                op = OP_LT
        elif c == 33:                        # '!'
            if p + 1 < n and buf[p + 1] == 61:
                op = OP_NE
                adv = 2
            else:
                op = OP_NOT
        elif c == 42:
            op = OP_STAR
        elif c == 37:
            op = OP_PERCENT
        elif c == 58:
            op = OP_COLON
        else:
            # unknown char — skip it defensively
            p = p + 1
            continue
        # Track ( ) / [ ] nesting so INDENT/DEDENT is suppressed while a
        # bracketed expression spans lines (Python's implicit line-join).
        # `{ }` is deliberately NOT counted: a brace block's indented body
        # and a colon-suite nested inside a brace block both still get
        # their INDENT/DEDENT, which is what makes the two syntaxes fully
        # interchangeable.
        if op == OP_LPAREN or op == OP_LBRACKET:
            _paren_depth = _paren_depth + 1
        elif op == OP_RPAREN or op == OP_RBRACKET:
            if _paren_depth > 0:
                _paren_depth = _paren_depth - 1
        _emit_tok(TK_OP, 0, cast[int64](op))
        p = p + adv
    # End of input: close every still-open indentation level so a suite
    # that runs to the last line of a file is terminated by a DEDENT.
    while _ind_sp > 1:
        _ind_sp = _ind_sp - 1
        _emit_tok(TK_DEDENT, 0, 0)
    _emit_tok(TK_EOF, 0, 0)
    if lex_error != 0:
        return -1
    return 0


# ====================================================================
# AST node arena
# ====================================================================
# A node is a fixed record. Children are node indices (a child of 0 is
# "none" — node 0 is the reserved null node). Lists of children
# (statement blocks, argv, list literals) use a side "kid pool": a
# node stores kid_start / kid_count into nd_kid[].
#
# Node kinds.
ND_NONE:     int32 = 0
# --- statements ---
ND_CMD:      int32 = 1     # external/builtin command: kids = words
ND_ASSIGN:   int32 = 2     # name (str=a) OP (i=op) = expr (b)
ND_IF:       int32 = 3     # a=cond  b=then-block  c=else-block
ND_WHILE:    int32 = 4     # a=cond  b=body-block
ND_FOR:      int32 = 5     # str=var  kids=item-words  b=body-block
ND_DEF:      int32 = 6     # str=name kids=param names  b=body-block
ND_RETURN:   int32 = 7     # a=expr (0 = bare)
ND_BREAK:    int32 = 8
ND_CONTINUE: int32 = 9
ND_BLOCK:    int32 = 10    # kids = statements
ND_TRY:      int32 = 11    # a=try-block  b=except-block
ND_NS:       int32 = 12    # i=clean flag  b=body-block
ND_ENTER:    int32 = 13    # a=ns-expr  i=clean  b=body-block
ND_SPAWN:    int32 = 14    # a=ns-expr  i=detached  b=body-block
ND_PIPELINE: int32 = 15    # kids = ND_CMD stages
ND_EXPRSTMT: int32 = 16    # a=expr  (a bare expression as a statement)
ND_AND:      int32 = 17    # a && b   (statement-level)
ND_OR:       int32 = 18    # a || b   (statement-level)
ND_RAISE:    int32 = 19    # a=value expr (0 = bare re-raise). §Exceptions
# --- expressions ---
ND_INT:      int32 = 30    # i=value
ND_STR:      int32 = 31    # str=value (literal)
ND_STRI:     int32 = 32    # str=value (interpolating literal)
ND_VAR:      int32 = 33    # str=name
ND_DOLEXPR:  int32 = 34    # str=raw source (re-lexed at eval)
ND_BACKEXP:  int32 = 35    # str=raw command source
ND_LIST:     int32 = 36    # kids = element exprs
ND_DICT:     int32 = 37    # kids = alternating key,value exprs
ND_BINOP:    int32 = 38    # i=op a=lhs b=rhs
ND_UNOP:     int32 = 39    # i=op a=operand
ND_CALL:     int32 = 40    # str=fname kids=arg exprs
ND_INDEX:    int32 = 41    # a=container b=index
ND_TRUE:     int32 = 42
ND_FALSE:    int32 = 43
ND_WORD:     int32 = 44    # a bare word in command position (literal)
ND_MOUNT:    int32 = 45    # §14 mount expr: a=srvfd b=path str=label i=flag
ND_ARGCAT:   int32 = 46    # kids concatenated into ONE argv word. Built
                           # for an ARGUMENT-position glued `=` (POSIX
                           # `cmd arg=value`): the `=` is a literal char,
                           # NOT an assignment. Each kid renders to a
                           # string and they join with no separator.
# --- §17 Python-esque data constructs (#110) ------------------------
ND_LISTCOMP: int32 = 47    # a=element expr; kids = clause nodes
                           # (ND_COMPFOR / ND_COMPIF) in source order.
ND_DICTCOMP: int32 = 48    # a=key expr; b=value expr; kids = clauses.
ND_COMPFOR:  int32 = 49    # a=iterable expr; kids = target-name ND_STR
                           # nodes (>1 = tuple unpack).
ND_COMPIF:   int32 = 50    # a=filter cond.
ND_TUPLE:    int32 = 51    # kids = element exprs (comma expr-list /
                           # tuple literal; evaluates to a VT_LIST).
ND_TUPLEASSIGN: int32 = 52 # kids = target-name ND_STR nodes; a=RHS expr
                           # (unpacked element-wise; swap-safe).
ND_SLICE:    int32 = 53    # a=lo b=hi c=step; nd_i bitflags: 1=has_lo,
                           # 2=has_hi, 4=has_step. Appears as ND_INDEX's
                           # index child.
ND_FLOAT:    int32 = 55    # str=source slice, parsed to a double at eval.
ND_FSTR:     int32 = 56    # str=f-string body; `{expr}` interpolated.
# --- §19 context managers (#111) ------------------------------------
ND_INDEXASSIGN: int32 = 58 # `TARGET[idx] = expr` — a=ND_INDEX (a=base,
                           # b=index/slice), b=RHS expr. Mutates a list
                           # element or sets a dict key in place.
ND_KWARG:    int32 = 59    # `name=expr` inside a call arg list. str=name,
                           # a=value expr. Appended AFTER positional args;
                           # ND_CALL's nd_c records how many kids are kwargs.
ND_WITH:     int32 = 57    # `with CM(args) as NAME: body`. i=CM kind
                           # (WITH_BIND/WITH_MOUNT/WITH_ENTER); a=arg1;
                           # b=arg2 (bind/mount only); c=body-block;
                           # str=optional `as NAME` (0 = none). The bind/
                           # mount is applied on entry and UNDONE on exit
                           # (even on error) — a Plan 9 bind that scopes
                           # to the block, Python-`with`-style.

# Context-manager kinds carried in ND_WITH's nd_i.
WITH_BIND:   int64 = 1
WITH_MOUNT:  int64 = 2
WITH_ENTER:  int64 = 3

nd_kind: Array[16384, int32]
nd_a:    Array[16384, int32]
nd_b:    Array[16384, int32]
nd_c:    Array[16384, int32]
nd_i:    Array[16384, int64]
# nd_str / nd_ks / nd_ke / nd_kn are indexed by node id, so they MUST
# be sized to NODE_MAX (16384) — a 512-slot array would let nd_new
# write past the end the moment the session creates its 513th node.
nd_str:  Array[16384, uint64]
nd_ks:   Array[16384, int32]   # head slot of the kid linked-list (0 = empty)
nd_ke:   Array[16384, int32]   # tail slot of the kid linked-list (O(1) append)
nd_kn:   Array[16384, uint64]  # kid count
nd_count: uint64 = 1          # node 0 reserved as null

# Kid storage is a LINKED LIST, not a contiguous run. The previous
# contiguous-pool design required "push all of one node's kids before
# touching another node" — which is impossible for any nested parse:
# parse_block pushes a statement onto the block's list, but building
# the NEXT statement pushes that statement's OWN word-kids into the
# pool in between, scattering the block's kid run. A per-slot `next`
# pointer makes append correct regardless of interleaving.
nd_kid:      Array[32768, int32]   # the kid node id at this slot
nd_kid_next: Array[32768, int32]   # next slot in the owner's list (0 = end)
nd_kid_cursor: uint64 = 1          # slot 0 reserved as the list terminator

# Parser cursor + error.
ps_pos:   uint64 = 0
ps_error: int32 = 0
ps_errmsg: Array[64, uint8]
# Source line of the token the parser choked on (0 = unknown). Captured
# by ps_set_err from tok_line[ps_pos]; run_source prints it so a parse
# error in a sourced script points at the offending line.
ps_errline: int32 = 0

# Recursion-depth guard. The parser is recursive-descent; deeply
# nested input (`{ { { ... } } }`, `(((...)))`, `[[[...]]]`) recurses
# the C stack one frame per level — and every nesting level of an
# expression burns the WHOLE precedence-climbing chain
# (parse_expr -> or -> and -> cmp -> add -> mul -> unary -> postfix
# -> primary), each frame carrying parse-state Array locals. On the
# 256 KiB user stack that overflows past ~16 levels, and a parser
# stack fault corrupts adjacent BSS arenas — so the guard MUST trip
# well before then. parse_statement / parse_expr bump ps_depth on
# entry; past PS_DEPTH_MAX they raise a clean "nested too deep" parse
# error instead of recursing. 12 is proven non-corrupting and is far
# deeper than any real interactive line or rc script nests.
ps_depth:     int32 = 0
PS_DEPTH_MAX: int32 = 12


def ps_set_err(msg: Ptr[uint8]):
    if ps_error != 0:
        return
    ps_error = 1
    ps_errline = tok_line[ps_pos]
    i: uint64 = 0
    while msg[i] != 0 and i + 1 < 64:
        ps_errmsg[i] = msg[i]
        i = i + 1
    ps_errmsg[i] = 0


def nd_new(kind: int32) -> int32:
    if nd_count >= NODE_MAX:
        ps_set_err("node arena full")
        return 0
    n: uint64 = nd_count
    nd_count = nd_count + 1
    nd_kind[n] = kind
    nd_a[n]    = 0
    nd_b[n]    = 0
    nd_c[n]    = 0
    nd_i[n]    = 0
    nd_str[n]  = 0
    nd_ks[n]   = 0          # 0 = empty kid list
    nd_ke[n]   = 0
    nd_kn[n]   = 0
    return cast[int32](n)


def nd_kid_push(node: int32, kid: int32):
    # Append `kid` to `node`'s kid linked-list. Correct regardless of
    # interleaving — building another node's kid list in between does
    # not disturb this one (the old contiguous-pool design silently
    # scattered a block's statements when each statement's own kids
    # got pushed between two block-level pushes).
    nu: uint64 = cast[uint64](node)
    if nd_kid_cursor >= 32768:
        ps_set_err("kid pool full")
        return
    slot: uint64 = nd_kid_cursor
    nd_kid_cursor = nd_kid_cursor + 1
    nd_kid[slot] = kid
    nd_kid_next[slot] = 0                # end-of-list sentinel
    if nd_ks[nu] == 0:
        nd_ks[nu] = cast[int32](slot)    # first kid — becomes the head
    else:
        nd_kid_next[cast[uint64](nd_ke[nu])] = cast[int32](slot)
    nd_ke[nu] = cast[int32](slot)        # new tail
    nd_kn[nu] = nd_kn[nu] + 1


def nd_kid_at(node: int32, idx: uint64) -> int32:
    # Walk the kid linked-list to position `idx`. Blocks / arg lists
    # are short, so the O(n) walk is cheap.
    nu: uint64 = cast[uint64](node)
    slot: int32 = nd_ks[nu]
    i: uint64 = 0
    while slot != 0 and i < idx:
        slot = nd_kid_next[cast[uint64](slot)]
        i = i + 1
    if slot == 0:
        return 0
    return nd_kid[cast[uint64](slot)]


# --- token cursor helpers -------------------------------------------

def pk_kind() -> int32:
    return tok_kind[ps_pos]


def pk_glued() -> int32:
    # 1 iff the current token abuts the previous token with no
    # whitespace between them (see tok_glued / QA-N20).
    return tok_glued[ps_pos]


def pk_is_op(op: int32) -> int32:
    if tok_kind[ps_pos] == TK_OP and tok_int[ps_pos] == cast[int64](op):
        return 1
    return 0


def pk_advance():
    if ps_pos + 1 < TOK_MAX:
        ps_pos = ps_pos + 1


def pk_expect_op(op: int32, what: Ptr[uint8]) -> int32:
    if pk_is_op(op) != 0:
        pk_advance()
        return 1
    ps_set_err(what)
    return 0


# Keyword test on a TK_WORD token.
def _word_is(idx: uint64, kw: Ptr[uint8]) -> int32:
    if tok_kind[idx] != TK_WORD:
        return 0
    return cstr_eq(str_ptr(tok_str[idx]), kw)


def pk_word_is(kw: Ptr[uint8]) -> int32:
    return _word_is(ps_pos, kw)


def _is_stmt_keyword(idx: uint64) -> int32:
    # §2 rule 1: first token a statement-starting reserved keyword.
    if _word_is(idx, "if") != 0:
        return 1
    if _word_is(idx, "while") != 0:
        return 1
    if _word_is(idx, "for") != 0:
        return 1
    if _word_is(idx, "def") != 0:
        return 1
    if _word_is(idx, "return") != 0:
        return 1
    if _word_is(idx, "break") != 0:
        return 1
    if _word_is(idx, "continue") != 0:
        return 1
    if _word_is(idx, "raise") != 0:
        return 1
    if _word_is(idx, "try") != 0:
        return 1
    if _word_is(idx, "with") != 0:
        return 1
    if _word_is(idx, "ns") != 0:
        return 1
    if _word_is(idx, "enter") != 0:
        return 1
    if _word_is(idx, "spawn") != 0:
        return 1
    return 0


def _is_continuation_keyword(idx: uint64) -> int32:
    # elif/else/except: reserved continuation keywords (§2).
    if _word_is(idx, "elif") != 0:
        return 1
    if _word_is(idx, "else") != 0:
        return 1
    if _word_is(idx, "except") != 0:
        return 1
    if _word_is(idx, "finally") != 0:
        return 1
    return 0


# ====================================================================
# Parser — recursive descent
# ====================================================================
# Forward-declared mutual recursion is fine in Adder (flat module
# namespace). parse_expr / parse_block / parse_statement call each
# other freely.

# --- expression grammar (precedence climbing) -----------------------
#   expr      := or_expr
#   or_expr   := and_expr   ( '||' and_expr )*
#   and_expr  := not_expr   ( '&&' not_expr )*
#   not_expr  := '!' not_expr | cmp_expr
#   cmp_expr  := add_expr   ( (== != < > <= >=) add_expr )*
#   add_expr  := mul_expr   ( (+ -) mul_expr )*
#   mul_expr  := unary      ( (* / %) unary )*
#   unary     := '-' unary | postfix
#   postfix   := primary ( '[' expr ']' )*
#   primary   := INT | STR | TRUE | FALSE | VAR | DOLEXPR | BACKEXP
#              | '(' expr ')' | '[' list ']' | '{' dict '}'
#              | IDENT '(' args ')'

def parse_expr() -> int32:
    # Depth-guarded entry to the expression grammar. Every nested
    # sub-expression ( ( ) / [ ] / dict / call args ) re-enters here,
    # so the guard here catches adversarial deep nesting before the C
    # stack overflows.
    if ps_depth >= PS_DEPTH_MAX:
        ps_set_err("expression nested too deep")
        return 0
    ps_depth = ps_depth + 1
    r: int32 = parse_or()
    ps_depth = ps_depth - 1
    return r


def parse_or() -> int32:
    lhs: int32 = parse_and()
    while pk_is_op(OP_OR) != 0:
        pk_advance()
        rhs: int32 = parse_and()
        n: int32 = nd_new(ND_BINOP)
        nd_i[cast[uint64](n)] = cast[int64](OP_OR)
        nd_a[cast[uint64](n)] = lhs
        nd_b[cast[uint64](n)] = rhs
        lhs = n
    return lhs


def parse_and() -> int32:
    lhs: int32 = parse_not()
    while pk_is_op(OP_AND) != 0:
        pk_advance()
        rhs: int32 = parse_not()
        n: int32 = nd_new(ND_BINOP)
        nd_i[cast[uint64](n)] = cast[int64](OP_AND)
        nd_a[cast[uint64](n)] = lhs
        nd_b[cast[uint64](n)] = rhs
        lhs = n
    return lhs


def parse_not() -> int32:
    if pk_is_op(OP_NOT) != 0:
        pk_advance()
        operand: int32 = parse_not()
        n: int32 = nd_new(ND_UNOP)
        nd_i[cast[uint64](n)] = cast[int64](OP_NOT)
        nd_a[cast[uint64](n)] = operand
        return n
    return parse_cmp()


def _is_cmp_op() -> int32:
    if pk_is_op(OP_EQEQ) != 0:
        return 1
    if pk_is_op(OP_NE) != 0:
        return 1
    if pk_is_op(OP_LT) != 0:
        return 1
    if pk_is_op(OP_GT) != 0:
        return 1
    if pk_is_op(OP_LE) != 0:
        return 1
    if pk_is_op(OP_GE) != 0:
        return 1
    return 0


def _peek_membership() -> int32:
    # 0 if the cursor is not on a membership keyword; OP_IN for a bare
    # `in`; OP_NOTIN for the two-word `not in`. Only a `not` that is
    # immediately followed by `in` is claimed — a lone `not` stays a
    # plain word (hamsh's boolean negation is `!`, handled in parse_not).
    if pk_word_is("in") != 0:
        return OP_IN
    if pk_word_is("not") != 0:
        if _word_is(ps_pos + 1, "in") != 0:
            return OP_NOTIN
    return 0


def parse_cmp() -> int32:
    lhs: int32 = parse_add()
    while True:
        if _is_cmp_op() != 0:
            op: int32 = cast[int32](tok_int[ps_pos])
            pk_advance()
            rhs: int32 = parse_add()
            n: int32 = nd_new(ND_BINOP)
            nd_i[cast[uint64](n)] = cast[int64](op)
            nd_a[cast[uint64](n)] = lhs
            nd_b[cast[uint64](n)] = rhs
            lhs = n
            continue
        memop: int32 = _peek_membership()
        if memop != 0:
            if memop == OP_NOTIN:
                pk_advance()                 # consume 'not'
            pk_advance()                     # consume 'in'
            mrhs: int32 = parse_add()
            m: int32 = nd_new(ND_BINOP)
            nd_i[cast[uint64](m)] = cast[int64](memop)
            nd_a[cast[uint64](m)] = lhs
            nd_b[cast[uint64](m)] = mrhs
            lhs = m
            continue
        break
    return lhs


def parse_add() -> int32:
    lhs: int32 = parse_mul()
    while pk_is_op(OP_PLUS) != 0 or pk_is_op(OP_MINUS) != 0:
        op: int32 = cast[int32](tok_int[ps_pos])
        pk_advance()
        rhs: int32 = parse_mul()
        n: int32 = nd_new(ND_BINOP)
        nd_i[cast[uint64](n)] = cast[int64](op)
        nd_a[cast[uint64](n)] = lhs
        nd_b[cast[uint64](n)] = rhs
        lhs = n
    return lhs


def parse_mul() -> int32:
    lhs: int32 = parse_unary()
    while pk_is_op(OP_STAR) != 0 or pk_is_op(OP_SLASH) != 0 or \
            pk_is_op(OP_FLOORDIV) != 0 or pk_is_op(OP_PERCENT) != 0:
        op: int32 = cast[int32](tok_int[ps_pos])
        pk_advance()
        rhs: int32 = parse_unary()
        n: int32 = nd_new(ND_BINOP)
        nd_i[cast[uint64](n)] = cast[int64](op)
        nd_a[cast[uint64](n)] = lhs
        nd_b[cast[uint64](n)] = rhs
        lhs = n
    return lhs


def parse_unary() -> int32:
    if pk_is_op(OP_MINUS) != 0:
        pk_advance()
        operand: int32 = parse_unary()
        n: int32 = nd_new(ND_UNOP)
        nd_i[cast[uint64](n)] = cast[int64](OP_MINUS)
        nd_a[cast[uint64](n)] = operand
        return n
    return parse_postfix()


def _word_method_dot(wref: uint64) -> int64:
    # If `wref` is `<ident>.<rest>` — the head a non-empty identifier
    # (letters/digits/_ only, so NOT a path with '/' and NOT a dotted
    # numeric/glob) with a non-empty tail after the first '.', return the
    # byte index of that '.'; else -1. Drives the `recv.method(...)`
    # desugar. Only ever consulted when a '(' follows, so a bare dotted
    # word (`a.txt`, `1.2`) is untouched unless literally called.
    s: Ptr[uint8] = str_ptr(wref)
    if _is_ident_start(s[0]) == 0:
        return -1
    i: uint64 = 0
    while s[i] != 0:
        if s[i] == 46:                       # '.'
            if i == 0 or s[i + 1] == 0:
                return -1
            return cast[int64](i)
        if _is_ident(s[i]) == 0:             # '/', '-', '*', … → not a method
            return -1
        i = i + 1
    return -1


def _parse_index_or_slice() -> int32:
    # Inside `[ ... ]`: either a single index expression, or a Python
    # slice `lo:hi:step` (each part optional). A plain index returns the
    # index expression node directly; a slice returns an ND_SLICE whose
    # nd_i bitflags (1/2/4) record which of lo/hi/step were supplied.
    lo: int32 = 0
    has_lo: int64 = 0
    if pk_is_op(OP_COLON) == 0 and pk_is_op(OP_RBRACKET) == 0:
        lo = parse_expr()
        has_lo = 1
    if pk_is_op(OP_COLON) == 0:
        return lo                     # plain subscript
    pk_advance()                      # consume first ':'
    hi: int32 = 0
    has_hi: int64 = 0
    if pk_is_op(OP_COLON) == 0 and pk_is_op(OP_RBRACKET) == 0:
        hi = parse_expr()
        has_hi = 1
    step: int32 = 0
    has_step: int64 = 0
    if pk_is_op(OP_COLON) != 0:
        pk_advance()                  # consume second ':'
        if pk_is_op(OP_RBRACKET) == 0:
            step = parse_expr()
            has_step = 1
    s: int32 = nd_new(ND_SLICE)
    nd_a[cast[uint64](s)] = lo
    nd_b[cast[uint64](s)] = hi
    nd_c[cast[uint64](s)] = step
    flags: int64 = 0
    if has_lo != 0:
        flags = flags | 1
    if has_hi != 0:
        flags = flags | 2
    if has_step != 0:
        flags = flags | 4
    nd_i[cast[uint64](s)] = flags
    return s


def parse_postfix() -> int32:
    base: int32 = parse_primary()
    while pk_is_op(OP_LBRACKET) != 0:
        pk_advance()
        idx: int32 = _parse_index_or_slice()
        pk_expect_op(OP_RBRACKET, "expected ]")
        n: int32 = nd_new(ND_INDEX)
        nd_a[cast[uint64](n)] = base
        nd_b[cast[uint64](n)] = idx
        base = n
    return base


def _parse_comp_targets(clause: int32):
    # A comprehension / for-loop target: NAME ( ',' NAME )* — one or more
    # bare identifiers stored as ND_STR kid nodes on `clause`. Multiple
    # targets = tuple unpacking (`for k, v in ...`).
    while True:
        if pk_kind() != TK_WORD:
            ps_set_err("expected name in comprehension")
            return
        t: int32 = nd_new(ND_STR)
        nd_str[cast[uint64](t)] = tok_str[ps_pos]
        nd_kid_push(clause, t)
        pk_advance()
        if pk_is_op(OP_COMMA) != 0:
            pk_advance()
            continue
        break


def parse_comp_clauses(comp: int32):
    # `for TARGET in ITER` and `if COND` clauses, in source order, appended
    # as ND_COMPFOR / ND_COMPIF kids of `comp`. Supports nesting
    # (`for a in .. for b in ..`) and an optional trailing `if`.
    while True:
        if pk_word_is("for") != 0:
            pk_advance()
            cf: int32 = nd_new(ND_COMPFOR)
            _parse_comp_targets(cf)
            if pk_word_is("in") == 0:
                ps_set_err("expected 'in' in comprehension")
                return
            pk_advance()
            nd_a[cast[uint64](cf)] = parse_expr()
            nd_kid_push(comp, cf)
            continue
        if pk_word_is("if") != 0:
            pk_advance()
            ci: int32 = nd_new(ND_COMPIF)
            nd_a[cast[uint64](ci)] = parse_expr()
            nd_kid_push(comp, ci)
            continue
        break


def parse_list_literal() -> int32:
    # caller has consumed '['
    if pk_is_op(OP_RBRACKET) != 0:
        pk_advance()
        return nd_new(ND_LIST)
    first: int32 = parse_expr()
    # `[ EXPR for x in ... ]` — a list comprehension.
    if pk_word_is("for") != 0:
        comp: int32 = nd_new(ND_LISTCOMP)
        nd_a[cast[uint64](comp)] = first
        parse_comp_clauses(comp)
        pk_expect_op(OP_RBRACKET, "expected ] to close comprehension")
        return comp
    n: int32 = nd_new(ND_LIST)
    nd_kid_push(n, first)
    while True:
        if pk_is_op(OP_COMMA) != 0:
            pk_advance()
            if pk_is_op(OP_RBRACKET) != 0:
                pk_advance()
                break
            e: int32 = parse_expr()
            nd_kid_push(n, e)
            continue
        pk_expect_op(OP_RBRACKET, "expected ] in list")
        break
    return n


def parse_dict_literal() -> int32:
    # caller has consumed '{'
    if pk_is_op(OP_RBRACE) != 0:
        pk_advance()
        return nd_new(ND_DICT)
    k: int32 = parse_expr()
    pk_expect_op(OP_COLON, "expected : in dict")
    v: int32 = parse_expr()
    # `{ K: V for x in ... }` — a dict comprehension.
    if pk_word_is("for") != 0:
        comp: int32 = nd_new(ND_DICTCOMP)
        nd_a[cast[uint64](comp)] = k
        nd_b[cast[uint64](comp)] = v
        parse_comp_clauses(comp)
        pk_expect_op(OP_RBRACE, "expected } to close dict comprehension")
        return comp
    n: int32 = nd_new(ND_DICT)
    nd_kid_push(n, k)
    nd_kid_push(n, v)
    while True:
        if pk_is_op(OP_COMMA) != 0:
            pk_advance()
            if pk_is_op(OP_RBRACE) != 0:
                pk_advance()
                break
            k2: int32 = parse_expr()
            pk_expect_op(OP_COLON, "expected : in dict")
            v2: int32 = parse_expr()
            nd_kid_push(n, k2)
            nd_kid_push(n, v2)
            continue
        pk_expect_op(OP_RBRACE, "expected } in dict")
        break
    return n


def parse_primary() -> int32:
    k: int32 = pk_kind()
    if k == TK_INT:
        n: int32 = nd_new(ND_INT)
        nd_i[cast[uint64](n)] = tok_int[ps_pos]
        pk_advance()
        return n
    if k == TK_FLOAT:
        n: int32 = nd_new(ND_FLOAT)
        nd_str[cast[uint64](n)] = tok_str[ps_pos]
        pk_advance()
        return n
    if k == TK_FSTR:
        n: int32 = nd_new(ND_FSTR)
        nd_str[cast[uint64](n)] = tok_str[ps_pos]
        pk_advance()
        return n
    if k == TK_STR:
        kind: int32 = ND_STR
        if tok_int[ps_pos] != 0:
            kind = ND_STRI
        n: int32 = nd_new(kind)
        nd_str[cast[uint64](n)] = tok_str[ps_pos]
        pk_advance()
        return n
    if k == TK_DOLLAR:
        n: int32 = nd_new(ND_VAR)
        nd_str[cast[uint64](n)] = tok_str[ps_pos]
        pk_advance()
        return n
    if k == TK_DOLEXPR:
        n: int32 = nd_new(ND_DOLEXPR)
        nd_str[cast[uint64](n)] = tok_str[ps_pos]
        pk_advance()
        return n
    if k == TK_BACKEXP:
        n: int32 = nd_new(ND_BACKEXP)
        nd_str[cast[uint64](n)] = tok_str[ps_pos]
        pk_advance()
        return n
    if k == TK_WORD:
        # true / false keywords, else a bare identifier (variable
        # reference in expression position, or a function call).
        if pk_word_is("true") != 0:
            pk_advance()
            return nd_new(ND_TRUE)
        if pk_word_is("false") != 0:
            pk_advance()
            return nd_new(ND_FALSE)
        # §11: `ns { }` / `enter NS { }` / `spawn NS { }` are valid in
        # expression position — `sandbox = ns { ... }` captures a
        # namespace template, `svc = spawn s { ... }` yields a process
        # handle. The same parsers used at statement scope produce the
        # node; exec_assign's RHS dispatch (rk == ND_NS / ND_SPAWN /
        # ND_ENTER) turns it into the right value.
        if pk_word_is("ns") != 0:
            return parse_ns()
        if pk_word_is("enter") != 0:
            return parse_enter()
        if pk_word_is("spawn") != 0:
            return parse_spawn()
        # §14: `m = mount $srv /n/r as L` — mount in expression
        # position yields a VT_MOUNT handle. The bare-statement form
        # stays a §15 builtin command (handled by run_builtin).
        if pk_word_is("mount") != 0:
            return parse_mount_expr()
        wref: uint64 = tok_str[ps_pos]
        pk_advance()
        if pk_is_op(OP_LPAREN) != 0:
            # function call
            pk_advance()
            n: int32 = nd_new(ND_CALL)
            # Method-call desugar (#110): the lexer glues `recv.meth` into
            # ONE word, so `recv.meth(args)` arrives as WORD "recv.meth"
            # + '('. When the head is a plain identifier we rewrite it to
            # `meth(recv, args)` — the receiver becomes the implicit first
            # argument. Every receiver-first builtin (upper/find/split/…)
            # and the new items/keys/values/get/append thus gain dotted
            # method syntax for free (`s.upper()`, `d.items()`).
            dotpos: int64 = _word_method_dot(wref)
            if dotpos >= 0:
                sp: Ptr[uint8] = str_ptr(wref)
                rv: int32 = nd_new(ND_VAR)
                nd_str[cast[uint64](rv)] = str_intern_n(sp, cast[uint64](dotpos))
                nd_str[cast[uint64](n)] = str_intern_cstr(
                    cast[Ptr[uint8]](cast[uint64](sp) + cast[uint64](dotpos) + 1))
                nd_kid_push(n, rv)
            else:
                nd_str[cast[uint64](n)] = wref
            kwcount: int64 = 0
            if pk_is_op(OP_RPAREN) == 0:
                while True:
                    # Keyword argument: `name=expr` inside a call. The `=`
                    # is either spaced (OP_ASSIGN) or glued (OP_ASSIGN_LIT,
                    # e.g. `key=len`); `==` is OP_EQEQ and stays a normal
                    # comparison expression. Kwargs collect as ND_KWARG
                    # kids after the positionals (nd_c records the count).
                    if pk_kind() == TK_WORD and ps_pos + 1 < TOK_MAX \
                            and tok_kind[ps_pos + 1] == TK_OP \
                            and (tok_int[ps_pos + 1] == cast[int64](OP_ASSIGN) \
                                 or tok_int[ps_pos + 1] \
                                    == cast[int64](OP_ASSIGN_LIT)):
                        kwname: uint64 = tok_str[ps_pos]
                        pk_advance()                 # consume name
                        pk_advance()                 # consume '='
                        kwval: int32 = parse_expr()
                        kw: int32 = nd_new(ND_KWARG)
                        nd_str[cast[uint64](kw)] = kwname
                        nd_a[cast[uint64](kw)] = kwval
                        nd_kid_push(n, kw)
                        kwcount = kwcount + 1
                    else:
                        arg: int32 = parse_expr()
                        nd_kid_push(n, arg)
                    if pk_is_op(OP_COMMA) != 0:
                        pk_advance()
                        continue
                    break
            nd_c[cast[uint64](n)] = cast[int32](kwcount)
            pk_expect_op(OP_RPAREN, "expected ) in call")
            return n
        # bare identifier as a variable reference in expression position
        n: int32 = nd_new(ND_VAR)
        nd_str[cast[uint64](n)] = wref
        return n
    if pk_is_op(OP_LPAREN) != 0:
        pk_advance()
        e: int32 = parse_expr()
        pk_expect_op(OP_RPAREN, "expected )")
        return e
    if pk_is_op(OP_LBRACKET) != 0:
        pk_advance()
        return parse_list_literal()
    if pk_is_op(OP_LBRACE) != 0:
        pk_advance()
        return parse_dict_literal()
    ps_set_err("expected expression")
    return 0


# --- skip optional NEWLINE separators -------------------------------
def _skip_newlines():
    while pk_kind() == TK_NEWLINE:
        pk_advance()


def _skip_seps():
    # Skip statement separators AND stray indentation tokens. Used at
    # every point that is between statements but NOT the structural
    # boundary of a colon-suite (parse_block's body, parse_program's
    # top level). A brace block whose body is indented emits INDENT
    # after `{` and DEDENT before `}`; swallowing them here lets the two
    # syntaxes mix freely — a colon-suite still consumes its OWN matched
    # INDENT/DEDENT explicitly in parse_colon_suite, so it never loses
    # its terminator to this skip.
    while True:
        k: int32 = pk_kind()
        if k == TK_NEWLINE or k == TK_INDENT or k == TK_DEDENT:
            pk_advance()
            continue
        break


# --- block: '{' statements '}'  OR  ':' indentation-suite -----------
def parse_suite() -> int32:
    # The universal block entry point. Every block-structured construct
    # (if/elif/else, while, for, def, try/except, ns, enter, spawn) calls
    # this where it expects its body. Two fully interchangeable forms:
    #   * brace   — `{ statements }`   (the interactive one-liner form)
    #   * colon   — `: NEWLINE INDENT statements DEDENT`  (Python-style),
    #               or a single-statement inline `: statement`.
    # The form is chosen per-block from the token that opens it, so a
    # script can mix them and either style works in any context.
    if pk_is_op(OP_LBRACE) != 0:
        return parse_block()
    if pk_is_op(OP_COLON) != 0:
        return parse_colon_suite()
    ps_set_err("expected '{' or ':' to open block")
    return 0


def parse_block() -> int32:
    # caller positioned at '{'.
    if pk_expect_op(OP_LBRACE, "expected {") == 0:
        return 0
    n: int32 = nd_new(ND_BLOCK)
    _skip_seps()
    while pk_is_op(OP_RBRACE) == 0 and pk_kind() != TK_EOF:
        if ps_error != 0:
            return n
        st: int32 = parse_statement()
        if st != 0:
            nd_kid_push(n, st)
        _skip_seps()
    pk_expect_op(OP_RBRACE, "expected } to close block")
    return n


def parse_colon_suite() -> int32:
    # caller positioned at the ':' that opens a Python-style suite.
    pk_advance()                              # consume ':'
    n: int32 = nd_new(ND_BLOCK)
    # Inline single-statement suite: `if COND: echo hi`. Anything other
    # than an immediate newline means the body rides on the header line.
    if pk_kind() != TK_NEWLINE:
        st: int32 = parse_statement()
        if st != 0:
            nd_kid_push(n, st)
        return n
    pk_advance()                              # consume the header newline
    # Tolerate blank lines between the header and the indented body.
    while pk_kind() == TK_NEWLINE:
        pk_advance()
    if pk_kind() != TK_INDENT:
        ps_set_err("expected an indented block after ':'")
        return n
    pk_advance()                              # consume the opening INDENT
    while pk_kind() != TK_DEDENT and pk_kind() != TK_EOF:
        if ps_error != 0:
            return n
        if pk_kind() == TK_NEWLINE:
            pk_advance()
            continue
        st: int32 = parse_statement()
        if st != 0:
            nd_kid_push(n, st)
        # Consume the statement's trailing newline(s); the matching
        # DEDENT (or EOF) closes the suite.
        while pk_kind() == TK_NEWLINE:
            pk_advance()
    if pk_kind() == TK_DEDENT:
        pk_advance()                          # consume our matched DEDENT
    return n


# --- command parsing -------------------------------------------------
# A command is a sequence of "word tokens". In command position, bare
# words are LITERAL strings (§2 rule 3). Interpolation reaches the argv
# only through $name / ${ } / `{ }`. Each word becomes one ND child.
# Redirects (> < >> 2> 2>&1) attach to the command.

def _word_token_to_node() -> int32:
    # Convert the current token (must be a command-word token) to an
    # expression node. Advances the cursor. Returns 0 if the current
    # token is not a word.
    k: int32 = pk_kind()
    if k == TK_WORD:
        n: int32 = nd_new(ND_WORD)
        nd_str[cast[uint64](n)] = tok_str[ps_pos]
        pk_advance()
        return n
    if k == TK_STR:
        kind: int32 = ND_STR
        if tok_int[ps_pos] != 0:
            kind = ND_STRI
        n: int32 = nd_new(kind)
        nd_str[cast[uint64](n)] = tok_str[ps_pos]
        pk_advance()
        return n
    if k == TK_INT:
        n: int32 = nd_new(ND_INT)
        nd_i[cast[uint64](n)] = tok_int[ps_pos]
        pk_advance()
        return n
    if k == TK_FLOAT:
        # §Float: in COMMAND-ARGUMENT position a numeric-dotted token is a
        # LITERAL word (§2 rule 3) — its exact source text reaches argv, so
        # `echo 3.14` / `pip install foo==1.10` keep their spelling and a
        # trailing-zero version is not collapsed to a float. Float SEMANTICS
        # apply only in expression position (parse_primary -> ND_FLOAT).
        n: int32 = nd_new(ND_WORD)
        nd_str[cast[uint64](n)] = tok_str[ps_pos]
        pk_advance()
        return n
    if k == TK_FSTR:
        n: int32 = nd_new(ND_FSTR)
        nd_str[cast[uint64](n)] = tok_str[ps_pos]
        pk_advance()
        return n
    if k == TK_DOLLAR:
        n: int32 = nd_new(ND_VAR)
        nd_str[cast[uint64](n)] = tok_str[ps_pos]
        pk_advance()
        return n
    if k == TK_DOLEXPR:
        n: int32 = nd_new(ND_DOLEXPR)
        nd_str[cast[uint64](n)] = tok_str[ps_pos]
        pk_advance()
        return n
    if k == TK_BACKEXP:
        n: int32 = nd_new(ND_BACKEXP)
        nd_str[cast[uint64](n)] = tok_str[ps_pos]
        pk_advance()
        return n
    return 0


def _cmd_word_ahead() -> int32:
    # 1 iff the current token can start/continue a command word.
    k: int32 = pk_kind()
    if k == TK_WORD or k == TK_STR or k == TK_INT or \
            k == TK_FLOAT or k == TK_FSTR or \
            k == TK_DOLLAR or k == TK_DOLEXPR or k == TK_BACKEXP:
        return 1
    return 0


def _glue_adjacent(w: int32) -> int32:
    # QA-N20: fuse tokens GLUED (no whitespace) to the just-parsed word
    # `w` into ONE argv word via ND_ARGCAT — the `$`-adjacency analog of
    # QA-N7 `=`-fusion. Covers `Kpre$s` -> `Kpreworld`, `K$s.txt` ->
    # `Kworld.txt`, `$s$s` -> `worldworld`, `p/$s/q` -> `p/world/q`
    # (chained, on either side). SPACE-separated args stay separate
    # (the next token's glued flag is 0). If nothing is glued, `w` is
    # returned unchanged so single words never wrap in an ARGCAT.
    if pk_glued() == 0 or _cmd_word_ahead() == 0:
        return w
    cat: int32 = w
    if nd_kind[cast[uint64](w)] != ND_ARGCAT:
        cat = nd_new(ND_ARGCAT)
        nd_kid_push(cat, w)
    while pk_glued() != 0 and _cmd_word_ahead() != 0:
        nd_kid_push(cat, _word_token_to_node())
    return cat


def _cmd_dash_arg_ahead() -> int32:
    # §2/§4: in a command statement, an argument beginning with '-' is a
    # LITERAL bare word — `-1`, `-c`, `--help`, a lone `-`. The lexer
    # already glues `-la` / `--all` into one TK_WORD (the "option word"
    # rule), but it deliberately keeps `-` + DIGIT as OP_MINUS + TK_INT
    # so negative literals (`x = -5`) keep working in EXPRESSION context.
    # Command-argument position is not expression context, so here that
    # OP_MINUS (with or without a following integer) is just the start
    # of an option word. 1 iff the cursor is on such an OP_MINUS.
    if pk_is_op(OP_MINUS) != 0:
        return 1
    return 0


def _cmd_dash_arg_to_node() -> int32:
    # Build the literal option-word ND_WORD for an OP_MINUS argument.
    # `-` followed by a TK_INT becomes the word `-<digits>` (so `head
    # -1` yields the argv string "-1"); a lone `-` becomes the word "-"
    # (e.g. `cat -`). Advances past the consumed tokens.
    pk_advance()                              # consume OP_MINUS
    optw: Array[24, uint8]
    optw[0] = 45                              # leading '-'
    wl: uint64 = 1
    if pk_kind() == TK_INT:
        # Render the integer's decimal digits AFTER the literal '-' so
        # the option word is faithful even for `-0` (which negation +
        # render_int would otherwise collapse to "0").
        dp: Ptr[uint8] = render_int(tok_int[ps_pos])
        di: uint64 = 0
        while dp[di] != 0 and wl + 1 < 24:
            optw[wl] = dp[di]
            wl = wl + 1
            di = di + 1
        pk_advance()
    optw[wl] = 0
    n: int32 = nd_new(ND_WORD)
    nd_str[cast[uint64](n)] = str_intern_n(&optw[0], wl)
    return n


def _parse_arg_assign_word(lhs: int32) -> int32:
    # ARGUMENT-position glued `=` (OP_ASSIGN_LIT): NOT an assignment.
    # `arg=value` is ONE literal command word. Build an ND_ARGCAT whose
    # kids render+concatenate into a single argv element. Handles a
    # chained `a=b=c`, an empty RHS (`arg=` yields the word `arg=`), and
    # `$VAR` expansion / quotes in the RHS (via _word_token_to_node).
    cat: int32 = nd_new(ND_ARGCAT)
    nd_kid_push(cat, lhs)
    while pk_is_op(OP_ASSIGN_LIT) != 0:
        pk_advance()                          # consume the literal '='
        eqc: Array[2, uint8]
        eqc[0] = 61                           # '='
        eqc[1] = 0
        eq: int32 = nd_new(ND_STR)
        nd_str[cast[uint64](eq)] = str_intern_n(&eqc[0], 1)
        nd_kid_push(cat, eq)
        if _cmd_word_ahead() != 0:
            nd_kid_push(cat, _word_token_to_node())
        # empty RHS (`arg=` at a separator): push nothing — the concat
        # is just `arg=`.
    return cat


def parse_simple_command() -> int32:
    # One pipeline stage: cmd word*, plus redirect annotations. The
    # redirect targets are stored on the ND_CMD: nd_a = stdout target
    # node (> / >>), nd_b = stdin target node (<), nd_c flags. We keep
    # it simple — at most one of each.
    n: int32 = nd_new(ND_CMD)
    nd_c[cast[uint64](n)] = 0      # bit0: append, bit1: 2>&1, bit2: bg
    got: int32 = 0
    while True:
        if _cmd_word_ahead() != 0:
            w: int32 = _word_token_to_node()
            # POSIX: a glued `=` (OP_ASSIGN_LIT) in ARGUMENT position
            # (we already have the command word, got != 0) is a LITERAL
            # char, not an assignment — `echo a=b` prints `a=b`, `make
            # FOO=bar` passes the argv word `FOO=bar`. Only a
            # STATEMENT-LEADING `VAR=value` is an assignment (caught by
            # _looks_like_assignment before we ever reach here). Fuse
            # `word=rhs` into one argv word ($vars in the rhs still
            # expand, quotes honored).
            if got != 0 and pk_is_op(OP_ASSIGN_LIT) != 0:
                w = _parse_arg_assign_word(w)
            # QA-N20: fuse a `$var`/word run GLUED to `w` (no whitespace)
            # into one argv word (`Kpre$s`, `$s.txt`, `$s$s`, `p/$s/q`).
            w = _glue_adjacent(w)
            nd_kid_push(n, w)
            got = 1
            continue
        # An argument starting with '-' (`-1`, `-c`, a lone `-`) is a
        # literal option word once we already have the command word.
        # Guarded by `got` so a statement that genuinely opens with a
        # bare operator still flags cleanly rather than being misread
        # as a command name.
        if got != 0 and _cmd_dash_arg_ahead() != 0:
            w: int32 = _cmd_dash_arg_to_node()
            nd_kid_push(n, w)
            continue
        if pk_is_op(OP_GT) != 0:
            pk_advance()
            tgt: int32 = _word_token_to_node()
            nd_a[cast[uint64](n)] = tgt
            continue
        if pk_is_op(OP_DGT) != 0:
            pk_advance()
            tgt: int32 = _word_token_to_node()
            nd_a[cast[uint64](n)] = tgt
            nd_c[cast[uint64](n)] = nd_c[cast[uint64](n)] | 1
            continue
        if pk_is_op(OP_LT) != 0:
            pk_advance()
            tgt: int32 = _word_token_to_node()
            nd_b[cast[uint64](n)] = tgt
            continue
        if pk_is_op(OP_DUP21) != 0:
            pk_advance()
            nd_c[cast[uint64](n)] = nd_c[cast[uint64](n)] | 2
            continue
        if pk_is_op(OP_REDIR2) != 0:
            pk_advance()
            # 2> file — store stderr target in nd_i (a node ref)
            tgt: int32 = _word_token_to_node()
            nd_i[cast[uint64](n)] = cast[int64](tgt)
            continue
        if pk_is_op(OP_AMP) != 0:
            pk_advance()
            nd_c[cast[uint64](n)] = nd_c[cast[uint64](n)] | 4
            continue
        break
    if got == 0:
        ps_set_err("empty command")
    return n


def parse_pipeline() -> int32:
    # cmd ( '|' cmd )*  — if there is only one stage, returns the
    # bare ND_CMD; else wraps the stages in an ND_PIPELINE.
    first: int32 = parse_simple_command()
    if pk_is_op(OP_PIPE) == 0:
        return first
    pl: int32 = nd_new(ND_PIPELINE)
    nd_kid_push(pl, first)
    while pk_is_op(OP_PIPE) != 0:
        pk_advance()
        st: int32 = parse_simple_command()
        nd_kid_push(pl, st)
        if nd_kn[cast[uint64](pl)] > PIPE_STAGE_MAX:
            ps_set_err("too many pipeline stages")
            return pl
    return pl


# --- the §2 statement dispatch --------------------------------------

def parse_if() -> int32:
    pk_advance()                         # consume 'if' / 'elif'
    cond: int32 = parse_expr()
    thenb: int32 = parse_suite()
    n: int32 = nd_new(ND_IF)
    nd_a[cast[uint64](n)] = cond
    nd_b[cast[uint64](n)] = thenb
    # else / elif chain. A colon-suite has already consumed its matched
    # DEDENT, positioning us right on the `elif`/`else` keyword (which
    # aligns with the `if`, so there is no net DEDENT to cross); a brace
    # suite leaves only a NEWLINE. So skip NEWLINEs ONLY — never a DEDENT,
    # which would belong to an ENCLOSING suite and must not be eaten here.
    _skip_newlines()
    if pk_word_is("elif") != 0:
        nd_c[cast[uint64](n)] = parse_if()         # recurse
    elif pk_word_is("else") != 0:
        pk_advance()
        nd_c[cast[uint64](n)] = parse_suite()
    return n


def parse_while() -> int32:
    pk_advance()
    cond: int32 = parse_expr()
    body: int32 = parse_suite()
    n: int32 = nd_new(ND_WHILE)
    nd_a[cast[uint64](n)] = cond
    nd_b[cast[uint64](n)] = body
    return n


def parse_for() -> int32:
    # `for VAR in ITEM... { BODY }` — the universal shell idiom (QA-N18).
    # ITEM... is ONE OR MORE words collected with the SAME word machinery
    # as command arguments (so `$var`/globs/`text$var` fusion behave
    # exactly as in `echo ...` — QA-N7/N16/N20), terminated by the opening
    # `{`. Each item is stored as a WORD kid on the ND_FOR node; exec_for
    # expands them (glob + list-flatten) into the iteration sequence:
    #   for x in a b c { }   -> 3 iterations (x=a, x=b, x=c)
    #   for f in solo   { }   -> 1 iteration  (f=solo)
    #   for y in $xs two { }  -> $xs's words, then `two`
    pk_advance()                         # 'for'
    if pk_kind() != TK_WORD:
        ps_set_err("expected loop variable")
        return 0
    var: uint64 = tok_str[ps_pos]
    pk_advance()
    n: int32 = nd_new(ND_FOR)
    nd_str[cast[uint64](n)] = var
    # EXPRESSION-ITERABLE / TUPLE-UNPACK mode (#110). Two triggers:
    #   * a comma after the first target — `for k, v in EXPR` — always
    #     iterates an EXPRESSION yielding pairs/tuples, unpacking each.
    #   * a single target whose iterable is UNAMBIGUOUSLY an expression:
    #     a `[` list-literal / comprehension, or a `WORD(` call
    #     (`range(4)`, `enumerate(xs)`, `d.items()`). Everything else
    #     keeps the shell word-list behaviour (`for i in a b`,
    #     `for x in $xs`, globs) — the SHELL SOUL is preserved.
    # nd_c: 0 = shell word-list mode, 1 = expression mode. In expr mode
    # the target names are ND_STR kids and nd_a is the iterable expr.
    if pk_is_op(OP_COMMA) != 0:
        # tuple targets — collect the rest (first already consumed).
        t0: int32 = nd_new(ND_STR)
        nd_str[cast[uint64](t0)] = var
        nd_kid_push(n, t0)
        while pk_is_op(OP_COMMA) != 0:
            pk_advance()
            if pk_kind() != TK_WORD:
                ps_set_err("expected loop variable")
                return n
            tk: int32 = nd_new(ND_STR)
            nd_str[cast[uint64](tk)] = tok_str[ps_pos]
            nd_kid_push(n, tk)
            pk_advance()
        if pk_word_is("in") == 0:
            ps_set_err("expected 'in'")
            return n
        pk_advance()
        nd_c[cast[uint64](n)] = 1
        nd_a[cast[uint64](n)] = parse_expr()
        nd_b[cast[uint64](n)] = parse_suite()
        return n
    if pk_word_is("in") == 0:
        ps_set_err("expected 'in'")
        return n
    pk_advance()
    # single-target expression iterable? `[` or a bare `WORD(` call.
    if pk_is_op(OP_LBRACKET) != 0 or \
            (pk_kind() == TK_WORD and ps_pos + 1 < TOK_MAX \
             and tok_kind[ps_pos + 1] == TK_OP \
             and tok_int[ps_pos + 1] == cast[int64](OP_LPAREN)):
        t0s: int32 = nd_new(ND_STR)
        nd_str[cast[uint64](t0s)] = var
        nd_kid_push(n, t0s)
        nd_c[cast[uint64](n)] = 1
        nd_a[cast[uint64](n)] = parse_expr()
        nd_b[cast[uint64](n)] = parse_suite()
        return n
    # Collect the item words until the block opener (`{` or `:`). Mirrors
    # the argument loop in parse_simple_command so word fusion / `-`-option
    # words match.
    while pk_is_op(OP_LBRACE) == 0 and pk_is_op(OP_COLON) == 0:
        if _cmd_word_ahead() != 0:
            w: int32 = _word_token_to_node()
            if pk_is_op(OP_ASSIGN_LIT) != 0:
                w = _parse_arg_assign_word(w)
            w = _glue_adjacent(w)
            nd_kid_push(n, w)
            continue
        if _cmd_dash_arg_ahead() != 0:
            w: int32 = _cmd_dash_arg_to_node()
            nd_kid_push(n, w)
            continue
        # not a word and not a block opener — malformed for-list
        ps_set_err("expected loop item, '{' or ':'")
        return n
    nd_b[cast[uint64](n)] = parse_suite()
    return n


def parse_def() -> int32:
    pk_advance()                         # 'def'
    if pk_kind() != TK_WORD:
        ps_set_err("expected function name")
        return 0
    name: uint64 = tok_str[ps_pos]
    pk_advance()
    n: int32 = nd_new(ND_DEF)
    nd_str[cast[uint64](n)] = name
    pk_expect_op(OP_LPAREN, "expected ( after def name")
    if pk_is_op(OP_RPAREN) == 0:
        while True:
            if pk_kind() != TK_WORD:
                ps_set_err("expected parameter name")
                break
            p: int32 = nd_new(ND_STR)
            nd_str[cast[uint64](p)] = tok_str[ps_pos]
            nd_kid_push(n, p)
            pk_advance()
            if pk_is_op(OP_COMMA) != 0:
                pk_advance()
                continue
            break
    pk_expect_op(OP_RPAREN, "expected ) after params")
    nd_b[cast[uint64](n)] = parse_suite()
    return n


def parse_try() -> int32:
    # §Exceptions: `try SUITE [except [as NAME] SUITE] [finally SUITE]`.
    # nd_a = try body; nd_b = except body (0 = none); nd_c = finally body
    # (0 = none); nd_str = `except as NAME` binding (0 = none). At least
    # one of except / finally must be present (as in Python).
    pk_advance()                         # 'try'
    tb: int32 = parse_suite()
    n: int32 = nd_new(ND_TRY)
    nu: uint64 = cast[uint64](n)
    nd_a[nu] = tb
    _skip_newlines()
    has_handler: int32 = 0
    if pk_word_is("except") != 0:
        pk_advance()
        # optional `as NAME` — bind the raised value in the handler.
        if pk_word_is("as") != 0:
            pk_advance()
            if pk_kind() == TK_WORD:
                nd_str[nu] = tok_str[ps_pos]
                pk_advance()
        nd_b[nu] = parse_suite()
        has_handler = 1
        _skip_newlines()
    if pk_word_is("finally") != 0:
        pk_advance()
        nd_c[nu] = parse_suite()
        has_handler = 1
    if has_handler == 0:
        ps_set_err("expected 'except' or 'finally' after try")
    return n


def parse_with() -> int32:
    # §19 (#111): `with CM(args) as NAME: body` — a Python-style context
    # manager married to Plan 9 binds. Three known context managers:
    #   with bind(SRC, DST) [as N]:   bind SRC onto DST on entry, UNBIND
    #                                 DST on exit (even on error).
    #   with mount(SRC, PATH) [as N]: mount on entry, unmount on exit.
    #   with enter(NS) [as N]:        run body in a scoped subshell whose
    #                                 private namespace evaporates on exit.
    # bind/mount arguments are parsed in COMMAND-WORD position (like the
    # `mount … as L` expression) so a bare path `/n/linux` is a LITERAL
    # string, never a division / variable-ref. `enter`'s single argument
    # is an EXPRESSION (a `$var` / bare name resolving to a VT_NS value).
    pk_advance()                         # 'with'
    n: int32 = nd_new(ND_WITH)
    nu: uint64 = cast[uint64](n)
    wk: int64 = 0
    if pk_word_is("bind") != 0:
        wk = WITH_BIND
    elif pk_word_is("mount") != 0:
        wk = WITH_MOUNT
    elif pk_word_is("enter") != 0:
        wk = WITH_ENTER
    else:
        ps_set_err("with: expected bind/mount/enter context manager")
        return n
    nd_i[nu] = wk
    pk_advance()                         # consume the context-manager verb
    if pk_expect_op(OP_LPAREN, "with: expected '(' after context manager") == 0:
        return n
    if wk == WITH_ENTER:
        nd_a[nu] = parse_expr()          # the namespace value expression
    else:
        nd_a[nu] = _word_token_to_node()  # SRC (command word)
        if pk_expect_op(OP_COMMA, "with bind/mount: expected two arguments") == 0:
            return n
        nd_b[nu] = _word_token_to_node()  # DST / PATH (command word)
    pk_expect_op(OP_RPAREN, "with: expected ')' to close arguments")
    # optional `as NAME`
    if pk_word_is("as") != 0:
        pk_advance()
        if pk_kind() == TK_WORD:
            nd_str[nu] = tok_str[ps_pos]
            pk_advance()
    nd_c[nu] = parse_suite()
    return n


def parse_ns() -> int32:
    pk_advance()                         # 'ns'
    clean: int64 = 0
    if pk_word_is("clean") != 0:
        clean = 1
        pk_advance()
    n: int32 = nd_new(ND_NS)
    nd_i[cast[uint64](n)] = clean
    nd_b[cast[uint64](n)] = parse_suite()
    return n


def parse_enter() -> int32:
    pk_advance()                         # 'enter'
    clean: int64 = 0
    if pk_word_is("clean") != 0:
        clean = 1
        pk_advance()
    nsexpr: int32 = parse_postfix()      # the namespace value
    n: int32 = nd_new(ND_ENTER)
    nd_i[cast[uint64](n)] = clean
    nd_a[cast[uint64](n)] = nsexpr
    nd_b[cast[uint64](n)] = parse_suite()
    return n


def parse_spawn() -> int32:
    pk_advance()                         # 'spawn'
    detached: int64 = 0
    if pk_word_is("detached") != 0:
        detached = 1
        pk_advance()
    nsexpr: int32 = parse_postfix()
    n: int32 = nd_new(ND_SPAWN)
    nd_i[cast[uint64](n)] = detached
    nd_a[cast[uint64](n)] = nsexpr
    nd_b[cast[uint64](n)] = parse_suite()
    return n


def parse_mount_expr() -> int32:
    # §14 mount as an EXPRESSION: `m = mount [-b|-a] SRC PATH [as L]`.
    # Yields a VT_MOUNT handle. The bare-statement form `mount …` is a
    # command (the §15 builtin); this is the value-producing form used
    # on an assignment RHS.
    #
    # SRC and PATH are parsed in COMMAND-WORD position, not as
    # expressions: a bare word like `/srv/foo` or `/n/r` is a LITERAL
    # string (§2/§4), exactly as for the `mount` builtin command.
    # `$var` / `${ expr }` interpolation still reach the argument the
    # normal way. (Parsing them as expressions would mis-read the bare
    # word `/srv/foo` as a *variable reference* — the bug §2 forbids.)
    pk_advance()                         # 'mount'
    flag: int64 = 0                      # MREPL
    # optional union flag: `-b` / `-a` now lex as a single word.
    if pk_kind() == TK_WORD and _word_is(ps_pos, "-b") != 0:
        flag = 1
        pk_advance()
    elif pk_kind() == TK_WORD and _word_is(ps_pos, "-a") != 0:
        flag = 2
        pk_advance()
    srvfd: int32 = _word_token_to_node()
    path: int32 = _word_token_to_node()
    n: int32 = nd_new(ND_MOUNT)
    nd_a[cast[uint64](n)] = srvfd
    nd_b[cast[uint64](n)] = path
    nd_i[cast[uint64](n)] = flag
    nd_str[cast[uint64](n)] = 0          # 0 = no inline label
    # optional `as LABEL` — LABEL is a bare word.
    if pk_word_is("as") != 0:
        pk_advance()
        if pk_kind() == TK_WORD:
            nd_str[cast[uint64](n)] = tok_str[ps_pos]
            pk_advance()
    return n


def _looks_like_assignment() -> int32:
    # §2 rule 2: IDENT ( = | += | -= ) ... — peek two tokens ahead
    # WITHOUT consuming. The first token must be a plain identifier
    # word; the second must be an assignment operator.
    if tok_kind[ps_pos] != TK_WORD:
        return 0
    nx: uint64 = ps_pos + 1
    if nx >= TOK_MAX:
        return 0
    if tok_kind[nx] != TK_OP:
        return 0
    op: int64 = tok_int[nx]
    if op == cast[int64](OP_ASSIGN):
        return 1
    if op == cast[int64](OP_ASSIGN_LIT):
        return 1
    if op == cast[int64](OP_PLUSEQ):
        return 1
    if op == cast[int64](OP_MINUSEQ):
        return 1
    return 0


def _parse_assign_rhs_literal() -> int32:
    # RHS of a POSIX `VAR=value` assignment (glued `=`, OP_ASSIGN_LIT):
    # the value is a COMMAND WORD, exactly as an argv word — NOT an
    # arithmetic expression. So `/`, `:`, `.` are literal (a path like
    # `/home/live` is the string, never a division), `'...'` is a
    # literal string, `"..."` still interpolates `$vars`, and `$VAR`
    # expands. An empty RHS (`VAR=` at end-of-statement) yields "".
    if _cmd_word_ahead() != 0:
        return _word_token_to_node()
    n: int32 = nd_new(ND_STR)
    nd_str[cast[uint64](n)] = 0          # 0 == interned ""
    return n


def parse_assignment() -> int32:
    name: uint64 = tok_str[ps_pos]
    pk_advance()
    op: int32 = cast[int32](tok_int[ps_pos])
    pk_advance()
    rhs: int32 = 0
    if op == OP_ASSIGN_LIT:
        # POSIX `VAR=value` — literal-word RHS (§2, no arithmetic).
        rhs = _parse_assign_rhs_literal()
    else:
        # spaced `=` / `+=` / `-=` — arithmetic-capable expression RHS.
        rhs = parse_expr()
    n: int32 = nd_new(ND_ASSIGN)
    nd_str[cast[uint64](n)] = name
    nd_i[cast[uint64](n)] = cast[int64](op)
    nd_a[cast[uint64](n)] = rhs
    nd_c[cast[uint64](n)] = 0            # export flag (set by `export VAR=…`)
    return n


def parse_expr_list() -> int32:
    # One expression, or a comma-separated tuple of them. A lone
    # expression returns its node unchanged; two-or-more wrap in an
    # ND_TUPLE (evaluates to a VT_LIST). Used for the RHS of a tuple
    # assignment and for multiple `return a, b`.
    first: int32 = parse_expr()
    if pk_is_op(OP_COMMA) == 0:
        return first
    n: int32 = nd_new(ND_TUPLE)
    nd_kid_push(n, first)
    while pk_is_op(OP_COMMA) != 0:
        pk_advance()
        # tolerate a trailing comma at a statement terminator
        lk: int32 = pk_kind()
        if lk == TK_NEWLINE or lk == TK_EOF or pk_is_op(OP_RBRACE) != 0:
            break
        nd_kid_push(n, parse_expr())
    return n


def _looks_like_tuple_assign() -> int32:
    # `NAME , NAME (, NAME)* =` — a destructuring assignment. Requires at
    # least one comma before a spaced `=` (OP_ASSIGN); a glued
    # OP_ASSIGN_LIT (`a=b`) is a command word, never this. Peeks WITHOUT
    # consuming.
    if tok_kind[ps_pos] != TK_WORD:
        return 0
    i: uint64 = ps_pos + 1
    saw_comma: int32 = 0
    while i < TOK_MAX:
        if tok_kind[i] == TK_OP and tok_int[i] == cast[int64](OP_COMMA):
            saw_comma = 1
            i = i + 1
            if i >= TOK_MAX or tok_kind[i] != TK_WORD:
                return 0
            i = i + 1
            continue
        if tok_kind[i] == TK_OP and tok_int[i] == cast[int64](OP_ASSIGN):
            return saw_comma
        return 0
    return 0


def parse_tuple_assign() -> int32:
    n: int32 = nd_new(ND_TUPLEASSIGN)
    while True:
        t: int32 = nd_new(ND_STR)
        nd_str[cast[uint64](t)] = tok_str[ps_pos]
        nd_kid_push(n, t)
        pk_advance()
        if pk_is_op(OP_COMMA) != 0:
            pk_advance()
            continue
        break
    pk_expect_op(OP_ASSIGN, "expected = in tuple assignment")
    nd_a[cast[uint64](n)] = parse_expr_list()
    return n


def _looks_like_index_assign() -> int32:
    # `NAME [ ... ] =` — an index/key assignment target. Scan from the
    # `[` to its MATCHING `]` (brackets nest: `xs[a[0]] = v`), then
    # require a spaced `=` (OP_ASSIGN) right after. Peeks; consumes
    # nothing. A glued `xs[i]=v` still lexes `=` as OP_ASSIGN because the
    # char before it is `]` (not a word char), so both spacings match.
    if tok_kind[ps_pos] != TK_WORD:
        return 0
    if ps_pos + 1 >= TOK_MAX:
        return 0
    if tok_kind[ps_pos + 1] != TK_OP \
            or tok_int[ps_pos + 1] != cast[int64](OP_LBRACKET):
        return 0
    depth: int64 = 0
    i: uint64 = ps_pos + 1
    while i < TOK_MAX:
        if tok_kind[i] == TK_NEWLINE or tok_kind[i] == TK_EOF:
            return 0
        if tok_kind[i] == TK_OP:
            if tok_int[i] == cast[int64](OP_LBRACKET):
                depth = depth + 1
            elif tok_int[i] == cast[int64](OP_RBRACKET):
                depth = depth - 1
                if depth == 0:
                    j: uint64 = i + 1
                    if j < TOK_MAX and tok_kind[j] == TK_OP \
                            and tok_int[j] == cast[int64](OP_ASSIGN):
                        return 1
                    return 0
        i = i + 1
    return 0


def parse_index_assign() -> int32:
    # Parse `TARGET[idx] = expr`. parse_postfix yields the ND_INDEX
    # (base + index/slice); we then take the `=` and the RHS expression.
    target: int32 = parse_postfix()
    pk_expect_op(OP_ASSIGN, "expected = in index assignment")
    rhs: int32 = parse_expr()
    n: int32 = nd_new(ND_INDEXASSIGN)
    nd_a[cast[uint64](n)] = target
    nd_b[cast[uint64](n)] = rhs
    return n


def parse_statement() -> int32:
    # Depth-guarded entry. Blocks nest one parse_statement frame per
    # `{`, so an adversarial `{ { { ... } } }` would recurse the C
    # stack without bound — the guard turns that into a clean parse
    # error well before a stack fault.
    if ps_depth >= PS_DEPTH_MAX:
        ps_set_err("statement nested too deep")
        return 0
    ps_depth = ps_depth + 1
    r: int32 = _parse_statement_body()
    ps_depth = ps_depth - 1
    return r


def _parse_chain_operand() -> int32:
    # One operand of a `&&` / `||` chain. Almost always a pipeline, but
    # the namespace verbs `ns` / `enter` / `spawn` are ALSO valid chain
    # operands: HAMSH_SPEC §11 shows `enter sandbox { apt update } &&
    # echo done`. Each yields an exit status (exec_enter / exec_ns set
    # eval_status; exec_spawn sets it to 0 on a clean handle) so they
    # slot into the §2 status-driven chain like any other command.
    if pk_kind() == TK_WORD:
        if pk_word_is("ns") != 0:
            return parse_ns()
        if pk_word_is("enter") != 0:
            return parse_enter()
        if pk_word_is("spawn") != 0:
            return parse_spawn()
    return parse_pipeline()


def _parse_statement_body() -> int32:
    # The load-bearing §2 dispatch. Decided DETERMINISTICALLY from the
    # first token — never by a heuristic.
    _skip_newlines()
    k: int32 = pk_kind()
    if k == TK_EOF:
        return 0
    # 1. control construct — first token a statement keyword.
    #
    # `ns` / `enter` / `spawn` are statement keywords, but unlike
    # `if` / `while` / `for` they ALSO compose into `&&` / `||` chains
    # (HAMSH_SPEC §11: `enter sandbox { apt update } && echo done`).
    # So they are NOT returned straight from the keyword dispatch — they
    # fall through to the shared chain loop in step 3 via
    # _parse_chain_operand(). The block-structured constructs below
    # (`if` etc.) genuinely end the statement and return directly.
    if k == TK_WORD:
        if pk_word_is("if") != 0:
            return parse_if()
        if pk_word_is("while") != 0:
            return parse_while()
        if pk_word_is("for") != 0:
            return parse_for()
        if pk_word_is("def") != 0:
            return parse_def()
        if pk_word_is("try") != 0:
            return parse_try()
        if pk_word_is("with") != 0:
            return parse_with()
        if pk_word_is("return") != 0:
            pk_advance()
            n: int32 = nd_new(ND_RETURN)
            if pk_kind() != TK_NEWLINE and pk_kind() != TK_EOF and \
                    pk_is_op(OP_RBRACE) == 0:
                nd_a[cast[uint64](n)] = parse_expr_list()
            return n
        if pk_word_is("break") != 0:
            pk_advance()
            return nd_new(ND_BREAK)
        if pk_word_is("continue") != 0:
            pk_advance()
            return nd_new(ND_CONTINUE)
        if pk_word_is("raise") != 0:
            pk_advance()
            rn: int32 = nd_new(ND_RAISE)
            if pk_kind() != TK_NEWLINE and pk_kind() != TK_EOF and \
                    pk_is_op(OP_RBRACE) == 0:
                nd_a[cast[uint64](rn)] = parse_expr()
            return rn
        # `export VAR=value` — assign AND export in one statement. Only
        # when a `NAME <assign-op>` follows `export`; bare `export VAR`
        # (export an already-set var) still flows to the §15 builtin.
        if pk_word_is("export") != 0 and ps_pos + 2 < TOK_MAX \
                and tok_kind[ps_pos + 1] == TK_WORD \
                and tok_kind[ps_pos + 2] == TK_OP:
            eop: int64 = tok_int[ps_pos + 2]
            if eop == cast[int64](OP_ASSIGN) \
                    or eop == cast[int64](OP_ASSIGN_LIT) \
                    or eop == cast[int64](OP_PLUSEQ) \
                    or eop == cast[int64](OP_MINUSEQ):
                pk_advance()                     # consume 'export'
                an: int32 = parse_assignment()
                nd_c[cast[uint64](an)] = 1       # also export
                return an
    # 2. assignment (scalar, then tuple destructuring `a, b = ...`).
    if _looks_like_assignment() != 0:
        return parse_assignment()
    if _looks_like_index_assign() != 0:
        return parse_index_assign()
    if _looks_like_tuple_assign() != 0:
        return parse_tuple_assign()
    # 2b. a bare function call as a statement — `name(args)`. A `def`'d
    # function must be callable on its own line (an rc/init script
    # calls helper functions for effect); `name(` glued is unambiguous
    # — it is not an assignment and never a real command (command
    # words don't carry a glued `(`). This parses the whole call
    # expression so trailing `)` cannot leak into the next statement.
    if k == TK_WORD and ps_pos + 1 < TOK_MAX \
            and tok_kind[ps_pos + 1] == TK_OP \
            and tok_int[ps_pos + 1] == cast[int64](OP_LPAREN):
        es: int32 = nd_new(ND_EXPRSTMT)
        nd_a[cast[uint64](es)] = parse_expr()
        return es
    # 2c. a bare brace block — `{ stmt ; stmt ; ... }` (QA-N27). A
    #     statement-LEADING `{` opens a compound block: every
    #     `;`/newline-separated statement inside runs in order, in the
    #     CURRENT scope (no fork, unlike `ns {}`). parse_block already
    #     drives the statement-list loop and consumes the closing `}`,
    #     and exec_statement dispatches ND_BLOCK -> exec_block, so all
    #     statements including the LAST one run. Without this branch a
    #     leading `{` fell through to the command path and died with a
    #     spurious "empty command" (a `{` is not a command word). Note:
    #     a `{ ... }` in EXPRESSION position (an assignment RHS / arg)
    #     is still a dict literal — that path is parse_primary, reached
    #     only after `_looks_like_assignment` / expression context, so
    #     this statement-leading rule never shadows it.
    if pk_is_op(OP_LBRACE) != 0:
        return parse_block()
    # 3. command (with && / || / pipeline chaining). _parse_chain_operand
    #    handles the §11 namespace verbs (`ns` / `enter` / `spawn`) too,
    #    so `enter s { ... } && echo done` and `ns { ... } || recover`
    #    chain exactly like plain commands.
    lhs: int32 = _parse_chain_operand()
    while pk_is_op(OP_AND) != 0 or pk_is_op(OP_OR) != 0:
        chain: int32 = ND_AND
        if pk_is_op(OP_OR) != 0:
            chain = ND_OR
        pk_advance()
        rhs: int32 = _parse_chain_operand()
        n: int32 = nd_new(chain)
        nd_a[cast[uint64](n)] = lhs
        nd_b[cast[uint64](n)] = rhs
        lhs = n
    # A well-formed statement ends at a separator: TK_NEWLINE (the
    # lexer emits it for both '\n' and ';'), TK_EOF, or a '}' closing
    # the enclosing block. Anything else left at the cursor — a stray
    # ')' / ']', a bare operator — is a malformed statement. Flag it
    # HERE with a clean message rather than letting the leftover token
    # cascade into a spurious "empty command" on the next statement.
    if ps_error == 0:
        lk: int32 = pk_kind()
        if lk != TK_NEWLINE and lk != TK_EOF \
                and pk_is_op(OP_RBRACE) == 0:
            ps_set_err("unexpected token after command")
    return lhs


def parse_program() -> int32:
    # Parse the whole token stream as a sequence of statements.
    ps_pos = 0
    ps_error = 0
    ps_errmsg[0] = 0
    ps_depth = 0
    n: int32 = nd_new(ND_BLOCK)
    _skip_seps()
    while pk_kind() != TK_EOF:
        if ps_error != 0:
            break
        st: int32 = parse_statement()
        if st != 0:
            nd_kid_push(n, st)
        _skip_seps()
    return n


def parser_reset():
    nd_count = 1
    nd_kid_cursor = 1          # slot 0 reserved as the list terminator


# ====================================================================
# Value system — dynamically typed hamsh values
# ====================================================================
# A value cell carries a type tag and a payload. Strings live in the
# string arena (a str ref). Lists and dicts reference a span in the
# shared element pool (val_elem[]), each entry a value-cell index.
#
# Values are NOT garbage-collected. Per command line the value arena
# is reset wholesale (val_reset) — a hamsh statement is short-lived.

VT_NIL:    int32 = 0
VT_INT:    int32 = 1
VT_BOOL:   int32 = 2
VT_STR:    int32 = 3      # payload = str ref
VT_LIST:   int32 = 4      # elem_start/elem_count into val_elem
VT_DICT:   int32 = 5      # elem span: alternating key,val cell ids
VT_NS:     int32 = 6      # namespace template handle (see §11);
                          # val_pay = captured body node, val_aux =
                          # clean flag (1 = `ns clean { }` → enter
                          # uses RFCNAMEG hermetic base, 0 = default
                          # overlay onto the caller's ambient ns)
VT_PROC:   int32 = 7      # process handle (pid in payload)
VT_MOUNT:  int32 = 8      # mount handle (see §14)
VT_FLOAT:  int32 = 9      # IEEE-754 double; payload in val_f (§Float)

val_type:  Array[16384, int32]
val_pay:   Array[16384, int64]    # int / bool / str ref / pid / nsid
# §Float: a SECOND, float-typed payload column, indexed by cell id like
# val_pay. VT_FLOAT stores its IEEE-754 double here (val_pay unused).
# A parallel column — rather than bit-punning val_pay — keeps float
# handling exact and sidesteps any int<->float reinterpret-cast idiom.
val_f:     Array[16384, float64]
# val_aux is a SECOND payload word per cell. VT_MOUNT uses it for the
# bound-path str ref (val_pay holds the namespace-identity tag, §13).
# val_es / val_ec / val_aux are all indexed by cell id, so they MUST
# be VAL_MAX-sized — a 1024-slot array let v_new write past the end
# the moment the session created its 1025th value cell.
val_aux:   Array[16384, int64]
val_es:    Array[16384, uint64]  # elem_start (list/dict)
val_ec:    Array[16384, uint64]  # elem_count
val_count: uint64 = 1            # cell 0 reserved = nil

val_elem:  Array[16384, int32]    # value-cell indices
val_elem_cursor: uint64 = 0

# §17 (#110): a deferred collection stack for building list/dict values
# whose elements are themselves computed by evaluation that may push into
# the SHARED val_elem pool (nested list literals, comprehension bodies,
# enumerate/zip pairs). Collecting cell ids here — NOT into val_elem —
# and building the final list/dict contiguously at the very end sidesteps
# the "elements must be pushed contiguously" invariant that a naive
# element-by-element push into val_elem would violate. Used as a stack:
# each nested build records its base cursor, appends above it, then pops
# back after materialising its result.
COMP_MAX:   uint64 = 4096
comp_out:   Array[4096, int32]   # collected element / list cell ids
comp_out_n: uint64 = 0
comp_key:   Array[4096, int32]   # dict-comprehension key cell ids
comp_val:   Array[4096, int32]   # dict-comprehension value cell ids
comp_dn:    uint64 = 0


def val_reset():
    val_count = 1
    val_elem_cursor = 0
    val_type[0] = VT_NIL


def v_new(t: int32) -> int32:
    if val_count >= VAL_MAX:
        return 0
    n: uint64 = val_count
    val_count = val_count + 1
    val_type[n] = t
    val_pay[n]  = 0
    val_aux[n]  = 0
    val_es[n]   = 0
    val_ec[n]   = 0
    val_f[n]    = 0.0
    return cast[int32](n)


def v_int(x: int64) -> int32:
    n: int32 = v_new(VT_INT)
    val_pay[cast[uint64](n)] = x
    return n


# §Float: allocate a VT_FLOAT cell holding the double `x`.
def v_float(x: float64) -> int32:
    n: int32 = v_new(VT_FLOAT)
    val_f[cast[uint64](n)] = x
    return n


# --- float helpers (adapted from lib/jsengine.ad's exact-bits math) --
def _f_trunc(x: float64) -> float64:
    # truncate toward zero; exact for |x| < 9e18
    if x != x:
        return x
    if x < 0.0:
        i: int64 = cast[int64](0.0 - x)
        return 0.0 - cast[float64](i)
    i2: int64 = cast[int64](x)
    return cast[float64](i2)


def _f_floor(x: float64) -> float64:
    t: float64 = _f_trunc(x)
    if t > x:
        return t - 1.0
    return t


def _f_abs(x: float64) -> float64:
    if x < 0.0:
        return 0.0 - x
    return x


def _f_fmod(a: float64, b: float64) -> float64:
    if b == 0.0:
        return 0.0
    q: float64 = _f_trunc(a / b)
    return a - q * b


def _f_is_nan(x: float64) -> int32:
    if x != x:
        return 1
    return 0


def _f_is_inf(x: float64) -> int32:
    if x > 1.0e308:
        return 1
    if x < -1.0e308:
        return 1
    return 0


# Parse a float literal / numeric string (the source slice `sref`) to a
# double. Handles sign, integer part, fraction, and an e/E exponent.
def _parse_float_str(sref: uint64) -> float64:
    p: Ptr[uint8] = str_ptr(sref)
    n: uint64 = str_len(sref)
    i: uint64 = 0
    sign: float64 = 1.0
    if i < n and p[i] == 43:
        i = i + 1
    elif i < n and p[i] == 45:
        sign = -1.0
        i = i + 1
    val: float64 = 0.0
    while i < n and _is_digit(p[i]) != 0:
        val = val * 10.0 + cast[float64](cast[int32](p[i]) - 48)
        i = i + 1
    if i < n and p[i] == 46:                       # '.'
        i = i + 1
        scale: float64 = 0.1
        while i < n and _is_digit(p[i]) != 0:
            val = val + cast[float64](cast[int32](p[i]) - 48) * scale
            scale = scale * 0.1
            i = i + 1
    if i < n and (p[i] == 101 or p[i] == 69):      # 'e' / 'E'
        i = i + 1
        esign: int32 = 1
        if i < n and p[i] == 43:
            i = i + 1
        elif i < n and p[i] == 45:
            esign = -1
            i = i + 1
        ev: int32 = 0
        while i < n and _is_digit(p[i]) != 0:
            ev = ev * 10 + (cast[int32](p[i]) - 48)
            i = i + 1
        k: int32 = 0
        while k < ev:
            if esign > 0:
                val = val * 10.0
            else:
                val = val * 0.1
            k = k + 1
    return sign * val


# Render a double into fnum_buf, NUL-terminated, JS/shell style:
# integer-valued floats print WITHOUT a trailing `.0` (so `3.0 * 2` -> `6`),
# fractions carry up to 12 significant digits with trailing zeros trimmed
# (so `1 / 2` -> `0.5`, `0.1 + 0.2` -> `0.3`).
fnum_buf:  Array[64, uint8]


def render_float(x: float64) -> Ptr[uint8]:
    pos: uint64 = 0
    if _f_is_nan(x) != 0:
        return "nan"
    if _f_is_inf(x) != 0:
        if x < 0.0:
            return "-inf"
        return "inf"
    if x == 0.0:
        fnum_buf[0] = 48
        fnum_buf[1] = 0
        return &fnum_buf[0]
    if x < 0.0:
        fnum_buf[pos] = 45                          # '-'
        pos = pos + 1
        x = 0.0 - x
    ip: float64 = _f_floor(x)
    frac: float64 = x - ip
    # integer part via render_int (num_buf is a SEPARATE buffer)
    if ip < 9.0e18:
        ipp: Ptr[uint8] = render_int(cast[int64](ip))
        j: uint64 = 0
        while ipp[j] != 0 and pos + 1 < 64:
            fnum_buf[pos] = ipp[j]
            pos = pos + 1
            j = j + 1
    else:
        fnum_buf[pos] = 49                          # crude '1e19'
        pos = pos + 1
    if frac > 0.0:
        fnum_buf[pos] = 46                          # '.'
        pos = pos + 1
        fbuf: Array[16, uint8]
        fn: int32 = 0
        kk: int32 = 0
        while kk < 12:
            frac = frac * 10.0
            d: int32 = cast[int32](_f_floor(frac))
            if d > 9:
                d = 9
            if d < 0:
                d = 0
            fbuf[fn] = cast[uint8](d) + 48
            fn = fn + 1
            frac = frac - cast[float64](d)
            kk = kk + 1
            if frac <= 0.0:
                break
        while fn > 1 and fbuf[fn - 1] == 48:        # trim trailing zeros
            fn = fn - 1
        jj: int32 = 0
        while jj < fn and pos + 1 < 64:
            fnum_buf[pos] = fbuf[jj]
            pos = pos + 1
            jj = jj + 1
    fnum_buf[pos] = 0
    return &fnum_buf[0]


# A value coerced to a double: float as-is, int/bool widened, str parsed.
def _val_as_float(v: int32) -> float64:
    t: int32 = val_type[cast[uint64](v)]
    if t == VT_FLOAT:
        return val_f[cast[uint64](v)]
    if t == VT_INT or t == VT_BOOL:
        return cast[float64](val_pay[cast[uint64](v)])
    if t == VT_STR:
        return _parse_float_str(cast[uint64](val_pay[cast[uint64](v)]))
    return 0.0


def _v_is_float(v: int32) -> int32:
    if val_type[cast[uint64](v)] == VT_FLOAT:
        return 1
    return 0


def v_bool(x: int32) -> int32:
    n: int32 = v_new(VT_BOOL)
    if x != 0:
        val_pay[cast[uint64](n)] = 1
    return n


def v_str_ref(sref: uint64) -> int32:
    n: int32 = v_new(VT_STR)
    val_pay[cast[uint64](n)] = cast[int64](sref)
    return n


def v_str_cstr(s: Ptr[uint8]) -> int32:
    return v_str_ref(str_intern_cstr(s))


def v_type(v: int32) -> int32:
    return val_type[cast[uint64](v)]


def v_is_truthy(v: int32) -> int32:
    t: int32 = val_type[cast[uint64](v)]
    if t == VT_NIL:
        return 0
    if t == VT_INT:
        if val_pay[cast[uint64](v)] != 0:
            return 1
        return 0
    if t == VT_BOOL:
        if val_pay[cast[uint64](v)] != 0:
            return 1
        return 0
    if t == VT_FLOAT:
        if val_f[cast[uint64](v)] != 0.0:
            return 1
        return 0
    if t == VT_STR:
        if str_len(cast[uint64](val_pay[cast[uint64](v)])) > 0:
            return 1
        return 0
    if t == VT_LIST:
        if val_ec[cast[uint64](v)] > 0:
            return 1
        return 0
    return 1


# A list builder: allocate a list cell, then push elements. Elements
# for one list must be pushed contiguously (shared pool).
def v_list_begin() -> int32:
    n: int32 = v_new(VT_LIST)
    val_es[cast[uint64](n)] = val_elem_cursor
    val_ec[cast[uint64](n)] = 0
    return n


def v_list_push(listv: int32, elem: int32):
    if val_elem_cursor >= LISTELEM_MAX:
        return
    val_elem[val_elem_cursor] = elem
    val_elem_cursor = val_elem_cursor + 1
    val_ec[cast[uint64](listv)] = val_ec[cast[uint64](listv)] + 1


def v_list_get(listv: int32, idx: uint64) -> int32:
    lu: uint64 = cast[uint64](listv)
    if idx >= val_ec[lu]:
        return 0
    return val_elem[val_es[lu] + idx]


def v_list_len(listv: int32) -> uint64:
    return val_ec[cast[uint64](listv)]


# --- in-place list mutation (append / pop / insert / setitem) --------
# The element pool (val_elem) is append-only and SHARED across every
# list, so a list sitting in the middle of the pool cannot simply grow
# in place — the slot after its last element belongs to whatever was
# built next. `_list_make_top` relocates a list's element run to the
# current top of the pool so it can then grow by extending the cursor.
# Because relocation rewrites the list CELL's own val_es (not the cell
# id), every name aliasing that cell keeps pointing at the same list —
# Python reference semantics: `ys = xs; xs.append(9)` shows in `ys`.
def _list_is_top(listv: int32) -> int32:
    lu: uint64 = cast[uint64](listv)
    if val_es[lu] + val_ec[lu] == val_elem_cursor:
        return 1
    return 0


def _list_make_top(listv: int32) -> int32:
    # Copy the list's elements to the top of the pool and repoint its
    # start there, so subsequent pushes extend contiguously. Returns 1
    # on success, 0 if the pool cannot hold the relocated copy.
    lu: uint64 = cast[uint64](listv)
    if _list_is_top(listv) != 0:
        return 1
    ln: uint64 = val_ec[lu]
    src: uint64 = val_es[lu]
    dst: uint64 = val_elem_cursor
    if dst + ln >= LISTELEM_MAX:
        return 0
    i: uint64 = 0
    while i < ln:
        val_elem[dst + i] = val_elem[src + i]
        i = i + 1
    val_es[lu] = dst
    val_elem_cursor = dst + ln
    return 1


def v_list_append(listv: int32, elem: int32):
    if val_type[cast[uint64](listv)] != VT_LIST:
        return
    if _list_make_top(listv) == 0:
        return
    v_list_push(listv, elem)


def v_list_insert(listv: int32, idx: int64, elem: int32):
    if val_type[cast[uint64](listv)] != VT_LIST:
        return
    if _list_make_top(listv) == 0:
        return
    lu: uint64 = cast[uint64](listv)
    ln: int64 = cast[int64](val_ec[lu])
    if idx < 0:
        idx = idx + ln                       # Python negative insert index
        if idx < 0:
            idx = 0
    if idx > ln:
        idx = ln
    if val_elem_cursor >= LISTELEM_MAX:
        return
    base: uint64 = val_es[lu]
    # shift [idx .. ln) right by one (walk downward to avoid clobbering)
    j: int64 = ln
    while j > idx:
        val_elem[base + cast[uint64](j)] = val_elem[base + cast[uint64](j - 1)]
        j = j - 1
    val_elem[base + cast[uint64](idx)] = elem
    val_elem_cursor = val_elem_cursor + 1
    val_ec[lu] = cast[uint64](ln + 1)


def v_list_pop(listv: int32, idx: int64) -> int32:
    # Remove and return the element at `idx` (default last for a bare
    # pop, which the caller signals by passing ln-1). Shifts the tail
    # left in place — a list only ever SHRINKS here, always safe.
    if val_type[cast[uint64](listv)] != VT_LIST:
        return 0
    lu: uint64 = cast[uint64](listv)
    ln: int64 = cast[int64](val_ec[lu])
    if ln == 0:
        return 0
    if idx < 0:
        idx = idx + ln
    if idx < 0 or idx >= ln:
        return 0
    base: uint64 = val_es[lu]
    popped: int32 = val_elem[base + cast[uint64](idx)]
    j: int64 = idx
    while j + 1 < ln:
        val_elem[base + cast[uint64](j)] = val_elem[base + cast[uint64](j + 1)]
        j = j + 1
    val_ec[lu] = cast[uint64](ln - 1)
    # reclaim the freed tail slot if the list sat at the pool top
    if base + cast[uint64](ln) == val_elem_cursor:
        val_elem_cursor = val_elem_cursor - 1
    return popped


def v_list_set(listv: int32, idx: int64, elem: int32) -> int32:
    # `xs[i] = v` — overwrite an existing slot (no growth). Returns 1 on
    # success, 0 if the index is out of range.
    if val_type[cast[uint64](listv)] != VT_LIST:
        return 0
    lu: uint64 = cast[uint64](listv)
    ln: int64 = cast[int64](val_ec[lu])
    if idx < 0:
        idx = idx + ln
    if idx < 0 or idx >= ln:
        return 0
    val_elem[val_es[lu] + cast[uint64](idx)] = elem
    return 1


# --- in-place dict mutation (setitem / setdefault / update / pop) ----
# A dict stores alternating key,val cell ids in the SAME shared pool, so
# adding a new key needs the same relocate-to-top trick as list growth.
def _dict_find(d: int32, key: int32) -> int64:
    # Index of `key` within the dict (0-based pair index), or -1.
    du: uint64 = cast[uint64](d)
    n: uint64 = val_ec[du]
    base: uint64 = val_es[du]
    i: uint64 = 0
    while i < n:
        if _v_streq(val_elem[base + i * 2], key) != 0:
            return cast[int64](i)
        i = i + 1
    return -1


def _dict_make_top(d: int32) -> int32:
    du: uint64 = cast[uint64](d)
    if val_es[du] + val_ec[du] * 2 == val_elem_cursor:
        return 1
    n2: uint64 = val_ec[du] * 2
    src: uint64 = val_es[du]
    dst: uint64 = val_elem_cursor
    if dst + n2 >= LISTELEM_MAX:
        return 0
    i: uint64 = 0
    while i < n2:
        val_elem[dst + i] = val_elem[src + i]
        i = i + 1
    val_es[du] = dst
    val_elem_cursor = dst + n2
    return 1


def v_dict_set(d: int32, key: int32, val: int32) -> int32:
    # `d[key] = val` — update in place if present, else append a new
    # pair (growing the pool). Returns 1 on success.
    if val_type[cast[uint64](d)] != VT_DICT:
        return 0
    idx: int64 = _dict_find(d, key)
    du: uint64 = cast[uint64](d)
    if idx >= 0:
        val_elem[val_es[du] + cast[uint64](idx) * 2 + 1] = val
        return 1
    if _dict_make_top(d) == 0:
        return 0
    if val_elem_cursor + 1 >= LISTELEM_MAX:
        return 0
    val_elem[val_elem_cursor] = key
    val_elem[val_elem_cursor + 1] = val
    val_elem_cursor = val_elem_cursor + 2
    val_ec[du] = val_ec[du] + 1
    return 1


def v_dict_pop(d: int32, key: int32, deflt: int32) -> int32:
    # Remove `key`, returning its value (or `deflt` if absent). Shifts
    # the trailing pairs left in place; reclaims the tail if at the top.
    if val_type[cast[uint64](d)] != VT_DICT:
        return deflt
    idx: int64 = _dict_find(d, key)
    if idx < 0:
        return deflt
    du: uint64 = cast[uint64](d)
    base: uint64 = val_es[du]
    n: uint64 = val_ec[du]
    got: int32 = val_elem[base + cast[uint64](idx) * 2 + 1]
    j: uint64 = cast[uint64](idx)
    while j + 1 < n:
        val_elem[base + j * 2]     = val_elem[base + (j + 1) * 2]
        val_elem[base + j * 2 + 1] = val_elem[base + (j + 1) * 2 + 1]
        j = j + 1
    val_ec[du] = n - 1
    if base + n * 2 == val_elem_cursor:
        val_elem_cursor = val_elem_cursor - 2
    return got


# --- value -> string rendering --------------------------------------
# Rendered into a shared scratch; copy out promptly.
render_buf: Array[1024, uint8]


def _render_append(pos: uint64, s: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while s[i] != 0 and pos + 1 < 1024:
        render_buf[pos] = s[i]
        pos = pos + 1
        i = i + 1
    return pos


def v_render(v: int32) -> Ptr[uint8]:
    # Render a value to a NUL-terminated string in render_buf.
    t: int32 = val_type[cast[uint64](v)]
    if t == VT_NIL:
        render_buf[0] = 0
        return &render_buf[0]
    if t == VT_INT:
        pos: uint64 = _render_append(
            0, render_int(val_pay[cast[uint64](v)]))
        render_buf[pos] = 0
        return &render_buf[0]
    if t == VT_FLOAT:
        pos: uint64 = _render_append(0, render_float(val_f[cast[uint64](v)]))
        render_buf[pos] = 0
        return &render_buf[0]
    if t == VT_BOOL:
        if val_pay[cast[uint64](v)] != 0:
            return "true"
        return "false"
    if t == VT_STR:
        return str_ptr(cast[uint64](val_pay[cast[uint64](v)]))
    if t == VT_LIST:
        pos: uint64 = 0
        n: uint64 = val_ec[cast[uint64](v)]
        i: uint64 = 0
        while i < n:
            if i > 0:
                pos = _render_append(pos, " ")
            elem: int32 = v_list_get(v, i)
            # render the element into a temp via recursion-safe copy
            ep: Ptr[uint8] = v_render_str_only(elem)
            pos = _render_append(pos, ep)
            i = i + 1
        render_buf[pos] = 0
        return &render_buf[0]
    if t == VT_PROC:
        pos: uint64 = _render_append(0, "<proc ")
        pos = _render_append(pos, render_int(val_pay[cast[uint64](v)]))
        pos = _render_append(pos, ">")
        render_buf[pos] = 0
        return &render_buf[0]
    if t == VT_NS:
        return "<namespace>"
    if t == VT_MOUNT:
        # §14: a mount handle displays as <mount LABEL>.
        pos: uint64 = _render_append(0, "<mount ")
        lref: uint64 = cast[uint64](val_aux[cast[uint64](v)])
        if lref != 0:
            pos = _render_append(pos, str_ptr(lref))
        pos = _render_append(pos, ">")
        render_buf[pos] = 0
        return &render_buf[0]
    render_buf[0] = 0
    return &render_buf[0]


# Sub-renderer used by v_render's list path so the recursion does not
# clobber render_buf — renders scalars into a small private scratch.
render_sub: Array[64, uint8]

# #110 fix: a NESTED list must render with visible elements, not blank.
# `v_render`'s top-level list path space-joins its elements via
# v_render_str_only; before this, v_render_str_only returned "" for a
# VT_LIST, so an inner list (`[[1,2],[3,4]]`, `zip(a,b)`) printed empty.
# _nl_render appends a Python-style `[a, b]` form into ONE dedicated
# buffer via a running cursor — sequential appends make the recursion
# alias-safe (each level writes above the previous), and a scalar leaf
# defers to v_render_str_only (which never touches this buffer). Only
# nested lists reach here: the top-level display path keeps its bracket-
# less space-join, so `echo $xs` still prints `10 20 30 40`.
nlrender_buf: Array[1024, uint8]


def _nl_render(v: int32, pos: uint64) -> uint64:
    t: int32 = val_type[cast[uint64](v)]
    if t == VT_LIST:
        if pos + 1 < 1024:
            nlrender_buf[pos] = 91                # '['
            pos = pos + 1
        n: uint64 = val_ec[cast[uint64](v)]
        i: uint64 = 0
        while i < n:
            if i > 0 and pos + 2 < 1024:
                nlrender_buf[pos] = 44            # ','
                nlrender_buf[pos + 1] = 32        # ' '
                pos = pos + 2
            pos = _nl_render(v_list_get(v, i), pos)
            i = i + 1
        if pos + 1 < 1024:
            nlrender_buf[pos] = 93                # ']'
            pos = pos + 1
        return pos
    # scalar leaf — v is NOT a list here, so v_render_str_only cannot
    # recurse back into this buffer.
    sp: Ptr[uint8] = v_render_str_only(v)
    j: uint64 = 0
    while sp[j] != 0 and pos + 1 < 1024:
        nlrender_buf[pos] = sp[j]
        pos = pos + 1
        j = j + 1
    return pos


def v_render_str_only(v: int32) -> Ptr[uint8]:
    t: int32 = val_type[cast[uint64](v)]
    if t == VT_STR:
        return str_ptr(cast[uint64](val_pay[cast[uint64](v)]))
    if t == VT_INT:
        src: Ptr[uint8] = render_int(val_pay[cast[uint64](v)])
        i: uint64 = 0
        while src[i] != 0 and i + 1 < 64:
            render_sub[i] = src[i]
            i = i + 1
        render_sub[i] = 0
        return &render_sub[0]
    if t == VT_FLOAT:
        src: Ptr[uint8] = render_float(val_f[cast[uint64](v)])
        i: uint64 = 0
        while src[i] != 0 and i + 1 < 64:
            render_sub[i] = src[i]
            i = i + 1
        render_sub[i] = 0
        return &render_sub[0]
    if t == VT_BOOL:
        if val_pay[cast[uint64](v)] != 0:
            return "true"
        return "false"
    if t == VT_PROC:
        # §11/§14: a process handle interpolates to its bare pid, so
        # `kill $svc` / `wait $svc` get a usable argument. (v_render's
        # decorative "<proc N>" form is for display only.)
        src: Ptr[uint8] = render_int(val_pay[cast[uint64](v)])
        i: uint64 = 0
        while src[i] != 0 and i + 1 < 64:
            render_sub[i] = src[i]
            i = i + 1
        render_sub[i] = 0
        return &render_sub[0]
    if t == VT_MOUNT:
        # §14: a mount handle interpolates to its LABEL — so `unmount
        # $m` hands the builtin exactly the handle the kernel keys on.
        lref: uint64 = cast[uint64](val_aux[cast[uint64](v)])
        if lref != 0:
            src: Ptr[uint8] = str_ptr(lref)
            i: uint64 = 0
            while src[i] != 0 and i + 1 < 64:
                render_sub[i] = src[i]
                i = i + 1
            render_sub[i] = 0
            return &render_sub[0]
        return ""
    if t == VT_LIST:
        # #110: render a (nested) list as a Python-style `[a, b]` string.
        p: uint64 = _nl_render(v, 0)
        nlrender_buf[p] = 0
        return &nlrender_buf[0]
    return ""


# ====================================================================
# Variable scope
# ====================================================================
# hamsh keeps a flat binding table with a frame-pointer discipline.
# Function calls push a frame; `enter`/`spawn`/`ns` blocks run in the
# child process or restore on exit so they need no extra frame here.
# A binding is (name str ref, value cell id, frame depth).

sc_name:  Array[64, uint64]
sc_val:   Array[64, int32]
sc_frame: Array[64, int32]
sc_count: uint64 = 0
sc_depth: int32 = 0


def scope_reset():
    sc_count = 0
    sc_depth = 0


def scope_push_frame() -> int32:
    sc_depth = sc_depth + 1
    return cast[int32](sc_count)      # mark = first binding of frame


def scope_pop_frame(mark: int32):
    sc_count = cast[uint64](mark)
    sc_depth = sc_depth - 1


def scope_set(name: uint64, val: int32):
    # Set in the current frame (or update an existing binding visible
    # in the current frame). Resolution is name-local; the shell's
    # outermost frame is depth 0.
    i: uint64 = sc_count
    while i > 0:
        i = i - 1
        if sc_frame[i] == sc_depth and \
                cstr_eq(str_ptr(sc_name[i]), str_ptr(name)) != 0:
            sc_val[i] = val
            return
    if sc_count >= SCOPE_MAX:
        return
    sc_name[sc_count]  = name
    sc_val[sc_count]   = val
    sc_frame[sc_count] = sc_depth
    sc_count = sc_count + 1


def scope_get(name: uint64) -> int32:
    # Look up `name`. In a function frame, look only in that frame and
    # the global frame (no dynamic-scope leakage from caller locals).
    i: uint64 = sc_count
    while i > 0:
        i = i - 1
        if sc_frame[i] == sc_depth or sc_frame[i] == 0:
            if cstr_eq(str_ptr(sc_name[i]), str_ptr(name)) != 0:
                return sc_val[i]
    return 0     # cell 0 = nil


def scope_has(name: uint64) -> int32:
    i: uint64 = sc_count
    while i > 0:
        i = i - 1
        if sc_frame[i] == sc_depth or sc_frame[i] == 0:
            if cstr_eq(str_ptr(sc_name[i]), str_ptr(name)) != 0:
                return 1
    return 0


# ====================================================================
# Environment — the /env namespace (§3)
# ====================================================================
# Exported variables are files under /env (the #e device). hamsh keeps
# an in-process mirror so $PATH etc. resolve fast; export writes the
# string form into /env/NAME via the #e device, and a fresh shell
# seeds the mirror from /env at startup. Children inherit env through
# the namespace.

ENV_MAX:        uint64 = 32
ENV_NAME_MAX:   uint64 = 32
ENV_VAL_MAX:    uint64 = 192

env_name:  Array[1024, uint8]    # 32 * 32
env_val:   Array[6144, uint8]    # 32 * 192
env_used:  Array[32, int32]
env_count: uint64 = 0


def env_find(name: Ptr[uint8]) -> int64:
    i: uint64 = 0
    while i < ENV_MAX:
        if env_used[i] != 0:
            if cstr_eq(&env_name[i * ENV_NAME_MAX], name) != 0:
                return cast[int64](i)
        i = i + 1
    return -1


def env_get(name: Ptr[uint8]) -> Ptr[uint8]:
    idx: int64 = env_find(name)
    if idx < 0:
        return cast[Ptr[uint8]](0)
    return &env_val[cast[uint64](idx) * ENV_VAL_MAX]


def env_set(name: Ptr[uint8], val: Ptr[uint8]):
    idx: int64 = env_find(name)
    slot: uint64 = 0
    if idx >= 0:
        slot = cast[uint64](idx)
    else:
        i: uint64 = 0
        found: int32 = 0
        while i < ENV_MAX:
            if env_used[i] == 0:
                slot = i
                found = 1
                break
            i = i + 1
        if found == 0:
            return
    nb: uint64 = slot * ENV_NAME_MAX
    j: uint64 = 0
    while name[j] != 0 and j + 1 < ENV_NAME_MAX:
        env_name[nb + j] = name[j]
        j = j + 1
    env_name[nb + j] = 0
    vb: uint64 = slot * ENV_VAL_MAX
    k: uint64 = 0
    while val[k] != 0 and k + 1 < ENV_VAL_MAX:
        env_val[vb + k] = val[k]
        k = k + 1
    env_val[vb + k] = 0
    env_used[slot] = 1
    if idx < 0 and slot >= env_count:
        env_count = slot + 1


# ====================================================================
# errstr (§16)
# ====================================================================
# $errstr is a native variable holding the last failure string. We
# mirror the kernel's per-process errstr buffer.
errstr_buf: Array[128, uint8]


def errstr_clear():
    errstr_buf[0] = 0


def errstr_set(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i + 1 < 128:
        errstr_buf[i] = s[i]
        i = i + 1
    errstr_buf[i] = 0


def errstr_pull_kernel():
    # Read the kernel's per-process errstr into our mirror. The Plan 9
    # swap semantics: passing an empty buffer reads without installing.
    probe: Array[128, uint8]
    probe[0] = 0
    sys_errstr(&probe[0], 128)
    i: uint64 = 0
    while probe[i] != 0 and i + 1 < 128:
        errstr_buf[i] = probe[i]
        i = i + 1
    errstr_buf[i] = 0


# ====================================================================
# Evaluator
# ====================================================================
# Control-flow signalling out of statement execution. exec_block
# returns one of these; the caller (loop / function) reacts.
EX_NORMAL:   int32 = 0
EX_BREAK:    int32 = 1
EX_CONTINUE: int32 = 2
EX_RETURN:   int32 = 3
EX_ERROR:    int32 = 4      # caught by try/except
EX_EXIT:     int32 = 5      # `exit` builtin — unwind to main

# The function return value lands here when EX_RETURN propagates.
eval_retval: int32 = 0
# Last command exit status (numeric). $status / $? expose it.
eval_status: int32 = 0
# Error message for EX_ERROR unwinding.
eval_errmsg: Array[128, uint8]
# §Exceptions: the value carried by an in-flight `raise`. exec_try binds
# it to the `except as NAME` variable; 0 = no value (status-only failure).
raised_val: int32 = 0


def eval_err(msg: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while msg[i] != 0 and i + 1 < 128:
        eval_errmsg[i] = msg[i]
        i = i + 1
    eval_errmsg[i] = 0
    errstr_set(msg)
    return EX_ERROR


# --- function registry ----------------------------------------------
# `def` registers a function: name + the ND_DEF node. Functions persist
# across lines (the node arena does NOT reset while a def is live), so
# defs live in their own small arena copied out of the per-line nodes.
FN_MAX:       uint64 = 32
fn_name:      Array[512, uint8]   # 32 * 16
FN_NAME_MAX:  uint64 = 16
fn_node:      Array[32, int32]
fn_count:     uint64 = 0


# The evaluator entry points (eval_expr / exec_block / exec_statement)
# call each other mutually; Adder resolves calls across the whole
# module so definition order is free.


# Python floor-division on integers: the quotient rounded toward
# NEGATIVE infinity (`-7 // 2 == -4`), unlike C's `/` which truncates
# toward zero (`-7 / 2 == -3`). Adjust the truncated quotient down by
# one when the operands' signs differ AND the division is inexact.
def _floordiv_int(a: int64, b: int64) -> int64:
    if b == 0:
        return 0
    q: int64 = a / b
    r: int64 = a - q * b
    if r != 0 and ((a < 0) != (b < 0)):
        q = q - 1
    return q


# Python floor-mod: the remainder carries the sign of the DIVISOR
# (`-7 % 2 == 1`, `7 % -2 == -1`), unlike C's `%` which carries the
# sign of the dividend. Defined so `a == (a // b) * b + (a % b)`.
def _floormod_int(a: int64, b: int64) -> int64:
    if b == 0:
        return 0
    r: int64 = a % b
    if r != 0 and ((r < 0) != (b < 0)):
        r = r + b
    return r


def _arith(op: int32, a: int64, b: int64) -> int64:
    if op == OP_PLUS:
        return a + b
    if op == OP_MINUS:
        return a - b
    if op == OP_STAR:
        return a * b
    if op == OP_SLASH:
        if b == 0:
            return 0
        return a / b
    if op == OP_FLOORDIV:
        return _floordiv_int(a, b)
    if op == OP_PERCENT:
        return _floormod_int(a, b)
    return 0


def _arith_float(op: int32, a: float64, b: float64) -> float64:
    if op == OP_PLUS:
        return a + b
    if op == OP_MINUS:
        return a - b
    if op == OP_STAR:
        return a * b
    if op == OP_SLASH:
        if b == 0.0:
            return 0.0
        return a / b
    if op == OP_FLOORDIV:
        if b == 0.0:
            return 0.0
        return _f_floor(a / b)
    if op == OP_PERCENT:
        return _f_fmod(a, b)
    return 0.0


def _cmp_float(op: int32, a: float64, b: float64) -> int32:
    if op == OP_EQEQ:
        if a == b:
            return 1
        return 0
    if op == OP_NE:
        if a != b:
            return 1
        return 0
    if op == OP_LT:
        if a < b:
            return 1
        return 0
    if op == OP_GT:
        if a > b:
            return 1
        return 0
    if op == OP_LE:
        if a <= b:
            return 1
        return 0
    if op == OP_GE:
        if a >= b:
            return 1
        return 0
    return 0


def _cmp_int(op: int32, a: int64, b: int64) -> int32:
    if op == OP_EQEQ:
        if a == b:
            return 1
        return 0
    if op == OP_NE:
        if a != b:
            return 1
        return 0
    if op == OP_LT:
        if a < b:
            return 1
        return 0
    if op == OP_GT:
        if a > b:
            return 1
        return 0
    if op == OP_LE:
        if a <= b:
            return 1
        return 0
    if op == OP_GE:
        if a >= b:
            return 1
        return 0
    return 0


def _val_as_int(v: int32) -> int64:
    t: int32 = val_type[cast[uint64](v)]
    if t == VT_INT:
        return val_pay[cast[uint64](v)]
    if t == VT_BOOL:
        return val_pay[cast[uint64](v)]
    if t == VT_FLOAT:
        return cast[int64](_f_trunc(val_f[cast[uint64](v)]))
    if t == VT_STR:
        # parse leading decimal
        s: Ptr[uint8] = str_ptr(cast[uint64](val_pay[cast[uint64](v)]))
        i: uint64 = 0
        neg: int32 = 0
        if s[0] == 45:
            neg = 1
            i = 1
        r: int64 = 0
        while s[i] >= 48 and s[i] <= 57:
            r = r * 10 + cast[int64](s[i] - 48)
            i = i + 1
        if neg != 0:
            return -r
        return r
    return 0


# Concatenate two values' string forms into the arena; return a STR.
concat_scratch: Array[1024, uint8]


def _v_concat(a: int32, b: int32) -> int32:
    pa: Ptr[uint8] = v_render_str_only(a)
    la: uint64 = cstr_len(pa)
    i: uint64 = 0
    while i < la and i + 1 < 1024:
        concat_scratch[i] = pa[i]
        i = i + 1
    pb: Ptr[uint8] = v_render_str_only(b)
    j: uint64 = 0
    while pb[j] != 0 and i + 1 < 1024:
        concat_scratch[i] = pb[j]
        i = i + 1
        j = j + 1
    concat_scratch[i] = 0
    return v_str_ref(str_intern_n(&concat_scratch[0], i))


def _v_streq(a: int32, b: int32) -> int32:
    pa: Ptr[uint8] = v_render_str_only(a)
    sa: Array[256, uint8]
    i: uint64 = 0
    while pa[i] != 0 and i + 1 < 256:
        sa[i] = pa[i]
        i = i + 1
    sa[i] = 0
    pb: Ptr[uint8] = v_render_str_only(b)
    return cstr_eq(&sa[0], pb)


def _v_member(needle: int32, container: int32) -> int32:
    # 1 iff `needle` is a member of `container`:
    #   VT_LIST — some element compares string-equal to needle,
    #   VT_DICT — some key compares string-equal to needle,
    #   VT_STR  — needle's string form occurs as a substring.
    ct: int32 = val_type[cast[uint64](container)]
    if ct == VT_LIST:
        n: uint64 = val_ec[cast[uint64](container)]
        i: uint64 = 0
        while i < n:
            if _v_streq(v_list_get(container, i), needle) != 0:
                return 1
            i = i + 1
        return 0
    if ct == VT_DICT:
        n2: uint64 = val_ec[cast[uint64](container)]
        base: uint64 = val_es[cast[uint64](container)]
        i2: uint64 = 0
        while i2 < n2:
            if _v_streq(val_elem[base + i2 * 2], needle) != 0:
                return 1
            i2 = i2 + 1
        return 0
    if ct == VT_STR:
        la: uint64 = _strfn_copy(&_strfn_a[0], 1024, container)
        lb: uint64 = _strfn_copy(&_strfn_b[0], 256, needle)
        if lb == 0:
            return 1
        p: uint64 = 0
        while p + lb <= la:
            if _match_at(&_strfn_a[0], la, p, &_strfn_b[0], lb) != 0:
                return 1
            p = p + 1
        return 0
    return 0


def eval_binop(node: int32) -> int32:
    nu: uint64 = cast[uint64](node)
    op: int32 = cast[int32](nd_i[nu])
    # short-circuit logicals
    if op == OP_AND:
        l: int32 = eval_expr(nd_a[nu])
        if v_is_truthy(l) == 0:
            return v_bool(0)
        r: int32 = eval_expr(nd_b[nu])
        return v_bool(v_is_truthy(r))
    if op == OP_OR:
        l: int32 = eval_expr(nd_a[nu])
        if v_is_truthy(l) != 0:
            return v_bool(1)
        r: int32 = eval_expr(nd_b[nu])
        return v_bool(v_is_truthy(r))
    lhs: int32 = eval_expr(nd_a[nu])
    rhs: int32 = eval_expr(nd_b[nu])
    lt: int32 = val_type[cast[uint64](lhs)]
    rt: int32 = val_type[cast[uint64](rhs)]
    # membership: `x in container` / `x not in container`.
    if op == OP_IN:
        return v_bool(_v_member(lhs, rhs))
    if op == OP_NOTIN:
        if _v_member(lhs, rhs) != 0:
            return v_bool(0)
        return v_bool(1)
    # '+' on two strings (or anything with a string) concatenates.
    if op == OP_PLUS:
        if lt == VT_STR or rt == VT_STR:
            return _v_concat(lhs, rhs)
    # comparisons
    if op == OP_EQEQ or op == OP_NE:
        if lt == VT_STR or rt == VT_STR:
            eq: int32 = _v_streq(lhs, rhs)
            if op == OP_NE:
                if eq != 0:
                    return v_bool(0)
                return v_bool(1)
            return v_bool(eq)
    if op == OP_EQEQ or op == OP_NE or op == OP_LT or op == OP_GT or \
            op == OP_LE or op == OP_GE:
        # §Float: a mixed or all-float comparison promotes to double.
        if lt == VT_FLOAT or rt == VT_FLOAT:
            return v_bool(_cmp_float(op,
                _val_as_float(lhs), _val_as_float(rhs)))
        return v_bool(_cmp_int(op, _val_as_int(lhs), _val_as_int(rhs)))
    # arithmetic. §Float: `/` is Python-3 true division (ALWAYS a float,
    # so `1 / 2` == 0.5); any float operand also promotes + - * % to
    # double. Everything else stays exact integer arithmetic.
    if op == OP_SLASH:
        return v_float(_arith_float(op, _val_as_float(lhs), _val_as_float(rhs)))
    if lt == VT_FLOAT or rt == VT_FLOAT:
        return v_float(_arith_float(op, _val_as_float(lhs), _val_as_float(rhs)))
    return v_int(_arith(op, _val_as_int(lhs), _val_as_int(rhs)))


# --- nested lex/parse for ${ } and `{ } -----------------------------
# ${ expr } and `{ cmd } carry a raw source slice. Evaluating them
# means lex+parse that slice. Re-lexing would clobber the live tok_*
# arrays mid-evaluation, so we snapshot/restore them around the nested
# pass. The node arena is shared and append-only within a line, so the
# nested AST simply extends it.

tok_save_kind: Array[4096, int32]
tok_save_str:  Array[4096, uint64]
tok_save_int:  Array[4096, int64]


def _save_tokens() -> uint64:
    saved: uint64 = tok_count
    i: uint64 = 0
    while i < tok_count:
        tok_save_kind[i] = tok_kind[i]
        tok_save_str[i]  = tok_str[i]
        tok_save_int[i]  = tok_int[i]
        i = i + 1
    return saved


def _restore_tokens(saved: uint64):
    i: uint64 = 0
    while i < saved:
        tok_kind[i] = tok_save_kind[i]
        tok_str[i]  = tok_save_str[i]
        tok_int[i]  = tok_save_int[i]
        i = i + 1
    tok_count = saved


def eval_subexpr(sref: uint64) -> int32:
    # Lex+parse+eval the raw source `sref` as a single expression.
    src: Ptr[uint8] = str_ptr(sref)
    slen: uint64 = str_len(sref)
    saved_tok: uint64 = _save_tokens()
    saved_pos: uint64 = ps_pos
    lex_line(src, slen)
    ps_pos = 0
    # A `${ … }` fragment is a single expression — indentation is
    # meaningless here, but lex_line still measures the fragment's leading
    # whitespace as an INDENT (and appends a closing DEDENT at EOF). Skip
    # those framing tokens so `${ expr }` with the natural surrounding
    # spaces parses identically to `${expr}` (previously the leading
    # INDENT made parse_expr fail and the whole `${ … }` render empty).
    while tok_kind[ps_pos] == TK_INDENT or tok_kind[ps_pos] == TK_NEWLINE:
        ps_pos = ps_pos + 1
    sub: int32 = parse_expr()
    result: int32 = 0
    if ps_error == 0:
        result = eval_expr(sub)
    else:
        ps_error = 0
        result = 0
    _restore_tokens(saved_tok)
    ps_pos = saved_pos
    return result


def eval_str_interp(sref: uint64) -> int32:
    # Evaluate a double-quoted string with $name / ${ } interpolation.
    # Single-pass scan of the literal bytes.
    src: Ptr[uint8] = str_ptr(sref)
    n: uint64 = str_len(sref)
    out: uint64 = 0
    p: uint64 = 0
    while p < n and out + 1 < 1024:
        c: uint8 = src[p]
        if c == 36 and p + 1 < n:               # '$'
            if src[p + 1] == 123:               # '${'
                close: uint64 = _scan_balanced(src, n, p + 1, 123, 125)
                if close < n:
                    inner: uint64 = p + 2
                    ilen: uint64 = close - inner
                    iref: uint64 = str_intern_n(
                        cast[Ptr[uint8]](cast[uint64](src) + inner),
                        ilen)
                    sub: int32 = eval_subexpr(iref)
                    sp: Ptr[uint8] = v_render_str_only(sub)
                    out = _render_append(out, sp)
                    # render into render_buf overwrites — copy carefully:
                    p = close + 1
                    continue
            # $name
            q: uint64 = p + 1
            nm: Array[64, uint8]
            ni: uint64 = 0
            while q < n and _is_ident(src[q]) != 0 and ni + 1 < 64:
                nm[ni] = src[q]
                ni = ni + 1
                q = q + 1
            nm[ni] = 0
            nref: uint64 = str_intern_n(&nm[0], ni)
            vv: int32 = eval_var_by_name(nref)
            sp: Ptr[uint8] = v_render_str_only(vv)
            out = _render_append(out, sp)
            p = q
            continue
        render_buf[out] = c
        out = out + 1
        p = p + 1
    render_buf[out] = 0
    return v_str_ref(str_intern_n(&render_buf[0], out))


# §f-string: a dedicated accumulator (NOT render_buf) so a nested
# interpolating string inside `{expr}` — which itself uses render_buf —
# cannot clobber the f-string being built.
fstr_buf: Array[1024, uint8]


def eval_fstring(sref: uint64) -> int32:
    # `f"x = {expr}"` — Python-style interpolation. `{expr}` evaluates an
    # arbitrary sub-expression; `{{` / `}}` are literal braces.
    src: Ptr[uint8] = str_ptr(sref)
    n: uint64 = str_len(sref)
    out: uint64 = 0
    p: uint64 = 0
    while p < n and out + 1 < 1024:
        c: uint8 = src[p]
        if c == 123:                                 # '{'
            if p + 1 < n and src[p + 1] == 123:      # '{{' -> literal '{'
                fstr_buf[out] = 123
                out = out + 1
                p = p + 2
                continue
            close: uint64 = _scan_balanced(src, n, p, 123, 125)
            if close < n:
                inner: uint64 = p + 1
                ilen: uint64 = close - inner
                iref: uint64 = str_intern_n(
                    cast[Ptr[uint8]](cast[uint64](src) + inner), ilen)
                sub: int32 = eval_subexpr(iref)
                sp: Ptr[uint8] = v_render_str_only(sub)
                k: uint64 = 0
                while sp[k] != 0 and out + 1 < 1024:
                    fstr_buf[out] = sp[k]
                    out = out + 1
                    k = k + 1
                p = close + 1
                continue
            fstr_buf[out] = c                        # unbalanced: literal
            out = out + 1
            p = p + 1
            continue
        if c == 125 and p + 1 < n and src[p + 1] == 125:   # '}}' -> '}'
            fstr_buf[out] = 125
            out = out + 1
            p = p + 2
            continue
        fstr_buf[out] = c
        out = out + 1
        p = p + 1
    fstr_buf[out] = 0
    return v_str_ref(str_intern_n(&fstr_buf[0], out))


def eval_var_by_name(nref: uint64) -> int32:
    # Resolve a variable by name. Special natives: errstr, status.
    np: Ptr[uint8] = str_ptr(nref)
    if cstr_eq(np, "errstr") != 0:
        return v_str_cstr(&errstr_buf[0])
    if cstr_eq(np, "status") != 0:
        return v_int(cast[int64](eval_status))
    if scope_has(nref) != 0:
        return scope_get(nref)
    # fall back to the environment
    ev: Ptr[uint8] = env_get(np)
    if cast[uint64](ev) != 0:
        return v_str_cstr(ev)
    return 0     # nil


# --- string builtin functions (Deliverable 2 ergonomics) ------------
# Python-style string helpers, exposed as ordinary call-position
# functions (`upper(s)`, `split(s, sep)`, …) rather than method syntax,
# so no new grammar is needed. Each renders its string arguments into a
# STABLE local buffer first — v_render_str_only shares render scratch,
# so two string args must be copied out before the second render.
_strfn_a: Array[1024, uint8]
_strfn_b: Array[256, uint8]
_strfn_out: Array[1024, uint8]


def _strfn_copy(dst: Ptr[uint8], cap: uint64, v: int32) -> uint64:
    # Render value v to a string and copy it (NUL-terminated) into dst.
    # Returns the byte length (excluding the NUL).
    sp: Ptr[uint8] = v_render_str_only(v)
    i: uint64 = 0
    while sp[i] != 0 and i + 1 < cap:
        dst[i] = sp[i]
        i = i + 1
    dst[i] = 0
    return i


def v_str_case(v: int32, to_upper: int32) -> int32:
    # upper(s) / lower(s): ASCII case fold.
    la: uint64 = _strfn_copy(&_strfn_a[0], 1024, v)
    i: uint64 = 0
    while i < la:
        c: uint8 = _strfn_a[i]
        if to_upper != 0:
            if c >= 97 and c <= 122:
                c = c - 32
        else:
            if c >= 65 and c <= 90:
                c = c + 32
        _strfn_out[i] = c
        i = i + 1
    return v_str_ref(str_intern_n(&_strfn_out[0], la))


def v_str_strip(v: int32) -> int32:
    # strip(s): drop leading + trailing ASCII whitespace.
    la: uint64 = _strfn_copy(&_strfn_a[0], 1024, v)
    start: uint64 = 0
    while start < la and (_strfn_a[start] == 32 or _strfn_a[start] == 9 \
            or _strfn_a[start] == 10 or _strfn_a[start] == 13):
        start = start + 1
    end: uint64 = la
    while end > start and (_strfn_a[end - 1] == 32 or _strfn_a[end - 1] == 9 \
            or _strfn_a[end - 1] == 10 or _strfn_a[end - 1] == 13):
        end = end - 1
    return v_str_ref(str_intern_n(&_strfn_a[start], end - start))


def _match_at(hay: Ptr[uint8], hlen: uint64, pos: uint64,
              needle: Ptr[uint8], nlen: uint64) -> int32:
    # 1 iff `needle` (length nlen) occurs in `hay` starting at `pos`.
    if pos + nlen > hlen:
        return 0
    i: uint64 = 0
    while i < nlen:
        if hay[pos + i] != needle[i]:
            return 0
        i = i + 1
    return 1


def v_str_split(sv: int32, sepv: int32) -> int32:
    # split(s, sep): a list of the substrings between each `sep`. An
    # empty sep returns the whole string as one element.
    la: uint64 = _strfn_copy(&_strfn_a[0], 1024, sv)
    lb: uint64 = _strfn_copy(&_strfn_b[0], 256, sepv)
    lst: int32 = v_list_begin()
    if lb == 0:
        v_list_push(lst, v_str_ref(str_intern_n(&_strfn_a[0], la)))
        return lst
    start: uint64 = 0
    p: uint64 = 0
    while p < la:
        if _match_at(&_strfn_a[0], la, p, &_strfn_b[0], lb) != 0:
            v_list_push(lst, v_str_ref(
                str_intern_n(&_strfn_a[start], p - start)))
            p = p + lb
            start = p
        else:
            p = p + 1
    v_list_push(lst, v_str_ref(str_intern_n(&_strfn_a[start], la - start)))
    return lst


def v_str_join(listv: int32, sepv: int32) -> int32:
    # join(list, sep): concatenate the list's elements with `sep`.
    lb: uint64 = _strfn_copy(&_strfn_b[0], 256, sepv)
    if val_type[cast[uint64](listv)] != VT_LIST:
        return v_str_ref(str_intern_n(&_strfn_a[0],
                         _strfn_copy(&_strfn_a[0], 1024, listv)))
    out: uint64 = 0
    n: uint64 = val_ec[cast[uint64](listv)]
    i: uint64 = 0
    while i < n:
        if i > 0:
            j: uint64 = 0
            while j < lb and out + 1 < 1024:
                _strfn_out[out] = _strfn_b[j]
                out = out + 1
                j = j + 1
        ep: Ptr[uint8] = v_render_str_only(v_list_get(listv, i))
        k: uint64 = 0
        while ep[k] != 0 and out + 1 < 1024:
            _strfn_out[out] = ep[k]
            out = out + 1
            k = k + 1
        i = i + 1
    return v_str_ref(str_intern_n(&_strfn_out[0], out))


def v_str_find(sv: int32, subv: int32) -> int64:
    # find(s, sub): 0-based index of the first occurrence of `sub` in
    # `s`, or -1 if absent. An empty needle matches at index 0.
    la: uint64 = _strfn_copy(&_strfn_a[0], 1024, sv)
    lb: uint64 = _strfn_copy(&_strfn_b[0], 256, subv)
    if lb == 0:
        return 0
    p: uint64 = 0
    while p + lb <= la:
        if _match_at(&_strfn_a[0], la, p, &_strfn_b[0], lb) != 0:
            return cast[int64](p)
        p = p + 1
    return -1


def v_str_count(sv: int32, subv: int32) -> int64:
    # count(s, sub): number of NON-overlapping occurrences of `sub`.
    la: uint64 = _strfn_copy(&_strfn_a[0], 1024, sv)
    lb: uint64 = _strfn_copy(&_strfn_b[0], 256, subv)
    if lb == 0:
        return 0
    c: int64 = 0
    p: uint64 = 0
    while p + lb <= la:
        if _match_at(&_strfn_a[0], la, p, &_strfn_b[0], lb) != 0:
            c = c + 1
            p = p + lb
        else:
            p = p + 1
    return c


def v_str_startswith(sv: int32, prev: int32) -> int32:
    # startswith(s, prefix): 1 iff `s` begins with `prefix`.
    la: uint64 = _strfn_copy(&_strfn_a[0], 1024, sv)
    lb: uint64 = _strfn_copy(&_strfn_b[0], 256, prev)
    if lb > la:
        return 0
    return _match_at(&_strfn_a[0], la, 0, &_strfn_b[0], lb)


def v_str_endswith(sv: int32, sufv: int32) -> int32:
    # endswith(s, suffix): 1 iff `s` ends with `suffix`.
    la: uint64 = _strfn_copy(&_strfn_a[0], 1024, sv)
    lb: uint64 = _strfn_copy(&_strfn_b[0], 256, sufv)
    if lb > la:
        return 0
    return _match_at(&_strfn_a[0], la, la - lb, &_strfn_b[0], lb)


def v_str_replace(sv: int32, oldv: int32, newv: int32) -> int32:
    # replace(s, old, new): replace every occurrence of `old` with `new`.
    la: uint64 = _strfn_copy(&_strfn_a[0], 1024, sv)
    lb: uint64 = _strfn_copy(&_strfn_b[0], 256, oldv)
    # The replacement text is rendered last into its own scratch.
    _strfn_rep: Array[256, uint8]
    lr: uint64 = 0
    rp: Ptr[uint8] = v_render_str_only(newv)
    while rp[lr] != 0 and lr + 1 < 256:
        _strfn_rep[lr] = rp[lr]
        lr = lr + 1
    out: uint64 = 0
    p: uint64 = 0
    if lb == 0:
        return v_str_ref(str_intern_n(&_strfn_a[0], la))
    while p < la:
        if _match_at(&_strfn_a[0], la, p, &_strfn_b[0], lb) != 0:
            j: uint64 = 0
            while j < lr and out + 1 < 1024:
                _strfn_out[out] = _strfn_rep[j]
                out = out + 1
                j = j + 1
            p = p + lb
        else:
            if out + 1 < 1024:
                _strfn_out[out] = _strfn_a[p]
                out = out + 1
            p = p + 1
    return v_str_ref(str_intern_n(&_strfn_out[0], out))


# ====================================================================
# §17 data-scripting core: iteration, comprehensions, slicing (#110)
# ====================================================================

def _iter_count(v: int32) -> uint64:
    # Number of items when `v` is iterated: list elements, or string
    # characters. Anything else is a zero-length iterable.
    t: int32 = val_type[cast[uint64](v)]
    if t == VT_LIST:
        return val_ec[cast[uint64](v)]
    if t == VT_STR:
        return str_len(cast[uint64](val_pay[cast[uint64](v)]))
    if t == VT_NS:
        # §19 (#111): a namespace iterates over its bind/mount-points.
        return val_ec[cast[uint64](_ns_binds_list(v))]
    return 0


_iterch: Array[2, uint8]


def _iter_get(v: int32, i: uint64) -> int32:
    # The i-th item of an iterable: a list element, or a one-char string.
    t: int32 = val_type[cast[uint64](v)]
    if t == VT_LIST:
        return v_list_get(v, i)
    if t == VT_STR:
        s: Ptr[uint8] = str_ptr(cast[uint64](val_pay[cast[uint64](v)]))
        _iterch[0] = s[i]
        _iterch[1] = 0
        return v_str_ref(str_intern_n(&_iterch[0], 1))
    if t == VT_NS:
        # §19 (#111): the i-th bind/mount-point of a namespace.
        return v_list_get(_ns_binds_list(v), i)
    return 0


def _v_pair(a: int32, b: int32) -> int32:
    # A fresh 2-element list (a tuple) — built in isolation so its two
    # elements stay contiguous in the shared pool.
    p: int32 = v_list_begin()
    v_list_push(p, a)
    v_list_push(p, b)
    return p


def _list_from_comp(base: uint64) -> int32:
    # Materialise comp_out[base .. comp_out_n) into one contiguous VT_LIST.
    lst: int32 = v_list_begin()
    i: uint64 = base
    while i < comp_out_n:
        v_list_push(lst, comp_out[i])
        i = i + 1
    return lst


def _tuple_from_kids(node: int32) -> int32:
    # Evaluate a node's kid expressions and build a VT_LIST from the
    # results via the deferred comp_out stack — robust even when a kid is
    # itself a nested list/comprehension that pushes into the shared pool.
    base: uint64 = comp_out_n
    i: uint64 = 0
    nk: uint64 = nd_kn[cast[uint64](node)]
    while i < nk:
        el: int32 = eval_expr(nd_kid_at(node, i))
        if comp_out_n < COMP_MAX:
            comp_out[comp_out_n] = el
            comp_out_n = comp_out_n + 1
        i = i + 1
    lst: int32 = _list_from_comp(base)
    comp_out_n = base
    return lst


def _comp_bind(clause: int32, el: int32):
    # Bind a for-clause's target(s) to iterable element `el`. One target
    # = direct bind; many = unpack `el` (a list/tuple) element-wise.
    ntar: uint64 = nd_kn[cast[uint64](clause)]
    if ntar == 1:
        scope_set(nd_str[cast[uint64](nd_kid_at(clause, 0))], el)
        return
    j: uint64 = 0
    while j < ntar:
        tv: int32 = 0
        if cast[uint64](j) < _iter_count(el):
            tv = _iter_get(el, j)
        scope_set(nd_str[cast[uint64](nd_kid_at(clause, j))], tv)
        j = j + 1


def _comp_run(comp: int32, ci: uint64, is_dict: int32):
    # Recursive comprehension driver: walk the clause list, and at the
    # innermost level emit the element (list) or key/value pair (dict).
    nc: uint64 = nd_kn[cast[uint64](comp)]
    if ci >= nc:
        if is_dict != 0:
            kk: int32 = eval_expr(nd_a[cast[uint64](comp)])
            vv: int32 = eval_expr(nd_b[cast[uint64](comp)])
            if comp_dn < COMP_MAX:
                comp_key[comp_dn] = kk
                comp_val[comp_dn] = vv
                comp_dn = comp_dn + 1
        else:
            e: int32 = eval_expr(nd_a[cast[uint64](comp)])
            if comp_out_n < COMP_MAX:
                comp_out[comp_out_n] = e
                comp_out_n = comp_out_n + 1
        return
    clause: int32 = nd_kid_at(comp, ci)
    if nd_kind[cast[uint64](clause)] == ND_COMPIF:
        cond: int32 = eval_expr(nd_a[cast[uint64](clause)])
        if v_is_truthy(cond) != 0:
            _comp_run(comp, ci + 1, is_dict)
        return
    # ND_COMPFOR
    iter: int32 = eval_expr(nd_a[cast[uint64](clause)])
    n: uint64 = _iter_count(iter)
    i: uint64 = 0
    while i < n:
        _comp_bind(clause, _iter_get(iter, i))
        _comp_run(comp, ci + 1, is_dict)
        i = i + 1


def eval_listcomp(node: int32) -> int32:
    base: uint64 = comp_out_n
    _comp_run(node, 0, 0)
    lst: int32 = _list_from_comp(base)
    comp_out_n = base
    return lst


def eval_dictcomp(node: int32) -> int32:
    base: uint64 = comp_dn
    _comp_run(node, 0, 1)
    d: int32 = v_new(VT_DICT)
    val_es[cast[uint64](d)] = val_elem_cursor
    val_ec[cast[uint64](d)] = 0
    i: uint64 = base
    while i < comp_dn:
        if val_elem_cursor + 1 < LISTELEM_MAX:
            val_elem[val_elem_cursor] = comp_key[i]
            val_elem[val_elem_cursor + 1] = comp_val[i]
            val_elem_cursor = val_elem_cursor + 2
            val_ec[cast[uint64](d)] = val_ec[cast[uint64](d)] + 1
        i = i + 1
    comp_dn = base
    return d


def _slice_clamp(i: int64, ln: int64, step: int64) -> int64:
    # CPython PySlice_AdjustIndices clamping for one bound.
    if i < 0:
        i = i + ln
        if i < 0:
            if step < 0:
                i = -1
            else:
                i = 0
    elif i >= ln:
        if step < 0:
            i = ln - 1
        else:
            i = ln
    return i


_slice_buf: Array[1024, uint8]


def eval_slice(cont: int32, sn: int32) -> int32:
    # Evaluate `cont[lo:hi:step]` for a VT_LIST or VT_STR. Negative
    # indices and a negative step (`s[::-1]`) follow Python semantics.
    t: int32 = val_type[cast[uint64](cont)]
    if t != VT_LIST and t != VT_STR:
        return 0
    ln: int64 = cast[int64](_iter_count(cont))
    nu: uint64 = cast[uint64](sn)
    flags: int64 = nd_i[nu]
    step: int64 = 1
    if (flags & 4) != 0:
        step = _val_as_int(eval_expr(nd_c[nu]))
        if step == 0:
            step = 1
    start: int64 = 0
    stop: int64 = ln
    if step < 0:
        start = ln - 1
        stop = -1
    if (flags & 1) != 0:
        start = _slice_clamp(_val_as_int(eval_expr(nd_a[nu])), ln, step)
    if (flags & 2) != 0:
        stop = _slice_clamp(_val_as_int(eval_expr(nd_b[nu])), ln, step)
    if t == VT_STR:
        s: Ptr[uint8] = str_ptr(cast[uint64](val_pay[cast[uint64](cont)]))
        out: uint64 = 0
        k: int64 = start
        while (step > 0 and k < stop) or (step < 0 and k > stop):
            if out + 1 < 1024:
                _slice_buf[out] = s[cast[uint64](k)]
                out = out + 1
            k = k + step
        return v_str_ref(str_intern_n(&_slice_buf[0], out))
    base: uint64 = comp_out_n
    k2: int64 = start
    while (step > 0 and k2 < stop) or (step < 0 and k2 > stop):
        if comp_out_n < COMP_MAX:
            comp_out[comp_out_n] = v_list_get(cont, cast[uint64](k2))
            comp_out_n = comp_out_n + 1
        k2 = k2 + step
    lst: int32 = _list_from_comp(base)
    comp_out_n = base
    return lst


# Two scratch buffers for a stable string comparison during sorted().
_cmp_a: Array[256, uint8]
_cmp_b: Array[256, uint8]
# Parallel key column for `sorted(seq, key=FN)`: sort_key[i] holds the
# comparison key computed for comp_out[i], carried alongside it through
# the selection sort so the ELEMENTS end up ordered by their keys.
sort_key: Array[4096, int32]


def _call_user_fn1(nameref: uint64, argval: int32) -> int32:
    # Apply a user-defined function to ONE pre-evaluated argument value
    # (the machinery of call_user_fn, but the arg is already a value —
    # used by `sorted(key=FN)`). Unknown name → identity (returns arg).
    np: Ptr[uint8] = str_ptr(nameref)
    fi: uint64 = 0
    found: int64 = -1
    while fi < fn_count:
        if cstr_eq(&fn_name[fi * FN_NAME_MAX], np) != 0:
            found = cast[int64](fi)
            break
        fi = fi + 1
    if found < 0:
        return argval
    if call_depth >= CALL_DEPTH_MAX:
        return argval
    defnode: int32 = fn_node[cast[uint64](found)]
    dnu: uint64 = cast[uint64](defnode)
    mark: int32 = scope_push_frame()
    nparams: uint64 = nd_kn[defnode]
    if nparams >= 1:
        scope_set(nd_str[cast[uint64](nd_kid_at(defnode, 0))], argval)
    pi: uint64 = 1
    while pi < nparams:
        scope_set(nd_str[cast[uint64](nd_kid_at(defnode, pi))], 0)
        pi = pi + 1
    eval_retval = 0
    call_depth = call_depth + 1
    ex: int32 = exec_block(nd_b[dnu])
    call_depth = call_depth - 1
    rv: int32 = 0
    if ex == EX_RETURN:
        rv = eval_retval
    scope_pop_frame(mark)
    return rv


def _apply_fn_name(nameref: uint64, argval: int32) -> int32:
    # Apply the function NAMED `nameref` to one value — the `key=` hook.
    # Handles the common single-arg builtins directly, then falls back to
    # a user-defined function (identity if the name is unknown).
    np: Ptr[uint8] = str_ptr(nameref)
    if cstr_eq(np, "len") != 0:
        t: int32 = val_type[cast[uint64](argval)]
        if t == VT_LIST or t == VT_DICT:
            return v_int(cast[int64](val_ec[cast[uint64](argval)]))
        if t == VT_STR:
            return v_int(cast[int64](
                str_len(cast[uint64](val_pay[cast[uint64](argval)]))))
        return v_int(0)
    if cstr_eq(np, "int") != 0:
        return v_int(_val_as_int(argval))
    if cstr_eq(np, "float") != 0:
        return v_float(_val_as_float(argval))
    if cstr_eq(np, "str") != 0:
        return v_str_cstr(v_render_str_only(argval))
    if cstr_eq(np, "abs") != 0:
        if _v_is_float(argval) != 0:
            return v_float(_f_abs(val_f[cast[uint64](argval)]))
        x: int64 = _val_as_int(argval)
        if x < 0:
            return v_int(-x)
        return v_int(x)
    if cstr_eq(np, "upper") != 0:
        return v_str_case(argval, 1)
    if cstr_eq(np, "lower") != 0:
        return v_str_case(argval, 0)
    if cstr_eq(np, "strip") != 0:
        return v_str_strip(argval)
    return _call_user_fn1(nameref, argval)


def _v_less(a: int32, b: int32) -> int32:
    # Ordering predicate for sorted()/min()/max(): numeric when both are
    # int/bool, else lexicographic on the rendered strings.
    ta: int32 = val_type[cast[uint64](a)]
    tb: int32 = val_type[cast[uint64](b)]
    # §Float: any numeric pair (int/bool/float) orders numerically; a
    # float on either side promotes both to double.
    if ta == VT_FLOAT or tb == VT_FLOAT:
        if (ta == VT_INT or ta == VT_BOOL or ta == VT_FLOAT) \
                and (tb == VT_INT or tb == VT_BOOL or tb == VT_FLOAT):
            if _val_as_float(a) < _val_as_float(b):
                return 1
            return 0
    if (ta == VT_INT or ta == VT_BOOL) and (tb == VT_INT or tb == VT_BOOL):
        if _val_as_int(a) < _val_as_int(b):
            return 1
        return 0
    pa: Ptr[uint8] = v_render_str_only(a)
    i: uint64 = 0
    while pa[i] != 0 and i + 1 < 256:
        _cmp_a[i] = pa[i]
        i = i + 1
    _cmp_a[i] = 0
    pb: Ptr[uint8] = v_render_str_only(b)
    j: uint64 = 0
    while pb[j] != 0 and j + 1 < 256:
        _cmp_b[j] = pb[j]
        j = j + 1
    _cmp_b[j] = 0
    p: uint64 = 0
    while _cmp_a[p] != 0 and _cmp_b[p] != 0:
        if _cmp_a[p] < _cmp_b[p]:
            return 1
        if _cmp_a[p] > _cmp_b[p]:
            return 0
        p = p + 1
    if _cmp_a[p] == 0 and _cmp_b[p] != 0:
        return 1
    return 0


def _kwarg_node(node: int32, name: Ptr[uint8]) -> int32:
    # Return the VALUE node of the keyword argument `name` on this call,
    # or 0 if absent. Kwargs are the ND_KWARG kids appended after the
    # positional args; nd_c[call] records how many there are.
    nu: uint64 = cast[uint64](node)
    kwn: uint64 = cast[uint64](nd_c[nu])
    tot: uint64 = nd_kn[nu]
    i: uint64 = tot - kwn
    while i < tot:
        kw: int32 = nd_kid_at(node, i)
        if nd_kind[cast[uint64](kw)] == ND_KWARG \
                and cstr_eq(str_ptr(nd_str[cast[uint64](kw)]), name) != 0:
            return nd_a[cast[uint64](kw)]
        i = i + 1
    return 0


def eval_call(node: int32) -> int32:
    # Built-in expression functions + user-defined functions.
    nu: uint64 = cast[uint64](node)
    fname: Ptr[uint8] = str_ptr(nd_str[nu])
    # Positional arity EXCLUDES trailing keyword args (nd_c = kwarg count).
    nargs: uint64 = nd_kn[nu] - cast[uint64](nd_c[nu])
    # len(x)
    if cstr_eq(fname, "len") != 0:
        if nargs >= 1:
            a: int32 = eval_expr(nd_kid_at(node, 0))
            t: int32 = val_type[cast[uint64](a)]
            if t == VT_LIST or t == VT_DICT:
                return v_int(cast[int64](val_ec[cast[uint64](a)]))
            if t == VT_STR:
                return v_int(cast[int64](
                    str_len(cast[uint64](val_pay[cast[uint64](a)]))))
        return v_int(0)
    # int(x) / float(x) / str(x)
    if cstr_eq(fname, "int") != 0:
        if nargs >= 1:
            return v_int(_val_as_int(eval_expr(nd_kid_at(node, 0))))
        return v_int(0)
    # float(x): int/bool widened, float passed through, string parsed.
    if cstr_eq(fname, "float") != 0:
        if nargs >= 1:
            return v_float(_val_as_float(eval_expr(nd_kid_at(node, 0))))
        return v_float(0.0)
    if cstr_eq(fname, "str") != 0:
        if nargs >= 1:
            a: int32 = eval_expr(nd_kid_at(node, 0))
            return v_str_cstr(v_render_str_only(a))
        return v_str_ref(0)
    # lines(x): split a string on '\n' into a list (the §8 converter).
    if cstr_eq(fname, "lines") != 0:
        if nargs >= 1:
            a: int32 = eval_expr(nd_kid_at(node, 0))
            return v_split_lines(a)
        return v_list_begin()
    # upper(s) / lower(s): ASCII case fold.
    if cstr_eq(fname, "upper") != 0:
        if nargs >= 1:
            return v_str_case(eval_expr(nd_kid_at(node, 0)), 1)
        return v_str_ref(0)
    if cstr_eq(fname, "lower") != 0:
        if nargs >= 1:
            return v_str_case(eval_expr(nd_kid_at(node, 0)), 0)
        return v_str_ref(0)
    # strip(s): trim surrounding whitespace.
    if cstr_eq(fname, "strip") != 0:
        if nargs >= 1:
            return v_str_strip(eval_expr(nd_kid_at(node, 0)))
        return v_str_ref(0)
    # split(s, sep) -> list.
    if cstr_eq(fname, "split") != 0:
        if nargs >= 2:
            sv: int32 = eval_expr(nd_kid_at(node, 0))
            spv: int32 = eval_expr(nd_kid_at(node, 1))
            return v_str_split(sv, spv)
        return v_list_begin()
    # join(list, sep) -> str. Order-agnostic so BOTH the function form
    # `join(list, sep)` and the Python method form `sep.join(list)`
    # (desugared to `join(sep, list)`) work: whichever argument is the
    # list is the sequence, the other is the separator.
    if cstr_eq(fname, "join") != 0:
        if nargs >= 2:
            a0: int32 = eval_expr(nd_kid_at(node, 0))
            a1: int32 = eval_expr(nd_kid_at(node, 1))
            if val_type[cast[uint64](a0)] == VT_LIST:
                return v_str_join(a0, a1)
            return v_str_join(a1, a0)
        return v_str_ref(0)
    # replace(s, old, new) -> str.
    if cstr_eq(fname, "replace") != 0:
        if nargs >= 3:
            sv: int32 = eval_expr(nd_kid_at(node, 0))
            ov: int32 = eval_expr(nd_kid_at(node, 1))
            nv: int32 = eval_expr(nd_kid_at(node, 2))
            return v_str_replace(sv, ov, nv)
        return v_str_ref(0)
    # find(s, sub) -> int index or -1.
    if cstr_eq(fname, "find") != 0:
        if nargs >= 2:
            sv: int32 = eval_expr(nd_kid_at(node, 0))
            subv: int32 = eval_expr(nd_kid_at(node, 1))
            return v_int(v_str_find(sv, subv))
        return v_int(-1)
    # count(s, sub) -> occurrence count.
    if cstr_eq(fname, "count") != 0:
        if nargs >= 2:
            sv: int32 = eval_expr(nd_kid_at(node, 0))
            subv: int32 = eval_expr(nd_kid_at(node, 1))
            return v_int(v_str_count(sv, subv))
        return v_int(0)
    # startswith(s, prefix) -> bool.
    if cstr_eq(fname, "startswith") != 0:
        if nargs >= 2:
            sv: int32 = eval_expr(nd_kid_at(node, 0))
            pv: int32 = eval_expr(nd_kid_at(node, 1))
            return v_bool(v_str_startswith(sv, pv))
        return v_bool(0)
    # endswith(s, suffix) -> bool.
    if cstr_eq(fname, "endswith") != 0:
        if nargs >= 2:
            sv: int32 = eval_expr(nd_kid_at(node, 0))
            sufv: int32 = eval_expr(nd_kid_at(node, 1))
            return v_bool(v_str_endswith(sv, sufv))
        return v_bool(0)
    # abs(x) — preserves the argument's numeric type (float stays float).
    if cstr_eq(fname, "abs") != 0:
        if nargs >= 1:
            av: int32 = eval_expr(nd_kid_at(node, 0))
            if _v_is_float(av) != 0:
                return v_float(_f_abs(val_f[cast[uint64](av)]))
            x: int64 = _val_as_int(av)
            if x < 0:
                return v_int(-x)
            return v_int(x)
        return v_int(0)
    # range(stop) / range(start, stop) / range(start, stop, step)
    if cstr_eq(fname, "range") != 0:
        start: int64 = 0
        stop: int64 = 0
        step: int64 = 1
        if nargs == 1:
            stop = _val_as_int(eval_expr(nd_kid_at(node, 0)))
        elif nargs >= 2:
            start = _val_as_int(eval_expr(nd_kid_at(node, 0)))
            stop = _val_as_int(eval_expr(nd_kid_at(node, 1)))
            if nargs >= 3:
                step = _val_as_int(eval_expr(nd_kid_at(node, 2)))
        if step == 0:
            step = 1
        base: uint64 = comp_out_n
        r: int64 = start
        guard: int64 = 0
        while ((step > 0 and r < stop) or (step < 0 and r > stop)) \
                and guard < 1000000:
            if comp_out_n < COMP_MAX:
                comp_out[comp_out_n] = v_int(r)
                comp_out_n = comp_out_n + 1
            r = r + step
            guard = guard + 1
        rl: int32 = _list_from_comp(base)
        comp_out_n = base
        return rl
    # enumerate(iterable) -> list of [i, elem]
    if cstr_eq(fname, "enumerate") != 0:
        if nargs >= 1:
            a: int32 = eval_expr(nd_kid_at(node, 0))
            eb: uint64 = comp_out_n
            en: uint64 = _iter_count(a)
            ei: uint64 = 0
            while ei < en:
                pr: int32 = _v_pair(v_int(cast[int64](ei)), _iter_get(a, ei))
                if comp_out_n < COMP_MAX:
                    comp_out[comp_out_n] = pr
                    comp_out_n = comp_out_n + 1
                ei = ei + 1
            el: int32 = _list_from_comp(eb)
            comp_out_n = eb
            return el
        return v_list_begin()
    # zip(a, b, ...) -> list of tuples, truncated to the shortest input
    if cstr_eq(fname, "zip") != 0:
        zv: Array[16, int32]
        minlen: uint64 = 0
        zj: uint64 = 0
        while zj < nargs and zj < 16:
            zv[zj] = eval_expr(nd_kid_at(node, zj))
            zl: uint64 = _iter_count(zv[zj])
            if zj == 0 or zl < minlen:
                minlen = zl
            zj = zj + 1
        zb: uint64 = comp_out_n
        zi: uint64 = 0
        while zi < minlen:
            tup: int32 = v_list_begin()
            zk: uint64 = 0
            while zk < nargs and zk < 16:
                v_list_push(tup, _iter_get(zv[zk], zi))
                zk = zk + 1
            if comp_out_n < COMP_MAX:
                comp_out[comp_out_n] = tup
                comp_out_n = comp_out_n + 1
            zi = zi + 1
        zres: int32 = _list_from_comp(zb)
        comp_out_n = zb
        return zres
    # sum(list) -> integer sum, or a FLOAT sum if any element is a float.
    if cstr_eq(fname, "sum") != 0:
        if nargs >= 1:
            a: int32 = eval_expr(nd_kid_at(node, 0))
            sn: uint64 = _iter_count(a)
            anyf: int32 = 0
            si0: uint64 = 0
            while si0 < sn:
                if _v_is_float(_iter_get(a, si0)) != 0:
                    anyf = 1
                si0 = si0 + 1
            if anyf != 0:
                facc: float64 = 0.0
                sif: uint64 = 0
                while sif < sn:
                    facc = facc + _val_as_float(_iter_get(a, sif))
                    sif = sif + 1
                return v_float(facc)
            acc: int64 = 0
            si: uint64 = 0
            while si < sn:
                acc = acc + _val_as_int(_iter_get(a, si))
                si = si + 1
            return v_int(acc)
        return v_int(0)
    # min(list) / min(a, b, ...) — max(...) symmetric
    if cstr_eq(fname, "min") != 0:
        return _builtin_minmax(node, nargs, 1)
    if cstr_eq(fname, "max") != 0:
        return _builtin_minmax(node, nargs, 0)
    # sorted(iterable [, key=FN] [, reverse=BOOL]) -> new sorted list.
    # `key` names a function (builtin or user def) mapping each element
    # to its comparison key; `reverse` flips the final order.
    if cstr_eq(fname, "sorted") != 0:
        if nargs >= 1:
            a: int32 = eval_expr(nd_kid_at(node, 0))
            keynode: int32 = _kwarg_node(node, "key")
            keyname: uint64 = 0
            if keynode != 0 and nd_kind[cast[uint64](keynode)] == ND_VAR:
                keyname = nd_str[cast[uint64](keynode)]
            revnode: int32 = _kwarg_node(node, "reverse")
            revflag: int32 = 0
            if revnode != 0:
                revflag = v_is_truthy(eval_expr(revnode))
            sb: uint64 = comp_out_n
            cn: uint64 = _iter_count(a)
            ci: uint64 = 0
            while ci < cn:
                if comp_out_n < COMP_MAX:
                    el: int32 = _iter_get(a, ci)
                    comp_out[comp_out_n] = el
                    if keyname != 0:
                        sort_key[comp_out_n] = _apply_fn_name(keyname, el)
                    else:
                        sort_key[comp_out_n] = el
                    comp_out_n = comp_out_n + 1
                ci = ci + 1
            # selection sort over comp_out[sb .. comp_out_n), ordering by
            # the parallel sort_key column (elements ride along).
            x: uint64 = sb
            while x < comp_out_n:
                m: uint64 = x
                y: uint64 = x + 1
                while y < comp_out_n:
                    less: int32 = _v_less(sort_key[y], sort_key[m])
                    if revflag != 0:
                        less = _v_less(sort_key[m], sort_key[y])
                    if less != 0:
                        m = y
                    y = y + 1
                tmp: int32 = comp_out[x]
                comp_out[x] = comp_out[m]
                comp_out[m] = tmp
                tk: int32 = sort_key[x]
                sort_key[x] = sort_key[m]
                sort_key[m] = tk
                x = x + 1
            sl: int32 = _list_from_comp(sb)
            comp_out_n = sb
            return sl
        return v_list_begin()
    # reversed(iterable) -> reversed list, or reversed string for a str
    if cstr_eq(fname, "reversed") != 0:
        if nargs >= 1:
            a: int32 = eval_expr(nd_kid_at(node, 0))
            if val_type[cast[uint64](a)] == VT_STR:
                s: Ptr[uint8] = str_ptr(cast[uint64](val_pay[cast[uint64](a)]))
                ll: uint64 = str_len(cast[uint64](val_pay[cast[uint64](a)]))
                out: uint64 = 0
                while out < ll and out + 1 < 1024:
                    _slice_buf[out] = s[ll - 1 - out]
                    out = out + 1
                return v_str_ref(str_intern_n(&_slice_buf[0], out))
            rb: uint64 = comp_out_n
            rn: uint64 = _iter_count(a)
            ri: uint64 = rn
            while ri > 0:
                ri = ri - 1
                if comp_out_n < COMP_MAX:
                    comp_out[comp_out_n] = _iter_get(a, ri)
                    comp_out_n = comp_out_n + 1
            rl2: int32 = _list_from_comp(rb)
            comp_out_n = rb
            return rl2
        return v_list_begin()
    # list(x): copy a list, split a string into chars, or a dict's keys
    if cstr_eq(fname, "list") != 0:
        if nargs >= 1:
            a: int32 = eval_expr(nd_kid_at(node, 0))
            ta: int32 = val_type[cast[uint64](a)]
            lb2: uint64 = comp_out_n
            if ta == VT_DICT:
                dn: uint64 = val_ec[cast[uint64](a)]
                dbase: uint64 = val_es[cast[uint64](a)]
                di: uint64 = 0
                while di < dn:
                    if comp_out_n < COMP_MAX:
                        comp_out[comp_out_n] = val_elem[dbase + di * 2]
                        comp_out_n = comp_out_n + 1
                    di = di + 1
            else:
                ln2: uint64 = _iter_count(a)
                li: uint64 = 0
                while li < ln2:
                    if comp_out_n < COMP_MAX:
                        comp_out[comp_out_n] = _iter_get(a, li)
                        comp_out_n = comp_out_n + 1
                    li = li + 1
            ll2: int32 = _list_from_comp(lb2)
            comp_out_n = lb2
            return ll2
        return v_list_begin()
    # dict(): empty dict, or dict([[k,v], ...]) from a list of pairs
    if cstr_eq(fname, "dict") != 0:
        d: int32 = v_new(VT_DICT)
        val_es[cast[uint64](d)] = val_elem_cursor
        val_ec[cast[uint64](d)] = 0
        if nargs >= 1:
            a: int32 = eval_expr(nd_kid_at(node, 0))
            if val_type[cast[uint64](a)] == VT_LIST:
                pn: uint64 = val_ec[cast[uint64](a)]
                pi: uint64 = 0
                while pi < pn:
                    pair: int32 = v_list_get(a, pi)
                    if _iter_count(pair) >= 2 \
                            and val_elem_cursor + 1 < LISTELEM_MAX:
                        val_elem[val_elem_cursor] = _iter_get(pair, 0)
                        val_elem[val_elem_cursor + 1] = _iter_get(pair, 1)
                        val_elem_cursor = val_elem_cursor + 2
                        val_ec[cast[uint64](d)] = val_ec[cast[uint64](d)] + 1
                    pi = pi + 1
        return d
    # keys(d) / values(d) / items(d) — d.keys() etc via the method desugar
    # binds(ns) / mounts(ns) — introspect a namespace template's mount
    # points as a list of strings (also reached via `ns.binds()` /
    # `ns.mounts()` through the method-call desugar). §19 (#111).
    if cstr_eq(fname, "binds") != 0 or cstr_eq(fname, "mounts") != 0:
        if nargs >= 1:
            return _ns_binds_list(eval_expr(nd_kid_at(node, 0)))
        return v_list_begin()
    if cstr_eq(fname, "keys") != 0:
        return _dict_project(node, nargs, 0)
    if cstr_eq(fname, "values") != 0:
        return _dict_project(node, nargs, 1)
    if cstr_eq(fname, "items") != 0:
        return _dict_project(node, nargs, 2)
    # get(d, key, default=nil) — d.get(key, default)
    if cstr_eq(fname, "get") != 0:
        if nargs >= 2:
            d: int32 = eval_expr(nd_kid_at(node, 0))
            key: int32 = eval_expr(nd_kid_at(node, 1))
            deflt: int32 = 0
            if nargs >= 3:
                deflt = eval_expr(nd_kid_at(node, 2))
            if val_type[cast[uint64](d)] == VT_DICT:
                du: uint64 = cast[uint64](d)
                dn: uint64 = val_ec[du]
                db: uint64 = val_es[du]
                gi: uint64 = 0
                while gi < dn:
                    if _v_streq(val_elem[db + gi * 2], key) != 0:
                        return val_elem[db + gi * 2 + 1]
                    gi = gi + 1
            return deflt
        return 0
    # --- list mutation (xs.append/pop/insert via the method desugar) ---
    # append(xs, v): grow the list in place; returns nil. Aliases share.
    if cstr_eq(fname, "append") != 0:
        if nargs >= 2:
            xs: int32 = eval_expr(nd_kid_at(node, 0))
            ev: int32 = eval_expr(nd_kid_at(node, 1))
            v_list_append(xs, ev)
        return 0
    # pop(xs) -> last elem, or pop(xs, i) -> elem at i, removed.
    if cstr_eq(fname, "pop") != 0:
        if nargs >= 1:
            xs: int32 = eval_expr(nd_kid_at(node, 0))
            if val_type[cast[uint64](xs)] == VT_DICT:
                # dict.pop(key[, default])
                if nargs >= 2:
                    key: int32 = eval_expr(nd_kid_at(node, 1))
                    dfl: int32 = 0
                    if nargs >= 3:
                        dfl = eval_expr(nd_kid_at(node, 2))
                    return v_dict_pop(xs, key, dfl)
                return 0
            idx: int64 = cast[int64](val_ec[cast[uint64](xs)]) - 1
            if nargs >= 2:
                idx = _val_as_int(eval_expr(nd_kid_at(node, 1)))
            return v_list_pop(xs, idx)
        return 0
    # insert(xs, i, v): insert v before index i.
    if cstr_eq(fname, "insert") != 0:
        if nargs >= 3:
            xs: int32 = eval_expr(nd_kid_at(node, 0))
            iv: int64 = _val_as_int(eval_expr(nd_kid_at(node, 1)))
            ev: int32 = eval_expr(nd_kid_at(node, 2))
            v_list_insert(xs, iv, ev)
        return 0
    # --- dict mutation (d.setdefault/update via the method desugar) ---
    # setdefault(d, key, default=nil): return d[key], inserting default
    # (or nil) first if the key is absent.
    if cstr_eq(fname, "setdefault") != 0:
        if nargs >= 2:
            d: int32 = eval_expr(nd_kid_at(node, 0))
            key: int32 = eval_expr(nd_kid_at(node, 1))
            dfl: int32 = 0
            if nargs >= 3:
                dfl = eval_expr(nd_kid_at(node, 2))
            if val_type[cast[uint64](d)] == VT_DICT:
                fi: int64 = _dict_find(d, key)
                if fi >= 0:
                    return val_elem[val_es[cast[uint64](d)] \
                        + cast[uint64](fi) * 2 + 1]
                v_dict_set(d, key, dfl)
                return dfl
            return dfl
        return 0
    # update(d, other): copy every key,val pair of `other` into `d`.
    if cstr_eq(fname, "update") != 0:
        if nargs >= 2:
            d: int32 = eval_expr(nd_kid_at(node, 0))
            o: int32 = eval_expr(nd_kid_at(node, 1))
            if val_type[cast[uint64](d)] == VT_DICT \
                    and val_type[cast[uint64](o)] == VT_DICT:
                on: uint64 = val_ec[cast[uint64](o)]
                oi: uint64 = 0
                while oi < on:
                    ob: uint64 = val_es[cast[uint64](o)]
                    v_dict_set(d, val_elem[ob + oi * 2],
                               val_elem[ob + oi * 2 + 1])
                    oi = oi + 1
            return d
        return 0
    # user-defined function
    return call_user_fn(nd_str[nu], node)


def _builtin_minmax(node: int32, nargs: uint64, want_min: int32) -> int32:
    # min/max over a single iterable argument, or over the argument list.
    src: int32 = 0
    from_list: int32 = 0
    if nargs == 1:
        a: int32 = eval_expr(nd_kid_at(node, 0))
        if val_type[cast[uint64](a)] == VT_LIST \
                or val_type[cast[uint64](a)] == VT_STR:
            src = a
            from_list = 1
        else:
            return a
    n: uint64 = 0
    if from_list != 0:
        n = _iter_count(src)
    else:
        n = nargs
    if n == 0:
        return 0
    best: int32 = 0
    i: uint64 = 0
    while i < n:
        cur: int32 = 0
        if from_list != 0:
            cur = _iter_get(src, i)
        else:
            cur = eval_expr(nd_kid_at(node, i))
        if i == 0:
            best = cur
        else:
            lt: int32 = _v_less(cur, best)
            if want_min != 0:
                if lt != 0:
                    best = cur
            else:
                if _v_less(best, cur) != 0:
                    best = cur
        i = i + 1
    return best


def _dict_project(node: int32, nargs: uint64, mode: int32) -> int32:
    # mode 0=keys, 1=values, 2=items ([k,v] pairs) of a VT_DICT.
    if nargs < 1:
        return v_list_begin()
    d: int32 = eval_expr(nd_kid_at(node, 0))
    if val_type[cast[uint64](d)] != VT_DICT:
        return v_list_begin()
    du: uint64 = cast[uint64](d)
    n: uint64 = val_ec[du]
    db: uint64 = val_es[du]
    base: uint64 = comp_out_n
    i: uint64 = 0
    while i < n:
        item: int32 = 0
        if mode == 0:
            item = val_elem[db + i * 2]
        elif mode == 1:
            item = val_elem[db + i * 2 + 1]
        else:
            item = _v_pair(val_elem[db + i * 2], val_elem[db + i * 2 + 1])
        if comp_out_n < COMP_MAX:
            comp_out[comp_out_n] = item
            comp_out_n = comp_out_n + 1
        i = i + 1
    lst: int32 = _list_from_comp(base)
    comp_out_n = base
    return lst


def v_split_lines(v: int32) -> int32:
    # Split a string value into a list of line strings (no trailing
    # empty element for a final newline).
    lst: int32 = v_list_begin()
    if val_type[cast[uint64](v)] != VT_STR:
        return lst
    s: Ptr[uint8] = str_ptr(cast[uint64](val_pay[cast[uint64](v)]))
    n: uint64 = cstr_len(s)
    start: uint64 = 0
    p: uint64 = 0
    while p < n:
        if s[p] == 10:
            ref: uint64 = str_intern_n(
                cast[Ptr[uint8]](cast[uint64](s) + start), p - start)
            v_list_push(lst, v_str_ref(ref))
            start = p + 1
        p = p + 1
    if start < n:
        ref: uint64 = str_intern_n(
            cast[Ptr[uint8]](cast[uint64](s) + start), n - start)
        v_list_push(lst, v_str_ref(ref))
    return lst


# §14: a monotonically increasing counter for auto-generated mount
# labels. `m = mount $srv /n/r` (no inline `as`) still needs a stable
# handle the kernel can key on, so the shell synthesises one ("m1",
# "m2", …). The label is what `unmount $m` resolves to.
_mount_label_seq: uint64 = 0
_mount_label_buf: Array[16, uint8]


def _gen_mount_label() -> Ptr[uint8]:
    _mount_label_seq = _mount_label_seq + 1
    _mount_label_buf[0] = 109                # 'm'
    src: Ptr[uint8] = render_int(cast[int64](_mount_label_seq))
    i: uint64 = 0
    while src[i] != 0 and i + 2 < 16:
        _mount_label_buf[i + 1] = src[i]
        i = i + 1
    _mount_label_buf[i + 1] = 0
    return &_mount_label_buf[0]


_mount_expr_src:  Array[128, uint8]
_mount_expr_path: Array[128, uint8]
_mount_expr_lbl:  Array[32, uint8]


def _copy_cstr_into(dst: Ptr[uint8], cap: uint64, src: Ptr[uint8]):
    i: uint64 = 0
    while src[i] != 0 and i + 1 < cap:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0


def eval_mount_expr(node: int32) -> int32:
    # §14: evaluate a `mount … as L` EXPRESSION to a VT_MOUNT handle.
    # The handle carries (val_pay = creating nsid for the §13 boundary
    # check, val_aux = label str ref). On failure it sets $errstr and
    # returns nil — `try { m = mount … } except { }` keys off that.
    # The mount itself goes through the shared _do_mount engine, so the
    # expression form mounts a real 9P server exactly as the builtin
    # does (a server-program source is spawned over a socketpair).
    nu: uint64 = cast[uint64](node)
    srcv: int32 = eval_expr(nd_a[nu])
    pathv: int32 = eval_expr(nd_b[nu])
    # eval_expr / v_render_str_only share render scratch — copy each
    # rendered string straight into a stable buffer before the next.
    _copy_cstr_into(&_mount_expr_src[0], 128, v_render_str_only(srcv))
    _copy_cstr_into(&_mount_expr_path[0], 128, v_render_str_only(pathv))
    flag: int32 = cast[int32](nd_i[nu])
    # A label: the inline `as L` one, else a synthesised handle name.
    labelref: uint64 = nd_str[nu]
    if labelref != 0:
        _copy_cstr_into(&_mount_expr_lbl[0], 32, str_ptr(labelref))
    else:
        _copy_cstr_into(&_mount_expr_lbl[0], 32, _gen_mount_label())
        labelref = str_intern_cstr(&_mount_expr_lbl[0])
    if _do_mount(&_mount_expr_src[0], &_mount_expr_path[0],
                 flag, &_mount_expr_lbl[0]) < 0:
        eval_status = 1
        return 0
    h: int32 = v_new(VT_MOUNT)
    val_pay[cast[uint64](h)] = cast[int64](sys_nsid())
    val_aux[cast[uint64](h)] = cast[int64](labelref)
    eval_status = 0
    return h


def eval_expr(node: int32) -> int32:
    if node == 0:
        return 0
    nu: uint64 = cast[uint64](node)
    k: int32 = nd_kind[nu]
    if k == ND_MOUNT:
        return eval_mount_expr(node)
    if k == ND_INT:
        return v_int(nd_i[nu])
    if k == ND_FLOAT:
        return v_float(_parse_float_str(nd_str[nu]))
    if k == ND_FSTR:
        return eval_fstring(nd_str[nu])
    if k == ND_STR:
        return v_str_ref(nd_str[nu])
    if k == ND_WORD:
        return v_str_ref(nd_str[nu])
    if k == ND_ARGCAT:
        # Concatenate the rendered kids into ONE string value (argv
        # word). Built for an argument-position glued `=` — see
        # _parse_arg_assign_word.
        out: uint64 = 0
        i: uint64 = 0
        while i < nd_kn[nu]:
            part: int32 = eval_expr(nd_kid_at(node, i))
            out = _render_append(out, v_render_str_only(part))
            i = i + 1
        render_buf[out] = 0
        return v_str_ref(str_intern_n(&render_buf[0], out))
    if k == ND_STRI:
        return eval_str_interp(nd_str[nu])
    if k == ND_TRUE:
        return v_bool(1)
    if k == ND_FALSE:
        return v_bool(0)
    if k == ND_VAR:
        return eval_var_by_name(nd_str[nu])
    if k == ND_DOLEXPR:
        return eval_subexpr(nd_str[nu])
    if k == ND_BACKEXP:
        return capture_command(nd_str[nu])
    if k == ND_BINOP:
        return eval_binop(node)
    if k == ND_UNOP:
        op: int32 = cast[int32](nd_i[nu])
        a: int32 = eval_expr(nd_a[nu])
        if op == OP_MINUS:
            if _v_is_float(a) != 0:
                return v_float(0.0 - val_f[cast[uint64](a)])
            return v_int(-_val_as_int(a))
        if op == OP_NOT:
            if v_is_truthy(a) != 0:
                return v_bool(0)
            return v_bool(1)
        return a
    if k == ND_LIST:
        # Build via the deferred comp_out stack so a NESTED list literal
        # (`[[1,2],[3,4]]`) — whose inner build pushes into the shared
        # element pool — cannot scatter the outer list's elements.
        return _tuple_from_kids(node)
    if k == ND_TUPLE:
        return _tuple_from_kids(node)
    if k == ND_LISTCOMP:
        return eval_listcomp(node)
    if k == ND_DICTCOMP:
        return eval_dictcomp(node)
    if k == ND_DICT:
        d: int32 = v_new(VT_DICT)
        val_es[cast[uint64](d)] = val_elem_cursor
        val_ec[cast[uint64](d)] = 0
        i: uint64 = 0
        while i + 1 < nd_kn[nu]:
            key: int32 = eval_expr(nd_kid_at(node, i))
            value: int32 = eval_expr(nd_kid_at(node, i + 1))
            if val_elem_cursor + 1 < LISTELEM_MAX:
                val_elem[val_elem_cursor] = key
                val_elem[val_elem_cursor + 1] = value
                val_elem_cursor = val_elem_cursor + 2
                val_ec[cast[uint64](d)] = val_ec[cast[uint64](d)] + 1
            i = i + 2
        return d
    if k == ND_INDEX:
        cont: int32 = eval_expr(nd_a[nu])
        bnode: int32 = nd_b[nu]
        if nd_kind[cast[uint64](bnode)] == ND_SLICE:
            return eval_slice(cont, bnode)
        idx: int32 = eval_expr(bnode)
        ct: int32 = val_type[cast[uint64](cont)]
        if ct == VT_LIST:
            ii: int64 = _val_as_int(idx)
            ln: int64 = cast[int64](val_ec[cast[uint64](cont)])
            if ii < 0:
                ii = ii + ln                 # Python negative index
            if ii >= 0 and ii < ln:
                return v_list_get(cont, cast[uint64](ii))
            return 0
        if ct == VT_STR:
            si: int64 = _val_as_int(idx)
            sl: int64 = cast[int64](
                str_len(cast[uint64](val_pay[cast[uint64](cont)])))
            if si < 0:
                si = si + sl
            if si >= 0 and si < sl:
                sp: Ptr[uint8] = str_ptr(
                    cast[uint64](val_pay[cast[uint64](cont)]))
                _iterch[0] = sp[cast[uint64](si)]
                _iterch[1] = 0
                return v_str_ref(str_intern_n(&_iterch[0], 1))
            return 0
        if ct == VT_DICT:
            return dict_get(cont, idx)
        return 0
    if k == ND_CALL:
        return eval_call(node)
    return 0


def dict_get(d: int32, key: int32) -> int32:
    du: uint64 = cast[uint64](d)
    n: uint64 = val_ec[du]
    base: uint64 = val_es[du]
    i: uint64 = 0
    while i < n:
        k: int32 = val_elem[base + i * 2]
        if _v_streq(k, key) != 0:
            return val_elem[base + i * 2 + 1]
        i = i + 1
    return 0


# ====================================================================
# Command execution
# ====================================================================
# Building the argv for one command stage. §3's list-interpolation
# rule: when a list value interpolates into command position, EACH
# ELEMENT becomes EXACTLY ONE argument. No re-splitting, ever. A value
# containing spaces stays one argument.

# argv assembly arenas. The argv strings are interned; argv_ptr holds
# cstring pointers for spawn() (NULL-terminated).
argv_ptr:   Array[64, uint64]
argv_n:     uint64 = 0

# Globbing scratch.
glob_buf:   Array[1024, uint8]


def _argv_reset():
    argv_n = 0


def _argv_push_cstr(s: Ptr[uint8]):
    if argv_n + 1 >= ARGV_MAX:
        return
    # intern so the pointer survives val_reset
    ref: uint64 = str_intern_cstr(s)
    argv_ptr[argv_n] = cast[uint64](str_ptr(ref))
    argv_n = argv_n + 1


def _argv_push_value(v: int32):
    # §3 list-interpolation: a list contributes one argv entry PER
    # element; every other value contributes exactly one entry.
    if val_type[cast[uint64](v)] == VT_LIST:
        i: uint64 = 0
        n: uint64 = val_ec[cast[uint64](v)]
        while i < n:
            elem: int32 = v_list_get(v, i)
            _argv_push_cstr(v_render_str_only(elem))
            i = i + 1
        return
    if val_type[cast[uint64](v)] == VT_NS:
        # §19 (#111): a namespace flattens to its bind/mount-points — so
        # `for m in $ns` (the shell word-list loop) and `echo $ns` walk the
        # namespace like a collection, matching the expression-mode iterator.
        bl: int32 = _ns_binds_list(v)
        bi: uint64 = 0
        bn: uint64 = val_ec[cast[uint64](bl)]
        while bi < bn:
            _argv_push_cstr(v_render_str_only(v_list_get(bl, bi)))
            bi = bi + 1
        return
    _argv_push_cstr(v_render_str_only(v))


def _word_has_glob(s: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while s[i] != 0:
        c: uint8 = s[i]
        if c == 42 or c == 63:               # '*' '?'
            return 1
        i = i + 1
    return 0


def _argv_build(cmdnode: int32) -> int32:
    # Build argv from a command node's word kids. Returns argc.
    # A bare ND_WORD containing glob metacharacters expands against
    # the current namespace (the only implicit expansion, §4).
    _argv_reset()
    nu: uint64 = cast[uint64](cmdnode)
    i: uint64 = 0
    while i < nd_kn[nu]:
        kid: int32 = nd_kid_at(cmdnode, i)
        kk: int32 = nd_kind[cast[uint64](kid)]
        if kk == ND_WORD:
            wp: Ptr[uint8] = str_ptr(nd_str[cast[uint64](kid)])
            if _word_has_glob(wp) != 0:
                _argv_glob_expand(wp)
            else:
                _argv_push_cstr(wp)
        else:
            v: int32 = eval_expr(kid)
            _argv_push_value(v)
        i = i + 1
    argv_ptr[argv_n] = 0
    return cast[int32](argv_n)


def _argv_glob_expand(pattern: Ptr[uint8]):
    # Expand a glob against the current namespace. We do a directory
    # listing of the pattern's parent dir and match the leaf. If no
    # match, the literal pattern is kept (bash 'nullglob off' default).
    # Conservative: split off the dir prefix, listdir, fnmatch leaf.
    matched: int32 = _glob_try(pattern)
    if matched == 0:
        _argv_push_cstr(pattern)


# --- the /fd device + pipe/redirect/dup as bind (§7) ----------------
# A process's standard streams are NAMES in its namespace: /fd/0,
# /fd/1, /fd/2 — paths served by the `#d` device. /fd/N is the
# primary, substrate thing. The Linux integer fd 0/1/2/N is a Layer-2
# mapping ONTO the name /fd/N.
#
# Pipe, redirect, and dup are ALL the ONE operation — sys_fdbind: bind
# a Chan at an /fd/N name. There is no separate pipe mechanism,
# redirect mechanism, or dup mechanism:
#
#   a | b      sys_pipechan creates a local pipe Chan pair; the write
#              end is sys_fdbind'd at a's /fd/1, the read end at b's
#              /fd/0. (sys_pipechan → a devtab pipe, NOT a 9P byte-
#              buffer: a local pipe is direct Chan reads, zero
#              mountrpc — §6.)
#   cmd > file sys_open_write the file → a kernel fd; sys_fdbind it
#              (DEVFD_FILE) at cmd's /fd/1.
#   cmd 2>&1   sys_fdbind(cmd, 2, DEVFD_DUP, 1): bind whatever Chan is
#              already at the name /fd/1 ALSO at /fd/2.
#
# The shell spawns each command with SPAWN_STDIO_NS — the child gets a
# private COW namespace whose /fd table starts as a copy of the
# shell's (console at 0/1/2). The shell then rebinds the child's
# /fd/N for any pipe / redirect / dup BEFORE yielding to it (the
# cooperative scheduler guarantees the child is still STATE_READY).


# --- PATH resolution + spawn ----------------------------------------
spawn_path: Array[256, uint8]


def _path_prefix(i: int32) -> Ptr[uint8]:
    if i == 0:
        return "/bin/"
    if i == 1:
        return "/sbin/"
    if i == 2:
        return "/usr/bin/"
    if i == 3:
        return "/usr/sbin/"
    return cast[Ptr[uint8]](0)


# Build spawn_path = "<dir>/<cmd>" from a $PATH directory slice
# [dir, dir+dlen) and a NUL-terminated command name. A trailing '/' on
# the dir is tolerated (we add exactly one separator). Used by the
# $PATH-walking arm of spawn_resolved so `enter linux { sh }` resolves
# wherever the distro's $PATH points; Debian's usr-merge keeps dash at
# /usr/bin/dash with /bin/sh a symlink, which the static prefixes already
# catch, but a distro that advertises a non-standard dir on $PATH must
# still find its shell.
def _build_path_dir(dir: Ptr[uint8], dlen: uint64, cmd: Ptr[uint8]):
    pi: uint64 = 0
    di: uint64 = 0
    while di < dlen and pi + 1 < 256:
        spawn_path[pi] = dir[di]
        pi = pi + 1
        di = di + 1
    if pi == 0 or spawn_path[pi - 1] != 47:
        if pi + 1 < 256:
            spawn_path[pi] = 47                  # '/'
            pi = pi + 1
    ci: uint64 = 0
    while cmd[ci] != 0 and pi + 1 < 256:
        spawn_path[pi] = cmd[ci]
        pi = pi + 1
        ci = ci + 1
    spawn_path[pi] = 0


def _build_path(prefix: Ptr[uint8], cmd: Ptr[uint8]):
    pi: uint64 = 0
    if cast[uint64](prefix) != 0:
        while prefix[pi] != 0:
            spawn_path[pi] = prefix[pi]
            pi = pi + 1
    ci: uint64 = 0
    while cmd[ci] != 0 and pi + 1 < 256:
        spawn_path[pi] = cmd[ci]
        pi = pi + 1
        ci = ci + 1
    spawn_path[pi] = 0


# envp staging for spawn() — children inherit /env through it.
ENVP_STRIDE:  uint64 = 224
envp_strs:    Array[7168, uint8]   # 32 * 224
envp_ptrs:    Array[33, uint64]


def _build_envp() -> Ptr[uint64]:
    n: uint64 = 0
    i: uint64 = 0
    while i < ENV_MAX:
        if env_used[i] != 0:
            base: uint64 = n * ENVP_STRIDE
            envp_ptrs[n] = cast[uint64](&envp_strs[base])
            off: uint64 = 0
            nb: uint64 = i * ENV_NAME_MAX
            j: uint64 = 0
            while env_name[nb + j] != 0 and off + 1 < ENVP_STRIDE:
                envp_strs[base + off] = env_name[nb + j]
                off = off + 1
                j = j + 1
            if off + 1 < ENVP_STRIDE:
                envp_strs[base + off] = 61          # '='
                off = off + 1
            vb: uint64 = i * ENV_VAL_MAX
            k: uint64 = 0
            while env_val[vb + k] != 0 and off + 1 < ENVP_STRIDE:
                envp_strs[base + off] = env_val[vb + k]
                off = off + 1
                k = k + 1
            envp_strs[base + off] = 0
            n = n + 1
        i = i + 1
    envp_ptrs[n] = 0
    return cast[Ptr[uint64]](&envp_ptrs[0])


# BUG 2 FIX helper: does `path` name an openable file? The kernel spawn()
# forks-then-execs, so a missing binary fails only in the child's exec and
# spawn() still hands back a pid — making a bogus command run silently to a
# 127 exit with NO "command not found". Probing with sys_open lets
# spawn_resolved skip a non-existent candidate so it ultimately returns -1 and
# the caller prints the diagnostic. (A directory also opens; spawn would then
# fail, but for command resolution the file-exists gate is what matters.)
def _path_execable(path: Ptr[uint8]) -> int32:
    fd: int32 = sys_open(cast[Ptr[char]](path))
    if fd < 0:
        return 0
    sys_close(fd)
    return 1


# Pipe slots for the stage spawn_resolved is about to launch, or -1. Set
# by run_one_command_x immediately before the call; consumed by _spawn_at.
# Module scope rather than a parameter so the three PATH-resolution call
# sites below stay one-liners.
sr_in_pipe:  int32 = -1
sr_out_pipe: int32 = -1


def _spawn_at(path: Ptr[char], argv: Ptr[uint64],
              envp: Ptr[uint64]) -> int32:
    # Launch `path`. A PIPELINE STAGE goes through spawn_pipeline_stage,
    # which binds the child's /fd/0 and /fd/1 to the pipe ends CHILD-side,
    # before execve. The old shape — plain spawn() plus a parent-side
    # sys_fdbind(pid, …) after it returned — is a data race the moment a
    # second CPU exists: under KVM the child can execve and start writing
    # before the parent's bind lands, so its /fd/1 is still the inherited
    # CONSOLE and the pipe never receives a byte. See lib/p9.ad's
    # spawn_pipeline_stage header. The caller has already pinned the pipe
    # ends' refcounts at P9_PIPE_PIN_W / P9_PIPE_PIN_R.
    if sr_in_pipe >= 0 or sr_out_pipe >= 0:
        return spawn_pipeline_stage(path, argv, sr_in_pipe, sr_out_pipe, envp)
    return spawn(path, argv, SPAWN_STDIO_NS, SPAWN_STDIO_NS, envp)


def spawn_resolved(cmd: Ptr[uint8], argv: Ptr[uint64]) -> int32:
    # Resolve `cmd` to a path and spawn() it. A command containing
    # '/' is taken verbatim; otherwise PATH dirs are tried in order.
    #
    # HAMSH §7: stdio is ALWAYS spawned in namespace-bind mode
    # (SPAWN_STDIO_NS). The child gets a private COW namespace whose
    # /fd table is a copy of the shell's (console at 0/1/2); the
    # caller rebinds the child's /fd/N for any redirect / dup via
    # sys_fdbind AFTER this returns and BEFORE waiting on it. PIPE ends
    # are the exception — they are bound child-side by _spawn_at, because
    # a post-spawn parent bind races the child on SMP.
    envp: Ptr[uint64] = _build_envp()
    has_slash: int32 = 0
    i: uint64 = 0
    while cmd[i] != 0:
        if cmd[i] == 47:
            has_slash = 1
        i = i + 1
    if has_slash != 0:
        # BUG 2 FIX: only spawn if the path actually EXISTS. The kernel
        # spawn() forks then execs; a missing binary fails in the CHILD's
        # exec, so spawn() still returns a valid pid and the caller's
        # not-found path is never taken (the command runs silently to a
        # 127 exit). Probe with sys_open first so a missing path resolves
        # to -1 here and the caller prints "command not found".
        if _path_execable(cmd) == 0:
            return -1
        return _spawn_at(cast[Ptr[char]](cmd), argv, envp)
    # (1) Walk $PATH colon-separated dirs first, so a command resolves
    # wherever the active namespace's $PATH advertises it. Inside
    # `enter linux { sh }` the body inherits the shell's $PATH
    # (/bin:/sbin:/usr/bin) plus anything an rc / template set; an empty
    # $PATH entry ("::" or a leading/trailing ':') is skipped, NOT
    # treated as ".".
    pv: Ptr[uint8] = env_get(cast[Ptr[uint8]]("PATH"))
    if cast[uint64](pv) != 0 and pv[0] != 0:
        seg: uint64 = 0
        j: uint64 = 0
        while 1 != 0:
            c: uint8 = pv[j]
            if c == 58 or c == 0:                # ':' or end
                dlen: uint64 = j - seg
                if dlen != 0:
                    _build_path_dir(
                        cast[Ptr[uint8]](cast[uint64](pv) + seg), dlen, cmd)
                    # BUG 2 FIX: existence-gate the spawn (see has_slash case).
                    if _path_execable(cast[Ptr[uint8]](&spawn_path[0])) != 0:
                        pid: int32 = _spawn_at(
                            cast[Ptr[char]](&spawn_path[0]), argv, envp)
                        if pid >= 0:
                            return pid
                seg = j + 1
            if c == 0:
                break
            j = j + 1
    # (2) Static fallback prefixes — used when $PATH is unset (a clean
    # hermetic namespace that seeded no env) and as a belt-and-braces
    # catch for the merged-/usr Debian layout.
    pi: int32 = 0
    while pi < 4:
        _build_path(_path_prefix(pi), cmd)
        # BUG 2 FIX: existence-gate the spawn (see has_slash case).
        if _path_execable(cast[Ptr[uint8]](&spawn_path[0])) != 0:
            pid2: int32 = _spawn_at(
                cast[Ptr[char]](&spawn_path[0]), argv, envp)
            if pid2 >= 0:
                return pid2
        pi = pi + 1
    return -1


# ====================================================================
# Builtins (§15) — run in-process, mutate the AMBIENT namespace
# ====================================================================
# bind / mount / unmount / import / cd are composition verbs: they run
# in-process and their effect persists for later commands at the prompt.

def builtin_cd(argc: int32) -> int32:
    if argc < 2:
        # `cd` with no args -> $HOME (the per-user home set at login by
        # _set_home_from_passwd), falling back to "/" if HOME is unset.
        h: Ptr[uint8] = env_get(cast[Ptr[uint8]]("HOME"))
        if cast[uint64](h) != 0 and h[0] != 0:
            sys_chdir(cast[Ptr[char]](h))
        else:
            sys_chdir(cast[Ptr[char]]("/"))
        return 0
    rc: int32 = sys_chdir(cast[Ptr[char]](argv_ptr[1]))
    if rc < 0:
        errstr_pull_kernel()
        return 1
    return 0


# `pwd` — print the working directory. A BUILTIN (POSIX shape) rather than a
# spawn of /bin/pwd. Beyond correctness this is a cold-start latency win: the
# first `pwd` in a freshly-opened DE terminal used to cold-exec /bin/pwd off
# the root fs (a page/block-cache MISS -> disk read -> ~0.5s), the single most
# visible symptom of the "first terminal is laggy, second is fast" report. As a
# builtin it runs in-process with one SYS_GETCWD syscall — no image load, no
# file-cache dependency, fast on the very first invocation. Writes via
# write_cstr1 so an in-process redirect (`pwd > f`) still lands (builtins have
# their redirects wired before dispatch — see _builtin_dispatch_kind_check).
pwd_buf: Array[512, uint8]


def builtin_pwd(argc: int32) -> int32:
    n: int64 = sys_getcwd(&pwd_buf[0], 512)
    if n <= 0:
        errstr_pull_kernel()
        return 1
    # SYS_GETCWD returns bytes INCLUDING the trailing NUL, so the buffer is
    # already NUL-terminated (see user/find.ad / user/du.ad usage).
    write_cstr1(&pwd_buf[0])
    write_cstr1("\n")
    return 0


def _flag_word(s: Ptr[uint8]) -> int32:
    # Map a `-b` / `-a` option word to MBEFORE / MAFTER; -1 if `s` is
    # not a recognised union-flag word. `-b` and `-a` are the union
    # options `mount` takes (§14). The `-c` suffix forms (`-bc` / `-ac`)
    # additionally set MCREATE so a CREATE at a shared name lands in
    # THIS union member — the writable-overlay recipe
    # (`bind -bc '#t/usr' /usr`) needs the tmpfs member to claim creates
    # while still falling through to the cpio base on a read miss.
    if cstr_eq(s, "-b") != 0:
        return MBEFORE_FLAG
    if cstr_eq(s, "-a") != 0:
        return MAFTER_FLAG
    if cstr_eq(s, "-bc") != 0:
        return MBEFORE_FLAG | MCREATE_FLAG
    if cstr_eq(s, "-ac") != 0:
        return MAFTER_FLAG | MCREATE_FLAG
    if cstr_eq(s, "-c") != 0:
        return MREPL_FLAG | MCREATE_FLAG
    # #69: `-r` marks the binding READ-ONLY (kernel-enforced): reads
    # resolve normally, but any mutation through the view is denied with
    # EROFS. `-br` / `-ar` make a read-only UNION member.
    if cstr_eq(s, "-r") != 0:
        return MREPL_FLAG | MRDONLY_FLAG
    if cstr_eq(s, "-br") != 0:
        return MBEFORE_FLAG | MRDONLY_FLAG
    if cstr_eq(s, "-ar") != 0:
        return MAFTER_FLAG | MRDONLY_FLAG
    return -1


def builtin_bind(argc: int32) -> int32:
    # bind [-b|-a] SRC DST — graft SRC onto the lookup name DST in the
    # ambient namespace. Source-first order matches BOTH Linux's
    # `mount source target` AND Plan 9's `bind new old` (which is
    # source→target already; old "Plan 9 style" rc.boot snippets like
    # `bind /srv '#s'` were just a wrapper bug, not a real Plan 9
    # idiom — docs/rootfs_partition.md "Future direction").
    #
    # `-b`/`-a` request a union mount (§14); `-r` (or `-br`/`-ar`) marks
    # the binding kernel-enforced READ-ONLY (#69) — reads resolve but a
    # write / create / truncate / remove / rename through the view is
    # denied with EROFS. The underlying syscall
    # is `sys_bind(new=DST, old=SRC, flag)` — the kernel still uses
    # Plan 9's NEW=lookup-path / OLD=source naming internally; this
    # wrapper just flips the user-visible argument order.
    #
    # Inversion warning: if DST (arg2) starts with '#' AND SRC (arg1)
    # does NOT, the user probably typed the old `bind NEW OLD` form by
    # muscle memory. Warn loudly (stderr) but don't refuse — the call
    # still goes through with the args as typed.
    i: int32 = 1
    flag: int32 = MREPL_FLAG
    if i < argc:
        f: int32 = _flag_word(cast[Ptr[uint8]](argv_ptr[cast[uint64](i)]))
        if f >= 0:
            flag = f
            i = i + 1
    if i + 1 >= argc:
        errstr_set("bind: usage: bind [-b|-a|-c|-r] src dst  (-r: read-only view, EROFS on write)")
        return 1
    src_p: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[cast[uint64](i)])
    dst_p: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[cast[uint64](i + 1)])
    # Inversion check: arg2 starts with '#' and arg1 does not.
    if dst_p[0] == 35 and src_p[0] != 35:
        _hamsh_bind_warn(src_p, dst_p)
    # Pass SRC as `old` (the source) and DST as `new` (the lookup
    # path) to the syscall — see the comment above for why.
    rc: int32 = sys_bind(cast[Ptr[char]](dst_p),
                         cast[Ptr[char]](src_p), flag)
    if rc < 0:
        errstr_pull_kernel()
        return 1
    return 0


def _hamsh_bind_warn(src: Ptr[uint8], dst: Ptr[uint8]):
    # Emit "[hamsh-bind] WARN: argument order looks inverted — did
    # you mean 'bind <dst> <src>'?\n" to fd 2. We don't have format-
    # like printf, so the message is assembled by hand.
    prefix: Ptr[uint8] = cast[Ptr[uint8]]("[hamsh-bind] WARN: argument order looks inverted -- did you mean 'bind ")
    sys_write(2, prefix, cstr_len(prefix))
    sys_write(2, dst, cstr_len(dst))
    sp: Ptr[uint8] = cast[Ptr[uint8]](" ")
    sys_write(2, sp, 1)
    sys_write(2, src, cstr_len(src))
    tail: Ptr[uint8] = cast[Ptr[uint8]]("'?\n")
    sys_write(2, tail, 3)


def builtin_unmount(argc: int32) -> int32:
    # unmount LABEL          — by handle (§14): peel the one mount
    #                          carrying LABEL, even under a union stack.
    # unmount [NEW] OLD      — by path (Plan 9 unmount(2)).
    #
    # A single argument is tried as a LABEL first (the §14 handle
    # form); only if no entry carries that label do we fall back to
    # treating it as a path. Two arguments is always the path form.
    if argc < 2:
        errstr_set("unmount: usage: unmount label | [new] old")
        return 1
    if argc == 2:
        # Try the label form: unmount the entry carrying this handle.
        if sys_nslabel(1, cast[Ptr[char]](argv_ptr[1]),
                       cast[Ptr[char]](0), cast[Ptr[char]](0)) == 0:
            return 0
        # Not a label — fall back to the path form (unbind everything
        # visible at this path).
        rc: int32 = sys_unmount(cast[Ptr[char]](0),
                                cast[Ptr[char]](argv_ptr[1]))
        if rc < 0:
            errstr_pull_kernel()
            return 1
        return 0
    rc: int32 = sys_unmount(cast[Ptr[char]](argv_ptr[1]),
                            cast[Ptr[char]](argv_ptr[2]))
    if rc < 0:
        errstr_pull_kernel()
        return 1
    return 0


def _str_is_numeric(s: Ptr[uint8]) -> int32:
    # 1 iff `s` is a non-empty run of decimal digits — i.e. a literal
    # srvfd rather than a `/srv/<name>` path.
    if s[0] == 0:
        return 0
    i: uint64 = 0
    while s[i] != 0:
        if s[i] < 48 or s[i] > 57:
            return 0
        i = i + 1
    return 1


def _srv_name_of(src: Ptr[uint8]) -> Ptr[uint8]:
    # If `src` is a `/srv/<name>` path, return a pointer past the
    # "/srv/" prefix (the bare posted name `sys_srv_open` wants).
    # Returns NULL if `src` is not a /srv path.
    if src[0] == 47 and src[1] == 115 and src[2] == 114 \
            and src[3] == 118 and src[4] == 47:        # "/srv/"
        return cast[Ptr[uint8]](cast[uint64](src) + 5)
    return cast[Ptr[uint8]](0)


def _do_mount(src: Ptr[uint8], path: Ptr[uint8], flag: int32,
              label: Ptr[uint8]) -> int32:
    # The shared mount engine (§15) behind both `mount` the builtin and
    # the `mount … as L` expression. `mount` only ever consumes a
    # SRVFD — `src` is one of:
    #   * a decimal srvfd        — an already-open 9P connection;
    #   * a `/srv/<name>` path   — a 9P server posted on the kernel
    #                              srv table; sys_srv_open resolves
    #                              the name to a fresh srvfd here.
    # The shell never spawns the server itself: `spawn` the server (it
    # posts to /srv/<name>), THEN `mount /srv/<name> …`. On success a
    # non-NULL `label` is stamped onto the new mount entry (§14).
    # Returns 0 on success, -1 on failure (errstr set).
    srvfd: int32 = -1
    if _str_is_numeric(src) != 0:
        srvfd = cast[int32](_parse_dec(src))
    else:
        nm: Ptr[uint8] = _srv_name_of(src)
        if cast[uint64](nm) == 0:
            errstr_set("mount: source must be a srvfd or /srv/<name>")
            return -1
        srvfd = sys_srv_open(cast[Ptr[char]](nm))
        if srvfd < 0:
            errstr_pull_kernel()
            return -1
    rc: int32 = sys_mount(srvfd, -1, cast[Ptr[char]](path),
                          flag, cast[Ptr[char]](0))
    if rc < 0:
        errstr_pull_kernel()
        return -1
    if cast[uint64](label) != 0:
        sys_nslabel(0, cast[Ptr[char]](label),
                    cast[Ptr[char]](path), cast[Ptr[char]](0))
    return 0


def builtin_mount(argc: int32) -> int32:
    # mount [-b|-a] SRC OLD [as LABEL] — attach a 9P file server at the
    # path OLD (§15). SRC is a decimal srvfd, or a `/srv/<name>` path
    # naming a posted 9P server. `-b`/`-a` request a union mount (§14);
    # `as LABEL` stamps a stable handle so `cat /proc/self/ns` names
    # this branch and `unmount LABEL` peels exactly it. A failed mount
    # pulls the kernel's errstr through — which `try { mount … }
    # except { }` keys off (§16). Returns 0 on success, 1 on failure.
    i: int32 = 1
    flag: int32 = MREPL_FLAG
    if i < argc:
        f: int32 = _flag_word(cast[Ptr[uint8]](argv_ptr[cast[uint64](i)]))
        if f >= 0:
            flag = f
            i = i + 1
    if i + 1 >= argc:
        errstr_set("mount: usage: mount [-b|-a] src path [as label]")
        return 1
    src: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[cast[uint64](i)])
    path: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[cast[uint64](i + 1)])
    # optional `as LABEL`
    label: Ptr[uint8] = cast[Ptr[uint8]](0)
    if i + 3 <= argc:
        aw: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[cast[uint64](i + 2)])
        if cstr_eq(aw, "as") != 0:
            label = cast[Ptr[uint8]](argv_ptr[cast[uint64](i + 3)])
    if _do_mount(src, path, flag, label) < 0:
        return 1
    return 0


def builtin_export(argc: int32) -> int32:
    # export NAME=VALUE  (or  export NAME  to export an existing var)
    if argc < 2:
        return 0
    i: int32 = 1
    while i < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[cast[uint64](i)])
        # split on first '='
        eq: int64 = -1
        j: uint64 = 0
        while a[j] != 0:
            if a[j] == 61 and eq < 0:
                eq = cast[int64](j)
            j = j + 1
        if eq >= 0:
            nm: Array[32, uint8]
            k: uint64 = 0
            while k < cast[uint64](eq) and k + 1 < 32:
                nm[k] = a[k]
                k = k + 1
            nm[k] = 0
            env_set(&nm[0], &a[cast[uint64](eq) + 1])
        else:
            # export an existing shell variable's string form
            ref: uint64 = str_intern_cstr(a)
            if scope_has(ref) != 0:
                vv: int32 = scope_get(ref)
                env_set(a, v_render_str_only(vv))
        i = i + 1
    return 0


def builtin_echo(argc: int32) -> int32:
    i: int32 = 1
    while i < argc:
        if i > 1:
            write_cstr1(" ")
        write_cstr1(cast[Ptr[uint8]](argv_ptr[cast[uint64](i)]))
        i = i + 1
    write_cstr1("\n")
    return 0


# ====================================================================
# `hamui` builtin — drive the lib/hamui.ad GUI toolkit from hamsh.
# ====================================================================
# A single verb whose first argument selects a toolkit operation. The
# constructor subcommands print the new widget id (a small int) on its
# own line so a script can capture it into a shell variable via command
# substitution:  btn = { hamui button "OK" }
# State/event readers print the queried int the same way, so a script
# branches on them with ordinary `if`. Everything maps 1:1 onto a
# lib/hamui.ad call, keeping the binding thin and the toolkit the single
# source of truth.
#
# Subcommands:
#   hamui init
#   hamui vbox | hbox | grid | fixed            -> id
#   hamui label TEXT | button TEXT | checkbox TEXT
#   hamui entry                                 -> id
#   hamui statusbar TEXT | dialog TITLE         -> id
#   hamui list | combo | menubar | toolbar      -> id
#   hamui textview | notebook                   -> id
#   hamui menu TITLE                            -> id
#   hamui menu-add MENU LABEL                   -> id
#   hamui notebook-page NB TITLE               -> id
#   hamui treeview COLS                         -> id
#   hamui treeview-add TREE TEXT
#   hamui textview-set ID TEXT
#   hamui list-add ID TEXT | combo-add ID TEXT
#   hamui progress                              -> id
#   hamui slider MIN MAX VAL | spin MIN MAX VAL -> id
#   hamui separator [VERT]                      -> id
#   hamui add PARENT CHILD
#   hamui text ID TEXT | size ID W H
#   hamui align ID HALIGN VALIGN | expand ID HX VX
#   hamui value ID [V] | range ID MIN MAX
#   hamui window ROOT [WID]                      -> wid
#   hamui show ID | hide ID | destroy ID
#   hamui render | step | run | event
#   hamui checked ID | selected ID | combo-sel ID | tree-sel ID
#   hamui entry-text ID | signalled ID
#   hamui calendar                               -> id
#   hamui calendar-sel ID                        -> prints YYYY-MM-DD
#   hamui tooltip ID TEXT
#   hamui alert TITLE TEXT                       -> prints 1 (dismissed)
#   hamui confirm TITLE TEXT                     -> prints 1=OK / 0=Cancel
#   hamui filechooser TITLE [STARTDIR]           -> prints chosen path
#                                                   (empty line on cancel)
#
# `event` drains hamui_take_event() and prints the fired widget id
# (-1 when the queue is empty) — the script loop's branch key.
#
# `alert`, `confirm` and `filechooser` are the toolkit's MODAL dialogs:
# they block inside lib/hamui.ad's *_run loop (hamui_step + sys_yield,
# exactly what `hamui run` does) until the user decides, then return
# here. The script needs no event loop of its own around them — but the
# tree must already be bound to a window (`hamui window ROOT`) so the
# overlay has somewhere to paint.

# Helper: render an int to stdout followed by a newline (id / state out).
def _hamui_emit_int(v: int64):
    write_cstr1(render_int(v))
    write_cstr1("\n")


# Fetch argv[idx] as a Ptr[uint8] (no bounds error: caller checks argc).
def _hamui_arg(idx: int32) -> Ptr[uint8]:
    return cast[Ptr[uint8]](argv_ptr[cast[uint64](idx)])


# Fetch argv[idx] parsed as a decimal int32.
def _hamui_argi(idx: int32) -> int32:
    return cast[int32](_parse_dec(_hamui_arg(idx)))


# `hamui calendar-sel` scratch — hamui_calendar_get is out-pointer style,
# so park the out-params in Array[1] globals (same pattern as the toolkit's
# other callers; distinctively prefixed for the shared module namespace).
_hshcal_y:   Array[1, int64]
_hshcal_m:   Array[1, int64]
_hshcal_d:   Array[1, int64]
_hshcal_buf: Array[16, uint8]        # "YYYY-MM-DD" render scratch


# Render y/m/d as zero-padded ISO "YYYY-MM-DD" into _hshcal_buf.
def _hamui_fmt_date(y: int64, m: int64, d: int64) -> Ptr[uint8]:
    _hshcal_buf[0] = cast[uint8]((y / 1000) % 10) + 48
    _hshcal_buf[1] = cast[uint8]((y / 100) % 10) + 48
    _hshcal_buf[2] = cast[uint8]((y / 10) % 10) + 48
    _hshcal_buf[3] = cast[uint8](y % 10) + 48
    _hshcal_buf[4] = 45                              # '-'
    _hshcal_buf[5] = cast[uint8]((m / 10) % 10) + 48
    _hshcal_buf[6] = cast[uint8](m % 10) + 48
    _hshcal_buf[7] = 45                              # '-'
    _hshcal_buf[8] = cast[uint8]((d / 10) % 10) + 48
    _hshcal_buf[9] = cast[uint8](d % 10) + 48
    _hshcal_buf[10] = 0
    return &_hshcal_buf[0]


def builtin_hamui(argc: int32) -> int32:
    if argc < 2:
        errstr_set("hamui: usage: hamui <subcommand> [args]")
        return 1
    sub: Ptr[uint8] = _hamui_arg(1)

    # ---- lifecycle ----
    if cstr_eq(sub, "init") != 0:
        hamui_init()
        return 0
    if cstr_eq(sub, "render") != 0:
        hamui_render()
        return 0
    if cstr_eq(sub, "step") != 0:
        _hamui_emit_int(cast[int64](hamui_step()))
        return 0
    if cstr_eq(sub, "run") != 0:
        hamui_run()
        return 0
    if cstr_eq(sub, "event") != 0:
        _hamui_emit_int(cast[int64](hamui_take_event()))
        return 0

    # ---- containers (no arg) ----
    if cstr_eq(sub, "vbox") != 0:
        _hamui_emit_int(cast[int64](hamui_vbox()))
        return 0
    if cstr_eq(sub, "hbox") != 0:
        _hamui_emit_int(cast[int64](hamui_hbox()))
        return 0
    if cstr_eq(sub, "grid") != 0:
        _hamui_emit_int(cast[int64](hamui_grid()))
        return 0
    if cstr_eq(sub, "fixed") != 0:
        _hamui_emit_int(cast[int64](hamui_fixed()))
        return 0

    # ---- widgets that take one text argument ----
    if cstr_eq(sub, "label") != 0:
        if argc < 3:
            errstr_set("hamui: label needs text")
            return 1
        _hamui_emit_int(cast[int64](hamui_label(_hamui_arg(2))))
        return 0
    if cstr_eq(sub, "button") != 0:
        if argc < 3:
            errstr_set("hamui: button needs text")
            return 1
        _hamui_emit_int(cast[int64](hamui_button(_hamui_arg(2))))
        return 0
    if cstr_eq(sub, "checkbox") != 0:
        if argc < 3:
            errstr_set("hamui: checkbox needs text")
            return 1
        _hamui_emit_int(cast[int64](hamui_checkbox(_hamui_arg(2))))
        return 0
    if cstr_eq(sub, "statusbar") != 0:
        if argc < 3:
            errstr_set("hamui: statusbar needs text")
            return 1
        _hamui_emit_int(cast[int64](hamui_statusbar(_hamui_arg(2))))
        return 0
    if cstr_eq(sub, "dialog") != 0:
        if argc < 3:
            errstr_set("hamui: dialog needs title")
            return 1
        _hamui_emit_int(cast[int64](hamui_dialog(_hamui_arg(2))))
        return 0
    if cstr_eq(sub, "menu") != 0:
        if argc < 3:
            errstr_set("hamui: menu needs title")
            return 1
        _hamui_emit_int(cast[int64](hamui_menu(_hamui_arg(2))))
        return 0

    # ---- widgets with no argument ----
    if cstr_eq(sub, "entry") != 0:
        _hamui_emit_int(cast[int64](hamui_entry()))
        return 0
    if cstr_eq(sub, "list") != 0:
        _hamui_emit_int(cast[int64](hamui_list()))
        return 0
    if cstr_eq(sub, "combo") != 0:
        _hamui_emit_int(cast[int64](hamui_combo()))
        return 0
    if cstr_eq(sub, "menubar") != 0:
        _hamui_emit_int(cast[int64](hamui_menubar()))
        return 0
    if cstr_eq(sub, "toolbar") != 0:
        _hamui_emit_int(cast[int64](hamui_toolbar()))
        return 0
    if cstr_eq(sub, "textview") != 0:
        _hamui_emit_int(cast[int64](hamui_textview()))
        return 0
    if cstr_eq(sub, "notebook") != 0:
        _hamui_emit_int(cast[int64](hamui_notebook()))
        return 0
    if cstr_eq(sub, "progress") != 0:
        _hamui_emit_int(cast[int64](hamui_progress()))
        return 0

    # ---- separator: optional VERT flag (default 0 = horizontal) ----
    if cstr_eq(sub, "separator") != 0:
        vflag: int32 = 0
        if argc >= 3:
            vflag = _hamui_argi(2)
        _hamui_emit_int(cast[int64](hamui_separator(vflag)))
        return 0

    # ---- range widgets: MIN MAX VAL ----
    if cstr_eq(sub, "slider") != 0:
        if argc < 5:
            errstr_set("hamui: slider needs MIN MAX VAL")
            return 1
        _hamui_emit_int(cast[int64](hamui_slider(_hamui_argi(2),
                                                 _hamui_argi(3),
                                                 _hamui_argi(4))))
        return 0
    if cstr_eq(sub, "spin") != 0:
        if argc < 5:
            errstr_set("hamui: spin needs MIN MAX VAL")
            return 1
        _hamui_emit_int(cast[int64](hamui_spin(_hamui_argi(2),
                                               _hamui_argi(3),
                                               _hamui_argi(4))))
        return 0

    # ---- treeview COLS / notebook-page NB TITLE ----
    if cstr_eq(sub, "treeview") != 0:
        if argc < 3:
            errstr_set("hamui: treeview needs COLS")
            return 1
        _hamui_emit_int(cast[int64](hamui_treeview(_hamui_argi(2))))
        return 0
    if cstr_eq(sub, "notebook-page") != 0:
        if argc < 4:
            errstr_set("hamui: notebook-page needs NB TITLE")
            return 1
        _hamui_emit_int(cast[int64](hamui_notebook_page(_hamui_argi(2),
                                                        _hamui_arg(3))))
        return 0
    if cstr_eq(sub, "menu-add") != 0:
        if argc < 4:
            errstr_set("hamui: menu-add needs MENU LABEL")
            return 1
        _hamui_emit_int(cast[int64](hamui_menu_add(_hamui_argi(2),
                                                   _hamui_arg(3))))
        return 0

    # ---- void: add to a list/combo/tree (ID TEXT) ----
    if cstr_eq(sub, "list-add") != 0:
        if argc < 4:
            errstr_set("hamui: list-add needs ID TEXT")
            return 1
        hamui_list_add(_hamui_argi(2), _hamui_arg(3))
        return 0
    if cstr_eq(sub, "combo-add") != 0:
        if argc < 4:
            errstr_set("hamui: combo-add needs ID TEXT")
            return 1
        hamui_combo_add(_hamui_argi(2), _hamui_arg(3))
        return 0
    if cstr_eq(sub, "treeview-add") != 0:
        if argc < 4:
            errstr_set("hamui: treeview-add needs ID TEXT")
            return 1
        hamui_treeview_add(_hamui_argi(2), _hamui_arg(3))
        return 0
    if cstr_eq(sub, "textview-set") != 0:
        if argc < 4:
            errstr_set("hamui: textview-set needs ID TEXT")
            return 1
        hamui_textview_set(_hamui_argi(2), _hamui_arg(3))
        return 0

    # ---- tree assembly ----
    if cstr_eq(sub, "add") != 0:
        if argc < 4:
            errstr_set("hamui: add needs PARENT CHILD")
            return 1
        hamui_add(_hamui_argi(2), _hamui_argi(3))
        return 0

    # ---- property setters ----
    if cstr_eq(sub, "text") != 0:
        if argc < 4:
            errstr_set("hamui: text needs ID TEXT")
            return 1
        hamui_set_text(_hamui_argi(2), _hamui_arg(3))
        return 0
    if cstr_eq(sub, "size") != 0:
        if argc < 5:
            errstr_set("hamui: size needs ID W H")
            return 1
        hamui_set_size(_hamui_argi(2), _hamui_argi(3), _hamui_argi(4))
        return 0
    if cstr_eq(sub, "align") != 0:
        if argc < 5:
            errstr_set("hamui: align needs ID HALIGN VALIGN")
            return 1
        hamui_set_align(_hamui_argi(2), _hamui_argi(3), _hamui_argi(4))
        return 0
    if cstr_eq(sub, "expand") != 0:
        if argc < 5:
            errstr_set("hamui: expand needs ID HEXP VEXP")
            return 1
        hamui_set_expand(_hamui_argi(2), _hamui_argi(3), _hamui_argi(4))
        return 0
    if cstr_eq(sub, "range") != 0:
        if argc < 5:
            errstr_set("hamui: range needs ID MIN MAX")
            return 1
        hamui_set_range(_hamui_argi(2), _hamui_argi(3), _hamui_argi(4))
        return 0

    # ---- value: reader (ID) or setter (ID V) ----
    if cstr_eq(sub, "value") != 0:
        if argc < 3:
            errstr_set("hamui: value needs ID [V]")
            return 1
        if argc >= 4:
            hamui_set_value(_hamui_argi(2), _hamui_argi(3))
            return 0
        _hamui_emit_int(cast[int64](hamui_value(_hamui_argi(2))))
        return 0

    # ---- window binding: ROOT [WID] (default wid 1) ----
    if cstr_eq(sub, "window") != 0:
        if argc < 3:
            errstr_set("hamui: window needs ROOT [WID]")
            return 1
        if argc >= 4:
            _hamui_emit_int(cast[int64](hamui_window_on(_hamui_argi(2),
                                                        _hamui_argi(3))))
            return 0
        _hamui_emit_int(cast[int64](hamui_window(_hamui_argi(2))))
        return 0

    # ---- visibility / lifecycle (ID) ----
    if cstr_eq(sub, "show") != 0:
        if argc < 3:
            errstr_set("hamui: show needs ID")
            return 1
        hamui_show(_hamui_argi(2))
        return 0
    if cstr_eq(sub, "hide") != 0:
        if argc < 3:
            errstr_set("hamui: hide needs ID")
            return 1
        hamui_hide(_hamui_argi(2))
        return 0
    if cstr_eq(sub, "destroy") != 0:
        if argc < 3:
            errstr_set("hamui: destroy needs ID")
            return 1
        hamui_destroy(_hamui_argi(2))
        return 0

    # ---- state readers (ID -> int) ----
    if cstr_eq(sub, "checked") != 0:
        if argc < 3:
            errstr_set("hamui: checked needs ID")
            return 1
        _hamui_emit_int(cast[int64](hamui_checked(_hamui_argi(2))))
        return 0
    if cstr_eq(sub, "selected") != 0:
        if argc < 3:
            errstr_set("hamui: selected needs ID")
            return 1
        _hamui_emit_int(cast[int64](hamui_list_selected(_hamui_argi(2))))
        return 0
    if cstr_eq(sub, "combo-sel") != 0:
        if argc < 3:
            errstr_set("hamui: combo-sel needs ID")
            return 1
        _hamui_emit_int(cast[int64](hamui_combo_selected(_hamui_argi(2))))
        return 0
    if cstr_eq(sub, "tree-sel") != 0:
        if argc < 3:
            errstr_set("hamui: tree-sel needs ID")
            return 1
        _hamui_emit_int(cast[int64](hamui_tree_selected(_hamui_argi(2))))
        return 0
    if cstr_eq(sub, "signalled") != 0:
        if argc < 3:
            errstr_set("hamui: signalled needs ID")
            return 1
        _hamui_emit_int(cast[int64](hamui_signalled(_hamui_argi(2))))
        return 0
    if cstr_eq(sub, "entry-text") != 0:
        if argc < 3:
            errstr_set("hamui: entry-text needs ID")
            return 1
        write_cstr1(hamui_entry_text(_hamui_argi(2)))
        write_cstr1("\n")
        return 0

    # ---- calendar (GtkCalendar-style month view) ----
    if cstr_eq(sub, "calendar") != 0:
        _hamui_emit_int(cast[int64](hamui_calendar()))
        return 0
    if cstr_eq(sub, "calendar-sel") != 0:
        if argc < 3:
            errstr_set("hamui: calendar-sel needs ID")
            return 1
        hamui_calendar_get(_hamui_argi(2), &_hshcal_y[0],
                           &_hshcal_m[0], &_hshcal_d[0])
        write_cstr1(_hamui_fmt_date(_hshcal_y[0], _hshcal_m[0],
                                    _hshcal_d[0]))
        write_cstr1("\n")
        return 0

    # ---- tooltip (text is copied by the toolkit; argv reuse is safe) ----
    if cstr_eq(sub, "tooltip") != 0:
        if argc < 4:
            errstr_set("hamui: tooltip needs ID TEXT")
            return 1
        hamui_set_tooltip(_hamui_argi(2), _hamui_arg(3))
        return 0

    # ---- modal dialogs (BLOCKING: lib/hamui.ad runs its own
    # ---- step+yield loop until the user decides, then returns) ----
    if cstr_eq(sub, "alert") != 0:
        if argc < 4:
            errstr_set("hamui: alert needs TITLE TEXT")
            return 1
        if hamui_alert(_hamui_arg(2), _hamui_arg(3)) == HAMUI_DLG_OK:
            _hamui_emit_int(cast[int64](1))
        else:
            _hamui_emit_int(cast[int64](0))
        return 0
    if cstr_eq(sub, "confirm") != 0:
        if argc < 4:
            errstr_set("hamui: confirm needs TITLE TEXT")
            return 1
        if hamui_confirm(_hamui_arg(2), _hamui_arg(3)) == HAMUI_DLG_OK:
            _hamui_emit_int(cast[int64](1))
        else:
            _hamui_emit_int(cast[int64](0))
        return 0
    if cstr_eq(sub, "filechooser") != 0:
        if argc < 3:
            errstr_set("hamui: filechooser needs TITLE [STARTDIR]")
            return 1
        startdir: Ptr[uint8] = cast[Ptr[uint8]](0)
        if argc >= 4:
            startdir = _hamui_arg(3)
        chosen: Ptr[uint8] = hamui_filechooser(_hamui_arg(2), startdir)
        if chosen != cast[Ptr[uint8]](0):
            write_cstr1(chosen)
        write_cstr1("\n")
        return 0

    errstr_set("hamui: unknown subcommand")
    return 1


# docs/security.md Phase 8: `read [-s] VAR` builtin.
#
# Plain stdin read until newline. Stores the result in shell variable
# VAR (accessible as $VAR after). The `-s` flag suppresses echoing —
# used for password prompts in `newshell` and the installer.
#
# Scratch buffer for one line of read input. 256 bytes covers usernames
# and passwords comfortably without being unreasonable. CR/LF and the
# trailing newline are stripped before the variable is assigned.
read_buf: Array[256, uint8]


def builtin_read(argc: int32) -> int32:
    # Usage: read VAR  | read -s VAR
    if argc < 2:
        errstr_set("read: usage: read [-s] VAR")
        return 1
    silent: int32 = 0
    var_arg_idx: int32 = 1
    arg1: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[1])
    if arg1[0] == 45 and arg1[1] == 115 and arg1[2] == 0:    # `-s`
        silent = 1
        var_arg_idx = 2
        if argc < 3:
            errstr_set("read: -s needs a variable name")
            return 1
    var_name: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[cast[uint64](var_arg_idx)])
    # Read byte-by-byte to newline. This is a RAW read of fd 0 — it
    # never runs through the interactive line editor, and the kernel
    # console does not echo bytes on a raw read, so on the serial /
    # framebuffer / SSH front-ends `-s` is effectively silent already
    # (same path newshell/su/login use for password entry). The lone
    # exception is the DE scene terminal, which does its OWN local
    # keystroke echo; we suppress that by bracketing the read with the
    # DE echo-off/echo-on control (de_echo_off/de_echo_on) — harmless on
    # serial/SSH front-ends, which ignore the unknown private CSI. `-s`
    # still appends the getpass(3)-shape trailing newline below regardless.
    if silent != 0:
        de_echo_off()
    n: uint64 = 0
    while n + 1 < 256:
        c: Array[1, uint8]
        rr: int64 = sys_read(0, &c[0], 1)
        if rr <= 0:
            break
        if c[0] == 10:
            break
        if c[0] == 13:
            continue
        read_buf[n] = c[0]
        n = n + 1
    read_buf[n] = 0
    if silent != 0:
        # Restore the terminal's local echo, then echo a newline so the
        # next prompt isn't on the same line as the (invisible) typed
        # password — matches getpass(3) shape.
        de_echo_on()
        write_cstr1("\n")
    # Stash the read value as a shell variable. v_str_cstr interns
    # the buffer into the shell's string arena; scope_set installs it
    # under the name.
    sref: uint64 = str_intern_cstr(var_name)
    val: int32 = v_str_cstr(&read_buf[0])
    scope_set(sref, val)
    return 0


# docs/security.md Phase 7: `newshell <user> [-c <command>]` builtin.
#
# Plan-9-shape elevation. Instead of POSIX `sudo` (run THIS command
# elevated), `newshell` opens a NEW shell session AS the target user
# with their full namespace recipe.
#
# Pipeline:
#   1. Lookup target uid in /etc/passwd.
#   2. Console-owner self-elevation fast path (uid 1 -> uid 1): skip the
#      password entirely (identity-vouching, like `login -f`).
#   3. Otherwise prompt for password (silent read) and authenticate via
#      the kernel /dev/auth cdev, which reads /etc/shadow + SHA-512-crypt
#      verifies in kernel context and stamps a verified-uid verdict on
#      the fd.
#   4. On match: rfork(RFPROC|RFNAMEG) — child gets a COW namespace.
#      Child calls SYS_SETUID_AUTH(authfd) — the kernel honours the fd's
#      verified-uid slot as proof of identity, so a REGULAR user can
#      elevate too (mirrors su.ad / login.ad). Then exec /bin/hamsh with
#      the target's recipe at /etc/users/<name>.ns (or default.ns).
#   5. Parent sys_waitpid for the child, then closes the auth fd.
#
# v1 limitations (deferred per the spec's "Implementation surface"
# phase ordering):
#   * /dev/auth cdev (Phase 4) is NOT yet implemented — verification
#     runs in userland against /etc/shadow read directly. This works
#     for the hostowner (kernel SYS_SETUID gate is "current uid == 1")
#     but a regular user trying `newshell hostowner` will fail the
#     SYS_SETUID gate, since they're not already hostowner. That gap
#     closes when /dev/auth's kernel-side handler can flip identity
#     after authenticating on PID 1's behalf.
#   * VFS permission check (Phase 5) is NOT yet implemented — even a
#     regular user can technically read /etc/shadow today. The mid-
#     term plan via per-user namespace recipes (Phase 9) won't BIND
#     /etc/shadow into a regular user's view, restoring the boundary.
#
# Despite those gaps, the v1 path lets hostowner-→hostowner test
# `newshell live` (password `hamnix`) succeed/fail correctly, which
# is the primary test_security.sh smoke.

from lib.passwd.passwd import (
    passwd_parse, passwd_lookup_by_name, passwd_lookup_by_uid,
    passwd_entry_uid, passwd_entry_name, passwd_entry_home,
)


# hamui GUI toolkit (lib/hamui.ad) — drives the `hamui` shell builtin so
# a hamsh script can assemble + run a window with ordinary shell control
# flow. Imported the same way lib.passwd is: the Adder compiler resolves
# the module and links it into the hamsh ELF (no build_user.sh change).
from lib.hamui import (
    hamui_init, hamui_vbox, hamui_hbox, hamui_grid, hamui_fixed,
    hamui_label, hamui_button, hamui_entry, hamui_checkbox,
    hamui_list, hamui_list_add, hamui_menubar, hamui_menu, hamui_menu_add,
    hamui_toolbar, hamui_statusbar, hamui_progress, hamui_slider,
    hamui_spin, hamui_combo, hamui_combo_add, hamui_notebook,
    hamui_notebook_page, hamui_treeview, hamui_treeview_add,
    hamui_textview, hamui_textview_set, hamui_dialog, hamui_separator,
    hamui_add, hamui_set_text, hamui_set_size, hamui_set_align,
    hamui_set_expand, hamui_set_value, hamui_set_range,
    hamui_window, hamui_window_on, hamui_show, hamui_hide, hamui_destroy,
    hamui_checked, hamui_value, hamui_list_selected, hamui_combo_selected,
    hamui_tree_selected, hamui_entry_text, hamui_render, hamui_step,
    hamui_run, hamui_take_event, hamui_signalled,
    hamui_calendar, hamui_calendar_get, hamui_set_tooltip,
    hamui_alert, hamui_confirm, hamui_filechooser, HAMUI_DLG_OK
)


NEWSHELL_BUF_MAX: uint64 = 4096
newshell_passwd_buf: Array[4096, uint8]
# Response buffer for /dev/auth — "ok <uid> <gid>\n" or "denied\n".
# 64 bytes covers either rendering with comfortable headroom.
newshell_auth_resp: Array[64, uint8]


def _newshell_read_file(path: Ptr[char], buf: Ptr[uint8],
                        cap: uint64) -> int64:
    # Open + slurp a file into `buf`. Returns bytes read, or -1.
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    total: uint64 = 0
    while total < cap:
        n: int64 = sys_read(fd, &buf[total], cap - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    return cast[int64](total)


def _newshell_write_line(fd: int32, prefix: Ptr[uint8], plen: uint64,
                         payload: Ptr[uint8], paylen: uint64) -> int64:
    # Emit "<prefix><payload>\n" as one syscall to /dev/auth. The cdev's
    # write side treats one syscall as one line; concatenating ourselves
    # avoids depending on the kernel buffering writes that arrived
    # piecemeal.
    line: Array[256, uint8]
    p: uint64 = 0
    while p < plen and p + 2 < 256:
        line[p] = prefix[p]
        p = p + 1
    j: uint64 = 0
    while j < paylen and p + 2 < 256:
        line[p] = payload[j]
        p = p + 1
        j = j + 1
    line[p] = 10                                       # '\n'
    p = p + 1
    return sys_write(fd, &line[0], p)


def _newshell_cstr_len(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _newshell_auth_via_cdev(target_user: Ptr[uint8],
                            password: Ptr[uint8]) -> int32:
    # docs/security.md Phase 4: authenticate via the kernel /dev/auth
    # cdev. The cdev reads /etc/shadow from kernel context, runs the
    # SHA-512-crypt verify, and stamps a per-fd verdict on SUCCESS.
    #
    # Returns the STILL-OPEN /dev/auth fd (>= 0) on a successful auth, or
    # -1 on any failure (wrong password OR no such user OR open failed) —
    # we deliberately collapse the failure modes into a single value;
    # leaking "the user exists" before a successful auth would help an
    # attacker enumerate accounts. The fd is returned OPEN so the caller
    # can hand it to SYS_SETUID_AUTH (the slot's verified-uid verdict
    # lives on the fd and is lost once it is closed) — mirroring su.ad /
    # login.ad, which authenticate then sys_setuid_auth(authfd) on the
    # same fd. The caller owns closing it.
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/auth"))
    if fd < 0:
        # /dev/auth not present (very early-boot path; the cdev should
        # always exist). Treat as auth failure.
        return -1
    ul: uint64 = _newshell_cstr_len(target_user)
    pl: uint64 = _newshell_cstr_len(password)
    user_prefix: Ptr[uint8] = "user "
    pass_prefix: Ptr[uint8] = "pass "
    if _newshell_write_line(fd, user_prefix, 5, target_user, ul) < 0:
        sys_close(fd)
        return -1
    if _newshell_write_line(fd, pass_prefix, 5, password, pl) < 0:
        sys_close(fd)
        return -1
    n: int64 = sys_read(fd, &newshell_auth_resp[0], 64)
    if n < 2:
        sys_close(fd)
        return -1
    # "ok" prefix == verified; anything else (notably "denied") fails.
    if newshell_auth_resp[0] == 111 and newshell_auth_resp[1] == 107:   # 'o','k'
        return fd
    sys_close(fd)
    return -1


def _newshell_name_is_hostowner(name: Ptr[uint8]) -> int32:
    # True if `name` is the literal alias "hostowner". Used to map the
    # alias onto the uid-1 /etc/passwd row (whose username may be `live`
    # or the installer-chosen name).
    ho: Array[10, uint8]
    ho[0] = 104  # h
    ho[1] = 111  # o
    ho[2] = 115  # s
    ho[3] = 116  # t
    ho[4] = 111  # o
    ho[5] = 119  # w
    ho[6] = 110  # n
    ho[7] = 101  # e
    ho[8] = 114  # r
    ho[9] = 0
    i: uint64 = 0
    while True:
        if name[i] != ho[i]:
            return 0
        if ho[i] == 0:
            return 1
        i = i + 1
    return 0


def _newshell_become(target_uid: uint32, target_user: Ptr[uint8],
                     cmd_string: Ptr[uint8], auth_fd: int32) -> int32:
    # rfork + change identity + exec the target user's shell session.
    # Shared by TWO callers, distinguished by `auth_fd`:
    #
    #   auth_fd >= 0  — AUTHENTICATED path. The fd is an open /dev/auth
    #     fd that already verified (target_user, password). The child
    #     calls SYS_SETUID_AUTH(auth_fd): the kernel honours the fd's
    #     verified-uid slot as proof of identity, so the identity change
    #     succeeds REGARDLESS of the caller's prior uid. This is exactly
    #     how su.ad / login.ad elevate — a REGULAR user can now `newshell
    #     hostowner` (or `newshell <other>`) after the password prompt,
    #     closing the documented gap. The fd survives the rfork because
    #     RFNAMEG COW-copies the /fd table (same fd number, same slot).
    #
    #   auth_fd <  0  — console-owner self-elevation fast-path (uid 1 →
    #     uid 1, no password). The child calls SYS_SETUID(target_uid);
    #     the kernel gate is "current uid must be 1", which the host
    #     owner satisfies. (This branch is only ever reached for the
    #     uid-1 → uid-1 transition; see builtin_newshell.)
    flags: int32 = RFPROC | RFNAMEG
    pid: int32 = sys_rfork(flags)
    if pid < 0:
        errstr_set("rfork failed")
        return 1
    if pid == 0:
        # Child: switch identity, set the per-user env hand-off so the
        # spawned /bin/hamsh knows it's a newshell-spawned interactive
        # shell (it'll load /etc/users/<target>.ns per Phase 9), then
        # exec.
        rs: int32 = -1
        if auth_fd >= 0:
            # Password-proof elevation (mirrors su.ad). The fd carries
            # the verified-uid verdict; the kernel sets uid+gid to it.
            rs = sys_setuid_auth(auth_fd)
        else:
            # Console-owner self-elevation (uid 1 → uid 1, no password).
            rs = sys_setuid(target_uid)
        if rs < 0:
            # Identity change rejected. For the auth path this means the
            # /dev/auth slot wasn't verified (should not happen — the
            # caller only passes a verified fd); for the no-password
            # path it means the caller wasn't uid 1.
            write_str(2, "newshell: identity change denied\n")
            sys_exit(1)
        # Stamp HAMNIX_NEWSHELL_USER=<target> in env so the spawned
        # hamsh's main() recognises this as a newshell session and
        # sources the per-user namespace recipe (Phase 9).
        env_set(cast[Ptr[uint8]]("HAMNIX_NEWSHELL_USER"), target_user)
        # Exec /bin/hamsh. For -c <cmd>, we wire the command via argv —
        # hamsh main() recognises an rc-script path argument and runs it.
        # NOTE: sys_execve isn't directly exposed to hamsh — we use
        # spawn() which fork+execs. The double-fork is harmless;
        # the original parent above waits on the rfork child, which
        # waits on the spawn() child, exit codes propagate normally.
        hamsh_path: Ptr[char] = cast[Ptr[char]]("/bin/hamsh")
        new_argv: Array[4, uint64]
        new_argv[0] = cast[uint64](hamsh_path)
        new_argv[1] = 0
        new_argv[2] = 0
        new_argv[3] = 0
        if cmd_string != cast[Ptr[uint8]](0):
            new_argv[1] = cast[uint64]("-c")
            new_argv[2] = cast[uint64](cmd_string)
            new_argv[3] = 0
        else:
            # DE-terminal hostowner elevation parity: when `newshell
            # hostowner` runs INSIDE a DE terminal (the rfork(RFNAMEG)
            # above just gave us a COW copy of the regular-user Pgrp
            # planted by rc.de-user), the elevated shell must rebind
            # to the FULL hostowner surface — distrofs / Linux-ABI
            # bindings included — so `enter linux { ... }` works. The
            # serial-shell case (no DE in the picture) ALSO benefits:
            # the inherited init Pgrp already has the right surface,
            # and rc.de-hostowner's binds are idempotent on top.
            # Detected via `target_uid == 1` (hostowner). For any
            # OTHER non-hostowner target, leave the existing path —
            # _load_per_user_namespace sources /etc/users/<name>.ns
            # at REPL start, which is the regular-user contract.
            if target_uid == 1:
                new_argv[1] = cast[uint64]("/etc/rc.de-hostowner")
                new_argv[2] = 0
                new_argv[3] = 0
        envp: Ptr[uint64] = _build_envp()
        sub_pid: int32 = spawn(hamsh_path,
                                   cast[Ptr[uint64]](&new_argv[0]),
                                   SPAWN_STDIO_NS, SPAWN_STDIO_NS,
                                   envp)
        if sub_pid < 0:
            write_str(2, "newshell: spawn /bin/hamsh failed\n")
            sys_exit(127)
        wstat: int64 = sys_waitpid(sub_pid)
        sys_exit(cast[uint64](wstat & 0xFF))
    # Parent: wait for the child shell session.
    sys_waitpid(pid)
    return 0


def builtin_newshell(argc: int32) -> int32:
    if argc < 2:
        errstr_set("usage: newshell <user> [-c <command>]")
        return 1
    target_user: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[1])
    cmd_string: Ptr[uint8] = cast[Ptr[uint8]](0)
    if argc >= 4:
        flag: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[2])
        if flag[0] == 45 and flag[1] == 99 and flag[2] == 0:    # `-c`
            cmd_string = cast[Ptr[uint8]](argv_ptr[3])
    # Step 1: parse /etc/passwd, find target. /etc/passwd is world-
    # readable per docs/security.md (only /etc/shadow is gated to
    # hostowner), so we can resolve the target uid even from a regular-
    # user shell.
    n_pwd: int64 = _newshell_read_file(cast[Ptr[char]]("/etc/passwd"),
                                       &newshell_passwd_buf[0],
                                       NEWSHELL_BUF_MAX)
    if n_pwd < 0:
        errstr_set("cannot open /etc/passwd")
        return 1
    passwd_parse(&newshell_passwd_buf[0], cast[uint64](n_pwd))
    pidx: int32 = passwd_lookup_by_name(target_user)
    if pidx < 0:
        # `hostowner` is a canonical ALIAS for "the uid-1 user", which
        # may be named `live` (ISO) or whatever the installer assigned.
        # /etc/passwd never literally contains a `hostowner` row, so a
        # name miss on `hostowner` resolves to the uid-1 entry instead.
        # This is the Plan-9 elevation idiom — `newshell hostowner` is
        # "become the single host owner", independent of their username.
        if _newshell_name_is_hostowner(target_user) != 0:
            pidx = passwd_lookup_by_uid(1)
    if pidx < 0:
        errstr_set("no such user")
        return 1
    target_uid: uint32 = passwd_entry_uid(pidx)
    # After an alias resolve, hand the REAL username (the uid-1 row's
    # name) to /dev/auth + the env stamp — `hostowner` isn't a shadow
    # principal, the uid-1 user is.
    target_user = passwd_entry_name(pidx)
    # Step 1.5 — console-owner self-elevation (no password).
    #
    # The reported bug: `newshell hostowner` on a fresh booted image
    # prompts for a password the user was never given. On the serial /
    # local console the shell ALREADY runs as uid 1 (the kernel upgrades
    # /init to UID_HOSTOWNER before exec'ing hamsh — see init/main.ad), so
    # `newshell hostowner` is the host owner RE-OPENING a shell as itself.
    # Demanding a secret to become who you already are is wrong (and on a
    # fresh image the only credential is the build-time `live`/`hamnix`
    # pair the user has no way to know).
    #
    # The Plan-9 idiom is identity-vouching, not a POSIX root password:
    # exactly how `login -f <user>` lets getty drop to a shell without a
    # prompt because the CALLER's established identity is the proof. Here
    # the caller IS uid 1, so for the uid-1→uid-1 transition we skip the
    # password + /dev/auth round-trip entirely and go straight to the
    # rfork+setuid+exec.
    #
    # This does NOT weaken multi-user auth:
    #   * A REGULAR user (uid != 1) running `newshell hostowner` does NOT
    #     take this branch — they still hit the password prompt below. The
    #     difference from the old code: a CORRECT password now DOES elevate
    #     them, because the authenticated path uses SYS_SETUID_AUTH (the
    #     /dev/auth fd's verified-uid slot is the proof of identity, not the
    #     caller's prior uid) exactly like su/login. A wrong/absent password
    #     still cannot — the /dev/auth verify fails and no fd is returned.
    #   * `newshell <other-user>` to a DIFFERENT uid (target_uid != 1) does
    #     NOT take this branch either — it prompts + authenticates + (on
    #     success) SYS_SETUID_AUTHs into that user.
    #   * `su` / `login` to other users are untouched (separate binaries).
    # Only the host owner confirming its OWN identity is password-free.
    cur_uid: uint32 = sys_getuid()
    if cur_uid == 1 and target_uid == 1:
        # No-password fast path: auth_fd = -1 → child uses SYS_SETUID.
        return _newshell_become(target_uid, target_user, cmd_string, -1)
    # Step 2: prompt password. The read is a RAW byte read of fd 0
    # (below) — it never goes through the interactive line editor, and
    # the kernel console (serial / framebuffer / SSH bridge) does NOT
    # echo bytes on a raw read, so the typed password is invisible on
    # those front-ends (verified: test_newshell_auth_elevation's serial
    # capture contains ZERO occurrences of the typed password). The one
    # front-end that still shows it is the DE scene terminal
    # (user/hamtermscene.ad), which does its OWN local keystroke echo to
    # its pane for zero-lag editing. We bracket the read with the DE
    # echo-off/echo-on control so the terminal suppresses that local echo
    # for the duration of the password read (harmless on serial/SSH, which
    # ignore the unknown private CSI). We bring the bytes through userland
    # only to hand them to /dev/auth; the cdev does the /etc/shadow read +
    # SHA-512-crypt verify entirely in kernel context so the hash never
    # leaves the kernel.
    write_cstr1("password: ")
    de_echo_off()
    n: uint64 = 0
    while n + 1 < 256:
        c: Array[1, uint8]
        rr: int64 = sys_read(0, &c[0], 1)
        if rr <= 0:
            break
        if c[0] == 10:
            break
        if c[0] == 13:
            continue
        read_buf[n] = c[0]
        n = n + 1
    read_buf[n] = 0
    de_echo_on()
    write_cstr1("\n")
    # Step 3: authenticate via /dev/auth. Plaintext lifetime here is
    # bounded by this function — the cdev's write zeroes its pass_buf
    # on success/failure, and we don't keep our own copy past this call.
    # On success the fd is returned STILL OPEN, carrying the verified-uid
    # slot — we hand it to _newshell_become's child for SYS_SETUID_AUTH.
    auth_fd: int32 = _newshell_auth_via_cdev(target_user, &read_buf[0])
    # Wipe the local read_buf so plaintext doesn't linger in hamsh's
    # global scratch beyond the auth call.
    wz: uint64 = 0
    while wz < 256:
        read_buf[wz] = 0
        wz = wz + 1
    if auth_fd < 0:
        # Print to stderr — auth failures are diagnostic, not data.
        write_str(2, "newshell: authentication failed\n")
        return 1
    # Step 4: rfork + SYS_SETUID_AUTH(auth_fd) + exec the target shell
    # session. The /dev/auth fd's verified slot is the proof of identity,
    # so this works whether the caller was the hostowner OR a regular
    # user (mirrors su.ad / login.ad) — closing the documented gap.
    rc_become: int32 = _newshell_become(target_uid, target_user,
                                        cmd_string, auth_fd)
    # Parent owns closing the auth fd now the child has consumed the slot.
    sys_close(auth_fd)
    return rc_become


# `setuid [<uid>]` — IN-PLACE identity change for the CURRENT shell
# process (no rfork, no new shell). Two uses:
#
#   setuid          — getter. Prints "uid <n>" for the current uid.
#                     Used as a runtime probe (tests, scripts).
#   setuid <uid>    — drop/keep identity. Calls SYS_SETUID(<uid>); the
#                     kernel gate is "current uid must be 1 (hostowner)",
#                     so this is a PRIVILEGE DROP primitive: the host
#                     owner can step DOWN to any uid, but a non-hostowner
#                     cannot use it to elevate (that needs the password
#                     proof — see `newshell` / su / login). On success
#                     prints "uid <n>"; on rejection prints an error and
#                     returns 1.
#
# This is what rc.de-user uses to stamp the DE terminal to a NON-host-
# owner uid (NOBODY, 65534): the compositor spawns the terminal's hamsh
# as hostowner (inherited), the rc plants the namespace surface while it
# still has the privilege to bind, then `setuid 65534` drops to NOBODY
# right before exec'ing the user program — so the desktop shell, and
# everything launched from it, runs unprivileged. Genuine elevation from
# inside the terminal still works via `newshell hostowner` (password).
def builtin_setuid(argc: int32) -> int32:
    if argc < 2:
        # Getter: report the current uid.
        write_cstr1("uid ")
        write_cstr1(render_int(cast[int64](cast[uint64](sys_getuid()))))
        write_cstr1("\n")
        return 0
    a: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[1])
    v: uint64 = 0
    i: uint64 = 0
    if a[0] == 0:
        errstr_set("setuid: empty uid")
        return 1
    while a[i] != 0:
        if a[i] < 48 or a[i] > 57:
            errstr_set("setuid: non-numeric uid")
            return 1
        v = v * 10 + cast[uint64](a[i] - 48)
        i = i + 1
    rs: int32 = sys_setuid(cast[uint32](v & 0xFFFFFFFF))
    if rs < 0:
        errstr_set("setuid: permission denied (only hostowner may change uid)")
        return 1
    write_cstr1("uid ")
    write_cstr1(render_int(cast[int64](cast[uint64](sys_getuid()))))
    write_cstr1("\n")
    return 0


# Builtin dispatch — returns -1 if `cmd` is not a builtin, else exit
# status.
#
# Redirect handling for builtins: HONOURED in-process by the wrap_self
# / unwrap_self pair invoked from run_one_command_x (§7). A builtin
# writes to integer fd 1/2 (write_cstr1 → sys_write(1, ...) → the task's
# fd_idx[1] mark, FD_STDOUT_MARK by default which routes to the
# console); the redirect wrapper sys_dup-saves fd 1, sys_open_write's
# the target file (or sys_openchan + the /fd/SCRATCH bridge for `>>`),
# sys_dup2's the new fd onto 1, runs the verb, then restores. Same
# scheme applies to fd 0 (`<`) and fd 2 (`2>`, `2>&1`). Builtins are
# in-process at the prompt scope (no fork) so an integer-fd dup2 is the
# cleanest mirror of how externals get _wire_redirects done at the
# spawn boundary.
#
# When a builtin fails it leaves a diagnosis in $errstr (§16). For an
# interactive prompt that is not enough — the user wants to SEE the
# error. _builtin_dispatch runs the verb; run_builtin prints
# `cmd: <errstr>` on a nonzero result so a bare failing builtin reports
# cleanly, exactly as a failed external prints "command not found".
# Inside `try { } except { }` the message is still in $errstr for
# structured handling — the print is the interactive surface, not a
# replacement for errstr.
def _builtin_dispatch(cmd: Ptr[uint8], argc: int32) -> int32:
    if cstr_eq(cmd, "cd") != 0:
        return builtin_cd(argc)
    if cstr_eq(cmd, "pwd") != 0:
        return builtin_pwd(argc)
    if cstr_eq(cmd, "bind") != 0:
        return builtin_bind(argc)
    if cstr_eq(cmd, "unmount") != 0:
        return builtin_unmount(argc)
    if cstr_eq(cmd, "mount") != 0:
        return builtin_mount(argc)
    if cstr_eq(cmd, "import") != 0:
        return builtin_import(argc)
    if cstr_eq(cmd, "export") != 0:
        return builtin_export(argc)
    if cstr_eq(cmd, "echo") != 0:
        return builtin_echo(argc)
    if cstr_eq(cmd, "hamui") != 0:
        return builtin_hamui(argc)
    if cstr_eq(cmd, "svc") != 0:
        return builtin_svc(argc)
    if cstr_eq(cmd, "service") != 0:
        return builtin_service(argc)
    if cstr_eq(cmd, "init") != 0:
        return builtin_init(argc)
    if cstr_eq(cmd, "telinit") != 0:
        return builtin_init(argc)
    # docs/security.md Phase 8.
    if cstr_eq(cmd, "read") != 0:
        return builtin_read(argc)
    # docs/security.md Phase 7.
    if cstr_eq(cmd, "newshell") != 0:
        return builtin_newshell(argc)
    if cstr_eq(cmd, "setuid") != 0:
        return builtin_setuid(argc)
    if cstr_eq(cmd, "source") != 0:
        return builtin_source(argc)
    return -1


def _builtin_dispatch_kind_check(cmd: Ptr[uint8]) -> int32:
    # Returns 1 if `cmd` is the name of a builtin (will be handled by
    # _builtin_dispatch), 0 if it would fall through to external
    # resolution. Used by run_one_command_x to decide whether to wire
    # in-process redirects BEFORE calling the verb — the verb itself
    # can't communicate "I'm a builtin" until after it runs, which is
    # too late to apply the redirect to its own writes.
    if cstr_eq(cmd, "cd") != 0:
        return 1
    if cstr_eq(cmd, "pwd") != 0:
        return 1
    if cstr_eq(cmd, "bind") != 0:
        return 1
    if cstr_eq(cmd, "unmount") != 0:
        return 1
    if cstr_eq(cmd, "mount") != 0:
        return 1
    if cstr_eq(cmd, "import") != 0:
        return 1
    if cstr_eq(cmd, "export") != 0:
        return 1
    if cstr_eq(cmd, "echo") != 0:
        return 1
    if cstr_eq(cmd, "hamui") != 0:
        return 1
    if cstr_eq(cmd, "svc") != 0:
        return 1
    if cstr_eq(cmd, "service") != 0:
        return 1
    if cstr_eq(cmd, "init") != 0:
        return 1
    if cstr_eq(cmd, "telinit") != 0:
        return 1
    if cstr_eq(cmd, "read") != 0:
        return 1
    if cstr_eq(cmd, "newshell") != 0:
        return 1
    if cstr_eq(cmd, "setuid") != 0:
        return 1
    if cstr_eq(cmd, "source") != 0:
        return 1
    return 0


def run_builtin(cmd: Ptr[uint8], argc: int32) -> int32:
    rc: int32 = _builtin_dispatch(cmd, argc)
    if rc > 0 and errstr_buf[0] != 0:
        write_cstr1(cmd)
        write_cstr1(": ")
        write_cstr1(&errstr_buf[0])
        write_cstr1("\n")
    return rc


def builtin_import(argc: int32) -> int32:
    # import HOST PATH — pull a remote 9P tree into the namespace.
    # Bridges to mount once a srv connection exists; with no network
    # set up it reports through errstr. Kept as a recognised verb so
    # scripts parse; the heavy lifting is the kernel mount path.
    if argc < 3:
        errstr_set("import: usage: import host path")
        return 1
    errstr_set("import: no transport configured")
    return 1


# `source FILE` — read FILE and execute its statements in THIS shell
# process, so any `bind`/`=` it performs mutates the calling shell's
# ambient namespace and scope (unlike running a script as an external
# command, which forks a child whose namespace dies with it). This is
# what lets the tiny cpio-resident bootstrap rc (/etc/rc.boot) hand off
# to the FULL rc that lives on the sysroot partition (/etc/rc.boot,
# visible only after `bind '#sysroot' /` lands): the partition rc's
# binds/services apply to PID 1 itself.
#
# Implementation: read into a DEDICATED buffer (NOT rc_buf — that one
# may hold the bootstrap rc we are mid-executing) and feed it to
# run_source. The node/value arenas are append-only and the lexer's
# token buffer was already consumed by the outer parse, so re-entering
# the lex/parse/exec pipeline here is safe. Returns 0 on success (file
# ran), 1 if the file was absent or unreadable.
src_buf: Array[16384, uint8]


def builtin_source(argc: int32) -> int32:
    if argc < 2:
        errstr_set("source: usage: source file")
        return 1
    path: Ptr[char] = cast[Ptr[char]](argv_ptr[1])
    fd: int32 = sys_open(path)
    if fd < 0:
        errstr_set("source: cannot open file")
        return 1
    total: uint64 = 0
    while True:
        n: int64 = sys_read(fd, &src_buf[total], 16384 - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
        if total >= 16384:
            break
    sys_close(fd)
    if total > 0:
        run_source(&src_buf[0], total)
    return 0


# ====================================================================
# Running a single command + pipelines (§6, §7)
# ====================================================================
# §7: pipe / redirect / dup are ALL the ONE operation — sys_fdbind:
# bind a Chan at an /fd/N name. The shell spawns each command with
# SPAWN_STDIO_NS; the child gets a private COW namespace whose /fd
# table starts as a copy of the shell's (console at 0/1/2). The shell
# then REBINDS the child's /fd/N for any pipe / redirect / dup —
# BEFORE yielding to it (the cooperative scheduler keeps the child
# STATE_READY until sys_waitpid). Concretely:
#   a | b      sys_pipechan -> a pipe slot; bind write end at a's
#              /fd/1 (DEVFD_PIPE_W), read end at b's /fd/0
#              (DEVFD_PIPE_R). The slot is a devtab pipe — direct
#              Chan reads, zero mountrpc (§6).
#   cmd > file sys_openchan -> a file channel slot; bind it at cmd's
#              /fd/1 (DEVFD_FILE).
#   cmd 2>&1   sys_fdbind(cmd, 2, DEVFD_DUP, 1) — bind /fd/1's Chan
#              also at the name /fd/2.


def _node_to_path(node: int32, out: Ptr[uint8], cap: uint64):
    # Evaluate a redirect-target node to its string form and copy it
    # NUL-terminated into `out`.
    tv: int32 = eval_expr(node)
    tp: Ptr[uint8] = v_render_str_only(tv)
    ci: uint64 = 0
    while tp[ci] != 0 and ci + 1 < cap:
        out[ci] = tp[ci]
        ci = ci + 1
    out[ci] = 0


def _redir_kind(fslot: int32, file_kind: int32) -> int32:
    # sys_openchan returns EITHER a small tmpfs slot OR (when the target
    # is a device cdev like /dev/wsys/<wid>/keys) an inline namec chan id
    # carrying CHAN_INLINE_TAG. Pick the matching devfd bind kind:
    # DEVFD_CHAN for a device chan, else the caller's tmpfs file kind
    # (DEVFD_FILE / DEVFD_FILE_APPEND).
    if (fslot & CHAN_INLINE_TAG) != 0:
        return DEVFD_CHAN
    return file_kind


def _wire_redirects(cmdnode: int32, pid: int32):
    # Apply a command's redirects (§7) as binds at the SPAWNED child's
    # /fd/N names. Runs after spawn_resolved, before sys_waitpid.
    nu: uint64 = cast[uint64](cmdnode)
    # `> file` / `>> file` — bind a file channel at the child's /fd/1.
    # nd_c bit 0 distinguishes the two: 0 = OPENCHAN_TRUNC (truncate;
    # tmpfs/ext4 create-or-zero), 1 = OPENCHAN_APPEND (open-at-EOF,
    # writes never overwrite, the DEVFD_FILE_APPEND kind makes each
    # write seek to tmpfs_size first — same path svc's log capture
    # uses for /var/log/svc/<name>.log).
    if nd_a[nu] != 0:
        fp: Array[256, uint8]
        _node_to_path(nd_a[nu], &fp[0], 256)
        if (nd_c[nu] & 1) != 0:
            fslot: int32 = sys_openchan(cast[Ptr[char]](&fp[0]),
                                        OPENCHAN_APPEND)
            if fslot >= 0:
                sys_fdbind(pid, 1, _redir_kind(fslot, DEVFD_FILE_APPEND),
                           fslot)
        else:
            fslot: int32 = sys_openchan(cast[Ptr[char]](&fp[0]),
                                        OPENCHAN_TRUNC)
            if fslot >= 0:
                sys_fdbind(pid, 1, _redir_kind(fslot, DEVFD_FILE), fslot)
    # `< file` — bind a file channel at the child's /fd/0.
    if nd_b[nu] != 0:
        fp: Array[256, uint8]
        _node_to_path(nd_b[nu], &fp[0], 256)
        fslot: int32 = sys_openchan(cast[Ptr[char]](&fp[0]),
                                    OPENCHAN_READ)
        if fslot >= 0:
            sys_fdbind(pid, 0, _redir_kind(fslot, DEVFD_FILE), fslot)
    # `2> file` — bind a file channel at the child's /fd/2.
    if nd_i[nu] != 0:
        fp: Array[256, uint8]
        _node_to_path(cast[int32](nd_i[nu]), &fp[0], 256)
        fslot: int32 = sys_openchan(cast[Ptr[char]](&fp[0]),
                                    OPENCHAN_TRUNC)
        if fslot >= 0:
            sys_fdbind(pid, 2, _redir_kind(fslot, DEVFD_FILE), fslot)
    # `2>&1` — dup-as-bind: whatever Chan is at /fd/1 also at /fd/2.
    if (nd_c[nu] & 2) != 0:
        sys_fdbind(pid, 2, DEVFD_DUP, 1)


# ----- in-process redirect for builtins (§7 in-process variant) -----
#
# A builtin runs at the prompt scope — there is no spawned child to
# rebind /fd/N on. Yet `echo foo > /tmp/x` MUST send "foo\n" to the
# file, not the console (every interactive user hits this; D4's cp_r
# test had to use `/bin/echo` to dodge it). The fix mirrors what
# _wire_redirects does for externals, but at the integer-fd layer of
# the calling task itself:
#
#   1. sys_dup(1) → save the prior fd 1 entry (FD_STDOUT_MARK by
#      default, or whatever a pipeline stage has bound).
#   2. sys_open_write(target) → fd N pointing at the file. For `>`
#      (truncate) this is exactly the SYS_OPEN_WRITE semantics
#      vfs_open_write provides (O_CREAT|O_WRONLY|O_TRUNC). For `>>`
#      (append) we open the tmpfs slot via sys_openchan(_, APPEND),
#      bind it at /fd/REDIRECT_SCRATCH_FD with DEVFD_FILE_APPEND, then
#      sys_open_write("/fd/<scratch>") to materialise the integer fd.
#   3. sys_dup2(N, 1) → integer fd 1 now references the file's entry.
#      Builtins call write_cstr1 (sys_write(1, ...)) just as before;
#      vfs_write resolves fd 1 through the redirected fd_idx entry and
#      the bytes land in the file.
#   4. sys_close(N) — the file is reachable via fd 1; we don't need
#      the original handle.
#   5. Run the builtin.
#   6. sys_dup2(saved, 1) → restore. sys_close(saved). Same dance for
#      fd 0 (`<`) and fd 2 (`2>` / `2>&1`).
#
# The save fds live in a fixed 3-int32 array (one slot per redirected
# stream). _wire_redirects_self installs the redirects and fills the
# array; _unwire_redirects_self restores from it. No allocation, no
# fork — same code path always, exit-status semantics preserved.

REDIRECT_SCRATCH_FD: int32 = 11

# Save-slot indices into the redirect-context array.
RCTX_SAVED_STDIN:  uint64 = 0   # save of fd 0 (-1 if not redirected)
RCTX_SAVED_STDOUT: uint64 = 1   # save of fd 1 (-1 if not redirected)
RCTX_SAVED_STDERR: uint64 = 2   # save of fd 2 (-1 if not redirected)
RCTX_LEN:          uint64 = 3


def _cmd_has_redirect(cmdnode: int32) -> int32:
    # Returns 1 if cmdnode carries any redirect annotation, else 0.
    # Cheap pre-check to skip the wire/unwire overhead for the common
    # `echo foo` (no redirect) case.
    nu: uint64 = cast[uint64](cmdnode)
    if nd_a[nu] != 0:
        return 1
    if nd_b[nu] != 0:
        return 1
    if nd_i[nu] != 0:
        return 1
    if (nd_c[nu] & 2) != 0:
        return 1
    return 0


def _open_redirect_target_write(cmdnode: int32, target_node: int32,
                                append: int32) -> int32:
    # Open a `>` / `>>` target as an integer fd suitable for sys_dup2.
    # For truncate, sys_open_write hits vfs_open_write directly (it
    # already does O_CREAT|O_WRONLY|O_TRUNC for tmpfs + ext4 + the
    # writable cdevs — the `> /dev/null` case still works because
    # /dev/null is in vfs_open_write's allow-list).
    # For append, route through sys_openchan + the /fd/<scratch>
    # bridge: sys_openchan(_, APPEND) returns a tmpfs slot opened at
    # EOF, we bind it via DEVFD_FILE_APPEND at our own
    # /fd/REDIRECT_SCRATCH_FD, then sys_open_write of that name yields
    # an integer fd whose vfs_write arm routes through devfd_write —
    # which for DEVFD_FILE_APPEND lands every write at tmpfs_size.
    #
    # We deliberately LEAVE /fd/REDIRECT_SCRATCH_FD bound to the slot
    # for the duration of the builtin's run. fd_buf on the integer
    # kfd stores only the /fd/<num> -> the resolution to a real slot
    # happens on EVERY vfs_write via devfd_slot_kind(pgrp, num); if
    # we rebound /fd/11 to CONS here, the builtin's writes would
    # silently route to the console. _unwire_redirects_self does the
    # rebind-to-CONS cleanup AFTER restoring fd 1 — that's the safe
    # moment (the kfd has been duped to fd 1 and the original closed,
    # but writes via fd 1 still resolve through /fd/11 until dup2
    # restores the prior fd 1 entry).
    fp: Array[256, uint8]
    _node_to_path(target_node, &fp[0], 256)
    if append != 0:
        slot: int32 = sys_openchan(cast[Ptr[char]](&fp[0]),
                                   OPENCHAN_APPEND)
        if slot < 0:
            return -1
        if sys_fdbind(0, REDIRECT_SCRATCH_FD, DEVFD_FILE_APPEND,
                      slot) < 0:
            return -1
        scratch_path: Array[8, uint8]
        scratch_path[0] = 47    # '/'
        scratch_path[1] = 102   # 'f'
        scratch_path[2] = 100   # 'd'
        scratch_path[3] = 47    # '/'
        scratch_path[4] = 49    # '1'
        scratch_path[5] = 49    # '1'  -> REDIRECT_SCRATCH_FD = 11
        scratch_path[6] = 0
        return sys_open_write(cast[Ptr[char]](&scratch_path[0]))
    return sys_open_write(cast[Ptr[char]](&fp[0]))


def _open_redirect_target_read(target_node: int32) -> int32:
    # Open a `<` target for read as an integer fd. sys_open handles
    # every readable backend the redirect can plausibly target
    # (tmpfs, initramfs, ext4, /proc, /dev/{null,zero,random,...}).
    fp: Array[256, uint8]
    _node_to_path(target_node, &fp[0], 256)
    return sys_open(cast[Ptr[char]](&fp[0]))


def _wire_redirects_self(cmdnode: int32, ctx: Ptr[int32]) -> int32:
    # In-process variant of _wire_redirects: rebind the CALLING task's
    # integer fds 0/1/2 according to cmdnode's redirect annotations,
    # saving the prior entries into `ctx` for later restore by
    # _unwire_redirects_self. Returns 0 on success, -1 if any open
    # failed (the caller treats that as a builtin error — the dance
    # has been partially applied; _unwire still restores what was
    # saved so the prompt's stdio isn't left dangling).
    nu: uint64 = cast[uint64](cmdnode)
    ctx[RCTX_SAVED_STDIN]  = -1
    ctx[RCTX_SAVED_STDOUT] = -1
    ctx[RCTX_SAVED_STDERR] = -1
    rc_overall: int32 = 0
    # `< file` — install BEFORE `>` so a `read VAR < /tmp/x > /tmp/y`
    # ordering is irrelevant (each stream is independent).
    if nd_b[nu] != 0:
        rfd: int32 = _open_redirect_target_read(nd_b[nu])
        if rfd < 0:
            errstr_set("redirect: cannot open input file")
            rc_overall = -1
        else:
            saved0: int32 = sys_dup(0)
            sys_dup2(rfd, 0)
            sys_close(rfd)
            ctx[RCTX_SAVED_STDIN] = saved0
    # `> file` / `>> file` — bit 0 of nd_c distinguishes append.
    if nd_a[nu] != 0:
        append_flag: int32 = 0
        if (nd_c[nu] & 1) != 0:
            append_flag = 1
        wfd: int32 = _open_redirect_target_write(cmdnode, nd_a[nu],
                                                 append_flag)
        if wfd < 0:
            errstr_set("redirect: cannot open output file")
            rc_overall = -1
        else:
            saved1: int32 = sys_dup(1)
            sys_dup2(wfd, 1)
            sys_close(wfd)
            ctx[RCTX_SAVED_STDOUT] = saved1
    # `2> file` — same shape as `>` but onto fd 2. There's no `2>>`
    # in the parser today; if you add one, mirror the append branch.
    if nd_i[nu] != 0:
        efd: int32 = _open_redirect_target_write(
            cmdnode, cast[int32](nd_i[nu]), 0)
        if efd < 0:
            errstr_set("redirect: cannot open stderr file")
            rc_overall = -1
        else:
            saved2: int32 = sys_dup(2)
            sys_dup2(efd, 2)
            sys_close(efd)
            ctx[RCTX_SAVED_STDERR] = saved2
    # `2>&1` — point fd 2 at the same entry fd 1 currently has. Order
    # matters: we copy the POST-`>`-redirect fd 1, so `cmd > /tmp/x
    # 2>&1` routes BOTH streams to /tmp/x exactly like a real shell.
    # Save the prior fd 2 ONLY if it hasn't already been saved by `2>`
    # above (you wouldn't normally write both, but defend cleanly).
    if (nd_c[nu] & 2) != 0:
        if ctx[RCTX_SAVED_STDERR] < 0:
            saved2b: int32 = sys_dup(2)
            ctx[RCTX_SAVED_STDERR] = saved2b
        sys_dup2(1, 2)
    return rc_overall


def _unwire_redirects_self(ctx: Ptr[int32]):
    # Restore fds 0/1/2 from the saves _wire_redirects_self left in
    # ctx. -1 in a slot means "not redirected, nothing to undo".
    # Always restore even on a partial-failure wire — the integer fds
    # that DID get rebound have to be put back so the next prompt's
    # write_cstr1 still hits the console.
    if ctx[RCTX_SAVED_STDIN] >= 0:
        sys_dup2(ctx[RCTX_SAVED_STDIN], 0)
        sys_close(ctx[RCTX_SAVED_STDIN])
    if ctx[RCTX_SAVED_STDOUT] >= 0:
        sys_dup2(ctx[RCTX_SAVED_STDOUT], 1)
        sys_close(ctx[RCTX_SAVED_STDOUT])
    if ctx[RCTX_SAVED_STDERR] >= 0:
        sys_dup2(ctx[RCTX_SAVED_STDERR], 2)
        sys_close(ctx[RCTX_SAVED_STDERR])
    # Release the append-scratch /fd/N: _open_redirect_target_write
    # left REDIRECT_SCRATCH_FD bound (DEVFD_FILE_APPEND) for the
    # duration of the verb so writes via fd 1 resolved through it.
    # Now that fd 1 is restored, rebind the name back to console
    # (idempotent: a no-redirect path that never touched the name
    # rebinds CONS-over-CONS, harmless). This also drops the
    # supervisor's reference to the tmpfs slot — the next `>>` opens
    # a fresh one.
    sys_fdbind(0, REDIRECT_SCRATCH_FD, DEVFD_CONS, 0)


# RFFDG — copy the fd table into the child. Declared next to the other
# RF* bits below (RFPROC / RFNAMEG / ...); mirrored from
# sys/src/9/port/sysproc.ad. A forked builtin stage needs its OWN fd
# table so dup2'ing the pipe Chan onto fd 0/1 cannot disturb the shell's.
RFFDG_BIT: int32 = 0x004

def _route_self_stdio(fdnum: int32, fdname: Ptr[char]):
    # Make the CALLING task's integer fd `fdnum` resolve through the
    # /fd/<fdnum> name in its own Pgrp. Same trick lib/p9.ad's
    # _p9_route_stdio_through_fdname plays for a spawned child: open the
    # /fd name (namec hands back an FD_CHAN_MARK / DEV_DEVFD chan that is
    # resolved per-I/O against the caller's Pgrp) and dup2 it onto the
    # integer slot. Without this, a builtin's write_cstr1 -> sys_write(1)
    # goes straight to the console-backed FD_STDOUT_MARK and BYPASSES the
    # /fd substrate entirely, no matter what /fd/1 is bound to.
    newfd: int32 = sys_open(fdname)
    if newfd < 0:
        return
    if newfd != fdnum:
        sys_dup2(newfd, fdnum)
        sys_close(newfd)


def _run_builtin_in_pipeline(cmdnode: int32, cmd: Ptr[uint8], argc: int32,
                             in_pipe: int32, out_pipe: int32,
                             do_wait: int32) -> int32:
    # A builtin that is a PIPELINE STAGE must run as a real PROCESS.
    #
    # Three independent reasons, any one of which is fatal on its own:
    #
    #   1. CORRECTNESS. The in-process builtin arm below never touched
    #      in_pipe / out_pipe. `echo X | wc -c` therefore wrote X to the
    #      SHELL's console-backed fd 1 while wc, whose /fd/0 was a pipe
    #      with no writer, read instant EOF and printed 0. The left-hand
    #      side of a pipe silently bypassed the pipe.
    #
    #   2. DEADLOCK. run_pipeline launches stages in order, so an inline
    #      builtin runs to completion BEFORE its reader exists. Any
    #      builtin whose output exceeds the pipe buffer would block
    #      forever with nothing on the other end.
    #
    #   3. THE WAIT CONTRACT. run_pipeline stores what this function
    #      returns in pl_pids and sys_waitpid()s it. The inline arm
    #      returned an exit STATUS, so a builtin exiting 1 made the shell
    #      wait on pid 1 (init) — a wait that never returns. That is the
    #      "shell wedges after the pipeline, with both children already
    #      reaped" hang.
    #
    # Consequence, and it is the RIGHT one: a builtin in a pipeline runs
    # in a subshell, so state it mutates (`cd`, `export`, `read`) does not
    # survive the stage. POSIX shells behave identically. A single-command
    # `cd /x` is not a pipeline and still runs at prompt scope.
    #
    # RFPROC|RFFDG|RFNAMEG mirrors lib/p9.ad's _spawn_flags: new process,
    # private fd table, private COW Pgrp. The child wires its OWN /fd
    # names before running the verb — a straight-line, pre-verb sequence
    # in the child's single thread, so no cross-CPU ordering is involved
    # (the same reason spawn_stdio_pipes binds child-side, cf. #136).
    #
    # PIN THE REFCOUNTS BEFORE THE FORK. A pipe end's reader/writer count
    # lives on the pipe slot, and devfd_bind_pipe_w bumps it. If the child
    # were the FIRST holder of the write end, run_pipeline would already
    # have launched the downstream stage — which would find writers == 0
    # and read instant EOF — before the child's bind ever ran. So bind the
    # ends at scratch /fd names HERE, in the shell: pgrp_clone (inside
    # rfork) copies the row and bumps the refcounts again, so the child
    # inherits a live reference the moment it exists, and the shell can
    # drop its own pin immediately afterwards. The count is >= 1 from
    # before the fork until the child exits and devfd_free_row runs.
    if out_pipe >= 0:
        sys_fdbind(0, P9_PIPE_PIN_W, DEVFD_PIPE_W, out_pipe)
    if in_pipe >= 0:
        sys_fdbind(0, P9_PIPE_PIN_R, DEVFD_PIPE_R, in_pipe)
    pid: int32 = sys_rfork(RFPROC | RFFDG_BIT | RFNAMEG)
    if pid < 0:
        # Drop the pins we just took; nothing inherited them.
        if out_pipe >= 0:
            sys_fdbind(0, P9_PIPE_PIN_W, DEVFD_CONS, 0)
        if in_pipe >= 0:
            sys_fdbind(0, P9_PIPE_PIN_R, DEVFD_CONS, 0)
        errstr_set("pipe: cannot fork builtin stage")
        write_cstr1("hamsh: cannot fork builtin pipeline stage: ")
        write_cstr1(cmd)
        write_cstr1("\n")
        if do_wait == 0:
            return -1
        return 1
    if pid == 0:
        # Child. Bind the pipe ends at our own /fd names, then route the
        # integer fds through those names so the verb's sys_write(1, …)
        # lands in the pipe. Finally drop the inherited pins so THIS
        # process holds exactly one reference per end — otherwise the
        # writer count never reaches 0 and the reader never sees EOF.
        if in_pipe >= 0:
            sys_fdbind(0, 0, DEVFD_PIPE_R, in_pipe)
            _route_self_stdio(0, cast[Ptr[char]]("/fd/0"))
        if out_pipe >= 0:
            sys_fdbind(0, 1, DEVFD_PIPE_W, out_pipe)
            _route_self_stdio(1, cast[Ptr[char]]("/fd/1"))
        p9_pipe_pins_release()
        # An explicit redirect on the stage still wins over the pipe
        # (`echo x > f | cat` writes the file, cat sees EOF) — same
        # precedence the external path gives _wire_redirects.
        ctx_c: Array[3, int32]
        rc_child: int32 = 0
        if _cmd_has_redirect(cmdnode) != 0:
            if _wire_redirects_self(cmdnode, &ctx_c[0]) == 0:
                rc_child = run_builtin(cmd, argc)
            else:
                rc_child = 1
            _unwire_redirects_self(&ctx_c[0])
        else:
            rc_child = run_builtin(cmd, argc)
        sys_exit(cast[uint64](cast[int64](rc_child)))
    # Parent. The child's cloned Pgrp holds a reference to each end, so we
    # release our per-stage pins right away. run_pipeline's rolling READ pin
    # (P9_PIPE_PIN_RA/RB) is NOT ours to drop — it guards this stage's output
    # pipe until the downstream stage binds it.
    if out_pipe >= 0:
        sys_fdbind(0, P9_PIPE_PIN_W, DEVFD_CONS, 0)
    if in_pipe >= 0:
        sys_fdbind(0, P9_PIPE_PIN_R, DEVFD_CONS, 0)
    if do_wait == 0:
        return pid
    return cast[int32](sys_waitpid(pid))


def run_one_command_x(cmdnode: int32, in_pipe: int32, out_pipe: int32,
                      do_wait: int32, prebuilt: int32) -> int32:
    # Execute a single ND_CMD. in_pipe / out_pipe are pipe SLOT ids
    # (-1 = none) for a pipeline stage; the shell binds them at the
    # child's /fd/0 / /fd/1. Returns the exit status (do_wait=1) or
    # the pid (do_wait=0).
    #
    # `prebuilt` != 0 means the caller has ALREADY run _argv_build on
    # this node and argv_ptr is still current — do not rebuild. This
    # matters because a word containing a `{ … }` command substitution
    # would re-RUN the substituted command on every _argv_build call;
    # exec_statement already built argv to dispatch the exit/help
    # builtins, so a rebuild here would spawn the substitution twice.
    argc: int32 = 0
    if prebuilt != 0:
        argc = cast[int32](argv_n)
    else:
        argc = _argv_build(cmdnode)
    if argc == 0:
        return 0
    cmd: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[0])

    # builtin? builtins run in-process at the prompt scope (§15).
    # Redirects (`>`, `>>`, `<`, `2>`, `2>&1`) are applied to the
    # CALLING task's integer fds 0/1/2 around the dispatch (mirroring
    # what _wire_redirects does at the spawn boundary for externals).
    # Without this, `echo foo > /tmp/x` silently dropped output to the
    # console because write_cstr1 → sys_write(1, …) → FD_STDOUT_MARK
    # bypasses the /fd substrate even when /fd/1 is bound elsewhere.
    rc_dispatch_check: int32 = _builtin_dispatch_kind_check(cmd)
    if rc_dispatch_check != 0:
        # A builtin that is a PIPELINE STAGE cannot run in-process: it
        # would write past the pipe to the console, it could deadlock on
        # a full pipe with no reader yet, and it would hand run_pipeline
        # an exit status where a PID is required. Fork it.
        if in_pipe >= 0 or out_pipe >= 0:
            return _run_builtin_in_pipeline(cmdnode, cmd, argc,
                                            in_pipe, out_pipe, do_wait)
        ctx: Array[3, int32]
        has_redir: int32 = _cmd_has_redirect(cmdnode)
        wire_rc: int32 = 0
        if has_redir != 0:
            wire_rc = _wire_redirects_self(cmdnode, &ctx[0])
        rc_builtin: int32 = 0
        if wire_rc == 0:
            rc_builtin = run_builtin(cmd, argc)
        else:
            # _wire_redirects_self already populated errstr; surface
            # the diagnosis the same way a verb-internal failure does.
            write_cstr1(cmd)
            write_cstr1(": ")
            write_cstr1(&errstr_buf[0])
            write_cstr1("\n")
            rc_builtin = 1
        if has_redir != 0:
            _unwire_redirects_self(&ctx[0])
        return rc_builtin

    # external command — spawn it in namespace-bind stdio mode (§7).
    #
    # Pin the pipe ends' refcounts in the SHELL's /fd table across the
    # spawn, then hand the slots to spawn_pipeline_stage (through sr_*),
    # which binds them CHILD-side before execve. Both halves are
    # load-bearing: the pin stops the downstream stage seeing writers == 0
    # (instant EOF) and stops the producer seeing readers == 0 (EPIPE,
    # output silently discarded); the child-side bind stops the child
    # racing past a parent-side bind and writing to the inherited console.
    # See lib/p9.ad :: spawn_pipeline_stage for the full argument.
    if out_pipe >= 0:
        sys_fdbind(0, P9_PIPE_PIN_W, DEVFD_PIPE_W, out_pipe)
    if in_pipe >= 0:
        sys_fdbind(0, P9_PIPE_PIN_R, DEVFD_PIPE_R, in_pipe)
    sr_in_pipe = in_pipe
    sr_out_pipe = out_pipe
    pid: int32 = spawn_resolved(cmd, cast[Ptr[uint64]](&argv_ptr[0]))
    sr_in_pipe = -1
    sr_out_pipe = -1
    # The child's cloned Pgrp holds its own reference to each end now, so
    # the shell drops its pins. (On the failure path nothing inherited
    # them, and dropping is equally correct.)
    if out_pipe >= 0:
        sys_fdbind(0, P9_PIPE_PIN_W, DEVFD_CONS, 0)
    if in_pipe >= 0:
        sys_fdbind(0, P9_PIPE_PIN_R, DEVFD_CONS, 0)
    if pid < 0:
        errstr_set("command not found")
        write_cstr1("hamsh: command not found: ")
        write_cstr1(cmd)
        write_cstr1("\n")
        # On the do_wait==0 path the caller expects a PID-or-negative, NOT
        # a wait-status: returning 127 here would be mistaken for a live
        # PID and launch_foreground_pid() would spin forever waiting on a
        # child that never existed (the "not-found hangs the system" bug).
        # Hand back a negative sentinel so the caller's `< 0` guard fires;
        # the waited path keeps 127 as the conventional not-found status.
        if do_wait == 0:
            return -1
        return 127
    # Pipe ends are ALREADY bound, child-side, by spawn_pipeline_stage.
    # Redirects are still wired parent-side: their target Chan is opened
    # here (a tmpfs / device slot) and the child must execve before it can
    # write, which is a far wider window than a pipe stage's.
    _wire_redirects(cmdnode, pid)
    if do_wait == 0:
        # caller manages the pid (pipeline / background)
        return pid
    code: int64 = sys_waitpid(pid)
    return cast[int32](code)


def run_one_command(cmdnode: int32, in_pipe: int32, out_pipe: int32,
                    do_wait: int32) -> int32:
    # Convenience entry: builds argv itself (prebuilt = 0).
    return run_one_command_x(cmdnode, in_pipe, out_pipe, do_wait, 0)


# pipeline stage bookkeeping. PIPE_STAGE_MAX caps how many `|`-joined
# stages one pipeline may have; parse_pipeline rejects more with a
# clean parse error, and run_pipeline clamps defensively so a stage
# count past the arrays can never corrupt memory.
PIPE_STAGE_MAX: uint64 = 64
pl_pids:  Array[64, int32]
pl_pipe:  Array[64, int32]     # inter-stage pipe SLOT ids


def run_pipeline(plnode: int32) -> int32:
    # Run an N-stage pipeline. Each inter-stage pipe is a Chan bound at
    # the producer's /fd/1 (DEVFD_PIPE_W) and the consumer's /fd/0
    # (DEVFD_PIPE_R) — ONE bind op per end (§7). sys_pipechan yields a
    # devtab pipe Chan: a LOCAL pipe is direct Chan reads, never
    # per-block 9P (§6) — the §18 stage-4 test asserts zero mountrpc.
    nstages: uint64 = nd_kn[plnode]
    if nstages == 0:
        return 0
    if nstages == 1:
        return run_one_command(nd_kid_at(plnode, 0), -1, -1, 1)
    # Defensive clamp: parse_pipeline already rejects an over-long
    # pipeline, but never index pl_pipe / pl_pids past their bounds.
    if nstages > PIPE_STAGE_MAX:
        errstr_set("pipe: too many stages")
        return 1
    # Create N-1 pipe Chans up front.
    npipes: uint64 = nstages - 1
    pi: uint64 = 0
    while pi < npipes:
        slot: int32 = sys_pipechan()
        if slot < 0:
            errstr_set("pipe: out of pipe channels")
            return 1
        pl_pipe[pi] = slot
        pi = pi + 1
    # Launch each stage. Its pipe ends are bound CHILD-side (see
    # lib/p9.ad :: spawn_pipeline_stage and _run_builtin_in_pipeline).
    #
    # THE ROLLING READ PIN. A pipe's write end gets its refcount from the
    # producer stage itself, but nothing holds its READ end until the
    # CONSUMER stage is forked one iteration later. In that window the
    # producer is already running, and a write to a pipe with readers == 0
    # is EPIPE — the bytes are silently discarded. So the shell holds a
    # reader reference on pl_pipe[si] from before stage si is forked until
    # after stage si+1 is forked (at which point the consumer's own clone
    # owns one). The windows for successive pipes abut and overlap by
    # exactly one fork, hence two alternating pin slots, not one.
    #
    # Every stage child clears the whole pin block right after binding its
    # real stdio, so no stage carries a stray reference: EOF (writers == 0)
    # and EPIPE (readers == 0) both still fire exactly when they should.
    si: uint64 = 0
    cur_rpin:  int32 = -1               # slot pinning pl_pipe[si]'s read end
    prev_rpin: int32 = -1               # slot pinning pl_pipe[si-1]'s read end
    while si < nstages:
        in_p:  int32 = -1
        out_p: int32 = -1
        if si > 0:
            in_p = pl_pipe[si - 1]       # consumer's /fd/0 = prev pipe
        if si < npipes:
            out_p = pl_pipe[si]          # producer's /fd/1 = this pipe
        cur_rpin = -1
        if out_p >= 0:
            if prev_rpin == P9_PIPE_PIN_RA:
                cur_rpin = P9_PIPE_PIN_RB
            else:
                cur_rpin = P9_PIPE_PIN_RA
            sys_fdbind(0, cur_rpin, DEVFD_PIPE_R, out_p)
        pl_pids[si] = run_one_command(nd_kid_at(plnode, si),
                                      in_p, out_p, 0)
        # Stage si has been forked, so its clone owns a reader reference on
        # pl_pipe[si-1]. Our pin on that pipe has done its job.
        if prev_rpin >= 0:
            sys_fdbind(0, prev_rpin, DEVFD_CONS, 0)
        prev_rpin = cur_rpin
        si = si + 1
    # The last stage has no output pipe, so prev_rpin was already released
    # above. Belt and braces: never leave a pipe end pinned in the shell —
    # it would keep readers > 0 forever and suppress EPIPE.
    if prev_rpin >= 0:
        sys_fdbind(0, prev_rpin, DEVFD_CONS, 0)
    # Wait on every stage; the pipeline's status is the last stage's.
    # The shell holds no pipe fd of its own — each pipe Chan is owned
    # entirely by the two /fd names it was bound at, so EOF propagates
    # when a stage exits and its Pgrp's /fd table is released.
    #
    # EVERY entry in pl_pids is a real PID or a negative sentinel — never
    # an exit status. That invariant used to be violated: run_one_command_x
    # ran a BUILTIN stage in-process and returned its STATUS here, so a
    # builtin exiting 0 made the shell sys_waitpid(0) and one exiting 1 made
    # it sys_waitpid(1) — a blocking wait on init, which never exits. The
    # shell wedged in this very loop with both real children already reaped.
    # _run_builtin_in_pipeline now forks the stage, so a builtin yields a
    # PID like any other stage.
    #
    # NOTE, separate and still open: the blocking sys_waitpid is a kernel-side
    # `while (state != EXITED) yield_to_others()` loop, and under -smp 2 the
    # shell intermittently never resumes from yield_to_others' halt — both
    # stages reap cleanly and hamsh wedges here forever. It reproduces on TCG
    # and KVM, on an UNMODIFIED hamsh, and polling sys_waitpid_jc + sys_yield
    # instead does not avoid it (that path halts in the same place). It is a
    # scheduler bug in kernel/sched/core.ad, not a pipe bug.
    last: int32 = 0
    si = 0
    while si < nstages:
        if pl_pids[si] >= 0:
            code: int64 = sys_waitpid(pl_pids[si])
            if si == nstages - 1:
                last = cast[int32](code)
        si = si + 1
    return last


# ====================================================================
# Job control (§ Tier-1): &, jobs, fg, bg, Ctrl-Z (SIGTSTP) / SIGCONT
# ====================================================================
# hamsh is PID 1 and owns the console. A pipeline launched with `&`
# becomes its own process group (pgid == leader pid); `jobs` lists the
# table, `fg`/`bg` resume + reattach the terminal, and Ctrl-Z stops the
# foreground job. The kernel pieces: SYS_SETPGID (new group), SYS_KILL
# with a negative pgid (signal a whole group), SYS_TCSETPGRP (terminal
# foreground group → routes Ctrl-C/Ctrl-Z), and SYS_WAITPID_JC (non-
# blocking wait reporting EXITED / STOPPED / CONTINUED).
#
# sys_waitpid_jc status word (low byte = kind, status>>8 & 0xFF = data):
#   0 RUNNING     — alive, nothing new (returns 0)
#   1 EXITED      — data = exit code; slot reaped
#   2 STOPPED     — data = stop signal (SIGTSTP=20 / SIGSTOP=19)
#   3 CONTINUED   — resumed since last poll
WAITJC_RUNNING:   int64 = 0
WAITJC_EXITED:    int64 = 1
WAITJC_STOPPED:   int64 = 2
WAITJC_CONTINUED: int64 = 3

# Signal numbers the shell sends (mirror kernel/sched/core.ad).
JC_SIGCONT: int32 = 18
JC_SIGTERM: int32 = 15
JC_SIGKILL: int32 = 9

# Job-table states.
JOB_FREE:    int32 = 0
JOB_RUNNING: int32 = 1
JOB_STOPPED: int32 = 2
JOB_DONE:    int32 = 3      # exited, not yet reported to the user

JOBS_MAX:    uint64 = 32
JOB_CMD_MAX: uint64 = 128

job_state:  Array[32, int32]            # JOB_*
job_pgid:   Array[32, int32]            # process-group id (== leader pid)
job_pid:    Array[32, int32]            # leader pid (single-stage = the cmd)
job_id:     Array[32, int32]            # human job number [%n]
job_code:   Array[32, int32]            # exit code once JOB_DONE
job_cmd:    Array[4096, uint8]          # 32 jobs * 128 bytes, NUL-terminated
job_next_id: int32 = 1                  # monotonically increasing %n
job_current: int32 = 0                  # the "+" job (last touched), 0=none


def _job_find_free() -> int32:
    j: uint64 = 0
    while j < JOBS_MAX:
        if job_state[j] == JOB_FREE:
            return cast[int32](j)
        j = j + 1
    return -1


def _job_by_id(id: int32) -> int32:
    j: uint64 = 0
    while j < JOBS_MAX:
        if job_state[j] != JOB_FREE and job_id[j] == id:
            return cast[int32](j)
        j = j + 1
    return -1


def _job_by_pid(pid: int32) -> int32:
    j: uint64 = 0
    while j < JOBS_MAX:
        if job_state[j] != JOB_FREE and job_pid[j] == pid:
            return cast[int32](j)
        j = j + 1
    return -1


def _job_set_cmd(slot: uint64):
    # Reconstruct the command text from the current argv arena into the
    # job's command buffer (space-joined argv). argv_ptr/argv_n still
    # reflect the command being launched.
    base: uint64 = slot * JOB_CMD_MAX
    o: uint64 = 0
    ai: uint64 = 0
    while ai < argv_n:
        if ai > 0 and o + 1 < JOB_CMD_MAX:
            job_cmd[base + o] = 32              # ' '
            o = o + 1
        s: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[ai])
        k: uint64 = 0
        while s[k] != 0 and o + 1 < JOB_CMD_MAX:
            job_cmd[base + o] = s[k]
            o = o + 1
            k = k + 1
        ai = ai + 1
    job_cmd[base + o] = 0


def _job_register(pid: int32, pgid: int32) -> int32:
    # Allocate a job-table entry for a backgrounded/stopped pipeline.
    # Returns the table slot or -1 if the table is full.
    slot: int32 = _job_find_free()
    if slot < 0:
        return -1
    su: uint64 = cast[uint64](slot)
    job_state[su] = JOB_RUNNING
    job_pid[su]   = pid
    job_pgid[su]  = pgid
    job_id[su]    = job_next_id
    job_code[su]  = 0
    job_next_id   = job_next_id + 1
    _job_set_cmd(su)
    job_current   = job_id[su]
    return slot


def _job_print_cmd(slot: uint64):
    write_cstr1(&job_cmd[slot * JOB_CMD_MAX])


def _job_report_line(slot: uint64, tag: Ptr[uint8]):
    # `[<id>]<+/-> <tag> <cmd>` — the shell's job-status notice line.
    write_cstr1("[")
    write_cstr1(render_int(cast[int64](job_id[slot])))
    write_cstr1("]")
    if job_id[slot] == job_current:
        write_cstr1("+ ")
    else:
        write_cstr1("  ")
    write_cstr1(tag)
    write_cstr1(" ")
    _job_print_cmd(slot)
    write_cstr1("\n")


def jobs_reap_and_report():
    # Called at every prompt: poll each live job non-blockingly, fold in
    # EXITED → JOB_DONE, and print Done/Stopped notices. A reaped DONE
    # job is then freed.
    st_word: Array[1, int64]
    j: uint64 = 0
    while j < JOBS_MAX:
        if job_state[j] == JOB_RUNNING:
            r: int64 = sys_waitpid_jc(job_pid[j], &st_word[0])
            if r > 0:
                kind: int64 = st_word[0] & 0xFF
                if kind == WAITJC_EXITED:
                    job_code[j]  = cast[int32]((st_word[0] >> 8) & 0xFF)
                    job_state[j] = JOB_DONE
                elif kind == WAITJC_STOPPED:
                    job_state[j] = JOB_STOPPED
        if job_state[j] == JOB_DONE:
            _job_report_line(j, "Done")
            job_state[j] = JOB_FREE
        j = j + 1


def _job_wait_foreground(slot: uint64) -> int32:
    # Give the terminal to the EXISTING job's group, then poll it to
    # completion OR until it stops (Ctrl-Z → SIGTSTP). Returns the exit
    # code on exit; on stop, prints the `Stopped` notice and returns -1.
    # Used by `fg` (the job is already in the table). The shell reclaims
    # the terminal (pgid 1) before returning either way.
    st_word: Array[1, int64]
    sys_tcsetpgrp(job_pgid[slot])
    rc: int32 = 0
    while True:
        r: int64 = sys_waitpid_jc(job_pid[slot], &st_word[0])
        if r > 0:
            kind: int64 = st_word[0] & 0xFF
            if kind == WAITJC_EXITED:
                rc = cast[int32]((st_word[0] >> 8) & 0xFF)
                break
            if kind == WAITJC_STOPPED:
                job_state[slot] = JOB_STOPPED
                job_current = job_id[slot]
                rc = -1
                write_cstr1("\n")
                _job_report_line(slot, "Stopped")
                break
        sys_yield()
    # Reclaim the controlling terminal for the shell (pgid 1).
    sys_tcsetpgrp(1)
    return rc


def launch_background(pid: int32):
    # `cmd &` already spawned `pid` (do_wait=0). Put it in its OWN
    # process group (pgid == pid), register the job, and print the
    # standard `[<id>] <pgid>` announce line. The shell does NOT wait —
    # it returns to the prompt immediately.
    if pid <= 0:
        return
    sys_setpgid(pid, pid)
    slot: int32 = _job_register(pid, pid)
    if slot < 0:
        # Table full — leave the child running, just no job control.
        return
    su: uint64 = cast[uint64](slot)
    write_cstr1("[")
    write_cstr1(render_int(cast[int64](job_id[su])))
    write_cstr1("] ")
    write_cstr1(render_int(cast[int64](pid)))
    write_cstr1("\n")


def launch_foreground_pid(pid: int32) -> int32:
    # A non-`&` external command: spawned at `pid`. Put it in its own
    # process group, hand it the terminal, and poll it. On normal exit
    # it consumes NO job number (foreground commands aren't "jobs"). On
    # Ctrl-Z it is registered as a STOPPED job so fg/bg can resume it.
    # Returns the exit code (or 0 after a stop).
    if pid <= 0:
        return 127
    sys_setpgid(pid, pid)
    sys_tcsetpgrp(pid)
    st_word: Array[1, int64]
    rc: int32 = 0
    while True:
        r: int64 = sys_waitpid_jc(pid, &st_word[0])
        if r > 0:
            kind: int64 = st_word[0] & 0xFF
            if kind == WAITJC_EXITED:
                rc = cast[int32]((st_word[0] >> 8) & 0xFF)
                break
            if kind == WAITJC_STOPPED:
                # Promote to a tracked job ONLY now (allocates a %n).
                slot: int32 = _job_register(pid, pid)
                if slot >= 0:
                    su: uint64 = cast[uint64](slot)
                    job_state[su] = JOB_STOPPED
                    job_current = job_id[su]
                    write_cstr1("\n")
                    _job_report_line(su, "Stopped")
                rc = 0
                break
        sys_yield()
    sys_tcsetpgrp(1)
    return rc


def _builtin_jobs(argc: int32):
    # `jobs` — list every tracked job with its state. Reap first so the
    # listing reflects freshly-finished work.
    jobs_reap_and_report()
    any: int32 = 0
    j: uint64 = 0
    while j < JOBS_MAX:
        if job_state[j] == JOB_RUNNING:
            _job_report_line(j, "Running")
            any = 1
        elif job_state[j] == JOB_STOPPED:
            _job_report_line(j, "Stopped")
            any = 1
        j = j + 1
    eval_status = 0


def _jobspec_to_slot(argc: int32) -> int32:
    # Resolve an optional `%n` job spec (argv[1]) to a table slot. With
    # no argument, use the current ("+") job. Returns -1 on miss.
    if argc >= 2:
        spec: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[1])
        i: uint64 = 0
        if spec[0] == 37:                  # '%'
            i = 1
        id: int32 = cast[int32](_parse_dec(&spec[i]))
        return _job_by_id(id)
    if job_current != 0:
        return _job_by_id(job_current)
    return -1


def _builtin_fg(argc: int32):
    # `fg [%n]` — bring a job to the foreground: SIGCONT it if stopped,
    # give it the terminal, and wait for it to exit or stop again.
    jobs_reap_and_report()
    slot: int32 = _jobspec_to_slot(argc)
    if slot < 0:
        errstr_set("fg: no such job")
        eval_status = 1
        return
    su: uint64 = cast[uint64](slot)
    # Echo the command, mimicking bash's `fg` (which prints the cmd).
    _job_print_cmd(su)
    write_cstr1("\n")
    if job_state[su] == JOB_STOPPED:
        sys_pgrp_kill(job_pgid[su], JC_SIGCONT)
        job_state[su] = JOB_RUNNING
    rc: int32 = _job_wait_foreground(su)
    if rc >= 0:
        job_state[su] = JOB_FREE
        eval_status = rc
    else:
        eval_status = 0


def _builtin_bg(argc: int32):
    # `bg [%n]` — resume a stopped job in the background (SIGCONT, no
    # terminal hand-off). Prints `[<id>]+ <cmd> &`.
    jobs_reap_and_report()
    slot: int32 = _jobspec_to_slot(argc)
    if slot < 0:
        errstr_set("bg: no such job")
        eval_status = 1
        return
    su: uint64 = cast[uint64](slot)
    if job_state[su] != JOB_STOPPED:
        errstr_set("bg: job already running")
        eval_status = 1
        return
    sys_pgrp_kill(job_pgid[su], JC_SIGCONT)
    job_state[su] = JOB_RUNNING
    job_current = job_id[su]
    write_cstr1("[")
    write_cstr1(render_int(cast[int64](job_id[su])))
    write_cstr1("]+ ")
    _job_print_cmd(su)
    write_cstr1(" &\n")
    eval_status = 0


# --- command substitution `{ ... } (§8) -----------------------------
# Run a command, capture its stdout into a string. A pipe Chan
# captures the bytes; we drain it after the command exits.
capture_buf: Array[4096, uint8]


def capture_command(sref: uint64) -> int32:
    # Lex+parse the raw command source, run it with stdout bound to a
    # capture pipe, drain it, return the captured text as a STR value.
    src: Ptr[uint8] = str_ptr(sref)
    slen: uint64 = str_len(sref)
    saved_tok: uint64 = _save_tokens()
    saved_pos: uint64 = ps_pos
    lex_line(src, slen)
    ps_pos = 0
    cmdtree: int32 = parse_pipeline()
    captured_ref: uint64 = 0
    if ps_error == 0:
        captured_ref = _run_and_capture(cmdtree)
    else:
        ps_error = 0
    _restore_tokens(saved_tok)
    ps_pos = saved_pos
    return v_str_ref(captured_ref)


# Scratch /fd slot the shell uses to read a capture pipe (§8). It is
# a name in the shell's OWN namespace — `{ … }` capture is, like
# everything else, a Chan bound at an /fd/N name.
CAPTURE_FD: int32 = 9


# Saved argv arena for the nested-capture case (see below).
cap_argv_save: Array[64, uint64]


def _run_and_capture(cmdnode: int32) -> uint64:
    # Spawn the (single-stage) command with /fd/1 bound to a pipe
    # Chan; the shell binds the pipe's read end at its own /fd/9,
    # opens that name to get a readable fd, drains it. Returns an
    # interned string ref of the output with one trailing newline
    # stripped. Command substitution is just another /fd bind (§7/§8).
    k: int32 = nd_kind[cast[uint64](cmdnode)]
    if k != ND_CMD:
        # capture of a pipeline stage — not wired at this milestone
        return 0
    slot: int32 = sys_pipechan()
    if slot < 0:
        return 0
    # Read end at the shell's own /fd/9; open it for a readable fd.
    sys_fdbind(0, CAPTURE_FD, DEVFD_PIPE_R, slot)
    rfd: int32 = sys_open(cast[Ptr[char]]("/fd/9"))
    # A `{ … }` substitution can occur INSIDE an outer command's argv
    # build (`echo X `{ … }``). _argv_build uses the module-global
    # argv_ptr/argv_n arena — so building the inner command's argv
    # would clobber the outer build in progress. Snapshot the outer
    # arena, build the inner one, restore on the way out.
    saved_argv_n: uint64 = argv_n
    si: uint64 = 0
    while si < saved_argv_n and si < ARGV_MAX:
        cap_argv_save[si] = argv_ptr[si]
        si = si + 1
    # Spawn the command; bind the pipe write end at its /fd/1.
    argc: int32 = _argv_build(cmdnode)
    pid: int32 = -1
    if argc > 0:
        cmd: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[0])
        rc_b: int32 = run_builtin(cmd, argc)
        if rc_b < 0:
            pid = spawn_resolved(cmd, cast[Ptr[uint64]](&argv_ptr[0]))
            if pid >= 0:
                sys_fdbind(pid, 1, DEVFD_PIPE_W, slot)
                _wire_redirects(cmdnode, pid)
            else:
                # Not found INSIDE a `{ … }` capture: the substitution
                # value is empty (no stdout). Don't stay fully silent —
                # report to stderr (fd 2), matching the prompt-path style,
                # so the user sees why the substitution produced nothing.
                # (fd 2, not fd 1, so the captured value is unaffected.)
                msg_pfx: Ptr[uint8] = cast[Ptr[uint8]]("hamsh: command not found: ")
                sys_write(2, msg_pfx, cstr_len(msg_pfx))
                sys_write(2, cmd, cstr_len(cmd))
                sys_write(2, cast[Ptr[uint8]]("\n"), 1)
    total: uint64 = 0
    if pid >= 0 and rfd >= 0:
        while True:
            n: int64 = sys_read(rfd, &capture_buf[total],
                                4096 - total)
            if n <= 0:
                break
            total = total + cast[uint64](n)
            if total >= 4096:
                break
        sys_waitpid(pid)
    if rfd >= 0:
        sys_close(rfd)
    # Release the shell's scratch /fd/9 binding so the pipe Chan is
    # reclaimed (re-binding CAPTURE_FD to console drops the pipe ref).
    sys_fdbind(0, CAPTURE_FD, DEVFD_CONS, 0)
    # Restore the outer command's argv arena that our nested
    # _argv_build clobbered (see the snapshot above).
    ri: uint64 = 0
    while ri < saved_argv_n and ri < ARGV_MAX:
        argv_ptr[ri] = cap_argv_save[ri]
        ri = ri + 1
    argv_n = saved_argv_n
    # strip exactly one trailing newline
    if total > 0 and capture_buf[total - 1] == 10:
        total = total - 1
    return str_intern_n(&capture_buf[0], total)


# ====================================================================
# Statement execution
# ====================================================================

# Call-depth guard. A user `def` can call itself; an unbounded
# recursion (`def f() { f() }`) would recurse the C stack and fault.
# Each hamsh call level burns a DEEP chain of native frames
# (call_user_fn -> exec_block -> exec_statement -> eval_call ->
# call_user_fn ...), each carrying sizable Array locals — empirically
# ~14 KiB of the 256 KiB user stack PER hamsh recursion level. Past
# ~16 levels the stack faults, and a fault mid-recursion corrupts the
# argv arena, which then feeds a garbage slot into a pipe syscall
# (observed as a kernel slab bad-free). 12 keeps a wide safety margin
# while still allowing real recursion; past it the call is refused
# (nil + errstr) so the evaluator unwinds cleanly and the prompt
# survives. A non-recursive evaluator would lift this — out of scope.
call_depth:     int32 = 0
CALL_DEPTH_MAX: int32 = 12


def call_user_fn(nameref: uint64, callnode: int32) -> int32:
    # Look up a user-defined function; bind args into a fresh frame;
    # run the body; return its value.
    np: Ptr[uint8] = str_ptr(nameref)
    fi: uint64 = 0
    found: int64 = -1
    while fi < fn_count:
        if cstr_eq(&fn_name[fi * FN_NAME_MAX], np) != 0:
            found = cast[int64](fi)
            break
        fi = fi + 1
    if found < 0:
        return 0
    if call_depth >= CALL_DEPTH_MAX:
        errstr_set("call: recursion too deep")
        eval_status = 1
        return 0
    defnode: int32 = fn_node[cast[uint64](found)]
    dnu: uint64 = cast[uint64](defnode)
    # evaluate args in the CALLER's scope first (kwargs — the trailing
    # ND_KWARG kids counted by nd_c — are not positional parameters).
    nargs: uint64 = nd_kn[cast[uint64](callnode)] \
        - cast[uint64](nd_c[cast[uint64](callnode)])
    argvals: Array[16, int32]
    ai: uint64 = 0
    while ai < nargs and ai < 16:
        argvals[ai] = eval_expr(nd_kid_at(callnode, ai))
        ai = ai + 1
    # push a fresh frame and bind parameters
    mark: int32 = scope_push_frame()
    nparams: uint64 = nd_kn[defnode]
    pi: uint64 = 0
    while pi < nparams:
        pnode: int32 = nd_kid_at(defnode, pi)
        pname: uint64 = nd_str[cast[uint64](pnode)]
        if pi < nargs and pi < 16:
            scope_set(pname, argvals[pi])
        else:
            scope_set(pname, 0)
        pi = pi + 1
    eval_retval = 0
    call_depth = call_depth + 1
    ex: int32 = exec_block(nd_b[dnu])
    call_depth = call_depth - 1
    rv: int32 = 0
    if ex == EX_RETURN:
        rv = eval_retval
    scope_pop_frame(mark)
    return rv


def exec_block(node: int32) -> int32:
    if node == 0:
        return EX_NORMAL
    nu: uint64 = cast[uint64](node)
    i: uint64 = 0
    while i < nd_kn[node]:
        st: int32 = nd_kid_at(node, i)
        ex: int32 = exec_statement(st)
        if ex != EX_NORMAL:
            return ex
        i = i + 1
    return EX_NORMAL


# --- namespace constructs (§10, §11) --------------------------------
# `ns { }` opens a nested scope: snapshot the mount table, run the
# body, restore at the closing brace. We desugar to: rfork(RFNAMEG)
# (a COW copy of the current Pgrp) -> run body -> restore by re-
# cloning... but since rfork(RFNAMEG) in-place gives us a private
# copy, the cleanest correct teardown for `ns {}` is the child-process
# model: fork a child, give the child the private namespace, run the
# body there. For an interactive `ns {}` at the prompt we want binds
# done by builtins inside the block to disappear at the brace AND the
# body to be able to print — so we use rfork(RFPROC|RFNAMEG): the
# child runs the block in its private namespace and the parent waits.

# RF* flag bits — must match sys/src/9/port/sysproc.ad exactly.
RFPROC:   int32 = 0x001       # create a new process
RFNAMEG:  int32 = 0x008       # copy namespace (COW Pgrp clone)
RFCNAMEG: int32 = 0x080       # start child with an EMPTY namespace
RFNOWAIT: int32 = 0x100       # detach — parent never reaps


# Parent-stdio snapshot for the clean-namespace child. `enter NS { }` /
# `ns clean { }` fork a child whose Pgrp is EMPTY (RFCNAMEG), so the child's
# /fd/0,1,2 are gone and must be re-seeded. The OLD code hardcoded them to
# DEVFD_CONS — which sent a windowed DE terminal's `enter linux { ls }`
# output to the SERIAL CONSOLE, invisible in the pane. We instead CAPTURE the
# parent's (kind,arg) for fd 0/1/2 just before the rfork and re-apply them in
# the child, so the child's stdout reaches the SAME pipe/pane as the parent's.
# A slot that was DEVFD_NONE in the parent falls back to CONS (a bare shell on
# the console still gets working stdio).
ns_pstdio_kind: Array[3, int32]
ns_pstdio_arg:  Array[3, int32]


def _ns_capture_parent_stdio():
    # Snapshot the CALLING (parent) task's /fd/0,1,2 bindings. Call this in
    # the PARENT, before rfork — the child's empty Pgrp can't report them.
    f: int32 = 0
    while f < 3:
        ns_pstdio_kind[cast[uint64](f)] = sys_fdslot_kind(0, f)
        ns_pstdio_arg[cast[uint64](f)]  = sys_fdslot_arg(0, f)
        f = f + 1


def _ns_child_ensure_stdio(clean: int32):
    # A namespace-scope child needs working stdio. Under the default
    # overlay (RFNAMEG) the /fd table was COW-copied with the Pgrp, so
    # /fd/0,1,2 are already bound — nothing to do. Under `ns clean`
    # (RFCNAMEG) the Pgrp is EMPTY: re-graft `#d` and re-apply the parent's
    # captured stdio (see _ns_capture_parent_stdio) so the child inherits the
    # real pipe/pane, NOT a hardcoded console.
    if clean != 0:
        sys_bind(cast[Ptr[char]]("/fd"), cast[Ptr[char]]("#d"),
                 MREPL_FLAG)
        f: int32 = 0
        while f < 3:
            k: int32 = ns_pstdio_kind[cast[uint64](f)]
            a: int32 = ns_pstdio_arg[cast[uint64](f)]
            if k == DEVFD_NONE:
                # Parent had nothing bound here — fall back to the console so
                # a bare clean shell on the serial console still has stdio.
                sys_fdbind(0, f, DEVFD_CONS, 0)
            else:
                sys_fdbind(0, f, k, a)
            f = f + 1


def exec_ns(node: int32) -> int32:
    # ns { } — nested namespace scope. Default = overlay (COW copy of
    # the ambient namespace); `ns clean { }` = hermetic empty base.
    # rfork(RFPROC|RFNAMEG) forks a child whose Pgrp is a COW clone;
    # the child runs the body, the parent waits, the child's binds
    # evaporate when it exits (§10).
    nu: uint64 = cast[uint64](node)
    clean: int32 = 0
    if nd_i[nu] != 0:
        clean = 1
    flags: int32 = RFPROC | RFNAMEG
    if clean != 0:
        flags = RFPROC | RFCNAMEG
    # Capture parent stdio BEFORE the fork so a clean child re-inherits the
    # real pipe/pane (not a hardcoded console).
    _ns_capture_parent_stdio()
    pid: int32 = sys_rfork(flags)
    if pid == 0:
        # child: run the body in the private namespace, then exit
        _ns_child_ensure_stdio(clean)
        ex: int32 = exec_block(nd_b[nu])
        # The child's exit status IS the body's last command status
        # (eval_status) — so `enter s { false }` propagates nonzero.
        # A hard evaluator error (EX_ERROR) overrides with 1.
        st: uint64 = cast[uint64](eval_status)
        if ex == EX_ERROR:
            st = 1
        sys_exit(st)
        return EX_NORMAL
    if pid < 0:
        errstr_pull_kernel()
        eval_status = 1
        return EX_NORMAL
    code: int64 = sys_waitpid(pid)
    eval_status = cast[int32](code)
    return EX_NORMAL


def ns_not_a_template(verb: Ptr[uint8], namenode: int32):
    # Shared loud-error path for `enter NAME { }` / `spawn NAME { }` when
    # NAME does not resolve to a VT_NS template (undefined variable, or a
    # value of the wrong type). Previously this was a SILENT no-op: the
    # body ran in the CURRENT namespace (native root), so `enter linux {…}`
    # against an undefined `linux` looked like a plain shell with no ns
    # switch. We now refuse: print to stderr, set eval_status=1, run nothing.
    write_str(2, verb)
    write_str(2, ": not a namespace: ")
    # Best-effort: if NAME was a bare identifier (ND_VAR), name it.
    if nd_kind[cast[uint64](namenode)] == ND_VAR:
        write_str(2, str_ptr(nd_str[cast[uint64](namenode)]))
    else:
        write_str(2, "<expr>")
    write_str(2, "\n")
    eval_status = 1


def exec_enter(node: int32) -> int32:
    # enter NS { body } — synchronous. Fork a child; child does
    # rfork(RFNAMEG), applies the captured namespace, runs the body;
    # parent BLOCKS and propagates the exit status (§11). Variables
    # set inside do NOT leak back (subshell rule, §13).
    #
    # `clean` is the union of two sources: an explicit `enter clean`
    # at the call site (nd_i[node]) AND the captured template's own
    # `ns clean { }` flag (val_aux on the VT_NS value). Evaluating
    # the template up-front in the PARENT lets us pick the right
    # rfork flag (RFNAMEG vs RFCNAMEG) before forking — once we are
    # in the child it is too late to choose. This is what makes
    # `linux = ns clean { ... }` then `enter linux { ... }` actually
    # clean: the template propagates its hermetic base through `=`.
    nu: uint64 = cast[uint64](node)
    clean: int32 = 0
    if nd_i[nu] != 0:
        clean = 1
    nsval: int32 = eval_expr(nd_a[nu])
    if val_type[cast[uint64](nsval)] != VT_NS:
        # Loud refusal instead of silently running the body in the current
        # namespace (the old behaviour made `enter linux {…}` against an
        # undefined `linux` indistinguishable from a plain shell).
        ns_not_a_template("enter", nd_a[nu])
        return EX_NORMAL
    if val_aux[cast[uint64](nsval)] != 0:
        clean = 1
    flags: int32 = RFPROC | RFNAMEG
    if clean != 0:
        flags = RFPROC | RFCNAMEG
    _ns_capture_parent_stdio()
    pid: int32 = sys_rfork(flags)
    if pid == 0:
        # child — apply the captured namespace template, run body.
        _ns_child_ensure_stdio(clean)
        apply_ns_template(nsval)
        ex: int32 = exec_block(nd_b[nu])
        # The child's exit status IS the body's last command status
        # (eval_status) — so `enter s { false }` propagates nonzero.
        # A hard evaluator error (EX_ERROR) overrides with 1.
        st: uint64 = cast[uint64](eval_status)
        if ex == EX_ERROR:
            st = 1
        sys_exit(st)
        return EX_NORMAL
    if pid < 0:
        errstr_pull_kernel()
        eval_status = 1
        return EX_NORMAL
    code: int64 = sys_waitpid(pid)
    eval_status = cast[int32](code)
    return EX_NORMAL


def exec_spawn(node: int32) -> int32:
    # spawn NS { body } — asynchronous. Same fork+rfork+apply, but the
    # shell does NOT wait — it returns a process handle immediately
    # (§11). `spawn detached` uses RFNOWAIT (the service outlives the
    # shell). The handle value lands in eval_retval for the enclosing
    # assignment.
    nu: uint64 = cast[uint64](node)
    detached: int32 = 0
    if nd_i[nu] != 0:
        detached = 1
    # Resolve the captured template up-front (in the PARENT) so we
    # know whether to use RFCNAMEG (hermetic base) or RFNAMEG (overlay).
    # `spawn linux { … }` must honor `linux = ns clean { … }` for the
    # same reason exec_enter does — see the comment there.
    clean: int32 = 0
    nsval: int32 = eval_expr(nd_a[nu])
    if val_type[cast[uint64](nsval)] != VT_NS:
        ns_not_a_template("spawn", nd_a[nu])
        eval_retval = 0
        return EX_NORMAL
    if val_aux[cast[uint64](nsval)] != 0:
        clean = 1
    base_flag: int32 = RFNAMEG
    if clean != 0:
        base_flag = RFCNAMEG
    flags: int32 = RFPROC | base_flag
    if detached != 0:
        flags = RFPROC | base_flag | RFNOWAIT
    _ns_capture_parent_stdio()
    pid: int32 = sys_rfork(flags)
    if pid == 0:
        # The detached flag controls reaping, not the namespace base —
        # the stdio-ensure clean argument tracks the namespace base.
        _ns_child_ensure_stdio(clean)
        apply_ns_template(nsval)
        ex: int32 = exec_block(nd_b[nu])
        # The child's exit status IS the body's last command status
        # (eval_status) — so `enter s { false }` propagates nonzero.
        # A hard evaluator error (EX_ERROR) overrides with 1.
        st: uint64 = cast[uint64](eval_status)
        if ex == EX_ERROR:
            st = 1
        sys_exit(st)
        return EX_NORMAL
    if pid < 0:
        errstr_pull_kernel()
        eval_status = 1
        eval_retval = 0
        return EX_NORMAL
    # parent: build a process handle value, tagged (§13) with the
    # namespace that created it — using the handle from a different
    # namespace later is a loud error (see _handle_pid).
    h: int32 = v_new(VT_PROC)
    val_pay[cast[uint64](h)] = cast[int64](pid)
    val_aux[cast[uint64](h)] = cast[int64](sys_nsid())
    eval_retval = h
    eval_status = 0
    return EX_NORMAL


def apply_ns_template(nsval: int32):
    # A namespace value (VT_NS) carries a captured ND_NS body node in
    # its payload. Applying it = running that body's bind/mount
    # statements in the current (already-rfork'd) namespace.
    if val_type[cast[uint64](nsval)] != VT_NS:
        return
    bodynode: int32 = cast[int32](val_pay[cast[uint64](nsval)])
    if bodynode != 0:
        exec_block(bodynode)


def exec_assign(node: int32) -> int32:
    nu: uint64 = cast[uint64](node)
    op: int32 = cast[int32](nd_i[nu])
    name: uint64 = nd_str[nu]
    rhs_node: int32 = nd_a[nu]
    # `x = ns { ... }` / `x = spawn ...` — the RHS is a special form.
    rk: int32 = nd_kind[cast[uint64](rhs_node)]
    newv: int32 = 0
    if rk == ND_NS:
        # capture the namespace as a VT_NS value (a template — not
        # entered, §11). val_pay holds the body node; val_aux carries
        # the ND_NS `clean` flag (`ns clean { }`) so a later
        # `enter linux { … }` against this template can switch to the
        # hermetic RFCNAMEG base WITHOUT the call-site having to
        # re-state `enter clean`. Without this propagation the
        # template's clean-ness would silently vanish through `=`.
        newv = v_new(VT_NS)
        val_pay[cast[uint64](newv)] = cast[int64](nd_b[cast[uint64](rhs_node)])
        val_aux[cast[uint64](newv)] = nd_i[cast[uint64](rhs_node)]
    elif rk == ND_SPAWN:
        exec_spawn(rhs_node)
        newv = eval_retval
    elif rk == ND_ENTER:
        exec_enter(rhs_node)
        newv = v_int(cast[int64](eval_status))
    else:
        newv = eval_expr(rhs_node)
    if op == OP_PLUSEQ:
        old: int32 = eval_var_by_name(name)
        if val_type[cast[uint64](old)] == VT_STR or \
                val_type[cast[uint64](newv)] == VT_STR:
            newv = _v_concat(old, newv)
        else:
            newv = v_int(_val_as_int(old) + _val_as_int(newv))
    elif op == OP_MINUSEQ:
        old: int32 = eval_var_by_name(name)
        newv = v_int(_val_as_int(old) - _val_as_int(newv))
    scope_set(name, newv)
    # `export VAR=value` (nd_c flag): mirror the assigned value into the
    # /env namespace so children inherit it, same as the bare `export`
    # builtin does for an already-set var.
    if nd_c[nu] != 0:
        env_set(str_ptr(name), v_render_str_only(newv))
    return EX_NORMAL


def exec_tuple_assign(node: int32) -> int32:
    # `a, b = EXPR` — evaluate the RHS FULLY first (so `a, b = b, a` swaps
    # correctly), then bind each target to the corresponding element. A
    # non-list RHS binds the first target and nils the rest.
    nu: uint64 = cast[uint64](node)
    rhs: int32 = eval_expr(nd_a[nu])
    ntar: uint64 = nd_kn[nu]
    cnt: uint64 = _iter_count(rhs)
    i: uint64 = 0
    while i < ntar:
        tnode: int32 = nd_kid_at(node, i)
        val: int32 = 0
        if i < cnt:
            val = _iter_get(rhs, i)
        elif i == 0 and val_type[cast[uint64](rhs)] != VT_LIST:
            val = rhs
        scope_set(nd_str[cast[uint64](tnode)], val)
        i = i + 1
    return EX_NORMAL


def exec_index_assign(node: int32) -> int32:
    # `TARGET[idx] = RHS`. nd_a is the ND_INDEX target (a=base, b=index).
    # A list index overwrites a slot; a dict key sets/inserts. The base
    # is evaluated to its LIVE cell so the mutation is visible through
    # every alias (reference semantics).
    nu: uint64 = cast[uint64](node)
    idxnode: int32 = nd_a[nu]
    cont: int32 = eval_expr(nd_a[cast[uint64](idxnode)])
    bnode: int32 = nd_b[cast[uint64](idxnode)]
    rhs: int32 = eval_expr(nd_b[nu])
    ct: int32 = val_type[cast[uint64](cont)]
    if ct == VT_LIST:
        if nd_kind[cast[uint64](bnode)] == ND_SLICE:
            errstr_set("index-assign: slice assignment unsupported")
            eval_status = 1
            return EX_NORMAL
        ii: int64 = _val_as_int(eval_expr(bnode))
        if v_list_set(cont, ii, rhs) == 0:
            errstr_set("index-assign: list index out of range")
            eval_status = 1
        return EX_NORMAL
    if ct == VT_DICT:
        key: int32 = eval_expr(bnode)
        v_dict_set(cont, key, rhs)
        return EX_NORMAL
    errstr_set("index-assign: target is not a list or dict")
    eval_status = 1
    return EX_NORMAL


def exec_def(node: int32) -> int32:
    # Register the function. The ND_DEF node persists because defs are
    # parsed at the top level and the node arena is not recycled until
    # the next line — so we copy the name and stash the node index.
    # NB: a `def` typed interactively is registered for THIS session;
    # the node it points at survives because parser_reset only runs
    # at the start of the next line and we re-register on redefinition.
    nu: uint64 = cast[uint64](node)
    if fn_count >= FN_MAX:
        return EX_NORMAL
    np: Ptr[uint8] = str_ptr(nd_str[nu])
    # replace if already defined
    fi: uint64 = 0
    slot: uint64 = fn_count
    while fi < fn_count:
        if cstr_eq(&fn_name[fi * FN_NAME_MAX], np) != 0:
            slot = fi
            break
        fi = fi + 1
    j: uint64 = 0
    while np[j] != 0 and j + 1 < FN_NAME_MAX:
        fn_name[slot * FN_NAME_MAX + j] = np[j]
        j = j + 1
    fn_name[slot * FN_NAME_MAX + j] = 0
    fn_node[slot] = node
    if slot >= fn_count:
        fn_count = fn_count + 1
    return EX_NORMAL


def exec_if(node: int32) -> int32:
    nu: uint64 = cast[uint64](node)
    cond: int32 = eval_expr(nd_a[nu])
    if v_is_truthy(cond) != 0:
        return exec_block(nd_b[nu])
    if nd_c[nu] != 0:
        celse: int32 = nd_c[nu]
        if nd_kind[cast[uint64](celse)] == ND_IF:
            return exec_statement(celse)        # elif chain
        return exec_block(celse)
    return EX_NORMAL


def exec_while(node: int32) -> int32:
    nu: uint64 = cast[uint64](node)
    guard: uint64 = 0
    while True:
        cond: int32 = eval_expr(nd_a[nu])
        if v_is_truthy(cond) == 0:
            break
        ex: int32 = exec_block(nd_b[nu])
        if ex == EX_BREAK:
            break
        if ex == EX_RETURN or ex == EX_ERROR or ex == EX_EXIT:
            return ex
        # EX_CONTINUE / EX_NORMAL: keep looping
        guard = guard + 1
        if guard > 100000:
            break
    return EX_NORMAL


def exec_for(node: int32) -> int32:
    # Expand the item-word kids into a flat sequence the SAME way command
    # argv is built (glob expansion + `$list` interpolation), then run the
    # body once per item with VAR bound to it (QA-N18). _argv_build writes
    # the shared argv arena, which the body's own commands clobber, so we
    # snapshot the expanded items into an interned-string list value up
    # front and iterate that.
    nu: uint64 = cast[uint64](node)
    # Expression-iterable / tuple-unpack mode (#110): nd_a is the iterable
    # expression, kids are the target names (>1 = unpack each element).
    if nd_c[nu] != 0:
        iter: int32 = eval_expr(nd_a[nu])
        n2: uint64 = _iter_count(iter)
        i2: uint64 = 0
        while i2 < n2:
            _comp_bind(node, _iter_get(iter, i2))
            ex2: int32 = exec_block(nd_b[nu])
            if ex2 == EX_BREAK:
                break
            if ex2 == EX_RETURN or ex2 == EX_ERROR or ex2 == EX_EXIT:
                return ex2
            i2 = i2 + 1
        return EX_NORMAL
    var: uint64 = nd_str[nu]
    argc: int32 = _argv_build(node)
    items: int32 = v_list_begin()
    j: int32 = 0
    while j < argc:
        v_list_push(items, v_str_cstr(cast[Ptr[uint8]](
            argv_ptr[cast[uint64](j)])))
        j = j + 1
    i: uint64 = 0
    n: uint64 = val_ec[cast[uint64](items)]
    while i < n:
        scope_set(var, v_list_get(items, i))
        ex: int32 = exec_block(nd_b[nu])
        if ex == EX_BREAK:
            break
        if ex == EX_RETURN or ex == EX_ERROR or ex == EX_EXIT:
            return ex
        i = i + 1
    return EX_NORMAL


def exec_try(node: int32) -> int32:
    # try SUITE [except [as e] SUITE] [finally SUITE] — built on errstr
    # (§16). The except block runs when the try block FAILED: either a
    # hard evaluator error (EX_ERROR — including an explicit `raise`), or
    # — the common case — its last command yielded a nonzero exit status
    # (a failed `mount`, a builtin that set errstr, an external command
    # exiting nonzero). Plan 9's model: every command yields a status AND
    # an errstr; `try` keys off the status. $errstr carries the message
    # into the handler; `as e` binds the raised value (or the errstr).
    #
    # The `finally` suite ALWAYS runs — on a normal exit, a caught error,
    # an uncaught (propagating) error, or a control unwind (break /
    # return / continue / exit) out of the try or except body. A control
    # unwind or error raised INSIDE finally overrides the pending outcome.
    nu: uint64 = cast[uint64](node)
    errstr_clear()
    raised_val = 0
    eval_status = 0
    ex: int32 = exec_block(nd_a[nu])
    outcome: int32 = ex
    # A control unwind (return / break / continue / exit) is NOT a
    # failure — it propagates past except (but finally still runs).
    is_unwind: int32 = 0
    if ex == EX_RETURN or ex == EX_BREAK or ex == EX_CONTINUE \
            or ex == EX_EXIT:
        is_unwind = 1
    if is_unwind == 0 and (ex == EX_ERROR or eval_status != 0):
        if nd_b[nu] != 0:                       # an `except` handler
            # bind `except as NAME` to the raised value, or — for a
            # status-only failure — the errstr string.
            if nd_str[nu] != 0:
                ev: int32 = raised_val
                if ev == 0:
                    ev = v_str_cstr(&errstr_buf[0])
                scope_set(nd_str[nu], ev)
            outcome = exec_block(nd_b[nu])
        else:
            outcome = ex                        # no handler: propagate
    # `finally` runs unconditionally; its own unwind/error wins.
    if nd_c[nu] != 0:
        raised_save: int32 = raised_val
        fex: int32 = exec_block(nd_c[nu])
        if fex != EX_NORMAL:
            return fex
        raised_val = raised_save
    return outcome


def _exec_with_enter(node: int32) -> int32:
    # `with enter(NS): body` — the scoped-subshell context manager. Same
    # fork+apply model as `enter NS { }`: a child gets a private namespace
    # (COW overlay, or hermetic base if the template is `ns clean`), applies
    # the template, runs the body, and exits — so every bind the template
    # (or body) makes evaporates at the block's end. The parent waits and
    # propagates the exit status. Auto-undo is inherent to the child model.
    nu: uint64 = cast[uint64](node)
    nsval: int32 = eval_expr(nd_a[nu])
    if val_type[cast[uint64](nsval)] != VT_NS:
        ns_not_a_template("with enter", nd_a[nu])
        return EX_NORMAL
    clean: int32 = 0
    if val_aux[cast[uint64](nsval)] != 0:
        clean = 1
    flags: int32 = RFPROC | RFNAMEG
    if clean != 0:
        flags = RFPROC | RFCNAMEG
    _ns_capture_parent_stdio()
    pid: int32 = sys_rfork(flags)
    if pid == 0:
        _ns_child_ensure_stdio(clean)
        apply_ns_template(nsval)
        ex: int32 = exec_block(nd_c[nu])
        st: uint64 = cast[uint64](eval_status)
        if ex == EX_ERROR:
            st = 1
        sys_exit(st)
        return EX_NORMAL
    if pid < 0:
        errstr_pull_kernel()
        eval_status = 1
        return EX_NORMAL
    code: int64 = sys_waitpid(pid)
    eval_status = cast[int32](code)
    return EX_NORMAL


def exec_with(node: int32) -> int32:
    # §19 (#111): the context-manager statement. `with bind/mount` applies
    # the graft IN THE CURRENT process (so the body sees it and can set
    # variables that persist), then UNDOES it on the way out — normal exit,
    # a body error, or a control unwind (break/return/exit) all still trigger
    # the teardown. A leaked bind is worse than no feature, so the undo is
    # unconditional. `with enter` uses the subshell model (see above).
    nu: uint64 = cast[uint64](node)
    wk: int64 = nd_i[nu]
    if wk == WITH_ENTER:
        return _exec_with_enter(node)
    # Stable per-invocation buffers: the DST path must survive body
    # execution (a nested `with` would clobber a shared/module buffer), so
    # they live on THIS frame. eval_expr / v_render_str_only share render
    # scratch — copy each rendered arg into its buffer before the next.
    srcbuf: Array[128, uint8]
    dstbuf: Array[128, uint8]
    av: int32 = eval_expr(nd_a[nu])
    bv: int32 = eval_expr(nd_b[nu])
    _copy_cstr_into(&srcbuf[0], 128, v_render_str_only(av))
    _copy_cstr_into(&dstbuf[0], 128, v_render_str_only(bv))
    yielded: int32 = 0
    if wk == WITH_BIND:
        # bind SRC onto the lookup path DST (sys_bind new=DST, old=SRC).
        rc: int32 = sys_bind(cast[Ptr[char]](&dstbuf[0]),
                             cast[Ptr[char]](&srcbuf[0]), MREPL_FLAG)
        if rc < 0:
            errstr_pull_kernel()
            eval_status = 1
            return EX_NORMAL             # bind failed — nothing to undo
        yielded = v_str_cstr(&dstbuf[0])
    else:                                # WITH_MOUNT
        if _do_mount(&srcbuf[0], &dstbuf[0], MREPL_FLAG,
                     cast[Ptr[uint8]](0)) < 0:
            eval_status = 1
            return EX_NORMAL             # mount failed — nothing to undo
        h: int32 = v_new(VT_MOUNT)
        val_pay[cast[uint64](h)] = cast[int64](sys_nsid())
        val_aux[cast[uint64](h)] = cast[int64](str_intern_cstr(&dstbuf[0]))
        yielded = h
    # Bind the `as NAME` target so the body can name the handle/path.
    if nd_str[nu] != 0:
        scope_set(nd_str[nu], yielded)
    ex: int32 = exec_block(nd_c[nu])
    # UNCONDITIONAL teardown — unbind/unmount DST regardless of how the
    # body ended. sys_unmount(new=0, old=DST) peels everything at the path.
    sys_unmount(cast[Ptr[char]](0), cast[Ptr[char]](&dstbuf[0]))
    return ex


def _ns_binds_list(nsval: int32) -> int32:
    # §19 (#111): a first-class, iterable view of a namespace template's
    # mount-points. Walk the captured `ns { }` body's bind/mount commands
    # and yield each one's DESTINATION (the lookup path a bind grafts onto,
    # or a mount's attach path) as a string. So `for m in $ns: …` iterates
    # a namespace like any Python collection, and `ns.binds()` returns the
    # list. Only literal-word commands are inspected (templates bind bare
    # paths) — no evaluation side effects, and the shared element pool stays
    # contiguous (no interleaved list allocation).
    lst: int32 = v_list_begin()
    if val_type[cast[uint64](nsval)] != VT_NS:
        return lst
    body: int32 = cast[int32](val_pay[cast[uint64](nsval)])
    if body == 0:
        return lst
    nk: uint64 = nd_kn[cast[uint64](body)]
    i: uint64 = 0
    while i < nk:
        st: int32 = nd_kid_at(body, i)
        if nd_kind[cast[uint64](st)] == ND_CMD:
            mp: int32 = _cmd_mountpoint_node(st)
            if mp != 0:
                v_list_push(lst, mp)
        i = i + 1
    return lst


def _cmd_mountpoint_node(cmdnode: int32) -> int32:
    # The mount-point word of a `bind`/`mount` command: the SECOND non-flag
    # argument after the verb (bind SRC DST -> DST; mount SRC PATH -> PATH).
    # Returns a VT_STR value, or 0 if this command is not a bind/mount or
    # has no such argument. Only literal ND_WORD/ND_STR words are read.
    verb: int32 = nd_kid_at(cmdnode, 0)
    if nd_kind[cast[uint64](verb)] != ND_WORD:
        return 0
    vp: Ptr[uint8] = str_ptr(nd_str[cast[uint64](verb)])
    if cstr_eq(vp, "bind") == 0 and cstr_eq(vp, "mount") == 0:
        return 0
    seen: int32 = 0
    j: uint64 = 1
    nk: uint64 = nd_kn[cast[uint64](cmdnode)]
    while j < nk:
        kid: int32 = nd_kid_at(cmdnode, j)
        kk: int32 = nd_kind[cast[uint64](kid)]
        if kk == ND_WORD or kk == ND_STR:
            wp: Ptr[uint8] = str_ptr(nd_str[cast[uint64](kid)])
            if wp[0] != 45:              # not a '-flag' word
                seen = seen + 1
                if seen == 2:
                    return v_str_ref(nd_str[cast[uint64](kid)])
        j = j + 1
    return 0


def exec_command(node: int32) -> int32:
    # A single command stage that is NOT inside a pipeline. No pipe
    # Chans (-1, -1); the child's /fd/0,1,2 are inherited from the
    # shell's namespace (console) and refined by any redirects.
    rc: int32 = run_one_command(node, -1, -1, 1)
    eval_status = rc
    # exit builtin is handled here for the prompt (help is now /bin/help)
    nu: uint64 = cast[uint64](node)
    return EX_NORMAL


def exec_statement(node: int32) -> int32:
    if node == 0:
        return EX_NORMAL
    nu: uint64 = cast[uint64](node)
    k: int32 = nd_kind[nu]
    if k == ND_BLOCK:
        return exec_block(node)
    if k == ND_ASSIGN:
        return exec_assign(node)
    if k == ND_TUPLEASSIGN:
        return exec_tuple_assign(node)
    if k == ND_INDEXASSIGN:
        return exec_index_assign(node)
    if k == ND_DEF:
        return exec_def(node)
    if k == ND_IF:
        return exec_if(node)
    if k == ND_WHILE:
        return exec_while(node)
    if k == ND_FOR:
        return exec_for(node)
    if k == ND_TRY:
        return exec_try(node)
    if k == ND_WITH:
        return exec_with(node)
    if k == ND_NS:
        return exec_ns(node)
    if k == ND_ENTER:
        return exec_enter(node)
    if k == ND_SPAWN:
        return exec_spawn(node)
    if k == ND_RETURN:
        if nd_a[nu] != 0:
            eval_retval = eval_expr(nd_a[nu])
        else:
            eval_retval = 0
        return EX_RETURN
    if k == ND_BREAK:
        return EX_BREAK
    if k == ND_CONTINUE:
        return EX_CONTINUE
    if k == ND_RAISE:
        # §Exceptions: throw a value (caught by an enclosing try/except).
        # `raise EXPR` carries the value; bare `raise` re-raises the value
        # currently in flight. errstr mirrors the value's string form so
        # `$errstr` reads it and an uncaught raise prints a message.
        if nd_a[nu] != 0:
            raised_val = eval_expr(nd_a[nu])
            errstr_set(v_render_str_only(raised_val))
        eval_status = 1
        return EX_ERROR
    if k == ND_PIPELINE:
        eval_status = run_pipeline(node)
        return EX_NORMAL
    if k == ND_AND:
        l: int32 = exec_statement(nd_a[nu])
        if l != EX_NORMAL:
            return l
        if eval_status == 0:
            return exec_statement(nd_b[nu])
        return EX_NORMAL
    if k == ND_OR:
        l: int32 = exec_statement(nd_a[nu])
        if l != EX_NORMAL:
            return l
        if eval_status != 0:
            return exec_statement(nd_b[nu])
        return EX_NORMAL
    if k == ND_CMD:
        # check for the exit builtin which needs to unwind
        argc: int32 = _argv_build(node)
        if argc >= 1:
            cmd: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[0])
            if cstr_eq(cmd, "exit") != 0:
                if argc >= 2:
                    eval_status = cast[int32](_parse_dec(
                        cast[Ptr[uint8]](argv_ptr[1])))
                return EX_EXIT
            # `help` is no longer a hamsh-internal builtin: it now
            # spawns /bin/help (user/help.ad), which prints the
            # discovery index by walking /usr/share/man/. Falling
            # through to _run_prebuilt_command below dispatches the
            # external binary like any other command. The old
            # hard-coded `builtin_help()` (printed a fixed 5-line
            # crib) has been deleted along with this dispatch arm —
            # see commit message for the migration rationale.
            if cstr_eq(cmd, "true") != 0:
                eval_status = 0
                return EX_NORMAL
            if cstr_eq(cmd, "false") != 0:
                eval_status = 1
                return EX_NORMAL
            if cstr_eq(cmd, "kill") != 0:
                _builtin_kill(node, argc)
                return EX_NORMAL
            if cstr_eq(cmd, "wait") != 0:
                _builtin_wait(node, argc)
                return EX_NORMAL
            # Job-control builtins MUST run in PID 1 (they hand off the
            # controlling terminal and wait on jobs), so they dispatch
            # here, not through the external-spawn path.
            if cstr_eq(cmd, "jobs") != 0:
                _builtin_jobs(argc)
                return EX_NORMAL
            if cstr_eq(cmd, "fg") != 0:
                _builtin_fg(argc)
                return EX_NORMAL
            if cstr_eq(cmd, "bg") != 0:
                _builtin_bg(argc)
                return EX_NORMAL
        # argv is already built; run the command directly
        eval_status = _run_prebuilt_command(node, argc)
        return EX_NORMAL
    if k == ND_EXPRSTMT:
        eval_expr(nd_a[nu])
        return EX_NORMAL
    # a bare expression statement (e.g. a function call as a statement)
    eval_expr(node)
    return EX_NORMAL


def _parse_dec(s: Ptr[uint8]) -> int64:
    i: uint64 = 0
    neg: int32 = 0
    if s[0] == 45:
        neg = 1
        i = 1
    r: int64 = 0
    while s[i] >= 48 and s[i] <= 57:
        r = r * 10 + cast[int64](s[i] - 48)
        i = i + 1
    if neg != 0:
        return -r
    return r


def _run_prebuilt_command(node: int32, argc: int32) -> int32:
    # exec_statement has ALREADY run _argv_build on `node` (to dispatch
    # the exit/true/false builtins) and argv_ptr is still current.
    # Pass prebuilt=1 so run_one_command_x does NOT rebuild — a rebuild
    # would re-RUN any `{ … }` command substitution in the argv. No
    # pipe Chans for a single command statement (-1, -1).
    # A trailing `&` (nd_c bit2) backgrounds the command: spawn without
    # waiting (do_wait=0), drop the child into its own process group,
    # register a job, and print `[<id>] <pgid>`. The shell returns to
    # the prompt immediately. The builtin-dispatch fast path inside
    # run_one_command_x means a builtin with `&` just runs synchronously
    # (returns a status, not a pid) — there's no child to background, so
    # launch_background's pid<=0 guard makes that a harmless no-op.
    # Is this an external command (vs an in-process builtin)? Only
    # externals are real spawned children that job control applies to.
    argc_pb: int32 = cast[int32](argv_n)
    is_external: int32 = 0
    if argc_pb >= 1:
        cmd_pb: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[0])
        if _builtin_dispatch_kind_check(cmd_pb) == 0:
            is_external = 1
    if (nd_c[cast[uint64](node)] & 4) != 0:
        # `&`: a builtin with `&` just runs synchronously (no child to
        # background); an external spawns into its own group as a job.
        if is_external != 0:
            bgpid: int32 = run_one_command_x(node, -1, -1, 0, 1)
            launch_background(bgpid)
            return 0
        return run_one_command_x(node, -1, -1, 1, 1)
    # Foreground: an external spawns do_wait=0 (we get the pid) then
    # job-control-waits so Ctrl-Z can suspend it; a builtin runs in
    # process as before.
    if is_external != 0:
        fgpid: int32 = run_one_command_x(node, -1, -1, 0, 1)
        if fgpid < 0:
            return 127
        return launch_foreground_pid(fgpid)
    return run_one_command_x(node, -1, -1, 1, 1)


# --- service supervisor (§11) ---------------------------------------
# A small init-side service supervisor. hamsh-as-PID-1 owns a fixed-
# size table of "known services" — each entry is a name, a namespace
# selector (init / linux / ...), an exec command line, and a restart
# policy. The `svc` builtin (see further below) drives status / start /
# stop / restart / reload against this table, and a periodic
# supervisor tick (called from the idle poll loop in ed_readline)
# reaps exited supervised children and applies the restart policy.
#
# WHY THIS LIVES IN HAMSH
# -----------------------
# /init is a 2-line shim that execs /bin/hamsh /etc/rc.boot — so
# hamsh IS PID 1, and a "supervisor in init's default namespace" is
# straightforwardly a hamsh module with module-scope state. A managed
# service is just a child of PID 1, spawned WITHOUT RFNOWAIT so the
# parent (the supervisor) can reap it. Compare `spawn detached` which
# uses RFNOWAIT and self-reaps — that path is fire-and-forget; the
# supervisor needs the opposite (reap-and-restart).
#
# CROSS-NAMESPACE START (§11)
# ---------------------------
# `ns: linux` in /etc/svc/<name>.hamsh dispatches via the same
# captured-template + sys_rfork(RFPROC|RFCNAMEG) + apply_ns_template
# path that `enter linux { … }` and `spawn linux { … }` use. The
# template is looked up by name in the hamsh scope (set in rc.boot:
# `linux = ns clean { … }`), so the supervisor itself doesn't need
# to know what `linux` binds — it consumes the same captured ns
# value as the regular `enter`/`spawn` verbs.

SVC_MAX:        uint64 = 32
SVC_NAME_MAX:   uint64 = 32
SVC_CMD_MAX:    uint64 = 256
SVC_NS_MAX:     uint64 = 16
SVC_DESC_MAX:   uint64 = 96

# Service states. Plain integers; svc_render_status maps to text.
SVC_STATE_STOPPED:    int32 = 0   # never started, or stopped cleanly
SVC_STATE_RUNNING:    int32 = 1   # child alive
SVC_STATE_FAILED:     int32 = 2   # exited with non-zero, no auto-restart
SVC_STATE_RESTARTING: int32 = 3   # waiting on backoff before next start

# Restart policies.
SVC_RESTART_NEVER:     int32 = 0
SVC_RESTART_ON_FAIL:   int32 = 1
SVC_RESTART_ALWAYS:    int32 = 2

# Service table — parallel arrays in the existing hamsh idiom. Each
# index i in [0, svc_count) is one service. svc_in_use[i] != 0 makes
# the slot "occupied" (we don't compact on removal — a removed slot is
# just marked free so its name can be re-registered later).
svc_in_use:        Array[32, int32]
svc_name:          Array[1024, uint8]      # 32 * 32 bytes, NUL-terminated
svc_ns:            Array[512, uint8]       # 32 * 16 bytes, NUL-terminated
svc_cmd:           Array[8192, uint8]      # 32 * 256 bytes, NUL-terminated
svc_desc:          Array[3072, uint8]      # 32 * 96 bytes, NUL-terminated
svc_state:         Array[32, int32]
svc_restart_pol:   Array[32, int32]
svc_pid:           Array[32, int32]        # 0 when not running
svc_last_exit:     Array[32, int32]
# docs/security.md Phase 11: per-service uid. Defaults to 1
# (hostowner) when the .hamsh file doesn't declare a `uid:` field.
# System services like sshd should set `uid: 2` so a sshd compromise
# doesn't grant hostowner authority. The supervisor switches to this
# uid via sys_setuid in the rfork'd child BEFORE spawn().
svc_uid:           Array[32, uint32]
svc_restarts:      Array[32, int32]        # restarts in this session
svc_backoff_ms:    Array[32, int64]        # current backoff (ms)
svc_backoff_init:  Array[32, int64]        # configured initial
svc_backoff_max:   Array[32, int64]        # configured ceiling
svc_last_start_j:  Array[32, uint64]       # jiffies at last start
svc_next_start_j:  Array[32, uint64]       # jiffies at which to start
# Stop-requested latch. svc_stop() sets this when an operator (or a
# runlevel 0/6 stop-all) deliberately SIGTERMs a service. The reaper
# consults it: a deliberately-stopped service that exits — even with
# the non-zero SIGTERM exit code (143) — is STOPPED, not FAILED. Reset
# to 0 on every (re)start so a later unexpected crash still reads
# FAILED. Without this, `service NAME stop` left the service `failed`.
svc_stop_req:      Array[32, int32]
# Runlevel / autostart (init-system layer). svc_enabled[i] != 0 means
# the service autostarts when its runlevel is entered. svc_runlevel[i]
# is a bitmask of runlevels the service belongs to: bit N = runlevel N
# (so a service in runlevels 3 and 5 has mask (1<<3)|(1<<5)). The
# declarative .svc file sets these via `enabled: yes` and
# `runlevel: 3 5`. The default multi-user level is 3.
svc_enabled:       Array[32, int32]
svc_runlevel:      Array[32, int32]        # bitmask of runlevels

svc_count:         uint64 = 0              # high-water mark (slots seen)

# Current runlevel. -1 = "not yet entered" (boot). The default
# multi-user runlevel is 3. Runlevel 0 = halt/poweroff, 6 = reboot,
# 5 = graphical (hamUI) bringup.
SVC_DEFAULT_RUNLEVEL: int32 = 3
svc_current_runlevel: int32 = -1


def _svc_name_at(idx: uint64) -> Ptr[uint8]:
    return &svc_name[idx * SVC_NAME_MAX]


def _svc_ns_at(idx: uint64) -> Ptr[uint8]:
    return &svc_ns[idx * SVC_NS_MAX]


def _svc_cmd_at(idx: uint64) -> Ptr[uint8]:
    return &svc_cmd[idx * SVC_CMD_MAX]


def _svc_desc_at(idx: uint64) -> Ptr[uint8]:
    return &svc_desc[idx * SVC_DESC_MAX]


def _svc_copy_in(dst: Ptr[uint8], src: Ptr[uint8], cap: uint64):
    # NUL-terminated bounded copy. Truncates rather than overflowing.
    i: uint64 = 0
    while src[i] != 0 and i + 1 < cap:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0


def svc_lookup(name: Ptr[uint8]) -> int32:
    # Return the slot index for `name`, or -1 if not registered.
    i: uint64 = 0
    while i < svc_count:
        if svc_in_use[i] != 0:
            if cstr_eq(_svc_name_at(i), name) != 0:
                return cast[int32](i)
        i = i + 1
    return -1


def _svc_alloc_slot() -> int32:
    # Find an unused slot. Returns -1 if the table is full.
    i: uint64 = 0
    while i < SVC_MAX:
        if svc_in_use[i] == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def svc_register(name: Ptr[uint8], ns: Ptr[uint8], cmdline: Ptr[uint8],
                 restart_pol: int32, backoff_ms: int64,
                 backoff_max_ms: int64, desc: Ptr[uint8],
                 uid: uint32, enabled: int32, runlevel: int32) -> int32:
    # Register a service (or refresh an existing entry's static fields).
    # Returns the slot index, or -1 on overflow. Does NOT start the
    # service — that's svc_start (Phase 3). `enabled`/`runlevel` come
    # from the declarative .svc file: `enabled: yes` and `runlevel: 3 5`.
    idx: int32 = svc_lookup(name)
    if idx < 0:
        idx = _svc_alloc_slot()
        if idx < 0:
            errstr_set("svc: table full")
            return -1
        u: uint64 = cast[uint64](idx)
        svc_in_use[u] = 1
        svc_state[u] = SVC_STATE_STOPPED
        svc_pid[u] = 0
        svc_last_exit[u] = 0
        svc_restarts[u] = 0
        svc_last_start_j[u] = 0
        svc_next_start_j[u] = 0
        if u >= svc_count:
            svc_count = u + 1
    u: uint64 = cast[uint64](idx)
    _svc_copy_in(_svc_name_at(u), name, SVC_NAME_MAX)
    _svc_copy_in(_svc_ns_at(u), ns, SVC_NS_MAX)
    _svc_copy_in(_svc_cmd_at(u), cmdline, SVC_CMD_MAX)
    _svc_copy_in(_svc_desc_at(u), desc, SVC_DESC_MAX)
    svc_restart_pol[u] = restart_pol
    svc_backoff_init[u] = backoff_ms
    svc_backoff_max[u]  = backoff_max_ms
    svc_backoff_ms[u]   = backoff_ms
    svc_enabled[u] = enabled
    svc_runlevel[u] = runlevel
    # docs/security.md Phase 11: stash the parsed uid. The spawn-into-
    # ns path reads it back and calls sys_setuid in the rfork'd child
    # before exec — service compromise then doesn't grant hostowner
    # authority.
    svc_uid[u] = uid
    # /proc/svc Phase 6: mirror the freshly-registered entry into the
    # kernel so `cat /proc/svc/<name>` works the instant a service
    # is registered (even before its first start).
    _svc_publish_to_kernel(idx)
    return idx


def svc_state_set(idx: int32, st: int32):
    if idx < 0:
        return
    u: uint64 = cast[uint64](idx)
    if u >= SVC_MAX:
        return
    svc_state[u] = st
    # Mirror to the kernel so `cat /proc/svc/<name>` sees the change.
    _svc_publish_to_kernel(idx)


# /proc/svc Phase 6: 400-byte staging buffer used to ship one service
# slot into the kernel mirror (fs/procfs.ad::svc_proc_publish). Layout
# must match the kernel decoder byte-for-byte:
#   off  size  field          (little-endian)
#     0    4   state          (int32)
#     4    4   pid            (int32)
#     8    4   restart_pol    (int32)
#    12    4   restarts       (int32)
#    16    4   uid            (uint32)
#    20    4   _pad
#    24    8   last_start_j   (uint64)
#    32   16   ns             (NUL-terminated, max 16 bytes)
#    48  256   exec           (NUL-terminated, max 256 bytes)
#   304   96   desc           (NUL-terminated, max 96 bytes)
SVC_PUBLISH_PAYLOAD_BYTES: uint64 = 400
svc_publish_buf:           Array[400, uint8]


def _svc_pub_put_u32(off: uint64, v: uint32):
    svc_publish_buf[off]     = cast[uint8](v & 0xFF)
    svc_publish_buf[off + 1] = cast[uint8]((v >> 8)  & 0xFF)
    svc_publish_buf[off + 2] = cast[uint8]((v >> 16) & 0xFF)
    svc_publish_buf[off + 3] = cast[uint8]((v >> 24) & 0xFF)


def _svc_pub_put_i32(off: uint64, v: int32):
    _svc_pub_put_u32(off, cast[uint32](v))


def _svc_pub_put_u64(off: uint64, v: uint64):
    _svc_pub_put_u32(off,     cast[uint32](v & 0xFFFFFFFF))
    _svc_pub_put_u32(off + 4, cast[uint32]((v >> 32) & 0xFFFFFFFF))


def _svc_pub_put_cstr(off: uint64, cap: uint64, src: Ptr[uint8]):
    # Copy NUL-terminated `src` into svc_publish_buf at [off, off+cap),
    # zero-padding remaining bytes so previously-published longer
    # strings don't bleed into a shorter one.
    i: uint64 = 0
    while i < cap:
        if i + 1 < cap and src[i] != 0:
            svc_publish_buf[off + i] = src[i]
        else:
            svc_publish_buf[off + i] = 0
        if src[i] == 0:
            # Zero out the rest of the field.
            while i < cap:
                svc_publish_buf[off + i] = 0
                i = i + 1
            return
        i = i + 1


def _svc_publish_to_kernel(idx: int32):
    # Build the 400-byte payload for slot `idx` and call SYS_SVC_PUBLISH.
    # Silent on failure — the kernel mirror is a best-effort introspection
    # hook, not a load-bearing dependency. A full mirror (32 entries) on
    # a system with more services would just stop accepting publishes;
    # the supervisor's own status still works.
    if idx < 0:
        return
    u: uint64 = cast[uint64](idx)
    if u >= SVC_MAX or svc_in_use[u] == 0:
        return
    _svc_pub_put_i32(0,  svc_state[u])
    _svc_pub_put_i32(4,  svc_pid[u])
    _svc_pub_put_i32(8,  svc_restart_pol[u])
    _svc_pub_put_i32(12, svc_restarts[u])
    _svc_pub_put_u32(16, svc_uid[u])
    _svc_pub_put_u32(20, 0)                          # _pad
    _svc_pub_put_u64(24, svc_last_start_j[u])
    _svc_pub_put_cstr(32,  16,  _svc_ns_at(u))
    _svc_pub_put_cstr(48,  256, _svc_cmd_at(u))
    _svc_pub_put_cstr(304, 96,  _svc_desc_at(u))
    sys_svc_publish(_svc_name_at(u), &svc_publish_buf[0])


def _svc_state_label(st: int32) -> Ptr[uint8]:
    if st == SVC_STATE_RUNNING:
        return "running"
    if st == SVC_STATE_FAILED:
        return "failed"
    if st == SVC_STATE_RESTARTING:
        return "restarting"
    return "stopped"


def _svc_restart_label(p: int32) -> Ptr[uint8]:
    if p == SVC_RESTART_ALWAYS:
        return "always"
    if p == SVC_RESTART_ON_FAIL:
        return "on-failure"
    return "never"


def svc_render_one(idx: int32):
    # Render one service's status to fd 1. Used by `svc status <name>`.
    if idx < 0:
        return
    u: uint64 = cast[uint64](idx)
    write_cstr1(_svc_name_at(u))
    write_cstr1("  state=")
    write_cstr1(_svc_state_label(svc_state[u]))
    write_cstr1("  ns=")
    write_cstr1(_svc_ns_at(u))
    write_cstr1("  pid=")
    write_cstr1(render_int(cast[int64](svc_pid[u])))
    write_cstr1("  restart=")
    write_cstr1(_svc_restart_label(svc_restart_pol[u]))
    write_cstr1("  restarts=")
    write_cstr1(render_int(cast[int64](svc_restarts[u])))
    # Uptime in seconds (only meaningful when running).
    if svc_state[u] == SVC_STATE_RUNNING and svc_last_start_j[u] != 0:
        now: uint64 = sys_get_jiffies()
        if now >= svc_last_start_j[u]:
            up_j: uint64 = now - svc_last_start_j[u]
            write_cstr1("  uptime=")
            write_cstr1(render_int(cast[int64](up_j / 100)))
            write_cstr1("s")
    write_cstr1("  exec=")
    write_cstr1(_svc_cmd_at(u))
    if _svc_desc_at(u)[0] != 0:
        write_cstr1("  desc=")
        write_cstr1(_svc_desc_at(u))
    write_cstr1("\n")


def svc_render_status():
    # `svc status` (no name): dump every registered service.
    if svc_count == 0:
        write_cstr1("svc: no services registered\n")
        return
    i: uint64 = 0
    while i < svc_count:
        if svc_in_use[i] != 0:
            svc_render_one(cast[int32](i))
        i = i + 1


# --- service supervisor: argv build + start path -------------------
# argv staging for the supervisor's own spawn() calls. Kept separate
# from the shell's main argv_ptr/argv_strs arenas so a supervisor tick
# firing mid-command doesn't trample the in-flight argv.
SVC_SPAWN_ARGV_MAX:    uint64 = 16
SVC_SPAWN_ARGV_BYTES:  uint64 = 1024
svc_spawn_argv_buf:    Array[1024, uint8]
svc_spawn_argv_ptr:    Array[16, uint64]
svc_spawn_argv_n:      uint64 = 0
svc_spawn_argv_cursor: uint64 = 0


def _svc_argv_tokenize(cmd: Ptr[uint8]) -> int32:
    # Tokenize a command line into svc_spawn_argv_buf + svc_spawn_argv_ptr.
    # Whitespace split with QUOTE awareness: a token may be wrapped in
    # matching '...' or "..." so an exec line can carry args that contain
    # spaces, e.g. `exec: /bin/hamnotify "Welcome to Hamnix" "DE up"` (the
    # boot welcome notification). The quotes are stripped; whitespace inside
    # them is preserved. Unquoted lines (the common case: `/bin/sshd`,
    # `/bin/foo -x`) tokenize exactly as before — this is back-compatible.
    svc_spawn_argv_n = 0
    svc_spawn_argv_cursor = 0
    i: uint64 = 0
    while cmd[i] != 0:
        # Skip leading whitespace.
        while cmd[i] != 0 and (cmd[i] == 32 or cmd[i] == 9):
            i = i + 1
        if cmd[i] == 0:
            break
        if svc_spawn_argv_n >= SVC_SPAWN_ARGV_MAX:
            return -1
        # Record pointer at current cursor.
        svc_spawn_argv_ptr[svc_spawn_argv_n] = \
            cast[uint64](&svc_spawn_argv_buf[svc_spawn_argv_cursor])
        # Copy bytes until unquoted whitespace, honouring quote runs.
        # quote = 0 (none) / 34 (") / 39 (') = the active opening quote char.
        quote: uint8 = 0
        while cmd[i] != 0:
            c: uint8 = cmd[i]
            if quote != 0:
                if c == quote:
                    quote = 0                       # closing quote: drop it
                    i = i + 1
                else:
                    if svc_spawn_argv_cursor + 1 >= SVC_SPAWN_ARGV_BYTES:
                        return -1
                    svc_spawn_argv_buf[svc_spawn_argv_cursor] = c
                    svc_spawn_argv_cursor = svc_spawn_argv_cursor + 1
                    i = i + 1
            else:
                if c == 32 or c == 9:
                    break
                if c == 34 or c == 39:              # opening quote: drop it
                    quote = c
                    i = i + 1
                else:
                    if svc_spawn_argv_cursor + 1 >= SVC_SPAWN_ARGV_BYTES:
                        return -1
                    svc_spawn_argv_buf[svc_spawn_argv_cursor] = c
                    svc_spawn_argv_cursor = svc_spawn_argv_cursor + 1
                    i = i + 1
        # NUL-terminate this argv slot.
        if svc_spawn_argv_cursor + 1 >= SVC_SPAWN_ARGV_BYTES:
            return -1
        svc_spawn_argv_buf[svc_spawn_argv_cursor] = 0
        svc_spawn_argv_cursor = svc_spawn_argv_cursor + 1
        svc_spawn_argv_n = svc_spawn_argv_n + 1
    # NULL-terminate argv array.
    if svc_spawn_argv_n >= SVC_SPAWN_ARGV_MAX:
        return -1
    svc_spawn_argv_ptr[svc_spawn_argv_n] = 0
    return cast[int32](svc_spawn_argv_n)


# --- per-service log capture (Phase 12) -----------------------------
# Every managed service has its stdout (fd 1) AND stderr (fd 2)
# redirected to /var/log/svc/<name>.log via a single DEVFD_FILE_APPEND
# tmpfs slot. The kernel-side primitive (devfd_bind_file_append, write
# arm always lands at tmpfs_size) makes BOTH binds safe against each
# other (no cursor collisions) AND across `svc restart` (the file is
# re-opened with tmpfs_open_for_append which preserves size). The
# /var/log/svc directory is pre-created by tmpfs_var_skeleton_init at
# kernel boot.
#
# The supervisor also writes a `--- restart at uptime=Nms ---` line
# before EVERY start (the first one too — it doubles as a per-boot
# header so a log that survives reboots-of-a-persistent-tmpfs would
# still group runs visibly). The supervisor writes via a scratch /fd
# slot in its OWN namespace bound to the same DEVFD_FILE_APPEND
# backing, so the separator and the child's output both land at EOF
# without coordination.
SVC_LOG_PATH_MAX: uint64 = 64
svc_log_path_buf: Array[64, uint8]
# Supervisor-side scratch /fd slot for separator writes. DEVFD_SLOTS
# is 16; 0/1/2 are stdio, 9 is CAPTURE_FD. 10 is well clear of both
# and not used by any pipeline path.
SVC_LOG_SCRATCH_FD: int32 = 10


def _svc_build_log_path(idx: int32):
    # Stamp svc_log_path_buf with `/var/log/svc/<name>.log`. The name
    # is bounded by SVC_NAME_MAX (32), the prefix is 13 bytes, the
    # suffix is 4 — well within the 64-byte buffer.
    if idx < 0:
        svc_log_path_buf[0] = 0
        return
    u: uint64 = cast[uint64](idx)
    prefix: Ptr[uint8] = "/var/log/svc/"
    suffix: Ptr[uint8] = ".log"
    name: Ptr[uint8] = _svc_name_at(u)
    pi: uint64 = 0
    while prefix[pi] != 0:
        svc_log_path_buf[pi] = prefix[pi]
        pi = pi + 1
    ni: uint64 = 0
    while name[ni] != 0 and pi + 1 < SVC_LOG_PATH_MAX:
        svc_log_path_buf[pi] = name[ni]
        pi = pi + 1
        ni = ni + 1
    si: uint64 = 0
    while suffix[si] != 0 and pi + 1 < SVC_LOG_PATH_MAX:
        svc_log_path_buf[pi] = suffix[si]
        pi = pi + 1
        si = si + 1
    svc_log_path_buf[pi] = 0


def _svc_open_log_chan(idx: int32) -> int32:
    # Open /var/log/svc/<name>.log as an OPENCHAN_APPEND tmpfs slot.
    # Returns the slot id (>= 0) or -1. The slot is global (tmpfs
    # entries are task-independent), so binding it into both the
    # supervisor's /fd table (for the separator write) and a child's
    # /fd table (for stdout+stderr) addresses the same backing.
    _svc_build_log_path(idx)
    if svc_log_path_buf[0] == 0:
        return -1
    return sys_openchan(cast[Ptr[char]](&svc_log_path_buf[0]),
                        OPENCHAN_APPEND)


SVC_LOG_DEVFD_PATH:  Array[8, uint8]   # "/fd/10\0", filled lazily
svc_log_devfd_inited: int32 = 0


def _svc_log_devfd_path() -> Ptr[char]:
    # Lazy-init "/fd/<SVC_LOG_SCRATCH_FD>\0" once. /fd/10 in the
    # supervisor's namespace is the route the separator write takes;
    # opening this path through vfs_open_write installs a kernel
    # integer fd whose vfs_write arm routes through devfd_write at
    # the SVC_LOG_SCRATCH_FD name. Without this kfd, sys_write(10, …)
    # would simply EBADF — the supervisor has no integer fd 10 open
    # at task start, only the /fd/N NAME side of the substrate.
    if svc_log_devfd_inited == 0:
        SVC_LOG_DEVFD_PATH[0] = 47     # '/'
        SVC_LOG_DEVFD_PATH[1] = 102    # 'f'
        SVC_LOG_DEVFD_PATH[2] = 100    # 'd'
        SVC_LOG_DEVFD_PATH[3] = 47     # '/'
        SVC_LOG_DEVFD_PATH[4] = 49     # '1'
        SVC_LOG_DEVFD_PATH[5] = 48     # '0'
        SVC_LOG_DEVFD_PATH[6] = 0
        svc_log_devfd_inited = 1
    return cast[Ptr[char]](&SVC_LOG_DEVFD_PATH[0])


def _svc_write_restart_separator(idx: int32, slot: int32):
    # Emit a one-line marker into /var/log/svc/<name>.log BEFORE the
    # next child writes its first byte. The supervisor doesn't have a
    # writable kernel fd to the log channel yet — it has the tmpfs
    # SLOT (returned by sys_openchan) and the supervisor's own /fd
    # table. We bridge them in three steps:
    #
    #   1. sys_fdbind(0, SCRATCH, DEVFD_FILE_APPEND, slot) — install
    #      the channel at the NAME /fd/<SCRATCH> in the supervisor's
    #      Pgrp.
    #   2. sys_open_write("/fd/<SCRATCH>") — Layer-2 mapping: a real
    #      integer kfd whose vfs_write arm routes through devfd_write
    #      at the SCRATCH name in the calling Pgrp.
    #   3. sys_write(kfd, ...) — bytes land at tmpfs_size every write
    #      because the bound kind is DEVFD_FILE_APPEND.
    #
    # Then sys_close + restore the SCRATCH name to console so the
    # supervisor's view of /fd is in a known state for the next
    # invocation. Format:
    #     `--- start <name> uptime=<Nms> restarts=<R> ---\n`
    # `uptime` is jiffies*10 (each jiffy is 10 ms today; see
    # arch/x86/kernel/time.ad). `restarts` is the cumulative count
    # for this slot in this session — 0 on the first start, then
    # bumped by the supervisor reap path. A grep-friendly fixed
    # prefix lets log readers split runs without ambiguity.
    if slot < 0:
        return
    rc: int32 = sys_fdbind(0, SVC_LOG_SCRATCH_FD, DEVFD_FILE_APPEND, slot)
    if rc < 0:
        return
    kfd: int32 = sys_open_write(_svc_log_devfd_path())
    if kfd < 0:
        # The /fd substrate isn't there (e.g. _setup_fd_namespace
        # didn't run for some reason). Quietly unbind and bail —
        # the redirect of the CHILD's stdio is the load-bearing
        # piece; the separator is a nice-to-have. Restore the
        # supervisor's /fd/<SCRATCH> to console all the same.
        sys_fdbind(0, SVC_LOG_SCRATCH_FD, DEVFD_CONS, 0)
        return
    write_str(kfd, "--- start ")
    u: uint64 = cast[uint64](idx)
    write_str(kfd, _svc_name_at(u))
    write_str(kfd, " uptime=")
    jif: uint64 = sys_get_jiffies()
    ms: int64 = cast[int64](jif * 10)
    write_str(kfd, render_int(ms))
    write_str(kfd, "ms restarts=")
    write_str(kfd, render_int(cast[int64](svc_restarts[u])))
    write_str(kfd, " ---\n")
    sys_close(kfd)
    # Re-bind the scratch slot back to the console so the supervisor's
    # own /fd/10 is in a known state. The DEVFD_FILE_APPEND slot itself
    # remains live (tmpfs slots are not refcounted); the next service's
    # _svc_redirect_child_log will bind the same kind onto a different
    # /fd in its child's namespace, addressing the same or a new slot.
    sys_fdbind(0, SVC_LOG_SCRATCH_FD, DEVFD_CONS, 0)


def _svc_redirect_child_log(pid: int32, slot: int32) -> int32:
    # Bind the log slot to the child's /fd/1 and /fd/2 as
    # DEVFD_FILE_APPEND. The first bind installs the kind; the second
    # uses DEVFD_DUP from /fd/1, which devfd_dup propagates as
    # DEVFD_FILE_APPEND so both stream writes land at EOF safely.
    # Returns 0 on success, -1 if either bind failed (the child still
    # runs — its output just stays on the inherited console).
    if pid < 0 or slot < 0:
        return -1
    r1: int32 = sys_fdbind(pid, 1, DEVFD_FILE_APPEND, slot)
    if r1 < 0:
        return -1
    r2: int32 = sys_fdbind(pid, 2, DEVFD_DUP, 1)
    if r2 < 0:
        return -1
    return 0


def _svc_spawn_into_ns(idx: int32) -> int32:
    # Launch the service's command. Returns the child pid (>0) or -1.
    #
    # For ns: init  — spawn() directly. Child inherits PID 1's ambient
    #                 namespace (the boot rc's bind set), which is what
    #                 a "Hamnix-native service" wants.
    # For ns: <other> — look up the captured ns template by name in
    #                 hamsh's scope, then rfork(RFPROC|<base>) + apply
    #                 template in child + spawn() the target binary
    #                 from inside the child + sys_exit(child's exit).
    #                 The child becomes a tiny wrapper whose lifetime
    #                 mirrors the real service's; the supervisor tracks
    #                 the wrapper as svc_pid. This is the same shape
    #                 exec_spawn uses for `spawn linux { /bin/nginx }`.
    #
    # docs/security.md Phase 11: if the .hamsh service definition
    # declares `uid: N` (N != 1), the supervisor rforks a wrapper
    # process, sys_setuid()s to N, then spawn()s the service binary.
    # Compromise of the service then runs at uid N — service-isolated.
    # The init-namespace + uid:1 fast path skips the rfork wrapper
    # entirely (no identity change needed).
    u: uint64 = cast[uint64](idx)
    ns_name: Ptr[uint8] = _svc_ns_at(u)
    cmd: Ptr[uint8] = _svc_cmd_at(u)
    target_uid: uint32 = svc_uid[u]
    rc: int32 = _svc_argv_tokenize(cmd)
    if rc <= 0:
        errstr_set("svc: empty or invalid exec line")
        return -1
    argv: Ptr[uint64] = cast[Ptr[uint64]](&svc_spawn_argv_ptr[0])
    path: Ptr[char] = cast[Ptr[char]](svc_spawn_argv_ptr[0])
    envp: Ptr[uint64] = _build_envp()
    # Open the per-service log channel ONCE per start. The slot is the
    # same DEVFD_FILE_APPEND backing the supervisor's separator write
    # and the child's /fd/1+/fd/2 will all bind. -1 here just means
    # the log is unavailable (out of slots, parent dir missing) —
    # service still launches; output stays on the inherited console.
    log_slot: int32 = _svc_open_log_chan(idx)
    if log_slot >= 0:
        _svc_write_restart_separator(idx, log_slot)
    # Fast path: ns=init AND uid=1 (hostowner). No identity change, no
    # ns template to apply — direct spawn() (the supervisor stays
    # the visible parent in the process tree).
    if cstr_eq(ns_name, "init") != 0 and target_uid == 1:
        pid: int32 = spawn(path, argv,
                               SPAWN_STDIO_NS, SPAWN_STDIO_NS, envp)
        if pid >= 0:
            # Cooperative scheduler: child is still STATE_READY here,
            # so the bind lands before its first instruction runs.
            _svc_redirect_child_log(pid, log_slot)
        return pid
    # uid switching path (still ns=init): rfork a wrapper so we can
    # call sys_setuid between fork and exec. The wrapper runs as the
    # service's uid and lives just long enough to spawn() + wait.
    if cstr_eq(ns_name, "init") != 0:
        flags_i: int32 = RFPROC | RFNAMEG
        pid_i: int32 = sys_rfork(flags_i)
        if pid_i == 0:
            rs: int32 = sys_setuid(target_uid)
            if rs < 0:
                # Should never happen — supervisor runs as hostowner
                # (uid 1) so SYS_SETUID's "current==1" gate passes.
                # Surface the failure as exit 126 so the .hamsh
                # supervisor records it as a setuid failure (distinct
                # from exit 127 = "command not found / spawn failed").
                write_str(2, "svc: setuid failed for uid-switched service\n")
                sys_exit(126)
                return EX_NORMAL
            # Redirect the wrapper's OWN /fd/1+/fd/2 (the rfork gave
            # us a private Pgrp via RFNAMEG, so this bind is invisible
            # to the supervisor). The subsequent spawn() hands a COW
            # copy of this /fd table to the real service binary, so
            # the binary's stdout+stderr land at /var/log/svc/<name>.log
            # without a second bind from the supervisor side.
            _svc_redirect_child_log(0, log_slot)
            cpid_i: int32 = spawn(path, argv,
                                      SPAWN_STDIO_NS, SPAWN_STDIO_NS,
                                      envp)
            if cpid_i < 0:
                write_str(2, "svc: spawn() failed in uid-switched wrapper\n")
                sys_exit(127)
                return EX_NORMAL
            code_i: int64 = sys_waitpid(cpid_i)
            sys_exit(cast[uint64](code_i))
            return EX_NORMAL
        if pid_i < 0:
            errstr_pull_kernel()
            return -1
        return pid_i
    # Non-init namespace: look up the captured `ns clean { … }` template
    # by name in the hamsh scope and apply it in a fresh child.
    nsval: int32 = eval_var_by_name(str_intern_cstr(ns_name))
    if val_type[cast[uint64](nsval)] != VT_NS:
        errstr_set("svc: namespace template not defined")
        return -1
    clean: int32 = 0
    if val_aux[cast[uint64](nsval)] != 0:
        clean = 1
    base_flag: int32 = RFNAMEG
    if clean != 0:
        base_flag = RFCNAMEG
    flags: int32 = RFPROC | base_flag
    _ns_capture_parent_stdio()
    pid: int32 = sys_rfork(flags)
    if pid == 0:
        # Child: clean namespace shape, apply template, switch uid
        # (Phase 11), exec the binary via spawn(), propagate exit.
        _ns_child_ensure_stdio(clean)
        apply_ns_template(nsval)
        if target_uid != 1:
            rs2: int32 = sys_setuid(target_uid)
            if rs2 < 0:
                sys_exit(127)
                return EX_NORMAL
        # Same shape as the uid-switch wrapper: rebind OUR /fd/1+/fd/2
        # so the inner spawn() COW-inherits the log redirection.
        _svc_redirect_child_log(0, log_slot)
        cpid: int32 = spawn(path, argv,
                                SPAWN_STDIO_NS, SPAWN_STDIO_NS, envp)
        if cpid < 0:
            sys_exit(127)
            return EX_NORMAL
        code: int64 = sys_waitpid(cpid)
        sys_exit(cast[uint64](code))
        return EX_NORMAL
    if pid < 0:
        errstr_pull_kernel()
        return -1
    return pid


def svc_start(idx: int32) -> int32:
    # Public starter. Returns 0 on success, -1 on a failure that has
    # set errstr. Idempotent: a service already running is left alone.
    if idx < 0:
        errstr_set("svc: bad slot")
        return -1
    u: uint64 = cast[uint64](idx)
    if u >= SVC_MAX or svc_in_use[u] == 0:
        errstr_set("svc: not registered")
        return -1
    if svc_state[u] == SVC_STATE_RUNNING:
        return 0
    pid: int32 = _svc_spawn_into_ns(idx)
    if pid < 0:
        svc_state[u] = SVC_STATE_FAILED
        # /proc/svc Phase 6: mirror the FAILED transition too.
        _svc_publish_to_kernel(idx)
        return -1
    svc_pid[u] = pid
    svc_state[u] = SVC_STATE_RUNNING
    svc_last_start_j[u] = sys_get_jiffies()
    svc_next_start_j[u] = 0
    # Fresh run: clear any prior stop-request latch so a future crash
    # of THIS run is recorded as FAILED, not silently STOPPED.
    svc_stop_req[u] = 0
    # /proc/svc Phase 6: publish the new pid + RUNNING state.
    _svc_publish_to_kernel(idx)
    return 0


def svc_stop(idx: int32) -> int32:
    # Signal a managed service to terminate. We send SIGTERM (15);
    # the supervisor reaper will see the exit on its next tick and
    # set state STOPPED. If the policy is `always`, the user typed
    # `svc stop` so they don't want it restarted: we additionally
    # flip the in-table policy to NEVER for this run, mirroring
    # systemd's `systemctl stop` (use start / restart to bring it
    # back). A reload (re-reading the .hamsh file) reverts that.
    if idx < 0:
        errstr_set("svc: bad slot")
        return -1
    u: uint64 = cast[uint64](idx)
    if u >= SVC_MAX or svc_in_use[u] == 0:
        errstr_set("svc: not registered")
        return -1
    if svc_state[u] != SVC_STATE_RUNNING:
        # Not running — fine, just clear restart-on-schedule.
        svc_state[u] = SVC_STATE_STOPPED
        svc_next_start_j[u] = 0
        _svc_publish_to_kernel(idx)
        return 0
    # Mark stop-requested by stashing policy = NEVER for this session.
    # Also latch svc_stop_req so the reaper records the SIGTERM exit as
    # a clean STOP (state=stopped), not a FAILED crash.
    svc_restart_pol[u] = SVC_RESTART_NEVER
    svc_stop_req[u] = 1
    # #450 F6: SIGTERM → Plan-9 note "terminate" written to /proc/<pid>/note.
    p9_note(svc_pid[u], cast[Ptr[uint8]]("terminate"))
    # /proc/svc Phase 6: publish the policy change immediately; the
    # supervisor tick will publish the eventual STOPPED transition.
    _svc_publish_to_kernel(idx)
    return 0


# --- enable / disable + runlevels (init-system layer) ---------------
# `enable`/`disable` flip a service's autostart flag. A service whose
# slot has svc_enabled != 0 and whose runlevel mask includes the
# current runlevel is (re)started when that runlevel is entered. The
# flag is persisted, best-effort, by rewriting the `enabled:` line in
# the declarative /etc/services.d/<name>.svc file so the choice
# survives a reboot when the root is writable (a no-op on a read-only
# cpio root — the in-memory flag still takes effect this session).

def _svc_persist_enabled(idx: int32):
    # Best-effort rewrite of /etc/services.d/<name>.svc with the
    # current svc_enabled flag stamped into an `enabled:` line. We
    # re-read the existing file, drop any existing enabled: line, and
    # append the new one. Silent on any failure (read-only root, etc.).
    if idx < 0:
        return
    u: uint64 = cast[uint64](idx)
    path_buf: Array[128, uint8]
    _svc_path_compose(_svc_name_at(u), "/etc/services.d/", ".svc",
                      &path_buf[0], 128)
    total: int64 = _svc_read_def_file(cast[Ptr[char]](&path_buf[0]))
    if total < 0:
        # Not a .svc-managed service (e.g. legacy /etc/svc/*.hamsh) —
        # nothing to persist. The in-memory flag still applies.
        return
    wfd: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if wfd < 0:
        return
    # Re-emit every line except a prior `enabled:` line.
    p: uint64 = 0
    n: uint64 = cast[uint64](total)
    while p < n:
        e: uint64 = p
        while e < n and svc_def_buf[e] != 10:
            e = e + 1
        # Detect a leading `enabled` key (skip leading whitespace).
        s: uint64 = p
        while s < e and (svc_def_buf[s] == 32 or svc_def_buf[s] == 9):
            s = s + 1
        is_enabled_line: int32 = _svc_key_eq(&svc_def_buf[0], s, e, "enabled")
        # _svc_key_eq compares the whole slice; the value part defeats
        # it, so instead check just the key token up to ':'.
        col: int64 = -1
        cs: uint64 = s
        while cs < e:
            if svc_def_buf[cs] == 58:        # ':'
                col = cast[int64](cs)
                break
            cs = cs + 1
        is_enabled_line = 0
        if col >= 0:
            is_enabled_line = _svc_key_eq(&svc_def_buf[0], s,
                                          cast[uint64](col), "enabled")
        if is_enabled_line == 0:
            sys_write(wfd, &svc_def_buf[p], e - p + 1)   # incl newline
        if e < n:
            p = e + 1
        else:
            p = e
    # Append the fresh enabled line.
    if svc_enabled[u] != 0:
        sys_write(wfd, "enabled: yes\n", 13)
    else:
        sys_write(wfd, "enabled: no\n", 12)
    sys_close(wfd)


def svc_enable(idx: int32, on: int32) -> int32:
    if idx < 0:
        errstr_set("svc: not registered")
        return -1
    u: uint64 = cast[uint64](idx)
    if u >= SVC_MAX or svc_in_use[u] == 0:
        errstr_set("svc: not registered")
        return -1
    svc_enabled[u] = on
    _svc_persist_enabled(idx)
    return 0


# --- runlevel rc scripts --------------------------------------------
# A runlevel transition sources /etc/rc.d/rc.<N> in PID 1's namespace.
# rc.0 / rc.6 drive the existing poweroff / reboot primitives; rc.5
# brings up the hamUI stack; rc.<default> (rc.3) is the multi-user
# level that starts all enabled services. The source runs in THIS
# (PID 1) process so its binds/spawns persist, exactly like rc.boot.

svc_rl_path: Array[32, uint8]


def _svc_rl_path_build(level: int32):
    # Compose "/etc/rc.d/rc.<level>" into svc_rl_path.
    prefix: Ptr[uint8] = "/etc/rc.d/rc."
    i: uint64 = 0
    while prefix[i] != 0:
        svc_rl_path[i] = prefix[i]
        i = i + 1
    # Single decimal digit (runlevels are 0..9).
    d: int32 = level
    if d < 0:
        d = 0
    svc_rl_path[i] = cast[uint8](48 + (d % 10))
    i = i + 1
    svc_rl_path[i] = 0


def _svc_source_path(path: Ptr[char]) -> int32:
    # Read `path` into src_buf and run it as hamsh statements in THIS
    # process. Returns 0 if sourced, -1 if the file was absent.
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    total: uint64 = 0
    while True:
        n: int64 = sys_read(fd, &src_buf[total], 16384 - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
        if total >= 16384:
            break
    sys_close(fd)
    if total > 0:
        run_source(&src_buf[0], total)
    return 0


# Scratch buffer for listing /etc/services.d/.
svc_defs_list: Array[2048, uint8]


def svc_load_all_defs():
    # Discover every declarative service definition under
    # /etc/services.d/ and register it (without starting). This makes
    # the user-addable layer real: dropping a .svc file is enough for
    # the service to appear in `service status` and to autostart at its
    # runlevel — no edit to any rc script. Each entry whose name ends in
    # ".svc" is loaded by its base name (svc_def_load strips nothing, so
    # we pass the leading name; svc_def_load rebuilds the full path).
    nlist: int64 = _ext_listdir("/etc/services.d", &svc_defs_list[0], 2048)
    if nlist <= 0:
        return
    p: uint64 = 0
    nm: Array[64, uint8]
    while p < cast[uint64](nlist):
        es: uint64 = p
        while p < cast[uint64](nlist) and svc_defs_list[p] != 10:
            p = p + 1
        elen: uint64 = p - es
        if p < cast[uint64](nlist):
            p = p + 1
        # Only consider entries ending in ".svc"; strip that suffix to
        # get the service name svc_def_load expects.
        if elen > 4:
            tail_ok: int32 = 1
            if svc_defs_list[es + elen - 4] != 46:    # '.'
                tail_ok = 0
            if svc_defs_list[es + elen - 3] != 115:   # 's'
                tail_ok = 0
            if svc_defs_list[es + elen - 2] != 118:   # 'v'
                tail_ok = 0
            if svc_defs_list[es + elen - 1] != 99:    # 'c'
                tail_ok = 0
            if tail_ok != 0:
                base_len: uint64 = elen - 4
                c: uint64 = 0
                while c < base_len and c + 1 < 64:
                    nm[c] = svc_defs_list[es + c]
                    c = c + 1
                nm[c] = 0
                svc_def_load(&nm[0])


def svc_start_enabled_for_level(level: int32):
    # Start every enabled service whose runlevel mask includes `level`.
    # Used by the default multi-user rc and by `init <N>`. First load
    # any not-yet-seen declarative definitions so a freshly-dropped
    # .svc file is picked up on the next runlevel entry.
    if level < 0:
        return
    svc_load_all_defs()
    bit: int32 = 1 << level
    i: uint64 = 0
    while i < svc_count:
        if svc_in_use[i] != 0:
            if svc_enabled[i] != 0 and (svc_runlevel[i] & bit) != 0:
                if svc_state[i] != SVC_STATE_RUNNING:
                    svc_start(cast[int32](i))
        i = i + 1


svc_in_runlevel_xition: int32 = 0


def svc_enter_runlevel(level: int32):
    # Transition to runlevel `level`. Two parts, in order:
    #   1. The BUILT-IN action for the level (so a transition works with
    #      no rc files at all): runlevel 0 -> stop-all + poweroff,
    #      runlevel 6 -> stop-all + reboot, any other level -> start
    #      every enabled service whose runlevel mask includes `level`.
    #   2. A best-effort `source /etc/rc.d/rc.<level>` for operator
    #      customisation (extra commands, custom service order). The rc
    #      script runs in THIS (PID 1) process so its binds/spawns
    #      persist. rc scripts must NOT re-invoke `init`/`svc runlevel`
    #      (that would recurse) — they layer extra work on top.
    # A re-entrancy guard makes an accidental recursive transition a
    # no-op rather than an infinite loop.
    if svc_in_runlevel_xition != 0:
        return
    svc_in_runlevel_xition = 1
    svc_current_runlevel = level
    write_cstr1("[init] entering runlevel ")
    write_cstr1(render_int(cast[int64](level)))
    write_cstr1("\n")
    # 1. Operator customisation via the rc script (optional). Runs
    #    FIRST so a runlevel 0/6 hook (flush, sync, notify) fires before
    #    the irreversible poweroff/reboot below.
    _svc_rl_path_build(level)
    _svc_source_path(cast[Ptr[char]](&svc_rl_path[0]))
    # 2. Built-in action for the level.
    if level == 0:
        svc_runlevel_halt()
    elif level == 6:
        svc_runlevel_reboot()
    else:
        svc_start_enabled_for_level(level)
    svc_in_runlevel_xition = 0


def svc_runlevel_halt():
    # init 0 — stop services, then poweroff via the existing primitive
    # (/dev/reboot <- "poweroff"). We print a grep-able marker first so
    # a test can assert the shutdown path was taken without the VM
    # actually having to power off.
    write_cstr1("[init] runlevel 0: shutdown -- stopping services\n")
    _svc_stop_all()
    write_cstr1("[init] runlevel 0: powering off\n")
    pfd: int32 = sys_open_write("/dev/reboot")
    if pfd >= 0:
        sys_write(pfd, "poweroff\n", 9)
        sys_close(pfd)


def svc_runlevel_reboot():
    # init 6 — stop services, then reboot via /dev/reboot <- "reboot".
    write_cstr1("[init] runlevel 6: reboot -- stopping services\n")
    _svc_stop_all()
    write_cstr1("[init] runlevel 6: rebooting\n")
    rfd: int32 = sys_open_write("/dev/reboot")
    if rfd >= 0:
        sys_write(rfd, "reboot\n", 7)
        sys_close(rfd)


def _svc_stop_all():
    # SIGTERM every running supervised service (used by runlevel 0/6).
    i: uint64 = 0
    while i < svc_count:
        if svc_in_use[i] != 0 and svc_state[i] == SVC_STATE_RUNNING:
            svc_restart_pol[i] = SVC_RESTART_NEVER
            svc_stop_req[i] = 1
            if svc_pid[i] > 0:
                # #450 F6: SIGTERM → Plan-9 note "terminate" /proc/<pid>/note.
                p9_note(svc_pid[i], cast[Ptr[uint8]]("terminate"))
            svc_state[i] = SVC_STATE_STOPPED
            _svc_publish_to_kernel(cast[int32](i))
        i = i + 1


# --- control-mailbox drain (native service/init -> supervisor) ------
# Native `service` / `init` commands enqueue a request via SYS_SVC_CTL;
# PID 1's supervisor drains the queue each tick and dispatches. This is
# the reverse channel of the /proc/svc publish path: publish lets any
# process READ supervisor state, the mailbox lets any process ASK the
# supervisor to act.
svc_ctl_name_buf: Array[32, uint8]


def _svc_ctl_drain():
    # Pop and dispatch every pending control request. Bounded by the
    # kernel queue depth so this can't spin.
    guard: int32 = 0
    while guard < 64:
        guard = guard + 1
        verb: int64 = sys_svc_ctl(0, cast[Ptr[uint8]](0), 0)   # poll
        if verb <= 0:
            return
        # Read out the request's name argument.
        sys_svc_ctl(7, &svc_ctl_name_buf[0], 32)
        v: int32 = cast[int32](verb)
        if v == 6:
            # runlevel: name buffer holds the level digit as text.
            lvl: int32 = cast[int32](_parse_dec(&svc_ctl_name_buf[0]))
            svc_enter_runlevel(lvl)
            continue
        # All other verbs take a service name. Resolve (auto-loading
        # the definition the first time it's referenced).
        idx: int32 = svc_lookup(&svc_ctl_name_buf[0])
        if idx < 0 and (v == 1 or v == 3 or v == 4 or v == 5):
            idx = svc_def_load(&svc_ctl_name_buf[0])
        if idx < 0:
            continue
        if v == 1:
            svc_start(idx)
        elif v == 2:
            svc_stop(idx)
        elif v == 3:
            _svc_restart_now(idx)
        elif v == 4:
            svc_enable(idx, 1)
        elif v == 5:
            svc_enable(idx, 0)


def _svc_restart_now(idx: int32):
    # Stop (if running) then start — used by the `restart` control verb
    # and `svc restart`. Non-blocking-friendly: SIGTERM the old pid and
    # let the next tick reap it, then start fresh.
    if idx < 0:
        return
    u: uint64 = cast[uint64](idx)
    if svc_state[u] == SVC_STATE_RUNNING and svc_pid[u] > 0:
        old_pid: int32 = svc_pid[u]
        # #450 F6: SIGTERM → Plan-9 note "terminate" /proc/<pid>/note.
        p9_note(old_pid, cast[Ptr[uint8]]("terminate"))
        sys_waitpid(old_pid)
        svc_pid[u] = 0
        svc_state[u] = SVC_STATE_STOPPED
        _svc_publish_to_kernel(idx)
    svc_start(idx)


# Supervisor loop -- called from the interactive idle poll. Two
# responsibilities:
#   1. REAP exited supervised children. Calls sys_waitpid(pid, WNOHANG)
#      on each svc_pid; -EAGAIN means still alive (cheap, doesn't
#      block), >=0 means the child has exited and was reaped here.
#      Updates svc_state per restart policy + svc_last_exit.
#   2. RESTART scheduled. For each SVC_STATE_RESTARTING, fire when
#      sys_get_jiffies() >= svc_next_start_j; apply exponential
#      backoff up to svc_backoff_max for the NEXT restart.
WAITPID_WNOHANG: int64 = 1


def _svc_reap_one(idx: uint64):
    if svc_state[idx] != SVC_STATE_RUNNING:
        return
    pid: int32 = svc_pid[idx]
    if pid <= 0:
        return
    # Cast +1 sentinel: WNOHANG path returns -11 if still alive.
    code: int64 = sys_waitpid_nb(pid)
    if code == cast[int64](-11):
        # Still running.
        return
    # Child has been reaped (or was never reapable). Either way mark
    # it as exited and apply the restart policy.
    svc_pid[idx] = 0
    svc_last_exit[idx] = cast[int32](code)
    # Reset backoff if the service ran cleanly for at least 60 s —
    # the brief's heuristic for "actually working".
    now: uint64 = sys_get_jiffies()
    ran_long: int32 = 0
    if svc_last_start_j[idx] != 0 and \
            now >= svc_last_start_j[idx] + 6000:    # 60 s
        ran_long = 1
    failed: int32 = 0
    if code != 0:
        failed = 1
    # Decide restart.
    pol: int32 = svc_restart_pol[idx]
    do_restart: int32 = 0
    if pol == SVC_RESTART_ALWAYS:
        do_restart = 1
    elif pol == SVC_RESTART_ON_FAIL and failed != 0:
        do_restart = 1
    if do_restart == 0:
        # A deliberately-stopped service (svc_stop latched svc_stop_req)
        # is STOPPED even though the SIGTERM exit code is non-zero (143);
        # only an UNREQUESTED non-zero exit is FAILED.
        if failed != 0 and svc_stop_req[idx] == 0:
            svc_state[idx] = SVC_STATE_FAILED
        else:
            svc_state[idx] = SVC_STATE_STOPPED
        svc_stop_req[idx] = 0
        # /proc/svc Phase 6: publish the terminal state.
        _svc_publish_to_kernel(cast[int32](idx))
        return
    # Restart-scheduled. Apply backoff: reset to initial if the last
    # run was long enough; else double up to ceiling.
    if ran_long != 0:
        svc_backoff_ms[idx] = svc_backoff_init[idx]
    else:
        svc_backoff_ms[idx] = svc_backoff_ms[idx] * 2
        if svc_backoff_ms[idx] > svc_backoff_max[idx]:
            svc_backoff_ms[idx] = svc_backoff_max[idx]
    backoff_j: uint64 = cast[uint64](svc_backoff_ms[idx] / 10)  # ms->jiffies
    svc_state[idx] = SVC_STATE_RESTARTING
    svc_next_start_j[idx] = now + backoff_j
    svc_restarts[idx] = svc_restarts[idx] + 1
    # /proc/svc Phase 6: publish the RESTARTING transition so a
    # `cat /proc/svc/<name>` between restarts shows the right state
    # and the bumped restarts counter.
    _svc_publish_to_kernel(cast[int32](idx))


def _svc_restart_due(idx: uint64):
    if svc_state[idx] != SVC_STATE_RESTARTING:
        return
    now: uint64 = sys_get_jiffies()
    if now < svc_next_start_j[idx]:
        return
    # Time's up — try to start. svc_start updates state on success
    # (RUNNING) or sets FAILED on a hard failure (e.g. unknown ns).
    svc_start(cast[int32](idx))


def svc_supervisor_tick():
    # Cheap when no service has churned: O(N) over a 32-slot table,
    # one sys_waitpid_nb per running service + one jiffies compare per
    # restarting one. Safe to call from the interactive idle loop.
    #
    # FIRST drain the native-command control mailbox (service/init ->
    # supervisor RPC). This must run even when svc_count == 0 so an
    # `init <N>` runlevel request or a `service <name> start` that
    # auto-loads the first service is honoured on a freshly-booted
    # system with no services yet registered.
    _svc_ctl_drain()
    if svc_count == 0:
        return
    i: uint64 = 0
    while i < svc_count:
        if svc_in_use[i] != 0:
            _svc_reap_one(i)
            _svc_restart_due(i)
        i = i + 1


# Native non-blocking waitpid wrapper. SYS_WAITPID with a1 bit 0 set
# returns -EAGAIN (-11) instead of yielding-to-others when the child
# is still alive. See arch/x86/kernel/syscall.ad's SYS_WAITPID arm.
extern def sys_waitpid_nb_raw(pid: int32, flags: int64) -> int64


def sys_waitpid_nb(pid: int32) -> int64:
    # Hamsh has only `extern def sys_waitpid(pid: int32) -> int64` (one
    # arg) wired through the user/runtime.S shim. The flagged variant
    # is exposed as sys_waitpid_nb_raw(pid, flags), which is the same
    # SYS_WAITPID number with bit 0 of a1 set so the kernel returns
    # -EAGAIN (-11) instead of yielding-to-others. This wrapper just
    # pins the flag so callers say `sys_waitpid_nb(pid)` and forget.
    return sys_waitpid_nb_raw(pid, WAITPID_WNOHANG)


# --- /etc/svc/<name>.hamsh parser -----------------------------------
# A service-definition file is plain text in a tiny `key: value` DSL.
# We deliberately don't use hamsh's own parser: a service definition
# is data, not code (no spawn/bind side effects from the file itself),
# and a typo in a file would otherwise raise an evaluator error
# instead of a clean "missing exec= line" diagnostic.
#
# Grammar (per the brief's design block):
#   - '#' to end-of-line is a comment.
#   - Blank / whitespace-only lines are skipped.
#   - Other lines split on the FIRST ':' into (key, value); the key
#     is trimmed; the value is trimmed of leading/trailing whitespace.
#   - Required keys: name, ns, exec.
#   - Optional keys: restart (always|on-failure|never), backoff_ms,
#     backoff_max_ms, description.

# Read buffer for the def file. 4 KiB is well above the brief's
# example (~7 short lines); if a file overflows, the parser truncates
# it and svc_def_load errs out with "file too long".
SVC_DEF_BUF_MAX:  uint64 = 4096
svc_def_buf:      Array[4096, uint8]

# Per-parse scratch fields. Each entry is NUL-terminated; an empty
# string for a required field surfaces as the validation error.
svc_pf_name:      Array[64, uint8]
svc_pf_ns:        Array[32, uint8]
svc_pf_exec:      Array[512, uint8]
svc_pf_desc:      Array[128, uint8]
svc_pf_restart:   int32 = 0
svc_pf_backoff:   int64 = 0
svc_pf_backoff_x: int64 = 0
# docs/security.md Phase 11: parsed `uid:` field from the service
# definition. Default 1 (hostowner) when omitted.
svc_pf_uid:       uint32 = 1
# init-system layer: parsed `enabled:` (yes/no) and `runlevel:` (a
# space-separated list of digits) fields. Default: enabled, default
# multi-user runlevel (3).
svc_pf_enabled:   int32 = 1
svc_pf_runlevel:  int32 = 0


def _svc_pf_reset():
    svc_pf_name[0] = 0
    svc_pf_ns[0] = 0
    svc_pf_exec[0] = 0
    svc_pf_desc[0] = 0
    svc_pf_restart = SVC_RESTART_ON_FAIL
    svc_pf_backoff = 1000              # 1 s default initial
    svc_pf_backoff_x = 30000           # 30 s default ceiling
    svc_pf_uid = 1                     # default hostowner
    svc_pf_enabled = 1                 # default enabled
    svc_pf_runlevel = 1 << SVC_DEFAULT_RUNLEVEL   # default multi-user (3)


def _svc_trim_copy(dst: Ptr[uint8], cap: uint64,
                   src: Ptr[uint8], lo: uint64, hi: uint64):
    # Copy src[lo..hi) trimmed of leading/trailing space, NUL-terminated.
    while lo < hi and (src[lo] == 32 or src[lo] == 9):
        lo = lo + 1
    while hi > lo and (src[hi - 1] == 32 or src[hi - 1] == 9 \
                       or src[hi - 1] == 13 or src[hi - 1] == 10):
        hi = hi - 1
    o: uint64 = 0
    while lo < hi and o + 1 < cap:
        dst[o] = src[lo]
        o = o + 1
        lo = lo + 1
    dst[o] = 0


def _svc_key_eq(src: Ptr[uint8], lo: uint64, hi: uint64,
                kw: Ptr[uint8]) -> int32:
    # Compare a trimmed slice of src to a NUL-terminated keyword.
    while lo < hi and (src[lo] == 32 or src[lo] == 9):
        lo = lo + 1
    while hi > lo and (src[hi - 1] == 32 or src[hi - 1] == 9):
        hi = hi - 1
    j: uint64 = 0
    while lo < hi:
        if kw[j] == 0:
            return 0
        if src[lo] != kw[j]:
            return 0
        lo = lo + 1
        j = j + 1
    if kw[j] != 0:
        return 0
    return 1


def _svc_parse_int(buf: Ptr[uint8], lo: uint64, hi: uint64) -> int64:
    while lo < hi and (buf[lo] == 32 or buf[lo] == 9):
        lo = lo + 1
    sign: int64 = 1
    if lo < hi and buf[lo] == 45:        # '-'
        sign = -1
        lo = lo + 1
    n: int64 = 0
    while lo < hi:
        c: uint8 = buf[lo]
        if c < 48 or c > 57:
            break
        n = n * 10 + cast[int64](c - 48)
        lo = lo + 1
    return n * sign


def _svc_apply_restart(buf: Ptr[uint8], lo: uint64, hi: uint64):
    if _svc_key_eq(buf, lo, hi, "always") != 0:
        svc_pf_restart = SVC_RESTART_ALWAYS
        return
    if _svc_key_eq(buf, lo, hi, "on-failure") != 0:
        svc_pf_restart = SVC_RESTART_ON_FAIL
        return
    if _svc_key_eq(buf, lo, hi, "never") != 0:
        svc_pf_restart = SVC_RESTART_NEVER
        return
    # Unknown — keep the default (on-failure).


def _svc_apply_enabled(buf: Ptr[uint8], lo: uint64, hi: uint64):
    # `enabled: yes|no|true|false|1|0`. Anything truthy enables.
    if _svc_key_eq(buf, lo, hi, "yes") != 0 \
            or _svc_key_eq(buf, lo, hi, "true") != 0 \
            or _svc_key_eq(buf, lo, hi, "1") != 0:
        svc_pf_enabled = 1
        return
    if _svc_key_eq(buf, lo, hi, "no") != 0 \
            or _svc_key_eq(buf, lo, hi, "false") != 0 \
            or _svc_key_eq(buf, lo, hi, "0") != 0:
        svc_pf_enabled = 0
        return
    # Unknown — keep the default (enabled).


def _svc_apply_runlevel(buf: Ptr[uint8], lo: uint64, hi: uint64):
    # `runlevel: 3 5` — a space/comma-separated list of single digits
    # 0..9. Builds a bitmask (bit N = runlevel N). An empty value leaves
    # the default mask in place.
    mask: int32 = 0
    any: int32 = 0
    i: uint64 = lo
    while i < hi:
        c: uint8 = buf[i]
        if c >= 48 and c <= 57:                # '0'..'9'
            d: int32 = cast[int32](c - 48)
            mask = mask | (1 << d)
            any = 1
        i = i + 1
    if any != 0:
        svc_pf_runlevel = mask


def _svc_parse_buf(n: uint64) -> int32:
    # Walk svc_def_buf[0..n), one line at a time. Returns 0 on success
    # (required fields present), -1 on a missing-required diagnostic
    # (errstr set).
    _svc_pf_reset()
    p: uint64 = 0
    while p < n:
        # Find end of line.
        e: uint64 = p
        while e < n and svc_def_buf[e] != 10:
            e = e + 1
        # Trim a trailing CR if present.
        line_hi: uint64 = e
        # Strip a leading '#' comment by treating it as line end.
        scan: uint64 = p
        while scan < e:
            if svc_def_buf[scan] == 35:    # '#'
                line_hi = scan
                break
            scan = scan + 1
        # Find the ':' separator.
        col: int64 = -1
        scan = p
        while scan < line_hi:
            if svc_def_buf[scan] == 58:    # ':'
                col = cast[int64](scan)
                break
            scan = scan + 1
        if col >= 0:
            key_lo: uint64 = p
            key_hi: uint64 = cast[uint64](col)
            val_lo: uint64 = cast[uint64](col) + 1
            val_hi: uint64 = line_hi
            base: Ptr[uint8] = &svc_def_buf[0]
            if _svc_key_eq(base, key_lo, key_hi, "name") != 0:
                _svc_trim_copy(&svc_pf_name[0], 64, base, val_lo, val_hi)
            elif _svc_key_eq(base, key_lo, key_hi, "ns") != 0:
                _svc_trim_copy(&svc_pf_ns[0], 32, base, val_lo, val_hi)
            elif _svc_key_eq(base, key_lo, key_hi, "exec") != 0:
                _svc_trim_copy(&svc_pf_exec[0], 512, base, val_lo, val_hi)
            elif _svc_key_eq(base, key_lo, key_hi, "description") != 0:
                _svc_trim_copy(&svc_pf_desc[0], 128, base, val_lo, val_hi)
            elif _svc_key_eq(base, key_lo, key_hi, "restart") != 0:
                _svc_apply_restart(base, val_lo, val_hi)
            elif _svc_key_eq(base, key_lo, key_hi, "backoff_ms") != 0:
                svc_pf_backoff = _svc_parse_int(base, val_lo, val_hi)
            elif _svc_key_eq(base, key_lo, key_hi, "backoff_max_ms") != 0:
                svc_pf_backoff_x = _svc_parse_int(base, val_lo, val_hi)
            elif _svc_key_eq(base, key_lo, key_hi, "uid") != 0:
                # docs/security.md Phase 11: per-service uid. The
                # supervisor switches to this identity before exec.
                svc_pf_uid = cast[uint32](_svc_parse_int(base, val_lo, val_hi) & 0xFFFFFFFF)
            elif _svc_key_eq(base, key_lo, key_hi, "enabled") != 0:
                _svc_apply_enabled(base, val_lo, val_hi)
            elif _svc_key_eq(base, key_lo, key_hi, "runlevel") != 0:
                _svc_apply_runlevel(base, val_lo, val_hi)
            # Unknown keys are silently ignored (forward-compat).
        p = e + 1
    # Validation.
    if svc_pf_name[0] == 0:
        errstr_set("svc: definition missing required key 'name'")
        return -1
    if svc_pf_ns[0] == 0:
        errstr_set("svc: definition missing required key 'ns'")
        return -1
    if svc_pf_exec[0] == 0:
        errstr_set("svc: definition missing required key 'exec'")
        return -1
    return 0


def _svc_path_compose(name: Ptr[uint8], prefix: Ptr[uint8],
                      suffix: Ptr[uint8], out: Ptr[uint8], cap: uint64):
    # Compose "<prefix><name><suffix>" into `out`, NUL-terminated.
    i: uint64 = 0
    while prefix[i] != 0 and i + 1 < cap:
        out[i] = prefix[i]
        i = i + 1
    j: uint64 = 0
    while name[j] != 0 and i + 1 < cap:
        out[i] = name[j]
        i = i + 1
        j = j + 1
    k: uint64 = 0
    while suffix[k] != 0 and i + 1 < cap:
        out[i] = suffix[k]
        i = i + 1
        k = k + 1
    out[i] = 0


def _svc_read_def_file(path: Ptr[char]) -> int64:
    # Read a definition file into svc_def_buf. Returns the byte count on
    # success, -1 if the file can't be opened. The caller validates a
    # zero-length read separately.
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    total: uint64 = 0
    while True:
        n: int64 = sys_read(fd, &svc_def_buf[total],
                            SVC_DEF_BUF_MAX - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
        if total >= SVC_DEF_BUF_MAX:
            break
    sys_close(fd)
    return cast[int64](total)


def svc_def_load(name: Ptr[uint8]) -> int32:
    # Locate and parse a service definition, then register it. Two
    # search locations, in order:
    #   1. /etc/services.d/<name>.svc — the user-addable declarative
    #      format (the init-system layer; drop a file here to add a
    #      service without recompiling anything).
    #   2. /etc/svc/<name>.hamsh — the legacy in-tree location (sshd).
    # Both share the same key:value grammar; the .svc form additionally
    # honours `enabled:` and `runlevel:`. Returns the slot index on
    # success, -1 on not-found / parse error (errstr set).
    path_buf: Array[128, uint8]
    _svc_path_compose(name, "/etc/services.d/", ".svc", &path_buf[0], 128)
    total: int64 = _svc_read_def_file(cast[Ptr[char]](&path_buf[0]))
    if total < 0:
        # Fall back to the legacy /etc/svc/<name>.hamsh location.
        _svc_path_compose(name, "/etc/svc/", ".hamsh", &path_buf[0], 128)
        total = _svc_read_def_file(cast[Ptr[char]](&path_buf[0]))
        if total < 0:
            errstr_set("svc: no such service definition")
            return -1
    if total == 0:
        errstr_set("svc: empty definition file")
        return -1
    if _svc_parse_buf(cast[uint64](total)) < 0:
        return -1
    return svc_register(&svc_pf_name[0], &svc_pf_ns[0],
                        &svc_pf_exec[0], svc_pf_restart,
                        svc_pf_backoff, svc_pf_backoff_x,
                        &svc_pf_desc[0], svc_pf_uid,
                        svc_pf_enabled, svc_pf_runlevel)


# --- svc builtin ----------------------------------------------------
# Subcommands: status [<name>] | start <name> | stop <name>
#              restart <name> | reload <name>
def builtin_svc(argc: int32) -> int32:
    if argc < 2:
        # `svc` with no args: same as `svc status`.
        svc_render_status()
        return 0
    verb: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[1])
    if cstr_eq(verb, "status") != 0:
        if argc >= 3:
            name: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[2])
            idx: int32 = svc_lookup(name)
            if idx < 0:
                errstr_set("svc: not registered")
                return 1
            svc_render_one(idx)
            return 0
        svc_render_status()
        return 0
    if cstr_eq(verb, "start") != 0:
        if argc < 3:
            errstr_set("svc start: missing service name")
            return 1
        name: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[2])
        idx: int32 = svc_lookup(name)
        if idx < 0:
            # Auto-load the def the first time the user references it.
            idx = svc_def_load(name)
            if idx < 0:
                return 1
        if svc_start(idx) < 0:
            return 1
        return 0
    if cstr_eq(verb, "stop") != 0:
        if argc < 3:
            errstr_set("svc stop: missing service name")
            return 1
        name: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[2])
        idx: int32 = svc_lookup(name)
        if idx < 0:
            errstr_set("svc: not registered")
            return 1
        if svc_stop(idx) < 0:
            return 1
        return 0
    if cstr_eq(verb, "restart") != 0:
        if argc < 3:
            errstr_set("svc restart: missing service name")
            return 1
        name: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[2])
        idx: int32 = svc_lookup(name)
        if idx < 0:
            idx = svc_def_load(name)
            if idx < 0:
                return 1
        u: uint64 = cast[uint64](idx)
        # If it's currently running, signal it and wait one cooperative
        # cycle for the reaper to update state. Even without the wait,
        # the supervisor tick will catch the exit and start a fresh
        # one when policy permits — but a user typing `svc restart`
        # wants the new instance up before the prompt returns.
        if svc_state[u] == SVC_STATE_RUNNING:
            old_pid: int32 = svc_pid[u]
            # Don't flip policy to NEVER like svc_stop — we want the
            # supervisor to bring it back. Direct note + manual reap.
            # #450 F6: SIGTERM → Plan-9 note "terminate" /proc/<pid>/note.
            p9_note(old_pid, cast[Ptr[uint8]]("terminate"))
            # Reap synchronously so the next svc_start sees a clean
            # SVC_STATE_STOPPED. sys_waitpid blocks here — acceptable
            # at an interactive `svc restart` (the user typed it).
            sys_waitpid(old_pid)
            svc_pid[u] = 0
            svc_state[u] = SVC_STATE_STOPPED
            # /proc/svc Phase 6: publish the STOPPED intermediate so a
            # concurrent `cat /proc/svc/<name>` between the kill and
            # the re-start doesn't show the dead pid as still running.
            _svc_publish_to_kernel(idx)
        if svc_start(idx) < 0:
            return 1
        return 0
    if cstr_eq(verb, "reload") != 0:
        if argc < 3:
            errstr_set("svc reload: missing service name")
            return 1
        name: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[2])
        idx: int32 = svc_def_load(name)
        if idx < 0:
            return 1
        return 0
    if cstr_eq(verb, "enable") != 0 or cstr_eq(verb, "disable") != 0:
        if argc < 3:
            errstr_set("svc enable/disable: missing service name")
            return 1
        name: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[2])
        idx: int32 = svc_lookup(name)
        if idx < 0:
            idx = svc_def_load(name)
            if idx < 0:
                return 1
        on: int32 = 0
        if cstr_eq(verb, "enable") != 0:
            on = 1
        if svc_enable(idx, on) < 0:
            return 1
        return 0
    if cstr_eq(verb, "runlevel") != 0:
        if argc < 3:
            # Report the current runlevel.
            write_cstr1("runlevel ")
            write_cstr1(render_int(cast[int64](svc_current_runlevel)))
            write_cstr1("\n")
            return 0
        lvl: int32 = cast[int32](_parse_dec(cast[Ptr[uint8]](argv_ptr[2])))
        svc_enter_runlevel(lvl)
        return 0
    errstr_set("svc: unknown verb (status/start/stop/restart/reload/enable/disable/runlevel)")
    return 1


# --- service / init builtins (sysadmin-shaped front ends) -----------
# `service <name> <verb>` and `init <N>` are the Linux-sysadmin
# spellings. When typed at the PID-1 prompt they run IN-PROCESS against
# the live supervisor table (no mailbox round-trip needed — the shell
# IS the supervisor). The standalone /bin/service and /bin/initctl
# binaries cover the same verbs from a non-PID-1 process via the
# SYS_SVC_CTL mailbox. Argument order is `service NAME VERB` (matching
# Debian's `service nginx restart`), the reverse of `svc VERB NAME`.
def builtin_service(argc: int32) -> int32:
    if argc < 2:
        svc_render_status()
        return 0
    a1: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[1])
    if cstr_eq(a1, "status") != 0 or cstr_eq(a1, "list") != 0:
        if argc >= 3:
            idx: int32 = svc_lookup(cast[Ptr[uint8]](argv_ptr[2]))
            if idx < 0:
                errstr_set("service: not registered")
                return 1
            svc_render_one(idx)
            return 0
        svc_render_status()
        return 0
    name: Ptr[uint8] = a1
    if argc < 3:
        # `service <name>` -> status of that service.
        idx: int32 = svc_lookup(name)
        if idx < 0:
            errstr_set("service: not registered")
            return 1
        svc_render_one(idx)
        return 0
    verb: Ptr[uint8] = cast[Ptr[uint8]](argv_ptr[2])
    if cstr_eq(verb, "status") != 0:
        idx: int32 = svc_lookup(name)
        if idx < 0:
            errstr_set("service: not registered")
            return 1
        svc_render_one(idx)
        return 0
    idx: int32 = svc_lookup(name)
    if idx < 0:
        idx = svc_def_load(name)
        if idx < 0:
            return 1
    if cstr_eq(verb, "start") != 0:
        if svc_start(idx) < 0:
            return 1
        return 0
    if cstr_eq(verb, "stop") != 0:
        if svc_stop(idx) < 0:
            return 1
        return 0
    if cstr_eq(verb, "restart") != 0:
        _svc_restart_now(idx)
        return 0
    if cstr_eq(verb, "enable") != 0:
        if svc_enable(idx, 1) < 0:
            return 1
        return 0
    if cstr_eq(verb, "disable") != 0:
        if svc_enable(idx, 0) < 0:
            return 1
        return 0
    errstr_set("service: unknown verb (start/stop/restart/status/enable/disable)")
    return 1


def builtin_init(argc: int32) -> int32:
    # `init <N>` / `telinit <N>` — change runlevel. Runs the transition
    # in THIS (PID 1) process so the runlevel rc's binds/spawns persist.
    if argc < 2:
        write_cstr1("runlevel ")
        write_cstr1(render_int(cast[int64](svc_current_runlevel)))
        write_cstr1("\n")
        return 0
    lvl: int32 = cast[int32](_parse_dec(cast[Ptr[uint8]](argv_ptr[1])))
    if lvl < 0 or lvl > 9:
        errstr_set("init: runlevel must be 0..9")
        return 1
    svc_enter_runlevel(lvl)
    return 0


# --- §13 live-handle resolution -------------------------------------
# A live handle (VT_PROC / VT_MOUNT) is valid ONLY in the namespace
# that created it. The handle value carries its creating-namespace id
# in val_aux; using it where sys_nsid() now differs is a loud error,
# not undefined behaviour (§13, §17). _handle_pid resolves a kill/wait
# argument node to a pid, applying that check.
#
# Return: a pid > 0 on success; 0 on a plain bad argument; -1 on the
# cross-namespace-handle error (errstr already set).

def _handle_pid(node: int32, argpos: uint64) -> int32:
    argkid: int32 = nd_kid_at(node, argpos)
    if argkid == 0:
        return 0
    v: int32 = eval_expr(argkid)
    if val_type[cast[uint64](v)] == VT_PROC:
        # A live process handle — enforce the namespace boundary.
        owner_ns: int64 = val_aux[cast[uint64](v)]
        if owner_ns != 0 and cast[uint64](owner_ns) != sys_nsid():
            errstr_set("handle used outside its owning namespace")
            return -1
        return cast[int32](val_pay[cast[uint64](v)])
    # Not a handle — accept a literal/interpolated decimal pid.
    return cast[int32](_parse_dec(v_render_str_only(v)))


def _builtin_kill(node: int32, argc: int32):
    # kill HANDLE — signal a spawned process. HANDLE is a VT_PROC
    # value (§14); §13 forbids using it outside its owning namespace.
    if argc < 2:
        errstr_set("kill: usage: kill handle")
        eval_status = 1
        return
    pid: int32 = _handle_pid(node, 1)
    if pid < 0:
        eval_status = 1             # cross-namespace-handle error
        return
    if pid > 0:
        # #450 F6: SIGKILL → Plan-9 note "kill" written to /proc/<pid>/note.
        p9_note(pid, cast[Ptr[uint8]]("kill"))
        eval_status = 0
    else:
        errstr_set("kill: bad handle")
        eval_status = 1


def _builtin_wait(node: int32, argc: int32):
    # wait HANDLE — block on a spawned process.
    if argc < 2:
        eval_status = 0
        return
    pid: int32 = _handle_pid(node, 1)
    if pid < 0:
        eval_status = 1             # cross-namespace-handle error
        return
    if pid > 0:
        code: int64 = sys_waitpid(pid)
        eval_status = cast[int32](code)
    else:
        eval_status = 1


# --- globbing (§4) --------------------------------------------------
# The single implicit expansion. An unquoted command-position word
# with glob metacharacters is matched against the current namespace.
# We list the pattern's parent directory and fnmatch the leaf.
glob_dir:  Array[256, uint8]
glob_leaf: Array[128, uint8]
glob_list: Array[4096, uint8]


def _fnmatch(pat: Ptr[uint8], name: Ptr[uint8]) -> int32:
    # Minimal glob match: '*' (any run) and '?' (one char). No
    # bracket classes here — generous enough for *.ad and friends.
    pi: uint64 = 0
    ni: uint64 = 0
    star_p: int64 = -1
    star_n: uint64 = 0
    while name[ni] != 0:
        pc: uint8 = pat[pi]
        if pc == 42:                          # '*'
            star_p = cast[int64](pi)
            star_n = ni
            pi = pi + 1
        elif pc == 63 or pc == name[ni]:      # '?' or literal match
            pi = pi + 1
            ni = ni + 1
        elif star_p >= 0:
            pi = cast[uint64](star_p) + 1
            star_n = star_n + 1
            ni = star_n
        else:
            return 0
    while pat[pi] == 42:
        pi = pi + 1
    if pat[pi] == 0:
        return 1
    return 0


def _glob_try(pattern: Ptr[uint8]) -> int32:
    # Split the pattern into dir + leaf, listdir the dir, fnmatch the
    # leaf, push each match as an argv entry. Returns count matched.
    n: uint64 = cstr_len(pattern)
    slash: int64 = -1
    i: uint64 = 0
    while i < n:
        if pattern[i] == 47:
            slash = cast[int64](i)
        i = i + 1
    di: uint64 = 0
    if slash >= 0:
        while di < cast[uint64](slash) and di + 1 < 256:
            glob_dir[di] = pattern[di]
            di = di + 1
        if di == 0:
            glob_dir[0] = 47
            di = 1
    else:
        glob_dir[0] = 46                      # '.'
        di = 1
    glob_dir[di] = 0
    li: uint64 = 0
    lstart: uint64 = 0
    if slash >= 0:
        lstart = cast[uint64](slash) + 1
    while lstart + li < n and li + 1 < 128:
        glob_leaf[li] = pattern[lstart + li]
        li = li + 1
    glob_leaf[li] = 0
    # listdir
    nlist: int64 = _ext_listdir(&glob_dir[0], &glob_list[0], 4096)
    if nlist <= 0:
        return 0
    count: int32 = 0
    p: uint64 = 0
    fp: Array[384, uint8]
    while p < cast[uint64](nlist):
        es: uint64 = p
        while p < cast[uint64](nlist) and glob_list[p] != 10:
            p = p + 1
        elen: uint64 = p - es
        if p < cast[uint64](nlist):
            p = p + 1
        # NUL-terminate the entry name in a temp
        ent: Array[128, uint8]
        ec: uint64 = 0
        while ec < elen and ec + 1 < 128:
            ent[ec] = glob_list[es + ec]
            ec = ec + 1
        ent[ec] = 0
        if _fnmatch(&glob_leaf[0], &ent[0]) != 0:
            # rebuild full path dir + '/' + ent
            fi: uint64 = 0
            if slash >= 0:
                while fi < cast[uint64](slash) and fi + 1 < 384:
                    fp[fi] = pattern[fi]
                    fi = fi + 1
                if fi + 1 < 384:
                    fp[fi] = 47
                    fi = fi + 1
            gj: uint64 = 0
            while ent[gj] != 0 and fi + 1 < 384:
                fp[fi] = ent[gj]
                fi = fi + 1
                gj = gj + 1
            fp[fi] = 0
            _argv_push_cstr(&fp[0])
            count = count + 1
    return count


# #450 F6: SYS_LISTDIR retired. p9_listdir() from lib/p9.ad is the
# Plan-9 open-dir + read-records replacement (imported at the top of
# this file alongside spawn()). The dir-fd's read backing
# (DEV_DIR_FILE::_dirfile_read) emits the exact same "NAME\n" packed
# format the old syscall returned, so glob parsing here is unchanged.


def _ext_listdir(path: Ptr[uint8], buf: Ptr[uint8],
                 cap: uint64) -> int64:
    return p9_listdir(cast[Ptr[char]](path), buf, cap)


# ====================================================================
# REPL
# ====================================================================
# The line driver: lex -> parse -> exec. Multi-line constructs use the
# continuation prompt: the parser knows a block is incomplete until
# the closing `}` (§5), so we count braces and keep reading until they
# balance. Paste-robust and REPL-friendly.

line_buf:   Array[2048, uint8]
# (Interactive input is collected by the line editor — see ed_readline
#  below. The rc/init path reads its script into rc_buf directly.)


def _maybe_recycle_arenas():
    # The node / value / string arenas are append-only across a
    # session. When they near capacity AND there is no live state to
    # preserve (no `def`'d functions, no variable bindings), recycle
    # them to baseline. With functions or variables live, we keep
    # growing — the soft-overflow path then degrades gracefully.
    if fn_count != 0:
        return
    if sc_count != 0:
        return
    if nd_count < NODE_MAX - 1024 and val_count < VAL_MAX - 1024 and \
            str_cursor < STR_ARENA_MAX - 4096 and \
            val_elem_cursor < LISTELEM_MAX - 1024:
        return
    nd_count = 1
    nd_kid_cursor = 1          # slot 0 reserved as the list terminator
    val_count = 1
    val_elem_cursor = 0
    str_cursor = 1
    str_arena[0] = 0


def _brace_balance(buf: Ptr[uint8], n: uint64) -> int64:
    # Net unclosed-brace count, ignoring braces inside quotes.
    depth: int64 = 0
    in_dq: int32 = 0
    in_sq: int32 = 0
    i: uint64 = 0
    while i < n:
        c: uint8 = buf[i]
        if in_dq != 0:
            if c == 34:
                in_dq = 0
        elif in_sq != 0:
            if c == 39:
                in_sq = 0
        else:
            if c == 34:
                in_dq = 1
            elif c == 39:
                in_sq = 1
            elif c == 123:
                depth = depth + 1
            elif c == 125:
                depth = depth - 1
        i = i + 1
    return depth


def _line_is_blank(buf: Ptr[uint8], n: uint64) -> int32:
    # 1 iff the logical line carries no statement — only whitespace,
    # statement separators (`;`), and `#` comments. A blank top-level
    # line MUST be a silent no-op (§18.1): no parse, no error, just a
    # re-prompt. This is the read-eval loop's job — an empty stage
    # *inside* a pipeline (`a | | b`) is still a real parse error,
    # because that line is NOT blank by this rule.
    i: uint64 = 0
    while i < n:
        c: uint8 = buf[i]
        if c == 35:                          # '#' — comment to EOL
            while i < n and buf[i] != 10:
                i = i + 1
            continue
        if _is_space(c) == 0 and c != 10 and c != 59:   # not WS/NL/';'
            return 0
        i = i + 1
    return 1


def _phys_ends_with_colon(buf: Ptr[uint8], n: uint64) -> int32:
    # 1 iff the physical line (ignoring a trailing comment and trailing
    # whitespace) ends with ':' — i.e. it opens a Python-style suite that
    # needs an indented body. Drives the interactive continuation prompt
    # so `if x:` <Enter> keeps reading until a blank line, mirroring the
    # Python REPL. Quotes are honoured so a ':' inside a string doesn't
    # count.
    last: int64 = -1
    i: uint64 = 0
    in_dq: int32 = 0
    in_sq: int32 = 0
    while i < n:
        c: uint8 = buf[i]
        if in_dq != 0:
            if c == 34:
                in_dq = 0
        elif in_sq != 0:
            if c == 39:
                in_sq = 0
        else:
            if c == 34:
                in_dq = 1
            elif c == 39:
                in_sq = 1
            elif c == 35:                    # comment to EOL — stop scan
                break
            elif c == 32 or c == 9:
                pass                          # trailing WS doesn't count
            else:
                last = cast[int64](c)
        i = i + 1
    if last == 58:                            # ':'
        return 1
    return 0


def _phys_is_blank(buf: Ptr[uint8], n: uint64) -> int32:
    # 1 iff a physical line is empty or whitespace-only. A blank line
    # terminates an interactive indentation suite.
    i: uint64 = 0
    while i < n:
        if _is_space(buf[i]) == 0:
            return 0
        i = i + 1
    return 1


def run_source(buf: Ptr[uint8], n: uint64) -> int32:
    # Lex, parse, and execute a complete logical input. Returns 1 if
    # `exit` was requested, else 0. The node / value / string arenas
    # are session-lifetime append-only (so variables and `def`'d
    # functions outlive the line); _maybe_recycle_arenas reclaims them
    # only when provably safe.
    # §18.1: a blank / whitespace-only / comment-only top-level line is
    # a silent no-op — skip lex/parse/exec entirely.
    if _line_is_blank(buf, n) != 0:
        return 0
    # Each top-level line starts with the call-depth counter clear —
    # a previous line that erred out mid-recursion must not leave the
    # guard tripped for the next line.
    call_depth = 0
    _maybe_recycle_arenas()
    if lex_line(buf, n) < 0:
        write_cstr1("hamsh: lexical error (unterminated quote or token-limit exceeded)\n")
        return 0
    prog: int32 = parse_program()
    if ps_error != 0:
        write_cstr1("hamsh: parse error [line ")
        write_cstr1(render_int(cast[int64](ps_errline)))
        write_cstr1("]: ")
        write_cstr1(&ps_errmsg[0])
        write_cstr1("\n")
        return 0
    ex: int32 = exec_block(prog)
    if ex == EX_EXIT:
        return 1
    # §Exceptions: an uncaught `raise` (or hard evaluator error) unwinds
    # to the top level — report it rather than swallowing it silently.
    if ex == EX_ERROR:
        write_cstr1("hamsh: uncaught exception: ")
        write_cstr1(&errstr_buf[0])
        write_cstr1("\n")
        eval_status = 1
    return 0


def prompt():
    write_cstr1("hamsh$ ")


def cont_prompt():
    write_cstr1("> ")


# ====================================================================
# Interactive line editor
# ====================================================================
# A cursor-aware line editor for the interactive prompt ONLY. It is
# driven entirely off fd 0, which the interactive shell binds to the
# raw console (DEVFD_CONS — no kernel-side cooking, no echo). The
# editor therefore owns echo, cursor motion, and redraw itself.
#
# SCOPE BOUNDARY: this code is reached ONLY from main()'s interactive
# read loop. The rc / init path (_run_rc_path) reads its script with a
# plain sys_read on a file fd and never touches the editor — sourcing
# /etc/rc.boot or /etc/hamsh.rc is wholly unaffected.
#
# Keys handled:
#   * printable bytes        — inserted at the cursor (mid-line insert
#                              shifts the tail right)
#   * Enter (CR / LF)        — terminate the physical line
#   * Backspace (0x08/0x7f)  — delete the char BEFORE the cursor
#   * ESC [ D / ESC [ C      — cursor Left / Right within the line
#   * ESC [ A / ESC [ B      — history Up / Down
#   * ESC [ 3~               — Delete the char AT the cursor
#   * ESC [ H, ESC [ 1~,
#     ESC O H                — Home (cursor to line start)
#   * ESC [ F, ESC [ 4~,
#     ESC O F                — End  (cursor to line end)
#   * Ctrl-C (0x03)          — discard the current line, fresh prompt
#
# Escape sequences arrive a byte at a time over the console; a tiny
# state machine reassembles them. The console RX path is interrupt-
# driven (a recent kernel fix), so no input bytes are dropped.

# --- physical-line edit buffer --------------------------------------
# One physical input line, generously larger than any line a human
# types interactively (and smaller than LINE_MAX so a full edited line
# always fits into line_buf with room for the appended newline).
ED_LINE_MAX: uint64 = 1024
ed_buf:   Array[1024, uint8]    # the line being edited (no NUL needed)
ed_len:   uint64 = 0            # number of live bytes in ed_buf
ed_cur:   uint64 = 0            # cursor position, 0..ed_len

# --- command history (ring buffer) ----------------------------------
# Each slot is a fixed-width line image. A modest ring depth keeps the
# static footprint small while covering a long interactive session.
HIST_MAX:  uint64 = 48          # ring depth
HIST_WID:  uint64 = 1024        # bytes per stored line (== ED_LINE_MAX)
hist_buf:  Array[49152, uint8]  # HIST_MAX * HIST_WID, flattened
hist_len:  Array[48, uint64]    # live byte count of each slot
hist_count: uint64 = 0          # number of lines ever appended
# hist_view: -1 == editing a fresh line; >=0 == browsing history,
# counting back from the newest entry (0 = newest).
hist_view: int64 = -1


def _ed_putc(c: uint8):
    # Emit one byte to the console (fd 1 == console for the shell).
    one: Array[1, uint8]
    one[0] = c
    sys_write(1, &one[0], 1)


def _ed_esc(s: Ptr[uint8]):
    # Emit a NUL-terminated terminal control string.
    write_cstr1(s)


def hist_append(buf: Ptr[uint8], n: uint64):
    # Append a completed line to the history ring. Empty lines and an
    # exact repeat of the most recent entry are not stored — the usual
    # interactive convenience.
    if n == 0:
        return
    if hist_count > 0:
        prev: uint64 = (hist_count - 1) % HIST_MAX
        if hist_len[prev] == n:
            same: int32 = 1
            k: uint64 = 0
            while k < n:
                if hist_buf[prev * HIST_WID + k] != buf[k]:
                    same = 0
                    break
                k = k + 1
            if same != 0:
                return
    slot: uint64 = hist_count % HIST_MAX
    copy_n: uint64 = n
    if copy_n > HIST_WID:
        copy_n = HIST_WID
    i: uint64 = 0
    while i < copy_n:
        hist_buf[slot * HIST_WID + i] = buf[i]
        i = i + 1
    hist_len[slot] = copy_n
    hist_count = hist_count + 1


def _hist_depth() -> uint64:
    # Number of distinct history entries currently retrievable.
    if hist_count < HIST_MAX:
        return hist_count
    return HIST_MAX


def _hist_load(back: uint64):
    # Load history entry `back` (0 = newest) into the edit buffer and
    # place the cursor at end. Caller guarantees back < _hist_depth().
    slot: uint64 = (hist_count - 1 - back) % HIST_MAX
    n: uint64 = hist_len[slot]
    i: uint64 = 0
    while i < n:
        ed_buf[i] = hist_buf[slot * HIST_WID + i]
        i = i + 1
    ed_len = n
    ed_cur = n


# The prompt in effect for the current ed_readline call. The editor
# re-emits it verbatim on every redraw so a CR-to-column-0 repaint
# never clobbers the prompt text. ed_prompt_kind selects which prompt
# to paint (0 == "hamsh$ ", 1 == continuation "> "); ed_prompt_len is
# its visible column width. Both are set by main() before ed_readline.
ed_prompt_kind: int32 = 0
ed_prompt_len:  uint64 = 0

# BUG 3 FIX (DE terminal local echo). When hamsh is the persistent shell
# behind a front-end that does its OWN local line editing + echo (the scene
# DE terminal, user/hamtermscene.ad, spawned as `/bin/hamsh --no-echo
# /etc/rc.de-user`), the shell's readline must NOT echo the typed bytes back
# over stdout — the front-end already painted them, so a shell echo would
# double every character. `ed_local_echo == 0` suppresses ALL per-keystroke
# readline echo (the in-line repaint, the Enter CRLF, tab-completion redraw)
# while STILL emitting the prompt (from main()) and command OUTPUT. Default 1
# keeps the normal echoing line editor for the serial console and SSH clients
# (a remote terminal relies on the shell to echo).
ed_local_echo: int32 = 1


def _ed_emit_prompt():
    # Re-emit the active prompt verbatim (used by _ed_redraw).
    if ed_prompt_kind == 0:
        write_cstr1("hamsh$ ")
    else:
        write_cstr1("> ")


def _ed_redraw():
    # Repaint the editable line in place: carriage-return to column 0,
    # re-emit the prompt verbatim, re-emit the edit buffer, clear any
    # stale tail (ESC[K), then park the cursor at ed_cur with a fresh
    # CR + cursor-forward over (prompt + ed_cur) columns.
    # BUG 3 FIX: when a local-echo front-end owns line painting, suppress
    # the shell's repaint entirely (no per-keystroke echo over stdout).
    if ed_local_echo == 0:
        return
    _ed_putc(13)                          # CR — column 0
    _ed_emit_prompt()                     # re-emit the prompt
    if ed_len > 0:
        sys_write(1, &ed_buf[0], ed_len)
    _ed_esc(cast[Ptr[uint8]]("\x1b[K"))   # clear to end of line
    # Park the cursor: CR back to column 0, then forward by the prompt
    # width plus the in-line cursor offset.
    _ed_putc(13)
    target: uint64 = ed_prompt_len + ed_cur
    if target > 0:
        # ESC[<n>C — cursor forward n columns.
        _ed_esc(cast[Ptr[uint8]]("\x1b["))
        write_cstr1(render_int(cast[int64](target)))
        _ed_putc(67)                      # 'C'


# Escape-parser state. 0 = ground, 1 = saw ESC, 2 = saw ESC[ (CSI),
# 3 = saw ESC O (SS3).
ed_esc_state: int32 = 0
ed_esc_param: uint64 = 0          # numeric parameter accumulated in CSI


# TEMP_DEBUG_HEARTBEAT
# Remove once real-hardware keyboard input works (Asus + Nook bring-up).
#
# The Asus boots all the way to hamsh-as-PID-1 but accepts no keyboard
# input — internal keyboard nor plugged-in USB keyboard produce
# anything. From a screen photo we cannot tell whether hamsh is alive
# but input-starved, or wedged. This emits a periodic "alive" line from
# hamsh's interactive idle loop straight to fd 2 (stderr), which the
# post-`05c9ffe` console-split routes unconditionally through
# early_putc_user to the framebuffer + UART — bypassing the
# post-interactive console log-level gate. The tick counter is monotonic
# so a static screen shows N stuck.
HB_PERIOD_JIFFIES: uint64 = 300       # 100 Hz tick -> 3 s cadence
hb_tick:           uint64 = 0         # monotonic heartbeat counter
hb_boot_jiffies:   uint64 = 0         # captured on first heartbeat call
hb_next_jiffies:   uint64 = 0         # jiffies value at which the next
                                      # heartbeat is due
hb_inited:         int32  = 0


def _diag_fd2_is_bridged() -> int32:
    # True when /fd/2 is a bridged session pipe — i.e. an SSH session
    # (sshd binds the child's /fd/2 to its stdout pipe, see user/sshd.ad
    # _spawn_shell) or the DE scene terminal (its visible pane is a pipe,
    # not a dev console). In those sessions fd 2 is the USER's interactive
    # stdout, so the dev-only [hamsh-alive] heartbeat and [hamsh:stage-NN]
    # bringup markers must NOT be written there or they spam the user's
    # shell every few seconds.
    #
    # A genuine serial / framebuffer console resolves /fd/2 to DEVFD_CONS,
    # and at very early boot (before _setup_fd_namespace) fd 2 may still be
    # DEVFD_NONE — in BOTH cases we return 0 so PID-1 boot diagnostics keep
    # reaching the kernel console, which is exactly where
    # test_hamsh_heartbeat (and the many stage-07 gate tests) read them.
    # Only an explicit pipe binding suppresses; CONS/NONE/FILE never do.
    k: int32 = sys_fdslot_kind(0, 2)
    if k == DEVFD_PIPE_W:
        return 1
    if k == DEVFD_PIPE_R:
        return 1
    return 0


def _hb_emit_to_stderr():
    # Build the heartbeat line in a small local scratch and dump it to
    # fd 2. Using render_int + the shared num_buf is fine here — we only
    # ever emit one number at a time, and the editor isn't holding
    # num_buf live across an ed_readline call.
    sys_write(2, cast[Ptr[uint8]]("[hamsh-alive] tick="),
              cstr_len(cast[Ptr[uint8]]("[hamsh-alive] tick=")))
    s_tick: Ptr[uint8] = render_int(cast[int64](hb_tick))
    sys_write(2, s_tick, cstr_len(s_tick))
    sys_write(2, cast[Ptr[uint8]](" uptime="),
              cstr_len(cast[Ptr[uint8]](" uptime=")))
    up_j: uint64 = sys_get_jiffies() - hb_boot_jiffies
    up_s: uint64 = up_j / 100         # 100 Hz tick
    s_up: Ptr[uint8] = render_int(cast[int64](up_s))
    sys_write(2, s_up, cstr_len(s_up))
    sys_write(2, cast[Ptr[uint8]]("s\r\n"), 3)


def _hb_check_and_emit():
    # Called from ed_readline's idle poll loop. If at least
    # HB_PERIOD_JIFFIES have elapsed since the last tick, emit one
    # heartbeat line and schedule the next one. Cheap when nothing is
    # due: one jiffies read + one compare.
    # BUG 1 FIX: under a local-echo front-end (the DE terminal, --no-echo)
    # fd 2 is the VISIBLE pane, NOT a dev console — the [hamsh-alive]
    # heartbeat is dev-only liveness noise that would flood the terminal and
    # CR-overwrite the user's typed line every 3s. Suppress it entirely; the
    # serial console keeps it (ed_local_echo defaults to 1).
    if ed_local_echo == 0:
        return
    # An SSH session (and any other bridged front-end) has /fd/2 bound to a
    # session pipe, NOT a dev console. The heartbeat is dev-only liveness
    # noise on the kernel console; never leak it onto a real user's
    # interactive stdout. The serial console (/fd/2 = CONS) still gets it,
    # which is where test_hamsh_heartbeat reads the ticks.
    if _diag_fd2_is_bridged() != 0:
        return
    now: uint64 = sys_get_jiffies()
    if hb_inited == 0:
        hb_boot_jiffies = now
        hb_next_jiffies = now + HB_PERIOD_JIFFIES
        hb_inited = 1
        return
    if now < hb_next_jiffies:
        return
    hb_tick = hb_tick + 1
    _hb_emit_to_stderr()
    # Repaint the prompt + edit buffer so the user's typed-but-unsent
    # text isn't visually orphaned above the heartbeat line.
    _ed_redraw()
    hb_next_jiffies = now + HB_PERIOD_JIFFIES


# TEMP_DEBUG_HAMSH_BRINGUP — fire a one-shot marker the first time the
# interactive line editor runs. Once-flag (not per-keystroke) so the
# log stays readable; the periodic [hamsh-alive] heartbeat covers the
# "still running" question once we're past stage 8.
ed_first_entry: int32 = 1


def ed_readline() -> int64:
    # Read and edit ONE physical line interactively. Returns the line
    # length in ed_buf (the trailing newline is NOT stored — the caller
    # appends '\n' to line_buf). Returns -1 on EOF, -2 on Ctrl-C.
    #
    # On entry the prompt has already been printed; ed_prompt_kind /
    # ed_prompt_len must be set by the caller so the editor can repaint
    # the line and place the cursor.
    #
    # TEMP_DEBUG_HEARTBEAT: the byte read is non-blocking + yield, so we
    # can fire the periodic alive tick (see _hb_check_and_emit above)
    # while sitting idle at the prompt. Without this the blocking
    # sys_read() pins hamsh inside the syscall and no user code runs to
    # signal liveness — the whole point of the heartbeat is to show the
    # shell is being scheduled on a box whose keyboard is broken. Remove
    # this poll-and-yield (and the heartbeat hook) once real-hardware
    # keyboard input works.
    # TEMP_DEBUG_HAMSH_BRINGUP — first ed_readline call. The very next
    # observable signal will be the [hamsh-alive] heartbeat (cadence
    # ~3s); if stage-08 prints but no heartbeat ever follows, the bug
    # is in the sys_read_nb / sys_yield loop on real silicon.
    if ed_first_entry != 0:
        ed_first_entry = 0
        # Dev-only bringup marker — kernel console only; suppress on a
        # bridged session (SSH / DE terminal) so it doesn't leak onto the
        # user's interactive stdout.
        if _diag_fd2_is_bridged() == 0:
            sys_write(2, cast[Ptr[uint8]]("[hamsh:stage-08] ed-readline-first\n"),
                      cstr_len(cast[Ptr[uint8]]("[hamsh:stage-08] ed-readline-first\n")))
        # Getty-style input flush at session start. Bytes that show up in
        # the very first instants of the interactive prompt did NOT come
        # from the user typing at the live shell — they are pre-prompt
        # serial input (UEFI/firmware probes, RS-232 line noise, a serial
        # BREAK) that was still draining into the kernel RX FIFO when the
        # REPL opened. Under slow boots (root-on-USB) one such stray byte
        # trickles in a few timer ticks AFTER the prompt and prepends to
        # the first command ('a' -> "command not found: aecho").
        #
        # Drain across a SHORT FIXED window only: discard whatever is
        # queued now, then yield a small bounded number of times draining
        # each pass, and stop unconditionally. This must NOT reset on every
        # byte seen — a real command is a burst of bytes, and a reset-on-
        # byte loop would swallow the whole first command. The pre-prompt
        # straggler lands within a handful of timer ticks; the user's first
        # real keystroke arrives only once they type, far outside this
        # window. The yields keep the heartbeat/supervisor alive meanwhile.
        #
        # Skip this flush when stdin is a pipe (DEVFD_PIPE_R). Pipe-
        # backed stdin never carries RS-232/UEFI serial noise; discarding
        # early bytes would eat the very command the parent just wrote
        # (e.g. the hamUId terminal selftest). The flush is only needed
        # when stdin is the raw console device (DEVFD_CONS).
        flush_buf: Array[1, uint8]
        if sys_fdslot_kind(0, 0) != DEVFD_PIPE_R:
            settle: int32 = 0
            while settle < 8:
                drained: int64 = sys_read_nb(0, &flush_buf[0], 1)
                while drained > 0:                    # discard queued bytes
                    drained = sys_read_nb(0, &flush_buf[0], 1)
                settle = settle + 1
                sys_yield()
    ed_len = 0
    ed_cur = 0
    ed_esc_state = 0
    ed_esc_param = 0
    rb: Array[1, uint8]
    while True:
        n: int64 = sys_read_nb(0, &rb[0], 1)
        if n < 0:
            return -1                         # true EOF / error
        if n == 0:
            # Stdin idle — fire the heartbeat if it's due, then yield.
            _hb_check_and_emit()
            # Service supervisor: reap any exited supervised children
            # and fire any restart-due transitions. Non-blocking; cheap
            # when the table is empty (zero-svc_count fast-path).
            svc_supervisor_tick()
            sys_yield()
            continue
        c: uint8 = rb[0]
        # Any byte other than Tab ends a consecutive-Tab run, so the
        # next Tab starts a fresh completion (this also covers the
        # arrow / escape keys handled by the state machine below).
        if c != 9:
            ed_tab_pending = 0

        if ed_esc_state == 1:
            # Just saw ESC. Expect '[' (CSI) or 'O' (SS3).
            if c == 91:                       # '['
                ed_esc_state = 2
                ed_esc_param = 0
            elif c == 79:                     # 'O'
                ed_esc_state = 3
            else:
                # Lone ESC or unrecognised — drop, back to ground.
                ed_esc_state = 0
            continue

        if ed_esc_state == 2:
            # Inside a CSI sequence. Accumulate digit parameters.
            if c >= 48 and c <= 57:           # '0'..'9'
                ed_esc_param = ed_esc_param * 10 + cast[uint64](c - 48)
                continue
            ed_esc_state = 0
            if c == 68:                       # 'D' — Left
                if ed_cur > 0:
                    ed_cur = ed_cur - 1
                    _ed_redraw()
                continue
            if c == 67:                       # 'C' — Right
                if ed_cur < ed_len:
                    ed_cur = ed_cur + 1
                    _ed_redraw()
                continue
            if c == 65:                       # 'A' — Up (older)
                _ed_hist_prev()
                continue
            if c == 66:                       # 'B' — Down (newer)
                _ed_hist_next()
                continue
            if c == 72:                       # 'H' — Home
                ed_cur = 0
                _ed_redraw()
                continue
            if c == 70:                       # 'F' — End
                ed_cur = ed_len
                _ed_redraw()
                continue
            if c == 126:                      # '~' — terminated param key
                if ed_esc_param == 3:         # ESC[3~ — Delete
                    if ed_cur < ed_len:
                        _ed_delete_at_cursor()
                        _ed_redraw()
                elif ed_esc_param == 1 or ed_esc_param == 7:   # Home
                    ed_cur = 0
                    _ed_redraw()
                elif ed_esc_param == 4 or ed_esc_param == 8:   # End
                    ed_cur = ed_len
                    _ed_redraw()
                continue
            # Any other final byte: unrecognised CSI — ignore.
            continue

        if ed_esc_state == 3:
            # SS3: ESC O H / ESC O F (Home / End on some terminals).
            ed_esc_state = 0
            if c == 72:                       # Home
                ed_cur = 0
                _ed_redraw()
            elif c == 70:                     # End
                ed_cur = ed_len
                _ed_redraw()
            continue

        # --- ground state ---------------------------------------------
        if c == 27:                           # ESC — start a sequence
            ed_esc_state = 1
            continue
        if c == 10 or c == 13:                # Enter — line complete
            # BUG 3 FIX: skip the echoed CRLF under a local-echo front-end
            # (hamterm already moved to a fresh row locally on Enter).
            if ed_local_echo != 0:
                _ed_putc(13)
                _ed_putc(10)
            return cast[int64](ed_len)
        if c == 3:                            # Ctrl-C — abandon line
            _ed_esc(cast[Ptr[uint8]]("^C\r\n"))
            ed_len = 0
            ed_cur = 0
            return -2
        if c == 8 or c == 127:                # Backspace — delete left
            if ed_cur > 0:
                ed_cur = ed_cur - 1
                _ed_delete_at_cursor()
                _ed_redraw()
            continue
        if c == 9:                            # Tab — completion
            _ed_complete()
            continue
        if c == 1:                            # Ctrl-A — Home
            ed_cur = 0
            _ed_redraw()
            continue
        if c == 5:                            # Ctrl-E — End
            ed_cur = ed_len
            _ed_redraw()
            continue
        if c < 32:
            # Other control bytes are not editing keys — ignore.
            continue
        # Printable byte: insert at the cursor.
        _ed_insert_at_cursor(c)
        _ed_redraw()


def _ed_insert_at_cursor(c: uint8):
    # Insert one byte at ed_cur, shifting the tail right.
    if ed_len + 1 >= ED_LINE_MAX:
        return
    i: uint64 = ed_len
    while i > ed_cur:
        ed_buf[i] = ed_buf[i - 1]
        i = i - 1
    ed_buf[ed_cur] = c
    ed_len = ed_len + 1
    ed_cur = ed_cur + 1


def _ed_delete_at_cursor():
    # Remove the byte at ed_cur, shifting the tail left. Cursor stays.
    if ed_cur >= ed_len:
        return
    i: uint64 = ed_cur
    while i + 1 < ed_len:
        ed_buf[i] = ed_buf[i + 1]
        i = i + 1
    ed_len = ed_len - 1


def _ed_hist_prev():
    # Up arrow — recall an older history line.
    depth: uint64 = _hist_depth()
    if depth == 0:
        return
    if hist_view < 0:
        hist_view = 0
    elif cast[uint64](hist_view) + 1 < depth:
        hist_view = hist_view + 1
    else:
        return
    _hist_load(cast[uint64](hist_view))
    _ed_redraw()


def _ed_hist_next():
    # Down arrow — walk toward newer history; past the newest entry the
    # buffer goes empty (a fresh line).
    if hist_view < 0:
        return
    if hist_view == 0:
        hist_view = -1
        ed_len = 0
        ed_cur = 0
        _ed_redraw()
        return
    hist_view = hist_view - 1
    _hist_load(cast[uint64](hist_view))
    _ed_redraw()


# --- Tab completion --------------------------------------------------
# HAMSH_SPEC §1: interactive command invocation is the #1 use case, and
# Tab completion serves it directly. The editor completes the token the
# cursor sits in:
#
#   * FIRST word (command position)  — completes against the builtin
#     verbs plus every executable name in /bin, /sbin, /usr/bin.
#   * any LATER word (argument)      — completes against file and
#     directory names in the current namespace: the partial token is
#     split into a directory prefix and a leaf, the directory is listed,
#     and leaf-prefixed entries are the candidates. A directory match
#     completes with a trailing '/'.
#
# Behaviour is the readline standard: Tab extends the token to the
# longest common prefix of all matches. A unique match completes fully
# (and gets a trailing '/' for a dir, ' ' for a command/file). If the
# token is already at an ambiguous point — multiple matches but no
# further common prefix — a second consecutive Tab LISTS the candidates
# then repaints the prompt + line.
#
# Scope: command + path completion, longest-common-prefix, list-on-
# ambiguous. No fuzzy matching, no option/flag completion, no
# programmable specs — the simple, standard behaviour.

# Candidate scratch. cmp_buf accumulates the running longest common
# prefix across all matches; cmp_list holds the "NAME\n" candidate set
# for the listing display. cmp_dir is the directory being listed for a
# path completion.
cmp_buf:   Array[256, uint8]    # running longest common prefix
cmp_len:   uint64 = 0           # live bytes in cmp_buf
cmp_count: uint64 = 0           # number of matches seen so far
cmp_list:  Array[4096, uint8]   # collected "NAME\n" lines for listing
cmp_list_len: uint64 = 0
cmp_is_dir: int32 = 0           # the SOLE match (cmp_count==1) is a dir
cmp_dir:   Array[256, uint8]    # path-completion directory
cmp_scan:  Array[4096, uint8]   # listdir scratch for one directory

# A consecutive-Tab counter: a second Tab with no progress lists the
# candidates. Reset to 0 by every non-Tab key in ground state.
ed_tab_pending: int32 = 0


def _cmp_path_is_dir(path: Ptr[uint8]) -> int32:
    # A path is a directory iff p9_listdir succeeds on it (>= 0). A
    # plain file yields -EINVAL from vfs_listdir, so a negative result
    # means "not a directory".
    probe: Array[4, uint8]
    r: int64 = _ext_listdir(path, &probe[0], 4)
    if r >= 0:
        return 1
    return 0


def _cmp_reset():
    cmp_len = 0
    cmp_count = 0
    cmp_list_len = 0
    cmp_is_dir = 0


def _cmp_seen(name: Ptr[uint8], nlen: uint64) -> int32:
    # Return 1 if `name` is already among the gathered candidates. The
    # listing buffer holds "NAME\n" lines, so a walk over it dedups —
    # e.g. the `echo` builtin and the /bin/echo executable both offer
    # the name "echo", but it should count as ONE candidate.
    p: uint64 = 0
    while p < cmp_list_len:
        s: uint64 = p
        while p < cmp_list_len and cmp_list[p] != 10:
            p = p + 1
        llen: uint64 = p - s
        if p < cmp_list_len:
            p = p + 1
        if llen == nlen:
            same: int32 = 1
            k: uint64 = 0
            while k < nlen:
                if cmp_list[s + k] != name[k]:
                    same = 0
                    break
                k = k + 1
            if same != 0:
                return 1
    return 0


def _cmp_offer(name: Ptr[uint8], nlen: uint64, is_dir: int32):
    # Register one candidate `name` (length `nlen`). Folds it into the
    # running longest common prefix (cmp_buf) and appends it to the
    # listing buffer. A name already gathered is ignored (dedup).
    if _cmp_seen(name, nlen) != 0:
        return
    if cmp_count == 0:
        i: uint64 = 0
        while i < nlen and i + 1 < 256:
            cmp_buf[i] = name[i]
            i = i + 1
        cmp_len = i
        cmp_is_dir = is_dir
    else:
        # Shrink cmp_buf to the common prefix with this candidate.
        k: uint64 = 0
        while k < cmp_len and k < nlen and cmp_buf[k] == name[k]:
            k = k + 1
        cmp_len = k
    cmp_count = cmp_count + 1
    # Append "name\n" to the listing buffer (truncate if it overflows).
    if cmp_list_len + nlen + 1 < 4096:
        j: uint64 = 0
        while j < nlen:
            cmp_list[cmp_list_len + j] = name[j]
            j = j + 1
        cmp_list[cmp_list_len + nlen] = 10
        cmp_list_len = cmp_list_len + nlen + 1


def _cmp_offer_if_prefix(name: Ptr[uint8], nlen: uint64,
                         pfx: Ptr[uint8], plen: uint64, is_dir: int32):
    # Offer `name` only if it starts with the `plen`-byte prefix `pfx`.
    if nlen < plen:
        return
    k: uint64 = 0
    while k < plen:
        if name[k] != pfx[k]:
            return
        k = k + 1
    _cmp_offer(name, nlen, is_dir)


# The completion verbs, as one space-separated string. Kept in step
# with _builtin_dispatch / the exec_statement keyword arm. `help` is
# included because it's a frequent prompt verb (now /bin/help, an
# external binary), so tab-completion should still offer it.
_CMP_BUILTINS: Array[96, uint8]


def _cmp_init_builtins():
    # Seed _CMP_BUILTINS at startup (global initialisers must be integer
    # constants, so the string is filled in here from a literal).
    src: Ptr[uint8] = cast[Ptr[uint8]]("cd bind mount unmount import export echo source true false kill wait exit help")
    i: uint64 = 0
    while src[i] != 0 and i + 1 < 96:
        _CMP_BUILTINS[i] = src[i]
        i = i + 1
    _CMP_BUILTINS[i] = 0


def _cmp_offer_builtins(pfx: Ptr[uint8], plen: uint64):
    # Walk the space-separated builtin list, offering each verb.
    i: uint64 = 0
    while _CMP_BUILTINS[i] != 0:
        s: uint64 = i
        while _CMP_BUILTINS[i] != 0 and _CMP_BUILTINS[i] != 32:
            i = i + 1
        wlen: uint64 = i - s
        if wlen > 0:
            _cmp_offer_if_prefix(&_CMP_BUILTINS[s], wlen, pfx, plen, 0)
        while _CMP_BUILTINS[i] == 32:
            i = i + 1


def _cmp_offer_dir_entries(dir: Ptr[uint8], pfx: Ptr[uint8],
                           plen: uint64, want_slash: int32):
    # List `dir`, offering every entry that begins with `pfx`. When
    # `want_slash` is set the entry's directory-ness is probed so a sole
    # match can be completed with a trailing '/'.
    n: int64 = _ext_listdir(dir, &cmp_scan[0], 4096)
    if n <= 0:
        return
    dlen: uint64 = cstr_len(dir)
    p: uint64 = 0
    ent: Array[256, uint8]
    full: Array[512, uint8]
    while p < cast[uint64](n):
        s: uint64 = p
        while p < cast[uint64](n) and cmp_scan[p] != 10:
            p = p + 1
        elen: uint64 = p - s
        if p < cast[uint64](n):
            p = p + 1
        ec: uint64 = 0
        while ec < elen and ec + 1 < 256:
            ent[ec] = cmp_scan[s + ec]
            ec = ec + 1
        ent[ec] = 0
        # Prefix test before the (more expensive) is-dir probe.
        if ec >= plen:
            ok: int32 = 1
            k: uint64 = 0
            while k < plen:
                if ent[k] != pfx[k]:
                    ok = 0
                    break
                k = k + 1
            if ok != 0:
                is_dir: int32 = 0
                if want_slash != 0:
                    # Build dir + '/' + ent and probe it.
                    fi: uint64 = 0
                    while fi < dlen and fi + 1 < 512:
                        full[fi] = dir[fi]
                        fi = fi + 1
                    if fi > 0 and full[fi - 1] != 47 and fi + 1 < 512:
                        full[fi] = 47
                        fi = fi + 1
                    gj: uint64 = 0
                    while ent[gj] != 0 and fi + 1 < 512:
                        full[fi] = ent[gj]
                        fi = fi + 1
                        gj = gj + 1
                    full[fi] = 0
                    is_dir = _cmp_path_is_dir(&full[0])
                _cmp_offer(&ent[0], ec, is_dir)


def _ed_token_start() -> uint64:
    # Index of the first byte of the token the cursor sits in: scan back
    # from ed_cur over non-whitespace bytes.
    i: uint64 = ed_cur
    while i > 0:
        c: uint8 = ed_buf[i - 1]
        if c == 32 or c == 9:
            break
        i = i - 1
    return i


def _ed_is_first_word(tok_start: uint64) -> int32:
    # The token is the command word iff only whitespace precedes it.
    i: uint64 = 0
    while i < tok_start:
        c: uint8 = ed_buf[i]
        if c != 32 and c != 9:
            return 0
        i = i + 1
    return 1


def _ed_insert_run_at_cursor(src: Ptr[uint8], n: uint64):
    # Insert `n` bytes from `src` at ed_cur, shifting the tail right.
    k: uint64 = 0
    while k < n:
        _ed_insert_at_cursor(src[k])
        k = k + 1


def _ed_complete_list():
    # Print the gathered candidate list on its own lines, then repaint
    # the prompt and the edit buffer.
    _ed_putc(13)
    _ed_putc(10)
    if cmp_list_len > 0:
        sys_write(1, &cmp_list[0], cmp_list_len)
    _ed_emit_prompt()
    _ed_redraw()


def _ed_complete():
    # Tab handler. Completes the token under the cursor against either
    # the command set (first word) or namespace paths (later words).
    tok_start: uint64 = _ed_token_start()
    first: int32 = _ed_is_first_word(tok_start)
    # The token leaf to be completed runs tok_start .. ed_cur.
    tok_len: uint64 = ed_cur - tok_start
    # Stage the token leaf into a NUL-terminated scratch buffer.
    tok: Array[256, uint8]
    ti: uint64 = 0
    while ti < tok_len and ti + 1 < 256:
        tok[ti] = ed_buf[tok_start + ti]
        ti = ti + 1
    tok[ti] = 0

    _cmp_reset()
    # `leaf` is the part of the token actually being prefix-matched;
    # `leaf_off` is its offset within `tok` (past any directory part).
    leaf_off: uint64 = 0

    if first != 0:
        # Command-name completion. A token that contains a '/' is a
        # path to an executable — fall through to path completion so
        # `./scr<Tab>` and `/bin/l<Tab>` still work.
        has_slash: int32 = 0
        si: uint64 = 0
        while si < ti:
            if tok[si] == 47:
                has_slash = 1
            si = si + 1
        if has_slash == 0:
            _cmp_offer_builtins(&tok[0], ti)
            _cmp_offer_dir_entries(cast[Ptr[uint8]]("/bin"),
                                   &tok[0], ti, 0)
            _cmp_offer_dir_entries(cast[Ptr[uint8]]("/sbin"),
                                   &tok[0], ti, 0)
            _cmp_offer_dir_entries(cast[Ptr[uint8]]("/usr/bin"),
                                   &tok[0], ti, 0)
            _ed_complete_apply(tok_start, leaf_off, ti, 1)
            return

    # Path completion (arguments, or a command word holding a '/').
    # Split the token into a directory part and a leaf.
    slash: int64 = -1
    si2: uint64 = 0
    while si2 < ti:
        if tok[si2] == 47:
            slash = cast[int64](si2)
        si2 = si2 + 1
    di: uint64 = 0
    if slash >= 0:
        while di < cast[uint64](slash) and di + 1 < 256:
            cmp_dir[di] = tok[di]
            di = di + 1
        if di == 0:
            cmp_dir[0] = 47                    # token began with '/'
            di = 1
        leaf_off = cast[uint64](slash) + 1
    else:
        cmp_dir[0] = 46                        # '.'  — current dir
        di = 1
        leaf_off = 0
    cmp_dir[di] = 0
    leaf_len: uint64 = ti - leaf_off
    _cmp_offer_dir_entries(&cmp_dir[0], &tok[leaf_off], leaf_len, 1)
    _ed_complete_apply(tok_start, leaf_off, ti, 0)


def _ed_complete_apply(tok_start: uint64, leaf_off: uint64,
                       tok_len: uint64, is_command: int32):
    # Given the gathered candidates (cmp_*), apply the readline policy:
    # extend to the longest common prefix, complete a unique match in
    # full, or — on a second Tab — list an ambiguous candidate set.
    #
    # tok_start  — index where the whole token began in ed_buf
    # leaf_off   — offset of the matched leaf within the token
    # tok_len    — length of the whole token (== ed_cur - tok_start)
    if cmp_count == 0:
        ed_tab_pending = 0
        return                                 # nothing matches
    # The leaf already present on the line.
    leaf_len: uint64 = tok_len - leaf_off
    if cmp_count == 1:
        # Unique match — complete it fully, then a separator. The
        # common-prefix buffer IS the whole match here.
        if cmp_len > leaf_len:
            _ed_insert_run_at_cursor(&cmp_buf[leaf_len],
                                     cmp_len - leaf_len)
        # Trailing decoration: '/' for a directory, ' ' otherwise. A
        # directory token already ending in '/' gets nothing extra.
        if cmp_is_dir != 0:
            if cmp_len == 0 or cmp_buf[cmp_len - 1] != 47:
                _ed_insert_at_cursor(47)       # '/'
        else:
            _ed_insert_at_cursor(32)           # ' '
        ed_tab_pending = 0
        _ed_redraw()
        return
    # Multiple matches. If the common prefix extends the leaf, insert
    # the extra bytes (and arm a follow-up Tab to list).
    if cmp_len > leaf_len:
        _ed_insert_run_at_cursor(&cmp_buf[leaf_len], cmp_len - leaf_len)
        ed_tab_pending = 1
        _ed_redraw()
        return
    # No further common prefix. A first Tab here just arms; a second
    # consecutive Tab lists the candidates.
    if ed_tab_pending != 0:
        _ed_complete_list()
        ed_tab_pending = 0
    else:
        ed_tab_pending = 1


def _setup_fd_namespace():
    # HAMSH §7: make /fd a name in the shell's namespace and seed the
    # standard streams. `bind '#d' /fd` grafts the fd device so opens
    # of /fd/N resolve through it. Then /fd/0,1,2 are bound to the
    # console — the shell's ambient stdio. Every command the shell
    # spawns inherits this /fd table via the COW Pgrp clone (§9), so
    # a bare command's stdio "just works" before any pipe/redirect.
    #
    # IMPORTANT: only seed the default cons-bind when /fd/N is actually
    # UNBOUND. The kernel's legacy-fd SYS_SPAWN path now auto-populates
    # /fd/0,1,2 from the child's integer-fd backings (so an sshd-spawned
    # hamsh inherits /fd/0 = pipe_r, /fd/1 = pipe_w, /fd/2 = cons). A
    # blind rebind would clobber those pre-baked bindings and route the
    # SSH session's stdout right back to the kernel console — exactly
    # the bug TIER 3 of test_sshd.sh catches.
    sys_bind(cast[Ptr[char]]("/fd"), cast[Ptr[char]]("#d"), MREPL_FLAG)
    # pid 0 == "my own Pgrp". Seed the three standard /fd names ONLY
    # where nothing has been bound yet.
    if sys_fdslot_kind(0, 0) == DEVFD_NONE:
        sys_fdbind(0, 0, DEVFD_CONS, 0)
    if sys_fdslot_kind(0, 1) == DEVFD_NONE:
        sys_fdbind(0, 1, DEVFD_CONS, 0)
    if sys_fdslot_kind(0, 2) == DEVFD_NONE:
        sys_fdbind(0, 2, DEVFD_CONS, 0)


# TEMP_DEBUG_HAMSH_BRINGUP
# Real-hardware (Asus UEFI) bring-up: hamsh prints nothing on the
# framebuffer after execve. /init's two "[init] ..." lines render fine,
# so userland-to-framebuffer DOES work up to the execve into hamsh —
# but no `[hamsh] M16.35 shell ready` ever appears. We need to know
# whether _start runs at all and, if it does, exactly where the startup
# wedges. Emission goes through sys_write(fd=2, ...) — the FD_STDERR_MARK
# arm in fs/vfs.ad routes every byte through early_putc_user, which
# unconditionally mirrors to UART + framebuffer (no console-loglevel
# gate). Same proven path /init's writes used.
#
# Remove together with the runtime.S `_start` marker once the bring-up
# bug is debugged.
def _dbg_stage(msg: Ptr[uint8]):
    # Dev-only bringup marker. Route to the kernel console only: when /fd/2
    # is a bridged session pipe (SSH / DE terminal) suppress it so the
    # [hamsh:stage-NN] markers don't leak onto the user's interactive
    # stdout. A real serial / framebuffer console — or fd 2 not yet bound
    # at very early boot — still gets it, which is where test_hamsh_heartbeat
    # and the stage-07 gate tests read these.
    if _diag_fd2_is_bridged() != 0:
        return
    sys_write(2, msg, cstr_len(msg))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # TEMP_DEBUG_HAMSH_BRINGUP — VERY FIRST instruction of main(). This
    # mirrors the hand-rolled marker in user/runtime.S's _start: a
    # single sys_write(2, ...) with a LITERAL byte-count, NOT going
    # through _dbg_stage (which itself routes through cstr_len() — one
    # more thing that could quietly wedge before producing output). If
    # this line appears on a real-hardware boot but stage-01 does not,
    # the bug is inside cstr_len; if neither appears but
    # `[runtime:hamsh] _start` does, the bug is between _start's
    # `call main` and the first instruction main() actually executes
    # (function prologue / canary check / call-site stack alignment).
    # Length 19 = len("[hamsh:_start hit]\n"); kept hardcoded so the
    # codepath here is just `sys_write(fd, buf, count)` — same opcode
    # pattern runtime.S uses, no helper involved (no cstr_len). The only
    # added dependency is the fd-2 bridged-session gate, a bare
    # sys_fdslot_kind syscall + int compares — so a bridged interactive
    # session (SSH / DE terminal) doesn't see this dev marker, while a
    # real serial / framebuffer console still does exactly as before.
    if _diag_fd2_is_bridged() == 0:
        sys_write(2,
                  cast[Ptr[uint8]]("[hamsh:_start hit]\n"),
                  cast[uint64](19))
    # TEMP_DEBUG_HAMSH_BRINGUP — first line hamsh main() runs. If we
    # see this but not the next marker, the bug is inside str_arena_init
    # or one of its peers; if we don't see this, control never reached
    # main() at all (call from _start in runtime.S broke).
    _dbg_stage(cast[Ptr[uint8]]("[hamsh:stage-01] main-enter\n"))
    str_arena_init()
    scope_reset()
    errstr_clear()
    _cmp_init_builtins()        # seed the Tab-completion builtin table
    # TEMP_DEBUG_HAMSH_BRINGUP — arenas and builtin table initialised.
    _dbg_stage(cast[Ptr[uint8]]("[hamsh:stage-02] arenas-ready\n"))
    # Seed a minimal environment so $PATH resolves.
    env_set("PATH", "/bin:/sbin:/usr/bin")
    env_set("HOME", "/")
    # TEMP_DEBUG_HAMSH_BRINGUP — argv/envp baseline resolved. We
    # haven't read argv[1] yet (rc dispatch); that's stage 5.
    _dbg_stage(cast[Ptr[uint8]]("[hamsh:stage-03] env-seeded\n"))
    # HAMSH §7: stdio as named channels — /fd/0,1,2 in the namespace.
    _setup_fd_namespace()
    # TEMP_DEBUG_HAMSH_BRINGUP — /fd namespace bound; heartbeat is
    # initialised on first ed_readline idle tick (lazy), so there is no
    # dedicated _hb_init call to mark.
    _dbg_stage(cast[Ptr[uint8]]("[hamsh:stage-04] fd-ns-ready\n"))
    write_cstr1("hamsh — Hamnix shell. Type 'help'.\n")
    # Stable readiness marker — the shared scripts/_qemu_drive.sh test
    # harness waits for this exact line before feeding input (the
    # 16550 RX FIFO has no software buffer, so a byte sent too early
    # is dropped). Many test_*.sh scripts pass it as the ready-marker;
    # keep emitting it so they survive the shell rewrite.
    write_cstr1("[hamsh] M16.35 shell ready\n")
    # Show the terminal cursor (DECTCEM). The framebuffer text console
    # (drivers/video/console/fb_text.ad) renders a software cursor as
    # a 2-row underline at the next write position — without this
    # explicit show, the parser keeps its boot default but a host
    # terminal that started with the cursor hidden would leave the
    # user without a visible insertion point at the hamsh$ prompt.
    # Safe to emit unconditionally; both the framebuffer console and
    # a real host terminal accept the sequence idempotently.
    write_cstr1("\x1b[?25h")

    # rc / init dispatch.
    #
    # When /init execs us as PID 1 it passes argv[1] = a boot rc path
    # (e.g. /etc/rc.boot). hamsh-as-init sources that script — it does
    # the namespace recipe (device binds) and launches boot services
    # via `bind` / `spawn` (HAMSH_SPEC §11) — then falls through to the
    # interactive prompt below. This replaces the old hard-coded
    # namespace recipe that lived in user/init.ad.
    #
    # When run with no rc argument (interactive: a sub-shell, or a test
    # that boots hamsh directly) we fall back to the optional
    # /etc/hamsh.rc per-user startup script.
    # BUG 3 FIX: a leading `--no-echo` flag (used by the scene DE terminal,
    # user/hamtermscene.ad, which spawns `/bin/hamsh --no-echo /etc/rc.de-user`)
    # turns off the readline's per-keystroke echo so the front-end can own
    # local echo without doubling every character. Consume it BEFORE rc
    # dispatch and shift the argv index past it so the rc path / DE-prog args
    # are read from their post-flag positions. All other call sites (init, hpm
    # hooks, tests, SSH) never pass the flag, so the default echoing editor is
    # unchanged for them.
    argbase: int32 = 1
    if argc >= 2 and argv != cast[Ptr[uint64]](0):
        a1: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        if a1 != cast[Ptr[uint8]](0) and cstr_eq(a1, "--no-echo") != 0:
            ed_local_echo = 0
            argbase = 2
    if argc >= argbase + 1 and argv != cast[Ptr[uint64]](0):
        rc_path: Ptr[char] = cast[Ptr[char]](argv[argbase])
        # DE terminal namespace plumbing: hamUId's daemon_spawn_window_prog
        # rewrites a DE-terminal spawn to `/bin/hamsh /etc/rc.de-user
        # <real-prog>` (or .../etc/rc.de-hostowner for an elevated path).
        # The real program to invoke after the rc plants its bindings rides
        # along as argv[2]; stash it in HAMNIX_DE_PROG so the rc's tail
        # `if $HAMNIX_DE_PROG { $HAMNIX_DE_PROG; exit }` can find it. When
        # argv[2] is absent (every legacy call site — /init exec'ing us
        # with just /etc/rc.boot, hpm hooks running scripts, test harness)
        # the env var stays unset and the rc's HAMNIX_DE_PROG branch falls
        # through to the interactive REPL exactly like before.
        if argc >= argbase + 2:
            de_prog: Ptr[uint8] = cast[Ptr[uint8]](argv[argbase + 1])
            if de_prog != cast[Ptr[uint8]](0) and de_prog[0] != 0:
                env_set(cast[Ptr[uint8]]("HAMNIX_DE_PROG"), de_prog)
        if argc >= argbase + 3:
            de_arg1: Ptr[uint8] = cast[Ptr[uint8]](argv[argbase + 2])
            if de_arg1 != cast[Ptr[uint8]](0) and de_arg1[0] != 0:
                env_set(cast[Ptr[uint8]]("HAMNIX_DE_PROG_ARG1"), de_arg1)
        # TEMP_DEBUG_HAMSH_BRINGUP — about to open the boot rc.
        _dbg_stage(cast[Ptr[uint8]]("[hamsh:stage-05] rc-open\n"))
        write_cstr1("[hamsh] init: sourcing boot rc ")
        write_cstr1(cast[Ptr[uint8]](rc_path))
        write_cstr1("\n")
        rcrc: int32 = _run_rc_path(rc_path)
        if rcrc == 0:
            write_cstr1("[hamsh] init: boot rc ")
            write_cstr1(cast[Ptr[uint8]](rc_path))
            write_cstr1(" not found\n")
        # If the rc script invoked `exit` (rcrc == 2), unwind out of
        # main rather than dropping into the interactive REPL. This is
        # the path `hamsh <script>` uses to run a script and quit —
        # hpm hooks rely on it (the hook's stdin is the parent's
        # stdin, which is busy talking to a different process; a REPL
        # would wedge here forever).
        if rcrc == 2:
            return cast[int32](eval_status)
        # TEMP_DEBUG_HAMSH_BRINGUP — boot rc finished (success or
        # silently-absent fallthrough); about to enter interactive loop.
        _dbg_stage(cast[Ptr[uint8]]("[hamsh:stage-06] rc-done\n"))
    else:
        # If a per-user startup script exists, run it first (init/rc).
        _run_rc_path(cast[Ptr[char]]("/etc/hamsh.rc"))
    # docs/security.md Phase 9: per-user namespace recipe loading.
    # When `newshell <user>` spawned us, it stamped HAMNIX_NEWSHELL_USER
    # in the env BEFORE forking the exec'd hamsh. On detecting that
    # env var, source the per-user recipe (/etc/users/<user>.ns) if it
    # exists, else fall back to /etc/users/default.ns. The recipe is
    # plain hamsh syntax (bind/unmount/ns) — sourced like rc.boot, then
    # we drop into the interactive REPL as normal.
    # $HOME coherence: replace the stage-03 "/" placeholder with the real
    # passwd home for our uid, now that /etc/passwd is resolvable and our
    # identity is final. Done BEFORE the per-user recipe so the recipe's
    # chdir-into-home (see _load_per_user_namespace -> _chdir_home) reads
    # a correct $HOME. See _set_home_from_passwd.
    _set_home_from_passwd()
    _load_per_user_namespace()
    # TEMP_DEBUG_HAMSH_BRINGUP — entering the interactive read-eval
    # loop. Next marker fires once per ed_readline call.
    _dbg_stage(cast[Ptr[uint8]]("[hamsh:stage-07] loop-enter\n"))

    # Interactive read-eval loop. Each logical line is built up from one
    # or more physical lines (a `{ }` block continues across lines). Each
    # physical line is read through the interactive line editor
    # (ed_readline) — cursor editing, history, ANSI escape handling. This
    # path is reached ONLY here; the rc/init path (_run_rc_path above)
    # reads its script with a plain file sys_read and is untouched.
    while True:
        total: uint64 = 0
        # Read a logical line, extending across `{ }` continuations AND
        # Python-style indentation suites (a header ending in ':' keeps
        # reading until a blank line, mirroring the Python REPL).
        done: int32 = 0
        first_line: int32 = 1
        indent_mode: int32 = 0
        while done == 0:
            # Print the prompt and tell the editor its visible width so
            # it can place the cursor on redraw.
            if first_line != 0:
                # Job control: before each fresh prompt, reap finished
                # background jobs and print their `[<id>]+ Done <cmd>` /
                # `Stopped` notices — POSIX shells report job status at
                # the prompt, not asynchronously.
                jobs_reap_and_report()
                prompt()
                ed_prompt_kind = 0
                ed_prompt_len = 7
            else:
                cont_prompt()
                ed_prompt_kind = 1
                ed_prompt_len = 2
            el: int64 = ed_readline()
            if el == -1:
                # EOF on stdin — exit cleanly.
                write_cstr1("\n")
                return cast[int32](eval_status)
            if el == -2:
                # Ctrl-C — abandon the whole logical line, fresh prompt.
                total = 0
                first_line = 1
                continue
            first_line = 0
            # Append the edited physical line + newline to line_buf.
            j: uint64 = 0
            while j < cast[uint64](el) and total + 2 < LINE_MAX:
                line_buf[total] = ed_buf[j]
                total = total + 1
                j = j + 1
            # Record the physical line in history (skips blanks/repeats).
            hist_append(&ed_buf[0], cast[uint64](el))
            hist_view = -1
            if total + 1 < LINE_MAX:
                line_buf[total] = 10              # '\n'
                total = total + 1
            # A physical line that opens a Python-style suite (ends with
            # ':') switches this logical input into indentation mode.
            if _phys_ends_with_colon(&ed_buf[0], cast[uint64](el)) != 0:
                indent_mode = 1
            # Continuation decision:
            #   * unbalanced `{ }` -> always keep reading (brace form).
            #   * indentation mode -> keep reading until a BLANK line, so
            #     the body's statements accumulate (Python REPL feel).
            #   * otherwise a balanced single line is complete.
            bal: int64 = _brace_balance(&line_buf[0], total)
            if bal > 0:
                done = 0
            elif indent_mode != 0:
                if _phys_is_blank(&ed_buf[0], cast[uint64](el)) != 0:
                    done = 1
                else:
                    done = 0
            else:
                done = 1
            if total + 2 >= LINE_MAX:
                done = 1
        if run_source(&line_buf[0], total) != 0:
            return cast[int32](eval_status)
    return 0


# --- rc / startup script --------------------------------------------
# The boot rc (/etc/rc.boot) does the namespace recipe, service
# launches, and the captured Linux-runtime `ns {}` value. 16 KiB is
# comfortably more than that script (with its explanatory comments)
# needs — and a truncated rc is a silent-failure footgun (the cut
# lands mid-statement, so the boot recipe runs only partially), so the
# buffer must stay safely larger than the on-disk rc.
rc_buf: Array[16384, uint8]


def _run_rc_path(path: Ptr[char]) -> int32:
    # Source the rc script at `path`. Returns 1 if the file existed and
    # was run (even if individual statements erred), 0 if the file was
    # absent, 2 if the script invoked `exit` (so the caller can
    # propagate the unwind out of main() — used by `hamsh <script>`
    # forms like hpm hooks to exit after the script rather than
    # dropping into an interactive REPL the caller's stdin is probably
    # not feeding).
    fd: int32 = sys_open(path)
    if fd < 0:
        return 0
    total: uint64 = 0
    while True:
        n: int64 = sys_read(fd, &rc_buf[total], 16384 - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
        if total >= 16384:
            break
    sys_close(fd)
    if total > 0:
        if run_source(&rc_buf[0], total) != 0:
            return 2
    return 1


# docs/security.md Phase 9: per-user namespace recipe at newshell-
# spawned hamsh startup. When `newshell <user>` exec'd this hamsh, it
# stamped HAMNIX_NEWSHELL_USER=<user> in the env. We detect that, then
# load /etc/users/<user>.ns (per-user override) or fall back to
# /etc/users/default.ns (the restricted recipe described in the spec —
# no /dev/blk/*, no #by-id/*, no /var/lib/hpm/). The recipe is plain
# hamsh syntax; source it the same way rc.boot is sourced.
#
# The hostowner (uid 1) does NOT load a per-user recipe — they
# inherit init's full ambient namespace from the boot rc. A `newshell
# live` (hostowner→hostowner) thus skips this whole path; the env
# var detection AND the file-existence probe BOTH need to fire for
# any sourcing to happen.

NEWSHELL_USER_PATH_MAX: uint64 = 96
newshell_user_path: Array[96, uint8]


# Stable buffer for the login user's name when it is resolved from the
# current uid (the pointer returned by passwd_entry_name aliases the
# passwd parse buffer, which callers re-parse — so copy it out).
resolved_user: Array[64, uint8]


def _resolve_login_user() -> Ptr[uint8]:
    # Determine WHO this shell belongs to, for the per-user-recipe
    # decision. Prefer the HAMNIX_NEWSHELL_USER env stamp (set by
    # su/login/newshell). But native execve does NOT propagate envp to a
    # freshly-exec'd hamsh, so that stamp is usually absent — fall back to
    # resolving the CURRENT uid against /etc/passwd, which is how a login
    # shell actually knows its identity. Returns the name, or 0 when this
    # is a non-login boot/system shell (hostowner/system uid < 1000 with
    # no stamp) for which the per-user recipe machinery does not apply.
    stamp: Ptr[uint8] = env_get(cast[Ptr[uint8]]("HAMNIX_NEWSHELL_USER"))
    if cast[uint64](stamp) != 0:
        if stamp[0] != 0:
            return stamp
    # No stamp: resolve by uid. Regular users (uid >= 1000) get the full
    # per-user treatment; hostowner (1) / system (2..999) boot shells keep
    # the historical ambient namespace.
    uid_now: uint32 = sys_getuid()
    if uid_now < 1000:
        return cast[Ptr[uint8]](0)
    n: int64 = _newshell_read_file(cast[Ptr[char]]("/etc/passwd"),
                                   &newshell_passwd_buf[0],
                                   NEWSHELL_BUF_MAX)
    if n < 0:
        return cast[Ptr[uint8]](0)
    passwd_parse(&newshell_passwd_buf[0], cast[uint64](n))
    idx: int32 = passwd_lookup_by_uid(uid_now)
    if idx < 0:
        return cast[Ptr[uint8]](0)
    nm: Ptr[uint8] = passwd_entry_name(idx)
    if cast[uint64](nm) == 0 or nm[0] == 0:
        return cast[Ptr[uint8]](0)
    i: uint64 = 0
    while nm[i] != 0 and i + 1 < 64:
        resolved_user[i] = nm[i]
        i = i + 1
    resolved_user[i] = 0
    return &resolved_user[0]


def _chdir_home():
    # chdir into $HOME. Called AFTER the per-user .ns recipe runs so the
    # `bind '#<name>' /home/<name>` has already made the home resolvable
    # (su/login chdir'd pre-exec, before that bind existed). Non-fatal.
    h: Ptr[uint8] = env_get(cast[Ptr[uint8]]("HOME"))
    if cast[uint64](h) != 0 and h[0] != 0:
        sys_chdir(cast[Ptr[char]](h))


def _load_per_user_namespace():
    # WHO we are is resolved from the newshell env stamp OR (its usual
    # fallback, since native execve drops envp) the current uid — see
    # _resolve_login_user. This is the crux fix that makes the per-user
    # recipe actually load for a logged-in regular user.
    target: Ptr[uint8] = _resolve_login_user()
    if target == cast[Ptr[uint8]](0):
        # Non-login boot/system shell (hostowner/system uid < 1000 with
        # no newshell stamp): keep the historical ambient namespace.
        return
    if target[0] == 0:
        return
    # docs/security.md: hostowner (uid 1) keeps the full ambient
    # namespace even when re-authed via `newshell hostowner`. The recipe
    # is for REGULAR users (>= 1000) — its job is to strip dangerous
    # paths from the inherited init namespace. Sourcing the restricted
    # recipe for hostowner would break `hpm install` (the restricted
    # recipe unmounts /var/lib/hpm/), which is the opposite of what
    # re-auth is meant to enable.
    if sys_getuid() == 1:
        _chdir_home()
        return
    # Compose "/etc/users/<target>.ns" in newshell_user_path. The
    # username can't legitimately contain '/' (passwd format forbids
    # it) so a simple concat is safe.
    prefix: Ptr[uint8] = "/etc/users/"
    suffix: Ptr[uint8] = ".ns"
    p: uint64 = 0
    i: uint64 = 0
    while prefix[i] != 0 and p + 1 < NEWSHELL_USER_PATH_MAX:
        newshell_user_path[p] = prefix[i]
        p = p + 1
        i = i + 1
    j: uint64 = 0
    while target[j] != 0 and p + 1 < NEWSHELL_USER_PATH_MAX:
        newshell_user_path[p] = target[j]
        p = p + 1
        j = j + 1
    k: uint64 = 0
    while suffix[k] != 0 and p + 1 < NEWSHELL_USER_PATH_MAX:
        newshell_user_path[p] = suffix[k]
        p = p + 1
        k = k + 1
    newshell_user_path[p] = 0
    # Try the per-user override first; fall back to default.ns. We
    # ignore the return value beyond the file-existence implicit in
    # _run_rc_path (returns 0 on file-not-found). The default recipe
    # is shipped in cpio so the fallback always exists.
    rc1: int32 = _run_rc_path(cast[Ptr[char]](&newshell_user_path[0]))
    if rc1 == 0:
        _run_rc_path(cast[Ptr[char]]("/etc/users/default.ns"))
    # The recipe just bound '#<name>' at /home/<name> (for installed
    # users); NOW chdir into the freshly-resolvable home (su/login
    # chdir'd before this bind existed).
    _chdir_home()


def _set_home_from_passwd():
    # Make $HOME COHERENT in every scope. main() seeds HOME="/" at
    # stage-03 only as a placeholder — at that instant the boot rc has
    # not run, so /etc/passwd is not yet bound and the real home cannot
    # be resolved. By the time we reach here the boot rc / per-user
    # namespace recipe HAS run (so #sysroot or the inherited namespace
    # has /etc/passwd bound), and sys_getuid() reports our real identity
    # (uid 1 for the hostowner init shell, the regular user's uid after
    # su/login, 65534 for the DE terminal dropped to NOBODY). Resolve the
    # passwd home for that uid and overwrite the placeholder, so $HOME,
    # `cd $HOME`, and every app that honours $HOME land in the user's
    # actual home (/home/hostowner, /home/live, /home/dave, ...) instead
    # of the filesystem root. On any failure (no /etc/passwd, uid not in the
    # table, empty home field) we leave the placeholder untouched rather
    # than break a minimal/-kernel boot.
    n_pwd: int64 = _newshell_read_file(cast[Ptr[char]]("/etc/passwd"),
                                       &newshell_passwd_buf[0],
                                       NEWSHELL_BUF_MAX)
    if n_pwd < 0:
        return
    passwd_parse(&newshell_passwd_buf[0], cast[uint64](n_pwd))
    idx: int32 = passwd_lookup_by_uid(sys_getuid())
    if idx < 0:
        return
    home: Ptr[uint8] = passwd_entry_home(idx)
    if home == cast[Ptr[uint8]](0):
        return
    if home[0] == 0:
        return
    env_set(cast[Ptr[uint8]]("HOME"), home)

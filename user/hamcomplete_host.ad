# user/hamcomplete_host.ad — HOST unit-test driver for the pure completion
# engine (lib/hamcomplete.ad), the matching kernel behind hamsh's interactive
# Tab completion (user/hamsh.ad :: _ed_complete).
#
# Built for the `x86_64-linux` Adder target: a freestanding ELF that runs
# DIRECTLY on the developer's host — no QEMU, no image. It drives hc_complete
# over a battery of cases (prefix filtering, longest-common-prefix extension,
# empty/one/many candidates, dedup) and prints one `PASS`/`FAIL` line per
# case, plus a final `RESULT ok`/`RESULT bad`. scripts/test_hamsh_complete_host.sh
# asserts on those markers.
#
# user/linux-runtime.S supplies _start + the raw Linux syscall wrappers.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

from lib.hamcomplete import hc_complete, hc_prefix_match, hc_common_prefix_len


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _w(s: Ptr[uint8]):
    sys_write(1, s, _slen(s))


fail_count: int32 = 0


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](48 + x % 10)
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while i < n:
        out[i] = digs[n - 1 - i]
        i = i + 1
    return n


# Compare a NUL-terminated string against the first `blen` bytes of b.
def _streq_n(a: Ptr[uint8], b: Ptr[uint8], blen: uint64) -> int32:
    if _slen(a) != blen:
        return 0
    k: uint64 = 0
    while k < blen:
        if a[k] != b[k]:
            return 0
        k = k + 1
    return 1


# Reusable output scratch for each hc_complete call.
o_prefix:  Array[256, uint8]
o_matches: Array[4096, uint8]
o_plen:    Array[1, uint64]


def _report(name: Ptr[uint8], ok: int32):
    if ok != 0:
        _w(cast[Ptr[uint8]]("PASS "))
    else:
        _w(cast[Ptr[uint8]]("FAIL "))
        fail_count = fail_count + 1
    _w(name)
    _w(cast[Ptr[uint8]]("\n"))


# A full case: run hc_complete(partial, cands) and assert the returned count,
# common prefix, and (optionally) that a given name is among the matches.
def _case(name: Ptr[uint8], partial: Ptr[uint8], cands: Ptr[uint8],
          want_count: uint64, want_prefix: Ptr[uint8],
          want_member: Ptr[uint8]):
    plen: uint64 = _slen(partial)
    clen: uint64 = _slen(cands)
    got: uint64 = hc_complete(partial, plen, cands, clen,
                              &o_prefix[0], 256, &o_matches[0], 4096,
                              &o_plen[0])
    ok: int32 = 1
    if got != want_count:
        ok = 0
    if _streq_n(want_prefix, &o_prefix[0], o_plen[0]) == 0:
        ok = 0
    # Membership check (only when a member is named).
    if want_member[0] != 0:
        mlen: uint64 = 0
        while o_matches[mlen] != 0 and mlen < 4096:
            mlen = mlen + 1
        found: int32 = 0
        p: uint64 = 0
        while p < mlen:
            s: uint64 = p
            while p < mlen and o_matches[p] != 10:
                p = p + 1
            elen: uint64 = p - s
            if p < mlen:
                p = p + 1
            if _streq_n(want_member, &o_matches[s], elen) != 0:
                found = 1
        if found == 0:
            ok = 0
    _report(name, ok)
    # Emit the observed prefix + count for eyeball debugging on a FAIL.
    if ok == 0:
        _w(cast[Ptr[uint8]]("  got count="))
        db: Array[24, uint8]
        dn: uint64 = _u64_to_dec(got, &db[0])
        sys_write(1, &db[0], dn)
        _w(cast[Ptr[uint8]](" prefix='"))
        sys_write(1, &o_prefix[0], o_plen[0])
        _w(cast[Ptr[uint8]]("'\n"))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # --- primitives: hc_prefix_match ---
    _report(cast[Ptr[uint8]]("prefix_match_hit"),
            hc_prefix_match(cast[Ptr[uint8]]("echo"), 4,
                            cast[Ptr[uint8]]("ec"), 2))
    _report(cast[Ptr[uint8]]("prefix_match_miss"),
            cast[int32](1 - hc_prefix_match(cast[Ptr[uint8]]("echo"), 4,
                                            cast[Ptr[uint8]]("xy"), 2)))
    # Empty prefix matches everything.
    _report(cast[Ptr[uint8]]("prefix_match_empty"),
            hc_prefix_match(cast[Ptr[uint8]]("echo"), 4,
                            cast[Ptr[uint8]](""), 0))
    # Prefix longer than the name never matches.
    _report(cast[Ptr[uint8]]("prefix_longer_than_name"),
            cast[int32](1 - hc_prefix_match(cast[Ptr[uint8]]("ec"), 2,
                                            cast[Ptr[uint8]]("echo"), 4)))

    # --- primitives: hc_common_prefix_len ---
    _report(cast[Ptr[uint8]]("lcp_partial"),
            cast[int32](hc_common_prefix_len(cast[Ptr[uint8]]("base64"), 6,
                                             cast[Ptr[uint8]]("basename"), 8) == 4))
    _report(cast[Ptr[uint8]]("lcp_none"),
            cast[int32](hc_common_prefix_len(cast[Ptr[uint8]]("abc"), 3,
                                             cast[Ptr[uint8]]("xyz"), 3) == 0))

    # --- driver: no candidates match ---
    _case(cast[Ptr[uint8]]("none_match"), cast[Ptr[uint8]]("zz"),
          cast[Ptr[uint8]]("echo\ncat\nls\n"),
          0, cast[Ptr[uint8]](""), cast[Ptr[uint8]](""))

    # --- driver: exactly one match, prefix == whole name ---
    _case(cast[Ptr[uint8]]("one_match_full"), cast[Ptr[uint8]]("ech"),
          cast[Ptr[uint8]]("echo\ncat\nls\n"),
          1, cast[Ptr[uint8]]("echo"), cast[Ptr[uint8]]("echo"))

    # --- driver: many matches -> longest common prefix extension ---
    # ba -> banner, base64, basename share "ba" only.
    _case(cast[Ptr[uint8]]("many_lcp_ba"), cast[Ptr[uint8]]("ba"),
          cast[Ptr[uint8]]("banner\nbase64\nbasename\ncat\n"),
          3, cast[Ptr[uint8]]("ba"), cast[Ptr[uint8]]("basename"))

    # --- driver: LCP extends past the typed prefix ---
    # bas -> base64, basename share "bas..." -> "base"? no: base64/basename
    # share "bas" + 'e' -> "base". Assert the engine extends "bas" to "base".
    _case(cast[Ptr[uint8]]("lcp_extends"), cast[Ptr[uint8]]("bas"),
          cast[Ptr[uint8]]("base64\nbasename\nbanner\n"),
          2, cast[Ptr[uint8]]("base"), cast[Ptr[uint8]]("base64"))

    # --- driver: dedup — the same name offered twice counts once ---
    # (echo from builtins AND /bin/echo).
    _case(cast[Ptr[uint8]]("dedup_echo"), cast[Ptr[uint8]]("ec"),
          cast[Ptr[uint8]]("echo\necho\n"),
          1, cast[Ptr[uint8]]("echo"), cast[Ptr[uint8]]("echo"))

    # --- driver: empty prefix returns ALL (deduped) candidates ---
    _case(cast[Ptr[uint8]]("empty_prefix_all"), cast[Ptr[uint8]](""),
          cast[Ptr[uint8]]("a\nb\nc\n"),
          3, cast[Ptr[uint8]](""), cast[Ptr[uint8]]("b"))

    # --- driver: leading/doubled/trailing newlines are skipped ---
    _case(cast[Ptr[uint8]]("skip_empty_fields"), cast[Ptr[uint8]]("c"),
          cast[Ptr[uint8]]("\ncat\n\ncp\n\n"),
          2, cast[Ptr[uint8]]("c"), cast[Ptr[uint8]]("cp"))

    # --- driver: a trailing '/'-decorated dir name is just a name here ---
    # (the slash decoration is applied by hamsh, not the pure engine; the
    # engine still matches the leaf and reports the common prefix.)
    _case(cast[Ptr[uint8]]("dir_leaf_prefix"), cast[Ptr[uint8]]("de"),
          cast[Ptr[uint8]]("dev\ndesktop\netc\n"),
          2, cast[Ptr[uint8]]("de"), cast[Ptr[uint8]]("desktop"))

    if fail_count == 0:
        _w(cast[Ptr[uint8]]("RESULT ok\n"))
        return 0
    _w(cast[Ptr[uint8]]("RESULT bad\n"))
    return 1

# user/join.ad
#
# Hamnix `join`: relational join of two SORTED files on a common field.
# For each pair of input lines whose join fields are equal, emit a line
# made of: the join field, then the remaining fields of file1, then the
# remaining fields of file2 (the GNU default ordering / "auto" format).
#
# Flags (GNU-compatible subset):
#   -1 N    join on field N of file1 (1-based, default 1)
#   -2 N    join on field N of file2 (1-based, default 1)
#   -j N    join on field N of BOTH files (shorthand for -1 N -2 N)
#   -t CHAR field separator CHAR; without it, fields are runs of blanks
#           and a single space separates output fields.
#   -a NUM  also print unpairable lines from file NUM (1 and/or 2); giving
#           both (-a 1 -a 2) yields a full outer join.
#   -e STR  replace empty output fields (only meaningful with -o) by STR.
#   -o SPEC output format: comma/blank separated FILENUM.FIELD specs, plus
#           the special `0.0` for the join field.
#   -i      ignore case when comparing the join field.
# A file operand of "-" reads standard input.
#
# Both inputs must be sorted on their join field (join does not sort).
# We do a standard merge with backtracking so duplicate keys produce the
# full cartesian product, and -a emits unpairable lines in key order,
# matching GNU.

# sys_open: the adder-user runtime thunk reads only %rdi (path) and opens
# read-only; the host (x86_64-linux) thunk is a raw open(2) needing
# flags/mode in %rsi/%rdx. Declaring all three args satisfies both — the
# kernel ignores the extras, the host gets O_RDONLY (flags=0, mode=0).
extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


FILE_CAP: uint64 = 16384
MAX_LINES: uint64 = 4096
MAX_OSPEC: uint64 = 64

buf1: Array[16384, uint8]
buf2: Array[16384, uint8]

# Per-file line tables.
l1start: Array[4096, uint64]
l1len:   Array[4096, uint64]
n1: uint64 = 0
l2start: Array[4096, uint64]
l2len:   Array[4096, uint64]
n2: uint64 = 0

# Join fields (1-based), separator. sep==0 means whitespace mode.
jf1: uint64 = 1
jf2: uint64 = 1
sep: uint8 = 0
ignore_case: int32 = 0

# -a: also print unpairable lines from the named file.
unpaired1: int32 = 0
unpaired2: int32 = 0

# -e: replacement string for empty output fields (stored as an address so
# it has an integer initializer; cast to Ptr[uint8] at use).
estr: uint64 = 0
estr_set: int32 = 0

# -o: output format specification.
ospec_file:  Array[64, uint8]     # 0 = join field (0.0), 1 = file1, 2 = file2
ospec_field: Array[64, uint64]
ospec_n: uint64 = 0
have_ospec: int32 = 0


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def parse_u64(s: Ptr[uint8]) -> int64:
    v: int64 = 0
    i: uint64 = 0
    if s[0] == 0:
        return -1
    while s[i] != 0:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            return -1
        v = v * 10 + cast[int64](c - 48)
        i = i + 1
    return v


def lower_u8(c: uint8) -> uint8:
    if c >= 65 and c <= 90:
        return c + 32
    return c


# A path of "-" reads standard input (fd 0) instead of opening a file.
def is_dash(path: Ptr[char]) -> int32:
    p: Ptr[uint8] = cast[Ptr[uint8]](path)
    if p[0] == 45 and p[1] == 0:
        return 1
    return 0


def load_file(b: Ptr[uint8], path: Ptr[char]) -> int64:
    stdin: int32 = is_dash(path)
    fd: int32 = 0
    if stdin == 0:
        fd = sys_open(path, 0, 0)
        if fd < 0:
            write_str(2, "join: cannot open ")
            write_str(2, cast[Ptr[uint8]](path))
            write_str(2, "\n")
            return -1
    total: uint64 = 0
    while total < FILE_CAP:
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
                                cast[uint64](b) + total),
                            FILE_CAP - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    if stdin == 0:
        sys_close(fd)
    return cast[int64](total)


# Build a line table for buffer b of `len` bytes.
def split_lines(b: Ptr[uint8], len: uint64,
                starts: Ptr[uint64], lens: Ptr[uint64]) -> uint64:
    cnt: uint64 = 0
    i: uint64 = 0
    while i < len and cnt < MAX_LINES:
        start: uint64 = i
        while i < len and b[i] != 10:
            i = i + 1
        starts[cnt] = start
        lens[cnt] = i - start
        cnt = cnt + 1
        if i < len:
            i = i + 1
    return cnt


def is_sep(c: uint8) -> int32:
    if sep == 0:
        if c == 32 or c == 9:
            return 1
        return 0
    if c == sep:
        return 1
    return 0


# Locate field number `fno` (1-based) within b[ls..le). On success writes
# the field's [start,end) into fs/fe and returns 0; returns -1 if the line
# has fewer than `fno` fields.
#
# Whitespace mode (sep==0) skips leading blanks and treats blank runs as
# one separator. Char mode treats each separator byte as a field break
# (so empty fields are possible), matching GNU.
def get_field(b: Ptr[uint8], ls: uint64, le: uint64, fno: uint64,
              fs: Ptr[uint64], fe: Ptr[uint64]) -> int32:
    i: uint64 = ls
    f: uint64 = 0
    while True:
        if sep == 0:
            while i < le and is_sep(b[i]) != 0:
                i = i + 1
            if i >= le:
                return -1
            f = f + 1
            start: uint64 = i
            while i < le and is_sep(b[i]) == 0:
                i = i + 1
            if f == fno:
                fs[0] = start
                fe[0] = i
                return 0
        else:
            f = f + 1
            start: uint64 = i
            while i < le and b[i] != sep:
                i = i + 1
            if f == fno:
                fs[0] = start
                fe[0] = i
                return 0
            if i >= le:
                return -1
            i = i + 1                  # skip the separator
            if i > le:
                return -1


# Compare byte ranges a[as_..ae) vs c[cs..ce), honouring -i (case-fold).
def range_cmp(a: Ptr[uint8], as_: uint64, ae: uint64,
              c: Ptr[uint8], cs: uint64, ce: uint64) -> int32:
    i: uint64 = as_
    k: uint64 = cs
    while i < ae and k < ce:
        av: uint8 = a[i]
        cv: uint8 = c[k]
        if ignore_case != 0:
            av = lower_u8(av)
            cv = lower_u8(cv)
        if av < cv:
            return -1
        if av > cv:
            return 1
        i = i + 1
        k = k + 1
    alen: uint64 = ae - as_
    clen: uint64 = ce - cs
    if alen < clen:
        return -1
    if alen > clen:
        return 1
    return 0


# Compute the join-field range of a line. `which` = 1 for file1, 2 for
# file2. A line with too few fields yields an empty range (GNU treats the
# missing join field as the empty string).
def key_range(which: int32, line: uint64,
              fs: Ptr[uint64], fe: Ptr[uint64]):
    if which == 1:
        if get_field(&buf1[0], l1start[line], l1start[line] + l1len[line],
                     jf1, fs, fe) != 0:
            fs[0] = l1start[line]
            fe[0] = l1start[line]
    else:
        if get_field(&buf2[0], l2start[line], l2start[line] + l2len[line],
                     jf2, fs, fe) != 0:
            fs[0] = l2start[line]
            fe[0] = l2start[line]


def write_range(b: Ptr[uint8], s: uint64, e: uint64):
    if e > s:
        sys_write(1, cast[Ptr[uint8]](cast[uint64](b) + s), e - s)


def emit_osep():
    o: Array[1, uint8]
    if sep == 0:
        o[0] = 32
    else:
        o[0] = sep
    sys_write(1, &o[0], 1)


# Emit every field of b[ls..le) EXCEPT field `skip`, each preceded by an
# output separator. Output separator is sep (when set) else a space.
def emit_rest(b: Ptr[uint8], ls: uint64, le: uint64, skip: uint64):
    i: uint64 = ls
    f: uint64 = 0
    while i < le:
        start: uint64 = 0
        end: uint64 = 0
        if sep == 0:
            while i < le and is_sep(b[i]) != 0:
                i = i + 1
            if i >= le:
                break
            start = i
            while i < le and is_sep(b[i]) == 0:
                i = i + 1
            end = i
        else:
            start = i
            while i < le and b[i] != sep:
                i = i + 1
            end = i
            if i < le:
                i = i + 1              # consume separator for next iter
        f = f + 1
        if f == skip:
            continue
        emit_osep()
        write_range(b, start, end)


# Emit one output field for an -o spec referencing file `file` (1 or 2).
def emit_ospec_field(file: uint8, have1: int32, a: uint64,
                     have2: int32, c: uint64, fld: uint64):
    valid: int32 = 0
    b: Ptr[uint8] = &buf1[0]
    fs: uint64 = 0
    fe: uint64 = 0
    if file == 1 and have1 != 0:
        if get_field(&buf1[0], l1start[a], l1start[a] + l1len[a],
                     fld, &fs, &fe) == 0:
            valid = 1
            b = &buf1[0]
    elif file == 2 and have2 != 0:
        if get_field(&buf2[0], l2start[c], l2start[c] + l2len[c],
                     fld, &fs, &fe) == 0:
            valid = 1
            b = &buf2[0]
    if valid != 0 and fe > fs:
        write_range(b, fs, fe)
    else:
        if estr_set != 0:
            write_str(1, cast[Ptr[uint8]](estr))


# Emit one output line. have1/have2 flag which side is present; a/c are the
# respective line indices when present.
def emit_line(have1: int32, a: uint64, have2: int32, c: uint64):
    ks: uint64 = 0
    ke: uint64 = 0
    kb: Ptr[uint8] = &buf1[0]
    if have1 != 0:
        key_range(1, a, &ks, &ke)
        kb = &buf1[0]
    else:
        key_range(2, c, &ks, &ke)
        kb = &buf2[0]

    if have_ospec != 0:
        s: uint64 = 0
        while s < ospec_n:
            if s > 0:
                emit_osep()
            if ospec_file[s] == 0:
                write_range(kb, ks, ke)          # 0.0 join field
            else:
                emit_ospec_field(ospec_file[s], have1, a, have2, c,
                                 ospec_field[s])
            s = s + 1
        sys_write(1, "\n", 1)
        return

    # default "auto" format: join field, then rest of file1, then file2.
    write_range(kb, ks, ke)
    if have1 != 0:
        emit_rest(&buf1[0], l1start[a], l1start[a] + l1len[a], jf1)
    if have2 != 0:
        emit_rest(&buf2[0], l2start[c], l2start[c] + l2len[c], jf2)
    sys_write(1, "\n", 1)


# Parse an -o argument: comma/blank separated FILENUM.FIELD specs, plus the
# special 0.0 for the join field. Accumulates across multiple -o options.
def parse_ospec(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        while s[i] == 44 or s[i] == 32 or s[i] == 9:      # , space tab
            i = i + 1
        if s[i] == 0:
            break
        fc: uint8 = s[i]
        if fc != 48 and fc != 49 and fc != 50:
            i = i + 1                                     # skip junk char
            continue
        filev: uint8 = fc - 48
        i = i + 1
        if s[i] == 46:                                    # '.'
            i = i + 1
        fld: uint64 = 0
        while s[i] >= 48 and s[i] <= 57:
            fld = fld * 10 + cast[uint64](s[i] - 48)
            i = i + 1
        if ospec_n < MAX_OSPEC:
            ospec_file[ospec_n] = filev
            ospec_field[ospec_n] = fld
            ospec_n = ospec_n + 1
    have_ospec = 1


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    f1: int32 = 0
    f2: int32 = 0
    ai: int32 = 1
    while ai < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
        if a[0] == 45 and a[1] != 0:
            letter: uint8 = a[1]
            if letter == 105:                             # -i (no argument)
                ignore_case = 1
            else:
                # Fetch the option argument: attached (-tX) or the next argv.
                oa: Ptr[uint8] = cast[Ptr[uint8]](0)
                if a[2] != 0:
                    oa = cast[Ptr[uint8]](cast[uint64](a) + 2)
                else:
                    if ai + 1 >= argc:
                        write_str(2, "join: option needs an argument\n")
                        return 1
                    ai = ai + 1
                    oa = cast[Ptr[uint8]](argv[cast[uint64](ai)])
                if letter == 49:                          # -1 N
                    v: int64 = parse_u64(oa)
                    if v < 1:
                        write_str(2, "join: bad -1 field\n")
                        return 1
                    jf1 = cast[uint64](v)
                elif letter == 50:                        # -2 N
                    v: int64 = parse_u64(oa)
                    if v < 1:
                        write_str(2, "join: bad -2 field\n")
                        return 1
                    jf2 = cast[uint64](v)
                elif letter == 106:                       # -j N (both)
                    v: int64 = parse_u64(oa)
                    if v < 1:
                        write_str(2, "join: bad -j field\n")
                        return 1
                    jf1 = cast[uint64](v)
                    jf2 = cast[uint64](v)
                elif letter == 116:                       # -t CHAR
                    sep = oa[0]
                elif letter == 97:                        # -a NUM
                    v: int64 = parse_u64(oa)
                    if v == 1:
                        unpaired1 = 1
                    elif v == 2:
                        unpaired2 = 1
                    else:
                        write_str(2, "join: -a expects 1 or 2\n")
                        return 1
                elif letter == 101:                       # -e STR
                    estr = cast[uint64](oa)
                    estr_set = 1
                elif letter == 111:                       # -o FORMAT
                    parse_ospec(oa)
                else:
                    write_str(2, "join: unknown flag\n")
                    return 1
        else:
            if f1 == 0:
                f1 = ai
            elif f2 == 0:
                f2 = ai
        ai = ai + 1

    if f1 == 0 or f2 == 0:
        write_str(2, "join: usage: join [OPTION]... FILE1 FILE2\n")
        return 1

    r1: int64 = load_file(&buf1[0], cast[Ptr[char]](argv[cast[uint64](f1)]))
    r2: int64 = load_file(&buf2[0], cast[Ptr[char]](argv[cast[uint64](f2)]))
    if r1 < 0 or r2 < 0:
        return 1
    n1 = split_lines(&buf1[0], cast[uint64](r1), &l1start[0], &l1len[0])
    n2 = split_lines(&buf2[0], cast[uint64](r2), &l2start[0], &l2len[0])

    i: uint64 = 0
    j: uint64 = 0
    while i < n1 or j < n2:
        if i >= n1:
            if unpaired2 != 0:
                emit_line(0, 0, 1, j)
            j = j + 1
            continue
        if j >= n2:
            if unpaired1 != 0:
                emit_line(1, i, 0, 0)
            i = i + 1
            continue

        ks1: uint64 = 0
        ke1: uint64 = 0
        ks2: uint64 = 0
        ke2: uint64 = 0
        key_range(1, i, &ks1, &ke1)
        key_range(2, j, &ks2, &ke2)
        cmp: int32 = range_cmp(&buf1[0], ks1, ke1, &buf2[0], ks2, ke2)
        if cmp < 0:
            if unpaired1 != 0:
                emit_line(1, i, 0, 0)
            i = i + 1
        elif cmp > 0:
            if unpaired2 != 0:
                emit_line(0, 0, 1, j)
            j = j + 1
        else:
            # Keys equal: emit the cartesian product of the equal-key runs.
            jend: uint64 = j
            while jend < n2:
                ts: uint64 = 0
                te: uint64 = 0
                key_range(2, jend, &ts, &te)
                if range_cmp(&buf1[0], ks1, ke1, &buf2[0], ts, te) != 0:
                    break
                jend = jend + 1
            iend: uint64 = i
            while iend < n1:
                us: uint64 = 0
                ue: uint64 = 0
                key_range(1, iend, &us, &ue)
                if range_cmp(&buf1[0], ks1, ke1, &buf1[0], us, ue) != 0:
                    break
                jj: uint64 = j
                while jj < jend:
                    emit_line(1, iend, 1, jj)
                    jj = jj + 1
                iend = iend + 1
            i = iend
            j = jend
    return 0

# user/ifconfig.ad
#
# Stub `ifconfig` — Hamnix has no real NIC driver yet (no e1000,
# no virtio-net, no socket layer), so the only "interface" we can
# truthfully claim is the loopback address that any TCP/IP stack
# synthesises in software. Print one line so scripts that probe
# for `lo` find it; everything else is intentionally absent.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main() -> int32:
    write_str(1, "lo  inet 127.0.0.1/8\n")
    return 0

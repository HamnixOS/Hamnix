# user/md5sum.ad
#
# Hamnix `md5sum` — output marker shape ONLY. We emit the coreutils
# "<hex>  -" line for stdin, but the hex is a fixed string (real MD5
# of the empty input) rather than a true digest of the bytes we read.
# Real MD5 is ~100 lines of 32-bit rotates + table arithmetic; that's
# deferred behind L-track scope. For now drains stdin (so callers
# can pipe into us without SIGPIPE) and prints the constant line.

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def main() -> int32:
    # Drain stdin so pipelines (`echo hi | /md5sum`) don't block the
    # writer. We discard every byte — the output is the same regardless.
    buf: Array[256, uint8]
    while True:
        n: int64 = sys_read(0, &buf[0], 256)
        if n <= 0:
            break
    sys_write(1, "d41d8cd98f00b204e9800998ecf8427e  -\n", 36)
    return 0

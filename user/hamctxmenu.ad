# user/hamctxmenu.ad
#
# hamctxmenu — DE pivot wave 3: right-click context menu extracted from
# daemon_pixel into a v2 client.

from lib.hamui import (
    hamui_init, hamui_window_on, hamui_set_protocol_v2, hamui_set_protocol_v2_dims,
    hamui_v2_clear, hamui_v2_clear_transparent, hamui_v2_fill_rect, hamui_v2_commit_rect,
    hamui_v2_is_active, hamui_v2_bb_ptr, hamui_v2_bb_w, hamui_v2_bb_h,
)
# Task #134: draw legible per-row labels using the SAME 8x16 console font the
# panel/compositor draws (lib/hamui_host_font.ad is extern-free, links native),
# blitting straight into the v2 backbuffer.
from lib.hamui_host_font import hamui_host_font_init, hamui_host_font_row

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield()
extern def sys_exit(code: int32)


_hc_open:  int32 = 0
_hc_count: int32 = 0
_hc_hover: int32 = -1
_hc_x:     int32 = 0
_hc_y:     int32 = 0
_hc_w:     int32 = 0
_hc_gen:   uint64 = 0
_hc_show_serial:      uint64 = 0
_hc_last_show_serial: uint64 = 0xffffffffffffffff
_hc_last_gen:         uint64 = 0xffffffffffffffff


_hc_WIN_W: int32 = 800
_hc_WIN_H: int32 = 600
# Item height MUST match the compositor's hit-test grid (hamUId CTX_ITEM_H=20 /
# ctxmenucore CTXM_ITEM_H=20) so the hovered row and the highlighted row line
# up and every label sits in its own box.
_hc_ITEM_H: int32 = 20
_hc_PAD_L:  int32 = 8            # left text inset (mirrors hamUId CTX_PAD_L)
_hc_GLYPH_W: int32 = 8          # 8x16 mono cell advance


_hc_snap_buf: Array[1024, uint8]
# Task #134: per-row label spans within _hc_snap_buf, filled by _parse_snapshot.
_HC_MAX_ROWS: int32 = 32
_hc_lbl_off: Array[32, uint32]
_hc_lbl_len: Array[32, uint32]
_hc_lbl_count: int32 = 0


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


def _read_snap() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctxmenu"))
    if fd < 0:
        return -1
    n: int64 = sys_read(fd, &_hc_snap_buf[0], 1024)
    sys_close(fd)
    return n


def _parse_u64(pos: Ptr[uint64], end: uint64) -> uint64:
    p: uint64 = pos[0]
    v: uint64 = 0
    while p < end and _hc_snap_buf[p] >= 48 and _hc_snap_buf[p] <= 57:
        v = v * 10 + cast[uint64](_hc_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    return v


def _parse_i64(pos: Ptr[uint64], end: uint64) -> int64:
    p: uint64 = pos[0]
    neg: int32 = 0
    if p < end and _hc_snap_buf[p] == 45:
        neg = 1
        p = p + 1
    v: int64 = 0
    while p < end and _hc_snap_buf[p] >= 48 and _hc_snap_buf[p] <= 57:
        v = v * 10 + cast[int64](_hc_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    if neg != 0:
        return -v
    return v


def _skip_ws(pos: uint64, end: uint64) -> uint64:
    p: uint64 = pos
    while p < end and (_hc_snap_buf[p] == 32 or _hc_snap_buf[p] == 9):
        p = p + 1
    return p


def _parse_snapshot(n: uint64) -> int32:
    if n == 0:
        return 0
    pos: Array[1, uint64]
    pos[0] = 0
    show_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    open_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    count_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    hover_v: int64 = _parse_i64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    x_v: int64 = _parse_i64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    y_v: int64 = _parse_i64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    w_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    gen_v: uint64 = _parse_u64(&pos[0], n)
    # Task #134: after the numeric header's newline comes the TAB-separated
    # per-row label blob (a leading TAB, then <l0>\t<l1>...). Record each
    # label's [offset,len) span within _hc_snap_buf so _paint can draw it.
    lp: uint64 = pos[0]
    while lp < n and _hc_snap_buf[lp] != 10:
        lp = lp + 1
    if lp < n:
        lp = lp + 1                          # skip the newline
    _hc_lbl_count = 0
    while lp < n and _hc_lbl_count < _HC_MAX_ROWS:
        if _hc_snap_buf[lp] != 9:            # expect a TAB before each label
            lp = lp + 1
        else:
            lp = lp + 1                      # skip the TAB
            ls: uint64 = lp
            while lp < n and _hc_snap_buf[lp] != 9:
                lp = lp + 1
            _hc_lbl_off[cast[uint64](_hc_lbl_count)] = cast[uint32](ls)
            _hc_lbl_len[cast[uint64](_hc_lbl_count)] = cast[uint32](lp - ls)
            _hc_lbl_count = _hc_lbl_count + 1
    _hc_show_serial = show_v
    _hc_open = cast[int32](open_v)
    _hc_count = cast[int32](count_v)
    _hc_hover = cast[int32](hover_v)
    _hc_x = cast[int32](x_v)
    _hc_y = cast[int32](y_v)
    _hc_w = cast[int32](w_v)
    _hc_gen = gen_v
    changed: int32 = 0
    if _hc_show_serial != _hc_last_show_serial:
        changed = 1
    if _hc_gen != _hc_last_gen:
        changed = 1
    _hc_last_show_serial = _hc_show_serial
    _hc_last_gen = _hc_gen
    return changed


# Task #134: blit one 8x16 console glyph opaquely into the v2 backbuffer at
# top-left (gx,gy), clipped to the backbuffer. Same font the panel draws.
def _hc_glyph(gx: int32, gy: int32, ch: uint8,
              r: uint8, g: uint8, b: uint8):
    if ch < 32 or ch > 126:
        return
    bbw: int32 = hamui_v2_bb_w()
    bbh: int32 = hamui_v2_bb_h()
    if bbw <= 0 or bbh <= 0:
        return
    bb: Ptr[uint8] = hamui_v2_bb_ptr()
    stride: uint64 = cast[uint64](bbw) * 4
    row: int32 = 0
    while row < 16:
        bits: uint8 = hamui_host_font_row(ch, cast[uint64](row))
        col: int32 = 0
        while col < 8:
            mask: uint8 = cast[uint8](128 >> col)
            if (bits & mask) != 0:
                px: int32 = gx + col
                py: int32 = gy + row
                if px >= 0 and py >= 0 and px < bbw and py < bbh:
                    off: uint64 = cast[uint64](py) * stride + cast[uint64](px) * 4
                    bb[off]     = r
                    bb[off + 1] = g
                    bb[off + 2] = b
                    bb[off + 3] = 255
            col = col + 1
        row = row + 1


# Draw label row `idx` (span in _hc_snap_buf) starting at (tx,ty).
def _hc_draw_label(idx: int32, tx: int32, ty: int32,
                   r: uint8, g: uint8, b: uint8):
    if idx < 0 or idx >= _hc_lbl_count:
        return
    off: uint64 = cast[uint64](_hc_lbl_off[cast[uint64](idx)])
    ln:  uint64 = cast[uint64](_hc_lbl_len[cast[uint64](idx)])
    cx: int32 = tx
    i: uint64 = 0
    while i < ln:
        _hc_glyph(cx, ty, _hc_snap_buf[off + i], r, g, b)
        cx = cx + _hc_GLYPH_W
        i = i + 1


def _paint():
    hamui_v2_clear_transparent()
    if _hc_open == 0 or _hc_count <= 0 or _hc_w <= 0:
        hamui_v2_commit_rect(0, 0, _hc_WIN_W, _hc_WIN_H)
        return
    mx: int32 = _hc_x
    my: int32 = _hc_y
    mw: int32 = _hc_w
    mh: int32 = _hc_count * _hc_ITEM_H
    if mx < 0:
        mx = 0
    if my < 0:
        my = 0
    if mx + mw > _hc_WIN_W:
        mw = _hc_WIN_W - mx
    if my + mh > _hc_WIN_H:
        mh = _hc_WIN_H - my
    # Body.
    hamui_v2_fill_rect(mx, my, mw, mh, 40, 46, 60)
    # Frame.
    hamui_v2_fill_rect(mx, my, mw, 1, 24, 28, 36)
    hamui_v2_fill_rect(mx, my + mh - 1, mw, 1, 24, 28, 36)
    hamui_v2_fill_rect(mx, my, 1, mh, 24, 28, 36)
    hamui_v2_fill_rect(mx + mw - 1, my, 1, mh, 24, 28, 36)
    # Item rows with hover highlight + real label text (Task #134).
    i: int32 = 0
    while i < _hc_count:
        iy: int32 = my + i * _hc_ITEM_H
        # Default light label on the dark menu body; white on the hover bar.
        lr: uint8 = 226
        lg: uint8 = 230
        lb: uint8 = 238
        if i == _hc_hover:
            hamui_v2_fill_rect(mx + 1, iy, mw - 2, _hc_ITEM_H, 86, 110, 150)
            lr = 255
            lg = 255
            lb = 255
        # Label text: 8x16 glyphs, left-inset, vertically centred in the row.
        _hc_draw_label(i, mx + _hc_PAD_L, iy + (_hc_ITEM_H - 16) / 2,
                       lr, lg, lb)
        i = i + 1
    hamui_v2_commit_rect(0, 0, _hc_WIN_W, _hc_WIN_H)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()
    hamui_host_font_init()          # decode the 8x16 label font once (Task #134)
    wid: int32 = 1
    sfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/self"))
    if sfd >= 0:
        sbuf: Array[16, uint8]
        sn: int64 = sys_read_nb(sfd, &sbuf[0], 16)
        sys_close(sfd)
        if sn > 0:
            v: int32 = 0
            i: uint64 = 0
            while i < cast[uint64](sn) and sbuf[i] >= 48 and sbuf[i] <= 57:
                v = v * 10 + cast[int32](sbuf[i]) - 48
                i = i + 1
            if v >= 2:
                wid = v
    if argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        v2: int32 = 0
        i2: uint64 = 0
        while ap[i2] >= 48 and ap[i2] <= 57:
            v2 = v2 * 10 + cast[int32](ap[i2]) - 48
            i2 = i2 + 1
        if v2 >= 1:
            wid = v2

    bound: int32 = hamui_window_on(0, wid)
    if bound < 0:
        _puts(2, "hamctxmenu: could not bind window\n")
        return 1
    if hamui_set_protocol_v2_dims(_hc_WIN_W, _hc_WIN_H) < 0:
        _puts(2, "hamctxmenu: v2 negotiate failed\n")
        return 1

    n0: int64 = _read_snap()
    if n0 > 0:
        _parse_snapshot(cast[uint64](n0))
    _paint()
    rdy: Ptr[uint8] = "HAMCTXMENU ready\n"
    sys_write(1, rdy, _strlen(rdy))

    while True:
        n: int64 = _read_snap()
        if n > 0:
            if _parse_snapshot(cast[uint64](n)) != 0:
                _paint()
        sys_yield()

    return 0

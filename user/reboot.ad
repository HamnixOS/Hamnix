# user/reboot.ad — request system reboot.
#
# Same scope as /bin/halt for now: print + exit. The hardware-
# reboot path (i8042 0xFE pulse, or ACPI reset register) is
# kernel-side work that lands once syscall.ad is unconflicted.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    sys_write(1, "reboot: requested reboot\n", 25)
    sys_exit(0)
    return 0

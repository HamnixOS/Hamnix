# user/reboot.ad — reboot the machine.
#
# Plan-9-shape: open /dev/reboot and write the verb "reboot". The
# kernel cdev funnels into arch/x86/kernel/power.ad's power_action():
# flush filesystems, then reset via the i8042 keyboard controller
# (0x64 <- 0xFE), falling back to a triple fault. Under QEMU with
# -no-reboot the reset makes the VM exit; on real hardware it reboots.
# The write never returns on success.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    sys_write(1, "reboot: requested reboot\n", 25)
    fd: int32 = sys_open("/dev/reboot")
    if fd < 0:
        sys_write(2, "reboot: cannot open /dev/reboot\n", 32)
        sys_exit(1)
        return 1
    sys_write(fd, "reboot\n", 7)
    sys_close(fd)
    sys_write(2, "reboot: reboot did not take\n", 28)
    sys_exit(1)
    return 1

# user/stat.ad
#
# Hamnix `stat`: display file/inode status, mirroring the most-used
# fields of coreutils `stat`. Hamnix's native userland has no full
# POSIX stat(2), so this tool reconstructs the status from the same
# metadata primitives the other tools use:
#
#   * file TYPE — sys_listdir(path) succeeds only on a directory (it
#     packs the dir's children as "NAME\n"); on a regular file it
#     returns -ENOTDIR. So a non-negative listdir => "directory",
#     otherwise we probe sys_open(path): opens => "regular file",
#     fails => the path doesn't exist (stat error, exit 1).
#   * SIZE — open + lseek(SEEK_END) returns the byte length, the same
#     mechanism glibc's fstat-via-lseek and `wc -c` rely on. (A
#     directory reports the byte length of its packed listing, which
#     is the best available analogue of a dir's size here.)
#
# Output formats:
#   default (no -c): a GNU-shaped multi-line block —
#       File: NAME
#       Size: NNN            <type>
#   -c FORMAT: a single line with the GNU directives
#       %n  file name (as given)
#       %s  total size, in bytes
#       %F  file type ("regular file" / "directory")
#   Unknown directives in -c are emitted verbatim after '%'. A literal
#   '%%' is a single '%'.
#
# Limitations vs GNU: no mtime/atime/ctime (Hamnix has no per-file
# timestamps yet — every other native tool is timestamp-free for the
# same reason), no device/inode/permission/uid fields. The implemented
# subset (name, size, type) is what's reconstructable from the present
# kernel primitives.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_lseek(fd: int32, offset: int64, whence: int32) -> int64
extern def sys_listdir(path: Ptr[char], buf: Ptr[uint8],
                       count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


SEEK_END: int32 = 2
LISTBUF:  uint64 = 1024

list_scratch: Array[1024, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def write_dec(fd: int32, v: uint64):
    if v == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    i: uint64 = 0
    while v != 0:
        digits[i] = cast[uint8](v % 10) + 48
        v = v / 10
        i = i + 1
    out: Array[24, uint8]
    j: uint64 = 0
    while j < i:
        out[j] = digits[i - 1 - j]
        j = j + 1
    sys_write(fd, &out[0], i)


# kind: 0 = regular file, 1 = directory, -1 = does not exist.
def probe_kind(path: Ptr[char]) -> int32:
    ln: int64 = sys_listdir(path, &list_scratch[0], LISTBUF)
    if ln >= 0:
        return 1
    fd: int32 = sys_open(path)
    if fd >= 0:
        sys_close(fd)
        return 0
    return -1


# Byte size: for a regular file, open + lseek(SEEK_END); for a
# directory, the byte length of its packed listing. Returns 0 if it
# can't be determined.
def probe_size(path: Ptr[char], kind: int32) -> uint64:
    if kind == 1:
        ln: int64 = sys_listdir(path, &list_scratch[0], LISTBUF)
        if ln > 0:
            return cast[uint64](ln)
        return 0
    fd: int32 = sys_open(path)
    if fd < 0:
        return 0
    sz: int64 = sys_lseek(fd, 0, SEEK_END)
    sys_close(fd)
    if sz < 0:
        return 0
    return cast[uint64](sz)


def type_str(kind: int32) -> Ptr[uint8]:
    if kind == 1:
        return "directory"
    return "regular file"


def emit_default(path: Ptr[uint8], kind: int32, size: uint64):
    write_str(1, "  File: ")
    write_str(1, path)
    sys_write(1, "\n", 1)
    write_str(1, "  Size: ")
    write_dec(1, size)
    write_str(1, "            ")
    write_str(1, type_str(kind))
    sys_write(1, "\n", 1)


def emit_format(fmt: Ptr[uint8], path: Ptr[uint8], kind: int32,
                size: uint64):
    i: uint64 = 0
    while fmt[i] != 0:
        c: uint8 = fmt[i]
        if c == 37:                                 # '%'
            d: uint8 = fmt[i + 1]
            if d == 110:                            # 'n'
                write_str(1, path)
                i = i + 2
                continue
            elif d == 115:                          # 's'
                write_dec(1, size)
                i = i + 2
                continue
            elif d == 70:                           # 'F'
                write_str(1, type_str(kind))
                i = i + 2
                continue
            elif d == 37:                           # '%%' -> '%'
                sys_write(1, "%", 1)
                i = i + 2
                continue
            else:
                # Unknown directive: emit '%' then carry on.
                sys_write(1, "%", 1)
                i = i + 1
                continue
        sys_write(1, &fmt[i], 1)
        i = i + 1
    sys_write(1, "\n", 1)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "stat: missing operand\n")
        return 1

    fmt: Ptr[uint8] = cast[Ptr[uint8]](0)
    first_file: int32 = 1
    flag: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    if flag[0] == 45 and flag[1] == 99 and flag[2] == 0:        # "-c"
        if argc < 4:
            write_str(2, "stat: -c FORMAT requires a file\n")
            return 1
        fmt = cast[Ptr[uint8]](argv[2])
        first_file = 3
    elif flag[0] == 45 and flag[1] == 99:                       # "-cFORMAT"
        fmt = cast[Ptr[uint8]](cast[uint64](flag) + 2)
        first_file = 2

    rc: int32 = 0
    i: int32 = first_file
    while i < argc:
        path: Ptr[char] = cast[Ptr[char]](argv[cast[uint64](i)])
        kind: int32 = probe_kind(path)
        if kind < 0:
            write_str(2, "stat: cannot stat ")
            write_str(2, cast[Ptr[uint8]](path))
            write_str(2, ": No such file or directory\n")
            rc = 1
            i = i + 1
            continue
        size: uint64 = probe_size(path, kind)
        if cast[uint64](fmt) != 0:
            emit_format(fmt, cast[Ptr[uint8]](path), kind, size)
        else:
            emit_default(cast[Ptr[uint8]](path), kind, size)
        i = i + 1
    return rc

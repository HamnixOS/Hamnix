# user/mktemp.ad
#
# Hamnix `mktemp`: create a uniquely-named temporary file (or, with
# -d, a directory), print its path to stdout, and exit 0. Mirrors the
# common coreutils `mktemp` contract:
#
#   mktemp                 -> create /tmp/tmp.XXXXXX  (file)
#   mktemp -d              -> create /tmp/tmp.XXXXXX  (directory)
#   mktemp TEMPLATE        -> TEMPLATE's trailing run of 'X's is
#                             replaced by a unique suffix; the file is
#                             created at that path.
#   mktemp -d TEMPLATE     -> same, but a directory.
#
# A TEMPLATE with no path separator is taken relative to /tmp (GNU
# only does this with --tmpdir, but on Hamnix a bare template is
# overwhelmingly meant for /tmp, so we anchor it there for ergonomics);
# a TEMPLATE containing '/' is used verbatim. A TEMPLATE with no
# trailing 'X' run is an error, matching GNU.
#
# UNIQUENESS. The suffix is derived from the caller's pid combined
# with the kernel jiffies counter and a per-call retry counter, then
# base-36-encoded into the 'X' field. We actually CREATE the entry
# (open-create for a file, sys_mkdir for a directory) and, on a
# collision, perturb the seed and retry — so concurrent or repeated
# invocations never hand back the same path. (Hamnix has no
# O_EXCL/O_CREAT split yet; sys_open_write creates-or-truncates, so we
# pre-check existence with sys_open to avoid clobbering an existing
# file. mkdir already fails with -EEXIST, giving real exclusivity for
# the -d path.)

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_mkdir(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_getpid() -> int32
extern def sys_get_jiffies() -> uint64


PATH_CAP: uint64 = 256

# Working path buffer (NUL-terminated). Module-scope keeps the frame
# small per the U9 compiler-quirk guidance.
path_buf: Array[256, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


# base-36 digit ('0'..'9','a'..'z') for 0..35.
def b36(v: uint64) -> uint8:
    if v < 10:
        return cast[uint8](v) + 48
    return cast[uint8](v - 10) + 97


# Copy template into path_buf. If the template has no '/', anchor it
# under /tmp/. Returns the path length (excluding NUL), or 0 on
# overflow.
def stage_template(tmpl: Ptr[uint8]) -> uint64:
    has_slash: int32 = 0
    i: uint64 = 0
    while tmpl[i] != 0:
        if tmpl[i] == 47:
            has_slash = 1
        i = i + 1
    out: uint64 = 0
    if has_slash == 0:
        prefix: Ptr[uint8] = "/tmp/"
        k: uint64 = 0
        while prefix[k] != 0:
            if out + 1 >= PATH_CAP:
                return 0
            path_buf[out] = prefix[k]
            out = out + 1
            k = k + 1
    j: uint64 = 0
    while tmpl[j] != 0:
        if out + 1 >= PATH_CAP:
            return 0
        path_buf[out] = tmpl[j]
        out = out + 1
        j = j + 1
    path_buf[out] = 0
    return out


# Find the trailing run of 'X' in path_buf[0..len). Sets *xs / *xe to
# the [start, end) byte indices of the run. Returns the run length (0
# if there's no trailing 'X').
def find_x_run(len: uint64, xs: Ptr[uint64], xe: Ptr[uint64]) -> uint64:
    if len == 0:
        return 0
    end: uint64 = len                                # one past last char
    if path_buf[end - 1] != 88:                      # 'X'
        return 0
    start: uint64 = end
    while start > 0 and path_buf[start - 1] == 88:
        start = start - 1
    xs[0] = start
    xe[0] = end
    return end - start


# Fill path_buf[start..end) with a base-36 rendering of `seed`.
def fill_suffix(start: uint64, end: uint64, seed: uint64):
    s: uint64 = seed
    i: uint64 = end
    while i > start:
        i = i - 1
        path_buf[i] = b36(s % 36)
        s = s / 36


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    make_dir: int32 = 0
    tmpl: Ptr[uint8] = cast[Ptr[uint8]](0)

    i: int32 = 1
    while i < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](i)])
        if a[0] == 45 and a[1] == 100 and a[2] == 0:            # "-d"
            make_dir = 1
        else:
            tmpl = a
        i = i + 1

    len: uint64 = 0
    if cast[uint64](tmpl) == 0:
        len = stage_template(cast[Ptr[uint8]]("tmp.XXXXXX"))
    else:
        len = stage_template(tmpl)
    if len == 0:
        write_str(2, "mktemp: path too long\n")
        return 1

    xs: uint64 = 0
    xe: uint64 = 0
    xrun: uint64 = find_x_run(len, &xs, &xe)
    if xrun == 0:
        write_str(2, "mktemp: template must end with XXXXXX\n")
        return 1

    pid: int32 = sys_getpid()
    base: uint64 = (cast[uint64](pid) << 20) ^ sys_get_jiffies()

    attempt: uint64 = 0
    while attempt < 4096:
        seed: uint64 = base + attempt * 2654435761
        fill_suffix(xs, xe, seed)
        if make_dir != 0:
            rc: int32 = sys_mkdir(cast[Ptr[char]](&path_buf[0]))
            if rc == 0:
                write_str(1, &path_buf[0])
                sys_write(1, "\n", 1)
                return 0
            # -EEXIST or transient failure: perturb and retry.
        else:
            # Pre-check existence so we don't clobber an unrelated file
            # (sys_open_write creates-or-truncates with no O_EXCL).
            probe: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
            if probe >= 0:
                sys_close(probe)                     # taken — retry
            else:
                fd: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
                if fd >= 0:
                    sys_close(fd)
                    write_str(1, &path_buf[0])
                    sys_write(1, "\n", 1)
                    return 0
                # open-create failed for a reason other than existence.
                write_str(2, "mktemp: failed to create temp file\n")
                return 1
        attempt = attempt + 1

    write_str(2, "mktemp: could not create a unique name\n")
    return 1

# user/cut.ad
#
# Hamnix `cut`: a native Plan-9-shape stdin filter matching GNU `cut` for
# the everyday option set.
#
#   -f LIST            select fields (delimiter-separated); default TAB
#   -d DELIM           field delimiter (single byte) for -f
#   -s                 suppress lines with no delimiter (-f only)
#   -c LIST            select character positions (bytes, under C locale)
#   -b LIST            select byte positions
#   --output-delimiter=STR   string to place between selected fields/ranges
#
# LIST syntax: comma-separated N | N-M | N- (open end) | -M (open start),
# 1-based. Ranges are sorted and merged (adjacent ranges coalesce) exactly
# like GNU, so output positions are always ascending and de-duplicated.
#
# This reads whole lines into a fixed buffer; lines longer than LINE_CAP
# are clipped at the boundary (plenty for initramfs-scale text).

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


LINE_CAP: uint64 = 8192
HI_INF:   uint64 = 0xFFFFFFFFFFFFFFFF

line: Array[8192, uint8]

# raw + merged range tables
rlo: Array[64, uint64]
rhi: Array[64, uint64]
mlo: Array[64, uint64]
mhi: Array[64, uint64]
n_raw:    uint64 = 0
n_merged: uint64 = 0

# output-delimiter buffer
odelim: Array[64, uint8]
odelim_len: uint64 = 0
odelim_given: int32 = 0

# option state
opt_mode: int32 = 0          # 1 = -f fields, 2 = -c chars, 3 = -b bytes
opt_delim: uint8 = 9         # TAB
opt_s: int32 = 0


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def str_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] == b[i]:
        return 1
    return 0


def str_starts(a: Ptr[uint8], pfx: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while pfx[i] != 0:
        if a[i] != pfx[i]:
            return 0
        i = i + 1
    return 1


# ---- LIST parsing ------------------------------------------------------
def parse_list(s: Ptr[uint8]) -> int32:
    # Fills rlo/rhi (n_raw), returns 0 ok, -1 on a malformed spec.
    i: uint64 = 0
    n_raw = 0
    while s[i] != 0:
        c: uint8 = s[i]
        if c == 44:                       # ','
            i = i + 1
            continue
        lo: uint64 = 0
        hi: uint64 = 0
        if c == 45:                       # leading '-' => open start "-M"
            lo = 1
            i = i + 1
            if s[i] < 48 or s[i] > 57:
                return -1
            hi = 0
            while s[i] >= 48 and s[i] <= 57:
                hi = hi * 10 + cast[uint64](s[i] - 48)
                i = i + 1
        else:
            if c < 48 or c > 57:
                return -1
            while s[i] >= 48 and s[i] <= 57:
                lo = lo * 10 + cast[uint64](s[i] - 48)
                i = i + 1
            if s[i] == 45:                # 'N-...' range
                i = i + 1
                if s[i] == 0 or s[i] == 44:
                    hi = HI_INF           # open end "N-"
                else:
                    if s[i] < 48 or s[i] > 57:
                        return -1
                    hi = 0
                    while s[i] >= 48 and s[i] <= 57:
                        hi = hi * 10 + cast[uint64](s[i] - 48)
                        i = i + 1
            else:
                hi = lo                   # single "N"
        if lo < 1:
            return -1
        if hi < lo:
            return -1
        if n_raw >= 64:
            return -1
        rlo[n_raw] = lo
        rhi[n_raw] = hi
        n_raw = n_raw + 1
    if n_raw == 0:
        return -1
    return 0


def merge_ranges():
    # Insertion-sort raw ranges by lo, then coalesce overlapping/adjacent.
    i: uint64 = 1
    while i < n_raw:
        klo: uint64 = rlo[i]
        khi: uint64 = rhi[i]
        j: uint64 = i
        while j > 0 and rlo[j - 1] > klo:
            rlo[j] = rlo[j - 1]
            rhi[j] = rhi[j - 1]
            j = j - 1
        rlo[j] = klo
        rhi[j] = khi
        i = i + 1
    n_merged = 0
    i = 0
    while i < n_raw:
        if n_merged == 0:
            mlo[0] = rlo[i]
            mhi[0] = rhi[i]
            n_merged = 1
        else:
            top: uint64 = n_merged - 1
            # Coalesce only OVERLAPPING ranges (next.lo <= cur.hi), NOT
            # merely adjacent ones — GNU keeps adjacent ranges distinct so
            # --output-delimiter still separates them.
            merged: int32 = 0
            if mhi[top] == HI_INF:
                merged = 1
            elif rlo[i] <= mhi[top]:
                merged = 1
            if merged != 0:
                if rhi[i] == HI_INF:
                    mhi[top] = HI_INF
                elif rhi[i] > mhi[top]:
                    mhi[top] = rhi[i]
            else:
                mlo[n_merged] = rlo[i]
                mhi[n_merged] = rhi[i]
                n_merged = n_merged + 1
        i = i + 1


def is_selected(idx: uint64) -> int32:
    k: uint64 = 0
    while k < n_merged:
        if idx >= mlo[k] and idx <= mhi[k]:
            return 1
        k = k + 1
    return 0


def is_range_start(idx: uint64) -> int32:
    k: uint64 = 0
    while k < n_merged:
        if idx == mlo[k]:
            return 1
        k = k + 1
    return 0


# ---- per-line emit -----------------------------------------------------
def emit_bytes(linelen: uint64):
    # -c / -b: walk positions, print selected, insert output delimiter at
    # each merged-range start (only if --output-delimiter given).
    found_any: int32 = 0
    p: uint64 = 1
    while p <= linelen:
        if is_selected(p) != 0:
            if odelim_given != 0 and found_any != 0 and is_range_start(p) != 0:
                sys_write(1, &odelim[0], odelim_len)
            found_any = 1
            sys_write(1, &line[p - 1], 1)
        p = p + 1
    sys_write(1, "\n", 1)


def emit_fields(linelen: uint64):
    # Detect whether the delimiter is present at all.
    has_delim: int32 = 0
    i: uint64 = 0
    while i < linelen:
        if line[i] == opt_delim:
            has_delim = 1
            break
        i = i + 1
    if has_delim == 0:
        if opt_s != 0:
            return                        # suppress non-delimited line
        sys_write(1, &line[0], linelen)
        sys_write(1, "\n", 1)
        return
    # Split into fields; emit selected ones joined by the output delimiter.
    field_idx: uint64 = 1
    found_any: int32 = 0
    start: uint64 = 0
    while True:
        end: uint64 = start
        while end < linelen and line[end] != opt_delim:
            end = end + 1
        if is_selected(field_idx) != 0:
            if found_any != 0:
                sys_write(1, &odelim[0], odelim_len)
            found_any = 1
            if end > start:
                sys_write(1, &line[start], end - start)
        if end >= linelen:
            break
        start = end + 1
        field_idx = field_idx + 1
        if start == linelen:
            # trailing empty field after a terminating delimiter
            if is_selected(field_idx) != 0:
                if found_any != 0:
                    sys_write(1, &odelim[0], odelim_len)
                found_any = 1
            break
    sys_write(1, "\n", 1)


def emit_line(linelen: uint64):
    if opt_mode == 1:
        emit_fields(linelen)
    else:
        emit_bytes(linelen)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    list_str: Ptr[uint8] = cast[Ptr[uint8]](0)
    delim_set: int32 = 0
    i: int32 = 1
    while i < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](i)])
        if a[0] != 45 or a[1] == 0:
            write_str(2, "cut: reads stdin only; unexpected operand\n")
            return 1
        if a[1] == 45:                    # long option "--..."
            if str_starts(a, "--output-delimiter=") != 0:
                src: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](a) + 19)
                l: uint64 = strlen_u8(src)
                if l > 64:
                    l = 64
                j: uint64 = 0
                while j < l:
                    odelim[j] = src[j]
                    j = j + 1
                odelim_len = l
                odelim_given = 1
            elif str_eq(a, "--complement") != 0:
                write_str(2, "cut: --complement not supported\n")
                return 1
            else:
                write_str(2, "cut: unknown option\n")
                return 1
            i = i + 1
            continue
        # short cluster
        k: uint64 = 1
        stop: int32 = 0
        while a[k] != 0 and stop == 0:
            c: uint8 = a[k]
            if c == 115:                  # 's'
                opt_s = 1
                k = k + 1
            elif c == 102 or c == 99 or c == 98:   # f / c / b
                if c == 102:
                    opt_mode = 1
                elif c == 99:
                    opt_mode = 2
                else:
                    opt_mode = 3
                if a[k + 1] != 0:
                    list_str = cast[Ptr[uint8]](cast[uint64](a) + k + 1)
                else:
                    i = i + 1
                    if i >= argc:
                        write_str(2, "cut: option requires a list\n")
                        return 1
                    list_str = cast[Ptr[uint8]](argv[cast[uint64](i)])
                stop = 1
            elif c == 100:                # 'd'
                if a[k + 1] != 0:
                    opt_delim = a[k + 1]
                else:
                    i = i + 1
                    if i >= argc:
                        write_str(2, "cut: -d requires a delimiter\n")
                        return 1
                    opt_delim = cast[Ptr[uint8]](argv[cast[uint64](i)])[0]
                delim_set = 1
                stop = 1
            else:
                write_str(2, "cut: unknown flag\n")
                return 1
        i = i + 1

    if opt_mode == 0:
        write_str(2, "cut: usage: cut -f LIST [-d C] [-s] | -c LIST | -b LIST\n")
        return 1
    if cast[uint64](list_str) == 0:
        write_str(2, "cut: a list of positions is required\n")
        return 1
    if parse_list(list_str) != 0:
        write_str(2, "cut: invalid list\n")
        return 1
    merge_ranges()

    # Default output delimiter for -f is the input delimiter.
    if odelim_given == 0 and opt_mode == 1:
        odelim[0] = opt_delim
        odelim_len = 1

    chunk: Array[512, uint8]
    pos: uint64 = 0
    while True:
        nr: int64 = sys_read(0, &chunk[0], 512)
        if nr <= 0:
            break
        bi: uint64 = 0
        while bi < cast[uint64](nr):
            ch: uint8 = chunk[bi]
            if ch == 10:
                emit_line(pos)
                pos = 0
            else:
                if pos < LINE_CAP:
                    line[pos] = ch
                    pos = pos + 1
            bi = bi + 1
    if pos > 0:
        emit_line(pos)
    return 0

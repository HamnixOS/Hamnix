# user/cut.ad
#
# Hamnix `cut -c N` / `cut -c M-N`: reads stdin line by line and
# emits the 1-based byte slice. Only the -c flag is supported.

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


LINE_BUF: uint64 = 1024
# Global line buf keeps the user task's kernel-stack frame small.
line: Array[1024, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def parse_spec(s: Ptr[uint8], lo: Ptr[uint64], hi: Ptr[uint64]) -> int32:
    # Accept "N" or "M-N" (inclusive). Returns 0 ok, -1 parse error.
    a: uint64 = 0
    b: uint64 = 0
    i: uint64 = 0
    while s[i] != 0 and s[i] != 45:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            return -1
        a = a * 10 + cast[uint64](c - 48)
        i = i + 1
    if a == 0:
        return -1
    if s[i] == 0:
        lo[0] = a
        hi[0] = a
        return 0
    i = i + 1
    while s[i] != 0:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            return -1
        b = b * 10 + cast[uint64](c - 48)
        i = i + 1
    if b < a:
        return -1
    lo[0] = a
    hi[0] = b
    return 0


def emit(lo: uint64, hi: uint64, n: uint64):
    if lo > n:
        sys_write(1, "\n", 1)
        return
    end: uint64 = hi
    if end > n:
        end = n
    sys_write(1, cast[Ptr[uint8]](cast[uint64](&line[0]) + (lo - 1)), end - (lo - 1))
    sys_write(1, "\n", 1)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        write_str(2, "cut: usage: cut -c N|M-N\n")
        return 1
    flag: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    if flag[0] != 45 or flag[1] != 99 or flag[2] != 0:
        write_str(2, "cut: only -c supported\n")
        return 1
    lo: uint64 = 0
    hi: uint64 = 0
    if parse_spec(cast[Ptr[uint8]](argv[2]), &lo, &hi) != 0:
        write_str(2, "cut: bad spec\n")
        return 1
    chunk: Array[256, uint8]
    pos: uint64 = 0
    while True:
        n: int64 = sys_read(0, &chunk[0], 256)
        if n <= 0:
            break
        i: uint64 = 0
        while i < cast[uint64](n):
            c: uint8 = chunk[i]
            if c == 10:
                emit(lo, hi, pos)
                pos = 0
            else:
                if pos + 1 < LINE_BUF:
                    line[pos] = c
                    pos = pos + 1
            i = i + 1
    if pos > 0:
        emit(lo, hi, pos)
    return 0

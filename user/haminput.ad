# user/haminput.ad — Input Event Inspector (/bin/haminput).
#
# A tiny scene-file DE diagnostic window that shows, LIVE, every input event it
# receives on its /event ring — the instrument the user asked for to debug why
# middle-mouse paste "doesn't work".
#
#   * KEY events   — "k <down|up> <keysym> <mods>" lines (delivered only to the
#                    FOCUSED window): shown as code + printable char + mods +
#                    down/up. Click the window first so it takes focus, then
#                    press keys.
#   * MOUSE events — "m <x> <y> <buttons> <dz>" lines: shown as x/y, the button
#                    that changed (LEFT/MIDDLE/RIGHT), down/up/move, and the
#                    wheel notch. MIDDLE-button lines are drawn BOLD + amber so
#                    the debugging target stands out.
#   * On a MIDDLE-button RISING edge the inspector also reads /dev/snarf.primary
#     (the exact PRIMARY-paste consumer step) and logs how many bytes it got +
#     a short preview — so you can see at a glance whether (a) the middle event
#     even arrives and (b) PRIMARY actually holds the highlighted text.
#
# Packaging: built by scripts/build_user.sh (build_adder_user haminput), a
# desktop launcher in etc/desktop.icons + etc/hamde/apps. Launch from the DE
# app drawer / desktop icon, or run /bin/haminput.
#
# Scene transport is modelled on user/hamlogscene.ad; the display list is built
# with lib/hamscene primitives and published with lib/hamui hamscene_commit.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_glyphs, \
    hamscene_glyphs_bold, hamscene_headerbar
from lib.hamui import hamscene_commit


_hi_WIN_W: int32 = 640
_hi_WIN_H: int32 = 460
_hi_BAR_H: int32 = 26

# --- scrolling event log (circular ring of formatted text lines) -----------
_hi_LINES: uint64 = 24                     # visible rows
_hi_LW:    uint64 = 108                    # bytes per row (NUL-terminated)
_hi_log_ring: Array[2592, uint8]           # _hi_LINES * _hi_LW
_hi_log_mid:  Array[24, uint8]             # per-row: 1 = MIDDLE-button _hi_line (bold)
_hi_log_head: uint64 = 0                   # next write slot
_hi_log_n:    uint64 = 0                   # filled rows (<= _hi_LINES)


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


# --- little string builder over a caller buffer ----------------------------
def _apc(buf: Ptr[uint8], p: uint64, c: uint8) -> uint64:
    if p < _hi_LW - 1:
        buf[p] = c
        return p + 1
    return p


def _aps(buf: Ptr[uint8], p: uint64, s: Ptr[uint8]) -> uint64:
    k: uint64 = 0
    q: uint64 = p
    while s[k] != 0:
        q = _apc(buf, q, s[k])
        k = k + 1
    return q


def _api(buf: Ptr[uint8], p: uint64, v: int64) -> uint64:
    q: uint64 = p
    x: int64 = v
    if x < 0:
        q = _apc(buf, q, 45)               # '-'
        x = 0 - x
    if x == 0:
        return _apc(buf, q, 48)
    digs: Array[24, uint8]
    n: uint64 = 0
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        q = _apc(buf, q, digs[n])
    return q


# Push a completed _hi_line (NUL-terminated in `buf`) into the ring. is_mid marks a
# MIDDLE-button row so the renderer draws it bold + amber.
def _log_push(buf: Ptr[uint8], is_mid: uint8):
    base: uint64 = _hi_log_head * _hi_LW
    k: uint64 = 0
    while k < _hi_LW - 1 and buf[k] != 0:
        _hi_log_ring[base + k] = buf[k]
        k = k + 1
    _hi_log_ring[base + k] = 0
    _hi_log_mid[_hi_log_head] = is_mid
    _hi_log_head = (_hi_log_head + 1) % _hi_LINES
    if _hi_log_n < _hi_LINES:
        _hi_log_n = _hi_log_n + 1


# --- window plumbing (mirrors hamlogscene) ---------------------------------
def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# --- PRIMARY read (the paste-consumer diagnostic) --------------------------
_hi_prim_buf: Array[264, uint8]


def _read_primary_len() -> uint64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/snarf.primary"))
    if fd < 0:
        return 0
    total: uint64 = 0
    while total < 256:
        r: int64 = sys_read(fd, &_hi_prim_buf[total], 256 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    _hi_prim_buf[total] = 0
    return total


# --- event field parse (whitespace-delimited signed ints) ------------------
def _next_int(buf: Ptr[uint8], pp: Ptr[uint64], le: uint64,
              out: Ptr[int64]) -> int32:
    p: uint64 = pp[0]
    while p < le and buf[p] == 32:
        p = p + 1
    neg: int32 = 0
    if p < le and buf[p] == 45:
        neg = 1
        p = p + 1
    v: int64 = 0
    have: int32 = 0
    while p < le and buf[p] >= 48 and buf[p] <= 57:
        v = v * 10 + cast[int64](buf[p]) - 48
        p = p + 1
        have = 1
    if neg != 0:
        v = 0 - v
    pp[0] = p
    out[0] = v
    return have


_hi_prev_btn: int64 = 0                    # previous mouse button bitmap (edge)
_hi_line: Array[108, uint8]                # per-event scratch _hi_line


def _fmt_and_push_mouse(x: int64, y: int64, btn: int64, dz: int64):
    # Which buttons changed since the previous bitmap (edge-detect each).
    l_now: int64 = btn & 1
    r_now: int64 = btn & 2
    m_now: int64 = btn & 4
    l_prev: int64 = _hi_prev_btn & 1
    r_prev: int64 = _hi_prev_btn & 2
    m_prev: int64 = _hi_prev_btn & 4
    is_mid: uint8 = 0
    p: uint64 = 0
    p = _aps(&_hi_line[0], p, cast[Ptr[uint8]]("MOUSE x="))
    p = _api(&_hi_line[0], p, x)
    p = _aps(&_hi_line[0], p, cast[Ptr[uint8]](" y="))
    p = _api(&_hi_line[0], p, y)
    p = _aps(&_hi_line[0], p, cast[Ptr[uint8]](" btn="))
    p = _api(&_hi_line[0], p, btn)
    p = _apc(&_hi_line[0], p, 32)
    # Describe the salient transition, MIDDLE first (the debug target).
    if m_now != 0 and m_prev == 0:
        p = _aps(&_hi_line[0], p, cast[Ptr[uint8]]("MIDDLE-down"))
        is_mid = 1
    elif m_now == 0 and m_prev != 0:
        p = _aps(&_hi_line[0], p, cast[Ptr[uint8]]("MIDDLE-up"))
        is_mid = 1
    elif l_now != 0 and l_prev == 0:
        p = _aps(&_hi_line[0], p, cast[Ptr[uint8]]("LEFT-down"))
    elif l_now == 0 and l_prev != 0:
        p = _aps(&_hi_line[0], p, cast[Ptr[uint8]]("LEFT-up"))
    elif r_now != 0 and r_prev == 0:
        p = _aps(&_hi_line[0], p, cast[Ptr[uint8]]("RIGHT-down"))
    elif r_now == 0 and r_prev != 0:
        p = _aps(&_hi_line[0], p, cast[Ptr[uint8]]("RIGHT-up"))
    elif dz != 0:
        p = _aps(&_hi_line[0], p, cast[Ptr[uint8]]("wheel"))
    else:
        p = _aps(&_hi_line[0], p, cast[Ptr[uint8]]("move"))
    if dz != 0:
        p = _aps(&_hi_line[0], p, cast[Ptr[uint8]](" dz="))
        p = _api(&_hi_line[0], p, dz)
    _hi_line[p] = 0
    _log_push(&_hi_line[0], is_mid)
    # On a MIDDLE rising edge, exercise the exact paste-consumer path: read
    # /dev/snarf.primary and report length + preview. This is the "did the
    # middle event arrive AND does PRIMARY hold text" proof in one _hi_line.
    if m_now != 0 and m_prev == 0:
        n: uint64 = _read_primary_len()
        q: uint64 = 0
        q = _aps(&_hi_line[0], q, cast[Ptr[uint8]]("  -> PRIMARY read "))
        q = _api(&_hi_line[0], q, cast[int64](n))
        q = _aps(&_hi_line[0], q, cast[Ptr[uint8]](" bytes: "))
        j: uint64 = 0
        while j < n and j < 48:
            c: uint8 = _hi_prim_buf[j]
            if c < 32 or c > 126:
                c = 46                      # '.'
            q = _apc(&_hi_line[0], q, c)
            j = j + 1
        _hi_line[q] = 0
        _log_push(&_hi_line[0], 1)


def _fmt_and_push_key(is_down: int32, code: int64, mods: int64):
    p: uint64 = 0
    p = _aps(&_hi_line[0], p, cast[Ptr[uint8]]("KEY "))
    if is_down != 0:
        p = _aps(&_hi_line[0], p, cast[Ptr[uint8]]("down"))
    else:
        p = _aps(&_hi_line[0], p, cast[Ptr[uint8]]("up  "))
    p = _aps(&_hi_line[0], p, cast[Ptr[uint8]](" code="))
    p = _api(&_hi_line[0], p, code)
    p = _aps(&_hi_line[0], p, cast[Ptr[uint8]](" char='"))
    if code >= 32 and code <= 126:
        p = _apc(&_hi_line[0], p, cast[uint8](code))
    else:
        p = _apc(&_hi_line[0], p, 46)          # '.'
    p = _aps(&_hi_line[0], p, cast[Ptr[uint8]]("' mods="))
    p = _api(&_hi_line[0], p, mods)
    _hi_line[p] = 0
    _log_push(&_hi_line[0], 0)


def _apply_event_line(buf: Ptr[uint8], ls: uint64, le: uint64):
    # buf[ls..le) is one event _hi_line WITHOUT the trailing '\n'.
    if le <= ls:
        return
    t: uint8 = buf[ls]
    if t == 109:                            # 'm' pointer/wheel
        p: uint64 = ls + 1
        x: int64 = 0
        y: int64 = 0
        btn: int64 = 0
        dz: int64 = 0
        if _next_int(buf, &p, le, &x) == 0:
            return
        if _next_int(buf, &p, le, &y) == 0:
            return
        _next_int(buf, &p, le, &btn)
        _next_int(buf, &p, le, &dz)
        _fmt_and_push_mouse(x, y, btn, dz)
        _hi_prev_btn = btn
    elif t == 107:                          # 'k' keyboard: "k down|up <code> <mods>"
        p2: uint64 = ls + 1
        while p2 < le and buf[p2] == 32:
            p2 = p2 + 1
        is_down: int32 = 0
        if p2 < le and buf[p2] == 100:      # 'd' (down)
            is_down = 1
        # skip the word (down/up) to the next space
        while p2 < le and buf[p2] != 32:
            p2 = p2 + 1
        code: int64 = 0
        mods: int64 = 0
        _next_int(buf, &p2, le, &code)
        _next_int(buf, &p2, le, &mods)
        _fmt_and_push_key(is_down, code, mods)
    elif t == 102:                          # 'f' focus in/out
        p3: uint64 = 0
        p3 = _aps(&_hi_line[0], p3, cast[Ptr[uint8]]("FOCUS "))
        if le > ls + 2 and buf[ls + 2] == 105:      # 'i' (in)
            p3 = _aps(&_hi_line[0], p3, cast[Ptr[uint8]]("in"))
        else:
            p3 = _aps(&_hi_line[0], p3, cast[Ptr[uint8]]("out"))
        _hi_line[p3] = 0
        _log_push(&_hi_line[0], 0)
    elif t == 114:                          # 'r' resize
        p4: uint64 = ls + 1
        wv: int64 = 0
        hv: int64 = 0
        _next_int(buf, &p4, le, &wv)
        _next_int(buf, &p4, le, &hv)
        p5: uint64 = 0
        p5 = _aps(&_hi_line[0], p5, cast[Ptr[uint8]]("RESIZE w="))
        p5 = _api(&_hi_line[0], p5, wv)
        p5 = _aps(&_hi_line[0], p5, cast[Ptr[uint8]](" h="))
        p5 = _api(&_hi_line[0], p5, hv)
        _hi_line[p5] = 0
        _log_push(&_hi_line[0], 0)


# --- scene render ----------------------------------------------------------
def _hi_emit_scene(wid: int32):
    hamscene_begin()
    hamscene_fill(0, 0, _hi_WIN_W, _hi_WIN_H, cast[Ptr[uint8]]("#12161c"))
    hamscene_headerbar(0, 0, _hi_WIN_W, _hi_BAR_H)
    hamscene_glyphs(10, 7, cast[Ptr[uint8]]("Input Event Inspector"),
                    cast[Ptr[uint8]]("#ffffff"))
    hamscene_glyphs(300, 7,
                    cast[Ptr[uint8]]("click to focus - keys + mouse - MIDDLE=amber"),
                    cast[Ptr[uint8]]("#c8d0d8"))
    # Render the ring oldest..newest, top..bottom.
    y: int32 = _hi_BAR_H + 10
    r: uint64 = 0
    while r < _hi_log_n:
        slot: uint64 = (_hi_log_head + _hi_LINES - _hi_log_n + r) % _hi_LINES
        base: uint64 = slot * _hi_LW
        if _hi_log_mid[slot] != 0:
            hamscene_glyphs_bold(10, y, &_hi_log_ring[base],
                                 cast[Ptr[uint8]]("#ffcc44"))
        else:
            hamscene_glyphs(10, y, &_hi_log_ring[base],
                            cast[Ptr[uint8]]("#a8f0c0"))
        y = y + 17
        r = r + 1
    hamscene_commit(wid)


# --- event drain (complete lines, carry the remainder) ---------------------
_hi_evbuf:   Array[2048, uint8]
_hi_evcarry: uint64 = 0


def _drain(efd: int32) -> int32:
    changed: int32 = 0
    passes: int32 = 0
    while passes < 4:
        room: uint64 = 2048 - _hi_evcarry
        if room == 0:
            _hi_evcarry = 0
            room = 2048
        en: int64 = sys_read(efd, &_hi_evbuf[_hi_evcarry], room)
        if en <= 0:
            break
        total: uint64 = _hi_evcarry + cast[uint64](en)
        i: uint64 = 0
        ls: uint64 = 0
        while i < total:
            if _hi_evbuf[i] == 10:
                _apply_event_line(&_hi_evbuf[0], ls, i)
                changed = 1
                ls = i + 1
            i = i + 1
        # carry the incomplete tail forward
        leftover: uint64 = total - ls
        m: uint64 = 0
        while m < leftover:
            _hi_evbuf[m] = _hi_evbuf[ls + m]
            m = m + 1
        _hi_evcarry = leftover
        passes = passes + 1
    return changed


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[haminput] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp:  Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("geometry 140 80 640 460\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("title Input Event Inspector\n"))
        sys_close(cfd3)
    cfd4: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd4 >= 0:
        _writeall(cfd4, cast[Ptr[uint8]]("z 9\n"))
        sys_close(cfd4)

    _log_push(cast[Ptr[uint8]]("ready - click the window, then press keys / click mouse buttons"), 0)
    _hi_emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[haminput] scene window ready\n"))

    while True:
        changed: int32 = 0
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            if _drain(efd) != 0:
                changed = 1
            sys_close(efd)
        if changed != 0:
            _hi_emit_scene(wid)
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 2:
            sys_yield()
    return 0

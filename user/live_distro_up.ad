# user/live_distro_up.ad
#
# LIVE-medium Debian-namespace bringup trigger (#410 Item 2).
#
# Usage:
#   live_distro_up                       (defaults below)
#   live_distro_up <sqfs_file> <inner_image>
#   live_distro_up /rootfs.sqfs /live-distro.ext4
#
# WHY THIS EXISTS. A LIVE boot off the installer medium (no install)
# still wants the real-Debian `enter linux { ... }` namespace. On the
# installed system #distro is a subtree of the NVMe ext4 partition; on
# the live medium there is NO readable disk (ESP-only GPT, broken USB
# driver on the NUC) — the Debian tree must come out of the
# firmware-loaded in-RAM squashfs. The kernel does all the work
# (drivers/block/loop.ad::loop_sqfs_live_root): loop-attach the
# squashfs, look up the live-distro ext4 image, decompress it into a
# fresh RAM block device (`live0`), mount it, and post its
# .hamnix-roots named roots (#distro) — the SAME machinery the
# installed disk uses, so the rc.boot.full `linux = ns clean { bind
# '#distro' / ... }` recipe works identically.
#
# Plan-9 native control surface: open the global /dev/loop/ctl cdev
# and write one verb line:
#
#   sqfs_live_root <sqfs_file> <inner_image>\n
#
# etc/rc.boot's LIVE branch spawns this tool DETACHED before handing
# off to rc.boot.full, so boot timing is unaffected; the ns recipe
# binds '#distro' at ENTER time, so the namespace is usable as soon as
# the kernel prints "[live-root] DONE".

extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def _append(dst: Ptr[uint8], at: uint64, src: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while src[i] != 0:
        dst[at] = src[i]
        at = at + 1
        i = i + 1
    return at


# "sqfs_live_root <a> <b>\n" — two cpio/squashfs paths; 1024 bytes is
# comfortable.
ctl_line: Array[1024, uint8]


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    sqfs_file:  Ptr[uint8] = "/rootfs.sqfs"
    inner_img:  Ptr[uint8] = "/live-distro.ext4"
    if argc >= 3:
        sqfs_file = cast[Ptr[uint8]](argv[1])
        inner_img = cast[Ptr[uint8]](argv[2])

    at: uint64 = 0
    at = _append(&ctl_line[0], at, "sqfs_live_root ")
    at = _append(&ctl_line[0], at, sqfs_file)
    ctl_line[at] = 32                              # ' '
    at = at + 1
    at = _append(&ctl_line[0], at, inner_img)
    ctl_line[at] = 10                              # '\n'
    at = at + 1

    write_str(1, "live_distro_up: bringing up #distro from ")
    write_str(1, sqfs_file)
    write_str(1, " (")
    write_str(1, inner_img)
    write_str(1, ")\n")

    fd: int32 = sys_open_write("/dev/loop/ctl")
    if fd < 0:
        write_str(2, "live_distro_up: cannot open /dev/loop/ctl\n")
        return 1
    w: int64 = sys_write(fd, &ctl_line[0], at)
    sys_close(fd)
    if w < 0:
        write_str(2, "live_distro_up: bringup failed (kernel rejected verb)\n")
        return 1
    write_str(1, "live_distro_up: OK (#distro posted)\n")
    return 0

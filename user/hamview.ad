# user/hamview.ad
#
# hamview — an IMAGE VIEWER built on the hamui widget toolkit
# (lib/hamui.ad). It is the MATE "Eye of MATE" / image-viewer equivalent:
# a separate-process hamui client that opens an image file (argv[1], or a
# built-in sample), decodes it, and displays it scaled+centred in a window
# with the filename and dimensions in the title and status bar.
#
# WHY A SEPARATE PROCESS: like hamclock / hamterm, hamview is an ordinary
# userland app that CONSUMES the compositor's on-disk wsys draw protocol.
# It never touches user/hamUId.ad (the compositor) or lib/hamui.ad (the
# toolkit) — it speaks the existing protocol the toolkit and compositor
# already agree on.
#
# IMAGE FORMATS (all decoded from scratch — no libc/zlib/libpng/libjpeg):
#   * PPM / PNM "P6" (binary RGB, the trivial NetPBM format): an ASCII
#     header "P6 <w> <h> <maxval>\n" followed by w*h*3 raw RGB bytes.
#   * BMP, uncompressed (BITMAPFILEHEADER + BITMAPINFOHEADER), 24bpp or
#     32bpp, BI_RGB only. Rows are 4-byte aligned and stored BOTTOM-UP
#     (positive biHeight) — we flip them. BGR(A) byte order -> RGBA.
#   * PNG (magic 89 50 4E 47) via lib/png.ad — a pure-Adder inflate +
#     unfilter; colour types 0/2/3/6, 8-bit, non-interlaced, <=512x512.
#   * JPEG (magic FF D8) via lib/jpeg.ad — a pure-Adder baseline (Huffman
#     + IDCT + YCbCr->RGB) decoder; BASELINE only (progressive -> rc<0),
#     <=512x512.
# The compressed decoders live in lib/png.ad / lib/jpeg.ad; hamview just
# dispatches on the magic bytes and feeds the decoded RGBA into the SAME
# scale+blit path the PPM/BMP branches use. Images larger than 512px on a
# side (or corrupt / progressive JPEG) fail the decoder and show a clean
# error placeholder rather than crashing.
#
# HOW PIXELS REACH THE SCREEN (the RIO-faithful "v2 blit" protocol):
# The scene DE's display-list path (hamscene fill/rect/glyph/line) has NO
# bitmap/image tier, and the older per-window "fb"/markup draw LAYERS are
# retired (they composite nothing now). The ONLY way to put a decoded
# raster on screen is the compositor's v2 blit protocol: a client owns a
# private RGBA8888 backbuffer, draws into it, and the compositor blits that
# buffer as the window's content. So hamview:
#   1. newwindow + geometry/decorate     map an OWNED top-level window
#   2. hamui_set_protocol_v2_dims(W,H)    opt the window into v2 blit
#   3. hamui_v2_clear + hamui_v2_fill_rect    paint the chrome bars
#   4. blit the scaled (<=256) decoded RGBA centred into the backbuffer
#   5. hamui_v2_commit_rect(0,0,W,H)      publish the frame
# Window-title text rides the compositor's server-side decoration (set via
# hamui_set_title); in-content labels are the DE's crude 4x6 text-blocks
# (the same _draw_text_blocks every v2 client uses until str-ink lands).
#
# COMPILER QUIRKS HONOURED (memory/feedback_compiler_quirks):
#   * big buffers at MODULE scope (no large locals, no malloc);
#   * string literals returned/passed at the call site, never stored in a
#     NUL-initialised global; NO adjacent string-literal concatenation;
#   * cast[T](x), +=, &arr[0] used throughout.

from lib.hamui import (
    hamui_init, hamui_window_on,
    hamui_set_protocol_v2_dims, hamui_v2_clear, hamui_v2_fill_rect,
    hamui_v2_bb_ptr, hamui_v2_bb_w, hamui_v2_bb_h, hamui_v2_commit_rect
)
from lib.png import png_decode, png_width, png_height, png_rgba_ptr
from lib.jpeg import jpeg_decode, jpeg_width, jpeg_height, jpeg_rgba_ptr

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield() -> int32

# ====================================================================
# Caps (no malloc — every buffer is a fixed module global).
# ====================================================================
# Window content is 640x480. fb layers cap at 256x256 RGBA8888 in the
# compositor, so we scale the source down to fit FB_MAX on its long edge.
FB_MAX:      uint64 = 256
WIN_W:       int64  = 640
WIN_H:       int64  = 480

# Raw file bytes. Cap the on-disk image at 1 MiB — enough for a 256x256
# 32bpp BMP plus headers, or a generous PPM.
RAW_CAP:     uint64 = 1048576
_hv_raw_buf:     Array[1048576, uint8]
_hv_raw_len:     uint64 = 0

# Decoded source pixels, RGBA8888, before scaling. Cap at 512x512 source;
# larger images are rejected (we still show their declared dimensions).
SRC_MAX:     uint64 = 512
_hv_src_buf:     Array[1048576, uint8]      # 512*512*4 (PPM/BMP raster)
_hv_src_w:       uint64 = 0
_hv_src_h:       uint64 = 0
# Points at the decoded RGBA raster to scale from: &_hv_src_buf[0] for the
# PPM/BMP paths, or the lib/png|jpeg output buffer for PNG/JPEG (no copy).
_hv_src_ptr:     Ptr[uint8] = cast[Ptr[uint8]](0)

# Scaled output buffer pushed to the "pix" fb layer (<=256x256 RGBA8888).
_hv_fb_buf:      Array[262144, uint8]       # 256*256*4
_hv_fb_w:        uint64 = 0
_hv_fb_h:        uint64 = 0

# Scratch / path / markup buffers.
_hv_path_buf:    Array[128, uint8]
_hv_ctl_buf:     Array[64, uint8]
_hv_markup_buf:  Array[256, uint8]
_hv_status_buf:  Array[128, uint8]

# widget ids
_hv_lbl_title:   int32 = 0
_hv_sbar:        int32 = 0


# ====================================================================
# Small string / number helpers (self-contained — no libc).
# ====================================================================
def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


# Append a NUL-terminated source string into dst at pos; return new pos.
def _put_s(dst: Ptr[uint8], pos: uint64, s: Ptr[uint8]) -> uint64:
    j: uint64 = 0
    while s[j] != 0:
        dst[pos] = s[j]
        pos = pos + 1
        j = j + 1
    return pos


# Append the decimal form of v into dst at pos; return new pos.
def _put_dec(dst: Ptr[uint8], pos: uint64, v: uint64) -> uint64:
    if v == 0:
        dst[pos] = 48
        return pos + 1
    tmp: Array[24, uint8]
    t: uint64 = 0
    while v != 0:
        tmp[t] = cast[uint8](v % 10) + 48
        v = v / 10
        t = t + 1
    while t > 0:
        t = t - 1
        dst[pos] = tmp[t]
        pos = pos + 1
    return pos


# Basename: pointer to the char after the last '/' in s.
def _basename(s: Ptr[uint8]) -> Ptr[uint8]:
    last: Ptr[uint8] = s
    i: uint64 = 0
    while s[i] != 0:
        if s[i] == 47:                          # '/'
            last = &s[i + 1]
        i = i + 1
    return last


# ====================================================================
# File loading.
# ====================================================================
def _load_file(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    total: uint64 = 0
    while total < RAW_CAP:
        n: int64 = sys_read(fd, &_hv_raw_buf[total], RAW_CAP - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    _hv_raw_len = total
    if total == 0:
        return -1
    return 0


# ====================================================================
# PPM (P6) decode.  Header: "P6" <ws> W <ws> H <ws> MAXVAL <single-ws>
# then W*H*3 raw RGB bytes.  Comments (# ... \n) are allowed in NetPBM
# headers; we skip them.
# ====================================================================
def _is_space(c: uint8) -> int32:
    if c == 32 or c == 9 or c == 10 or c == 13:
        return 1
    return 0


# Skip whitespace and '#'-to-EOL comments starting at p; return new index.
def _ppm_skip_ws(p: uint64) -> uint64:
    while p < _hv_raw_len:
        c: uint8 = _hv_raw_buf[p]
        if _is_space(c) != 0:
            p = p + 1
        elif c == 35:                           # '#'
            while p < _hv_raw_len and _hv_raw_buf[p] != 10:
                p = p + 1
        else:
            break
    return p


# Parse a non-negative decimal at p; store value via out[0], return new idx.
def _ppm_uint(p: uint64, out: Ptr[uint64]) -> uint64:
    v: uint64 = 0
    while p < _hv_raw_len and _hv_raw_buf[p] >= 48 and _hv_raw_buf[p] <= 57:
        v = v * 10 + cast[uint64](_hv_raw_buf[p] - 48)
        p = p + 1
    out[0] = v
    return p


def _decode_ppm() -> int32:
    if _hv_raw_len < 2 or _hv_raw_buf[0] != 80 or _hv_raw_buf[1] != 54:   # "P6"
        return -1
    p: uint64 = 2
    wv: Array[1, uint64]
    hv: Array[1, uint64]
    mv: Array[1, uint64]
    p = _ppm_skip_ws(p)
    p = _ppm_uint(p, &wv[0])
    p = _ppm_skip_ws(p)
    p = _ppm_uint(p, &hv[0])
    p = _ppm_skip_ws(p)
    p = _ppm_uint(p, &mv[0])
    # exactly ONE whitespace byte separates the header from the raster.
    if p < _hv_raw_len and _is_space(_hv_raw_buf[p]) != 0:
        p = p + 1
    w: uint64 = wv[0]
    h: uint64 = hv[0]
    _hv_src_w = w
    _hv_src_h = h
    if w == 0 or h == 0 or w > SRC_MAX or h > SRC_MAX:
        return -2                               # too big / empty: dims only
    _hv_src_ptr = &_hv_src_buf[0]
    if mv[0] == 0 or mv[0] > 255:
        return -1                               # only 8-bit channels
    need: uint64 = w * h * 3
    if p + need > _hv_raw_len:
        return -1                               # truncated raster
    # Expand RGB -> RGBA into _hv_src_buf.
    i: uint64 = 0
    n: uint64 = w * h
    while i < n:
        so: uint64 = p + i * 3
        dofs: uint64 = i * 4
        _hv_src_buf[dofs]     = _hv_raw_buf[so]
        _hv_src_buf[dofs + 1] = _hv_raw_buf[so + 1]
        _hv_src_buf[dofs + 2] = _hv_raw_buf[so + 2]
        _hv_src_buf[dofs + 3] = 255
        i = i + 1
    return 0


# ====================================================================
# BMP decode (uncompressed BI_RGB, 24/32bpp, bottom-up).
# Little-endian field readers off _hv_raw_buf.
# ====================================================================
def _rd_u16(off: uint64) -> uint64:
    return cast[uint64](_hv_raw_buf[off]) | (cast[uint64](_hv_raw_buf[off + 1]) << 8)


def _rd_u32(off: uint64) -> uint64:
    return cast[uint64](_hv_raw_buf[off]) \
        | (cast[uint64](_hv_raw_buf[off + 1]) << 8) \
        | (cast[uint64](_hv_raw_buf[off + 2]) << 16) \
        | (cast[uint64](_hv_raw_buf[off + 3]) << 24)


def _decode_bmp() -> int32:
    if _hv_raw_len < 54 or _hv_raw_buf[0] != 66 or _hv_raw_buf[1] != 77:   # "BM"
        return -1
    data_off: uint64 = _rd_u32(10)
    hdr_size: uint64 = _rd_u32(14)              # BITMAPINFOHEADER = 40
    if hdr_size < 40:
        return -1
    w: uint64 = _rd_u32(18)
    raw_h: uint64 = _rd_u32(22)                 # treat as positive (bottom-up)
    planes: uint64 = _rd_u16(26)
    bpp: uint64 = _rd_u16(28)
    compression: uint64 = _rd_u32(30)
    h: uint64 = raw_h
    _hv_src_w = w
    _hv_src_h = h
    if planes != 1:
        return -1
    if compression != 0:                        # BI_RGB only
        return -1
    if bpp != 24 and bpp != 32:
        return -1
    if w == 0 or h == 0 or w > SRC_MAX or h > SRC_MAX:
        return -2                               # dims only
    _hv_src_ptr = &_hv_src_buf[0]
    bytes_pp: uint64 = bpp / 8
    # rows are padded to a 4-byte boundary.
    row_stride: uint64 = ((w * bytes_pp + 3) / 4) * 4
    if data_off + row_stride * h > _hv_raw_len:
        return -1                               # truncated
    # bottom-up: source row 0 is the BOTTOM of the image.
    y: uint64 = 0
    while y < h:
        src_row: uint64 = data_off + (h - 1 - y) * row_stride
        x: uint64 = 0
        while x < w:
            so: uint64 = src_row + x * bytes_pp
            dofs: uint64 = (y * w + x) * 4
            # BMP stores BGR(A); map to RGBA.
            _hv_src_buf[dofs]     = _hv_raw_buf[so + 2]   # R
            _hv_src_buf[dofs + 1] = _hv_raw_buf[so + 1]   # G
            _hv_src_buf[dofs + 2] = _hv_raw_buf[so]       # B
            if bytes_pp == 4:
                a: uint8 = _hv_raw_buf[so + 3]
                # Many 32bpp BMPs leave alpha 0; treat all-0 alpha as opaque.
                if a == 0:
                    a = 255
                _hv_src_buf[dofs + 3] = a
            else:
                _hv_src_buf[dofs + 3] = 255
            x = x + 1
        y = y + 1
    return 0


# ====================================================================
# PNG decode (lib/png.ad — inflate + unfilter, colour types 0/2/3/6,
# 8-bit, non-interlaced, <=512x512).  On success point _hv_src_ptr at the
# decoder's RGBA output (no copy) and record the real dimensions.
# ====================================================================
def _decode_png() -> int32:
    rc: int32 = png_decode(&_hv_raw_buf[0], _hv_raw_len)
    if rc < 0:
        return -1                               # corrupt / unsupported / too big
    _hv_src_w = cast[uint64](png_width())
    _hv_src_h = cast[uint64](png_height())
    if _hv_src_w == 0 or _hv_src_h == 0:
        return -1
    _hv_src_ptr = png_rgba_ptr()
    return 0


# ====================================================================
# JPEG decode (lib/jpeg.ad — baseline Huffman + IDCT + YCbCr->RGB,
# <=512x512).  Progressive / arithmetic streams return rc<0.
# ====================================================================
def _decode_jpeg() -> int32:
    rc: int32 = jpeg_decode(&_hv_raw_buf[0], _hv_raw_len)
    if rc < 0:
        return -1                               # progressive / corrupt / too big
    _hv_src_w = cast[uint64](jpeg_width())
    _hv_src_h = cast[uint64](jpeg_height())
    if _hv_src_w == 0 or _hv_src_h == 0:
        return -1
    _hv_src_ptr = jpeg_rgba_ptr()
    return 0


# ====================================================================
# Format dispatch on magic bytes.  Returns 0 ok, -2 dims-only (too big),
# -1 unrecognised / corrupt.
# ====================================================================
def _decode() -> int32:
    if _hv_raw_len >= 2 and _hv_raw_buf[0] == 80 and _hv_raw_buf[1] == 54:      # "P6"
        return _decode_ppm()
    if _hv_raw_len >= 2 and _hv_raw_buf[0] == 66 and _hv_raw_buf[1] == 77:      # "BM"
        return _decode_bmp()
    # PNG signature: 89 50 4E 47.
    if _hv_raw_len >= 4 and _hv_raw_buf[0] == 137 and _hv_raw_buf[1] == 80 \
       and _hv_raw_buf[2] == 78 and _hv_raw_buf[3] == 71:
        return _decode_png()
    # JPEG SOI: FF D8.
    if _hv_raw_len >= 2 and _hv_raw_buf[0] == 255 and _hv_raw_buf[1] == 216:
        return _decode_jpeg()
    return -1


# ====================================================================
# Scale the decoded RGBA raster at _hv_src_ptr (_hv_src_w x _hv_src_h) down
# into _hv_fb_buf, preserving aspect, so the long edge is <= FB_MAX.
# Nearest-neighbour (the compositor blit from fb -> window is also
# nearest-neighbour, so this is consistent).  Works uniformly for the
# PPM/BMP raster (_hv_src_buf) and the lib/png|jpeg output buffers.
# ====================================================================
def _scale_to_fb():
    src: Ptr[uint8] = _hv_src_ptr
    sw: uint64 = _hv_src_w
    sh: uint64 = _hv_src_h
    dw: uint64 = sw
    dh: uint64 = sh
    # shrink the long edge to FB_MAX (only ever downscale).
    if dw > FB_MAX or dh > FB_MAX:
        if dw >= dh:
            dh = (dh * FB_MAX) / dw
            dw = FB_MAX
        else:
            dw = (dw * FB_MAX) / dh
            dh = FB_MAX
    if dw == 0:
        dw = 1
    if dh == 0:
        dh = 1
    _hv_fb_w = dw
    _hv_fb_h = dh
    y: uint64 = 0
    while y < dh:
        sy: uint64 = (y * sh) / dh
        x: uint64 = 0
        while x < dw:
            sx: uint64 = (x * sw) / dw
            so: uint64 = (sy * sw + sx) * 4
            dofs: uint64 = (y * dw + x) * 4
            _hv_fb_buf[dofs]     = src[so]
            _hv_fb_buf[dofs + 1] = src[so + 1]
            _hv_fb_buf[dofs + 2] = src[so + 2]
            _hv_fb_buf[dofs + 3] = src[so + 3]
            x = x + 1
        y = y + 1


# ====================================================================
# v2 blit rendering — draw the chrome + image into the client backbuffer.
# ====================================================================
# Crude 4x6 text blocks (one opaque block per non-space char). This is the
# SAME placeholder text every v2 DE client uses (hamlock/hamrun/hamappmenu's
# _draw_text_blocks) until real str-ink-on-v2 glyphs land — good enough to
# read the filename/dimensions row apart from the image.
_GLYPH_W:   int32 = 4
_GLYPH_H:   int32 = 6
_GLYPH_ADV: int32 = 5

def _draw_text_blocks(x: int32, y: int32, s: Ptr[uint8],
                      r: uint8, g: uint8, b: uint8, max_w: int32):
    i: uint64 = 0
    cx: int32 = x
    while s[i] != 0 and cx + _GLYPH_W <= x + max_w:
        if s[i] != 32:
            hamui_v2_fill_rect(cx, y, _GLYPH_W, _GLYPH_H, r, g, b)
        cx = cx + _GLYPH_ADV
        i = i + 1


# Opaque-blit the scaled RGBA raster (_hv_fb_buf, _hv_fb_w x _hv_fb_h) into
# the v2 backbuffer at (px,py), clipped to the buffer bounds.
def _blit_image_v2(px: int32, py: int32):
    bb: Ptr[uint8] = hamui_v2_bb_ptr()
    if bb == cast[Ptr[uint8]](0):
        return
    bw: int32 = hamui_v2_bb_w()
    bh: int32 = hamui_v2_bb_h()
    stride: uint64 = cast[uint64](bw) * 4
    iw: int32 = cast[int32](_hv_fb_w)
    ih: int32 = cast[int32](_hv_fb_h)
    yy: int32 = 0
    while yy < ih:
        dy: int32 = py + yy
        if dy >= 0 and dy < bh:
            xx: int32 = 0
            while xx < iw:
                dx: int32 = px + xx
                if dx >= 0 and dx < bw:
                    so: uint64 = (cast[uint64](yy) * _hv_fb_w \
                                  + cast[uint64](xx)) * 4
                    dofs: uint64 = cast[uint64](dy) * stride \
                                   + cast[uint64](dx) * 4
                    bb[dofs]     = _hv_fb_buf[so]
                    bb[dofs + 1] = _hv_fb_buf[so + 1]
                    bb[dofs + 2] = _hv_fb_buf[so + 2]
                    bb[dofs + 3] = 255
                xx = xx + 1
        yy = yy + 1


# ====================================================================
# Window creation — self-allocate an OWNED top-level via `newwindow` and
# MAP it with an explicit geometry (the step that makes it visible), the
# proven sequence hambrowse uses. hamui_window() alone left the window
# unmapped (registered in the taskbar but never shown).
# ====================================================================
def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


# Build "/dev/wsys/<wid>/ctl" into _hv_path_buf.
def _wsys_ctl_path(wid: int32):
    i: uint64 = 0
    i = _put_s(&_hv_path_buf[0], i, "/dev/wsys/")
    i = _put_dec(&_hv_path_buf[0], i, cast[uint64](wid))
    i = _put_s(&_hv_path_buf[0], i, "/ctl")
    _hv_path_buf[i] = 0


# Write one ctl verb to the per-window ctl path currently in _hv_path_buf.
def _wctl(verb: Ptr[uint8]):
    fd: int32 = sys_open_write(cast[Ptr[char]](&_hv_path_buf[0]))
    if fd >= 0:
        sys_write(fd, verb, _strlen(verb))
        sys_close(fd)


# Compose the in-content status text "<name>  <w>x<h> <note>" into
# _hv_status_buf (NUL-terminated).
def _build_status_text(name: Ptr[uint8], note: Ptr[uint8]):
    p: uint64 = 0
    p = _put_s(&_hv_status_buf[0], p, name)
    p = _put_s(&_hv_status_buf[0], p, "  ")
    if _hv_src_w != 0 and _hv_src_h != 0:
        p = _put_dec(&_hv_status_buf[0], p, _hv_src_w)
        _hv_status_buf[p] = 120                     # 'x'
        p = p + 1
        p = _put_dec(&_hv_status_buf[0], p, _hv_src_h)
        _hv_status_buf[p] = 32
        p = p + 1
    p = _put_s(&_hv_status_buf[0], p, note)
    _hv_status_buf[p] = 0


# Paint the whole window into the v2 backbuffer and commit it. `ok` != 0
# means the image decoded and is blitted; otherwise `note` is shown.
def _paint_v2(wid: int32, name: Ptr[uint8], note: Ptr[uint8], ok: int32):
    w: int32 = cast[int32](WIN_W)
    h: int32 = cast[int32](WIN_H)
    # backdrop
    hamui_v2_clear(43, 43, 43)                       # #2b2b2b
    # title + status bars
    hamui_v2_fill_rect(0, 0, w, 22, 58, 58, 58)
    hamui_v2_fill_rect(0, h - 18, w, 18, 58, 58, 58)
    # title text: "hamview - <name>"
    tp: uint64 = 0
    ttmp: Array[128, uint8]
    tp = _put_s(&ttmp[0], tp, "hamview - ")
    tp = _put_s(&ttmp[0], tp, name)
    ttmp[tp] = 0
    _draw_text_blocks(6, 8, &ttmp[0], 220, 220, 220, w - 12)
    # status text
    _build_status_text(name, note)
    _draw_text_blocks(6, h - 14, &_hv_status_buf[0], 200, 200, 200, w - 12)
    # image (centred in the area between the two bars)
    if ok != 0:
        iw: int32 = cast[int32](_hv_fb_w)
        ih: int32 = cast[int32](_hv_fb_h)
        avail_top: int32 = 22
        avail_h: int32 = (h - 18) - avail_top
        px: int32 = (w - iw) / 2
        py: int32 = avail_top + (avail_h - ih) / 2
        if px < 0:
            px = 0
        if py < avail_top:
            py = avail_top
        _blit_image_v2(px, py)
    hamui_v2_commit_rect(0, 0, w, h)
    # PRESENT: a pure-v2 window is INVISIBLE under the scene compositor until
    # its scene carries the `buffer` verb (which copies the kernel-side v2
    # backbuffer into the window's scene cache) followed by a `commit`. This is
    # the step hamui_v2_commit_rect alone does NOT do (it only ships the 'B'
    # blit); mirrors hambrowse's _present_buffer().
    _present_v2(wid)


# Publish the committed v2 backbuffer to the scene compositor: write the
# `buffer 0 0 W H` scene verb, then poke `commit` on the window ctl.
def _present_v2(wid: int32):
    sp: uint64 = 0
    sp = _put_s(&_hv_path_buf[0], sp, "/dev/wsys/")
    sp = _put_dec(&_hv_path_buf[0], sp, cast[uint64](wid))
    sp = _put_s(&_hv_path_buf[0], sp, "/scene")
    _hv_path_buf[sp] = 0
    sfd: int32 = sys_open_write(cast[Ptr[char]](&_hv_path_buf[0]))
    if sfd >= 0:
        m: uint64 = 0
        m = _put_s(&_hv_markup_buf[0], m, "buffer 0 0 ")
        m = _put_dec(&_hv_markup_buf[0], m, WIN_W)
        _hv_markup_buf[m] = 32                           # ' '
        m = m + 1
        m = _put_dec(&_hv_markup_buf[0], m, WIN_H)
        _hv_markup_buf[m] = 10                           # '\n'
        m = m + 1
        sys_write(sfd, &_hv_markup_buf[0], m)
        sys_close(sfd)
    _wsys_ctl_path(wid)
    _wctl("commit\n")


# ====================================================================
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()

    # ---- resolve the file path (argv[1] or a built-in sample) ----
    has_path: int32 = 0
    path: Ptr[char] = cast[Ptr[char]]("/share/hamview/sample.ppm")
    if argc > 1:
        path = cast[Ptr[char]](argv[1])
        has_path = 1

    name: Ptr[uint8] = _basename(cast[Ptr[uint8]](path))

    # ---- load + decode FIRST, BEFORE creating the window ----
    # `newwindow` on /dev/wsys/ctl (below) rebinds this process's stdout to the
    # window. So do the decode here and emit the serial
    # proof markers to STDERR (fd 2, which stays on the console) BEFORE that —
    # this is what the on-device gate reads ("hamview: decoded WxH"). The decode
    # needs no window, so nothing is lost by ordering it first.
    _hv_src_w = 0
    _hv_src_h = 0
    loaded: int32 = _load_file(path)
    rc: int32 = -100                                 # sentinel: not decoded yet
    if loaded >= 0:
        rc = _decode()
    if rc == 0:
        _puts(2, "hamview: decoded ")
        dec_p: uint64 = 0
        dec_tmp: Array[48, uint8]
        dec_p = _put_dec(&dec_tmp[0], dec_p, _hv_src_w)
        dec_tmp[dec_p] = 120                         # 'x'
        dec_p = dec_p + 1
        dec_p = _put_dec(&dec_tmp[0], dec_p, _hv_src_h)
        dec_tmp[dec_p] = 10
        dec_p = dec_p + 1
        dec_tmp[dec_p] = 0
        _puts(2, &dec_tmp[0])
    elif loaded < 0:
        _puts(2, "hamview: cannot open image\n")
    else:
        _puts(2, "hamview: decode failed\n")

    # Scale the decoded raster (<=256 long edge) into _hv_fb_buf for blitting.
    if rc == 0:
        _scale_to_fb()

    # ---- self-allocate an OWNED top-level window, MAP it with an explicit
    # geometry (the visible-window step), decorate + title it, then opt into
    # the v2 blit protocol so we can composite a REAL bitmap (the scene
    # display-list has no image tier; the legacy /draw fb-layer paints nothing
    # in the scene DE). Mirrors hambrowse's proven window bring-up. ----
    wid: int32 = _newwindow()
    if wid < 1:
        _puts(2, "hamview: newwindow failed\n")
        return 1
    _wsys_ctl_path(wid)
    _wctl("geometry 120 80 640 480\n")
    _wctl("decorate 1\n")
    _wctl("z 12\n")
    # SSD title = the filename.
    tn: uint64 = 0
    tn = _put_s(&_hv_ctl_buf[0], tn, "title ")
    tn = _put_s(&_hv_ctl_buf[0], tn, name)
    _hv_ctl_buf[tn] = 10
    tn = tn + 1
    _hv_ctl_buf[tn] = 0
    _wctl(&_hv_ctl_buf[0])

    hamui_window_on(0, wid)
    if hamui_set_protocol_v2_dims(cast[int32](WIN_W), cast[int32](WIN_H)) < 0:
        _puts(2, "hamview: v2 blit negotiate failed\n")
        return 1

    # ---- compose the frame into the backbuffer, commit + present ----
    if rc == 0:
        _paint_v2(wid, name, "", 1)
    elif loaded < 0:
        if has_path != 0:
            _paint_v2(wid, name, "(cannot open)", 0)
        else:
            _paint_v2(wid, name, "(no image given)", 0)
    elif rc == -2:
        _paint_v2(wid, name, "(too large to display)", 0)
    else:
        _paint_v2(wid, name, "(unsupported or corrupt image)", 0)

    _puts(2, "HAMVIEW ready\n")
    _loop(wid)
    return 0


# Idle loop — the frame is committed + presented and the compositor caches the
# window's scene, so the static image persists. Re-present periodically to
# survive an expose/damage from other windows, yielding the CPU between.
def _loop(wid: int32):
    while True:
        sys_yield()
        _present_v2(wid)

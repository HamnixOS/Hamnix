# user/hamterm.ad
#
# hamterm — a real GUI terminal built on the hamui widget toolkit
# (lib/hamui.ad). It is the GTK/Qt-style consumer shape the desktop app
# suite follows: build a widget tree, bind a window, run a pull-based
# event loop.
#
# Layout (640x480 window):
#   * a toolbar across the top with Clear + Quit buttons
#   * a large scrolling textview that accumulates command output
#   * an entry for the command line + a Run button
#   * a statusbar showing the session state
#
# SEPARATE-PROCESS COMPOSITOR CLIENT (Increment-2 of the MATE-mirror DE
# rewrite)
# ---------------------------------------------------------------------
# hamterm is the canonical desktop app: the compositor (hamUId) SPAWNS it
# as its OWN process, allocates it a kernel wid AFTER spawn (SYS_WSYS_ALLOC
# is hostowner-only, so the wid cannot be an exec argv), and routes
# focus-gated keyboard/pointer events to it via the per-window event files
# /dev/wsys/<wid>/{keys,pointer}. hamterm self-discovers its wid at runtime
# by reading /dev/wsys/self (rendered "<wid>\n" for the CALLING task) — the
# SAME spine the Increment-1 proof (user/hamecho.ad) established — and binds
# the toolkit to it with hamui_window_on() (NOT hamui_window(), which would
# bind the foreground serial-shell's wid 1). Its hamui "ui" markup layer is
# composited LIVE by the compositor at the window body; opening it damages
# ONLY its own window rect (no full-screen recomposite — the historical
# multi-second terminal-open lag bug the rewrite exists to kill). This
# replaces the old IN-DAEMON, hand-drawn APP_TERM grid that conflated the
# terminal into the compositor process.
#
# PERSISTENT INTERACTIVE SHELL (this rewrite)
# -------------------------------------------
# hamterm spawns ONE long-lived `/bin/hamsh` at startup and keeps it
# alive for the whole session, exactly the way user/sshd.ad bridges an
# SSH channel to a shell. Two pipes wire us to it:
#
#   to_sh  : hamterm writes [1]  ->  hamsh reads  [0] as its stdin
#   from_sh: hamsh  writes [1]   ->  hamterm reads [0] as its stdout/err
#
# hamsh is launched with NO rc argument, so it drops into its normal
# interactive read-eval loop (user/hamsh.ad main()). That loop reads
# command lines from fd 0 with sys_read_nb + sys_yield, and — crucially —
# it detects a PIPE-backed stdin (DEVFD_PIPE_R) and SKIPS the getty-style
# first-prompt input flush, so the very first line we feed it is NOT
# eaten (see ed_readline in user/hamsh.ad). Successive commands therefore
# share ONE shell process: cwd (`cd`), environment (`export`), shell
# variables and function defs all persist across commands, like a real
# terminal — not the old one-shot "fresh hamsh per command" capture.
#
# Each event-loop tick we non-blockingly drain from_sh[0] into a growing
# scrollback buffer (the textview content). On Enter / Run we write the
# typed line + '\n' into to_sh[1]; the shell's own prompt and the
# command's stdout/stderr come back over from_sh and land in the
# scrollback. We also echo the typed line locally so the transcript shows
# what was sent even before the shell's prompt catches up.
#
# sys_read_nb on a pipe read-end returns >0 (bytes), 0 (open but empty —
# shell still alive), or -1 (no writers left — the shell exited); see
# fs/vfs.ad::vfs_read_nb. We treat -1 as "shell gone" and stop feeding.
#
# The scrollback is a fixed buffer (no malloc). When it fills we drop the
# OLDEST half and keep the tail, so a long-running terminal never wedges
# on a full buffer — it scrolls, like a real terminal's bounded
# scrollback.

from lib.hamui import (
    hamui_init, hamui_vbox, hamui_hbox, hamui_label, hamui_button,
    hamui_entry, hamui_toolbar, hamui_statusbar, hamui_scrolled,
    hamui_textview, hamui_textview_set, hamui_textview_text, hamui_add,
    hamui_window_on, hamui_focus, hamui_set_size, hamui_set_expand,
    hamui_entry_text, hamui_step, hamui_take_event, hamui_status_set,
    hamui_set_text, hamui_render, hamui_wait, hamui_eof_requested
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_pipe(fds: Ptr[int32]) -> int32
extern def sys_yield()
extern def sys_exit(code: uint64)
# Non-blocking reap (WNOHANG=1): returns -EAGAIN (-11) while the child is
# still alive, otherwise reaps it (status >=0, or -ECHILD if already gone).
extern def sys_waitpid_nb_raw(pid: int32, flags: int64) -> int64
WAITPID_WNOHANG: int64 = 1


# --- module-scope buffers (no malloc; fixed arrays only) -------------
OUTBUF_CAP:  uint64 = 16384
READ_CHUNK:  uint64 = 512

# Accumulated terminal scrollback (what the textview displays).
out_buf:  Array[16384, uint8]
out_len:  uint64 = 0

# Per-read scratch from the shell's stdout pipe.
read_buf: Array[512, uint8]

# Scratch for building the line written to the shell's stdin.
line_buf: Array[1024, uint8]

# argv for spawn: [ "/bin/hamsh", 0 ]  (no rc -> interactive REPL).
spawn_argv: Array[2, uint64]

# Two-fd pipe descriptors (fds[0]=read end, fds[1]=write end).
to_sh:    Array[2, int32]     # hamterm -> hamsh (shell stdin)
from_sh:  Array[2, int32]     # hamsh -> hamterm (shell stdout/err)

# Live shell wiring kept in the parent after spawn.
sh_pid:    int32 = -1
sh_in_fd:  int32 = -1         # write end of to_sh   (feed commands)
sh_out_fd: int32 = -1         # read end of from_sh  (drain output)
sh_alive:  int32 = 0


from lib.p9 import spawn

def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


# Append the unsigned decimal of v at out[pos..]; returns the new position.
def _put_dec(out: Ptr[uint8], pos: uint64, v: uint64) -> uint64:
    if v == 0:
        out[pos] = 48
        return pos + 1
    tmp: Array[20, uint8]
    t: uint64 = 0
    while v != 0:
        tmp[t] = cast[uint8](v % 10) + 48
        v = v / 10
        t = t + 1
    p: uint64 = pos
    while t > 0:
        t = t - 1
        out[p] = tmp[t]
        p = p + 1
    return p


# When the scrollback is full, drop the oldest half and keep the tail so
# the terminal keeps scrolling indefinitely rather than wedging. We try
# to cut on a newline boundary near the midpoint for clean line breaks.
def _out_make_room():
    if out_len < OUTBUF_CAP - 1:
        return
    cut: uint64 = OUTBUF_CAP / 2
    # Advance the cut to just past the next newline so we don't split a
    # line mid-way (cosmetic; bounded scan).
    scan: uint64 = cut
    while scan < out_len and out_buf[scan] != 10:
        scan = scan + 1
    if scan < out_len:
        cut = scan + 1
    # Shift [cut..out_len) down to the front.
    i: uint64 = 0
    while cut + i < out_len:
        out_buf[i] = out_buf[cut + i]
        i = i + 1
    out_len = i
    out_buf[out_len] = 0


# Append a NUL-terminated string to the scrollback.
def _out_append(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        if out_len >= OUTBUF_CAP - 1:
            _out_make_room()
        out_buf[out_len] = s[i]
        out_len = out_len + 1
        i = i + 1
    out_buf[out_len] = 0


# Append raw bytes (a pipe read chunk, which is not NUL terminated).
def _out_append_n(p: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n:
        if out_len >= OUTBUF_CAP - 1:
            _out_make_room()
        out_buf[out_len] = p[i]
        out_len = out_len + 1
        i = i + 1
    out_buf[out_len] = 0


# Spawn the ONE persistent hamsh and keep its stdin/stdout pipe ends.
# Returns 0 on success, -1 on failure.
def _start_shell() -> int32:
    if sys_pipe(&to_sh[0]) != 0:
        _out_append("hamterm: pipe (stdin) failed\n")
        return -1
    if sys_pipe(&from_sh[0]) != 0:
        sys_close(to_sh[0])
        sys_close(to_sh[1])
        _out_append("hamterm: pipe (stdout) failed\n")
        return -1

    spawn_argv[0] = cast[uint64]("/bin/hamsh")
    spawn_argv[1] = 0

    # Child stdin  = read end of to_sh; child stdout = write end of from_sh.
    pid: int32 = spawn(cast[Ptr[char]]("/bin/hamsh"), &spawn_argv[0],
                           to_sh[0], from_sh[1], cast[Ptr[uint64]](0))
    # Close our copies of the ends hamsh now owns. spawn dup'd
    # to_sh[0] -> child fd 0 and from_sh[1] -> child fd 1. If we keep our
    # own copies open, from_sh still has a live writer (us) after hamsh
    # exits, so our EOF probe (sys_read_nb == -1) would never fire.
    sys_close(to_sh[0])
    sys_close(from_sh[1])
    if pid < 0:
        sys_close(to_sh[1])
        sys_close(from_sh[0])
        _out_append("hamterm: spawn hamsh failed\n")
        return -1

    sh_pid = pid
    sh_in_fd = to_sh[1]
    sh_out_fd = from_sh[0]
    sh_alive = 1
    return 0


# Non-blocking drain of the shell's stdout into the scrollback. Returns
# the number of bytes appended this call (0 = nothing ready). Sets
# sh_alive = 0 if the shell has exited (pipe EOF).
def _drain_shell() -> uint64:
    if sh_alive == 0 or sh_out_fd < 0:
        return 0
    got: uint64 = 0
    # Bounded passes per tick so a chatty command can't starve the UI.
    passes: int32 = 0
    while passes < 8:
        n: int64 = sys_read_nb(sh_out_fd, &read_buf[0], READ_CHUNK)
        if n > 0:
            _out_append_n(&read_buf[0], cast[uint64](n))
            got = got + cast[uint64](n)
            passes = passes + 1
            continue
        if n < 0:
            # No writers left — the shell exited.
            sh_alive = 0
        break
    return got


# Feed one command line to the persistent shell's stdin (line + '\n').
# Returns 0 on success, -1 if the shell is gone / write failed.
def _send_line(line: Ptr[uint8]) -> int32:
    if sh_alive == 0 or sh_in_fd < 0:
        return -1
    j: uint64 = 0
    while line[j] != 0 and j < 1022:
        line_buf[j] = line[j]
        j = j + 1
    line_buf[j] = 10                       # '\n'
    j = j + 1
    w: int64 = sys_write(sh_in_fd, &line_buf[0], j)
    if w < 0:
        sh_alive = 0
        return -1
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()

    # --- widget tree -------------------------------------------------
    root: int32 = hamui_vbox()

    # Toolbar: Clear + Quit.
    tbar: int32 = hamui_toolbar()
    hamui_set_size(tbar, 640, 30)
    hamui_add(root, tbar)
    btn_clear: int32 = hamui_button("Clear")
    hamui_add(tbar, btn_clear)
    btn_quit: int32 = hamui_button("Quit")
    hamui_add(tbar, btn_quit)
    hamui_add(tbar, hamui_label("hamterm"))

    # Output area inside a scrolled window so long output clips/scrolls.
    sc: int32 = hamui_scrolled()
    hamui_set_size(sc, 632, 392)
    hamui_set_expand(sc, 1, 1)
    hamui_add(root, sc)
    out_tv: int32 = hamui_textview()
    hamui_set_size(out_tv, 620, 1000)
    hamui_add(sc, out_tv)

    # Command line row: entry + Run.
    cmdrow: int32 = hamui_hbox()
    hamui_set_size(cmdrow, 640, 30)
    hamui_add(root, cmdrow)
    cmd_entry: int32 = hamui_entry()
    hamui_set_size(cmd_entry, 540, 26)
    hamui_set_expand(cmd_entry, 1, 0)
    hamui_add(cmdrow, cmd_entry)
    btn_run: int32 = hamui_button("Run")
    hamui_add(cmdrow, btn_run)

    # Status bar.
    sbar: int32 = hamui_statusbar("ready")
    hamui_set_size(sbar, 640, 20)
    hamui_add(root, sbar)

    # Seed the transcript.
    out_len = 0
    out_buf[0] = 0
    _out_append("hamterm: persistent hamsh. Type a command and press Run.\n")
    hamui_textview_set(out_tv, &out_buf[0])

    # --- discover OUR compositor-allocated wid (the Increment-1 spine) ---
    # The compositor allocates our wid AFTER it spawns us (SYS_WSYS_ALLOC
    # runs post-spawn), so it cannot be handed to us as an exec argv. We
    # learn it at runtime from /dev/wsys/self, which the kernel renders as
    # "<wid>\n" for the CALLING task ("0\n" if we own none). argv[1] is
    # still honoured as an explicit override for standalone runs; a
    # standalone run with neither falls back to wid 1 (the foreground shell).
    wid: int32 = 1
    sp: Ptr[uint8] = "/dev/wsys/self"
    sfd: int32 = sys_open(cast[Ptr[char]](sp))
    if sfd >= 0:
        self_buf: Array[16, uint8]
        sn: int64 = sys_read_nb(sfd, &self_buf[0], 16)
        sys_close(sfd)
        if sn > 0:
            sv: int32 = 0
            si: uint64 = 0
            while si < cast[uint64](sn) and self_buf[si] >= 48 \
                    and self_buf[si] <= 57:
                sv = sv * 10 + cast[int32](self_buf[si]) - 48
                si = si + 1
            if sv >= 2:
                wid = sv
    if argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        v: int32 = 0
        ai: uint64 = 0
        while ap[ai] >= 48 and ap[ai] <= 57:
            v = v * 10 + cast[int32](ap[ai]) - 48
            ai = ai + 1
        if v >= 1:
            wid = v

    bound: int32 = hamui_window_on(root, wid)
    if bound < 0:
        _puts(2, "hamterm: could not bind window\n")
        return 1

    # Seed keyboard focus on the command entry so routed keystrokes land
    # there immediately (no prior mouse click needed); GTK grab-focus shape.
    hamui_focus(cmd_entry)

    # --- start the ONE persistent shell ------------------------------
    if _start_shell() != 0:
        hamui_status_set(sbar, "shell failed")
        hamui_textview_set(out_tv, &out_buf[0])
    else:
        hamui_status_set(sbar, "shell ready")

    # Publish the body markup BEFORE announcing readiness so the compositor
    # never samples an empty "ui" layer when it composites on the "HAMTERM
    # ready" marker.
    hamui_render()

    # "HAMTERM ready wid=<N>\n" — the wid suffix lets a spine/terminal
    # self-test log which wid the child actually bound (self-discovery proof).
    rl: Array[40, uint8]
    rp: uint64 = 0
    rpfx: Ptr[uint8] = "HAMTERM ready wid="
    rk: uint64 = 0
    while rpfx[rk] != 0:
        rl[rp] = rpfx[rk]
        rp = rp + 1
        rk = rk + 1
    rp = _put_dec(&rl[0], rp, cast[uint64](wid))
    rl[rp] = 10
    rp = rp + 1
    sys_write(1, &rl[0], rp)

    # --- event loop --------------------------------------------------
    running: int32 = 1
    sent_count: uint64 = 0
    while running != 0:
        hamui_step()

        # Ctrl-D at the prompt: deliver EOF to the shell by closing OUR write
        # end of its stdin pipe. hamsh's stdin then reads EOF (-1) and exits
        # cleanly, which the waitpid(WNOHANG) probe below observes -> window
        # closes. Exactly like Ctrl-D at a real tty. Guarded so a second
        # Ctrl-D (before the shell is reaped) is a harmless no-op.
        if hamui_eof_requested() != 0 and sh_in_fd >= 0:
            sys_close(sh_in_fd)
            sh_in_fd = -1
            hamui_status_set(sbar, "EOF (Ctrl-D)")

        # Always pump the shell's output first so prompts/results stream
        # live into the scrollback even when the user isn't typing.
        drained: uint64 = _drain_shell()
        if drained > 0:
            hamui_textview_set(out_tv, &out_buf[0])
            hamui_render()
        # Authoritative shell-exit detection: reap the child non-blocking.
        # The pipe-EOF probe in _drain_shell only trips when the stdout
        # pipe's writer refcount reaches zero, which an interactive `exit`
        # or a Ctrl-D-induced stdin EOF does not reliably deliver (a lingering
        # dup of the write end keeps a phantom writer). Polling waitpid(WNOHANG)
        # observes the hamsh PROCESS actually leaving regardless, so BOTH
        # `exit` and Ctrl-D close the window. -EAGAIN (-11) == still running.
        if sh_alive != 0 and sh_pid >= 0:
            wr: int64 = sys_waitpid_nb_raw(sh_pid, WAITPID_WNOHANG)
            if wr != cast[int64](-11):
                sh_alive = 0
        if sh_alive == 0 and sh_pid >= 0:
            # The shell exited (interactive `exit`, Ctrl-D/EOF, or death):
            # hamsh's process returned, closing its stdout write-end, so our
            # EOF probe (_drain_shell sys_read_nb == -1) cleared sh_alive. A
            # real terminal window disappears when its shell exits, so tear
            # OUR window down and quit — the same teardown the Quit button
            # takes (loop exit -> main returns -> process exit; the
            # compositor reaps our wid and destroys the window). We already
            # drained any final output above, so the last bytes are shown.
            sh_pid = -1
            hamui_status_set(sbar, "shell exited")
            hamui_render()
            # Emit a stdout marker so a launcher/self-test that owns OUR
            # stdout pipe can observe the shell-exit -> window-teardown path.
            xm: Ptr[uint8] = "HAMTERM shell-exit; closing window\n"
            sys_write(1, xm, _strlen(xm))
            running = 0

        ev: int32 = hamui_take_event()
        while ev >= 0:
            if ev == btn_quit:
                running = 0
            else:
                if ev == btn_clear:
                    out_len = 0
                    out_buf[0] = 0
                    hamui_textview_set(out_tv, &out_buf[0])
                    hamui_status_set(sbar, "cleared")
                    hamui_render()
                else:
                    # The command runs on either the "Run" button OR Enter
                    # in the entry: the toolkit fires the entry's "activate"
                    # signal on Enter (lib/hamui.ad _h_dispatch_key), so a
                    # routed keystroke stream alone ("ls\n") drives a real
                    # command — no mouse needed.
                    if ev == btn_run or ev == cmd_entry:
                        line: Ptr[uint8] = hamui_entry_text(cmd_entry)
                        if line != cast[Ptr[uint8]](0) and line[0] != 0:
                            # Echo the typed line locally so the transcript
                            # shows what was sent even before the shell's
                            # own prompt streams back.
                            _out_append(line)
                            _out_append("\n")
                            if _send_line(line) == 0:
                                hamui_status_set(sbar, "running")
                                sent_count = sent_count + 1
                            else:
                                _out_append("hamterm: shell is not running\n")
                                hamui_status_set(sbar, "shell exited")
                            # Clear the entry for the next command (real
                            # terminal: the line leaves the input box once
                            # submitted).
                            hamui_set_text(cmd_entry, "")
                            hamui_textview_set(out_tv, &out_buf[0])
                            hamui_render()
                            # Emit a stdout marker so a launcher/self-test
                            # that owns OUR stdout pipe can observe that a
                            # focus-gated command was received and forwarded
                            # to the one persistent /bin/hamsh.
                            ml: Array[48, uint8]
                            mp: uint64 = 0
                            mpfx: Ptr[uint8] = "HAMTERM sent="
                            mk: uint64 = 0
                            while mpfx[mk] != 0:
                                ml[mp] = mpfx[mk]
                                mp = mp + 1
                                mk = mk + 1
                            mp = _put_dec(&ml[0], mp, sent_count)
                            ml[mp] = 10
                            mp = mp + 1
                            sys_write(1, &ml[0], mp)
                            # Re-focus the entry so the next command line is
                            # live for routed keystrokes.
                            hamui_focus(cmd_entry)
            ev = hamui_take_event()
        # Event-driven idle: PARK until a keystroke / pointer event lands on
        # our window OR the shell writes output — instead of the old busy
        # sys_yield() poll. The busy loop stayed permanently STATE_READY and
        # round-robined behind every other polling app (each napping a full
        # ~10 ms scheduler tick in the cooperative-yield hlt), which compounded
        # into the ~0.5 s keystroke->echo lag. hamui_wait sleeps us OFF the
        # runqueue; the compositor's key push (waitfds_notify) wakes us at
        # once, so echo is immediate. A short timeout still bounds the sleep so
        # late shell output / status updates repaint promptly.
        sh_fds: Array[1, int32]
        sh_fds[0] = sh_out_fd
        hamui_wait(&sh_fds[0], 1, 50)

    return 0

# user/hamsnakescene_host.ad — HOST driver + render harness for the Snake
# scene app (built for the x86_64-linux Adder target; runs directly on the
# dev host, no QEMU).
#
# It drives the SAME core the native app ships (lib/hamsnakecore.ad): resets +
# lays out the board, builds the scene display list, and RASTERIZES it with
# lib/hamui_host.ad's parser+font rasterizer into an RGB framebuffer written
# out as a binary PPM a human/agent can LOOK at (scripts/test_hamsnake_host.sh
# converts it to PNG). Then it feeds SCRIPTED input (keyboard "d <code>" lines
# + explicit ticks) through the core's pure handlers and asserts the game state
# evolved: the snake MOVES, eating food GROWS it + scores, a wall hit is GAME
# OVER, and New restarts. It also dumps the raw scene display list + sampled
# pixel colours to stdout so the gate can assert on layout/colour.
#
# USAGE (built to build/host/hamsnake_host):
#   hamsnake_host BEFORE.ppm AFTER.ppm
#   hamsnake_host big OUT.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamsnakecore import hsnake_reset, hsnake_build_scene, \
    hsnake_draw_overlay, hsnake_tick, hsnake_alive, hsnake_gameover, \
    hsnake_len, hsnake_score, hsnake_head_x, hsnake_head_y, \
    hsnake_food_x, hsnake_food_y, hsnake_test_food, hsnake_test_setlen, \
    hsnake_key_line, hsnake_btn_at, hsnake_ctrl_press, hsnake_set_dir


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)                                          # '#'
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    # O_WRONLY|O_CREAT|O_TRUNC = 0x241, mode 0644 = 420.
    fd: int32 = sys_open(path, 577, 420)
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hsnake_build_scene()
    hsnake_draw_overlay()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


# Feed one keyboard press for ASCII byte `code` through the core's key-line
# parser (constructs the "d <code>" wire line the compositor delivers).
kl: Array[16, uint8]


def _press(code: int32) -> int32:
    kl[0] = 100                                        # 'd'
    kl[1] = 32
    p: uint64 = 2
    if code >= 100:
        kl[p] = cast[uint8](code / 100) + 48
        p = p + 1
    if code >= 10:
        kl[p] = cast[uint8]((code / 10) % 10) + 48
        p = p + 1
    kl[p] = cast[uint8](code % 10) + 48
    p = p + 1
    return hsnake_key_line(&kl[0], p)


def _streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] == b[i]:
        return 1
    return 0


def _suf_path(prefix: Ptr[uint8], suffix: Ptr[uint8]) -> Ptr[char]:
    sp: Array[128, uint8]
    p: uint64 = 0
    k: uint64 = 0
    while prefix[k] != 0 and p < 100:
        sp[p] = prefix[k]
        p = p + 1
        k = k + 1
    j: uint64 = 0
    while suffix[j] != 0 and p < 124:
        sp[p] = suffix[j]
        p = p + 1
        j = j + 1
    sp[p] = 0
    return cast[Ptr[char]](&sp[0])


# BIG MODE: render a long-body snake so a human/agent can LOOK at many body
# cells, and report the display-list size so the gate can assert it stays
# BOUNDED below the 16384-byte scene cap.
def _big_main(path: Ptr[char]) -> int32:
    W: int32 = 360
    H: int32 = 470
    hsnake_reset()
    hsnake_test_setlen(16)             # a full-column snake
    hsnake_test_food(2, 2)
    hsnake_build_scene()
    seg: uint64 = hamscene_length()
    hamui_host_begin(W, H)
    prims: int32 = hamui_host_rasterize()
    _write_ppm(path)
    _o_str(cast[Ptr[uint8]]("BIGLEN "))
    _o_dec(cast[int64](hsnake_len()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("BIGSEG "))
    _o_dec(cast[int64](seg))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("BIGPRIMS "))
    _o_dec(cast[int64](prims))
    _o_ch(10)
    _o_flush()
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc >= 3 and _streq(cast[Ptr[uint8]](argv[1]),
                            cast[Ptr[uint8]]("big")) == 1:
        return _big_main(cast[Ptr[char]](argv[2]))

    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hamsnake_host BEFORE.ppm AFTER.ppm\n"))
        _o_str(cast[Ptr[uint8]]("       hamsnake_host big OUT.ppm\n"))
        _o_flush()
        return 2

    W: int32 = 360
    H: int32 = 470

    # DETERMINISTIC: fixed default LCG state, then FORCE the food cell so the
    # render + eat path is reproducible (no clock seed).
    hsnake_reset()
    hsnake_test_food(2, 2)             # a known empty cell (top-left area)

    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))

    # Summary + sampled pixels (proves the RASTERIZER, not just the builder).
    _o_str(cast[Ptr[uint8]]("PRIMS "))
    _o_dec(cast[int64](prims))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("HEADX0 "))
    _o_dec(cast[int64](hsnake_head_x()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("HEADY0 "))
    _o_dec(cast[int64](hsnake_head_y()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("LEN0 "))
    _o_dec(cast[int64](hsnake_len()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SCORE0 "))
    _o_dec(cast[int64](hsnake_score()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("ALIVE0 "))
    _o_dec(cast[int64](hsnake_alive()))
    _o_ch(10)
    # Backdrop pixel (top-left) = window navy #1b1b2e.
    _o_str(cast[Ptr[uint8]]("PIX 4 4 "))
    _o_hexcol(hamui_host_pixel(4, 4))
    _o_ch(10)
    # Board interior empty cell (bottom-left cell 0,15) = board #101024.
    _o_str(cast[Ptr[uint8]]("PIX 25 361 "))
    _o_hexcol(hamui_host_pixel(25, 361))
    _o_ch(10)
    # Head cell (8,8): px = 20+160=180, py = 56+160=216; fill inset +1 -> 181.
    _o_str(cast[Ptr[uint8]]("PIX 186 222 "))
    _o_hexcol(hamui_host_pixel(186, 222))
    _o_ch(10)
    # Food cell (2,2): px=60 py=96, inset +2 -> 62,98 -> sample 66,102.
    _o_str(cast[Ptr[uint8]]("PIX 66 102 "))
    _o_hexcol(hamui_host_pixel(66, 102))
    _o_ch(10)
    _o_flush()

    # Dump the raw scene display list so the gate can assert layout/colour.
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()

    # ---- SCRIPTED INPUT -------------------------------------------------
    # 1) On-screen pointer: a press in the control row must hit-test a button.
    #    _btn_x(1)=84, BTN_W=62 -> x=110 lands on the Up button; CTRL_Y=430.
    b: int64 = hsnake_btn_at(110, 440)
    _o_str(cast[Ptr[uint8]]("BTNAT 110 440 "))
    _o_dec(b)
    _o_ch(10)

    # 2) EAT: head is at (8,8) heading right; food is directly ahead at (9,8).
    #    One tick eats it -> length grows, score rises.
    hsnake_test_food(9, 8)
    hsnake_set_dir(1, 0)
    hsnake_tick()
    _o_str(cast[Ptr[uint8]]("HEADX1 "))
    _o_dec(cast[int64](hsnake_head_x()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("HEADY1 "))
    _o_dec(cast[int64](hsnake_head_y()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("LEN1 "))
    _o_dec(cast[int64](hsnake_len()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SCORE1 "))
    _o_dec(cast[int64](hsnake_score()))
    _o_ch(10)

    # 3) KEYBOARD turn: press 's' (down) via the wire parser, tick, head y+1.
    ky: int32 = _press(115)                            # 's' = down
    hsnake_tick()
    _o_str(cast[Ptr[uint8]]("KEYTURN "))
    _o_dec(cast[int64](ky))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("HEADY2 "))
    _o_dec(cast[int64](hsnake_head_y()))
    _o_ch(10)

    prims2: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _o_str(cast[Ptr[uint8]]("PRIMS2 "))
    _o_dec(cast[int64](prims2))
    _o_ch(10)
    _o_flush()

    # ---- DEATH: run the snake straight into the right wall. --------------
    hsnake_reset()
    hsnake_test_food(0, 0)                             # keep food out of the way
    hsnake_set_dir(1, 0)
    guard: int32 = 0
    while hsnake_alive() != 0 and guard < 64:
        hsnake_tick()
        guard = guard + 1
    _o_str(cast[Ptr[uint8]]("DEATH_ALIVE "))
    _o_dec(cast[int64](hsnake_alive()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("DEATH_GAMEOVER "))
    _o_dec(cast[int64](hsnake_gameover()))
    _o_ch(10)

    # A tick while dead is a no-op (returns 0).
    dead_tick: int32 = hsnake_tick()
    _o_str(cast[Ptr[uint8]]("DEAD_TICK "))
    _o_dec(cast[int64](dead_tick))
    _o_ch(10)

    # ---- SELF-COLLISION: stepping onto a non-tail body cell kills. -------
    # Lay a 6-long column with the head at row 0 and its body directly below
    # (rows 1..5). A DOWN step drives the head onto cell (8,1) — its own neck,
    # a non-tail body cell — which must be a self-collision death.
    hsnake_test_setlen(6)             # column at col 8, rows 0..5, head row0
    hsnake_test_food(15, 15)
    hsnake_set_dir(0, 1)
    surv: int32 = hsnake_tick()
    _o_str(cast[Ptr[uint8]]("SELFHIT_TICK "))
    _o_dec(cast[int64](surv))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SELFHIT_ALIVE "))
    _o_dec(cast[int64](hsnake_alive()))
    _o_ch(10)

    # ---- RESTART via the New button clears game over. --------------------
    hsnake_reset()
    hsnake_set_dir(1, 0)
    g2: int32 = 0
    while hsnake_alive() != 0 and g2 < 64:
        hsnake_tick()
        g2 = g2 + 1
    hsnake_ctrl_press(0)              # New
    _o_str(cast[Ptr[uint8]]("NEW_ALIVE "))
    _o_dec(cast[int64](hsnake_alive()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("NEW_GAMEOVER "))
    _o_dec(cast[int64](hsnake_gameover()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("NEW_LEN "))
    _o_dec(cast[int64](hsnake_len()))
    _o_ch(10)
    _o_flush()
    return 0

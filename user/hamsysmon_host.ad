# user/hamsysmon_host.ad — HOST render gate (x86_64-linux, no QEMU) for the
# reworked MATE/Task-Manager System Monitor. It exercises the SHIPPED cores:
#
#   * lib/hammoncore.ad  — the APP: total + per-core CPU% history graph, a
#     memory history graph, and a PID/CPU%/COMMAND process list.
#   * lib/sysmonspark.ad — the panel APPLET's rolling CPU+memory sparkline.
#
# It feeds synthetic samples (deterministic, no /proc), rasterizes each scene
# to a PPM via lib/hamui_host.ad, and prints COUNT lines the driving shell
# asserts on: the CPU graph must contain white (total) + green (per-core)
# strokes, the memory graph must contain blue columns, and the process list
# must contain the amber "hot process" row. Also emits PNG-ready PPMs to VIEW.

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hammoncore import hammon_set_uptime, hammon_set_mem, \
    hammon_tasks_clear, hammon_proc_add, hammon_build_scene, \
    hammon_set_win_size, hammon_set_cpu_total, hammon_set_core, \
    hammon_set_ncores
from lib.sysmonspark import sysmon_spark


obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


ppm_hdr: Array[64, uint8]
path_buf: Array[256, uint8]


def _pstr(pos: uint64, s: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while s[i] != 0:
        path_buf[pos] = s[i]
        pos = pos + 1
        i = i + 1
    return pos


def _write_ppm(dir: Ptr[uint8], name: Ptr[uint8]):
    p: uint64 = _pstr(0, dir)
    p = _pstr(p, cast[Ptr[uint8]]("/"))
    p = _pstr(p, name)
    p = _pstr(p, cast[Ptr[uint8]](".ppm"))
    path_buf[p] = 0
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]), 577, 420)
    if fd < 0:
        return
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)


# --- pixel-channel predicates over a scanned rect --------------------
def _r(px: uint32) -> int64:
    return cast[int64]((px >> 16) & 255)


def _g(px: uint32) -> int64:
    return cast[int64]((px >> 8) & 255)


def _b(px: uint32) -> int64:
    return cast[int64](px & 255)


def _is_whiteish(px: uint32) -> int32:
    if _r(px) > 220 and _g(px) > 220 and _b(px) > 220:
        return 1
    return 0


def _is_greenish(px: uint32) -> int32:
    if _g(px) > 150 and _r(px) < 150 and _b(px) < 150:
        return 1
    return 0


def _is_blueish(px: uint32) -> int32:
    if _b(px) > 180 and _r(px) < 140 and _g(px) > 90 and _g(px) < 200:
        return 1
    return 0


def _is_amber(px: uint32) -> int32:
    if _r(px) > 195 and _g(px) > 140 and _g(px) < 205 and _b(px) < 140:
        return 1
    return 0


# Count pixels in [x0,y0,w,h] matching predicate `kind`
#   0=white 1=green 2=blue 3=amber
def _count(kind: int32, x0: int32, y0: int32, w: int32, h: int32) -> int64:
    total: int64 = 0
    yy: int32 = y0
    while yy < y0 + h:
        xx: int32 = x0
        while xx < x0 + w:
            px: uint32 = hamui_host_pixel(xx, yy)
            hit: int32 = 0
            if kind == 0:
                hit = _is_whiteish(px)
            elif kind == 1:
                hit = _is_greenish(px)
            elif kind == 2:
                hit = _is_blueish(px)
            else:
                hit = _is_amber(px)
            if hit != 0:
                total = total + 1
            xx = xx + 1
        yy = yy + 1
    return total


def _report(tag: Ptr[uint8], v: int64):
    _o_str(cast[Ptr[uint8]]("COUNT "))
    _o_str(tag)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)
    _o_flush()


# ====================================================================
# APP scene: feed a history of synthetic samples, then render.
# ====================================================================
def _feed_app():
    hammon_set_uptime(3661)                              # 1:01:01
    hammon_set_ncores(2)
    # Push ~30 history samples so the graphs have a real scrolling trace.
    i: uint64 = 0
    while i < 30:
        # Total CPU sweeps 10..95%; cores phase-shifted so both lines show.
        tot: int32 = 10 + cast[int32]((i * 85) / 29)
        hammon_set_cpu_total(tot)
        hammon_set_core(0, 20 + cast[int32]((i * 60) / 29))
        c1: int32 = 90 - cast[int32]((i * 70) / 29)
        hammon_set_core(1, c1)
        # Memory climbs 30..80%.
        mt: uint64 = 2048000
        mu: uint64 = (mt * cast[uint64](30 + (i * 50) / 29)) / 100
        hammon_set_mem(mt, mu)
        i = i + 1
    # Process list: one HOT process (>50% -> amber) among calmer ones.
    hammon_tasks_clear()
    hammon_proc_add(1, cast[Ptr[uint8]]("init"), 4)
    hammon_proc_add(2, cast[Ptr[uint8]]("hamUId"), 11)
    hammon_proc_add(42, cast[Ptr[uint8]]("hammonscene"), 73)
    hammon_proc_add(7, cast[Ptr[uint8]]("hamsh"), 22)


def _render_app(dir: Ptr[uint8]):
    W: int32 = 440
    H: int32 = 540
    hammon_set_win_size(W, H)
    hammon_build_scene()
    hamui_host_begin(W, H)
    hamui_host_rasterize()
    _write_ppm(dir, cast[Ptr[uint8]]("sysmon_app"))
    # CPU graph occupies roughly x[11..W-11], y[63..145].
    _report(cast[Ptr[uint8]]("app_cpu_white"), _count(0, 12, 63, W - 24, 82))
    _report(cast[Ptr[uint8]]("app_cpu_green"), _count(1, 12, 63, W - 24, 82))
    # Memory graph sits below the CPU legend/label; scan a generous band.
    _report(cast[Ptr[uint8]]("app_mem_blue"), _count(2, 12, 150, W - 24, 130))
    # Process list starts at y~251 (hot amber row near y~279); scan that band.
    _report(cast[Ptr[uint8]]("app_proc_amber"), _count(3, 8, 245, W - 16, 70))


# ====================================================================
# APPLET sparkline: synthetic rings -> sysmon_spark.
# ====================================================================
spark_cpu: Array[48, uint8]
spark_mem: Array[48, uint8]


def _render_applet(dir: Ptr[uint8]):
    n: uint64 = 40
    i: uint64 = 0
    while i < n:
        spark_cpu[i] = cast[uint8](15 + (i * 80) / 39)
        spark_mem[i] = cast[uint8](70 - (i * 45) / 39)
        i = i + 1
    W: int32 = 120
    H: int32 = 28
    hamui_host_begin(W, H)
    sysmon_spark(&spark_cpu[0], &spark_mem[0], n, 48, 2, 2, 112, 24)
    hamui_host_rasterize()
    _write_ppm(dir, cast[Ptr[uint8]]("sysmon_applet"))
    _report(cast[Ptr[uint8]]("applet_cpu_green"), _count(1, 2, 2, 112, 24))
    _report(cast[Ptr[uint8]]("applet_mem_blue"), _count(2, 2, 2, 112, 24))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        _o_str(cast[Ptr[uint8]]("usage: hamsysmon_host OUTDIR\n"))
        _o_flush()
        return 2
    dir: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    _feed_app()
    _render_app(dir)
    _render_applet(dir)
    return 0

# user/haminstallui.ad
#
# Scene-file DE visual installer — a GUI FRONT-END over the proven
# /bin/install on-target package installer (docs/de_scene_file_arch.md).
# It does NOT reinvent partitioning / format / rootfs lay-down: it collects
# the install parameters and shells out to `install --auto`, exactly like the
# unattended /etc/install_nvme.hamsh path does, but interactively.
#
# WHAT IT COLLECTS:
#   (a) a system / host NAME       — a text-input field (typed via /keys).
#   (b) the TARGET DRIVE           — a selectable list of detected disks
#                                    with their capacity. Whole disks only
#                                    (partitions filtered out); the live-root
#                                    disk (/dev/blk/rootdev) is excluded so
#                                    the installer can never target itself.
#   (c) an ONLINE-REPO toggle      — when checked AND a network is up, install
#                                    from the online HPM repo; else fall back
#                                    to the local in-RAM repo (the default).
#   then a CONFIRM button that:
#       1. writes the host NAME to /etc/hostname (best-effort), and
#       2. spawns `/bin/install --auto <disk> --repo <url>` with stdout
#          redirected to a log, then streams that log into a PROGRESS pane
#          (auto-scrolling) until the child exits.
#
# `install` does the real work — GPT partition (hamnix_partition), mkfs the
# ESP (FAT) + root (ext4), stream the ESP boot files from the in-RAM squashfs
# (sqfs_to_blk), then install the native system as PACKAGES via
# `hpm install hamnix-base` onto the fresh ext4 root (kernel install_file ctl
# path) — a real Debian-style package install, NOT a dd/golden block copy and
# NOT the manifest copy from /n/distros. It refuses the live-root disk in the
# KERNEL guard, so this GUI is a thin, safe driver.
#
# RENDER: a titled window with a NAME entry, a disk LIST, a Confirm button,
# and a status/progress area. Drawn with the lib/hamui hamscene_* helpers
# and committed to /dev/wsys/<wid>/scene. INPUT (§11): pointer on /event
# (select a disk / hit Confirm), text on /keys (type the host name).

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32
extern def sys_waitpid(pid: int32) -> int64
extern def sys_pipechan() -> int32
extern def sys_fdbind(pid: int32, fdnum: int32, kind: int32, slot: int32) -> int32

from lib.p9 import spawn, p9_listdir

# Spawn stdio-namespace sentinel + sys_fdbind kinds (mirrors hamtermscene).
# The install child's stdout AND stderr are routed through a pipe we drain
# non-blocking, so EVERY line the installer prints (incl. the FAIL lines it
# writes to stderr) reaches the progress pane. The previous design redirected
# only fd 1 to a file via an integer-fd dup2 (which lib/p9 spawn silently
# skips when the fd number is >= 16) and dropped stderr entirely — so a real
# install failure printed only to fd 2, the pane froze on "installing from
# repo ...", and the install "hung" forever with no further output.
SPAWN_STDIO_NS: int32 = -2
DEVFD_CONS:     int32 = 1
DEVFD_PIPE_R:   int32 = 2
DEVFD_PIPE_W:   int32 = 3
INST_OUT_FD:    int32 = 12        # our scratch /fd name for the stdout READ end
from lib.hamui import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_stroke, hamscene_glyphs, hamscene_panel_button, hamscene_commit


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def strcpy_ui(dst: Ptr[uint8], src: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while src[i] != 0:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0
    return i


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# ====================================================================
# DISK ENUMERATION
# ====================================================================
# Read /dev/blk: one "NAME\n" per node (whole disks AND partitions). Keep
# only WHOLE disks (a name that is a strict prefix of another, or simply has
# no trailing 'pN' partition suffix on a base name that also appears). We use
# a simpler, robust rule matching lsblk/haminstall conventions: a partition
# name contains 'p' followed only by digits to end (e.g. nvme0n1p2, vdap1);
# everything else is a whole disk. Exclude the live-root disk via rootdev.

MAX_DISKS: uint64 = 12
disk_name: Array[384, uint8]          # MAX_DISKS * 32
disk_namelen: Array[12, uint64]
disk_sectors: Array[12, uint64]       # capacity in 512-byte sectors
n_disks: uint64 = 0


def disk_name_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&disk_name[0]) + i * 32)


# Is `name` (len nl) a partition node? Heuristic: it contains a 'p' that is
# followed only by decimal digits up to the end (matching the GPT child
# naming the installer tools use: <disk>p<num>).
def _is_partition(name: Ptr[uint8], nl: uint64) -> int32:
    # Scan for the LAST 'p' that has only digits after it.
    i: uint64 = 0
    while i < nl:
        if name[i] == 0x70:                              # 'p'
            j: uint64 = i + 1
            alldig: int32 = 1
            if j >= nl:
                alldig = 0
            while j < nl:
                if name[j] < 48 or name[j] > 57:
                    alldig = 0
                j = j + 1
            if alldig == 1:
                return 1
        i = i + 1
    return 0


root_disk: Array[32, uint8]
root_disk_len: uint64 = 0
def _read_rootdev():
    root_disk_len = 0
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/blk/rootdev"))
    if fd < 0:
        return
    buf: Array[32, uint8]
    n: int64 = sys_read(fd, &buf[0], 31)
    sys_close(fd)
    if n <= 0:
        return
    ln: uint64 = cast[uint64](n)
    while ln > 0 and (buf[ln - 1] == 10 or buf[ln - 1] == 13
                      or buf[ln - 1] == 32):
        ln = ln - 1
    i: uint64 = 0
    while i < ln and i < 31:
        root_disk[i] = buf[i]
        i = i + 1
    root_disk_len = ln


def _name_eq(a: Ptr[uint8], al: uint64, b: Ptr[uint8], bl: uint64) -> int32:
    if al != bl:
        return 0
    i: uint64 = 0
    while i < al:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# Read /dev/blk/<name>/size -> capacity in 512-byte sectors (0 on failure).
sizepath: Array[96, uint8]
def _read_size(name: Ptr[uint8], nl: uint64) -> uint64:
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/blk/")
    k: uint64 = 0
    while pre[k] != 0:
        sizepath[p] = pre[k]
        p = p + 1
        k = k + 1
    k = 0
    while k < nl:
        sizepath[p] = name[k]
        p = p + 1
        k = k + 1
    suf: Ptr[uint8] = cast[Ptr[uint8]]("/size")
    k = 0
    while suf[k] != 0:
        sizepath[p] = suf[k]
        p = p + 1
        k = k + 1
    sizepath[p] = 0
    fd: int32 = sys_open(cast[Ptr[char]](&sizepath[0]))
    if fd < 0:
        return 0
    sbuf: Array[32, uint8]
    n: int64 = sys_read(fd, &sbuf[0], 31)
    sys_close(fd)
    if n <= 0:
        return 0
    v: uint64 = 0
    i: uint64 = 0
    while i < cast[uint64](n) and sbuf[i] >= 48 and sbuf[i] <= 57:
        v = v * 10 + cast[uint64](sbuf[i]) - 48
        i = i + 1
    return v


lsbuf: Array[4096, uint8]
def _enumerate_disks():
    n_disks = 0
    _read_rootdev()
    n: int64 = p9_listdir(cast[Ptr[char]]("/dev/blk"), &lsbuf[0], 4096)
    if n < 0:
        return
    nm: Array[32, uint8]
    nl: uint64 = 0
    i: uint64 = 0
    total: uint64 = cast[uint64](n)
    while i < total:
        c: uint8 = lsbuf[i]
        if c == 10:
            if nl > 0:
                # Skip the rootdev pseudo-file + partitions + the live root.
                is_meta: int32 = 0
                if _name_eq(&nm[0], nl, cast[Ptr[uint8]]("rootdev"), 7) != 0:
                    is_meta = 1
                if _name_eq(&nm[0], nl, cast[Ptr[uint8]]("ctl"), 3) != 0:
                    is_meta = 1
                if is_meta == 0 and _is_partition(&nm[0], nl) == 0:
                    is_root: int32 = 0
                    if root_disk_len > 0 and \
                       _name_eq(&nm[0], nl, &root_disk[0], root_disk_len) != 0:
                        is_root = 1
                    if is_root == 0 and n_disks < MAX_DISKS:
                        dp: Ptr[uint8] = disk_name_ptr(n_disks)
                        k: uint64 = 0
                        while k < nl:
                            dp[k] = nm[k]
                            k = k + 1
                        dp[nl] = 0
                        disk_namelen[n_disks] = nl
                        disk_sectors[n_disks] = _read_size(&nm[0], nl)
                        n_disks = n_disks + 1
            nl = 0
        else:
            if nl < 31:
                nm[nl] = c
                nl = nl + 1
        i = i + 1


# ====================================================================
# NETWORK DETECTION (for the optional online package repo)
# ====================================================================
# Mirror hampanel._probe_net: read #I /net/ipifc/ctl (Plan-9) or the
# Linux-shim /proc/net/dev, and treat the net as "up" if we see an IPv4
# dotted literal in the snapshot. Result drives whether the online-repo
# checkbox is enabled + honored. Sets the module-global `net_up`.
netprobe_buf: Array[512, uint8]
def _probe_net():
    new_up: int32 = 0
    paths: Array[2, uint64]
    paths[0] = cast[uint64](cast[Ptr[char]]("/net/ipifc/ctl"))
    paths[1] = cast[uint64](cast[Ptr[char]]("/proc/net/dev"))
    pi: int32 = 0
    while pi < 2:
        fd: int32 = sys_open(cast[Ptr[char]](paths[pi]))
        if fd >= 0:
            nb: int64 = sys_read(fd, &netprobe_buf[0], 511)
            sys_close(fd)
            if nb > 0:
                k: int64 = 0
                while k < nb:
                    # An IPv4 dotted literal: a digit, then '.', then a digit.
                    if netprobe_buf[k] == 46 and k > 0 and k + 1 < nb:
                        pc: uint8 = netprobe_buf[k - 1]
                        nc: uint8 = netprobe_buf[k + 1]
                        if pc >= 48 and pc <= 57 and nc >= 48 and nc <= 57:
                            new_up = 1
                    k = k + 1
        pi = pi + 1
    net_up = new_up


# Render a sector count as a human size string "<n> MiB" / "<n> GiB" into out
# (NUL-terminated). 512 bytes/sector.
def _fmt_size(sectors: uint64, out: Ptr[uint8]):
    # bytes = sectors * 512.  MiB = bytes / 2^20 = sectors / 2048.
    mib: uint64 = sectors / 2048
    p: uint64 = 0
    if mib >= 1024:
        gib: uint64 = mib / 1024
        frac: uint64 = ((mib % 1024) * 10) / 1024
        p = p + _u64_to_dec(gib, &out[p])
        out[p] = 46                                       # '.'
        p = p + 1
        p = p + _u64_to_dec(frac, &out[p])
        out[p] = 32
        out[p+1] = 71                                     # 'G'
        out[p+2] = 105
        out[p+3] = 66                                     # 'iB'
        out[p+4] = 0
    else:
        p = p + _u64_to_dec(mib, &out[p])
        out[p] = 32
        out[p+1] = 77                                     # 'M'
        out[p+2] = 105
        out[p+3] = 66                                     # 'iB'
        out[p+4] = 0


# ====================================================================
# HOST NAME ENTRY
# ====================================================================
HOSTNAME_CAP: uint64 = 30
hostname_buf: Array[32, uint8]
hostname_len: uint64 = 0


def _hostname_default():
    # Seed with "hamnix".
    seed: Ptr[uint8] = cast[Ptr[uint8]]("hamnix")
    i: uint64 = 0
    while seed[i] != 0:
        hostname_buf[i] = seed[i]
        i = i + 1
    hostname_buf[i] = 0
    hostname_len = i


# Accept a typed byte into the host-name field. Returns 1 if it changed.
def _hostname_key(c: uint8) -> int32:
    if c == 8 or c == 127:                                # Backspace / DEL
        if hostname_len > 0:
            hostname_len = hostname_len - 1
            hostname_buf[hostname_len] = 0
            return 1
        return 0
    # Allow letters, digits, '-' (valid hostname chars).
    ok: int32 = 0
    if c >= 48 and c <= 57:
        ok = 1
    if c >= 65 and c <= 90:
        ok = 1
    if c >= 97 and c <= 122:
        ok = 1
    if c == 45:                                           # '-'
        ok = 1
    if ok == 1 and hostname_len < HOSTNAME_CAP:
        hostname_buf[hostname_len] = c
        hostname_len = hostname_len + 1
        hostname_buf[hostname_len] = 0
        return 1
    return 0


def _write_hostname():
    if hostname_len == 0:
        return
    fd: int32 = sys_open_write(cast[Ptr[char]]("/etc/hostname"))
    if fd < 0:
        return
    sys_write(fd, &hostname_buf[0], hostname_len)
    sys_write(fd, cast[Ptr[uint8]]("\n"), 1)
    sys_close(fd)


# ====================================================================
# STATE + LAYOUT
# ====================================================================
WIN_W: int32 = 420
WIN_H: int32 = 440

sel_disk: int64 = -1            # selected disk index, or -1
# UI phase: 0 = collecting inputs, 1 = installing, 2 = done, 3 = error.
phase: int32 = 0

# Online-repo toggle. When set AND a network is up, the install sources
# packages from the online HPM repo (--repo=<ONLINE_REPO_URL>); otherwise
# it falls back to the in-RAM local repo (file:///iso-packages). Local is
# always the default + the fallback so an offline install still works.
use_online: int32 = 0           # 1 = prefer the online repo when up
net_up:     int32 = 0           # 1 = a network interface has an IP
net_poll:   int32 = 0           # loop-tick counter for periodic net re-probe

# Disk-list geometry.
LIST_X: int32 = 16
LIST_Y: int32 = 116
ROW_H: int32 = 26
NAME_X: int32 = 16
NAME_Y: int32 = 56
NAME_W: int32 = 388
NAME_H: int32 = 26
CONFIRM_X: int32 = 16
CONFIRM_W: int32 = 140
CONFIRM_H: int32 = 30
# Online-repo checkbox (rendered to the right of the Confirm button).
ONLINE_X: int32 = 172
ONLINE_W: int32 = 232
ONLINE_BOX: int32 = 16


def _confirm_y() -> int32:
    return LIST_Y + cast[int32](n_disks) * ROW_H + 16


def _status_y() -> int32:
    return _confirm_y() + CONFIRM_H + 14


# Progress log ring. We retain the last PROG_LINES streamed lines and the
# renderer shows the tail that fits the content rect (auto-scroll-to-latest),
# so install output NEVER runs off the window. PROG_W is wide enough for the
# installer's "[install] (N/5) ..." lines at the pane's ~48-glyph width.
PROG_LINES: uint64 = 24
PROG_W: uint64 = 62
PROG_GLYPH_W: uint64 = 6              # px per glyph (panel font)
PROG_LINE_H: int32 = 12              # px per progress line
prog_text: Array[1488, uint8]         # PROG_LINES * PROG_W
prog_n: uint64 = 0                    # number of live lines (<= PROG_LINES)


def prog_line_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&prog_text[0]) + i * PROG_W)


def _prog_push(s: Ptr[uint8], n: uint64):
    # Append one line; scroll the ring up by one when full so the newest
    # line is always retained (the renderer then shows the visible tail).
    if prog_n >= PROG_LINES:
        i: uint64 = 1
        while i < PROG_LINES:
            src: Ptr[uint8] = prog_line_ptr(i)
            dst: Ptr[uint8] = prog_line_ptr(i - 1)
            k: uint64 = 0
            while k < PROG_W:
                dst[k] = src[k]
                k = k + 1
            i = i + 1
        prog_n = PROG_LINES - 1
    dl: Ptr[uint8] = prog_line_ptr(prog_n)
    cn: uint64 = n
    if cn > PROG_W - 1:
        cn = PROG_W - 1
    k2: uint64 = 0
    while k2 < cn:
        dl[k2] = s[k2]
        k2 = k2 + 1
    dl[cn] = 0
    prog_n = prog_n + 1


# ====================================================================
# RENDER
# ====================================================================
def emit_scene(wid: int32):
    hamscene_begin()
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#d4d0c8"))
    # Title banner.
    hamscene_fill(0, 0, WIN_W, 28, cast[Ptr[uint8]]("#3a6ea5"))
    hamscene_glyphs(12, 9, cast[Ptr[uint8]]("Install Hamnix"),
                    cast[Ptr[uint8]]("#ffffff"))

    # --- host NAME field ---
    hamscene_glyphs(NAME_X, 40, cast[Ptr[uint8]]("System name:"),
                    cast[Ptr[uint8]]("#202020"))
    hamscene_fill(NAME_X, NAME_Y, NAME_W, NAME_H, cast[Ptr[uint8]]("#ffffff"))
    hamscene_stroke(NAME_X, NAME_Y, NAME_W, NAME_H, 1,
                    cast[Ptr[uint8]]("#808080"))
    hamscene_glyphs(NAME_X + 6, NAME_Y + 9, &hostname_buf[0],
                    cast[Ptr[uint8]]("#202020"))
    # Caret after the text (only while collecting inputs).
    if phase == 0:
        cx: int32 = NAME_X + 6 + cast[int32](hostname_len) * 8
        hamscene_fill(cx, NAME_Y + 6, 1, 14, cast[Ptr[uint8]]("#202020"))

    # --- target DRIVE list ---
    hamscene_glyphs(LIST_X, 98, cast[Ptr[uint8]]("Target drive:"),
                    cast[Ptr[uint8]]("#202020"))
    if n_disks == 0:
        hamscene_glyphs(LIST_X + 8, LIST_Y + 6,
                        cast[Ptr[uint8]]("(no installable disks found)"),
                        cast[Ptr[uint8]]("#a02020"))
    else:
        i: uint64 = 0
        while i < n_disks:
            ry: int32 = LIST_Y + cast[int32](i) * ROW_H
            face: Ptr[uint8] = cast[Ptr[uint8]]("#eceae4")
            if sel_disk == cast[int64](i):
                face = cast[Ptr[uint8]]("#3a6ea5")
            hamscene_fill(LIST_X, ry, NAME_W, ROW_H - 2, face)
            hamscene_stroke(LIST_X, ry, NAME_W, ROW_H - 2, 1,
                            cast[Ptr[uint8]]("#a0a0a0"))
            txtcol: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
            if sel_disk == cast[int64](i):
                txtcol = cast[Ptr[uint8]]("#ffffff")
            # "<name>   <size>"
            row: Array[64, uint8]
            p: uint64 = 0
            dp: Ptr[uint8] = disk_name_ptr(i)
            k: uint64 = 0
            while dp[k] != 0 and p < 16:
                row[p] = dp[k]
                p = p + 1
                k = k + 1
            while p < 16:
                row[p] = 32
                p = p + 1
            _fmt_size(disk_sectors[i], &row[p])
            hamscene_glyphs(LIST_X + 8, ry + 6, &row[0], txtcol)
            i = i + 1

    # --- Confirm button ---
    cy: int32 = _confirm_y()
    ready: int32 = 0
    if phase == 0 and sel_disk >= 0 and hostname_len > 0:
        ready = 1
    btnface: Ptr[uint8] = cast[Ptr[uint8]]("#c8c4bc")
    if ready == 0:
        btnface = cast[Ptr[uint8]]("#bdbab4")
    hamscene_fill(CONFIRM_X, cy, CONFIRM_W, CONFIRM_H, btnface)
    hamscene_stroke(CONFIRM_X, cy, CONFIRM_W, CONFIRM_H, 1,
                    cast[Ptr[uint8]]("#606060"))
    btnlbl: Ptr[uint8] = cast[Ptr[uint8]]("Install")
    btncol: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    if ready == 0 and phase == 0:
        btncol = cast[Ptr[uint8]]("#808080")
    if phase == 1:
        btnlbl = cast[Ptr[uint8]]("Installing...")
    hamscene_glyphs(CONFIRM_X + 14, cy + 9, btnlbl, btncol)

    # --- online-repo checkbox (to the right of Confirm) ---
    # When checked AND a network is up, the install pulls packages from the
    # online HPM repo; otherwise it falls back to the local in-RAM repo.
    obx: int32 = ONLINE_X
    oby: int32 = cy + (CONFIRM_H - ONLINE_BOX) / 2
    boxface: Ptr[uint8] = cast[Ptr[uint8]]("#ffffff")
    if phase != 0:
        boxface = cast[Ptr[uint8]]("#d8d4cc")
    hamscene_fill(obx, oby, ONLINE_BOX, ONLINE_BOX, boxface)
    hamscene_stroke(obx, oby, ONLINE_BOX, ONLINE_BOX, 1,
                    cast[Ptr[uint8]]("#606060"))
    if use_online != 0:
        # Draw a check (an 'X'-ish fill) inside the box.
        hamscene_fill(obx + 4, oby + 4, ONLINE_BOX - 8, ONLINE_BOX - 8,
                      cast[Ptr[uint8]]("#3a6ea5"))
    olbl: Ptr[uint8] = cast[Ptr[uint8]]("Use online repo if available")
    ocol: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    if net_up == 0:
        olbl = cast[Ptr[uint8]]("Use online repo (no network detected)")
        ocol = cast[Ptr[uint8]]("#808080")
    hamscene_glyphs(obx + ONLINE_BOX + 6, cy + 9, olbl, ocol)

    # --- status / progress area ---
    sy: int32 = _status_y()
    ph: int32 = WIN_H - sy - 12              # progress pane height (px)
    hamscene_fill(LIST_X, sy, NAME_W, ph, cast[Ptr[uint8]]("#101418"))
    hamscene_stroke(LIST_X, sy, NAME_W, ph, 1, cast[Ptr[uint8]]("#404040"))
    if phase == 0:
        hamscene_glyphs(LIST_X + 6, sy + 6,
                        cast[Ptr[uint8]]("Pick a disk + name, then Install."),
                        cast[Ptr[uint8]]("#80c080"))
    else:
        # Auto-scroll: show only the tail of the log that fits the pane.
        # Reserve the bottom row for the phase-2/3 status line.
        avail_px: int32 = ph - 12 - 22
        vis: uint64 = 1
        if avail_px > 0:
            vis = cast[uint64](avail_px / PROG_LINE_H)
        if vis < 1:
            vis = 1
        first: uint64 = 0
        if prog_n > vis:
            first = prog_n - vis              # drop the oldest lines
        li: uint64 = first
        row_i: int32 = 0
        while li < prog_n:
            hamscene_glyphs(LIST_X + 6,
                            sy + 6 + row_i * PROG_LINE_H,
                            prog_line_ptr(li), cast[Ptr[uint8]]("#80d080"))
            row_i = row_i + 1
            li = li + 1
    if phase == 2:
        hamscene_glyphs(LIST_X + 6, WIN_H - 26,
                        cast[Ptr[uint8]]("Install complete - reboot to disk."),
                        cast[Ptr[uint8]]("#a0e0a0"))
    if phase == 3:
        hamscene_glyphs(LIST_X + 6, WIN_H - 26,
                        cast[Ptr[uint8]]("Install FAILED - see log above."),
                        cast[Ptr[uint8]]("#e08080"))

    hamscene_commit(wid)


# ====================================================================
# RUN THE REAL INSTALL (front-end over /bin/install — package-based)
# ====================================================================
# The GUI drives the SAME Debian-style package installer the unattended
# /etc/install_nvme.hamsh path uses: `/bin/install --auto <disk> --repo <url>`.
# That command partitions the disk, mkfs's the ESP + ext4 root, streams the
# ESP boot files from the in-RAM squashfs (sqfs_to_blk), then installs the
# native system as PACKAGES via `hpm install hamnix-base` onto the fresh ext4
# root (kernel install_file ctl path), NOT a dd/golden block copy and NOT the
# manifest copy from /n/distros. The kernel /dev/blk/rootdev guard inside
# `install` still refuses the live-root disk, so the GUI stays a thin driver.
ONLINE_REPO_URL: Array[64, uint8]      # filled in main() (hpm's hosted repo)
LOCAL_REPO_URL:  Array[32, uint8]      # filled in main() (file:///iso-packages)
inst_argv: Array[8, uint64]
inst_disk: Array[32, uint8]
inst_repo: Array[96, uint8]            # the --repo value actually used
install_pid: int32 = -1
inst_out_fd: int32 = -1                 # read end of the install stdout/stderr pipe
inst_eof: int32 = 0                     # 1 once the child closed the pipe (drained)


def _begin_install():
    # Write the host name first (best-effort), then spawn the package-based
    # installer with stdout/stderr -> a log we stream into the progress pane.
    _write_hostname()
    di: uint64 = cast[uint64](sel_disk)
    dp: Ptr[uint8] = disk_name_ptr(di)
    k: uint64 = 0
    while dp[k] != 0:
        inst_disk[k] = dp[k]
        k = k + 1
    inst_disk[k] = 0

    # Choose the package repo: online if the user opted in AND a network is
    # up, else the local in-RAM repo. Local is the default AND the fallback.
    src: Ptr[uint8] = &LOCAL_REPO_URL[0]
    if use_online != 0 and net_up != 0:
        src = &ONLINE_REPO_URL[0]
    ri: uint64 = 0
    while src[ri] != 0:
        inst_repo[ri] = src[ri]
        ri = ri + 1
    inst_repo[ri] = 0

    # argv: /bin/install --auto <disk> --repo <url>
    inst_argv[0] = cast[uint64](cast[Ptr[uint8]]("/bin/install"))
    inst_argv[1] = cast[uint64](cast[Ptr[uint8]]("--auto"))
    inst_argv[2] = cast[uint64](&inst_disk[0])
    inst_argv[3] = cast[uint64](cast[Ptr[uint8]]("--repo"))
    inst_argv[4] = cast[uint64](&inst_repo[0])
    inst_argv[5] = 0

    # Capture the install child's stdout AND stderr through a single pipe we
    # drain non-blocking in _poll_log. We hold the READ end at our scratch
    # /fd/12 name; the child's fd 1 and fd 2 are fdbind'd to the WRITE end
    # (via SPAWN_STDIO_NS, the child routes 0/1/2 through /fd names that our
    # post-spawn binds retarget — the child is STATE_READY until we yield, so
    # the binds land before its first instruction). This replaces the old
    # "redirect fd 1 to a /tmp file" path, which dropped stderr and silently
    # failed to redirect at all when the file's fd number was >= 16.
    out_slot: int32 = sys_pipechan()
    if out_slot < 0:
        _prog_push(cast[Ptr[uint8]]("pipechan FAILED"), 15)
        phase = 3
        return
    sys_fdbind(0, INST_OUT_FD, DEVFD_PIPE_R, out_slot)
    inst_out_fd = sys_open(cast[Ptr[char]]("/fd/12"))
    if inst_out_fd < 0:
        _prog_push(cast[Ptr[uint8]]("open pipe read end FAILED"), 25)
        phase = 3
        return
    inst_eof = 0
    pid: int32 = spawn(cast[Ptr[char]]("/bin/install"), &inst_argv[0],
                       SPAWN_STDIO_NS, SPAWN_STDIO_NS, cast[Ptr[uint64]](0))
    install_pid = pid
    prog_n = 0
    if pid < 0:
        _prog_push(cast[Ptr[uint8]]("spawn /bin/install FAILED"), 25)
        phase = 3
        return
    # Wire the child's stdout (fd 1) and stderr (fd 2) to the pipe WRITE end so
    # ALL installer output — including the "[install] FAIL ..." lines it writes
    # to stderr — streams into the progress pane. fd 0 (stdin) is left routed
    # to its /fd/0 name; --auto never reads it.
    sys_fdbind(pid, 1, DEVFD_PIPE_W, out_slot)
    sys_fdbind(pid, 2, DEVFD_PIPE_W, out_slot)
    phase = 1
    if use_online != 0 and net_up != 0:
        _prog_push(cast[Ptr[uint8]]("installing from ONLINE repo..."), 30)
    else:
        _prog_push(cast[Ptr[uint8]]("installing from local repo..."), 29)


# Poll the install log: push any new complete lines into the progress pane.
# Returns 1 if the progress text changed (caller re-emits the scene).
# Substring search: does s[0..n) contain the NUL-terminated needle?
def _line_has(s: Ptr[uint8], n: uint64, needle: Ptr[uint8]) -> int32:
    nl: uint64 = _slen(needle)
    if nl == 0 or nl > n:
        return 0
    i: uint64 = 0
    while i + nl <= n:
        m: uint64 = 0
        while m < nl and s[i + m] == needle[m]:
            m = m + 1
        if m == nl:
            return 1
        i = i + 1
    return 0


# Push one complete line into the pane and watch for the installer's terminal
# markers. Returns 1 if a marker flipped the phase or text was pushed.
def _emit_install_line(s: Ptr[uint8], n: uint64):
    if n == 0:
        return
    _prog_push(s, n)
    if _line_has(s, n, cast[Ptr[uint8]]("install complete")) != 0:
        phase = 2
    if _line_has(s, n, cast[Ptr[uint8]]("FAIL")) != 0:
        phase = 3


# Partial-line carry: pipe reads split lines arbitrarily, so we accumulate
# bytes here until we see a newline (or the child closes the pipe / EOF).
logbuf:  Array[4096, uint8]
linebuf: Array[512, uint8]
line_len: uint64 = 0


def _line_carry(c: uint8):
    if c == 10:
        _emit_install_line(&linebuf[0], line_len)
        line_len = 0
        return
    if line_len < 511:
        linebuf[line_len] = c
        line_len = line_len + 1


# Drain the install child's stdout/stderr pipe NON-BLOCKING. We never call
# sys_waitpid (that would freeze the UI for the whole install); the child's
# own "[install] install complete" / "FAIL" markers move us to the done/error
# phase. A clean pipe EOF (read returns 0 after the child exits) flushes any
# trailing partial line and, if we never saw a terminal marker, surfaces that
# the installer exited without completing rather than hanging on the last line.
def _poll_log() -> int32:
    if inst_out_fd < 0 or inst_eof != 0:
        return 0
    changed: int32 = 0
    drained: int32 = 0
    while drained < 16:
        r: int64 = sys_read_nb(inst_out_fd, &logbuf[0], 4096)
        if r == 0:
            break                       # would-block: writers open, empty now
        if r < 0:
            # Pipe EOF (-1): the install child closed both fds (exited). Flush
            # any trailing partial line, then mark the stream done.
            if line_len > 0:
                _emit_install_line(&linebuf[0], line_len)
                line_len = 0
                changed = 1
            inst_eof = 1
            sys_close(inst_out_fd)
            inst_out_fd = -1
            # Release our scratch /fd/12 reader bind so the pipe Chan is
            # reclaimed (re-binding it to console drops the last pipe ref).
            sys_fdbind(0, INST_OUT_FD, DEVFD_CONS, 0)
            if phase == 1:
                # Child exited but we never saw a completion/FAIL marker.
                _prog_push(cast[Ptr[uint8]](
                    "installer exited without 'install complete' - see log"), 53)
                phase = 3
            changed = 1
            break
        i: uint64 = 0
        while i < cast[uint64](r):
            _line_carry(logbuf[i])
            i = i + 1
        changed = 1
        drained = drained + 1
    return changed


# ====================================================================
# INPUT
# ====================================================================
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                             # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc = acc * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc = 0 - acc
        vals[v] = acc
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1


btn_down: int32 = 0
def _handle_click(x: int64, y: int64) -> int32:
    if phase != 0:
        return 0
    # Disk row?
    if x >= cast[int64](LIST_X) and x < cast[int64](LIST_X + NAME_W):
        i: uint64 = 0
        while i < n_disks:
            ry: int64 = cast[int64](LIST_Y) + cast[int64](i) * cast[int64](ROW_H)
            if y >= ry and y < ry + cast[int64](ROW_H - 2):
                sel_disk = cast[int64](i)
                return 1
            i = i + 1
    # Confirm button?
    cy: int64 = cast[int64](_confirm_y())
    if x >= cast[int64](CONFIRM_X) and x < cast[int64](CONFIRM_X + CONFIRM_W) \
            and y >= cy and y < cy + cast[int64](CONFIRM_H):
        if sel_disk >= 0 and hostname_len > 0:
            _begin_install()
            return 1
    # Online-repo checkbox? (only togglable when a network is up.)
    if x >= cast[int64](ONLINE_X) \
            and x < cast[int64](ONLINE_X + ONLINE_W) \
            and y >= cy and y < cy + cast[int64](CONFIRM_H):
        if net_up != 0:
            if use_online != 0:
                use_online = 0
            else:
                use_online = 1
            return 1
    return 0


# Parse one "<type> <code>" key line; on a press ('d') apply it to the host
# name field. Returns 1 on change.
def _key_line(s: Ptr[uint8], n: uint64) -> int32:
    if phase != 0:
        return 0
    if n < 1 or s[0] != 100:                             # 'd' press only
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    neg: int32 = 0
    if i < n and s[i] == 45:
        neg = 1
        i = i + 1
    code: int32 = 0
    got: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        code = code * 10 + cast[int32](s[i]) - 48
        i = i + 1
        got = 1
    if got == 0:
        return 0
    if neg != 0:
        code = 0 - code
    if code < 0 or code > 255:
        return 0
    return _hostname_key(cast[uint8](code))


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[haminstallui] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp: Array[64, uint8]
    keysp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        geo: Array[64, uint8]
        gp: uint64 = 0
        pre: Ptr[uint8] = cast[Ptr[uint8]]("geometry 200 90 ")
        a: uint64 = 0
        while pre[a] != 0:
            geo[gp] = pre[a]
            gp = gp + 1
            a = a + 1
        gp = gp + _u64_to_dec(cast[uint64](WIN_W), &geo[gp])
        geo[gp] = 32
        gp = gp + 1
        gp = gp + _u64_to_dec(cast[uint64](WIN_H), &geo[gp])
        geo[gp] = 10
        gp = gp + 1
        sys_write(cfd, &geo[0], gp)
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("title Install Hamnix\n"))
        sys_close(cfd3)
    cfd4: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd4 >= 0:
        _writeall(cfd4, cast[Ptr[uint8]]("z 7\n"))
        sys_close(cfd4)

    # Seed the online-repo URL (hpm's canonical hosted repo) + detect net.
    # Local file:///iso-packages stays the default/fallback; the user opts
    # into the online repo via the checkbox, which is only live when net_up.
    strcpy_ui(&ONLINE_REPO_URL[0], cast[Ptr[uint8]]("https://255.one/"))
    strcpy_ui(&LOCAL_REPO_URL[0], cast[Ptr[uint8]]("file:///iso-packages"))

    _hostname_default()
    _enumerate_disks()
    _probe_net()
    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[haminstallui] scene window ready\n"))

    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))

    evbuf: Array[256, uint8]
    kbuf: Array[256, uint8]
    while True:
        changed: int32 = 0
        # Keyboard (host name).
        if kfd >= 0:
            kr: int64 = sys_read_nb(kfd, &kbuf[0], 255)
            if kr > 0:
                kls: uint64 = 0
                ki: uint64 = 0
                while ki <= cast[uint64](kr):
                    katend: int32 = 0
                    if ki == cast[uint64](kr):
                        katend = 1
                    if katend == 1 or kbuf[ki] == 10:
                        if ki > kls:
                            if _key_line(&kbuf[kls], ki - kls) == 1:
                                changed = 1
                        kls = ki + 1
                    ki = ki + 1
        # Pointer.
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            r: int64 = sys_read(efd, &evbuf[0], 255)
            sys_close(efd)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            bx: int64 = 0
                            by: int64 = 0
                            bbtn: int64 = 0
                            if parse_pointer(&evbuf[ls], i - ls, &bx, &by,
                                             &bbtn) == 1:
                                nd: int32 = 0
                                if (bbtn & 1) != 0:
                                    nd = 1
                                if nd == 1 and btn_down == 0:
                                    if _handle_click(bx, by) == 1:
                                        changed = 1
                                btn_down = nd
                        ls = i + 1
                    i = i + 1
        # Poll install progress. We do NOT block on sys_waitpid (that would
        # freeze the UI for the whole install); _poll_log streams the child's
        # output and flips phase to 2/3 when it sees the installer's terminal
        # "install complete" / "FAIL" markers.
        if phase == 1:
            if _poll_log() == 1:
                changed = 1
        # While collecting inputs, re-probe the network occasionally so the
        # online-repo checkbox lights up if a link comes up after launch.
        if phase == 0:
            net_poll = net_poll + 1
            if net_poll >= 64:
                net_poll = 0
                prev_up: int32 = net_up
                _probe_net()
                if net_up != prev_up:
                    if net_up == 0:
                        use_online = 0     # link dropped — fall back to local
                    changed = 1
        if changed != 0:
            emit_scene(wid)
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 3:
            sys_yield()
    return 0

# user/haminstallui.ad
#
# Scene-file DE visual installer — a Debian-installer-style MULTI-PAGE
# WIZARD front-end over the proven /bin/install on-target package
# installer (docs/de_scene_file_arch.md). It does NOT reinvent
# partitioning / format / rootfs lay-down: it collects the install
# parameters across a sequence of pages and shells out to
# `install --auto ... <flags>`, exactly like the unattended
# /etc/install_nvme.hamsh path does, but interactively.
#
# WIZARD PAGES (Back / Next navigation; Install on the last page):
#   0. System (host) name          — text field.
#   1. Install user's username     — text field (the uid-1000 regular
#                                    account created on the target).
#   2. Install user's password     — password + confirm.
#   3. Host-owner (admin) password — password + confirm (uid 1).
#   4. Partition manager           — the target DISK picker + a
#                                    guided-whole-disk (default) vs
#                                    manual layout choice + an
#                                    online-repo toggle. Guided and
#                                    manual both drive the same
#                                    GPT+ESP+ext4 layout the installer
#                                    already writes; manual additionally
#                                    exposes the ESP size (MiB).
#   5. Summary                     — review, then Install: spawns
#                                    `/bin/install --auto <disk> --repo
#                                    <url> --esp-mb <n> --part-mode <m>
#                                    --hostname <h> --user <u>
#                                    --user-pass <p> --root-pass <p>`
#                                    and streams its stdout/stderr into a
#                                    progress pane until the child exits.
#
# HOW INPUTS REACH THE INSTALLED SYSTEM. The wizard passes every value
# as a flag to `/bin/install`. install.ad, after the base package
# install lays down the target root, WRITES the collected values onto
# the TARGET ext4 partition (NOT the live root) via the `<dev>/ctl
# install_file` verb: /etc/hostname, a composed /etc/passwd (hostowner +
# the chosen uid-1000 user), and /etc/shadow with $6$ hashes generated
# from the typed passwords (lib/crypt sha512_crypt — the same scheme the
# kernel /dev/auth setpass verb produces). See install.ad provision_*.
#
# `install` still does the real disk work — GPT partition, mkfs ESP+root,
# stream the ESP from the in-RAM squashfs, and `hpm install hamnix-base`
# onto the fresh ext4 root — and still refuses the live-root disk in the
# KERNEL guard, so this GUI stays a thin, safe driver.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32
extern def sys_waitpid(pid: int32) -> int64
extern def sys_pipechan() -> int32
extern def sys_fdbind(pid: int32, fdnum: int32, kind: int32, slot: int32) -> int32

from lib.p9 import spawn, p9_listdir

# Spawn stdio-namespace sentinel + sys_fdbind kinds (mirrors hamtermscene).
# The install child's stdout AND stderr are routed through a pipe we drain
# non-blocking, so EVERY line the installer prints (incl. the FAIL lines it
# writes to stderr) reaches the progress pane.
SPAWN_STDIO_NS: int32 = -2
DEVFD_CONS:     int32 = 1
DEVFD_PIPE_R:   int32 = 2
DEVFD_PIPE_W:   int32 = 3
INST_OUT_FD:    int32 = 12        # our scratch /fd name for the stdout READ end
from lib.hamui import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_stroke, hamscene_glyphs, hamscene_panel_button, hamscene_commit


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def strcpy_ui(dst: Ptr[uint8], src: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while src[i] != 0:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0
    return i


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# ====================================================================
# DISK ENUMERATION  (unchanged from the single-screen installer)
# ====================================================================
MAX_DISKS: uint64 = 12
disk_name: Array[384, uint8]          # MAX_DISKS * 32
disk_namelen: Array[12, uint64]
disk_sectors: Array[12, uint64]       # capacity in 512-byte sectors
n_disks: uint64 = 0


def disk_name_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&disk_name[0]) + i * 32)


def _is_partition(name: Ptr[uint8], nl: uint64) -> int32:
    i: uint64 = 0
    while i < nl:
        if name[i] == 0x70:                              # 'p'
            j: uint64 = i + 1
            alldig: int32 = 1
            if j >= nl:
                alldig = 0
            while j < nl:
                if name[j] < 48 or name[j] > 57:
                    alldig = 0
                j = j + 1
            if alldig == 1:
                return 1
        i = i + 1
    return 0


root_disk: Array[32, uint8]
root_disk_len: uint64 = 0
def _read_rootdev():
    root_disk_len = 0
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/blk/rootdev"))
    if fd < 0:
        return
    buf: Array[32, uint8]
    n: int64 = sys_read(fd, &buf[0], 31)
    sys_close(fd)
    if n <= 0:
        return
    ln: uint64 = cast[uint64](n)
    while ln > 0 and (buf[ln - 1] == 10 or buf[ln - 1] == 13
                      or buf[ln - 1] == 32):
        ln = ln - 1
    i: uint64 = 0
    while i < ln and i < 31:
        root_disk[i] = buf[i]
        i = i + 1
    root_disk_len = ln


def _name_eq(a: Ptr[uint8], al: uint64, b: Ptr[uint8], bl: uint64) -> int32:
    if al != bl:
        return 0
    i: uint64 = 0
    while i < al:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


sizepath: Array[96, uint8]
def _read_size(name: Ptr[uint8], nl: uint64) -> uint64:
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/blk/")
    k: uint64 = 0
    while pre[k] != 0:
        sizepath[p] = pre[k]
        p = p + 1
        k = k + 1
    k = 0
    while k < nl:
        sizepath[p] = name[k]
        p = p + 1
        k = k + 1
    suf: Ptr[uint8] = cast[Ptr[uint8]]("/size")
    k = 0
    while suf[k] != 0:
        sizepath[p] = suf[k]
        p = p + 1
        k = k + 1
    sizepath[p] = 0
    fd: int32 = sys_open(cast[Ptr[char]](&sizepath[0]))
    if fd < 0:
        return 0
    sbuf: Array[32, uint8]
    n: int64 = sys_read(fd, &sbuf[0], 31)
    sys_close(fd)
    if n <= 0:
        return 0
    v: uint64 = 0
    i: uint64 = 0
    while i < cast[uint64](n) and sbuf[i] >= 48 and sbuf[i] <= 57:
        v = v * 10 + cast[uint64](sbuf[i]) - 48
        i = i + 1
    return v


bm_sector0: Array[512, uint8]
bm_partpath: Array[96, uint8]
def _bytes_eq(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


def _is_boot_medium(name: Ptr[uint8], nl: uint64) -> int32:
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/blk/")
    k: uint64 = 0
    while pre[k] != 0:
        bm_partpath[p] = pre[k]
        p = p + 1
        k = k + 1
    k = 0
    while k < nl:
        bm_partpath[p] = name[k]
        p = p + 1
        k = k + 1
    bm_partpath[p] = 0x70                                 # 'p'
    p = p + 1
    bm_partpath[p] = 49                                   # '1'
    p = p + 1
    bm_partpath[p] = 0
    fd: int32 = sys_open(cast[Ptr[char]](&bm_partpath[0]))
    if fd < 0:
        return 0
    n: int64 = sys_read(fd, &bm_sector0[0], 512)
    sys_close(fd)
    if n < 512:
        return 0
    tag: Ptr[uint8] = cast[Ptr[uint8]]("HAMNIXINST")
    if _bytes_eq(cast[Ptr[uint8]](cast[uint64](&bm_sector0[0]) + 43),
                 tag, 10) == 1:
        return 1
    if _bytes_eq(cast[Ptr[uint8]](cast[uint64](&bm_sector0[0]) + 71),
                 tag, 10) == 1:
        return 1
    return 0


def _name_has_prefix(name: Ptr[uint8], prefix: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while prefix[i] != 0:
        if name[i] != prefix[i]:
            return 0
        i = i + 1
    return 1


def _is_ram_backed(name: Ptr[uint8]) -> int32:
    if _name_has_prefix(name, cast[Ptr[uint8]]("ram")) == 1:
        return 1
    if _name_has_prefix(name, cast[Ptr[uint8]]("loop")) == 1:
        return 1
    if _name_has_prefix(name, cast[Ptr[uint8]]("live")) == 1:
        return 1
    return 0


lsbuf: Array[4096, uint8]
def _enumerate_disks():
    n_disks = 0
    _read_rootdev()
    n: int64 = p9_listdir(cast[Ptr[char]]("/dev/blk"), &lsbuf[0], 4096)
    if n < 0:
        return
    nm: Array[32, uint8]
    nl: uint64 = 0
    i: uint64 = 0
    total: uint64 = cast[uint64](n)
    while i < total:
        c: uint8 = lsbuf[i]
        if c == 10:
            if nl > 0:
                is_meta: int32 = 0
                if _name_eq(&nm[0], nl, cast[Ptr[uint8]]("rootdev"), 7) != 0:
                    is_meta = 1
                if _name_eq(&nm[0], nl, cast[Ptr[uint8]]("ctl"), 3) != 0:
                    is_meta = 1
                if is_meta == 0 and _is_partition(&nm[0], nl) == 0:
                    is_root: int32 = 0
                    if root_disk_len > 0 and \
                       _name_eq(&nm[0], nl, &root_disk[0], root_disk_len) != 0:
                        is_root = 1
                    if is_root == 0 and _is_ram_backed(&nm[0]) != 0:
                        is_root = 1
                    if is_root == 0 and _is_boot_medium(&nm[0], nl) != 0:
                        is_root = 1
                    if is_root == 0 and n_disks < MAX_DISKS:
                        dp: Ptr[uint8] = disk_name_ptr(n_disks)
                        k: uint64 = 0
                        while k < nl:
                            dp[k] = nm[k]
                            k = k + 1
                        dp[nl] = 0
                        disk_namelen[n_disks] = nl
                        disk_sectors[n_disks] = _read_size(&nm[0], nl)
                        n_disks = n_disks + 1
            nl = 0
        else:
            if nl < 31:
                nm[nl] = c
                nl = nl + 1
        i = i + 1


# ====================================================================
# NETWORK DETECTION (for the optional online package repo)
# ====================================================================
netprobe_buf: Array[512, uint8]
net_up:     int32 = 0
net_poll:   int32 = 0
def _probe_net():
    new_up: int32 = 0
    paths: Array[2, uint64]
    paths[0] = cast[uint64](cast[Ptr[char]]("/net/ipifc/ctl"))
    paths[1] = cast[uint64](cast[Ptr[char]]("/proc/net/dev"))
    pi: int32 = 0
    while pi < 2:
        fd: int32 = sys_open(cast[Ptr[char]](paths[pi]))
        if fd >= 0:
            nb: int64 = sys_read(fd, &netprobe_buf[0], 511)
            sys_close(fd)
            if nb > 0:
                k: int64 = 0
                while k < nb:
                    if netprobe_buf[k] == 46 and k > 0 and k + 1 < nb:
                        pc: uint8 = netprobe_buf[k - 1]
                        nc: uint8 = netprobe_buf[k + 1]
                        if pc >= 48 and pc <= 57 and nc >= 48 and nc <= 57:
                            new_up = 1
                    k = k + 1
        pi = pi + 1
    net_up = new_up


def _fmt_size(sectors: uint64, out: Ptr[uint8]):
    mib: uint64 = sectors / 2048
    p: uint64 = 0
    if mib >= 1024:
        gib: uint64 = mib / 1024
        frac: uint64 = ((mib % 1024) * 10) / 1024
        p = p + _u64_to_dec(gib, &out[p])
        out[p] = 46                                       # '.'
        p = p + 1
        p = p + _u64_to_dec(frac, &out[p])
        out[p] = 32
        out[p+1] = 71                                     # 'G'
        out[p+2] = 105
        out[p+3] = 66                                     # 'iB'
        out[p+4] = 0
    else:
        p = p + _u64_to_dec(mib, &out[p])
        out[p] = 32
        out[p+1] = 77                                     # 'M'
        out[p+2] = 105
        out[p+3] = 66                                     # 'iB'
        out[p+4] = 0


# ====================================================================
# WIZARD STATE — pages + text fields
# ====================================================================
PAGE_HOST:    int32 = 0
PAGE_USER:    int32 = 1
PAGE_UPASS:   int32 = 2
PAGE_RPASS:   int32 = 3
PAGE_DISK:    int32 = 4
PAGE_SUMMARY: int32 = 5
N_PAGES:      int32 = 6

# Char-class filters for text fields.
CLS_HOST:  int32 = 0        # [A-Za-z0-9-]
CLS_USER:  int32 = 1        # [A-Za-z0-9_-]
CLS_PW:    int32 = 2        # any printable
CLS_DIGIT: int32 = 3        # [0-9]

page:  int32 = 0
focus: int32 = 0            # sub-field focus (password pages: 0=first,1=confirm)

# UI phase: 0 = collecting, 1 = installing, 2 = done, 3 = error.
phase: int32 = 0

# Text field buffers + lengths.
HOST_CAP: uint64 = 30
NAME_CAP: uint64 = 30
PW_CAP:   uint64 = 60
host_buf:  Array[64, uint8]
user_buf:  Array[64, uint8]
upass_buf: Array[64, uint8]
upass2_buf: Array[64, uint8]
rpass_buf: Array[64, uint8]
rpass2_buf: Array[64, uint8]
espmb_buf: Array[16, uint8]
host_len:  uint64 = 0
user_len:  uint64 = 0
upass_len: uint64 = 0
upass2_len: uint64 = 0
rpass_len: uint64 = 0
rpass2_len: uint64 = 0
espmb_len: uint64 = 0

sel_disk: int64 = -1        # selected disk index, or -1
part_mode: int32 = 0        # 0 = guided (whole disk), 1 = manual
use_online: int32 = 0       # 1 = prefer the online repo when up

mask_buf: Array[64, uint8]


def _seed_defaults():
    host_len = strcpy_ui(&host_buf[0], cast[Ptr[uint8]]("hamnix"))
    user_buf[0] = 0
    user_len = 0
    upass_buf[0] = 0
    upass2_buf[0] = 0
    rpass_buf[0] = 0
    rpass2_buf[0] = 0
    espmb_len = strcpy_ui(&espmb_buf[0], cast[Ptr[uint8]]("64"))


def _mask(n: uint64) -> Ptr[uint8]:
    i: uint64 = 0
    while i < n and i < 63:
        mask_buf[i] = 42                                  # '*'
        i = i + 1
    mask_buf[i] = 0
    return &mask_buf[0]


def _char_ok(c: uint8, cls: int32) -> int32:
    if cls == CLS_PW:
        if c >= 32 and c <= 126:
            return 1
        return 0
    if cls == CLS_DIGIT:
        if c >= 48 and c <= 57:
            return 1
        return 0
    # host / user
    if c >= 48 and c <= 57:
        return 1
    if c >= 65 and c <= 90:
        return 1
    if c >= 97 and c <= 122:
        return 1
    if c == 45:                                           # '-'
        return 1
    if cls == CLS_USER and c == 95:                       # '_'
        return 1
    return 0


def _field_key(buf: Ptr[uint8], lenp: Ptr[uint64], cap: uint64,
               c: uint8, cls: int32) -> int32:
    if c == 8 or c == 127:                                # Backspace / DEL
        if lenp[0] > 0:
            lenp[0] = lenp[0] - 1
            buf[lenp[0]] = 0
            return 1
        return 0
    if _char_ok(c, cls) == 0:
        return 0
    if lenp[0] < cap:
        buf[lenp[0]] = c
        lenp[0] = lenp[0] + 1
        buf[lenp[0]] = 0
        return 1
    return 0


def _apply_key(c: uint8) -> int32:
    # Route a typed byte to the active field on the current page.
    if c == 9:                                            # Tab
        if page == PAGE_UPASS or page == PAGE_RPASS:
            if focus == 0:
                focus = 1
            else:
                focus = 0
            return 1
        return 0
    if page == PAGE_HOST:
        return _field_key(&host_buf[0], &host_len, HOST_CAP, c, CLS_HOST)
    if page == PAGE_USER:
        return _field_key(&user_buf[0], &user_len, NAME_CAP, c, CLS_USER)
    if page == PAGE_UPASS:
        if focus == 0:
            return _field_key(&upass_buf[0], &upass_len, PW_CAP, c, CLS_PW)
        return _field_key(&upass2_buf[0], &upass2_len, PW_CAP, c, CLS_PW)
    if page == PAGE_RPASS:
        if focus == 0:
            return _field_key(&rpass_buf[0], &rpass_len, PW_CAP, c, CLS_PW)
        return _field_key(&rpass2_buf[0], &rpass2_len, PW_CAP, c, CLS_PW)
    if page == PAGE_DISK:
        if part_mode == 1:
            return _field_key(&espmb_buf[0], &espmb_len, 6, c, CLS_DIGIT)
    return 0


def _streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while True:
        if a[i] != b[i]:
            return 0
        if a[i] == 0:
            return 1
        i = i + 1
    return 0


def _page_ready() -> int32:
    # 1 if the current page's inputs are valid enough to advance.
    if page == PAGE_HOST:
        if host_len > 0:
            return 1
        return 0
    if page == PAGE_USER:
        if user_len > 0:
            return 1
        return 0
    if page == PAGE_UPASS:
        if upass_len > 0 and _streq(&upass_buf[0], &upass2_buf[0]) == 1:
            return 1
        return 0
    if page == PAGE_RPASS:
        if rpass_len > 0 and _streq(&rpass_buf[0], &rpass2_buf[0]) == 1:
            return 1
        return 0
    if page == PAGE_DISK:
        if sel_disk >= 0:
            return 1
        return 0
    if page == PAGE_SUMMARY:
        return 1
    return 0


# ====================================================================
# LAYOUT
# ====================================================================
WIN_W: int32 = 440
WIN_H: int32 = 470
HDR_H: int32 = 28
CONTENT_X: int32 = 20
FIELD_W: int32 = 400
FIELD_H: int32 = 26
FOOTER_H: int32 = 30


def _footer_y() -> int32:
    return WIN_H - 14 - FOOTER_H


BACK_X: int32 = 20
BACK_W: int32 = 96
def _next_x() -> int32:
    return WIN_W - 20 - 120
NEXT_W: int32 = 120

# Disk-list geometry (PAGE_DISK).
DLIST_X: int32 = 20
DLIST_Y: int32 = 78
DROW_H: int32 = 24
def _radio_y() -> int32:
    return DLIST_Y + cast[int32](n_disks) * DROW_H + 12
RESCAN_X: int32 = 20
RESCAN_W: int32 = 110
RESCAN_H: int32 = 26


# ====================================================================
# INSTALL PROGRESS RING
# ====================================================================
PROG_LINES: uint64 = 24
PROG_W: uint64 = 62
PROG_LINE_H: int32 = 12
prog_text: Array[1488, uint8]         # PROG_LINES * PROG_W
prog_n: uint64 = 0


def prog_line_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&prog_text[0]) + i * PROG_W)


def _prog_push(s: Ptr[uint8], n: uint64):
    if prog_n >= PROG_LINES:
        i: uint64 = 1
        while i < PROG_LINES:
            src: Ptr[uint8] = prog_line_ptr(i)
            dst: Ptr[uint8] = prog_line_ptr(i - 1)
            k: uint64 = 0
            while k < PROG_W:
                dst[k] = src[k]
                k = k + 1
            i = i + 1
        prog_n = PROG_LINES - 1
    dl: Ptr[uint8] = prog_line_ptr(prog_n)
    cn: uint64 = n
    if cn > PROG_W - 1:
        cn = PROG_W - 1
    k2: uint64 = 0
    while k2 < cn:
        dl[k2] = s[k2]
        k2 = k2 + 1
    dl[cn] = 0
    prog_n = prog_n + 1


# ====================================================================
# RENDER HELPERS
# ====================================================================
def _draw_input(x: int32, y: int32, w: int32, label: Ptr[uint8],
                text: Ptr[uint8], tlen: uint64, is_pw: int32,
                active: int32):
    hamscene_glyphs(x, y - 16, label, cast[Ptr[uint8]]("#202020"))
    hamscene_fill(x, y, w, FIELD_H, cast[Ptr[uint8]]("#ffffff"))
    bord: Ptr[uint8] = cast[Ptr[uint8]]("#808080")
    if active != 0:
        bord = cast[Ptr[uint8]]("#3584e4")
    hamscene_stroke(x, y, w, FIELD_H, 1, bord)
    shown: Ptr[uint8] = text
    if is_pw != 0:
        shown = _mask(tlen)
    hamscene_glyphs(x + 6, y + 9, shown, cast[Ptr[uint8]]("#202020"))
    if active != 0 and phase == 0:
        cx: int32 = x + 6 + cast[int32](tlen) * 8
        hamscene_fill(cx, y + 6, 1, 14, cast[Ptr[uint8]]("#202020"))


def _draw_button(x: int32, y: int32, w: int32, label: Ptr[uint8],
                 enabled: int32):
    face: Ptr[uint8] = cast[Ptr[uint8]]("#e6e8ec")
    col: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    if enabled == 0:
        face = cast[Ptr[uint8]]("#bdbab4")
        col = cast[Ptr[uint8]]("#808080")
    hamscene_fill(x, y, w, FOOTER_H, face)
    hamscene_stroke(x, y, w, FOOTER_H, 1, cast[Ptr[uint8]]("#606060"))
    hamscene_glyphs(x + 16, y + 9, label, col)


def _draw_radio(x: int32, y: int32, on: int32, label: Ptr[uint8]):
    hamscene_fill(x, y, 14, 14, cast[Ptr[uint8]]("#ffffff"))
    hamscene_stroke(x, y, 14, 14, 1, cast[Ptr[uint8]]("#606060"))
    if on != 0:
        hamscene_fill(x + 3, y + 3, 8, 8, cast[Ptr[uint8]]("#3584e4"))
    hamscene_glyphs(x + 22, y + 3, label, cast[Ptr[uint8]]("#202020"))


# ====================================================================
# RENDER
# ====================================================================
def _page_title(out_wid: int32):
    t: Ptr[uint8] = cast[Ptr[uint8]]("")
    if page == PAGE_HOST:
        t = cast[Ptr[uint8]]("Step 1 of 5: System name")
    if page == PAGE_USER:
        t = cast[Ptr[uint8]]("Step 2 of 5: Create your user")
    if page == PAGE_UPASS:
        t = cast[Ptr[uint8]]("Step 3 of 5: User password")
    if page == PAGE_RPASS:
        t = cast[Ptr[uint8]]("Step 4 of 5: Administrator password")
    if page == PAGE_DISK:
        t = cast[Ptr[uint8]]("Step 5 of 5: Disk & partitioning")
    if page == PAGE_SUMMARY:
        t = cast[Ptr[uint8]]("Review & install")
    hamscene_glyphs(CONTENT_X, 40, t, cast[Ptr[uint8]]("#202020"))


sumrow: Array[80, uint8]
def _emit_summary_row(y: int32, label: Ptr[uint8], value: Ptr[uint8]):
    hamscene_glyphs(CONTENT_X, y, label, cast[Ptr[uint8]]("#606060"))
    hamscene_glyphs(CONTENT_X + 150, y, value, cast[Ptr[uint8]]("#202020"))


def emit_scene(wid: int32):
    hamscene_begin()
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#eceef2"))
    hamscene_fill(0, 0, WIN_W, HDR_H, cast[Ptr[uint8]]("#3584e4"))
    hamscene_glyphs(12, 9, cast[Ptr[uint8]]("Install Hamnix"),
                    cast[Ptr[uint8]]("#ffffff"))
    _page_title(wid)

    if page == PAGE_HOST:
        _draw_input(CONTENT_X, 92, FIELD_W,
                    cast[Ptr[uint8]]("System (host) name:"),
                    &host_buf[0], host_len, 0, 1)
        hamscene_glyphs(CONTENT_X, 140,
                cast[Ptr[uint8]]("Names the installed machine (/etc/hostname)."),
                cast[Ptr[uint8]]("#606060"))
    elif page == PAGE_USER:
        _draw_input(CONTENT_X, 92, FIELD_W,
                    cast[Ptr[uint8]]("Your username (regular user, uid 1000):"),
                    &user_buf[0], user_len, 0, 1)
        hamscene_glyphs(CONTENT_X, 140,
                cast[Ptr[uint8]]("Letters, digits, '-' and '_'. This is your"),
                cast[Ptr[uint8]]("#606060"))
        hamscene_glyphs(CONTENT_X, 154,
                cast[Ptr[uint8]]("everyday login on the installed system."),
                cast[Ptr[uint8]]("#606060"))
    elif page == PAGE_UPASS:
        af0: int32 = 0
        af1: int32 = 0
        if focus == 0:
            af0 = 1
        else:
            af1 = 1
        _draw_input(CONTENT_X, 92, FIELD_W,
                    cast[Ptr[uint8]]("Password:"),
                    &upass_buf[0], upass_len, 1, af0)
        _draw_input(CONTENT_X, 156, FIELD_W,
                    cast[Ptr[uint8]]("Confirm password:"),
                    &upass2_buf[0], upass2_len, 1, af1)
        if upass_len > 0 and _streq(&upass_buf[0], &upass2_buf[0]) == 0:
            hamscene_glyphs(CONTENT_X, 196,
                    cast[Ptr[uint8]]("Passwords do not match."),
                    cast[Ptr[uint8]]("#a02020"))
        hamscene_glyphs(CONTENT_X, 214,
                cast[Ptr[uint8]]("(Tab switches fields.)"),
                cast[Ptr[uint8]]("#606060"))
    elif page == PAGE_RPASS:
        bf0: int32 = 0
        bf1: int32 = 0
        if focus == 0:
            bf0 = 1
        else:
            bf1 = 1
        _draw_input(CONTENT_X, 92, FIELD_W,
                    cast[Ptr[uint8]]("Administrator (hostowner) password:"),
                    &rpass_buf[0], rpass_len, 1, bf0)
        _draw_input(CONTENT_X, 156, FIELD_W,
                    cast[Ptr[uint8]]("Confirm password:"),
                    &rpass2_buf[0], rpass2_len, 1, bf1)
        if rpass_len > 0 and _streq(&rpass_buf[0], &rpass2_buf[0]) == 0:
            hamscene_glyphs(CONTENT_X, 196,
                    cast[Ptr[uint8]]("Passwords do not match."),
                    cast[Ptr[uint8]]("#a02020"))
        hamscene_glyphs(CONTENT_X, 214,
                cast[Ptr[uint8]]("Used by 'newshell hostowner' (uid 1 admin)."),
                cast[Ptr[uint8]]("#606060"))
    elif page == PAGE_DISK:
        hamscene_glyphs(CONTENT_X, 62, cast[Ptr[uint8]]("Target drive:"),
                        cast[Ptr[uint8]]("#202020"))
        if n_disks == 0:
            hamscene_glyphs(CONTENT_X, DLIST_Y + 4,
                    cast[Ptr[uint8]]("No installable target disk detected."),
                    cast[Ptr[uint8]]("#a02020"))
            hamscene_glyphs(CONTENT_X, DLIST_Y + 20,
                    cast[Ptr[uint8]]("Attach a blank disk, then Rescan."),
                    cast[Ptr[uint8]]("#606060"))
            hamscene_fill(RESCAN_X, DLIST_Y + 44, RESCAN_W, RESCAN_H,
                          cast[Ptr[uint8]]("#e6e8ec"))
            hamscene_stroke(RESCAN_X, DLIST_Y + 44, RESCAN_W, RESCAN_H, 1,
                            cast[Ptr[uint8]]("#606060"))
            hamscene_glyphs(RESCAN_X + 14, DLIST_Y + 52,
                            cast[Ptr[uint8]]("Rescan"),
                            cast[Ptr[uint8]]("#202020"))
        else:
            i: uint64 = 0
            while i < n_disks:
                ry: int32 = DLIST_Y + cast[int32](i) * DROW_H
                face: Ptr[uint8] = cast[Ptr[uint8]]("#eceae4")
                tc: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
                if sel_disk == cast[int64](i):
                    face = cast[Ptr[uint8]]("#3584e4")
                    tc = cast[Ptr[uint8]]("#ffffff")
                hamscene_fill(DLIST_X, ry, FIELD_W, DROW_H - 2, face)
                hamscene_stroke(DLIST_X, ry, FIELD_W, DROW_H - 2, 1,
                                cast[Ptr[uint8]]("#a0a0a0"))
                row: Array[64, uint8]
                p: uint64 = 0
                dp: Ptr[uint8] = disk_name_ptr(i)
                k: uint64 = 0
                while dp[k] != 0 and p < 16:
                    row[p] = dp[k]
                    p = p + 1
                    k = k + 1
                while p < 16:
                    row[p] = 32
                    p = p + 1
                _fmt_size(disk_sectors[i], &row[p])
                hamscene_glyphs(DLIST_X + 8, ry + 5, &row[0], tc)
                i = i + 1
            # Guided / manual radios.
            ry2: int32 = _radio_y()
            _draw_radio(CONTENT_X, ry2, 1 - part_mode,
                        cast[Ptr[uint8]]("Guided - use entire disk"))
            _draw_radio(CONTENT_X, ry2 + 22, part_mode,
                        cast[Ptr[uint8]]("Manual - choose ESP size"))
            if part_mode == 1:
                _draw_input(CONTENT_X + 24, ry2 + 62, 120,
                            cast[Ptr[uint8]]("ESP size (MiB, >= 64):"),
                            &espmb_buf[0], espmb_len, 0, 1)
            # Online-repo checkbox.
            oby: int32 = ry2 + 100
            boxf: Ptr[uint8] = cast[Ptr[uint8]]("#ffffff")
            hamscene_fill(CONTENT_X, oby, 14, 14, boxf)
            hamscene_stroke(CONTENT_X, oby, 14, 14, 1,
                            cast[Ptr[uint8]]("#606060"))
            if use_online != 0:
                hamscene_fill(CONTENT_X + 3, oby + 3, 8, 8,
                              cast[Ptr[uint8]]("#3584e4"))
            olbl: Ptr[uint8] = cast[Ptr[uint8]]("Use online repo if available")
            ocol: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
            if net_up == 0:
                olbl = cast[Ptr[uint8]]("Use online repo (no network detected)")
                ocol = cast[Ptr[uint8]]("#808080")
            hamscene_glyphs(CONTENT_X + 22, oby + 3, olbl, ocol)
    elif page == PAGE_SUMMARY:
        if phase == 0:
            _emit_summary_row(84, cast[Ptr[uint8]]("Host name:"), &host_buf[0])
            _emit_summary_row(104, cast[Ptr[uint8]]("Username:"), &user_buf[0])
            _emit_summary_row(124, cast[Ptr[uint8]]("User password:"),
                              _mask(upass_len))
            _emit_summary_row(144, cast[Ptr[uint8]]("Admin password:"),
                              _mask(rpass_len))
            dstr: Ptr[uint8] = cast[Ptr[uint8]]("(none)")
            if sel_disk >= 0:
                dstr = disk_name_ptr(cast[uint64](sel_disk))
            _emit_summary_row(164, cast[Ptr[uint8]]("Target disk:"), dstr)
            mstr: Ptr[uint8] = cast[Ptr[uint8]]("guided (whole disk)")
            if part_mode == 1:
                mstr = cast[Ptr[uint8]]("manual")
            _emit_summary_row(184, cast[Ptr[uint8]]("Partitioning:"), mstr)
            rstr: Ptr[uint8] = cast[Ptr[uint8]]("local (in-RAM)")
            if use_online != 0 and net_up != 0:
                rstr = cast[Ptr[uint8]]("online repo")
            _emit_summary_row(204, cast[Ptr[uint8]]("Packages:"), rstr)
            hamscene_glyphs(CONTENT_X, 240,
                    cast[Ptr[uint8]]("The target disk will be ERASED. Click"),
                    cast[Ptr[uint8]]("#a02020"))
            hamscene_glyphs(CONTENT_X, 254,
                    cast[Ptr[uint8]]("Install to begin."),
                    cast[Ptr[uint8]]("#a02020"))
        else:
            # Progress pane. Reserve a STATUS_BAND strip between the pane and
            # the footer so the phase-2/3 status line ("Install complete ...")
            # renders CLEARLY ABOVE the Back/Next buttons instead of overlapping
            # them. Layout invariant: msg_y + glyph height (~12) < _footer_y().
            py: int32 = 84
            STATUS_BAND: int32 = 20
            ph: int32 = _footer_y() - py - 8 - STATUS_BAND
            hamscene_fill(CONTENT_X, py, FIELD_W, ph,
                          cast[Ptr[uint8]]("#101418"))
            hamscene_stroke(CONTENT_X, py, FIELD_W, ph, 1,
                            cast[Ptr[uint8]]("#404040"))
            avail: int32 = ph - 12 - 22
            vis: uint64 = 1
            if avail > 0:
                vis = cast[uint64](avail / PROG_LINE_H)
            if vis < 1:
                vis = 1
            first: uint64 = 0
            if prog_n > vis:
                first = prog_n - vis
            li: uint64 = first
            row_i: int32 = 0
            while li < prog_n:
                hamscene_glyphs(CONTENT_X + 6, py + 6 + row_i * PROG_LINE_H,
                                prog_line_ptr(li),
                                cast[Ptr[uint8]]("#80d080"))
                row_i = row_i + 1
                li = li + 1
            # Status line: sits inside the reserved STATUS_BAND, comfortably
            # above _footer_y() (py+ph+6 = _footer_y()-STATUS_BAND-2 + 6, i.e.
            # ~16px of clearance to the footer buttons) — no longer overlapping.
            msg_y: int32 = py + ph + 6
            if phase == 2:
                hamscene_glyphs(CONTENT_X, msg_y,
                        cast[Ptr[uint8]]("Install complete - reboot to disk."),
                        cast[Ptr[uint8]]("#207020"))
            if phase == 3:
                hamscene_glyphs(CONTENT_X, msg_y,
                        cast[Ptr[uint8]]("Install FAILED - see log above."),
                        cast[Ptr[uint8]]("#a02020"))

    # --- footer: Back / Next|Install ---
    fy: int32 = _footer_y()
    back_en: int32 = 0
    if page > 0 and phase == 0:
        back_en = 1
    _draw_button(BACK_X, fy, BACK_W, cast[Ptr[uint8]]("Back"), back_en)
    nlbl: Ptr[uint8] = cast[Ptr[uint8]]("Next")
    nx_en: int32 = 0
    if phase == 0 and _page_ready() == 1:
        nx_en = 1
    if page == PAGE_SUMMARY:
        nlbl = cast[Ptr[uint8]]("Install")
        if phase == 1:
            nlbl = cast[Ptr[uint8]]("Installing...")
            nx_en = 0
        if phase == 2 or phase == 3:
            nx_en = 0
    _draw_button(_next_x(), fy, NEXT_W, nlbl, nx_en)

    hamscene_commit(wid)


# ====================================================================
# RUN THE REAL INSTALL (front-end over /bin/install — package-based)
# ====================================================================
ONLINE_REPO_URL: Array[64, uint8]
LOCAL_REPO_URL:  Array[32, uint8]
inst_argv: Array[24, uint64]
inst_disk: Array[32, uint8]
inst_repo: Array[96, uint8]
inst_espmb: Array[8, uint8]
install_pid: int32 = -1
inst_out_fd: int32 = -1
inst_eof: int32 = 0


def _begin_install():
    di: uint64 = cast[uint64](sel_disk)
    dp: Ptr[uint8] = disk_name_ptr(di)
    k: uint64 = 0
    while dp[k] != 0:
        inst_disk[k] = dp[k]
        k = k + 1
    inst_disk[k] = 0

    src: Ptr[uint8] = &LOCAL_REPO_URL[0]
    if use_online != 0 and net_up != 0:
        src = &ONLINE_REPO_URL[0]
    strcpy_ui(&inst_repo[0], src)

    # ESP size: manual uses the typed value (floored at 64 to fit the
    # shipped esp.img); guided always 64.
    espv: uint64 = 64
    if part_mode == 1 and espmb_len > 0:
        v: uint64 = 0
        j: uint64 = 0
        while j < espmb_len:
            v = v * 10 + cast[uint64](espmb_buf[j]) - 48
            j = j + 1
        if v >= 64:
            espv = v
    ei: uint64 = _u64_to_dec(espv, &inst_espmb[0])
    inst_espmb[ei] = 0

    pmode: Ptr[uint8] = cast[Ptr[uint8]]("guided")
    if part_mode == 1:
        pmode = cast[Ptr[uint8]]("manual")

    ai: uint64 = 0
    inst_argv[ai] = cast[uint64](cast[Ptr[uint8]]("/bin/install"))
    ai = ai + 1
    inst_argv[ai] = cast[uint64](cast[Ptr[uint8]]("--auto"))
    ai = ai + 1
    inst_argv[ai] = cast[uint64](&inst_disk[0])
    ai = ai + 1
    inst_argv[ai] = cast[uint64](cast[Ptr[uint8]]("--repo"))
    ai = ai + 1
    inst_argv[ai] = cast[uint64](&inst_repo[0])
    ai = ai + 1
    inst_argv[ai] = cast[uint64](cast[Ptr[uint8]]("--esp-mb"))
    ai = ai + 1
    inst_argv[ai] = cast[uint64](&inst_espmb[0])
    ai = ai + 1
    inst_argv[ai] = cast[uint64](cast[Ptr[uint8]]("--part-mode"))
    ai = ai + 1
    inst_argv[ai] = cast[uint64](pmode)
    ai = ai + 1
    inst_argv[ai] = cast[uint64](cast[Ptr[uint8]]("--hostname"))
    ai = ai + 1
    inst_argv[ai] = cast[uint64](&host_buf[0])
    ai = ai + 1
    inst_argv[ai] = cast[uint64](cast[Ptr[uint8]]("--user"))
    ai = ai + 1
    inst_argv[ai] = cast[uint64](&user_buf[0])
    ai = ai + 1
    inst_argv[ai] = cast[uint64](cast[Ptr[uint8]]("--user-pass"))
    ai = ai + 1
    inst_argv[ai] = cast[uint64](&upass_buf[0])
    ai = ai + 1
    inst_argv[ai] = cast[uint64](cast[Ptr[uint8]]("--root-pass"))
    ai = ai + 1
    inst_argv[ai] = cast[uint64](&rpass_buf[0])
    ai = ai + 1
    inst_argv[ai] = 0

    out_slot: int32 = sys_pipechan()
    if out_slot < 0:
        _prog_push(cast[Ptr[uint8]]("pipechan FAILED"), 15)
        phase = 3
        return
    sys_fdbind(0, INST_OUT_FD, DEVFD_PIPE_R, out_slot)
    inst_out_fd = sys_open(cast[Ptr[char]]("/fd/12"))
    if inst_out_fd < 0:
        _prog_push(cast[Ptr[uint8]]("open pipe read end FAILED"), 25)
        phase = 3
        return
    inst_eof = 0
    pid: int32 = spawn(cast[Ptr[char]]("/bin/install"), &inst_argv[0],
                       SPAWN_STDIO_NS, SPAWN_STDIO_NS, cast[Ptr[uint64]](0))
    install_pid = pid
    prog_n = 0
    if pid < 0:
        _prog_push(cast[Ptr[uint8]]("spawn /bin/install FAILED"), 25)
        phase = 3
        return
    sys_fdbind(pid, 1, DEVFD_PIPE_W, out_slot)
    sys_fdbind(pid, 2, DEVFD_PIPE_W, out_slot)
    phase = 1
    if use_online != 0 and net_up != 0:
        _prog_push(cast[Ptr[uint8]]("installing from ONLINE repo..."), 30)
    else:
        _prog_push(cast[Ptr[uint8]]("installing from local repo..."), 29)


def _line_has(s: Ptr[uint8], n: uint64, needle: Ptr[uint8]) -> int32:
    nl: uint64 = _slen(needle)
    if nl == 0 or nl > n:
        return 0
    i: uint64 = 0
    while i + nl <= n:
        m: uint64 = 0
        while m < nl and s[i + m] == needle[m]:
            m = m + 1
        if m == nl:
            return 1
        i = i + 1
    return 0


def _emit_install_line(s: Ptr[uint8], n: uint64):
    if n == 0:
        return
    _prog_push(s, n)
    if _line_has(s, n, cast[Ptr[uint8]]("install complete")) != 0:
        phase = 2
    if _line_has(s, n, cast[Ptr[uint8]]("FAIL")) != 0:
        phase = 3


logbuf:  Array[4096, uint8]
linebuf: Array[512, uint8]
line_len: uint64 = 0


def _line_carry(c: uint8):
    if c == 10:
        _emit_install_line(&linebuf[0], line_len)
        line_len = 0
        return
    if line_len < 511:
        linebuf[line_len] = c
        line_len = line_len + 1


def _poll_log() -> int32:
    if inst_out_fd < 0 or inst_eof != 0:
        return 0
    changed: int32 = 0
    drained: int32 = 0
    while drained < 16:
        r: int64 = sys_read_nb(inst_out_fd, &logbuf[0], 4096)
        if r == 0:
            break
        if r < 0:
            if line_len > 0:
                _emit_install_line(&linebuf[0], line_len)
                line_len = 0
                changed = 1
            inst_eof = 1
            sys_close(inst_out_fd)
            inst_out_fd = -1
            sys_fdbind(0, INST_OUT_FD, DEVFD_CONS, 0)
            if phase == 1:
                _prog_push(cast[Ptr[uint8]](
                    "installer exited without 'install complete' - see log"), 53)
                phase = 3
            changed = 1
            break
        i: uint64 = 0
        while i < cast[uint64](r):
            _line_carry(logbuf[i])
            i = i + 1
        changed = 1
        drained = drained + 1
    return changed


# ====================================================================
# INPUT
# ====================================================================
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                             # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc = acc * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc = 0 - acc
        vals[v] = acc
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1


def _in_rect(x: int64, y: int64, rx: int32, ry: int32,
             rw: int32, rh: int32) -> int32:
    if x >= cast[int64](rx) and x < cast[int64](rx + rw) \
            and y >= cast[int64](ry) and y < cast[int64](ry + rh):
        return 1
    return 0


def _goto_next():
    if _page_ready() == 0:
        return
    if page == PAGE_SUMMARY:
        _begin_install()
        return
    page = page + 1
    focus = 0
    # Refresh the disk list + net state when we land on the disk page.
    if page == PAGE_DISK:
        _enumerate_disks()
        _probe_net()


def _goto_back():
    if page > 0:
        page = page - 1
        focus = 0


btn_down: int32 = 0
def _handle_click(x: int64, y: int64) -> int32:
    # Footer buttons are live on every page.
    fy: int32 = _footer_y()
    if _in_rect(x, y, BACK_X, fy, BACK_W, FOOTER_H) != 0:
        if page > 0 and phase == 0:
            _goto_back()
            return 1
        return 0
    if _in_rect(x, y, _next_x(), fy, NEXT_W, FOOTER_H) != 0:
        if phase == 0:
            _goto_next()
            return 1
        return 0
    if phase != 0:
        return 0

    # Password-page field focus.
    if page == PAGE_UPASS or page == PAGE_RPASS:
        if _in_rect(x, y, CONTENT_X, 92, FIELD_W, FIELD_H) != 0:
            focus = 0
            return 1
        if _in_rect(x, y, CONTENT_X, 156, FIELD_W, FIELD_H) != 0:
            focus = 1
            return 1
        return 0

    # Disk page widgets.
    if page == PAGE_DISK:
        if n_disks == 0:
            if _in_rect(x, y, RESCAN_X, DLIST_Y + 44, RESCAN_W, RESCAN_H) != 0:
                _enumerate_disks()
                sel_disk = -1
                return 1
            return 0
        i: uint64 = 0
        while i < n_disks:
            ry: int32 = DLIST_Y + cast[int32](i) * DROW_H
            if _in_rect(x, y, DLIST_X, ry, FIELD_W, DROW_H - 2) != 0:
                sel_disk = cast[int64](i)
                return 1
            i = i + 1
        ry2: int32 = _radio_y()
        if _in_rect(x, y, CONTENT_X, ry2, FIELD_W, 16) != 0:
            part_mode = 0
            return 1
        if _in_rect(x, y, CONTENT_X, ry2 + 22, FIELD_W, 16) != 0:
            part_mode = 1
            return 1
        oby: int32 = ry2 + 100
        if _in_rect(x, y, CONTENT_X, oby, FIELD_W, 16) != 0:
            if net_up != 0:
                if use_online != 0:
                    use_online = 0
                else:
                    use_online = 1
                return 1
        return 0
    return 0


def _key_line(s: Ptr[uint8], n: uint64) -> int32:
    if phase != 0:
        return 0
    if n < 1 or s[0] != 100:                             # 'd' press only
        return 0
    i: uint64 = 1
    while i < n and s[i] == 32:
        i = i + 1
    neg: int32 = 0
    if i < n and s[i] == 45:
        neg = 1
        i = i + 1
    code: int32 = 0
    got: int32 = 0
    while i < n and s[i] >= 48 and s[i] <= 57:
        code = code * 10 + cast[int32](s[i]) - 48
        i = i + 1
        got = 1
    if got == 0:
        return 0
    if neg != 0:
        code = 0 - code
    if code < 0 or code > 255:
        return 0
    if code == 10 or code == 13:                          # Enter / Return = Next
        _goto_next()
        return 1
    return _apply_key(cast[uint8](code))


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[haminstallui] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp: Array[64, uint8]
    keysp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        geo: Array[64, uint8]
        gp: uint64 = 0
        pre: Ptr[uint8] = cast[Ptr[uint8]]("geometry 180 70 ")
        a: uint64 = 0
        while pre[a] != 0:
            geo[gp] = pre[a]
            gp = gp + 1
            a = a + 1
        gp = gp + _u64_to_dec(cast[uint64](WIN_W), &geo[gp])
        geo[gp] = 32
        gp = gp + 1
        gp = gp + _u64_to_dec(cast[uint64](WIN_H), &geo[gp])
        geo[gp] = 10
        gp = gp + 1
        sys_write(cfd, &geo[0], gp)
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("title Install Hamnix\n"))
        sys_close(cfd3)
    cfd4: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd4 >= 0:
        _writeall(cfd4, cast[Ptr[uint8]]("z 7\n"))
        sys_close(cfd4)

    strcpy_ui(&ONLINE_REPO_URL[0], cast[Ptr[uint8]]("https://255.one/"))
    strcpy_ui(&LOCAL_REPO_URL[0], cast[Ptr[uint8]]("file:///iso-packages"))

    _seed_defaults()
    _enumerate_disks()
    _probe_net()
    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[haminstallui] scene window ready\n"))

    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))

    evbuf: Array[256, uint8]
    kbuf: Array[256, uint8]
    while True:
        changed: int32 = 0
        if kfd >= 0:
            kr: int64 = sys_read_nb(kfd, &kbuf[0], 255)
            if kr > 0:
                kls: uint64 = 0
                ki: uint64 = 0
                while ki <= cast[uint64](kr):
                    katend: int32 = 0
                    if ki == cast[uint64](kr):
                        katend = 1
                    if katend == 1 or kbuf[ki] == 10:
                        if ki > kls:
                            if _key_line(&kbuf[kls], ki - kls) == 1:
                                changed = 1
                        kls = ki + 1
                    ki = ki + 1
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            # Non-blocking: a blocking /event read would park the whole loop
            # whenever the pointer is idle, freezing _poll_log() so the
            # install progress pane never advances (BUG B: "no progress for
            # 5-9 minutes"). Poll pointer events instead so the log drains
            # and package/partition lines surface as they happen.
            r: int64 = sys_read_nb(efd, &evbuf[0], 255)
            sys_close(efd)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            bx: int64 = 0
                            by: int64 = 0
                            bbtn: int64 = 0
                            if parse_pointer(&evbuf[ls], i - ls, &bx, &by,
                                             &bbtn) == 1:
                                nd: int32 = 0
                                if (bbtn & 1) != 0:
                                    nd = 1
                                if nd == 1 and btn_down == 0:
                                    if _handle_click(bx, by) == 1:
                                        changed = 1
                                btn_down = nd
                        ls = i + 1
                    i = i + 1
        if phase == 1:
            if _poll_log() == 1:
                changed = 1
        if phase == 0 and page == PAGE_DISK:
            net_poll = net_poll + 1
            if net_poll >= 64:
                net_poll = 0
                prev_up: int32 = net_up
                _probe_net()
                if net_up != prev_up:
                    if net_up == 0:
                        use_online = 0
                    changed = 1
        if changed != 0:
            emit_scene(wid)
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 3:
            sys_yield()
    return 0

# user/xargs.ad
#
# Minimal Hamnix `xargs CMD ARGS...` — drains stdin into one buffer,
# tokenizes on whitespace, appends up to 16 tokens to CMD's argv,
# then sys_spawn's CMD once with the combined argv. Output goes to
# our stdout via the spawned child (we inherit fds 0/1 onto it).
#
#   /find /mnt | /xargs /echo
#
# Single-shot only (no -n batching, no -I replace) — the shell pipe
# model already exists for streaming; xargs here is just a CLI
# adapter so commands that don't read stdin natively can consume it.

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_spawn(path: Ptr[char], argv: Ptr[uint64],
                     stdin_fd: int32, stdout_fd: int32) -> int32
extern def sys_waitpid(pid: int32) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


# 4 KiB stdin scratch — enough for a `find /mnt` style dump but small
# enough to keep us on the 16 KiB user stack budget without blowing
# through page tables.
STDIN_CAP: uint64 = 4096
MAX_TOKENS: uint64 = 16
ARGV_CAP: uint64 = 32                       # CMD args + stdin tokens

stdin_buf: Array[4096, uint8]
argv_buf:  Array[32, uint64]


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "xargs: usage: xargs CMD [ARGS...]\n")
        return 1
    # Copy the caller's CMD + extra args (argv[1..]) into our argv_buf.
    out_i: uint64 = 0
    i: int32 = 1
    while i < argc and out_i < ARGV_CAP - 1:
        argv_buf[out_i] = argv[cast[uint64](i)]
        out_i = out_i + 1
        i = i + 1

    # Slurp stdin.
    total: uint64 = 0
    while total < STDIN_CAP:
        n: int64 = sys_read(0, cast[Ptr[uint8]](
            cast[uint64](&stdin_buf[0]) + total), STDIN_CAP - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)

    # Tokenize on whitespace, NUL-terminating each token in place so
    # argv_buf can hold raw pointers into stdin_buf.
    tokens: uint64 = 0
    p: uint64 = 0
    while p < total and tokens < MAX_TOKENS:
        while p < total and (stdin_buf[p] == 32 or stdin_buf[p] == 9 \
                or stdin_buf[p] == 10 or stdin_buf[p] == 13):
            p = p + 1
        if p >= total:
            break
        start: uint64 = p
        while p < total and stdin_buf[p] != 32 and stdin_buf[p] != 9 \
                and stdin_buf[p] != 10 and stdin_buf[p] != 13:
            p = p + 1
        # NUL-terminate this token (overwrites the whitespace OR the
        # last byte we read, but stdin_buf has room because total <
        # STDIN_CAP and we cap reads at STDIN_CAP-1 above? No — we
        # may have filled the buffer. Guard the write.)
        if p < STDIN_CAP:
            stdin_buf[p] = 0
        if out_i >= ARGV_CAP - 1:
            break
        argv_buf[out_i] = cast[uint64](&stdin_buf[start])
        out_i = out_i + 1
        tokens = tokens + 1
        p = p + 1

    argv_buf[out_i] = 0
    cmd: Ptr[char] = cast[Ptr[char]](argv_buf[0])
    pid: int32 = sys_spawn(cmd, &argv_buf[0], 0, 1)
    if pid < 0:
        write_str(2, "xargs: spawn failed\n")
        return 1
    sys_waitpid(pid)
    return 0

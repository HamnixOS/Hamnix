# user/hamlock.ad
#
# hamlock — the DE screen lock, as a SELF-CONTAINED scene client.
#
# WHY A REWRITE
# -------------
# The previous hamlock was a v2-blit client that only RENDERED a curtain
# whose locked/unlocked model was owned by the hamUId compositor daemon
# (published on /dev/wsys/lock, driven by session_lock/session_unlock).
# In the scene-file DE that daemon is retired: at runlevel 5 hamUId does
# the `desktop` flip (hands /dev/fb to the kernel scene compositor) and
# EXITS (user/hamUId.ad main, autoflag==0 path). Nothing ever publishes
# the lock model, so the old hamlock read "0 0 0 0" forever and painted
# nothing — the panel's "Lock Screen" row appeared to do nothing.
#
# This rewrite makes hamlock a standalone, self-sufficient lock like the
# other scene clients (hamsessui, hammonscene): it owns its own window,
# curtain, password field, and — crucially — the unlock DECISION, which
# it makes by authenticating the typed password against /dev/auth (the
# same Plan-9 factotum primitive login/su use). No compositor daemon is
# required. hamsessui's "Lock Screen" row spawns /bin/hamlock and the
# process stays up until the correct password clears it.
#
# WIRE MODEL
# ----------
#   1. sys_bind /dev <- #c (reach /dev/wsys, /dev/fb, /dev/auth).
#   2. newwindow -> wid; set full-screen geometry, chromeless, z 200
#      (above the z-100 panel) so the curtain covers the whole desktop.
#   3. Emit the curtain scene (dark fill + "Screen Locked" + masked field).
#      The first scene commit raises+focuses the window, so keystrokes are
#      routed to our /dev/wsys/<wid>/keys.
#   4. Loop: block on /keys. Printable bytes append to the password buffer
#      (shown masked); Backspace deletes; Enter authenticates via /dev/auth.
#      Escape is ignored (a lock must not be dismissable without a secret).
#   5. On "ok" from /dev/auth we sys_exit(0): the window unmaps and the
#      desktop is revealed. On "denied" we clear the field and show an error.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_getuid() -> uint32
extern def sys_exit(code: int32)

from lib.hamui import hamscene_begin, hamscene_fill, hamscene_glyphs, \
    hamscene_stroke, hamscene_commit
from lib.passwd.passwd import passwd_parse, passwd_lookup_by_uid, \
    passwd_entry_name


# --- tiny helpers (mirrors user/hamsessui.ad) -----------------------
def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# Read the framebuffer "W H PITCH BPP FMT\n" header (mirrors hamdesktop).
def _screen_dims(wp: Ptr[int64], hp: Ptr[int64]):
    wp[0] = 1024
    hp[0] = 768
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/fb"))
    if fd < 0:
        return
    hdr: Array[64, uint8]
    r: int64 = sys_read(fd, &hdr[0], 63)
    sys_close(fd)
    if r <= 0:
        return
    i: uint64 = 0
    w: int64 = 0
    while i < cast[uint64](r) and hdr[i] >= 48 and hdr[i] <= 57:
        w = w * 10 + cast[int64](hdr[i]) - 48
        i = i + 1
    while i < cast[uint64](r) and hdr[i] == 32:
        i = i + 1
    h: int64 = 0
    while i < cast[uint64](r) and hdr[i] >= 48 and hdr[i] <= 57:
        h = h * 10 + cast[int64](hdr[i]) - 48
        i = i + 1
    if w > 0:
        wp[0] = w
    if h > 0:
        hp[0] = h


# --- model ----------------------------------------------------------
SCR_W: int64 = 1024
SCR_H: int64 = 768
PW_CAP: uint64 = 128
pw_buf:   Array[128, uint8]        # typed plaintext (never rendered)
pw_len:   uint64 = 0
mask_buf: Array[136, uint8]        # '*' per typed char, for display
fails:    int32 = 0
user_name: Array[64, uint8]        # session username for /dev/auth
GLYPH_W:  int64 = 8


# Resolve the current session username via sys_getuid + /etc/passwd. Falls
# back to "live" (the default DE user) if the lookup fails.
_pw_file: Array[4096, uint8]
def _resolve_user():
    user_name[0] = 108                                    # 'l'
    user_name[1] = 105                                    # 'i'
    user_name[2] = 118                                    # 'v'
    user_name[3] = 101                                    # 'e'
    user_name[4] = 0
    fd: int32 = sys_open(cast[Ptr[char]]("/etc/passwd"))
    if fd < 0:
        return
    total: uint64 = 0
    while total < 4096:
        n: int64 = sys_read(fd, &_pw_file[total], 4096 - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    if total == 0:
        return
    passwd_parse(&_pw_file[0], total)
    uid: uint32 = sys_getuid()
    idx: int32 = passwd_lookup_by_uid(uid)
    if idx < 0:
        return
    nm: Ptr[uint8] = passwd_entry_name(idx)
    i: uint64 = 0
    while i < 63 and nm[i] != 0:
        user_name[i] = nm[i]
        i = i + 1
    user_name[i] = 0


def _rebuild_mask():
    i: uint64 = 0
    while i < pw_len and i < 128:
        mask_buf[i] = 42                                   # '*'
        i = i + 1
    mask_buf[i] = 0


# --- render ---------------------------------------------------------
def _paint(wid: int32):
    hamscene_begin()
    # Dark full-screen curtain.
    hamscene_fill(0, 0, cast[int32](SCR_W), cast[int32](SCR_H),
                  cast[Ptr[uint8]]("#0e1018"))
    # Centred prompt panel.
    bw: int64 = 360
    bh: int64 = 150
    bx: int64 = SCR_W / 2 - bw / 2
    by: int64 = SCR_H / 2 - bh / 2
    hamscene_fill(cast[int32](bx), cast[int32](by),
                  cast[int32](bw), cast[int32](bh),
                  cast[Ptr[uint8]]("#20242e"))
    hamscene_stroke(cast[int32](bx), cast[int32](by),
                    cast[int32](bw), cast[int32](bh), 1,
                    cast[Ptr[uint8]]("#3a4256"))

    # Title.
    title: Ptr[uint8] = "Screen Locked"
    tw: int64 = cast[int64](_slen(title)) * GLYPH_W
    hamscene_glyphs(cast[int32](SCR_W / 2 - tw / 2),
                    cast[int32](by + 22), title,
                    cast[Ptr[uint8]]("#dce4f5"))

    # "<user>'s password:" prompt.
    plabel: Ptr[uint8] = "Password:"
    hamscene_glyphs(cast[int32](bx + 24), cast[int32](by + 60),
                    plabel, cast[Ptr[uint8]]("#9aa6c0"))

    # Masked password field box + '*' string.
    fx: int64 = bx + 24
    fy: int64 = by + 78
    fw: int64 = bw - 48
    fh: int64 = 26
    hamscene_fill(cast[int32](fx), cast[int32](fy),
                  cast[int32](fw), cast[int32](fh),
                  cast[Ptr[uint8]]("#12151d"))
    hamscene_stroke(cast[int32](fx), cast[int32](fy),
                    cast[int32](fw), cast[int32](fh), 1,
                    cast[Ptr[uint8]]("#4a5468"))
    _rebuild_mask()
    hamscene_glyphs(cast[int32](fx + 6), cast[int32](fy + 9),
                    &mask_buf[0], cast[Ptr[uint8]]("#c8d7f5"))

    # Hint / error line.
    if fails > 0:
        hamscene_glyphs(cast[int32](bx + 24), cast[int32](by + 120),
                        cast[Ptr[uint8]]("Incorrect password - try again"),
                        cast[Ptr[uint8]]("#e07070"))
    else:
        hamscene_glyphs(cast[int32](bx + 24), cast[int32](by + 120),
                        cast[Ptr[uint8]]("Enter your password to unlock"),
                        cast[Ptr[uint8]]("#6b7690"))
    hamscene_commit(wid)


# --- authenticate the typed password via /dev/auth ------------------
# Returns 1 on success ("ok"), 0 on denial / error. Mirrors login/su.
_auth_resp: Array[64, uint8]
_auth_line: Array[256, uint8]

# Write "<prefix><payload>\n" as ONE write. /dev/auth parses each write as
# a single command line (this is how login/su's auth_write_line frames it);
# splitting the line across writes yields malformed commands and denial.
def _auth_write_line(fd: int32, prefix: Ptr[uint8], payload: Ptr[uint8],
                     paylen: uint64):
    p: uint64 = 0
    while prefix[p] != 0 and p + 2 < 256:
        _auth_line[p] = prefix[p]
        p = p + 1
    j: uint64 = 0
    while j < paylen and p + 2 < 256:
        _auth_line[p] = payload[j]
        p = p + 1
        j = j + 1
    _auth_line[p] = 10
    p = p + 1
    sys_write(fd, &_auth_line[0], p)


def _try_unlock() -> int32:
    afd: int32 = sys_open(cast[Ptr[char]]("/dev/auth"))
    if afd < 0:
        return 0
    _auth_write_line(afd, cast[Ptr[uint8]]("user "),
                     &user_name[0], _slen(&user_name[0]))
    _auth_write_line(afd, cast[Ptr[uint8]]("pass "), &pw_buf[0], pw_len)
    rn: int64 = sys_read(afd, &_auth_resp[0], 63)
    sys_close(afd)
    if rn >= 2 and _auth_resp[0] == 111 and _auth_resp[1] == 107:   # "ok"
        return 1
    return 0


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)

    wdim: Array[1, int64]
    hdim: Array[1, int64]
    _screen_dims(&wdim[0], &hdim[0])
    SCR_W = wdim[0]
    SCR_H = hdim[0]
    _resolve_user()

    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(2, cast[Ptr[uint8]]("hamlock: FAIL newwindow\n"))
        return 1

    ctlp:  Array[64, uint8]
    keysp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))

    # Full-screen, chromeless, above the panel (z 100).
    gbuf: Array[64, uint8]
    gp: uint64 = 0
    pre: Ptr[uint8] = "geometry 0 0 "
    kk: uint64 = 0
    while pre[kk] != 0:
        gbuf[gp] = pre[kk]
        gp = gp + 1
        kk = kk + 1
    gp = gp + _u64_to_dec(cast[uint64](SCR_W), &gbuf[gp])
    gbuf[gp] = 32
    gp = gp + 1
    gp = gp + _u64_to_dec(cast[uint64](SCR_H), &gbuf[gp])
    gbuf[gp] = 10
    gp = gp + 1
    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        sys_write(cfd, &gbuf[0], gp)
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 0\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 200\n"))
        sys_close(cfd3)

    _paint(wid)
    # Re-assert z above the panel AFTER the first commit's raise+focus, so
    # the curtain covers the z-100 panel too.
    cfd4: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd4 >= 0:
        _writeall(cfd4, cast[Ptr[uint8]]("z 200\n"))
        sys_close(cfd4)
    _writeall(1, cast[Ptr[uint8]]("HAMLOCK ready\n"))

    # Open /keys ONCE and keep it: reopening can drop queued events. The
    # read blocks until a key arrives (parks off-runqueue).
    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))
    if kfd < 0:
        _writeall(2, cast[Ptr[uint8]]("hamlock: cannot open keys\n"))
        return 1
    kbuf: Array[256, uint8]
    while True:
        r: int64 = sys_read(kfd, &kbuf[0], 255)
        if r <= 0:
            s2: uint64 = sys_get_jiffies()
            while sys_get_jiffies() - s2 < 2:
                sys_yield()
            continue
        changed: int32 = 0
        i: uint64 = 0
        while i < cast[uint64](r):
            # Lines look like "d <code>" (press) / "u <code>" (release).
            if kbuf[i] == 100:                             # 'd' press
                kj: uint64 = i + 1
                while kj < cast[uint64](r) and kbuf[kj] == 32:
                    kj = kj + 1
                code: int32 = 0
                got: int32 = 0
                while kj < cast[uint64](r) and kbuf[kj] >= 48 \
                      and kbuf[kj] <= 57:
                    code = code * 10 + cast[int32](kbuf[kj]) - 48
                    kj = kj + 1
                    got = 1
                if got != 0:
                    if code == 10 or code == 13:           # Enter
                        au: int32 = _try_unlock()
                        if au != 0:
                            # Unlock: close OUR window via the per-window /ctl
                            # `close` verb. The kernel frees the wid and
                            # recomposites the vacated full-screen footprint,
                            # repainting the desktop/panel/apps beneath the
                            # curtain. Then exit.
                            xfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
                            if xfd >= 0:
                                _writeall(xfd, cast[Ptr[uint8]]("close\n"))
                                sys_close(xfd)
                            sys_exit(0)
                        fails = fails + 1
                        pw_len = 0
                        changed = 1
                    elif code == 8 or code == 127:         # Backspace
                        if pw_len > 0:
                            pw_len = pw_len - 1
                            changed = 1
                    elif code == 27:                       # Esc: ignored
                        changed = 0
                    elif code >= 32 and code < 127:        # printable
                        if pw_len < PW_CAP - 1:
                            pw_buf[pw_len] = cast[uint8](code)
                            pw_len = pw_len + 1
                            changed = 1
                # advance past this line
                i = kj
            else:
                i = i + 1
        if changed != 0:
            _paint(wid)
    return 0

# user/hamlock.ad
#
# hamlock — DE pivot wave 5: the full-screen screen-lock overlay extracted
# out of user/hamUId.ad's daemon_pixel cascade into a standalone hamui v2
# client (matches the wave-1 hampanel, wave-2 hamappmenu, wave-3 hamcycler,
# and wave-4 hamcalpop/hamrun pattern).
#
# Wire model
# ----------
# 1. The compositor publishes the lock model (locked flag + consecutive-
#    fails counter) via the `lock <locked> <fails>` verb on /dev/wsys/ctl.
#    The snapshot is served at /dev/wsys/lock as one line:
#       "<show_serial> <locked> <fails> <gen>\n"
# 2. The compositor spawns /bin/hamlock once at startup. Whenever the
#    lock state mutates (session_lock / session_unlock / a verify drain)
#    it republishes the model and bumps the show serial by writing to
#    /dev/wsys/lock/show.
# 3. We open OUR /dev/wsys/<wid>/wctl, write "version 2\n" to opt into
#    the rio v2 blit protocol, then rasterise the centred lock chrome
#    (dark curtain + "Screen Locked" title + masked password field +
#    feedback line) directly into our backbuffer via lib/hamui's
#    hamui_v2_* family. The compositor blits our backbuffer to /dev/fb
#    each frame.
# 4. While `locked` is 0 we leave the backbuffer cleared-to-transparent
#    so the overlay is "off" (the kernel-side present is a no-op on an
#    unchanged buffer). When `locked` flips to 1 we paint the curtain.
#
# Why password verification still lives in the compositor
# -------------------------------------------------------
# Like the cycler/run waves, only the RENDER moved out. The unlock secret
# (lock_pw_secret in hamUId) and the lock_pw_try() decision both stay in
# the compositor: posting an attempted password to /dev/wsys/lock/verify
# enqueues a serial-bumped record that hamUId drains on the next frame
# and feeds into lock_pw_try(). On match the compositor clears LOCKED
# and republishes; on mismatch it bumps LOCK_FAILS and republishes.
#
# WHAT THIS REPLACES
# ------------------
# The ~25-line per-pixel "Screen Locked / Click to unlock" overlay inside
# daemon_pixel in user/hamUId.ad. That code is gone; this file is its
# replacement.

from lib.hamui import (
    hamui_init, hamui_window_on, hamui_set_protocol_v2,
    hamui_v2_clear, hamui_v2_clear_transparent, hamui_v2_fill_rect, hamui_v2_commit_rect,
    hamui_v2_is_active,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield()
extern def sys_exit(code: int32)


# --- model storage --------------------------------------------------
_hl_locked: int32 = 0
_hl_fails:  int32 = 0
_hl_gen:    uint64 = 0
_hl_show_serial:      uint64 = 0
_hl_last_show_serial: uint64 = 0xffffffffffffffff
_hl_last_gen:         uint64 = 0xffffffffffffffff


# --- layout (window-local pixels, v2 backbuffer cap) ----------------
# Mirrors the legacy full-screen lock overlay. The window itself is the
# lock surface — no surrounding desktop dim (the curtain IS the dim).
_hl_WIN_W: int32 = 640
_hl_WIN_H: int32 = 480
_hl_PAD:   int32 = 14
_hl_GLYPH_H: int32 = 6
_hl_GLYPH_W: int32 = 7


# --- scratch --------------------------------------------------------
_hl_snap_buf: Array[256, uint8]


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


# --- snapshot parser ------------------------------------------------
def _read_lock_snapshot() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/lock"))
    if fd < 0:
        return -1
    n: int64 = sys_read(fd, &_hl_snap_buf[0], 256)
    sys_close(fd)
    return n


def _parse_u64(pos: Ptr[uint64], end: uint64) -> uint64:
    p: uint64 = pos[0]
    v: uint64 = 0
    while p < end and _hl_snap_buf[p] >= 48 and _hl_snap_buf[p] <= 57:
        v = v * 10 + cast[uint64](_hl_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    return v


def _skip_ws(pos: uint64, end: uint64) -> uint64:
    p: uint64 = pos
    while p < end and (_hl_snap_buf[p] == 32 or _hl_snap_buf[p] == 9):
        p = p + 1
    return p


def _parse_snapshot(n: uint64) -> int32:
    # Returns 1 if anything CHANGED since the last parse (gen or
    # show_serial differ), 0 otherwise.
    if n == 0:
        return 0
    pos: Array[1, uint64]
    pos[0] = 0
    show_v:  uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    locked_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    fails_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    gen_v:   uint64 = _parse_u64(&pos[0], n)
    _hl_show_serial = show_v
    _hl_locked = cast[int32](locked_v)
    _hl_fails = cast[int32](fails_v)
    _hl_gen = gen_v
    changed: int32 = 0
    if _hl_show_serial != _hl_last_show_serial:
        changed = 1
    if _hl_gen != _hl_last_gen:
        changed = 1
    _hl_last_show_serial = _hl_show_serial
    _hl_last_gen = _hl_gen
    return changed


# --- crude glyph-block rendering ------------------------------------
# Mirrors hamcycler/hamappmenu/hamrun's _draw_text_blocks — one 4x6 block
# per non-space char. Glyph fidelity will come later from str_ink-on-v2.
def _draw_text_blocks(x: int32, y: int32, label: Ptr[uint8], len: uint64,
                      r: uint8, g: uint8, b: uint8, max_w: int32):
    i: uint64 = 0
    cx: int32 = x
    while i < len and cx + 4 <= x + max_w:
        c: uint8 = label[i]
        if c != 32:
            hamui_v2_fill_rect(cx, y, 4, _hl_GLYPH_H, r, g, b)
        cx = cx + _hl_GLYPH_W - 1
        i = i + 1


def _paint_closed():
    # Lock hidden: keep transparent clear. The compositor's APP_TERM cursor
    # block for this slot is at body origin (0,0..15), which lies under the
    # panel band (rows 0..PANEL_H-1), so no stray dot leaks onto the
    # desktop. We MUST NOT opaque-clear: hamlock spawns at (0,0,scr_w,scr_h)
    # full-screen and the v2 alpha-aware blit would race with the panel
    # (also a v2 client at z above us) and overpaint the Apps/taskbar
    # buttons in the top band.
    hamui_v2_clear_transparent()
    hamui_v2_commit_rect(0, 0, _hl_WIN_W, _hl_WIN_H)


def _paint_open():
    # Dark curtain — matches the legacy 14/16/24 lock-overlay body.
    hamui_v2_clear(14, 16, 24)

    # Centred "Screen Locked" banner (legacy 220/228/245 ink).
    title: Ptr[uint8] = "Screen Locked"
    tw: int32 = cast[int32](_strlen(title)) * (_hl_GLYPH_W - 1)
    tx: int32 = _hl_WIN_W / 2 - tw / 2
    ty: int32 = _hl_WIN_H / 2 - _hl_GLYPH_H * 4
    _draw_text_blocks(tx, ty, title, _strlen(title),
                      220, 228, 245, _hl_WIN_W)

    # Hint line just below.
    hint: Ptr[uint8] = "Click to unlock"
    hw: int32 = cast[int32](_strlen(hint)) * (_hl_GLYPH_W - 1)
    hx: int32 = _hl_WIN_W / 2 - hw / 2
    hy: int32 = _hl_WIN_H / 2 + _hl_GLYPH_H
    _draw_text_blocks(hx, hy, hint, _strlen(hint),
                      140, 150, 170, _hl_WIN_W)

    # Failed-attempt feedback line (only when fails > 0). The legacy
    # daemon_pixel render didn't show this; the v2 client surfaces the
    # `fails` counter so the user knows their last password attempt was
    # rejected (the actual verify still happens in the compositor).
    if _hl_fails > 0:
        warn: Ptr[uint8] = "Wrong password"
        ww: int32 = cast[int32](_strlen(warn)) * (_hl_GLYPH_W - 1)
        wx: int32 = _hl_WIN_W / 2 - ww / 2
        wy: int32 = _hl_WIN_H / 2 + _hl_GLYPH_H * 4
        _draw_text_blocks(wx, wy, warn, _strlen(warn),
                          220, 110, 110, _hl_WIN_W)

    hamui_v2_commit_rect(0, 0, _hl_WIN_W, _hl_WIN_H)


def _paint():
    if _hl_locked != 0:
        _paint_open()
    else:
        _paint_closed()


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()
    # Self-discover OUR wid via /dev/wsys/self (same shape hamrun uses).
    # argv[1] may override for tests.
    wid: int32 = 1
    self_path: Ptr[uint8] = "/dev/wsys/self"
    sfd: int32 = sys_open(cast[Ptr[char]](self_path))
    if sfd >= 0:
        sbuf: Array[16, uint8]
        sn: int64 = sys_read_nb(sfd, &sbuf[0], 16)
        sys_close(sfd)
        if sn > 0:
            v: int32 = 0
            i: uint64 = 0
            while i < cast[uint64](sn) and sbuf[i] >= 48 and sbuf[i] <= 57:
                v = v * 10 + cast[int32](sbuf[i]) - 48
                i = i + 1
            if v >= 2:
                wid = v
    if argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        v2: int32 = 0
        i2: uint64 = 0
        while ap[i2] >= 48 and ap[i2] <= 57:
            v2 = v2 * 10 + cast[int32](ap[i2]) - 48
            i2 = i2 + 1
        if v2 >= 1:
            wid = v2

    bound: int32 = hamui_window_on(0, wid)
    if bound < 0:
        _puts(2, "hamlock: could not bind window\n")
        return 1
    if hamui_set_protocol_v2() < 0:
        _puts(2, "hamlock: v2 negotiate failed\n")
        return 1

    # Initial paint from whatever the compositor has already published.
    n0: int64 = _read_lock_snapshot()
    if n0 > 0:
        _parse_snapshot(cast[uint64](n0))
    _paint()
    rdy: Ptr[uint8] = "HAMLOCK ready\n"
    sys_write(1, rdy, _strlen(rdy))

    # Long-lived event loop: poll the snapshot. On a gen or show_serial
    # bump repaint. The compositor pokes /dev/wsys/lock/show whenever the
    # lock state changes (no socket: we just resample the snapshot).
    while True:
        n: int64 = _read_lock_snapshot()
        if n > 0:
            if _parse_snapshot(cast[uint64](n)) != 0:
                _paint()
        sys_yield()

    return 0
